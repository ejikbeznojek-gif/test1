	<restrictionTemplate>
		<name>ОграничениеЧтенияДокументовПоУровню</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица        
ГДЕ НЕ &amp;КонтрольДатыВидимости или (ТекущаяТаблица.#Параметр(1).УровеньДоступа=0 И ТекущаяТаблица.Дата&gt;=&amp;ДатаЗапретаВидимости)</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ОграничениеЧтенияПоУровню</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица       
ГДЕ (НЕ &amp;КонтрольДатыВидимости или ТекущаяТаблица.#Параметр(1).УровеньДоступа=0) И (IsNull(ТекущаяТаблица.#Параметр(1).УровеньДоступа,0)&lt;= &amp;УровеньДоступа)</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ОсновноеОграничениеЧтения</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица        
ГДЕ (ТекущаяТаблица.#Параметр(1)=ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка) или
            ТекущаяТаблица.#Параметр(1) В (&amp;ДоступныеПодразделения))</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ЧтениеДокументов</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица        
ГДЕ (НЕ &amp;КонтрольДатыВидимости или
            ТекущаяТаблица.#Параметр(1) &gt;=&amp;ДатаЗапретаВидимости)</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ЧтениеДокументовОстатки</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица        
ГДЕ (НЕ &amp;КонтрольДатыВидимости или
            ТекущаяТаблица.ВводОстатков)</condition>
	</restrictionTemplate>
</Rights>
