Функция getPriceSNL(Spisok)
	СтруктураЗапроса = Десериализовать(Spisok);
	Дата2 = СтруктураЗапроса.Дата2;
	ТипЦен = СтруктураЗапроса.ТипЦен;
	СписокКодовНоменклатуры = СтруктураЗапроса.СписокКодовНоменклатуры;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Код КАК КодНоменклатуры,
		|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК Период
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
		|			ТипЦен.Код = &ТипЦен
		|				И Прайс.Проведен
		|				И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2
		|				И Прайс.Дата <= &Дата2
		|				И Номенклатура.Код В (&СписокКодовНоменклатуры)) КАК ЦеныНоменклатурыСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|			МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Прайс.Дата) КАК Дата
		|		ИЗ
		|			РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|					КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
		|					ТипЦен.Код = &ТипЦен
		|						И Прайс.Проведен
		|						И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2
		|						И Прайс.Дата <= &Дата2
		|						И Номенклатура.Код В (&СписокКодовНоменклатуры)) КАК ЦеныНоменклатурыСрезПоследних
		|		ГДЕ
		|			ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ЦеныНоменклатурыСрезПоследних.Номенклатура) КАК Даты
		|		ПО ЦеныНоменклатурыСрезПоследних.Прайс.Дата = Даты.Дата
		|			И ЦеныНоменклатурыСрезПоследних.Номенклатура = Даты.Номенклатура
		|ГДЕ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
	
	Запрос.УстановитьПараметр("Дата2", Дата2);
	Запрос.УстановитьПараметр("СписокКодовНоменклатуры", СписокКодовНоменклатуры);
	Запрос.УстановитьПараметр("ТипЦен", ТипЦен);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(РезультатЗапроса), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

