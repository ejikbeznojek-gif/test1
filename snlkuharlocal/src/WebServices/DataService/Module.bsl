	|	И Номенклатура.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("СписокКодовSNL", СписокКодовSNL);
	
	Тз = Запрос.Выполнить().Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.Наименование КАК Наименование,
	|	Номенклатура.Код КАК Код,
	|	Номенклатура.Родитель.Код КАК КодРодителя,
	|	Номенклатура.Размер.Наименование КАК Размер,
	|	Номенклатура.Цвет.Наименование КАК Цвет
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Родитель.Код В(&СписокКодовSNL)
	|	И НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("СписокКодовSNL", СписокКодовSNL);
	
	ТЗЦветовИРазмеров = Запрос.Выполнить().Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
