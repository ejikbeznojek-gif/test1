		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "readingjson_error";
		стрРезультат.ErrorDescription = "Error during reading json string";
		Возврат стрРезультат;
	КонецПопытки;
	Попытка
		
		Запрос = Новый Запрос;
		НомерЛиста=СокрЛП(Сода["LNum"]);
		
		Если ЗначениеЗаполнено(НомерЛиста) Тогда
			
			Запрос.Текст = "ВЫБРАТЬ
			|	ЛистЗагрузки.ДатаОтгрузки КАК ДатаОтгрузки,
			|	ЛистЗагрузки.Водитель.Наименование КАК Водит,
			|	ЛистЗагрузки.Автомобиль.Наименование КАК Автом
			|ИЗ
			|	Документ.ЛистЗагрузки КАК ЛистЗагрузки
			|ГДЕ
			|	ЛистЗагрузки.Номер = &НомерЛиста";
			Запрос.УстановитьПараметр("НомерЛиста", НомерЛиста);
		Иначе
			стрРезультат.Error = "Num_is_not_filled_error";
			стрРезультат.ErrorDescription = "Inv Num is empty";
			Возврат стрРезультат;
			
		КонецЕсли;
		ВС = Новый Структура;
		ДатаОт="";
		Автом="";
		Водит="";
		Выб = Запрос.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			ДатаОт=Формат(Выб.ДатаОтгрузки,"ДФ=dd.MM.yyyy");
			Автом=СокрЛП(Выб.Автом);
			Водит=СокрЛП(Выб.Водит);
		КонецЕсли;
		ВС.Вставить("ShipD",ДатаОт);
		ВС.Вставить("Avtom",Автом);
		ВС.Вставить("Driver",Водит);
		стрРезультат.RS = ВС;
	Исключение
		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "procdata_error";
		стрРезультат.ErrorDescription = "Error during data processsing: " + ОписаниеОшибки();
		Возврат стрРезультат;
	КонецПопытки;
	
	Возврат стрРезультат;
КонецФункции

