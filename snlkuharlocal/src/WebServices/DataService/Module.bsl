Функция GetInfo(DataType, DataName, Param)
	
	если Param="ОбщаяЗагрузкаСправочников" тогда
		ТЗСправочников=новый ТаблицаЗначений;
		ТЗСправочников.Колонки.Добавить("ИмяСправочника");		
		СтрТЗ=ТЗСправочников.Добавить();
		СтрТЗ.ИмяСправочника="Номенклатура";
		СтрТЗ=ТЗСправочников.Добавить();
		СтрТЗ.ИмяСправочника="ШтрихКоды";
		СтруктураОбмена=РаботаСWS.ПолучитьСтруктуруСправочниковДляWS(ТЗСправочников);		
	ИначеЕсли Param="ЗагрузкаПланаНабора" тогда 
		СтруктураОбмена=РаботаСWS.ПолучитьСтруктуруПлановНабора();	
		// Кухарь А.Ю.  28.07.2022 начало
		//
	ИначеЕсли Param="СверкаТабеляИзЗУП" тогда 
		КодПодразделения="SSP-0211";
		Дата=Дата(DataName);
		СтруктураОбмена= РаботаСWS.ПолучитьДанныеТабеля(КодПодразделения,Дата);	
		// Кухарь А.Ю.  28.07.2022 конец
		// Кухарь А.Ю.  06.07.2023 начало
	ИначеЕсли Param="ПолучитьДанныеПапокНоменклатурыВерхнегоУровня" тогда
		СтруктураОбмена= РаботаСWS.ПолучитьДанныеПоПапкамВерхнегоУровня();	
		
	ИначеЕсли  Param="ПолучитьДанныеКаналовСбыта" тогда
		СтруктураОбмена= РаботаСWS.ПолучитьДанныеПоКаналамСбыта();	
		// Кухарь А.Ю.  06.07.2023 конец
	КонецЕсли;
	
	
	
	записьJSON = новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(записьJSON,СтруктураОбмена);
	СтрJSON = ЗаписьJSON.Закрыть();	
	Возврат СтрJSON;
КонецФункции

Функция GetInvList(NumList)
	// Вставить содержимое обработчика.
	стрРезультат = ВернутьСтруктуруРезультатОбм(NumList);
	джЗапись = Новый ЗаписьJSON;
	джЗапись.УстановитьСтроку();
	ЗаписатьJSON(джЗапись, стрРезультат);
	Возврат джЗапись.Закрыть();
КонецФункции

Функция ВернутьСтруктуруРезультатОбм(jsonstr)
	стрРезультат = Новый Структура("RS, Error, ErrorDescription", "", "", "");
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(jsonstr);
		//ЧтениеJSON.ОткрытьФайл(ИмяФайла);
		Сода = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "readingjson_error";
		стрРезультат.ErrorDescription = "Error during reading json string";
		Возврат стрРезультат;
	КонецПопытки;
	Попытка
		
		Запрос = Новый Запрос;
		НомерЛиста=СокрЛП(Сода["LNum"]);
		
		Если ЗначениеЗаполнено(НомерЛиста) Тогда
			
			Запрос.Текст = "ВЫБРАТЬ
			//ЛистЗагрузкиЗаявка.НомерНакладной КАК НомерНакладной,
			|ЛистЗагрузкиЛистыНабора.ДатаНакладной КАК ДатаНакладной,
			|ЛистЗагрузкиЛистыНабора.НомерНакладной КАК НомерНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.Номер КАК Номер,
			|ЛистЗагрузкиЗаявка.Ссылка.СостояниеНакладной КАК СостояниеНакладной
			|ИЗ
			|Документ.ЛистЗагрузки.Заявка КАК ЛистЗагрузкиЗаявка
			|СОЕДИНЕНИЕ Документ.ЛистЗагрузки.ЛистыНабора КАК ЛистЗагрузкиЛистыНабора
			|ПО ЛистЗагрузкиЗаявка.Ссылка = ЛистЗагрузкиЛистыНабора.Ссылка
			|И ЛистЗагрузкиЗаявка.Получатель = ЛистЗагрузкиЛистыНабора.Получатель
			|И ЛистЗагрузкиЗаявка.ПунктДоставки = ЛистЗагрузкиЛистыНабора.ПунктДоставки
			|И ЛистЗагрузкиЗаявка.НомерНакладной = ЛистЗагрузкиЛистыНабора.НомерНакладной
			|ГДЕ
			|ЛистЗагрузкиЗаявка.Ссылка.Номер=&НомерЛиста
			//ЛистЗагрузкиЗаявка.Получатель = &Получатель
			//И ЛистЗагрузкиЗаявка.ПунктДоставки = &ПунктДоставки
			//И ЛистЗагрузкиЗаявка.Ссылка.ДатаОтгрузки >= &ДатаОтгрузки
			
			|СГРУППИРОВАТЬ ПО
			//ЛистЗагрузкиЗаявка.НомерНакладной,
			|ЛистЗагрузкиЛистыНабора.ДатаНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.Номер,
			|ЛистЗагрузкиЛистыНабора.НомерНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.СостояниеНакладной
			|";
			Запрос.УстановитьПараметр("НомерЛиста", НомерЛиста);
		Иначе
			ДатаОт=ПолучитьДатуИзСтр(СокрЛП(Сода["SHDate"]));
			КодКонтра=СокрЛП(Сода["Rec"]);
			Запрос.Текст = "ВЫБРАТЬ
			//ЛистЗагрузкиЗаявка.НомерНакладной КАК НомерНакладной,
			|ЛистЗагрузкиЛистыНабора.ДатаНакладной КАК ДатаНакладной,
			|ЛистЗагрузкиЛистыНабора.НомерНакладной КАК НомерНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.Номер КАК Номер,
			|ЛистЗагрузкиЗаявка.Ссылка.СостояниеНакладной КАК СостояниеНакладной
			|ИЗ
			|Документ.ЛистЗагрузки.Заявка КАК ЛистЗагрузкиЗаявка
			|СОЕДИНЕНИЕ Документ.ЛистЗагрузки.ЛистыНабора КАК ЛистЗагрузкиЛистыНабора
			|ПО ЛистЗагрузкиЗаявка.Ссылка = ЛистЗагрузкиЛистыНабора.Ссылка
			|И ЛистЗагрузкиЗаявка.Получатель = ЛистЗагрузкиЛистыНабора.Получатель
			|И ЛистЗагрузкиЗаявка.ПунктДоставки = ЛистЗагрузкиЛистыНабора.ПунктДоставки
			|И ЛистЗагрузкиЗаявка.НомерНакладной = ЛистЗагрузкиЛистыНабора.НомерНакладной
			|ГДЕ
			//|ЛистЗагрузкиЗаявка.Ссылка.Номер=&НомерЛиста
			|ЛистЗагрузкиЗаявка.Получатель = &Получатель
			//И ЛистЗагрузкиЗаявка.ПунктДоставки = &ПунктДоставки
			|И ЛистЗагрузкиЗаявка.Ссылка.ДатаОтгрузки >= &ДатаОтгрузки1
			|И ЛистЗагрузкиЗаявка.Ссылка.ДатаОтгрузки <= &ДатаОтгрузки2
			|СГРУППИРОВАТЬ ПО
			//ЛистЗагрузкиЗаявка.НомерНакладной,
			|ЛистЗагрузкиЛистыНабора.ДатаНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.Номер,
			|ЛистЗагрузкиЛистыНабора.НомерНакладной,
			|ЛистЗагрузкиЗаявка.Ссылка.СостояниеНакладной
			|";
			Запрос.УстановитьПараметр("Получатель", Справочники.Контрагенты.НайтиПоКоду(КодКонтра));
			Запрос.УстановитьПараметр("ДатаОтгрузки1", НачалоДня(ДатаОт));
			Запрос.УстановитьПараметр("ДатаОтгрузки2", КонецДня(ДатаОт));
		КонецЕсли;
		МасЭл = Новый Массив;
		
		Выб = Запрос.Выполнить().Выбрать();
		Пока Выб.Следующий() Цикл
			МасЭл.Добавить(Новый Структура("InvNum", СокрЛП(Выб.НомерНакладной)));
		КонецЦикла;
		стрРезультат.RS = МасЭл;
	Исключение
		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "procdata_error";
		стрРезультат.ErrorDescription = "Error during data processsing: " + ОписаниеОшибки();
		Возврат стрРезультат;
	КонецПопытки;
	
	Возврат стрРезультат;
КонецФункции

Функция ПолучитьДатуИзСтр(СтрДата) Экспорт
	Рез=неопределено;
	
	Попытка
		СтрДата=СокрЛП(СтрДата);
		СтрРез="";
		РаздТ=Найти(СтрДата,".");
		РаздТр=Найти(СтрДата,"-");
		РаздЗ=Найти(СтрДата,",");
		РаздСП=Найти(СтрДата,"/");
		РаздСО=Найти(СтрДата,"\");
		РаздДТ=Найти(СтрДата,":");
		Если (РаздТ>0) И (РаздТр>0) Тогда
			Если (РаздТ>РаздТр) Тогда
				РаздТ=0;
			КонецЕсли;	
		КонецЕсли;	
		
		Если РаздТ>0 ИЛИ РаздЗ>0  ИЛИ РаздСП>0 ИЛИ РаздСО>0 Тогда
			//Если РаздСО>0 Тогда
			//ИначеЕсли РаздСП>0 Тогда
			//ИначеЕсли РаздСЗ>0 Тогда
			//Иначе
			//предположим германский с разными разделителями
			Если Сред(СтрДата,3,1)="." Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						СтрЧМ=СокрЛП(Сред(СтрДата,11));
						СтрЧМ=СтрЗаменить(СтрЧМ,":","");
						СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ)=5 Тогда
							СтрЧМ="0"+СтрЧМ;
						КонецЕсли;	
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ=Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ="000000") Тогда
							СтрРез=СтрРез+СтрЧМ;
						КонецЕсли;
						Рез=Дата(СтрРез);
					Иначе	
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						Рез=Дата(СтрРез);
					КонецЕсли;	
				Исключение
				КонецПопытки;	
			КонецЕсли;	
			//КонецЕсли;	
		ИначеЕсли РаздТр>0 Тогда
			
			Если Сред(СтрДата,3,1)="-" Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						СтрЧМ=СокрЛП(Сред(СтрДата,11));
						
						СтрЧМ=СтрЗаменить(СтрЧМ,":","");
						СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ)=5 Тогда
							СтрЧМ="0"+СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ=Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ="000000") Тогда
							СтрРез=СтрРез+СтрЧМ;
						КонецЕсли;
						Рез=Дата(СтрРез);
					Иначе	
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						Рез=Дата(СтрРез);
					КонецЕсли;	
				Исключение
				КонецПопытки;	
			Иначе
				
				СтрЧМ=СокрЛП(Сред(СтрДата,11));
				СтрРез=СтрЗаменить(СокрЛП(Лев(СтрДата,10)),"-","");
				СтрЧМ=СтрЗаменить(СтрЧМ,":","");
				СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
				Если СтрДлина(СтрЧМ)=5 Тогда
					СтрЧМ="0"+СтрЧМ;
				КонецЕсли;	
				Если СтрДлина(СтрЧМ)>6 Тогда
					СтрЧМ=Лев(СтрЧМ,6);
				КонецЕсли;
				Если НЕ(СтрЧМ="000000") Тогда
					СтрРез=СтрРез+СтрЧМ;
				КонецЕсли;
				Рез=Дата(СтрРез);
			КонецЕсли;
			
			
			
		Иначе
			//анси формат
			Если СтрДлина(СтрДата)>=8 Тогда
				Рез=Дата(Лев(СтрДата,8));
			КонецЕсли;	
		КонецЕсли;	
	Исключение
	КонецПопытки;
	Возврат Рез;
КонецФункции

Функция GetColList(ItemsList)
	стрРезультат = ВернутьСтруктуруРезультатОбм1(ItemsList);
	джЗапись = Новый ЗаписьJSON;
	джЗапись.УстановитьСтроку();
	ЗаписатьJSON(джЗапись, стрРезультат);
	Возврат джЗапись.Закрыть();
	
КонецФункции

Функция ВернутьСтруктуруРезультатОбм1(jsonstr)
	стрРезультат = Новый Структура("RS, Error, ErrorDescription", "", "", "");
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(jsonstr);
		//ЧтениеJSON.ОткрытьФайл(ИмяФайла);
		Сода = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "readingjson_error";
		стрРезультат.ErrorDescription = "Error during reading json string";
		ЗаписатьВЛог("ВебСервис","Error during reading json string: " + ОписаниеОшибки(),"Информация");
		Возврат стрРезультат;
	КонецПопытки;
	Попытка
		МасКод=Новый Массив;
		МасК=Сода["CodeItems"];
		Для Каждого ТЭ Из МасК Цикл
			МасКод.Добавить(ТЭ);
		КонецЦикла;
		ДУ=?(МасКод.Количество()," И Номенклатура.Родитель.Код В (&МасКод) ","");
		Запрос = Новый Запрос;
		
		// ЗапросV8 = V8.NewObject("Запрос");
		//++Данилова Е.В. 15.10.2025 HELP-6674
		//Запрос.Текст=
		//"ВЫБРАТЬ РАЗЛИЧНЫЕ
		//|Номенклатура.Родитель.Код КАК РодКод,
		//|Номенклатура.Цвет КАК Цвет
		//|ИЗ
		//|Справочник.Номенклатура КАК Номенклатура
		//|ГДЕ
		//|НЕ Номенклатура.ЭтоГруппа
		//|"+ДУ+"
		////|И Номенклатура.Родитель.Код В (&МасКод)
		//|упорядочить по 1
		//|";
		// 	
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура.Цвет КАК Цвет,
		|	Номенклатура.Родитель КАК Родитель,
		|	Номенклатура.СнятСПроизводства КАК СнятСПроизводства
		|ПОМЕСТИТЬ ВтТаблицаРазмеров
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.СнятСПроизводства
		|	"+ДУ+"
		|	И НЕ Номенклатура.ЭтоГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура.Родитель.Код КАК РодКод,
		|	Номенклатура.Цвет КАК Цвет,
		|	ЕСТЬNULL(ВтТаблицаРазмеров.СнятСПроизводства, ИСТИНА) КАК СнятСПроизводства
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВтТаблицаРазмеров КАК ВтТаблицаРазмеров
		|		ПО Номенклатура.Родитель = ВтТаблицаРазмеров.Родитель
		|			И Номенклатура.Цвет = ВтТаблицаРазмеров.Цвет
		|ГДЕ
		|	НЕ Номенклатура.ЭтоГруппа
		|	"+ДУ+"
		|
		|УПОРЯДОЧИТЬ ПО
		|	РодКод"; 	
		
		//--Данилова Е.В. 15.10.2025
		
		Если МасКод.Количество() Тогда
			Запрос.УстановитьПараметр("МасКод", МасКод);
		КонецЕсли;
		Выб=Запрос.Выполнить().Выбрать();
		МасЭл = Новый Массив;
		Пока Выб.Следующий() Цикл
			//++Данилова Е.В. 15.10.2025 HELP-6674
			//МасЭл.Добавить(Новый Структура("CodeItem,Color", СокрЛП(Выб.РодКод),СокрЛП(Выб.Цвет)));
			МасЭл.Добавить(Новый Структура("CodeItem,Color,removed", СокрЛП(Выб.РодКод),СокрЛП(Выб.Цвет),XMLСтрока(Выб.СнятСПроизводства)));
			//--Данилова Е.В. 15.10.2025
		КонецЦикла;	
		ЗаписатьВЛог("ВебСервис","ВР "+Строка(МасЭл.Количество()),"Информация");
		стрРезультат.RS = МасЭл;
		
	Исключение
		//стрРезультат.ID=Формат(Выб.Ссылка.Номер,"ЧДЦ=; ЧГ=");
		стрРезультат.Error = "procdata_error";
		стрРезультат.ErrorDescription = "Error during data processsing: " + ОписаниеОшибки();
		ЗаписатьВЛог("ВебСервис","Error during data processsing: " + ОписаниеОшибки(),"Информация");
		Возврат стрРезультат;
	КонецПопытки;
	
	Возврат стрРезультат;
КонецФункции

