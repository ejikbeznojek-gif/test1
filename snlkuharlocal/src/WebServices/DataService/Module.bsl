		|	И НЕ(ЕСТЬNULL(ФизическиеЛица.Код, """") В (&СписокКодов)
		|				ИЛИ ЕСТЬNULL(ФизическиеЛица.Родитель.Код, """") В (&СписокКодов)
		|				ИЛИ ЕСТЬNULL(ФизическиеЛица.Родитель.Родитель.Код, """") В (&СписокКодов)
		|				ИЛИ ЕСТЬNULL(ФизическиеЛица.Родитель.Родитель.Родитель.Код, """") В (&СписокКодов)
		|				ИЛИ ЕСТЬNULL(ФизическиеЛица.Родитель.Родитель.Родитель.Родитель.Код, """") В (&СписокКодов))
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическиеЛица.Ссылка ИЕРАРХИЯ";
	
	Запрос.УстановитьПараметр("Код", "SNL-00849");
	СписокНенужныхКодов = Новый СписокЗначений;
	СписокНенужныхКодов.добавить("SNL-00850");  //ДЛ
	СписокНенужныхКодов.добавить("SNL-01028");  //Безопасники
	СписокНенужныхКодов.добавить("SNL-00782");  //Дизайн Бюро
	СписокНенужныхКодов.добавить("SNL-00853");  //кадры
	СписокНенужныхКодов.добавить("SNL-00858");  //Розница
	СписокНенужныхКодов.добавить("SNL-01446");  //Фин отдел
	Запрос.УстановитьПараметр("СписокКодов", СписокНенужныхКодов);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат Сериализовать(РезультатЗапроса);

КонецФункции

