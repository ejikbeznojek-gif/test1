Функция GetCIS(НомерДокумента, ДатаДокумента, ТипДокумента)
	
	ДанныеОтвета = Неопределено;
	Если ТипДокумента = "РасходнаяНакладная" Тогда
		ДанныеОтвета = ПолучитьДанныеПоКИЗ_РасходнаяНакладная(НомерДокумента, ДатаДокумента);
	КонецЕсли;
	
	Если ДанныеОтвета <> Неопределено Тогда 
		СтрокаJSON = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеОтвета);
		
		Возврат СтрокаJSON;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Получить данные по КИЗ расходная накладная
//
// Параметры:
//  НомерДокумента	 - Строка	 - Номер документа РНК в системе склада
//  ДатаДокумента	 - Дата 	 - Дата документа РНК в системе склада
// 
// Возвращаемое значение:
//  Структура - Данные с кодами маркировки
//
Функция ПолучитьДанныеПоКИЗ_РасходнаяНакладная(НомерДокумента, ДатаДокумента)
	
	ДанныеПоКИЗ = Новый Структура;
	ДанныеПоКИЗ.Вставить("Дата",  Формат(ДатаДокумента, "ДФ=dd.MM.yyyy"));
	ДанныеПоКИЗ.Вставить("Номер", НомерДокумента);
	ДанныеПоКИЗ.Вставить("КИЗы",  Новый Массив);
	
	РасходнаяНакладная = Документы.РасходнаяНакладная.НайтиПоНомеру(НомерДокумента, ДатаДокумента);
	
	Запрос = Новый Запрос(ТекстЗапросаДанныеПоКодамМаркировки());
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Ссылка", 	 РасходнаяНакладная);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтруктураТовара = Новый Структура;
		СтруктураТовара.Вставить("DataMatrix");	СтруктураТовара.Вставить("СтоимостьБезНДС");
		СтруктураТовара.Вставить("SKU");        СтруктураТовара.Вставить("Количество");
		СтруктураТовара.Вставить("EAN");
		
		ЗаполнитьЗначенияСвойств(СтруктураТовара, Выборка);
		
		ДанныеПоКИЗ.КИЗы.Добавить(СтруктураТовара);
	КонецЦикла;
	
	Возврат ДанныеПоКИЗ;
	
КонецФункции // ПолучитьДанныеПоКИЗ_РасходнаяНакладная()

// Функция - Текст запроса данные по кодам маркировки
// 
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаДанныеПоКодамМаркировки()
	
	Возврат "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	РасходнаяНакладнаяТовары.Цена КАК Цена,
	|	РасходнаяНакладная.Контрагент КАК Контрагент,
	|	РасходнаяНакладная.Договор КАК Договор
	|ПОМЕСТИТЬ вт_ТоварыПоРасходнойНакладной
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	|		ПО РасходнаяНакладнаяТовары.Номенклатура = РасходнаяНакладнаяКомплектующие.Продукция
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодНабора = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|			ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки
	|		ИНАЧЕ ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодНабора
	|	КОНЕЦ КАК ШтрихКод
	|ПОМЕСТИТЬ вт_КодыМаркировки
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
	|		ПО ХранилищеКодовМаркировки.Ссылка = ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка
	|ГДЕ
	|	ХранилищеКодовМаркировки.ДокОснование В
	|			(ВЫБРАТЬ
	|				вт_ТоварыПоРасходнойНакладной.Ссылка
	|			ИЗ
	|				вт_ТоварыПоРасходнойНакладной)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Представление КАК ЗначениеШтрихкода,
	|	ШтрихкодыУпаковокТоваров.Владелец КАК Номенклатура
	|ПОМЕСТИТЬ вт_ПоштучныеКодыПоТоварам
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_КодыМаркировки.ШтрихКод
	|			ИЗ
	|				вт_КодыМаркировки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.Ссылка КАК Ссылка,
	|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(128)) КАК АртикулКонтрагента,
	|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный
	|ПОМЕСТИТЬ вт_ДанныеМатрицы
	|ИЗ
	|	Документ.Матрица КАК Матрица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.Товары КАК МатрицаТовары
	|		ПО Матрица.Ссылка = МатрицаТовары.Ссылка
	|ГДЕ
	|	Матрица.Контрагент В
	|			(ВЫБРАТЬ
	|				вт_ТоварыПоРасходнойНакладной.Контрагент
	|			ИЗ
	|				вт_ТоварыПоРасходнойНакладной)
	|	И МатрицаТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				вт_ТоварыПоРасходнойНакладной.Номенклатура
	|			ИЗ
	|				вт_ТоварыПоРасходнойНакладной)
	|	И Матрица.Проведен
	|	И Матрица.Проведен
	|	И Матрица.ДатаОкончания > &ТекущаяДата
	|	И Матрица.Договор В
	|			(ВЫБРАТЬ
	|				вт_ТоварыПоРасходнойНакладной.Договор
	|			ИЗ
	|				вт_ТоварыПоРасходнойНакладной)
	|	И МатрицаТовары.ШККонтрагента <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_ПоштучныеКодыПоТоварам.ЗначениеШтрихкода КАК DataMatrix,
	|	ЕСТЬNULL(вт_ДанныеМатрицы.АртикулКонтрагента, """") КАК SKU,
	|	1 КАК Количество,
	|	вт_ТоварыПоРасходнойНакладной.Цена КАК СтоимостьБезНДС,
	|	вт_ДанныеМатрицы.ШККонтрагентаДополнительный КАК EAN
	|ИЗ
	|	вт_ПоштучныеКодыПоТоварам КАК вт_ПоштучныеКодыПоТоварам
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеМатрицы КАК вт_ДанныеМатрицы
	|		ПО вт_ПоштучныеКодыПоТоварам.Номенклатура = вт_ДанныеМатрицы.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ТоварыПоРасходнойНакладной КАК вт_ТоварыПоРасходнойНакладной
	|		ПО вт_ПоштучныеКодыПоТоварам.Номенклатура = вт_ТоварыПоРасходнойНакладной.Номенклатура"
	
КонецФункции  // ТекстЗапросаДанныеПоКодамМаркировки()
