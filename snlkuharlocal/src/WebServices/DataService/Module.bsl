Функция getMatrix(structure)
	СтруктураПараметров = Десериализовать(structure);
	КодКонтрагентаSNL = СтруктураПараметров.КодКонтрагентаSNL;
	ТаблицаШК = СтруктураПараметров.ТаблицаШК;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗ.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ИсходныеДанные
	|ИЗ
	|	вт КАК вт
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура.Код КАК КодЭлемента,
	|	МатрицаТовары.Номенклатура.Наименование КАК НаименованиеЭлемента,
	|	МатрицаТовары.ШККонтрагента КАК ШтрихКод,
	|	МатрицаТовары.Номенклатура.Родитель.Наименование КАК НаименованиеМодели,
	|	МатрицаТовары.Номенклатура.Родитель.Код КАК КодМодели,
	|	МатрицаТовары.Номенклатура.Родитель.Родитель.Родитель.Код КАК КодБрэнда
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	(МатрицаТовары.Ссылка.Проведен
	|				И МатрицаТовары.Ссылка.Контрагент.Код = &Контрагент
	|			ИЛИ МатрицаТовары.Ссылка.Контрагент.Ведущий.Код = &Контрагент
	|				И МатрицаТовары.Ссылка.Дата <= &Дата
	|				И МатрицаТовары.Ссылка.ДатаОкончания >= &ДатаОкончания
	|				И МатрицаТовары.ШККонтрагента В
	|					(ВЫБРАТЬ
	|						ИсходныеДанные.Штрихкод
	|					ИЗ
	|						ИсходныеДанные КАК ИсходныеДанные))";
	Запрос.УстановитьПараметр("ТЗ",ТаблицаШК);
	Запрос.УстановитьПараметр("Контрагент",КодКонтрагентаSNL);
	Запрос.УстановитьПараметр("Дата",КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ДатаОкончания",НачалоДня(ТекущаяДата()));
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат Сериализовать(РезультатЗапроса);
КонецФункции


