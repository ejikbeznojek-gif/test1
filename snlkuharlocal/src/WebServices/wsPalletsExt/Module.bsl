	Для Каждого Строка из СписокСтрокизПаллет Цикл
		
		ШККоробок = Новый ТаблицаЗначений; 
		//++Данилова Е.В. 25.05.2026  HELP-9853
		//ШККоробок =  ПолучитьСписокШКкоробокЛистаНабора(Строка.ЛистНабора);
		ШККоробок =  ПолучитьСписокШКкоробокЛистаНабора(Строка.ЛистНабора,,,ложь);
		//--Данилова Е.В. 25.05.2026 
		// ищем По ШК и прописываем количество.
		ТекНомер = Строка.НомерКоробки;
		НайденнаяСтрока = ШККоробок.Найти(Число(ТекНомер), "НомерКоробки");
		Если НайденнаяСтрока = Неопределено Тогда
			//Предупреждение("Товар не найден!");
		Иначе
			Строка.Номенклатура = НайденнаяСтрока.Номенклатура;
			Строка.Количество = НайденнаяСтрока.Номенклатура.Родитель.ШтукВКоробке;
		КонецЕсли;
		
	КонецЦикла;
	
	// вторая часть по блочкам и штукам
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ПаллетаЛистыНабора.Ссылка КАК Паллета,
