&НаСервере
Функция В_JSON(Значение) Экспорт
	ЗначениеВнутр = ПривестиЗначение(Значение);
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON,ЗначениеВнутр);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции
&НаСервере
Функция Из_JSON(Значение,ВСоответствие=Истина) Экспорт
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Значение);
	Возврат ПрочитатьJSON(ЧтениеJSON,ВСоответствие);
КонецФункции
&НаСервере
Функция ПривестиЗначение(Значение) Экспорт   
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Неопределено") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Булево") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Массив") Тогда	
		ЗначениеВнутр = Новый Массив;
		Для каждого СтрЗнач Из Значение Цикл
			ЗначениеВнутр.Добавить(ПривестиЗначение(СтрЗнач));
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли ТипЗнч(Значение) = Тип("Структура") Тогда	
		ЗначениеВнутр = Новый Структура;
		Для каждого СтрЗнач Из Значение Цикл
			ЗначениеВнутр.Вставить(СтрЗнач.Ключ,ПривестиЗначение(СтрЗнач.Значение));
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда	
		ЗначениеВнутр = Новый Массив;
		Для каждого СтрЗнач Из Значение Цикл
			СтрокаЗначения = Новый Структура();
			Для каждого Колонка Из Значение.Колонки Цикл
				СтрокаЗначения.Вставить(Колонка.Имя,ПривестиЗначение(СтрЗнач[Колонка.Имя]));	
			КонецЦикла;	
			ЗначениеВнутр.Добавить(СтрокаЗначения);
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) Тогда
		Если Значение.Пустая() Тогда
			Возврат Неопределено;
		КонецЕсли;	
		Возврат Строка(Значение.УникальныйИдентификатор());
	Иначе
		Возврат Строка(Значение);
	КонецЕсли;	
КонецФункции


Функция GetPData(RNK_Number, RNK_Date)
	ДатаПериодаРНК = Дата(RNK_Date);
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	ДокПаллета_ЛистыНабора.Ссылка КАК Ссылка
	                      |ПОМЕСТИТЬ Вт_Паллеты
	                      |ИЗ
	                      |	Документ.Паллета.ЛистыНабора КАК ДокПаллета_ЛистыНабора
	                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Паллета КАК ДокПаллета
	                      |		ПО (ДокПаллета.Ссылка = ДокПаллета_ЛистыНабора.Ссылка)
	                      |			И (ДокПаллета.Проведен)
	                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК ДокРНК
	                      |		ПО (ДокРНК.Ссылка = ДокПаллета_ЛистыНабора.Документ)
	                      |ГДЕ
	                      |	ДокРНК.Номер = &НомерРНК
	                      |	И ДокРНК.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаРНК, ГОД) И КОНЕЦПЕРИОДА(&ДатаРНК, ГОД)
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	ДокПаллета.Ссылка КАК ПаллетаСсылка,
	                      |	ДокПаллета_Товары.SSCCКод КАК SSCCКод,
	                      |	ДокПаллета_Товары.Номенклатура КАК Номенклатура,
	                      |	ДокПаллета_Товары.Количество КАК Количество
	                      |ИЗ
	                      |	Документ.Паллета КАК ДокПаллета
	                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Паллета.Товары КАК ДокПаллета_Товары
	                      |		ПО (ДокПаллета_Товары.Ссылка = ДокПаллета.Ссылка)
	                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Вт_Паллеты КАК Вт_Паллеты
	                      |		ПО ДокПаллета.Ссылка = Вт_Паллеты.Ссылка
	                      |ГДЕ
	                      |	ДокПаллета.Проведен
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	ПаллетаСсылка,
	                      |	Номенклатура,
	                      |	SSCCКод");
	Запрос.УстановитьПараметр("НомерРНК",RNK_Number);
	Запрос.УстановитьПараметр("ДатаРНК",ДатаПериодаРНК);
	Таб = Запрос.Выполнить().Выгрузить();
	Возврат В_JSON(Таб);
КонецФункции

