Функция ЗначениеИзХранилища(ХранилищеЗначений)
		
	Возврат  ХранилищеЗначений.Получить();
	
КонецФункции

Функция ЗначениеВХранилище(Значение)
	
	Хранилище = Новый ХранилищеЗначения(Значение, Новый СжатиеДанных(9));
	 	
	Возврат Хранилище;
    	
КонецФункции

Функция ИнформацияОФото(Штрихкод)  
	
	массивШК = ЗначениеИзХранилища(Штрихкод);

    тШтрихкод = массивШК[0];
	
	МассивСтр = Новый Массив;  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихКоды.Владелец КАК Владелец
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Наименование = &Штрихкод"; 
	
	Запрос.Параметры.Вставить("Штрихкод", тШтрихкод); 	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если  ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		НоваяСтр = Новый Соответствие;    
		
		ТекТовар =  ВыборкаДетальныеЗаписи.Владелец;
		РодТовара = ТекТовар.Родитель;  	
		
		НоваяСтр.Вставить("Код",ТекТовар.Код);
		НоваяСтр.Вставить("Наименование",ТекТовар.Наименование); 				
		
		МассивСтр.Добавить(НоваяСтр);   	//инфо о товаре	
		
		ЗапросВ = Новый Запрос;
		ЗапросВ.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Наименование КАК Наименование,
		|	Номенклатура.Код КАК Код
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Родитель = &Родитель
		|	И Номенклатура.Ссылка <> &Ссылка";  
		
		ЗапросВ.Параметры.Вставить("Родитель", РодТовара); 		
		ЗапросВ.Параметры.Вставить("Ссылка", ТекТовар.Ссылка); 
		
		РезультатВ = ЗапросВ.Выполнить().Выгрузить();
		
		МассивСтр.Добавить(РезультатВ);     //похожий товар
		
	Иначе	
		Возврат ЗначениеВХранилище(Ложь);
	КонецЕсли;          
	
	ЗапросО = Новый Запрос;
	ЗапросО.Текст =	
	
	"ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК Остаток,
	|	ОстаткиТМЦОстатки.Склад.Наименование КАК МестоХранения
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.Номенклатура = &Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОстаткиТМЦОстатки.КоличествоОстаток УБЫВ";
	ЗапросО.Параметры.Вставить("Номенклатура", ТекТовар); 
	
    Результат0 = ЗапросО.Выполнить().Выгрузить();
		
	МассивСтр.Добавить(Результат0); //отстатки	

	
	КаталогКартинок			=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить())+"Pictures\";   
	ПустаяКартинка = Новый Картинка;


	ТекДанные = Справочники.Номенклатура.НайтиПоКоду(ТекТовар.Код);
	
	Если ТекДанные<>Справочники.Номенклатура.ПустаяСсылка() Тогда    	
		
		ИмяФайлаКартинки=КаталогКартинок+?(ТекДанные.ЭтоГруппа,ТекДанные.Код,ТекДанные.Родитель.Код)+".jpg";
			                                                         	
		Файл=Новый Файл(ИмяФайлаКартинки);
		Если Файл.Существует() Тогда
			ВыбранноеФото = Новый Картинка(ИмяФайлаКартинки);			
		Иначе
			ВыбранноеФото = Новый Картинка(); 
		КонецЕсли;  
		
		МассивСтр.Добавить(ВыбранноеФото); 
		
	КонецЕсли;
	
	Возврат ЗначениеВХранилище(МассивСтр);  
	
КонецФункции

Функция ИнформацияОНоменклатура(Штрихкод) 
	//"8300041958028"
	МойМассив = ЗначениеИзХранилища(Штрихкод);

    тШтрихкод = МойМассив[0];
	
	МассивСтр = Новый Массив;  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихКоды.Владелец КАК Владелец
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Наименование = &Штрихкод"; 
	
	Запрос.Параметры.Вставить("Штрихкод", тШтрихкод); 	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если  ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		НоваяСтр = Новый Соответствие;    
		
		ТекТовар =  ВыборкаДетальныеЗаписи.Владелец;
		РодТовара = ТекТовар.Родитель;  	
		
		НоваяСтр.Вставить("Код",           ТекТовар.Код);
		НоваяСтр.Вставить("Наименование",  ТекТовар.Наименование); 				
		НоваяСтр.Вставить("КодР",          РодТовара.Код);
		НоваяСтр.Вставить("НаименованиеР", РодТовара.Наименование);		
		НоваяСтр.Вставить("ШтукВКоробке",  РодТовара.ШтукВКоробке);
		НоваяСтр.Вставить("ШтукВКоробочке",РодТовара.ШтукВКоробочке);  
		
		МассивСтр.Добавить(НоваяСтр);   //информация о товаре		
		
		ЗапросВ = Новый Запрос;
		ЗапросВ.Текст = 
		"ВЫБРАТЬ
		|	ШтрихКоды.Наименование КАК Наименование,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ВидШК) КАК ВидШК,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ТипШК) КАК ТипШК,
		|	ШтрихКоды.Код КАК КодШК
		|ИЗ
		|	Справочник.ШтрихКоды КАК ШтрихКоды
		|ГДЕ
		|	ШтрихКоды.Владелец = &Владелец";
		ЗапросВ.Параметры.Вставить("Владелец", ТекТовар); 		
		ЗапросВ.Параметры.Вставить("ВидШК",    Перечисления.ВидыШК.Основной); 
		
		РезультатВ = ЗапросВ.Выполнить().Выгрузить();
		
		МассивСтр.Добавить(РезультатВ); //информация о штрихкоде

	Иначе
		
		//штрихкод не найден в базе
		Возврат ЗначениеВХранилище(Ложь);
		
	КонецЕсли;
	
	Возврат ЗначениеВХранилище(МассивСтр); 	
	
КонецФункции        


Функция РазбираемАгрегацию(Штрихкод)  Экспорт
		
	МойМассив = ЗначениеИзХранилища(Штрихкод);

    тШтрихкод = МойМассив[0]; 
			
	МассивСтр = Новый Массив;  
		
	СтруктураМарки  =Неопределено;
	ДанныеМаркиЧЗ   =НайтиТоварПоШтрихКоду(тШтрихкод,Неопределено,0,СтруктураМарки,Ложь);
	
	//из марки получить штрихкод единицы товара , а нам нужна КОРОБКИ штрихкод
			
	Если СтруктураМарки<>Неопределено Тогда 
		
		ШтрихКодШтуки	    = СтруктураМарки.ШтрихКод;  
		
		Если ШтрихКодШтуки<> Неопределено Тогда 		
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	ШтрихКоды.Владелец КАК Владелец
			|ПОМЕСТИТЬ НужныйВладелец
			|ИЗ
			|	Справочник.ШтрихКоды КАК ШтрихКоды
			|ГДЕ
			|	ШтрихКоды.Наименование = &Наименование
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ШтрихКоды.Наименование КАК ШтрихкодКоробки
			|ИЗ
			|	Справочник.ШтрихКоды КАК ШтрихКоды
			|ГДЕ
			|	ШтрихКоды.Владелец В
			|			(ВЫБРАТЬ
			|				НужныйВладелец.Владелец КАК Владелец
			|			ИЗ
			|				НужныйВладелец КАК НужныйВладелец)
			|	И ШтрихКоды.ТипШК = &ТипШК
			|	И ШтрихКоды.ВидШК = &ВидШК";
			//Параметры запроса
			Запрос.УстановитьПараметр("Наименование",ШтрихКодШтуки);// Строка
			Запрос.УстановитьПараметр("ВидШК",       Перечисления.ВидыШК.Основной);// Виды ШК
			Запрос.УстановитьПараметр("ТипШК",       Перечисления.ТипыШтрихКодов.Коробка);// Типы штрих кодов
			Результат = Запрос.Выполнить().Выбрать();
			
			Если Результат.Следующий() Тогда
				
				Возврат ЗначениеВХранилище(Результат.ШтрихкодКоробки);
				
			Иначе
				
				Возврат ЗначениеВХранилище(ШтрихКодШтуки);
				
			КонецЕсли;
				
		КонецЕсли;
	
	КОнецЕсли;  
	
	Возврат  ЗначениеВХранилище(Неопределено);
	
КонецФункции    


Функция ИнформацияПоЗНБ(Штрихкод)  Экспорт
		
	МойМассив = ЗначениеИзХранилища(Штрихкод);

    ШКЗНБ = МойМассив[0]; //получаем КОД в базе 64 
	
	//штатным спобом разбиваем и находим документ
	
	ЗНБ = ADRESS.ВернутьЗНБпоШтрихкоду(ШКЗНБ);
		
	Если ЗНБ<>Документы.ЗаданиеНабора.ПустаяСсылка() Тогда
		
		МассивСтр = Новый Массив;  
	    		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ЗаданиеНабораТовары.Номенклатура.Код КАК НоменклатураКод,
		|	СУММА(ЗаданиеНабораТовары.Количество) КАК Количество
		|ИЗ
		|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|ГДЕ
		|	ЗаданиеНабораТовары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаданиеНабораТовары.Номенклатура.Код";
		//Параметры запроса
		Запрос.УстановитьПараметр("Ссылка",ЗНБ);// ЗНБ
		ТЗЗНБ = Запрос.Выполнить().Выгрузить();   
		
		ДокСтруктра = Новый Структура;    
		ДокСтруктра.Вставить("ПредставлениеДок",Строка(ЗНБ));
		ДокСтруктра.Вставить("КодСектор",ЗНБ.Сектор.Код);
		ДокСтруктра.Вставить("ЭтоМаркировка",ЗНБ.ТребуетсяМаркировка);
		
		МассивСтр.Добавить(ДокСтруктра);
		МассивСтр.Добавить(ТЗЗНБ);	
					
		Возврат ЗначениеВХранилище(МассивСтр);
			                      		
	Иначе
		
		Возврат Неопределено
		
	КОнецЕсли; 
	
КонецФункции     

 
Функция ИнформацияПоВсемШтрихкодамНоменклатуры(КодСклада) 
		
	МассивСтр   = Новый Массив;  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ 
	               |	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ОстаткиТовара
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад В (&Склады)) КАК ОстаткиТМЦОстатки
	               |ГДЕ
	               | ОстаткиТМЦОстатки.КоличествоОстаток > 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ТипШК) КАК ТипШК,
	               |	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ВидШК) КАК ВидШК,
	               |	ШтрихКоды.Наименование КАК Штрихкод,
	               |	ШтрихКоды.Владелец.Код КАК Код,
	               |	ШтрихКоды.Владелец.Наименование КАК Наименование,
	               |	ШтрихКоды.Владелец.Родитель.Код КАК КодР,
	               |	ШтрихКоды.Владелец.Родитель.Наименование КАК НаименованиеР,
	               |	ШтрихКоды.Владелец.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	               |	ШтрихКоды.Владелец.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
	               |	ШтрихКоды.Код КАК КодШК
	               |ИЗ
	               |	Справочник.ШтрихКоды КАК ШтрихКоды
	               |ГДЕ
	               |	НЕ ШтрихКоды.ПометкаУдаления
	               |	И ШтрихКоды.Владелец В
	               |			(ВЫБРАТЬ
	               |				ОстаткиТовара.Номенклатура КАК Номенклатура
	               |			ИЗ
	               |				ОстаткиТовара КАК ОстаткиТовара)";
	
	Склады = Новый СписокЗначений;
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STA-48")); // <Склады>[Склад Часцы (Основной)],
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STD-95")); // <Склады>[Маркировка Склад Часцы (Основной)]  
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-37")); // <Склады>[Маркировка Склад Часцы (Вычерки)]  
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-38")); // <Склады>[Склад Часцы (Вычерки)]
	
	Запрос.УстановитьПараметр("Склады", Склады);  
	Результат = Запрос.Выполнить().Выгрузить();
	МассивСтр.Добавить(Результат); 	
	
	Возврат ЗначениеВХранилище(МассивСтр);
		
КонецФункции      

Функция ИнформацияПоКодамНоменклатуры(ХрТЗКОДЫ) Экспорт	
	
	//Запрос через ВЕБ СЕРВИС InfoALLKod
	
	ТЗКОДЫ = ЗначениеИзХранилища(ХрТЗКОДЫ); 	        		
	//Входная таблица с кодами Номенклатуры     
	
	МассивСтр   = Новый Массив;
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗКОДЫ.Код КАК СТРОКА(10)) КАК КодТовара
	|ПОМЕСТИТЬ ТоварыКод
	|ИЗ
	|	&ТЗКОДЫ КАК ТЗКОДЫ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ ОстаткиТовара
	|ИЗ
	|	ТоварыКод КАК ТоварыКод
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО ТоварыКод.КодТовара = Номенклатура.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ТипШК) КАК ТипШК,
	|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ВидШК) КАК ВидШК,
	|	ШтрихКоды.Наименование КАК Штрихкод,
	|	ШтрихКоды.Владелец.Код КАК Код,
	|	ШтрихКоды.Владелец.Наименование КАК Наименование,
	|	ШтрихКоды.Владелец.Родитель.Код КАК КодР,
	|	ШтрихКоды.Владелец.Родитель.Наименование КАК НаименованиеР,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
	|	ШтрихКоды.Код КАК КодШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.Владелец В
	|			(ВЫБРАТЬ
	|				ОстаткиТовара.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ОстаткиТовара КАК ОстаткиТовара)";
	Запрос.УстановитьПараметр("ТЗКОДЫ", ТЗКОДЫ);  
	Результат = Запрос.Выполнить().Выгрузить();  
	
	
	ЗаписатьВЛог("АДРЕС",Строка(ТекущаяДата())+" "+Строка(Результат.Количество()),"Информация");

	МассивСтр.Добавить(Результат); 	
	
	Возврат ЗначениеВХранилище(МассивСтр);
	
КонецФункции  


Функция ИнформацияПоGTINНоменклатуры(врТЗКОДЫ) Экспорт	
	
	//Запрос через ВЕБ СЕРВИС InfoGTIN
	
	ТЗКОДЫ = ЗначениеИзХранилища(врТЗКОДЫ); 	        		
	//Входная таблица с кодами Номенклатуры     
	
	МассивСтр   = Новый Массив;
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВЫРАЗИТЬ(ТЗКОДЫ.Код КАК СТРОКА(10)) КАК КодТовара
	               |ПОМЕСТИТЬ ТоварыКод
	               |ИЗ
	               |	&ТЗКОДЫ КАК ТЗКОДЫ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Номенклатура.Ссылка КАК Номенклатура,
	               |	Номенклатура.ГТИН КАК ГТИН
	               |ПОМЕСТИТЬ ТоварСсылки
	               |ИЗ
	               |	ТоварыКод КАК ТоварыКод
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	               |		ПО ТоварыКод.КодТовара = Номенклатура.Код
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ИсторияГТИННоменклатуры.Номенклатура КАК Номенклатура,
	               |	ИсторияГТИННоменклатуры.ГТИН КАК ГТИН
	               |ПОМЕСТИТЬ ИзРЕГИСТРА
	               |ИЗ
	               |	РегистрСведений.ИсторияГТИННоменклатуры КАК ИсторияГТИННоменклатуры
	               |ГДЕ
	               |	ИсторияГТИННоменклатуры.Номенклатура В
	               |			(ВЫБРАТЬ
	               |				ТоварСсылки.Номенклатура КАК Номенклатура
	               |			ИЗ
	               |				ТоварСсылки КАК ТоварСсылки)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТоварСсылки.Номенклатура,
	               |	ТоварСсылки.ГТИН
	               |ИЗ
	               |	ТоварСсылки КАК ТоварСсылки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ИзРЕГИСТРА.ГТИН КАК ГТИН,
	               |	ИзРЕГИСТРА.Номенклатура.Код КАК КодТовара
	               |ИЗ
	               |	ИзРЕГИСТРА КАК ИзРЕГИСТРА
	               |ГДЕ
	               |	ИзРЕГИСТРА.ГТИН <> """"";
	
	Запрос.УстановитьПараметр("ТЗКОДЫ", ТЗКОДЫ);  
	Результат = Запрос.Выполнить().Выгрузить();  
	
	МассивСтр.Добавить(Результат); 	
	
	Возврат ЗначениеВХранилище(МассивСтр);
	
КонецФункции 


Функция ИнформацияПоКодамНоменклатурыЛокально(ТЗКОДЫ) Экспорт	
				
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗКОДЫ.Код КАК СТРОКА(10)) КАК КодТовара
	|ПОМЕСТИТЬ ТоварыКод
	|ИЗ
	|	&ТЗКОДЫ КАК ТЗКОДЫ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ ОстаткиТовара
	|ИЗ
	|	ТоварыКод КАК ТоварыКод
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО ТоварыКод.КодТовара = Номенклатура.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ТипШК) КАК ТипШК,
	|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.ВидШК) КАК ВидШК,
	|	ШтрихКоды.Наименование КАК Штрихкод,
	|	ШтрихКоды.Владелец.Код КАК Код,
	|	ШтрихКоды.Владелец.Наименование КАК Наименование,
	|	ШтрихКоды.Владелец.Родитель.Код КАК КодР,
	|	ШтрихКоды.Владелец.Родитель.Наименование КАК НаименованиеР,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
	|	ШтрихКоды.Код КАК КодШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.Владелец В
	|			(ВЫБРАТЬ
	|				ОстаткиТовара.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ОстаткиТовара КАК ОстаткиТовара)";
	Запрос.УстановитьПараметр("ТЗКОДЫ", ТЗКОДЫ);  
	Результат = Запрос.Выполнить().Выгрузить();  
	
	Возврат Результат;
	
КонецФункции 

Функция ОстаткиТовараНаСкладах(КодСклада) 
	
	//Остатки на складах ОСНОВНОЙ и МАРКИРОВКА
	
	МассивСтр   = Новый Массив;  
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК Остаток,
	|	ОстаткиТМЦОстатки.Номенклатура.Код КАК Код
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад В (&Склады)) КАК ОстаткиТМЦОстатки";
	
	Склады = Новый СписокЗначений;
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STA-48")); // <Склады>[Склад Часцы (Основной)], 
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-38")); // <Склады>[Склад Часцы (Вычерки)]

	Запрос.Параметры.Вставить("Склады", Склады); 	
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить(); 
		
	МассивСтр.Добавить(РезультатЗапроса); 	
	
	//И маркировка
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК Остаток,
	|	ОстаткиТМЦОстатки.Номенклатура.Код КАК Код
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад В (&Склады)) КАК ОстаткиТМЦОстатки";
	
	Склады = Новый СписокЗначений;
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STD-95")); // <Склады>[Маркировка Склад Часцы (Основной)]	
	Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-37")); // <Склады>[Маркировка Склад Часцы (Вычерки)] 
	
	Запрос.Параметры.Вставить("Склады", Склады); 	
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивСтр.Добавить(РезультатЗапроса); 
	
	Возврат ЗначениеВХранилище(МассивСтр);
	
	
КонецФункции

Функция ОстаткиТовараВерхНиз(МассивТовара) Экспорт 
	
	//в массиве список товара и признак маркировки
	//возрващает остаток номенклатуры на ВЕРХУ и ВНИЗУ
	
	
	МойМассив = ЗначениеИзХранилища(МассивТовара); 
	
	СписокТовара  = МойМассив[0];
	ЭтоМаркировка = МойМассив[1];      	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК ОстатокВерх,
	|	0 КАК ОстатокНиз
	|ПОМЕСТИТЬ ОСТАТКИ
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &Склад
	|				И Номенклатура В (&СписокТовара)) КАК ОстаткиТМЦОстатки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура,
	|	0,
	|	ОстаткиТМЦОстатки.КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &СкладОсновной
	|				И Номенклатура В (&СписокТовара)) КАК ОстаткиТМЦОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОСТАТКИ.Номенклатура КАК Номенклатура,
	|	СУММА(ОСТАТКИ.ОстатокВерх) КАК ОстатокВерх,
	|	СУММА(ОСТАТКИ.ОстатокНиз) КАК ОстатокНиз
	|ИЗ
	|	ОСТАТКИ КАК ОСТАТКИ
	|
	|СГРУППИРОВАТЬ ПО
	|	ОСТАТКИ.Номенклатура";         
	
	
	Если ЭтоМаркировка Тогда
		
		Запрос.УстановитьПараметр("Склад",         Справочники.Склады.НайтиПоКоду("STЕ-17"));// Маркировка Склад Часцы (Паллетного хранения)
		Запрос.УстановитьПараметр("СкладОсновной", Справочники.Склады.НайтиПоКоду("STD-95"));// Маркировка Склад Часцы (Основной)
		
	Иначе
		Запрос.УстановитьПараметр("Склад",         Справочники.Склады.НайтиПоКоду("STC-27"));// Склад Часцы (Паллетного хранения)
		Запрос.УстановитьПараметр("СкладОсновной", Справочники.Склады.НайтиПоКоду("STA-48"));// Склад Часцы (Основной)
		
	КонецЕсли;  
	
	Запрос.УстановитьПараметр("СписокТовара",СписокТовара);// Список значений
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	
	Возврат ЗначениеВХранилище(РезультатЗапроса);
	
КонецФункции

Функция ДанныеПоДокументу(ГУИДДОК) Экспорт    
	
	ЗаписатьВЛог("АДРЕС","Начало выполнения-Данные по документу","Информация");
	
	//получаем массив
	МойМассив = ЗначениеИзХранилища(ГУИДДОК); 	
	//получаем ГУИД из массива по нулевому индексу
	ГУИД          = МойМассив[0];    
	ВариантОтвета = МойМассив[1]; 
	//ищем документ в базе по ГУИД
	СсылкаДок=ADRESS.ВернутьДокументПоГУИД(ГУИД); 

	Ответ="";
	
	Если СсылкаДок<>Неопределено Тогда   
		
		Если ТипЗнч(СсылкаДок) = Тип("ДокументСсылка.ЛистНабора") Тогда	
			
			МассивДОк = Новый Массив;  
			
			ДокументОснование= СсылкаДок.ДокОснование;
			
			СтрДокОснования = Новый Структура;
			СтрДокОснования.Вставить("СтрОснование", Строка(ДокументОснование));
		    СтрДокОснования.Вставить("ГУИДОснование",Строка(ДокументОснование.УникальныйИдентификатор())); 	
			СтрДокОснования.Вставить("ГУИД",         Строка(СсылкаДок.УникальныйИдентификатор())); 
			СтрДокОснования.Вставить("Основание",    Строка(СсылкаДок));
			
			МассивДОк.Добавить(СтрДокОснования);
			//ТЮА 23.12.2025
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	ЛистНабораТовары.Номенклатура.Код КАК Код,
			               |	ЛистНабораТовары.Количество КАК Количество,
			               |	ПРЕДСТАВЛЕНИЕ(ЛистНабораТовары.ТипШК) КАК ТипШК,
			               |	ЛистНабораТовары.ШК КАК Штрихкод,
			               |	ЛистНабораТовары.ШтВКоробе КАК КолвоСкан,
			               |	ЛистНабораТовары.ЭтоНекондиция КАК ЭтоНекондиция,
			               |	ЛистНабораТовары.ЭтоБрак КАК ЭтоБрак,
			               |	ЛистНабораТовары.Ссылка.КоличествоДокумента КАК КоличествоДокумента,
			               |	ЛистНабораТовары.Ссылка.КоличествоКоробок КАК КоличествоКоробок,
			               |	ЛистНабораТовары.Ссылка.НеполныйКороб КАК НеполныйКороб
			               |ИЗ
			               |	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
			               |ГДЕ
			               |	ЛистНабораТовары.Ссылка = &Ссылка";
			//Параметры запроса
			Запрос.УстановитьПараметр("Ссылка",СсылкаДок);// ЛН
			
			Результат = Запрос.Выполнить().Выгрузить(); 
			
			Если Результат.Количество()>0 Тогда    
												
				Результат.Колонки.Добавить("ИнфоОТоваре");
				
				Для Каждого стр из Результат Цикл
					Стр.ИнфоОтоваре = ADRESS.МассивОНоменклатура(стр.Штрихкод);
				КонецЦикла;
				
				МассивДОк.Добавить(Результат);				
				Возврат ЗначениеВХранилище(МассивДОк); 
				
			Иначе
				Ответ= "Документ пустой"; 			
			КонецЕсли;  		
			
		Иначе
			Ответ= "Этот документ не ЛИСТ НАБОРА.Отмена";	
		КонецЕсли;		
	Иначе     
		
		Ответ= "Не найден документ";
		
	КонецЕсли;   
	
	Возврат ЗначениеВХранилище(Ответ);
	
КонецФункции

