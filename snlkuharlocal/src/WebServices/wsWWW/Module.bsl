Функция ВыгрузкаНужныхДокументов(ГУИДДОК) Экспорт    
	
	
	
	//получаем массив
	МойМассив     = ЗначениеИзХранилища(ГУИДДОК); 	
	//получаем ГУИД из массива по нулевому индексу
	ТЗГУИД        = МойМассив[0];     //ГУИД документов
	ВидДок        = МойМассив[1];     //вид документа
	НачВремя      = МойМассив[2];     //начало переиода
	КонВремя      = МойМассив[3];     //конецПериода
	СтатусДок     = МойМассив[4];     //статус документа

	Если ВидДок = "РасходнаяНакладная" Тогда  
		
	    ЗаписатьВЛог("АДРЕС","НАЧАЛО ОБМЕНА РНК "+Строка(ТекущаяДата()),"Информация");	
		//если ТЗ ГУИД пустая - значит нужно получить все НОВЫЙ ДОКУМЕНТЫ (ГУИДЫ) для проверки
		Если ТЗГУИД.Количество()=0 Тогда
			
			//СостояниеНакладной  =    ПолучитьСсылкуНаЗначениеПеречисления("СостоянияНакладной",СтатусДок);			
			//ЗаписатьВЛог("АДРЕС",Строка(СостояниеНакладной),"Информация");
			//ТЮА на будущее передавать состояния накладных - для регулировки потока  
			
			
			//получим все ОТГРУЖЕННЫЕ ДОКУМЕНТЫ
			Если СтатусДок="Отгружено" Тогда
				
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ
				|	РасходнаяНакладная.Ссылка КАК Док
				|ПОМЕСТИТЬ НужныеДок
				|ИЗ
				|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
				|ГДЕ
				|	РасходнаяНакладная.Проведен
				|	И РасходнаяНакладная.ДатаОтгрузки МЕЖДУ &НачВремя И &КонВремя
				|	И РасходнаяНакладная.СостояниеНакладной =&СостояниеНакладной
				|	И РасходнаяНакладная.Склад В ИЕРАРХИИ(&Склад)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(НужныеДок.Док)) КАК ГУИД
				|ИЗ
				|	НужныеДок КАК НужныеДок     
				|	
				|";
				//Параметры запроса
				
				Запрос.УстановитьПараметр("НачВремя",НачВремя);// Дата
				Запрос.УстановитьПараметр("КонВремя",КонВремя);// Дата
				Запрос.УстановитьПараметр("Склад",   Справочники.Склады.НайтиПоКоду("STA-47"));// Склад Часцы
												
				Запрос.УстановитьПараметр("СостояниеНакладной",Перечисления.СостоянияНакладной.Отгружена);// Список значений				
				Результат = Запрос.Выполнить().Выгрузить(); 		
				
				Возврат ЗначениеВХранилище(Результат);  

			Иначе      
				//иначе все готовящиеся к отгрузке
				
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ
				|	РасходнаяНакладная.Ссылка КАК Док
				|ПОМЕСТИТЬ НужныеДок
				|ИЗ
				|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
				|ГДЕ
				|	РасходнаяНакладная.Проведен
				|	И РасходнаяНакладная.ДатаОтгрузки МЕЖДУ &НачВремя И &КонВремя
				|	И НЕ РасходнаяНакладная.СостояниеНакладной В (&СостояниеНакладной)
				|	И РасходнаяНакладная.Склад В ИЕРАРХИИ(&Склад)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(НужныеДок.Док)) КАК ГУИД
				|ИЗ
				|	НужныеДок КАК НужныеДок     
				|	
				|";
				//Параметры запроса
				
				Запрос.УстановитьПараметр("НачВремя",НачВремя);// Дата
				Запрос.УстановитьПараметр("КонВремя",КонВремя);// Дата
				Запрос.УстановитьПараметр("Склад",   Справочники.Склады.НайтиПоКоду("STA-47"));// Склад Часцы
				
				//Параметр список 'СостояниеНакладной'
				ПараметрСписок_СостояниеНакладной = Новый СписокЗначений;
				ПараметрСписок_СостояниеНакладной.Добавить(Перечисления.СостоянияНакладной.Отгружена);
				ПараметрСписок_СостояниеНакладной.Добавить(Перечисления.СостоянияНакладной.ГотоваКОтгрузке);
				ПараметрСписок_СостояниеНакладной.Добавить(Перечисления.СостоянияНакладной.Паллетирование);
				ПараметрСписок_СостояниеНакладной.Добавить(Перечисления.СостоянияНакладной.ОжиданиеПаллетирования); 
				
				Запрос.УстановитьПараметр("СостояниеНакладной",ПараметрСписок_СостояниеНакладной);// Список значений
				
				Результат = Запрос.Выполнить().Выгрузить(); 		
				
				Возврат ЗначениеВХранилище(Результат);  
				
			КонецЕсли;
			
		Иначе
			
			//есть НЕОБРАБОТАННЫЕ документы
			
			НоваяТЗ = Новый ТаблицаЗначений;
			НоваяТЗ.Колонки.Добавить("Документ", Новый ОписаниеТипов("ДокументСсылка.РасходнаяНакладная"));
			НоваяТЗ.Колонки.Добавить("ГУИД",     Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36)));
			НоваяТЗ.Колонки.Добавить("ДанныеДОк",Новый ОписаниеТипов("ТаблицаЗначений"));
			НоваяТЗ.Колонки.Добавить("Номер");
			НоваяТЗ.Колонки.Добавить("Дата");
			НоваяТЗ.Колонки.Добавить("ДатаОтгрузки");
			НоваяТЗ.Колонки.Добавить("ТребуетсяМаркировка");
			
			
			Для Каждого Гдок из ТЗГУИД Цикл 
				
				ТекДок = Документы.РасходнаяНакладная.ПолучитьСсылку(Новый УникальныйИдентификатор(Гдок.ГУИД));
				
				Если Найти(Строка(ТекДок),"Объект не найден")=0 Тогда 				
					СтрТЗ                     = НоваяТЗ.Добавить();
					СтрТЗ.Документ            = ТекДок; 
					СтрТЗ.ГУИД                = Гдок.ГУИД;
					СтрТЗ.Номер               = ТекДок.Номер;
					СтрТЗ.Дата                = ТекДок.Дата;
					СтрТЗ.ДатаОтгрузки        = ТекДок.ДатаОтгрузки;
					СтрТЗ.ТребуетсяМаркировка = ТекДок.ТребуетсяМаркировка;

				Иначе
					ЗаписатьВЛог("АДРЕС","Не найден документ по ГУИД "+Строка(Гдок.ГУИД),"Ошибка");
				КонецЕсли;
				
			КОнецЦикла;				   
			
			//получить ВСЮ НОМЕНКЛУТУРУ (по НОВЫМ документам) для проверки ее наличия в АДРЕСЕ
			ТЗКодовТовара= ПолучитьКодыНоменклатурыПоДокументам(НоваяТЗ);	
			
			НовМас       = Новый Массив;			
			//инфомация о новом товаре  таблица с КОДАМИ НОВОГО ТОВАРА 
			
			Если ТЗКодовТовара=Неопределено Тогда
				ТЗКодовТовара=Новый ТаблицаЗначений;
			КонецЕсли;
			
			НовМас.Добавить(ТЗКодовТовара);	
			
			//получим полную информацию о НОВЫХ документах
			
			Для Каждого СтрДок из НоваяТЗ Цикл				
				СтрДок.ДанныеДОк =  ВернутьДанныеПоРасходнойНакладной(СтрДок.Документ);		
			КОнецЦикла;	     
			
			//НоваяТЗ.ЗаполнитьЗначения("","Документ");
			НоваяТЗ.Колонки.Удалить("Документ");
			//инфомация о докумнетах
			НовМас.Добавить(НоваяТЗ);
			
			ЗаписатьВЛог("АДРЕС","КОНЕЦ ОБМЕНА РНК "+Строка(ТекущаяДата()),"Информация"); 
			
			Возврат ЗначениеВХранилище(НовМас);  		
			
		КонецЕсли;     
		
	ИначеЕсли ВидДок = "ПриходнаяНакладная" Тогда
	     ЗаписатьВЛог("АДРЕС","НАЧАЛО ОБМЕНА ПНК "+Строка(ТекущаяДата()),"Информация");	
		
		Если ТЗГУИД.Количество()=0 Тогда  		
						
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	ОстаткиТМЦОстаткиИОбороты.Регистратор КАК Док
			|ПОМЕСТИТЬ ВсеДок
			|ИЗ
			|	РегистрНакопления.ОстаткиТМЦ.ОстаткиИОбороты(&Начвремя, &Конвремя, Регистратор, , Склад В (&Склады)) КАК ОстаткиТМЦОстаткиИОбороты
			|ГДЕ
			|	ОстаткиТМЦОстаткиИОбороты.Регистратор ССЫЛКА Документ.ПриходнаяНакладная
			|
			|СГРУППИРОВАТЬ ПО
			|	ОстаткиТМЦОстаткиИОбороты.Регистратор
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВсеДок.Док)) КАК ГУИД
			|ИЗ
			|	ВсеДок КАК ВсеДок";  
			
			//Параметры запроса
			Запрос.УстановитьПараметр("НачВремя",      НачВремя);// Дата 
			Запрос.УстановитьПараметр("КонВремя",      КонВремя);// Дата
			
			//Параметр список 'Склад'
			Склады = Новый СписокЗначений;
			Склады.Добавить(Справочники.Склады.НайтиПоКоду("STA-48")); // <Склады>[Склад Часцы (Основной)],
			Склады.Добавить(Справочники.Склады.НайтиПоКоду("STD-95")); // <Склады>[Маркировка Склад Часцы (Основной)]  
			Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-37")); // <Склады>[Маркировка Склад Часцы (Вычерки)]  
			Склады.Добавить(Справочники.Склады.НайтиПоКоду("STЕ-38")); // <Склады>[Склад Часцы (Вычерки)]
			
			Запрос.УстановитьПараметр("Склады",Склады );// Список значений
            							
			Результат = Запрос.Выполнить().Выгрузить();  			      
			
			Возврат ЗначениеВХранилище(Результат);       
			
		Иначе
			
			//есть НЕОБРАБОТАННЫЕ документы 
			
			НоваяТЗ = Новый ТаблицаЗначений;
			НоваяТЗ.Колонки.Добавить("Документ",  Новый ОписаниеТипов("ДокументСсылка.ПриходнаяНакладная"));
			НоваяТЗ.Колонки.Добавить("ГУИД",      Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36)));
			НоваяТЗ.Колонки.Добавить("ДанныеДОк", Новый ОписаниеТипов("ТаблицаЗначений"));
			НоваяТЗ.Колонки.Добавить("ЛистыНабора",Новый ОписаниеТипов("ТаблицаЗначений"));			
			НоваяТЗ.Колонки.Добавить("Номер");
			НоваяТЗ.Колонки.Добавить("Дата");
			НоваяТЗ.Колонки.Добавить("ДатаОтгрузки");
			НоваяТЗ.Колонки.Добавить("ТребуетсяМаркировка");
			
			
			Для Каждого Гдок из ТЗГУИД Цикл 
				
				ТекДок = Документы.ПриходнаяНакладная.ПолучитьСсылку(Новый УникальныйИдентификатор(Гдок.ГУИД));
				
				Если Найти(Строка(ТекДок),"Объект не найден")=0 Тогда 				
					СтрТЗ                     = НоваяТЗ.Добавить();
					СтрТЗ.Документ            = ТекДок; 
					СтрТЗ.ГУИД                = Гдок.ГУИД;
					СтрТЗ.Номер               = ТекДок.Номер;
					СтрТЗ.Дата                = ТекДок.Дата;
					СтрТЗ.ДатаОтгрузки        = ТекДок.ДатаОтгрузки;
					СтрТЗ.ТребуетсяМаркировка = ТекДок.ТребуетсяМаркировка;

				Иначе
					ЗаписатьВЛог("АДРЕС","Не найден документ по ГУИД "+Строка(Гдок.ГУИД),"Ошибка");
				КонецЕсли;
				
			КОнецЦикла;				   
			
			//получить ВСЮ НОМЕНКЛУТУРУ (по НОВЫМ документам) для проверки ее наличия в АДРЕСЕ
			ТЗКодовТовара= ПолучитьКодыНоменклатурыПоПНК(НоваяТЗ);	
			
			НовМас       = Новый Массив;			
			//инфомация о новом товаре  таблица с КОДАМИ НОВОГО ТОВАРА 
			
			Если ТЗКодовТовара=Неопределено Тогда
				ТЗКодовТовара=Новый ТаблицаЗначений;
			КонецЕсли;
			
			НовМас.Добавить(ТЗКодовТовара);	
			
			//получим полную информацию о НОВЫХ документах
			
			Для Каждого СтрДок из НоваяТЗ Цикл				
				СтрДок.ДанныеДОк   =  ВернутьДанныеПоПриходнойНакладной(СтрДок.Документ);	
				СтрДок.ЛистыНабора =  ПолучитьЛНпоПриходнойНакладной(СтрДок.Документ);
			КОнецЦикла;	     
			
			//НоваяТЗ.ЗаполнитьЗначения("","Документ");
			НоваяТЗ.Колонки.Удалить("Документ");
			//инфомация о докумнетах
			НовМас.Добавить(НоваяТЗ);   // это документ ОФФ:Приходная накладная !!!
						
			ЗаписатьВЛог("АДРЕС","КОНЕЦ ОБМЕНА ПНК "+Строка(ТекущаяДата()),"Информация"); 
			
			Возврат ЗначениеВХранилище(НовМас);     		
			
		КонецЕсли;	                                
		
		
	КонецЕсли;                      	
	
КонецФункции      

Функция ПолучитьЛНпоПриходнойНакладной(Док)
	

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПРЕДСТАВЛЕНИЕ(ЛистНабораТовары.Ссылка) КАК Описание,
	               |	ЛистНабораТовары.Ссылка.Номер КАК Номер,
	               |	ЛистНабораТовары.Ссылка.Дата КАК Дата,
	               |	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ЛистНабораТовары.Ссылка) КАК ГУИД,
	               |	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ЛистНабораТовары.Ссылка.ДокОснование) КАК ГУИДОснование,
	               |	ПРЕДСТАВЛЕНИЕ(ЛистНабораТовары.Ссылка.ДокОснование) КАК ОписаниеДокОснования,
	               |	ЛистНабораТовары.Номенклатура.Код КАК Код,
	               |	ЛистНабораТовары.Количество КАК Количество,
	               |	ПРЕДСТАВЛЕНИЕ(ЛистНабораТовары.ТипШК) КАК ТипШК,
	               |	ЛистНабораТовары.ШК КАК ШК,
	               |	ЛистНабораТовары.ШтВКоробе КАК ШтВКоробе,
	               |	ЛистНабораТовары.ЭтоНекондиция КАК ЭтоНекондиция,
	               |	ЛистНабораТовары.ЭтоБрак КАК ЭтоБрак
	               |ИЗ
	               |	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	               |ГДЕ
	               |	ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
	               |	И ЛистНабораТовары.Ссылка.Проведен
	               |	И ЛистНабораТовары.Количество > 0";
	//Параметры запроса
	Запрос.УстановитьПараметр("ДокОснование",Док);// ПНК
	Результат = Запрос.Выполнить().Выгрузить();

	Возврат Результат;

КонецФункции 

Функция ВернутьДанныеПоРасходнойНакладной(Док) 
	
	Если Док.ОтгрузкаКомплектов Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладнаяКомплектующие.Номенклатура.Код КАК Код,
		|	РасходнаяНакладнаяКомплектующие.Количество КАК Количество,
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходнаяНакладнаяКомплектующие.Номенклатура)) КАК GUID
		|ИЗ
		|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		|ГДЕ
		|	РасходнаяНакладнаяКомплектующие.Количество > 0
		|	И РасходнаяНакладнаяКомплектующие.Ссылка = &Ссылка"; 
		
		Запрос.УстановитьПараметр("Ссылка", Док);// ссылка на документ  
		
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладнаяТовары.Номенклатура.Код КАК Код,
		|	РасходнаяНакладнаяТовары.Количество КАК Количество,
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходнаяНакладнаяТовары.Номенклатура)) КАК GUID
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
		|ГДЕ
		|	РасходнаяНакладнаяТовары.Количество > 0
		|	И РасходнаяНакладнаяТовары.Ссылка = &Ссылка"; 
		
		Запрос.УстановитьПараметр("Ссылка", Док);// ссылка на документ  
		
	КонецЕсли;
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса; 
	
КонецФункции    

Функция ВернутьДанныеПоПриходнойНакладной(Док)
	  		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходнаяНакладнаяТовары.Номенклатура.Код КАК Код,
		|	ПриходнаяНакладнаяТовары.Количество КАК Количество
		|ИЗ
		|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
		|ГДЕ
		|	ПриходнаяНакладнаяТовары.Количество > 0
		|	И ПриходнаяНакладнаяТовары.Ссылка = &Ссылка"; 
	
	Запрос.УстановитьПараметр("Ссылка", Док);// ссылка на документ
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса; 
	
КонецФункции

Функция ПолучитьКодыНоменклатурыПоДокументам(НужныеДок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗДОК.Документ КАК Ссылка
	               |ПОМЕСТИТЬ НужныеДок
	               |ИЗ
	               |	&НужныеДок КАК ТЗДОК
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВложенныйЗапрос.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ИтогТовар
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура
	               |	ИЗ
	               |		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	               |	ГДЕ
	               |		РасходнаяНакладнаяТовары.Ссылка В
	               |				(ВЫБРАТЬ
	               |					НужныеДок.Ссылка КАК Ссылка
	               |				ИЗ
	               |					НужныеДок КАК НужныеДок)
	               |		И РасходнаяНакладнаяТовары.Количество > 0
	               |		И НЕ РасходнаяНакладнаяТовары.Ссылка.ОтгрузкаКомплектов
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		РасходнаяНакладнаяТовары.Номенклатура
	               |	ИЗ
	               |		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	               |	ГДЕ
	               |		РасходнаяНакладнаяТовары.Ссылка В
	               |				(ВЫБРАТЬ
	               |					НужныеДок.Ссылка КАК Ссылка
	               |				ИЗ
	               |					НужныеДок КАК НужныеДок)
	               |		И РасходнаяНакладнаяТовары.Количество > 0
	               |		И РасходнаяНакладнаяТовары.Ссылка.ОтгрузкаКомплектов) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВложенныйЗапрос.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ИтогТовар.Номенклатура)) КАК GUID,
	               |	ИтогТовар.Номенклатура.Код КАК Код
	               |ИЗ
	               |	ИтогТовар КАК ИтогТовар";
	//Параметры запроса

	Запрос.УстановитьПараметр("НужныеДок", НужныеДок);// Дата

	Результат = Запрос.Выполнить().Выгрузить();

	Возврат Результат;

КонецФункции         


Функция ПолучитьКодыНоменклатурыПоПНК(НужныеДок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТЗДОК.Документ КАК Ссылка
	|ПОМЕСТИТЬ НужныеДок
	|ИЗ
	|	&НужныеДок КАК ТЗДОК
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ИтогТовар
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	ПриходнаяНакладнаяТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				НужныеДок.Ссылка КАК Ссылка
	|			ИЗ
	|				НужныеДок КАК НужныеДок)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриходнаяНакладнаяТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ИтогТовар.Номенклатура)) КАК GUID,
	|	ИтогТовар.Номенклатура.Код КАК Код
	|ИЗ
	|	ИтогТовар КАК ИтогТовар";
	//Параметры запроса

	Запрос.УстановитьПараметр("НужныеДок", НужныеДок);// Дата

	Результат = Запрос.Выполнить().Выгрузить();

	Возврат Результат;

КонецФункции 


