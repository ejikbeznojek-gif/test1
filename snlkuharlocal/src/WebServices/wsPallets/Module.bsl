Функция dataSheets(DateString,ЛистЗагрузкиУИД, filterData, barcode)
	Если  НЕ barcode = "" Тогда
		ШК = barcode;
		Если СтрДлина(ШК)=13 Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЛистНабора.ДокОснование КАК ДокОснование
			|ИЗ
			|	Документ.ЛистНабора КАК ЛистНабора
			|ГДЕ
			|	ЛистНабора.ШКЛистаНабора = &ШКЛистаНабора";
			
			Запрос.УстановитьПараметр("ШКЛистаНабора", Лев(ШК,7));
			
			РезультатЗапроса = Запрос.Выполнить();
			Если Не РезультатЗапроса.Пустой() Тогда
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				ВыборкаДетальныеЗаписи.Следующий();
				ДокОснование= ВыборкаДетальныеЗаписи.ДокОснование;
			КонецЕсли;
			Если ТипЗнч(ДокОснование)=Тип("ДокументСсылка.Перемещение") Тогда
				filterData = "ПРМ";
				ДатаОтгрузки = ДокОснование.ДатаОтгрузки;
				СкладПолучатель = ДокОснование.СкладПолучатель;
				ПунктДоставки = ?(ДокОснование.ТипДоставки = Перечисления.ТипыДоставки.ТранспортнаяКомпания,ДокОснование.ПунктПерегруза,ДокОснование.ПунктДоставки);
			Иначе		
				filterData = "РНК";
