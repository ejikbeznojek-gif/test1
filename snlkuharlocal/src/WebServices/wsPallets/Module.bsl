Функция getTypesOfWork(ИДУстройства)
	Новый_UID  = Новый УникальныйИдентификатор(ИДУстройства);
	// пытаемся получить объект по UID
	НоваяСсылка = Справочники.Оборудование.ПолучитьСсылку(Новый_UID);
	// пытаемся получить объект
	ТСД = НоваяСсылка.ПолучитьОбъект();
	// проверяем есть ли объект
	Если ТСД = Неопределено Тогда
		НовыйТСД = Справочники. Оборудование.СоздатьЭлемент();
		// для нового объекта – еще не записанного мы можем присвоить UID
		НовыйТСД.УстановитьСсылкуНового(НоваяСсылка);
		// говорим программе что это загрузка объекта
		НовыйТСД.ОбменДанными.Загрузка = Истина;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(Оборудование.Номер), 0) КАК Номер
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.ТипОборудования = &ТипОборудования";
		Запрос.УстановитьПараметр("ТипОборудования", Перечисления.ТипыОборудования.ТСД);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НовыйНомер = 1;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			НовыйНомер = ВыборкаДетальныеЗаписи.Номер + 1;
		КонецЕсли;
		НовыйТСД.Номер = НовыйНомер;
		НовыйТСД.ТипОборудования = Перечисления.ТипыОборудования.ТСД;
		НовыйТСД.Наименование = "" + Перечисления.ТипыОборудования.ТСД + " № " + НовыйНомер;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Оборудование.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.Наименование = &Наименование
		|	И Оборудование.ЭтоГруппа";
		
		Запрос.УстановитьПараметр("Наименование", Строка(Перечисления.ТипыОборудования.ТСД));
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НоваяГруппа = Справочники.Оборудование.СоздатьГруппу();
			НоваяГруппа.Наименование = Строка(Перечисления.ТипыОборудования.ТСД);
			НоваяГруппа.Записать();
			Родитель = НоваяГруппа.Ссылка;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			Родитель = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
		НовыйТСД.Родитель = Родитель;
		НовыйТСД.Записать();
		ТСД = НовыйТСД.Ссылка;
	КонецЕсли;
	тзВидыВыполняемыхРабот = ВидыВыполняемыхРабот();
	СтруктураОтвета = Новый Структура("НомерТСД, тзВидыВыполняемыхРабот",ТСД.Номер,тзВидыВыполняемыхРабот);
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураОтвета), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

