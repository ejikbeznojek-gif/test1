Функция getBarcode(ИДУстройства)
	Новый_UID  = Новый УникальныйИдентификатор(ИДУстройства);
	// пытаемся получить объект по UID
	НоваяСсылка = Справочники.Оборудование.ПолучитьСсылку(Новый_UID);
	// пытаемся получить объект
	ТСД = НоваяСсылка.ПолучитьОбъект();
	// проверяем есть ли объект
	Если ТСД = Неопределено Тогда
		НовыйТСД = Справочники. Оборудование.СоздатьЭлемент();
		// для нового объекта – еще не записанного мы можем присвоить UID
		НовыйТСД.УстановитьСсылкуНового(НоваяСсылка);
		// говорим программе что это загрузка объекта
		НовыйТСД.ОбменДанными.Загрузка = Истина;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(Оборудование.Номер), 0) КАК Номер
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.ТипОборудования = &ТипОборудования";
		Запрос.УстановитьПараметр("ТипОборудования", Перечисления.ТипыОборудования.ТСД);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НовыйНомер = 1;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			НовыйНомер = ВыборкаДетальныеЗаписи.Номер + 1;
		КонецЕсли;
		НовыйТСД.Номер = НовыйНомер;
		НовыйТСД.ТипОборудования = Перечисления.ТипыОборудования.ТСД;
		НовыйТСД.Наименование = "" + Перечисления.ТипыОборудования.ТСД + " № " + НовыйНомер;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Оборудование.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.Наименование = &Наименование
		|	И Оборудование.ЭтоГруппа";
		
		Запрос.УстановитьПараметр("Наименование", Строка(Перечисления.ТипыОборудования.ТСД));
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НоваяГруппа = Справочники.Оборудование.СоздатьГруппу();
			НоваяГруппа.Наименование = Строка(Перечисления.ТипыОборудования.ТСД);
			НоваяГруппа.Записать();
			Родитель = НоваяГруппа.Ссылка;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			Родитель = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
		НовыйТСД.Родитель = Родитель;
		НовыйТСД.Записать();
		ТСД = НовыйТСД.Ссылка;
	Иначе 
		ТСД = ТСД.Ссылка;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладТСД.Ссылка КАК Ссылка
	|ИЗ
	|	ПланОбмена.СкладТСД КАК СкладТСД
	|ГДЕ
	|	СкладТСД.ТСД = &ТСД";
	
	Запрос.УстановитьПараметр("ТСД", ТСД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		НовыйУзел = ПланыОбмена.СкладТСД.СоздатьУзел();	
		НовыйУзел.УстановитьНовыйКод();
		НовыйУзел.Наименование = Строка(ТСД);
		НовыйУзел.ТСД = ТСД;
		НовыйУзел.Записать();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОстаткиТМЦОбороты.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Обороты(ДАТАВРЕМЯ(2020, 1, 1), , , ) КАК ОстаткиТМЦОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихКоды.Ссылка КАК ШК,
	|	ШтрихКоды.Наименование КАК ШКНаименование,
	|	ШтрихКоды.ТипШК КАК ТипШК,
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ШтрихКоды.Владелец.Код КАК НоменклатураКод,
	|	ШтрихКоды.Владелец.Наименование КАК НоменклатураНаименование,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	ШтрихКоды.Владелец.Родитель.ШтукВКоробочке КАК ШтукВКоробочке
	|ИЗ
	|	втТовары КАК втТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
	|		ПО втТовары.Номенклатура = ШтрихКоды.Владелец
	|ГДЕ
	|	НЕ ШтрихКоды.ПометкаУдаления
	|	И НЕ втТовары.Номенклатура.ПометкаУдаления
	|	И НЕ ПОДСТРОКА(ШтрихКоды.Наименование, 1, 4) = ""9999""
	|	И НЕ ПОДСТРОКА(ШтрихКоды.Наименование, 1, 4) = ""0000""
	|	И НЕ ШтрихКоды.Ссылка.Владелец В ИЕРАРХИИ (&СписокИсключений)";
	СписокИсключений = Новый СписокЗначений;
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-063490")); // Реклама
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-095760")); // Сертификаты
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-377816")); // Упаковка GLD
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-165492")); // Подарочные коробки
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-144268")); // Платная реклама
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-144143")); // Основные средства
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-095142")); // Оборудование
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-266341")); // Упаковка/Этикетки из КИТАЯ
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-539031")); // Упаковка/Этикетки из УЗБЕКИСТАН
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-309252")); // Франчайзинг
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-005211")); // Я - Архив
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-303453")); // Я - Номенклатура внешних клиентов
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-353622")); // Я - Номенклатура комиссионеров
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-000066")); // Я - Номенклатура на отвественном хранении
	СписокИсключений.Добавить(Справочники.Номенклатура.НайтиПоКоду("SNL-436258")); // Я-оформление документов
	Запрос.УстановитьПараметр("СписокИсключений",СписокИсключений);
	
	тзШтрихкоды = Запрос.Выполнить().Выгрузить();
	тзШтрихкоды.Колонки.Добавить("ШтрихКодыУИД",Новый ОписаниеТипов("УникальныйИдентификатор"));
	тзШтрихкоды.Колонки.Добавить("НоменклатураУИД",Новый ОписаниеТипов("УникальныйИдентификатор"));
	
	Для каждого Строка Из тзШтрихкоды Цикл
		Строка.ШтрихКодыУИД = Строка.ШК.УникальныйИдентификатор();	
		Строка.НоменклатураУИД = Строка.Номенклатура.УникальныйИдентификатор();	
	КонецЦикла;
	тзШтрихкоды.Колонки.Удалить(тзШтрихкоды.Колонки.Найти("ШК"));
	тзШтрихкоды.Колонки.Удалить(тзШтрихкоды.Колонки.Найти("Номенклатура"));
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

