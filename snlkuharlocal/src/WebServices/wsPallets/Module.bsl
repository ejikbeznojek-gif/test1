Функция РаботникиСклада()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ФизическиеЛица.Код КАК Код,
	|	ФизическиеЛица.Ссылка КАК Ссылка,
	|	""012345678901234567890123456789123456"" КАК УИД,
	|	ФизическиеЛица.ШтрихКод КАК ШтрихКод,
	|	ФизическиеЛица.Фамилия КАК Фамилия,
	|	ФизическиеЛица.Имя КАК Имя,
	|	ФизическиеЛица.Отчество КАК Отчество
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	НЕ ФизическиеЛица.ЭтоГруппа
	|	И НЕ ФизическиеЛица.ПометкаУдаления
	// Кельманов А.В. - HELP-8333 - 2025.12.23 {
	//|	И ФизическиеЛица.Ссылка В ИЕРАРХИИ(&Подразделение)
	|	И (ФизическиеЛица.Ссылка В ИЕРАРХИИ (&Логистика)
	|			ИЛИ ФизическиеЛица.Ссылка В ИЕРАРХИИ (&СкладЧасцы)
	|			ИЛИ ФизическиеЛица.Ссылка В ИЕРАРХИИ (&Аутсорсинг))
	// Кельманов А.В. - HELP-8333 - 2025.12.23 }
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	// Кельманов А.В. - HELP-8333 - 2025.12.23 {
	//Запрос.УстановитьПараметр("Подразделение", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00850")); // Физические лица
	Запрос.УстановитьПараметр("Логистика", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00850")); 
	Запрос.УстановитьПараметр("Аутсорсинг", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-09056"));
	Запрос.УстановитьПараметр("СкладЧасцы", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-09136"));
	// Кельманов А.В. - HELP-8333 - 2025.12.23 }

	Результат = Запрос.Выполнить();
	тз = Результат.Выгрузить();
	Для каждого Строка Из Тз Цикл
		Строка.УИД = Строка.Ссылка.УникальныйИдентификатор();	
	КонецЦикла;
	Возврат тз;
	
КонецФункции

