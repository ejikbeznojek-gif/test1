						НоваяСтрокаШК.ШК = Строка.ШК;
						НоваяСтрокаШК.ТипШК = Строка.ТипШК;
						Если НачалоСканирования > Строка.ВремяСканирования Тогда
							НачалоСканирования = Строка.ВремяСканирования	
						КонецЕсли;
						Если ОкончаниеСканирования < Строка.ВремяСканирования Тогда
							ОкончаниеСканирования = Строка.ВремяСканирования	
						КонецЕсли;
					КонецЦикла;
					МенВрТаб = Новый МенеджерВременныхТаблиц;
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	тзШК.НомерСтроки КАК НомерСтроки,
					|	тзШК.ШК КАК ШК,
					|	тзШК.ТипШК КАК ТипШК
					|ПОМЕСТИТЬ втШК
					|ИЗ
					|	&тзШК КАК тзШК";
					Запрос.УстановитьПараметр("тзШК",тзШК);
					
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст =  
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	втШК.НомерСтроки КАК НомерСтроки,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.Ссылка ЕСТЬ NULL
					|			ТОГДА ИСТИНА
					|		ИНАЧЕ ЛОЖЬ
					|	КОНЕЦ КАК Маркировка,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.Ссылка ЕСТЬ NULL
					|			ТОГДА ШтрихкодыУпаковокТоваров.ТипШК
					|		ИНАЧЕ ШтрихКоды.ТипШК
					|	КОНЕЦ КАК ТипШК,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.Ссылка ЕСТЬ NULL
					|			ТОГДА ШтрихкодыУпаковокТоваров.Наименование
					|		ИНАЧЕ ШтрихКоды.Наименование
					|	КОНЕЦ КАК ШК,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.Ссылка ЕСТЬ NULL
					|			ТОГДА ШтрихкодыУпаковокТоваров.Владелец
					|		ИНАЧЕ ШтрихКоды.Владелец
					|	КОНЕЦ КАК Номенклатура,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.Ссылка ЕСТЬ NULL
					|			ТОГДА ШтрихкодыУпаковокТоваров.Количество
					|		ИНАЧЕ ВЫБОР
					|				КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
					|					ТОГДА ВЫБОР
					|							КОГДА ШтрихКоды.ШтВКоробе = 0
					|								ТОГДА Номенклатура.ШтукВКоробке
					|							ИНАЧЕ ШтрихКоды.ШтВКоробе
					|						КОНЕЦ
					|				КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
					|					ТОГДА Номенклатура.ШтукВКоробочке
					|				ИНАЧЕ 1
					|			КОНЕЦ
					|	КОНЕЦ КАК ШтукВКоробке,
					|	1 КАК Количество
					|ПОМЕСТИТЬ втДанные
					|ИЗ
					|	втШК КАК втШК
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
					|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
					|			ПО ШтрихКоды.Владелец.Родитель = Номенклатура.Ссылка
					|		ПО втШК.ШК = ШтрихКоды.Наименование
					|			И втШК.ТипШК = ШтрихКоды.ТипШК
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
					|		ПО втШК.ШК = ШтрихкодыУпаковокТоваров.Наименование
					|			И втШК.ТипШК = ШтрихкодыУпаковокТоваров.ТипШК
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	втДанные.Маркировка КАК Маркировка,
					|	втДанные.Номенклатура КАК Номенклатура,
					|	втДанные.ТипШК КАК ТипШК,
					|	ВЫБОР
					|		КОГДА втДанные.Маркировка
					|			ТОГДА """"
					|		ИНАЧЕ втДанные.ШК
					|	КОНЕЦ КАК ШК,
					|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втДанные.НомерСтроки) КАК Количество,
					|	втДанные.ШтукВКоробке КАК ШтукВКоробке
					|ПОМЕСТИТЬ Данные
					|ИЗ
					|	втДанные КАК втДанные
					|
					|СГРУППИРОВАТЬ ПО
					|	втДанные.Маркировка,
					|	втДанные.ТипШК,
					|	ВЫБОР
					|		КОГДА втДанные.Маркировка
					|			ТОГДА """"
					|		ИНАЧЕ втДанные.ШК
					|	КОНЕЦ,
					|	втДанные.Номенклатура,
					|	втДанные.ШтукВКоробке
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	Данные.Маркировка КАК Маркировка,
					|	Данные.Номенклатура КАК Номенклатура,
					|	Данные.ТипШК КАК ТипШК,
					|	Данные.ШК КАК ШК,
					|	Данные.Количество КАК Количество,
					|	Данные.ШтукВКоробке КАК ШтукВКоробке,
					|	втДанные.НомерСтроки КАК НомерСтроки
					|ПОМЕСТИТЬ втНомераКоробок
					|ИЗ
					|	Данные КАК Данные
					|		ЛЕВОЕ СОЕДИНЕНИЕ втДанные КАК втДанные
					|		ПО Данные.Маркировка = втДанные.Маркировка
					|			И Данные.Номенклатура = втДанные.Номенклатура
					|			И Данные.ТипШК = втДанные.ТипШК
					|			И Данные.ШтукВКоробке = втДанные.ШтукВКоробке";
					
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	втНомераКоробок.Маркировка КАК Маркировка,
					|	втНомераКоробок.Номенклатура КАК Номенклатура,
					|	втНомераКоробок.ТипШК КАК ТипШК,
					|	втНомераКоробок.ШК КАК ШК,
					|	втНомераКоробок.Количество КАК Количество,
					|	втНомераКоробок.ШтукВКоробке КАК ШтукВКоробке,
					|	втНомераКоробок.НомерСтроки КАК НомерСтроки
					|ИЗ
					|	втНомераКоробок КАК втНомераКоробок
					|ИТОГИ ПО
					|	Маркировка,
					|	Номенклатура,
					|	ТипШК,
					|	ШтукВКоробке,
					|	Количество,
					|	ШК";
					
					РезультатЗапроса = Запрос.Выполнить();

					тзПорядковыхНомеров = Новый ТаблицаЗначений;
					тзПорядковыхНомеров.Колонки.Добавить("Маркировка",Новый ОписаниеТипов("Булево"));
					тзПорядковыхНомеров.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
					тзПорядковыхНомеров.Колонки.Добавить("ТипШК",Новый ОписаниеТипов("ПеречислениеСсылка.ТипыШтрихКодов"));
					тзПорядковыхНомеров.Колонки.Добавить("ШтукВКоробке",Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
					тзПорядковыхНомеров.Колонки.Добавить("Количество",Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
					
					тзПорядковыхНомеров.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(220, ДопустимаяДлина.Переменная)));
					тзПорядковыхНомеров.Колонки.Добавить("ПорядковыйНомерКоробки",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(1000, ДопустимаяДлина.Переменная)));
					ВыборкаМаркировка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаМаркировка.Следующий() Цикл
						ВыборкаНоменклатура = ВыборкаМаркировка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаНоменклатура.Следующий() Цикл
							ВыборкаТипШК = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
							Пока ВыборкаТипШК.Следующий() Цикл
								ВыборкаШтукВКоробке = ВыборкаТипШК.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
								Пока ВыборкаШтукВКоробке.Следующий() Цикл
									ВыборкаКоличество = ВыборкаШтукВКоробке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
									Пока ВыборкаКоличество.Следующий() Цикл
										ВыборкаШК = ВыборкаКоличество.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
										Пока ВыборкаШК.Следующий() Цикл
											ВыборкаНомеров = ВыборкаШК.Выбрать();
											ПорядковыйНомерКоробки = "";
											Пока ВыборкаНомеров.Следующий() Цикл
												ПорядковыйНомерКоробки = ПорядковыйНомерКоробки + ВыборкаНомеров.НомерСтроки+";";
											КонецЦикла;
											НоваяСтрока = тзПорядковыхНомеров.Добавить();
											НоваяСтрока.Маркировка = ВыборкаШК.Маркировка;
											НоваяСтрока.Номенклатура = ВыборкаШК.Номенклатура;
											НоваяСтрока.ТипШК = ВыборкаШК.ТипШК;
											НоваяСтрока.ШтукВКоробке = ВыборкаШК.ШтукВКоробке;
											НоваяСтрока.Количество = ВыборкаШК.Количество;
											НоваяСтрока.ШК = ВыборкаШК.ШК;
											НоваяСтрока.ПорядковыйНомерКоробки = ПорядковыйНомерКоробки;
										КонецЦикла;
									КонецЦикла;
								КонецЦикла;
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	тзПорядковыхНомеров.Маркировка КАК Маркировка,
					|	тзПорядковыхНомеров.Номенклатура КАК Номенклатура,
					|	тзПорядковыхНомеров.ТипШК КАК ТипШК,
					|	тзПорядковыхНомеров.ШтукВКоробке КАК ШтукВКоробке,
					|	тзПорядковыхНомеров.Количество КАК Количество,
					|	тзПорядковыхНомеров.ШК КАК ШК,
					|	тзПорядковыхНомеров.ПорядковыйНомерКоробки КАК ПорядковыйНомерКоробки
					|ПОМЕСТИТЬ втПорядковыеНомера
					|ИЗ
					|	&тзПорядковыхНомеров КАК тзПорядковыхНомеров";
					
					Запрос.УстановитьПараметр("тзПорядковыхНомеров",тзПорядковыхНомеров);
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ Различные
					|	втДанные.Маркировка КАК Маркировка,
					|	втДанные.ТипШК КАК ТипШК,
					|	втДанные.ШК КАК ШК,
					|	втДанные.Номенклатура КАК Номенклатура,
					|	втДанные.Количество КАК КоличествоКоробок,
					|	втДанные.ШтукВКоробке КАК ШтукВКоробке,
					|	втПорядковыеНомера.ПорядковыйНомерКоробки КАК ПорядковыйНомерКоробки
					|ИЗ
					|	Данные КАК втДанные
					|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядковыеНомера КАК втПорядковыеНомера
					|		ПО втДанные.Маркировка = втПорядковыеНомера.Маркировка
					|		И втДанные.ТипШК = втПорядковыеНомера.ТипШК
					|		И втДанные.Номенклатура = втПорядковыеНомера.Номенклатура
					|		И втДанные.Количество = втПорядковыеНомера.Количество
					|		И втДанные.ШтукВКоробке = втПорядковыеНомера.ШтукВКоробке
					|		И втДанные.ШК = втПорядковыеНомера.ШК
					|";
					
					Запрос.УстановитьПараметр("тзПорядковыхНомеров",тзПорядковыхНомеров);
					РезультатЗапроса = Запрос.Выполнить();
					тзСоставЛН = РезультатЗапроса.Выгрузить();
					КоличествоКоробок = 0;
					Для каждого Строка Из тзСоставЛН Цикл
						НоваяСтрока = ЛистНабораОбъект.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
						НоваяСтрока.Количество = Строка.КоличествоКоробок * Строка.ШтукВКоробке;
						НоваяСтрока.ШтВКоробе = Строка.ШтукВКоробке;
						НоваяСтрока.ТипШК = Строка.ТипШК;
						НоваяСтрока.Единица = Строка.Номенклатура.ОсновнаяЕдиница;
						НоваяСтрока.Коэффициент = Строка.Номенклатура.ОсновнаяЕдиница.Коэффициент;
						НоваяСтрока.Объем = Строка.Номенклатура.Родитель.ОбъемКоробки *Строка.КоличествоКоробок;
						КоличествоКоробок = КоличествоКоробок + Строка.КоличествоКоробок;
					КонецЦикла;
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	втДанные.Маркировка КАК Маркировка,
					|	втДанные.ТипШК КАК ТипШК,
					|	втДанные.ШК КАК ШК,
					|	втДанные.Номенклатура КАК Номенклатура,
					|	втДанные.Количество КАК КоличествоКоробок,
					|	втДанные.ШтукВКоробке КАК ШтукВКоробке,
					|	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихкодУпаковки
					|ИЗ
					|	втДанные КАК втДанные
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
					|		ПО втДанные.ШК = ШтрихкодыУпаковокТоваров.Наименование
					|ГДЕ
					|	втДанные.Маркировка";
					
					РезультатЗапроса = Запрос.Выполнить();
					тзСоставЛН = РезультатЗапроса.Выгрузить();
					Для каждого Строка Из тзСоставЛН Цикл
						НоваяСтрока = ЛистНабораОбъект.ШтрихкодыУпаковок.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
						НоваяСтрока.Количество = Строка.КоличествоКоробок * Строка.ШтукВКоробке;
						НоваяСтрока.ШтрихкодУпаковки = Строка.ШтрихкодУпаковки;
					КонецЦикла;
					ЛистНабораОбъект.КоличествоКоробок = КоличествоКоробок;
					ЛистНабораОбъект.Записать(РежимЗаписиДокумента.Запись);
					ЛистНабораОбъект.Записать(РежимЗаписиДокумента.Проведение);
					МассивПроведенныхЛН.Добавить(Новый_UID);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	СтруктураОтвета = Новый Структура("МассивПеренесенныхЛН,МассивОшибок",МассивПроведенныхЛН,МассивОшибок);
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураОтвета), Новый СжатиеДанных(9))); 
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();

	Возврат  Ответ;
КонецФункции


Функция getStampControl(ШК)
	//Если ШК = "" Тогда
