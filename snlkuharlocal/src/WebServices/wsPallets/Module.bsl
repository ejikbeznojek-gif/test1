					НоваяСтрокаСостава.ЛН_УИД = ЛН.ЛН_УИД;
					х=0;
				КонецЦикла;	
			КонецЦикла;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	тзШК.ЛН_УИД КАК ЛН_УИД,
			|	тзШК.ШК КАК ШК,
			|	тзШК.ТипШК КАК ТипШК
			|ПОМЕСТИТЬ втШК
			|ИЗ
			|	&тзШК КАК тзШК
