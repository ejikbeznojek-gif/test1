Функция Бинарное(НачЗн)
	Зн=НачЗн;	
	Стр="";	
	Для Сч=1 по 8 Цикл
		Бит=Зн%2;
		
		Стр=""+Бит+Стр;   
		Зн=(Зн-Бит)/2;		
	КонецЦикла;     
	
	Возврат Стр;
КонецФункции 

Функция Десятичное(НачЗн)
	Зн=0;
	База=128;
	
	ТекДлинна=Мин(СтрДлина(НачЗн),8);
	
	Для Сч=1 по ТекДлинна Цикл
		Зн=Зн+База*Число(Сред(НачЗн,Сч,1));					    
		База=База/2;
	КонецЦикла;
	
	Возврат Зн;
КонецФункции 

Функция Закодировать64(НачСтр) 
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=НачСтр;
	
	Остаток=СтрДлина(Стр) % 3;
	НеХватает=?(Остаток=0,0,3-Остаток); 
	
	Для Сч=1 по НеХватает Цикл
		Стр=Стр+" ";	    
	КонецЦикла;	
	
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		СтрокаБит=СтрокаБит+Бинарное(БайтовыйКодСимвола(Сред(Стр,Сч,1)));		
	КонецЦикла;
	
	СтрокаКода="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение="00"+Лев(СтрокаБит,6);
		
		СтрокаКода	=СтрокаКода+Сред(База,Десятичное(БитовоеЗначение)+1,1);			    
		СтрокаБит	=Сред(СтрокаБит,7);
	КонецЦикла;                                                      
	
	Возврат СтрокаКода;	
КонецФункции  

Функция Раскодировать64(НачСтр)  
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=СокрЛП(НачСтр);
	
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		Символ=Сред(Стр,Сч,1);
		Десятичное=Найти(База,Символ)-1;		
		СтрокаБит=СтрокаБит+Сред(Бинарное(Десятичное),3);		
	КонецЦикла;
	
	СтрокаИсходная="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение=Лев(СтрокаБит,8);
		
		СтрокаИсходная	=СтрокаИсходная+СимволпоБайтовомуКоду(Десятичное(БитовоеЗначение));			    
		СтрокаБит		=Сред(СтрокаБит,9);
	КонецЦикла;                      
	
	Возврат СтрокаИсходная;	    
КонецФункции 

Функция ИдПоВидуДокумента(Вид)
	Возврат Метаданные.Документы[Вид].Синоним;	
КонецФункции 

Функция СформироватьШКДока(Док) экспорт
	Если Док.Пустая() Тогда Возврат "" КонецЕсли;
	КодИсх="*"+ИдПоВидуДокумента(Док.Метаданные().Имя)+"*"+Док.Номер+"*"+Прав(""+Год(Док.Дата),2)+"*";		
	Возврат Закодировать64(КодИсх);
КонецФункции 

Функция officer(ИДУстройства)
	Новый_UID  = Новый УникальныйИдентификатор(ИДУстройства);
	// пытаемся получить объект по UID
	НоваяСсылка = Справочники.Оборудование.ПолучитьСсылку(Новый_UID);
	// пытаемся получить объект
	ТСД = НоваяСсылка.ПолучитьОбъект();
	// проверяем есть ли объект
	Если ТСД = Неопределено Тогда
		НовыйТСД = Справочники. Оборудование.СоздатьЭлемент();
		// для нового объекта – еще не записанного мы можем присвоить UID
		НовыйТСД.УстановитьСсылкуНового(НоваяСсылка);
		// говорим программе что это загрузка объекта
		НовыйТСД.ОбменДанными.Загрузка = Истина;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(Оборудование.Номер), 0) КАК Номер
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.ТипОборудования = &ТипОборудования";
		Запрос.УстановитьПараметр("ТипОборудования", Перечисления.ТипыОборудования.ТСД);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НовыйНомер = 1;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			НовыйНомер = ВыборкаДетальныеЗаписи.Номер + 1;
		КонецЕсли;
		НовыйТСД.Номер = НовыйНомер;
		НовыйТСД.ТипОборудования = Перечисления.ТипыОборудования.ТСД;
		НовыйТСД.Наименование = "" + Перечисления.ТипыОборудования.ТСД + " № " + НовыйНомер;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Оборудование.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.Наименование = &Наименование
		|	И Оборудование.ЭтоГруппа";
		
