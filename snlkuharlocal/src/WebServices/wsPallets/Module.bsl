Функция ЗоныХранения()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА ЗоныХранения.Родитель.Наименование ЕСТЬ NULL
	               |			ТОГДА 0
	               |		КОГДА ЗоныХранения.Родитель.Родитель.Наименование ЕСТЬ NULL
	               |			ТОГДА 1
	               |		КОГДА ЗоныХранения.Родитель.Родитель.Родитель.Наименование ЕСТЬ NULL
	               |			ТОГДА 2
	               |		КОГДА ЗоныХранения.Родитель.Родитель.Родитель.Родитель.Наименование ЕСТЬ NULL
	               |			ТОГДА 3
	               |		ИНАЧЕ 4
	               |	КОНЕЦ КАК Уровень,
	               |	ЗоныХранения.Ссылка КАК ЗонаХранения,
	               |	""012345678901234567890123456789123456"" КАК УИД,
	               |	ЗоныХранения.ЭтоГруппа КАК ЭтоГруппа,
	               |	ЗоныХранения.Родитель КАК Родитель,
	               |	""012345678901234567890123456789123456"" КАК РодительУИД,
	               |	ЗоныХранения.Код КАК Код,
	               |	ЗоныХранения.Наименование КАК Наименование,
	               |	ЗоныХранения.ШтрихКод КАК ШтрихКод
	               |ИЗ
	               |	Справочник.ЗоныХранения КАК ЗоныХранения
	               |ГДЕ
	               |	НЕ ЗоныХранения.ПометкаУдаления
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Уровень,
	               |	Наименование";
	//Параметры запроса
	Результат = Запрос.Выполнить();
	тз = Результат.Выгрузить();
	Для каждого Строка Из Тз Цикл
		Строка.УИД = Строка.ЗонаХранения.УникальныйИдентификатор();	
		Строка.РодительУИД = Строка.Родитель.УникальныйИдентификатор();	
	КонецЦикла;
	тз.Колонки.Удалить("ЗонаХранения");
	тз.Колонки.Удалить("Родитель");
	Возврат тз;
КонецФункции

Функция EXCELВТаблицуЗначений(ДвоичныеДанные, Расширение)
	
	ФайлEXCELНаСервере = ПолучитьИмяВременногоФайла(Расширение);
	ДвоичныеДанные.Записать(ФайлEXCELНаСервере);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.Прочитать(ФайлEXCELНаСервере);
	УдалитьФайлы(ФайлEXCELНаСервере);
	ОбластьТаблицы = ТабличныйДокумент.Область(1, 2, ТабличныйДокумент.ВысотаТаблицы, ТабличныйДокумент.ШиринаТаблицы);
	
	ПостроительЗапроса = Новый ПостроительЗапроса;
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьТаблицы);  
	ПостроительЗапроса.Выполнить();
	ТаблицаДанных = ПостроительЗапроса.Результат.Выгрузить();
	
	// теперь посмотрим что в Таблице
	//Возврат ТаблицаЗначенийВТабличныйДокумент(ТаблицаДанных);
	Возврат ТаблицаДанных;
	
КонецФункции 

Функция СформироватьШКДокаРазвернуто(Метаданные,Номер,Дата) 
	КодИсх="*"+ИдПоВидуДокумента(Метаданные)+"*"+Номер+"*"+Прав(""+Год(Дата),2)+"*";		
	Возврат Закодировать64(КодИсх);
КонецФункции

