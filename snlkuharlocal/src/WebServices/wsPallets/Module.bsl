Процедура УстановитьНомерДокумента(ДокументОбъект) 
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	ДопБуква="";
	Если МетаданныеДокумента.Имя="РасходнаяНакладная" Тогда
		Если ДокументОбъект.Дата >= '20200101' Тогда
			ДопБуква="б";
		Иначе
			ДопБуква=?(ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН,"б","а");
		КонецЕсли;
	ИначеЕсли МетаданныеДокумента.Имя="ОтчетКассовойСмены" Тогда
		ДопБуква=?(ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН,"кб","кн");	
	КонецЕсли; 
	
	Вид=МетаданныеДокумента.Имя;
	Если Вид="ЛистНабора" или Вид="ЛистПереукладки" Тогда
		ИмяДокумента=СокрЛП(ДокументОбъект.ДокОснование.Номер);
		ТипДокОсн= ДокументОбъект.ДокОснование.Метаданные().Имя;
		Если ТипДокОсн="Инвентаризация" Тогда			
			ИмяДокумента=""+ИмяДокумента+"i";
			ИмяДокумента=Лев(ИмяДокумента,4)+Сред(ИмяДокумента,6,СтрДлина(ИмяДокумента))+"/";
			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ИмяДокумента));
		Иначе
			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ДокументОбъект.ДокОснование.Номер)+"/");
		КонецЕсли;
	ИначеЕсли ЕстьРеквизитДокумента("ИБ",МетаданныеДокумента) Тогда
		ЭтотУзел=ПараметрыСеанса.ЭтотУзел;
		
		Если МетаданныеДокумента.Имя="РасходнаяНакладная" И СокрЛП(ДокументОбъект.Контрагент.Код)="SSP-8643" Тогда		
			Если ДокументОбъект.Дата>Дата(2015,06,28) и ДокументОбъект.Дата<Дата(2016,01,01) Тогда			
				КодИБ="SST";
				ПрефиксИБ = "SST";				
			иначе
				// Кухарь А.Ю.  29.06.2022 начало
				//  Кончились номера SSP
				//	КодИБ = "SSP";
				//ПрефиксИБ = "SSP";
				если ДеньГода(ДокументОбъект.Дата) > 172   тогда
					КодИБ = "SST";
					ПрефиксИБ = "SST";	
				иначе
					КодИБ = "SSP";
					ПрефиксИБ = "SSP";				
				КонецЕсли;
				
				// Кухарь А.Ю.  29.06.2022 конец
				
			КонецЕсли;		
		Иначе
			Если ЕстьРеквизитДокумента("Склад",МетаданныеДокумента) Тогда
				ПрефиксИБ=ДокументОбъект.Склад.ПрефиксИБ;
				если (МетаданныеДокумента.Имя="РасходнаяНакладная" ИЛИ МетаданныеДокумента.Имя="Перемещение" ИЛИ МетаданныеДокумента.Имя="ПриходнаяНакладная")  Тогда
					// Кухарь А.Ю.  22.06.2022 начало
					//Если  ДеньГода(ДокументОбъект.Дата) > 334 Тогда 
					Если  ДеньГода(ДокументОбъект.Дата) > 172 Тогда  
						// Кухарь А.Ю.  22.06.2022 конец
						
						Если ЭтотУзел.Код = "EKF" Тогда 
							ПрефиксИБ = "EKT";
						КонецЕсли;		
						Если ПрефиксИБ = "SSP" или ПрефиксИБ = "" Тогда 
							ПрефиксИБ = "SST";
						КонецЕсли;
					ИначеЕсли ДеньГода(ДокументОбъект.Дата) > 181 Тогда
						
						Если ПрефиксИБ = "SSP" или ПрефиксИБ = "" Тогда 
							ПрефиксИБ = "SSV";
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;		
			Если ПустаяСтрока(ПрефиксИБ) Тогда
				ПрефиксИБ=ДокументОбъект.ИБ.Код;			
			КонецЕсли; 
			
			КодИБ=?(ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение,ПрефиксИБ,ЭтотУзел.Код);			
			Если ПрефиксИБ = "EKT" Тогда
				КодИБ = ПрефиксИБ;	
				ПрефиксИБ = "SST";
			КонецЕсли; 
			
		КонецЕсли;		
		
		Если МетаданныеДокумента.Имя="Заказ"  Тогда		
			Если ЕстьРеквизитДокумента("Склад",МетаданныеДокумента) Тогда
				ПрефиксИБ=ДокументОбъект.Склад.ПрефиксИБ;
			КонецЕсли;		
			Если ПустаяСтрока(ПрефиксИБ) Тогда
				ПрефиксИБ=ДокументОбъект.ИБ.Код;			
			КонецЕсли; 
			
			КодИБ=?(ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение,ПрефиксИБ,ЭтотУзел.Код);			
		КонецЕсли;		
		
		Если МетаданныеДокумента.Имя="РекомендованныйОстаток"  Тогда		
			ПрефиксИБ="";			
			КодИБ=ПараметрыСеанса.ЭтотУзел.Код;			
		КонецЕсли;	
		Если МетаданныеДокумента.Имя="ПриходнаяНакладная" И (КодИБ="SSP" ИЛИ КодИБ="SST" ИЛИ КодИБ="SSV") Тогда
			ДокументОбъект.УстановитьНовыйНомер(КодИБ+"-0");
		Иначе
			ДокументОбъект.УстановитьНовыйНомер(КодИБ+ДопБуква+"-");
		КонецЕсли;
	ИначеЕсли Вид="УслугиСтороннихОрганизаций" или Вид="СчетЗаДоставку" или Вид="НоменклатурноеПриложениеКПаллете"  Тогда
		если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			Префикс=ДокументОбъект.Организация.Префикс+"-";
		иначе
			Префикс=ПараметрыСеанса.ЭтотУзел.Код+"-";
		КонецЕсли;
		ДокументОбъект.УстановитьНовыйНомер(Префикс);
	ИначеЕсли Вид="АвансовыйОтчет" Тогда
		Если ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН Тогда
			Префикс=ДокументОбъект.Организация.Префикс+"-";
		Иначе
			Префикс=ПараметрыСеанса.ЭтотУзел.Код;			
		КонецЕсли;
		
		ДокументОбъект.УстановитьНовыйНомер(Префикс);
	Иначе		
		КодИБ=ПараметрыСеанса.ЭтотУзел.Код;
		
		ДокументОбъект.УстановитьНовыйНомер(КодИБ+"-");		
	КонецЕсли;	
КонецПроцедуры 

Процедура УстановитьПунктДоставки(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент",ИмяРеквизитаПД="ПунктДоставки") 	
	Контрагент		=ДокументОбъект[ИмяРеквизитаКонтрагент];
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЕстьРеквизитДокумента("ОсновнойПунктДоставки",Контрагент.Метаданные()) И ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект[ИмяРеквизитаПД]=Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПД(Контрагент)=1 Тогда		
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин начало
			//для складов, если несколько ПД, выбираем первый
		ИначеЕсли ИмяРеквизитаКонтрагент = "СкладПолучатель" Тогда
			//крохин начало 28.07.2011
			//выбираем первый по наименованию
			//Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент,,"Наименование Убыв");
			//крохин конец 28.07.2011
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин конец
		Иначе
			ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
	КонецЕсли;	
КонецПроцедуры

Функция КоличествоПД(Контрагент) 
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	Владелец = &Владелец";
		
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;		
	КонецЕсли;
	
	Возврат 0;
КонецФункции 

Функция filterINV()
	тзШтрихкоды = Новый ТаблицаЗначений;
	тзШтрихкоды.Колонки.Добавить("ИНВ",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВДата",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(80, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Инвентаризация.Ссылка КАК ИНВ
	|ИЗ
	|	Документ.Инвентаризация КАК Инвентаризация
	|ГДЕ
	|	Инвентаризация.Проведен
	|	И Инвентаризация.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Сканирование)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Инвентаризация.Ссылка
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	//Параметры запроса
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = тзШтрихкоды.Добавить();
		НоваяСтрока.ИНВ = Выборка.ИНВ;
		НоваяСтрока.ИНВНомер = Выборка.ИНВ.Номер;
		НоваяСтрока.ИНВДата = Выборка.ИНВ.Дата;
		НоваяСтрока.ИНВУИД = Выборка.ИНВ.УникальныйИдентификатор();
		х=0;
	КонецЦикла;
	
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

Функция dataINV(ШК)
	Если ШК = "" Тогда
		ИНВ = Документы.Инвентаризация.ПустаяСсылка();
	Иначе
		Массив = РазложитьСтрокуВМассивПодстрок(СокрЛП(Раскодировать64(ШК)),"*");
		Номер = Массив[2];
		Дата =  Дата(Число("20"+Массив[3]),1,1);
		ИНВ = Документы.Инвентаризация.НайтиПоНомеру(Номер,Дата);
	КонецЕсли;
	
	тзШтрихкоды = Новый ТаблицаЗначений;
	тзШтрихкоды.Колонки.Добавить("ИНВ",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ИНВДата",Новый ОписаниеТипов("Дата", , ,
	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	тзШтрихкоды.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(100, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ТипШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(20, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ВидШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(20, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(32, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("Коэффициент",Новый ОписаниеТипов("Число",
	Новый КвалификаторыЧисла(3, 0, ДопустимыйЗнак.Любой)));
	тзШтрихкоды.Колонки.Добавить("НомерШК",Новый ОписаниеТипов("Число",
	Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Ссылка КАК ИНВ,
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	ШтрихКоды.Наименование КАК ШК,
	|	ШтрихКоды.ТипШК КАК ТипШК,
	|	ШтрихКоды.ВидШК КАК ВидШК,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	|			ТОГДА Номенклатура1.ШтукВКоробке
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	|			ТОГДА Номенклатура1.ШтукВКоробочке
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Коэффициент
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
	|		ПО (ШтрихКоды.Владелец = Номенклатура.Ссылка)
	|			И (НЕ ШтрихКоды.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
	|		ПО Номенклатура.Родитель = Номенклатура1.Ссылка
	|ГДЕ
	|	Номенклатура.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ИнвентаризацияТовары.Номенклатура КАК Номенклатура
	|			ИЗ
	|				Документ.Инвентаризация.Товары КАК ИнвентаризацияТовары
	|			ГДЕ
	|				ИнвентаризацияТовары.Ссылка = &Ссылка)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИНВ
	|ИТОГИ ПО
	|	Номенклатура,
	|	ТипШК,
	|	ВидШК
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	//Параметры запроса
	Если НЕ ИНВ.Пустая() Тогда
		Запрос.УстановитьПараметр("Ссылка",ИНВ);
	КонецЕсли;
	Результат = Запрос.Выполнить();
	
	ВыборкаНоменклатура = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНоменклатура.Следующий() Цикл
		ВыборкаТипШК = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТипШК.Следующий() Цикл
			ВыборкаВидШК= ВыборкаТипШК.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаВидШК.Следующий() Цикл
				ВыборкаДетальныеЗаписи= ВыборкаВидШК.Выбрать();
				НомерШК = 0;
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НомерШК = НомерШК + 1;
					НоваяСтрока= тзШтрихкоды.Добавить();
					НоваяСтрока.ИНВ = ВыборкаДетальныеЗаписи.ИНВ;
					НоваяСтрока.ИНВНомер = ВыборкаДетальныеЗаписи.ИНВ.Номер;
					НоваяСтрока.ИНВДата = ВыборкаДетальныеЗаписи.ИНВ.Дата;
					НоваяСтрока.ИНВУИД = ВыборкаДетальныеЗаписи.ИНВ.УникальныйИдентификатор();
					
					НоваяСтрока.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
					НоваяСтрока.ТипШК = ВыборкаДетальныеЗаписи.ТипШК;
					НоваяСтрока.ВидШК = ВыборкаДетальныеЗаписи.ВидШК;
					НоваяСтрока.НомерШК = НомерШК;
					НоваяСтрока.ШК = ВыборкаДетальныеЗаписи.ШК;
					НоваяСтрока.Коэффициент = ВыборкаДетальныеЗаписи.Коэффициент;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

Функция createINV(Параметр1)
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("wsPallets.createINV");	
	
	МассивИНВ = Десериализовать(Десериализовать(Десериализовать(Параметр1)).Получить());
	МассивПроведенныхЛН = Новый Массив;
	МассивОшибок = Новый Массив;
	Для каждого ЭлементМассива Из МассивИНВ Цикл
		// +++ {Кузнецов Сергей Владимирович [29.09.2022]  Вставить блок проверок
		// }Кузнецов Сергей Владимирович +++ [29.09.2022]
		ИНВ_УИД  = Новый УникальныйИдентификатор(ЭлементМассива.ИНВ_УИД);
		ИНВ = Документы.Инвентаризация.ПолучитьСсылку(ИНВ_УИД);
		ИНВОбъект = ИНВ.ПолучитьОбъект();
		Если ИНВОбъект = Неопределено Тогда
			
		КонецЕсли;
		
		Оборудование_УИД  = Новый УникальныйИдентификатор(ЭлементМассива.Оборудование_УИД);
		Оборудование = Справочники.Оборудование.ПолучитьСсылку(Оборудование_УИД);
		ОборудованиеОбъект = Оборудование.ПолучитьОбъект();
		Если ОборудованиеОбъект = Неопределено Тогда
			
		КонецЕсли;
		Для каждого СотрудникМассива  Из ЭлементМассива.МассивСотрудник Цикл
			Сотрудник_УИД  = Новый УникальныйИдентификатор(СотрудникМассива.Сотрудник_УИД);
			Сотрудник = Справочники.ФизическиеЛица.ПолучитьСсылку(Сотрудник_УИД);
			СотрудникОбъект = Сотрудник.ПолучитьОбъект();
			Если СотрудникОбъект = Неопределено Тогда
				
			КонецЕсли;
			
			тзЗН = Новый ТаблицаЗначений;
			тзЗН.Колонки.Добавить("Брэнд",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			тзЗН.Колонки.Добавить("Коллекция",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			тзЗН.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			тзЗН.Колонки.Добавить("Единица",Новый ОписаниеТипов("СправочникСсылка.Единицы"));
			тзЗН.Колонки.Добавить("Коэффициент",Новый ОписаниеТипов("Число",
			Новый КвалификаторыЧисла(10, 3, ДопустимыйЗнак.Любой)));
			тзЗН.Колонки.Добавить("Количество",Новый ОписаниеТипов("Число",
			Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
			тзЗН.Колонки.Добавить("Объем",Новый ОписаниеТипов("Число",
			Новый КвалификаторыЧисла(3, 3, ДопустимыйЗнак.Любой)));
			
			Для каждого ЭлементМассиваЛН Из СотрудникМассива.МассивЛН Цикл
				Новый_UID  = ЭлементМассиваЛН.ЛНИНВ_УИД;
				НоваяСсылка = Документы.ЛистНабора.ПолучитьСсылку(Новый_UID);
				ЛистНабораОбъект = НоваяСсылка.ПолучитьОбъект();
				Если ЛистНабораОбъект = Неопределено Тогда
					ЛистНабораОбъект = Документы.ЛистНабора.СоздатьДокумент();
					ЛистНабораОбъект.УстановитьСсылкуНового(НоваяСсылка);
					ЛистНабораОбъект.Дата = ЭлементМассиваЛН.ЛНИНВ_Дата;
					Попытка
						ЛистНабораОбъект.ЗонаХранения = Справочники.ЗоныХранения.ПолучитьСсылку(ЭлементМассиваЛН.ЗонаХранения_УИД);
					Исключение
					КонецПопытки;
					ЛистНабораОбъект.ДокОснование = ИНВ;
					ЛистНабораОбъект.УстановитьНовыйНомер(СокрЛП(ИНВ.Номер)+"/");
					ЛистНабораОбъект.ТипШК = Перечисления.ТипыШтрихКодов.Коробка;
					ЛистНабораОбъект.РежимСканирования = Перечисления.РежимСканирования.Добавление;
					ЛистНабораОбъект.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
					ЛистНабораОбъект.Склад = ИНВ.Склад;
					ЛистНабораОбъект.Сканировщик = Сотрудник.Ссылка;
					ЛистНабораОбъект.Наборщик = Сотрудник.Ссылка;
					ЛистНабораОбъект.Оборудование = Оборудование;
					ЛистНабораОбъект.Автор = Справочники.Пользователи.НайтиПоКоду("export");
					тзШК = Новый ТаблицаЗначений;
					тзШК.Колонки.Добавить("НомерСтроки",Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(5, 0, ДопустимыйЗнак.Любой)));
					тзШК.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
					тзШК.Колонки.Добавить("ТипШК",Новый ОписаниеТипов("ПеречислениеСсылка.ТипыШтрихКодов"));
					
					НачалоСканирования = Дата(2100,1,1);
					ОкончаниеСканирования =  Дата(1,1,1);
					Для каждого Строка Из ЭлементМассиваЛН.Состав Цикл
						НоваяСтрокаШК = тзШК.Добавить();
						НоваяСтрокаШК.НомерСтроки = Строка.НомерКоробки;
						НоваяСтрокаШК.ШК = Строка.ШК;
						НоваяСтрокаШК.ТипШК = Строка.ТипШК;
						Если НачалоСканирования > Строка.ВремяСканирования Тогда
							НачалоСканирования = Строка.ВремяСканирования	
						КонецЕсли;
						Если ОкончаниеСканирования < Строка.ВремяСканирования Тогда
							ОкончаниеСканирования = Строка.ВремяСканирования	
						КонецЕсли;
					КонецЦикла;
					МенВрТаб = Новый МенеджерВременныхТаблиц;
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	тзШК.НомерСтроки КАК НомерСтроки,
					|	тзШК.ШК КАК ШК,
					|	тзШК.ТипШК КАК ТипШК
					|ПОМЕСТИТЬ втШК
					|ИЗ
					|	&тзШК КАК тзШК";
					Запрос.УстановитьПараметр("тзШК",тзШК);
					
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	ШтрихКоды.ТипШК КАК ТипШК,
					|	ШтрихКоды.Наименование КАК ШК,
					|	ШтрихКоды.Владелец КАК Номенклатура,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
					|			ТОГДА ВЫБОР
					|					КОГДА ШтрихКоды.ШтВКоробе = 0
					|						ТОГДА Номенклатура.ШтукВКоробке
					|					ИНАЧЕ ШтрихКоды.ШтВКоробе
					|				КОНЕЦ
					|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
					|			ТОГДА Номенклатура.ШтукВКоробочке
					|		ИНАЧЕ 1
					|	КОНЕЦ КАК ШтукВКоробке
					|ПОМЕСТИТЬ вт
					|ИЗ
					|	втШК КАК втШК
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
					|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
					|			ПО ШтрихКоды.Владелец.Родитель = Номенклатура.Ссылка
					|		ПО втШК.ШК = ШтрихКоды.Наименование
					|			И втШК.ТипШК = ШтрихКоды.ТипШК
					|ГДЕ
					|	НЕ ШтрихКоды.ПометкаУдаления
					|
					|СГРУППИРОВАТЬ ПО
					|	ШтрихКоды.ТипШК,
					|	ШтрихКоды.Наименование,
					|	ШтрихКоды.Владелец,
					|	ВЫБОР
					|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
					|			ТОГДА ВЫБОР
					|					КОГДА ШтрихКоды.ШтВКоробе = 0
					|						ТОГДА Номенклатура.ШтукВКоробке
					|					ИНАЧЕ ШтрихКоды.ШтВКоробе
					|				КОНЕЦ
					|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
					|			ТОГДА Номенклатура.ШтукВКоробочке
					|		ИНАЧЕ 1
					|	КОНЕЦ
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	втШК.ШК КАК ШК,
					|	втШК.ТипШК КАК ТипШК,
					|	вт.Номенклатура КАК Номенклатура,
					|	вт.ШтукВКоробке КАК ШтукВКоробке,
					|	СУММА(1) КАК Количество
					|ПОМЕСТИТЬ ВтДанные
					|ИЗ
					|	втШК КАК втШК
					|		ЛЕВОЕ СОЕДИНЕНИЕ вт КАК вт
					|		ПО втШК.ШК = вт.ШК
					|			И втШК.ТипШК = вт.ТипШК
					|
					|СГРУППИРОВАТЬ ПО
					|	втШК.ТипШК,
					|	втШК.ШК,
					|	вт.Номенклатура,
					|	вт.ШтукВКоробке";
					
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	втШК.ШК КАК ШК,
					|	втШК.НомерСтроки КАК НомерСтроки
					|ИЗ
					|	втШК КАК втШК
					|ИТОГИ ПО
					|	ШК";
					
					РезультатЗапроса = Запрос.Выполнить();
					тзПорядковыхНомеров = Новый ТаблицаЗначений;
					тзПорядковыхНомеров.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(14, ДопустимаяДлина.Переменная)));
					тзПорядковыхНомеров.Колонки.Добавить("ПорядковыйНомерКоробки",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(1000, ДопустимаяДлина.Переменная)));											  
					ВыборкаШК = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаШК.Следующий() Цикл
						ВыборкаНомеров = ВыборкаШК.Выбрать();
						ПорядковыйНомерКоробки = "";
						Пока ВыборкаНомеров.Следующий() Цикл
							ПорядковыйНомерКоробки = ПорядковыйНомерКоробки + ВыборкаНомеров.НомерСтроки+";";
						КонецЦикла;
						НоваяСтрока = тзПорядковыхНомеров.Добавить();
						НоваяСтрока.ШК = ВыборкаШК.ШК;
						НоваяСтрока.ПорядковыйНомерКоробки = ПорядковыйНомерКоробки;
					КонецЦикла;
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	тзПорядковыхНомеров.ШК КАК ШК,
					|	тзПорядковыхНомеров.ПорядковыйНомерКоробки КАК ПорядковыйНомерКоробки
					|ПОМЕСТИТЬ втПорядковыеНомера
					|ИЗ
					|	&тзПорядковыхНомеров КАК тзПорядковыхНомеров";
					
					Запрос.УстановитьПараметр("тзПорядковыхНомеров",тзПорядковыхНомеров);
					РезультатЗапроса = Запрос.Выполнить();
					
					Запрос = Новый Запрос;
					Запрос.МенеджерВременныхТаблиц = МенВрТаб;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	втДанные.ТипШК КАК ТипШК,
					|	втДанные.ШК КАК ШК,
					|	втДанные.Номенклатура КАК Номенклатура,
					|	втДанные.Количество КАК КоличествоКоробок,
					|	втДанные.ШтукВКоробке КАК ШтукВКоробке,
					|	втПорядковыеНомера.ПорядковыйНомерКоробки КАК ПорядковыйНомерКоробки
					|ИЗ
					|	втДанные КАК втДанные
					|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядковыеНомера КАК втПорядковыеНомера
					|		ПО втДанные.ШК = втПорядковыеНомера.ШК";
					
					Запрос.УстановитьПараметр("тзПорядковыхНомеров",тзПорядковыхНомеров);
					РезультатЗапроса = Запрос.Выполнить();
					тзСоставЛН = РезультатЗапроса.Выгрузить();
					КоличествоКоробок = 0;
					Для каждого Строка Из тзСоставЛН Цикл
						НоваяСтрока = ЛистНабораОбъект.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
						попытка
							НоваяСтрока.Количество = Строка.КоличествоКоробок * Строка.ШтукВКоробке;
						Исключение
							ЗаписатьВЛог("Отладка","Сбой добавление строки "+НоваяСтрока.Номенклатура,"Ошибка");
							Продолжить;
						КонецПопытки;
						НоваяСтрока.ШтВКоробе = Строка.ШтукВКоробке;
						НоваяСтрока.ТипШК = Строка.ТипШК;
						НоваяСтрока.Единица = Строка.Номенклатура.ОсновнаяЕдиница;
						НоваяСтрока.Коэффициент = Строка.Номенклатура.ОсновнаяЕдиница.Коэффициент;
						НоваяСтрока.Объем = Строка.Номенклатура.Родитель.ОбъемКоробки *Строка.КоличествоКоробок;
						КоличествоКоробок = КоличествоКоробок + Строка.КоличествоКоробок;
					КонецЦикла;
					ЛистНабораОбъект.КоличествоКоробок = КоличествоКоробок;
					ЛистНабораОбъект.Записать(РежимЗаписиДокумента.Запись);
					ЛистНабораОбъект.Записать(РежимЗаписиДокумента.Проведение);
					МассивПроведенныхЛН.Добавить(Новый_UID);
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	СтруктураОтвета = Новый Структура("МассивПеренесенныхЛН,МассивОшибок",МассивПроведенныхЛН,МассивОшибок);
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураОтвета), Новый СжатиеДанных(9))); 
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();

	Возврат  Ответ;
КонецФункции

Функция dataPNK(ШК)
	Если ШК = "" Тогда
		ПНК = Документы.ПриходнаяНакладная.ПустаяСсылка();
	Иначе
		Массив = РазложитьСтрокуВМассивПодстрок(СокрЛП(Раскодировать64(ШК)),"*");
		Номер = Массив[2];
		Дата =  Дата(Число("20"+Массив[3]),1,1);
		ПНК = Документы.ПриходнаяНакладная.НайтиПоНомеру(Номер,Дата);
	КонецЕсли;
	
	тзШтрихкоды = Новый ТаблицаЗначений;
	тзШтрихкоды.Колонки.Добавить("ПНК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПНКУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПНКНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПНКДата",Новый ОписаниеТипов("Дата", , ,
	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	тзШтрихкоды.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(100, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ТипШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(20, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ВидШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(20, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(32, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("Коэффициент",Новый ОписаниеТипов("Число",
	Новый КвалификаторыЧисла(3, 0, ДопустимыйЗнак.Любой)));
	тзШтрихкоды.Колонки.Добавить("НомерШК",Новый ОписаниеТипов("Число",
	Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	  "ВЫБРАТЬ
	  |	&Ссылка КАК ПНК,
	  |	Номенклатура.Ссылка КАК Номенклатура,
	  |	ВЫБОР
	  |		КОГДА Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Создана)
	  |			ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Наименование
	  |		ИНАЧЕ ШтрихКоды.Наименование
	  |	КОНЕЦ КАК ШК,
	  |	ВЫБОР
	  |		КОГДА Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Создана)
	  |			ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК
	  |		ИНАЧЕ ШтрихКоды.ТипШК
	  |	КОНЕЦ КАК ТипШК,
	  |	ШтрихКоды.ВидШК КАК ВидШК,
	  |	ВЫБОР
	  |		КОГДА Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Создана)
	  |			ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Количество
	  |		ИНАЧЕ ВЫБОР
	  |				КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	  |					ТОГДА Номенклатура1.ШтукВКоробке
	  |				КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	  |					ТОГДА Номенклатура1.ШтукВКоробочке
	  |				ИНАЧЕ 1
	  |			КОНЕЦ
	  |	КОНЕЦ КАК Коэффициент
	  |ИЗ
	  |	Справочник.Номенклатура КАК Номенклатура
	  |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
	  |		ПО (ШтрихКоды.Владелец = Номенклатура.Ссылка)
	  |			И (НЕ ШтрихКоды.ПометкаУдаления)
	  |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
	  |		ПО Номенклатура.Родитель = Номенклатура1.Ссылка
	  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
	  |		ПО (&Ссылка = ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка.ДокОснование)
	  |			И Номенклатура.Ссылка = ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	  |ГДЕ
	  |	Номенклатура.Ссылка В
	  |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	  |				ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура
	  |			ИЗ
	  |				Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	  |			ГДЕ
	  |				ПриходнаяНакладнаяТовары.Ссылка = &Ссылка)
	  |	И НЕ Номенклатура.ЭтоГруппа
	  |	И НЕ Номенклатура.ПометкаУдаления
	  |	И НЕ ВЫБОР
	  |				КОГДА Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Создана)
	  |					ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Наименование
	  |				ИНАЧЕ ШтрихКоды.Наименование
	  |			КОНЕЦ ЕСТЬ NULL
	  |
	  |УПОРЯДОЧИТЬ ПО
	  |	ПНК
	  |ИТОГИ ПО
	  |	Номенклатура,
	  |	ТипШК,
	  |	ВидШК
	  |АВТОУПОРЯДОЧИВАНИЕ";
	//Параметры запроса
	Если НЕ ПНК.Пустая() Тогда
		Запрос.УстановитьПараметр("Ссылка",ПНК);
	КонецЕсли;
	Результат = Запрос.Выполнить();
	
	ВыборкаНоменклатура = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНоменклатура.Следующий() Цикл
		ВыборкаТипШК = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаТипШК.Следующий() Цикл
			ВыборкаВидШК= ВыборкаТипШК.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаВидШК.Следующий() Цикл
				ВыборкаДетальныеЗаписи= ВыборкаВидШК.Выбрать();
				НомерШК = 0;
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НомерШК = НомерШК + 1;
					НоваяСтрока= тзШтрихкоды.Добавить();
					НоваяСтрока.ПНК = ВыборкаДетальныеЗаписи.ПНК;
					НоваяСтрока.ПНКНомер = ВыборкаДетальныеЗаписи.ПНК.Номер;
					НоваяСтрока.ПНКДата = ВыборкаДетальныеЗаписи.ПНК.Дата;
