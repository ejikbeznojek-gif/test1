					НоваяСтрока.НомерШК = НомерШК;
					НоваяСтрока.ШК = ВыборкаДетальныеЗаписи.ШК;
					НоваяСтрока.Коэффициент = ВыборкаДетальныеЗаписи.Коэффициент;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;         
	
	
    Данные = Новый Структура("тзШтрихкоды, МассивНоменклатуры", тзШтрихкоды, МассивНоменклатуры); 
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(Данные), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

Функция СтруктураНоменклатуры(Номенклатура) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Номенклатура.Наименование КАК Наименование,
	|	Номенклатура.Код КАК Код,
	|	Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	Номенклатура.Родитель.ШтукВКоробочке КАК ШтукВКоробочке
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();      
	Возврат Новый Структура("УИД, Код, Наименование, ШтукВКоробе, ШтукВБлочке",
								Номенклатура.УникальныйИдентификатор(),
								ВыборкаДетальныеЗаписи.Код,
								ВыборкаДетальныеЗаписи.Наименование,
								ВыборкаДетальныеЗаписи.ШтукВКоробке,
								ВыборкаДетальныеЗаписи.ШтукВКоробочке);
	
КонецФункции

Функция createPPMT(Параметр1)
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("wsPallets.createPPMT");	
	
	МассивДокументов = Десериализовать(Десериализовать(Десериализовать(Параметр1)).Получить());     
	МассивПроведенныхДокументов = Новый Массив;
	МассивОшибок = Новый Массив;
	Для каждого ЭлементМассива Из МассивДокументов Цикл 
		
		Оборудование_УИД  = Новый УникальныйИдентификатор(ЭлементМассива.Оборудование_УИД);
		Оборудование = Справочники.Оборудование.ПолучитьСсылку(Оборудование_УИД);
		ОборудованиеОбъект = Оборудование.ПолучитьОбъект();
		Если ОборудованиеОбъект = Неопределено Тогда
			
		КонецЕсли;
		
		УИДСотрудник  = Новый УникальныйИдентификатор(ЭлементМассива.УИДСотрудник);
		Сотрудник = Справочники.ФизическиеЛица.ПолучитьСсылку(УИДСотрудник);
		СотрудникОбъект = Сотрудник.ПолучитьОбъект();
		Если СотрудникОбъект = Неопределено Тогда
			
		КонецЕсли;
		
		УИДНоменклатураОсновная  = Новый УникальныйИдентификатор(ЭлементМассива.УИДНоменклатураОсновная);
		Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(УИДНоменклатураОсновная);
		НоменклатураОбъект = Номенклатура.ПолучитьОбъект();
		Если НоменклатураОбъект = Неопределено Тогда
			
		КонецЕсли;      
		
		УИДКодАгрегации  = Новый УникальныйИдентификатор(ЭлементМассива.УИДКодАгрегации);
		КодАгрегации = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСсылку(УИДКодАгрегации);
		КодАгрегацииОбъект = КодАгрегации.ПолучитьОбъект();
		Если КодАгрегацииОбъект = Неопределено Тогда
			
		КонецЕсли;
		
		ППMT_УИД  = Новый УникальныйИдентификатор(ЭлементМассива.УИДПроверка);
		ППMTСсылка = Документы.ПроверкаПоставкиМаркированногоТовара.ПолучитьСсылку(ППMT_УИД);
		ППMTОбъект = ППMTСсылка.ПолучитьОбъект();
		Если ППMTОбъект = Неопределено Тогда
			ППMTОбъект = Документы.ПроверкаПоставкиМаркированногоТовара.СоздатьДокумент();
			ППMTОбъект.УстановитьСсылкуНового(ППMTСсылка);
		КонецЕсли;
		ППMTОбъект.Дата = ЭлементМассива.ДокументДата;
		ППMTОбъект.Оборудование = Оборудование;
		ППMTОбъект.Сканировщик = Сотрудник;
		ППMTОбъект.НоменклатураОсновная = Номенклатура;
		ППMTОбъект.КодАгрегации = КодАгрегации;
		ППMTОбъект.КоличествоЗаводское = ЭлементМассива.КоличествоЗаводское;
		ППMTОбъект.КоличествоНеверныхШтучныхКодов = ЭлементМассива.КоличествоНеверныхШтучныхКодов;
		ППMTОбъект.КоличествоНеправильногоСодержимогоКоробки = ЭлементМассива.КоличествоНеправильногоСодержимогоКоробки;
		ППMTОбъект.ОтклонениеОтЗаводскогоКоличества = ЭлементМассива.ОтклонениеОтЗаводскогоКоличества;
		ППMTОбъект.НеПолныйКороб = ЭлементМассива.НеПолныйКороб;
		
        ППMTОбъект.Товары.Очистить();
		Для каждого ЭлементМассиваТовары Из ЭлементМассива.МассивТовары Цикл  
			НоваяСтрока = ППMTОбъект.Товары.Добавить();    
			НоваяСтрока.Номенклатура = Номенклатура;
			НоваяСтрока.Количество = ЭлементМассиваТовары.Количество;
			х=0;	
		КонецЦикла;
		ППMTОбъект.ШтрихкодыУпаковок.Очистить();
					НачалоСканирования = Дата(2100,1,1);
					ОкончаниеСканирования =  Дата(1,1,1);
		Для каждого ЭлементМассиваШтрихкодыУпаковок Из ЭлементМассива.МассивШтрихкодыУпаковок Цикл      
			Если НачалоСканирования > ЭлементМассиваШтрихкодыУпаковок.ВремяВыполнения Тогда
				НачалоСканирования = ЭлементМассиваШтрихкодыУпаковок.ВремяВыполнения	
			КонецЕсли;
			Если ОкончаниеСканирования < ЭлементМассиваШтрихкодыУпаковок.ВремяВыполнения Тогда
				ОкончаниеСканирования = ЭлементМассиваШтрихкодыУпаковок.ВремяВыполнения	
			КонецЕсли;
			Если СокрЛП(ЭлементМассиваШтрихкодыУпаковок.ОписаниеОшибки)="" Тогда
				УИДШтрихкодУпаковки  = Новый УникальныйИдентификатор(ЭлементМассиваШтрихкодыУпаковок.УИДШтрихкодУпаковки);
				ШтрихкодУпаковки = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСсылку(УИДШтрихкодУпаковки);
				ШтрихкодУпаковкиОбъект = ШтрихкодУпаковки.ПолучитьОбъект();
				Если ШтрихкодУпаковкиОбъект = Неопределено Тогда
					
				КонецЕсли;
			Иначе		
				ШтрихкодУпаковки  = Справочники.ШтрихкодыУпаковокТоваров.НайтиПоНаименованию(ЭлементМассиваШтрихкодыУпаковок.ОписаниеОшибки,Истина);
			КонецЕсли;
			НоваяСтрока = ППMTОбъект.ШтрихкодыУпаковок.Добавить();    
			
			НоваяСтрока.Номенклатура = ШтрихкодУпаковки.Владелец;
			НоваяСтрока.ШтрихкодУпаковки = ШтрихкодУпаковки;
			НоваяСтрока.ТекстQR = ЭлементМассиваШтрихкодыУпаковок.ТекстQR;
			НоваяСтрока.ОписаниеОшибки = ЭлементМассиваШтрихкодыУпаковок.ОписаниеОшибки;
			НоваяСтрока.ВремяВыполнения = ЭлементМассиваШтрихкодыУпаковок.ВремяВыполнения;
			х=0;	
		КонецЦикла;   
        ППMTОбъект.СоставБригады.Очистить();
		Для каждого ЭлементМассиваСоставБригады Из ЭлементМассива.МассивСоставБригады Цикл  
			НоваяСтрока = ППMTОбъект.СоставБригады.Добавить();    
			УИДСотрудника  = Новый УникальныйИдентификатор(ЭлементМассиваСоставБригады.УИДСотрудника);
			Сотрудник = Справочники.ФизическиеЛица.ПолучитьСсылку(УИДСотрудника);

			НоваяСтрока.Сотрудник = Сотрудник;
			НоваяСтрока.ДатаНачала = ЭлементМассиваСоставБригады.ДатаНачала;
			НоваяСтрока.ДатаОкончания = ЭлементМассиваСоставБригады.ДатаОкончания;
			х=0;	
		КонецЦикла;
		ППMTОбъект.НачалоСканирования = НачалоСканирования;
		ППMTОбъект.ОкончаниеСканирования = ОкончаниеСканирования;
		Попытка
			ППMTОбъект.Записать(РежимЗаписиДокумента.Запись);
			МассивПроведенныхДокументов.Добавить(ППMTСсылка);   
		Исключение
			х=0;
		КонецПопытки;
	КонецЦикла;
	СтруктураОтвета = Новый Структура("МассивПеренесенныхДокументов,МассивОшибок",МассивПроведенныхДокументов,МассивОшибок);
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураОтвета), Новый СжатиеДанных(9))); 
	//Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать("Успешно"), Новый СжатиеДанных(9))); 
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();

	Возврат  Ответ;
КонецФункции
	
