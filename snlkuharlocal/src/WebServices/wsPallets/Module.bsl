					ЛистНабораОбъект.Наборщик = Сотрудник.Ссылка;
					ЛистНабораОбъект.Оборудование = Оборудование;
					ЛистНабораОбъект.Автор = Справочники.Пользователи.НайтиПоКоду("export");
					тзШК = Новый ТаблицаЗначений;
					тзШК.Колонки.Добавить("НомерСтроки",Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(5, 0, ДопустимыйЗнак.Любой)));
					тзШК.Колонки.Добавить("ШК",Новый ОписаниеТипов("Строка", ,
					Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
					тзШК.Колонки.Добавить("ТипШК",Новый ОписаниеТипов("ПеречислениеСсылка.ТипыШтрихКодов"));
					
					НачалоСканирования = Дата(2100,1,1);
					ОкончаниеСканирования =  Дата(1,1,1);
					Для каждого Строка Из ЭлементМассиваЛН.Состав Цикл
						НоваяСтрокаШК = тзШК.Добавить();
