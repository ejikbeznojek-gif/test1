	|	ВремТЗ.КонтрагентКод КАК КонтрагентКод,
	|	ВремТЗ.КонтрагентУИД КАК КонтрагентУИД,
	|	ВремТЗ.ПунктДоставки КАК ПунктДоставки,
	|	ВремТЗ.ПунктДоставкиКод КАК ПунктДоставкиКод,
	|	ВремТЗ.ПунктДоставкиУИД КАК ПунктДоставкиУИД
	|ПОМЕСТИТЬ втДанные
	|ИЗ
	|	ВремТЗ КАК ВремТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПаллетаЛистыНабора.Ссылка КАК Паллета,
	|	ПаллетаЛистыНабора.ШКЛистаНабора КАК Штрихкод
	|ПОМЕСТИТЬ втПаллет
	|ИЗ
	|	втДанные КАК втДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|		ПО втДанные.НакладнаяДокумент = ПаллетаЛистыНабора.Документ
	|			И (ПаллетаЛистыНабора.Ссылка.Проведен)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанные.ЛистЗагрузки КАК ЛистЗагрузки,
	|	втДанные.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|	втДанные.ЛистЗагрузкиДата КАК ЛистЗагрузкиДата,
	|	втДанные.ЛистЗагрузкиУИД КАК ЛистЗагрузкиУИД,
	|	втДанные.ЛистЗагрузкиШтрихкод КАК ЛистЗагрузкиШтрихкод,
	|	втДанные.Автомобиль КАК Автомобиль,
	|	втДанные.НомерХодки КАК НомерХодки,
	|	втДанные.Накладная КАК Накладная,
	|	втДанные.Документ КАК Документ,
	|	втДанные.Штрихкод КАК Штрихкод,
	|	втДанные.НомерКоробки КАК НомерКоробки,
	|	втДанные.ВсегоКоробок КАК ВсегоКоробок,
	|	втДанные.Контрагент КАК Контрагент,
	|	втДанные.КонтрагентКод КАК КонтрагентКод,
	|	втДанные.КонтрагентУИД КАК КонтрагентУИД,
	|	втДанные.ПунктДоставки КАК ПунктДоставки,
	|	втДанные.ПунктДоставкиКод КАК ПунктДоставкиКод,
	|	втДанные.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
	|	втПаллет.Паллета КАК Паллета,
	|	втПаллет.Паллета.ШКПаллеты КАК ШКПаллеты
	|ИЗ
	|	втДанные КАК втДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПаллет КАК втПаллет
	|		ПО втДанные.Штрихкод = втПаллет.Штрихкод";
	
	Запрос.УстановитьПараметр("ВремТЗ",ВремТЗ);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = тзШтрихкоды.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
		НоваяСтрока.ПаллетаНомер = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Паллета),ВыборкаДетальныеЗаписи.Паллета.Номер,"");
		НоваяСтрока.ПаллетаДата = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Паллета),ВыборкаДетальныеЗаписи.Паллета.Дата,"");
		НоваяСтрока.ПаллетаУИД = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Паллета),ВыборкаДетальныеЗаписи.Паллета.УникальныйИдентификатор(),"");
	КонецЦикла;
	тзШтрихкоды.Колонки.Удалить("НакладнаяДокумент");
	тзШтрихкоды.Сортировать("ЛистЗагрузки, Накладная, НомерКоробки, Паллета");
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

Функция filterSheets(DateString)
	ДатаОтгрузки = Дата(DateString);
	
	тзШтрихкоды = Новый ТаблицаЗначений;
	тзШтрихкоды.Колонки.Добавить("ЛистЗагрузки",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЛистЗагрузкиНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЛистЗагрузкиДата",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(80, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЛистЗагрузкиУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("Автомобиль",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(45, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("НомерХодки",Новый ОписаниеТипов("Число",
	Новый КвалификаторыЧисла(2, 0, ДопустимыйЗнак.Любой)));
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЛистЗагрузкиЗаявка.Ссылка КАК ЛистЗагрузки
	               |ИЗ
	               |	Документ.ЛистЗагрузки.Заявка КАК ЛистЗагрузкиЗаявка
	               |ГДЕ
	               |	(ЛистЗагрузкиЗаявка.ВидНакладной = ""РНК""
	               |			ИЛИ ЛистЗагрузкиЗаявка.ВидНакладной = ""ПРМ"")
	               |	И ЛистЗагрузкиЗаявка.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	               |	И ЛистЗагрузкиЗаявка.Ссылка.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеСканирования)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ЛистЗагрузки";
	
	//Параметры запроса
	Запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);// Дата
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = тзШтрихкоды.Добавить();
		НоваяСтрока.ЛистЗагрузки = Выборка.ЛистЗагрузки;
		НоваяСтрока.ЛистЗагрузкиНомер = Выборка.ЛистЗагрузки.Номер;
		НоваяСтрока.ЛистЗагрузкиДата = Выборка.ЛистЗагрузки.Дата;
		НоваяСтрока.ЛистЗагрузкиУИД = Выборка.ЛистЗагрузки.УникальныйИдентификатор();
		НоваяСтрока.Автомобиль =  Выборка.ЛистЗагрузки.Автомобиль;
		НоваяСтрока.НомерХодки =  Выборка.ЛистЗагрузки.НомерХодки;
		х=0;
	КонецЦикла;
	
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

Функция createSheets(Параметр1)
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("wsPallets.createSheets");	
	
	МассивЛистовЗагрузки = Десериализовать(Десериализовать(Десериализовать(Параметр1)).Получить());
	МассивПроведенныхЛЗ = Новый Массив;
	МассивОшибок = Новый Массив;
	Для каждого ЭлементМассива Из МассивЛистовЗагрузки Цикл
		МассивОшибокПоЛЗ = Новый Массив;
		Для каждого Строка Из ЭлементМассива.Состав Цикл
			МассивОшибокПоШК = Новый Массив;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СоставЛистаЗагрузкиСостав.Ссылка КАК Ссылка,
			|	СоставЛистаЗагрузкиСостав.Ссылка.Номер КАК Номер,
			|	СоставЛистаЗагрузкиСостав.Ссылка.Дата КАК Дата
			|ИЗ
			|	Документ.СоставЛистаЗагрузки.Состав КАК СоставЛистаЗагрузкиСостав
			|ГДЕ
			|	СоставЛистаЗагрузкиСостав.ШК = &ШК";
			
			Запрос.УстановитьПараметр("ШК", Строка.ШК);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				СтруктураОшибкиПоШК = Новый Структура;
				СтруктураОшибкиПоШК.Вставить("ЛистЗагрузки_УИД", Строка(ВыборкаДетальныеЗаписи.Ссылка.УникальныйИдентификатор()));
				СтруктураОшибкиПоШК.Вставить("ЛистЗагрузки_Номер", ВыборкаДетальныеЗаписи.Номер);
				СтруктураОшибкиПоШК.Вставить("ЛистЗагрузки_Дата", ВыборкаДетальныеЗаписи.Дата);
				МассивОшибокПоШК.Добавить(СтруктураОшибкиПоШК);
				х=0;
			КонецЦикла;
			Если НЕ МассивОшибокПоШК.Количество() = 0 Тогда
				СтруктураОшибкиПоЛЗ = Новый Структура;
				СтруктураОшибкиПоЛЗ.Вставить("ШК", Строка.ШК);
				СтруктураОшибкиПоЛЗ.Вставить("МассивОшибокПоШК", МассивОшибокПоШК);
				МассивОшибокПоЛЗ.Добавить(СтруктураОшибкиПоЛЗ);
			КонецЕсли;
		КонецЦикла;
		Если НЕ МассивОшибокПоЛЗ.Количество() = 0 Тогда
			
			МассивОшибок.Добавить(Новый Структура("СоставЛистаЗагрузки_УИД, ОшибкиПоПаллете", ЭлементМассива.СоставЛистаЗагрузки_УИД, МассивОшибокПоЛЗ));
			х=0;
			Продолжить;	
		КонецЕсли;
		
		Новый_UID  = Новый УникальныйИдентификатор(ЭлементМассива.Оборудование_УИД);
		// пытаемся получить объект по UID
		НоваяСсылка = Справочники.Оборудование.ПолучитьСсылку(Новый_UID);
		// пытаемся получить объект
		Оборудование = НоваяСсылка.ПолучитьОбъект();
		// проверяем есть ли объект
		Если Оборудование = Неопределено Тогда
			//НоваяСсылка = Справочники.Склады.ПолучитьСсылку(Новый_UID);
			//// пытаемся получить объект
			//Контрагент = НоваяСсылка.ПолучитьОбъект();
			
		КонецЕсли;
		
		Новый_UID  = Новый УникальныйИдентификатор(ЭлементМассива.Сотрудник_УИД);
		// пытаемся получить объект по UID
		НоваяСсылка = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый_UID);
		// пытаемся получить объект
		//Сотрудник = НоваяСсылка.ПолучитьОбъект();
		Сотрудник = НоваяСсылка;
		
		Новый_UID  = Новый УникальныйИдентификатор(ЭлементМассива.СоставЛистаЗагрузки_УИД);
		// пытаемся получить объект по UID
		НоваяСсылка = Документы.СоставЛистаЗагрузки.ПолучитьСсылку(Новый_UID);
		// пытаемся получить объект
		СоставЛистаЗагрузки = НоваяСсылка.ПолучитьОбъект();
		// проверяем есть ли объект
		Если СоставЛистаЗагрузки = Неопределено Тогда
			// создаем новый элемент
			СоставЛистаЗагрузки = Документы.СоставЛистаЗагрузки.СоздатьДокумент();
			// для нового объекта – еще не записанного мы можем присвоить UID
			СоставЛистаЗагрузки.УстановитьСсылкуНового(НоваяСсылка);
			// говорим программе что это загрузка объекта
			СоставЛистаЗагрузки.УстановитьНовыйНомер("OD7-");
			СоставЛистаЗагрузки.Дата = ЭлементМассива.СоставЛистаЗагрузки_Дата;
			// +++ {Кузнецов Сергей Владимирович [28.09.2022] Для отладки
			СоставЛистаЗагрузки.Сотрудник = Сотрудник;
			СоставЛистаЗагрузки.Оборудование = Оборудование.Ссылка;
			ЛистЗагрузки_УИД  = Новый УникальныйИдентификатор(ЭлементМассива.ЛистЗагрузки_УИД);
			// пытаемся получить объект по UID
			СоставЛистаЗагрузки.ЛистЗагрузки = Документы.ЛистЗагрузки.ПолучитьСсылку(ЛистЗагрузки_УИД);
			
			// }Кузнецов Сергей Владимирович +++ [28.09.2022]
			Для каждого Строка Из ЭлементМассива.Состав Цикл
				НоваяСтрока = СоставЛистаЗагрузки.Состав.Добавить();
				НоваяСтрока.ВремяВыполнения = Строка.ВремяСканирования;
				
				Если СтрДлина(Строка.ШК)=13 Тогда //Листы набора 
// Кухарь А.Ю.  27.11.2023 начало
					//ЛН=Документы.ЛистНабора.НайтиПоРеквизиту("ШКЛистаНабора",Лев(Строка.ШК,7));
					запрос=новый запрос;
					запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
					|	ЛистНабора.Ссылка КАК ЛН,
					|	ЛистНабора.Дата КАК Дата
					|ИЗ
					|	Документ.ЛистНабора КАК ЛистНабора
					|ГДЕ
					|	ПОДСТРОКА(ЛистНабора.ШКЛистаНабора, 1, 7) = &ШКЛистаНабора
					|	И ЛистНабора.Дата >= &Дата
					|	И ЛистНабора.Проведен
					|
					|УПОРЯДОЧИТЬ ПО
					|	Дата УБЫВ";
					запрос.УстановитьПараметр("Дата",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-30*24*3600);
					запрос.УстановитьПараметр("ШКЛистаНабора",Лев(Строка.ШК,7));
					ЛН=документы.ЛистНабора.ПустаяСсылка();
					Результат=запрос.Выполнить().Выбрать();
					пока Результат.Следующий() цикл
						ЛН=Результат.ЛН;
					КонецЦикла;
					// Кухарь А.Ю.  27.11.2023 конец

					НоваяСтрока.Накладная = ЛН;
					НоваяСтрока.ПредставлениеКоробки = Строка.ПредставлениеКоробки;
					НоваяСтрока.ШК = Строка.ШК;
				ИначеЕсли СтрДлина(Строка.ШК)=14 Тогда //Листы переукладки 
				ИначеЕсли СтрДлина(Строка.ШК)=32 Тогда //Паллета 
					Паллета=Документы.Паллета.НайтиПоРеквизиту("ШКПаллеты",Строка.ШК);
					НоваяСтрока.ПредставлениеКоробки = Строка.ПредставлениеКоробки;
					НоваяСтрока.Накладная = Строка.Накладная;
					НоваяСтрока.ШК = Строка.ШК;
				КонецЕсли;
			КонецЦикла;
			
			//записываем
			Попытка
				СоставЛистаЗагрузки.Записать(РежимЗаписиДокумента.Проведение);
				ЗаполнитьЛЗ(СоставЛистаЗагрузки.Ссылка,ЭлементМассива.тзПлана);         
				МассивПроведенныхЛЗ.Добавить(Новый_UID);
			Исключение
				СтруктураОшибки = Новый Структура("СоставЛистаЗагрузки_УИД, ОписаниеОшибки",Новый_UID,"Не перенесен Состав листа загрузки"+Символы.ПС + ОписаниеОшибки());
				МассивОшибок.Добавить(СтруктураОшибки);
			КонецПопытки;
		КонецЕсли;
		ч=0;
	КонецЦикла;
	СтруктураОтвета = Новый Структура("МассивПроведенныхЛЗ,МассивОшибок",МассивПроведенныхЛЗ,МассивОшибок);
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураОтвета), Новый СжатиеДанных(9))); 
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();

	Возврат  Ответ;
КонецФункции

Процедура ЗаполнитьЛЗ(СоставЛЗ,тзПлана) 
	МенВрТаб = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенВрТаб;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	тзПлан.ТипОбъекта КАК ТипОбъекта,
	|	тзПлан.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|	тзПлан.ШтрихкодПаллеты КАК ШтрихкодПаллеты,
	|	тзПлан.Накладная КАК НакладнаяНомер,
	|	тзПлан.Документ КАК Документ,
	|	тзПлан.Штрихкод КАК Штрихкод,
	|	тзПлан.НомерКоробки КАК НомерКоробки,
	|	тзПлан.ВсегоКоробок КАК ВсегоКоробок,
	|	тзПлан.КонтрагентУИД КАК КонтрагентУИД,
	|	тзПлан.ПунктДоставкиУИД КАК ПунктДоставкиУИД
	|ПОМЕСТИТЬ втПлан
	|ИЗ
	|	&тзПлан КАК тзПлан
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПлан.ТипОбъекта КАК ТипОбъекта,
	|	втПлан.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|	втПлан.НакладнаяНомер КАК НакладнаяНомер,
	|	втПлан.ШтрихкодПаллеты КАК ШтрихкодПаллеты,
	|	втПлан.Документ КАК Документ,
	|	втПлан.Штрихкод КАК Штрихкод,
	|	втПлан.НомерКоробки КАК НомерКоробки,
	|	втПлан.ВсегоКоробок КАК ВсегоКоробок,
	|	втПлан.КонтрагентУИД КАК КонтрагентУИД,
	|	втПлан.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
	|	СоставЛистаЗагрузкиСостав.ВремяВыполнения КАК ВремяВыполнения
	|ПОМЕСТИТЬ втКороба
	|ИЗ
	|	втПлан КАК втПлан
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СоставЛистаЗагрузки.Состав КАК СоставЛистаЗагрузкиСостав
	|		ПО втПлан.Штрихкод = СоставЛистаЗагрузкиСостав.ШК
	|ГДЕ
	|	втПлан.ШтрихкодПаллеты ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втПлан.ТипОбъекта КАК ТипОбъекта,
	|	втПлан.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|	втПлан.ШтрихкодПаллеты КАК ШтрихкодПаллеты,
	|	втПлан.НакладнаяНомер КАК НакладнаяНомер,
	|	втПлан.Документ КАК Документ,
	|	втПлан.Штрихкод КАК Штрихкод,
	|	втПлан.НомерКоробки КАК НомерКоробки,
	|	втПлан.ВсегоКоробок КАК ВсегоКоробок,
	|	втПлан.КонтрагентУИД КАК КонтрагентУИД,
	|	втПлан.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
	|	СоставЛистаЗагрузкиСостав.ВремяВыполнения КАК ВремяВыполнения
	|ПОМЕСТИТЬ втПаллеты
	|ИЗ
	|	втПлан КАК втПлан
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СоставЛистаЗагрузки.Состав КАК СоставЛистаЗагрузкиСостав
	|		ПО втПлан.ШтрихкодПаллеты = СоставЛистаЗагрузкиСостав.ШК
	|ГДЕ
	|	НЕ втПлан.ШтрихкодПаллеты ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.ТипОбъекта КАК ВидНакладной,
	|	вт.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|	вт.НакладнаяНомер КАК НомерНакладной,
	|	вт.ШтрихкодПаллеты КАК ШКПаллеты,
	|	вт.Документ КАК Документ,
	|	вт.Штрихкод КАК ШККоробки,
	|	вт.НомерКоробки КАК НомерКоробки,
	|	вт.ВсегоКоробок КАК ВсегоКоробок,
	|	вт.КонтрагентУИД КАК КонтрагентУИД,
	|	вт.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
	|	вт.ВремяВыполнения КАК ВремяСканирования
	|ИЗ
	|	(ВЫБРАТЬ
	|		втКороба.ТипОбъекта КАК ТипОбъекта,
	|		втКороба.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
	|		втКороба.НакладнаяНомер КАК НакладнаяНомер,
	|		втКороба.ШтрихкодПаллеты КАК ШтрихкодПаллеты,
	|		втКороба.Документ КАК Документ,
	|		втКороба.Штрихкод КАК Штрихкод,
	|		втКороба.НомерКоробки КАК НомерКоробки,
	|		втКороба.ВсегоКоробок КАК ВсегоКоробок,
	|		втКороба.КонтрагентУИД КАК КонтрагентУИД,
	|		втКороба.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
	|		втКороба.ВремяВыполнения КАК ВремяВыполнения
	|	ИЗ
	|		втКороба КАК втКороба
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		втПаллеты.ТипОбъекта,
	|		втПаллеты.ЛистЗагрузкиНомер,
	|		втПаллеты.НакладнаяНомер,
	|		втПаллеты.ШтрихкодПаллеты,
	|		втПаллеты.Документ,
	|		втПаллеты.Штрихкод,
	|		втПаллеты.НомерКоробки,
	|		втПаллеты.ВсегоКоробок,
	|		втПаллеты.КонтрагентУИД,
	|		втПаллеты.ПунктДоставкиУИД,
	|		втПаллеты.ВремяВыполнения
	|	ИЗ
	|		втПаллеты КАК втПаллеты) КАК вт
	|ГДЕ
	|	вт.ВремяВыполнения ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("тзПлан",тзПлана);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = МенВрТаб;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	вт.ТипОбъекта КАК ВидНакладной,
		|	вт.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
		|	вт.НакладнаяНомер КАК НомерНакладной,
		|	вт.ШтрихкодПаллеты КАК ШКПаллеты,
		|	вт.Документ КАК Документ,
		|	вт.Штрихкод КАК ШККоробки,
		|	вт.НомерКоробки КАК НомерКоробки,
		|	вт.ВсегоКоробок КАК ВсегоКоробок,
		|	вт.КонтрагентУИД КАК КонтрагентУИД,
		|	вт.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
		|	вт.ВремяВыполнения КАК ВремяСканирования
		|ИЗ
		|	(ВЫБРАТЬ
		|		втКороба.ТипОбъекта КАК ТипОбъекта,
		|		втКороба.ЛистЗагрузкиНомер КАК ЛистЗагрузкиНомер,
		|		втКороба.НакладнаяНомер КАК НакладнаяНомер,
		|		втКороба.ШтрихкодПаллеты КАК ШтрихкодПаллеты,
		|		втКороба.Документ КАК Документ,
		|		втКороба.Штрихкод КАК Штрихкод,
		|		втКороба.НомерКоробки КАК НомерКоробки,
		|		втКороба.ВсегоКоробок КАК ВсегоКоробок,
		|		втКороба.КонтрагентУИД КАК КонтрагентУИД,
		|		втКороба.ПунктДоставкиУИД КАК ПунктДоставкиУИД,
		|		втКороба.ВремяВыполнения КАК ВремяВыполнения
		|	ИЗ
		|		втКороба КАК втКороба
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		втПаллеты.ТипОбъекта,
		|		втПаллеты.ЛистЗагрузкиНомер,
		|		втПаллеты.НакладнаяНомер,
		|		втПаллеты.ШтрихкодПаллеты,
		|		втПаллеты.Документ,
		|		втПаллеты.Штрихкод,
		|		втПаллеты.НомерКоробки,
		|		втПаллеты.ВсегоКоробок,
		|		втПаллеты.КонтрагентУИД,
		|		втПаллеты.ПунктДоставкиУИД,
		|		втПаллеты.ВремяВыполнения
		|	ИЗ
		|		втПаллеты КАК втПаллеты) КАК вт
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидНакладной,
		|	НомерНакладной,
		|	НомерКоробки";
		
		РезультатЗапросаИтог = Запрос.Выполнить();
		ЛЗ = СоставЛЗ.ЛистЗагрузки;
		ЛЗ= ЛЗ.ПолучитьОбъект();
		ВыборкаДетальныеЗаписи = РезультатЗапросаИтог.Выбрать();
		ЛистыНабора = ЛЗ.ЛистыНабора;
		ЛистыНабора.Очистить();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрока = ЛистыНабора.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
			Если ВыборкаДетальныеЗаписи.ВидНакладной = "РНК" Тогда
				НоваяСтрока.Получатель = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ВыборкаДетальныеЗаписи.КонтрагентУИД));	
			Иначе
				НоваяСтрока.Получатель = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ВыборкаДетальныеЗаписи.КонтрагентУИД));	
			КонецЕсли;
			НоваяСтрока.ПунктДоставки = Справочники.ПунктыДоставки.ПолучитьСсылку(Новый УникальныйИдентификатор(ВыборкаДетальныеЗаписи.ПунктДоставкиУИД));	
		КонецЦикла;
		// +++ {Кузнецов Сергей Владимирович [09.01.2024]
		ЛЗ.СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;	
		// }Кузнецов Сергей Владимирович +++ [09.01.2024]
		ЛЗ.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
	КонецЕсли;
	
	МенВрТаб = Неопределено;
КонецПроцедуры

Функция dataZnb(ШКЗНБ)
	тзШтрихкоды = Новый ТаблицаЗначений;
	тзШтрихкоды.Колонки.Добавить("ПРМ",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПРМУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПРМНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПРМДата",Новый ОписаниеТипов("Дата", , ,
	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	тзШтрихкоды.Колонки.Добавить("ПланНабора",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПланНабораУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПланНабораНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ПланНабораДата",Новый ОписаниеТипов("Дата", , ,
	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	тзШтрихкоды.Колонки.Добавить("ЗНБ",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(50, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЗНБУИД",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(36, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЗНБНомер",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(9, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("ЗНБДата",Новый ОписаниеТипов("Дата", , ,
	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	тзШтрихкоды.Колонки.Добавить("ШКЗНБ",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(32, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("Направление",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(10, ДопустимаяДлина.Переменная)));
	тзШтрихкоды.Колонки.Добавить("Сектор",Новый ОписаниеТипов("Строка", ,
	Новый КвалификаторыСтроки(150, ДопустимаяДлина.Переменная)));
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Перемещение.Ссылка КАК ПРМ,
	|	ВЫБОР
	|		КОГДА Перемещение.Склад = &СкладПаллетногоХранения
	|			ТОГДА ""Вниз""
	|		ИНАЧЕ ""Вверх""
	|	КОНЕЦ КАК Направление,
	|	ПланНабора.Ссылка КАК ПланНабора,
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Сектор КАК Сектор
	|ИЗ
	|	Документ.Перемещение КАК Перемещение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|		ПО (ЗаданиеНабора.Накладная = Перемещение.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
	|		ПО Перемещение.Ссылка = ПланНабора.ДокОснование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
	|		ПО Перемещение.Ссылка = ЛистНабора.ДокОснование
	|ГДЕ
	|	(Перемещение.Склад = &СкладПаллетногоХранения
	|			ИЛИ Перемещение.СкладПолучатель = &СкладПаллетногоХранения)
	|	И ЗаданиеНабора.Проведен
	|	И Перемещение.Проведен";
	Если НЕ ШКЗНБ ="" Тогда
		Запрос.Текст = Запрос.Текст+"
		|   И ЗаданиеНабора.Ссылка = &ЗНБ";
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст+"
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПРМ,
	|	ЗНБ
	|АВТОУПОРЯДОЧИВАНИЕ";
	//Параметры запроса
	// Кухарь А.Ю. 22.12.2025 начало
	// Запрос.УстановитьПараметр("СкладПаллетногоХранения", Справочники.Склады.НайтиПоКоду("STC-27"));  
	Запрос.УстановитьПараметр("СкладПаллетногоХранения", Справочники.Склады.НайтиПоКоду("STЕ-17"));  
	// Кухарь А.Ю. 22.12.2025 конец
	Если НЕ ШКЗНБ ="" Тогда
		ЗНБ_Строкой = Раскодировать64(ШКЗНБ);
		МассивЗНБ = РазложитьСтрокуВМассивПодстрок(ЗНБ_Строкой,"*");
		ЗНБ = Документы.ЗаданиеНабора.НайтиПоНомеру(МассивЗНБ[2],Дата("20"+МассивЗНБ[3],1,1));
		Запрос.УстановитьПараметр("ЗНБ",ЗНБ);
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НачатьТранзакцию();
		
		НоваяСтрока= тзШтрихкоды.Добавить();
		НоваяСтрока.ПРМ = ВыборкаДетальныеЗаписи.ПРМ;
		НоваяСтрока.ПРМНомер = ВыборкаДетальныеЗаписи.ПРМ.Номер;
		НоваяСтрока.ПРМДата = ВыборкаДетальныеЗаписи.ПРМ.Дата;
		НоваяСтрока.ПРМУИД = ВыборкаДетальныеЗаписи.ПРМ.УникальныйИдентификатор();
		
		НоваяСтрока.ПланНабора = ВыборкаДетальныеЗаписи.ПланНабора;
		НоваяСтрока.ПланНабораНомер = ВыборкаДетальныеЗаписи.ПланНабора.Номер;
		НоваяСтрока.ПланНабораДата = ВыборкаДетальныеЗаписи.ПланНабора.Дата;
		НоваяСтрока.ПланНабораУИД = ВыборкаДетальныеЗаписи.ПланНабора.УникальныйИдентификатор();
		
		НоваяСтрока.ЗНБ = ВыборкаДетальныеЗаписи.ЗНБ;
		НоваяСтрока.ЗНБНомер = ВыборкаДетальныеЗаписи.ЗНБ.Номер;
		НоваяСтрока.ЗНБДата = ВыборкаДетальныеЗаписи.ЗНБ.Дата;
