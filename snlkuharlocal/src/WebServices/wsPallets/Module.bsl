			|	СкладТСД.Ссылка КАК Ссылка
			|ИЗ
			|	ПланОбмена.СкладТСД КАК СкладТСД
			|ГДЕ
			|	НЕ(СкладТСД.Наименование = ""Все""
			|				ИЛИ СкладТСД.Наименование = ""Основной"")";
			
			РезультатЗапросаТСД = ЗапросТСД.Выполнить();
			
			ВыборкаДетальныеЗаписиТСД = РезультатЗапросаТСД.Выбрать();
			
			Пока ВыборкаДетальныеЗаписиТСД.Следующий() Цикл
				МассивТСД.Добавить(ВыборкаДетальныеЗаписиТСД.Ссылка);
			КонецЦикла;
			
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НачатьТранзакцию();
				Попытка
					Для каждого ТСД Из МассивТСД Цикл
						ПланыОбмена.ЗарегистрироватьИзменения(ТСД, ВыборкаДетальныеЗаписи.Ссылка);	
					КонецЦикла;
					ПланыОбмена.УдалитьРегистрациюИзменений(ГлавныйУзел, ВыборкаДетальныеЗаписи.Ссылка);
					
					ЗафиксироватьТранзакцию();
				Исключение
					ОтменитьТранзакцию();
					// Сюда писать код обработки ошибки
					ВызватьИсключение;
				КонецПопытки;	
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихКодыИзменения.Ссылка КАК ШК,
	|	ШтрихКодыИзменения.Ссылка.Наименование КАК ШКНаименование,
	|	ШтрихКодыИзменения.Ссылка.ТипШК КАК ТипШК,
	|	ШтрихКодыИзменения.Ссылка.Владелец КАК Номенклатура,
	|	ШтрихКодыИзменения.Ссылка.Владелец.Код КАК НоменклатураКод,
	|	ШтрихКодыИзменения.Ссылка.Владелец.Наименование КАК НоменклатураНаименование,
	|	ШтрихКодыИзменения.Ссылка.Владелец.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	ШтрихКодыИзменения.Ссылка.Владелец.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
	|	ШтрихКодыИзменения.Ссылка.ШтВКоробе КАК ШтукВКоробе
	|ИЗ
	|	Справочник.ШтрихКоды.Изменения КАК ШтрихКодыИзменения
	|ГДЕ
	|	ШтрихКодыИзменения.Узел = &Узел";
	
	Запрос.УстановитьПараметр("Узел", Узел);
	//Запрос.УстановитьПараметр("Узел", ПланыОбмена.СкладТСД.НайтиПоНаименованию("Все",Истина));
	
	тзШтрихкоды = Запрос.Выполнить().Выгрузить();
	тзШтрихкоды.Колонки.Добавить("ШтрихКодыУИД",Новый ОписаниеТипов("УникальныйИдентификатор"));
	тзШтрихкоды.Колонки.Добавить("НоменклатураУИД",Новый ОписаниеТипов("УникальныйИдентификатор"));
	
	Для каждого Строка Из тзШтрихкоды Цикл
		Строка.ШтрихКодыУИД = Строка.ШК.УникальныйИдентификатор();	
		Строка.НоменклатураУИД = Строка.Номенклатура.УникальныйИдентификатор();	
	КонецЦикла;
	тзШтрихкоды.Колонки.Удалить(тзШтрихкоды.Колонки.Найти("ШК"));
	тзШтрихкоды.Колонки.Удалить(тзШтрихкоды.Колонки.Найти("Номенклатура"));
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
	
КонецФункции

Функция setShangesBarcodes(СтруктураПараметров)
	//Ответ = Десериализовать
	СтруктураОтвета = Десериализовать(Десериализовать(СтруктураПараметров).Получить());
	ИДУстройства = СтруктураОтвета.ИДУстройства;
	МассивЗаписанныхШК = СтруктураОтвета.МассивЗаписанныхШК;
	Новый_UID  = Новый УникальныйИдентификатор(ИДУстройства);
	// пытаемся получить объект по UID
	НоваяСсылка = Справочники.Оборудование.ПолучитьСсылку(Новый_UID);
	// пытаемся получить объект
	ТСД = НоваяСсылка.ПолучитьОбъект();
	// проверяем есть ли объект
	Если ТСД = Неопределено Тогда
		НовыйТСД = Справочники. Оборудование.СоздатьЭлемент();
		// для нового объекта – еще не записанного мы можем присвоить UID
		НовыйТСД.УстановитьСсылкуНового(НоваяСсылка);
		// говорим программе что это загрузка объекта
		НовыйТСД.ОбменДанными.Загрузка = Истина;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(Оборудование.Номер), 0) КАК Номер
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.ТипОборудования = &ТипОборудования";
		Запрос.УстановитьПараметр("ТипОборудования", Перечисления.ТипыОборудования.ТСД);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НовыйНомер = 1;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			НовыйНомер = ВыборкаДетальныеЗаписи.Номер + 1;
		КонецЕсли;
		НовыйТСД.Номер = НовыйНомер;
		НовыйТСД.ТипОборудования = Перечисления.ТипыОборудования.ТСД;
		НовыйТСД.Наименование = "" + Перечисления.ТипыОборудования.ТСД + " № " + НовыйНомер;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Оборудование.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Оборудование КАК Оборудование
		|ГДЕ
		|	Оборудование.Наименование = &Наименование
		|	И Оборудование.ЭтоГруппа";
		
		Запрос.УстановитьПараметр("Наименование", Строка(Перечисления.ТипыОборудования.ТСД));
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			НоваяГруппа = Справочники.Оборудование.СоздатьГруппу();
			НоваяГруппа.Наименование = Строка(Перечисления.ТипыОборудования.ТСД);
			НоваяГруппа.Записать();
			Родитель = НоваяГруппа.Ссылка;
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			Родитель = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
		НовыйТСД.Родитель = Родитель;
		НовыйТСД.Записать();
		ТСД = НовыйТСД.Ссылка;
	Иначе 
		ТСД = ТСД.Ссылка;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладТСД.Ссылка КАК Ссылка
	|ИЗ
	|	ПланОбмена.СкладТСД КАК СкладТСД
	|ГДЕ
	|	СкладТСД.ТСД = &ТСД";
	
	Запрос.УстановитьПараметр("ТСД", ТСД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		НовыйУзел = ПланыОбмена.СкладТСД.СоздатьУзел();	
		НовыйУзел.УстановитьНовыйКод();
		НовыйУзел.Наименование = Строка(ТСД);
		НовыйУзел.ТСД = ТСД;
		НовыйУзел.Записать();
		Узел = НовыйУзел.Ссылка;
	Иначе
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		Узел = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	Для каждого ЭлементМассива Из МассивЗаписанныхШК Цикл
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Справочники.Штрихкоды.ПолучитьСсылку(ЭлементМассива));
	КонецЦикла;
	Возврат Истина;
КонецФункции

