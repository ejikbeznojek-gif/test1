		ПРМ_Объект =  ВыборкаДетальныеЗаписи.ПРМ.ПолучитьОбъект();
		//ПРМ_Объект.ОбменДанными.Загрузка = Истина;
		ПРМ_Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ВНаборе;
		ПРМ_Объект.Записать();
		
		ЗНБ_Объект =  ВыборкаДетальныеЗаписи.ЗНБ.ПолучитьОбъект();
		//ЗНБ_Объект.ОбменДанными.Загрузка = Истина;
		ЗНБ_Объект.ОтправленНаТСД = Истина;
		ЗНБ_Объект.Записать();
		
		ПланНабораОбъект = ВыборкаДетальныеЗаписи.ПланНабора.ПолучитьОбъект();
		//ПланНабораОбъект.ОбменДанными.Загрузка = Истина;
		СтрокаПланаНабора = ПланНабораОбъект.тБрэндов.Найти(ЗНБ_Объект.НомерЧасти);
		СтрокаПланаНабора.Состояние = Перечисления.СостоянияНакладной.ВНаборе;
		СтрокаПланаНабора.ВремяТекущегоСостояния = ТекущаяДата();
		ПланНабораОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
		
	КонецЦикла;
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(тзШтрихкоды), Новый СжатиеДанных(9)));
	Возврат Ответ;
КонецФункции

