
Функция НачатьОбмен(КодУзла, НомерОтправленного, НомерПринятого)	
	
	УзелОбмена = ПланыОбмена.МобильныеТСД.НайтиПоКоду(КодУзла);
	
	Если УзелОбмена.Пустая() Тогда Возврат "" КонецЕсли;	
	
	Если УзелОбмена.НомерОтправленного <> НомерОтправленного ИЛИ УзелОбмена.НомерПринятого <> НомерПринятого Тогда
		
		Узел 					= УзелОбмена.ПолучитьОбъект();
		
		Узел.НомерОтправленного = НомерОтправленного;		
		Узел.НомерПринятого		= НомерПринятого;
		
		Узел.Записать();
		
		//Обмен.ЗарегистрироватьИзмененияДанных(УзелОбмена);		
	КонецЕсли;	
	
	Возврат УзелОбмена.Код;	
КонецФункции

//Кухарь 15.08.19 начало
//Не пойму зачем 2 раза соединятся с базой через WS
//если можно всё сделать 1м соединением
//Перенёс сюда функцию НачатьОбмен() а её саму удалю потом, когда выясню, что ничего не сломалось
//Функция ПолучитьДанные(КодУзла,ШтрихКод)
Функция ПолучитьДанные(КодУзла,ШтрихКод, НомерОтправленного, НомерПринятого, ВидКоманды, ТаблицаПараметров)
	ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("wsExchangeTSD.ПолучитьДанные");	
	Ошибки = "";
	
	ЧтениеJSON = Новый ЧтениеJSON;                                 
	ЧтениеJSON.УстановитьСтроку(ТаблицаПараметров);
	СтруктураДопПараметров = Новый Структура;
	
	пока ЧтениеJSON.Прочитать() цикл
		если ЧтениеJSON.ТипТекущегоЗначения=ТипЗначенияJSON.ИмяСвойства тогда
			ИмяСвойства=ЧтениеJSON.ТекущееЗначение;
			Продолжить;
		КонецЕсли;
		если ИмяСвойства<>Неопределено и (ЧтениеJSON.ТипТекущегоЗначения=ТипЗначенияJSON.Строка или ЧтениеJSON.ТипТекущегоЗначения=ТипЗначенияJSON.Число или ЧтениеJSON.ТипТекущегоЗначения=ТипЗначенияJSON.Булево)  тогда
			СтруктураДопПараметров.Вставить(ИмяСвойства,ЧтениеJSON.ТекущееЗначение);
		КонецЕсли;
	КонецЦикла;
	//////////////////////////////////////////////////////////
	
	// Кухарь А.Ю.  18.01.2023 начало
	// проверим, что дата на ТСД - правильная
	если СтруктураДопПараметров.Свойство("ТекущаяДатаТСД") тогда
		попытка
			ТекущаяДатаТСД=СтруктураДопПараметров.ТекущаяДатаТСД;
			ТекущаяДатаТСД=СтрЗаменить(ТекущаяДатаТСД,"-","");
			ТекущаяДатаТСД=СтрЗаменить(ТекущаяДатаТСД,"T","");
			ТекущаяДатаТСД=СтрЗаменить(ТекущаяДатаТСД,":","");
			ТекущаяДатаТСД=Дата(ТекущаяДатаТСД);
			
			Дельта=Модуль(ТекущаяДатаТСД-ТекущаяДата());
			если дельта>3600 тогда
				возврат Новый ХранилищеЗначения("Ошибки: Неверная дата устройства. Настройте на ТСД правильные дату и время.", Новый СжатиеДанных(9));
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	УзелОбмена = ПланыОбмена.МобильныеТСД.НайтиПоКоду(КодУзла);
	
	Если УзелОбмена.Пустая() Тогда		
		ВызватьИсключение("Неизвестное устройство – " + КодУзла);		
	КонецЕсли;
	
	Если УзелОбмена.НомерОтправленного <> НомерОтправленного ИЛИ УзелОбмена.НомерПринятого <> НомерПринятого Тогда		
		Узел 					= УзелОбмена.ПолучитьОбъект();	
		Узел.НомерОтправленного = НомерОтправленного;		
		Узел.НомерПринятого		= НомерПринятого;		
		Узел.Записать();		
	КонецЕсли;	
	
	ДопПараметры = Новый Структура();
	ДопПараметры.Вставить("ШтрихКодСпецификации", "");
	
	Если ШтрихКод <> "" Тогда			
		
		// Кельманов А.В. - SNL-120 - 2026.04.08 {
		//Результат = ОбменСТСД.ЗарегистрироватьЗаданиеНаНаборПоШК(УзелОбмена, ШтрихКод, Ошибки, СтруктураДопПараметров);	
		//
		//Если Не Результат Тогда		
		//	
		//	Ошибки = "Ошибки:" + Ошибки;			
		//	
		//	Возврат Новый ХранилищеЗначения(Ошибки, Новый СжатиеДанных(9));	
		//	
		//КонецЕсли;
		//
		//ДопПараметры.ШтрихКодСпецификации = ШтрихКод;
		Если ВидКоманды = "ПолучитьДанныеFBS" Тогда
			
			Результат = ОбменСТСД.ЗарегистрироватьДанныеFBSПоНакладной(УзелОбмена, ШтрихКод, Ошибки, СтруктураДопПараметров);	
			
			Если Не Результат Тогда		
				
				Ошибки = "Ошибки:" + Ошибки;			
				
				Возврат Новый ХранилищеЗначения(Ошибки, Новый СжатиеДанных(9));	
				
			КонецЕсли;
			
			ДопПараметры.Вставить("ДополнительныеДанныеДляFBS", Истина);
			
		Иначе
			
			Результат = ОбменСТСД.ЗарегистрироватьЗаданиеНаНаборПоШК(УзелОбмена, ШтрихКод, Ошибки, СтруктураДопПараметров);	
			
			Если Не Результат Тогда		
				
				Ошибки = "Ошибки:" + Ошибки;			
				
				Возврат Новый ХранилищеЗначения(Ошибки, Новый СжатиеДанных(9));	
				
			КонецЕсли;
			
			ДопПараметры.ШтрихКодСпецификации = ШтрихКод;
			
		КонецЕсли;
		// Кельманов А.В. - SNL-120 - 2026.04.08 }
			
	КонецЕсли;
	
	
	// Кухарь А.Ю.  22.06.2025 начало 
	// HELP-5280
	если ВидКоманды = "ПолучитьЛистыЗНА" тогда    
		ДопПараметры.Вставить("Узел",УзелОбмена);   
		если СтруктураДопПараметров.Свойство("ШтрихКод") тогда
			ДопПараметры.Вставить("ШтрихКод",СтруктураДопПараметров.ШтрихКод); 
		иначе  
			ДопПараметры.Вставить("ШтрихКод",""); 
		КонецЕсли;
		
		если СтруктураДопПараметров.Свойство("УИД_ЗНА") тогда
			ДопПараметры.Вставить("УИД_ЗНА",СтруктураДопПараметров.УИД_ЗНА); 
		иначе  
			ДопПараметры.Вставить("УИД_ЗНА",""); 
		КонецЕсли;
		
		
		если СтруктураДопПараметров.Свойство("НужныТолькоЛП") тогда
			ДопПараметры.Вставить("НужныТолькоЛП",СтруктураДопПараметров.НужныТолькоЛП); 
		иначе  
			ДопПараметры.Вставить("НужныТолькоЛП",ложь); 
		КонецЕсли;			
		
		если СтруктураДопПараметров.Свойство("Сканировщик") тогда
			ДопПараметры.Вставить("Сканировщик",СтруктураДопПараметров.Сканировщик); 
		иначе  
			ДопПараметры.Вставить("Сканировщик",Справочники.ФизическиеЛица.ПустаяСсылка()); 
		КонецЕсли;			
		
		если СтруктураДопПараметров.Свойство("КоличествоКоробок") тогда
			ДопПараметры.Вставить("КоличествоКоробок",СтруктураДопПараметров.КоличествоКоробок); 
		иначе  
			ДопПараметры.Вставить("КоличествоКоробок",1); 
		КонецЕсли;		
		
		
		РезультатПолучения =  ОбменСТСД.ЗарегистрироватьДанныеЗНА(ДопПараметры);  
		если не РезультатПолучения.Успех тогда    
			Ошибки = "Ошибки:" + СтрСоединить(РезультатПолучения.Ошибки,", ");
			Возврат Новый ХранилищеЗначения(Ошибки, Новый СжатиеДанных(9));
		КонецЕсли;	
	КонецЕсли;
	// Кухарь А.Ю.  22.06.2025 конец
	
	// Кельманов А.В. - ASU-2104 - 2025.03.22 {
	Если ВидКоманды = "СоздатьПолучитьДанныеЛСК" Тогда
		
		Если СтруктураДопПараметров.Свойство("ДополнительныеДанные") Тогда
			
			// Кельманов А.В. - HELP-3850 - 2025.04.07 {
			//Результат = СоздатьПолучитьЛСК_ДляТСД(УзелОбмена, Ошибки, СтруктураДопПараметров.ДополнительныеДанные);
			Результат = СоздатьПолучитьЛСК_ДляТСД(УзелОбмена, Ошибки, СтруктураДопПараметров);
			// Кельманов А.В. - HELP-3850 - 2025.04.07 }
			
			Если Не Результат Тогда
				
				Ошибки = "Ошибки:" + Ошибки;
				
				Возврат Новый ХранилищеЗначения(Ошибки, Новый СжатиеДанных(9));
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	// Кельманов А.В. - ASU-2104 - 2025.03.22 }
	
	Если ВидКоманды = "ЗагрузитьНачальныеДанные" Тогда
		
		ОбменСТСД.ЗарегистрироватьНачальныеДанные(УзелОбмена);
		
		// Кельманов А.В. - ASU-1746 - 2025.02.11 {
	ИначеЕсли ВидКоманды = "ОбновитьПринтерыЭтикеток" Тогда
		
		ОбменСТСД.ЗарегистрироватьСправочникПринтерыЭтикеток(УзелОбмена);
		
		// Кельманов А.В. - ASU-1746 - 2025.02.11 }
		
		// Кухарь А.Ю. 07.04.2022 начало
	ИначеЕсли СтрНайти(ВидКоманды, "ЗагрузитьТипКоробаПоШК") > 0 Тогда
		
		ШК = СтрЗаменить(ВидКоманды, "ЗагрузитьТипКоробаПоШК", "");
		
		Результат = ОбменСТСД.ЗарегистрироватьТипКоробаПоШК(УзелОбмена, ШК, Ошибки);
		
		Если Не Результат Тогда
			
			Возврат Новый ХранилищеЗначения("Ошибки:" + Ошибки, Новый СжатиеДанных(9));
			
		КонецЕсли;		
		// Кухарь А.Ю. 07.04.2022 конец
		
	КонецЕсли;
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();
	
	Возврат ОбменСТСД.СформироватьПакетОбмена(УзелОбмена, ДопПараметры);	
	
КонецФункции

Функция ЗаписатьДанные(КодУзла, ДанныеМобильногоПриложения, ТаблицаПараметров)
	
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("wsExchangeTSD.ЗаписатьДанные");	
	УзелОбмена = ПланыОбмена.МобильныеТСД.НайтиПоКоду(КодУзла);
	
	Если УзелОбмена.Пустая() Тогда
		ВызватьИсключение("Неизвестное устройство - " + КодУзла);
	КонецЕсли;
	
	Ошибки = "";
	
	Оповещения = ""; 

	ЧтениеJSON = Новый ЧтениеJSON;                                 
	ЧтениеJSON.УстановитьСтроку(ТаблицаПараметров);
	
	СтруктураДопПараметров = Новый Структура;
	
	Пока ЧтениеJSON.Прочитать() Цикл
		
		Если ЧтениеJSON.ТипТекущегоЗначения = ТипЗначенияJSON.ИмяСвойства Тогда
			ИмяСвойства = ЧтениеJSON.ТекущееЗначение;
			Продолжить;
		КонецЕсли;
		
		Если ИмяСвойства <> Неопределено И (ЧтениеJSON.ТипТекущегоЗначения = ТипЗначенияJSON.Строка Или ЧтениеJSON.ТипТекущегоЗначения = ТипЗначенияJSON.Число 
			Или ЧтениеJSON.ТипТекущегоЗначения = ТипЗначенияJSON.Булево) Тогда
			СтруктураДопПараметров.Вставить(ИмяСвойства, ЧтениеJSON.ТекущееЗначение);
		КонецЕсли;
		
	КонецЦикла;

	МассивОбъектовСОшибками = Неопределено;
	
	Результат = ОбменСТСД.ПринятьПакетОбмена(УзелОбмена, ДанныеМобильногоПриложения, СтруктураДопПараметров, Ошибки, Оповещения, МассивОбъектовСОшибками);
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();
	
	
	Если Ошибки = "" И Оповещения <> "" Тогда
		
		Оповещения = "Оповещение " + Оповещения;
		
		Возврат Оповещения;
	Иначе
		Если ТипЗнч(МассивОбъектовСОшибками) = Тип("Массив") Тогда
			
			МассивОбъектовСОшибками.Добавить(Ошибки);
			
			Возврат Сериализовать(Новый ХранилищеЗначения(Сериализовать(МассивОбъектовСОшибками), Новый СжатиеДанных(9)));
		Иначе
			Возврат Ошибки;
		КонецЕсли;
	КонецЕсли;
КонецФункции

Функция ЗаписатьЛоги(КодУзла,ТекстЛога)
	УзелОбмена = ПланыОбмена.МобильныеТСД.НайтиПоКоду(КодУзла);
	
	Если УзелОбмена.Пустая() Тогда
		ВызватьИсключение("Неизвестное устройство - " + КодУзла);
	КонецЕсли;
	Ошибки="";
	
	Результат= ОбменСТСД.ЗаписатьЛоги(УзелОбмена, ТекстЛога,,Ошибки);
	
	
	возврат Ошибки;
	
КонецФункции

Функция ПолучитьДанныеМарки(markName)
	
	Данные = ПолучитьДанныеКодаЧЗДляТСД(markName);
	
	Возврат Данные;
	
КонецФункции

