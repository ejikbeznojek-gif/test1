Функция ВыполнитьПроверкиTSD(Data,Info)
	
	СтруктураВозврата = новый Структура ("Успех,Ошибки,Данные",Ложь,Новый Массив,Неопределено);
	
    Данные = ДесериализоватьЛокальная(Data);	
    СтруктураДопПараметров = ДесериализоватьЛокальная(Info);

	Если  СтруктураДопПараметров.Свойство ("ИмяДействия")  тогда 
		если СтруктураДопПараметров.ИмяДействия = "ПроверитьЛистПереукладкиПередВыгрузкойИзТСД" тогда 
			СтруктураВозврата = ОбменСТСД.ПроверитьЛистПереукладкиПередВыгрузкойИзТСД(Данные);
		КонецЕсли;
	КонецЕсли;

	Возврат Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураВозврата), Новый СжатиеДанных(9)));

КонецФункции    

