Функция СтавкаНДСПоУмолчанию(Дата) Экспорт
	Результат = Перечисления.СтавкиНДС.НДС18;
	
	Если Дата >= '20260101'  Тогда           
		Результат = Перечисления.СтавкиНДС.НДС22;	
	ИначеЕсли Дата >= '20190101'  Тогда           
		Результат = Перечисления.СтавкиНДС.НДС20;				
	КонецЕсли;	
	
    Возврат Результат;
КонецФункции //СтавкаНДСПоУмолчанию(Дата) Экспорт