Процедура ЗагрузкаМониторинга()
	Перем Запр;
	Перем Spid;
	Перем mon;
	
	try
		ЗапросМониторинг=Новый Запрос("Выбрать ""softpoint auth""");
		ЗапросМониторинг.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
