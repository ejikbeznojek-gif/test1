Функция глСформироватьШКДокаСоСтрокой(Док,ИДСтроки,НомерСпецификации) экспорт
	
	Если Док.Пустая() Тогда Возврат "" КонецЕсли;
	КодИсх="*"+ИдПоВидуДокумента(Док.Метаданные().Имя)+"*"+Док.Номер+"*"+Прав(""+Год(Док.Дата),2)+"**"+НомерСпецификации;
	ШК = Закодировать64(КодИсх);
	НаборЗаписей = РегистрыСведений.ИнформацияШКПланаНабора.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ШКНабораСтрокПланаНабора.Использование	=Истина;
	НаборЗаписей.Отбор.ШКНабораСтрокПланаНабора.Значение		=ШК;
	НаборЗаписей.Очистить();
    Запись = НаборЗаписей.Добавить();
	Запись.ШКНабораСтрокПланаНабора = ШК;
	Запись.СписокНомеровСтрок = ИДСтроки;
	НаборЗаписей.Записать();

	Возврат ШК;
КонецФункции 
