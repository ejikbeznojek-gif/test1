Функция глНайтиДокПоШК(ШК, ТекстОшибки = "") Экспорт
	// Кельманов А.В. - SNL-119 - 2026.03.16 }
	
	ТекСтр=СокрЛП(ШК);
	ТекСтр=Раскодировать64(ТекСтр);
	
	Если Сред(ТекСтр,1,1)<>"*" Тогда
		
		// Кельманов А.В. - SNL-119 - 2026.03.16 {
		//Сообщить("Штрих-код: """+ШК+""" не является штрих-кодом документа !");
		ТекстОшибки = "Штрих-код: """ + ШК + """ не является штрих-кодом документа !";
		Сообщить(ТекстОшибки);
		// Кельманов А.В. - SNL-119 - 2026.03.16 }
		
		Возврат "";
		
	КонецЕсли;	
	
	Если ПустаяСтрока(ТекСтр)=0 Тогда
		ТекСтр=Сред(ТекСтр,2,СтрДлина(ТекСтр)-2);
		ТекСтр=СтрЗаменить(ТекСтр,"*",Символы.ПС);
		
		СЗ=Новый Структура;
		
		Для Сч=1 По СтрЧислоСтрок(ТекСтр) Цикл
			СЗ.Вставить("Пар"+Сч,СтрПолучитьСтроку(ТекСтр,Сч));					
		КонецЦикла; 		
		
		Ид  	=СЗ.Пар1;
		Номер 	=СЗ.Пар2;         
		Дт  	=СЗ.Пар3;
		Дт  	=Дата("20"+Дт,1,1);
		
		Вид=ВидПоИдДокумента(Ид);
		Если ПустаяСтрока(Вид)=1 Тогда
			
			// Кельманов А.В. - SNL-119 - 2026.03.16 {
			//Сообщить("Не обнаружен вид документа соответствующий ИД: """+Ид+""" !","!");     
			ТекстОшибки = "Не обнаружен вид документа соответствующий ИД: """ + Ид + """ !";
			Сообщить(ТекстОшибки, "!");
			// Кельманов А.В. - SNL-119 - 2026.03.16 }
			
			Возврат Неопределено;
			
		КонецЕсли;
		
		Док=Документы[Вид].НайтиПоНомеру(Номер,Дт);
		
		Если Док<>Неопределено И НЕ Док.Пустая() Тогда
			Возврат Док;   
		КонецЕсли;
	КонецЕсли; 
	
	Возврат Неопределено;
	
КонецФункции //глНайтиДокПоШК


 //загрузка XMl при измененной структуре метаданных
Функция ПолучитьСтруктуруОбъекта(МетаОбъект)
	СтруктураОбъекта=Новый Соответствие;
	
	Если ТипОбъекта(МетаОбъект)="Документ" Тогда
		
		//<Ref>cb7ebfea-760e-11db-abb3-0016e65e0172</Ref>
		//<DeletionMark>false</DeletionMark>
		//<Date>2006-11-17T10:39:46</Date>
		//<Number>1</Number>
		//<Posted>true</Posted>
		
		СвойстваРеквизита=Новый Структура("Тип",Тип("ДокументСсылка."+МетаОбъект.Имя));
		СтруктураОбъекта.Вставить("Ref",СвойстваРеквизита);
		
		СвойстваРеквизита=Новый Структура("Тип",Тип("Булево"));
		СтруктураОбъекта.Вставить("DeletionMark",СвойстваРеквизита);
		
		СвойстваРеквизита=Новый Структура("Тип",Тип("Дата"));
		СтруктураОбъекта.Вставить("Date",СвойстваРеквизита);
		
		СвойстваРеквизита=Новый Структура("Тип",Тип("Строка"));
		СтруктураОбъекта.Вставить("Number",СвойстваРеквизита);
		
		СвойстваРеквизита=Новый Структура("Тип",Тип("Булево"));
		СтруктураОбъекта.Вставить("Posted",СвойстваРеквизита);
		
		Для Каждого Реквизит Из МетаОбъект.Реквизиты Цикл
			
			СвойстваРеквизита=Новый Структура("Тип",ТипМетаРеквизита(Реквизит));
			СтруктураОбъекта.Вставить(Реквизит.Имя,СвойстваРеквизита);
			
			Для Каждого ТЧ Из МетаОбъект.ТабличныеЧасти Цикл				
				СтруктураТЧ=Новый Соответствие;
				Для Каждого Реквизит Из ТЧ.Реквизиты Цикл
					СвойстваРеквизита=Новый Структура("Тип",ТипМетаРеквизита(Реквизит));
					СтруктураТЧ.Вставить(Реквизит.Имя,СвойстваРеквизита);
				КонецЦикла; 
				
				СвойстваРеквизита=Новый Структура("Тип,Структура","ТабличнаяЧасть",СтруктураТЧ);
				СтруктураОбъекта.Вставить(ТЧ.Имя,СвойстваРеквизита);			
			КонецЦикла; 
		КонецЦикла;	
	КонецЕсли;
	
	Возврат СтруктураОбъекта;
КонецФункции // ПолучитьСтруктуруОбъекта()

Функция ТипРеквизита(Чтение,МетаТипРеквизита)
	ТипXML=ПолучитьXMLТип(Чтение);
	
	Если ТипXML<>Неопределено Тогда
		ТипРеквизита=ИзXMLТипа(ТипXML);	
	КонецЕсли;	
	Если ТипРеквизита=Неопределено Тогда
		ТипРеквизита=МетаТипРеквизита;		
	КонецЕсли;
	
	Возврат ТипРеквизита;
КонецФункции // ТипРеквизита() 

Функция ТипМетаРеквизита(МетаРеквизит)
	Если МетаРеквизит.Тип.Типы().ВГраница()>0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат МетаРеквизит.Тип.Типы()[0];			
	КонецЕсли;
КонецФункции // ТипМетаРеквизита()

Функция ЗагрузитьРеквизит(Чтение,МетаТипРеквизита)
	ТипРеквизита=ТипРеквизита(Чтение,МетаТипРеквизита);
	
	Значение=Неопределено;
	
	Если Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда		
		Чтение.Прочитать();	
		Если Чтение.ТипУзла=ТипУзлаXML.Текст Тогда			
			Значение=XMLЗначение(ТипРеквизита,Чтение.Значение);
		КонецЕсли; 
	КонецЕсли; 
	
	Если Чтение.ТипУзла<>ТипУзлаXML.КонецЭлемента Тогда	Чтение.Прочитать() КонецЕсли;
	
	Возврат Значение;
КонецФункции // ЗагрузитьРеквизит()

Функция ЗагрузитьСтрокуТЧ(Чтение,Структура,СтрокаТЧ)	
	Уровень=1;
	Пока Чтение.Прочитать() Цикл
		ТипУзла=Чтение.ТипУзла;
		ИмяУзла=Чтение.Имя;

		Если ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда
			Уровень=Уровень+1;
			
			ОписаниеРеквизита=Структура[ИмяУзла];
			Если ОписаниеРеквизита<>Неопределено Тогда
				СтрокаТЧ[ИмяУзла]=ЗагрузитьРеквизит(Чтение,ОписаниеРеквизита.Тип);			
			КонецЕсли;
		КонецЕсли;
		
		Если Чтение.ТипУзла=ТипУзлаXML.КонецЭлемента Тогда
			Уровень=Уровень-1;
			
			Если ИмяУзла="Row" И Уровень=0 Тогда
				Возврат СтрокаТЧ;			
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла; 
	
	Сообщить("Плохой выхлоп !!!",СтатусСообщения.ОченьВажное);
КонецФункции // ЗагрузитьСтрокуТЧ() 

Функция ЗагрузитьТЧ(Чтение,СтруктураТЧ)
	Уровень=0;
	
	ТЧ=Новый ТаблицаЗначений;
	Для Каждого Реквизит Из СтруктураТЧ Цикл		
		МассивТипов=Новый Массив;
		МассивТипов.Добавить(Реквизит.Значение.Тип);
		ТипКолонки=Новый ОписаниеТипов(МассивТипов);
		ТЧ.Колонки.Добавить(Реквизит.Ключ,ТипКолонки);	
	КонецЦикла; 
	
	ИмяТЧ=Чтение.Имя;	
	Пока Чтение.Прочитать() Цикл
		ТипУзла=Чтение.ТипУзла;
		ИмяУзла=Чтение.Имя;
		
		Если ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда			
			Если ИмяУзла="Row" Тогда
				СтрокаТЧ=ТЧ.Добавить();		
				
				ЗагрузитьСтрокуТЧ(Чтение,СтруктураТЧ,СтрокаТЧ);			
			КонецЕсли; 						
		ИначеЕсли ТипУзла=ТипУзлаXML.КонецЭлемента Тогда			
			Если Чтение.Имя=ИмяТЧ Тогда Возврат ТЧ КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТЧ;
КонецФункции // ЗагрузитьТЧ()


Функция ЗагрузитьДокументИз_XML(Чтение,ТипОбъекта) Экспорт
	Структура	=КэшСтруктур[ТипОбъекта];
	МетаОбъект	=Метаданные.НайтиПоТипу(ТипОбъекта);
	Если Структура=Неопределено Тогда		
		Структура	=ПолучитьСтруктуруОбъекта(МетаОбъект);		
		КэшСтруктур.Вставить(ТипОбъекта,Структура);
	КонецЕсли; 
	
	Объект=Неопределено;
	
	ИмяУзлаОбъекта	=Чтение.Имя;
	Пока Чтение.Прочитать() Цикл				
		Если Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда
			ИмяРеквизита		=Чтение.Имя;
			РеквизитСтруктуры	=Структура[ИмяРеквизита];
			
			Если РеквизитСтруктуры=Неопределено Тогда Продолжить КонецЕсли; //нет реквизита в объекте
			
			МетаТипРеквизита=РеквизитСтруктуры.Тип;
			
			ЗначениеРеквизита=Неопределено;
			
			ТипРеквизита=ТипРеквизита(Чтение,МетаТипРеквизита);					
			
			Если ТипРеквизита="ТабличнаяЧасть" Тогда						
				ТЧ=ЗагрузитьТЧ(Чтение,Структура[ИмяРеквизита].Структура);
				
				Объект[ИмяРеквизита].Очистить();
				Объект[ИмяРеквизита].Загрузить(ТЧ);				
			Иначе
				ЗначениеРеквизита	=ЗагрузитьРеквизит(Чтение,МетаТипРеквизита);							
				
				Если ИмяРеквизита="Ref" Тогда
					Объект=ЗначениеРеквизита.ПолучитьОбъект();
					
					Если Объект=Неопределено Тогда
						Объект=Документы[МетаОбъект.Имя].СоздатьДокумент();				
						Объект.УстановитьСсылкуНового(ЗначениеРеквизита);						
					КонецЕсли;			
				Иначе
					Объект[ИмяРеквизита]=ЗначениеРеквизита;
				КонецЕсли; 				
			КонецЕсли;
		КонецЕсли;
		
		Если Чтение.ТипУзла=ТипУзлаXML.КонецЭлемента И Чтение.Имя=ИмяУзлаОбъекта Тогда Прервать КонецЕсли;			
	КонецЦикла; 
	
	Возврат Объект;
КонецФункции

Процедура ПередНачаломРаботыСистемы(Отказ)
	Если РольДоступна("Automat") Тогда
		Отказ=Истина;
	КонецЕсли;					
	Если ПараметрыПриложения = Неопределено Тогда
		ПараметрыПриложения = Новый Соответствие;
	КонецЕсли;
КонецПроцедуры

