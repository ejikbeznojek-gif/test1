    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЖурналДокументовАРМ_Паллетировщика.Ссылка КАК Ссылка,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.Дата) КАК Дата,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.Номер) КАК Номер,
	ЖурналДокументовАРМ_Паллетировщика.Тип КАК Тип,
	ЖурналДокументовАРМ_Паллетировщика.ПометкаУдаления КАК ПометкаУдаления,
	ЖурналДокументовАРМ_Паллетировщика.Проведен КАК Проведен,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.ДатаОтгрузки) КАК ДатаОтгрузки,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.Контрагент) КАК Контрагент,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.Склад) КАК Склад,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.СостояниеНакладной) КАК СостояниеНакладной,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.Отгружен) КАК Отгружен,
	МАКСИМУМ(ЖурналДокументовАРМ_Паллетировщика.НужноПаллетирование) КАК НужноПаллетирование,
	СУММА(ЖурналДокументовАРМ_Паллетировщика.КоличествоКоробок) КАК КоличествоКоробок,
	КОЛИЧЕСТВО(ПаллетаЛистыНабора.ЛистНабора) КАК ВсегоКоробокВПаллетах,
	&quot;&quot; КАК СостояниеПаллетирования
ИЗ
	ЖурналДокументов.АРМ_Паллетировщика КАК ЖурналДокументовАРМ_Паллетировщика
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		ПО ЖурналДокументовАРМ_Паллетировщика.Ссылка = ПаллетаЛистыНабора.Документ
ГДЕ
	ЖурналДокументовАРМ_Паллетировщика.Проведен
	И ЖурналДокументовАРМ_Паллетировщика.Дата > &amp;ДатаЗапретаРедактирования
	И ЖурналДокументовАРМ_Паллетировщика.Отгружен = ЗНАЧЕНИЕ(Перечисление.Отгружен.Резерв)

СГРУППИРОВАТЬ ПО
	ЖурналДокументовАРМ_Паллетировщика.Ссылка,
	ЖурналДокументовАРМ_Паллетировщика.ПометкаУдаления,
	ЖурналДокументовАРМ_Паллетировщика.Проведен,
	ЖурналДокументовАРМ_Паллетировщика.Тип</queryText>
      <mainTable>DocumentJournal.АРМ_Паллетировщика</mainTable>
