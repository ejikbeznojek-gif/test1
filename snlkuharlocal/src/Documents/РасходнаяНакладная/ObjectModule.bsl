Процедура СформироватьДляЕДО(ДокОбъект, Ошибка) Экспорт
	
	//нечаева 18,05,21+++
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом тогда
	Если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда
		//Кухарь А.Ю. 31.03.2026 конец
       
		ЗаписатьВЛог("ОшибкиЕкод","Отмена выполнения. подтверждение не создано "+ДокОбъект+" база "+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
		
		ошибка=1;
		
		Возврат ;
	КонецЕсли;
	// нечаева 18,05,21----
	
	
	Если ПустаяСтрока(ДокОбъект.НомерЗаказа) Тогда
		Ошибка = 1;
		#Если Клиент Тогда
			Сообщить(Строка(ДокОбъект)+" - не заполнен номер заказа. Уведомление об отгрузке не создано");
		#Иначе
			ЗаписатьВЛог("ЕКОД",Строка(ДокОбъект)+" - не заполнен номер заказа. Уведомление об отгрузке не создано","Важное");
		#КонецЕсли
		Возврат;
	КонецЕсли;
	
	//Нечаева 07,04,15+++
	Если СтрДлина(ПунктДоставки.КодИЛН) = 0  Тогда
		Ошибка = 1;
		#Если Клиент Тогда
			Сообщить(Строка(ДокОбъект)+" - не заполнен номер GLN у пункта доставки. Уведомление об отгрузке не создано");
