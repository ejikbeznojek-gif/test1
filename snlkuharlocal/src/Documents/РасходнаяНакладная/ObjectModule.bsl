Процедура УстановитьСостояниеДокументов(НовоеСостояниеДокументов,КодУзла = Неопределено,НЕКонтрольСФ = Неопределено) Экспорт
	//крохин начало 15.04.2013
	Если НЕКонтрольСФ <> Неопределено И  НеКонтрольСФ Тогда
		НеконтролироватьНаличиеСФ = Истина;
	КонецЕсли;
	//крохин конец 15.04.2013
	//крохин начало 15.02.2013
	//теперь не выгружаем документ, вместо этого делаем запись в регистре сведений "состояние документов", 
	//на основании которого обработкой проставляем состояния в ЦО
	
	////крохин начало 09.02.2011
	////за датой запрета записываем реквизиты только в ЦО
	////НеКонтролироватьЗапись=Истина;
	////СостояниеДокументов=НовоеСостояниеДокументов;
	////Записать();
	////НеКонтролироватьЗапись=Ложь;
	//Отказ = Ложь;
	//Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
	//	Отказ = Истина;
	//КонецЕсли;
	//Если Отказ Тогда
	//	Если	ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение  Тогда
	//	НеКонтролироватьЗапись=Истина;
	//СостояниеДокументов=НовоеСостояниеДокументов;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;	
	//	КонецЕсли;
	//Иначе
	//НеКонтролироватьЗапись=Истина;
	//СостояниеДокументов=НовоеСостояниеДокументов;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	//КонецЕсли;
	////крохин конец 09.02.2011
	Если СостояниеДокументов <> НовоеСостояниеДокументов Тогда
		НеВыгружатьДокумент = Истина;
		НеКонтролироватьЗапись=Истина;
		СостояниеДокументов=НовоеСостояниеДокументов;
		Записать();
		Если КодУзла = Неопределено Тогда
			СписокПолучателей = Новый СписокЗначений;
			Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				//крохин начало 29.03.2013
				//только для складов с указанным кодом
				//СписокПолучателей.Добавить(Склад.КодФизическогоУзла);
				Если НЕ ПустаяСтрока(Склад.КодФизическогоУзла) Тогда
					СписокПолучателей.Добавить(Склад.КодФизическогоУзла);
				КонецЕсли;
				//крохин конец 29.03.2013
				
				ПодразделениеДоговора=Договор.Подразделение;
				
				//крохин начало 01.09.2011
				//кроме пустых подразделений
				//Если ПодразделениеДоговора<>ЭтотУзел.Подразделение Тогда
				Если ПодразделениеДоговора<>ПараметрыСеанса.ЭтотУзел.Подразделение И НЕ ПодразделениеДоговора.пустая() Тогда
					//крохин конец 01.09.2011
					Запрос=Новый Запрос;
					Запрос.Текст=" 
					|ВЫБРАТЬ
					|	Ссылка
					|ИЗ
					|	ПланОбмена.Основной КАК Основной
					|ГДЕ
					|	Подразделение = &Подразделение
					|	И НЕ ПометкаУдаления
					|	И Ссылка<>&ЭтотУзел";					
					
					Запрос.УстановитьПараметр("Подразделение",	ПодразделениеДоговора);
					Запрос.УстановитьПараметр("ЭтотУзел",		ПараметрыСеанса.ЭтотУзел);
					
					Выборка=Запрос.Выполнить().Выбрать();
					
					Пока Выборка.Следующий() Цикл
						СписокПолучателей.Добавить(Выборка.Ссылка.Код);
					КонецЦикла;						
				КонецЕсли;				
				
			Иначе
				
				Если Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					СписокПолучателей.Добавить("SNL");					
				КонецЕсли;
			КонецЕсли;
			НЗ = РегистрыСведений.СостояниеДокументов.СоздатьНаборЗаписей();
			НЗ.Отбор.КодУзла.Установить(ПараметрыСеанса.ЭтотУзел.Код,Истина);
			НЗ.Отбор.Документ.Установить(Ссылка,Истина);
			Для Каждого УзелИзСписка Из СписокПолучателей Цикл
				Запись = НЗ.Добавить();
				Запись.Регистратор = Ссылка;
				Запись.Состояние = НовоеСостояниеДокументов;
				Запись.Автор = ПараметрыСеанса.Пользователь;
				Запись.КодУзлаПолучателя = УзелИзСписка;
				Запись.Документ = Ссылка;
				запись.КодУзла =  ПараметрыСеанса.ЭтотУзел.Код;
				Запись.Отработана = Ложь;
			КонецЦикла;
			НЗ.Записать();
		Иначе
			//крохин начало 11.08.2013
			//"отработана" ставим в обработке, запись не удаляем
			//НЗ = РегистрыСведений.СостояниеДокументов.СоздатьНаборЗаписей();
			//НЗ.Отбор.КодУзла.Установить(КодУзла,Истина);
			//НЗ.Отбор.КодУзлаПолучателя.Установить(ПараметрыСеанса.ЭтотУзел.Код,Истина);
			//НЗ.Отбор.Документ.Установить(Ссылка,Истина);
			//НЗ.Записать();
			//крохин конец 11.08.2013
		КонецЕсли;
		
		НеКонтролироватьЗапись=Ложь;
		НеВыгружатьДокумент = Ложь;
	КонецЕсли;
	
	Если КодУзла <> Неопределено Тогда
		НЗ = РегистрыСведений.СостояниеДокументов.СоздатьНаборЗаписей();
		НЗ.Отбор.КодУзла.Установить(КодУзла,Истина);
		НЗ.Отбор.КодУзлаПолучателя.Установить(ПараметрыСеанса.ЭтотУзел.Код,Истина);
		НЗ.Отбор.Документ.Установить(Ссылка,Истина);
		НЗ.Записать();
	КонецЕсли;	
	
	//крохин конец 15.02.2013
	
	//крохин начало 15.04.2013
	
	НеконтролироватьНаличиеСФ = Ложь;
	//крохин конец 15.04.2013
	
КонецПроцедуры

Процедура УстановитьДатуНомерСчета(НоваяДатасчета,НовыйНомерСчета)   Экспорт
	//крохин начало 09.02.2011
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//НомерСчета=НовыйНомерСчета;
	//ДатаСчета= НоваяДатасчета;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда
		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			НеКонтролироватьЗапись=Истина;
			НомерСчета=НовыйНомерСчета;
			ДатаСчета= НоваяДатасчета;
			Записать();
			НеКонтролироватьЗапись=Ложь;
		КонецЕсли;	
	Иначе
		НеКонтролироватьЗапись=Истина;
		НомерСчета=НовыйНомерСчета;
		ДатаСчета= НоваяДатасчета;
		Записать();
		НеКонтролироватьЗапись=Ложь;
	КонецЕсли;
	//крохин конец 09.02.2011
КонецПроцедуры

