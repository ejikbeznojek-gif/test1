			Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
		Если Склад.Подразделение <> ЭтотУзел.Подразделение Тогда
			Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
	//крохин конец 27.02.2013
	
	
	Если Менеджер.Пустая() Тогда
		Менеджер=?(ПунктДоставки.Менеджер.Пустая(),Контрагент.Менеджер,ПунктДоставки.Менеджер);
		
	КонецЕсли;
	//крохин начало	
	//++Данилова Е.В. 29.09.2025 HELP-7048
	//Подразделение = Менеджер.Подразделение; 
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер);
	//--Данилова Е.В. 29.09.2025
	Если Подразделение = Справочники.Подразделения.ПустаяСсылка() Тогда
		Подразделение = Склад.Подразделение;
	КонецЕсли;
	//крохин конец
	
	Если Договор.Пустая() Или Договор.НеИспользовать Тогда
		Договор=Контрагент.ОсновнойДоговор;			
	КонецЕсли; 
	//крохин начало
	//только предоплата
	Если Контрагент.Ведущий.ТолькоПредоплата Тогда
		ОтсрочкаПлатежа = Справочники.ОтсрочкиПлатежа.НайтиПоКоду("1");	
	КонецЕсли;
	//крохин конец
	
	//крохин начало 03.10.2012
	//ставка НДС
	Если ПунктДоставки.НулеваяСтавкаНДС или Контрагент.НулеваяСтавкаНДС Тогда
		НулеваяСтавкаНДС = Истина;	
	Иначе
		НулеваяСтавкаНДС = Ложь;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ ИЗ Товары Цикл
		Если НулеваяСтавкаНДС Тогда
			СтрокаТЧ.СтавкаНДС = Перечисления.СтавкиНДС.НДС0;
		Иначе
			СтрокаТЧ.СтавкаНДС = СтрокаТЧ.Номенклатура.Родитель.СтавкаНДС;			
		КонецЕсли;
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект,"ОтВсего");
	КонецЦикла;
	//крохин конец 03.10.2012
	
	//крохин начало 22.02.2013
	СостояниеКоррекции = Перечисления.СостоянияКоррекции.ПустаяСсылка();
	//крохин конец 22.02.2013
	
	//крохин начало 17.09.2013
	ОтгружатьПоНулевымЦенам = Ложь;
	ОтгружатьСПревышениемЛимитаКредита = Ложь;
	ОтгружатьСПросроченнойЗадолженостью = Ложь;
	ОтгрузкуРазрешил = Ложь;
	//крохин конец 17.09.2013 
	
	//крохин начало 19.05.2015
	Упаковка.Очистить();
	РедактированиеУпаковки = Ложь;
	//крохин конец 19.05.2015
	//Кухарь 09.03.17 начало
	КоличествоПаллет=0;
	//Кухарь 09.03.17 конец	
	//Кухарь 18.10.17 начало
	ОбъемПаллет=0;
	//Кухарь 18.10.17 конец
	
	//крохин начало 10.04.2017
	НомерСчета = Неопределено;
	ДатаСчета = Неопределено;
	//крохин конец 10.04.2017
	//Кухарь 19.01.18 начало
	ГосНомерАМЭкспедитора="";
	ФиоЭкспедитора="";
	ТелефонЭкспедитора="";
	ВремяПерегруза="";
	
	//Кухарь 19.01.18 конец	
	//Кухарь 14.05.18 начало
	//Заполним адрес из ПД
	если ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.Перегруз или ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.Самовывоз тогда
		АдресПерегруза=ПунктДоставки.АдресАнтор;
	КонецЕсли;
	//Кухарь 14.05.18 начало
	
	//Кухарь 16.01.19 начало
	ТрудозатратыНаТермоусадку=0;
	ТрудозатратыНаДО=0;
	ТрудозатратыНаНабор=0;
	ТрудозатратыНаПаллетирование=0;
	ТрудозатратыНаСканирование=0;
	ВремяНаДО=0;
