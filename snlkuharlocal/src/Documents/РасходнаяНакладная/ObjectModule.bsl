				Поиск = Рез22.Найти(ТСтр.Номенклатура,"Номенклатура");
				Если Поиск<> неопределено Тогда 
					ТСтр.Ном2 = ном;
				КонецЕсли;	
				
			КонецЦикла;
			
		КонецЦикла;
		//+++++++++02,03,20
