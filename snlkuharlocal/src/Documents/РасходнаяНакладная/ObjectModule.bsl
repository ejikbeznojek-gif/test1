Процедура ОтправлятьПисьмоОпревышенииЛимита() Экспорт
	
	// пропишем в регист нужно ли отправлять письмо
	
	ЗапросПисьмоОтправлено = Новый запрос;
	ЗапросПисьмоОтправлено.Текст = "ВЫБРАТЬ
	|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.Отправлено,
	|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.Емайл,
	|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгрузкуРазрешил
	|ИЗ
	|	РегистрСведений.ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж КАК ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж
	|ГДЕ
	|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.РНК = &ТекРНК
	|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.Отгружен = &Отгружен
	|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгрузкуРазрешил = &ОтгрузкуРазрешил
	|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгружатьСПросроченнойЗадолженностью = &ПрЗад
	|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгружатьСПревышениемЛимита = &ПрЛим";
	ЗапросПисьмоОтправлено.УстановитьПараметр("ТекРНк",Ссылка);
	ЗапросПисьмоОтправлено.УстановитьПараметр("Отгружен",Отгружен);
	ЗапросПисьмоОтправлено.УстановитьПараметр("ОтгрузкуРазрешил",ОтгрузкуРазрешил);
	ЗапросПисьмоОтправлено.УстановитьПараметр("ПрЗад",ОтгружатьСПросроченнойЗадолженостью);
	ЗапросПисьмоОтправлено.УстановитьПараметр("ПрЛим",ОтгружатьСПревышениемЛимитаКредита);
	
	УжеЕсть=Ложь;
	
	Выборка = ЗапросПисьмоОтправлено.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Отправлено = Выборка.Отправлено;
		УжеЕсть=Истина;
	Иначе
		Отправлено = Неопределено;
	КонецЕсли;
	
	//	#Если КЛИЕНТ Тогда
	// проверить изменилось ли ОЛ. - если да, то ставить ложь. и галки на отгрузку 
	Если ссылка.ОтгружатьСПросроченнойЗадолженостью<> ОтгружатьСПросроченнойЗадолженостью или
		ссылка.ОтгружатьСПревышениемЛимитаКредита <> ОтгружатьСПревышениемЛимитаКредита или
		ссылка.ОтгрузкуРазрешил  <> ОтгрузкуРазрешил Тогда
		// отправляем письмо еще раз, с новыми данными.
		
		Отправлено = Неопределено;
		
	КонецЕсли;
	//	#конецЕсли 
	
	
	Попытка
		// отправляем письмо, если еще не отправляли
		Если Отправлено=Неопределено и СостояниеНакладной<>перечисления.СостоянияНакладной.ВРаботе и не отгрузкуРазрешил.Пустая() Тогда
			
			
			// Проверим, есть ли такая запись...
			Запрос=новый Запрос;
			Запрос.текст="ВЫБРАТЬ
			|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.РНК КАК РНК,
			|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгрузкуРазрешил КАК отгрузкуРазрешил
			|ИЗ
			|	РегистрСведений.ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж КАК ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж
			|ГДЕ
			|	ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.РНК = &Рнк
			|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.Отгружен = &Отгружен
			|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгрузкуРазрешил = &ОтгрузкуРазрешил
			|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгружатьСПросроченнойЗадолженностью = &П1
			|	И ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.ОтгружатьСПревышениемЛимита = &П2";
			
			Запрос.УстановитьПараметр("РНК",Ссылка);
			Запрос.УстановитьПараметр("Отгружен",Отгружен);
			Запрос.УстановитьПараметр("ОтгрузкуРазрешил",ОтгрузкуРазрешил);
			Запрос.УстановитьПараметр("п1",ОтгружатьСПросроченнойЗадолженостью);
			Запрос.УстановитьПараметр("п2",ОтгружатьСПревышениемЛимитаКредита);
			
			Рез=запрос.Выполнить().Выгрузить();
			
			Если УжеЕсть=Ложь и Рез.Количество()=0 Тогда
				// Если нет записей, тогда создаем новую	    		
				Попытка						
					НаборЗаписей = РегистрыСведений.ОтгруженныеРНКСПревышениемЛимитаИлиПросрЗадолж.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.РНК.значение=Ссылка;
					НаборЗаписей.Отбор.Отгружен.значение=Отгружен;
					НаборЗаписей.Отбор.РНК.Использование = Истина;
					НаборЗаписей.Отбор.Отгружен.Использование = Истина;
					НаборЗаписей.Отбор.ОтгрузкуРазрешил.значение = ОтгрузкуРазрешил;
					НаборЗаписей.Отбор.ОтгрузкуРазрешил.Использование = Истина;
					
					
					//НаборЗаписей.Отбор.ОтгрузкуРазрешил.значение = Ссылка.ОтгрузкуРазрешил;
