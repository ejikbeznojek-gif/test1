Функция ПолучитьТаблицуНакладнойТандерЭкспозиторы(Режим="Накладная",СФ=Неопределено,Экспозитор)
	
	ТН=Новый ТаблицаЗначений;
	
	ТН.Колонки.Добавить("Номенклатура");	
	ТН.Колонки.Добавить("Количество");
	ТН.Колонки.Добавить("НДС");
	ТН.Колонки.Добавить("Сумма");
	ТН.Колонки.Добавить("СтавкаНДС");
	ТН.Колонки.Добавить("Всего");
	ТН.Колонки.Добавить("Цена");
	
	ИсходнаяТЧ=Товары.Выгрузить();
	ИсходнаяТЧ = Новый ТаблицаЗначений;
	ИсходнаяТЧ.Колонки.Добавить("Номенклатура");	
	ИсходнаяТЧ.Колонки.Добавить("Количество");
	ИсходнаяТЧ.Колонки.Добавить("НДС");
	ИсходнаяТЧ.Колонки.Добавить("Сумма");
	ИсходнаяТЧ.Колонки.Добавить("Всего");
	ИсходнаяТЧ.Колонки.Добавить("Цена");
	
	
	// заменияем на колво экспозиторов. Цену берем из матрицы.
	
	ОбщКолво = товары.Итог("Количество");
	КолвВ1Эксп = Экспозитор.Коплектующие.Итог("Количество");
	Если КолвВ1Эксп = 0 Тогда
		ВсегоЭксп  = Окр(ОбщКолво);
	Иначе
		ВсегоЭксп  = Окр(ОбщКолво/КолвВ1Эксп);
	КонецЕсли;
	
	
	//------------------------------------------------------------------------
	//------------------------------------------------------------------------
	НовСтр = ТН.Добавить();
	НовСТр.Номенклатура = Экспозитор;
	НовСТр.Количество = ВсегоЭксп;
	//ЗаполнитьЦенуНоменклатурыТабЧастиПоМатрице(НовСТр, ДокОбъект) ;
	//ПриИзмененииНоменклатурыТабЧасти(НовСтр, ТекОб);
	
	
	
	//получим цену номенклатуры
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	МатрицаТовары.Номенклатура,
	|	МатрицаТовары.Цена,
	|	МатрицаПунктыДоставки.Ссылка
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
