// +++ 2011-11-21 сезонные бонусы
Функция РасчетСезонногоБонусаРазрешен(ФлагСообщатьОПричинахЗапрета = Ложь) Экспорт
	
	МассивСообщений	= Новый Массив;
	Результат		= Истина;
	
	ТипУзла = ПараметрыСеанса.ТипУзла;	
	Если ТипУзла <> Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		// Цены расчитываются только в офисных базах !!!
		МассивСообщений.Добавить("Недопустимый тип узла текущей ИБ: " + ТипУзла + ".");
		Результат = Ложь;
	КонецЕсли;
	
	МассивДопустимыхСостояний = Новый Массив;
	МассивДопустимыхСостояний.Добавить(Перечисления.СостоянияНакладной.ВРаботе);
	МассивДопустимыхСостояний.Добавить(Перечисления.СостоянияНакладной.КОтправкеНаСклад);
	Если МассивДопустимыхСостояний.Найти(СостояниеНакладной) = Неопределено Тогда 
		МассивСообщений.Добавить("Недопустимое состояние накладной: " + СостояниеНакладной + ".");
		Результат = Ложь;
	КонецЕсли;
	
	//Если КодОперации <> Перечисления.КодыОперацийОстатки.Реализация Тогда
	//	МассивСообщений.Добавить("Недопустимый код операции: " + КодОперации + ".");
	//	Результат = Ложь;
	//КонецЕсли;		
	
	Если НЕ Результат И ФлагСообщатьОПричинахЗапрета Тогда
		Сообщить("Расчет бонусов для " + ЭтотОбъект + " запрещён:", СтатусСообщения.Важное);
		Для Каждого Сообщение Из МассивСообщений Цикл
			Сообщить(" - " + Сообщение);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Процедура РассчитатьСезонныйБонус() Экспорт
	
	Если Товары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// проверим есть ли в таб.части Товары ненулевые суммы в колонке "ВсегоБезБонуса"
	ЗаполненоВсегоБезБонуса = Ложь;
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.ВсегоБезБонуса <> 0 Тогда
			ЗаполненоВсегоБезБонуса = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	Если НЕ ЗаполненоВсегоБезБонуса Тогда
		// это старый документ, у которого в таб.части Товары не заполнена колонка "ВсегоБезБонуса"
		СообщитьОбОшибке("В табличной части ""Товары"" не заполнены значения в колонке ""ВсегоБезБонуса"".");
		Возврат;		
	КонецЕсли;		
	
	Если НЕ РасчетСезонногоБонусаРазрешен() Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоОтменаНачисления = (НЕ СезонныйБонус); // если СезонныйБонус = Ложь, то нужно сделать "отмену начисления ранее начисленного бонуса"
	
	ДоговорСезонногоБонуса = ПолучитьДоговорСезонногоБонуса(Контрагент);
	
	Если СезонныйБонус И (ДоговорСезонногоБонуса = Неопределено) Тогда
		СообщитьОбОшибке("Для контрагента """ + Контрагент + """ не найден договор с видом """ + Справочники.ВидыДоговоров.СезонныйБонус + """!");
		ЭтоОтменаНачисления = Истина;
	КонецЕсли;
	
	ДопустимыйКодОперации = Перечисления.КодыОперацийОстатки.Реализация;
	Если СезонныйБонус И (КодОперации <> ДопустимыйКодОперации) Тогда
		СообщитьОбОшибке("Расчет сезонного бонуса возможен только для накладных с кодом операции """ + ДопустимыйКодОперации + """!");
		ЭтоОтменаНачисления = Истина;
	КонецЕсли;
	
	Если ЭтоОтменаНачисления Тогда
		// отменяем начисление сезонного бонуса
		Для Каждого СтрокаТЧ Из Товары Цикл
			Если СтрокаТЧ.ВсегоБезБонуса = 0 Тогда
				// видимо это строка старого документа, в котором не установлено значение ВсегоБезБонуса
				Продолжить;
			КонецЕсли;
			Если СтрокаТЧ.Всего <> СтрокаТЧ.ВсегоБезБонуса Тогда
				СтрокаТЧ.Всего = СтрокаТЧ.ВсегоБезБонуса;
				РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект, "ОтВсего");
			КонецЕсли;
		КонецЦикла;
		// всё сделано ==> выходим
		Возврат;
	КонецЕсли;
	
	ОстатокБонуса	= 0;
	ИтогоБезБонуса	= Товары.Итог("ВсегоБезБонуса");
	
	// получим остаток на бонусном договоре
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВзаиморасчетыОстатки.Договор,
	|	-ВзаиморасчетыОстатки.СуммаВалОстаток КАК ОстатокБонуса
	|ИЗ
	|	РегистрНакопления.Взаиморасчеты.Остатки(, Договор = &Договор) КАК ВзаиморасчетыОстатки";
	Запрос.УстановитьПараметр("Договор", ДоговорСезонногоБонуса);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка			= РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ВалютаБонуса	= ПолучитьВалютуРасчетов(ДоговорСезонногоБонуса);
		ОстатокБонуса	= ОстатокБонуса + ?(ВалютаБонуса = Валюта, Выборка.ОстатокБонуса, глПересчет(Выборка.ОстатокБонуса, ВалютаБонуса, Дата, Валюта, Курс));
	КонецЕсли;
	
	// добавим движения текущего документа по бонусному договору
	Если Проведен Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(Взаиморасчеты.СуммаВал * ВЫБОР
		|			КОГДА Взаиморасчеты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|				ТОГДА 1
		|			ИНАЧЕ -1
		|		КОНЕЦ) КАК СуммаДвиженийТекДок
		|ИЗ
		|	РегистрНакопления.Взаиморасчеты КАК Взаиморасчеты
		|ГДЕ
		|	Взаиморасчеты.Регистратор = &Регистратор
		|	И Взаиморасчеты.Активность
		|	И Взаиморасчеты.Договор = &Договор";
		Запрос.УстановитьПараметр("Регистратор", Ссылка);
		Запрос.УстановитьПараметр("Договор", ДоговорСезонногоБонуса);
		РезультатЗапроса = Запрос.Выполнить();
		Если НЕ РезультатЗапроса.Пустой() Тогда
			Выборка			= РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			ОстатокБонуса	= ОстатокБонуса + Выборка.СуммаДвиженийТекДок;
		КонецЕсли;
	КонецЕсли;	
	
	МаксБонусПоНакл	= Окр(ИтогоБезБонуса * ДоговорСезонногоБонуса.ПроцентСкидкиСБ / 100, 2);
	РазмерБонуса	= Мин(ОстатокБонуса, МаксБонусПоНакл);
	Если РазмерБонуса < 0 Тогда
		РазмерБонуса = 0;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		СтрокаТЧ.Всего = СтрокаТЧ.ВсегоБезБонуса - Окр(РазмерБонуса * (СтрокаТЧ.ВсегоБезБонуса / ИтогоБезБонуса), 2);
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект, "ОтВсего");
	КонецЦикла;
	ОшибкаОкругления = ИтогоБезБонуса - Товары.Итог("Всего") - РазмерБонуса;
	Если ОшибкаОкругления <> 0 Тогда
		// накопленные ошибки округления бросаем на строку с кол-вом = 1 (а если такой нет, то на 1-ую строку)
		СтрокаТЧ = Товары.Найти(1, "Количество");
		Если СтрокаТЧ = Неопределено Тогда
			СтрокаТЧ = Товары[0];
		КонецЕсли;
		СтрокаТЧ.Всего = СтрокаТЧ.Всего + ОшибкаОкругления;
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект, "ОтВсего");
	КонецЕсли;
	
КонецПроцедуры

