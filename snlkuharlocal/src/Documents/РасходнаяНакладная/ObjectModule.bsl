Функция КоличествоШКПоЗаранееСформированнымАгрегациям(Знач ДокументОснование)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ВложенныйЗапрос.КоличествоПоКоробкам) + СУММА(ВложенныйЗапрос.КоличествоПоБлочкам) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод) КАК КоличествоПоКоробкам,
	|		0 КАК КоличествоПоБлочкам
	|	ИЗ
	|		Документ.ЛистНабора КАК ЛистНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка
	|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
	|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка
	|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки)
	|				И (ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки)
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|			ПО (ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка)
	|	ГДЕ
	|		ЛистНабора.Проведен
	|		И ЛистНабора.ДокОснование = &ДокОснование
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		0,
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод)
	|	ИЗ
	|		Документ.ЛистНабора КАК ЛистНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка
	|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок))
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|			ПО (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка)
	|	ГДЕ
	|		ЛистНабора.Проведен
	|		И ЛистНабора.ДокОснование = &ДокОснование) КАК ВложенныйЗапрос";
	
	Запрос.УстановитьПараметр("ДокОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КоличествоВложенных = 0; 	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КоличествоВложенных = ВыборкаДетальныеЗаписи.Количество; 
	КонецЦикла;
	
	Возврат КоличествоВложенных; 
	
	
КонецФункции // КоличествоШКПоЗаранееСформированнымАгрегациям()

Процедура СоздатьРазагрегациюПоЗаводскимКоробкамВОбороте()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки КАК ШтрихкодУпаковки,
	|	ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки.Наименование КАК КодАгрегации
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
	|		ПО ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка = ЛистНабора.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКМ_Факт.СрезПоследних(, ) КАК СтатусыКМ_ФактШК
	|		ПО (СтатусыКМ_ФактШК.ШтрихКодУпаковки = ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
	|			И (СтатусыКМ_ФактШК.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Расформирован))
	|ГДЕ
	|	ЛистНабора.Проведен
	|	И ЛистНабора.ДокОснование = &ДокОснование
	|	И ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки <> ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки,
	|	ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки.Наименование
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыКоробокДляАгрегации КАК ЛистПереукладкиШтрихкодыКоробокДляАгрегации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
	|		ПО ЛистПереукладкиШтрихкодыКоробокДляАгрегации.Ссылка = ЛистПереукладки.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКМ_Факт.СрезПоследних(, ) КАК СтатусыКМ_ФактШК
	|		ПО (СтатусыКМ_ФактШК.ШтрихКодУпаковки = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
	|			И (СтатусыКМ_ФактШК.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Расформирован))
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &ДокОснование
	|	И ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки <> ЛистПереукладкиШтрихкодыКоробокДляАгрегации.НовыйКодКоробки";
	
	Запрос.УстановитьПараметр("ДокОснование", ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ШКДляМаркировкиТоваров = РезультатЗапроса.Выгрузить(); 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|ГДЕ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ДокументОснование = &Док
		|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.Проведен
		|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.РасформированиеУпаковки)
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка";
		
		Запрос.УстановитьПараметр("Док", ссылка);
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		
		Если Выборка.Следующий() Тогда
			
			рШапки		= ПолучитьРеквизитыШапки(Выборка.ссылка, "Статус"); 
			
			Если рШапки.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки Тогда 			
				ДокМаркировкиОбъект = Выборка.ссылка.ПолучитьОбъект();
				ДокМаркировкиОбъект.Товары.Очистить();
				ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить(); 
			Иначе
				
				ТекстОшибки = СтрШаблон("Недопустимый статус документа: '%1' !", рШапки.Статус);
				Сообщить(ТекстОшибки); 
				Отказ = истина;
				Возврат; 
			КонецЕсли;
		Иначе 
			ДокМаркировкиОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент(); 
		КонецЕсли;
		
		ДокМаркировкиОбъект.Дата	= ТекущаяДатаСеанса(); 			
		
		ДокМаркировкиОбъект.Организация	= Организация; 
		ДокМаркировкиОбъект.Заполнить(ссылка);
		ДокМаркировкиОбъект.ДокументОснование = ссылка;
		ДокМаркировкиОбъект.ПодразделениеНанесения = Склад.Подразделение;
		ДокМаркировкиОбъект.ДополнительныеСвойства.Вставить("ЗаполнятьТолькоШапку", Истина);
		
		ДокМаркировкиОбъект.ВидОперации		= Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки;
		ДокМаркировкиОбъект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки;
		ДокМаркировкиОбъект.Статус			= Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
		
		ДокМаркировкиОбъект.ШтрихкодыУпаковок.Загрузить(ШКДляМаркировкиТоваров); 
		
		Попытка
			ДокМаркировкиОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Отказ = Истина; 
			Сообщить("Ошибка проведения документа разагрегации!!! Описание ошибки: " +ОписаниеОшибки(),СтатусСообщения.Важное);
		КонецПопытки;
		
	КонецЕсли;	
	
	
КонецПроцедуры

