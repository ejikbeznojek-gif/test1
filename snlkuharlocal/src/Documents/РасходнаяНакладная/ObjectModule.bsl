//++Данилова Е.В. 24.03.2026 ASU-2089 
Функция ПроверитьКомплектующиеАссортито()
	
	Результат = МаркировкаКС.СтруктураРезультата(Истина); 
	
	Если Не ОтгрузкаКомплектов Тогда
		
		Возврат Результат; 	
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Комплектующие.Продукция КАК Справочник.Номенклатура) КАК Продукция,
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	Комплектующие.Количество КАК Количество
	|ПОМЕСТИТЬ ВТКомплектующие
	|ИЗ
	|	&Комплектующие КАК Комплектующие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТКомплектующие.Продукция) КАК Продукция,
	|	ВТКомплектующие.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТКомплектующие КАК ВТКомплектующие
	|ГДЕ
	|	ВТКомплектующие.Продукция.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Ассортито)
	|	И ВТКомплектующие.Количество > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТКомплектующие.Номенклатура
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТКомплектующие.Продукция) > 1";
	
	Запрос.УстановитьПараметр("Комплектующие", Комплектующие.Выгрузить(,"Продукция,номенклатура,количество"));
	
	РезультатЗапроса = Запрос.Выполнить(); 
	
	Если НЕ  РезультатЗапроса.Пустой() Тогда
		
		ТекстОошибки = "В одной РНК не должна быть продукция вида ассортито с одинаковыми комплектующими!!"; 
		
		Выборка = РезультатЗапроса.Выбрать(); 
		
		МассивПовторов = Новый Массив; 
		Пока Выборка.Следующий()  Цикл
			
			ТекстРасшифровка = СтрШаблон("Комплектующая по разной продукции %1",Выборка.Номенклатура); 	
			МассивПовторов.Добавить(ТекстРасшифровка); 
			
		КонецЦикла;
		
		Результат.Ошибки.Добавить(ТекстОошибки + Символы.ПС + СтрСоединить(МассивПовторов,Символы.ПС)); 
	КонецЕсли;
	
	Результат.Успешно = Результат.Ошибки.Количество() = 0; 
	
	Возврат Результат; 
КонецФункции // ПроверитьКомплектующиеАссортито()

