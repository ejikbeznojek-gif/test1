Процедура ЗаписьБезКонтроляПолномочий(ТЗПараметров = Неопределено) Экспорт
	
	ТЗНеизменяемыхРеквизитов = ТЗПараметров;
	//Кухарь 17.01.19 конец
	
	НеКонтролироватьЗапись = ?(Дата > ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования(), Истина, Ложь);
	//++Данилова Е.В. 27.10.2025 HELP-7587 
	если ТипЗнч(ТЗНеизменяемыхРеквизитов) = Тип("ТаблицаЗначений") 
		И ТЗНеизменяемыхРеквизитов.найти("ЗаписьНЕВПопытке")<>Неопределено тогда
		ЗаписьНЕВПопытке=Истина; 
	иначе
		ЗаписьНЕВПопытке=Ложь;			
	КонецЕсли;
	
	Если ЗаписьНЕВПопытке Тогда
		
		Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
		НеКонтролироватьЗапись = Ложь;	
		
	Иначе 
		
		Попытка
			Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
			НеКонтролироватьЗапись = Ложь;
		Исключение
			#Если ТолстыйКлиентОбычноеПриложение Тогда
				Оповестить("ОшибкаПриЗаписиДокумента", "Ошибка при записи документа " + Строка(ЭтотОбъект));
			#КонецЕсли
		КонецПопытки;
	КонецЕсли;
	//--Данилова Е.В. 27.10.2025
	
КонецПроцедуры
