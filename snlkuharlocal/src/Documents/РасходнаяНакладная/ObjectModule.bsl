Функция В_JSON(Значение) Экспорт
	ЗначениеВнутр = ПривестиЗначение(Значение);
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON,ЗначениеВнутр);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции
Функция Из_JSON(Значение,ВСоответствие=Истина) Экспорт
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Значение);
	Возврат ПрочитатьJSON(ЧтениеJSON,ВСоответствие);
КонецФункции
Функция ПривестиЗначение(Значение) Экспорт   
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Неопределено") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Булево") Тогда	
		Возврат Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Массив") Тогда	
		ЗначениеВнутр = Новый Массив;
		Для каждого СтрЗнач Из Значение Цикл
			ЗначениеВнутр.Добавить(ПривестиЗначение(СтрЗнач));
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли ТипЗнч(Значение) = Тип("Структура") Тогда	
		ЗначениеВнутр = Новый Структура;
		Для каждого СтрЗнач Из Значение Цикл
			ЗначениеВнутр.Вставить(СтрЗнач.Ключ,ПривестиЗначение(СтрЗнач.Значение));
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда	
		ЗначениеВнутр = Новый Массив;
		Для каждого СтрЗнач Из Значение Цикл
			СтрокаЗначения = Новый Структура();
			Для каждого Колонка Из Значение.Колонки Цикл
				СтрокаЗначения.Вставить(Колонка.Имя,ПривестиЗначение(СтрЗнач[Колонка.Имя]));	
			КонецЦикла;	
			ЗначениеВнутр.Добавить(СтрокаЗначения);
		КонецЦикла;	
		Возврат ЗначениеВнутр;
	ИначеЕсли Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) Тогда
		Если Значение.Пустая() Тогда
			Возврат Неопределено;
		КонецЕсли;	
		Возврат Строка(Значение.УникальныйИдентификатор());
	Иначе
		Возврат Строка(Значение);
	КонецЕсли;	
КонецФункции

Функция ПолучитьТаблицуССКодов(НомерРНК,ДатаРНК) Экспорт
	
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//WS_User="*%*%*%";
	//WS_Password="*$*$*$";
	WS_User = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
	Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКWebСервисуСклада).Логин;
	WS_Password = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
	Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКWebСервисуСклада).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	Определение = Новый WSОпределения("http://srvsql-sk:31415/od7/ws/wsPalletsExt.1cws?wsdl",WS_User,WS_Password);
	
	Прокси = Новый WSПрокси(Определение, "http://collant.ru/wsPalletsExt","wsPalletsExt","wsPalletsExtSoap" );    
	Прокси.Пользователь = WS_User;
	Прокси.Пароль = WS_Password;
	
	
	Данные = Прокси.GetPData(НомерРНК,Формат(ДатаРНК,"ДФ=yyyyMMdd"));
	ДанныеВН = Из_JSON(Данные,Ложь);
	
	Результат = Новый ТаблицаЗначений();
	Результат.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Результат.Колонки.Добавить("Количество",Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("ССКод",Новый ОписаниеТипов("Строка"));
	
	Для каждого Элемент Из ДанныеВН Цикл
		Если Элемент.SSCCКод <> "" Тогда
			Стр = Результат.Добавить();
			Стр.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.Номенклатура));
			Стр.Количество = Элемент.Количество;
			Стр.ССКод = Элемент.SSCCКод;
			
		КонецЕсли;	
	КонецЦикла;    
	Результат.Сортировать("Номенклатура");
	Возврат Результат;
	
КонецФункции

