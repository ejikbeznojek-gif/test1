				НовСтр.Номенклатура = Строчка1.Номенклатура;
				НовСтр.НомерСтроки = Строчка1.НомерСтроки;
				
				НовСтр.ШККонтрагента = Строчка1.ШККонтрагента;
				НовСтр.ЭтоГруппаНом = Строчка1.ЭтоГруппаНом;
				
				Сч = Сч+1;
				
				//пересчитаем
				НовСтр.Всего = Окр(НовСтр.Цена * НовСтр.Количество,2); //новая сумма С НДС
				НовСтр.НДС = НовСтр.Всего- Окр(НовСтр.ВСего/(1+СтавкаНДС2),2);  // сумма ндс
				НовСтр.Сумма = НовСтр.Всего - НовСтр.НДС;
				
				
			КонецЦикла;
			
		иначе	
			// просто sscc код прописываем.
			ТС = РезНом.Следующий();
			Строчка1.ССКод = РезНом.ССКод ;
			
		КонецЕсли;
		
	Конеццикла;
	
	
	
	// добавим строки разбитые в исходную таблицу. и сделаем пересчет.
