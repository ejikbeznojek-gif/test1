		Запрос.Текст="ВЫБРАТЬ
		|	ТЗ2.Количество,
		|	ТЗ2.СсКод как ССКод
		|ИЗ
		|	ТЗ2 КАК ТЗ2	";
		
		РезНом=Запрос.Выполнить().Выбрать();
		
		Если РезНом.Количество()>1 Тогда
			// делим строки по количеству и пересчитываем их.
			//ЦенаСН = Строчка1.Сумма/Строчка1.количество; //цена c НДС;
			Сч =1;
			Пока РезНом.Следующий() Цикл
				Если Сч = 1 Тогда
					
					Строчка1.ССкод = РезНом.Сскод ;
					Строчка1.количество = РезНом.Количество;
					Строчка1.заявка = РезНом.Количество;
					//пересчитаем
					Строчка1.Всего = Окр(ЦенаСН * Строчка1.Количество,2); //новая сумма С НДС
					Строчка1.НДС =  Строчка1.Всего- Окр(Строчка1.Всего/(1+СтавкаНДС2),2);;
					Строчка1.Сумма = Строчка1.Всего - Строчка1.НДС;
					
					Сч = Сч+1;
					продолжить;
				КонецЕсли;	
				
				НовСтр = ВыборкаСтрокТовары2.Добавить();
				НовСтр.Количество = РезНом.Количество;
				НовСтр.ССКод = РезНом.СсКод ;
				НовСтр.СтавкаНДС = Строчка1.СтавкаНДС;
				НовСтр.Сумма = Строчка1.Сумма;
				//НовСтр.СуммаНДС = Строчка1.СуммаНДС;
				НовСтр.Цена = Строчка1.Цена;
				НовСтр.СуммаБезНДС = Строчка1.СуммаБезНДС;
				НовСтр.СуммаСНДС = Строчка1.СуммаСНДС;
				НовСтр.Кратность = Строчка1.Кратность;
				НовСтр.АртикулКонтрагента = Строчка1.АртикулКонтрагента;
				НовСтр.Всего = Строчка1.Всего;  //????
				НовСтр.Заявка = РезНом.Количество;
				НовСтр.КратностьБлочка = Строчка1.КратностьБлочка;
				НовСтр.Модель = Строчка1.Модель;
				НовСтр.НДС = Строчка1.НДС;
