Функция ПолучитьАртикулыМатрицы(ДокОбъект)
	
	
	// для договоров не по матрице
	Попытка
		Если ДокОбъект.Договор.НеИспользоватьМатрицу Тогда
			НеИспользоватьМартицуПоДоговору=Истина;
		иначе
			НеИспользоватьМартицуПоДоговору=ложь;
		КонецЕсли;	
	Исключение
		НеИспользоватьМартицуПоДоговору=ложь;
	конецПопытки;
	ТЗ = новый ТаблицаЗначений;
	Тз.Очистить();
	
	Попытка
		Если ДокОбъект.контрагент.ИспользоватьНоменклатурнуюМатрицу и не НеИспользоватьМартицуПоДоговору Тогда
			// проверяем по какому типу расчитывать цену - с учетом договора или нет(если по договору не найдено). 
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Матрица.Ссылка КАК Ссылка1
			|ИЗ
			|	Документ.Матрица КАК Матрица
			|ГДЕ
			|	Матрица.Контрагент = &Контрагент
			|	И Матрица.Дата <= &Дата1
			|	И Матрица.ДатаОкончания >= &Дата2
			|	И Матрица.Договор = &Договор
			|	И Матрица.Проведен = истина
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			
			Запрос.УстановитьПараметр("Дата2",НачалоДня(ДокОбъект.дата));
			Запрос.УстановитьПараметр("Дата1",КонецДня(ДокОбъект.дата));
			Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
			Запрос.УстановитьПараметр("Договор",ДокОбъект.Договор);
			ТЗЕстьМатрицаПоДоговору = Запрос.Выполнить().Выгрузить();
			
			
