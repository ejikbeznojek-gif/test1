	ВремяНаПаллетирование=0;
	ВремяНаСканирование=0;
	ВремяНаТермоусадку=0;
	//Кухарь 16.01.19 конец
	
	//крохин начало 22.01.2020
	ДоговорСкидкиДС = Справочники.Договоры.ПустаяСсылка();
	СуммаСкидкиДС = 0;
	//крохин конец 22.01.2020
	
	//  Кухарь 18.08.2020 начало
	//  
	РасходныеМатериалы.Очистить();
	// Кухарь  18.08.2020 конец
	
	//крохин начало 21.11.2023
	КодВторичногоКонтрагента = "";
	НаименованиеВторичногоКонтрагента = "";
	НомерЗаказаВторичногоКонтрагента = "";
	//крохин конец 21.11.2023
	
	// Шворобей ВЮ 10.01.2024 ++
	ПоставщикПоАгентскойСхеме = Неопределено;
	ПересчитатьТабличнуюЧасть(Товары);
