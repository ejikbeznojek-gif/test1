// *** 2011-11-21 сезонные бонусы
//Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь)
// ---------- заменено на:
Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь,Очищать=Истина)
	// 2011-11-21 сезонные бонусы ***
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Продолжить  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];
		Если Очищать Тогда
			НаборЗаписей.Очистить();
		КонецЕсли;
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	
	если МеждуСвоимиОрганизациями тогда возврат;КонецЕсли; 
	
	Если ОбщегоНазначения_ПИ.ЭтоУзел_ЦО() Тогда
		Если СостояниеКоррекции = Перечисления.СостоянияКоррекции.Отработана Тогда
			Возврат;	
		КонецЕсли;
	ИначеЕсли ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад Тогда
		Если СостояниеНакладной = Перечисления.СостоянияНакладной.Отменена Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;
	
	ДвиженияПоРегистрам=Неопределено;
	
	Если ОбщегоНазначения_ПИ.ЭтоУзел_Склад() Тогда		
		Если  СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоСкладом Тогда
			Возврат;
		КонецЕсли;
		Если Отгружен<>Перечисления.Отгружен.Отгружен Тогда
			Возврат;								
		КонецЕсли;		
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Если КодОперации = Перечисления.КодыОперацийОстатки.ВозвратПоставщику Тогда		
		ТаблицаСписания = Неопределено;
		РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка,ТаблицаСписания);
		//подарки
	ИначеЕсли Подарок Тогда
		ТаблицаСписания = Неопределено;
		РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка,ТаблицаСписания);
	Иначе
		РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
	Конецесли;
	
	Результат=РезультатПроведения["Результат"];
	
	Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда		
		Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));		
		
		ВывестиТрассировку(РезультатПроведения["ТОшибок"],?(Отказ,-2,Результат));			
	КонецЕсли; 
	
	
	Если НЕ Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
		
		ОчищатьДвиженияПоВзаиморасчетам = Истина;
		Если СезонныйБонус Тогда
			ДвиженияПоВзаиморасчетам	= Неопределено;
			РезультатПроведения			= ПровестиПоВзаиморасчетамСезонныеБонусы(Ссылка, ДвиженияПоВзаиморасчетам);
			ВыполнитьДвиженияПоРегистрам(ДвиженияПоВзаиморасчетам, ОбменДанными.Загрузка, ОчищатьДвиженияПоВзаиморасчетам);
			ОчищатьДвиженияПоВзаиморасчетам = Ложь; // последующие вызовы ВыполнитьДвиженияПоРегистрам() не должны приводить к очистке движений по взаиморасчётам
		КонецЕсли;
		
		Если Отгружен=Перечисления.Отгружен.Отгружен Тогда
			ДвиженияПоВзаиморасчетам=Неопределено;
			РезультатПроведения=ПроведениеПоРегистрамВзаиморасчетов(Ссылка, ДвиженияПоВзаиморасчетам);
			
			ВыполнитьДвиженияПоРегистрам(ДвиженияПоВзаиморасчетам, ОбменДанными.Загрузка, ОчищатьДвиженияПоВзаиморасчетам);
			
			Если  дата >= '20100701'  Тогда
				СформироватьДвиженияПоЗатратам(ТаблицаСписания);	
			КонецЕсли;
			
			Если КодОперации = Перечисления.КодыОперацийОстатки.Комиссия
				ИЛИ (КодОперации = Перечисления.КодыОперацийОстатки.Реализация И Склад.ТипСклада = Перечисления.ТипСклада.КомиссионныйСклад) Тогда
				
				ДвиженияПоОстаткамТМЦКомиссия = Неопределено;
				РезультатПроведения = ПроведениеПоРегиструОстаткиТМЦКомиссия(Ссылка,ДвиженияПоОстаткамТМЦКомиссия);
				ВыполнитьДвиженияПоРегистрам(ДвиженияПоОстаткамТМЦКомиссия, ОбменДанными.Загрузка);
				
			КонецЕсли;
		КонецЕсли;      
		
		// Кухарь А.Ю.  13.07.2026 начало 
		// Изменение 0000000223
		НужныПроводкиПоПланам = ОбщегоНазначения_ПИ.ДляНакладнойТребуютсяПроводкиПоОстаткамПланов(Ссылка, Контрагент);    
		Если НужныПроводкиПоПланам Тогда
			РегистрыНакопления.ОстаткиПлановПродаж.СформироватьИЗаписатьДвижения(ЭтотОбъект);    
		КонецЕсли;
		// Кухарь А.Ю.  13.07.2026 конец
		
	КонецЕсли; 
	
	
	если не УчетСертификатов.ПровестиДокументПоСертификатнымОстаткам(ЭтотОбъект) тогда
		отказ=Истина;
	КонецЕсли;
	
	//заказы контрагентов. Дописать условие на код операции
	Если КодОперации = Перечисления.КодыОперацийОстатки.АгентскийДоговор Тогда
		ДвиженияПоРегистрам=Неопределено;
		РезультатПроведения=ПроведениеПоРегистрамЗаказыКонтрагентов(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);
	КонецЕсли;
	
	//запись объёма коробов и количество коробок в регистр	
	ЧСостояние=ПолучитьНомерСостоянияНакладной(СостояниеНакладной);
	если  ЧСостояние < 400 и ЧСостояние<>0 тогда
		если ПараметрыСеанса.ЭтотУзел.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			ЗаписатьКоличествоИОбъемКоробовВРегистр(ЭтотОбъект.Ссылка,КоличествоКоробок,ОбъемКоробов);
		КонецЕсли;		
	КонецЕсли;
	
	Движения.Записать();
	если СостояниеКоррекции=Перечисления.СостоянияКоррекции.Утверждена и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение и не ОбменДанными.Загрузка тогда
		ЗаписатьЗначениеВРеквизитыРНКПНКПРМ("ДатаПоследнегоИзменения",ТекущаяДата(),Ссылка);
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2199
	Если ПараметрыСеанса.ТипУзла <> Перечисления.ТипУзлаИБ.Склад
		// Ихсанов Д. А. Начало 27.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2270
		//И СостояниеНакладной = Перечисления.СостоянияНакладной.КОтправкеНаСклад
		// Ихсанов Д. А. Конец  27.05.2025
		И (НЕ ОбменДанными.Загрузка) Тогда
		ПроверитьИнтернетЗаказПоРасходнойНакладной(Отказ);
	КонецЕсли;
	// Ихсанов Д. А. Конец  16.04.2025  
	
	
	

	
КонецПроцедуры



Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	////////////////////////////////////////////////////////////////////////
