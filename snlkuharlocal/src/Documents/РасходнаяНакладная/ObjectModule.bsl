КонецПроцедуры

// +++ Родионов, 2011-12-14, заполнение реквизита КоличествоПродукции
Функция НакладнаяОтгружена() Экспорт
	
	Возврат (СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена)
	Или (СостояниеНакладной = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад);
	
КонецФункции

Процедура ЗаполнитьКоличествоПродукции() Экспорт
	
	// обнуление колонки КоличествоПродукции
	Для Каждого СтрокаТЧ Из Комплектующие Цикл 
		СтрокаТЧ.КоличествоПродукции = 0;
	КонецЦикла;
	
	ТПродукции = Товары.Выгрузить(, "Номенклатура, Количество, Коэффициент");
	Для Каждого СтрокаТЗ Из ТПродукции Цикл
		СтрокаТЗ.Количество = СтрокаТЗ.Количество * СтрокаТЗ.Коэффициент;		
	КонецЦикла;
	ТПродукции.Свернуть("Номенклатура", "Количество");
	
	Для Каждого СтрокаТЗ Из ТПродукции Цикл
		СтрокаКомплектующих = Комплектующие.Найти(СтрокаТЗ.Номенклатура, "Продукция");
		Если СтрокаКомплектующих <> Неопределено Тогда
			СтрокаКомплектующих.КоличествоПродукции = СтрокаТЗ.Количество;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
// заполнение реквизита КоличествоПродукции, 2011-12-14, Родионов +++

//крохин начало
Процедура СформироватьДвиженияПоЗатратам(ТС) Экспорт
	ВалютаУпр=Константы.ВалютаУпрУчета_2009.Получить();
	Если КодОперации = Перечисления.КодыОперацийОстатки.ВозвратПоставщику Тогда
		ТС.Свернуть("Номенклатура","Количество,СписанаСтоимость");
		
		
		
		
		//списания по акциям
		ТЗ=Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Подразделение");
		ТЗ.Колонки.Добавить("СтатьяЗатрат");
		
		ТЗ.Колонки.Добавить("СуммаУпр",ПолучитьОписаниеТиповЧисла(19,2));
		//крохин начало 03.02.2016
		//по возвратам поставщику другой вид движения
		ТЗ.Колонки.Добавить("ВидДвижения");
		//крохин конец 03.02.2016
		
		Для Каждого СтрокаТЧ Из Товары Цикл	
			СтрокаТС=ТС.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");			
			Если СтрокаТС<>Неопределено И СтрокаТС.Количество<>0 Тогда
				// Шворобей 09.01.2024 ++ https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2458 Тогда
				Если Дата >= '20160101' И Контрагент.СтавкаНДСКонтрагента = Перечисления.СтавкиНДС.БезНДС И КодОперации = Перечисления.КодыОперацийОстатки.ВозвратПоставщику Тогда
					ТекСТавкаНДС = ПроцентНДСпоСтавке(ПолучитьСтавкуНДС(СтрокаТС.Номенклатура));
					ТекСтоимость = СтрокаТЧ.Цена*(1 + ТекСТавкаНДС/(1+ТекСТавкаНДС));
					//крохин начало 26.02.2016
					//НДС сверху с февраля 2016
					//ТекСтоимость = СтрокаТЧ.Цена*(1 + ТекСТавкаНДС/(1+ТекСТавкаНДС));
					Если Дата >= '20160201' Тогда
						ТекСтоимость = СтрокаТЧ.Цена*(1 + ТекСТавкаНДС);					
					Иначе
						ТекСтоимость = СтрокаТЧ.Цена*(1 + ТекСТавкаНДС/(1+ТекСТавкаНДС));
					КонецЕсли;
					//крохин конец 26.02.2016
					ДобавкаНДС = Окр(СтрокаТЧ.Всего - ТекСтоимость*СтрокаТС.Количество,2);
					Если ДобавкаНДС <> 0 Тогда
						СтрокаТЗ=ТЗ.Добавить();	
						СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Приход;
						СтрокаТЗ.СуммаУпр		=  - ДобавкаНДС;
						СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("321 210");;//ндс
						СтрокаТЗ.Подразделение	= Справочники.Подразделения.НайтиПоКоду("SSP-0001");
						
					КонецЕсли;
					СуммаЗатрат = Окр(СтрокаТЧ.Всего - СтрокаТЧ.Количество*СтрокаТС.СписанаСтоимость/СтрокаТС.Количество,2);
					ОстатокЗатрат = СуммаЗатрат - ДобавкаНДС;
					Если ОстатокЗатрат <> 0 Тогда
						СтрокаТЗ=ТЗ.Добавить();		
						СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Расход;
						СтрокаТЗ.СуммаУпр		= ОстатокЗатрат;
						СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.Конвертация;//ошибки ценообразования
						СтрокаТЗ.Подразделение	= Подразделение;
						
					КонецЕсли;
					
				Иначе
					СтрокаТЗ=ТЗ.Добавить();	
					СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Расход;
					СтрокаТЗ.СуммаУпр		= Окр(СтрокаТЧ.Всего - СтрокаТЧ.Количество*СтрокаТС.СписанаСтоимость/СтрокаТС.Количество,2);
					СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.Конвертация;//ошибки ценообразования
					СтрокаТЗ.Подразделение	= Подразделение;
				КонецЕсли;
				//крохин конец 03.02.2016		
			КонецЕсли;
		КонецЦикла;
		
		//крохин начало 03.02.2016
		//ТЗ.Свернуть("Подразделение,СтатьяЗатрат","СуммаУпр");
		ТЗ.Свернуть("Подразделение,СтатьяЗатрат,ВидДвижения","СуммаУпр");
		//крохин конец 03.02.2016
		
		Для Каждого СтрокаТЗ Из ТЗ Цикл		
			Если СтрокаТЗ.СуммаУпр = 0 Тогда Продолжить КонецЕсли;
			Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			//крохин начало 03.02.2016
			//Движение.ВидДвижения	= ВидДвиженияНакопления.Расход;		
			Если Дата >= '20160101' И СтрокаТЗ.ВидДвижения <> Неопределено Тогда
				Движение.ВидДвижения	= СтрокаТЗ.ВидДвижения;	
			Иначе
				Движение.ВидДвижения	= ВидДвиженияНакопления.Расход;	
			КонецЕсли;
			//крохин конец 03.02.2016		
			
			Движение.Подразделение	= СтрокаТЗ.Подразделение;			
			Движение.СтатьяЗатрат	= СтрокаТЗ.СтатьяЗатрат;
			
			Движение.СуммаУпр		= СтрокаТЗ.СуммаУпр;	
			
			Движение.СуммаДокумента	= СтрокаТЗ.СуммаУпр;
			Движение.ВалютаДокумента= ВалютаУпр;
			
			//крохин начало
			Движение.Комментарий        = "возврат поставщику";
			//крохин конец
			
			Движение.ДатаЗаписи		= ТекущаяДата();
		КонецЦикла; 
		//крохин начало 10.04.2012
		//подарки
	ИначеЕсли Подарок Тогда
		ТЗ=Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Подразделение");
		ТЗ.Колонки.Добавить("СтатьяЗатрат");
		ТЗ.Колонки.Добавить("Субзатрата");
		
		ТЗ.Колонки.Добавить("СуммаУпр",ПолучитьОписаниеТиповЧисла(19,2));		
		Для Каждого СтрокаТЧ Из Товары Цикл	
			СтрокаТС=ТС.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");			
			
			Если СтрокаТС<>Неопределено И СтрокаТС.Количество<>0 Тогда				
				СтрокаТЗ=ТЗ.Добавить();							
				СтрокаТЗ.СуммаУпр		= Окр(СтрокаТЧ.Всего - СтрокаТЧ.Количество*СтрокаТС.СписанаСтоимость/СтрокаТС.Количество,2);
				//крохин начало 07.02.2020
				//изменилась статья затрат
				//СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("320 510");//Продвижение Бренда
				//СтрокаТЗ.Субзатрата     = Справочники.СубЗатраты.НайтиПоКоду("SNL-00045");
				Если Дата >= '20200101' Тогда
					СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("320 570");//Трейд маркетинг
					СтрокаТЗ.Субзатрата     = Справочники.СубЗатраты.НайтиПоКоду("SNL-00063");
				Иначе			
					СтрокаТЗ.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("320 510");//Продвижение Бренда
					СтрокаТЗ.Субзатрата     = Справочники.СубЗатраты.НайтиПоКоду("SNL-00045");
				КонецЕсли;
				//крохин конец 07.02.2020
				СтрокаТЗ.Подразделение	= Подразделение;
				
			КонецЕсли;			
			
		КонецЦикла;
		
		ТЗ.Свернуть("Подразделение,СтатьяЗатрат,СубЗатрата","СуммаУпр");
		Для Каждого СтрокаТЗ Из ТЗ Цикл		
			Если СтрокаТЗ.СуммаУпр = 0 Тогда Продолжить КонецЕсли;
			Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;		
			
			Движение.Подразделение	= СтрокаТЗ.Подразделение;			
			Движение.СтатьяЗатрат	= СтрокаТЗ.СтатьяЗатрат;
			Движение.СубЗатрата     = СтрокаТЗ.Субзатрата;
			
			
			Движение.СуммаУпр		= - СтрокаТЗ.СуммаУпр;	
			
			Движение.СуммаДокумента	= - СтрокаТЗ.СуммаУпр;
			Движение.ВалютаДокумента= ВалютаУпр;
			
			//крохин начало
			Движение.Комментарий        = "подарок";
			//крохин конец
			
			Движение.ДатаЗаписи		= ТекущаяДата();
		КонецЦикла; 
		
		
		//крохин конец 10.04.2012
		
	Иначе	
		//услуги
		//Чирков 03.10.12+++
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура.Наименование КАК Номенклатура_Наименование,		
		|	Всего
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
		|ГДЕ
		|	Ссылка = &Ссылка
		|	И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Услуга)";
		
		Запрос.УстановитьПараметр("Ссылка",Ссылка);
		
		ТекСтатьяЗатрат=Справочники.СтатьиЗатрат.НайтиПоКоду("212 000");
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			//Чирков 03.10.12---
			Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			Движение.ВидДвижения	= ВидДвиженияНакопления.Расход;		
			
			Движение.Подразделение	= Подразделение;			
			Движение.СтатьяЗатрат	= ТекСтатьяЗатрат;
			//крохин начало 11.03.2019
			//появились услуги в валюте
			//Движение.СуммаУпр		= Выборка.Всего;	
			//
			//Движение.СуммаДокумента	= Выборка.Всего;
			//Движение.ВалютаДокумента= ВалютаУпр;
			
			Движение.СуммаУпр		= глПересчет(Выборка.Всего, Валюта, Курс, ВалютаУпр, Дата);	
			
			Движение.СуммаДокумента	= Выборка.Всего;
			
			Движение.ВалютаДокумента= Валюта;
			
			//крохин конец 11.03.2019
			
			//крохин начало
			Движение.Комментарий    = Выборка.Номенклатура_Наименование;
			//крохин конец
			
			Движение.ДатаЗаписи		= ТекущаяДата();			
		КонецЦикла;
	Конецесли;	
	
	//крохин начало 22.01.2020
	//при заполнении "суммы скидки" формируются доп. проводки
	Если СуммаСкидкиДС <> 0 Тогда
		Движение=Движения.Затраты.Добавить();
		
