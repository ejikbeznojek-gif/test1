				СформироватьПодтверждениеЗаказа(ТЗЗаказов, Ошибка, Выборка.Провайдер);
				
				//нечаева 28,10,15+++
				Если Ошибка = 0 Тогда
					Для каждого текЗаказ из ТЗЗаказов цикл
						Док = ТекЗаказ.документ.ссылка;
						ЗаписатьДанныеВРегистрОтправкаЭлектронныхДокументов(Док,,Перечисления.ДокументЕКОД.ПодтверждениеЗаказа);
					конецЦикла;
				КонецЕсли;
				//нечаева 28,10,15---
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	// нечаева 28,01,15 ---
	
	
	
	
	Если Ошибка = 0 Тогда
		// нечаева 28,01,15 +++
		// проверим не отправлено ли еще уведомление об отгрузке 
		Запрос2 = Новый Запрос;
		Запрос2.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОтправкаЭлектронныхДокументов.ВидДокумента,
		|	ОтправкаЭлектронныхДокументов.ДокументОтправлен
		|ИЗ
		|	РегистрСведений.ОтправкаЭлектронныхДокументов КАК ОтправкаЭлектронныхДокументов
		|ГДЕ
		|	ОтправкаЭлектронныхДокументов.ДокументОтправлен = ИСТИНА
