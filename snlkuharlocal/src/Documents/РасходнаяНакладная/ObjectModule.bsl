		КонецЕсли;
		//крохин конец 08.10.2020	
	#КОНЕЦЕСЛИ
	
	
	ДокОснование	= Основание;
	
	// Шворобей ВЮ 20.09.2023 ++
	
	//Кухарь А.Ю.  20.10.2023 начало
	//ШаблонРеквизитов = "ИБ,Контрагент,Договор,ЛевыйКонтрагент,ПунктДоставки,Менеджер,БанковскийСчет,Организация,ОтсрочкаПлатежа,ВидОплаты,ТипЦен,ТипСкидок,Скидка,ТранспортнаяКомпания";
	ШаблонРеквизитов = "ИБ,Контрагент,Договор,ЛевыйКонтрагент,ПунктДоставки,Менеджер,БанковскийСчет,Организация,
	|ОтсрочкаПлатежа,ВидОплаты,ТипЦен,ТипСкидок,Скидка,ТранспортнаяКомпания,КодВторичногоКонтрагента,НаименованиеВторичногоКонтрагента,НомерЗаказаВторичногоКонтрагента";	
	//Кухарь А.Ю.  20.10.2023 конец
	
	
	СписокРеквизитов = ЗаполнениеДокументов.СформироватьСтрокуРеквизитовПоШаблону(Основание, ШаблонРеквизитов);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание, СписокРеквизитов);
	
	//ИБ				= Основание.ИБ;
	//Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование,"Контрагент");
	//Договор			= ПолучитьРеквизитОбъекта(ДокОснование,"Договор");
	//ЛевыйКонтрагент = ПолучитьРеквизитОбъекта(ДокОснование,"ЛевыйКонтрагент");
	//ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");
	//Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	//БанковскийСчет	= ПолучитьРеквизитОбъекта(ДокОснование,"БанковскийСчет");
	//ОтсрочкаПлатежа = ПолучитьРеквизитОбъекта(ДокОснование,"ОтсрочкаПлатежа");			
	//ВидОплаты		= ПолучитьРеквизитОбъекта(ДокОснование,"ВидОплаты");		
	//Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");
	
	//ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	//ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	//Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");	
	//ТранспортнаяКомпания = ПолучитьРеквизитОбъекта(ДокОснование,"ТранспортнаяКомпания");
	
	// Шворобей ВЮ 20.09.2023 ++
	
	//крохин начало 03.08.2015
	ПереданПокупателюВЭлВиде = Ложь;
	//крохин конец 03.08.2015
	
	//крохин начало 25.05.2015
	//состояние накладной "в работе", иначе неверно отрабатывает "управление видимостью"
	СостояниеНакладной  = Перечисления.СостоянияНакладной.ВРаботе;
	//крохин конец 25.05.2015
	
	//крохин начало 25.12.2014
	//банковский счет и организацию перезаполняем из договора	
