		КонецЕсли;	
		ЦенаСН = Строчка1.Всего/Строчка1.количество;
		СтавкаНДС2=ПроцентНДСпоСтавке(Строчка1.СтавкаНДС);
		
		// выбираем строки с номенклатурой из СписокСтрокПоПаллетам.
