Процедура ПеренестиРезерв() Экспорт
	НеКонтролироватьТА=Истина;
	//крохин начало 06.11.2012
	//при переносе резерва меняется курс
	Доллары					= Справочники.Валюты.НайтиПоКоду("840");
	Курс=ПолучитьКурсВалюты(?(Валюта=ПараметрыСеанса.ВалютаНац,Доллары,Валюта),Дата).Курс;
	//крохин конец 06.11.2012
	Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
	НеКонтролироватьТА=Ложь;
КонецПроцедуры 


