Функция ОтсканированыВЛН_ЛП_Агрегаты(ТиШК,ДокОснование) 
	
	Если  ТиШК = Перечисления.ТипыШтрихКодов.Блочок Тогда
		
		Запрос = Новый Запрос; 
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
		|		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка
		|ГДЕ
		|	ЛистНабора.ДокОснование = &ДокОснование
		|	И ЛистНабора.Проведен
		|	И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛистПереукладки.Ссылка
		|ИЗ
		|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
		|		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладки.Ссылка
		|ГДЕ
		|	ЛистПереукладки.ДокОснование = &ДокОснование
		|	И ЛистПереукладки.Проведен
		|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)";
		Запрос.УстановитьПараметр("ДокОснование",ДокОснование); 
		РезультатЗапроса = Запрос.Выполнить(); 
		
		Возврат НЕ РезультатЗапроса.Пустой(); 
		
	ИначеЕсли ТиШК = Перечисления.ТипыШтрихКодов.Коробка Тогда
		
		Запрос = Новый Запрос; 
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
		|		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
		|		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка
		|			И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
		|			И (ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки = ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
		|ГДЕ
		|	ЛистНабора.ДокОснование = &ДокОснование
		|	И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
		|	И ЛистНабора.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛистПереукладки.Ссылка
		|ИЗ
		|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
		|		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладки.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.ШтрихкодыКоробокДляАгрегации КАК ЛистПереукладкиШтрихкодыКоробокДляАгрегации
		|		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.Ссылка
		|			И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
		|			И (ЛистПереукладкиШтрихкодыКоробокДляАгрегации.НовыйКодКоробки = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
		|ГДЕ
		|	ЛистПереукладки.ДокОснование = &ДокОснование
		|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
		|	И ЛистПереукладки.Проведен"; 
		
		Запрос.УстановитьПараметр("ДокОснование",ДокОснование); 
		РезультатЗапроса = Запрос.Выполнить(); 
		
		Возврат НЕ РезультатЗапроса.Пустой(); 
		
	Иначе 
		
		Возврат Ложь;
		
	КонецЕсли;
	
	
	
КонецФункции // ОтсканированыТолькоАгрегаты()

//++Данилова Е.В. 16.10.2025 MARK-3128
Процедура ПроверитьЗаполненностьТНВЭД(ТипУзла) 	
	
	НезаполненныеТНВЭД = Новый Массив; 
	Если СостояниеНакладной = Перечисления.СостоянияНакладной.КОтправкеНаСклад
		И НачСостНакладной = Перечисления.СостоянияНакладной.ВРаботе 
		И  ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда  		
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(РасходнаяНакладнаяТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	РасходнаяНакладнаяТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК РасходнаяНакладнаяТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(РасходнаяНакладнаяТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	РасходнаяНакладнаяТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТКомплектующие
		|ИЗ
		|	&Комплектующие КАК РасходнаяНакладнаяТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Код КАК Код
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|ГДЕ
		|	ВТТовары.Количество > 0
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ЭтоМодель
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ВидНоменклатуры = &Товар
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ТНВЭД = &ПустойТНВЭД
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТовары.Номенклатура,
		|	ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Код
		|ИЗ
		|	ВТКомплектующие КАК ВТТовары
		|ГДЕ
		|	ВТТовары.Количество > 0
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ЭтоМодель
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ВидНоменклатуры = &Товар
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ТНВЭД = &ПустойТНВЭД";
		
		Запрос.УстановитьПараметр("ПустойТНВЭД", Справочники.ТНВЭД.ПустаяСсылка());
		Запрос.УстановитьПараметр("Товар", Перечисления.ВидыНоменклаутры.Товар);
		Запрос.УстановитьПараметр("Товары", Товары.Выгрузить(,"Номенклатура,Количество"));
		Запрос.УстановитьПараметр("Комплектующие", Комплектующие.Выгрузить(,"Номенклатура,Количество"));
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НезаполненныеТНВЭД.Добавить(ВыборкаДетальныеЗаписи.Код);
		КонецЦикла; 	
		
		Если НезаполненныеТНВЭД.Количество() > 0 Тогда
			
			Если НЕ СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе Тогда 		
				
				#Если  КЛИЕНТ Тогда
					
					ТекстСообщения = "В РНК присутствует позиции с незаполненным полем ТНВЭД:" + Символы.ПС + СтрСоединить(НезаполненныеТНВЭД,Символы.ПС)+					
					" Товар не будет промаркирован КМ. Обратитесь в отдел ВЭД для проставления кода ТНВЭД в случае необходимости промаркировать товар."; 
					
					СписокВопрос = Новый СписокЗначений; 
					СписокВопрос.Добавить("Продолжить","Продолжить");
					СписокВопрос.Добавить("Отменить","Отменить");
					КодОтвета = Вопрос(ТекстСообщения,СписокВопрос);
					Если КодОтвета = "Отменить" Тогда
						
						СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе;	
						
					КонецЕсли;
					
				#ИНАЧЕ
					
					СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе; 
					
				#КонецЕсли
			КонецЕсли;                      
			
			ТекстСообщения = "В накладной есть позиции с незаполненным ТНВЭД:" + Символы.ПС + СтрСоединить(НезаполненныеТНВЭД,Символы.ПС); 	
			СообщитьИзМодуля(ТекстСообщения);
			
		КонецЕсли;
	Конецесли;
	
КонецПроцедуры

