	Иначе
		ИЛНПок =  ДокОбъект.Контрагент.Родитель.КодИЛН;
	КонецЕсли;
	//Определяем какие EDI-документы надо формировать
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВыгружаемыеДокументыЕКОД.Провайдер
	|ИЗ
	|	Справочник.ВыгружаемыеДокументыЕКОД КАК ВыгружаемыеДокументыЕКОД
	|ГДЕ
	|	ВыгружаемыеДокументыЕКОД.Владелец = &Контрагент
	|	И ВыгружаемыеДокументыЕКОД.ВидДокумента = &ВидДокумента
	|	И ВыгружаемыеДокументыЕКОД.ПометкаУдаления = ЛОЖЬ";
	
	
