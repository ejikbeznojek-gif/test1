	//если склад не соответствует подразделению - не копируем
	ЭтотУзел = ПараметрыСеанса.ЭтотУзел;
	Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если Склад.ТипСклада = Перечисления.ТипСклада.Филиал Тогда
			Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
		Если Склад.Подразделение <> ЭтотУзел.Подразделение Тогда
			Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
	//крохин конец 27.02.2013
	
	//крохин начало 05.03.2011
	//подразделение не копируем
	//++Данилова Е.В. 29.09.2025 HELP-7048
	//Подразделение = Менеджер.Подразделение; 
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер);
	//--Данилова Е.В. 29.09.2025
	Если Подразделение = Справочники.Подразделения.ПустаяСсылка() Тогда
		Подразделение = Склад.Подразделение;
	КонецЕсли;
	//крохин конец 05.03.2011
	
	//крохин начало 01.11.2012
	//снова копируем подразделение, только для РНК-основания
	Если ДокОснование.Метаданные().Имя = "РасходнаяНакладная" Тогда
		Подразделение = ПолучитьРеквизитРодителя(ДокОснование,"Подразделение");
	КонецЕсли;
	//крохин конец 01.11.2012
	
	//крохин начало
	//Группы товаров пересчитаем заново
