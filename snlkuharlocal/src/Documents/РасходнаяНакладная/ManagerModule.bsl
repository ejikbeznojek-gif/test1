
Функция ПереместитьСФизическогоСкладаНаВиртуальный(ДокСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	СводнаяТаблица = Новый ТаблицаЗначений;
	СводнаяТаблица.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	СводнаяТаблица.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	СводнаяТаблица.Колонки.Добавить("СвободныйОстатокСклад", Новый ОписаниеТипов("Число"));
	СводнаяТаблица.Колонки.Добавить("СвободныйОстатокСкладФиз", Новый ОписаниеТипов("Число"));
	
	МассивСкладов = Новый Массив();
	МассивСкладов.Добавить(ДокСсылка.Склад);
	Если ЗначениеЗаполнено(ДокСсылка.Склад.ФизическийСклад) Тогда
		МассивСкладов.Добавить(ДокСсылка.Склад.ФизическийСклад);
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Количество КАК Количество
	|ПОМЕСТИТЬ ТабличнаяЧасть
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &ДокСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сводный.Номенклатура КАК Номенклатура,
	|	СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) КАК СвободныйОстаток,
	|	СУММА(Сводный.Количество) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Остатки.Номенклатура, ТабличнаяЧасть.Номенклатура) КАК Номенклатура,
	|		ЕСТЬNULL(ТабличнаяЧасть.Количество, 0) КАК Количество,
	|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	|		0 КАК ВиртуальныйРезерв
	|	ИЗ
	|		ТабличнаяЧасть КАК ТабличнаяЧасть
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад = &Склад) КАК Остатки
	|				ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(, Склад = &Склад) КАК Резервы
	|				ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			ПО (Остатки.Номенклатура = ТабличнаяЧасть.Номенклатура)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЕСТЬNULL(ОстаткиТМЦ.Номенклатура, ТабличнаяЧасть.Номенклатура),
	|		0,
	|		ЕСТЬNULL(ОстаткиТМЦ.Количество, 0),
	|		0,
	|		0
	|	ИЗ
	|		ТабличнаяЧасть КАК ТабличнаяЧасть
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|			ПО (ОстаткиТМЦ.Номенклатура = ТабличнаяЧасть.Номенклатура)
	|	ГДЕ
	|		ОстаткиТМЦ.Регистратор = &ДокСсылка
	|		И ОстаткиТМЦ.Склад = &Склад
	|		И ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЕСТЬNULL(РезервыТМЦ.Номенклатура, ТабличнаяЧасть.Номенклатура),
	|		0,
	|		0,
	|		-ЕСТЬNULL(РезервыТМЦ.Количество, 0),
	|		0
	|	ИЗ
	|		ТабличнаяЧасть КАК ТабличнаяЧасть
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|			ПО (РезервыТМЦ.Номенклатура = ТабличнаяЧасть.Номенклатура)
	|	ГДЕ
	|		РезервыТМЦ.Регистратор = &ДокСсылка
	|		И РезервыТМЦ.Склад = &Склад) КАК Сводный
	|
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТабличнаяЧасть";
	
	Для Каждого Склад ИЗ МассивСкладов Цикл
		
		Запрос.УстановитьПараметр("Склад", Склад);
		
		УстановитьПривилегированныйРежим(Истина);
		ТаблицаОстатков = Запрос.Выполнить().Выгрузить();
		УстановитьПривилегированныйРежим(Ложь);
		
		Для Каждого Стр ИЗ ТаблицаОстатков Цикл
			НоваяСтрока = СводнаяТаблица.Добавить();
			НоваяСтрока.Номенклатура = Стр.Номенклатура;
			Если Склад.ВидСклада = Перечисления.ВидСклада.Виртуальный Тогда
				НоваяСтрока.СвободныйОстатокСклад = Стр.СвободныйОстаток;
			КонецЕсли;
			Если Склад.ВидСклада = Перечисления.ВидСклада.Физический Тогда
				НоваяСтрока.СвободныйОстатокСкладФиз = Стр.СвободныйОстаток;
				НоваяСтрока.Количество = Стр.Количество;	
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	СводнаяТаблица.Свернуть("Номенклатура", "Количество, СвободныйОстатокСклад, СвободныйОстатокСкладФиз");
	
	//////////////// ПО СВОДНОЙ ТАБЛИЦЕ /////////////////////////////////////////////////////////////////
	
	ТаблицаКЗагрузке = Новый ТаблицаЗначений;
	ТаблицаКЗагрузке.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаКЗагрузке.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	
	Для Каждого Стр ИЗ СводнаяТаблица Цикл
		Если Стр.Количество > Стр.СвободныйОстатокСклад И Стр.СвободныйОстатокСкладФиз > 0 Тогда
			НоваяСтрока = ТаблицаКЗагрузке.Добавить();
			НоваяСтрока.Номенклатура = Стр.Номенклатура;
			Если Стр.СвободныйОстатокСкладФиз >= Стр.Количество - Стр.СвободныйОстатокСклад Тогда
				НоваяСтрока.Количество = Стр.Количество - Стр.СвободныйОстатокСклад;
			Иначе
				НоваяСтрока.Количество = Стр.СвободныйОстатокСкладФиз;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ТаблицаКЗагрузке.Количество() > 0 Тогда
		НачатьТранзакцию();
		Перемещение = СоздатьПеремещение(ДокСсылка, ТаблицаКЗагрузке);
		Если Перемещение = Неопределено Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция СоздатьПеремещение(ДокументСсылка, ТаблицаКЗагрузке)
	
	Если НЕ ЗначениеЗаполнено(ДокументСсылка.Склад.ФизическийСклад) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТаблицаКЗагрузке.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Перемещение = Документы.Перемещение.СоздатьДокумент();
	
	// Кухарь А.Ю. 12.05.2022 начало
	// Начало дня - слишком рано. Иногда товара у отправителя на этот момент ещё нет
	//Перемещение.Дата = НачалоДня(ДокументСсылка.Дата);
	Перемещение.Дата = ДокументСсылка.Дата-1;
	// Кухарь А.Ю. 12.05.2022 конец
	
	Перемещение.ДатаОтгрузки = НачалоДня(ДокументСсылка.Дата);
	Перемещение.ДатаПриемки = НачалоДня(ДокументСсылка.Дата);
	
	ЗаполнитьШапкуДокумента(Перемещение,ПараметрыСеанса.Пользователь);
	Перемещение.ДокОснование = ДокументСсылка;
	Перемещение.СкладПолучатель = ДокументСсылка.Склад;	
	ОбменЭДО.УстановитьПунктДоставкиСб2б(Перемещение,"СкладПолучатель","ПунктДоставки");
	
	Перемещение.Валюта = Справочники.Валюты.НайтиПоКоду("810");
	Перемещение.Курс = 1;
	
	Перемещение.Склад = ДокументСсылка.Склад.ФизическийСклад;
	Перемещение.Комментарий = "Перемещаем с Физ.склада на Виртуальный";
	
	Перемещение.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	Перемещение.СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.Принята;
	Перемещение.Отгружен = Перечисления.Отгружен.Отгружен;
	
	УстановитьНомерДокументаКлиентСервер(Перемещение); 	 
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаКЗагрузке Цикл
		НоваяСтрока = Перемещение.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		НоваяСтрока.Заявка = НоваяСтрока.Количество;
		НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		НоваяСтрока.ПодтвержденнаяЗаявкаПеремещения = НоваяСтрока.Количество;
		НоваяСтрока.Коэффициент = 1;
		НоваяСтрока.Единица = СтрокаТЧ.Номенклатура.ОсновнаяЕдиница;
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, Перемещение);
		РассчитатьСуммуТабЧасти(НоваяСтрока, Перемещение);	
	КонецЦикла;
	
	Попытка
		Перемещение.Записать(РежимЗаписиДокумента.Проведение);
		//Кухарь А.Ю.  17.03.2022 начало
		СообщитьИзМодуля(""+Перемещение); 
		//Кухарь А.Ю.   17.03.2022 конец
		
		Возврат Перемещение.Ссылка;
	Исключение
		Сообщить(ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

