// Возвращает ИСТИНА - товар маркирован, ЛОЖЬ - не маркирован
Функция ТоварМаркирован(Номенклатура, ДатаОтгрузки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	спрНоменклатура.Ссылка КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА спрНоменклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА спрНоменклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаМаркировки,
	|	ВЫБОР
	|		КОГДА спрНоменклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА спрНоменклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаОбязательнойМаркировки
	|ПОМЕСТИТЬ ДанныеОТоваре
	|ИЗ
	|	Справочник.Номенклатура КАК спрНоменклатура
	|ГДЕ
	|	спрНоменклатура.Ссылка = &Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОТоваре.Номенклатура КАК Номенклатура,
	|	ДанныеОТоваре.ДатаМаркировки КАК ДатаМаркировки
	|ПОМЕСТИТЬ НеМаркированныйТовар
	|ИЗ
	|	ДанныеОТоваре КАК ДанныеОТоваре
	|ГДЕ
	|	(ДанныеОТоваре.ДатаМаркировки = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ ДанныеОТоваре.ДатаМаркировки > &ДатаОтгрузки)
	|	И (ДанныеОТоваре.ДатаОбязательнойМаркировки = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ ДанныеОТоваре.ДатаОбязательнойМаркировки > &ДатаОтгрузки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОТоваре.Номенклатура КАК Номенклатура,
	|	ДанныеОТоваре.ДатаМаркировки КАК ДатаМаркировки
	|ПОМЕСТИТЬ МаркированныйТовар
	|ИЗ
	|	ДанныеОТоваре КАК ДанныеОТоваре
	|ГДЕ
	|	ДанныеОТоваре.ДатаМаркировки <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДанныеОТоваре.ДатаМаркировки <= &ДатаОтгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОТоваре.Номенклатура КАК Номенклатура,
	|	ДанныеОТоваре.ДатаОбязательнойМаркировки КАК ДатаОбязательнойМаркировки
	|ПОМЕСТИТЬ ОбязательноМаркированныйТовар
	|ИЗ
	|	ДанныеОТоваре КАК ДанныеОТоваре
	|ГДЕ
	|	(ДанныеОТоваре.ДатаОбязательнойМаркировки <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ДанныеОТоваре.ДатаОбязательнойМаркировки <= &ДатаОтгрузки
	|			ИЛИ ДанныеОТоваре.Номенклатура.ОтгрузкаТолькоЧерезЧЗ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеОТоваре.Номенклатура) КАК Номенклатура
	|ИЗ
	|	ДанныеОТоваре КАК ДанныеОТоваре";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивПакета = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	УстановитьПривилегированныйРежим(Ложь);
	
	НеМаркированныйТовар = МассивПакета[1].Выгрузить();
	МаркированныйТовар = МассивПакета[2].Выгрузить();
	ОбязательноМаркированныйТовар = МассивПакета[3].Выгрузить();
	
	Если НеМаркированныйТовар.Количество() > 0 Тогда
		Возврат Ложь;
	ИначеЕсли МаркированныйТовар.Количество() > 0 ИЛИ ОбязательноМаркированныйТовар.Количество() > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции
