Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	Доллары				=Справочники.Валюты.НайтиПоКоду("840");
	Рубли				=Справочники.Валюты.НайтиПоКоду("810");
	Евро				=Справочники.Валюты.НайтиПоКоду("978");
	
	ВалютаУпр			=?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр				=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	//На регистре
	//СуммаВАЛ - сумма в валюте расчетов
	//СуммаУПР - сумма в упр валюте
	
	Для Каждого СтрокаТЧ Из Расчеты Цикл
		ВалютаРасчетов=ПолучитьВалютуРасчетов(СтрокаТЧ.Договор);		
						
		СуммаВал					= глПересчет(СтрокаТЧ.Сумма,СтрокаТЧ.Валюта,СтрокаТЧ.Курс,ВалютаРасчетов,Дата);		
		СуммаУпр					= глПересчет(СтрокаТЧ.Сумма,СтрокаТЧ.Валюта,Дата,ВалютаУпр,КурсУпр);		
		
		//Взаиморасчеты
		Движение 					= Движения.Взаиморасчеты.Добавить();
		
		Движение.ВидДвижения		= ?(СуммаВАЛ>0,ВидДвиженияНакопления.Приход,ВидДвиженияНакопления.Расход);		
		
		Движение.Период				= Дата;
		Движение.Контрагент			= СтрокаТЧ.Контрагент;
		Движение.Договор 			= СтрокаТЧ.Договор;			
		
		Движение.СуммаВал			= Модуль(СуммаВАЛ);
		Движение.СуммаУпр			= Модуль(СуммаУпр);
		
		Движение.СуммаДокумента		= СтрокаТЧ.Сумма;
		Движение.ВалютаДокумента	= СтрокаТЧ.Валюта;	
		
		//ЗАТРАТЫ
		Движение 					= Движения.Затраты.Добавить();		
		
		Движение.ВидДвижения		= ?(СуммаВАЛ>0,ВидДвиженияНакопления.Расход,ВидДвиженияНакопления.Приход);				
		
		Движение.Период				= Дата;
		Движение.Подразделение		= СтрокаТЧ.Подразделение;
		Движение.СтатьяЗатрат		= СтрокаТЧ.СтатьяЗатрат;
		//++Данилова Е.В. 24.04.2026 HELP-9467 
		Если Дата >= Дата(2026,04,01) Тогда
			Движение.КаналСбыта 		= СтрокаТЧ.КаналСбыта; 
		КонецЕсли;
		//--Данилова Е.В. 24.04.2026 
		Движение.СубЗатрата			= СтрокаТЧ.СубЗатрата;
		
		Движение.СуммаУпр			= Модуль(СуммаУпр);		
		
		Движение.Контрагент			= СтрокаТЧ.Контрагент;
		Движение.Договор			= СтрокаТЧ.Договор;
		
		Движение.СуммаДокумента		= Модуль(СтрокаТЧ.Сумма);
		Движение.ВалютаДокумента	= СтрокаТЧ.Валюта;	
		
		
		Движение.КапитальныеЗатраты	= СтрокаТЧ.КапитальныеЗатраты;
		Движение.Проект				= СтрокаТЧ.Проект;
		Движение.ПериодРасходов		= ?(ЗначениеЗаполнено(СтрокаТЧ.ПериодРасходов),НачалоМесяца(СтрокаТЧ.ПериодРасходов),НачалоМесяца(Дата));
		
	    //крохин начало
		Движение.Комментарий        = Комментарий;
		//крохин конец

		
		Движение.ДатаЗаписи			= ТекущаяДата();		
	КонецЦикла; 
	
	Если ОбменДанными.Загрузка Тогда
		Движения.Взаиморасчеты.Записать();	
	КонецЕсли; 
КонецПроцедуры

//СОБЫТИЯ ОБЪЕКТА
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ЕстьИзменения		=Модифицированность();
	НужноВыгружать		=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	
	Если НЕ ОбменДанными.Загрузка Тогда		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		
		Если Отказ Тогда Возврат КонецЕсли; 		
	КонецЕсли;	
	
	Если Отказ Тогда Возврат КонецЕсли;	
	
	Если ЕстьИзменения Тогда
		СуммаДокумента=Расчеты.Итог("Сумма");		
	КонецЕсли;
	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
		//Катаев+ 08/10/14
		Если Не ЭтотОбъект.Ссылка.Пустая() Тогда
			НужноВыгружать = Ложь;
		КонецЕсли;
		//Катаев- 08/10/14
	КонецЕсли;	
КонецПроцедуры

