Процедура ОбработкаЗаполнения(Основание)
	//крохин начало 10.07.2019
	Если ТипЗнч(Основание)=Тип("Структура") ИЛИ Основание = Неопределено Тогда Возврат КонецЕсли;
	//крохин конец 10.07.2019
	
	Если Основание.Метаданные().Имя = "Претензия" Тогда
		ВидОплаты = Перечисления.ВидыОплаты.БН;
		ДокОснование = Основание;
		Комментарий = "ПРТ "+ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДЛФ=DD")+ ". "+ДокОснование.Комментарий;
		СтрокаТЧ = Расчеты.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,ДокОснование);
		//крохин начало 27.06.2012
		СтрокаТЧ.Контрагент = ?(ДокОснование.контрагент.ведущий.пустая(),ДокОснование.контрагент,ДокОснование.контрагент.ведущий);
		//крохин конец 27.06.2012
		СтрокаТЧ.СтатьяЗатрат = Справочники.СтатьиЗатрат.НайтиПоКоду("223 230"); //Недостача ТМЦ по заказу клиента
		Если НЕ ДокОснование.ПризнакВозврата Тогда
			СтрокаТЧ.Сумма = ДокОснование.СуммаДокумента;
		Иначе
			СтрокаТЧ.Сумма = -ДокОснование.СуммаДокумента;
		КонецЕсли;
		СтрокаТЧ.ПериодРасходов = ДокОснование.ДокОснование.Дата;
		
		// +++ spk, 2013-01-31, "Подотчет на карты"
	ИначеЕсли Основание.Метаданные().Имя = "ЗаявкаНаОплату" Тогда
		
		Если Основание.ВидОперации = Перечисления.ВидыОперацийППИсходящее.ПеречислениеПодотчетномуЛицу Тогда			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Ссылка", Основание);
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаявкаНаОплату.Организация,
			|	ЗаявкаНаОплату.Валюта,
			|	ЗаявкаНаОплату.Курс,
			|	ЗаявкаНаОплату.Подразделение,
			|	ЗаявкаНаОплату.СтатьяЗатрат,
			|	ЗаявкаНаОплату.СубЗатрата,
			|	ЗаявкаНаОплату.КапитальныеЗатраты,
			|	ЗаявкаНаОплату.Проект,
			|	ЗаявкаНаОплату.ПериодРасходов
			|ИЗ
			|	Документ.ЗаявкаНаОплату КАК ЗаявкаНаОплату
			|ГДЕ
			|	ЗаявкаНаОплату.Ссылка = &Ссылка";
			РезультатЗапроса = Запрос.Выполнить();
			Если НЕ РезультатЗапроса.Пустой() Тогда
				Шапка = РезультатЗапроса.Выбрать();
				Шапка.Следующий();
			Иначе
				Шапка = Новый Структура("Организация", Справочники.Организации.ПустаяСсылка());
			КонецЕсли; 
			
			// заполняем шапку документа
			Организация		= Шапка.Организация;
			ДокОснование	= Основание;
			ВидОплаты		= Перечисления.ВидыОплаты.БН;
			
			ТаблицаДоговоров	= Неопределено;
			ВидДоговораПодОтчет	= Справочники.ВидыДоговоров.НайтиПоНаименованию("Под отчёт", Истина);
			Если ЗначениеЗаполнено(ВидДоговораПодОтчет) Тогда
				Запрос = Новый Запрос;
				Запрос.УстановитьПараметр("Ссылка"		, Основание);
				Запрос.УстановитьПараметр("ВидДоговора"	, ВидДоговораПодОтчет);
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	ЗаявкаНаОплатуПодотчет.Сотрудник,
				|	МАКСИМУМ(Договоры.Ссылка) КАК Договор
				|ИЗ
				|	Справочник.Договоры КАК Договоры
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаОплату.Подотчет КАК ЗаявкаНаОплатуПодотчет
				|		ПО Договоры.Владелец = ЗаявкаНаОплатуПодотчет.Сотрудник
				|			И (ЗаявкаНаОплатуПодотчет.Ссылка = &Ссылка)
				|			И (Договоры.ВидДоговора_Новый = &ВидДоговора)
				|			И ((НЕ Договоры.ПометкаУдаления))
				|
				|СГРУППИРОВАТЬ ПО
				|	ЗаявкаНаОплатуПодотчет.Сотрудник";
				ТаблицаДоговоров = Запрос.Выполнить().Выгрузить();
				ТаблицаДоговоров.Индексы.Добавить("Сотрудник");
			КонецЕсли; 
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Ссылка", Основание);
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаявкаНаОплатуПодотчет.Сотрудник,
			|	ЗаявкаНаОплатуПодотчет.Сумма
			|ИЗ
			|	Документ.ЗаявкаНаОплату.Подотчет КАК ЗаявкаНаОплатуПодотчет
			|ГДЕ
			|	ЗаявкаНаОплатуПодотчет.Ссылка = &Ссылка";
			Выборка = Запрос.Выполнить().Выбрать();
			// заполняем таб.часть Расчеты
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Расчеты.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Шапка);
				НоваяСтрока.Контрагент	= Выборка.Сотрудник;
				НоваяСтрока.Сумма		= Выборка.Сумма;
				Если ТаблицаДоговоров <> Неопределено Тогда
					СтрокаТабДог = ТаблицаДоговоров.Найти(Выборка.Сотрудник, "Сотрудник");
					Если СтрокаТабДог <> Неопределено Тогда
						НоваяСтрока.Договор = СтрокаТабДог.Договор;
					КонецЕсли; 
				КонецЕсли;
				//Валетов + 15,04,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9445
				Если НоваяСтрока.Проект.ПометкаУдаления Тогда
					НоваяСтрока.Проект ="";
				КонецЕсли;
				//валетов -
			КонецЦикла;
			
			СуммаДокумента = Расчеты.Итог("Сумма");
			
		КонецЕсли; 
		// "Подотчет на карты", 2013-01-31, spk +++
	КонецЕсли;
	
КонецПроцедуры

