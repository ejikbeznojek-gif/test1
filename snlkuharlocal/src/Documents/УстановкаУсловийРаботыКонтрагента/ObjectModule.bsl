Перем ОтработаноДоИзменений; 


Процедура ОбработкаПроведения(Отказ, РежимПроведения)

 	форма=ЭтотОбъект.ПолучитьФорму("ФормаДокумента");
 	КонтрагентОбъект=Контрагент.ПолучитьОбъект();
	  
	Если этотОбъект.Отработано = истина и ОтработаноДоИзменений=ложь  тогда
	форма.ЭлементыФормы.Надпись1.Картинка = БиблиотекаКартинок.ВыполненоУспешно32;	
		для каждого СтрКонтрагента из КонтрагентОбъект.Скидки цикл
			СтрКонтрагента.Скидка = 0;
		Конеццикла;
		
		для каждого СтрТч из СкидкиПослеИзменения цикл
			
			Структура = новый структура;
			Структура.Вставить("Номенклатура",СтрТЧ.Номенклатура);							
			
			НайденнаяСтрокаВСправочнике=КонтрагентОбъект.Скидки.НайтиСтроки(Структура);
			
			// если строка нашлась, то просто изменяем скидку
			если НайденнаяСтрокаВСправочнике.Количество()<>0 тогда;		
				
				Для каждого Строчка из НайденнаяСтрокаВСправочнике цикл
					Строчка.скидка=СтрТч.скидка;
					ЗаполнитьЗначенияСвойств(Строчка,СтрТч); 
				Конеццикла;
				
				//если новая строчка
			иначе 		
				НоваяСтрока=КонтрагентОбъект.Скидки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрТч); 
			конецесли;	
		Конеццикла;	
		
		
		МассивУдаляемыхСтрок=КонтрагентОбъект.Скидки.НайтиСтроки(новый Структура("Скидка",0));
		для каждого СтрМассива из МассивУдаляемыхСтрок цикл
			КонтрагентОбъект.Скидки.Удалить(СтрМассива);
		КонецЦикла;
		ОтработаноПослеИзменени=Отработано;
		ОтработаноПослеИзменени=Истина;
	
		КонтрагентОбъект.Записать();		
		КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
ОтработаноДоИзменений = Ссылка.Отработано;
КонецПроцедуры

процедура ПриКопировании(ЭтотОбъект);
	Скидки.Очистить();
	СкидкиПослеИзменения.Очистить();
	Отработано=Ложь;
конецпроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Скидки.Очистить();
	СкидкиПослеИзменения.Очистить();
	Отработано=Ложь;

КонецПроцедуры
