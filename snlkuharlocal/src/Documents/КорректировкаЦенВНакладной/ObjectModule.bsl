Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	
	Если НЕ ПроводитьПоОстаткам Тогда Возврат  КонецЕсли; 
	
	//для проведения РКМ/КЦН в ЦО
	Если НЕ ОбменДанными.Загрузка И НЕ ПараметрыСеанса.ЗапущенаОбработка Тогда
	
		#если клиент Тогда
		//по офисным складам можно делать РКМ
		Если ПараметрыСеанса.ЭтотУзел.Код = "SNL" И НЕ ПустаяСтрока(Склад.КодФизическогоУзла) Тогда	
				сообщить("РКМ и КЦН проводятся только на складе!");
				отказ = истина;
				возврат;		
			КонецЕсли;	
		#КонецЕсли
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ДвиженияПоРегистрам=Неопределено;	
	Доллары				=Справочники.Валюты.НайтиПоКоду("840");
	Рубли				=Справочники.Валюты.НайтиПоКоду("810");
	Евро				=Справочники.Валюты.НайтиПоКоду("978");
	
	ВалютаУпр			=?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр				=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	//На регистре
	//СуммаВАЛ - сумма в валюте расчетов
	//СуммаУПР - сумма в упр валюте
	
	СтатьяЗатрат=Справочники.СтатьиЗатрат.НайтиПоКоду("321 410  ");
	
	
	// нечаева доработка для ПНК 02,07,14 +++
	
	ТекВид=ДокОснование.Метаданные().Имя;
	Если ТекВид<>"ПриходнаяНакладная" Тогда
		
		Если Дата < '20160201' ИЛИ ДокОснование.КодОперации <> Перечисления.КодыОперацийОстатки.Реализация Тогда
			СуммаВал					=  Модуль(товары.Итог("Всего"));
			СуммаУпр					=  Модуль(товары.Итог("Всего"));
			
			//ЗАТРАТЫ
			Движение 					= Движения.Затраты.Добавить();		
			
			Движение.ВидДвижения		= ?(товары.Итог("Всего")<0,ВидДвиженияНакопления.Расход,ВидДвиженияНакопления.Приход);				
			
			Движение.Период				= Дата;
			//++Данилова Е.В. 03.10.2025 HELP-7050 
			Если Дата >= дата(2025,09,01) Тогда
				
				Движение.Подразделение		= ?(ЗначениеЗаполнено(Подразделение),Подразделение,ДокОснование.Подразделение);
			Иначе 
				Движение.Подразделение		= ДокОснование.Подразделение;
			КонецЕсли;
			//Движение.Подразделение		= ДокОснование.Подразделение;
			//--Данилова Е.В. 03.10.2025			

			Движение.СтатьяЗатрат		= СтатьяЗатрат;
			
			Движение.СуммаУпр			= Модуль(СуммаУпр);		
			
			Движение.Контрагент			= ДокОснование.Контрагент.Ведущий;
			Движение.Договор			= ДокОснование.Договор;
			
			Движение.СуммаДокумента		= Модуль(товары.Итог("Всего"));
			Движение.ВалютаДокумента	= Валюта;	
			
			Движение.ПериодРасходов		= ДокОснование.Дата;
			
			Движение.Комментарий        = Комментарий;
			
			Движение.ДатаЗаписи			= ТекущаяДата();	
		Иначе
			
			ДвиженияПоРегистрам=Неопределено;	
			
			РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
			
			Результат=РезультатПроведения["Результат"];
			
			
			Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда 			
				Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));
			КонецЕсли;
			
			
			Если Не Отказ Тогда
				ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);		
			КонецЕсли;
			
			
		КонецЕсли;
		
		
		//************************************************************************************************************************************************	
		//Взаиморасчеты
		Движение 					= Движения.Взаиморасчеты.Добавить();
		
		Движение.ВидДвижения		= ?(товары.Итог("Всего")<0,ВидДвиженияНакопления.Приход,ВидДвиженияНакопления.Расход);		
		
		Движение.Период				= Дата;
		Если Лев(ДокОснование.Ссылка,18) = "<Объект не найден>" Тогда
			Движение.Контрагент			= Корреспондент.Ведущий;
			Движение.Договор 			= Договор;	
		Иначе
			Движение.Контрагент			= ДокОснование.Контрагент.Ведущий;
			Движение.Договор 			= Докоснование.Договор;	
		КонецЕсли;
		движение.КодОперации        = перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
		
		Движение.СуммаВал			= Модуль(товары.Итог("Всего"));
		Движение.СуммаУпр			= Модуль(товары.Итог("Всего"));
		
		Движение.СуммаДокумента		= товары.Итог("Всего");
		Движение.ВалютаДокумента	= Валюта;	
		
		Движение.Дата_НачалаЗадолженности = ДокОснование.ДатаОплаты;
	Иначе
		// это для ПНК
		СуммаВал					= -Модуль(товары.Итог("Всего"));
		СуммаУпр					= -Модуль(товары.Итог("Всего"));
		
		//ЗАТРАТЫ
		Движение 					= Движения.Затраты.Добавить();		
		
		Движение.ВидДвижения		= ?(товары.Итог("Всего")<0,ВидДвиженияНакопления.Расход,ВидДвиженияНакопления.Приход);				
		
		Движение.Период				= Дата;
		//++Данилова Е.В. 03.10.2025 HELP-7050 
		Если Дата >= дата(2025,09,01) Тогда
		
			Движение.Подразделение		= ?(ЗначениеЗаполнено(Подразделение),Подразделение,ДокОснование.Подразделение);
		Иначе 
			Движение.Подразделение		= ДокОснование.Подразделение;
		КонецЕсли;
		//Движение.Подразделение		= ДокОснование.Подразделение;
		//--Данилова Е.В. 03.10.2025
		Движение.СтатьяЗатрат		= СтатьяЗатрат;
		
		Движение.СуммаУпр			= - Модуль(СуммаУпр);		
		
		Движение.Контрагент			= ДокОснование.Контрагент.Ведущий;
		Движение.Договор			= ДокОснование.Договор;
		
		Движение.СуммаДокумента		= товары.Итог("Всего");
		Движение.ВалютаДокумента	= Валюта;	
		
		Движение.ПериодРасходов		= ДокОснование.Дата;
		
		Движение.Комментарий        = Комментарий;
		
		Движение.ДатаЗаписи			= ТекущаяДата();		
		
		
		//************************************************************************************************************************************************	
		//Взаиморасчеты
		Движение 					= Движения.Взаиморасчеты.Добавить();
		
		Движение.ВидДвижения		= ?(товары.Итог("Всего")<0,ВидДвиженияНакопления.Приход,ВидДвиженияНакопления.Расход);		
		
		Движение.Период				= Дата;
		Движение.Контрагент			= ДокОснование.Контрагент.Ведущий;
		Движение.Договор 			= Докоснование.Договор;	
		движение.КодОперации        = перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
		
		Движение.СуммаВал			= - Модуль(товары.Итог("Всего"));
		Движение.СуммаУпр			= - Модуль(товары.Итог("Всего"));
		
		Движение.СуммаДокумента		= товары.Итог("Всего");
		Движение.ВалютаДокумента	= Валюта;	
		
	конецЕсли;
	
	//при заполнении "суммы скидки" формируются доп. проводки
	ВалютаУпр=Константы.ВалютаУпрУчета_2009.Получить();
	
		Если  СуммаСкидкиДС <> 0 Тогда

		Запись=Движения.Взаиморасчеты.Добавить();                                          
							Запись.Период			=Дата;
							Запись.Активность		=Истина;
							Запись.ВидДвижения		=ВидДвиженияНакопления.Расход;
							
							Запись.СуммаУпр			=глПересчет(СуммаСкидкиДС,Валюта,Курс,ВалютаУпр,Дата);
							Запись.СуммаВал			=глПересчет(СуммаСкидкиДС,Валюта,Курс,ВалютаУпр,Курс);
							
							Запись.Контрагент		=Корреспондент.Ведущий;		
							Запись.Договор			=ДоговорСкидкиДС;
							
							Запись.СуммаДокумента	=СуммаДокумента;
							Запись.ВалютаДокумента	=Валюта;
	
		КонецЕсли;	 				
	Если СуммаСкидкиДС <> 0 Тогда
            Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;		
			
			//++Данилова Е.В. 03.10.2025 HELP-7050 
			Если Дата >= дата(2025,09,01) Тогда
				
				Движение.Подразделение		= ?(ЗначениеЗаполнено(Подразделение),Подразделение,ДокОснование.Подразделение);
			Иначе 
				Движение.Подразделение		= ДокОснование.Подразделение;
			КонецЕсли;
			//Движение.Подразделение		= ДокОснование.Подразделение;
			//--Данилова Е.В. 03.10.2025			
			
			Движение.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("320 570"); //Трейд-маркетинг
			
			Движение.СуммаУпр		= глПересчет(СуммаСкидкиДС, Валюта, Курс, ВалютаУпр, Дата);	
			
			Движение.СуммаДокумента	= СуммаДокумента;
			
			Движение.ВалютаДокумента= Валюта;
			
			Движение.Комментарий    = "скидка по ДС";

			
			Движение.ДатаЗаписи		= ТекущаяДата();
	КонецЕсли;		

	Если ОбменДанными.Загрузка тогда
		Движения.Взаиморасчеты.Записать();
		Движения.Затраты.Записать();
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;	
	
	ВидОснования	= Основание.Метаданные().Имя;
	ДокОснование	= Основание;
	
	//Нечаева 15,01,14  +++
	Если ВидОснования="Перемещение" Тогда 
		Если КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) >= ДокОснование.Дата Тогда
			//ВидРекламации=Перечисления.ВидыРекламаций.Вычерк 
			Сообщить("Не возможно создание Вычерка на основании документа Перемещение");
			мСозданиеНевозможно=Истина;
		КонецЕсли;
	КонецЕсли;
	//Нечаева 15,01,14  ---
	
	
	
	
	//Нечаева 03,07,14  +++
	Если ВидОснования="ПриходнаяНакладная" и основание.кодоперации<>перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда 
		Если КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) >= ДокОснование.Дата Тогда
			//ВидРекламации=Перечисления.ВидыРекламаций.Вычерк 
			Сообщить("Не возможно создание Вычерка на основании документа Приходная Накладная с типом не равным - Возврат от покупателя");
			мСозданиеНевозможно=Истина;
		иначе
			Сообщить("Не возможно создание КЦН в открытом периоде");
			мСозданиеНевозможно=Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОснования="ПриходнаяНакладная" и Докоснование.кодоперации=перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда 
		Если КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) < ДокОснование.Дата Тогда
			Сообщить("Не возможно создание КЦН в открытом периоде");
			мСозданиеНевозможно=Истина;
		КонецЕсли;
	КонецЕсли;
	//Нечаева 03,07,14  ---
	
	
	
	
	
	//
	//
	//Если КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) >= ДокОснование.Дата Тогда
	//	Сообщить("Корректировка проводится только для документов в закрытом периоде!");
	//	мСозданиеНевозможно=Истина;
	//КонецЕсли;
	
	
	ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");			
	Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");			
	Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");	
	ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	ТипЦенРаспродажа	= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦенРаспродажа");
	СкидкаФакт			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");
	ДопСкидкаНаНакладную = ПолучитьРеквизитОбъекта(ДокОснование,"ДопСкидкаНаНакладную"); 
	//++Данилова Е.В. 03.10.2025 HELP-7050 
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер); 
	Если НЕ ЗначениеЗаполнено(Подразделение)
		И ЕстьРеквизитДокумента("Подразделение",Докоснование.Метаданные()) Тогда
	
		Подразделение = ДокОснование.Подразделение; 	
	
	КонецЕсли;
	//--Данилова Е.В. 03.10.2025
	
	//менеджер, для отчета "продажи"
	Менеджер			= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	//крохин конец 29.01.2013
	
	Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");		
	
	Если ВидОснования="ПриходнаяНакладная" ИЛИ ВидОснования="РасходнаяНакладная" Тогда
		Корреспондент	= ДокОснование.Контрагент;		
		Склад			= ДокОснование.Склад;
		//крохин начало 06.03.2012
		ВидОплаты = ДокОснование.ВидОплаты;
		//крохин конец 06.03.2012
		//крохин начало 24.05.2012
		ДатаОплаты = Докоснование.ДатаОплаты;
		//крохин конец 24.05.2012
		
		//крохин начало 28.04.2020
		Договор = ДокОснование.Договор;
		//крохин конец 28.04.2020
	ИначеЕсли ВидОснования="Перемещение" Тогда
		Корреспондент	= ДокОснование.СкладПолучатель;
		Склад			= ДокОснование.Склад;
		// Катаев+ 19/03/13 
	ИначеЕсли Видоснования="АктПриемки"	 Тогда
		Корреспондент	= ДокОснование.Контрагент;		
		Склад			= ДокОснование.Склад;
		ДатаОплаты = ДокОснование.РНК.ДатаОплаты;
		//Катаев- 19/03/13
	Иначе
		Склад			= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");		
	КонецЕсли;	
	
	Если ВидОснования="ПриходнаяНакладная" И ДокОснование.КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР Тогда
		Поставщику=Истина;
		
		Для Каждого ИсхСтрокаТЧ ИЗ ДокОснование.Товары Цикл
			Если ИсхСтрокаТЧ.ПодтвержденнаяЗаявка<>ИсхСтрокаТЧ.Количество Тогда
				СтрокаТЧ=Товары.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,ИсхСтрокаТЧ,,"Количество");
				
				СтрокаТЧ.ЦенаИсх	=ИсхСтрокаТЧ.Цена;
				СтрокаТЧ.ЦенаФакт	=ИсхСтрокаТЧ.Цена;
				СтрокаТЧ.ЦенаФактБезСкидки	=ИсхСтрокаТЧ.ЦенаБезСкидки;
				СтрокаТЧ.СкидкаФакт	=ИсхСтрокаТЧ.Скидка;
				СтрокаТЧ.Цена		=СтрокаТЧ.ЦенаФакт-СтрокаТЧ.ЦенаИсх;				
				СтрокаТЧ.ЦенаБезСкидки=СтрокаТЧ.Цена;				
				
				РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);
			КонецЕсли; 			
		КонецЦикла;
	ИначеЕсли ВидОснования="Перемещение" Тогда
		Для Каждого ИсхСтрокаТЧ ИЗ ДокОснование.Товары Цикл
			Если ИсхСтрокаТЧ.ПодтвержденнаяЗаявка<>ИсхСтрокаТЧ.Количество Тогда
				СтрокаТЧ=Товары.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,ИсхСтрокаТЧ,,"Количество");
				
				СтрокаТЧ.ЦенаИсх	=ИсхСтрокаТЧ.Цена;
				СтрокаТЧ.ЦенаФактБезСкидки	=ИсхСтрокаТЧ.ЦенаБезСкидки;
				СтрокаТЧ.СкидкаФакт	=ИсхСтрокаТЧ.Скидка;
				СтрокаТЧ.ЦенаФакт	=ИсхСтрокаТЧ.Цена;
				СтрокаТЧ.Цена		=СтрокаТЧ.ЦенаИсх-СтрокаТЧ.ЦенаФакт;				
				СтрокаТЧ.ЦенаБезСкидки=СтрокаТЧ.Цена;				
				
				РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; 
	//02,07,14 +++ нечаева добавила ПНК
	Если ( ВидОснования="РасходнаяНакладная" или  ВидОснования="ПриходнаяНакладная") И КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) >= ДокОснование.Дата Тогда
		ВидРекламации = Перечисления.ВидыРекламаций.Вычерк;
	Иначе
		Отказ=истина;
		ВидРекламации =Перечисления.ВидыРекламаций.Рекламация;
	КонецЕсли;
	//02,07,14 --- нечаева добавила ПНК
	
	//крохин начало 05.05.2020
	//комиссионная торговля
	Если ВидОснования="РасходнаяНакладная" И  ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
	СкладКомиссия = ДокОснование.СкладКомиссия;
	//ДоговорКомиссия = ДокОснование.ДоговорКомиссия;
	КонецЕсли;
	//крохин конец 05.05.2020
	
	
КонецПроцедуры


