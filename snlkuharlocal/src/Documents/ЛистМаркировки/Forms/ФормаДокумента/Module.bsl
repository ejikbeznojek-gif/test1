&НаСервере
Функция ПовторитьПечатьПоследнегоQRНаСервере()
	// Вставить содержимое обработчика.
	если ЗначениеЗаполнено(ТекущаяМарка) тогда
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК КодЧЗ,
		|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода КАК ЗначениеКМ,
		|	ШтрихкодыУпаковокТоваров.Владелец.Цвет КАК Цвет,
		|	ШтрихкодыУпаковокТоваров.Владелец.Размер КАК Размер,
		|	ШтрихкодыУпаковокТоваров.Владелец.Родитель.КодПроизводителя КАК Артикул
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.Ссылка = &Ссылка";
		запрос.УстановитьПараметр("Ссылка",ТекущаяМарка);
		
		
		Выборка=запрос.Выполнить().Выбрать();
		пока Выборка.Следующий() цикл
			ТабДок=СформироватьQRКодЭтикетки (Выборка);
			возврат ТабДок;
		КонецЦикла;
		
		
	иначе
		Сообщить("Воспользуйтесь печатью выделенной строки.");
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПовторитьПечатьПоследнегоQR(Команда)
	ТабДок=ПовторитьПечатьПоследнегоQRНаСервере();
	если ТабДок<>Неопределено тогда
		
		// Смирнов М.Ю. 23.07.2025 HELP-4556 начало
		Если Команда.Имя = "ПовторитьПечатьПоследнегоQR" Тогда
			ТабДок.показать();
			Возврат;
		КонецЕсли;
		
		Если Команда.Имя = "ПовторитьПечатьПоследнегоQRНаПринтер" Тогда
			ТабДок.Напечатать();
			Возврат;
		КонецЕсли;
		// Смирнов М.Ю. 23.07.2025 HELP-4556 конец
		
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Функция ПовторитьПечатьВыделеннойСтрокиПечатиНаСервере(ТекШтихКод,Ошибки)
	// Вставить содержимое обработчика.
	если объект.ШтрихкодыУпаковок.НайтиСтроки(новый Структура("ШтрихкодУпаковки",ТекШтихКод)).количество() > 0 тогда
		Ошибки="Этот код ЧЗ уже отсканирован, возобновление работы  нужно.";
		возврат Неопределено;
	КонецЕсли;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК КодЧЗ,
	|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода КАК ЗначениеКМ,
	|	ШтрихкодыУпаковокТоваров.Владелец.Цвет КАК Цвет,
	|	ШтрихкодыУпаковокТоваров.Владелец.Размер КАК Размер,
	|	ШтрихкодыУпаковокТоваров.Владелец.Родитель.КодПроизводителя КАК Артикул
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Ссылка = &Ссылка";
	запрос.УстановитьПараметр("Ссылка",ТекШтихКод);
	
	
	Выборка=запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл
		ТабДок=СформироватьQRКодЭтикетки (Выборка);
		ТекущаяМарка=Выборка.кодЧЗ;
		ОжидаемыйВидШК="!!!!Код ЧЗ!!!!";	
		Возврат ТабДок;
	КонецЦикла;
	
	
	
КонецФункции

&НаКлиенте
Процедура ПовторитьПечатьВыделеннойСтрокиПечати(Команда)
	Ошибки="";
	ТекДанные=элементы.ШтрихкодыУпаковокРаспечатанная.ТекущиеДанные;
	ТабДок=ПовторитьПечатьВыделеннойСтрокиПечатиНаСервере(ТекДанные.ШтрихКодУпаковки,Ошибки);
	если ТабДок<>Неопределено тогда
		ТабДок.показать();
	КонецЕсли;
	если Ошибки<>"" тогда 
		Сообщить(Ошибки);
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьПоНапечатанномуНаСервере()
	для каждого СТрТЧ из объект.ШтрихкодыУпаковокРаспечатанная цикл
		МассивСтрок= объект.ШтрихкодыУпаковок.НайтиСтроки(новый Структура("ШтрихкодУпаковки",СТрТЧ.ШтрихкодУпаковки));
		если МассивСтрок.Количество() = 0  тогда
			СтрокаКода= объект.ШтрихкодыУпаковок.Добавить();
			СтрокаКода.ШтрихкодУпаковки=СТрТЧ.ШтрихкодУпаковки;
		КонецЕсли;
	КонецЦикла;// Вставить содержимое обработчика.
	
КонецПроцедуры


&НаКлиенте
Процедура ЗаполнитьПоНапечатанному(Команда)

	ЗаполнитьПоНапечатанномуНаСервере();
КонецПроцедуры


&НаКлиенте
Процедура Очистить(Команда)
ОчиститьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОчиститьНаСервере()
	если не РольДоступна("Администратор") тогда возврат;КонецЕсли;
	Объект.ШтрихкодыУпаковок.Очистить();
	объект.ШтрихкодыУпаковокРаспечатанная.Очистить();;
КонецПроцедуры
