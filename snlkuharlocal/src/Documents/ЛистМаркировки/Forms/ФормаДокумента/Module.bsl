&НаСервере
Функция ПечатьВыделеннойСтрокиНаСервере(МассивШк)
	// Андреев И.Д. 22.04.2025 начало
	ТД_Результат = Новый ТабличныйДокумент;
	
	Для каждого СтрМасс из МассивШк цикл 
		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК КодЧЗ,
		|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода КАК ЗначениеКМ,
		|	ШтрихкодыУпаковокТоваров.Владелец.Цвет КАК Цвет,
		|	ШтрихкодыУпаковокТоваров.Владелец.Размер КАК Размер,
		|	ШтрихкодыУпаковокТоваров.Владелец.Родитель.КодПроизводителя КАК Артикул
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.Ссылка = &Ссылка";
		запрос.УстановитьПараметр("Ссылка",СтрМасс);
		
		
		Выборка=запрос.Выполнить().Выбрать();
		
		
		// Андреев 24.04.2025 начало	
		пока Выборка.Следующий() цикл
			ТабДок=СформироватьQRКодЭтикетки (Выборка,ТД_Результат);	
		КонецЦикла;  
		// Андреев 24.04.2025 конец
		
	Конеццикла;
	
	
	Возврат ТабДок;
КонецФункции

&НаКлиенте
Процедура ПечатьВыделеннойСтроки(Команда)  
		
	// Андреев И.Д. 22.04.2025 начало	
	ТекДанные = элементы.штрихкодыупаковок.выделенныеСтроки;
	МассивШк = новый Массив;     
	
	СписокЗначений = новый СписокЗначений;
	
	Для каждого СтрМасс из ТекДанные цикл
		СписокЗначений.Добавить(СтрМасс);
	Конеццикла; 
	
	СписокЗначений.СортироватьПоЗначению(НаправлениеСортировки.Возр);
	
	Для каждого СтрМасс из СписокЗначений цикл
		МассивШк.Добавить(элементы.штрихкодыупаковок.ДанныеСтроки(СтрМасс.Значение).штрихкодупаковки);	
	Конеццикла; 
		
	ТабДок = ПечатьВыделеннойСтрокиНаСервере(МассивШк);   
	// Андреев И.Д. 22.04.2025 конец
	
	если ТабДок<>Неопределено тогда
		
		// Смирнов М.Ю. 23.07.2025 HELP-4556 начало
		Если Команда.Имя = "ПечатьВыделенныхСтрок" Тогда
			ТабДок.показать();
			Возврат;
		КонецЕсли;
		
		Если Команда.Имя = "ПечатьВыделенныхСтрокНаПринтер" Тогда 
			ТабДок.Напечатать();
			Возврат;
		КонецЕсли;
		// Смирнов М.Ю. 23.07.2025 HELP-4556 конец
		
	КонецЕсли;	
	
КонецПроцедуры


