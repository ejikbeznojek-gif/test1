Процедура ВнешнееСобытие(Источник, Событие, Данные)
	// Кухарь А.Ю.  03.07.2024 начало
	//
	если ТолькоПросмотр тогда
		Возврат;
	КонецЕсли;
	
	// Кухарь А.Ю.  03.07.2024 конец
	
	Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	
	Если НЕ ВводДоступен() и Источник<>"ИмитацияСканирования" Тогда Возврат КонецЕсли; //кухарь 16.12.13 Имитация
	

	// Кухарь А.Ю. 17.03.2025 начало
	// Пустая задача
	//Данные=СтрЗаменить(Данные,Символы.ПС,"");		
	//данные=Лев(Данные,31); 	
	ПолныеДанные=СтрЗаменить(Данные,Символы.ПС,"");		
	данные=Лев(ПолныеДанные,31); 	
	// Кухарь А.Ю. 17.03.2025 конец
	
	
	
	глТорговоеОборудование.СканерПосылкаДанных(1);
	глСобытиеСканераОтработано=Истина;
	
	
	РезультатСканирования=ВнешнееСобытиеНаСервере(Данные);
	если не РезультатСканирования.Успех тогда
		// Кухарь А.Ю.  04.04.2025 начало
		
		//Сообщить(РезультатСканирования.Ошибки);
		если ТипЗнч(РезультатСканирования.Ошибки)=Тип("Массив") тогда		
			Сообщить(СтрСоединить(РезультатСканирования.Ошибки,Символы.ПС));
		иначе
			Сообщить(РезультатСканирования.Ошибки);
		КонецЕсли;
		// Кухарь А.Ю.  04.04.2025 конец
		
		Возврат;
	иначе
		
		// Кухарь А.Ю. 17.03.2025 начало
		// ASU-2105
		//Теперь всегда обычный ШК
		//если ОжидаемыйВидШК="Обычный штрих-код"  тогда
		//	ОжидаемыйВидШК="!!!!Код ЧЗ!!!!";
		//иначе
		//	ОжидаемыйВидШК="Обычный штрих-код";
		//КонецЕсли;
		если ЗначениеЗаполнено(ТекущаяМарка) тогда
			СтрокаКМ = СокрЛП(Справочники.ШтрихкодыУпаковокТоваров.ВосстановитьКод_GS1(ТекущаяМарка.ЗначениеШтрихкода));
			ОповеститьОВыборе(СтрокаКМ); 
		КонецЕсли;
		// Кухарь А.Ю. 17.03.2025 конец
		
	КонецЕсли;	
	
	ТабДок = РезультатСканирования.ТабДок;	
	
	Если ТабДок<>Неопределено Тогда
		//+++Чирков 24.04.2025
		//если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр И НЕ фПечататьЛентуСразуНаПинтер тогда		
		Если НЕ фПечататьЛентуСразуНаПинтер Тогда
		//---Чирков 24.04.2025
			ТабДок.Показать();
		Иначе
			Попытка 
				ТабДок.Напечатать()
			Исключение
				ТабДок.Показать();
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;	

