						СтрокаТЧ.Всего = СтрокаТЧ.ВесНетто * СтрокаТЧ.НормативУтилизации * СтрокаТЧ.СтавкаЭкологическогоСбора;
						
					КонецЕсли;	
				КонецЦикла;
				
				ПеречитатьОбласти = Ложь;
				
			ИначеЕсли ВариантЗагрузки = 2 Тогда
				
				НомерПервойСтроки = 21;
				НомерПервойКолонки = 2;
				
				ИсточникДанных = ЧитаемаяОбласть.Область(НомерПервойСтроки, НомерПервойКолонки, ЧитаемаяОбласть.ВысотаТаблицы, ЧитаемаяОбласть.ШиринаТаблицы);
				ТЗ_Экологический = Документы.ДопДанныеГТДкМашине.ПрочитатьТабличныйДокументВТаблицуЗначений(ИсточникДанных);
				
				КодТНВЭД = СокрЛП(ТЗ_Экологический[0]["Номер_12"]);
				
				ТНВЭД = Справочники.ТНВЭД.НайтиПоКоду(КодТНВЭД);
				
				Для Каждого Стр ИЗ ТЗ_Экологический Цикл
					Если НЕ ПустаяСтрока(Стр["Номер_"]) Тогда
						
						СтрокаТЧ = ДанныеГТДУпаковки.Добавить();
						
						СтрокаТЧ.ТНВЭД = ТНВЭД;
						
						СтрокаТЧ.ТНВЭДНоменклатуры = Справочники.ТНВЭД.НайтиПоКоду(СокрЛП(Стр["Номер_"]));
						
						СтрокаТЧ.Количество = ?(Стр["Номер_5"] = "/", 0, Стр["Номер_5"]);
						СтрокаТЧ.ВесНетто = ?(Стр["Номер_6"] = "/", 0, Стр["Номер_6"]);    // ???
						СтрокаТЧ.ВесБрутто = ?(Стр["Номер_12"] = "/", 0, Стр["Номер_12"]);
						
