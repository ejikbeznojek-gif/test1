						СтрокаТЧ.НормативУтилизации = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "НормативУтилизации", КонецДня(ДокОбъект.Дата));
						Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НормативУтилизации) Тогда
							СтрокаТЧ.НормативУтилизации = СтрокаТЧ.ТНВЭД.НормативУтилизации;	
						КонецЕсли;
						
						СтрокаТЧ.СтавкаЭкологическогоСбора = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "СтавкаЭкологическогоСбора", КонецДня(ДокОбъект.Дата));
						Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СтавкаЭкологическогоСбора) Тогда
							СтрокаТЧ.СтавкаЭкологическогоСбора = СтрокаТЧ.ТНВЭД.СтавкаЭкологическогоСбора;	
						КонецЕсли;
						
						СтрокаТЧ.Всего = СтрокаТЧ.ВесНетто * СтрокаТЧ.НормативУтилизации * СтрокаТЧ.СтавкаЭкологическогоСбора;
						
					КонецЕсли;	
				КонецЦикла;
				
				ПеречитатьОбласти = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	// Перечитаем Области, дозаполним ДанныеГТДУпаковки
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	Если ПеречитатьОбласти Тогда
		
		Для Каждого Область Из ТабличныйДокумент.Области Цикл
		
			ЧитаемаяОбласть = ТабличныйДокумент.ПолучитьОбласть(Область.Имя);
			
			Если Область.Имя = "Инвойс" Тогда
				
				НомерПервойСтроки = 13;
				НомерПервойКолонки = 1;
			
   	   			ИсточникДанных = ЧитаемаяОбласть.Область(НомерПервойСтроки, НомерПервойКолонки, ЧитаемаяОбласть.ВысотаТаблицы, ЧитаемаяОбласть.ШиринаТаблицы);
				ТЗ_Инвойс = Документы.ДопДанныеГТДкМашине.ПрочитатьТабличныйДокументВТаблицуЗначений(ИсточникДанных);
				
				Для Каждого Стр ИЗ ТЗ_Инвойс Цикл
				
					НайденныеСтроки = ДанныеГТДУпаковки.НайтиСтроки(Новый Структура("Артикул", СокрЛП(Стр["Номер_"])));
					
					Для Каждого НСтрока ИЗ НайденныеСтроки Цикл
						
						НСтрока.ТНВЭДНоменклатуры = Справочники.ТНВЭД.НайтиПоКоду(СокрЛП(Стр["Номер_2"]));
						
						Если ТипЗнч(Стр["Номер_6"]) = Тип("Число") Тогда
							НСтрока.ТаможеннаяСтоимость = НСтрока.Количество * Стр["Номер_6"];
						Иначе
							НСтрока.ТаможеннаяСтоимость = НСтрока.Количество * Стр["Номер_7"];	
						КонецЕсли;
						
					КонецЦикла;
				
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	// Удалим пустые строки в ТЗ ДанныеГТДУпаковки
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	СтрокиДляУдаления = Новый Массив;

	Для Каждого СтрокаТЧ Из ДанныеГТДУпаковки Цикл
	
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТНВЭДНоменклатуры) И НЕ ЗначениеЗаполнено(СтрокаТЧ.Количество) Тогда
			СтрокиДляУдаления.Добавить(СтрокаТЧ);
		КонецЕсли;
	
	КонецЦикла;

	Для Каждого СтрокаТЧ Из СтрокиДляУдаления Цикл
		ДанныеГТДУпаковки.Удалить(СтрокаТЧ);
	КонецЦикла;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	// Удалим временные файлы
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	Попытка
   		УдалитьФайлы(ИмяВременногоФайла);
	Исключение
   		ЗаписьЖурналаРегистрации(НСтр("ru = 'Удаление временного файла'"), УровеньЖурналаРегистрации.Предупреждение, , , ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат ДанныеГТДУпаковки;
	
КонецФункции

&НаСервере
Функция ПолучитьТаблицуЗначений(ИсточникДанных) Экспорт
	
	ПостроительЗапроса = Новый ПостроительЗапроса;
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(ИсточникДанных);
	ПостроительЗапроса.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
	ПостроительЗапроса.ЗаполнитьНастройки();
	ПостроительЗапроса.Выполнить();
			
	Возврат ПостроительЗапроса.Результат.Выгрузить();
	
КонецФункции

&НаСервере
Функция ПрочитатьТабличныйДокументВТаблицуЗначений(ИсточникДанных) Экспорт
	
	ПостроительЗапроса = Новый ПостроительЗапроса;
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(ИсточникДанных);
	ПостроительЗапроса.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
	ПостроительЗапроса.Выполнить();
	
	ТЗРезультат = ПостроительЗапроса.Результат.Выгрузить();
	
	КоличествоСтолбцов = ТЗРезультат.Колонки.Количество()-1;
	
	Если КоличествоСтолбцов = 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Для НомерСтолбца = 0 По КоличествоСтолбцов Цикл
		ТЗРезультат.Колонки[НомерСтолбца].Имя = "Номер_" + Формат(НомерСтолбца,"ЧГ=0");
		ТЗРезультат.Колонки[НомерСтолбца].Заголовок = "Номер_" + Формат(НомерСтолбца,"ЧГ=0");
	КонецЦикла;
	
	Возврат ТЗРезультат;
	
КонецФункции

