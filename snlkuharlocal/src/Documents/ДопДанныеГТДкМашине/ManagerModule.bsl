
#Область ЗагрузкаИзXML

// Возвращает Таблицу значений из загруженного файла
Функция ЗагрузитьИзФайлаXMLНаСервере(ДокОбъект, АдресВременногоХранилища, Расширение) Экспорт
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	Поток = ДвоичныеДанные.ОткрытьПотокДляЧтения();
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьПоток(Поток,,,);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);	
	ЧтениеXML.Закрыть();
	
	Разыменователь = Новый РазыменовательПространствИменDOM(ДокументDOM);
	
	ПервыйПараметрПроверки = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("REGNUM",ДокументDOM,Разыменователь));
	ВторойПараметрПроверки = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_16_1",ДокументDOM,Разыменователь));
	
	Если ПервыйПараметрПроверки <> Неопределено И ВторойПараметрПроверки <> Неопределено Тогда 
		Возврат ПервыйТипXML(ДокОбъект, ДокументDOM,Разыменователь);	
	Иначе 
		ПервыйПараметрПроверки = ДокументDOM.ПолучитьЭлементыПоИмени("cat_ru:PrDocumentNumber");
		ВторойПараметрПроверки = ДокументDOM.ПолучитьЭлементыПоИмени("RUScat_ru:CounryName");
		
		Если ПервыйПараметрПроверки.Количество() > 0 и ВторойПараметрПроверки.Количество() > 0 Тогда 
			Возврат ВторойТипXML(ДокОбъект, ДокументDOM,Разыменователь);			
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначениеУзлаXPath(РезультатXPath, ТипРезультата = Неопределено)
	Если РезультатXPath <> Неопределено Тогда
		Узел = РезультатXPath.ПолучитьСледующий();
		Если Узел <> Неопределено Тогда
			ТекстУзла = Узел.ТекстовоеСодержимое;
			Если ТипРезультата = Неопределено Тогда
				Возврат ТекстУзла;
			Иначе
				Возврат XMLЗначение(ТипРезультата,ТекстУзла);		
			КонецЕсли;		
		КонецЕсли;		
	КонецЕсли; 
	
	Возврат Неопределено;
КонецФункции

Функция ПервыйТипXML(ДокОбъект, ДокументDOM, Разыменователь)
	
	// G_31_8 = Количество, G_33_1 = ТНВЭД, G_35_1 = Вес Брутто, G_38_1 = Вес Нетто, G_42_1 = Таможенная Стоимость
	// G_38_2 = Вес Нетто без Упаковки
	
	ДанныеГТД = Новый ТаблицаЗначений;
	ДанныеГТД.Колонки.Добавить("ГТД", Новый ОписаниеТипов("СправочникСсылка.ГТД"));
	ДанныеГТД.Колонки.Добавить("ТНВЭД", Новый ОписаниеТипов("СправочникСсылка.ТНВЭД"));
	ДанныеГТД.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ТаможеннаяСтоимость", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесНетто", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесНеттоБезУпаковки", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесБрутто", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("НормативУтилизации", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("СтавкаЭкологическогоСбора", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("Всего", Новый ОписаниеТипов("Число"));
	
	НомерГТДСтрокой = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("REGNUM",ДокументDOM,Разыменователь));
	СтранаСтрокой = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_16_1",ДокументDOM,Разыменователь));
	
	ГТД = НайтиСоздатьГТД(НомерГТДСтрокой, , СтранаСтрокой);
	
	ДанныеГТД.Очистить();	
	
	РазделыDOM = ДокументDOM.ПолучитьЭлементыПоИмени("BLOCK");
	
	Для Каждого РазделDOM Из РазделыDOM Цикл
		
		СтрокаТЧ = ДанныеГТД.Добавить();
		
		СтрокаТЧ.ГТД = ГТД;
		
		СтрокаТЧ.ТНВЭД = Справочники.ТНВЭД.НайтиПоКоду(ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_33_1",РазделDOM, Разыменователь)));		
		
		СтрокаТЧ.Количество = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_31_8", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ТаможеннаяСтоимость = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_42_1", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ВесНетто = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_38_1", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ВесНеттоБезУпаковки = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_38_2", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ВесБрутто = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("G_35_1", РазделDOM, Разыменователь));
		
		СтрокаТЧ.НормативУтилизации = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "НормативУтилизации", КонецДня(ДокОбъект.Дата));
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НормативУтилизации) Тогда
			СтрокаТЧ.НормативУтилизации = СтрокаТЧ.ТНВЭД.НормативУтилизации;	
		КонецЕсли;
		
		СтрокаТЧ.СтавкаЭкологическогоСбора = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "СтавкаЭкологическогоСбора", КонецДня(ДокОбъект.Дата));
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СтавкаЭкологическогоСбора) Тогда
			СтрокаТЧ.СтавкаЭкологическогоСбора = СтрокаТЧ.ТНВЭД.СтавкаЭкологическогоСбора;	
		КонецЕсли;
		
		СтрокаТЧ.Всего = СтрокаТЧ.ВесНетто * СтрокаТЧ.НормативУтилизации * СтрокаТЧ.СтавкаЭкологическогоСбора;
		
	КонецЦикла;
	
	Возврат ДанныеГТД;
	
КонецФункции

Функция ВторойТипXML(ДокОбъект, ДокументDOM, Разыменователь)
	
	// catESAD_cu:GrossWeightQuantity = Вес Брутто
	// catESAD_cu:NetWeightQuantity = Вес Нетто
	// catESAD_cu:GoodsTNVEDCode = ТНВЭД
	// catESAD_cu:GoodsQuantity = Количество
	// catESAD_cu:InvoicedCost = Таможенная Стоимость
	
	// catESAD_cu:NetWeightQuantity2 = Вес Нетто без Упаковки
	
	ДанныеГТД = Новый ТаблицаЗначений;
	ДанныеГТД.Колонки.Добавить("ГТД", Новый ОписаниеТипов("СправочникСсылка.ГТД"));
	ДанныеГТД.Колонки.Добавить("ТНВЭД", Новый ОписаниеТипов("СправочникСсылка.ТНВЭД"));
	ДанныеГТД.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ТаможеннаяСтоимость", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесНетто", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесНеттоБезУпаковки", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("ВесБрутто", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("НормативУтилизации", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("СтавкаЭкологическогоСбора", Новый ОписаниеТипов("Число"));
	ДанныеГТД.Колонки.Добавить("Всего", Новый ОписаниеТипов("Число"));
	
	ГТД = Неопределено;
	
	Если СтрДлина(ДокументDOM.ПолучитьЭлементыПоИмени("ED_Container").Элемент(0).СледующийСоседний.ТекстовоеСодержимое)=26	Тогда
		НомерГТДСтр = Прав(ДокументDOM.ПолучитьЭлементыПоИмени("ED_Container").Элемент(0).СледующийСоседний.ТекстовоеСодержимое,23);
		СтранаШапка	= ДокументDOM.ПолучитьЭлементыПоИмени("RUScat_ru:CounryName").элемент(0).ТекстовоеСодержимое;
		ГТД	= НайтиСоздатьГТД(НомерГТДСтр,,СтранаШапка);
	КонецЕсли;
	
	ДанныеГТД.Очистить();
	
	РазделыDOM = ДокументDOM.ПолучитьЭлементыПоИмени("ESADout_CUGoods");
	
	Для Каждого РазделDOM Из РазделыDOM Цикл
		
		СтрокаТЧ = ДанныеГТД.Добавить();
		
		СтрокаТЧ.ГТД = ГТД;
		
		СтрокаТЧ.ТНВЭД = Справочники.ТНВЭД.НайтиПоКоду(ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("catESAD_cu:GoodsTNVEDCode", РазделDOM, Разыменователь)));
		
		СтрокаТЧ.ВесБрутто = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("catESAD_cu:GrossWeightQuantity", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ВесНетто = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("catESAD_cu:NetWeightQuantity", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ВесНеттоБезУпаковки = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("catESAD_cu:NetWeightQuantity2", РазделDOM, Разыменователь));
		
		СтрокаТЧ.ТаможеннаяСтоимость = ПолучитьЗначениеУзлаXPath(ДокументDOM.ВычислитьВыражениеXPath("catESAD_cu:InvoicedCost", РазделDOM, Разыменователь));
		
		СтрокаТЧ.НормативУтилизации = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "НормативУтилизации", КонецДня(ДокОбъект.Дата));
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НормативУтилизации) Тогда
			СтрокаТЧ.НормативУтилизации = СтрокаТЧ.ТНВЭД.НормативУтилизации;	
		КонецЕсли;
		
		СтрокаТЧ.СтавкаЭкологическогоСбора = ПолучитьПериодическийРеквизит(СтрокаТЧ.ТНВЭД, "СтавкаЭкологическогоСбора", КонецДня(ДокОбъект.Дата));
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СтавкаЭкологическогоСбора) Тогда
			СтрокаТЧ.СтавкаЭкологическогоСбора = СтрокаТЧ.ТНВЭД.СтавкаЭкологическогоСбора;	
		КонецЕсли;
		
		ТоварыDOM = РазделDOM.ПолучитьЭлементыПоИмени(РазделDOM.URIПространстваИмен,"catESAD_cu:GoodsGroupDescription");
		
		ВсегоКоличествоПоТоварам = 0;
		
		Для Каждого ТоварDOM Из ТоварыDOM Цикл	
			
			Для Каждого Товары из ТоварDOM.ДочерниеУзлы Цикл
				
				Если Товары.ИмяУзла = "catESAD_cu:GoodsGroupInformation" Тогда
					
					Для Каждого ДочернийУзелОписанияТоваров Из Товары.ДочерниеУзлы цикл
						
						Если ДочернийУзелОписанияТоваров.ИмяУзла = "catESAD_cu:GoodsGroupQuantity" Тогда	
							Для Каждого УзелКоличества из ДочернийУзелОписанияТоваров.ДочерниеУзлы Цикл
								Если  УзелКоличества.ИмяУзла = "catESAD_cu:GoodsQuantity" Тогда
									Количество = УзелКоличества.ТекстовоеСодержимое;
									ВсегоКоличествоПоТоварам = ВсегоКоличествоПоТоварам + Количество;
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		СтрокаТЧ.Количество = ВсегоКоличествоПоТоварам;
		
		СтрокаТЧ.Всего = СтрокаТЧ.ВесНетто * СтрокаТЧ.НормативУтилизации * СтрокаТЧ.СтавкаЭкологическогоСбора;
		
	КонецЦикла;
	
	Возврат ДанныеГТД;
	
КонецФункции

Функция НайтиСоздатьГТД(НомерГТДСтр, НомерРаздела = Неопределено, Страна = "")
	
	Запрос=Новый Запрос("
	|ВЫБРАТЬ ПЕРВЫЕ 1 
	|	Ссылка
	|ИЗ 
	|	Справочник.ГТД 
	|ГДЕ 
	|	Наименование=&Наименование 
	|	И "+?(ЗначениеЗаполнено(НомерРаздела),"НЕ","")+" ЭтоГруппа
	|");
	
	Наименование=""+НомерГТДСтр+?(ЗначениеЗаполнено(НомерРаздела),"/"+НомерРаздела,"");
	Запрос.УстановитьПараметр("Наименование",СокрЛП(Наименование));
	
	Выборка=Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Если ЗначениеЗаполнено(НомерРаздела) Тогда
			мНомерГТД=Справочники.ГТД.СоздатьЭлемент();
			
			Если ЗначениеЗаполнено(Страна) Тогда
				мНомерГТД.СтранаПроисхождения = Справочники.КлассификаторСтранМира.НайтиПоНаименованию(Страна);					
			КонецЕсли;
			Если мНомерГТД.СтранаПроисхождения.Пустая() Тогда
				Сообщить("Не возможно создать ГТД. Не указана или не найдена страна !",СтатусСообщения.Важное);
				Возврат Справочники.ГТД.ПустаяСсылка();			
			КонецЕсли;							
			//мНомерГТД.Родитель = НомерГТДСтр;
		Иначе			
			мНомерГТД=Справочники.ГТД.СоздатьГруппу();					
		КонецЕсли;
		
		мНомерГТД.Владелец = Справочники.ИБ.НайтиПоКоду("SSP");
		мНомерГТД.Наименование = СокрЛП(Наименование);
		мНомерГТД.Записать();
		
		Возврат мНомерГТД.Ссылка;
	КонецЕсли;	
	
КонецФункции

#КонецОбласти

#Область ЗагрузкаИзЭксель

Функция ЗагрузитьИзФайлаЭксельНаСервере(ДокОбъект, АдресВременногоХранилища, Расширение) Экспорт
	
	ДанныеГТДУпаковки = Новый ТаблицаЗначений;
	ДанныеГТДУпаковки.Колонки.Добавить("ГТД", Новый ОписаниеТипов("СправочникСсылка.ГТД"));
	ДанныеГТДУпаковки.Колонки.Добавить("ТНВЭД", Новый ОписаниеТипов("СправочникСсылка.ТНВЭД"));
	ДанныеГТДУпаковки.Колонки.Добавить("ТНВЭДНоменклатуры", Новый ОписаниеТипов("СправочникСсылка.ТНВЭД"));
	ДанныеГТДУпаковки.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("ТаможеннаяСтоимость", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("ВесНетто", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("ВесНеттоБезУпаковки", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("ВесБрутто", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("НормативУтилизации", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("СтавкаЭкологическогоСбора", Новый ОписаниеТипов("Число"));
	ДанныеГТДУпаковки.Колонки.Добавить("Всего", Новый ОписаниеТипов("Число"));
	
	ДанныеГТДУпаковки.Колонки.Добавить("Артикул", Новый ОписаниеТипов("Строка"));
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Расширение);
	ДвоичныеДанные.Записать(ИмяВременногоФайла);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Попытка
		ТабличныйДокумент.Прочитать(ИмяВременногоФайла, СпособЧтенияЗначенийТабличногоДокумента.Значение);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки();
		Сообщение.Сообщить();
		Возврат ДанныеГТДУпаковки;
	КонецПопытки;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	// Сформируем ДанныеГТДУпаковки (оба Варианта)
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	ПеречитатьОбласти = Ложь;  ВариантЗагрузки = 1; // "Упаковочный"
	
	Если ТабличныйДокумент.Области.Найти("Упаковочный") = Неопределено Тогда
		ВариантЗагрузки = 2;	
	КонецЕсли;
	
	Для Каждого Область Из ТабличныйДокумент.Области Цикл
		
		ЧитаемаяОбласть = ТабличныйДокумент.ПолучитьОбласть(Область.Имя);
		
		Если Область.Имя = "ПереводЛиста" Тогда  // "Перевод"
			
			НомерПервойСтроки = 21;
			НомерПервойКолонки = 1;
			
   	   		ИсточникДанных = ЧитаемаяОбласть.Область(НомерПервойСтроки, НомерПервойКолонки, ЧитаемаяОбласть.ВысотаТаблицы, ЧитаемаяОбласть.ШиринаТаблицы);
