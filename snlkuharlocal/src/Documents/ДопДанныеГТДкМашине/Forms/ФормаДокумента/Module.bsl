#Область ЗагрузкаИзXML

&НаКлиенте
Процедура ЗагрузитьИзXML(Команда)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл XML";
	Диалог.ПолноеИмяФайла = ""; 
	Фильтр = "Файл xml (*.xml)|*.xml"; 
	Диалог.Фильтр = Фильтр; 
	Диалог.МножественныйВыбор = Ложь;	
	Диалог.Показать(Новый ОписаниеОповещения("ЗагрузитьФайлЗавершение", ЭтаФорма, Новый Структура("Диалог", Диалог)));
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Диалог = ДополнительныеПараметры.Диалог; 
	
	Если ВыбранныеФайлы <> Неопределено Тогда				
		
		АдресВременногоХранилища = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Диалог.ПолноеИмяФайла));		
		ЗагрузитьИзXMLНаСервере(АдресВременногоХранилища, "xml");
				
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзXMLНаСервере(АдресВременногоХранилища, Расширение)
	
	тзДанныеГТД = Документы.ДопДанныеГТДкМашине.ЗагрузитьИзФайлаXMLНаСервере(ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.ДопДанныеГТДкМашине")),
		АдресВременногоХранилища, Расширение);
		
	Если тзДанныеГТД.Количество() > 0 Тогда	
		Объект.ДанныеГТД.Загрузить(тзДанныеГТД);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаИзЭксель

&НаКлиенте
Процедура ЗагрузитьВариант1(Команда)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл XML";
	Диалог.ПолноеИмяФайла = ""; 
	Фильтр = "Файл Эксель 2007 (*.xlsx)|*.xlsx| Файл Эксель 2003 (*.xls)|*.xls"; 
	Диалог.Фильтр = Фильтр; 
	Диалог.МножественныйВыбор = Ложь;	
	Диалог.Показать(Новый ОписаниеОповещения("ЗагрузитьФайлВариант1_Завершение", ЭтаФорма, Новый Структура("Диалог", Диалог)));

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлВариант1_Завершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Диалог = ДополнительныеПараметры.Диалог;
	Индекс = Диалог.ИндексФильтра;
	
	Если Индекс = 0 Тогда
		РасширениеФайла = "xlsx";
	ИначеЕсли Индекс = 1 Тогда
		РасширениеФайла = "xls";
	КонецЕсли;
	
	Если ВыбранныеФайлы <> Неопределено Тогда				
		
		АдресВременногоХранилища = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Диалог.ПолноеИмяФайла));		
		ЗагрузитьИзЭксельНаСервере(АдресВременногоХранилища, РасширениеФайла);
				
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзЭксельНаСервере(АдресВременногоХранилища, Расширение)
	
	тзДанныеГТДУпаковки = Документы.ДопДанныеГТДкМашине.ЗагрузитьИзФайлаЭксельНаСервере(ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.ДопДанныеГТДкМашине")),
		АдресВременногоХранилища, Расширение);
		
	Если тзДанныеГТДУпаковки.Количество() > 0 Тогда 
		Объект.ДанныеГТДУпаковки.Загрузить(тзДанныеГТДУпаковки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

////////// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ //////////////////////////////////////////////////////////

&НаКлиенте
Процедура ДокОснованиеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		ЭтаФорма.ДокСсылка = ЗаполнениеДокументов.НайтиПодчиненныйДокумент(ВыбранноеЗначение, "ДопДанныеГТДкМашине", Ложь, Истина);
		
		Если НЕ ЭтаФорма.ДокСсылка.Пустая() И ВыбранноеЗначение <> Объект.ДокОснование Тогда
			Объект.ДокОснование = Неопределено;
			ВызватьИсключение "Уже существует подчиненный документ к этому Основанию!!!";
		Иначе
			Объект.ДокОснование = ВыбранноеЗначение;
		КонецЕсли;
		
		ЗаполнитьНаСервере(Объект.ДокОснование);
		ЭтаФорма.ОбновитьОтображениеДанных();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеПриИзменении(Элемент)
	
	ТекДанные = Элементы.ДанныеГТД.ТекущиеДанные;
	
	Если ТекДанные <> Неопределено Тогда
		
		ТекДанные.Всего = ТекДанные.ВесНетто * ТекДанные.НормативУтилизации * ТекДанные.СтавкаЭкологическогоСбора; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере(ДокОснование)
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Заполнить(ДокОснование);
	ЗаполнитьЗначенияСвойств(Объект, ДокументОбъект, "Дата, Комментарий");
	ЗначениеВРеквизитФормы(ДокументОбъект.ДанныеГТД, "Объект.ДанныеГТД");
	
КонецПроцедуры

