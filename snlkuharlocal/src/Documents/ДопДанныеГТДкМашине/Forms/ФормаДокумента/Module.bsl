
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Основание <> Неопределено И ТипЗнч(Параметры.Основание) <> Тип("Массив") Тогда
		ЭтаФорма.ДокСсылка = ЗаполнениеДокументов.НайтиПодчиненныйДокумент(Параметры.Основание, "ДопДанныеГТДкМашине", Ложь, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если НЕ ЭтаФорма.ДокСсылка.Пустая() Тогда
		ОткрытьЗначение(ЭтаФорма.ДокСсылка);
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

