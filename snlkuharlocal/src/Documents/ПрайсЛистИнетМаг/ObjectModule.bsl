	Для Каждого ТСтр Из ТЗЦен Цикл
		ТНоменклатура=ТСтр.Номенклатура;
		
		Если ТСтр.Расчет Тогда
			Если НЕ МасНом.Найти(ТНоменклатура)=неопределено Тогда
				Продолжить;
			КонецЕсли;
			НовЗап=Набор1.Добавить();
			НовЗап.ТипЦен=ИнетМагазин;
			НовЗап.Прайс=Ссылка;
			НовЗап.Номенклатура=ТНоменклатура;
			НовЗап.Период=Дата;
			НовЗап.Модель=ТСтр.Группа;
			НовЗап.Брэнд=ТСтр.Группа.Родитель;
			НовЗап.ТипТовара=ТСтр.Группа.Родитель.Родитель;
			//Если Акция Тогда
			НовЗап.ИДРесурс=ТСтр.ИДСайт;
			НовЗап.Цена=ТСтр.ЦенаВыгр;
			НовЗап.ЦенаСтр=Формат(ТСтр.ЦенаВыгр,"ЧДЦ=0; ЧГ=0");
			НовЗап.Скидка=ТСтр.Скидка;
			НовЗап.Промо=ТСтр.Промо;
			НовЗап.ЦенаИтог=ТСтр.ЦенаПлан;
			//НовЗап.ИнетМаг=ИнетМагазин;
			НовЗап.ДатаОкончания=Дата2;
				
			//	НовЗап.Промо=ТСтр.Промо;
			//	НовЗап.ЦенаИтог=ТСтр.ЦенаИтог;
			//КонецЕсли;
			МасНом.Добавить(ТНоменклатура);
		КонецЕсли;
	КонецЦикла;	
	Набор1.Записать();
	ТСтат=ПолучитьСтатус();
	Попытка
		Если ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.Статус) Тогда
			ТСтат=ЭтотОбъект.ДополнительныеСвойства.Статус;
		КонецЕсли;	
	Исключение
	КонецПопытки;
	
	//Попытка
	//	//ДокПЛ=Документы.ПрайсЛист.СоздатьДокумент();
	//	//ДокПЛ.Дата=Дата;
	//	//ДокПЛ.ТипЦен=ТипЦен;
	//	//ДокПЛ.УровеньДоступа=ТипЦен.УровеньДоступа;
	//	//ДокПЛ.Организация = Справочники.Организации.НайтиПоКоду("SS-001");
	//	//
	//	//ДокПЛ.ИБ = Справочники.ИБ.НайтиПоКоду("SMN");
