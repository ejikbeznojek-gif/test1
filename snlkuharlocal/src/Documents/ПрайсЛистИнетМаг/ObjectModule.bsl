Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	// Вставить содержимое обработчика.
	Набор1=РегистрыСведений.ЦеныНоменклатурыИнетМаг.СоздатьНаборЗаписей();
	Набор1.Отбор.ТипЦен.Установить(ИнетМагазин);
	Набор1.Отбор.Прайс.Установить(Ссылка);
	//Если Акция Тогда
	ТЗЦен=Товары1.Выгрузить();
	//Иначе
	//	ТЗЦен=Товары.Выгрузить();
	//КонецЕсли;
