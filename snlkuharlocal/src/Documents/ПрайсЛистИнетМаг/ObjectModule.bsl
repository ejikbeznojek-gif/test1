	//			Если НЕ МасНом.Найти(ТНоменклатура)=неопределено Тогда
	//				Продолжить;
	//			КонецЕсли;
	//			
	//			НовЗап=Набор2.Добавить();
	//			НовЗап.ТипЦен=ДокПЛСсыл.ТипЦен;
	//			НовЗап.Прайс=ДокПЛ.Ссылка;
	//			НовЗап.Номенклатура=ТНоменклатура;
	//			НовЗап.Брэнд=ТСтр.Группа;
	//			НовЗап.Период=Дата;
