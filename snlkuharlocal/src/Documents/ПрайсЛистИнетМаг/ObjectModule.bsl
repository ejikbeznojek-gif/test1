	//КонецПопытки;
	
	
	Если (ТСтат=Перечисления.СтатусПрайсМаркетПлейс.ГотовКВыгрузке) Тогда	
		
		МенЗап=РегистрыСведений.ИнетПрайсыКВыгрузке.СоздатьМенеджерЗаписи();
		МенЗап.Статус=ТСтат;
		МенЗап.Прайс=Ссылка;
		МенЗап.ИнетМаг=Ссылка.ИнетМагазин;
