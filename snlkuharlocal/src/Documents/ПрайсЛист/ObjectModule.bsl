Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	НадоПерезаписыватьЦены = Ложь;
	ЕстьИзменения = Модифицированность();	
	
	Если НЕ ОбменДанными.Загрузка Тогда
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ);	
		
		Если Отказ Тогда Возврат КонецЕсли;
		
		Если Дата<>Ссылка.Дата ИЛИ ТипЦен<>Ссылка.ТипЦен Тогда
			НадоПерезаписыватьЦены=Истина;
		КонецЕсли; 
		
		
	КонецЕсли;
	
	Если УровеньДоступа <> ТипЦен.УровеньДоступа Тогда
		УровеньДоступа = ТипЦен.УровеньДоступа;		
	КонецЕсли;
	
	УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
	УстановитьПолучателейИзмененийОбъектаВнешние(ЭтотОбъект);
	
	Если ЕстьИзменения И НЕ ЭтоНовый() Тогда
		ДополнительныеСвойства.Вставить("ОтправитьОповещение", Истина);
	КонецЕсли;
	
	Если НЕ ЕстьИзменения Тогда Возврат КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НадоПерезаписыватьЦены Тогда
		Набор = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
		Набор.Отбор.Прайс.Установить(Ссылка);
		Набор.Прочитать();
		
		ВсегоЗаписей=Набор.Количество();
		
		Для Каждого Запись Из Набор Цикл 
			#ЕСЛИ КЛИЕНТ ТОГДА 
				Состояние("Осталось: "+ВсегоЗаписей);
			#КОНЕЦЕСЛИ
			
			ВсегоЗаписей = ВсегоЗаписей-1;
			
			Если Запись.Период<>НачалоДня(Дата) Тогда
				Запись.Период=Дата;		
			КонецЕсли;		
			Если Запись.ТипЦен<>ТипЦен Тогда
				Запись.ТипЦен=ТипЦен;		
			КонецЕсли; 
		КонецЦикла;	
		Если Набор.Модифицированность() Тогда
			Набор.Записать();	
		КонецЕсли;				
	КонецЕсли;
	
КонецПроцедуры

