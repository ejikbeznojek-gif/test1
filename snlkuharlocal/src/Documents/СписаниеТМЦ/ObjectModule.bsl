Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ЕстьИзменения	=Модифицированность();
	НужноВыгружать	=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	
//Кухарь А.Ю.  12.02.2024 начало
// Саща попросил снять запрет на запись  Опр и Спн	
	//если НЕ ПараметрыСеанса.ЗапущенаОбработка И НЕ ОбменДанными.Загрузка И Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
	//	#Если клиент тогда
	//		Сообщить("В ЦО запрещено создание документов по виртуальным складам");
	//	#КонецЕсли
	//	отказ=Истина;
	//КонецЕсли;
//Кухарь А.Ю.  12.02.2024 конец

	
	
	Если НЕ ОбменДанными.Загрузка Тогда
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		Если Отказ Тогда Возврат КонецЕсли;		
	КонецЕсли;
	//++Данилова Е.В. 03.02.2026  SNL-109 
	Если НЕ ОбменДанными.Загрузка
		И ЕстьИзменения  Тогда 
		
		ЕстьБлокировкаПоТоварам = Обработки.ПланИнвентаризации.ЕстьблокировкаПоТоварамСклада(Склад,Товары.Выгрузить(,"Номенклатура").выгрузитьКолонку("Номенклатура")); 
		
		Если ЕстьБлокировкаПоТоварам Тогда 
			Отказ = истина;
			Сообщить("В документе присутствует заблокированная номенклатура! Документ доступен только для просмотра!");
			Возврат; 
		КонецЕсли; 	
		
	КонецЕсли;
	//--Данилова Е.В. 03.02.2026 
	
	Если ЕстьИзменения Тогда 
		СуммаДокумента		= Товары.Итог("Всего");
		ОбъемДокумента		= Товары.Итог("Объем");
		КоличествоДокумента = Товары.Итог("Количество");
		
		ГруппыТоваров   	= ГруппыТоваровДокумента(ЭтотОбъект);
		
		// Кухарь А.Ю. 09.09.2024 начало
		ТребуетсяМаркировка=МаркировкаКС.ОпределитьЗначениеТребуетсяМаркировкаВДокументе(ЭтотОбъект,,,Истина); 
		//крохин начало 19.03.2025
		//HELP-2535 - затычка		
		//// Кухарь А.Ю.  15.01.2025 начало
		//// если ТребуетсяМаркировка тогда
		//если ТребуетсяМаркировка и Дата>='20250101' тогда		 
		//	// Кухарь А.Ю.  15.01.2025 конец
		если ТребуетсяМаркировка и Дата>='20250301' тогда	
		//крохин конец 19.03.2025

			если ЭтоУзелОтправителяПоСкладу(Склад) тогда
				если Проведен и СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена тогда
					// Кухарь А.Ю. 28.03.2025 начало
					// Пустая задача
					если ОбщегоНазначения_ПИ.ЕстьЛНСМаркировкой(Ссылка) тогда
						// Кухарь А.Ю. 28.03.2025 конец
						
						РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_СПН(Ссылка);
						если не РезультатРаботыСХКМ.Успешно тогда
							РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
							СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
							отказ=Истина;	
						КонецЕсли;
						// Кухарь А.Ю. 28.03.2025 начало
						// Пустая задача
					КонецЕсли; 
					// Кухарь А.Ю. 28.03.2025 конец
					
				ИначеЕсли РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения или (СостояниеНакладной<>Перечисления.СостоянияНакладной.Отгружена и Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена) тогда
					РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Отменить_ХКМ_к_НАК(Ссылка,Перечисления.ПланФакт.Факт);
					если не РезультатРаботыСХКМ.Успешно тогда
						РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
						СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
						отказ=Истина;	
					КонецЕсли;						
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// Кухарь А.Ю. 09.09.2024 конец
		
	КонецЕсли; 
	//Кухарь 29.12.15 начало
	//Не выгружаем ни куда при перепроведении
	если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение и ПараметрыСеанса.ОтключитьЖурнализациюЗаписи =Истина тогда
		НужноВыгружать=ложь;
	КонецЕсли;
	//Кухарь 29.12.15 конец		
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
