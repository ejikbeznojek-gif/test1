  <attributes>
    <name>Список</name>
    <title>
      <key>ru</key>
      <value>Список</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ           
	ВЫРАЗИТЬ(ДокументОснование КАК Документ.РасходнаяНакладная) КАК РасходнаяНакладная,
	МАКСИМУМ(Ссылка) КАК ОперацияМаркировки
ПОМЕСТИТЬ ВТ_ОперацииМаркировки	
ИЗ                
	Документ.МаркировкаТоваровИСМП
ГДЕ
	ДокументОснование ССЫЛКА Документ.РасходнаяНакладная
	И (
		ВЫРАЗИТЬ(ДокументОснование КАК Документ.РасходнаяНакладная).ДистанционнаяПродажа = Истина
		ИЛИ НЕ ВЫРАЗИТЬ(ДокументОснование КАК Документ.РасходнаяНакладная).Контрагент.СтранаРегистрации В (ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка),ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.Россия))
	)			
СГРУППИРОВАТЬ ПО
	ДокументОснование
;
ВЫБРАТЬ
	РНК.Ссылка				КАК Ссылка,
	РНК.Ссылка.Дата 		КАК Дата,	
	РНК.Ссылка.Номер		КАК Номер,
	РНК.Ссылка.Контрагент	КАК Контрагент,
	РНК.Ссылка.Склад		КАК Склад,
	РНК.Ссылка.Проведен		КАК Проведен,
	
	РНК.Отгружен			КАК Отгружен,
	РНК.СостояниеНакладной	КАК СостояниеНакладной,
	
	ВТ_ОперацииМаркировки.ОперацияМаркировки КАК ОперацияМаркировки,
	
	РНК.Контрагент.СтранаРегистрации КАК СтранаРегистрации,
	РНК.Контрагент.СтранаРегистрации.УчастникЕАЭС КАК УчастникЕАЭС,
	
	ВЫБОР 
		КОГДА РНК.Контрагент.СтранаРегистрации В (ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка),ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.Россия)) ТОГДА Ложь
		ИНАЧЕ Истина
	КОНЕЦ КАК Экспорт
ИЗ
	Документ.РасходнаяНакладная КАК РНК
ЛЕВОЕ СОЕДИНЕНИЕ
	ВТ_ОперацииМаркировки
ПО              
	РНК.Ссылка = ВТ_ОперацииМаркировки.РасходнаяНакладная		
ГДЕ
	(
		РНК.ДистанционнаяПродажа
		ИЛИ НЕ (РНК.Контрагент.СтранаРегистрации В (ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка),ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.Россия)))
	)
		</queryText>
      <mainTable>Document.РасходнаяНакладная</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
