&НаСервере
Процедура ПерезаполнитьТаблицыБезУчетаГотовыхНаборов()
	 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВТТовары.Номенклатура КАК Номенклатура,
	               |	ВТТовары.Количество КАК Количество,
	               |	ВТТовары.Цена КАК Цена
	               |ПОМЕСТИТЬ ВтТовары
	               |ИЗ
	               |	&Товары КАК ВТТовары
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВЫРАЗИТЬ(ВТШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	               |	ВТШтрихкодыУпаковок.КодАгрегации КАК КодАгрегации,
	               |	ВТШтрихкодыУпаковок.ДокументОснование КАК ДокументОснование,
	               |	ВТШтрихкодыУпаковок.ШтрихкодНабора КАК ШтрихкодНабора,
	               |	ВТШтрихкодыУпаковок.ШтрихкодКоробки КАК ШтрихкодКоробки,
	               |	ВТШтрихкодыУпаковок.ДокументАгрегации КАК ДокументАгрегации
	               |ПОМЕСТИТЬ ВтШКУпаковки
	               |ИЗ
	               |	&ШтрихкодыУпаковок КАК ВТШтрихкодыУпаковок
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТовары.Номенклатура КАК Номенклатура,
	               |	ВТТовары.Цена КАК Цена,
	               |	ВТТовары.Количество КАК Количество
	               |ПОМЕСТИТЬ ВТТоварыБезГН
	               |ИЗ
	               |	ВтТовары КАК ВТТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправ
	               |		ПО ВТТовары.Номенклатура = НоменклатураСправ.Ссылка
	               |			И (НоменклатураСправ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	               |		ПО (НоменклатураКоплектующие.Номенклатура = ВТТовары.Номенклатура)
	               |			И (НоменклатураКоплектующие.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
				   //++Данилова Е.В. 25.06.2025  MARK-2355
				   |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправСпайки
	               |		ПО ВТТовары.Номенклатура = НоменклатураСправСпайки.Ссылка
	               |			И (НоменклатураСправСпайки.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующиеСпайки
	               |		ПО (НоменклатураКоплектующиеСпайки.Номенклатура = ВТТовары.Номенклатура)
	               |			И (НоменклатураКоплектующиеСпайки.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект))

				   //--Данилова Е.В. 25.06.2025
	               |ГДЕ 
				   //++Данилова Е.В. 25.06.2025 MARK-2355, MARK-2484  
	               //|	НоменклатураСправ.Ссылка ЕСТЬ NULL
				   |	НоменклатураКоплектующиеСпайки.Ссылка ЕСТЬ NULL 
				   //--Данилова Е.В. 25.06.2025
	               |	И НоменклатураКоплектующие.Ссылка ЕСТЬ NULL
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТоварыБезГН.Номенклатура КАК Номенклатура,
	               |	ВТТоварыБезГН.Цена КАК Цена,
	               |	ВТТоварыБезГН.Количество КАК Количество
	               |ИЗ
	               |	ВТТоварыБезГН КАК ВТТоварыБезГН
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВтШКУпаковки.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	               |	ВтШКУпаковки.КодАгрегации КАК КодАгрегации,
	               |	ВтШКУпаковки.ДокументОснование КАК ДокументОснование,
	               |	ВтШКУпаковки.ШтрихкодНабора КАК ШтрихкодНабора,
	               |	ВтШКУпаковки.ШтрихкодКоробки КАК ШтрихкодКоробки,
	               |	ВтШКУпаковки.ДокументАгрегации КАК ДокументАгрегации
	               |ИЗ
	               |	ВтШКУпаковки КАК ВтШКУпаковки
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБезГН КАК ВтТовары
	               |		ПО ВтШКУпаковки.ШтрихкодУпаковки.Владелец = ВтТовары.Номенклатура";
	
	Запрос.УстановитьПараметр("Товары",Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("ШтрихкодыУпаковок",Объект.ШтрихкодыУпаковок.Выгрузить());
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	Объект.Товары.Загрузить(ПакетЗапросов[3].Выгрузить()); 
	Объект.ШтрихкодыУпаковок.Загрузить(ПакетЗапросов[4].Выгрузить()); 
	
КонецПроцедуры // ()

&НаСервере
Процедура ДополнитьКодыНаСервере(ЧислоКодов)
	ТипШК=Объект.ТипШК;
	ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
	ДопПараметры = Новый Структура("Добавлять", Истина);
	
	рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыАгрегации(ТипШК,
	ТипУпаковки,ЧислоКодов,объект.Ссылка,ДопПараметры);
	если рБронирования.Успешно тогда
		
		Для каждого СтрМасс из рБронирования.Данные цикл
			СтрТЧ=объект.ШтрихкодыКоробок.Добавить();
			СтрТЧ.ДатаДобавления=ТекущаяДата();
			СтрТЧ.ШтрихкодКоробки=СтрМасс;
		КонецЦикла;			
		Попытка
			Записать();
		Исключение
			Сообщить("Не удалось записать документ: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнитьКоды(Команда)
	ЧислоКодов=0;
	ВвестиЧисло(ЧислоКодов,"Введите число заказываемых кодов");
	ДополнитьКодыНаСервере(ЧислоКодов);
КонецПроцедуры

