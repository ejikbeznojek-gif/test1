
#Область СобытияФормы
	

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда
		рПроверки = МожноСоздаватьДокумент();
		Если рПроверки.Успешно Тогда
		Иначе
			Отказ = Истина;
			МаркировкаКС.ВывестиОшибки(рПроверки);
		КонецЕсли; 
	КонецЕсли; 
	
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МаркировкаК.ПроверкаРазрешенияРедактированияУФ(ЭтаФорма);
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)	
	Если ИмяСобытия = "ИзмененСтатус" И Источник = Объект.Ссылка  Тогда
		Если НЕ Модифицированность Тогда		
			Прочитать();
			УправлениеВидимостью();
		КонецЕсли;		
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	//++Данилова Е.В. 19.02.2025 MARK-1454
	Если НЕ Отказ
		И Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийМаркировки.ВводВОборот")
		И Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовМаркировки.ВРаботе")
		И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		СоздаватьДокументПоГотовымКомплектам = Ложь; 
		ПроверитьДокументНаНаличиеГотовыхКомплектовНаСервере(СоздаватьДокументПоГотовымКомплектам);
		
		Если СоздаватьДокументПоГотовымКомплектам Тогда
			
			Отказ = Истина; 
			//Данилова Е.В. 04.06.2026 без задачи 
			ОповещениеВопросПоСозданиюДокумента = Новый ОписаниеОповещения("ОтветНаВопросСоздатьДокументГотовыйКомплект",ЭтотОбъект);
			//ОповещениеВопросПоСозданиюДокумента = Новый ОписаниеОповещения("ОтветНаВопросСоздатьДокументГотовыйКомплект",ЭтаФорма); 
			ПоказатьВопрос(ОповещениеВопросПоСозданиюДокумента,"Найдены готовые комплекты, выделить их в отдельный документ?",РежимДиалогаВопрос.ОКОтмена); 	
			
		КонецЕсли;
		
	КонецЕсли;   
	//--Данилова Е.В. 19.02.2025
КонецПроцедуры


#КонецОбласти

#Область СобытияЭлементовУправления


&НаКлиенте
Процедура ВидОперацииИСПМ_ПриИзменении(Элемент)
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ТипДокумента_ПриИзменении(Элемент)
	УправлениеВидимостью();
КонецПроцедуры


#КонецОбласти


&НаСервере
Функция МожноСоздаватьДокумент()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		ТипОснования = ТипЗнч(Объект.ДокументОснование);
		Если ТипОснования = Тип("ДокументСсылка.ЛистНабора") Тогда
			АгрегацииПоОснованию = Документы.МаркировкаТоваровИСМП.ПолучитьОперацииПоОснованию(Объект.ДокументОснование, Перечисления.ВидыОперацийМаркировки.Агрегация);					
			Если АгрегацииПоОснованию.Количество() > 0 Тогда				
				Результат.Ошибки.Добавить("Уже сущсевуют подчиненные агрегации к ЛН: " + Объект.ДокументОснование);
			КонецЕсли; 
		КонецЕсли;	
	КонецЕсли;
	
	Результат.Успешно = ( Результат.Ошибки.Количество() = 0 );
	
	Возврат Результат;
КонецФункции //МожноСоздаватьДокумент()

&НаСервере
Процедура УправлениеВидимостью()
	Имена = СтрРазделить("
		|Организация,ПодразделениеНанесения,ДокументОснование,ШтрихкодыУпаковок,Дата,ВидОперации,ВидОперацииИСМП,
		|ТипДокумента,НаименованиеПервичногоДокумента,ОписаниеПричины,ИдентификаторГосКонтракта,Страна,ИмпортерИД,
		|КоличествоКодовSSCC,ТипУпаковки,ТипШК,фКодыАгрегацийДляПоставщиков,ДокументыОснования", ","
	);
	
	Если РольДоступна("Администратор") Тогда
		Элементы.ПодразделениеНанесенияС.Доступность = Истина;
		Если НЕ ТолькоПросмотр Тогда		
			Элементы.кнОчиститьКМ.Доступность = Истина;
		КонецЕсли;		
	Иначе		
		Имена.Добавить("Статус");
		Элементы.АТК.ТолькоПросмотр 		= Истина;
		
		Элементы.гТовары.ТолькоПросмотр		= Истина;
		Элементы.гКоды.ТолькоПросмотр		= Истина;
		Элементы.гКоробки.ТолькоПросмотр	= Истина;
	КонецЕсли;
	
	Элементы.гТовары.Заголовок 	= СтрШаблон("Товары (%1)", 	Формат(Объект.Товары.Количество(), "ЧН=0; ЧРГ=' '; ЧГ=3,0"));
	Элементы.гКоды.Заголовок 	= СтрШаблон("Коды (%1)", 	Формат(Объект.ШтрихкодыУпаковок.Количество(), "ЧН=0; ЧРГ=' '; ЧГ=3,0"));
	Элементы.гКоробки.Заголовок = СтрШаблон("Коробки (%1)", Формат(Объект.ШтрихкодыКоробок.Количество(), "ЧН=0; ЧРГ=' '; ЧГ=3,0"));	
	
	Элементы.КоличествоКодовSSCC.Видимость		= Ложь;
	Элементы.ПодразделениеНанесения.Видимость	= Ложь;
	Элементы.ТипШК.Видимость					= Ложь;
	Элементы.АТК.Видимость						= Ложь;
	
	Элементы.ВидОперацииИСМП.Видимость	= Истина;
	Элементы.ТипДокумента.Видимость 	= Истина;
	Элементы.гкНоменклатура.Видимость	= Истина;	
	
	мТолькоПросмотр = ТолькоПросмотр ИЛИ (Объект.Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе);
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
		Элементы.ШтрихкодыУпаковокКодАгрегации.Видимость = Истина;		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.АТК Тогда
		Элементы.ШтрихкодыУпаковокКодАгрегации.Видимость = Истина;
		Элементы.ШтрихкодыУпаковокКодАгрегации.ТолькоПросмотр = Истина;		
		Элементы.ВидОперацииИСМП.Видимость	= Ложь;
		Элементы.КоличествоКодовSSCC.Видимость		= Истина;
		Элементы.АТК.Видимость						= Истина;
		Элементы.АТК.ТолькоПросмотр					= Истина;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияАТК Тогда
		Элементы.АТК.Видимость						= Истина;
		Элементы.АТК.ТолькоПросмотр					= мТолькоПросмотр;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
		Элементы.ШтрихкодыУпаковокКодАгрегации.Видимость	= Истина;
		Элементы.КоличествоКодовSSCC.Видимость				= Истина;
		Элементы.ПодразделениеНанесения.Видимость			= Истина;
		
		Элементы.гкНоменклатура.Видимость	= Ложь;
		Элементы.ВидОперацииИСМП.Видимость	= Ложь;
		Элементы.ТипДокумента.Видимость 	= Ложь;						
	Иначе
		Элементы.ШтрихкодыУпаковокКодАгрегации.Видимость = Ложь;		
	КонецЕсли;
	
	Для Каждого ИмяЭУ Из Имена Цикл
		Элементы[СокрЛП(ИмяЭУ)].ТолькоПросмотр = мТолькоПросмотр;	
	КонецЦикла;	
	
	Элементы.ДобавитьКоды.Доступность				= НЕ мТолькоПросмотр;
	Элементы.УдалитьКоды.Доступность 				= НЕ мТолькоПросмотр;
	Элементы.УдалитьКодыНаборов.Доступность			= НЕ мТолькоПросмотр;
	Элементы.ЗаполнитьРазагрегации.Доступность 		= НЕ мТолькоПросмотр;
	Элементы.ПодразделениеНанесения.ТолькоПросмотр	= мТолькоПросмотр;
	Элементы.ПодразделениеНанесенияС.ТолькоПросмотр	= мТолькоПросмотр;
	
	Элементы.НаименованиеПервичногоДокумента.Видимость	= Ложь;					
	Элементы.ОписаниеПричины.Видимость 					= Ложь;	
	Элементы.ИдентификаторГосКонтракта.Видимость		= Ложь;
	Элементы.гСтрана.Видимость							= Ложь;
	Элементы.ВозвращаемыйТоварБылОплачен.Видимость 		= Ложь;
	Элементы.гкНабор.Видимость							= Ложь;
	Элементы.гКоробки.Видимость							= Ложь;
	Элементы.фКодыАгрегацийДляПоставщиков.Видимость		= Ложь;
	Элементы.гШтрихКодУпаковки.Видимость 				= Ложь;
	Элементы.ИННПокупателя.Видимость					= Ложь;
	
	//ВидОперацииИСМП
	Если Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт   
		//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522 Добавил ИЛИ 
		ИЛИ Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно
		ИЛИ Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков Тогда		
		Элементы.ТипДокумента.Видимость 	= Ложь;
		Если Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков 
			//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522 Добавил ИЛИ 
			ИЛИ Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно Тогда
			Элементы.ПодразделениеНанесения.Видимость = Истина;		
		КонецЕсли; 
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_БезвозмезднаяПередача Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли; 					
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ВозвратФизическомуЛицу Тогда
		Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ТрансграничнаяПродажаВСтраныЕАЭС Тогда	
		Элементы.ТипДокумента.Видимость = Ложь;
		Элементы.гСтрана.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ИспользованиеДляСобственныхНужд Тогда
		Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;
		Элементы.ИННПокупателя.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Конфискация Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоОбразцам Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоГосударственномуКонтракту Тогда	
		Элементы.ТипДокумента.Видимость					= Ложь;
		Элементы.ИдентификаторГосКонтракта.Видимость	= Истина;						
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоСделкеСГосударственнойТайной Тогда	
		Элементы.ТипДокумента.Видимость					= Ложь;
		Элементы.ИдентификаторГосКонтракта.Видимость	= Истина;						
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Уничтожение Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Утилизация Тогда
		Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Утрата Тогда
		Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Прочее Тогда
		Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ЭкспортЗаПределыСтранЕАЭС Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки Тогда				
		Элементы.ВидОперацииИСМП.Видимость	= Ложь;		
		//Элементы.гкНоменклатура.Видимость	= Ложь;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВозвратВОборот_Возврат_РозничнаяРеализация Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВозвратВОборот_Возврат_ПриобретениеНеДляПерепродажи Тогда
		Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВозвратВОборот_Возврат_ДистанционнаяПродажа Тогда
		Элементы.ВозвращаемыйТоварБылОплачен.Видимость = Истина;
		
		Если Объект.ВозвращаемыйТоварБылОплачен Тогда
			Если Объект.ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Элементы.НаименованиеПервичногоДокумента.Видимость = Истина;					
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли Объект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ФормированиеНабора Тогда
		Элементы.гкНабор.Видимость		= Истина;
		Элементы.ТипДокумента.Видимость	= Ложь;	
	Иначе
		Элементы.ТипДокумента.Видимость		= Ложь;		
	КонецЕсли;	
	
	Элементы.ТипУпаковки.Доступность 		= Ложь;
	Элементы.гКодыSSCC.Видимость 			= Ложь;
	Элементы.гкАгрегация.Видимость			= Ложь;
	Элементы.гкБронированиеSSCC.Видимость	= Ложь;
	
	//ВидОперации
