Процедура ЗаполнитьРазагрегации(Команда)
	ТипОснования = ТипЗнч(Объект.ДокументОснование);
	Если ЗначениеЗаполнено(Объект.ДокументОснование) И ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		рПолучения = ПолучитьРазАгрегации_НаСервере(Объект.ДокументОснование);
		Если рПолучения.Успешно Тогда
			Объект.ШтрихкодыУпаковок.Очистить();
			Для Каждого ШтрихкодУпаковки Из рПолучения.Данные Цикл
				СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();
				СтрокаТЧ.ШтрихкодУпаковки = ШтрихкодУпаковки;				
			КонецЦикла;
			Если рПолучения.Данные.Количество() = 0 Тогда
				Сообщить("Не обнаружено агрегационных кодов для расформирования.", СтатусСообщения.Обычное);			
			КонецЕсли; 
		Иначе
			МаркировкаКС.ВывестиОшибки(рПолучения);
		КонецЕсли; 
	Иначе
		Сообщить("Недопустимый тип основания: " + ТипОснования);
	КонецЕсли; 	
КонецПроцедуры

