Процедура ОтветНаВопросСоздатьДокументГотовыйКомплект(ОтветНаВопрос,ДополнительныеПараметры) Экспорт 

	Если ОтветНаВопрос = КодВозвратаДиалога.ОК Тогда
		
		
		ДокументПоКомплектам = СоздатьДокументГотовыйКомплектНаСервере();
		 
		Если Не ЗначениеЗаполнено(ДокументПоКомплектам) Тогда
			
			Возврат; 	
			
		КонецЕсли;
		
		Записать();
		
		ОткрытьЗначение(ДокументПоКомплектам);	
		
	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция СоздатьДокументГотовыйКомплектНаСервере()
	
	ПараметрыЗаполнения = Новый Структура("ПодразделениеНанесения,Организация,ДокументОснование,ВидОперации,ВидОперацииИСМП"); 
	ЗаполнитьЗначенияСвойств(ПараметрыЗаполнения,Объект); 	
	
	ТЧТовары 		= Объект.Товары.Выгрузить(); 
	ТЧШтрихКоды 	= Объект.ШтрихкодыУпаковок.Выгрузить(); 
	
	ДокОбъект = РеквизитФормыВЗначение("Объект"); 
	
	НовыйДокумент = ДокОбъект.СоздатьНовыйДокументМаркировкиПоГотовымКомплектам(ТЧТовары,ТЧШтрихКоды,ПараметрыЗаполнения);  
	
	Если Не ЗначениеЗаполнено(НовыйДокумент) Тогда
		
		Возврат неопределено; 	
		
	КонецЕсли;
	
	//////////////////////////////////////////////////
	/////////////////////////////////////////////////
	Для каждого СтрокаТоваров Из  НовыйДокумент.Товары Цикл
		
		НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура",СтрокаТоваров.Номенклатура)); 
		Если  НайденныеСтроки.Количество()> 0 Тогда
			
			Объект.Товары.Удалить(НайденныеСтроки[0]); 
			
		КонецЕсли;
	КонецЦикла;
	
	Для каждого СтрокаШК Из  НовыйДокумент.ШтрихкодыУпаковок Цикл
		
		НайденныеСтроки = Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодУпаковки",СтрокаШК.ШтрихкодУпаковки)); 
		Если  НайденныеСтроки.Количество()> 0 Тогда
			
			Объект.ШтрихкодыУпаковок.Удалить(НайденныеСтроки[0]); 
			
		КонецЕсли;
	КонецЦикла;

	
	Возврат НовыйДокумент.ссылка; 
	
 КонецФункции
 
