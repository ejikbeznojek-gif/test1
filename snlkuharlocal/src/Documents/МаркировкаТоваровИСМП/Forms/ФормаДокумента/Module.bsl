&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда 
		Если Объект.Товары.Количество() > 0 Тогда	
			Объект.Товары.Очистить();
		КонецЕсли;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
		КривыхСтрок = 0;
		
		Для Каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок Цикл			
			Если НЕ (
				ЗначениеЗаполнено(СтрокаТЧ.КодАгрегации) 
				ИЛИ ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодКоробки)
				ИЛИ ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодНабора) 
				) Тогда
				КривыхСтрок = КривыхСтрок + 1;							
			КонецЕсли;		
		КонецЦикла; 
		
		Если КривыхСтрок > 0 Тогда
			Сообщить(СтрШаблон("Не заполнены коды агрегации в %1 строках.", КривыхСтрок), СтатусСообщения.ОченьВажное);
			Отказ = Истина;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

