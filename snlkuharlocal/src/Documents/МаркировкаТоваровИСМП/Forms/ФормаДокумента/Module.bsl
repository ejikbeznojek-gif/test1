			ПоказатьЗначение( , ТекСтрока.ШтрихкодНабора);
		ИначеЕсли СтрНачинаетсяС(Поле.Имя, "ШтрихкодыУпаковокКодАгрегации") Тогда
			КодКоробки = НайтиКодМаркировки(ТекСтрока.КодАгрегации);
			Если ЗначениеЗаполнено(КодКоробки) Тогда
				ПоказатьЗначение( , КодКоробки);
			Иначе				
				ПоказатьЗначение( , ТекСтрока.ШтрихкодНабора);				
			КонецЕсли;			
		ИначеЕсли Поле.Имя = "ШтрихкодыУпаковокШтрихкодУпаковкиВладелец" Тогда
			ПоказатьЗначение( , МаркировкаВС.ПолучитьРеквизитШапки_(ТекСтрока.ШтрихкодУпаковки, "Владелец"));			
		КонецЕсли;			
	КонецЕсли;
