Функция ПолучитьВложенныеКодыПоНаборам()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ПОМЕСТИТЬ ВтНаборы
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваров.Ссылка
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
		|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = &Ссылка
		|	И ШтрихкодыУпаковокТоваров.Владелец.Родитель.ВидКомплекта = &Комплект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
		|ПОМЕСТИТЬ ВтВложенныеШК
		|ИЗ
		|	ВтНаборы КАК ВтНаборы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		|		ПО ВтНаборы.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки КАК ШтрихКодУпаковки,
		|	СтатусыКМ_ФактСрезПоследних.Статус КАК Статус,
		|	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки.ТипШК КАК ТипШК
		|ИЗ
		|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(
		|			,
		|			ШтрихКодУпаковки В
		|				(ВЫБРАТЬ
		|					ВТВложенныеШК.Штрихкод
		|				ИЗ
		|					ВТВложенныеШК)) КАК СтатусыКМ_ФактСрезПоследних";
	
	Запрос.УстановитьПараметр("ссылка", Ссылка);
	Запрос.УстановитьПараметр("Комплект", Перечисления.ВидыКомплектов.Комплект);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить(); 

КонецФункции

