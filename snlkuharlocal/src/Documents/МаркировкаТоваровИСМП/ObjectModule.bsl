Процедура ОбработкаУдаленияПроведения(Отказ)
	рПроверки = МожноПроводитьДокументВЭтомУзле();
	Если НЕ рПроверки.Успешно Тогда 
		Отказ = Истина;
		ВызватьИсключение СтрСоединить(рПроверки.Ошибки, Символы.ПС);
		Возврат; 
	КонецЕсли;
	
	Если Статус = Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ
		ИЛИ Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
		ИЛИ Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
		
		Отказ = Истина;		
	КонецЕсли; 
	
	Если НЕ Отказ Тогда	
		Получатели = ОпределитьПолучателей();
		ЗарегистрироватьИзменения_Статусы(Получатели);
	КонецЕсли;	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)	
	сПроверяемыеРеквизиты = Новый Соответствие;
	Для Каждого ИмяРеквизита Из ПроверяемыеРеквизиты Цикл
		сПроверяемыеРеквизиты[ИмяРеквизита] = Истина;			
	КонецЦикла;	
	
	Для Каждого КиЗ Из ОбязательныеРеквизитыДоп() Цикл
		сПроверяемыеРеквизиты[КиЗ.Ключ] = КиЗ.Значение;
	КонецЦикла; 
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
		сПроверяемыеРеквизиты["Товары.Номенклатура"]	= Ложь;
		сПроверяемыеРеквизиты["Товары.Количество"]		= Ложь;
		сПроверяемыеРеквизиты["ВидОперацииИСМП"] 		= Ложь;
		сПроверяемыеРеквизиты["ДокументОснование"] 		= Ложь; 
		
		сПроверяемыеРеквизиты["КоличествоКодовSSCC"]	= Истина;
		сПроверяемыеРеквизиты["ТипШК"]					= Истина;
		сПроверяемыеРеквизиты["ПодразделениеНанесения"]	= Истина;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки Тогда
		сПроверяемыеРеквизиты["ДокументОснование"] 		= Ложь;
		сПроверяемыеРеквизиты["ТипУпаковки"] 			= Ложь;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВыводИзОборота Тогда
		сПроверяемыеРеквизиты["ТипУпаковки"] 			= Ложь;		
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияУпаковки Тогда
		сПроверяемыеРеквизиты["ШтрихкодУпаковки"] 		= Истина;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.Перемаркировка Тогда
		сПроверяемыеРеквизиты["ДокументОснование"] 		= Ложь;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ФормированиеНабора Тогда
		сПроверяемыеРеквизиты["ТипУпаковки"] 			= Ложь;
	КонецЕсли;	
	
	ПроверяемыеРеквизиты.Очистить();
	Для Каждого КиЗ Из сПроверяемыеРеквизиты Цикл
		Если КиЗ.Значение = Истина Тогда		
			ПроверяемыеРеквизиты.Добавить(КиЗ.Ключ);			
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры


#КонецОбласти

Функция лМожноЗаписатьДокумент()
	Результат = Новый Структура("Успешно,Ошибки", Истина, Новый Массив);
	
	Если ЭтоНовый() Тогда
		мКодУзлаСоздания = КодУзлаСоздания;
	Иначе 
		мКодУзлаСоздания = ПолучитьРеквизитШапки(Ссылка, "КодУзлаСоздания");
	КонецЕсли;		
		
	Если ОбменДанными.Загрузка Тогда
		УзелОтправитель = ОбменДанными.Отправитель;
		Если ЗначениеЗаполнено(УзелОтправитель) Тогда
			Если УзелОтправитель.Код <> мКодУзлаСоздания Тогда				
				Результат.Успешно = Ложь;							
				Результат.Ошибки.Добавить("Нельзя перезаписывать ОМ созданную в другом узле ! " + Ссылка + " создан: " + мКодУзлаСоздания);				
			ИначеЕсли мКодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код() Тогда
				Результат.Успешно = Ложь;							
				Результат.Ошибки.Добавить("Можно загружать только ОМ созданные в других узлах ! "+ЭтотОбъект+" узел отправитель: "+УзелОтправитель.Код+", код узла создания: "+мКодУзлаСоздания);
			КонецЕсли; 			 
		КонецЕсли;
	Иначе
		Если НЕ ЭтоНовый() Тогда
			Если мКодУзлаСоздания <> Маркировка_ПИ.ЭтотУзел_Код() И Модифицированность() Тогда
				Результат.Успешно = Ложь;
				Результат.Ошибки.Добавить("Нельзя изменять ОМ созданную в другом узле ! "+Ссылка+" создан: "+мКодУзлаСоздания);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ПараметрыСеанса.ОтключитьКонтрольДЗР Тогда    
			Отказ = Ложь;
			КонтрольДатыЗапрета(ЭтотОбъект, Отказ);
			Если Отказ Тогда
				Результат.Успешно = Ложь;
				Результат.Ошибки.Добавить("Нарушение ДЗР !");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //лМожноЗаписатьДокумент()

Функция ДобавитьКодыВАгрегат()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|    Штрихкод
	|ПОМЕСТИТЬ ВТ_ВложенныеКоды
	|ИЗ	
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|ГДЕ
	|	ВложенныеШтрихкоды.Ссылка = &КодАгрегата
	|ИНДЕКСИРОВАТЬ ПО	
	|	Штрихкод	
	|;	
	|ВЫБРАТЬ
	|	ТЧ.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ТЧ
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_ВложенныеКоды
	|ПО  	
	|	ТЧ.ШтрихкодУпаковки 		= ВТ_ВложенныеКоды.Штрихкод
	|ГДЕ
	|	ТЧ.Ссылка 					= &Ссылка	
	|	И ВТ_ВложенныеКоды.ШтрихКод ЕСТЬ NULL
	|";
	
	Запрос.УстановитьПараметр("Ссылка", 		Ссылка);
	Запрос.УстановитьПараметр("КодАгрегата",	ШтрихкодУпаковки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 Тогда
		СпрОбъект = ШтрихкодУпаковки.ПолучитьОбъект();
		
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = СпрОбъект.ВложенныеШтрихкоды.Добавить();
			СтрокаТЧ.Штрихкод = Выборка.ШтрихкодУпаковки;
		КонецЦикла;
		
		СпрОбъект.Количество = ПолучитьКоличествоВложенныхКодов(СпрОбъект);
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		
		СпрОбъект.Записать();
	КонецЕсли;	
КонецФункции //ДобавитьКодыВАгрегат()

Функция УдалитьКодыИзАгрегата()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|    Штрихкод
	|ПОМЕСТИТЬ ВТ_ВложенныеКоды
	|ИЗ	
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|ГДЕ
	|	ВложенныеШтрихкоды.Ссылка = &КодАгрегата
	|ИНДЕКСИРОВАТЬ ПО	
	|	Штрихкод	
	|;	
	|ВЫБРАТЬ
	|	ТЧ.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ТЧ
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_ВложенныеКоды
	|ПО  	
	|	ТЧ.ШтрихкодУпаковки 		= ВТ_ВложенныеКоды.Штрихкод
	|ГДЕ
	|	ТЧ.Ссылка 					= &Ссылка	
	|	И ВТ_ВложенныеКоды.ШтрихКод ЕСТЬ НЕ NULL
	|";
	
	Запрос.УстановитьПараметр("Ссылка", 		Ссылка);
	Запрос.УстановитьПараметр("КодАгрегата",	ШтрихкодУпаковки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 Тогда
		КодыКУдалению = Новый Соответствие;		
		Пока Выборка.Следующий() Цикл
			КодыКУдалению[Выборка.ШтрихкодУпаковки] = Истина;
		КонецЦикла;
		
		СпрОбъект 	= ШтрихкодУпаковки.ПолучитьОбъект();
		Сч 			= СпрОбъект.ВложенныеШтрихкоды.Количество() - 1;
		Пока Сч >= 0 Цикл          
			ТекСтрока = СпрОбъект.ВложенныеШтрихкоды[Сч];
			Если КодыКУдалению[ТекСтрока.Штрихкод] <> Неопределено Тогда
				СпрОбъект.ВложенныеШтрихкоды.Удалить(ТекСтрока);							
			КонецЕсли;
			Сч = Сч - 1;			
		КонецЦикла;
		
		СпрОбъект.Количество = ПолучитьКоличествоВложенныхКодов(СпрОбъект);
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		
		СпрОбъект.Записать();
	КонецЕсли;	
КонецФункции //ДобавитьКодыВАгрегат()

Функция ПолучитьКоличествоВложенныхКодов(КМ_Объект)
	Резуьтат = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ВложенныеШтрихкоды ИЗ &ВложенныеШтрихкоды КАК ВложенныеШтрихкоды 
	|;
	|ВЫБРАТЬ СУММА(Штрихкод.Количество) КАК Количество ИЗ ВТ_ВложенныеШтрихкоды
	|";
	
	Запрос.УстановитьПараметр("ВложенныеШтрихкоды", КМ_Объект.ВложенныеШтрихкоды);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Резуьтат = Выборка.Количество;
	КонецЕсли;                       
	
	Возврат Резуьтат;
КонецФункции //ПолучитьКоличествоВложенныхКодов(КМ_Объект)

Функция ПолучитьТаблицуШК(ДокСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки					КАК ШтрихкодУпаковки,
	|	ШтрихкодУпаковки.ТипШК				КАК ТипШК,
	//+++Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	|	ШтрихкодУпаковки.ТипУпаковки 		КАК ТипУпаковки,
	|	ШтрихкодУпаковки.СпособВводаВОборот КАК СпособВводаВОборот,                    
	//---Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	|	ШтрихкодУпаковки.Владелец 			КАК Номенклатура
	|ИЗ
	|	" +  ДокСсылка.Метаданные().ПолноеИмя() + ".ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";                             
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьТаблицуШК(ДокСсылка)

Функция МожноПроводитьДокументВЭтомУзле()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	КодТекУзла = ВРег(СокрЛП(Маркировка_ПИ.ЭтотУзел_Код("Основной")));	
	Если КодТекУзла <> СокрЛП(СокрЛП(КодУзлаСоздания)) Тогда 
		ТекстСообщения = СтрШаблон("Документ создан в узле: %1, текущий узел: %2.
		|Нельзя изменять проводить (распроводить) операции маркировки полученные из других узлов !", КодУзлаСоздания, КодТекУзла);
		
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(ТекстСообщения);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции // ()

Функция ОпределитьПолучателяКодов()
	ИмяПланаОбмена	= "ДанныеЧЗ";
	Результат		= ПланыОбмена[ИмяПланаОбмена].ПустаяСсылка();
	
	Если ЗначениеЗаполнено(ПодразделениеНанесения) И ТипЗнч(ПодразделениеНанесения) = Тип("СправочникСсылка.Подразделения") Тогда		
		УзелПолучатель	= Маркировка_ПИ.УзелПодразделения(ПодразделениеНанесения, ИмяПланаОбмена);		
		Если ЗначениеЗаполнено(УзелПолучатель) И УзелПолучатель <> Маркировка_ПИ.ЭтотУзел(ИмяПланаОбмена) Тогда
			Результат = УзелПолучатель;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ОпределитьПолучателяКодов()

