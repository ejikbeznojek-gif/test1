#Область СобытияОбъекта


Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс);	
	КонецЕсли; 
	Префикс = Префикс+Маркировка_ПИ.ЭтотУзел_Код("Основной")+"-";
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)	
	ЗаполнитьШапкуДокумента(ЭтотОбъект, ПараметрыСеанса.Пользователь, ОбщегоНазначения_ПИ.ВалютаНац());
	
	Статус				= Перечисления.СтатусыДокументовМаркировки.ВРаботе;	 
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	//СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков; 
	СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка;
	//Валетов-
	ТипУпаковки 		= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	ТипШК				= Перечисления.ТипыШтрихКодов.Коробка;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ДокументОснование	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеЗаполнения, "ДокументОснование");
		ДопПараметры		= ДанныеЗаполнения;
	Иначе		
		ДокументОснование	= ДанныеЗаполнения;
		ДопПараметры		= Неопределено;
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда Возврат КонецЕсли;
	ТипОснования 		= ТипЗнч(ДокументОснование);
	
	ЗаполнятьТолькоШапку = МаркировкаКС.ПолучитьЗначениеПараметра(ДополнительныеСвойства, "ЗаполнятьТолькоШапку", Ложь);
	
	СтрокаРеквизитов = "Дата,Комментарий";
	Если ТипОснования	= Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
		СтрокаРеквизитов = СтрокаРеквизитов+",ПодразделениеНанесения,СпособВводаВОборот";
		//++Данилова Е.В. 26.05.2026  MARK-3615 
		ДокПеремаркировки = Документы.Перемаркировка.ОтработкаПоПеремаркировке(ДокументОснование);
		Если ДокПеремаркировки <> Неопределено Тогда
		
			СтрокаРеквизитов = СтрокаРеквизитов+",СпособВводаВОборот";	
		
		КонецЕсли; 
			
		//--Данилова Е.В. 26.05.2026 
	КонецЕсли;
	Если ЕстьРеквизитДокумента("Организация", ДокументОснование.Метаданные()) Тогда
		СтрокаРеквизитов = СтрокаРеквизитов+",Организация";	
	КонецЕсли;	
	РеквизитыОснования 	= ПолучитьРеквизитыШапки(ДокументОснование, СтрокаРеквизитов);
	
	Если ТипОснования = Тип("ДокументСсылка.ЛистНабора") Тогда
		РеквизитыОснования.Вставить("Организация", ПолучитьРеквизитШапки(ДокументОснование, "ДокОснование.Организация"));				
	КонецЕсли;
	
	Организация 		= РеквизитыОснования.Организация;	
	
	Если ТипОснования = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
		Если ЗаполнятьТолькоШапку Тогда
		Иначе
			ЗаполнитьТоварыПо_ЗПС(ДанныеЗаполнения);
		КонецЕсли;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Если ЗаполнятьТолькоШапку Тогда
		Иначе
			ЗаполнитьТоварыПо_ЗПС(ДанныеЗаполнения);
		КонецЕсли;		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЛистНабора") Тогда
		
		ЗаполнитьПоЛистуНабора(ДокументОснование);
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Машина") Тогда
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
		
		ЗаполнитьПоПРМ(ДокументОснование);
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ") Тогда		
		//Данилова Е.В. 18.08.2025 MARK-1756 
		Если ЗаполнятьТолькоШапку Тогда 
		Иначе
			ЗаполнитьПоЗСБ(ДокументОснование);	
		КонецЕсли; 
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		
		ЗаполнитьПоЗНМ(ДокументОснование, ДопПараметры);
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
		
		ВидОперации		= Перечисления.ВидыОперацийМаркировки.ВводВОборот;
		
		Если РеквизитыОснования.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков Тогда			
			ВидОперацииИСМП	= Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков;                      
			
			Дата = ДокументОснование.Дата;   
		//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
		ИначеЕсли РеквизитыОснования.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка тогда
		    ВидОперации		= Перечисления.ВидыОперацийМаркировки.Перемаркировка;
			ВидОперацииИСМП	= Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно;                      
			Дата = ДокументОснование.Дата;
		//Валетов-
		Иначе                                                                              
			ВидОперацииИСМП	= Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт;
			Дата = ТекущаяДата();			
		КонецЕсли;
		
		ПодразделениеНанесения = РеквизитыОснования.ПодразделениеНанесения;
		Комментарий = РеквизитыОснования.Комментарий;
		
		ЗаполнитьШКпоЗаказуНаЭмиссию(ДокументОснование);		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Комментарий = РеквизитыОснования.Комментарий;
		
		Если НЕ ЗаполнятьТолькоШапку Тогда		
			ЗаполнитьТоварыПоНакладной(ДокументОснование);
		КонецЕсли;		
		ЗаполнитьПоПНК(ДокументОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Комментарий = РеквизитыОснования.Комментарий;
		
		ЗаполнитьПоРНК(ДокументОснование);
		
		Если НЕ ЗаполнятьТолькоШапку Тогда		
			ЗаполнитьТоварыПоНакладной(ДокументОснование);
			ЗаполнитьШКпоЛН(ДокументОснование);
		КонецЕсли;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.РекламационнаяНакладная") Тогда
		Комментарий = РеквизитыОснования.Комментарий;
		
		ЗаполнитьПоРКМ(ДокументОснование);
		
		Если НЕ ЗаполнятьТолькоШапку Тогда		
			ЗаполнитьТоварыПоНакладной(ДокументОснование);
			ЗаполнитьШКпоХКМ(ДокументОснование);
		КонецЕсли;	
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеТМЦ") Тогда
		НаименованиеПервичногоДокумента = "СПН";
		Комментарий = РеквизитыОснования.Комментарий;
		
		ЗаполнитьТоварыПоНакладной(ДокументОснование);
		ЗаполнитьПоСПН(ДокументОснование);		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда		
		рШапки = ПолучитьРеквизитыШапки(ДокументОснование, "ВидОперации");
		Если рШапки.ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
			ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияУпаковки;
		ИначеЕсли рШапки.ВидОперации = Перечисления.ВидыОперацийМаркировки.АТК Тогда
			ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияАТК;
			АТК			= ПолучитьРеквизитШапки(ДокументОснование, "АТК");
		Иначе			
			ДокументОснование = Неопределено;
			Сообщить("В качестве основания можно использовать только документы с видом операции 'Агрегация' или 'АТК' !", СтатусСообщения.Важное);
		КонецЕсли;
	КонецЕсли;
	
	Дата = ТекущаяДата();
	
	ЗаписатьДокОснованиеВТЧ();
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	
	рПроверки = лМожноЗаписатьДокумент();
	Если Не рПроверки.Успешно Тогда
		ТекстОшибки = СтрСоединить(рПроверки.Ошибки, Символы.ПС);
		ЗаписатьВЛог("ОбменДанными", ТекстОшибки, "Ошибка");
		Отказ = Истина;                         
		ВызватьИсключение ТекстОшибки;
		Возврат;
	КонецЕсли;
	
	ЕстьИзменения	= Модифицированность();
	
	Если ЭтоНовый() Тогда
		БылСтатус = ПолучитьРеквизитШапки(Ссылка, "Статус");
	Иначе		
		БылСтатус = ПолучитьРеквизитШапки(Ссылка, "Статус");
		Если ЗначениеЗаполнено(БылСтатус) И БылСтатус = Перечисления.СтатусыДокументовМаркировки.Обработан И ЕстьИзменения Тогда
			Если НЕ РольДоступна("Администратор") Тогда			
				Отказ = Истина;
				ТекстСообщения = СтрШаблон("Документ %1 уже обработан, изменения документа запрещены !", Ссылка);
				ВызватьИсключение ТекстСообщения;
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;	
	ДополнительныеСвойства.Вставить("БылСтатус", БылСтатус);
	
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	
	Если ЭтоНовый() ИЛИ НЕ ЗначениеЗаполнено(КодУзлаСоздания) Тогда
		КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код();		
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
		Если Маркировка_ПИ.ТипТекущегоУзла() <> Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ВызватьИсключение "Бронирование кодов маркировки разрешено только в ЦО !";	
		КонецЕсли;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВводВОборот Тогда
		Если ЗначениеЗаполнено(ТипШК) Тогда
			ТипШК = Неопределено;		
		КонецЕсли;
		//++Данилова Е.В. 19.02.2025 MARK-1454
		Если Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе 
			И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
			СтруктураДанныхПоТоварам = ПроверитьГотовыеКомплектыВДокументе(Товары.Выгрузить()); 
			Если СтруктураДанныхПоТоварам.ГотовыеКомплекты  
				И СтруктураДанныхПоТоварам.НеГотовыеКомплекты Тогда  			  
				
				ВызватьИсключение "Необходимо выделить готовые наборы в отдельный документ"; 
				
			КонецЕсли;
		КонецЕсли; 
		//--Данилова Е.В. 19.02.2025
	//++Данилова Е.В. 11.06.2026 №0000001162
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВыводИзОборота И РежимЗаписи
		= РежимЗаписиДокумента.Проведение Тогда
		Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа Или ВидОперацииИСМП
			= Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоОбразцам Или ВидОперацииИСМП
			= Перечисления.ВидыОперацийИСМП.ВыводИзОборота_РозничнаяПродажа Тогда
			КПППодразделения  = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ПодразделениеНанесения,"КПП");
			ИдентификаторФИАС = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ПодразделениеНанесения,"ИдентификаторФИАС"); 
			ТекстОшибки = ""; 
			Если Не ЗначениеЗаполнено(КПППодразделения) Тогда
				ТекстОшибки = СтрШаблон(
					"Поле КПП у подразделения нанесения %1 не заполнено. Провести документ невозможно.",
					ПодразделениеНанесения) + Символы.ПС;
			КонецЕсли;

			Если Не ЗначениеЗаполнено(ИдентификаторФИАС) Тогда
				ТекстОшибки = ТекстОшибки + СтрШаблон(
					"Поле Идентификатор ФИАС у подразделения нанесения %1 не заполнено. Провести документ невозможно.",
					ПодразделениеНанесения) + Символы.ПС;
			КонецЕсли;
			 
		    Если ЗначениеЗаполнено(ТекстОшибки) Тогда 
		    	Отказ = Истина;
		    	Сообщить(ТекстОшибки);
				Возврат; 
		    КонецЕсли;		   
		КонецЕсли;
		//--Данилова Е.В. 11.06.2026 
	КонецЕсли; 
		
	НужноВыгружать	= НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления)
		И (
			Статус = Перечисления.СтатусыДокументовМаркировки.Обработан
			ИЛИ Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
		);
	
	ДополнительныеСвойства.Вставить("НужноВыгружать", НужноВыгружать);
	
	Если ЕстьИзменения Тогда		
		ЗаполнитьТоварыПоКМ();
		
		ГруппыТоваров		= ГруппыТоваровДокумента(ЭтотОбъект);
		
		КоличествоДокумента = Товары.Итог("Количество");	
		Если ШтрихкодыУпаковок.Количество() > 0 Тогда
			КоличествоКодовSSCC	= ПолучитьКоличествоУникальныхКодовВКолонке("КодАгрегации");		
		КонецЕсли;
	КонецЕсли;        
	
	Если НужноВыгружать Тогда
		Документы.МаркировкаТоваровИСМП.УстановитьПолучателейИзменений(ЭтотОбъект);		
	КонецЕсли;
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	
	ИмяПланаОбмена = "Основной";
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.ФормированиеНабора Тогда	
		ПроверитьОбновитьСтатусЗаданияНаСборку();
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
		Документы.МаркировкаТоваровИСМП.ЗарегистрироватьИспользованныеКоробки(Ссылка);
		
		Если КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код(ИмяПланаОбмена)
			И (ОбработанВпервые() ИЛИ СтатусВпервые(Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки)) Тогда
			УстановитьПолучателейКоробок();
		КонецЕсли; 	 
	Иначе
		Документы.МаркировкаТоваровИСМП.ОчиститьИспользованныеКоробки(Ссылка);		
	КонецЕсли; 	
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.ВводВОборот Тогда
		Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ОбновитьСтатусЗаказНаЭмиссию();
			Если ОбработанВпервые() Тогда        
				УзелПолучатель = ОпределитьПолучателяКодов();
				Если ЗначениеЗаполнено(УзелПолучатель) Тогда				
					ЗарегистрироватьКодыДляПолучателя(УзелПолучатель);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		//Валетов+10,06,2025 КТО-ТО ЗАТЕР)) ПУСТАЯ ЗАДАЧА
		//Регистрация Готовых Наборов для ЕКат    
		//Валетов + 09,12,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3361 Добавил перемаркировку
	ИначеЕсли (ВидОперации = Перечисления.ВидыОперацийМаркировки.ФормированиеНабора 
		ИЛИ ВидОперации = Перечисления.ВидыОперацийМаркировки.Перемаркировка)
		//Валетов - 
		И Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		ОбновитьСтатусЗаказНаЭмиссию();
		Если ОбработанВпервые() Тогда        
			УзелПолучатель = ОпределитьПолучателяКодов();
			Если ЗначениеЗаполнено(УзелПолучатель) Тогда 
				//Валетов + 09,10,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3083
				//Если УзелПолучатель.ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда	
				ЗарегистрироватьКодыДляПолучателяСНаборами(УзелПолучатель);
				//КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	//++Данилова Е.В. 25.05.2026 MARK-3615
	//++Данилова Е.В. 13.03.2026 MARK-3512 
	//Если Модифицированность() Тогда
	Если ЕстьИзменения Тогда
	//--Данилова Е.В. 25.05.2026 	
		Если ТипШК = Перечисления.ТипыШтрихКодов.Коробка 
			И (ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация 
			И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КонтрактСПроизводителем")) 
			ИЛИ (ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов 
			И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику")) тогда
			
			ОбменДаннымиПоAPI_ТСД.ЗаписатьВФонеДатуИзмененияЗаказовДляТСД(ДокументОснование); 
			
			
		КонецЕсли;	
		
	КонецЕсли;
	//--Данилова Е.В. 13.03.2026 
	//++Данилова Е.В. 25.05.2026 MARK-3615
	Если Проведен И ОбработанВпервые() Тогда
		ДокПеремаркировки = Документы.Перемаркировка.ОтработкаПоПеремаркировке(ДокументОснование);
		Если ДокПеремаркировки <> Неопределено Тогда
			РезультатПроверки = Документы.Перемаркировка.ВсеДокументыЧЗОтработаны(ДокПеремаркировки);
			
			Если РезультатПроверки.Успешно Тогда
				
				//ИдентификаторФЗ = Новый УникальныйИдентификатор;
				//МаркировкаС.ИзменитьСтатусПеремаркировкиВФоне(ДокПеремаркировки, ИдентификаторФЗ);
                документы.Перемаркировка.УстановитьСтатусПеремаркировки(ДокПеремаркировки,Перечисления.СтатусыПеремаркировки.ОбработаноЧЗ); 
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	//--Данилова Е.В. 25.05.2026 
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Статус			= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
	Автор 			= ПараметрыСеанса.Пользователь;
	ИД_ДокументаЧЗ	= Неопределено;
	ТекстОшибки		= "";
	Комментарий		= "";
	КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код();
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация
		ИЛИ ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
		
		Товары.Очистить();	
		ШтрихкодыУпаковок.Очистить();	
	КонецЕсли; 
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт                     
	рПроверки = МожноПроводитьДокументВЭтомУзле();
	Если НЕ рПроверки.Успешно Тогда 
		Отказ = Истина;
		ВызватьИсключение СтрСоединить(рПроверки.Ошибки, Символы.ПС); 		 
	КонецЕсли;            
	
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация Тогда		
		Если Статус = Перечисления.СтатусыДокументовМаркировки.Обработан 
			ИЛИ Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки Тогда
			
			Если КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код() Тогда
				Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
					Документы.МаркировкаТоваровИСМП.ПроверитьЗаполнитьСоставАгрегационныхКодов(Ссылка);
				ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда  //MARK-2937 Заполнение состава агрегаций, сделанных на основании ЗНМ в статусе "ожидание отложенной обработки"
					РегистрыСведений.ЗадачиОтложеннойОбработкиДокументов.СоздатьЗадачу(Ссылка, Перечисления.ЗадачиОтложеннойОбработкиДокументов.ЗаполнитьСоставАгрегаций, Новый Структура("Порядок", -1));					
				ИначеЕсли  ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") //MARK-2520 Заполнить вложения пустых импортных коробов
					ИЛИ ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
					РегистрыСведений.ЗадачиОтложеннойОбработкиДокументов.СоздатьЗадачу(Ссылка, Перечисления.ЗадачиОтложеннойОбработкиДокументов.ЗаполнитьСоставАгрегаций, Новый Структура("Порядок", -1));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
		Если Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке Тогда
			рПроверки = ПроверитьЗабронироватьКодыАгрегации();
			Если НЕ рПроверки.Успешно Тогда
				Отказ = Истина;
				Сообщить(СтрСоединить(рПроверки.Ошибки, Символы.ПС), СтатусСообщения.Важное);
			КонецЕсли;		
		КонецЕсли;	
	КонецЕсли;	
	
	Движения_СтатусыКМ_Факт 	= Движения.СтатусыКМ_Факт;
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки Тогда 
		//Валетов + https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3317   Было
		//Если Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
		Если Статус = Перечисления.СтатусыДокументовМаркировки.Обработан ИЛИ Статус = Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ Тогда
			СформироватьДвиженияРазАгрегации(Движения_СтатусыКМ_Факт);
		КонецЕсли;
	КонецЕсли;
	
	//Статус распечатан по коробкам //Чирков - на всякий пожарный - Леша и Яна любят играться со статусами документов	
	Для Каждого СтрокаТЧ Из МаркировкаС.ПолучитьДанныеКоробок(Ссылка, "ШтрихкодыКоробок") Цикл
		Если СтрокаТЧ.ДатаДобавления = Дата Тогда
			ДатаДобавления = Дата - 2;
		ИначеЕсли СтрокаТЧ.ДатаДобавления = Дата - 1 Тогда
			ДатаДобавления = Дата - 2;			
		Иначе
			ДатаДобавления = СтрокаТЧ.ДатаДобавления;
		КонецЕсли; 		
		
		//СтатусыКМ_Факт
		Движение = Движения_СтатусыКМ_Факт.Добавить();				
		
		Движение.Период 			= ?(ЗначениеЗаполнено(ДатаДобавления), ДатаДобавления, Дата-2);
		
		Движение.ШтрихКодУпаковки	= СтрокаТЧ.ШтрихкодКоробки;
		Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.Распечатан;
		Движение.Местонахождение	= ПодразделениеНанесения;				
		
		//СтатусыКМ_Факт_А
		Движение = Движения.СтатусыКМ_Факт_А.Добавить();				
		
		Движение.Период 			= ?(ЗначениеЗаполнено(ДатаДобавления), ДатаДобавления, Дата-2);
		
		Движение.ШтрихКодУпаковки	= СтрокаТЧ.ШтрихкодКоробки;
		Движение.СпособВводаВОборот = СтрокаТЧ.СпособВводаВОборот;
		//+++Чирков 01.12.2025 ТипУпаковки - убираем
		//Движение.ТипУпаковки		= СтрокаТЧ.ТипУпаковки;		
		//---Чирков 01.12.2025
		Движение.ТипШК				= СтрокаТЧ.ТипШК;
		
		Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.Распечатан;
		Движение.Местонахождение	= ПодразделениеНанесения;
	КонецЦикла;
	
	Если Статус <> Перечисления.СтатусыДокументовМаркировки.Обработан Тогда 
		Движения.СтатусыКМ_ЧЗ.Очистить();
		
		Если Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки Тогда			
			ЭтоОфис = (Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение);
			Если ЭтоОфис И ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
				Местонахождение = ОпределитьМестонахождениеПоОснованию();			
				
				тКоробок = МаркировкаС.ПолучитьДанныеКоробок(Ссылка, "ШтрихКодыУпаковок");
				Для Каждого СтрокаКоробки Из тКоробок Цикл
					//Движения_СтатусыКМ_Факт
					Движение					= Движения_СтатусыКМ_Факт.Добавить();
					
					Движение.Период				= Дата;
					
					Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихКодКоробки;
					
					Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.ПереданПоставщику;
					Движение.Местонахождение	= Местонахождение;				
					Движение.ВПути 				= Истина;
					
					
					//Движения.СтатусыКМ_Факт_А
					Движение					= Движения.СтатусыКМ_Факт_А.Добавить();
					
					Движение.Период				= Дата;
					
					Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихКодКоробки;
					Движение.ТипШК				= СтрокаКоробки.ТипШК;
					Движение.СпособВводаВОборот	= СтрокаКоробки.СпособВводаВОборот;
					//+++Чирков 01.12.2025 ТипУпаковки - убираем
					//Движение.ТипУпаковки		= СтрокаКоробки.ТипУпаковки;
					//---Чирков 01.12.2025
					
					Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.ПереданПоставщику;
					Движение.Местонахождение	= Местонахождение;				
					Движение.ВПути 				= Истина;					
				КонецЦикла;				
			КонецЕсли;
		КонецЕсли;
		
		//ЗаписатьДвиженияВРегистр_СтатусыКМ_Факт(Движения_СтатусыКМ_Факт);
		//МаркировкаС.ЗаписатьДвиженияВРегистр_СтатусыКМ_Факт_А(ЭтотОбъект, "МаркировкаТоваровИСМП.ЗаписатьДвиженияВРегистр_СтатусыКМ_Факт");
		МаркировкаКС.СохранитьОтложенныеДвижения(ЭтотОбъект, Отказ);
		
		Возврат;
	КонецЕсли;
		
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация Тогда
		
		НЗ_ИСМП 		= Движения.СтатусыКМ_ЧЗ;
		
		Местонахождение = ОпределитьМестонахождениеПоОснованию();
		
		ЭтоОфис			= (Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение);	
		СтатусКМ_Факт 	= ?(ЭтоОфис, Перечисления.СтатусыКодовМаркировкиФакт.Эмитирован, Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте);
		ВПути			= (ЭтоОфис И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику"));
		
		ЭтоМаркировкаОстатков = (ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаданиеНаМаркировку"));
		
		тКоробок = МаркировкаС.ПолучитьДанныеКоробок(Ссылка, "ШтрихкодыУпаковок");
		Для Каждого СтрокаКоробки Из тКоробок Цикл
			//Статусы ЧЗ
			Движение = НЗ_ИСМП.Добавить();
			
			Движение.Период 			= Дата;
			Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихКодКоробки;
			Движение.Статус				= Перечисления.СтатусыКодовМаркировкиИСМП.Эмитирован;
			
			//Статусы факт
			Если НЕ ЭтоМаркировкаОстатков Тогда     
				//Движения_СтатусыКМ_Факт
				Движение					= Движения_СтатусыКМ_Факт.Добавить();
					
				Движение.Период				= Дата;
				Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихКодКоробки;
				Движение.Статус				= СтатусКМ_Факт;
				Движение.Местонахождение	= Местонахождение;				
				
				Движение.ВПути 				= ВПути;				
				
				//Движения.СтатусыКМ_Факт_А
				Движение					= Движения.СтатусыКМ_Факт_А.Добавить();
				
				Движение.Период				= Дата;
				
				Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихКодКоробки;
				Движение.ТипШК				= СтрокаКоробки.ТипШК;
				Движение.СпособВводаВОборот	= СтрокаКоробки.СпособВводаВОборот;
				//+++Чирков 01.12.2025 ТипУпаковки - убираем
				//Движение.ТипУпаковки		= СтрокаКоробки.ТипУпаковки;
				//---Чирков 01.12.2025
				
				Движение.Статус				= СтатусКМ_Факт;
				Движение.Местонахождение	= Местонахождение;				
				
				Движение.ВПути 				= ВПути;
			КонецЕсли;			
		КонецЦикла;
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки Тогда
		
		НЗ_ИСМП = Движения.СтатусыКМ_ЧЗ;
		
		Для Каждого ШтрихКодКоробки Из ПолучитьШтрихКодыКоробок() Цикл			
			Движение = НЗ_ИСМП.Добавить();
				
			Движение.Период 			= Дата;
			Движение.ШтрихКодУпаковки	= ШтрихКодКоробки;
			Движение.Статус				= Перечисления.СтатусыКодовМаркировкиИСМП.Расформирован;			
		КонецЦикла;
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ФормированиеНабора Тогда
		//+++Чирков 11.08.2025
		Если КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код() Тогда
			РегистрыСведений.ЗадачиОтложеннойОбработкиДокументов.СоздатьЗадачу(Ссылка,
				Перечисления.ЗадачиОтложеннойОбработкиДокументов.ЗаполнитьСоставНаборов, Новый Структура("Порядок", -1));
		КонецЕсли;
		//---Чирков 11.08.2025
		
		НЗ_ИСМП 			= Движения.СтатусыКМ_ЧЗ;
		НЗ_СтатусыКМ_Факт	= Движения_СтатусыКМ_Факт;
		//++Данилова Е.В. 26.03.2025
		НЗ_СтатусыКМ_Факт_Пропускать = Ложь; 
		//--Данилова Е.В. 26.03.2025
		Местонахождение = Неопределено;
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
			Местонахождение = ПолучитьРеквизитШапки(ДокументОснование, "ПодразделениеНанесения");
			//++Данилова Е.В. 26.03.2025
			Если ДокументОснование.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда
				
				НЗ_СтатусыКМ_Факт_Пропускать = Истина; 	
				//Валетов + https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3032	
				Для каждого СтрТЧ Из ШтрихкодыУпаковок Цикл
					Движение = НЗ_СтатусыКМ_Факт.Добавить();
					
					Движение.Период 			= Дата;
					Движение.ШтрихКодУпаковки	= СтрТЧ.ШтрихкодУпаковки;				
					Движение.ТипШК				= СтрТЧ.ШтрихкодУпаковки.ТипШК;
					Движение.Номенклатура		= СтрТЧ.ШтрихкодУпаковки.Владелец;
					Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально;				
					
					Движение.Местонахождение 	= Местонахождение;  
				КонецЦикла; 
				//Валетов -
			КонецЕсли;
			//--Данилова Е.В. 26.03.2025  
			
			//Валетов + https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3032 
			//Пропускаем запись по кодам наборов, делаем запись по кодам комплектующих в статусе "нанесен виртуально"
		ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
			Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
				Местонахождение = ПолучитьРеквизитШапки(ДокументОснование, "Подразделение");  
			Иначе 
