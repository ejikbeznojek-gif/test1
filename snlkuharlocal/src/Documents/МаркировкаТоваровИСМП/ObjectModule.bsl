Функция УстановитьПолучателейКоробок() Экспорт
	ИмяПланаОбмена = "ДанныеЧЗ";
	ТипУзла = Маркировка_ПИ.ТипТекущегоУзла(ИмяПланаОбмена);
	
	Получатели = Новый Массив;
	Если ТипУзла = Перечисления.ТипУзлаИБ.Склад
		ИЛИ ТипУзла = Перечисления.ТипУзлаИБ.Филиал Тогда
		Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.УправляющееПодразделение, ИмяПланаОбмена);
	ИначеЕсли ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.Склад, ИмяПланаОбмена);
		ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Перемещение") Тогда
			Получатели = Документы.МаркировкаТоваровИСМП.ПолучателиПеремещения(ЭтотОбъект);			
		КонецЕсли;
	КонецЕсли;
	     
	Если Получатели.Количество() > 0 Тогда		
		КодыКоробок = ПолучитьШтрихКодыКоробок();		
		Если КодыКоробок.Количество() > 0 Тогда
			ОбменДаннымиЧЗ.УстановитьПолучателей(Получатели, КодыКоробок);		
		КонецЕсли;		
	КонецЕсли; 
КонецФункции //УстановитьПолучателейКоробок() Экспорт


Функция ОбработанВпервые()
	Возврат СтатусВпервые(Перечисления.СтатусыДокументовМаркировки.Обработан);
КонецФункции //ОбработанВпервые()

Функция СтатусВпервые(ПроверяемыйСтатус)
	Результат = Ложь;
	БылСтатус = МаркировкаКС.ПолучитьЗначениеПараметра(ДополнительныеСвойства, "БылСтатус");
	Если Статус = ПроверяемыйСтатус И БылСтатус <> Статус Тогда
		Результат = Истина;		
	КонецЕсли;
	Возврат Результат;	
КонецФункции //СтатусВпервые()

Процедура ЗарегистрироватьКодыДляПолучателя(УзелПолучатель)			
	
	ТипУзлаПолучателя = ПолучитьРеквизитШапки(УзелПолучатель, "ТипУзла");
	Если ТипУзлаПолучателя <> Перечисления.ТипУзлаИБ.Склад Тогда				
		мКоды = Новый Массив;				
		Для каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодУпаковки) Тогда
				мКоды.Добавить(СтрокаТЧ.ШтрихкодУпаковки); 			
			КонецЕсли; 		
		КонецЦикла;                      
		ОбменДаннымиЧЗ.УстановитьПолучателей(УзелПолучатель, мКоды);
		
		НЗ = РегистрыСведений.СтатусыКМ_ЧЗ.СоздатьНаборЗаписей();
		НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
		
		ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, НЗ);				
		
		НЗ = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
		НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
		
		ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, НЗ);				
	КонецЕсли;

	//Ввод в оборот тоже отправляем (чтобы можно было сверить реестры) 
	ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, Ссылка);	
КонецПроцедуры

Процедура ЗарегистрироватьКодыКоробокДляПолучателя()
	ИмяПланаОбмена = "ДанныеЧЗ";
	
	Если ЗначениеЗаполнено(ПодразделениеНанесения) И ТипЗнч(ПодразделениеНанесения) = Тип("СправочникСсылка.Подразделения") Тогда
		УзелПолучатель	= Маркировка_ПИ.УзелПодразделения(ПодразделениеНанесения, ИмяПланаОбмена);
		Если ЗначениеЗаполнено(УзелПолучатель) И УзелПолучатель <> Маркировка_ПИ.ЭтотУзел(ИмяПланаОбмена) Тогда
		    ТипУзла = ПолучитьРеквизитШапки(УзелПолучатель, "ТипУзла");
			Если ТипУзла <> Перечисления.ТипУзлаИБ.Склад Тогда			
				Для каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл
					Если ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодУпаковки) Тогда
						ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, СтрокаТЧ.ШтрихкодУпаковки); 			
					КонецЕсли; 		
				КонецЦикла;
				
				НЗ = РегистрыСведений.СтатусыКМ_ЧЗ.СоздатьНаборЗаписей();
				НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
				
				ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, НЗ);
				
				
				НЗ = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
				НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
				
				ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, НЗ);
			КонецЕсли;		
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

Процедура ПроверитьОбновитьСтатусЗаданияНаСборку()
	Если Проведен Тогда
		Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ") Тогда
			СтатусЗаданияНаСборку = ПолучитьРеквизитШапки(ДокументОснование, "СтатусОбработкиЧЗ");
			Если СтатусЗаданияНаСборку <> Статус Тогда
				Задание = ДокументОснование.ПолучитьОбъект();
				
				Задание.СтатусОбработкиЧЗ		= Статус;
				Задание.ОбменДанными.Загрузка	= Истина;
				
				Задание.Записать(РежимЗаписиДокумента.Запись);
				#ЕСЛИ КЛИЕНТ ТОГДА
				ОповеститьОбИзменении(ДокументОснование);
				#КОНЕЦЕСЛИ
			КонецЕсли;					
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры  //ПроверитьОбновитьСтатусЗаданияНаСборку()

Функция ОпределитьМестонахождениеПоОснованию()
	Результат		= ПодразделениеНанесения;
	ТипОснования	= ТипЗнч(ДокументОснование); 
	
	Если ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументОснование, "Контрагент");
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументОснование, "Склад.Подразделение");	
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументОснование, "Склад.Подразделение");	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ОпределитьПоследнееМестонахождение()
 
Процедура ЗарегистрироватьИзменения_ШК(Получатели)
	НужноВыгружать = Ложь;
	
	Если НЕ (ДополнительныеСвойства.Свойство("НужноВыгружать", НужноВыгружать) И НужноВыгружать) Тогда Возврат КонецЕсли; 
		
	Если Получатели.Количество()>0 Тогда
		Для Каждого СтрокаШК Из ШтрихкодыУпаковок Цикл
			ПланыОбмена.ЗарегистрироватьИзменения(Получатели, СтрокаШК.ШтрихкодУпаковки); 
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры //ЗарегистрироватьИзменения()

Процедура ЗарегистрироватьИзменения_Статусы(Получатели)
	НужноВыгружать = Ложь;
	
	Если НЕ (ДополнительныеСвойства.Свойство("НужноВыгружать", НужноВыгружать) И НужноВыгружать) Тогда Возврат КонецЕсли; 
		
	Если Получатели.Количество()>0 Тогда					
		ПланыОбмена.ЗарегистрироватьИзменения(Получатели, Движения.СтатусыКМ_ЧЗ);
		ПланыОбмена.ЗарегистрироватьИзменения(Получатели, Движения.СтатусыКМ_Факт);		
	КонецЕсли;
КонецПроцедуры //ЗарегистрироватьИзменения_Статусы()
 
Функция ОпределитьПолучателей()
	ИмяПланаОбмена	= "ДанныеЧЗ";
	Получатели		= Новый Массив;
	
	Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда	
		Если ЗначениеЗаполнено(ПодразделениеНанесения) Тогда
			Если ТипЗнч(ПодразделениеНанесения) = Тип("СправочникСсылка.Подразделения") Тогда
				УзелПодразделения = Маркировка_ПИ.УзелПодразделения(ПодразделениеНанесения, ИмяПланаОбмена);
				Если ЗначениеЗаполнено(УзелПодразделения) Тогда
					Получатели.Добавить(УзелПодразделения);
				КонецЕсли;
			КонецЕсли; 			
		КонецЕсли;
	Иначе
		Если СокрЛП(КодУзлаСоздания) = СокрЛП(Маркировка_ПИ.ЭтотУзел_Код()) Тогда
			Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.УправляющееПодразделение, ИмяПланаОбмена);
		КонецЕсли; 
	КонецЕсли;
	
	Получатели2 = Новый Массив;
	ЭтотУзел 	= Маркировка_ПИ.ЭтотУзел(ИмяПланаОбмена);
	
	Для Каждого Получатель Из Получатели Цикл
		Если Получатель <> ЭтотУзел Тогда
			Получатели2.Добавить(Получатель);					
		КонецЕсли;	
	КонецЦикла; 
	
	Возврат Получатели2;
КонецФункции //ОпределитьПолучателей()
 
Функция НайтиСоздатьКодАТК()       
	Результат = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(АТК) И ШтрихкодыУпаковок.Количество()>0 Тогда	
		Менеджер = Справочники.ШтрихкодыУпаковокТоваров;
		Результат = Менеджер.НайтиПоНаименованию(АТК, Истина);
		Если Результат.Пустая() Тогда
			КодАТК 				= Менеджер.СоздатьЭлемент();					
			КодАТК.Наименование = СокрЛП(АТК);
		Иначе                                               
			КодАТК 				= Результат.ПолучитьОбъект();
		КонецЕсли;
		
		КодАТК.ЗначениеШтрихкода = АТК;
		КодАТК.ТипКода 		= Перечисления.ТипыКодовМаркировки.АТК;
		КодАТК.Владелец		= Товары[0].Номенклатура;
		
		КодАТК.СпособВводаВОборот	= Перечисления.СпособыВводаВОборотСУЗ.Импорт;		
		
		КодАТК.Партия		= ДокументОснование;
		КодАТК.Количество	= ШтрихкодыУпаковок.Количество();
		
		Попытка
			КодАТК.Записать();
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
			
		Результат = КодАТК.Ссылка;		
	КонецЕсли;        
	
	Возврат Результат;
КонецФункции //НайтиСоздатьКодАТК()

Функция ПроверитьСоздатьКодыАгрегации()
	Запрос 		= Документы.МаркировкаТоваровИСМП.СоздатьЗапрос_АгрегационныеКодыПоОперации(Ссылка);	
	рЗапроса 	= Запрос.Выполнить();	
	
	Выборка_КодАгрегации = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "КодАгрегации");	
	
	Пока Выборка_КодАгрегации.Следующий() Цикл
		КодАгрегации = СокрЛП(Выборка_КодАгрегации.КодАгрегации);
		Если КодАгрегации = "9999" Тогда Продолжить КонецЕсли; 
		
		Если Выборка_КодАгрегации.КМ_Коробка = NULL Тогда				
			СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();				
			
			СпрОбъект.Наименование		= КодАгрегации;
			СпрОбъект.ЗначениеШтрихкода	= КодАгрегации;
			
			СпрОбъект.Владелец		= Выборка_КодАгрегации.Номенклатура;
			СпрОбъект.ТипУпаковки	= ?(Выборка_КодАгрегации.КоличествоНоменклатуры>1, Перечисления.ТипыУпаковок.МультитоварнаяУпаковка, Перечисления.ТипыУпаковок.МонотоварнаяУпаковка);
			СпрОбъект.ТипКода 		= Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка;
			СпрОбъект.ТипШК			= Перечисления.ТипыШтрихКодов.Коробка;				
			СпрОбъект.СпособВводаВОборот = Выборка_КодАгрегации.СпособВводаВОборот;
			
			СпрОбъект.Количество	= Выборка_КодАгрегации.КМ_Штука;             				
			
			СпрОбъект.ЗаказКМ		= Выборка_КодАгрегации.ДокАгрегации;
			СпрОбъект.Партия		= ДокументОснование;
			
			Выборка 				= Выборка_КодАгрегации.Выбрать();				
			Пока Выборка.Следующий() Цикл
				СтрокаПК = СпрОбъект.ВложенныеШтрихкоды.Добавить();				
				СтрокаПК.Штрихкод = Выборка.КМ_Штука;
			КонецЦикла; 
			
			СпрОбъект.Записать();
			
			ТекКодКоробки = СпрОбъект.Ссылка;				
		Иначе
			ТекКодКоробки = Выборка_КодАгрегации.КМ_Коробка;
		КонецЕсли;		 
	КонецЦикла;
	
	Если ЕстьНеЗаполненныеКодыКоробок() Тогда
		ПрописатьКодыКоробокВТЧ(); 	
	КонецЕсли;
КонецФункции //ПроверитьСоздатьКодыАгрегации()

Функция ЕстьНеЗаполненныеКодыКоробок()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	КодАгрегации,
	|	ШтрихкодКоробки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И КодАгрегации <> """"
	|	И ШтрихкодКоробки = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Количество() > 0);
КонецФункции //ЕстьНеЗаполненныеКодыКоробок() 

Процедура ПрописатьКодыКоробокВТЧ()
	КодыАгрегации = ПолучитьКодыАгрегации();
	
	сШтрихКодыКоробок = Новый Соответствие;	
	
	Для Каждого СтрокаКА Из КодыАгрегации Цикл
		Если ЗначениеЗаполнено(СтрокаКА.ШтрихкодУпаковки) Тогда				
			сШтрихКодыКоробок[СтрокаКА.КодАгрегации] = СтрокаКА.ШтрихкодУпаковки;
		КонецЕсли;				
	КонецЦикла;
	
	НадоЗаписать = Ложь;
	Для Каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.КодАгрегации) И НЕ ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодКоробки)  Тогда
			ШтрихкодКоробки = сШтрихКодыКоробок[СтрокаТЧ.КодАгрегации];
			Если ЗначениеЗаполнено(ШтрихкодКоробки) Тогда			
				СтрокаТЧ.ШтрихкодКоробки = ШтрихкодКоробки;
				НадоЗаписать = Истина;
			КонецЕсли;
		КонецЕсли; 			
	КонецЦикла;
	
	Если НадоЗаписать Тогда
		Записать(РежимЗаписиДокумента.Запись);	
	КонецЕсли; 
КонецПроцедуры //ПрописатьКодыКоробокВТЧ()
 

Функция ПроверитьЗабронироватьКодыАгрегации()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ШтрихкодыУпаковок.Количество() = 0 Тогда //Бронируем номера
		НомерКА	= Документы.МаркировкаТоваровИСМП.ПолучитьПоследнийКодАгрегации(Организация);
		ГЛН		= Лев(Справочники.КодыGLN.ПолучитьДействующийГЛН(Организация), 9);
		
		Для Сч = 1 По КоличествоКодовSSCC Цикл
			СтрокаТЧ = ШтрихкодыУпаковок.Добавить();	
			СтрокаТЧ.КодАгрегации = Документы.МаркировкаТоваровИСМП.СформироватьSSCC(ГЛН, НомерКА + Сч); 
		КонецЦикла;
		
		Записать();
	КонецЕсли;
	
	//Записываем в справочник
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ТЧ.НомерСтроки		КАК НомерСтроки,
	|	ТЧ.КодАгрегации		КАК КодАгрегации,
	|	Спр.Ссылка			КАК КМ_Ссылка
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ТЧ
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	Справочник.ШтрихкодыУпаковокТоваров КАК Спр
	|ПО
	|	ТЧ.КодАгрегации		= Спр.Наименование
	|	И Спр.ЗаказКМ		= ТЧ.Ссылка		
	|ГДЕ
	|	ТЧ.Ссылка = &Ссылка	
	|";
	
	Успешно = Истина;
	
	НачатьТранзакцию();
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.КМ_Ссылка = Null Тогда
			Попытка
				КМ_Ссылка = СоздатьКодАгрегации(Выборка.КодАгрегации);
			Исключение
				Результат.Успешно = Ложь;
				Результат.Ошибки.Добавить(ОписаниеОшибки());
			КонецПопытки;			
		Иначе		
			КМ_Ссылка = Выборка.КМ_Ссылка;
		КонецЕсли; 		
		
		ТекСтрока = ШтрихкодыУпаковок[Выборка.НомерСтроки-1];
		Если ТекСтрока.ШтрихкодУпаковки.Пустая() Тогда
			ТекСтрока.ШтрихкодУпаковки = КМ_Ссылка;		
		КонецЕсли;
	КонецЦикла;
	
	Если Результат.Успешно Тогда
		Если Статус <> Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
			Статус = Перечисления.СтатусыДокументовМаркировки.Обработан;		
		КонецЕсли; 
		Если Модифицированность() Тогда
			Записать();	
		КонецЕсли; 	
		ЗафиксироватьТранзакцию();	
	КонецЕсли;
	
	//Валетов + 03,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3468 
	Если Статус = Перечисления.СтатусыДокументовМаркировки.Обработан И ОбработанВпервые() Тогда
		УзелПолучатель = ОпределитьПолучателяКодов();
		
		ТипУзлаПолучателя = ПолучитьРеквизитШапки(УзелПолучатель, "ТипУзла");
		Если ТипУзлаПолучателя = Перечисления.ТипУзлаИБ.Склад Тогда
			
			ЗаписиСтатусовФакт = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
			ЗаписиСтатусовФакт.Отбор.Регистратор.Установить(Ссылка, Истина);
			
			ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, ЗаписиСтатусовФакт);	
			ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, Ссылка);
		КонецЕсли;  
	КонецЕсли;
    //Валетов -
		
	Возврат Результат;	
КонецФункции //ПроверитьСоздатьКодыАгрегации()

Функция СоздатьКодАгрегации(КодАгрегации)
	СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();				
				
	СпрОбъект.Наименование		= СокрЛП(КодАгрегации);
	СпрОбъект.ЗначениеШтрихкода	= СокрЛП(КодАгрегации);		
	
	СпрОбъект.ТипУпаковки			= ТипУпаковки;
	СпрОбъект.ТипКода 				= Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка;
	СпрОбъект.ТипШК					= ТипШК;	
	//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	СпрОбъект.СпособВводаВОборот	= ?(фКодыАгрегацийДляПоставщиков, Перечисления.СпособыВводаВОборотСУЗ.Импорт, Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков);
	//СпрОбъект.СпособВводаВОборот	= ?(фКодыАгрегацийДляПоставщиков, Перечисления.СпособыВводаВОборотСУЗ.Импорт, Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка);
	//Валетов -
	
	СпрОбъект.ЗаказКМ				= Ссылка;
	
	СпрОбъект.ОбменДанными.Загрузка = Истина;
	СпрОбъект.ДополнительныеСвойства.Вставить("ВидОперации", ВидОперации);
	
	СпрОбъект.Записать();
	
	Возврат СпрОбъект.Ссылка;
КонецФункции //СоздатьКодАгрегации(КодАгрегации)

Функция ПолучитьКодыАгрегации()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КодАгрегации
	|ПОМЕСТИТЬ ВТ_КодыАгрегации
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &Ссылка
	|;	
	|ВЫБРАТЬ
	|	ВТ_КодыАгрегации.КодАгрегации   КАК КодАгрегации,
	|	Спр_ШК.Ссылка 					КАК ШтрихкодУпаковки	
	|ИЗ
	|	ВТ_КодыАгрегации
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	Справочник.ШтрихкодыУпаковокТоваров КАК Спр_ШК
	|ПО 
	|	Спр_ШК.Наименование = ВТ_КодыАгрегации.КодАгрегации
	|	И Спр_ШК.ТипУпаковки = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МонотоварнаяУпаковка)
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьКодыАгрегации()

Функция ПолучитьШтрихКодыКоробок()
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ШтрихкодКоробки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок	
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И ШтрихкодКоробки<>ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодКоробки.Наименование
	|";	
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодКоробки");
КонецФункции //ПолучитьШтрихКодыКоробок()

Функция ПолучитьШтрихКодыНаборов()
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ШтрихкодНабора,
	|	ШтрихкодНабора.ТипШК	КАК ТипШК,
	|	ШтрихкодНабора.Владелец КАК Номенклатура,
	|	ШтрихкодНабора.Владелец.Родитель.ВидКомплекта КАК ВидКомплекта		
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок	
	|ГДЕ
	|	Ссылка = &Ссылка	
	|	И ШтрихкодНабора.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодНабора.Наименование
	|";
		
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьШтрихКодыНаборов()

