Функция ЗаполнитьПоЗСБ(ЗаданиеНаСборку) Экспорт	        	
	ВидОперации 	= Перечисления.ВидыОперацийМаркировки.ФормированиеНабора;
	ВидОперацииИСМП	= Перечисления.ВидыОперацийИСМП.ФормированиеНабора;	
	
	Если Организация = Маркировка_ПИ.ОрганизацияБТК() Тогда
		Организация = Маркировка_ПИ.ОрганизацияЕЕЭ();	
	КонецЕсли;
	
	ЗаполнитьШКпоЗСБ(ЗаданиеНаСборку);	
