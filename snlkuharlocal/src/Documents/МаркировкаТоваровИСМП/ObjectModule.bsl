//++Данилова Е.В. 21.05.2026  MARK-3717  
Процедура ОчиститьВложенныеКодыУпаковки()

	Для Каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл		
		ШтрихкодУпаковки =  СтрокаТЧ.ШтрихкодУпаковки;
		Если ШтрихкодУпаковки.ВложенныеШтрихкоды.Количество() > 0  Тогда
			
			ШтрихкодУпаковкиОбъект = ШтрихкодУпаковки.ПолучитьОбъект(); 
			ШтрихкодУпаковкиОбъект.ВложенныеШтрихкоды.Очистить();
			ШтрихкодУпаковкиОбъект.Количество = 0; 
			ШтрихкодУпаковкиОбъект.ОбменДанными.Загрузка = Истина; 
			ШтрихкодУпаковкиОбъект.Записать();
			
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

