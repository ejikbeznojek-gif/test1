Функция ЗаполнитьПоРКМ(РКМ) Экспорт
	ВидОперации 	= Перечисления.ВидыОперацийМаркировки.ВозвратВОборот;
	ТипДокумента	= Перечисления.ТипыДокументовИСМП.ТоварнаяНакладная;
	
	ДокОснование 	= ПолучитьРеквизитШапки(РКМ, "ДокОснование");
	
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		рШапки 			= ПолучитьРеквизитыШапки(ДокОснование, "ДистанционнаяПродажа,Контрагент.СтранаРегистрации,Контрагент.ИННИностранногоКонтрагента,Контрагент.СтранаРегистрации.УчастникЕАЭС,Склад.Подразделение");
		ПодразделениеНанесения = ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла();	
		
		ДистанционнаяПродажа = рШапки.ДистанционнаяПродажа;
		Если ДистанционнаяПродажа Тогда
			ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВозвратВОборот_Возврат_ДистанционнаяПродажа;
		КонецЕсли;	
	КонецЕсли;	
КонецФункции //ЗаполнитьПоРКМ(РКМ) Экспорт

Процедура ЗаполнитьШКпоЛН(ДокСсылка)
	ШтрихкодыУпаковок.Очистить();
	
	мШК = Документы.ХранилищеКодовМаркировки.ПолучитьКМпоЛистамНабора(ДокСсылка, 0);
	
	Для Каждого ШтрихКодУпаковки Из мШК Цикл
		СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
		СтрокаТЧ.ШтрихкодУпаковки = ШтрихКодУпаковки;	
	КонецЦикла;	
КонецПроцедуры

Процедура ЗаполнитьШКпоХКМ(ДокСсылка)
	ШтрихкодыУпаковок.Очистить();
	
	мШК = Документы.ХранилищеКодовМаркировки.ПолучитьКМпоХКМ(ДокСсылка, 0);
	
	Для Каждого ШтрихКодУпаковки Из мШК Цикл
		СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
		СтрокаТЧ.ШтрихкодУпаковки = ШтрихКодУпаковки;	
	КонецЦикла;	
КонецПроцедуры

Процедура ЗаполнитьШКпоЗНМ(ДокСсылка, ДопПараметры)
	УпрощенныйРежим = ПолучитьРеквизитШапки(ДокСсылка, "фУпрощенныйРежим");
	Если УпрощенныйРежим Тогда
		ЗаполнитьШКпоЗНМ_Упр(ДокСсылка, ДопПараметры);
	Иначе
		ЗаполнитьШКпоЗНМ_Обычный(ДокСсылка);
	КонецЕсли;
КонецПроцедуры
	
Процедура ЗаполнитьШКпоЗНМ_Обычный(ДокСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки					КАК ШтрихкодУпаковки,
	|	Ссылка.ШтрихкодКоробки.Наименование КАК КодАгрегации
	|ИЗ
	|	Документ.ЛистМаркировкиОстатков.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокСсылка
	|	И НЕ Ссылка.ЕстьОшибки
	|	И Ссылка.Завершен
	|	И Ссылка.Проведен
	|	И НЕ Ссылка.НеПолный
	|	И Ссылка.ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|УПОРЯДОЧИТЬ ПО
	|	КодАгрегации,
	|	ШтрихкодУпаковки.Наименование	
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	ШтрихкодыУпаковок.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаКМ = ШтрихкодыУпаковок.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаКМ, Выборка);
	КонецЦикла;
КонецПроцедуры //ЗаполнитьШКпоЗНМ(ДокСсылка)  

Процедура ЗаполнитьШКпоЗНМ_Упр(ДокСсылка, ДопПараметры = Неопределено)	
	Запрос = Новый Запрос;
	
	Если ТипШК = Перечисления.ТипыШтрихКодов.Блочок Тогда
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	ШтрихкодУпаковки				КАК ШтрихкодУпаковки,
		|	ШтрихкодБлочка.Наименование 	КАК КодАгрегации,
		|	ШтрихкодБлочка					КАК ШтрихкодКоробки
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
		|ГДЕ
		|	Ссылка = &ДокСсылка
		|	И Ссылка.Проведен	
		|	И ШтрихкодБлочка <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
		|УПОРЯДОЧИТЬ ПО
		|	КодАгрегации,
		|	ШтрихкодУпаковки.Наименование	
		|";			
	ИначеЕсли ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда
		фАгрегироватьБлочки = ПолучитьРеквизитШапки(ДокСсылка, "фАгрегироватьБлочки");
		
		ПолеШК = ?(фАгрегироватьБлочки, "ШтрихкодБлочка", "ШтрихкодУпаковки");
		Запрос.Текст = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	" + ПолеШК + "					КАК ШтрихкодУпаковки,
		|	ШтрихкодКоробки.Наименование 	КАК КодАгрегации,
		|	ШтрихкодКоробки					КАК ШтрихкодКоробки
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
		|ГДЕ
		|	Ссылка = &ДокСсылка
		|	И Ссылка.Проведен	
		|	И ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
		|УПОРЯДОЧИТЬ ПО
		|	КодАгрегации,
		|	" + ПолеШК + ".Наименование	
		|";		
	ИначеЕсли ТипШК = Перечисления.ТипыШтрихКодов.Палета Тогда
		Запрос.Текст = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ШтрихкодКоробки					КАК ШтрихкодУпаковки,
		|	ШтрихкодПалеты.Наименование 	КАК КодАгрегации,
		|	ШтрихкодПалеты					КАК ШтрихкодКоробки
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
		|ГДЕ
		|	Ссылка = &ДокСсылка
		|	И Ссылка.Проведен	
		|	И ШтрихкодПалеты <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
		|УПОРЯДОЧИТЬ ПО
		|	КодАгрегации,
		|	ШтрихкодКоробки.Наименование	
		|";	
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	ШтрихкодыУпаковок.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаКМ = ШтрихкодыУпаковок.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаКМ, Выборка);
	КонецЦикла;
КонецПроцедуры

