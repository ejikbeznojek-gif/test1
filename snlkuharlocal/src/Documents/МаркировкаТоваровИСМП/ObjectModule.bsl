Функция ЗаполнитьТоварыПоНакладной(ДокСсылка, ИмяТЧ = "Товары")
	МетаДок     = ДокСсылка.Метаданные();
	МетаТЧ 		= МетаДок.ТабличныеЧасти[ИмяТЧ];
	КолВсего    = ?(МетаТЧ.Реквизиты.Найти("Всего")<>Неопределено, "Всего", "0");
	
	Товары.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(Количество) КАК Количество,	
	|	ВЫБОР 
	|		КОГДА СУММА(Количество) <> 0 ТОГДА СУММА("+КолВсего+")/СУММА(Количество)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Цена
	|ИЗ
	|	" + МетаДок.ПолноеИмя() + "." + ИмяТЧ + "
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ИМЕЮЩИЕ
	|	СУММА(Количество) > 0
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецФункции //ЗаполнитьТоварыПоНакладной(ДокСсылка)

Функция ОбязательныеРеквизитыДоп()
	Результат = Новый Соответствие;	
	
	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.ВводВОборот Тогда
		Если ЗначениеЗаполнено(ДокументОснование) Тогда
			МетаДок = Метаданные.НайтиПоТипу(ТипЗнч(ДокументОснование));
			Если МетаДок.Реквизиты.Найти("СпособВводаВОборот") <> Неопределено Тогда
				СпособВводаВОборот = ПолучитьРеквизитШапки(ДокументОснование, "СпособВводаВОборот", "Документ"); 
				//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522 Добавил ИЛИ
				Если СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков ИЛИ СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка Тогда			
					Результат["ПодразделениеНанесения"]	= Истина;				
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВыводИзОборота Тогда
		
		Результат["ТипДокумента"]		= Истина;
		Результат["ДокументОснование"]	= Истина;	
		
		Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_БезвозмезднаяПередача Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли; 					
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ВозвратФизическомуЛицу Тогда
			Результат["НаименованиеПервичногоДокумента"] = Истина;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли;
			//++Данилова Е.В. 11.06.2026 №0000001162
			Результат["ПодразделениеНанесения"]	= Истина;
			//--Данилова Е.В. 11.06.2026 	
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ТрансграничнаяПродажаВСтраныЕАЭС Тогда
			Результат["ТипДокумента"]	= Ложь;
			Результат["Страна"]			= Истина;
			Результат["ИмпортерИД"]		= Истина;			
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ИспользованиеДляСобственныхНужд Тогда
			Результат["НаименованиеПервичногоДокумента"] = Истина;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Конфискация Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоОбразцам Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли;
			//++Данилова Е.В. 11.06.2026 №0000001162
			Результат["ПодразделениеНанесения"]	= Истина;
			//--Данилова Е.В. 11.06.2026 
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоГосударственномуКонтракту Тогда
			Результат["ТипДокумента"]				= Ложь;
			Результат["ИдентификаторГосКонтракта"]	= Истина;	
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ПродажаПоСделкеСГосударственнойТайной Тогда	
			Результат["ТипДокумента"]				= Ложь;
			Результат["ИдентификаторГосКонтракта"]	= Истина;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Уничтожение Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Утилизация Тогда
			Результат["НаименованиеПервичногоДокумента"] = Истина;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Утрата Тогда
			Результат["НаименованиеПервичногоДокумента"] = Истина;
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ЭкспортЗаПределыСтранЕАЭС Тогда
			Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
				Результат["НаименованиеПервичногоДокумента"] = Истина;
			КонецЕсли;
		//++Данилова Е.В. 11.06.2026 №0000001162	
		ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_РозничнаяПродажа Тогда
			Результат["ПодразделениеНанесения"]	= Истина;
			//--Данилова Е.В. 11.06.2026 
		КонецЕсли;
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.Списание Тогда 
		
		Результат["ТипДокумента"]		= Ложь;
		Результат["ДокументОснование"]	= Истина;	
		
		Результат["ВидОперацииИСМП"]	= Истина;	
		
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции // ()

Функция СформироватьДвиженияРазАгрегации(Движения_СтатусыКМ_Факт)
	Если Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
		Для Каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл		
			Движение = Движения.СтатусыКМ_ЧЗ.Добавить();				
						
			Движение.Период 			= Дата;
			
			Движение.ШтрихКодУпаковки	= СтрокаТЧ.ШтрихкодУпаковки;
			Движение.Статус				= Перечисления.СтатусыКодовМаркировкиИСМП.Расформирован;			
		КонецЦикла; 	
	КонецЕсли; 
	
	//+++Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	Для Каждого СтрокаШК Из ПолучитьТаблицуШК(Ссылка) Цикл		
		Движение = Движения_СтатусыКМ_Факт.Добавить();				
					
		Движение.Период 			= Дата;
		
		Движение.ТипШК				= СтрокаШК.ТипШК;
		Движение.ШтрихКодУпаковки	= СтрокаШК.ШтрихкодУпаковки;
		
		Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.Расформирован;
		Движение.Местонахождение	= ПодразделениеНанесения;
		
		Движение_Кор = Движения.СтатусыКМ_Факт_А.Добавить();
		ЗаполнитьЗначенияСвойств(Движение_Кор, Движение);
			
		Движение_Кор.СпособВводаВОборот = СтрокаШК.СпособВводаВОборот;
		//+++Чирков 01.12.2025 ТипУпаковки - убираем
		//Движение_Кор.ТипУпаковки 		= СтрокаШК.ТипУпаковки;
		//---Чирков 01.12.2025
	КонецЦикла;                                                
	//---Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	
	//++Данилова Е.В. 16.12.2025  MARK-3379 		
	ВложенныеКодыНаборов = ПолучитьВложенныеКодыПоНаборам();
	Для каждого СтрокаКодов Из ВложенныеКодыНаборов Цикл
		
		Если СтрокаКодов.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Вложен Тогда
			
			//Валетов + 25,12,2025 ПУСТАЯ ЗАДАЧА Делаем наоборот по требованию маркировки.
			//	СтатусКМВложенного = Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати; 	
			//	
			//ИначеЕсли СтрокаКодов.Статус = Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально Тогда
			//	
			//	СтатусКМВложенного = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;     
			СтатусКМВложенного = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;	
		ИначеЕсли СтрокаКодов.Статус = Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально Тогда
			СтатусКМВложенного = Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати;   
			//Валетов -
		Иначе 
			СтатусКМВложенного = СтрокаКодов.Статус; 
		КонецЕсли;
		
		Движение = Движения_СтатусыКМ_Факт.Добавить();				
		
		Движение.Период 			= Дата;
		
		Движение.ТипШК				= СтрокаКодов.ТипШК;
		Движение.ШтрихКодУпаковки	= СтрокаКодов.ШтрихкодУпаковки;
		
		Движение.Статус				= СтатусКМВложенного;
		Движение.Местонахождение	= ПодразделениеНанесения; 		
		
	КонецЦикла;
	//--Данилова Е.В. 16.12.2025 	 
КонецФункции //СформироватьДвиженияРазАгрегации()

Функция ПолучитьКоличествоУникальныхКодовВКолонке(ИмяКолонки)
	Результат = 0;
	КодыКоробок = ШтрихкодыУпаковок.Выгрузить( , ИмяКолонки);
	КодыКоробок.Свернуть(ИмяКолонки);
	КодыКоробок = КодыКоробок.ВыгрузитьКолонку(ИмяКолонки);
	Для каждого мШтрихкодКоробки Из КодыКоробок Цикл
		Если ЗначениеЗаполнено(мШтрихкодКоробки) Тогда
			Результат = Результат + 1;					
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Результат;	
КонецФункции //ПолучитьКоличествоУникальныхКодовВКолонке(ИмяКолонки)

Функция ЗаписатьДвиженияВРегистр_СтатусыКМ_Факт(Движения_СтатусыКМ_Факт)	
	Для Каждого СтрокаТ Из Движения_СтатусыКМ_Факт Цикл
		СтрокаТ.Активность = Истина;	
	КонецЦикла;
	Движения.СтатусыКМ_Факт.Загрузить(Движения_СтатусыКМ_Факт);
	
	Если ОбменДанными.Загрузка Тогда		
		Движения.Записать();
	КонецЕсли; 
КонецФункции

