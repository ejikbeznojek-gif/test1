Функция ЗаполнитьТоварыПоКМ() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_КМ ИЗ &ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	СУММА(1) КАК Количество
	|ИЗ
	|	ВТ_КМ	
	|ГДЕ
	|	ШтрихкодУпаковки.Владелец <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодУпаковки.Владелец
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодУпаковки.Владелец.Наименование
	|";	
	
	Запрос.УстановитьПараметр("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	
	Цены = Новый Соответствие;
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Цена) Тогда
			Цены[СтрокаТЧ.Номенклатура] = СтрокаТЧ.Цена;		
		КонецЕсли;	
	КонецЦикла;
	
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());	
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		СтрокаТЧ.Цена = Цены[СтрокаТЧ.Номенклатура];	
	КонецЦикла; 
КонецФункции

Функция ЗаполнитьШКпоЗаказуНаЭмиссию(ЗаказНаЭмиссию) Экспорт	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	               |ПОМЕСТИТЬ ВТ_ОформленныеКМ
	               |ИЗ
	               |	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	               |ГДЕ
	               |	(МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВОборот)
	               |			ИЛИ МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Перемаркировка))
	               |	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ДокументОснование = &ЗаказНаЭмиссию
	               |	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка <> &Ссылка
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВсеКоды.Ссылка.Владелец КАК Номенклатура,
	               |	ВсеКоды.Ссылка КАК ШтрихкодУпаковки
	               |ИЗ
	               |	Справочник.ШтрихкодыУпаковокТоваров КАК ВсеКоды
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОформленныеКМ КАК ВТ_ОформленныеКМ
	               |		ПО (ВТ_ОформленныеКМ.ШтрихкодУпаковки = ВсеКоды.Ссылка)
	               |ГДЕ
	               |	ВсеКоды.ЗаказКМ = &ЗаказНаЭмиссию
	               |	И ВТ_ОформленныеКМ.ШтрихкодУпаковки ЕСТЬ NULL
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВсеКоды.Владелец.Наименование
	               |ИТОГИ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки)
	               |ПО
	               |	Номенклатура";
	
	Запрос.УстановитьПараметр("ЗаказНаЭмиссию", ЗаказНаЭмиссию);
	Запрос.УстановитьПараметр("Ссылка", 		Ссылка);
	
	ШтрихкодыУпаковок.Очистить();	
	
	МаксЧислоСтрок	= 95000;
	ОформленоСтрок	= 0;
	ВсегоСтрок 		= 0;
	
	Выборка_Номенклатура = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
	Пока Выборка_Номенклатура.Следующий() Цикл
		ВсегоСтрок = ВсегоСтрок + Выборка_Номенклатура.ШтрихкодУпаковки;		
		Если ВсегоСтрок <= МаксЧислоСтрок Тогда			
			Выборка = Выборка_Номенклатура.Выбрать();			
			Пока Выборка.Следующий() Цикл
				СтрокаТЧ = ШтрихкодыУпаковок.Добавить();							
				СтрокаТЧ.ШтрихкодУпаковки = Выборка.ШтрихкодУпаковки;
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла;
	
	Если ВсегоСтрок > МаксЧислоСтрок Тогда
		ТекстСообщения = СтрШаблон("Превышено максимально возможное число строк в документе ! 
		|К оформлению %1, максимум: %2.
		|Запишите документ и оформите еще один.", ВсегоСтрок, МаксЧислоСтрок);
		Сообщить(ТекстСообщения, СтатусСообщения.Важное);
	КонецЕсли;
КонецФункции //ЗаполнитьШКпоЗаказуНаЭмиссию(ЗаказНаЭмиссию) Экспорт

Функция ЗаполнитьПоЛистуНабора(ЛистНабора) Экспорт	        	
	ВидОперации 	= Перечисления.ВидыОперацийМаркировки.Агрегация;
	ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация;
	ТипДокумента	= Перечисления.ТипыДокументовИСМП.ТоварнаяНакладная;
	
	рПолучения		= Документы.ХранилищеКодовМаркировки.ПолучитьКМпоЛистуНабора(ЛистНабора);	
	
	Если рПолучения.КоличествоНоменклатуры > 1 Тогда	
		ТипУпаковки	= Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;		
	Иначе		
		ТипУпаковки	= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	КонецЕсли;	
	
	рШапки			= ПолучитьРеквизитыШапки(ЛистНабора, "ДокОснование,Склад.Подразделение");
	Местонахождение = рШапки.Склад_Подразделение;
	Накладная		= рШапки.ДокОснование;
	ЗаданиеНаМаркировку = НайтиДокумент("ЗаданиеНаМаркировку", Новый Структура("ДокОснование", Накладная));
	
	рПоискаКоробки	= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныйКод_Коробка(ТипУпаковки, ЗаданиеНаМаркировку);	
	
	ШтрихкодыУпаковок.Очистить();
	Если рПоискаКоробки.Успешно Тогда		
		КодАгрегации = ПолучитьРеквизитШапки(рПоискаКоробки.Данные, "Наименование"); 
		Для Каждого ШтрихкодУпаковки Из рПолучения.КодыМаркировки Цикл
			СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
			СтрокаТЧ.ШтрихкодУпаковки	= ШтрихкодУпаковки; 
			СтрокаТЧ.КодАгрегации		= КодАгрегации;
		КонецЦикла;		
	Иначе				
		Сообщить(СтрСоединить(рПоискаКоробки.Ошибки, Символы.ПС), СтатусСообщения.Важное);		
	КонецЕсли;
	
КонецФункции //ЗаполнитьПоЛистуНабора(ЛистНабора) Экспорт

Функция ЗаполнитьПоПНК(ПНК) Экспорт
	ТипДокумента	= Перечисления.ТипыДокументовИСМП.ТоварнаяНакладная;
	
	рШапки 			= ПолучитьРеквизитыШапки(ПНК, "Контрагент.СтранаРегистрации,Контрагент.ИННИностранногоКонтрагента,Контрагент.СтранаРегистрации.УчастникЕАЭС,КодОперации,Склад");
	
	ПодразделениеНанесения = Маркировка_ПИ.ФизическоеПодразделениеСклада(рШапки.Склад);
	Если рШапки.КодОперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда
		ВидОперации = Перечисления.ВидыОперацийМаркировки.ВозвратВОборот;
	КонецЕсли; 
	
	Если ОбщегоНазначения_ПИ.ЭтоУзел_Склад() ИЛИ ОбщегоНазначения_ПИ.ЭтоУзел_СкладФилиала() Тогда
		ЗаполнитьШКпоЛН(ПНК);
	Иначе		
		ЗаполнитьШКпоХКМ(ПНК);		
	КонецЕсли; 
	
КонецФункции //ЗаполнитьПоПНК(ПНК) Экспорт

Функция ЗаполнитьПоПРМ(ПРМ) Экспорт	        	
	ВидОперации 	= Перечисления.ВидыОперацийМаркировки.ВыводИзОборота;
	ВидОперацииИСМП	= Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Прочее;	
	
	ЗаполнитьШКпоЛН(ПРМ);	
КонецФункции //ЗаполнитьПоЗСБ(ЗаказНаЭмиссию) Экспорт

Функция ЗаполнитьПоРНК(РНК)
	ВидОперации 	= Перечисления.ВидыОперацийМаркировки.ВыводИзОборота;
	ТипДокумента	= Перечисления.ТипыДокументовИСМП.ТоварнаяНакладная;
	
	рШапки 			= ПолучитьРеквизитыШапки(РНК, "ДистанционнаяПродажа,Контрагент.СтранаРегистрации,Контрагент.ИННИностранногоКонтрагента,Контрагент.СтранаРегистрации.УчастникЕАЭС,Склад.Подразделение");
	ПодразделениеНанесения = ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла();
	
	ДистанционнаяПродажа = ПолучитьРеквизитШапки(РНК, "ДистанционнаяПродажа");
	Если ДистанционнаяПродажа Тогда
		ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа;	
	Иначе
		Если рШапки.Контрагент_СтранаРегистрации = Справочники.КлассификаторСтранМира.Россия Тогда
			ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Прочее;
		Иначе
			Если рШапки.Контрагент_СтранаРегистрации_УчастникЕАЭС = Истина Тогда
				ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ТрансграничнаяПродажаВСтраныЕАЭС;
				Страна			= рШапки.Контрагент_СтранаРегистрации;
				ИмпортерИД		= рШапки.Контрагент_ИННИностранногоКонтрагента;
			Иначе
				ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ЭкспортЗаПределыСтранЕАЭС;				
			КонецЕсли; 
		КонецЕсли;		
	КонецЕсли;
	
	// Кухарь А.Ю.  08.04.2025 начало
	Если Организация = Маркировка_ПИ.ОрганизацияБТК() Тогда	
		Организация = Маркировка_ПИ.ОрганизацияЕЕЭ();
	КонецЕсли;	
	// Кухарь А.Ю.  08.04.2025 конец	
КонецФункции //ЗаполнитьПоРНК(ЗаказНаЭмиссию) Экспорт

