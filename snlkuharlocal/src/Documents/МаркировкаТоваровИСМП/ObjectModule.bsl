Процедура ПолучитьКомлектующиеГотовыхНаборов(КомлектующиеГотовыхНаборов)
	
	Если ТипЗнч(КомлектующиеГотовыхНаборов) <> Тип("Соответствие")  Тогда
		
		КомлектующиеГотовыхНаборов = Новый Соответствие; 
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправочник
		|			ПО НоменклатураКоплектующие.Ссылка = НоменклатураСправочник.Ссылка
		|				И (НоменклатураСправочник.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
		|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец = НоменклатураКоплектующие.Номенклатура
		|ГДЕ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КомлектующиеГотовыхНаборов.Вставить(ВыборкаДетальныеЗаписи.ШтрихкодУпаковки,истина); 
	КонецЦикла;
	

КонецПроцедуры

