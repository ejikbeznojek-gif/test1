Функция ПроверитьГотовыеКомплектыВДокументе(ТаблицаТоваров)  Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыТЧ.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	&Товары КАК ТоварыТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВтТовары КАК ВтТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ВтТовары.Номенклатура = НоменклатураСпр.Ссылка
		|			И (НоменклатураСпр.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВтТовары КАК ВтТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ВтТовары.Номенклатура = НоменклатураСпр.Ссылка
		|			И (НоменклатураСпр.ВидКомплекта <> ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))";
	
	Запрос.УстановитьПараметр("Товары",ТаблицаТоваров);
	
	РезультатЗапросаПакеты = Запрос.ВыполнитьПакет();
	
	ГотовыеКомплекты =  НЕ РезультатЗапросаПакеты[1].Пустой();  
	
    НеГотовыеКомплекты = НЕ РезультатЗапросаПакеты[2].Пустой();
	
	Возврат Новый Структура("ГотовыеКомплекты, НеГотовыеКомплекты",ГотовыеКомплекты,НеГотовыеКомплекты); 
	
КонецФункции // ПроверитьГотовыеКомплектыВДокументе()

Функция СоздатьНовыйДокументМаркировкиПоГотовымКомплектам(Знач ТоварыТЧ, Знач ТЧШтрихкоды, Знач ПараметрыЗаполнения) Экспорт
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	 |	ВТТовары.ЦЕНА КАК Цена,
	 |	ВТТовары.Количество КАК Количество
	 |ПОМЕСТИТЬ ВТТовары
	 |ИЗ
	 |	&Товары КАК ВТТовары
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВЫРАЗИТЬ(ШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	 |	ШтрихкодыУпаковок.ШтрихкодНабора КАК ШтрихкодНабора
	 |ПОМЕСТИТЬ ВтШКУпаковки
	 |ИЗ
	 |	&ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВТТовары.Номенклатура КАК Номенклатура,
	 |	ВТТовары.Цена КАК Цена,
	 |	ВТТовары.Количество КАК Количество
	 |ИЗ
	 |	ВТТовары КАК ВТТовары
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
	 |		ПО ВТТовары.Номенклатура = НоменклатураСпр.Ссылка
	 |			И (НоменклатураСпр.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВтШКУпаковки.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	 |	ВтШКУпаковки.ШтрихкодНабора КАК ШтрихкодНабора
	 |ИЗ
	 |	ВтШКУпаковки КАК ВтШКУпаковки
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТовары КАК ВТТовары
	 |		ПО ВтШКУпаковки.ШтрихкодУпаковки.Владелец = ВТТовары.Номенклатура
	 |			И (ВТТовары.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))";
	 
	 Запрос.УстановитьПараметр("Товары",ТоварыТЧ);
	 Запрос.УстановитьПараметр("ШтрихкодыУпаковок",ШтрихкодыУпаковок);
	 
	 ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	 
	 ВыборкаТовары 	= ПакетЗапросов[2].Выбрать();
	 ВыборкаШК		= ПакетЗапросов[3].Выбрать();
	 
	 НовыйДокумент = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
	 
	 ЗаполнитьЗначенияСвойств(НовыйДокумент,ПараметрыЗаполнения,"ПодразделениеНанесения,Организация,ДокументОснование,ВидОперации,ВидОперацииИСМП"); 
		 
	 НовыйДокумент.Дата 				= ТекущаяДатаСеанса();	 
	 НовыйДокумент.Статус				= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
	 НовыйДокумент.Автор 				= ПараметрыСеанса.Пользователь;	  
	 НовыйДокумент.ТипУпаковки 			= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	  
	 Пока ВыборкаТовары.Следующий() Цикл
		 
		 НоваяСтрока = НовыйДокумент.Товары.Добавить(); 
		 ЗаполнитьЗначенияСвойств(Новаястрока,ВыборкаТовары); 
		 
	 КонецЦикла;
	 
	 Пока ВыборкаШК.Следующий() Цикл
		 
		 НоваяСтрока = НовыйДокумент.ШтрихкодыУпаковок.Добавить(); 
		 ЗаполнитьЗначенияСвойств(Новаястрока,ВыборкаШК);	 
		 
	 КонецЦикла;
	 
	 Попытка
	 
	 	НовыйДокумент.Записать(); 
		
		Возврат НовыйДокумент.Ссылка; 
	 
	 Исключение
	    Сообщить(ОписаниеОшибки()); 
	 КонецПопытки;
	 
	 Возврат Неопределено; 
 
 КонецФункции // НовыйДокумент()
  

