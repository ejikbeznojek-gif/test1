
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	//Вставить содержимое обработчика.
	//ПараметрыФормы = Новый Структура("", );
	//ОткрытьФорму("Документ.МаркировкаТоваровИСМП.ФормаСписка", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
	если не РольДоступна("Администратор") и не РольДоступна("ОператорЧЗ") тогда
		Сообщить("Функционал доступен под роль - Администратор или Оператор ЧЗ");
		возврат;
	КонецЕсли;
	ПерезаполнитьДокументы(ПараметрКоманды);
	Сообщить("Готово");
	
КонецПроцедуры



&НаСервере
Функция ПерезаполнитьДокументы(мСсылки)
	Результат = Новый Структура("Ошибки,Успех", Новый Массив, Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	МаркировкаТоваровИСМП.Ссылка КАК Агрегация,
	|	МаркировкаТоваровИСМП.ДокументОснование КАК Накладная,
	|	МаркировкаТоваровИСМП.ТипШК КАК ТипШК
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|ГДЕ
	|	МаркировкаТоваровИСМП.Ссылка В(&мСсылки)
	|	И МаркировкаТоваровИСМП.Проведен
	|	И МаркировкаТоваровИСМП.ВидОперацииИСМП = &ВидОперацииИСМП
	|	И МаркировкаТоваровИСМП.Статус В(&Статусы)";
	Запрос.УстановитьПараметр("мСсылки", мСсылки);
	Запрос.УстановитьПараметр("ВидОперацииИСМП", Перечисления.ВидыОперацийИСМП.Агрегация);
	Статусы=новый СписокЗначений;
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.ВРаботе);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокМаркировкиОбъект=Выборка.Агрегация.ПолучитьОбъект();
		Накладная=Выборка.Накладная;
		
		если Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Блочок тогда
			запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Лист.Ссылка КАК ДокументОснование,
			|	Лист.ШтрихкодБлочка КАК ШтрихкодКоробки
			|ИЗ
			|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК Лист
			|ГДЕ
			|	Лист.Ссылка.ДокОснование = &ДокОснование
			// Кухарь А.Ю.  12.03.2025 начало
			// Исправление ошибки
			|  И Лист.Ссылка.проведен	
			// Кухарь А.Ю.  12.03.2025 конец
			
			|	И Лист.ШтрихкодБлочка <> &КодАгрегации
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Лист.Ссылка,
			|	Лист.ШтрихкодБлочка
			|ИЗ
			|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК Лист
			|ГДЕ
			|	Лист.Ссылка.ДокОснование = &ДокОснование
			// Кухарь А.Ю.  12.03.2025 начало
			// Исправление ошибки
			|  И Лист.Ссылка.проведен		
			// Кухарь А.Ю.  12.03.2025 конец
			
			|	И Лист.ШтрихкодБлочка <> &КодАгрегации";
			запрос.УстановитьПараметр("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
			запрос.УстановитьПараметр("ДокОснование",Накладная);
			ДокМаркировкиОбъект.ШтрихкодыКоробок.Загрузить(запрос.Выполнить().Выгрузить());
			ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить();
			ДокМаркировкиОбъект.Записать();
			РезультатСоздания=Документы.МаркировкаТоваровИСМП.ЗаполнитьШтрихкодыУпаковокПоЛистамНабора (Выборка.Агрегация,Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
			если не РезультатСоздания.Успешно  тогда
				СообщитьИзМодуля(СтрСоединить(РезультатСоздания.Ошибки,символы.ПС));
				Продолжить;
			КонецЕсли;
			
		ИначеЕсли  Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка тогда
			запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			             |	Лист.Ссылка КАК ДокументОснование,
			             |	Лист.КодАгрегации КАК ШтрихкодКоробки
			             |ИЗ
			             |	Документ.ЛистНабора КАК Лист
			             |ГДЕ
			             |	Лист.Проведен
			             |	И Лист.КодАгрегации <> &КодАгрегации
			             |	И Лист.ДокОснование = &ДокОснование
			             |
			             |ОБЪЕДИНИТЬ ВСЕ
			             |
			             |ВЫБРАТЬ
			             |	Лист.Ссылка,
			             |	Лист.КодАгрегации
			             |ИЗ
			             |	Документ.ЛистПереукладки КАК Лист
			             |ГДЕ
			             |	Лист.Проведен
			             |	И Лист.КодАгрегации <> &КодАгрегации
			             |	И Лист.ДокОснование = &ДокОснование
			             |
			             |ОБЪЕДИНИТЬ ВСЕ
			             |
			             |ВЫБРАТЬ
			             |	ЛистНабора.Ссылка,
			             |	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки
			             |ИЗ
			             |	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
			             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
			             |		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка
			             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
			             |		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка
			             |			И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
			             |			И (ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки <> ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
			             |ГДЕ
			             |	ЛистНабора.ДокОснование = &ДокОснование
			             |	И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
			             |	И ЛистНабора.Проведен
			             |
			             |ОБЪЕДИНИТЬ ВСЕ
			             |
			             |ВЫБРАТЬ
			             |	ЛистПереукладки.Ссылка,
			             |	ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки
			             |ИЗ
			             |	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
			             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
			             |		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладки.Ссылка
			             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.ШтрихкодыКоробокДляАгрегации КАК ЛистПереукладкиШтрихкодыКоробокДляАгрегации
			             |		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.Ссылка
			             |			И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистПереукладкиШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
			             |			И (ЛистПереукладкиШтрихкодыКоробокДляАгрегации.НовыйКодКоробки <> ЛистПереукладкиШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки)
			             |ГДЕ
			             |	ЛистПереукладки.ДокОснование = &ДокОснование
			             |	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
			             |	И ЛистПереукладки.Проведен";
			запрос.УстановитьПараметр("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
			запрос.УстановитьПараметр("ДокОснование",Накладная);
			ДокМаркировкиОбъект.ШтрихкодыКоробок.Загрузить(запрос.Выполнить().Выгрузить());
			ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить();
			ДокМаркировкиОбъект.Записать();
			РезультатСоздания=Документы.МаркировкаТоваровИСМП.ЗаполнитьШтрихкодыУпаковокПоЛистамНабора (Выборка.Агрегация,Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
			если не РезультатСоздания.Успешно  тогда
				СообщитьИзМодуля(СтрСоединить(РезультатСоздания.Ошибки,символы.ПС));
				Продолжить;
			КонецЕсли;
			
		ИначеЕсли  Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Палета тогда
			запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ различные
			|	ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты КАК ШтрихкодКоробки,
			|	ПаллетаЛистыНабора.Документ КАК ДокументОснование
			|ИЗ
			|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
			|ГДЕ
			|	ПаллетаЛистыНабора.Ссылка.Проведен
			|	И ПаллетаЛистыНабора.Документ = &ДокОснование
			|	И ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты <> &КодАгрегации";
			запрос.УстановитьПараметр("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
			запрос.УстановитьПараметр("ДокОснование",Накладная);
			ДокМаркировкиОбъект.ШтрихкодыКоробок.Загрузить(запрос.Выполнить().Выгрузить());
			ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить();
			ДокМаркировкиОбъект.Записать();
			
			РезультатСоздания=Документы.МаркировкаТоваровИСМП.ЗаполнитьШтрихкодыУпаковокПоПалетам(Выборка.Агрегация,Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
			если не РезультатСоздания.Успешно  тогда
				СообщитьИзМодуля(СтрСоединить(РезультатСоздания.Ошибки,символы.ПС));
				Продолжить;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 	
	
	Возврат Результат;
КонецФункции //ПроверитьДокументыКОбработке(мСсылки)
