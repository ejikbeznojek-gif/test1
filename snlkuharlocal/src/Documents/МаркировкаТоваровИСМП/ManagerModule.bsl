Функция СостояниеНакладнойДопускаетАгрегациюВПаллету(СостояниеНакладной)
	Результат = Истина;
	Если СостояниеНакладной <> Перечисления.СостоянияНакладной.ГотоваКОтгрузке тогда				
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции  
Процедура РазбитьОМ(ДокОбъект)         
	РазмерТЧ = 99500;
	Если ДокОбъект.ШтрихкодыУпаковок.Количество()>РазмерТЧ Тогда   
		ТЧ_ШК = ДокОбъект.ШтрихкодыУпаковок.Выгрузить();
		ДокОбъект.ШтрихкодыУпаковок.Очистить();
		ДокТЧ_Коробки = ДокОбъект.ШтрихкодыКоробок.Выгрузить();  
		ДокОбъект.ШтрихкодыКоробок.Очистить();
		
		ТЧ_Коробки = ТЧ_ШК.Скопировать(); 
		ТЧ_Коробки.Свернуть("ШтрихкодКоробки");
		ТЧ_Коробки.Сортировать("ШтрихкодКоробки");      
		
		Запрос = новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
		                      |	Док_ШкКоробок.Ссылка КАК Ссылка
		                      |ИЗ
		                      |	Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК Док_ШкКоробок
		                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК Док
		                      |		ПО (Док.Ссылка = Док_ШкКоробок.Ссылка)
		                      |			И (Док.ДокументОснование = &ДокументОснование)
		                      |			И (НЕ Док.Ссылка = &ТекОМ) и Док.Проведен
		                      |ГДЕ
		                      |	Док_ШкКоробок.ШтрихкодКоробки В(&ШтрихкодыКоробок)
		                      |
		                      |ОБЪЕДИНИТЬ
		                      |
		                      |ВЫБРАТЬ РАЗЛИЧНЫЕ
		                      |	ДокШкУпаковок.Ссылка
		                      |ИЗ
		                      |	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ДокШкУпаковок
		                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК Док
		                      |		ПО (Док.Ссылка = ДокШкУпаковок.Ссылка)
		                      |			И (Док.ДокументОснование = &ДокументОснование)
		                      |			И (НЕ Док.Ссылка = &ТекОМ)  и Док.Проведен
		                      |ГДЕ
		                      |	ДокШкУпаковок.ШтрихкодУпаковки В(&ШтрихкодыУпаковок)");
		Запрос.УстановитьПараметр("ШтрихкодыКоробок",ТЧ_Коробки.ВыгрузитьКолонку("ШтрихкодКоробки"));
		Запрос.УстановитьПараметр("ШтрихкодыУпаковок",ТЧ_ШК.ВыгрузитьКолонку("ШтрихкодУпаковки"));
		Запрос.УстановитьПараметр("ТекОМ",ДокОбъект.Ссылка);    
		Запрос.УстановитьПараметр("ДокументОснование",ДокОбъект.ДокументОснование);    
		ВсеОМ = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		Для каждого ОМ Из ВсеОМ Цикл
			ОмОбъект = ОМ.ПолучитьОбъект();                
			ОмОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе;
			ОмОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);   
			ОмОбъект.УстановитьПометкуУдаления(Истина);         
			НЗ = РегистрыСведений.ИспользованныеКодыАгрегаций.СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(ОМ);         
			НЗ.Записать();
		КонецЦикла;	
		
		ТекДокОбъект = ДокОбъект;                 
		
		Для каждого Коробка Из ТЧ_Коробки.ВыгрузитьКолонку("ШтрихкодКоробки") Цикл 
			
			ТЧ_ШкКоробки = ТЧ_ШК.Скопировать(Новый Структура("ШтрихкодКоробки",Коробка));
			Если (ТекДокОбъект.ШтрихкодыУпаковок.Количество()+ТЧ_ШкКоробки.Количество())> РазмерТЧ Тогда  
				
				ТекДокОбъект.Записать(РежимЗаписиДокумента.Проведение);  
				ТекДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ТекДокОбъект,ДокОбъект,,"Номер");  
				ТекДокОбъект.ДокументыОснования.Загрузить(ДокОбъект.ДокументыОснования.Выгрузить());
 				ТекДокОбъект.Записать(РежимЗаписиДокумента.Запись);  
			КонецЕсли;	 
			
			СтрокиКоробок = ДокТЧ_Коробки.НайтиСтроки(Новый Структура("ШтрихкодКоробки",Коробка));    
			Для каждого СтрокаКоробок Из СтрокиКоробок Цикл
				СтрКоробки = ТекДокОбъект.ШтрихкодыКоробок.Добавить();	
				ЗаполнитьЗначенияСвойств(СтрКоробки,СтрокаКоробок);  
			КонецЦикла;	
			Для каждого СтрШкКоробки Из ТЧ_ШкКоробки Цикл 
				СтрТЧ = ТекДокОбъект.ШтрихкодыУпаковок.Добавить();
				ЗаполнитьЗначенияСвойств(СтрТЧ,СтрШкКоробки);
			КонецЦикла;	
		КонецЦикла;	
		
		ТекДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Иначе
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;	
КонецПроцедуры	

//++Данилова Е.В. 14.01.2026   ASU-2089 
Функция ПолучитьЗабронироватьКодАгрегацииДляМультиПаллеты(Паллета, Накладная,КоличествоКодов,Знач ТипУпаковки = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
		
	Если ЗначениеЗаполнено(Паллета) Тогда
		Если НЕ ТипЗнч(Паллета) = Тип("ДокументСсылка.Паллета") Тогда
			Результат.Ошибки.Добавить("Недопустимое основание для агрегации: " + ТипЗнч(Паллета));
		КонецЕсли; 
	Иначе
		Результат.Ошибки.Добавить("Не указана палета !");	
	КонецЕсли;	
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли;
	
	рПроверки = МожноАгрегироватьНакладную(Накладная); 
	
	Если НЕ рПроверки.Успешно Тогда
		Возврат рПроверки;		
	КонецЕсли;	
	
	ТипШК = Перечисления.ТипыШтрихКодов.Палета;
	Если ТипУпаковки = Неопределено Тогда
		ТипУпаковки = ОпределитьТипУпаковкиПоСоставуНакладной(Накладная);			
	КонецЕсли;
	
	ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, ТипШК);
	
	рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыАгрегации(ТипШК,ТипУпаковки,КоличествоКодов,ОперАгрегации,Новый Структура("Добавлять", Истина)); 
	Если рБронирования.Успешно Тогда
		ШтрихкодыАгрегации = рБронирования.Данные;
		
		рДобавления = ДобавитьШККоробокВАгрегацию(ОперАгрегации, Накладная, ШтрихкодыАгрегации);
		Если рДобавления.Успешно Тогда
			Результат.Успешно 	= Истина;						
			Результат.Данные 	= ШтрихкодыАгрегации;
		Иначе						
			МаркировкаКС.ДобавитьОшибки(Результат, рДобавления);
		КонецЕсли;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рБронирования);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьСвободныйКодАгрегацииДляЛН(ЛистНабора, ТипШК, Знач ТипУпаковки = Неопределено) Экспорт

Функция ДобавитьШККоробокВАгрегацию(ДокМаркировки, ЛистНабора, ШтрихКодыАгрегации) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь); 
	ТипШК_Док = ПолучитьРеквизитШапки(ДокМаркировки, 		"ТипШК");
	
	Для каждого ШтрихКодАгрегации Из ШтрихКодыАгрегации Цикл
		
		ТипШК_Код = ПолучитьРеквизитШапки(ШтрихКодАгрегации, 	"ТипШК");
		
		Если ТипШК_Код <> ТипШК_Док Тогда
			
			Результат.Ошибки.Добавить(СтрШаблон("Не совпадют типы ШК кода %1 и документа !",ТипШК_Код));
		Иначе 
			мШтрихКодАгрегации = ВыдавалсяКодАгрегации(ДокМаркировки, ЛистНабора, ШтрихКодАгрегации);
			
			Если ЗначениеЗаполнено(мШтрихКодАгрегации) Тогда
				ТекстСообщения = СтрШаблон("Для документа '%1' уже выдавался код агрегации '%2' !", ЛистНабора, мШтрихКодАгрегации);
				Результат.Ошибки.Добавить(ТекстСообщения);
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() > 0  Тогда 
		
		Возврат Результат;
	
	КонецЕсли;
	
	
	ДокОбъект = ДокМаркировки.ПолучитьОбъект();
	Если ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
		ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;					
	КонецЕсли;
	Если НЕ ДокОбъект.Проведен Тогда
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);		
	КонецЕсли;
	
	ТекДата =  ТекущаяДата();
	Для каждого ШтрихКодАгрегации Из ШтрихКодыАгрегации Цикл
		СтрокаК = ДокОбъект.ШтрихкодыКоробок.Добавить();											
		
		СтрокаК.ШтрихкодКоробки		= ШтрихКодАгрегации;
		СтрокаК.ДокументОснование   = ЛистНабора;
		СтрокаК.ДатаДобавления		= ТекДата; 
	КонецЦикла;
	
	Попытка
		ДокОбъект.Записать();
		
		Результат.Успешно 	= Истина;						
	Исключение
		ТекстОшибки = СтрШаблон("Не удалось провести документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
		Результат.Ошибки.Добавить(ТекстОшибки);					
	КонецПопытки;
	
	
	Возврат Результат;
КонецФункции

