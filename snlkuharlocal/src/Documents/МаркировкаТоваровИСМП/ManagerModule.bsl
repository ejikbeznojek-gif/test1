Функция ОпределитьТипУпаковкиПоСоставуЛН(ЛистНабора) Экспорт
	рПолучения	= Документы.ХранилищеКодовМаркировки.ПолучитьКМпоЛистуНабора(ЛистНабора);	
	
	ТипУпаковки	= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	
	Если рПолучения.КоличествоНоменклатуры > 1 Тогда	
		ТипУпаковки	= Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;		
	КонецЕсли;
	
	Возврат ТипУпаковки;
КонецФункции

Функция ОпределитьТипУпаковкиПоСоставуНакладной(Накладная, ИмяТЧ = "Товары") Экспорт
	Результат = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Номенклатура) КАК КолПозицийНоменклатуры
	|ИЗ
	|	" + Накладная.Метаданные().ПолноеИмя() + "." + ИмяТЧ + " 
	|ГДЕ
	|	Ссылка = &Накладная
	|";
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.КолПозицийНоменклатуры > 1 Тогда
		Результат = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ОпределитьТипУпаковкиПоСоставуНакладной(Накладная, ИмяТЧ = "Товары") Экспорт
