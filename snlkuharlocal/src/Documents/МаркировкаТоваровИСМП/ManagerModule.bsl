Функция ПолучитьКодыАТКпоМашине(МАШ_Ссылка)
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	Спр_ШК.Ссылка КАК ШтрихКод	
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП КАК ДокМаркировка
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК Спр_ШК	
	|ПО
	|	Спр_ШК.Наименование = ДокМаркировка.АТК 			
	|	И Спр_ШК.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.АТК)
	|ГДЕ
	|	ДокМаркировка.ДокументОснование 	= &МАШ_Ссылка
	|	И ДокМаркировка.ВидОперации 		= ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.АТК)
	|	И ДокМаркировка.Ссылка.Проведен	
	|";
	
	Запрос.УстановитьПараметр("МАШ_Ссылка", МАШ_Ссылка);	
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихКод");
КонецФункции //ПолучитьКодыАТКпоМашине(МАШ_Ссылка)

Функция ПолучитьСоздатьДокМаркировки(ДокОснование, СуществующиеДокументы, Сч, ВидОперацииИСМП, Основной = Истина) Экспорт
	ДокСсылка = СуществующиеДокументы[Сч];					
	Если ДокСсылка = Неопределено Тогда
		ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
			
		ДокОбъект.Дата	= ТекущаяДата();
		
		ДокОбъект.Организация	= ПолучитьРеквизитШапки(ДокОснование, "Организация");
		ДокОбъект.ДополнительныеСвойства.Вставить("ЗаполнятьТолькоШапку", Истина);
		ДокОбъект.Заполнить(ДокОснование);
	Иначе
		ДокОбъект = ДокСсылка.ПолучитьОбъект();
		ДокОбъект.Организация		= ПолучитьРеквизитШапки(ДокОснование, "Организация");
		ДокОбъект.ДокументОснование	= ДокОснование; //Хвосты иногда не видны если прицеплены не к тому основанию
	КонецЕсли;
	
	ДокОбъект.ВидОперации		= Перечисления.ВидыОперацийИСМП.ВидОперацииМаркировки(ВидОперацииИСМП);
	ДокОбъект.ВидОперацииИСМП 	= ВидОперацииИСМП;
	
	ДокОбъект.Товары.Очистить();
	ДокОбъект.ШтрихкодыУпаковок.Очистить();
	
	Возврат ДокОбъект;
КонецФункции //ПолучитьСоздатьАгрегацию(ДокОснование, СуществующиеДокументы, Сч)

Функция ПолучитьСоздатьДокАгрегации(ДокументОснование, Знач ТипШК = Неопределено, ТипУпаковки = Неопределено, ДопПараметры = Неопределено) Экспорт	
	Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат Неопределено;
	КонецЕсли; 
	Если ТипШК = Перечисления.ТипыШтрихКодов.Штука Тогда
		Возврат Неопределено;	
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ТипШК) Тогда
		ТипШК = Перечисления.ТипыШтрихКодов.Коробка;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТипУпаковки) Тогда
		ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	КонецЕсли;	
	
	ВидОперации = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ВидОперации", Перечисления.ВидыОперацийМаркировки.Агрегация);
	

	// Кухарь А.Ю.  18.03.2025 начало
	//СтруктураПоиска = Новый Структура("ДокументОснование,ВидОперации,ТипШК,ТипУпаковки", ДокументОснование, ВидОперации, ТипШК, ТипУпаковки);
	СтруктураПоиска = Новый Структура("ДокументОснование,ВидОперации,ТипШК", ДокументОснование, ВидОперации, ТипШК);
	// Кухарь А.Ю.  18.03.2025 конец
	
	ДокСсылка = НайтиДокумент("МаркировкаТоваровИСМП", СтруктураПоиска);	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
		ДокОбъект.ДополнительныеСвойства.Вставить("ЗаполнятьТолькоШапку", Истина);
		
		ДокОбъект.Заполнить(ДокументОснование);		
		Если НЕ ЗначениеЗаполнено(ДокОбъект.ПодразделениеНанесения) Тогда
			ДокОбъект.ПодразделениеНанесения = ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла();			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ДокОбъект, СтруктураПоиска);
		
		ДокОбъект.Дата		= ТекущаяДата();	
		ДокОбъект.Статус	= Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;		
		Если ДокОбъект.ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
			ДокОбъект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация;		
		КонецЕсли;		
		
		// Кельманов А.В. - HELP-7961 + HELP-9743 + HELP-9832 - 2026.05.21 {
		//ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		ДокОбъект.Проведен = Истина;
		ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
		// Кельманов А.В. - HELP-7961 + HELP-9743 + HELP-9832 - 2026.05.21 }
		
		ДокСсылка = ДокОбъект.Ссылка;
	КонецЕсли;
	
	Возврат ДокСсылка;
КонецФункции //ПолучитьСоздатьДокАгрегации(ДокументОснование, Знач ТипШК = Неопределено, ТипУпаковки = Неопределено, ДопПараметры = Неопределено) Экспорт

Функция СоздатьЗапрос_АгрегационныеКодыПоОперации(ОперМаркировки_Ссылка) Экспорт
	Запрос	= Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ТЧ_ШК.КодАгрегации							КАК КодАгрегации,		
	|	ТЧ_ШК.Ссылка								КАК ДокАгрегации,		
	|	ТЧ_ШК.ШтрихкодУпаковки.Владелец 			КАК Номенклатура,
	|	ТЧ_ШК.ШтрихкодУпаковки.Владелец 			КАК КоличествоНоменклатуры,
	|	ТЧ_ШК.ШтрихкодУпаковки						КАК КМ_Штука,
	|	ТЧ_ШК.ШтрихкодУпаковки.Наименование 		КАК КМ_Штука_Наименование,
	|	ТЧ_ШК.ШтрихкодУпаковки.СпособВводаВОборот	КАК СпособВводаВОборот,
	|	
	|	СпрШК_КодыАгрегации.Ссылка					КАК КМ_Коробка,	
	|	СпрШК_КодыАгрегации.Ссылка.Наименование		КАК КМ_Коробка_Наименование
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ТЧ_ШК		
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК_КодыАгрегации	
	|ПО
	|	ТЧ_ШК.КодАгрегации				= СпрШК_КодыАгрегации.Наименование
	|	И СпрШК_КодыАгрегации.ТипКода 	= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|ГДЕ
	|	ТЧ_ШК.Ссылка = &ОперМаркировки_Ссылка 
	|	И ТЧ_ШК.КодАгрегации<>""""	
	|	И ТЧ_ШК.ШтрихкодУпаковки.ТипКода 	= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
	|	И СпрШК_КодыАгрегации.Ссылка ЕСТЬ NULL
	|УПОРЯДОЧИТЬ ПО		
	|	КодАгрегации,
	|	ТЧ_ШК.ШтрихкодУпаковки.Владелец,
	|	ТЧ_ШК.ШтрихкодУпаковки.Наименование
	|ИТОГИ 	
	|	КОЛИЧЕСТВО(Различные КоличествоНоменклатуры),
	|	КОЛИЧЕСТВО(Различные КМ_Штука),
	|	МАКСИМУМ(Номенклатура),
	|	МАКСИМУМ(СпособВводаВОборот),
	|	МАКСИМУМ(КМ_Коробка),
	|	МАКСИМУМ(КМ_Коробка_Наименование),
	|	МАКСИМУМ(ДокАгрегации)
	|ПО	
	|	КодАгрегации	
	|";                       
	
	Запрос.УстановитьПараметр("ОперМаркировки_Ссылка", ОперМаркировки_Ссылка);
	
	Возврат Запрос;
КонецФункции //СоздатьЗапрос_АгрегационныеКодыПоОперации() Экспорт

Функция ПолучитьОперацииПоОснованию(ДокументОснование, ВидОперации = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП
	|ГДЕ
	|	ДокументОснование = &ДокументОснование
	|	" + ?(ЗначениеЗаполнено(ВидОперации), "И ВидОперации = &ВидОперации", "") + "
	|";
	
	Запрос.УстановитьПараметр("ДокументОснование", 	ДокументОснование);
	Запрос.УстановитьПараметр("ВидОперации", 		ВидОперации);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");	
КонецФункции //ПолучитьОперацииПоОснованию(ДокументОснование, ВидОперации = Неопределено) Экспорт

Процедура ЗарегистрироватьИспользованныеКоробки(Ссылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодКоробки
	|ИЗ
	|(
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ШтрихкодКоробки
	|	ИЗ
	|		Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|	ГДЕ
	|		Ссылка = &Ссылка
	|		И Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)	
	|	ОБЪЕДИНИТЬ 
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ШтрихкодКоробки
	|	ИЗ
	|		Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок
	|	ГДЕ
	|		Ссылка = &Ссылка
	|		И Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)	
	|) КАК Сводный
	|ГДЕ
	|	ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	НЗ = РегистрыСведений.ИспользованныеКодыАгрегаций.СоздатьНаборЗаписей();
	НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = НЗ.Добавить();
		Запись.ШтрихКодУпаковки = Выборка.ШтрихкодКоробки;		
	КонецЦикла;
	
	Попытка
		НЗ.Записать();
	Исключение
		ВызватьИсключение "Не удалось забронировать агрегационный код ! " + ОписаниеОшибки(); 
	КонецПопытки;
	
КонецПроцедуры

Процедура ОчиститьИспользованныеКоробки(Ссылка) Экспорт	
	
	НЗ = РегистрыСведений.ИспользованныеКодыАгрегаций.СоздатьНаборЗаписей();
	НЗ.Отбор.Регистратор.Установить(Ссылка, Истина);
	
	Попытка
		НЗ.Записать();
	Исключение
		ВызватьИсключение "Не удалось очистить используемые коды ! " + ОписаниеОшибки(); 
	КонецПопытки;

КонецПроцедуры

Функция ПолучитьДанныеРазАгрегации(РНК_Ссылка, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодКоробки,
	|	ШтрихкодУпаковки,
	|	Ссылка
	|ПОМЕСТИТЬ ВТ_Отгрузка
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	ВЫРАЗИТЬ(Ссылка.ДокументОснование КАК Документ.РасходнаяНакладная) = &РНК_Ссылка
	|	И Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И НЕ ШтрихкодКоробки.ВерсияДанных ЕСТЬ NULL
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	Агр.ШтрихкодКоробки						КАК ШтрихкодКоробки,
	|	Агр.ШтрихкодКоробки.СпособВводаВОборот	КАК СпособВводаВОборот
	|ПОМЕСТИТЬ ВТ_КоробкиНаРазбор	
	|ИЗ
	|	ВТ_Отгрузка
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК Агр
	|ПО
	|	Агр.ШтрихкодУпаковки = ВТ_Отгрузка.ШтрихкодУпаковки
	|	И Агр.Ссылка <> ВТ_Отгрузка.Ссылка
	|	И Агр.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И (
	|		Агр.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.ОбработанЧЗ)
	|		ИЛИ Агр.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
	|	)
	|ГДЕ
	|	НЕ Агр.ШтрихкодКоробки ЕСТЬ NULL		
	|	И НЕ Агр.ШтрихкодКоробки = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)		
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	КодыКоробок.Ссылка КАК ШтрихкодКоробки,
	|	КодыКоробок.Ссылка.СпособВводаВОборот
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК КодыКоробок
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ	
	|	ВТ_Отгрузка
	|ПО
	|	КодыКоробок.Штрихкод = ВТ_Отгрузка.ШтрихкодУпаковки
	|	И КодыКоробок.Ссылка.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Импорт)
	|ГДЕ
	|	НЕ КодыКоробок.Ссылка.Наименование ПОДОБНО ""%\_%"" СПЕЦСИМВОЛ ""\""
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_КоробкиНаРазбор.ШтрихкодКоробки	
	|ИЗ
	|	ВТ_КоробкиНаРазбор		
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.СтатусыКМ_Факт КАК Статусы	
	|ПО		
	|	ВТ_КоробкиНаРазбор.ШтрихкодКоробки = Статусы.ШтрихКодУпаковки	
	|	И (
	|		Статусы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Списан)
	|		ИЛИ Статусы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Выбыл)
	|		ИЛИ Статусы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Расформирован)
	|	)
	|ГДЕ
	|	Статусы.Статус ЕСТЬ NULL
	|";	
	
	Запрос.УстановитьПараметр("РНК_Ссылка", РНК_Ссылка);	
	
	рЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка_КоробкиРНК = рЗапроса[рЗапроса.ВГраница()-1].Выбрать();
	Если Выборка_КоробкиРНК.Количество() = 0 Тогда
		Результат.Ошибки.Добавить("Не найдено кодов агрегаций к накладной !");		
		Результат.Успешно = Ложь;
	Иначе
		Результат.Данные = рЗапроса[рЗапроса.ВГраница()].Выгрузить().ВыгрузитьКолонку("ШтрихкодКоробки");		
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ПолучитьДанныеРазАгрегации(РНК_Ссылка, ДопПараметры = Неопределено) Экспорт
 

