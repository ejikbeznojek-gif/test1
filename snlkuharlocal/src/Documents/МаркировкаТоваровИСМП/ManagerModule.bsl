	//если КоличествоСвободныхКодов<>КоличествоЛистов тогда
	//	ТекстОшибки = СтрШаблон("Недостаточно свободных кодов на короба %1, нужно %2. Предварительно забронируйте недостающее количество.", КоличествоСвободныхКодов,КоличествоЛистов);
	//	Результат.Ошибки.Добавить(ТекстОшибки);			
