	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ВТ.НомерСтроки КАК НомерСтроки,
	             |	ВТ.ДокументОснование КАК ДокументОснование,
	             |	ВТ.ШтрихкодКоробки КАК ШтрихкодКоробки
	             |ИЗ
	             |	ВТ КАК ВТ
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ДокументОснование,
	             |	НомерСтроки";
	запрос.УстановитьПараметр("ШтрихкодыКоробок",ДокОбъект.ШтрихкодыКоробок.выгрузить());  
	запрос.УстановитьПараметр("МассивЛистов",МассивЛистов);  
	//++Данилова Е.В. 02.09.2025  HELP-6414 
