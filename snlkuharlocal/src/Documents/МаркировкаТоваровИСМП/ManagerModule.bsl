// Кухарь А.Ю.  02.04.2025 начало
Функция ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста(Знач ЛистНабора,Знач Накладная, Знач ТипШК) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);		
	ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, ТипШК);		
	рДобавления = ДобавитьЛистВПакетнуюАгрегацию(ОперАгрегации, ЛистНабора);
	Если рДобавления.Успешно Тогда
		Результат.Успешно 	= Истина;						
		Результат.Данные 	= рДобавления.Данные;
	Иначе						
		МаркировкаКС.ДобавитьОшибки(Результат, рДобавления);
	КонецЕсли;		
	

	Возврат Результат;
КонецФункции 


Функция ДобавитьЛистВПакетнуюАгрегацию(ДокМаркировки, ЛистНабора) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	ДокОбъект = ДокМаркировки.ПолучитьОбъект();
	
	Если ДокОбъект.Статус <> Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
		и ДокОбъект.Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе тогда
		ТекстОшибки = СтрШаблон("Недопустимый статус у документа агрегации: '%1' ! %2", ДокОбъект, ДокОбъект.Статус);
		Результат.Ошибки.Добавить(ТекстОшибки);					
	КонецЕсли; 
	
	Попытка
		ДокОбъект.Заблокировать();
	Исключение
		ТекстОшибки = СтрШаблон("Не удалось заблокировать документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
		Результат.Ошибки.Добавить(ТекстОшибки);	
		// Кухарь А.Ю.  22.07.2025 начало
		возврат Результат; 
		// Кухарь А.Ю.  22.07.2025 конец
		
	КонецПопытки;
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	             |	ТЧ.НомерСтроки КАК НомерСтроки,
	             |	ТЧ.ДокументОснование КАК ДокументОснование
	             |ПОМЕСТИТЬ ВТ
	             |ИЗ
	             |	&ШтрихкодыКоробок КАК ТЧ
	             |ГДЕ
	             |	ТЧ.ДокументОснование = НЕОПРЕДЕЛЕНО
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ДокументОснование УБЫВ
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ВТ.НомерСтроки КАК НомерСтроки
	             |ИЗ
	             |	ВТ КАК ВТ";
	запрос.УстановитьПараметр("ШтрихкодыКоробок",ДокОбъект.ШтрихкодыКоробок.выгрузить());
	ТЗКоробов=запрос.Выполнить().Выгрузить();
	
	СтрокаНашласть=ложь;
	Для каждого СтрокаТЗ из ТЗКоробов цикл
		СтрокаТЧ=ДокОбъект.ШтрихкодыКоробок.получить(СтрокаТЗ.НомерСтроки-1);
		СтрокаТЧ.ДокументОснование=ЛистНабора;
		Результат.Данные.Добавить(СтрокаТЧ.ШтрихкодКоробки);	
		СтрокаНашласть=Истина;
	КонецЦикла;
	
	если не СтрокаНашласть тогда
		ТекстОшибки = СтрШаблон("Закончились предварительно зарезервированные коды в %1", ДокОбъект);
		Результат.Ошибки.Добавить(ТекстОшибки);	
	КонецЕсли;
	
	если Результат.Ошибки.Количество()=0 тогда
		Попытка
			// Кухарь А.Ю.  22.07.2025 начало
			ДокОбъект.ОбменДанными.Загрузка = Истина; 
			ДокОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи",Истина);
			// Кухарь А.Ю.  22.07.2025 конец
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
			ДокОбъект.Разблокировать();
			Результат.Успешно 	= Истина;					
		Исключение
			ТекстОшибки = СтрШаблон("Не удалось провести документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
			Результат.Ошибки.Добавить(ТекстОшибки);					
		КонецПопытки;
	КонецЕсли;
	
	
	Возврат Результат;
КонецФункции //ДобавитьКодАгрегацииИзЛН(ДокументОснование) Экспорт

