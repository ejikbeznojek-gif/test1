			СтрокаТаблицыДанных		 							= ТаблицаДанных.Добавить();
			СтрокаТаблицыДанных.Лист							= ТекущийЛист; 
			СтрокаТаблицыДанных.КодАгрегации					= СтрокаТЧ.ШтрихкодКоробки;           // пишем в таблицу которую вернём
