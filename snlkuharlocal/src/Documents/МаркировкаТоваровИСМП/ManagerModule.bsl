Функция ПроверитьДокументАТКНаНаличиеГотовыхНаборов(Знач ДокументМаркировки, Знач ВидОперации)

	Если ВидОперации = Перечисления.ВидыОперацийМаркировки.АТК Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МаркировкаТоваровИСМП.Номенклатура КАК Номенклатура
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.Товары КАК МаркировкаТоваровИСМП
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправ
		|		ПО МаркировкаТоваровИСМП.Номенклатура = НоменклатураСправ.Ссылка
		|			И (НоменклатураСправ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|		ПО (НоменклатураКоплектующие.Номенклатура = МаркировкаТоваровИСМП.Номенклатура)
		|			И (НоменклатураКоплектующие.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
		|ГДЕ
		|	МаркировкаТоваровИСМП.Ссылка = &ДокументМаркировки  
		//Данилова Е.В. 25.06.2025 MARK-2484
		//|	И (НЕ НоменклатураСправ.Ссылка ЕСТЬ NULL ИЛИ
		|			 И (НЕ НоменклатураКоплектующие.Ссылка ЕСТЬ NULL)";
		
		Запрос.УстановитьПараметр("ДокументМаркировки", ДокументМаркировки);
		
		РезультатЗапроса = Запрос.Выполнить(); 
		
		Если РезультатЗапроса.Пустой()  Тогда
		
			Возврат Неопределено;
		Иначе 
			
			МассивТоваровОшибка = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура");
			
			Возврат СтрСоединить(МассивТоваровОшибка,";"); 
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат неопределено; 

КонецФункции // ПроверитьДокументАТКПоГотовымНаборам()
