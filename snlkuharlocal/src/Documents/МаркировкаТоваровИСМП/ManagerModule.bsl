
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)	
	СтандартнаяОбработка = Ложь;
	Если Данные.ВидОперации = Перечисления.ВидыОперацийМаркировки.Агрегация Тогда
		Представление = СтрШаблон("Операция маркировка (%1 (%4)) № %2 от %3", Данные.ВидОперации, Данные.Номер, Формат(Данные.Дата,"ДФ=dd.MM.yyyy"), Данные.ТипШК);
	Иначе
		Представление = СтрШаблон("Операция маркировка (%1) № %2 от %3", Данные.ВидОперации, Данные.Номер, Формат(Данные.Дата,"ДФ=dd.MM.yyyy"));	
	КонецЕсли; 	
	
КонецПроцедуры

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Поля = СтрРазделить("Дата,Номер,ВидОперации,ТипШК",",");
КонецПроцедуры

Функция ПроверитьДокументПередОтправкойВЧЗ(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка, "Проведен,Статус,ВидОперации,ДокументОснование");
	Если Реквизиты.Проведен Тогда
		Если Реквизиты.ВидОперации = Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
			ТекстОшибки = СтрШаблон("Вид операции '%1' не обрабатывается ЧЗ.", Реквизиты.ВидОперации);
			Результат.Ошибки.Добавить(ТекстОшибки);			
		Иначе
			Если Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе
				ИЛИ Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
				ИЛИ Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке Тогда
				//++Данилова Е.В. 03.02.2025
				ДокВводаВОборотГотНаб = ДокументВводаВОборотПередОтправкойВЧЗФормированиеНабора(Реквизиты.ДокументОснование,Реквизиты.ВидОперации); 
				Если НЕ ЗначениеЗаполнено(ДокВводаВОборотГотНаб) Тогда
					Результат.Успешно = Истина;
				Иначе  					
					ТекстОшибки = "Не введены в оборот комплектующие по готовым наборам, документ ""Операция маркировки"" " + ДокВводаВОборотГотНаб; 
					Результат.Ошибки.Добавить(ТекстОшибки);
				КонецЕсли;
				//
				//--Данилова Е.В. 03.02.2025
				
				//++Данилова Е.В. 19.02.2025 MARK-1454
				РезультатПроверки = ПроверитьДокументАТКНаНаличиеГотовыхНаборов(ДокСсылка,Реквизиты.ВидОперации);
				Если НЕ ЗначениеЗаполнено(РезультатПроверки) Тогда
					Результат.Успешно = Истина;
				Иначе  					
					ТекстОшибки = "Товары не могут входить в состав маркировки с типом ""АТК"" (готовые наборы и комплектующие): " + РезультатПроверки; 
					Результат.Ошибки.Добавить(ТекстОшибки);
				КонецЕсли;

				//--Данилова Е.В. 19.02.2025
			Иначе			
				ТекстОшибки = СтрШаблон("Не допустимый статус док-та: %1, статус: '%2', должен быть: 'В работе' или 'К обработке'.", ДокСсылка, Реквизиты.Статус);
				Результат.Ошибки.Добавить(ТекстОшибки);
			КонецЕсли;		
		КонецЕсли;		
		
		Если ТипЗнч(Реквизиты.ДокументОснование) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
			Если Реквизиты.ВидОперации = Перечисления.ВидыОперацийМаркировки.АТК Тогда
				ТекстОшибки = СтрШаблон("Не док-т: %1, является дополнением к '%2', обработан может только первичный документ.", ДокСсылка, Реквизиты.ДокументОснование);
				Результат.Ошибки.Добавить(ТекстОшибки);					
				Результат.Успешно = Ложь;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ТекстОшибки = СтрШаблон("Документ  '%1' не проведен.", ДокСсылка);
		Результат.Ошибки.Добавить(ТекстОшибки);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПроверитьДокументПередОтправкойВЧЗ()

Функция ПроверитьДокументПередПолучениемИзЧЗ(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка, "Проведен,Статус");
	Если Реквизиты.Проведен Тогда
		Если Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.Обрабатывается Тогда
			Результат.Успешно = Истина;
		Иначе			
			ТекстОшибки = СтрШаблон("Не допустимый статус док-та: %1, статус: '%2', должен быть: 'Обрабатывается'.", ДокСсылка, Реквизиты.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли; 	
	Иначе
		Результат.Ошибки.Добавить("Документ не проведен.");
	КонецЕсли;
	
	Возврат Результат;

КонецФункции //ПроверитьДокументПередПолучениемИзЧЗ(ДокСсылка) Экспорт

Функция СоздатьАгрегацииКЗПС(ЗПС_Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказПоставщикуТовары.Номенклатура.ГТИН КАК ГТИН,
	               |	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	               |	СУММА(ЗаказПоставщикуТовары.Количество) КАК Количество
	               |ПОМЕСТИТЬ ВТ_Товары
	               |ИЗ
	               |	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	               |ГДЕ
	               |	ЗаказПоставщикуТовары.Ссылка = &ЗПС_Ссылка
	               |	И НЕ(ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	               |				ИЛИ ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗаказПоставщикуТовары.Номенклатура,
	               |	ЗаказПоставщикуТовары.Номенклатура.ГТИН
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Товары.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТКомплектующиеГН
	               |ИЗ
	               |	ВТ_Товары КАК ВТ_Товары
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	               |		ПО ВТ_Товары.Номенклатура = НоменклатураКоплектующие.Номенклатура
	               |			И (НоменклатураКоплектующие.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	               |				ИЛИ НоменклатураКоплектующие.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)) 
				   //Валетов + 04,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3485
	               |ГДЕ
	               |	НоменклатураКоплектующие.Ссылка В
	               |			(ВЫБРАТЬ
	               |				ВТ_товары.Номенклатура
	               |			ИЗ
	               |				ВТ_товары)  
				   //Валетов -
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ШтрихкодыУпаковокТоваров.Ссылка.Владелец КАК Номенклатура,
	               |	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка,
	               |	ШтрихкодыУпаковокТоваров.Ссылка.Наименование КАК СГТИН
	               |ПОМЕСТИТЬ ВТ_КМ
	               |ИЗ
	               |	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	               |ГДЕ
	               |	ШтрихкодыУпаковокТоваров.ЗаказКМ В
	               |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |				Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	               |			ИЗ
	               |				Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	               |			ГДЕ
	               |				Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = &ЗПС_ссылка)
	               |	И (ШтрихкодыУпаковокТоваров.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
	               |			ИЛИ ШтрихкодыУпаковокТоваров.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор))
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Товары.Номенклатура КАК Номенклатура,
	               |	ВТ_Товары.Номенклатура.Код КАК Номенклатура_Код,
	               |	ВТ_Товары.Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	               |	ВТ_Товары.Количество КАК Количество,
	               |	ВТ_КМ.Ссылка КАК ШтрихкодУпаковки
	               |ИЗ
	               |	ВТ_Товары КАК ВТ_Товары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КМ КАК ВТ_КМ
	               |		ПО (ВТ_КМ.Номенклатура = ВТ_Товары.Номенклатура)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТКомплектующиеГН КАК ВТКомплектующиеГН
	               |		ПО (ВТКомплектующиеГН.Номенклатура = ВТ_КМ.Номенклатура)
	               |ГДЕ
	               |	ВТКомплектующиеГН.Номенклатура ЕСТЬ NULL
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВТ_Товары.Номенклатура.Наименование,
	               |	ВТ_КМ.СГТИН
	               |ИТОГИ
	               |	МАКСИМУМ(ШтукВКоробке),
	               |	МАКСИМУМ(Количество),
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки)
	               |ПО
	               |	Номенклатура";		
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);	
	
	рЗапроса 				= Запрос.Выполнить();	
	
	Выборка_Номенклатура 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");	
	
	ЧислоКодовВДокументе	= 50000;
	НомерДокумента			= 1;
	ДокОбъект 				= Неопределено;
	ВидОперацииИСМП			= Перечисления.ВидыОперацийИСМП.Агрегация;
	
	НомерКА 				= 1;
	
	ГЛН 					= Лев(Справочники.КодыGLN.ПолучитьДействующийГЛН(ЗПС_Ссылка.Организация),9);
	
	рОчистки 				= ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, Перечисления.ВидыОперацийИСМП.Агрегация);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы = рОчистки.СуществующиеДокументы;
		
		Пока Выборка_Номенклатура.Следующий() Цикл		
			Если Выборка_Номенклатура.ШтрихкодУпаковки <> Выборка_Номенклатура.Количество Тогда
				ТекстОшибки = СтрШаблон(
					"Не совпадает количество полученных КМ с количеством в ЗПС ! Кол-во кодов: %1, штук товара в ЗПС: %2, номенклатура: %3 (%4)",					
					 Выборка_Номенклатура.ШтрихкодУпаковки, Выборка_Номенклатура.Количество,
					 Выборка_Номенклатура.Номенклатура, Выборка_Номенклатура.Номенклатура_Код,
				);	
				Результат.Ошибки.Добавить(ТекстОшибки
				);				
				Продолжить;			
			КонецЕсли; 
			ШтукВКоробке	= Выборка_Номенклатура.ШтукВКоробке;
			
			//+++Чирков Д.С. 27.03.2026 MARK-3531 "необходимо при распределении кодов агрегации для импортных заказов выдавать также коды агрегации на неполные короба"
			//НадоСписать	= ШтукВКоробке*Цел(Выборка_Номенклатура.Количество/ШтукВКоробке);
			НадоСписать		= Выборка_Номенклатура.Количество;
			Сч				= 0;
			//---Чирков Д.С. 27.03.2026
			
			Выборка = Выборка_Номенклатура.Выбрать();
			
			Пока Выборка.Следующий() И НадоСписать > 0 Цикл
				Если ДокОбъект <> Неопределено И ДокОбъект.ШтрихКодыУпаковок.Количество() >= ЧислоКодовВДокументе И НадоСписать % Выборка_Номенклатура.ШтукВКоробке = 0 Тогда					
					ДокОбъект.ЗаполнитьТоварыПоКМ();
					
					ДокОбъект.Дата	= ТекущаяДата();
					ДокОбъект.ПометкаУдаления = Ложь;
					ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
					
					рЗаполнения = ЗаполнитьКодыКоробокДляИмпорта(ДокОбъект);
					Если рЗаполнения.Успешно Тогда
						ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
						ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
					Иначе
						МаркировкаКС.ДобавитьОшибки(Результат, рЗаполнения);
					КонецЕсли; 
					
					Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
				
					НомерДокумента	= НомерДокумента + 1;					
					ДокОбъект		= Неопределено;
				КонецЕсли;							
				
				Если ДокОбъект = Неопределено Тогда
					ДокОбъект = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокМаркировки(ЗПС_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);					
				КонецЕсли;				
				
				СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
				СтрокаТЧ.ШтрихкодУпаковки	= Выборка.ШтрихкодУпаковки;
				СтрокаТЧ.КодАгрегации		= НомерКА;		
				
				//+++Чирков Д.С. 27.03.2026 MARK-3531
				Сч = Сч + 1;
				//---Чирков Д.С. 27.03.2026
				
				НадоСписать = НадоСписать - 1;
				//+++Чирков Д.С. 27.03.2026 MARK-3531
				//Если НадоСписать % ШтукВКоробке = 0 Тогда
				Если Сч % ШтукВКоробке = 0 Тогда
				//---Чирков Д.С. 27.03.2026					
					НомерКА = НомерКА + 1;
				КонецЕсли; 
			КонецЦикла;
			
			//+++Чирков Д.С. 27.03.2026 MARK-3531
			Если Сч % ШтукВКоробке <> 0 Тогда
				НомерКА = НомерКА + 1;			
			КонецЕсли;			           
			//---Чирков Д.С. 27.03.2026
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли; 
	
	Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество() > 0 Тогда		
		ДокОбъект.ЗаполнитьТоварыПоКМ();
		
		ДокОбъект.Дата	= ТекущаяДата();
		ДокОбъект.ПометкаУдаления = Ложь; 
		ДокОбъект.Записать(РежимЗаписиДокумента.Запись);	
		
		рЗаполнения = ЗаполнитьКодыКоробокДляИмпорта(ДокОбъект);
		Если рЗаполнения.Успешно Тогда
			ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рЗаполнения);
		КонецЕсли;
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов > 0);
	
	Возврат Результат;
	
КонецФункции //СоздатьАгрегацииКЗПС(ЗПС_Ссылка)

Функция СоздатьАгрегацииККП(КП_Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура.ГТИН 	КАК ГТИН,
	|	Номенклатура 		КАК Номенклатура,
	|	СУММА(Количество)	КАК Количество
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ.КонтрактСПроизводителем.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	Ссылка = &КП_Ссылка
	|	И НЕ(
	|		Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|		ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)
	|	)	
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|;	
	|ВЫБРАТЬ
	|	Ссылка.Владелец 	КАК Номенклатура,
	|	Ссылка 				КАК Ссылка,
	|	Ссылка.Наименование КАК СГТИН
	|ПОМЕСТИТЬ ВТ_КМ
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ЗаказКМ В
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		Ссылка
	|	ИЗ
	|		Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|	ГДЕ
	|		Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = &КП_Ссылка
	|	)
	|	И (
	|		ШтрихкодыУпаковокТоваров.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)	
	|	    ИЛИ ШтрихкодыУпаковокТоваров.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|	)	
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура	
	|;	
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура 							КАК Номенклатура,
	|	ВТ_Товары.Номенклатура.Код 						КАК Номенклатура_Код,
	|	ВТ_Товары.Номенклатура.Родитель.ШтукВКоробке 	КАК ШтукВКоробке,
	|	ВТ_Товары.Количество 							КАК Количество,
	|	ВТ_КМ.Ссылка									КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_КМ КАК ВТ_КМ
	|ПО 
	|	ВТ_КМ.Номенклатура = ВТ_Товары.Номенклатура	
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Товары.Номенклатура.Наименование,
	|	ВТ_КМ.СГТИН
	|ИТОГИ
	|	МАКСИМУМ(ШтукВКоробке),
	|	МАКСИМУМ(Количество),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки)
	|ПО
	|	Номенклатура";		
	
	Запрос.УстановитьПараметр("КП_Ссылка", КП_Ссылка);	
	
	рЗапроса 				= Запрос.Выполнить();	
	
	Выборка_Номенклатура 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");	
	
	ЧислоКодовВДокументе	= 50000;
	НомерДокумента			= 1;
	ДокОбъект 				= Неопределено;
	ВидОперацииИСМП			= Перечисления.ВидыОперацийИСМП.Агрегация;
	
	НомерКА 				= 1;
	
	ГЛН 					= Лев(Справочники.КодыGLN.ПолучитьДействующийГЛН(КП_Ссылка.Организация), 9);
	
	рОчистки 				= ОчиститьПодчиненныеДокументыМаркировки(КП_Ссылка, Перечисления.ВидыОперацийИСМП.Агрегация);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы = рОчистки.СуществующиеДокументы;
		
		Пока Выборка_Номенклатура.Следующий() Цикл		
			Если Выборка_Номенклатура.ШтрихкодУпаковки <> Выборка_Номенклатура.Количество Тогда
				ТекстОшибки = СтрШаблон(
					"Не совпадает количество полученных КМ с количеством в КП ! Кол-во кодов: %1, штук товара в КП: %2, номенклатура: %3 (%4)",					
					 Выборка_Номенклатура.ШтрихкодУпаковки, Выборка_Номенклатура.Количество,
					 Выборка_Номенклатура.Номенклатура, Выборка_Номенклатура.Номенклатура_Код,
				);	
				Результат.Ошибки.Добавить(ТекстОшибки
				);				
				Продолжить;			
			КонецЕсли; 
			ШтукВКоробке	= Выборка_Номенклатура.ШтукВКоробке;
			
			// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 {
			// По аналогии с функцией СоздатьАгрегацииКЗПС(ЗПС_Ссылка)
			// "необходимо при распределении кодов агрегации для импортных заказов выдавать также коды агрегации на неполные короба"
			//НадоСписать = ШтукВКоробке*Цел(Выборка_Номенклатура.Количество/ШтукВКоробке);
			НадоСписать = Выборка_Номенклатура.Количество;
			Сч = 0;
			// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 }
			
			Выборка = Выборка_Номенклатура.Выбрать();
			
			Пока Выборка.Следующий() И НадоСписать > 0 Цикл
				Если ДокОбъект <> Неопределено И ДокОбъект.ШтрихКодыУпаковок.Количество() >= ЧислоКодовВДокументе И НадоСписать % Выборка_Номенклатура.ШтукВКоробке = 0 Тогда					
					ДокОбъект.ЗаполнитьТоварыПоКМ();
					
					ДокОбъект.Дата	= ТекущаяДата();
					ДокОбъект.ПометкаУдаления = Ложь;
					ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
					
					рЗаполнения = ЗаполнитьКодыКоробокДляИмпорта(ДокОбъект);
					Если рЗаполнения.Успешно Тогда
						ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
						ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
					Иначе
						МаркировкаКС.ДобавитьОшибки(Результат, рЗаполнения);
					КонецЕсли; 
					
					Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
				
					НомерДокумента	= НомерДокумента + 1;					
					ДокОбъект		= Неопределено;
				КонецЕсли;							
				
				Если ДокОбъект = Неопределено Тогда
					ДокОбъект = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокМаркировки(КП_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);					
				КонецЕсли;				
				
				СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
				СтрокаТЧ.ШтрихкодУпаковки	= Выборка.ШтрихкодУпаковки;
				СтрокаТЧ.КодАгрегации		= НомерКА;		
				
				// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 {
				// По аналогии с функцией СоздатьАгрегацииКЗПС(ЗПС_Ссылка)
				// "необходимо при распределении кодов агрегации для импортных заказов выдавать также коды агрегации на неполные короба"
				//НадоСписать = НадоСписать-1;
				//Если НадоСписать % ШтукВКоробке = 0 Тогда
				//	НомерКА = НомерКА + 1; 				
				//КонецЕсли; 
				Сч = Сч + 1;				
				НадоСписать = НадоСписать - 1;
				
				Если Сч % ШтукВКоробке = 0 Тогда
					НомерКА = НомерКА + 1;
				КонецЕсли;
				// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 }
				
			КонецЦикла;

			// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 {
			// По аналогии с функцией СоздатьАгрегацииКЗПС(ЗПС_Ссылка)
			// "необходимо при распределении кодов агрегации для импортных заказов выдавать также коды агрегации на неполные короба"
			Если Сч % ШтукВКоробке <> 0 Тогда
				НомерКА = НомерКА + 1;			
			КонецЕсли;			           
			// Кельманов А.В. - Проблема 0000000220 - 2026.07.15 }

		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли; 
	
	Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество() > 0 Тогда		
		ДокОбъект.ЗаполнитьТоварыПоКМ();
		
		ДокОбъект.Дата	= ТекущаяДата();
		ДокОбъект.ПометкаУдаления = Ложь; 
		ДокОбъект.Записать(РежимЗаписиДокумента.Запись);	
		
		рЗаполнения = ЗаполнитьКодыКоробокДляИмпорта(ДокОбъект);
		Если рЗаполнения.Успешно Тогда
			ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рЗаполнения);
		КонецЕсли;
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов > 0);
	
	Возврат Результат;	
КонецФункции //СоздатьАгрегацииККП(КП_Ссылка)

Функция ЗаполнитьКодыКоробокДляИмпорта(ДокАгрегации)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если 1 = 2 Тогда
		ДокАгрегации = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
	КонецЕсли;
	
	Коды = ДокАгрегации.ШтрихкодыУпаковок.Выгрузить(,"КодАгрегации");
	Коды.Свернуть("КодАгрегации");
	Коды = Коды.ВыгрузитьКолонку("КодАгрегации");	
	
	НачатьТранзакцию();
	//НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	//РегистрыСведений.СтатусыКМ_Факт.ЗаблокироватьТаблицу();
		
	ДопПараметры 	= Новый Структура("Статус,СпособВводаВОборот", Перечисления.СтатусыКодовМаркировкиФакт.Эмитирован, Перечисления.СпособыВводаВОборотСУЗ.Импорт);		
	рПолучения 		= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСвободныеКодыАгрегации(Перечисления.ТипыШтрихКодов.Коробка, Перечисления.ТипыУпаковок.МонотоварнаяУпаковка, Коды.Количество(), ДопПараметры);
		
	Если рПолучения.Успешно Тогда
		РегистрыСведений.СтатусыКМ_Факт.УстановитьСтатусКМ(рПолучения.Данные, Перечисления.СтатусыКодовМаркировкиФакт.ПереданПоставщику, ДокАгрегации.Ссылка, Новый Структура("ИспользоватьУправляемыеБлокировки", Истина));
		
		Если ТранзакцияАктивна() Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
		
		КодыКоробок = Новый Соответствие;
		Для Сч = 0 По Коды.Количество() - 1 Цикл
			КодыКоробок[Коды[Сч]] = рПолучения.Данные[Сч];			
		КонецЦикла; 
		
		Для Каждого СтрокаТЧ Из ДокАгрегации.ШтрихкодыУпаковок Цикл
			СтрокаТЧ.ШтрихкодКоробки = КодыКоробок[СтрокаТЧ.КодАгрегации];		
			СтрокаТЧ.КодАгрегации = СтрокаТЧ.ШтрихкодКоробки;
		КонецЦикла; 
	Иначе
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;		
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ЗаполнитьКодыКоробок(ДокАгрегации) 

Функция СоздатьАгрегацииКЗПСпоВыбраннымКодам(ЗПС_Ссылка, ТаблицаАгрегации, Очищать = Ложь) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ТаблицаАгрегации_Нов ИЗ &ТаблицаАгрегации КАК ТаблицаАгрегации 
	|;
	|ВЫБРАТЬ
	|	КодАгрегации,
	|	ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ТаблицаАгрегации
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка.ДокументОснование = &ЗПС_Ссылка
	|	И Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И НЕ Ссылка.ПометкаУдаления
	|	И НЕ &Очищать
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	КодАгрегации,
	|	ШтрихкодУпаковки	
	|ИЗ
	|	ВТ_ТаблицаАгрегации_Нов	
	|;	
	|ВЫБРАТЬ
	|	КодАгрегации									КАК КодАгрегации,
	|
	|	ШтрихкодУпаковки.Владелец						КАК Номенклатура,	
	|	ШтрихкодУпаковки.Владелец.Родитель.ШтукВКоробке	КАК ШтукВКоробке,
	|	ШтрихкодУпаковки								КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ТаблицаАгрегации	
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодУпаковки.Владелец.Наименование,
	|	КодАгрегации,
	|	ШтрихкодУпаковки.Наименование
	|ИТОГИ ПО
	|	КодАгрегации
	|";
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", 		ЗПС_Ссылка);
	Запрос.УстановитьПараметр("ТаблицаАгрегации",	ТаблицаАгрегации);
	Запрос.УстановитьПараметр("Очищать",			Очищать);
	
	рЗапроса 				= Запрос.Выполнить();	
	
	Выборка_КодАгрегации 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "КодАгрегации");	
	
	ЧислоКодовВДокументе	= 50000;
	НомерДокумента			= 1;
	ДокОбъект 				= Неопределено;
	ВидОперацииИСМП			= Перечисления.ВидыОперацийИСМП.Агрегация;
	
	рОчистки 				= ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, Перечисления.ВидыОперацийИСМП.Агрегация);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы = рОчистки.СуществующиеДокументы;	
		
		Пока Выборка_КодАгрегации.Следующий() Цикл			
			Выборка = Выборка_КодАгрегации.Выбрать();
			
			Пока Выборка.Следующий() Цикл				
				Если ДокОбъект = Неопределено Тогда
					ДокОбъект	= Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокМаркировки(ЗПС_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);	
				КонецЕсли;				
				
				СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
				СтрокаТЧ.ШтрихкодУпаковки	= Выборка.ШтрихкодУпаковки;
				СтрокаТЧ.КодАгрегации		= Выборка.КодАгрегации;				
			КонецЦикла;
			
			Если ДокОбъект <> Неопределено И ДокОбъект.ШтрихКодыУпаковок.Количество() >= ЧислоКодовВДокументе  Тогда
				ЗаписатьДокументМаркировки(ДокОбъект, РежимЗаписиДокумента.Проведение);					
				Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
				
				НомерДокумента	= НомерДокумента + 1;					
				ДокОбъект		= Неопределено;
			КонецЕсли;							
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли; 
	
	Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество() > 0 Тогда		
		ЗаписатьДокументМаркировки(ДокОбъект, РежимЗаписиДокумента.Проведение);	
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов > 0);
	
	Возврат Результат;	
КонецФункции //СоздатьАгрегацииКЗПСпоВыбраннымКодам(ЗПС_Ссылка, ТаблицаАгрегации) Экспорт

Функция СоздатьАгрегацииКЗПСпоСпискуКМ(ЗПС_Ссылка, КодыМаркировки) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_КМ ИЗ &КодыМаркировки КАК КодыМаркировки
	|;	
	|ВЫБРАТЬ
	|	ШтрихКодКоробки						                КАК ШтрихКодКоробки,
	|	ШтрихКодКоробки.Наименование						КАК КодАгрегации,
	|	ШтрихКодУпаковки.Владелец							КАК Номенклатура,
	|	ШтрихКодУпаковки.Владелец.Код						КАК Номенклатура_Код,
	|	ШтрихКодУпаковки.Владелец.Родитель.ШтукВКоробке		КАК ШтукВКоробке,
	|	1													КАК Количество,
	|
	|	ШтрихКодУпаковки									КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_КМ	
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихКодУпаковки.Владелец.Наименование,
	|	ШтрихКодУпаковки.Наименование
	|ИТОГИ 	
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки)	
	|ПО
	|	Номенклатура,
	|	ШтрихКодКоробки	
	|";		
	
	Запрос.УстановитьПараметр("КодыМаркировки", КодыМаркировки);	
	
	рЗапроса 				= Запрос.Выполнить();	
	
	Выборка_Номенклатура 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");	
	
	МаксЧислоКодовВДокументе= 75000;
	НомерДокумента			= 1;
	ДокОбъект 				= Неопределено;
	ВидОперацииИСМП			= Перечисления.ВидыОперацийИСМП.Агрегация;	
	
	рОчистки 				= ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, Перечисления.ВидыОперацийИСМП.Агрегация);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы  = рОчистки.СуществующиеДокументы;		
		
		Пока Выборка_Номенклатура.Следующий() Цикл		
			Выборка_ШтрихКодКоробки = Выборка_Номенклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихКодКоробки");
			
			Пока Выборка_ШтрихКодКоробки.Следующий() Цикл			
				Выборка = Выборка_ШтрихКодКоробки.Выбрать();
				
				Если ДокОбъект <> Неопределено И (ДокОбъект.ШтрихкодыУпаковок.Количество() + Выборка.Количество()) > МаксЧислоКодовВДокументе Тогда
					ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
					
					ДокОбъект.ЗаполнитьТоварыПоКМ();                
					
					ДокОбъект.ПометкаУдаления	= Ложь;					
					ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);					
					
					//+++Чирков 15.10.2025 MARK-3130 - вынесено в отложенную обработку при проведении - тут не нужно
					//Документы.МаркировкаТоваровИСМП.ПроверитьЗаполнитьСоставАгрегационныхКодов(ДокОбъект.Ссылка);
					//---Чирков 15.10.2025
			
					ДокОбъект = Неопределено;
					
					НомерДокумента = НомерДокумента + 1;
					
					Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
				КонецЕсли;				
				
				Если ДокОбъект = Неопределено Тогда
					ДокОбъект		= Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокМаркировки(ЗПС_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);	
				КонецЕсли;
				
				Пока Выборка.Следующий() Цикл
					СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
					СтрокаТЧ.ШтрихкодУпаковки	= Выборка.ШтрихкодУпаковки;
					СтрокаТЧ.ШтрихкодКоробки	= Выборка.ШтрихкодКоробки;
					СтрокаТЧ.КодАгрегации		= Выборка.КодАгрегации;				
				КонецЦикла;								
			КонецЦикла;			
			
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли; 
	
	Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество() > 0 Тогда		
		ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;
		
		ДокОбъект.ЗаполнитьТоварыПоКМ();
		
		ДокОбъект.ПометкаУдаления = Ложь; 
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
		
		//+++Чирков 15.10.2025 MARK-3130 - вынесено в отложенную обработку при проведении - тут не нужно
		//Документы.МаркировкаТоваровИСМП.ПроверитьЗаполнитьСоставАгрегационныхКодов(ДокОбъект.Ссылка);
		//---Чирков 15.10.2025
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов > 0);
	
	Возврат Результат;
	
КонецФункции //СоздатьАгрегацииКЗПС(ЗПС_Ссылка)

Функция СоздатьБронированиеSSCCкЗПС(ЗПС_Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ПустаяСсылка();
	ПодчДокументы = ПолучитьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, ВидОперацииИСМП);
	
	Если ПодчДокументы.Количество() = 0  Тогда
		КоличествоКодовSSCC = КоличествоМоноКоробокЗПС(ЗПС_Ссылка);	
	
		Если КоличествоКодовSSCC > 0 Тогда
			ДокОбъект = ПолучитьСоздатьДокМаркировки(ЗПС_Ссылка, Новый Соответствие, 0, ВидОперацииИСМП);
			
			ДокОбъект.ВидОперацииИСМП		= Неопределено;
			ДокОбъект.ВидОперации 			= Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов;
			ДокОбъект.КоличествоКодовSSCC   = КоличествоКодовSSCC;
			ДокОбъект.Статус				= Перечисления.СтатусыДокументовМаркировки.КОбработке; 								
			ДокОбъект.ПодразделениеНанесения= ПолучитьРеквизитШапки(ЗПС_Ссылка, "Контрагент");
			ДокОбъект.фКодыАгрегацийДляПоставщиков = Истина;
			
			Попытка
			    ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);			
				Результат.ОбработаноОбъектов = 1;
				Результат.Успешно = Истина;
			Исключение
				Результат.Ошибки.Добавить("Не удалось забронировать коды SSCC ! "+ОписаниеОшибки());			
			КонецПопытки;
		Иначе
			Результат.Ошибки.Добавить("В ЗПС "+ЗПС_Ссылка+" нулевое количество моно-коробов с маркируемым товаром !");			
		КонецЕсли;
	Иначе
		Результат.Ошибки.Добавить("К ЗПС "+ЗПС_Ссылка+" уже оформлены агрегации или бронирования !");
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //СоздатьБронированиеSSCCкЗПС(ЗПС_Ссылка)

Функция КоличествоМоноКоробокЗПС(ЗПС_Ссылка)
	Результат = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	Номенклатура,
	|	Номенклатура.Родитель.ШтукВКоробке	КАК ШтукВКоробке,
	|	СУММА(Количество) 					КАК Количество	
	|ИЗ
	|	" + ЗПС_Ссылка.Метаданные().ПолноеИмя() + ".Товары
	|ГДЕ
	|	Ссылка = &ЗПС_Ссылка
	|	И НЕ (
	|		Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|		ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)
	|	)		
	|СГРУППИРОВАТЬ ПО	
	|	Номенклатура
	|";		
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат = Результат + Цел(Выборка.Количество/Выборка.ШтукВКоробке);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //КоличествоЦелыхКоробокЗПС(ЗПС_Ссылка) 

Функция ЗаписатьДокументМаркировки(ДокОбъект, Знач РежимЗаписи = Неопределено) Экспорт	
	Если РежимЗаписи = Неопределено Тогда
		Если ДокОбъект.Проведен Тогда			
		    РежимЗаписи = РежимЗаписиДокумента.Проведение;
		Иначе
			РежимЗаписи = РежимЗаписиДокумента.Запись;			
		КонецЕсли; 		
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ДокОбъект.ПометкаУдаления = Ложь;	
	КонецЕсли;
	
	ДокОбъект.ЗаполнитьТоварыПоКМ();
					
	ДокОбъект.ПометкаУдаления = Ложь;
	ДокОбъект.Записать(РежимЗаписи);
КонецФункции //ЗаписатьДокументМаркировки(ДокОбъект, Знач РежимЗаписи = Неопределено)	

Функция ПолучитьПоследнийКодАгрегации(Организация, ДокументОснование = Неопределено) Экспорт
	Запрос = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодАгрегации
	|ПОМЕСТИТЬ ВТ_1
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|ГДЕ
	|	(Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|				И Ссылка.ДокументОснование <> &ДокументОснование
	|			ИЛИ Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов))
	//|	И Ссылка.Организация = &Организация
	|	И ПОДСТРОКА(КодАгрегации, 2, 9) = &Префикс
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.МаркировкаТоваровИСМП
	|
	|УПОРЯДОЧИТЬ ПО
	|	МаркировкаТоваровИСМПШтрихкодыУпаковок.КодАгрегации УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Наименование КАК КодАгрегации
	|ПОМЕСТИТЬ ВТ_2
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|	И НЕ Наименование ПОДОБНО ""%\_%"" СПЕЦСИМВОЛ ""\""
	//|	И ШтрихкодыУпаковокТоваров.ЗаказКМ.Организация = &Организация
	|	И ПОДСТРОКА(Наименование, 2, 9) = &Префикс
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодАгрегации УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сводный.КодАгрегации КАК КодАгрегации
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВТ_1.КодАгрегации КАК КодАгрегации
	|	ИЗ
	|		ВТ_1 КАК ВТ_1
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВТ_2.КодАгрегации
	|	ИЗ
	|		ВТ_2 КАК ВТ_2) КАК Сводный
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сводный.КодАгрегации УБЫВ";
	
	Запрос.УстановитьПараметр("Организация", 		Организация);	
	Запрос.УстановитьПараметр("ДокументОснование", 	ДокументОснование);	
	// Кухарь А.Ю.  01.10.2024 начало                                              
	GLN = Лев(Справочники.КодыGLN.ПолучитьДействующийГЛН(Организация), 9);
	Запрос.УстановитьПараметр("Префикс", GLN);		 
	// Кухарь А.Ю.  01.10.2024 конец
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КодАгрегации) Тогда
		Результат = Число(Лев(Прав(СокрЛП(Выборка.КодАгрегации),8),7));
	Иначе
		Результат = 0;			
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьПоследнийКодАгрегации(Организация, ДокументОснование = Неопределено) Экспорт

Функция СформироватьSSCC(ПрефиксGLN, Номер, Расширение = 0) Экспорт
	Результат = ""+Расширение+ПрефиксGLN+Формат(Номер, "ЧЦ=7; ЧВН=; ЧГ=");
	
	Возврат Результат + МаркировкаКС.КонтрольныйСимволSSCC(Результат);
КонецФункции // ()

Функция Создать_ЗапросыНаАТК_МАШ(МАШ_Ссылка, Знач ДопПараметры = Неопределено) Экспорт
	Результат 			= МаркировкаКС.СтруктураРезультата(Ложь);
	
	ВидОперацииИСМП		= Перечисления.ВидыОперацийИСМП.АТК;     
	
	Если ТипЗнч(ДопПараметры) <> Тип("Структура") Тогда
		ДопПараметры = Новый Структура;	
	КонецЕсли;
	
	ЧислоКодовВПорции	= 90000;
	НомерДокумента		= 1;	
	
	рОчистки 			= ОчиститьПодчиненныеДокументыМаркировки(МАШ_Ссылка, Перечисления.ВидыОперацийИСМП.АТК);	
	
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы	= рОчистки.СуществующиеДокументы;		
		
		ДопПараметры.Вставить("ДлиннаКодаТНВЭД", 10); // Кухарь А.Ю.  28.08.2024 - полный код ТНВЭД
		рЗапроса				= Получить_КодыМаркировкиМАШ_ДляАТК(МАШ_Ссылка, ДопПараметры); 
		
		Выборка_ПорядковыйНомерАТК = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ПорядковыйНомерАТК");
		Если Выборка_ПорядковыйНомерАТК.Количество() = 0 Тогда
			Результат.Ошибки.Добавить("Не найдены КМ к МАШ " + МАШ_Ссылка + " !");
		КонецЕсли;
		
		Пока Выборка_ПорядковыйНомерАТК.Следующий() Цикл			
			Выборка_ТНВЭД = Выборка_ПорядковыйНомерАТК.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ТНВЭД_Группа");		
			
			Пока Выборка_ТНВЭД.Следующий() Цикл
				ДокОбъект = Неопределено;			
				ОсновнойДокумент = Документы.МаркировкаТоваровИСМП.ПустаяСсылка();
				
				Выборка = Выборка_ТНВЭД.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если ДокОбъект = Неопределено Тогда
						ДокОбъект			= ПолучитьСоздатьДокМаркировки(МАШ_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);
						ДокОбъект.ТНВЭД 	= Справочники.ТНВЭД.НайтиПоКоду(Выборка_ТНВЭД.ТНВЭД_Группа);
						
						ДокОбъект.Комментарий = "Порядковый № АТК: " + Выборка_ПорядковыйНомерАТК.ПорядковыйНомерАТК;
					КонецЕсли;
					
					Если Выборка.КМ_Штука_Наименование = Null Тогда Продолжить КонецЕсли;
					
					СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
					СтрокаТЧ.ШтрихкодУпаковки	= Выборка.КМ_Штука;
					
					Если ДокОбъект.ШтрихкодыУпаковок.Количество() >= ЧислоКодовВПорции Тогда
						рПроведения = ПровестиДокумент(ДокОбъект);
						Если НЕ рПроведения.Успешно Тогда
							МаркировкаКС.ДобавитьОшибки(Результат, рПроведения);					
						КонецЕсли; 
						
						Если НЕ ЗначениеЗаполнено(ОсновнойДокумент) И ТипЗнч(ДокОбъект.ДокументОснование) <> Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
							ОсновнойДокумент = ДокОбъект.Ссылка;					
						КонецЕсли; 
						
						НомерДокумента	= НомерДокумента + 1;
						
						ДокОбъект		= ПолучитьСоздатьДокМаркировки(МАШ_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперацииИСМП);
						ДокОбъект.ТНВЭД	= Справочники.ТНВЭД.НайтиПоКоду(Выборка_ТНВЭД.ТНВЭД_Группа);
						ДокОбъект.Комментарий = "Порядковый № АТК: " + Выборка_ПорядковыйНомерАТК.ПорядковыйНомерАТК;
						
						ДокОбъект.ДокументОснование = ОсновнойДокумент; 				
					КонецЕсли; 
				КонецЦикла;			
				
				Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество()>0 Тогда
					рПроведения = ПровестиДокумент(ДокОбъект);
					Если НЕ рПроведения.Успешно Тогда
						МаркировкаКС.ДобавитьОшибки(Результат, рПроведения);					
					КонецЕсли;									
					
					НомерДокумента	= НомерДокумента + 1;				
				КонецЕсли;				
			КонецЦикла;		
		КонецЦикла;	
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
		
		Возврат Результат;
	КонецЕсли;
	
	Результат.ОбработаноОбъектов = НомерДокумента - 1;
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);
	
	Возврат Результат;	
КонецФункции //СоздатьАгрегацииКЗПС(ЗПС_Ссылка)

Функция ПровестиДокумент(ДокОбъект)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ДокОбъект.ПометкаУдаления = Ложь;				  
				
	Попытка
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение                                              
		ДокОбъект.Записать();
		
		ТекстОшибки = СтрШаблон("Не удалось провести документ: %1. Причина: %2.", ДокОбъект.Ссылка, ОписаниеОшибки());
		
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(ТекстОшибки);						
	КонецПопытки;
	
	Возврат Результат;
КонецФункции // ()
 

Функция Создать_ВводВОборот_МАШ(МАШ_Ссылка) Экспорт
	Результат 			= МаркировкаКС.СтруктураРезультата(Ложь);			
	
	ВидОперации			= Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт;
	
	ЧислоКодовВПорции	= 10000;
	НомерДокумента		= 1;	
	
	рОчистки 			= ОчиститьПодчиненныеДокументыМаркировки(МАШ_Ссылка, ВидОперации);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы	= рОчистки.СуществующиеДокументы;
		рЗапроса				= Получить_КодыМаркировкиМАШ_ДляАТК(МАШ_Ссылка);
		
		Выборка_ТНВЭД = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ТНВЭД_Группа");
		Если Выборка_ТНВЭД.Количество() = 0 Тогда
			Результат.Ошибки.Добавить("Не найдены КМ к МАШ: "+МАШ_Ссылка+" !");
		КонецЕсли;
		
		ДокОбъект = Неопределено;
		
		Пока Выборка_ТНВЭД.Следующий() Цикл
			Выборка_СтавкаНДС = Выборка_ТНВЭД.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "СтавкаНДС"); 
			Пока Выборка_СтавкаНДС.Следующий() Цикл
				
				Выборка_Модель = Выборка_СтавкаНДС.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Модель");
				Пока Выборка_Модель.Следующий() Цикл
					Выборка = Выборка_Модель.Выбрать();
					Пока Выборка.Следующий() Цикл
						Если ДокОбъект = Неопределено Тогда 
							ДокОбъект			= ПолучитьСоздатьДокМаркировки(МАШ_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперации);
							ДокОбъект.ТНВЭД 	= Справочники.ТНВЭД.НайтиПоКоду(Выборка_ТНВЭД.ТНВЭД_Группа);
							ДокОбъект.СтавкаНДС	= Выборка_СтавкаНДС.СтавкаНДС;
						ИначеЕсли ДокОбъект.ШтрихКодыУпаковок.Количество() >= ЧислоКодовВПорции Тогда							
							ДокОбъект.ПометкаУдаления = Ложь;						
							ДокОбъект.Записать();												
							
							НомерДокумента	= НомерДокумента + 1;
							
							ДокОбъект		= ПолучитьСоздатьДокМаркировки(МАШ_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперации);							
							ДокОбъект.ТНВЭД = Справочники.ТНВЭД.НайтиПоКоду(Выборка_ТНВЭД.ТНВЭД_Группа);
						КонецЕсли;					
						
						СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
						СтрокаТЧ.ШтрихкодУпаковки	= Выборка.КМ_Штука;			
					КонецЦикла; 
				КонецЦикла;				
			КонецЦикла;
		КонецЦикла;		
		
		Если ДокОбъект<>Неопределено И ДокОбъект.ШтрихкодыУпаковок.Количество()>0 Тогда
			ДокОбъект.ПометкаУдаления = Ложь;				  
			
			Попытка
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение                                              
				ДокОбъект.Записать();
				
				ТекстОшибки = СтрШаблон("Не удалось провести документ: %1. Причина: %2.", ДокОбъект.Ссылка, ОписаниеОшибки());
				
				Результат.Успешно = Ложь;
				Результат.Ошибки.Добавить(ТекстОшибки);						
			КонецПопытки;					
			
			НомерДокумента	= НомерДокумента + 1;				
		КонецЕсли;
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
		
		Возврат Результат;
	КонецЕсли;
	
	Результат.ОбработаноОбъектов = НомерДокумента - 1;
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов>0);
	
	Возврат Результат;
	
КонецФункции //Создать_ВводВОборот_МАШ(МАШ_Ссылка)

Функция Создать_ВводВОборот_МАШ_АТК(МАШ_Ссылка) Экспорт
	Результат 			= МаркировкаКС.СтруктураРезультата(Ложь);			
	
	ВидОперации			= Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт;
	
	ЧислоКодовВПорции	= 10000;
	НомерДокумента		= 1;	
	
	рОчистки 			= ОчиститьПодчиненныеДокументыМаркировки(МАШ_Ссылка, ВидОперации);
	Если рОчистки.Успешно Тогда
		СуществующиеДокументы	= рОчистки.СуществующиеДокументы;
		КодыАТК					= ПолучитьКодыАТКпоМашине(МАШ_Ссылка);		
		
		Если КодыАТК.Количество() = 0 Тогда
			Результат.Ошибки.Добавить("Не найдены АТК к МАШ: "+МАШ_Ссылка+" !");
		КонецЕсли;
		
		ДокОбъект = Неопределено;
		
		ДокОбъект = ПолучитьСоздатьДокМаркировки(МАШ_Ссылка, СуществующиеДокументы, НомерДокумента, ВидОперации);
		
		Если 1 = 2 Тогда
			ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();		
		КонецЕсли;
		
		ДокОбъект.ШтрихкодыУпаковок.Очистить();
		Для Каждого КодАТК Из КодыАТК Цикл		
			СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
			СтрокаТЧ.ШтрихкодУпаковки	= КодАТК;						
		КонецЦикла;
		
		ДокОбъект.ПометкаУдаления = Ложь;						
		
		ДокОбъект.Записать();		
			
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение                                              
			ДокОбъект.Записать();
			
			ТекстОшибки = СтрШаблон("Не удалось провести документ: %1. Причина: %2.", ДокОбъект.Ссылка, ОписаниеОшибки());
			
			Результат.Успешно = Ложь;
			Результат.Ошибки.Добавить(ТекстОшибки);						
		КонецПопытки;		
	Иначе
		Результат.Успешно = Ложь;
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
		
		Возврат Результат;
	КонецЕсли;
	
	Результат.ОбработаноОбъектов = НомерДокумента - 1;
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И Результат.ОбработаноОбъектов>0);
	
	Возврат Результат;
	
КонецФункции //Создать_ВводВОборот_МАШ_АТК(МАШ_Ссылка)

Функция ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, ВидОперацииИСМП) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ПодчДокументы = ПолучитьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, ВидОперацииИСМП);
	
	Для Каждого СтрокаПД Из ПодчДокументы Цикл
		Если НЕ (
			СтрокаПД.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе 
			ИЛИ СтрокаПД.Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке ) Тогда
			
			ТекстОшибки = СтрШаблон("Недопустимый статус заказа на КМ: '%1', тек. статус: '%2', допустимые статусы: 'В работе' или 'К обработке'.", СтрокаПД.Ссылка, СтрокаПД.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли; 	
	КонецЦикла;
	
	СуществующиеДокументы = Новый Соответствие;
	
	Сч = 1;
	Если Результат.Ошибки.Количество() = 0 Тогда
		
		
		НачатьТранзакцию();
		
		Для Каждого СтрокаПД Из ПодчДокументы Цикл
			ДокОбъект = СтрокаПД.Ссылка.ПолучитьОбъект();
			
			ДокОбъект.Статус 			= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
			ДокОбъект.ИД_ДокументаЧЗ    = "";
			
			ДокОбъект.Товары.Очистить();
			ДокОбъект.ШтрихкодыУпаковок.Очистить();
			ДокОбъект.ШтрихкодыКоробок.Очистить();
			
			ДокОбъект.Проведен 			= Ложь;
			ДокОбъект.ПометкаУдаления 	= Истина;
		
			ДокОбъект.Записать();
			
			НЗ = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(ДокОбъект.Ссылка, Истина);
			НЗ.Записать();
			
			НЗ = РегистрыСведений.СтатусыКМ_Факт_А.СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(ДокОбъект.Ссылка, Истина);
			НЗ.Записать();
			
			НЗ = РегистрыСведений.ИспользованныеКодыАгрегаций.СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(ДокОбъект.Ссылка, Истина);
			НЗ.Записать();			
			
			СуществующиеДокументы[Сч] = ДокОбъект.Ссылка;
			Сч	= Сч+1;
		КонецЦикла;		
		
		ЗафиксироватьТранзакцию();	
	Иначе
		Результат.Успешно = Ложь;
	КонецЕсли; 
	
	Результат.Вставить("СуществующиеДокументы", СуществующиеДокументы);

	Возврат Результат;
КонецФункции //ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка)

Функция ПолучитьПодчиненныеДокументыМаркировки(ДокументОснование, ВидОперацииИСМП)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка
	|ПОМЕСТИТЬ ВТ_Основные
	|ИЗ	
	|	Документ.МаркировкаТоваровИСМП
	|ГДЕ
	|	ДокументОснование	= &ДокументОснование
	|	И ВидОперацииИСМП	= &ВидОперацииИСМП
	|;
	|ВЫБРАТЬ
	|	Ссылка,
	|	Ссылка.Статус 	КАК Статус,
	|	1	 			КАК Порядок,
	|	Ссылка			КАК Основной
	|ИЗ
	|	ВТ_Основные
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	Дополнительные.Ссылка,
	|	Дополнительные.Ссылка.Статус 	КАК Статус,
	|	2					 			КАК Порядок,
	|	ВТ_Основные.Ссылка				КАК Основной
	|ИЗ	
	|	Документ.МаркировкаТоваровИСМП КАК Дополнительные
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	ВТ_Основные
	|ПО
	|	Дополнительные.ДокументОснование = ВТ_Основные.Ссылка		
	|	И Дополнительные.ВидОперацииИСМП = &ВидОперацииИСМП	
	|УПОРЯДОЧИТЬ ПО
	|	Порядок
	|";
	
	Запрос.УстановитьПараметр("ДокументОснование",	ДокументОснование);
	Запрос.УстановитьПараметр("ВидОперацииИСМП",	ВидОперацииИСМП);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьПодчиненныеДокументыМаркировки(ДокументОснование, ВидОперацииИСМП)
 
Функция Получить_КодыМаркировкиЗПС_ДляАТК(ЗПС_Ссылка)
	Запрос	= Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ДокументОснование КАК ЗПС,
	|	Ссылка КАК Эмиссия
	|ПОМЕСТИТЬ ВТ_Эмиссии	
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|ГДЕ
	|	ДокументОснование = &ЗПС_Ссылка
	|;			
	|ВЫБРАТЬ	
	|	ПОДСТРОКА(ШК_ЧЗ.Владелец.Родитель.ТНВЭД.Код,1,4)	КАК ТНВЭД_Группа,
	|	ШК_ЧЗ.Владелец.Родитель 							КАК Модель,
	|	ШК_ЧЗ.Владелец.Родитель.Код							КАК Модель_Код,
	
	|	ШК_ЧЗ.Владелец 								КАК Номенклатура,
	|	ШК_ЧЗ.Владелец.Родитель.СтавкаНДС			КАК СтавкаНДС,
	|	ШК_ЧЗ.Ссылка 								КАК КМ_Штука,	
	|	ШК_ЧЗ.Ссылка.Наименование 					КАК КМ_Штука_Наименование	
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШК_ЧЗ	
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_Эмиссии
	|ПО
	|	ШК_ЧЗ.ЗаказКМ = ВТ_Эмиссии.Эмиссия	
	|ГДЕ
	|	ШК_ЧЗ.ТипКода 	= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
	|УПОРЯДОЧИТЬ ПО
	|	ШК_ЧЗ.Владелец,
	|	ШК_ЧЗ.Наименование
	|ИТОГИ 
	|	КОЛИЧЕСТВО(Различные КМ_Штука)	
	|ПО
	|	ТНВЭД_Группа,
	|	СтавкаНДС,
	|	Модель	
	|";
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);
	
	Возврат Запрос.Выполнить();
КонецФункции //()

Функция Получить_КодыМаркировкиМАШ_ДляАТК(МАШ_Ссылка, ДопПараметры = Неопределено)
	ДлиннаКодаТНВЭД = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДлиннаКодаТНВЭД", 4);
	НомераАТК		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "НомераАТК");
	
	Если НомераАТК = Неопределено Тогда
		НомераАТК = Новый ТаблицаЗначений;
		НомераАТК.Колонки.Добавить("Номенклатура", 			Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		НомераАТК.Колонки.Добавить("ПорядковыйНомерАТК",	ПолучитьОписаниеТиповЧисла(2));
	КонецЕсли;
	
	Запрос	= Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_НомераАТК ИЗ &НомераАТК КАК НомераАТК ИНДЕКСИРОВАТЬ ПО Номенклатура 
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	ТоварыЗПС.Номенклатура
	|ПОМЕСТИТЬ ВТ_НоменклатураЗПС	 
	|ИЗ 
	|	Документ.ЗаказПоставщику.Товары КАК ТоварыЗПС
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ	
	|	Документ.Машина.Заказы КАК ЗаказыМашины
	|ПО
	|	ЗаказыМашины.Заказ = ТоварыЗПС.Ссылка
	//++Данилова Е.В. 21.07.2025 MARK-2484 
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправ
