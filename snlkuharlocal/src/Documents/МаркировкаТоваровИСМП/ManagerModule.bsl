Функция РезультатПроверкиОбработкиРасформированияНабораГНпоЗСБ(Знач ДокументМаркировки)  экспорт 
    Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ТипЗнч(ДокументМаркировки.ДокументОснование) = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ")
		И ДокументМаркировки.ВидОперации = перечисления.ВидыОперацийМаркировки.ФормированиеНабора Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркировкаТоваровИСМП.Ссылка КАК Ссылка,
		|	МаркировкаТоваровИСМП.Статус КАК Статус
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|ГДЕ
		|	МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
		|	И МаркировкаТоваровИСМП.ВидОперации = &ВидОперации
		|	И МаркировкаТоваровИСМП.Проведен";
		
		Запрос.УстановитьПараметр("ВидОперации", Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки);
		Запрос.УстановитьПараметр("ДокументОснование", ДокументМаркировки.ДокументОснование);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
		
			Возврат Результат;	
		Иначе 
			Выборка = РезультатЗапроса.Выбрать(); 
			Выборка.Следующий(); 
			
			Результат.Успешно = Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан ИЛИ  Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ; 
			Возврат Результат; 
		КонецЕсли;
		
	Иначе 
		Возврат Результат; 
	КонецЕсли;

КонецФункции // ПроверкаОбработкиРасформированияНабораГНпоЗСБ()

