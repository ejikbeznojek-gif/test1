		запрос.Текст = СтрЗаменить(запрос.Текст,"ПЕРВЫЕ 1","ПЕРВЫЕ "+КоличествоКодовБронь);
	Иначе 
		запрос.Текст = СтрЗаменить(запрос.Текст,"ПЕРВЫЕ 1","ПЕРВЫЕ "+КоличествоЛистов);
		
	КонецЕсли;
	//запрос.Текст = СтрЗаменить(запрос.Текст,"ПЕРВЫЕ 1","ПЕРВЫЕ "+КоличествоЛистов);
	//--Данилова Е.В. 02.09.2025
	ТЗКоробов				 = запрос.Выполнить().Выгрузить();                                      
	КоличествоСвободныхКодов = ТЗКоробов.Количество();
	//++Данилова Е.В. 02.09.2025  HELP-6414
	Если КоличествоКодовБронь > 0  Тогда
		//++Данилова Е.В. 07.11.2025 без задачи 
		КоличествоКодовБлочковНаЛист = КоличествоКодовБронь/КоличествоЛистов;
		//--Данилова Е.В. 07.11.2025
		если КоличествоСвободныхКодов<>КоличествоКодовБронь тогда
