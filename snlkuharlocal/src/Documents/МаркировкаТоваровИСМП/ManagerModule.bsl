	|       И ШтрихкодыКоробокДляАгрегации.НовыйКодКоробки <> ШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки 
	//++Данилова Е.В. 02.04.2026 MARK-3539
	|		И НЕ &АгрегацииВЛП
	//--Данилова Е.В. 02.04.2026
	|
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ШтрихкодыКоробокДляАгрегации.НовыйКодКоробки,
	|		ШтрихкодыКоробокДляАгрегации.НовыйКодКоробки.Наименование,
	|		ВложенныеШтрихкодыСпр.Штрихкод
	|	ИЗ
	|		Документ.ЛистПереукладки.ШтрихкодыКоробокДляАгрегации КАК ШтрихкодыКоробокДляАгрегации
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкодыСпр
	|			ПО ШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки = ВложенныеШтрихкодыСпр.Ссылка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПОснование
	|			ПО ШтрихкодыКоробокДляАгрегации.Ссылка.ДокОснование = МаркировкаТоваровИСМПОснование.ДокументОснование
	|	ГДЕ
	|		МаркировкаТоваровИСМПОснование.Ссылка = &ДокМаркировки
	|		И ШтрихкодыКоробокДляАгрегации.Ссылка.ДополнительныеАгрегации 
	|       И ШтрихкодыКоробокДляАгрегации.НовыйКодКоробки <> ШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки
	|

	//--Данилова Е.В. 27.05.2025
	
	//Штуки в блочки
	|	ОБЪЕДИНИТЬ
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|		ШтрихкодыУпаковок.ШтрихкодБлочка 				КАК ШтрихкодКоробки,
	|		ШтрихкодыУпаковок.ШтрихкодБлочка.Наименование	КАК КодАгрегации,
	|		ШтрихкодыУпаковок.ШтрихкодУпаковки				КАК ШтрихкодУпаковки 
	|	ИЗ	
	|		Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ 		
	|		Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК ШтрихкодыКоробок
	|	ПО
	|		ШтрихкодыУпаковок.Ссылка = ШтрихкодыКоробок.ДокументОснование
	|	ГДЕ
	|		ШтрихкодыКоробок.Ссылка = &ДокМаркировки
	|		И ШтрихкодыКоробок.Ссылка.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	|		И ШтрихкодыУпаковок.ШтрихкодБлочка <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	//++Данилова Е.В. 27.05.2025  HELP-5109
	|	    И ШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	//|	ОБЪЕДИНИТЬ
	//|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|		ШтрихкодыУпаковок.ШтрихкодБлочка КАК ШтрихкодКоробки,
	//|		ШтрихкодыУпаковок.ШтрихкодБлочка.Наименование КАК КодАгрегации,
	//|		ШтрихкодыУпаковокТоваров.Штрихкод КАК ШтрихкодУпаковки
	//|	ИЗ
	//|		Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК ШтрихкодыКоробок
	//|			ПО ШтрихкодыУпаковок.Ссылка = ШтрихкодыКоробок.ДокументОснование
	//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваров
	//|			ПО ШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваров.Ссылка
	//|	ГДЕ
	//|		ШтрихкодыКоробок.Ссылка = &ДокМаркировки
	//|		И ШтрихкодыКоробок.Ссылка.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	//|		И ШтрихкодыУпаковок.ШтрихкодБлочка <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	//|		И ШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	//|		И ШтрихкодыУпаковок.ШтрихкодУпаковки <> ШтрихкодыУпаковок.ШтрихкодБлочка
	
	//--Данилова Е.В. 27.05.2025  HELP-5109
	|) КАК Сводный
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодКоробки.Наименование,
	|	ШтрихкодУпаковки.Наименование
	|";
	
	Запрос.УстановитьПараметр("ДокМаркировки", ДокМаркировки);
	//++Данилова Е.В. 02.04.2026 MARK-3539
	запрос.УстановитьПараметр("АгрегацииВЛП",МаркировкаС.ЕстьЛПСКодамиЧЗ(ДокМаркировки.ДокументОснование));
	//--Данилова Е.В. 02.04.2026
	
	рШапки		= ПолучитьРеквизитыШапки(ДокМаркировки, "Статус,Проведен");
	
	Если рШапки.Проведен Тогда 
		//++Данилова Е.В. 12.01.2026 MARK-2540 
		//Если рШапки.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки Тогда
		Если СтатусыОбработкиОМ.Найти(рШапки.Статус) <> Неопределено Тогда 
		//--Данилова Е.В. 12.01.2026 
			ДокОбъект	= ДокМаркировки.ПолучитьОбъект();	
			ДокОбъект.ШтрихкодыУпаковок.Загрузить(Запрос.Выполнить().Выгрузить());
			
			Если ЗначениеЗаполнено(НовыйСтатус) Тогда			
				ДокОбъект.Статус = НовыйСтатус;
			КонецЕсли;
			
			Попытка			
				    
				//ДокОбъект.Записать(?(ДокОбъект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));  
				РазбитьОМ(ДокОбъект);				
				Результат.Успешно = Истина;
			Исключение
				ТекстСообщения = СтрШаблон("Ошибка записи документа: '%1' ! %2.", ДокМаркировки, ОписаниеОшибки());
				Результат.Ошибки.Добавить(ТекстСообщения);				
			КонецПопытки;			
		Иначе
			//++Данилова Е.В. 12.01.2026 MARK-2540 
			//Результат.Ошибки.Добавить(СтрШаблон("Недопустимый статус документа Операция Маркироки: '%1' ! Ожидаемый статус: '%2'", рШапки.Статус, Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки));
			Результат.Ошибки.Добавить(СтрШаблон("Недопустимый статус документа Операция Маркироки: '%1' ! Ожидаемый статус: '%2'", рШапки.Статус, СтрСоединить(СтатусыОбработкиОМ," или ")));
			
			//--Данилова Е.В. 12.01.2026 
		КонецЕсли;
	Иначе		
		Результат.Ошибки.Добавить("Документ не проведен !");
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции

Функция ЗаполнитьШтрихкодыУпаковокПоПалетам(ДокМаркировки, НовыйСтатус = Неопределено)	Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Накладная = ПолучитьРеквизитШапки(ДокМаркировки, "ДокументОснование");	
	Если НЕ (ЗначениеЗаполнено(Накладная) И ТипЗнч(Накладная) = Тип("ДокументСсылка.РасходнаяНакладная")) Тогда
		ТекстОшибки = СтрШаблон("Недопустимое значение основания агрегации: %1, основание: %2 (%3) !", ДокМаркировки, Накладная, ТипЗнч(Накладная));
		Результат.Ошибки.Добавить(ТекстОшибки);
		Возврат Результат;
	КонецЕсли; 
	
	Запрос = Новый Запрос;  
	// Кухарь А.Ю.  17.04.2025 начало
	
	ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(Накладная);
	
	если  ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок
		тогда
		// Кухарь А.Ю.  17.04.2025 конец
		
         
		// Кухарь А.Ю.  06.11.2025 начало
		// HELP-7763
		//Запрос.Текст = "
		//|ВЫБРАТЬ 		
		//|	ШтрихкодУпаковкиПаллеты 				КАК ШтрихкодКоробки,
		//|	ШтрихкодУпаковкиПаллеты.Наименование	КАК КодАгрегации,
		//|	ЛистНабора.КодАгрегации					КАК ШтрихкодУпаковки
		//|ИЗ
		//|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		//|ГДЕ
		//|	Документ = &Накладная
		//|	И Ссылка.Проведен
		//|	И ВЫРАЗИТЬ(ЛистНабора.КодАгрегации КАК Справочник.ШтрихКодыУпаковокТоваров)<>ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		//|	И ШтрихкодУпаковкиПаллеты<>ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		//|УПОРЯДОЧИТЬ ПО
		//|	ШтрихкодУпаковкиПаллеты.Наименование,
		//|	ЛистНабора.КодАгрегации.Наименование
		//|";  
		Запрос.Текст = "ВЫБРАТЬ
		|	ТЗСводная.ШтрихкодКоробки КАК ШтрихкодКоробки,
		|	ТЗСводная.КодАгрегации КАК КодАгрегации,
		|	ТЗСводная.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты КАК ШтрихкодКоробки,
		|		ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты.Наименование КАК КодАгрегации,
		|		ПаллетаЛистыНабора.ЛистНабора.КодАгрегации КАК ШтрихкодУпаковки
		|	ИЗ
		|		Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		|	ГДЕ
		|		ПаллетаЛистыНабора.Документ = &Накладная
		|		И ПаллетаЛистыНабора.Ссылка.Проведен
		|		И (ВЫРАЗИТЬ(ПаллетаЛистыНабора.ЛистНабора.КодАгрегации КАК Справочник.ШтрихкодыУпаковокТоваров)) <> ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		|		И ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты <> ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты,
		|		ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты.Наименование,
		|		ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
		|	ИЗ
		|		Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
		|			ПО ПаллетаЛистыНабора.ЛистНабора = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка
		|	ГДЕ
		|		ПаллетаЛистыНабора.Документ = &Накладная
		|		И ПаллетаЛистыНабора.Ссылка.Проведен
		|		И (ВЫРАЗИТЬ(ПаллетаЛистыНабора.ЛистНабора.КодАгрегации КАК Справочник.ШтрихкодыУпаковокТоваров)) = ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		|		И ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)) КАК ТЗСводная
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТЗСводная.КодАгрегации";   	
		// Кухарь А.Ю.  06.11.2025 конец
		
		// Кухарь А.Ю.  17.04.2025 начало
		// 
	Иначе 
		
		Запрос.Текст = "ВЫБРАТЬ различные
		|	ЛистНабораШтрихкодыУпаковок.Ссылка КАК ЛистНабора,
		|	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ПОМЕСТИТЬ КодыЛН
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|ГДЕ
		|	ЛистНабораШтрихкодыУпаковок.Ссылка.Проведен
		|	И ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование = &Накладная
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты КАК ШтрихкодКоробки,
		|	ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты.Наименование КАК КодАгрегации,
		|	КодыЛН.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ИЗ
		|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		|		ЛЕВОЕ СОЕДИНЕНИЕ КодыЛН КАК КодыЛН
		|		ПО ПаллетаЛистыНабора.ЛистНабора = КодыЛН.ЛистНабора
		|ГДЕ
		|	ПаллетаЛистыНабора.Документ = &Накладная
		|	И ПаллетаЛистыНабора.Ссылка.Проведен
		|	И ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты <> ЗНАЧЕНИЕ(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты.Наименование,
		|	ПаллетаЛистыНабора.ЛистНабора.КодАгрегации.Наименование";
		Если  ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков тогда 
			запрос.Текст=СтрЗаменить(запрос.Текст,"ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки","ЛистНабораШтрихкодыУпаковок.ШтрихкодБлочка КАК ШтрихкодУпаковки");
		КонецЕсли;	
	КонецЕсли;
	// Кухарь А.Ю.  17.04.2025 конец
	
	
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	рШапки		= ПолучитьРеквизитыШапки(ДокМаркировки, "Статус,Проведен");
	
	Если рШапки.Проведен Тогда
		Если рШапки.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки Тогда
			ДокОбъект	= ДокМаркировки.ПолучитьОбъект();	
			ДокОбъект.ШтрихкодыУпаковок.Загрузить(Запрос.Выполнить().Выгрузить());
			
			Если ЗначениеЗаполнено(НовыйСтатус) Тогда			
				ДокОбъект.Статус = НовыйСтатус;
			КонецЕсли;
			
			Попытка			
				ДокОбъект.Записать(?(ДокОбъект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
				Результат.Успешно = Истина;
			Исключение
				ТекстСообщения = СтрШаблон("Ошибка записи документа: '%1' ! %2.", ДокМаркировки, ОписаниеОшибки());
				Результат.Ошибки.Добавить(ТекстСообщения);				
			КонецПопытки;			
		Иначе			
			Результат.Ошибки.Добавить(СтрШаблон("Недопустимый статус документа: '%1' !", рШапки.Статус));
		КонецЕсли;
	Иначе		
		Результат.Ошибки.Добавить("Документ не проведен !");
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //ЗаполнитьШтрихкодыУпаковокПоПалетам(Накладная, НовыйСтатус = Неопределено)	Экспорт

Функция ПроверитьЗаполнитьСоставАгрегационныхКодов(ДокАгрегации) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();                     
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодКоробки,
	|	ШтрихкодУпаковки,                         
	//+++Чирков 17.10.2025 MARK-3089
	//|	ШтрихкодУпаковки.Количество КАК Количество
	|	ВЫБОР 
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка) 
	|			ТОГДА ШтрихкодУпаковки.Количество 
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Количество	                
	//---Чирков 17.10.2025
	|ПОМЕСТИТЬ ВТ_ДанныеДокумента
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокАгрегации
	|	И ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВложенныеШтрихкоды.Ссылка	КАК ШтрихкодКоробки,
	|	ВложенныеШтрихкоды.Штрихкод	КАК ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ДанныеСправочника
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ ШтрихкодКоробки ИЗ ВТ_ДанныеДокумента) КАК КодыКоробок	
	|ПО
	|	ВложенныеШтрихкоды.Ссылка = КодыКоробок.ШтрихкодКоробки	
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ВТ_ДанныеДокумента.ШтрихкодКоробки КАК ШтрихкодКоробки	
	|ПОМЕСТИТЬ ВТ_КривыеКодыКоробок
	|ИЗ
	|	ВТ_ДанныеДокумента
	|ПОЛНОЕ СОЕДИНЕНИЕ	
	|	ВТ_ДанныеСправочника	
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодКоробки = ВТ_ДанныеСправочника.ШтрихкодКоробки
	|	И ВТ_ДанныеДокумента.ШтрихкодУпаковки = ВТ_ДанныеСправочника.ШтрихкодУпаковки
	|ГДЕ	
	|	НЕ ВТ_ДанныеДокумента.ШтрихкодКоробки ЕСТЬ NULL
	|	И (
	|		IsNULL(ВТ_ДанныеДокумента.ШтрихкодУпаковки, ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)) 
	|			<> IsNULL(ВТ_ДанныеСправочника.ШтрихкодУпаковки, ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
	|		ИЛИ ВТ_ДанныеДокумента.ШтрихкодКоробки.Количество = 0
	|	)
	|;
	|ВЫБРАТЬ	
	|	ВТ_ДанныеДокумента.ШтрихкодКоробки				КАК ШтрихкодКоробки,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки.Владелец 	КАК Номенклатура,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки.Владелец 	КАК КолНоменклатуры,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки 			КАК ШтрихкодУпаковки_Док,	
	|	ВТ_ДанныеДокумента.Количество					КАК Количество		
	|ИЗ
	|	ВТ_ДанныеДокумента
	|ПРАВОЕ СОЕДИНЕНИЕ	
	|	ВТ_КривыеКодыКоробок
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодКоробки = ВТ_КривыеКодыКоробок.ШтрихкодКоробки	
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ДанныеДокумента.ШтрихкодУпаковки),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КолНоменклатуры),
	|	СУММА(Количество),
	|	МАКСИМУМ(Номенклатура)	
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодКоробки	
	|";
	
	Запрос.УстановитьПараметр("ДокАгрегации", ДокАгрегации);
	
	ТипУпаковки = Неопределено;
	
	Выборка_ШтрихкодКоробки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихкодКоробки");
	Пока Выборка_ШтрихкодКоробки.Следующий() Цикл
		СпрОбъект = Выборка_ШтрихкодКоробки.ШтрихкодКоробки.ПолучитьОбъект();
		
		Если 1=2 Тогда
			СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();		
		КонецЕсли; 
		
		СпрОбъект.ВложенныеШтрихкоды.Очистить();
		Выборка = Выборка_ШтрихкодКоробки.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = СпрОбъект.ВложенныеШтрихкоды.Добавить();		
			СтрокаТЧ.Штрихкод = Выборка.ШтрихкодУпаковки_Док;		
		КонецЦикла;
		
		Если Выборка_ШтрихкодКоробки.КолНоменклатуры = 1 Тогда
			СпрОбъект.ТипУпаковки	= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
			СпрОбъект.Владелец		= Выборка_ШтрихкодКоробки.Номенклатура;
			Если ТипУпаковки = Неопределено Тогда
				ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;			
			КонецЕсли; 
		Иначе
			СпрОбъект.Владелец = Неопределено;		
			СпрОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
			
			ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
		КонецЕсли; 
		
		СпрОбъект.Количество 			= Выборка_ШтрихкодКоробки.Количество;
		
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		СпрОбъект.ДополнительныеСвойства.Вставить("ОтключитьПроверки", Истина);
		
		СпрОбъект.Записать();	
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТипУпаковки) Тогда
		ТипУпаковкиДокумента = ПолучитьРеквизитШапки(ДокАгрегации, "ТипУпаковки");
		Если ТипУпаковкиДокумента <> ТипУпаковки Тогда
			УстановитьРеквизитыОбъекта(ДокАгрегации, Новый Структура("ТипУпаковки", ТипУпаковки));
		КонецЕсли; 
	КонецЕсли;
	
	ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало) / 1000;
	ТекстСообщения = СтрШаблон("Обработка док-та: %1, записано: %2 агр. кодов.", ДокАгрегации, Результат.ОбработаноОбъектов);
	ЗаписатьВЛог("ЗаполнениеАгрегаций", ТекстСообщения, "Информация", , , ВремяВыполнения);
	
	Возврат Результат;
КонецФункции //ПроверитьЗаполнитьСоставАгрегационныхКодов(ДокАгрегации) Экспорт 

Функция ПроверитьЗаполнитьСоставКодовНабора(ДокФормированияНабора) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(ДокФормированияНабора) Тогда
		Если ТипЗнч(ДокФормированияНабора) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
			ВидОперации = ПолучитьРеквизитШапки(ДокФормированияНабора, "ВидОперации");
			Если ВидОперации <> Перечисления.ВидыОперацийМаркировки.ФормированиеНабора Тогда
				ТекстОшибки = СтрШаблон("Неподдерживаемый вид операции: '%1' !",  ВидОперации);
			КонецЕсли;
		Иначе                                                                         
			ТекстОшибки = СтрШаблон("Неподдерживаемый вид обрабатываемого документа: '%1' !",  ТипЗнч(ДокФормированияНабора));
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли;
	Иначе       
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");		
	КонецЕсли;                                                           
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодНабора,
	|	ШтрихкодУпаковки,
	|	ШтрихкодУпаковки.Количество КАК Количество
	|ПОМЕСТИТЬ ВТ_ДанныеДокумента
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокФормированияНабора
	|	И ШтрихкодНабора <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодНабора,
	|	ШтрихкодУпаковки
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВложенныеШтрихкоды.Ссылка	КАК ШтрихкодНабора,
	|	ВложенныеШтрихкоды.Штрихкод	КАК ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ДанныеСправочника
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ ШтрихкодНабора ИЗ ВТ_ДанныеДокумента) КАК КодыНаборов
	|ПО
	|	ВложенныеШтрихкоды.Ссылка = КодыНаборов.ШтрихкодНабора	
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодНабора,
	|	ШтрихкодУпаковки
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ВТ_ДанныеДокумента.ШтрихкодНабора КАК ШтрихкодНабора	
	|ПОМЕСТИТЬ ВТ_КривыеКоды
	|ИЗ
	|	ВТ_ДанныеДокумента
	|ПОЛНОЕ СОЕДИНЕНИЕ	
	|	ВТ_ДанныеСправочника	
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодНабора = ВТ_ДанныеСправочника.ШтрихкодНабора
	|	И ВТ_ДанныеДокумента.ШтрихкодУпаковки = ВТ_ДанныеСправочника.ШтрихкодУпаковки
	|ГДЕ	
	|	НЕ ВТ_ДанныеДокумента.ШтрихкодНабора ЕСТЬ NULL
	|	И (
	|		IsNULL(ВТ_ДанныеДокумента.ШтрихкодУпаковки, ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)) 
	|			<> IsNULL(ВТ_ДанныеСправочника.ШтрихкодУпаковки, ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
	|		ИЛИ ВТ_ДанныеДокумента.ШтрихкодНабора.Количество = 0
	|	)
	|;
	|ВЫБРАТЬ	
	|	ВТ_ДанныеДокумента.ШтрихкодНабора				КАК ШтрихкодНабора,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки.Владелец 	КАК Номенклатура,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки.Владелец 	КАК КолНоменклатуры,
	|	ВТ_ДанныеДокумента.ШтрихкодУпаковки 			КАК ШтрихкодУпаковки_Док,	
	|	ВТ_ДанныеДокумента.Количество					КАК Количество		
	|ИЗ
	|	ВТ_ДанныеДокумента
	|ПРАВОЕ СОЕДИНЕНИЕ	
	|	ВТ_КривыеКоды
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодНабора = ВТ_КривыеКоды.ШтрихкодНабора	
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ДанныеДокумента.ШтрихкодУпаковки),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КолНоменклатуры),
	|	СУММА(Количество),
	|	МАКСИМУМ(Номенклатура)	
	|ПО
	|	ВТ_ДанныеДокумента.ШтрихкодНабора
	|";
	
	Запрос.УстановитьПараметр("ДокФормированияНабора", ДокФормированияНабора);
	
	ТипУпаковки = Неопределено;
	
	Выборка_ШтрихкодНабора = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихкодНабора");
	Пока Выборка_ШтрихкодНабора.Следующий() Цикл
		СпрОбъект = Выборка_ШтрихкодНабора.ШтрихкодНабора.ПолучитьОбъект();
		
		Если 1 = 2 Тогда
			СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();		
		КонецЕсли; 
		
		СпрОбъект.ВложенныеШтрихкоды.Очистить();
		Выборка = Выборка_ШтрихкодНабора.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = СпрОбъект.ВложенныеШтрихкоды.Добавить();		
			СтрокаТЧ.Штрихкод = Выборка.ШтрихкодУпаковки_Док;		
		КонецЦикла;
						
		СпрОбъект.Количество = Выборка_ШтрихкодНабора.Количество;
		
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		СпрОбъект.ДополнительныеСвойства.Вставить("ОтключитьПроверки", Истина);
		
		СпрОбъект.Записать();	
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	КонецЦикла;	
	
	Результат.Успешно = Истина;
	
	Возврат Результат;
КонецФункции //ПроверитьЗаполнитьСоставКодовНабора(ДокФормированияНабора) Экспорт 

Функция ДобавитьШККоробкиВАгрегацию(ДокМаркировки, ЛистНабора, ШтрихКодАгрегации) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	ТипШК_Код = ПолучитьРеквизитШапки(ШтрихКодАгрегации, 	"ТипШК");
	ТипШК_Док = ПолучитьРеквизитШапки(ДокМаркировки, 		"ТипШК");
	Если ТипШК_Код <> ТипШК_Док Тогда
		Результат.Ошибки.Добавить("Не совпадют типы ШК кода и документа !");
		Возврат Результат;	
	КонецЕсли; 	
	
	мШтрихКодАгрегации = ВыдавалсяКодАгрегации(ДокМаркировки, ЛистНабора, ШтрихКодАгрегации);
	Если ЗначениеЗаполнено(мШтрихКодАгрегации) Тогда
		ТекстСообщения = СтрШаблон("Для документа '%1' уже выдавался код агрегации '%2' !", ЛистНабора, мШтрихКодАгрегации);
		Результат.Ошибки.Добавить(ТекстСообщения);
	Иначе					
		ДокОбъект = ДокМаркировки.ПолучитьОбъект();
		Если ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
			ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;					
		КонецЕсли;
		Если НЕ ДокОбъект.Проведен Тогда
		    ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);		
		КонецЕсли;
		
		СтрокаК = ДокОбъект.ШтрихкодыКоробок.Добавить();											
			
		СтрокаК.ШтрихкодКоробки		= ШтрихКодАгрегации;
		СтрокаК.ДокументОснование   = ЛистНабора;
		СтрокаК.ДатаДобавления		= ТекущаяДата();
		
		Попытка
			ДокОбъект.Записать();
			
			Результат.Успешно 	= Истина;						
		Исключение
			ТекстОшибки = СтрШаблон("Не удалось провести документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
			Результат.Ошибки.Добавить(ТекстОшибки);					
		КонецПопытки;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ДобавитьКодАгрегацииИзЛН(ДокументОснование) Экспорт

