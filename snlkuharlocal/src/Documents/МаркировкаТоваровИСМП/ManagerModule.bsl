		КонецЕсли;   
		СтрокаТЗВыборки											= ТЗКоробов.получить(Сч-1);	
		СтрокаТЧ												= ДокОбъект.ШтрихкодыКоробок.получить(СтрокаТЗВыборки.НомерСтроки-1);   //Пишем в эту строку документа агрегации
		если СтрокаТЧ.ДокументОснование	= Неопределено тогда
