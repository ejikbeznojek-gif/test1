Процедура УстановитьПолучателейИзменений(ДокОбъект)	Экспорт
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	мПолучателей = СписокПолучателейИзменений(ДокОбъект);
	Для Каждого УзелПолучатель Из мПолучателей Цикл
		ДокОбъект.ОбменДанными.Получатели.Добавить(УзелПолучатель);
	КонецЦикла;	
	
	//Отправка подтверждений о приеме накладных складом или магазином
КонецПроцедуры

Функция СписокПолучателейИзменений(ДокОбъект, ДопИнфо = Неопределено)
	Если 1=2 Тогда
		ДокОбъект = Документы.ХранилищеКодовМаркировки.СоздатьДокумент();	
	КонецЕсли;
	
	СписокПолучателей	= Новый Массив;
	ЭтотУзел_Код		= Маркировка_ПИ.ЭтотУзел_Код();
	Если НЕ СокрЛП(ДокОбъект.КодУзлаСоздания) = СокрЛП(ЭтотУзел_Код) Тогда //"Чужие" документы никуда не отправляем
		Возврат СписокПолучателей
	КонецЕсли;	
	
	ЭтотУзел			= Маркировка_ПИ.ЭтотУзел();
	
	УправляющийУзел		= Маркировка_ПИ.УправляющийУзел();
	ТипУзла				= Маркировка_ПИ.ТипТекущегоУзла();
	
	ОбменДанными		= ДокОбъект.ОбменДанными;
	Отправитель			= ОбменДанными.Отправитель;
	Загрузка			= ОбменДанными.Загрузка;	
	
	ТипОснования		= ТипЗнч(ДокОбъект.ДокументОснование);
	
	Если ТипУзла = Перечисления.ТипУзлаИБ.Склад 
		ИЛИ ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда //Склады, Филиалы, Магазины.....		
		МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УправляющийУзел, Отправитель, Загрузка);
	Иначе //ЦО
		Если ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") 
			ИЛИ ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Склад		= ПолучитьРеквизитШапки(ДокОбъект.ДокументОснование, "Склад");
			УзелСклада	= Маркировка_ПИ.УзелСклада(Склад);
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСклада, Отправитель, Загрузка);			
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
			СписокПолучателей = ПолучателиПеремещения(ДокОбъект);
		КонецЕсли;		
	КонецЕсли;
	
	Возврат ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(СписокПолучателей, Истина);	
КонецФункции

Функция ПолучитьПравилоВыгрузки(ДопПараметры = Неопределено) Экспорт	
	ОперИмпорта					= "Документ.МаркировкаТоваровИСМП";
	ОперИмпорта_Представление   = "ЗаказКМ";
	
	ИмяТаблицы_Тек	= "Документ.МаркировкаТоваровИСМП";	
	ИмяТаблицы_Ист	= "Документ.МаркировкаТоваровИСМП";
	
	МетаОбъект 		= Метаданные.НайтиПоПолномуИмени(ИмяТаблицы_Тек);
	
	ЗапросыИст = ОбменДаннымиЧЗ.СоздатьТаблицуИменЗапросов();	
	
	#Область ВТ_Ссылки
	
	ТекстЗапросаИзменений = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".Изменения
	|ГДЕ
	|	Узел = &УзелПолучатель	
	|";
	
	ТекстЗапроса = "
	|ВЫБРАТЬ 
	|	Ссылка	
	|ПОМЕСТИТЬ ВТ_Ссылки
	|ИЗ	
	|	" + ИмяТаблицы_Ист + "
	|ГДЕ
	|	Ссылка В (&МассивСсылок)
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|";	
	
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ВТ_Ссылки", ТекстЗапроса, Ложь);
	
	#КонецОбласти
	
	#Область Шапка
	
	Поля = Новый Массив;
	Поля.Добавить("Шапка.Ссылка,Шапка.Номер,Шапка.Дата,Шапка.Проведен,Шапка.ПометкаУдаления");
	Для Каждого МетаРекв Из МетаОбъект.Реквизиты Цикл
		Поля.Добавить("Шапка." + МетаРекв.Имя);			
	КонецЦикла; 
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	" + СтрСоединить(Поля, ",") + "
    |ИЗ	
	|	" + ИмяТаблицы_Ист + " КАК Шапка
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = Шапка.Ссылка
	|УПОРЯДОЧИТЬ ПО 
	|	Дата,Номер
	|";	                                      
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "Шапка", ТекстЗапроса, Истина, Ложь);	
	
	#КонецОбласти
	
	#Область ТЧ_Товары		
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ТЧ.*
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".Товары КАК ТЧ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = ТЧ.Ссылка
	|";
	
    ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ТЧ_Товары", ТекстЗапроса, Истина, Истина);
	
	#КонецОбласти
	
	#Область ТЧ_ШтрихкодыУпаковок	
	#КонецОбласти
	
	#Область ТЧ_ШтрихкодыКоробок
	#КонецОбласти
	
	#Область ТЧ_ДокументыОснования
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ТЧ.*
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".ДокументыОснования КАК ТЧ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = ТЧ.Ссылка
	|";
	
    ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ТЧ_ДокументыОснования", ТекстЗапроса, Истина, Истина);
	
	#КонецОбласти	

	Возврат Новый Структура("РазмерПорции,ТекстЗапросаИзменений,ЗапросыИст,ОперИмпорта,ОперИмпорта_Представление", 1000, ТекстЗапросаИзменений, ЗапросыИст, ОперИмпорта, ОперИмпорта_Представление);
КонецФункции //Экспорт

Функция ЗагрузитьДанныеПакета(ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	фПерезаписывать = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "фПерезаписывать", Ложь);
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");
	
	Шапка 		= Неопределено;
	ДанныеТЧ 	= Новый Соответствие;
	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ,"ТЧ_") Тогда
			КиЗ.Значение.Индексы.Добавить("Ссылка");
			ДанныеТЧ[Сред(КиЗ.Ключ, 4)] = КиЗ.Значение;
		ИначеЕсли КиЗ.Ключ = "Шапка" Тогда
			Шапка = КиЗ.Значение;			
		КонецЕсли;		
	КонецЦикла;	  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Шапка ИЗ &Шапка КАК Шапка
	|;
	|ВЫБРАТЬ
	|	IsNULL(Ссылка.ВерсияДанных,"""") КАК ВерсияДанных,
	|	*
	|ИЗ
	|	ВТ_Шапка
	|ГДЕ
	|	Ссылка.ВерсияДанных ЕСТЬ NULL	
	|	ИЛИ &фПерезаписывать
	|";  
	
	Запрос.УстановитьПараметр("Шапка", 				Шапка);
	Запрос.УстановитьПараметр("фПерезаписывать",	фПерезаписывать);
	
	Менеджер 		= Документы.МаркировкаТоваровИСМП;
	ВидДокумента	= "" + Метаданные.НайтиПоТипу(ТипЗнч(Менеджер.ПустаяСсылка()));
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	ОшибокЗаписи = 0;
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	СовсемНачало= Начало;
	
	ЗаписанныеОбъекты = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Если ЗначениеЗаполнено(Выборка.ВерсияДанных) Тогда
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();			
		Иначе			
			ДокОбъект = Менеджер.СоздатьДокумент();		
			ДокОбъект.УстановитьСсылкуНового(Выборка.Ссылка);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ДокОбъект, Выборка, , "Ссылка");		
		
		Для Каждого КиЗ Из ДанныеТЧ Цикл
			СтрокиТЧ = КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка));		
			
			ТЧ_Объекта = ДокОбъект[КиЗ.Ключ];
			
			ТЧ_Объекта.Очистить();			
			Для Каждого СтрокаТЧ_Ист Из КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка)) Цикл
				СтрокаТЧ_Тек = ТЧ_Объекта.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ_Тек, СтрокаТЧ_Ист);			
			КонецЦикла; 
		КонецЦикла;
		
		ДокОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи", Истина);
		ДокОбъект.ОбменДанными.Загрузка 	= Истина;
		ДокОбъект.ОбменДанными.Отправитель	= Отправитель;
		
		Попытка
			ДокОбъект.Записать();		
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
			
			ИмяТаблицы = ДокОбъект.Метаданные().ПолноеИмя();
			Записано = ЗаписанныеОбъекты[ИмяТаблицы];
			Если Записано = Неопределено Тогда
				Записано = 0;			
			КонецЕсли;                              
			ЗаписанныеОбъекты[ИмяТаблицы] = Записано + 1;
		Исключение
			ТекстОшибки = СтрШаблон("Ошибка записи документа: %1. %2 !", ДокОбъект, ОписаниеОшибки());
			Результат.Ошибки.Добавить(ТекстОшибки);
			
			ОшибокЗаписи = ОшибокЗаписи + 1;
		КонецПопытки;		
		
		Сч = Сч + 1;
		Если Сч % 10 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка " + ВидДокумента + ". Загружено: %1 из %2 документов.", Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		
			Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
			ТекстСообщения = СтрШаблон("Записано 10 " + ВидДокумента + ". Время выполнения: %1, скорость записи: %2 док/с.", Время, Формат(10 / Время, "ЧДЦ=0"));			
			ЗаписатьВЛог("Загрузка " + ВидДокумента, ТекстСообщения, "Информация", , , Время);
			
			Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли;		
	КонецЦикла;
	
	Результат.Вставить("ПрочитаноОбъектов", Шапка.Количество());
	Результат.Вставить("ОшибокЗаписи", 		ОшибокЗаписи);
	
	Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - СовсемНачало)/1000;
	ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1, записано: %2, ошибок записи: %3.",  Результат.ПрочитаноОбъектов, Результат.ОбработаноОбъектов, ОшибокЗаписи);
	ЗаписатьВЛог("Загрузка " + ВидДокумента, ТекстСообщения, "Информация", , , Время);
	
	Результат.Сообщения.Добавить(ТекстСообщения);	
	Для Каждого КиЗ Из ЗаписанныеОбъекты Цикл
		ТекстСообщения = СтрШаблон("Записано: %1 объектов: %2.",  КиЗ.Значение, КиЗ.Ключ);	
		Результат.Сообщения.Добавить();	
	КонецЦикла;
	
	Возврат Результат;	
КонецФункции //Функция ЗагрузитьДанныеПакета(ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт

Функция ПолучателиПеремещения(ОП_Объект) Экспорт	
	СписокПолучателей	= Новый Массив;            
	
	ПРМ_Ссылка 	= ОП_Объект.ДокументОснование;
	ОбменДанными= ОП_Объект.ОбменДанными;	
	
	Отправитель = ОбменДанными.Отправитель;
	Загрузка	= ОбменДанными.Загрузка;
	
	ИмяПО 	= "ДанныеЧЗ";
	рШапки	= ПолучитьРеквизитыШапки(ПРМ_Ссылка, "Склад,СкладПолучатель,Склад.КодФизическогоУзла,СкладПолучатель.КодФизическогоУзла,Склад.ФизическийСклад,СкладПолучатель.ФизическийСклад");
	
	Склад						= рШапки.Склад;
	СкладПолучатель 			= рШапки.СкладПолучатель;
	
	ФизическийСклад				= рШапки.Склад_ФизическийСклад;
	ФизическийСкладПолучатель	= рШапки.СкладПолучатель_ФизическийСклад;
			
	УзелСклада					= Маркировка_ПИ.УзелПоКоду(рШапки.Склад_КодФизическогоУзла + "cz", ИмяПО);
	УзелСкладаПолучателя		= Маркировка_ПИ.УзелПоКоду(рШапки.СкладПолучатель_КодФизическогоУзла + "cz", ИмяПО);
	
	ТипУзла						= Маркировка_ПИ.ТипТекущегоУзла(ИмяПО);			
	
	Если ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда			
		ОбменДаннымиЧЗ.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСклада, Отправитель, Загрузка);			
		ОбменДаннымиЧЗ.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСкладаПолучателя, Отправитель, Загрузка);
	Иначе
		//Все агрегации по ПРМ будут делаться в ЦО			
	КонецЕсли;			
	
	Возврат ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(СписокПолучателей, Истина);
КонецФункции //ПолучателиПеремещения(ПРМ_Объект)


