					Прервать; 	
				
				КонецЕсли;
				СтрокаДанных				= ТаблицаДанных.Добавить(); // пишем в таблицу которую вернём
				СтрокаДанных.Лист			= ТекущийЛист;        
				СтрокаДанных.КодАгрегации	= СтрокаКоробов.ШтрихкодКоробки;
				КолКМ = КолКМ + 1; 				
			КонецЦикла;
			
			Если КолКМ < КоличествоКодовБлочковНаЛист  Тогда
				
				ОтборПоЛП = Новый Структура("ДокументОснование",неопределено);
				СтрокиКоробов = ТЗКоробов.НайтиСтроки(ОтборПоЛП);
				Если СтрокиКоробов.Количество() = 0 Тогда
					
					ТекстОшибки = "Ошибка распределения кодов агрегации. Не найден свободный код агрегации";
					Результат.Ошибки.Добавить(ТекстОшибки);	
					Прервать;	
				Иначе 
					Для каждого СтрокаКоробов Из СтрокиКоробов Цикл 			
						Если КолКМ =  КоличествоКодовБлочковНаЛист Тогда
							
							Прервать; 	
							
						КонецЕсли;
						СтрокаДанных				= ТаблицаДанных.Добавить(); // пишем в таблицу которую вернём
