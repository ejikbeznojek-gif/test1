Функция ПолучитьВложенныеКоды(ШтрихКодыКоробок) Экспорт
	Результат = Новый Массив;
	
	Если ШтрихКодыКоробок = Неопределено ИЛИ ШтрихКодыКоробок.Количество() = 0 Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ШтрихКодКоробки ПОМЕСТИТЬ ВТ_ШтрихКодыКоробок ИЗ &ШтрихКодыКоробок КАК ШтрихКодыКоробок
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВложенныеКоды.Штрихкод КАК ШтрихКод 
	|ПОМЕСТИТЬ ВТ_ВложенныеКоды
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеКоды
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ	
	|	ВТ_ШтрихКодыКоробок
	|ПО
	|	ВТ_ШтрихКодыКоробок.ШтрихКодКоробки = ВложенныеКоды.Ссылка
	|;
	|ВЫБРАТЬ 
	|	ШтрихКод
	|ИЗ
	|	ВТ_ВложенныеКоды
	|;
	|ВЫБРАТЬ 
	|	ШтрихКод
	|ИЗ
	|	ВТ_ВложенныеКоды
	|ГДЕ
	|	ВТ_ВложенныеКоды.ШтрихКод.ТипКода В (
	|		ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка),
	|		ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|	)
	|";
	
	Запрос.УстановитьПараметр("ШтрихКодыКоробок", МассивВТаблицу(ШтрихКодыКоробок, "ШтрихКодКоробки"));
	рЗапроса = Запрос.ВыполнитьПакет();
	
	сШтрихКоды = Новый Соответствие;
	//Штрих коды 1 уровень
	Выборка = рЗапроса[рЗапроса.ВГраница()-1].Выбрать();
	Пока Выборка.Следующий() Цикл
		сШтрихКоды[Выборка.ШтрихКод] = Истина;
	КонецЦикла; 
	
	//Штрих коды коробки
	ШтрихКодыВложенныхКоробок = рЗапроса[рЗапроса.ВГраница()].Выгрузить().ВыгрузитьКолонку("ШтрихКод");
	Если ШтрихКодыВложенныхКоробок.Количество() > 0 Тогда
		СоставВложений = ПолучитьВложенныеКоды(ШтрихКодыВложенныхКоробок);
		Для Каждого ШтрихКод Из СоставВложений Цикл
			сШтрихКоды[ШтрихКод] = Истина;					
		КонецЦикла; 
	КонецЕсли;
	
	Для Каждого КиЗ Из сШтрихКоды Цикл
		Результат.Добавить(КиЗ.Ключ);	
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции //ПолучитьВложенныеКоды(ШтрихКодыКоробок)

Функция МассивВТаблицу(МассивЗначений, ИмяКолонки)
	ТЗ = Новый ТаблицаЗначений;
	Если МассивЗначений.Количество() > 0 Тогда
		МТ = Новый Массив;
		МТ.Добавить(ТипЗнч(МассивЗначений[0]));
		ТипКолонки = Новый ОписаниеТипов(МТ);
	Иначе
		ТипКолонки = Неопределено;	
	КонецЕсли;
	ТЗ.Колонки.Добавить(ИмяКолонки, ТипКолонки);
	
	Для Каждого ТекЗнач Из МассивЗначений Цикл
		Если ЗначениеЗаполнено(ТекЗнач) Тогда
			СтрокаТК = ТЗ.Добавить();	
			СтрокаТК[ИмяКолонки] = ТекЗнач;		
		КонецЕсли;	
	КонецЦикла; 
	
	Возврат ТЗ;
КонецФункции //МассивВТаблицу(МассивЗначений, ИмяКолонки)

