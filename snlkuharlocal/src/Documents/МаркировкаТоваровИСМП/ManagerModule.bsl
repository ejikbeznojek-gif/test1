			ТекстОшибки = "Ошибка распределения кодов агрегации. Не найден свободный код агрегации";
			Результат.Ошибки.Добавить(ТекстОшибки);	
			Прервать;
		КонецЕсли;  	
		сч = сч+1; 
	КонецЦикла;  			
	
	если Результат.Ошибки.Количество()=0 тогда
		Попытка   
			если ДокОбъект.модифицированность() тогда	
				// Кухарь А.Ю.  22.07.2025 начало
				ДокОбъект.ОбменДанными.Загрузка = Истина; 
				ДокОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи",Истина);
				// Кухарь А.Ю.  22.07.2025 конец

				ДокОбъект.Записать(РежимЗаписиДокумента.Запись);   
			КонецЕсли;
			ДокОбъект.Разблокировать();    
			
			Результат.Успех 	= Истина;					
		Исключение
			ТекстОшибки = СтрШаблон("Не удалось провести документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
			Результат.Ошибки.Добавить(ТекстОшибки);					
		КонецПопытки;
	КонецЕсли;
	
	
	Возврат Результат;
КонецФункции //ДобавитьКодАгрегацииИзЛН(ДокументОснование) Экспорт

Функция УбратьМассивЛистовИзПакетнойАгрегации(ДокМаркировки, МассивЛистов) Экспорт  
	
	КоличествоЛистов = МассивЛистов.Количество(); 	
	Результат		 = новый Структура("Успех,Ошибки",ложь,новый Массив);
	если КоличествоЛистов = 0 тогда 
		Результат.Успех = истина;
		возврат Результат;
	КонецЕсли;            
	
	
	ДокОбъект		 = ДокМаркировки.ПолучитьОбъект();
      
	
	Если ДокОбъект.Статус <> Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
		и ДокОбъект.Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе тогда
		ТекстОшибки = СтрШаблон("Недопустимый статус у документа агрегации: '%1' ! %2", ДокОбъект, ДокОбъект.Статус);
		Результат.Ошибки.Добавить(ТекстОшибки);					
	КонецЕсли;  
	
	если Результат.Ошибки.Количество()>0 тогда
		возврат Результат;
	КонецЕсли;
	
	Попытка
		ДокОбъект.Заблокировать();
	Исключение
		ТекстОшибки = СтрШаблон("Не удалось заблокировать документ агрегации: '%1' ! %2", ДокОбъект, ОписаниеОшибки());
		Результат.Ошибки.Добавить(ТекстОшибки);	
	КонецПопытки;

	если Результат.Ошибки.Количество()>0 тогда
		возврат Результат;
	КонецЕсли;
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ 
	|	ТЧ.НомерСтроки КАК НомерСтроки,
	|	ТЧ.ШтрихкодКоробки КАК ШтрихкодКоробки,
	|	ТЧ.ДокументОснование КАК ДокументОснование
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&ШтрихкодыКоробок КАК ТЧ
	|ГДЕ
	|ТЧ.ДокументОснование В (&МассивЛистов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	ВТ КАК ВТ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументОснование,
	|	НомерСтроки"; 
	запрос.УстановитьПараметр("МассивЛистов",МассивЛистов); 
	запрос.УстановитьПараметр("ШтрихкодыКоробок",ДокОбъект.ШтрихкодыКоробок.выгрузить());  

	Выборка				 = запрос.Выполнить().выбрать();                                           
	пока выборка.Следующий() цикл
		СтрокаТЧ	= ДокОбъект.ШтрихкодыКоробок.получить(выборка.НомерСтроки-1);  
		СтрокаТЧ.ДокументОснование = Неопределено;
