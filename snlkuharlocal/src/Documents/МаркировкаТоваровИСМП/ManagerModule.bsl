#Область АгрегацияПоЛистамНабораИПалетам

Функция ПолучитьЗабронироватьКодАгрегацииДляЛН(ЛистНабора, ТипШК, Знач ТипУпаковки = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	рПроверки = МожноАгрегироватьЛистНабораИлиПереукладки(ЛистНабора);
	Если рПроверки.Успешно Тогда
		Накладная = рПроверки.Данные;
	Иначе		
		МаркировкаКС.ДобавитьОшибки(Результат, рПроверки);
	КонецЕсли;
	
	Если НЕ (ТипШК = Перечисления.ТипыШтрихКодов.Блочок	ИЛИ ТипШК = Перечисления.ТипыШтрихКодов.Коробка) Тогда
		ТекстОшибки = СтрШаблон("Недопустимое значение типа ШК: '%1' !", ТипШК);
		Результат.Ошибки.Добавить(ТекстОшибки);
	КонецЕсли;
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли;	
	
	Если ТипУпаковки = Неопределено Тогда
		ТипУпаковки = ОпределитьТипУпаковкиПоСоставуЛН(ЛистНабора);
	КонецЕсли;
	
	ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, ТипШК);
	
	рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныйКодАгрегации(ТипШК, ТипУпаковки, ОперАгрегации, Новый Структура("Добавлять", Истина));
	
	Если рБронирования.Успешно Тогда
		ШтрихКодАграгации = рБронирования.Данные;
		рДобавления = ДобавитьШККоробкиВАгрегацию(ОперАгрегации, ЛистНабора, ШтрихКодАграгации);
		Если рДобавления.Успешно Тогда
			Результат.Успешно 	= Истина;						
			Результат.Данные 	= ШтрихКодАграгации;
		Иначе						
			МаркировкаКС.ДобавитьОшибки(Результат, рДобавления);
		КонецЕсли;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рБронирования);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьСвободныйКодАгрегацииДляЛН(ЛистНабора, ТипШК, Знач ТипУпаковки = Неопределено) Экспорт

Функция ПолучитьЗабронироватьКодАгрегацииДляПалеты(Палета, Накладная, Знач ТипУпаковки = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
		
	Если ЗначениеЗаполнено(Палета) Тогда
		Если НЕ ТипЗнч(Палета) = Тип("ДокументСсылка.Паллета") Тогда
			Результат.Ошибки.Добавить("Недопустимое основание для агрегации: " + ТипЗнч(Палета));
		КонецЕсли; 
	Иначе
		Результат.Ошибки.Добавить("Не указана палета !");	
	КонецЕсли;	
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли;
	
	рПроверки = МожноАгрегироватьНакладную(Накладная); 
	
	Если НЕ рПроверки.Успешно Тогда
		Возврат рПроверки;		
	КонецЕсли;	
	
	ТипШК = Перечисления.ТипыШтрихКодов.Палета;
	Если ТипУпаковки = Неопределено Тогда
		ТипУпаковки = ОпределитьТипУпаковкиПоСоставуНакладной(Накладная);			
	КонецЕсли;
	
	ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, ТипШК);
	
	рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныйКодАгрегации(ТипШК, ТипУпаковки, ОперАгрегации, Новый Структура("Добавлять", Истина));
	
	Если рБронирования.Успешно Тогда
		ШтрихКодАграгации = рБронирования.Данные;
		рДобавления = ДобавитьШККоробкиВАгрегацию(ОперАгрегации, Накладная, ШтрихКодАграгации);
		Если рДобавления.Успешно Тогда
			Результат.Успешно 	= Истина;						
			Результат.Данные 	= ШтрихКодАграгации;
		Иначе						
			МаркировкаКС.ДобавитьОшибки(Результат, рДобавления);
		КонецЕсли;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рБронирования);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьСвободныйКодАгрегацииДляЛН(ЛистНабора, ТипШК, Знач ТипУпаковки = Неопределено) Экспорт

Функция ВыдавалсяКодКоробки(ДокМаркировки, ЛистНабора)
	Результат = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодКоробки	
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК МаркировкаТоваровИСМПШтрихкодыКоробок
	|ГДЕ
	|	Ссылка = &ДокМаркировки
	|	И ДокументОснование = &ЛистНабора
	|";
	
	Запрос.УстановитьПараметр("ДокМаркировки",	ДокМаркировки);
	Запрос.УстановитьПараметр("ЛистНабора", 	ЛистНабора);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ШтрихкодКоробки) Тогда
		Результат = Выборка.ШтрихкодКоробки;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ВыдавалсяКодКобки(ДокМаркировки, ЛистНабора)

Функция ВыдавалсяКодАгрегации(ДокМаркировки, ЛистНабора, ШтрихКодКоробки)
	Результат = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодКоробки	
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК МаркировкаТоваровИСМПШтрихкодыКоробок
	|ГДЕ
	|	Ссылка				= &ДокМаркировки
	|	И ДокументОснование = &ЛистНабора
	|	И ШтрихКодКоробки	= &ШтрихКодКоробки
	|";
	
	Запрос.УстановитьПараметр("ДокМаркировки",		ДокМаркировки);
	Запрос.УстановитьПараметр("ЛистНабора", 		ЛистНабора);
	Запрос.УстановитьПараметр("ШтрихКодКоробки",	ШтрихКодКоробки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ШтрихкодКоробки) Тогда
		Результат = Выборка.ШтрихкодКоробки;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ВыдавалсяКодКобки(ДокМаркировки, ЛистНабора)

Функция МожноАгрегироватьЛистНабораИлиПереукладки(ДокСсылка)
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(ДокСсылка) Тогда
		ТипДокумента = ТипЗнч(ДокСсылка);
		Если ТипДокумента = Тип("ДокументСсылка.ЛистНабора")
			ИЛИ ТипДокумента = Тип("ДокументСсылка.ЛистПереукладки") Тогда
			
			Накладная	= ПолучитьРеквизитШапки(ДокСсылка, "ДокОснование");
			рНакладной	= ПолучитьРеквизитыШапки(Накладная, "Организация,Склад.Подразделение,СостояниеНакладной");
	
			Если СостояниеНакладнойДопускаетАгрегацию(рНакладной.СостояниеНакладной)
				//++Данилова Е.В. 10.02.2026 SNL-138
				ИЛИ ВидОснованияДокускаетАгрегацию(Накладная) Тогда
				//--Данилова Е.В. 10.02.2026
				Результат.Данные	= Накладная;
				Результат.Успешно	= Истина;
			Иначе
				Результат.Ошибки.Добавить(СтрШаблон("Недопустимый тип основания: '%1' !", ТипДокумента));
			КонецЕсли;
		КонецЕсли;
	Иначе
		Результат.Ошибки.Добавить("Не заполнен лист набора или переукладки !");		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ЭтоДопустимыйЛистНабораИлиПереукладки(ДокСсылка)

Функция МожноАгрегироватьНакладную(Накладная)
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Если ЗначениеЗаполнено(Накладная) Тогда 
		ТипНакладной = ТипЗнч(Накладная);
		Если ТипНакладной = Тип("ДокументСсылка.РасходнаяНакладная")
			ИЛИ ТипНакладной = Тип("ДокументСсылка.Перемещение") Тогда
		
			СостояниеНакладной	= ПолучитьРеквизитШапки(Накладная, "СостояниеНакладной");		
			
				// Кухарь А.Ю. 12.02.2025 начало
				// Если СостояниеНакладнойДопускаетАгрегацию(СостояниеНакладной) Тогда
				Если СостояниеНакладнойДопускаетАгрегациюВПаллету(СостояниеНакладной) Тогда 
				// Кухарь А.Ю. 12.02.2025 конец
				
				Результат.Успешно = Истина;				
			Иначе
				Результат.Ошибки.Добавить(СтрШаблон("Недопустимое состояние накладной ( '%1' ) для агрегации палет !", СостояниеНакладной));
			КонецЕсли;			
		Иначе
			Результат.Ошибки.Добавить(СтрШаблон("Недопустимый тип накладной ( '%1' ) для агрегации палет !", ТипНакладной));					
		КонецЕсли;
	Иначе
		Результат.Ошибки.Добавить("Не указана накладная для агрегации палета !");		
	КонецЕсли;

	Возврат Результат;
