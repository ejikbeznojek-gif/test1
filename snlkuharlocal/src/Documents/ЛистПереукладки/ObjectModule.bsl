Перем НужноВыгружать;
Перем ПростоЗаписывать; 
Процедура ПростоЗаписать()  экспорт
	ПростоЗаписывать=Истина;
	Записать();
КонецПроцедуры


Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	если ПростоЗаписывать = Истина тогда
		Возврат;
	КонецЕсли;
	
	если ТипШК=Перечисления.ТипыШтрихКодов.ПустаяСсылка() тогда
		ТипШК=Перечисления.ТипыШтрихКодов.Штука;
	КонецЕсли;
	
	если ОбъемДокумента = 0 тогда
		ОбъемДокумента=ТипКороба.Объем;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Склад) Тогда
	
		Если ЕстьРеквизитДокумента("Склад",ДокОснование.Ссылка.Метаданные()) 
			И ЗначениеЗаполнено(ДокОснование.Склад) Тогда
			
			Склад = ДокОснование.Склад; 
			
		КонецЕсли;
		
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ОбъемКоробов)
		ИЛИ ОбъемКоробов <>  ТипКороба.Объем Тогда
	
		ОбъемКоробов = ТипКороба.Объем; 
	
	КонецЕсли;
	
	если не ОбменДанными.Загрузка тогда
		если ОбъемДокумента= 0 тогда
			СообщитьИзМодуля("запрещён пустой объём в ЛП");
			Отказ=Истина;
		КонецЕсли;
		если не ЗначениеЗаполнено(ТипКороба) тогда
			СообщитьИзМодуля("запрещён пустой тип короба в ЛП");
			Отказ=Истина;
		КонецЕсли;
	КонецЕсли;
	
	
	Если ЭтоНовый() тогда
		Если НЕ (ДополнительныеСвойства.Свойство("НомерДокУстановлен") 
			И ДополнительныеСвойства.НомерДокУстановлен) Тогда 
			УстановитьНовыйНомер(СокрЛП(ДокОснование.Номер)+"/");
		КонецЕсли;
		ГруппыТоваров		=ГруппыТоваровДокумента(ЭтотОбъект);
	КонецЕсли;
	
	Если НЕ НеУчитыватьПриОпределенииКоличестваМест И РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения Тогда
		СформироватьШКЛистаПереукладки();
	КонецЕсли;	 
	
	КоличествоКоробок = 1;
	
	ПравилаАгрегацииЧестногоЗнака = ДокОснование.ПравилаАгрегацииЧестногоЗнака;
	Если ПравилаАгрегацииЧестногоЗнака.ТребуетсяАгрегацияБлочков ИЛИ ПравилаАгрегацииЧестногоЗнака.ТребуетсяАгрегацияКоробок  Тогда
		НеТребуетсяСканирование = Ложь;
	Иначе
		НеТребуетсяСканирование = Истина;
	КонецЕсли;
	
	КоличествоДокумента=Товары.Итог("Количество");
	
	ЕстьИзменения	= Модифицированность();
	

	если ШтрихкодыУпаковок.Количество() тогда
		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Номер КАК Номер
		|ИЗ
		|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
		|ГДЕ
		|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Проведен
		|	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка <> &Ссылка
		|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки В(&ШтрихкодУпаковки)
		|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки <> &ПустойШК
		|	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Дата >= &Дата";
		запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());	
		запрос.УстановитьПараметр("ссылка",Ссылка);	
		
		запрос.УстановитьПараметр("ДокОснование",ДокОснование);
		запрос.УстановитьПараметр("Дата",Дата-3*86400);
		
		запрос.УстановитьПараметр("ШтрихкодУпаковки",ШтрихкодыУпаковок.Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки"));
		Выборка=запрос.Выполнить().Выбрать();
		
		если Выборка.Количество()>0 тогда
			ЗаписатьВЛог("Отладка",СтрШаблон("Найдены дубли кодов ЧЗ в ЛП в количестве %1",Выборка.Количество()),"Система");
		КонецЕсли;   
		
		МассивСообщений=новый Массив;
		пока Выборка.Следующий() цикл
			МассивСообщений.Добавить("Обнаружены дубли кодов в других ЛП - "+Выборка.Номер+"______"+Выборка.ШтрихкодУпаковки);
		КонецЦикла;
		если МассивСообщений.Количество()>0 тогда
			Сообщить(СтрСоединить(МассивСообщений,Символы.ПС));
			Отказ = Истина;
		КонецЕсли;

		ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ДокОснование);		
		
		если ЗначениеЗаполнено(КодАгрегации) тогда
			Запрос=новый запрос;
			запрос.Текст=  "ВЫБРАТЬ
			|	ЛистПереукладки.Ссылка.Номер КАК Ссылка
			|ИЗ
			|	Документ.ЛистПереукладки КАК ЛистПереукладки
			|ГДЕ
			|	ЛистПереукладки.Ссылка <> &Ссылка
			|	И ЛистПереукладки.КодАгрегации = &КодАгрегации
			|	И ЛистПереукладки.Дата >= &Дата
			|	И ЛистПереукладки.Проведен";
			запрос.УстановитьПараметр("Ссылка",Ссылка);
			запрос.УстановитьПараметр("КодАгрегации",КодАгрегации);
			запрос.УстановитьПараметр("Дата",Дата-14*86400);
			Выборка = запрос.Выполнить().Выбрать();  
			
			если Выборка.Количество()>0 тогда
				ЗаписатьВЛог("Отладка",СтрШаблон("Найдены дубли агрегационных кодов ЧЗ в ЛП в количестве %1",Выборка.Количество()),"Система");
			КонецЕсли;   
			
			пока Выборка.Следующий() цикл
				МассивСообщений.Добавить("Обнаружены дубли агрегационных кодов в других ЛП - "+Выборка.Номер);
			КонецЦикла;
		КонецЕсли;
		если МассивСообщений.Количество()>0 тогда
			отказ=Истина;
			СообщитьИзМодуля(СтрСоединить(МассивСообщений,символы.ПС));
			
		КонецЕсли;		  
	КонецЕсли;
	// Установка логирования для выявления проблемы при неправильном отображении печатной формы со штрихкодами по заказам FBS
	Попытка
		Если Не РольДоступна("Администратор")
			И ОбменМаркетПлейс.КонтрагентУчастникМаркетПлейса(ДокОснование.Контрагент, ДокОснование.ПунктДоставки) Тогда
			Запрос = Новый Запрос("ВЫБРАТЬ
			|	ВложенныйЗапрос.Отсканировано КАК Отсканировано
			|ИЗ
			|	(ВЫБРАТЬ ПЕРВЫЕ 1
			|		ЛистПереукладкиТовары.Ссылка КАК Ссылка,
			|		ЛистПереукладкиТовары.Отсканировано КАК Отсканировано
			|	ИЗ
			|		Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
			|	ГДЕ
			|		ЛистПереукладкиТовары.Ссылка = &ЛистПереукладки) КАК ВложенныйЗапрос
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
			|		ПО ВложенныйЗапрос.Ссылка = ЗаказКлиентаFBSТовары.ЛистПереукладки");
			Запрос.УстановитьПараметр("ЛистПереукладки", Ссылка);
			
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			Если Не РезультатЗапроса.Пустой() И Выборка.Следующий() Тогда
				Если Товары.Количество() > 0 И Выборка.Отсканировано > Товары[0].Отсканировано Тогда
					ЗаписатьВЛог("HELP_6552", СтрШаблон("Зафиксировано изменение количества отсканированного товара в меньшую сторону по ЛП № %1. %2", Номер, ТекущаяДатаСеанса()), "Предупреждение")
				КонецЕсли
			КонецЕсли
		КонецЕсли
	Исключение
		// Обработка исключения не обязательна
	КонецПопытки;

	Если ЗначениеЗаполнено(ДатаНачалаСканирования) 
		И НЕ ЗначениеЗаполнено(ДатаОкончанияСканирования)
		И Товары.Итог("Количество") = Товары.Итог("Отсканировано") 
		И (НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ВозвратВработу")
		ИЛИ ЭтотОбъект.ДополнительныеСвойства.ВозвратВработу = ЛОЖЬ) Тогда   
		ДатаОкончанияСканирования = ТекущаяДата();		
	КонецЕсли;
    //++Данилова Е.В. 07.05.2026 HELP-8363
	//Если НЕ Отказ
	//	И Проведен
	//	И РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения
	//	И (НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ВозвратВработу")
	//	ИЛИ ЭтотОбъект.ДополнительныеСвойства.ВозвратВработу = ЛОЖЬ)
	//	И Не ЭтотОбъект.ДополнительныеСвойства.Свойство("ЗаписьИзОбработкиFBS")
	//	И Не ОтклКонтрольНоменклатуры Тогда 
	//	
	//	ЛПЗавершен = МаркировкаКС.ПроверитьЗавершениеЛП(ЭтотОбъект,ПравилаРаботыСАгрегациейЧЗ); 
	//	
	//	Если Завершен <> ЛПЗавершен Тогда
	//		
	//		Завершен = ЛПЗавершен; 
	//		
	//		Если Завершен Тогда
	//			НомерКоробкиНовый = Обработки.ПечатьЛистаНабора.ПолучитьНомерКоробкиПоЛистуПереукладки(ЭтотОбъект);
	//			Если НомерКоробкиНовый <> НомерКоробки Тогда
	//			
	//				НомерКоробки = 	НомерКоробкиНовый; 
	//			
	//			КонецЕсли;
	//			Сообщить(Строка(ссылка) + " завершен и доступен только для просмотра");	
	//			
	//		КонецЕсли;
	//		
	//	КонецЕсли;
	//	
	//КонецЕсли;
    //--Данилова Е.В. 07.05.2026 
	Если Не Отказ 
		И (ПометкаУдаления 
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения) Тогда
		
		НомерКоробки = 0; 
		//++Данилова Е.В. 28.04.2026 HELP-9565 
		РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(ссылка); 
		//--Данилова Е.В. 28.04.2026
		//++Данилова Е.В. 19.05.2026  HELP-9825 перенесены в при записи 
		//++Данилова Е.В. 08.05.2026 HELP-9716 
		//Иначе 
		//	Если НЕ ЭтоНовый()
		//		И ЗначениеЗаполнено(ДокОснование)
		//		И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
		//		Обработки.ПечатьЛистаНабора.ПроверитьЗанятыеНомераБезЗаписиВЛист(ДокОснование,ссылка);
		//	КонецЕсли;
		//--Данилова Е.В. 08.05.2026 
		//--Данилова Е.В. 19.05.2026 
	КонецЕсли;
	//Валетов+ 04,06,2026 Проблема 0000000034
	Если НЕ Отказ И НЕ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда 
		ДополнительныеАгрегации = ШтрихкодыКоробокДляАгрегации.Количество() > 0;
	КонецЕсли;
	//Валетов-
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ШК", Штрихкод);
	Запрос.УстановитьПараметр("ШКЛистаПереукладки", Штрихкод);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИнформацияШКЛП.ШК КАК ШК,
	|	ИнформацияШКЛП.ШКЛистаПереукладки КАК ШКЛистаПереукладки,
	|	ИнформацияШКЛП.Год КАК Год,
	|	ИнформацияШКЛП.Накладная КАК Накладная,
	|	ИнформацияШКЛП.НомерЛП КАК НомерЛП,
	|	ИнформацияШКЛП.ВидНакладной КАК ВидНакладной,
	|	ИнформацияШКЛП.НомерНакладной КАК НомерНакладной,
	|	ИнформацияШКЛП.Количество КАК Количество,
	|	ИнформацияШКЛП.ГруппыТоваров КАК ГруппыТоваров,
	|	ИнформацияШКЛП.Подразделение КАК Подразделение,
	|	ИнформацияШКЛП.КоличествоКоробок КАК КоличествоКоробок,
	|	ИнформацияШКЛП.НомерКоробки КАК НомерКоробки,
	|	ИнформацияШКЛП.НомерКоробкиЛП КАК НомерКоробкиЛП
	|ИЗ
	|	РегистрСведений.ИнформацияШКЛП КАК ИнформацияШКЛП
	|ГДЕ
	|	ИнформацияШКЛП.ШК = &ШК
	|	И ИнформацияШКЛП.ШКЛистаПереукладки = &ШКЛистаПереукладки";
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписиЖурнала = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	///////// НАКЛАДЫВАЕМ УПРАВЛЯЕМУЮ БЛОКИРОВКУ /////////////////////////////
	Блокировка = Новый БлокировкаДанных;
	
	ЭлементБлокировки = Блокировка.Добавить();
	ЭлементБлокировки.Область = "РегистрСведений.ИнформацияШКЛП";
	ЭлементБлокировки.УстановитьЗначение("ШК", Штрихкод);
	ЭлементБлокировки.УстановитьЗначение("ШКЛистаПереукладки", Штрихкод);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Разделяемый;
	
	Если ЗаписиЖурнала.Количество() Тогда
		
		Попытка
			Блокировка.Заблокировать();
		Исключение
			СообщитьИзМодуля("Отмена проведения в Автоматическом режиме " + Строка(Ссылка));
		КонецПопытки;
		
		///////// НАКЛАДЫВАЕМ УПРАВЛЯЕМУЮ БЛОКИРОВКУ /////////////////////////////
		
		Для Каждого текЗаписьЖурнала Из ЗаписиЖурнала Цикл
			текЗапись = РегистрыСведений.ИнформацияШКЛП.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(текЗапись, текЗаписьЖурнала);
			текЗапись.Удалить();
		КонецЦикла;
		
		ШКЛистаНабора="";
		
	КонецЕсли;
	
	
КонецПроцедуры

