Функция СверитьКолШтВКоробке() Экспорт

	Результат = МаркировкаКС.СтруктураРезультата(истина); 
	
	Если ОтклКонтрольНоменклатуры Тогда
		
		Если КолШтВКоробке <> Товары.Итог("Отсканировано") Тогда
			
			Результат.Успешно = Ложь; 
			Результат.Ошибки.Добавить("Не совпало расчётное количество шт. в коробе с фактическим"); 
			
		КонецЕсли;
		
		Возврат Результат; 
		
	Иначе 
		Возврат Результат; 
	КонецЕсли;

КонецФункции // СверитьКолШтВКоробке()
