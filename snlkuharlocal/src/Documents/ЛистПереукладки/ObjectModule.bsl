Функция ПолучитьМаксимальныйНомерШКЛП(ПрефиксШК)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИнформацияШКЛП.ШК КАК ШК
	|ИЗ
	|	РегистрСведений.ИнформацияШКЛП КАК ИнформацияШКЛП
	|ГДЕ
	|	ИнформацияШКЛП.ШК ПОДОБНО &ШК
	|
	|УПОРЯДОЧИТЬ ПО
	|	ШК УБЫВ
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("ШК",ПрефиксШК+"%");
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Число(Сред(Выборка.ШК,СтрДлина(ПрефиксШК)+1,13 - СтрДлина(ПрефиксШК)));	 
	Иначе
		Возврат Число(0);	 
	КонецЕсли;
КонецФункции

процедура ПрописатьНомераКоробокЛП()
	СтруктураРНК = Новый Структура;
	СтруктураРНК.Вставить("ДокОснование",Ссылка.ДокОснование);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.ДокОснование = &ДокОснование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЛистПереукладки.Номер
	|АВТОУПОРЯДОЧИВАНИЕ";
	запрос.УстановитьПараметр("ДокОснование",Ссылка.ДокОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	Сч = 1;
	Пока Выборка.Следующий() Цикл
		ТекЛистПереукладки = Выборка.Ссылка;  
		Если ТекЛистПереукладки.Проведен = Ложь Тогда
			Продолжить;		
		КонецЕсли;
		НаборЗаписей = РегистрыСведений.ИнформацияШКЛП.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ШКЛистаПереукладки.Значение = ТекЛистПереукладки.Штрихкод;
		НаборЗаписей.Отбор.ШКЛистаПереукладки.использование = Истина;
		НаборЗаписей.Прочитать();
		СписокШК = Новый Соответствие;
		Для Каждого Запись ИЗ НаборЗаписей Цикл
			СписокШК.Вставить(Запись.НомерКоробкиЛП,Запись.ШК);	 
		КонецЦикла;
		ТекШКЛистаПереукладки = ТекЛистПереукладки.Штрихкод;
		НовыйНаборЗаписей = РегистрыСведений.ИнформацияШКЛП.СоздатьНаборЗаписей();
		НовыйНаборЗаписей.Отбор.ШКЛистаПереукладки.Значение = ТекЛистПереукладки.Штрихкод;
		НовыйНаборЗаписей.Отбор.ШКЛистаПереукладки.использование = Истина;
		НовыйНаборЗаписей.Отбор.ШК.Значение = ТекШКЛистаПереукладки;
		НовыйНаборЗаписей.Отбор.ШК.использование = Истина;
		НовыйНаборЗаписей.Прочитать();
		Для Каждого Запись Из НовыйНаборЗаписей Цикл
			Запись.НомерКоробки = Сч;
		КонецЦикла;
		Сч = Сч + 1;
		НовыйНаборЗаписей.Записать();
	КонецЦикла;
КонецПроцедуры


Процедура ПриЗаписи(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если Завершен И Проведен Тогда
		//+++Чирков 29.04.2026 - оказывается  есть проведенные ЛН к удаленным накладным ..... может и ЛП такие есть ......
		// которые еще и перезаписывают ..... их не надо регистрировать
		Если ПолучитьРеквизитШапки(ДокОснование, "Проведен") = Истина Тогда
			//---Чирков
			Если НЕ РегистрыСведений.ОтгружаемыеКодыМаркировки.ЕстьЗаписиПроверкиДокумента(Ссылка) Тогда
				РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьЗадачуПроверкиДокумента(Ссылка);			
			КонецЕсли;
			//+++Чирков 01.06.2026 MARK-3589
			МаркировкаС.ПроверитьКМпоДокументу(Ссылка, Новый Структура("ОтложеннаяПроверка", Истина));
			//---Чирков 01.06.2026
		КонецЕсли;
	Иначе
		//+++Чирков 29.04.2026 - MARK-3682
		Если РегистрыСведений.ОтгружаемыеКодыМаркировки.ЕстьЗаписиПроверкиДокумента(Ссылка) Тогда
			РегистрыСведений.ОтгружаемыеКодыМаркировки.УдалитьЗаписиПоДокументу(Ссылка);
		КонецЕсли;
		//---Чирков 29.04.2026 - MARK-3682
	КонецЕсли;
	//++Данилова Е.В. 19.05.2026 HELP-9825 
	Если НЕ ЭтоНовый()
		И ЗначениеЗаполнено(ДокОснование)
		И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
		Обработки.ПечатьЛистаНабора.ПроверитьЗанятыеНомераБезЗаписиВЛист(ДокОснование,ссылка);
	КонецЕсли;
	//--Данилова Е.В. 19.05.2026 
КонецПроцедуры


