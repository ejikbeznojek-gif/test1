Процедура СформироватьШКЛистаПереукладки() Экспорт
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	Если ПустаяСтрока(Штрихкод) Тогда	
		
		
		КоличествоСекунд=Формат(ТекущаяДата()- НачалоДня(ТекущаяДата()),"ЧЦ=5; ЧВН=");
		если КоличествоСекунд="" тогда 
			КоличествоСекунд="00000";
		КонецЕсли;	
		Штрихкод=Формат(ДеньГода(ТекущаяДата()),"ЧЦ=3; ЧВН=")+КоличествоСекунд+Прав(Номер,5);				 	 
		Штрихкод=Штрихкод+КонтрольныйСимволEAN(Штрихкод,14);
	КонецЕсли;
	//++Данилова Е.В. 28.05.2025 HELP-5109 ДЛЯ СКЛАДА НЕ НУЖНО, УБРАТЬ
	//НачатьТранзакцию();    
	НачатьТранзакцию();
	//--Данилова Е.В. 28.05.2025
	
	Если ПроведениеС.УправляемыйРежим() Тогда
	///////// НАКЛАДЫВАЕМ УПРАВЛЯЕМУЮ БЛОКИРОВКУ /////////////////////////////
	Блокировка = Новый БлокировкаДанных;
	
	ЭлементБлокировки = Блокировка.Добавить();
	ЭлементБлокировки.Область = "РегистрСведений.ИнформацияШКЛП";
	ЭлементБлокировки.УстановитьЗначение("ШК", Штрихкод);
	ЭлементБлокировки.УстановитьЗначение("ШКЛистаПереукладки", Штрихкод);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	
	Блокировка.Заблокировать();
	///////// НАКЛАДЫВАЕМ УПРАВЛЯЕМУЮ БЛОКИРОВКУ /////////////////////////////
	КонецЕсли;
	//Кухарь 29.03.17 конец
	НаборЗаписей = РегистрыСведений.ИнформацияШКЛП.СоздатьНаборЗаписей();
