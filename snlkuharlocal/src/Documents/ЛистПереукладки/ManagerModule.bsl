Функция НайтиСоздатьТипКороба(Данные)  Экспорт
	Результат=Справочники.ТипыКоробов.НайтиПоРеквизиту("ШтрихКод",Данные);
	Если НЕ Результат.Пустая() Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	КоробкаНоменклатуры = НайтиТоварПоШтрихКоду(Данные,Перечисления.ТипыШтрихКодов.Коробка); 
	Если КоробкаНоменклатуры.Пустая() Тогда
		КоробкаНоменклатуры = НайтиТоварПоШтрихКоду(Данные,Перечисления.ТипыШтрихКодов.Блочок);
		Если КоробкаНоменклатуры.Пустая() Тогда
			Сообщить("Неверный ШК короба/блочка: "+Данные,СтатусСообщения.Важное); 
		Иначе
			НовыйТипКороба						= Справочники.ТипыКоробов.СоздатьЭлемент();
			
			НовыйТипКороба.Родитель 			= Справочники.ТипыКоробов.СтандартныеКороба;
			НовыйТипКороба.КоличествоВКоробе	= КоробкаНоменклатуры.Родитель.ШтукВКоробочке;
			
			Если КоробкаНоменклатуры.Родитель.ШтукВКоробочке > 0 Тогда
				НовыйТипКороба.Объем = КоробкаНоменклатуры.Родитель.ОбъемКоробки*КоробкаНоменклатуры.Родитель.ШтукВКоробочке/КоробкаНоменклатуры.Родитель.ШтукВКоробке;
			Иначе
				НовыйТипКороба.Объем = 0;
			КонецЕсли;
			НовыйТипКороба.Наименование = КоробкаНоменклатуры.Наименование+ " Объем: "+НовыйТипКороба.Объем;
			
			НовыйТипКороба.ШтрихКод = Данные;
			
			НовыйТипКороба.Записать();
			
			Результат = НовыйТипКороба.Ссылка;
		КонецЕсли;                          
	Иначе
		НовыйТипКороба 						= Справочники.ТипыКоробов.СоздатьЭлемент();
		
		НовыйТипКороба.Родитель 			= Справочники.ТипыКоробов.СтандартныеКороба;
		НовыйТипКороба.КоличествоВКоробе	= КоробкаНоменклатуры.Родитель.ШтукВКоробке;				
		НовыйТипКороба.Объем 				= КоробкаНоменклатуры.Родитель.ОбъемКоробки;
		НовыйТипКороба.Наименование 		= КоробкаНоменклатуры.Наименование+ " Объем: "+НовыйТипКороба.Объем;
		НовыйТипКороба.ШтрихКод				= Данные;
		
		НовыйТипКороба.Записать();
		
		Результат = НовыйТипКороба.Ссылка;
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции
