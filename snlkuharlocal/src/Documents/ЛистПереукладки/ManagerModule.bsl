Процедура ОбработатьПланНабора (ВидДокументаОснования,ДокОснование) Экспорт
	
	Если СтрНайти("Перемещение,РасходнаяНакладная,Комплектация",ВидДокументаОснования)<>0 Тогда
		// Кухарь А.Ю.  17.08.2022 начало
		//ПланНабора			= Документы.ПланНабора.НайтиПоРеквизиту("ДокОснование",ДокОснование);
		ПланНабора=НайтиДокумент("ПланНабора",Новый Структура("ДокОснование,Проведен",ДокОснование,Истина));	 
		// Кухарь А.Ю.  17.08.2022 конец 
		
		ЗаданияНабора = ЗаданиянабораПоНакладной(ДокОснование); 		
		
		ОтсканировалиНеТотЗНБ = Ложь;
		//ЗНБсОшибками = ПроверитьОшибкиПоЗНБ(ДокОснование,ЗаданияНабора,ОтсканировалиНеТотЗНБ);	 			
		ВремяОкончания 		= ТекущаяДата();
		ПланНабораОбъект 	= ПланНабора.ПолучитьОбъект();
		
		для каждого СтрЗНБ из ЗаданияНабора цикл
			ЗНБ=СтрЗНБ.ЗаданиеНабора;		
			Если ОтсканировалиНеТотЗНБ=Истина Тогда
				Отказ 		= Истина;				
				#Если Клиент Тогда
					Сообщить("Не совпадает номенклатура в планах набора и листе набора! Пересканируйте планы набора!");						
				#КонецЕсли	
				Отказ = Истина;	
			КонецЕсли;		
			СтароеСостояние=ЗНБ.СостояниеНакладной;
			если СтароеСостояние=Перечисления.СостоянияНакладной.ОжиданиеНабора или СтароеСостояние=Перечисления.СостоянияНакладной.ВНаборе тогда
				#Если Клиент Тогда
					Сообщить("Не закончен набор! Завершение сканирования невозможно!");	
				#КонецЕсли
				Продолжить;
			КонецЕсли;		
			
			// Кухарь А.Ю.  11.11.2024 начало
			если ПолучитьНомерСостоянияНакладной(СтароеСостояние)>1180 тогда
				Продолжить;
			КонецЕсли;	
			// Кухарь А.Ю.  11.11.2024 конец
			
			
			//СтрТЗ=ЗНБсОшибками.найти(ЗНБ);	
			//если СтрТЗ=Неопределено тогда
			//НовоеСостояние=ПолучитьНовоеСостояниеЗНБ (ЗНБ,Перечисления.СостоянияНакладной.Сканирование);
			
			НовоеСостояние = ПолучитьНовоеСостояниеЗНБЛП(знб, СтароеСостояние);

			НужноЗаканчиватьСканирование=Истина;	
			//иначе
			//	НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;
			//	НужноЗаканчиватьСканирование=ложь;
			//КонецЕсли;		
			
			если НовоеСостояние<>СтароеСостояние тогда			
				МассСтрок=ПланНабораОбъект.тБрэндов.найтистроки(новый Структура("НомерЧасти",ЗНБ.НомерЧасти));
				для каждого СтрокаПН из МассСтрок цикл
					СтрокаПН.Состояние 				= НовоеСостояние;
					если НужноЗаканчиватьСканирование=Истина тогда
						СтрокаПН.ОкончаниеСканировки	= ВремяОкончания;
						СтрокаПН.СканировкаЗакончена	= Истина;
						СтрокаПН.ВремяТекущегоСостояния = ВремяОкончания;
						если СтрокаПН.НачалоСканировки=ПустаяДата() тогда
							СтрокаПН.НачалоСканировки=ВремяОкончания-1;
						КонецЕсли;
					КонецЕсли;					
				КонецЦикла;		 
			КонецЕсли;
		КонецЦикла;
		
		если ПланНабораОбъект.Модифицированность() тогда
			ПланНабораОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;			
КонецПроцедуры

