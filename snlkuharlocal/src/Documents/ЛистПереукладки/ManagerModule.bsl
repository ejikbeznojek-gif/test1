Функция НайтиКоличествоВТабличныхЧастяхДокумента(Знач ТЗ_Товары, Знач ТЗ_ШтрихКодыУпаковок, Знач Номенклатура) Экспорт
	
	СтруктураВозврата = Новый Структура("Номенклатура, КоличествоТовары, КоличествоШтрихКоды", Номенклатура, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ_Товары", ТЗ_Товары);
	Запрос.УстановитьПараметр("ТЗ_ШтрихКодыУпаковок", ТЗ_ШтрихКодыУпаковок);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗ_Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТЗ_Товары.Количество, 0) КАК КоличествоТовары
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	&ТЗ_Товары КАК ТЗ_Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗ_ШтрихКодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	|	ЕСТЬNULL(ТЗ_ШтрихКодыУпаковок.Количество, 0) КАК КоличествоШтрихКоды
	|ПОМЕСТИТЬ вр_Штрихкоды
	|ИЗ
	|	&ТЗ_ШтрихКодыУпаковок КАК ТЗ_ШтрихКодыУпаковок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Товары.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(вр_Товары.КоличествоТовары, 0)) КАК КоличествоТовары,
	|	СУММА(ЕСТЬNULL(вр_Штрихкоды.КоличествоШтрихКоды, 0)) КАК КоличествоШтрихКоды
	|ИЗ
	|	вр_Товары КАК вр_Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Штрихкоды КАК вр_Штрихкоды
	|		ПО вр_Товары.Номенклатура = вр_Штрихкоды.ШтрихкодУпаковки.Владелец
	|ГДЕ
	|	вр_Товары.Номенклатура = &Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Товары.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);	
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ТекстЗапроса_ВсеКодыДокумента()
	Возврат "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки,ШтрихкодБлочка,Ссылка.КодАгрегации КАК ШтрихкодКоробки
	|ПОМЕСТИТЬ ВТ_ШтрихкодыУпаковок
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ВсеКМДокумента
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихкодБлочка
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодБлочка <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихкодКоробки
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|";
КонецФункции

Функция ПолучитьПорцииКМДляПроверки(ДокСсылка, РазмерПорции = 1000) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ВсеКодыДокумента() + "
	|;
	|ВЫБРАТЬ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.Наименование КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ВсеКМДокумента
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ИспользованныеКодыАгрегаций КАК ИспользованныеКА
	|ПО 	
	|	ИспользованныеКА.ШтрихКодУпаковки = ВТ_ВсеКМДокумента.ШтрихКодУпаковки
	|	И ИспользованныеКА.Регистратор ССЫЛКА Документ.МаркировкаТоваровИСМП
	|	И ИспользованныеКА.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
	|	И ИспользованныеКА.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И ИспользованныеКА.Регистратор.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная
	|ГДЕ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.Наименование КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ВсеКМДокумента
	|ГДЕ 
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.ТипКода <> ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ВсегоСтрок 	= Выборка.Количество();
	Сч			= 0;
	
	Порции = Новый Массив;
	ТекПорция = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		Сч = Сч + 1;
		
		ТекПорция.Добавить(Выборка.ШтрихкодУпаковки);
		Если ТекПорция.Количество() >= РазмерПорции ИЛИ Сч >= ВсегоСтрок Тогда
			Порции.Добавить(ТекПорция);
			ТекПорция = Новый Массив;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Порции;
КонецФункции //ПолучитьКМДляПроверки(ДокСсылка) Экспорт

