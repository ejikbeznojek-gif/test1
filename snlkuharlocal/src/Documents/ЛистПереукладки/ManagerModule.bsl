Функция НайтиЕдиныйЗНАПоРНК(Знач РНК) Экспорт 
	
	СтруктураВозврата 	 = новый Структура("Успех,Ошибки,Данные",Ложь,новый Массив,Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗаданиеНаАгрегацию.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию
	|ГДЕ
	|	ЗаданиеНаАгрегацию.Проведен
	|	И ЗаданиеНаАгрегацию.ДокОснование = &ДокОснование
	|	И ЗаданиеНаАгрегацию.ПроизвольнаяКоробка";
	
	Запрос.УстановитьПараметр("ДокОснование", РНК.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		СтруктураВозврата.Успех = Истина; 
		СтруктураВозврата.Данные = ВыборкаДетальныеЗаписи.ссылка; 
		
		Возврат СтруктураВозврата; 
		
	Иначе
		СтруктураЗаполненияШапкиЗНА = новый Структура("ТипКороба,Товары,КоличествоКоробок,НеПроверятьКороб",Справочники.ТипыКоробов.ПустаяСсылка(),РНК.Товары.Выгрузить(),0,истина);
		
		РезультатПолучения = Документы.ЗаданиеНаАгрегацию.НайтиСоздатьЗНАПоНакладнойИСтруктуреПараметров(РНК.Ссылка,СтруктураЗаполненияШапкиЗНА);
		Если РезультатПолучения.Успех Тогда 
			
			Если РНК.СостояниеНакладной <> Перечисления.СостоянияНакладной.Переукладка Тогда
				РНКОбъект = РНК.ПолучитьОбъект();
				
				РНКОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.Переукладка;
				
				РНКОбъект.Записать();
			КонецЕсли;
			
		КонецЕсли;		
		Возврат РезультатПолучения; 
	КонецЕсли;
КонецФункции 

Процедура ПроставитьКоличествоКоробокПоЗНА(Знач РНК) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаАгрегацию.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию
	|ГДЕ
	|	ЗаданиеНаАгрегацию.Проведен
	|	И ЗаданиеНаАгрегацию.ДокОснование = &ДокОснование
	|	И ЗаданиеНаАгрегацию.ПроизвольнаяКоробка";
	
	Запрос.УстановитьПараметр("ДокОснование", РНК.ссылка);
	ЗНАТЧ = Запрос.Выполнить().Выгрузить();
	
	Если ЗНАТЧ.Количество() = 1 Тогда  		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК Количество
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|ГДЕ
		|	ЛистПереукладки.Проведен
		|	И ЛистПереукладки.ЗаданиеНаАгрегацию = &ЗаданиеНаАгрегацию";
		
		Запрос.УстановитьПараметр("ЗаданиеНаАгрегацию", ЗНАТЧ[0].ссылка);
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		Если Выборка.Следующий() Тогда
		
			ЗнаОбъект = ЗНАТЧ[0].ссылка.ПолучитьОбъект(); 	
		    ЗнаОбъект.КоличествоКоробок = Выборка.Количество;
			ЗнаОбъект.Записать(); 
			
		КонецЕсли; 		
	 	
	КонецЕсли;

КонецПроцедуры

