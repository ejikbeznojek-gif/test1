Функция ПроверитьОшибкиПоЗНБ(ДокОснование,ЗаданияНабора,ОтсканировалиНеТотЗНБ)
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	ЗНБ.Номенклатура КАК Номенклатура,
	             |	СУММА(ЕСТЬNULL(ЗНБ.Количество, 0)) КАК Количество,
	             |	ЗНБ.Ссылка.Накладная КАК Накладная,
	             |	ЗНБ.Ссылка КАК Ссылка
	             |ПОМЕСТИТЬ тЗНБ
	             |ИЗ
	             |	Документ.ЗаданиеНабора.Товары КАК ЗНБ
	             |ГДЕ
	             |	ЗНБ.Ссылка.Ссылка В(&СписокЗНБ)
	             |	И ЗНБ.Ссылка.Дата >= &Дата
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ЗНБ.Номенклатура,
	             |	ЗНБ.Ссылка.Накладная,
	             |	ЗНБ.Ссылка
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ЛистНабораТовары.Номенклатура КАК Номенклатура,
	             |	СУММА(ЛистНабораТовары.Отсканировано) КАК Количество
	             |ПОМЕСТИТЬ тЛН
	             |ИЗ
	             |	Документ.ЛистПереукладки КАК ЛистПереукладки
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.Товары КАК ЛистНабораТовары
	             |		ПО (ЛистНабораТовары.Ссылка = ЛистПереукладки.Ссылка)
	             |ГДЕ
	             |	ЛистПереукладки.Дата >= &Дата
	             |	И ЛистПереукладки.Проведен
	             |	И ЛистПереукладки.ЛистНабора.ДокОснование = &Накладная
	             |	И НЕ ЛистПереукладки.ЛистНабора.ТребуетПроверки
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ЛистНабораТовары.Номенклатура
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тЗНБ.Номенклатура КАК Номенклатура,
	             |	СУММА(ЕСТЬNULL(тЗНБ.Количество, 0)) КАК План,
	             |	СУММА(ЕСТЬNULL(тЛН.Количество, 0)) КАК Факт,
	             |	тЗНБ.Ссылка КАК ЗНБ
	             |ИЗ
	             |	тЗНБ КАК тЗНБ
	             |		ПОЛНОЕ СОЕДИНЕНИЕ тЛН КАК тЛН
	             |		ПО тЗНБ.Номенклатура = тЛН.Номенклатура
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	тЗНБ.Номенклатура,
	             |	тЗНБ.Ссылка
	             |
	             |ИМЕЮЩИЕ
	             |	СУММА(ЕСТЬNULL(тЗНБ.Количество, 0)) <> СУММА(ЕСТЬNULL(тЛН.Количество, 0))";
	запрос.УстановитьПараметр("Дата",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-30*24*3600);
	запрос.УстановитьПараметр("СписокЗНБ",ЗаданияНабора.ВыгрузитьКолонку("ЗаданиеНабора"));
	запрос.УстановитьПараметр("Накладная",ДокОснование);
	ТЗОшибок=запрос.Выполнить().Выгрузить();
	если ТЗОшибок.НайтиСтроки(новый Структура("План",0)).Количество()>0 тогда
		ОтсканировалиНеТотЗНБ=Истина;
	иначе
		ОтсканировалиНеТотЗНБ=ложь;		
	КонецЕсли;
	ТЗОшибок.Свернуть("ЗНБ");
	возврат ТЗОшибок;
КонецФункции

Функция ЗаданиянабораПоНакладной(Накладная,ТолькоРезультат = Ложь) экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК ЗаданиеНабора
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Накладная = &Накладная
	|	И ЗаданиеНабора.Проведен";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если ТолькоРезультат Тогда 
		Возврат НЕ РезультатЗапроса.Пустой();
	Иначе 
		Возврат РезультатЗапроса.Выгрузить(); 
	КонецЕсли;
КонецФункции

