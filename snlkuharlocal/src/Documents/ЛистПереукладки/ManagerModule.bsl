Функция ПолучитьМаксимальныйНомерКоробкиПоНакладной (Накладная) экспорт
	
	Запрос= новый запрос;   
	Запрос.УстановитьПараметр("Накладная",Накладная);
	Запрос.Текст="ВЫБРАТЬ
	|	ЛистПереукладки.НомерКоробки КАК НомерКоробки
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.ДокОснование = &Накладная
	|	И ЛистПереукладки.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерКоробки УБЫВ"; 
	
	МаксимальныйНомер = 0;
	Выборка = запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл
		возврат Выборка.НомерКоробки;
	КонецЦикла;
	
	возврат МаксимальныйНомер;
	
КонецФункции    


Функция ПереномероватьВсеКоробкиНакладной (Накладная) экспорт
	Запрос= новый запрос;   
	Запрос.УстановитьПараметр("Накладная",Накладная);
	Запрос.Текст="ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.ДокОснование = &Накладная
	|	И ЛистПереукладки.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Номер";
	Выборка = запрос.Выполнить().Выбрать();
	Сч=1;
	пока Выборка.Следующий() цикл
		ЛПОбъект = Выборка.ссылка.получитьОбъект();
		ЛПОбъект.НомерКоробки = сч;
		ЛПОбъект.ПростоЗаписать();   
		сч = сч+1;	
	КонецЦикла;
	
КонецФункции               


Процедура ВернутьЛистОтЗНАВРаботу(Лист) экспорт
	
	ЛистОбъект = Лист.ПолучитьОбъект();
	ЛистОбъект.СканировщикФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	ЛистОбъект.Бригада.Очистить(); // Кельманов А.В. - SNL-187 + SNL-208 - 2026.04.22
	ЛистОбъект.УзелТСД = Неопределено;
	ЛистОбъект.РабочееМесто = Неопределено;
	ЛистОбъект.ОтправленНаТСД = ложь;
	ЛистОбъект.ЗагруженИзТСД = ложь;
	ЛистОбъект.ШтрихкодыУпаковок.Очистить();     
	ЛистОбъект.ДатаНачалаСканирования = ПустаяДата();
	ЛистОбъект.ДатаОкончанияСканирования = ПустаяДата();	
	для каждого СтрТЧ из ЛистОбъект.Товары цикл
		СтрТЧ.Отсканировано = 0;
	КонецЦикла;
	ЛистОбъект.ПростоЗаписать();
	
КонецПроцедуры
