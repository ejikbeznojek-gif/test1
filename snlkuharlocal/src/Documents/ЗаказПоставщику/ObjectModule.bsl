Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	//Мессерле. Для Риги блокируем запись ЗПС не по их родному складу.Также надо будет позднее когда устаканится заблокировать ЗПС и в ЦО по складу Риги (как только начнут на складе все делать сами
	//Откючено- теперь (25.10.11) блокируется форма
	
	//Если НЕ ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение и  НЕ (ОтгрузкаСТранзитногоСклада и ЗначениеЗаполнено(ТранзитныйСклад) и ТранзитныйСклад.ТипСклада=Перечисления.ТипСклада.ВнешнийСклад) и НЕ ОбменДанными.Загрузка тогда
	//	Сообщить("Входящие ЗПС (контейнеры с Китая) не могут редактироваться на складе...");Отказ=Истина;Возврат;
	//Конецесли;
	
	
	Если НЕ Машина.Пустая() И НомерМашины<>Машина.НомерМашины Тогда
		НомерМашины=Машина.НомерМашины;	
	КонецЕсли; 
	
	ЕстьИзменения		=Модифицированность();	
	Если НЕ ОбменДанными.Загрузка Тогда
		Если НеКонтролироватьЗапись Тогда
		Иначе
			//крохин начало
			//запрещено только редактирование из формы, обработками можно менять (при проведении ПНК)
			//			КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
			//крохин конец
			МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
