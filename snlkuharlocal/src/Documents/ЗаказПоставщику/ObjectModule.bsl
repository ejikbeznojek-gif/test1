Функция РазбитьПоПроизводителям()
	ТЗБезПроизводителей=ТоварыПартии.Выгрузить();
	ТЗСПроизводителями=ТоварыПартии.Выгрузить();
	ТЗСПроизводителями.Очистить();
	СписокПартий=ТЗБезПроизводителей.ВыгрузитьКолонку("Им7");
	СписокНоменклатуры=ТЗБезПроизводителей.ВыгрузитьКолонку("Номенклатура");
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПартииОстатки.Партия,
	|	ПартииОстатки.Номенклатура,
	|	ПартииОстатки.Склад,
	|	ПартииОстатки.ШтВКоробе,
	|	ПартииОстатки.Контракт,
	|	ПартииОстатки.Производитель,
	|	СУММА(ЕСТЬNULL(ПартииОстатки.КоличествоОстаток, 0)) КАК Количество,
	|	СУММА(ЕСТЬNULL(ПартииОстатки.СуммаОстаток, 0)) КАК Сумма,
	|	СУММА(ЕСТЬNULL(ПартииОстатки.ВесОстаток, 0)) КАК Вес,
	|	СУММА(ЕСТЬNULL(ПартииОстатки.ВесНеттоОстаток, 0)) КАК ВесВсего
	|ИЗ
	|	РегистрНакопления.Партии.Остатки(
	|			&Дата,
	|			Партия В (&СписокПартий)
	|				И Номенклатура В (&СписокНоменклатуры)
	|				И склад = &Склад) КАК ПартииОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ПартииОстатки.Партия,
	|	ПартииОстатки.Номенклатура,
	|	ПартииОстатки.Склад,
	|	ПартииОстатки.ШтВКоробе,
	|	ПартииОстатки.Контракт,
	|	ПартииОстатки.ЛН,
	|	ПартииОстатки.Производитель
	|
	|УПОРЯДОЧИТЬ ПО
	|	Количество УБЫВ";
	//кухарь 21.05.15 начало
	//если вид границы включая, остатков не хватает
	//Запрос.УстановитьПараметр("Дата",Новый граница(Дата,видграницы.Включая));
	Запрос.УстановитьПараметр("Дата",Новый граница(Дата,видграницы.Исключая));
	//кухарь 21.05.15 конец
	Запрос.УстановитьПараметр("Склад",ТранзитныйСклад);
	Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
	Запрос.УстановитьПараметр("СписокПартий",СписокПартий);
	результат=запрос.Выполнить().Выгрузить();
	
	для каждого СтрТЧ из  ТоварыПартии цикл
		Отбор=новый Структура;
		Отбор.Вставить("ШтВКоробе",СтрТЧ.ШтукВКоробе);
		Отбор.Вставить("Номенклатура",СтрТЧ.Номенклатура);
		Отбор.Вставить("Партия",СтрТЧ.Им7);
		
		НашлиОтбором=результат.НайтиСтроки(Отбор);
		если НашлиОтбором.Количество()=0 тогда
			СтрТЗ=ТЗСПроизводителями.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ,СтрТЧ);
		иначе
			если НашлиОтбором.Получить(0).Количество>=СтрТЧ.Количество тогда
				СтрТЗ=ТЗСПроизводителями.Добавить();
				ЗаполнитьЗначенияСвойств(СтрТЗ,СтрТЧ);
				СтрТЗ.производитель=НашлиОтбором.Получить(0).Производитель;
			иначе
				СчКоличества=0;
				ОсталосьДобрать=СтрТЧ.Количество;
				Для каждого СтрФабрики из НашлиОтбором цикл
					СтрТЗ=ТЗСПроизводителями.Добавить();
					ЗаполнитьЗначенияСвойств(СтрТЗ,СтрТЧ);
					СтрТЗ.производитель=НашлиОтбором.Получить(0).Производитель;
					
					если ОсталосьДобрать>=СтрФабрики.Количество тогда
						СтрТЗ.количество=СтрФабрики.Количество;
					иначе
						СтрТЗ.количество=ОсталосьДобрать;
					КонецЕсли;
					ОсталосьДобрать=ОсталосьДобрать-СтрТЗ.Количество;					
					если ОсталосьДобрать=0 тогда
						Прервать;
					КонецЕсли;
					
				КонецЦикла;		
				если ОсталосьДобрать>0 тогда
					#Если КЛИЕНТ Тогда
						Сообщить("Сбой распределения по фабрикам, обратитесь в тех поддержку!");
						Возврат ложь;
					#КонецЕсли
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТоварыПартии.Очистить();
	ТоварыПартии.Загрузить(ТЗСПроизводителями);
	Возврат Истина;
КонецФункции

