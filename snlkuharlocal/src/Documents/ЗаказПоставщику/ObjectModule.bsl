						ДвижениеПоПартиям.Валюта = СписокВалютИм7.получить(Стр.Им7);
						ДвижениеПоПартиям.Вес =  ТекВес;
						ДвижениеПоПартиям.ВесНетто =ТекВесНетто;	
					КонецЕсли;				
				Иначе
					ДвижениеПоПартиям.Сумма = 0;
					ДвижениеПоПартиям.Валюта = СписокВалютИм7.получить(Стр.Им7);
