Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	ДвиженияПоРегистрам=Неопределено;
	
	Если СостояниеЗаказа=Перечисления.СостояниеЗаказаПоставщику.ВПути			
		ИЛИ СостояниеЗаказа=Перечисления.СостояниеЗаказаПоставщику.Таможня     		
		ИЛИ СостояниеЗаказа=Перечисления.СостояниеЗаказаПоставщику.Получен Тогда			
		ПроводитьПоПути=Истина;
	Иначе
		ПроводитьПоПути=Ложь;			
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Доллары		= Справочники.Валюты.НайтиПоКоду("840");
	Евро		= Справочники.Валюты.НайтиПоКоду("978");
	
	КурсВалюты	= ПолучитьКурсВалюты_ПоРусски(Валюта,Дата);
	
	ВалютаУпр	= ?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	КурсДоллара	= ПолучитьКурсВалюты(Доллары,Дата).Курс;
	КурсЕвро	= ПолучитьКурсВалюты(Евро,Дата).Курс;
	Рубли		= ПараметрыСеанса.ВалютаНац;
	
	Валюты_Курсы=Новый Структура("ВалютаДокумента,КурсДокумента,Рубли,Доллары,Евро,ВалютаНац,Евро,Доллары,КурсДоллара,КурсЕвро",Валюта,Курс,1,КурсДоллара,КурсЕвро,1,Справочники.Валюты.НайтиПоКоду("978"),Справочники.Валюты.НайтиПоКоду("840"),КурсДоллара,КурсЕвро);
	
	ПроводитьПоЗаказам	= ПроводитьПоЗаказам(Ссылка);
	
	Если Не Отказ Тогда		
		Если  СостояниеЗаказа<>Перечисления.СостоянияНакладной.ВРаботе и СостояниеЗаказа<>Перечисления.СостоянияНакладной.Сканирование и  ОтгрузкаСТранзитногоСклада 
			И ( ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение ИЛИ ПараметрыСеанса.ЭтотУзел.Код = ТранзитныйСклад.КодФизическогоУзла) Тогда
			ТаблицаСписания=Неопределено;
			
			РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка,ТаблицаСписания);			
			Результат=РезультатПроведения["Результат"];
			
			Результат=РезультатПроведения["Результат"];
			
			Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда		
				Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));		
				
				ВывестиТрассировку(РезультатПроведения["ТОшибок"],?(Отказ,-2,Результат));			
			КонецЕсли; 
			
			Если НЕ Отказ Тогда
				ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);						
			КонецЕсли;			
			
			ТаблицаСписания.Свернуть("Номенклатура","Количество,СписанаСтоимость");
			Если ПроводитьПоПути = Истина Тогда
				ТаблицаПути = Новый ТаблицаЗначений;
				ТаблицаПути.Колонки.Добавить("Номенклатура");
				ТаблицаПути.Колонки.Добавить("Количество");
				ТаблицаПути.Колонки.Добавить("Сумма");
				ТаблицаПути.Колонки.Добавить("СуммаПоставщика");
				
				Для Каждого СтрокаТЧ Из ТаблицаСписания Цикл	
					Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли;
					СтрокаТаблицыПути = ТаблицаПути.Добавить();
					СтрокаТаблицыПути.Номенклатура = СтрокаТЧ.Номенклатура;
					СтрокаТаблицыПути.Количество   = СтрокаТЧ.Количество;
