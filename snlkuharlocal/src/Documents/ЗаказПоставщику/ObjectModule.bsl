				ТекСумма = 0;
				ТекВес = 0;
				ТекВесНетто = 0;
				ТекКоличество = 0;

				Для Каждого СтрокаОстатка Из ТекОстатки Цикл
					Если СтрокаОстатка.Им7 = Стр.Им7 Тогда
						ТекСумма  =ТекСумма	+СтрокаОстатка.Сумма;
						ТекВес = ТекВес + СтрокаОстатка.Брутто; 
						ТекВесНетто = ТекВесНетто + СтрокаОстатка.Нетто;
						ТекКоличество = ТекКоличество + СтрокаОстатка.Количество;
					КонецЕсли;
				КонецЦикла;	

				Если стр.Количество <>  0 Тогда
					если ТекКоличество<>стр.Количество тогда
						ДвижениеПоПартиям.Сумма = стр.Количество*ТекСумма/ТекКоличество;
						ДвижениеПоПартиям.Валюта = СписокВалютИм7.получить(Стр.Им7);
