Процедура ОбновитьДанныеЗаказа() Экспорт
	НеКонтролироватьЗапись=Истина;	
	Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
	НеКонтролироватьЗапись=Ложь;	
КонецПроцедуры 

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь,Очищать=Истина)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		Если Очищать Тогда
			НаборЗаписей.Очистить();		
		КонецЕсли;		
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

Процедура ПересчетДопРасходовПоИнвойсу() Экспорт	
	ДопРасходыПоИнвойсу=0;
	Для Каждого СтрокаДР Из Расходы Цикл
		ДопРасходыПоИнвойсу=ДопРасходыПоИнвойсу+глПересчет(СтрокаДР.Всего,СтрокаДР.Валюта,СтрокаДР.Курс,Валюта,Курс);	
	КонецЦикла;  
	Всего=Товары.Итог("Всего");	
	
	МаксРасходы=-10000000000000;
	СтрокаМаксРасходы=Неопределено;
	Для Каждого СтрокаТЧ ИЗ Товары Цикл
		Если Всего=0 Тогда
			СтрокаТЧ.ДопРасходыПоИнвойсу=0;
		Иначе
			СтрокаТЧ.ДопРасходыПоИнвойсу=СтрокаТЧ.Всего*ДопРасходыПоИнвойсу/Всего;		
		КонецЕсли;		
		Если СтрокаТЧ.ДопРасходыПоИнвойсу>МаксРасходы Тогда
			МаксРасходы=СтрокаТЧ.ДопРасходыПоИнвойсу;		
			СтрокаМаксРасходы=СтрокаТЧ;
		КонецЕсли;		
	КонецЦикла;	
	
	Хвост=ДопРасходыПоИнвойсу-Товары.Итог("ДопРасходыПоИнвойсу");
	Если Хвост<>0 И СтрокаМаксРасходы<>Неопределено Тогда
		СтрокаМаксРасходы.ДопРасходыПоИнвойсу=СтрокаМаксРасходы.ДопРасходыПоИнвойсу+Хвост;
	КонецЕсли; 
КонецПроцедуры

Процедура РасчетПроцента(СтрокаТЧ,КоэффициентКурса)
	СуммаИнвойса=СтрокаТЧ.Всего+СтрокаТЧ.ДопРасходыПоИнвойсу;
	Если СуммаИнвойса=0 Тогда
		СтрокаТЧ.ПроцентДопРасходовМашины=0;
	Иначе
		СтрокаТЧ.ПроцентДопРасходовМашины=100*КоэффициентКурса*СтрокаТЧ.ДопРасходыПоМашине/СуммаИнвойса;
	КонецЕсли;		
КонецПроцедуры 

Процедура ПересчетДопРасходовПоМашине() Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура.Родитель.Родитель КАК Брэнд,
	|	НомерСтроки-1 КАК НомерСтроки,
	|	Всего+ДопРасходыПоИнвойсу КАК СуммаИнвойса,	
	|	0 КАК ДопРасходыПоМашине
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка = &Заказ
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Брэнд,
	|	-1,
	|	0,	
	|	ДопРасходы КАК ДопРасходыПоМашине
	|ИЗ Документ.Машина.РаспределениеРасходов
	|ГДЕ 
	|	Ссылка=&Машина И Заказ=&Заказ
	|ИТОГИ СУММА(СуммаИнвойса),СУММА(ДопРасходыПоМашине) ПО Брэнд";
	
	Запрос.УстановитьПараметр("Заказ",Ссылка);
	Запрос.УстановитьПараметр("Машина",Машина);
	
	ВалютаМашины=Машина.Валюта;
	КурсМашины	=Машина.Курс;
	
	Если ВалютаМашины<>Валюта Тогда
		КоэффициентКурса=глПересчет(100000,ВалютаМашины,КурсМашины,Валюта,Курс)/100000;
	Иначе
		КоэффициентКурса=1;		
	КонецЕсли; 
	
	ВыборкаПоБрэндам=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Брэнд");
	Пока ВыборкаПоБрэндам.Следующий() Цикл
		СуммаИнвойсаПоБрэнду		= ВыборкаПоБрэндам.СуммаИнвойса;
		ДопРасходыПоМашине			= ВыборкаПоБрэндам.ДопРасходыПоМашине;
		ДопРасходыПоМашинеСписано   = 0;
		
		МаксРасходы					= -10000000000000;
		СтрокаМаксРасходы			= Неопределено;
		
		ВыборкаПоСтрокам=ВыборкаПоБрэндам.Выбрать();
		Пока ВыборкаПоСтрокам.Следующий() Цикл
			Если ВыборкаПоСтрокам.НомерСтроки<0 Тогда Продолжить КонецЕсли; 
			
			СтрокаТЧ=Товары.Получить(ВыборкаПоСтрокам.НомерСтроки);
			
			Если ВыборкаПоСтрокам.СуммаИнвойса=0 Тогда
				СтрокаТЧ.ДопРасходыПоМашине=0;
			Иначе
				СтрокаТЧ.ДопРасходыПоМашине=ВыборкаПоСтрокам.СуммаИнвойса*ДопРасходыПоМашине/СуммаИнвойсаПоБрэнду;		
			КонецЕсли;
			
			Если СтрокаТЧ.ДопРасходыПоМашине>МаксРасходы Тогда
				МаксРасходы=СтрокаТЧ.ДопРасходыПоМашине;		
				СтрокаМаксРасходы=СтрокаТЧ;
			КонецЕсли;		
			
			РасчетПроцента(СтрокаТЧ,КоэффициентКурса);
			
			ДопРасходыПоМашинеСписано=ДопРасходыПоМашинеСписано+СтрокаТЧ.ДопРасходыПоМашине;
		КонецЦикла; 
		
		Хвост=ДопРасходыПоМашине-ДопРасходыПоМашинеСписано;
		Если Хвост<>0 И СтрокаМаксРасходы<>Неопределено Тогда
			СтрокаМаксРасходы.ДопРасходыПоМашине=СтрокаМаксРасходы.ДопРасходыПоМашине+Хвост;
			РасчетПроцента(СтрокаТЧ,КоэффициентКурса);
		КонецЕсли; 
	КонецЦикла;
	
	
КонецПроцедуры

Процедура РасчетРублевыхЦенСтарая() Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура.Родитель КАК Модель,
	|	НомерСтроки-1 КАК НомерСтроки,
	|	(Всего+ДопРасходыПоИнвойсу)*&КурсЗаказа+ДопРасходыПоМашине*&КурсМашины КАК Всего,
	|	Количество КАК Количество
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка = &Заказ	
	|ИТОГИ СУММА(Всего),СУММА(Количество) ПО Модель";
	
	Запрос.УстановитьПараметр("Заказ",Ссылка);
	
	Запрос.УстановитьПараметр("КурсЗаказа",?(Валюта=ПараметрыСеанса.ВалютаУпр,1,Курс));	
	Запрос.УстановитьПараметр("КурсМашины",?(Машина.Валюта=ПараметрыСеанса.ВалютаУпр,1,Машина.Курс));	
	
	ВыборкаПоМоделям=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Модель");
	Пока ВыборкаПоМоделям.Следующий() Цикл
		Если ВыборкаПоМоделям.Количество=0 Тогда Продолжить КонецЕсли; 
		
		ВыборкаПоСтрокам=ВыборкаПоМоделям.Выбрать();
		Пока ВыборкаПоСтрокам.Следующий() Цикл
			СтрокаТЧ=Товары.Получить(ВыборкаПоСтрокам.НомерСтроки);		
			
			Если ВыборкаПоСтрокам.Количество=0 Тогда
				СтрокаТЧ.РасчетнаяЦена	=0;			
			Иначе				
				СтрокаТЧ.РасчетнаяЦена	=ВыборкаПоСтрокам.Всего/ВыборкаПоСтрокам.Количество;			
			КонецЕсли; 
			
			СтрокаТЧ.РасчетнаяСумма	=СтрокаТЧ.РасчетнаяЦена*СтрокаТЧ.Количество;
			//Кухарь 23.09.19 начало		
			//ПРоцент резерва теперь на разные строчки товаров разный.
			//		Если Машина.ПроцентРезерва<>0 Тогда
			//СтрокаТЧ.РасчетнаяСумма=СтрокаТЧ.РасчетнаяСумма*(1+Машина.ПроцентРезерва/100);	
			ПроцентРезерва=Машина.ПроцентРезерва;
			МассСтрокМашины=машина.РаспределениеРасходов.НайтиСтроки(новый Структура("Заказ,Брэнд",Ссылка,ВыборкаПоМоделям.модель.родитель));
			Для каждого СтрМасс из МассСтрокМашины цикл
				Процент=СтрМасс.ПроцентРезерва;
			КонецЦикла;
			
			Если ПроцентРезерва<>0 Тогда
				СтрокаТЧ.РасчетнаяСумма=СтрокаТЧ.РасчетнаяСумма*(1+ПроцентРезерва/100);	
				//Кухарь 23.09.19 конец	
				Если СтрокаТЧ.Количество<>0 Тогда
					СтрокаТЧ.РасчетнаяЦена=СтрокаТЧ.РасчетнаяСумма/СтрокаТЧ.Количество;								
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла;		
	КонецЦикла;	
КонецПроцедуры

//нечаева 23,03,15++ добавила расчет валютных цен расчетных.
Процедура РасчетРублевыхЦен() Экспорт
	Запрос=Новый Запрос;
	// добавила расчет валютных сумм расчетных. и цену расчетную валютную
	//нечаева 23,03,15+++ Нечаева
	Запрос.Текст="ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель КАК Модель,
	|	ЗаказПоставщикуТовары.НомерСтроки - 1 КАК НомерСтроки,
	|	(ЗаказПоставщикуТовары.Всего + ЗаказПоставщикуТовары.ДопРасходыПоИнвойсу) * &КурсЗаказа + ЗаказПоставщикуТовары.ДопРасходыПоМашине * &КурсМашины КАК Всего,
	|	ЗаказПоставщикуТовары.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА (НЕ &КурсМАшины = 1)
	|				И (НЕ &КурсЗаказа = 1) и ЗаказПоставщикуТовары.Ссылка.ОтгрузкаСТранзитногоСклада = ложь
	|			ТОГДА ЗаказПоставщикуТовары.Всего + ЗаказПоставщикуТовары.ДопРасходыПоИнвойсу + ЗаказПоставщикуТовары.ДопРасходыПоМашине
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ВсегоВАл
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка = &Заказ
	|ИТОГИ
	|	СУММА(Всего),
	|	СУММА(Количество),
	|	СУММА(ВсегоВАл)
	|ПО
	|	Модель";
	
	//нечаева 23,03,15--- Нечаева	
	
	Запрос.УстановитьПараметр("Заказ",Ссылка);
	
	Запрос.УстановитьПараметр("КурсЗаказа",?(Валюта=ПараметрыСеанса.ВалютаУпр,1,Курс));	
	Запрос.УстановитьПараметр("КурсМашины",?(Машина.Валюта=ПараметрыСеанса.ВалютаУпр,1,Машина.Курс));	
	
	ВыборкаПоМоделям=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Модель");
	Пока ВыборкаПоМоделям.Следующий() Цикл
		Если ВыборкаПоМоделям.Количество=0 Тогда Продолжить КонецЕсли; 
		
		ВыборкаПоСтрокам=ВыборкаПоМоделям.Выбрать();
		Пока ВыборкаПоСтрокам.Следующий() Цикл
			СтрокаТЧ=Товары.Получить(ВыборкаПоСтрокам.НомерСтроки);		
			
			Если ВыборкаПоСтрокам.Количество=0 Тогда
				СтрокаТЧ.РасчетнаяЦена	=0;			
				СтрокаТЧ.СуммаРасчетнаяВВалюте = 0;
			Иначе				
				СтрокаТЧ.РасчетнаяЦена	=ВыборкаПоСтрокам.Всего/ВыборкаПоСтрокам.Количество;
				//нечаева 23,03,15+++ Нечаева
				СтрокаТЧ.ЦенаРасчетнаяВВалюте = Окр(ВыборкаПоСтрокам.ВсегоВал/ВыборкаПоСтрокам.Количество,2,1);
				//нечаева 23,03,15--- Нечаева
				
			КонецЕсли; 
			
			СтрокаТЧ.РасчетнаяСумма	=СтрокаТЧ.РасчетнаяЦена*СтрокаТЧ.Количество;
			//нечаева 23,03,15+++ Нечаева
			СтрокаТЧ.СуммаРасчетнаяВВалюте	=СтрокаТЧ.ЦенаРасчетнаяВВалюте*СтрокаТЧ.Количество;
			//нечаева 23,03,15--- Нечаева
			
			//Кухарь 23.09.19 начало
			//Если Машина.ПроцентРезерва<>0 Тогда
			//СтрокаТЧ.РасчетнаяСумма=СтрокаТЧ.РасчетнаяСумма*(1+Машина.ПроцентРезерва/100);
			//СтрокаТЧ.СуммаРасчетнаяВВалюте=СтрокаТЧ.СуммаРасчетнаяВВалюте*(1+Машина.ПроцентРезерва/100);					
			ПроцентРезерва=Машина.ПроцентРезерва;
			МассСтрокМашины=машина.РаспределениеРасходов.НайтиСтроки(новый Структура("Заказ,Брэнд",Ссылка,ВыборкаПоМоделям.модель.родитель));
			Для каждого СтрМасс из МассСтрокМашины цикл
				ПроцентРезерва=СтрМасс.ПроцентРезерва;
				
				если ПроцентРезерва<>0 тогда					
					СтрокаТЧ.РасчетнаяСумма=СтрокаТЧ.РасчетнаяСумма*(1+ПроцентРезерва/100);
					СтрокаТЧ.СуммаРасчетнаяВВалюте=СтрокаТЧ.СуммаРасчетнаяВВалюте*(1+ПроцентРезерва/100);			
					//Кухарь 23.09.19 конец					
					Если СтрокаТЧ.Количество<>0 Тогда
						СтрокаТЧ.РасчетнаяЦена=СтрокаТЧ.РасчетнаяСумма/СтрокаТЧ.Количество;
						//нечаева 23,03,15+++ Нечаева
						СтрокаТЧ.ЦенаРасчетнаяВВалюте = СтрокаТЧ.СуммаРасчетнаяВВалюте/СтрокаТЧ.Количество;
						//нечаева 23,03,15--- Нечаева			
					КонецЕсли; 
				КонецЕсли; 
				//Кухарь 23.09.19 начало			
			КонецЦикла;
			//Кухарь 23.09.19 конец	
		КонецЦикла;		
	КонецЦикла;	
КонецПроцедуры


