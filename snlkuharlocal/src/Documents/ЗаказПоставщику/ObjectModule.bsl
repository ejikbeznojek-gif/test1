					ДвидВзР1.Период=Дата;
					ДвидВзР1.СуммаВал=СумКомпВал;
					ДвидВзР1.СуммаУпр=СуммаУпр;
					ДвидВзР1.СуммаДокумента=СуммаДокумента;
					ДвидВзР1.Регистратор=Ссылка;
					ДвидВзР1.ВалютаДокумента=Валюта;
					
					ДвидВзР2=Движения.Взаиморасчеты.Добавить();
