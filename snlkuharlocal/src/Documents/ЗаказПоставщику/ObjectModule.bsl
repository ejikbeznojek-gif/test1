					ДвидВзР2.Контрагент=КонтрагентКомпенсация;
					ДвидВзР2.Договор=ДоговорКомпенсация;
					ДвидВзР2.Период=Дата;
					ДвидВзР2.СуммаВал=СумКомпВал;
					ДвидВзР2.СуммаУпр=СуммаУпр;
					ДвидВзР2.СуммаДокумента=СуммаДокумента;
					ДвидВзР2.Регистратор=Ссылка;
					ДвидВзР2.ВалютаДокумента=Валюта;
					
					//ВалютаДокумента
					Движения.Взаиморасчеты.Записать();
				КонецЕсли;	
			КонецЕсли;	
			Если ПроводитьПоПути Тогда
				
				ТаблицаПути = Новый ТаблицаЗначений;
				ТаблицаПути.Колонки.Добавить("Номенклатура");
				ТаблицаПути.Колонки.Добавить("Количество");
				ТаблицаПути.Колонки.Добавить("Сумма");
				ТаблицаПути.Колонки.Добавить("СуммаПоставщика");
				
				Для Каждого СтрокаТЧ Из Товары Цикл	
					Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли;
					СтрокаТаблицыПути = ТаблицаПути.Добавить();
					СтрокаТаблицыПути.Номенклатура = СтрокаТЧ.Номенклатура;
					СтрокаТаблицыПути.Количество   = СтрокаТЧ.Количество;
					СтрокаТаблицыПути.Сумма		 =глПересчет(СтрокаТЧ.Всего+СтрокаТЧ.ДопРасходыПоИнвойсу,Валюта,Курс,ВалютаУпр,КурсУпр);
					СтрокаТаблицыПути.СуммаПоставщика	=СтрокаТЧ.Всего;	
				КонецЦикла;		
				ПровестиПоТоварамВПути(ТаблицаПути,ОбменДанными.Загрузка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если СостояниеЗаказа<>Перечисления.СостоянияНакладной.ВРаботе и СостояниеЗаказа<>Перечисления.СостоянияНакладной.Сканирование и ОтгрузкаСТранзитногоСклада 
		и  ТоварыПартии.Количество()>0 И ( ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение ИЛИ ПараметрыСеанса.ЭтотУзел.Код = ТранзитныйСклад.КодФизическогоУзла) Тогда

		Если ТоварыПартии.итог("Количество")<>Товары.итог("Количество") тогда
			Сообщить(""+ссылка+"Разное количество по товарам и по партиям. Не должно проводиться!");
			Отказ=ИСТИНА;возврат;
		Конецесли;	
		Остатки = ПолучитьОстаткиПартий(ТоварыПартии,Дата);
		СписокВалютИм7 = ПолучитьВалютыПартий(ТоварыПартии.ВыгрузитьКолонку("Им7"));
		Для Каждого Стр Из ТоварыПартии Цикл
