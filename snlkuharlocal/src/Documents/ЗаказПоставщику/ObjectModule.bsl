						ДвижениеПоПартиям.Вес = 0;
						ДвижениеПоПартиям.ВесНетто = 0;
						
						ДвижениеПоПартиям.Контракт          =Контракт;
					Конецесли;
				КонецЦикла;
			КонецЕсли;	
		КонецЕсли;
	иначе
		//++Данилова Е.В. 11.08.2025
		Если ПроводитьПоЗаказам Тогда				
			Если СостояниеЗаказа<>Перечисления.СостояниеЗаказаПоставщику.Ликвидирован Тогда 
				ДвиженияПоЗаказамПоставщикам("Товары","ЗаказыПоставщикам");
