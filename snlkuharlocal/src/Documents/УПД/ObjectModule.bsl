Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание.кодОперации =перечисления.КодыОперацийОстатки.Реализация ТОгда
		СФ = СФНакладной(Основание);
		Если НЕ СФ.пустая() Тогда
			НомерУПД = СФ.Номер;
		Иначе
			сообщить("Для РНК не существует документа СФ, просьба создать.");
			возврат;
		КонецЕсли;
	конецЕсли;
	
	ВидОснования = Основание.Метаданные().Имя;
	
	ИБ			 = Основание.ИБ; 
	
	Если ВидОснования = "РасходнаяНакладная" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		ДокОснование = Основание;
		ТипУПД = Перечисления.ТипУПД.СЧФДОП;
		
		// если комиссия, то тип УПД - ДОП
		Если договор.условияОплаты = перечисления.УсловияОплаты.Комиссия
			или Основание.кодОперации =перечисления.КодыОперацийОстатки.Комиссия 
		ТОгда
		
			ТипУПД = Перечисления.ТипУПД.доп;
		
		КонецЕсли;
		
		НомерУПД = Основание.Номер;
		ДатаУПД = Основание.Дата;

		Если Основание.кодОперации =перечисления.КодыОперацийОстатки.Реализация ТОгда
			СФ = СФНакладной(Основание);
			Если НЕ СФ.пустая() Тогда
				НомерУПД = СФ.Номер;
			Иначе
				сообщить("Для РНК не существует документа СФ, просьба создать.");
				возврат;
			КонецЕсли;
			
		ИначеЕсли Основание.кодОперации =перечисления.КодыОперацийОстатки.АгентскийДоговор  ТОгда
			
			НомерУПД = Основание.Номер;	
			
			
		КонецЕсли;			
		
		
	КонецЕсли;	
	
	// нечаева 06,11,24+++
	Если ВидОснования = "ПередачаКодовМаркировкиМП" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		ДокОснование = Основание;
		ТипУПД = Перечисления.ТипУПД.СЧФДОП;
		
		// если комиссия, то тип УПД - ДОП
		Если договор.условияОплаты = перечисления.УсловияОплаты.Комиссия
			или Основание.кодОперации =перечисления.КодыОперацийОстатки.Комиссия 
		ТОгда
		
			ТипУПД = Перечисления.ТипУПД.доп;
		
		КонецЕсли;
		
		НомерУПД = Основание.Номер;
		ДатаУПД = Основание.Дата;
		
		
		// пока сделали для всех контрагентов, из номера акта приемки.
		Если  СокрЛП(Основание.НомерАктаПриемки)<>"" Тогда
			ДатаУПД= Основание.ДатаАктаПриемки;
			НомерУПД = Основание.НомерАктаПриемки;
			ТипУПД = перечисления.ТипУПД.ДОП;
		КонецЕсли;
			
		
		
	КонецЕсли;
	// нечаева 06,11,24---
	
	
	
	
	
	
	
	Если ВидОснования = "РасходнаяНакладная" И ЗначениеЗаполнено(Основание.ДатаОтгрузки) И НачалоДня(Основание.ДатаОтгрузки)>НачалоДня(Основание.Дата) Тогда
		Дата=Основание.ДатаОтгрузки;		
	Иначе
		СдвигДаты=ПолучитьЗначениеПоУмолчанию("СдвигатьДатуСФ");
		Если СдвигДаты<>Неопределено Тогда
			Дата=Основание.Дата+СдвигДаты*24*60*60;		
		КонецЕсли;
	КонецЕсли;	
	
	РасчетИтогов();
	
КонецПроцедуры
