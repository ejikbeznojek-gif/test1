
Процедура РасчетИтогов() Экспорт
	СуммаБезНДС18		=0;
	НДС18				=0;
	СуммаБезНДС10		=0;
	НДС10				=0;
	СуммаСовсемБезНДС	=0;
	
	Если ДокОснование<>Неопределено И НЕ  ДокОснование.Пустая() Тогда
		ТабСтавок= ДокОснование.Товары.Выгрузить();
		ТабСтавок.Свернуть("СтавкаНДС","Всего,НДС");	
		
		Всего=ТабСтавок.Итог("Всего");		
		
		Для Каждого СтрокаСтавок Из ТабСтавок Цикл
				Если СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС18 ИЛИ СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС20 Тогда
								СуммаБезНДС18	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				НДС18			= СтрокаСтавок.НДС;			
			ИначеЕсли СтрокаСтавок.СтавкаНДС=Перечисления.СтавкиНДС.НДС10 Тогда
				СуммаБезНДС10	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				НДС10			= СтрокаСтавок.НДС;			
			ИначеЕсли СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.БезНДС ИЛИ СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.НДС0 Тогда
	
				СуммаСовсемБезНДС	= СтрокаСтавок.Всего;			
			КонецЕсли;			
		КонецЦикла; 
	КонецЕсли;
КонецПроцедуры

Функция КонтрольДублейСФ(СФОбъект,Отказ,Дубли=Неопределено) Экспорт	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	УПД.Ссылка КАК Ссылка,
	             |	УПД.ДокОснование КАК ДокОснование
	             |ИЗ
	             |	Документ.УПД КАК УПД
	             |ГДЕ
	             |	УПД.ПометкаУдаления = ложь
	             |	И УПД.ДокОснование = &докОсн
				 |	И Ссылка <> &Ссылка
				 |	И Ссылка.Организация = &Организация";
	
	
	//|ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|	Ссылка КАК СФ,
	//|	Накладная
	//|ИЗ
	//|	Документ.УПД КАК СчетФактураНакладные
	//|ГДЕ
	//|	Накладная В(&Накладные)
	//|	И НЕ Ссылка.ПометкаУдаления
	//|	И Ссылка <> &Ссылка
	//|	И Ссылка.Организация = &Организация";
	
	Запрос.УстановитьПараметр("ДокОсн",СФОбъект.ДокОснование);
	Запрос.УстановитьПараметр("Ссылка",СФОбъект.Ссылка);
	Запрос.УстановитьПараметр("Организация",СФОбъект.Организация);
	
	ЕстьДубли=Ложь;	
	
	Дубли=Новый Массив;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Сообщить("На накладную: "+Выборка.ДокОснование+", по организации: """+СФОбъект.Организация+"""
		|	уже выписана СФ: "+Выборка.Ссылка,СтатусСообщения.Важное);		
		ЕстьДубли=Истина;	
		
		Дубли.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Если НЕ Отказ И ЕстьДубли Тогда
		Отказ=Истина;
	КонецЕсли;	
	
	Возврат НЕ ЕстьДубли;
КонецФункции //КонтрольДублейСФ(СФОбъект,Отказ)


