Функция ЗаписатьЗначениеВРеквизитыДокументовСервер(Документ, ИмяРеквизита, ЗначениеРеквизита)
	
	ЗаписьВРег = РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
	ЗаписьВРег.Документ = Документ;
	ЗаписьВРег.ИмяРеквизита = ИмяРеквизита;
	ЗаписьВРег.Период = ТекущаяДатаСеанса();
	ЗаписьВРег.ЗначениеРеквизита = ЗначениеРеквизита;
	
	Попытка
		ЗаписьВРег.Записать();
		Возврат ЗаписьВРег;
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//++Данилова Е.В. 24.10.2025 HELP-7587 
	Если ЗначениеЗаполнено(НакладнаяИсточник)
		И ДокОснование <> НакладнаяИсточник Тогда
	
		ДокОснование = НакладнаяИсточник; 	
	
	КонецЕсли;
	//--Данилова Е.В. 24.10.2025
КонецПроцедуры

#КонецОбласти 

 
