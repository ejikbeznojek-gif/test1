#Область СобытияОбъекта

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Дата = ТекущаяДата();
	
	СтруктураВозврата = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьНастройки();
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураВозврата, "СкладБезМарок,СкладМаркировки,СкладСмешанныеСпайки");
	
	Если ТипЗнч(СтруктураВозврата.ДоступныеСкладыБезМарок) = Тип("Массив") Тогда
		ДоступныеСкладыБезМарок.Очистить();
		//++Данилова Е.В. 26.12.2025 SNL-92
		Приоритет = 1;
		//--Данилова Е.В. 26.12.2025 
		Для Каждого Элемент ИЗ СтруктураВозврата.ДоступныеСкладыБезМарок Цикл
			НоваяСтрока = ДоступныеСкладыБезМарок.Добавить();
			НоваяСтрока.СкладБезМарок = Элемент;
			//++Данилова Е.В. 26.12.2025  SNL-92
			НоваяСтрока.Приоритет = Приоритет; 
			Приоритет = Приоритет + 1; 
			//--Данилова Е.В. 26.12.2025
		КонецЦикла;
	КонецЕсли;
	//Данилова Е.В. 06.02.2026 
	СкладыДляРасчетаСпаек = Документы.ЗаказСмешанныхСпаекFBO.СкладДляРасчетаСпаек();
	Если ТипЗнч(СтруктураВозврата.ДоступныеСкладыМаркировка) = Тип("Массив") Тогда
		ДоступныеСкладыМаркировка.Очистить(); 
		//++Данилова Е.В. 26.12.2025 SNL-92
		Приоритет = 1;
		//--Данилова Е.В. 26.12.2025
		Для Каждого Элемент ИЗ СтруктураВозврата.ДоступныеСкладыМаркировка Цикл
			НоваяСтрока = ДоступныеСкладыМаркировка.Добавить();
			НоваяСтрока.СкладМаркировки = Элемент;
			//++Данилова Е.В. 26.12.2025  SNL-92
			НоваяСтрока.Приоритет = Приоритет; 
			Приоритет = Приоритет + 1;
			//Данилова Е.В. 03.02.2026 SNL-92
			//Данилова Е.В. 06.02.2026
			если СкладыДляРасчетаСпаек.Найти(НоваяСтрока.СкладМаркировки) <> Неопределено Тогда 
			//Если НоваяСтрока.СкладМаркировки = Документы.ЗаказСмешанныхСпаекFBO.СкладДляРасчетаСпаек() Тогда //Справочники.Склады.НайтиПоКоду("STD-99")  Тогда
				
				НоваяСтрока.РасчетПоГотовымСпайкам = Истина; 	
				
			КонецЕсли;
			//--Данилова Е.В. 26.12.2025
		КонецЦикла;
	КонецЕсли;
	
	НакладнаяИсточник = ДанныеЗаполнения;
	//++Данилова Е.В. 24.10.2025  HELP-7587 
	ДокОснование = ДанныеЗаполнения; 
	//--Данилова Е.В. 24.10.2025
	
	Если НЕ ЗначениеЗаполнено(НакладнаяИсточник) Тогда Возврат; КонецЕсли;
	//++Данилова Е.В. 24.10.2025 HELP-7587
	//тзКомплектующие = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьСпайки(НакладнаяИсточник);
	//
	//Спайки.Загрузить(тзКомплектующие);
	
	МассивНемаркированныхСкладов = ДоступныеСкладыБезМарок.Выгрузить().ВыгрузитьКолонку("СкладБезМарок");  
	МассивНемаркированныхСкладов.Добавить(СкладБезМарок);
	
	МассивМаркированныхСкладов = ДоступныеСкладыМаркировка.Выгрузить().ВыгрузитьКолонку("СкладМаркировки"); 
	МассивМаркированныхСкладов.Добавить(СкладМаркировки);
	
	тзКомплектующие = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьСпайки(НакладнаяИсточник, МассивНемаркированныхСкладов, МассивМаркированныхСкладов);
	
	Спайки.Загрузить(тзКомплектующие);
	
	//++Данилова Е.В. 01.11.2025 HELP-7698
	ЗаполнитьТоварыПоРНК(НакладнаяИсточник); 
	РежимРасчета = ВычислитьРежимРасчета(Товары.Выгрузить()); 
	//--Данилова Е.В. 01.11.2025
	////////////////////////////// УПАКОВКА //////////////////////////////////////////////////////////
	
	тзУпаковка = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьУпаковку(НакладнаяИсточник, МассивНемаркированныхСкладов, МассивМаркированныхСкладов);
	
	Упаковка.Загрузить(тзУпаковка); 
    //--Данилова Е.В. 24.10.2025
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если РасходныеНакладные.Количество() > 0 И Перемещения.Количество() > 0 Тогда
		СделатьЗаписиВРегистрРеквизитыДокументов();	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

