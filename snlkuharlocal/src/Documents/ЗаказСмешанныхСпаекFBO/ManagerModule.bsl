Функция СкладДляРасчетаСпаек() Экспорт 
     
 	//Возврат Справочники.Склады.НайтиПоКоду("STD-99");
	СкладИзНастроек = Справочники.Склады.НайтиПоКоду("STD-95");
	СкладыИзНастроек = Документы.ЗаказСмешанныхСпаекFBO.ПолучитьЗначениеРеквизитыСправочников(, "РасчетПоСпайкамЗаказFBO", ложь,ложь);
	Если ТипЗнч(СкладыИзНастроек) = Тип("Массив") Тогда
		
		Возврат СкладыИзНастроек; 
	Иначе 
		СкладыИзНастроек = Новый Массив;
		СкладыИзНастроек.Добавить(СкладИзНастроек); 
	КонецЕсли;
	
	Возврат СкладыИзНастроек; 
	 
 
КонецФункции 
