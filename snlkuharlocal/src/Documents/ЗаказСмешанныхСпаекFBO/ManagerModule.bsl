Функция РассчитатьОстатки(тзСпайки, МассивСкладов, БазовыйСклад, УчитыватьРезерв = Истина, РасчетУпаковокПоСкладуСмешанСпаек = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("тзСпайки", тзСпайки);
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	Если ТипЗнч(БазовыйСклад) = Тип("СправочникСсылка.Склады") Тогда
		МассивСкладовБазовый = Новый Массив;
		МассивСкладовБазовый.Добавить(БазовыйСклад);
		Запрос.УстановитьПараметр("БазовыйСклад", МассивСкладовБазовый);
	ИначеЕсли ТипЗнч(БазовыйСклад) = Тип("Массив") Тогда
		Запрос.УстановитьПараметр("БазовыйСклад", БазовыйСклад);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	Если УчитыватьРезерв Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(Спайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(Спайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
		|	ВЫРАЗИТЬ(Спайки.ПризнакМаркировки КАК БУЛЕВО) КАК ПризнакМаркировки,
		|	ВЫРАЗИТЬ(Спайки.Количество КАК ЧИСЛО) КАК Количество,
		|	ВЫРАЗИТЬ(Спайки.КоличествоКомплектующих КАК ЧИСЛО) КАК КоличествоКомплектующих
		|ПОМЕСТИТЬ вр_Спайка
		|ИЗ
		|	&тзСпайки КАК Спайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Спайка.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее) КАК Комплектующее,
		|	СУММА(ЕСТЬNULL(вр_Спайка.Количество, 0)) КАК Количество,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0) = 0
		|				ТОГДА 1
		|			ИНАЧЕ ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)
		|		КОНЕЦ) КАК КоличествоКомплектующих,
		|	МАКСИМУМ(вр_Спайка.ПризнакМаркировки) КАК ПризнакМаркировки,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) > 0
		|				ТОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОстатокНаБазовомСкладе,
		|	ВЫБОР
		|		КОГДА СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) >= СУММА(ВЫБОР
		|					КОГДА ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0) = 0
		|						ТОГДА 1
		|					ИНАЧЕ ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)
		|				КОНЕЦ)
		|			ТОГДА 0
		|		ИНАЧЕ СУММА(ВЫБОР
		|					КОГДА ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0) = 0
		|						ТОГДА 1
		|					ИНАЧЕ ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)
		|				КОНЕЦ) - СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0))
		|	КОНЕЦ КАК НужноПереместитьНаБазовыйСклад
		|ПОМЕСТИТЬ вр_ОстатокНаБазовомСкладе
		|ИЗ
