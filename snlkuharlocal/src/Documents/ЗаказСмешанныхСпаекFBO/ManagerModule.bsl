		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад В (&БазовыйСклад)) КАК ОстаткиТМЦОстатки
		|		ПО вр_Спайка.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	вр_Спайка.Номенклатура,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Спайка.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее) КАК Комплектующее,
		|	МАКСИМУМ(ЕСТЬNULL(вр_Спайка.Количество, 0)) КАК Количество,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0) = 0
		|				ТОГДА 1
		|			ИНАЧЕ ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)
		|		КОНЕЦ) КАК КоличествоКомплектующих,
		|	МАКСИМУМ(вр_Спайка.ПризнакМаркировки) КАК ПризнакМаркировки,
		|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0)) КАК Остаток
		|ПОМЕСТИТЬ вр_Остатки
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
		|		ПО вр_Спайка.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	вр_Спайка.Номенклатура,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Спайка.Номенклатура КАК Номенклатура,
		|	вр_Спайка.Комплектующее КАК Комплектующее,
		|	СУММА(ЕСТЬNULL(вр_Спайка.Количество, 0)) КАК Количество,
		|	СУММА(ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)) КАК КоличествоКомплектующих,
		|	МАКСИМУМ(вр_Спайка.ПризнакМаркировки) КАК ПризнакМаркировки,
		|	СУММА(ЕСТЬNULL(вр_ОстатокНаБазовомСкладе.ОстатокНаБазовомСкладе, 0)) КАК ОстатокБазовыйСклад,
		|	СУММА(ЕСТЬNULL(вр_Остатки.Остаток, 0)) КАК Остаток,
		|	0 КАК НужноПереместить
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ОстатокНаБазовомСкладе КАК вр_ОстатокНаБазовомСкладе
		|		ПО вр_Спайка.Комплектующее = вр_ОстатокНаБазовомСкладе.Комплектующее
		|			И вр_Спайка.Номенклатура = вр_ОстатокНаБазовомСкладе.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Остатки КАК вр_Остатки
		|		ПО вр_Спайка.Комплектующее = вр_Остатки.Комплектующее
		|			И вр_Спайка.Номенклатура = вр_Остатки.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	вр_Спайка.Номенклатура,
		|	вр_Спайка.Комплектующее";
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	тзОстатки = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	//Данилова Е.В. 06.10.2025 используется для упаковок
	Для Каждого Стр ИЗ тзОстатки Цикл
		
		//++Данилова Е.В. 24.10.2025 
		Если РасчетУпаковокПоСкладуСмешанСпаек Тогда
			
			Стр.ОстатокБазовыйСклад = 0; 	
			
		КонецЕсли;
		//--Данилова Е.В. 24.10.2025

		Если Стр.КоличествоКомплектующих > Стр.ОстатокБазовыйСклад + Стр.Остаток Тогда  		
			Стр.НужноПереместить = Стр.Остаток;			
		ИначеЕсли Стр.КоличествоКомплектующих <= Стр.ОстатокБазовыйСклад Тогда
			Стр.НужноПереместить = 0;
		ИначеЕсли Стр.КоличествоКомплектующих > Стр.ОстатокБазовыйСклад И Стр.КоличествоКомплектующих <= Стр.ОстатокБазовыйСклад + Стр.Остаток Тогда
			Стр.НужноПереместить = Стр.КоличествоКомплектующих - Стр.ОстатокБазовыйСклад;
		КонецЕсли;
		
	КонецЦикла;

	Возврат тзОстатки;
	
КонецФункции

Функция ОпределитьТипСпайки(тзОднойСпайки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзОднойСпайки", тзОднойСпайки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзОднойСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(тзОднойСпайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
	|	ВЫРАЗИТЬ(тзОднойСпайки.ПризнакМаркировки КАК БУЛЕВО) КАК ПризнакМаркировки
	|ПОМЕСТИТЬ вр_Спайка
	|ИЗ
	|	&тзОднойСпайки КАК тзОднойСпайки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Спайка.Номенклатура КАК Номенклатура,
	|	вр_Спайка.Комплектующее КАК Комплектующее,
	|	вр_Спайка.ПризнакМаркировки КАК ПризнакМаркировки
	|ПОМЕСТИТЬ вр_НемаркированныеКомплектующие
	|ИЗ
	|	вр_Спайка КАК вр_Спайка
	|ГДЕ
	|	вр_Спайка.ПризнакМаркировки = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Спайка.Номенклатура КАК Номенклатура,
	|	вр_Спайка.Комплектующее КАК Комплектующее,
	|	вр_Спайка.ПризнакМаркировки КАК ПризнакМаркировки
	|ПОМЕСТИТЬ вр_МаркированныеКомплектующие
	|ИЗ
	|	вр_Спайка КАК вр_Спайка
	|ГДЕ
	|	вр_Спайка.ПризнакМаркировки = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ вр_Спайка.Комплектующее) КАК Комплектующее
	|ИЗ
	|	вр_Спайка КАК вр_Спайка";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивПакетов = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	УстановитьПривилегированныйРежим(Ложь);
	
	НемаркированныеКомплектующие = МассивПакетов[1].Выгрузить();
	МаркированныеКомплектующие = МассивПакетов[2].Выгрузить();
	
	Если НемаркированныеКомплектующие.Количество() > 0 И МаркированныеКомплектующие.Количество() = 0 Тогда
		Возврат "БезМарок";
	ИначеЕсли НемаркированныеКомплектующие.Количество() = 0 И МаркированныеКомплектующие.Количество() > 0 Тогда
		Возврат "СМарками";
	ИначеЕсли НемаркированныеКомплектующие.Количество() > 0 И МаркированныеКомплектующие.Количество() > 0 Тогда
		Возврат "СмешанныеСпайки";
	Иначе
		Возврат "БезМарок";
	КонецЕсли;
	
КонецФункции
//Данилова Е.В. 23.10.2025 HELP-5978
Функция ПодогнатьКоличествоСпаекКОстатку(тзСпайки,ЭтоСмешанныеСпайки = Ложь, МассивНоменклатуры = неопределено, ПроверятьНаМинКолПродукции = ложь) Экспорт
	
	тзПодогнанныхСпаек = тзСпайки.СкопироватьКолонки();
	//++Данилова Е.В. 01.11.2025  HELP-7698 
	Если МассивНоменклатуры = Неопределено  Тогда
		
		МассивНоменклатуры = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(тзСпайки.ВыгрузитьКолонку("Номенклатура"));	
		
	КонецЕсли; 
	//--Данилова Е.В. 01.11.2025
	Для Каждого Номенклатура ИЗ МассивНоменклатуры Цикл
		
		тзОднойСпайки = тзСпайки.Скопировать(Новый Структура("Номенклатура", Номенклатура));
		//++Данилова Е.В. 28.10.2025 HELP-7587 
		тзОднойСпайки.Колонки.Добавить("ОстатокБазовыйСкладСохр");
		тзОднойСпайки.Колонки.Добавить("ОстатокСохр");
		//--Данилова Е.В. 28.10.2025
		ВсеОК = Истина;
		//++Данилова Е.В. 02.10.2025 HELP-5978
		//ПересчитыватьСпайку = Ложь;
		
		МассивКоличеств = Новый Массив; 
		
		
		СоответствиеКомплектующееКолСпаек = Новый Соответствие;
		ПересчитыватьСпайку = Истина;
		//--Данилова Е.В. 02.10.2025
		
		Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл   // Цикл по Спайке
			//++Данилова Е.В. 23.10.2025 HELP-5978
			Если ЭтоСмешанныеСпайки = Истина Тогда
			
				СтрокаТЗ.ОстатокБазовыйСклад = 0; 	
			
			КонецЕсли;
			
			СтрокаТЗ.ОстатокБазовыйСкладСохр = СтрокаТЗ.ОстатокБазовыйСклад; 
			СтрокаТЗ.ОстатокСохр = СтрокаТЗ.Остаток; 
			//--Данилова Е.В. 23.10.2025
			
			///// ЕСЛИ ОСТАТОК ПО ОДНОЙ КОМПЛЕКТУЮЩЕЙ <= 0 - ВЫЧЕРКИВАЕМ ВСЮ СПАЙКУ
			Если СтрокаТЗ.Остаток <= 0 И СтрокаТЗ.ОстатокБазовыйСклад <= 0 Тогда
				ВсеОК = Ложь;
				//++Данилова Е.В. 02.10.2025
				ПересчитыватьСпайку = ЛОЖЬ;
				//--Данилова Е.В. 02.10.2025
				Прервать;
			Иначе   //Если  СтрокаТЗ.КоличествоКомплектующих > СтрокаТЗ.Остаток + СтрокаТЗ.ОстатокБазовыйСклад Тогда  //++Данилова Е.В. 02.10.2025 HELP-5978
				//++Данилова Е.В. 02.10.2025 HELP-5978 
				Если СтрокаТЗ.Количество = 0 Тогда
				
					КоличествоКомплектВСпайке = 0; 	
				Иначе 
					КоличествоКомплектВСпайке = Цел(СтрокаТЗ.КоличествоКомплектующих/СтрокаТЗ.Количество);
				КонецЕсли;
				
				Если КоличествоКомплектВСпайке = 0 Тогда
				
					ПодобранноеКоличество = 0; 	
				Иначе 
					ПодобранноеКоличество = Цел((СтрокаТЗ.Остаток + СтрокаТЗ.ОстатокБазовыйСклад)/КоличествоКомплектВСпайке); 
				КонецЕсли;
				//Коэффициент = СтрокаТЗ.КоличествоКомплектующих / ?(СтрокаТЗ.Количество = 0, 1, СтрокаТЗ.Количество);
				//ПодобранноеКоличество = (СтрокаТЗ.Остаток + СтрокаТЗ.ОстатокБазовыйСклад) / ?(СтрокаТЗ.КоличествоКомплектующих = 0, 1, СтрокаТЗ.КоличествоКомплектующих);
				//ПодобранноеКоличество = Окр(ПодобранноеКоличество, 0, РежимОкругления.Окр15как10);
				//--Данилова Е.В. 02.10.2025 
				Если ПодобранноеКоличество <= 0 Тогда
					ВсеОК = Ложь;
					//++Данилова Е.В. 02.10.2025
					ПересчитыватьСпайку = ЛОЖЬ;
					//--Данилова Е.В. 02.10.2025
					Прервать;
				КонецЕсли;
				//++Данилова Е.В. 02.10.2025 HELP-5978
				//ПересчитыватьСпайку = Истина; 
				МассивКоличеств.Добавить(ПодобранноеКоличество); 
				СоответствиеКомплектующееКолСпаек.Вставить(СтрокаТЗ.Комплектующее,КоличествоКомплектВСпайке); 
				//--Данилова Е.В. 02.10.2025
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПересчитыватьСпайку Тогда
			Если МассивКоличеств.Количество() > 0 Тогда
				МинимальноеКоличество = 1000000;
				Для Каждого СтрКоличество ИЗ МассивКоличеств Цикл
					МинимальноеКоличество = Мин(СтрКоличество, МинимальноеКоличество);	
				КонецЦикла;
				Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл 
					//++Данилова Е.В. 03.10.2025 HELP-5978
					//СтрокаТЗ.Количество = МинимальноеКоличество;
					СтрокаТЗ.Количество = Мин(СтрокаТЗ.Количество,МинимальноеКоличество);
					//++Данилова Е.В. 01.11.2025 HELP-7698 
					Если ПроверятьНаМинКолПродукции = Истина 
						И СтрокаТЗ.ЕстьМИН Тогда
						
						Если СтрокаТЗ.Количество < СтрокаТЗ.МинКоличествоПродукции Тогда
							
							ВсеОК = ЛОЖЬ; 
							Прервать; 
							
						КонецЕсли;	
						
					КонецЕсли;
					//--Данилова Е.В. 01.11.2025
					КоличествоКомплектВСпайке = СоответствиеКомплектующееКолСпаек.Получить(СтрокаТЗ.Комплектующее);
					Если КоличествоКомплектВСпайке <> неопределено  Тогда
					
						СтрокаТЗ.КоличествоКомплектующих = СтрокаТЗ.Количество * КоличествоКомплектВСпайке;	
					
					КонецЕсли;
					//++Данилова Е.В. 28.10.2025 HELP-7587  
					ОстатокБазовыйСкладКомпл  = СтрокаТЗ.ОстатокБазовыйСклад; 
					ОстатокКомпл = СтрокаТЗ.Остаток; 
					//--Данилова Е.В. 28.10.2025
					Если СтрокаТЗ.КоличествоКомплектующих > СтрокаТЗ.ОстатокБазовыйСклад + СтрокаТЗ.Остаток Тогда  		
						СтрокаТЗ.НужноПереместить = СтрокаТЗ.Остаток;
						//++Данилова Е.В. 28.10.2025 HELP-7587  
						ОстатокБазовыйСкладКомпл = 0; 
						ОстатокКомпл = 0; 
						//--Данилова Е.В. 28.10.2025
					ИначеЕсли СтрокаТЗ.КоличествоКомплектующих <= СтрокаТЗ.ОстатокБазовыйСклад Тогда
						СтрокаТЗ.НужноПереместить = 0;
						//++Данилова Е.В. 28.10.2025 HELP-7587  
						ОстатокБазовыйСкладКомпл = ОстатокБазовыйСкладКомпл - СтрокаТЗ.КоличествоКомплектующих; 						 
						//--Данилова Е.В. 28.10.2025
					ИначеЕсли СтрокаТЗ.КоличествоКомплектующих > СтрокаТЗ.ОстатокБазовыйСклад И СтрокаТЗ.КоличествоКомплектующих <= СтрокаТЗ.ОстатокБазовыйСклад + СтрокаТЗ.Остаток Тогда
						СтрокаТЗ.НужноПереместить = СтрокаТЗ.КоличествоКомплектующих - СтрокаТЗ.ОстатокБазовыйСклад;
						//++Данилова Е.В. 28.10.2025 HELP-7587  
						ОстатокБазовыйСкладКомпл = 0; 
						ОстатокКомпл = ОстатокКомпл - СтрокаТЗ.НужноПереместить; 
						//--Данилова Е.В. 28.10.2025
					КонецЕсли;
					
					//--Данилова Е.В. 03.10.2025  
					//++Данилова Е.В. 28.10.2025 HELP-7587 
					//необходимо еще уменьшить остаток по комплектующей, чтобы расчет был верный 
					ОтборКомплект = Новый Структура("Комплектующее",СтрокаТЗ.Комплектующее);
					СтрокиПоКомплектующей = ТЗСпайки.НайтиСтроки(ОтборКомплект);
					Для каждого СтрокаПоКомплектующей Из СтрокиПоКомплектующей Цикл
					
						СтрокаПоКомплектующей.ОстатокБазовыйСклад = ОстатокБазовыйСкладКомпл; 
						СтрокаПоКомплектующей.Остаток = ОстатокКомпл; 
					
					КонецЦикла;
					//--Данилова Е.В. 28.10.2025
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		Если ВсеОК Тогда
			Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл 
				//++Данилова Е.В. 28.10.2025 HELP-7587
				//ЗаполнитьЗначенияСвойств(тзПодогнанныхСпаек.Добавить(), СтрокаТЗ,,"ОстатокБазовыйСклад,Остаток"); 
				НоваяСтрока = тзПодогнанныхСпаек.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ,,"ОстатокБазовыйСклад,Остаток");
				НоваяСтрока.ОстатокБазовыйСклад 	= СтрокаТЗ.ОстатокБазовыйСкладСохр; 
				НоваяСтрока.Остаток 				= СтрокаТЗ.ОстатокСохр;
				//-Данилова Е.В. 28.10.2025 HELP-7587 
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат тзПодогнанныхСпаек;
	
КонецФункции

Функция ПреобразоватьТаблицуСпаекВТаблицуТовары(тзСпайки, тзТовары = Неопределено, СкладПриемник = Неопределено, СпайкиБезУпаковки = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзСпайки", тзСпайки);
	Запрос.УстановитьПараметр("тзТовары", тзТовары);
	Запрос.УстановитьПараметр("СкладПриемник", СкладПриемник);
	//++Данилова Е.В. 06.11.2025 HELP-7698
	Запрос.УстановитьПараметр("ТЗСпайкиБезУпаковки", СпайкиБезУпаковки);
	//--Данилова Е.В. 06.11.2025
	Если тзТовары = Неопределено И СкладПриемник = Неопределено Тогда  // Перемещение
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзСпайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
		|	ВЫРАЗИТЬ(тзСпайки.НужноПереместить КАК ЧИСЛО) КАК НужноПереместить
		|ПОМЕСТИТЬ вр_Спайка
		|ИЗ
		|	&тзСпайки КАК тзСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Спайка.Комплектующее КАК Номенклатура,
		|	ЕСТЬNULL(вр_Спайка.НужноПереместить, 0) КАК Количество
		|ПОМЕСТИТЬ вр_Сводная
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|ГДЕ
		|	ЕСТЬNULL(вр_Спайка.НужноПереместить, 0) > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Сводная.Номенклатура КАК Номенклатура,
		|	СУММА(ЕСТЬNULL(вр_Сводная.Количество, 0)) КАК Количество
		|ИЗ
		|	вр_Сводная КАК вр_Сводная
		|
		|СГРУППИРОВАТЬ ПО
		|	вр_Сводная.Номенклатура";
		
	ИначеЕсли тзТовары = Неопределено И ТипЗнч(СкладПриемник) = Тип("СправочникСсылка.Склады") Тогда  // Перемещение на Склад Отгрузки
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзСпайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
		|	ВЫРАЗИТЬ(тзСпайки.НужноПереместить КАК ЧИСЛО) КАК НужноПереместить,
		|	ВЫРАЗИТЬ(тзСпайки.СкладОтгрузки КАК Справочник.Склады) КАК СкладОтгрузки
		|ПОМЕСТИТЬ вр_Спайка
		|ИЗ
		|	&тзСпайки КАК тзСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Спайка.Комплектующее КАК Номенклатура,
		|	ЕСТЬNULL(вр_Спайка.НужноПереместить, 0) КАК Количество
		|ПОМЕСТИТЬ вр_Сводная
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|ГДЕ
		|	ЕСТЬNULL(вр_Спайка.НужноПереместить, 0) > 0
		|	И вр_Спайка.СкладОтгрузки = &СкладПриемник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вр_Сводная.Номенклатура КАК Номенклатура,
		|	СУММА(ЕСТЬNULL(вр_Сводная.Количество, 0)) КАК Количество
		|ИЗ
		|	вр_Сводная КАК вр_Сводная
		|
		|СГРУППИРОВАТЬ ПО
		|	вр_Сводная.Номенклатура";
		//++Данилова Е.В. 06.11.2025 HELP-7698 
	ИначеЕсли ТипЗнч(тзТовары) = Тип("ТаблицаЗначений") И ТипЗнч(СпайкиБезУпаковки) = Тип("ТаблицаЗначений") Тогда //РНК по спайкам 
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзТовары.Количество КАК ЧИСЛО) КАК КоличествоИсх
		|ПОМЕСТИТЬ вр_Товары
		|ИЗ
		|	&тзТовары КАК тзТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзСпайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
		|	ВЫРАЗИТЬ(тзСпайки.Количество КАК ЧИСЛО) КАК Количество,
		|	тзСпайки.БезУпаковки КАК БезУпаковки
		|ПОМЕСТИТЬ вр_Спайка
		|ИЗ
		|	&тзСпайки КАК тзСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗСпайкиБезУпаковки.Номенклатура КАК Номенклатура,
		|	ТЗСпайкиБезУпаковки.Отгрузить КАК Отгрузить,
		|	ТЗСпайкиБезУпаковки.СкладОтгрузки КАК СкладОтгрузки
		|ПОМЕСТИТЬ ВТСпайкиБезУпаковки
		|ИЗ
		|	&ТЗСпайкиБезУпаковки КАК ТЗСпайкиБезУпаковки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	вр_Спайка.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(вр_Товары.КоличествоИсх, 0) >= ЕСТЬNULL(вр_Спайка.Количество, 0)
		|			ТОГДА ЕСТЬNULL(вр_Спайка.Количество, 0)
		|		ИНАЧЕ ЕСТЬNULL(вр_Товары.КоличествоИсх, 0)
		|	КОНЕЦ КАК Количество
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
		|		ПО вр_Спайка.Номенклатура = вр_Товары.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСпайкиБезУпаковки КАК ВТСпайкиБезУпаковки
		|		ПО (ВТСпайкиБезУпаковки.Номенклатура = вр_Спайка.Номенклатура)
		|			И (ВТСпайкиБезУпаковки.СкладОтгрузки = &СкладПриемник)
		|			И (вр_Спайка.БезУпаковки)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ ВТСпайкиБезУпаковки.Номенклатура ЕСТЬ NULL
		|				ТОГДА ВТСпайкиБезУпаковки.Отгрузить
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";

		//--Данилова Е.В. 06.11.2025
	ИначеЕсли ТипЗнч(тзТовары) = Тип("ТаблицаЗначений") Тогда  // Расходная накладная
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзТовары.Количество КАК ЧИСЛО) КАК КоличествоИсх
		|ПОМЕСТИТЬ вр_Товары
		|ИЗ
		|	&тзТовары КАК тзТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(тзСпайки.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
		|	ВЫРАЗИТЬ(тзСпайки.Количество КАК ЧИСЛО) КАК Количество
		|ПОМЕСТИТЬ вр_Спайка
		|ИЗ
		|	&тзСпайки КАК тзСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	вр_Спайка.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(вр_Товары.КоличествоИсх, 0) >= ЕСТЬNULL(вр_Спайка.Количество, 0)
		|			ТОГДА ЕСТЬNULL(вр_Спайка.Количество, 0)
		|		ИНАЧЕ ЕСТЬNULL(вр_Товары.КоличествоИсх, 0)
		|	КОНЕЦ КАК Количество
		|ИЗ
		|	вр_Спайка КАК вр_Спайка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
		|		ПО вр_Спайка.Номенклатура = вр_Товары.Номенклатура";
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	тзСпайкиТовары = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат тзСпайкиТовары;
	
КонецФункции

