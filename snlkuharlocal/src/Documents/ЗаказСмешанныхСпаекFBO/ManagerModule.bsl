Функция РассчитатьОстаткиПоОдномуСкладу(Номенклатура, Склад, УчитыватьРезерв = Истина) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	Если УчитыватьРезерв Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) > 0
		|				ТОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Остаток
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			&Период,
		|			Склад = &Склад
		|				И Номенклатура = &Номенклатура) КАК ОстаткиТМЦОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				&Период,
		|				Склад = &Склад
		|					И Номенклатура = &Номенклатура) КАК РезервыТМЦОстатки
		|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
		|			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	ОстаткиТМЦОстатки.Номенклатура";
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) > 0
		|				ТОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0)
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Остаток
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			&Период,
		|			Склад = &Склад
		|				И Номенклатура = &Номенклатура) КАК ОстаткиТМЦОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ОстаткиТМЦОстатки.Номенклатура";
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Остаток;
	КонецЦикла;

	Возврат 0;
	
КонецФункции

Функция УстановитьСкладОтгрузкиДляУпаковки(тзУпаковка, тзСпайки, СкладПриемник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзСпайки", тзСпайки);
	Запрос.УстановитьПараметр("тзУпаковка", тзУпаковка);
	Запрос.УстановитьПараметр("СкладПриемник", СкладПриемник);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Спайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Спайки.НужноПереместить КАК ЧИСЛО) КАК НужноПереместить
	|ПОМЕСТИТЬ вр_Спайка
	|ИЗ
	|	&тзСпайки КАК Спайки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзУпаковка.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(тзУпаковка.Комплектующее КАК Справочник.Номенклатура) КАК Комплектующее,
	|	ВЫРАЗИТЬ(тзУпаковка.ПризнакМаркировки КАК БУЛЕВО) КАК ПризнакМаркировки,
	|	ВЫРАЗИТЬ(тзУпаковка.Количество КАК ЧИСЛО) КАК Количество,
	|	ВЫРАЗИТЬ(тзУпаковка.КоличествоКомплектующих КАК ЧИСЛО) КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ вр_Упаковка
	|ИЗ
	|	&тзУпаковка КАК тзУпаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Упаковка.Номенклатура КАК Номенклатура,
	|	вр_Упаковка.Комплектующее КАК Комплектующее,
	|	вр_Упаковка.ПризнакМаркировки КАК ПризнакМаркировки,
	|	ЕСТЬNULL(вр_Упаковка.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(вр_Упаковка.КоличествоКомплектующих, 0) КАК КоличествоКомплектующих,
	|	ВЫБОР
	|		КОГДА вр_Упаковка.Номенклатура = вр_Спайка.Номенклатура
	|				И ЕСТЬNULL(вр_Спайка.НужноПереместить, 0) > 0
	|			ТОГДА ЕСТЬNULL(вр_Упаковка.КоличествоКомплектующих, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НужноПереместить,
	|	ВЫБОР
	|		КОГДА вр_Упаковка.Номенклатура = вр_Спайка.Номенклатура
	|			ТОГДА &СкладПриемник
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|	КОНЕЦ КАК СкладОтгрузки
	|ИЗ
	|	вр_Упаковка КАК вр_Упаковка
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Спайка КАК вр_Спайка
	|		ПО вр_Упаковка.Номенклатура = вр_Спайка.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	тзУпаковкаСклад = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат тзУпаковкаСклад;
	
КонецФункции

#КонецОбласти

#Область Служебные

// Возвращает структуру реквизитов объекта или ссылки, включая стандартные реквизиты и реквизиты табличной части.
// Можно использовать, если необходимо, например, эмулировать вызов метода, использующего объект формы.
//
// Параметры:
//  ВходящийОбъект - ЛюбаяСсылка или ЛюбойОбъект
//
// Возвращаемое значение:
//  Структура
//
Функция КонвертироватьОбъектВСтруктуру(ВходящийОбъект, ТолькоРеквизиты = Ложь,
		КонвертироватьСтандартныеРеквизиты = Ложь, МассивНеКонвертировать = Неопределено) Экспорт
	
	СтруктураОбъекта = Новый Структура;
	Если МассивНеКонвертировать = Неопределено Тогда
		МассивНеКонвертировать = Новый Массив;	
	КонецЕсли;
	
	Если КонвертироватьСтандартныеРеквизиты Тогда
		СтандартныеРеквизитыОбъекта = ВходящийОбъект.Метаданные().СтандартныеРеквизиты;
		Для Каждого СтандартныйРеквизит Из СтандартныеРеквизитыОбъекта Цикл
			СтруктураОбъекта.Вставить(СтандартныйРеквизит.Имя, ВходящийОбъект[СтандартныйРеквизит.Имя]);
		КонецЦикла;
	КонецЕсли;
	
	РеквизитыОбъекта = ВходящийОбъект.Метаданные().Реквизиты;
	Для Каждого Реквизит Из РеквизитыОбъекта Цикл
		Если МассивНеКонвертировать.Найти(Реквизит.Имя) = Неопределено Тогда 
			СтруктураОбъекта.Вставить(Реквизит.Имя, ВходящийОбъект[Реквизит.Имя]);
		КонецЕсли;
	КонецЦикла;
	
	Если ТолькоРеквизиты = Ложь Тогда	
		ТЧ = ВходящийОбъект.Метаданные().ТабличныеЧасти;
		Для Каждого ТаблЧасть Из ТЧ Цикл
			ТЗ = ВходящийОбъект[ТаблЧасть.Имя].Выгрузить();
			Массив = ТаблицаЗначенийВМассив(ТЗ);
			СтруктураОбъекта.Вставить(ТаблЧасть.Имя, Массив);
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтруктураОбъекта;
	
КонецФункции

Функция ТаблицаЗначенийВМассив(ТаблицаЗначений) Экспорт
	
	Массив = Новый Массив();
	СтруктураСтрокой = "";
	НужнаЗапятая = Ложь;
	Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл
		Если НужнаЗапятая Тогда
			СтруктураСтрокой = СтруктураСтрокой + ",";
		КонецЕсли;
		СтруктураСтрокой = СтруктураСтрокой + Колонка.Имя;
		НужнаЗапятая = Истина;
	КонецЦикла;
	Для Каждого Строка Из ТаблицаЗначений Цикл
		НоваяСтрока = Новый Структура(СтруктураСтрокой);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		Массив.Добавить(НоваяСтрока);
	КонецЦикла;
	Возврат Массив;
	
КонецФункции

