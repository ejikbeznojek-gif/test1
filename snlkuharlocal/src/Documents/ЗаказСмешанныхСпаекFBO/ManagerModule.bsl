#Область ЗаполнитьНастройки
//Данилова Е.В. 26.12.2025 SNL-92  добавление параметра
Функция ПолучитьЗначениеРеквизитыСправочников(Ссылка = Неопределено, ИмяРеквизита = "", ТолькоПервые = Ложь, ТочноеСоответствие = Истина ) Экспорт
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	//++Данилова Е.В. 26.12.2025 SNL-92 
	Если ТочноеСоответствие Тогда
		
		Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита);	
	Иначе 
		Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита + "%");
	КонецЕсли;
	//Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита);
	//--Данилова Е.В. 26.12.2025
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ " + ?(ТолькоПервые = Истина, "ПЕРВЫЕ 1", "") + "
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита,
	|   РеквизитыСправочников.ИмяРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ 
	//++Данилова Е.В. 26.12.2025 SNL-92 
	|	РеквизитыСправочников.ИмяРеквизита ПОДОБНО &ИмяРеквизита 
	//|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	//--Данилова Е.В. 26.12.2025
	|	" + ?(Ссылка = Неопределено, "", "И РеквизитыСправочников.Справочник = &Ссылка") + "
	|  УПОРЯДОЧИТЬ ПО РеквизитыСправочников.ИмяРеквизита ";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТолькоПервые Тогда
		Если Выборка.Следующий() Тогда
			Результат = Выборка.ЗначениеРеквизита;
		КонецЕсли;
	Иначе
		Результат = Новый Массив;
		Пока Выборка.Следующий() Цикл
			Результат.Добавить(Выборка.ЗначениеРеквизита);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьНастройки() Экспорт
	
	СтруктураВозврата = Новый Структура; 
	
	СтруктураВозврата.Вставить("СкладБезМарок", ПолучитьЗначениеРеквизитыСправочников(, "СкладБезМарок", Истина));
	СтруктураВозврата.Вставить("СкладМаркировки", ПолучитьЗначениеРеквизитыСправочников(, "СкладМаркировки", Истина));
	СтруктураВозврата.Вставить("СкладСмешанныеСпайки", ПолучитьЗначениеРеквизитыСправочников(, "СкладСмешанныеСпайки", Истина));
	
	СтруктураВозврата.Вставить("ДоступныеСкладыБезМарок", ПолучитьЗначениеРеквизитыСправочников(, "ДоступныйСкладБезМарок", Ложь,ложь));
	СтруктураВозврата.Вставить("ДоступныеСкладыМаркировка", ПолучитьЗначениеРеквизитыСправочников(, "ДоступныйСкладМаркировка", Ложь,ложь));
    //++Данилова Е.В. 01.11.2025 HELP-7698 
	СтруктураВозврата.Вставить("СкладНекоррМарок", ПолучитьЗначениеРеквизитыСправочников(, "СкладНекоррМарок", Истина));
	//--Данилова Е.В. 01.11.2025 
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаполнитьСпайки(НакладнаяИсточник, НемаркированныеСклады, МаркированныеСклады) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НакладнаяИсточник", НакладнаяИсточник);
	Запрос.УстановитьПараметр("НемаркированныеСклады", НемаркированныеСклады);
	Запрос.УстановитьПараметр("МаркированныеСклады", МаркированныеСклады);
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Комплектующие.Продукция КАК Номенклатура,
	|	Комплектующие.Номенклатура КАК Комплектующее,
	|	ЕСТЬNULL(Товары.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(Комплектующие.Количество, 0) КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ вр_Спайка
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК Комплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Товары КАК Товары
	|		ПО Комплектующие.Продукция = Товары.Номенклатура
	|			И Комплектующие.Ссылка = Товары.Ссылка
	|ГДЕ
	|	Комплектующие.Ссылка = &НакладнаяИсточник
	//++Данилова Е.В. 03.10.2025  HELP-5978 
	//|	И Комплектующие.Номенклатура.Родитель.ВидНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар), ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	|	И Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	//--Данилова Е.В. 03.10.2025
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Спайка.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее) КАК Комплектующее,
	|	СУММА(ЕСТЬNULL(вр_Спайка.Количество, 0)) КАК Количество,
	|	СУММА(ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)) КАК КоличествоКомплектующих,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК ОстатокНаНемаркированныхСкладах
	|ПОМЕСТИТЬ вр_ОстатокНаНемаркированныхСкладах
	|ИЗ
	|	вр_Спайка КАК вр_Спайка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад В (&НемаркированныеСклады)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Период, Склад В (&НемаркированныеСклады)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО вр_Спайка.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Спайка.Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Спайка.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее) КАК Комплектующее,
	|	СУММА(ЕСТЬNULL(вр_Спайка.Количество, 0)) КАК Количество,
	|	СУММА(ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0)) КАК КоличествоКомплектующих,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК ОстатокНаМаркированныхСкладах
	|ПОМЕСТИТЬ вр_ОстатокНаМаркированныхСкладах
	|ИЗ
	|	вр_Спайка КАК вр_Спайка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад В (&МаркированныеСклады)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Период, Склад В (&МаркированныеСклады)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО вр_Спайка.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Спайка.Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, вр_Спайка.Комплектующее)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Спайка.Номенклатура КАК Номенклатура,
	|	вр_Спайка.Комплектующее КАК Комплектующее,
	|	ЕСТЬNULL(вр_Спайка.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(вр_Спайка.КоличествоКомплектующих, 0) КАК КоличествоКомплектующих,
	|	ЕСТЬNULL(вр_ОстатокНаНемаркированныхСкладах.ОстатокНаНемаркированныхСкладах, 0) КАК ОстатокНаНемаркированныхСкладах,
	|	ЕСТЬNULL(вр_ОстатокНаМаркированныхСкладах.ОстатокНаМаркированныхСкладах, 0) КАК ОстатокНаМаркированныхСкладах,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вр_ОстатокНаНемаркированныхСкладах.ОстатокНаНемаркированныхСкладах, 0) > ЕСТЬNULL(вр_ОстатокНаМаркированныхСкладах.ОстатокНаМаркированныхСкладах, 0)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ЕСТЬNULL(вр_ОстатокНаМаркированныхСкладах.ОстатокНаМаркированныхСкладах, 0) > ЕСТЬNULL(вр_ОстатокНаНемаркированныхСкладах.ОстатокНаНемаркированныхСкладах, 0)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ
	|	КОНЕЦ КАК ПризнакМаркировки
	|ИЗ
	|	вр_Спайка КАК вр_Спайка
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ОстатокНаНемаркированныхСкладах КАК вр_ОстатокНаНемаркированныхСкладах
	|		ПО вр_Спайка.Комплектующее = вр_ОстатокНаНемаркированныхСкладах.Комплектующее
	|			И вр_Спайка.Номенклатура = вр_ОстатокНаНемаркированныхСкладах.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ОстатокНаМаркированныхСкладах КАК вр_ОстатокНаМаркированныхСкладах
	|		ПО вр_Спайка.Комплектующее = вр_ОстатокНаМаркированныхСкладах.Комплектующее
	|			И вр_Спайка.Номенклатура = вр_ОстатокНаМаркированныхСкладах.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	тзКомплектующие = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);

	Возврат тзКомплектующие;

КонецФункции

