				//		
				//	КонецПопытки;				
				//	
				//КонецЕсли;
				////--Данилова Е.В. 10.10.2025
				//НоваяСтрока = Объект.РасходныеНакладные.Добавить();
				//НоваяСтрока.НакладнаяПриемник = РНК_Спайки_МаркированныйТовар;
				//--Данилова Е.В. 17.10.2025 
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.СмешанныеСпайки.Количество() > 0 Тогда
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладСмешанныеСпайки);
		
