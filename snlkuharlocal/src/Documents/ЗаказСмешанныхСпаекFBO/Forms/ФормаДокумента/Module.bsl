	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУпаковкиДляМарокОстатки КАК ВТУпаковкиДляМарокОстатки
	|		ПО (ВТУпаковкиДляМарокОстатки.Номенклатура = ВтТовары.Номенклатура)
	|ГДЕ
	|	ВТУпаковкиДляМарокОстатки.Остаток + ВТУпаковкиДляМарокОстатки.ОстатокБазовыйСклад < ВтТовары.Количество"; 
	
	Запрос.УстановитьПараметр("СкладМаркировки",Объект.СкладМаркировки);
	Запрос.УстановитьПараметр("Товары",ТаблицаСпаекМаркированныеКопия); 
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	
	ТЧУпаковкиХватает = ПакетЗапросов[2].Выгрузить(); 
	ТЧУпаковкиХватает.Колонки.Добавить("НеХватает");
	
	ТЧУпаковкиХватаетКопия = ТЧУпаковкиХватает.Скопировать();
	
	КорректировкаОстатковСпайкиПоУпаковкам(ТЧУпаковкиХватает, ТЧУпаковкиХватаетКопия);
	
	ВыборкаУпаковкиНеХватает = ПакетЗапросов[3].Выбрать(); 
	
	Пока ВыборкаУпаковкиНеХватает.Следующий() Цикл
		
		НоваяСтрНеХватает = Объект.СпайкиБезУпаковки.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрНеХватает,ВыборкаУпаковкиНеХватает);  	
		
		ОтборПродукция = Новый Структура("Номенклатура",ВыборкаУпаковкиНеХватает.Номенклатура); 
		СтрокиБезМарок = Объект.СМарками.НайтиСтроки(ОтборПродукция);
		Для каждого СтрокаБезМарок Из СтрокиБезМарок Цикл
			
			СтрокаБезМарок.БезУпаковки = истина; 	
			
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

