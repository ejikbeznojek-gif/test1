&НаСервере
Функция ПолучитьТЗДоступныеСклады()
	
	Перем ДоступныеСклады, Запрос;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказСмешанныхСпаекFBOДоступныеСкладыБезМарок.СкладБезМарок КАК СкладБезМарок,
	|	ЗаказСмешанныхСпаекFBOДоступныеСкладыБезМарок.Приоритет КАК Приоритет
	|ПОМЕСТИТЬ ВТСкладыБезМарок
	|ИЗ
	|	&ДоступныеСкладыБезМарок КАК ЗаказСмешанныхСпаекFBOДоступныеСкладыБезМарок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказСмешанныхСпаекFBOДоступныеСкладыМаркировка.СкладМаркировки КАК СкладМаркировки,
	|	ЗаказСмешанныхСпаекFBOДоступныеСкладыМаркировка.Приоритет КАК Приоритет
	|ПОМЕСТИТЬ ВТСкладыМаркировки
	|ИЗ
	|	&ДоступныеСкладыМаркировка КАК ЗаказСмешанныхСпаекFBOДоступныеСкладыМаркировка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСкладыБезМарок.СкладБезМарок КАК Склад,
	|	ВТСкладыБезМарок.Приоритет КАК Приоритет
	|ИЗ
	|	ВТСкладыБезМарок КАК ВТСкладыБезМарок
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТСкладыМаркировки.СкладМаркировки,
	|	ВТСкладыМаркировки.Приоритет
	|ИЗ
	|	ВТСкладыМаркировки КАК ВТСкладыМаркировки";  
	
	Запрос.УстановитьПараметр("ДоступныеСкладыБезМарок",Объект.ДоступныеСкладыБезМарок.Выгрузить());
	Запрос.УстановитьПараметр("ДоступныеСкладыМаркировка",Объект.ДоступныеСкладыМаркировка.Выгрузить());
	
	ДоступныеСклады = Запрос.Выполнить().Выгрузить();
	Возврат ДоступныеСклады;

КонецФункции


&НаСервере
Процедура ЗаписатьПровестиДокументыРНКПРМ(Знач МассивПРМОбъекты, Знач МассивРНКОбъекты,РезультатСозданияДокументов) 	
	
	УстановитьПривилегированныйРежим(Истина); 
	ПараметрыСеанса.ЗапущенаОбработка = Истина; 
	УстановитьПривилегированныйРежим(ложь); 
	
	НачатьТранзакцию();
	
	МассивРНКЗаписанные = Новый Массив;
	МассивПРМЗаписанные = Новый Массив;
	
	ОшибкаЗаписи = ложь; 
	
	Если МассивПРМОбъекты.Количество() > 0  Тогда
		
		Для каждого  Перемещение Из МассивПРМОбъекты  Цикл
			
			УстановитьНомерДокументаКлиентСервер(Перемещение);	
			Перемещение.ДополнительныеСвойства.Вставить("ЗаписыватьБезПроверкиФизСкладов",истина);
			//++Данилова Е.В. 30.10.2025 HELP-7587 
			//Перемещение.ТребуетсяМаркировка = МаркировкаКС.ОпределитьЗначениеТребуетсяМаркировкаВДокументе(Перемещение,,,истина);
			//--Данилова Е.В. 30.10.2025
			
			Попытка
				Перемещение.ЗаписьБезКонтроляПолномочий();
				 				
			Исключение
				Сообщить("Не могу записать документ ПРМ"); 
				ОшибкаЗаписи = истина;
				ОтменитьТранзакцию();				 
				Прервать; 
			КонецПопытки;
			
			ПроводимоеПРМ = Перемещение.ссылка.ПолучитьОбъект();	
			ПроводимоеПРМ.Проведен = Истина;
			ПроводимоеПРМ.ДополнительныеСвойства.Вставить("ЗаписыватьБезПроверкиФизСкладов",истина);
			Попытка
				
				ПроводимоеПРМ.ЗаписьБезКонтроляПолномочий();
				
				МассивПРМЗаписанные.Добавить(ПроводимоеПРМ.ссылка);
			исключение
				Сообщить("Не могу провести документ ПРМ" + Строка(Перемещение.ссылка));
				ОшибкаЗаписи = истина;
				ОтменитьТранзакцию();
				Прервать; 
			КонецПопытки;
			
		КонецЦикла;
		
	КонецЕсли; 	
	
	ТЗНеизменяемыхРеквизитов=новый ТаблицаЗначений;
	ТЗНеизменяемыхРеквизитов.Колонки.Добавить("ИмяРеквизита");
	СтрТЗ = ТЗНеизменяемыхРеквизитов.Добавить();
	СтрТЗ.ИмяРеквизита = "ЗаписьНЕВПопытке";
	
	Если НЕ ОшибкаЗаписи
		И МассивРНКОбъекты.Количество() > 0  Тогда 		 
		
		Для каждого ДокРасходнаяНакладная Из МассивРНКОбъекты Цикл
			//Данилова Е.В. 30.10.2025 HELP-7587
			УстановитьНомерДокументаКлиентСервер(ДокРасходнаяНакладная);
			ДокРасходнаяНакладная.ОбменДанными.Загрузка = Истина;
			ДокРасходнаяНакладная.Дата = ТекущаяДатаСеанса();
			ДокРасходнаяНакладная.ДатаОтгрузки = ТекущаяДатаСеанса();
			Попытка
				ДокРасходнаяНакладная.ЗаписьБезКонтроляПолномочий(ТЗНеизменяемыхРеквизитов);
				
				МассивРНКЗаписанные.Добавить(ДокРасходнаяНакладная.ссылка);
			Исключение
				Сообщить("Не могу записать документ РНК");
				ОшибкаЗаписи = истина;
				ОтменитьТранзакцию();
				Прервать;
			КонецПопытки;
			Попытка
				РНК_Объект = ДокРасходнаяНакладная.ссылка.ПолучитьОбъект();
			Исключение
				Сообщить("Не удалось записать документ РНК");
				ОшибкаЗаписи = истина;
				Если ТранзакцияАктивна()  Тогда
					
					ОтменитьТранзакцию();	
					
				КонецЕсли;
				Прервать; 	
				
			КонецПопытки;
			
			РНК_Объект.Проведен = Истина; 		
			
			ТекстОшибкиОстатки = ""; 
			ПроверитьОстаткиИВывестиОшибки(ТекстОшибкиОстатки,РНК_Объект.ссылка);
			
			Если ЗначениеЗаполнено(ТекстОшибкиОстатки) Тогда
				
				Сообщить("Ошибки по остаткам на складе " + Строка(РНК_Объект.Склад) + Символы.ПС + ТекстОшибкиОстатки,СтатусСообщения.Важное); 	
				
			КонецЕсли;   		
			
			Попытка
				 
				РНК_Объект.ЗаписьБезКонтроляПолномочий(ТЗНеизменяемыхРеквизитов);
				//МассивРНКЗаписанные.Добавить(РНК_Объект.ссылка);
				
			Исключение
				 
				Сообщить("Не могу провести " + Строка(ДокРасходнаяНакладная.ссылка));
				ОшибкаЗаписи = истина;
				ОтменитьТранзакцию();
				Прервать; 
			КонецПопытки;
		КонецЦикла;
		
				
		
	КонецЕсли; 
	
	Если НЕ ОшибкаЗаписи 
		И ТранзакцияАктивна() Тогда
		
		ЗафиксироватьТранзакцию(); 
		
		Для каждого ЗаписанныйРНК Из МассивРНКЗаписанные Цикл
			
			НоваяСтрока = Объект.РасходныеНакладные.Добавить();
			НоваяСтрока.НакладнаяПриемник = ЗаписанныйРНК;		
			
		КонецЦикла; 
		
		Для каждого ЗаписанныйПРМ Из МассивПРМЗаписанные Цикл
			
			НоваяСтрока = Объект.Перемещения.Добавить();
			НоваяСтрока.ПеремещениеПриемник = ЗаписанныйПРМ;
			
			
		КонецЦикла;

		
		//++Данилова Е.В. 24.10.2025  HELP-7587 
		РезультатСозданияДокументов = Истина; 
		//--Данилова Е.В. 24.10.2025
		
	ИначеЕсли ТранзакцияАктивна() Тогда 
		ОтменитьТранзакцию();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина); 
	ПараметрыСеанса.ЗапущенаОбработка = Ложь; 
	УстановитьПривилегированныйРежим(ложь);
	
		
	
КонецПроцедуры

#КонецОбласти

#Область Сортировка

&НаСервере
Процедура РассортироватьСпайкиПоГруппамНаСервере(тзСпайки)
	
	Объект.БезМарок.Очистить();
	Объект.СМарками.Очистить();
	Объект.СмешанныеСпайки.Очистить();
	
	МассивНоменклатуры = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(тзСпайки.ВыгрузитьКолонку("Номенклатура"));
	
	Для Каждого Номенклатура ИЗ МассивНоменклатуры Цикл
		
		тзОднойСпайки = тзСпайки.Скопировать(Новый Структура("Номенклатура", Номенклатура));
		
		ТипСпайки = Документы.ЗаказСмешанныхСпаекFBO.ОпределитьТипСпайки(тзОднойСпайки);
		
		Если ТипСпайки = "БезМарок" Тогда
			Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл 
     				ЗаполнитьЗначенияСвойств(Объект.БезМарок.Добавить(), СтрокаТЗ) 
			КонецЦикла;	
		ИначеЕсли ТипСпайки = "СМарками" Тогда
			Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл 
     				ЗаполнитьЗначенияСвойств(Объект.СМарками.Добавить(), СтрокаТЗ) 
			КонецЦикла;
		ИначеЕсли ТипСпайки = "СмешанныеСпайки" Тогда
			Для Каждого СтрокаТЗ ИЗ тзОднойСпайки Цикл 
     				ЗаполнитьЗначенияСвойств(Объект.СмешанныеСпайки.Добавить(), СтрокаТЗ) 
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СозданиеДокументов
//Данилова Е.В. 05.11.2025 HELP-7698 
&НаСервере
Функция СоздатьРНК_НаСервере_Спайки()
		
	МассивНеКонвертировать = Новый Массив;
	МассивНеКонвертировать.Добавить("ДокОснование");
	МассивНеКонвертировать.Добавить("ДокументОснование");
	МассивНеКонвертировать.Добавить("Основание");
	
	ДополнительныеРеквизитыРНК = Документы.ЗаказСмешанныхСпаекFBO.КонвертироватьОбъектВСтруктуру(Объект.НакладнаяИсточник, Истина, Ложь, МассивНеКонвертировать);
	ДополнительныеРеквизитыРНК.Вставить("ДатаОтгрузки", Дата(1,1,1));
	ДополнительныеРеквизитыРНК.Вставить("Дата", ТекущаяДатаСеанса());
	ДополнительныеРеквизитыРНК.Вставить("НеЗаписыватьДокумент",истина); 
	ДополнительныеРеквизитыРНК.Вставить("Автор",ПараметрыСеанса.Пользователь);
	
	МассивРНК = Новый Массив; 
	
	ОтгрузкаКомплектов = Объект.РежимРасчета = 2; 
	
	Если Объект.БезМарок.Количество() > 0 Тогда 
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладБезМарок);
		
		тзБезМарок = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(Объект.БезМарок.Выгрузить(), Объект.НакладнаяИсточник.Товары.Выгрузить(),Объект.СкладБезМарок,Объект.СпайкиБезУпаковки.Выгрузить());
		
		Если тзБезМарок.Количество() > 0 Тогда
			
			РНК_Спайки_НемаркированныйТовар = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзБезМарок,
			ДополнительныеРеквизитыРНК,, "Без Марок", ОтгрузкаКомплектов, Истина, Истина, Ложь);
			
			УдалитьИзРНККомплектующиеУпаковки(РНК_Спайки_НемаркированныйТовар); 
			
			Если РНК_Спайки_НемаркированныйТовар <> Неопределено Тогда
				
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_НемаркированныйТовар,"Без марок");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла;
				
				 
			КонецЕсли;			
		КонецЕсли;
		
	КонецЕсли; 
	
	Если Объект.НекорректныеМарки.Количество() > 0 Тогда 
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладНекоррМарок);
		
		тзНекорректныеМарки = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(Объект.НекорректныеМарки.Выгрузить(), Объект.НакладнаяИсточник.Товары.Выгрузить(),Объект.СкладНекоррМарок,Объект.СпайкиБезУпаковки.Выгрузить());
		
		Если тзНекорректныеМарки.Количество() > 0 Тогда
			
			РНК_Спайки_НекорректныеМарки = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзНекорректныеМарки,
			ДополнительныеРеквизитыРНК,, "Некоректные марки", ОтгрузкаКомплектов, Истина, Истина, Ложь);
			
			УдалитьИзРНККомплектующиеУпаковки(РНК_Спайки_НекорректныеМарки);
			
			Если РНК_Спайки_НекорректныеМарки <> Неопределено Тогда 
				
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_НекорректныеМарки,"Некоректные марки");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла; 			
				 
			КонецЕсли;			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.СМарками.Количество() > 0 Тогда 
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладМаркировки);
		
		тзСМарками = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(Объект.СМарками.Выгрузить(), Объект.НакладнаяИсточник.Товары.Выгрузить(),Объект.СкладМаркировки,Объект.СпайкиБезУпаковки.Выгрузить());
		
		Если тзСМарками.Количество() > 0 Тогда
			
			РНК_Спайки_МаркированныйТовар = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзСМарками,
			ДополнительныеРеквизитыРНК,, "С Марками", ОтгрузкаКомплектов, Истина, Истина, Ложь);
			
			УдалитьИзРНККомплектующиеУпаковки(РНК_Спайки_МаркированныйТовар);
			
			Если РНК_Спайки_МаркированныйТовар <> Неопределено Тогда   			
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_МаркированныйТовар,"С марками");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла; 				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.ГотовыеСпайки.Количество() > 0 Тогда
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладМаркировки);
		
		КопияГотовыеСпайки = ПодготовитьТЧГотовыеСпайкиДляОбработки(); 
		Для каждого СтрокаГотСпайки Из КопияГотовыеСпайки Цикл
		    //++Данилова Е.В. 26.12.2025 SNL-92 
			//СтрокаГотСпайки.Количество = МИН(СтрокаГотСпайки.Остаток,СтрокаГотСпайки.Количество); 	
		    СтрокаГотСпайки.Количество = МИН(СтрокаГотСпайки.Остаток + СтрокаГотСпайки.ОстатокБазовыйСклад ,СтрокаГотСпайки.Количество);
			//--Данилова Е.В. 26.12.2025
		КонецЦикла;
		тзГотовыеСпайки = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(КопияГотовыеСпайки, Объект.НакладнаяИсточник.Товары.Выгрузить());
		
		Если тзГотовыеСпайки.Количество() > 0 Тогда
			
			РНК_Спайки_ГотовыеСпайки = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзГотовыеСпайки,
			ДополнительныеРеквизитыРНК,, "Готовые Спайки", ЛОЖЬ, Истина, Истина, Ложь);		
						
			Если РНК_Спайки_ГотовыеСпайки <> Неопределено Тогда
				
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_ГотовыеСпайки,"Готовые Спайки");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла; 			
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли; 
	
	//++Данилова Е.В. 17.10.2025 HELP-5978 
	
	Возврат МассивРНК; 
	//--Данилова Е.В. 17.10.2025
	
КонецФункции

&НаСервере
Функция ПодготовитьТЧГотовыеСпайкиДляОбработки() 	
	
	КопияГотовыеСпайки = Объект.ГотовыеСпайки.Выгрузить(); 
	//КопияГотовыеСпайки.Колонки.Добавить("Комплектующее",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказСмешанныхСпаекFBOГотовыеСпайки.Номенклатура КАК Номенклатура,
		|	ЗаказСмешанныхСпаекFBOГотовыеСпайки.Количество КАК Количество,
		|	ЗаказСмешанныхСпаекFBOГотовыеСпайки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
		|	ЗаказСмешанныхСпаекFBOГотовыеСпайки.Остаток КАК Остаток,
		|	ЗаказСмешанныхСпаекFBOГотовыеСпайки.НужноПереместить КАК НужноПереместить
		|ПОМЕСТИТЬ ВТГотовыеСпайки
		|ИЗ
		|	&ГотовыеСпайки КАК ЗаказСмешанныхСпаекFBOГотовыеСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТГотовыеСпайки.Номенклатура КАК Номенклатура,
		|	ВТГотовыеСпайки.Количество КАК Количество,
		|	ВТГотовыеСпайки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
		|	ВТГотовыеСпайки.Остаток КАК Остаток,
		|	ВТГотовыеСпайки.НужноПереместить КАК НужноПереместить,
		|	ВТГотовыеСпайки.Номенклатура КАК Комплектующее
		|ИЗ
		|	ВТГотовыеСпайки КАК ВТГотовыеСпайки";
	Запрос.УстановитьПараметр("ГотовыеСпайки",КопияГотовыеСпайки); 
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции
//++Данилова Е.В. 26.12.2025 SNL-92 
//вместо массива складов - ТЗ складов
&НаСервере
Функция СоздатьПРМ_НаСервере_Спайки(тзСпайки, ТаблицаСкладовИсточников, СкладПриемник,ЭтоУпаковка = Ложь) 
	 
	МассивПРМ = Новый Массив; 
	
	
	ДатаПРМ = ТекущаяДатаСеанса();
	
	ДополнительныеРеквизитыПРМ = Новый Структура;
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладной", Перечисления.СостоянияНакладной.Отгружена);
	ДополнительныеРеквизитыПРМ.Вставить("Отгружен", Перечисления.Отгружен.Отгружен);
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладнойУПолучателя", Перечисления.СостоянияНакладной.Принята);
	ДополнительныеРеквизитыПРМ.Вставить("Дата", ДатаПРМ);
	ДополнительныеРеквизитыПРМ.Вставить("ДатаПриемки", ДатаПРМ);
	ДополнительныеРеквизитыПРМ.Вставить("ДатаОтгрузки", ДатаПРМ);
	
	ДополнительныеРеквизитыПРМ.Вставить("НеЗаписыватьДокумент", истина);   
	ДополнительныеРеквизитыПРМ.Вставить("Контрагент", Справочники.Контрагенты.НайтиПоКоду("SSP-7012")); 
	//Данилова Е.В. 12.11.2025 HELP-7698
	ДополнительныеРеквизитыПРМ.Вставить("Автор",ПараметрыСеанса.Пользователь); 
	//++Данилова Е.В. 26.12.2025 
	//Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	Склады.Ссылка КАК Ссылка,
	//	|	ВЫБОР
	//	|		КОГДА Склады.ЭтоСкладFBS
	//	|			ТОГДА 2
	//	|		ИНАЧЕ 1
	//	|	КОНЕЦ КАК Сортировка
	//	|ИЗ
	//	|	Справочник.Склады КАК Склады
	//	|ГДЕ
	//	|	Склады.Ссылка В(&МассивСкладов)
	//	|
	//	|УПОРЯДОЧИТЬ ПО
	//	|	Сортировка";
	//
	//Запрос.УстановитьПараметр("МассивСкладов", МассивСкладовИсточников); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСкладов.Склад КАК Склад,
		|	ТаблицаСкладов.Приоритет КАК Приоритет
		|ПОМЕСТИТЬ ВТСклады
		|ИЗ
		|	&ТаблицаСкладов КАК ТаблицаСкладов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Склады.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА Склады.ЭтоСкладFBS
		|			ТОГДА 999
		|		ИНАЧЕ ВТСклады.Приоритет
		|	КОНЕЦ КАК Сортировка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
		|		ПО (ВТСклады.Склад = Склады.Ссылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сортировка";
	
	Запрос.УстановитьПараметр("ТаблицаСкладов", ТаблицаСкладовИсточников);
	//--Данилова Е.В. 26.12.2025 
	
	МассивСкладовИсточниковСортировка = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	///////////////////////////
	//ограничим остаток по FBS еще дополнительно 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(Матрица.Ссылка) КАК Матрица
		|ПОМЕСТИТЬ ВТМатрица
		|ИЗ
		|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица КАК Матрица
		|		ПО МатрицаПунктыДоставки.Ссылка = Матрица.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИнетМагазины КАК ИнетМагазиныСпр
		|		ПО (НЕ ИнетМагазиныСпр.ПометкаУдаления)
		|			И (ИнетМагазиныСпр.Контрагент = &Контрагент)
		|			И (ИнетМагазиныСпр.Организация = &Организация)
		|			И (ИнетМагазиныСпр.ПунктДоставки = МатрицаПунктыДоставки.ПунктДоставки)
		|ГДЕ
		|	Матрица.Проведен
		|	И Матрица.Дата <= &ТекущаяДата
		|	И Матрица.ДатаОкончания >= &ТекущаяДата
		|	И Матрица.Контрагент = &Контрагент
		|	И НЕ Матрица.Акция
		|	И Матрица.ПостояннаяАкция = &ПостояннаяАкция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТЧТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТКомплектующиеПРМ
		|ИЗ
		|	&ТЧТовары КАК ТЧТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МатрицаТовары.Номенклатура КАК Номенклатура,
		|	МатрицаТовары.МинимальноеКоличество КАК МинимальноеКоличество
		|
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМатрица КАК ВТМатрица
		|		ПО МатрицаТовары.Ссылка = ВТМатрица.Матрица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомплектующиеПРМ КАК ВТТоварыДляОтработки
		|		ПО (ВТТоварыДляОтработки.Номенклатура = МатрицаТовары.Номенклатура)
		|ГДЕ
		|	МатрицаТовары.МинимальноеКоличество <> 0";
	
	Запрос.УстановитьПараметр("Контрагент", Объект.НакладнаяИсточник.Контрагент);
	Запрос.УстановитьПараметр("Организация", Константы.ОсновнаяОрганизацияУправленческогоУчета.Получить());
	Запрос.УстановитьПараметр("ПостояннаяАкция", ложь);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ТЧТовары",тзСпайки); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СоответствиеМинКоличествоFBS = Новый Соответствие; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СоответствиеМинКоличествоFBS.Вставить(ВыборкаДетальныеЗаписи.Номенклатура,ВыборкаДетальныеЗаписи.МинимальноеКоличество); 
	КонецЦикла;


	Для Каждого СтрСклад ИЗ МассивСкладовИсточниковСортировка Цикл  // Обходим Склады
		
		Если СтрСклад = СкладПриемник Тогда
			Продолжить;
		КонецЕсли;
				
		тзСпайкиПРМ = Новый ТаблицаЗначений;
		тзСпайкиПРМ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		тзСпайкиПРМ.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
		
		Для Каждого СтрокаТЗ ИЗ тзСпайки Цикл  // Обходим Спайки с Комплектующими (Номенклатура)
			
			//++Данилова Е.В. 10.11.2025 HELP-7698
			//если это упаковка, то если по складу отгрузки, с которого собираются остатки, 
			//по этой упаковке есть, что нужно переместить, 
			//значит на нем уже не хватает и нельзя с него брать 
			УменьшитьИспользуемыйОстаток = 0;
			
			Если ЭтоУпаковка Тогда
				
				ОтборПоУпаковке = Новый Структура("Комплектующее,СкладОтгрузки",СтрокаТЗ.Номенклатура,СтрСклад); 	
				СтрокиПоУпаковке = Объект.Упаковка.НайтиСтроки(ОтборПоУпаковке); 
				 
				НельзяБратьУпаковку = Ложь;  
				Для каждого СтрокаПоУпаковке  Из СтрокиПоУпаковке Цикл
					
					Если СтрокаПоУпаковке.НужноПереместить > 0   Тогда
						
						НельзяБратьУпаковку = Истина; 	
						Прервать;  
					КонецЕсли;
					
					УменьшитьИспользуемыйОстаток = УменьшитьИспользуемыйОстаток + СтрокаПоУпаковке.КоличествоКомплектующих; 
					
				КонецЦикла;
				Если НельзяБратьУпаковку Тогда
					
					Продолжить; 	
					
				КонецЕсли;
				
			КонецЕсли;
			//также по FBS 
			Если СтрСклад.ЭтоСкладFBS 
				И СоответствиеМинКоличествоFBS.Получить(СтрокаТЗ.Номенклатура)<> Неопределено 
				И ТипЗнч(СоответствиеМинКоличествоFBS.Получить(СтрокаТЗ.Номенклатура)) = Тип("Число") Тогда
				
				УменьшитьИспользуемыйОстаток = 	УменьшитьИспользуемыйОстаток + СоответствиеМинКоличествоFBS.Получить(СтрокаТЗ.Номенклатура); 
				
			КонецЕсли;  		
			
			//--Данилова Е.В. 10.11.2025

			Количество = СтрокаТЗ.Количество;
			
			Если Количество <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ОстатокНаСкладе = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстаткиПоОдномуСкладу(СтрокаТЗ.Номенклатура, СтрСклад);
			//++Данилова Е.В. 11.11.2025  HELP-7698 
			Если ЭтоУпаковка 
				ИЛИ СтрСклад.ЭтоСкладFBS Тогда //Данилова Е.В. 26.12.2025 SNL-92
			
				ОстатокНаСкладе = ОстатокНаСкладе - УменьшитьИспользуемыйОстаток; 	
			
			КонецЕсли;
			//--Данилова Е.В. 11.11.2025
			Если ОстатокНаСкладе <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если Количество >= ОстатокНаСкладе Тогда
				
				НоваяСтрока = тзСпайкиПРМ.Добавить();
				НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
				НоваяСтрока.Количество = ОстатокНаСкладе;
				
				СтрокаТЗ.Количество = Количество - ОстатокНаСкладе;
				
			ИначеЕсли ОстатокНаСкладе > Количество Тогда
				
				НоваяСтрока = тзСпайкиПРМ.Добавить();
				НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
				НоваяСтрока.Количество = Количество;
				
				СтрокаТЗ.Количество = 0;	
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если тзСпайкиПРМ.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДополнительныеРеквизитыПРМ.Вставить("Склад", СтрСклад);
		
		ПРМ_Спайки = ЗаполнениеДокументов.СоздатьПеремещение(Объект.НакладнаяИсточник, тзСпайкиПРМ, СтрСклад,
		СкладПриемник, "Создано документом" + Строка(Объект.НакладнаяИсточник), ДополнительныеРеквизитыПРМ, Ложь, Истина,истина);		
		
		Если ПРМ_Спайки <> Неопределено Тогда			 
			МассивПРМ.Добавить(ПРМ_Спайки); 
		КонецЕсли;
		
	КонецЦикла;
	
	 
	Возврат МассивПРМ; 
	
	
КонецФункции



&НаСервере
Функция СоздатьРНК_НаСервере()
		
	МассивНеКонвертировать = Новый Массив;
	МассивНеКонвертировать.Добавить("ДокОснование");
