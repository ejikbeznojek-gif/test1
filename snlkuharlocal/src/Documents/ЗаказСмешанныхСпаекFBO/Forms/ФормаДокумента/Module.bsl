&НаСервере
Процедура РасчетОстатковСпайки()
	
	
	ОчиститьТаблицыПередРасчетом();
	
	МассивСкладыБезМарок = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
	МассивСкладыСМарками = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
	
	МассивВсеСклады = Объединить2Массива_НаСервере(МассивСкладыБезМарок, МассивСкладыСМарками);
	
	МассивВсеСклады.Добавить(Объект.СкладБезМарок);
	МассивВсеСклады.Добавить(Объект.СкладМаркировки);
	//МассивВсеСклады.Добавить(Объект.СкладСмешанныеСпайки); //кроме склада некоррект. марок 

	
	Запрос = Неопределено;
    МенеджерВременныхТаблиц = Неопределено;
    //ТоварыДляОбработки = Неопределено;
    РасчетОстатковПредварительныйРасчет(Запрос,МассивВсеСклады, МенеджерВременныхТаблиц); 	
	РасчетОстатковСпайкиГотовыеСпайки(Запрос, МенеджерВременныхТаблиц);	
	РасчетОстатковСпайкиБезМаркировки(Запрос, МассивВсеСклады, МассивСкладыБезМарок, МенеджерВременныхТаблиц);
	РасчетОстатковСпайкиНекорректныеМарки(Запрос, МассивВсеСклады, МенеджерВременныхТаблиц); 
	РасчетОстатковСпайкиСМарками(Запрос, МассивВсеСклады, МассивСкладыСМарками, МенеджерВременныхТаблиц);
	
	Объект.РасчетОстатковВыполнен = Истина; 
	
	ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));

КонецПроцедуры

&НаСервере
Процедура РасчетОстатковСпайкиСМарками(Запрос, МассивВсеСклады, МассивСкладыСМарками, МенеджерВременныхТаблиц)
	
	///////////////////////////////////////////////////////////
	//С марками 
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ВТКомплектующие.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВТКомплектующие.Комплектующее КАК Комплектующее,
	|	ВТКомплектующие.Количество - ЕСТЬNULL(ВТТоварыБезМарок.Количество, 0) - ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|			ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|		ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|	КОНЕЦ - ЕСТЬNULL(ВТТоварыНеКорректМарки.Количество, 0) КАК Количество,
	|	(ВТКомплектующие.Количество - ЕСТЬNULL(ВТТоварыБезМарок.Количество, 0) - ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|			ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|		ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|	КОНЕЦ - ЕСТЬNULL(ВТТоварыНеКорректМарки.Количество, 0)) * ВТКомплектующие.КоличествоКомплектующих / ВТКомплектующие.Количество КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ ВТКомплектующиеДляСМарками
	|ИЗ
	|	ВТКомплектующие КАК ВТКомплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ПО (ВТТоварыДляОтработки.Номенклатура = ВТКомплектующие.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыБезМарок КАК ВТТоварыБезМарок
	|		ПО (ВТТоварыБезМарок.Номенклатура = ВТТоварыДляОтработки.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТГотовыеСпайки КАК ВТГотовыеСпайки
	|		ПО (ВТГотовыеСпайки.Номенклатура = ВТКомплектующие.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыНеКорректМарки КАК ВТТоварыНеКорректМарки
	|		ПО (ВТТоварыНеКорректМарки.Номенклатура = ВТТоварыДляОтработки.Номенклатура)
	|ГДЕ
	|	ВТКомплектующие.Количество - ЕСТЬNULL(ВТТоварыБезМарок.Количество, 0) - ВЫБОР
	|			КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|				ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|			ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|		КОНЕЦ - ЕСТЬNULL(ВТТоварыНеКорректМарки.Количество, 0) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиБазовыйСкладСМарками
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее
	|	ИЗ
	|		ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками) КАК ВТКомплектующиеДляСМарками
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад = &СкладСмарками
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТКомплектующиеДляСМарками.Комплектующее
	|						ИЗ
	|							ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад = &СкладСмарками
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТКомплектующиеДляСМарками.Комплектующее
	|							ИЗ
	|								ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО ВТКомплектующиеДляСМарками.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиНаДрСкладахНЕFBS
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее
	|	ИЗ
	|		ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками) КАК ВТКомплектующиеДляСМарками
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&СкладыСМарками)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТКомплектующиеДляСМарками.Комплектующее
	|						ИЗ
	|							ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)
	|					И НЕ Склад.ЭтоСкладFBS) КАК ОстаткиТМЦОстаткиДрСкладыНеFBS
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&СкладыСМарками)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТКомплектующиеДляСМарками.Комплектующее
	|							ИЗ
	|								ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)
	|						И НЕ Склад.ЭтоСкладFBS) КАК РезервыТМЦОстаткиДрСкладыНеFBS
	|			ПО ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура = РезервыТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|				И ОстаткиТМЦОстаткиДрСкладыНеFBS.Склад = РезервыТМЦОстаткиДрСкладыНеFBS.Склад
	|		ПО ВТКомплектующиеДляСМарками.Комплектующее = ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТКомплектующиеДляСМарками.Комплектующее
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиНаДрСкладахFBS
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ВТКомплектующиеДляСМарками.Комплектующее КАК Комплектующее
	|	ИЗ
	|		ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками) КАК ВТКомплектующиеДляСМарками
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&СкладыСМарками)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТКомплектующиеДляСМарками.Комплектующее
	|						ИЗ
	|							ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)
	|					И Склад.ЭтоСкладFBS) КАК ОстаткиТМЦОстаткиДрСкладыFBS
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&СкладыСМарками)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТКомплектующиеДляСМарками.Комплектующее
	|							ИЗ
	|								ВТКомплектующиеДляСМарками КАК ВТКомплектующиеДляСМарками)
