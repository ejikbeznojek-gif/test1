&НаСервере
Функция ДопСкладыПоГотовымСпайкам() 
	
	ТЗСклады = Объект.ДоступныеСкладыМаркировка.Выгрузить();
	ТЗСклады.Очистить(); 
	 
	Отбор = Новый Структура("РасчетПоГотовымСпайкам",истина); 
	СтрокиДоп = Объект.ДоступныеСкладыМаркировка.НайтиСтроки(Отбор); 
	Для каждого СтрокаДоп Из СтрокиДоп Цикл
		
		СтрокаТЧ = ТЗСклады.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаДоп); 
		
	КонецЦикла;
	КолонкаТЗ = ТЗСклады.Колонки.Найти("СкладМаркировки"); 
	КолонкаТЗ.Имя = "Склад";
	
	Возврат ТЗСклады;

КонецФункции

&НаСервере
Процедура РасчетОстатковПредварительныйРасчет(Запрос, МассивВсеСклады, МенеджерВременныхТаблиц)
	
	////////////////////
	///Товары, по которым необходима обработка 
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ЗаказСмешанныхСпаекFBOТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ЗаказСмешанныхСпаекFBOТовары.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	&Товары КАК ЗаказСмешанныхСпаекFBOТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ФР_ВидыНоменклатуры.Ссылка КАК ВидНоменклатуры,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК МинКоличество
	|ПОМЕСТИТЬ ВТМинимальныеКоличества
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФР_ВидыНоменклатуры КАК ФР_ВидыНоменклатуры
	|		ПО РеквизитыСправочников.Справочник = ФР_ВидыНоменклатуры.Родитель
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = ""МинКоличествоЗаказFBO""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.Количество КАК Количество,
	|	ЕСТЬNULL(ВТМинимальныеКоличества.МинКоличество, 0) КАК МинКоличество
	|ПОМЕСТИТЬ ВТТоварыДляОтработки
	|ИЗ
	|	ВТТовары КАК ВТТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМинимальныеКоличества КАК ВТМинимальныеКоличества
	|		ПО (ВТМинимальныеКоличества.ВидНоменклатуры = ВТТовары.Номенклатура.Родитель.ФР_ВидНоменклатуры)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТМинимальныеКоличества.МинКоличество ЕСТЬ NULL
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВТТовары.Количество >= ЕСТЬNULL(ВТМинимальныеКоличества.МинКоличество, 0)
	|		КОНЕЦ
	|	И ВТТовары.Количество > 0"; 
	
	Запрос.УстановитьПараметр("Товары",Объект.Товары.Выгрузить()); 
	//ТоварыДляОбработки = Запрос.Выполнить().Выгрузить();
	Запрос.Выполнить(); 
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;
	
	//если режим расчета 2, то расчет еще общего остатка для дальнейшей корректировки остатков 
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказСмешанныхСпаекFBOУпаковка.Номенклатура КАК Номенклатура,
	|	ЗаказСмешанныхСпаекFBOУпаковка.Комплектующее КАК Комплектующее,
	|	ЗаказСмешанныхСпаекFBOУпаковка.Количество КАК Количество,
	|	ЗаказСмешанныхСпаекFBOУпаковка.КоличествоКомплектующих КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ ВТУпаковка
	|ИЗ
	|	&Упаковка КАК ЗаказСмешанныхСпаекFBOУпаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТУпаковка.Комплектующее КАК Комплектующее
	|ПОМЕСТИТЬ ВтУпаковкаКомплектующие
	|ИЗ
	|	ВТУпаковка КАК ВТУпаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтУпаковкаКомплектующие.Комплектующее КАК Комплектующее,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСклады.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСклады.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСклады.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСклады.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСклады.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСклады.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК ОстатокОбщий
	|ПОМЕСТИТЬ ВТОстаткиОбщиеУпаковка
	|ИЗ
	|	ВтУпаковкаКомплектующие КАК ВтУпаковкаКомплектующие
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&ВсеСклады)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВтУпаковкаКомплектующие.Комплектующее
	|						ИЗ
	|							ВтУпаковкаКомплектующие КАК ВтУпаковкаКомплектующие)) КАК ОстаткиТМЦОстаткиДрСклады
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&ВсеСклады)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВтУпаковкаКомплектующие.Комплектующее
	|							ИЗ
	|								ВтУпаковкаКомплектующие КАК ВтУпаковкаКомплектующие)) КАК РезервыТМЦОстаткиДрСклады
	|			ПО ОстаткиТМЦОстаткиДрСклады.Номенклатура = РезервыТМЦОстаткиДрСклады.Номенклатура
	|				И ОстаткиТМЦОстаткиДрСклады.Склад = РезервыТМЦОстаткиДрСклады.Склад
	|		ПО ВтУпаковкаКомплектующие.Комплектующее = ОстаткиТМЦОстаткиДрСклады.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтУпаковкаКомплектующие.Комплектующее
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТУпаковка.Номенклатура КАК Номенклатура,
	|	ВТУпаковка.Комплектующее КАК Комплектующее,
	|	ВТУпаковка.Количество КАК Количество,
	|	ВТУпаковка.КоличествоКомплектующих КАК КоличествоКомплектующих,
	|	ВТОстаткиОбщиеУпаковка.ОстатокОбщий КАК ОстатокОбщий
	|ИЗ
	|	ВТУпаковка КАК ВТУпаковка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОстаткиОбщиеУпаковка КАК ВТОстаткиОбщиеУпаковка
	|		ПО ВТУпаковка.Комплектующее = ВТОстаткиОбщиеУпаковка.Комплектующее";
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДатаСеанса()); 
	Запрос.УстановитьПараметр("ВсеСклады",МассивВсеСклады);
	Запрос.УстановитьПараметр("Упаковка",Объект.Упаковка.Выгрузить());
	
	
	Объект.Упаковка.Загрузить(Запрос.Выполнить().Выгрузить()); 
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 

