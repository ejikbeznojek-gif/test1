	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДатаСеанса()); 
	Запрос.УстановитьПараметр("ВсеСклады",МассивВсеСклады);
	Запрос.УстановитьПараметр("СкладыБезМарок",МассивСкладыБезМарок);
	Запрос.УстановитьПараметр("СкладБезМарок",Объект.СкладБезМарок); 
	Запрос.УстановитьПараметр("Спайки",Объект.Спайки.Выгрузить());
	Запрос.УстановитьПараметр("Упаковка",Объект.Упаковка.Выгрузить());
	
	Запрос.УстановитьПараметр("Контрагент", Объект.НакладнаяИсточник.Контрагент);
	Запрос.УстановитьПараметр("ПостояннаяАкция", Объект.НакладнаяИсточник.ПостояннаяАкция);
	Запрос.УстановитьПараметр("Организация", Константы.ОсновнаяОрганизацияУправленческогоУчета.Получить());
	
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ОстаткиКомплектБезМарок = ПакетРезультатов[8].Выгрузить();
	//ОстаткиУпаковокБезМарок = ПакетРезультатов[11].Выгрузить();
	МассивСпаек = ПакетРезультатов[14].Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
	
	ТаблицаСпаекБезМарок = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(ОстаткиКомплектБезМарок,ложь,МассивСпаек, истина); 
	Объект.БезМарок.Загрузить(ТаблицаСпаекБезМарок); 
	
	//по упаковкам расчитываем и сразу нужно переместить?? 
	ТаблицаСпаекБезМарокКопия =  ТаблицаСпаекБезМарок; 
	ТаблицаСпаекБезМарокКопия.Свернуть("Номенклатура,Количество");
	
	запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	
	//СКЛАД ОТГРУЗКИ Склад без марок 
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТоварыБезМарок
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТТоварыБезМарок.Номенклатура КАК Номенклатура,
	|	ВТТоварыБезМарок.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТоварыБезМарокРазличные
	|ИЗ
	|	ВТТоварыБезМарок КАК ВТТоварыБезМарок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТУпаковкиДляБезМарокОстатки.Номенклатура КАК Номенклатура,
	|	ВТУпаковкиДляБезМарокОстатки.Комплектующее КАК Комплектующее,
	|	ВтТовары.Количество КАК Количество,
	|	ВтТовары.Количество КАК КоличествоКомплектующих,
	|	ВТУпаковкиДляБезМарокОстатки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
	|	ВТУпаковкиДляБезМарокОстатки.Остаток КАК Остаток,
	|	&СкладБезМарок КАК СкладОтгрузки,
	|	0 КАК НужноПереместить
	|ИЗ
	|	ВТТоварыБезМарокРазличные КАК ВтТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУпаковкиДляБезМарокОстатки КАК ВТУпаковкиДляБезМарокОстатки
	|		ПО (ВТУпаковкиДляБезМарокОстатки.Номенклатура = ВтТовары.Номенклатура)
	|ГДЕ
	|	ВТУпаковкиДляБезМарокОстатки.Остаток + ВТУпаковкиДляБезМарокОстатки.ОстатокБазовыйСклад >= ВтТовары.Количество
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТУпаковкиДляБезМарокОстатки.Номенклатура КАК Номенклатура,
	|	ВТУпаковкиДляБезМарокОстатки.Комплектующее КАК Комплектующее,
	|	ВтТовары.Количество КАК Количество,
	|	ВтТовары.Количество КАК КоличествоКомплектующих,
	|	ВТУпаковкиДляБезМарокОстатки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
	|	ВТУпаковкиДляБезМарокОстатки.Остаток КАК Остаток,
	|	&СкладБезМарок КАК СкладОтгрузки,
	|	0 КАК НужноПереместить
	|ИЗ
	|	ВТТоварыБезМарокРазличные КАК ВтТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУпаковкиДляБезМарокОстатки КАК ВТУпаковкиДляБезМарокОстатки
	|		ПО (ВТУпаковкиДляБезМарокОстатки.Номенклатура = ВтТовары.Номенклатура)
	|ГДЕ
	|	ВТУпаковкиДляБезМарокОстатки.Остаток + ВТУпаковкиДляБезМарокОстатки.ОстатокБазовыйСклад < ВтТовары.Количество"; 
	
	Запрос.УстановитьПараметр("СкладБезМарок",Объект.СкладБезМарок);
	Запрос.УстановитьПараметр("Товары",ТаблицаСпаекБезМарокКопия); 
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	
	//здесь хватает, но нужно пересчитать 
	ТЧУпаковкиХватает = ПакетЗапросов[2].Выгрузить(); 
	ТЧУпаковкиХватает.Колонки.Добавить("НеХватает");
	
	ТЧУпаковкиХватаетКопия = ТЧУпаковкиХватает.Скопировать();
	
	КорректировкаОстатковСпайкиПоУпаковкам(ТЧУпаковкиХватает, ТЧУпаковкиХватаетКопия);

	//здесь точно не хватает, поэтому сразу в таблицу нехватки 
	ВыборкаУпаковкиНеХватает = ПакетЗапросов[3].Выбрать(); 
	
	Пока ВыборкаУпаковкиНеХватает.Следующий() Цикл
		
		НоваяСтрНеХватает = Объект.СпайкиБезУпаковки.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрНеХватает,ВыборкаУпаковкиНеХватает); 
		
		ОтборПродукция = Новый Структура("Номенклатура",ВыборкаУпаковкиНеХватает.Номенклатура); 
		СтрокиБезМарок = Объект.БезМарок.НайтиСтроки(ОтборПродукция);
		Для каждого СтрокаБезМарок Из СтрокиБезМарок Цикл
			
			СтрокаБезМарок.БезУпаковки = истина; 	
			
		КонецЦикла;
	КонецЦикла; 
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;

КонецПроцедуры

&НаСервере
Процедура КорректировкаОстатковСпайкиПоУпаковкам(Знач ТЧУпаковкиХватает, Знач ТЧУпаковкиХватаетКопия)
	
	Для каждого  Стр ИЗ ТЧУпаковкиХватает  Цикл 	
		
		Стр.НеХватает = Ложь;
		
		ОтборПоиск = Новый Структура("Комплектующее",Стр.Комплектующее); 
		СтрокиПоиск = ТЧУпаковкиХватаетКопия.НайтиСтроки(ОтборПоиск);
		//возьмем первую строку
		СтрокаДляРасчета = СтрокиПоиск[0];
		
		//общий остаток необходимо уменьшать и по нему еще определять хватает ли остатков
		СтрокиТЧУпаковки = Объект.Упаковка.НайтиСтроки(ОтборПоиск); 
		СтрокаТЧУпаковки = СтрокиТЧУпаковки[0];
		
		
		Если Стр.КоличествоКомплектующих > СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток
			ИЛИ Стр.КоличествоКомплектующих > СтрокаТЧУпаковки.ОстатокОбщий Тогда  		
			//Стр.НужноПереместить = СтрокаДляРасчета.Остаток;
			
			//СтрокаДляРасчета.ОстатокБазовыйСклад = 0;
			//СтрокаДляРасчета.Остаток = 0;
			Стр.НеХватает = Истина; 
			
		ИначеЕсли Стр.КоличествоКомплектующих <= СтрокаДляРасчета.ОстатокБазовыйСклад Тогда
			Стр.НужноПереместить = 0;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад  = СтрокаДляРасчета.ОстатокБазовыйСклад - Стр.КоличествоКомплектующих; 
			
			СтрокаТЧУпаковки.ОстатокОбщий = СтрокаТЧУпаковки.ОстатокОбщий - Стр.КоличествоКомплектующих; 
			
		ИначеЕсли Стр.КоличествоКомплектующих > СтрокаДляРасчета.ОстатокБазовыйСклад 
			И Стр.КоличествоКомплектующих <= СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток Тогда
			
			Стр.НужноПереместить = Стр.КоличествоКомплектующих - СтрокаДляРасчета.ОстатокБазовыйСклад;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0; 
			СтрокаДляРасчета.остаток = СтрокаДляРасчета.остаток - Стр.НужноПереместить; 
			
			СтрокаТЧУпаковки.ОстатокОбщий = СтрокаТЧУпаковки.ОстатокОбщий - Стр.ОстатокБазовыйСклад - Стр.НужноПереместить;
		КонецЕсли;
		
		Для каждого СтрокаПоиск Из СтрокиПоиск Цикл
			
			СтрокаПоиск.ОстатокБазовыйСклад = СтрокаДляРасчета.ОстатокБазовыйСклад; 
			СтрокаПоиск.Остаток = СтрокаДляРасчета.Остаток; 
			
		КонецЦикла;
		
		Для каждого СтрокаТЧУпаковкиСтр Из СтрокиТЧУпаковки Цикл
		
			СтрокаТЧУпаковкиСтр.ОстатокОбщий = СтрокаТЧУпаковки.ОстатокОбщий; 	
		
		КонецЦикла;
	КонецЦикла;
	
	//в первый раз склад отгрузки должен быть пустой 
	Для каждого СтрокаТЧУпаковки Из ТЧУпаковкиХватает Цикл 
		
		Если СтрокаТЧУпаковки.НеХватает Тогда
			
			НоваяСтрНеХватает = Объект.СпайкиБезУпаковки.Добавить(); 
			ЗаполнитьЗначенияСвойств(НоваяСтрНеХватает,СтрокаТЧУпаковки);
			
		Иначе
			ОтборУпаковка = Новый Структура("Номенклатура,Комплектующее,СкладОтгрузки",);
			ЗаполнитьЗначенияСвойств(ОтборУпаковка,СтрокаТЧУпаковки); 
			ОтборУпаковка.СкладОтгрузки = Справочники.Склады.ПустаяСсылка(); 
			
			СтрокиУпаковки = Объект.Упаковка.НайтиСтроки(ОтборУпаковка);
			Если СтрокиУпаковки.Количество() > 0 Тогда
				
				Для каждого СтрокаУпаковки  Из СтрокиУпаковки Цикл
					
					ЗаполнитьЗначенияСвойств(СтрокаУпаковки,СтрокаТЧУпаковки); 	
					
				КонецЦикла;
			Иначе 
				
				ОтборУпаковка = Новый Структура("Комплектующее",СтрокаТЧУпаковки.Комплектующее);
				СтрокиУпаковки = Объект.Упаковка.НайтиСтроки(ОтборУпаковка);
				ОстатокОбщий = 0; 
				Если СтрокиУпаковки.Количество() > 0 Тогда
					ОстатокОбщий = СтрокиУпаковки[0].ОстатокОбщий; 
				Иначе 
					ОстатокОбщий = СтрокаТЧУпаковки.ОстатокБазовыйСклад + СтрокаТЧУпаковки.Остаток
				КонецЕсли;  
				
				НоваяСтрХватает = Объект.Упаковка.Добавить(); 
				ЗаполнитьЗначенияСвойств(НоваяСтрХватает,СтрокаТЧУпаковки);
				
				НоваяСтрХватает.ОстатокОбщий = ОстатокОбщий; 
			КонецЕсли;
 	
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура РасчетОстатковСпайкиГотовыеСпайки(Запрос, МенеджерВременныхТаблиц)
	
	
	///////////////////////////////////////////////////
	//готовые спайки 
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	//Данилова Е.В. 26.12.2025 SNL-92 
	"ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВтОстаткиГотовыеСпайки
	|ИЗ
	|	ВТТоварыДляОтработки КАК ВТТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад = &СкладМаркировка
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТовары.Номенклатура
	|						ИЗ
	|							ВТТоварыДляОтработки КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад = &СкладМаркировка
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТовары.Номенклатура
	|							ИЗ
	|								ВТТоварыДляОтработки КАК ВТТовары)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ПО ВТТовары.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМинимальныеКоличества КАК ВТМинимальныеКоличества
	|		ПО (ВТМинимальныеКоличества.ВидНоменклатуры = ВТТовары.Номенклатура.Родитель.ФР_ВидНоменклатуры)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ > 0
	|	И ВЫБОР
	|			КОГДА ВТМинимальныеКоличества.ВидНоменклатуры ЕСТЬ NULL
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|							КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|								ТОГДА 0
	|							ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|						КОНЕЦ < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|							КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|								ТОГДА 0
	|							ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|						КОНЕЦ
	|				КОНЕЦ >= ВТМинимальныеКоличества.МинКоличество
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиГотовыхСпаекДОП
	|ИЗ
	|	ВТТоварыДляОтработки КАК ВТТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&ДопСкладыМаркировки)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТовары.Номенклатура
	|						ИЗ
	|							ВТТоварыДляОтработки КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&ДопСкладыМаркировки)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТовары.Номенклатура
	|							ИЗ
	|								ВТТоварыДляОтработки КАК ВТТовары)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ПО ВТТовары.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМинимальныеКоличества КАК ВТМинимальныеКоличества
	|		ПО (ВТМинимальныеКоличества.ВидНоменклатуры = ВТТовары.Номенклатура.Родитель.ФР_ВидНоменклатуры)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ > 0
	|	И ВЫБОР
	|			КОГДА ВТМинимальныеКоличества.ВидНоменклатуры ЕСТЬ NULL
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|							КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|								ТОГДА 0
	|							ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|						КОНЕЦ < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|							КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|								ТОГДА 0
	|							ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|						КОНЕЦ
	|				КОНЕЦ >= ВТМинимальныеКоличества.МинКоличество
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВтГотовыеСпайки.Номенклатура, ВТОстаткиГотовыхСпаекДОП.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ВтГотовыеСпайки.Количество, ВТОстаткиГотовыхСпаекДОП.Количество) КАК Количество,
	|	ЕСТЬNULL(ВтГотовыеСпайки.Остаток, 0) + ЕСТЬNULL(ВТОстаткиГотовыхСпаекДОП.Остаток, 0) КАК Остаток,
	|	ЕСТЬNULL(ВтГотовыеСпайки.Остаток, 0) КАК ОстатокБазовый,
	|	ЕСТЬNULL(ВТОстаткиГотовыхСпаекДОП.Остаток, 0) КАК ОстатокДОП
	|ПОМЕСТИТЬ ВтГотовыеСпайки
	|ИЗ
	|	ВтОстаткиГотовыеСпайки КАК ВтГотовыеСпайки
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТОстаткиГотовыхСпаекДОП КАК ВТОстаткиГотовыхСпаекДОП
	|		ПО ВтГотовыеСпайки.Номенклатура = ВТОстаткиГотовыхСпаекДОП.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтГотовыеСпайки.Номенклатура КАК Номенклатура,
	|	ВтГотовыеСпайки.Количество КАК Количество,
	|	ВтГотовыеСпайки.ОстатокБазовый КАК ОстатокБазовыйСклад,
	|	ВтГотовыеСпайки.ОстатокДОП КАК ОстатокДОП,
	|	ВЫБОР
	|		КОГДА ВтГотовыеСпайки.Количество <= ВтГотовыеСпайки.ОстатокБазовый
	|			ТОГДА 0
	|		КОГДА ВтГотовыеСпайки.Количество > ВтГотовыеСпайки.ОстатокБазовый + ВтГотовыеСпайки.ОстатокДОП
	|			ТОГДА ВтГотовыеСпайки.ОстатокДОП
	|		ИНАЧЕ ВтГотовыеСпайки.Количество - ВтГотовыеСпайки.ОстатокБазовый
	|	КОНЕЦ КАК НужноПереместить
	|ИЗ
	|	ВтГотовыеСпайки КАК ВтГотовыеСпайки";
	
	Запрос.УстановитьПараметр("СкладМаркировка", Объект.СкладМаркировки);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	//++Данилова Е.В. 26.12.2025 SNL-92 
	СкладыДоп = ДопСкладыПоГотовымСпайкам(); 
	Запрос.УстановитьПараметр("ДопСкладыМаркировки",СкладыДоп.выгрузитьКолонку("Склад")); 
	//--Данилова Е.В. 26.12.2025 
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НоваяСтрока = Объект.ГотовыеСпайки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
		//++Данилова Е.В. 26.12.2025 SNL-92
		НоваяСтрока.Остаток = ВыборкаДетальныеЗаписи.ОстатокДОП;		
		//--Данилова Е.В. 26.12.2025 
		
	КонецЦикла;
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;

КонецПроцедуры
