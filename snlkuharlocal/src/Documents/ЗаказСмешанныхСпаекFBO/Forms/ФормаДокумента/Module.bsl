//   <Тип.Вид>   - <описание возвращаемого значения>
//
&НаСервере
Функция РазделитьРНКПоКомплектующим(Знач РНК,Комментарий)
	
	МассивРНК = Новый Массив;   
	
	КоличествоКомплектующих = РНК.Комплектующие.Итог("Количество");
	
	
	Если КоличествоКомплектующих > 10000 Тогда
		
		
		МассивНеКонвертировать = Новый Массив;
		МассивНеКонвертировать.Добавить("ДокОснование");
		МассивНеКонвертировать.Добавить("ДокументОснование");
		МассивНеКонвертировать.Добавить("Основание");
		
		ДополнительныеРеквизитыРНК = Документы.ЗаказСмешанныхСпаекFBO.КонвертироватьОбъектВСтруктуру(Объект.НакладнаяИсточник, Истина, Ложь, МассивНеКонвертировать);
		ДополнительныеРеквизитыРНК.Вставить("ДатаОтгрузки", Дата(1,1,1));
		ДополнительныеРеквизитыРНК.Вставить("Дата", ТекущаяДатаСеанса());
		
		ДополнительныеРеквизитыРНК.Вставить("НеЗаписыватьДокумент",истина);
		ДополнительныеРеквизитыРНК.Вставить("Склад",РНК.Склад);
		ДополнительныеРеквизитыРНК.Вставить("Автор",ПараметрыСеанса.Пользователь);
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
		|	ВЫРАЗИТЬ(РасходнаяНакладнаяКомплектующие.Количество КАК ЧИСЛО(15, 0)) КАК Количество,
		|	РасходнаяНакладнаяКомплектующие.Единица КАК Единица,
		|	РасходнаяНакладнаяКомплектующие.Коэффициент КАК Коэффициент,
		|	РасходнаяНакладнаяКомплектующие.ЦенаБезСкидки КАК ЦенаБезСкидки,
		|	РасходнаяНакладнаяКомплектующие.Цена КАК Цена,
		|	РасходнаяНакладнаяКомплектующие.Сумма КАК Сумма,
		|	РасходнаяНакладнаяКомплектующие.СтавкаНДС КАК СтавкаНДС,
		|	РасходнаяНакладнаяКомплектующие.НДС КАК НДС,
		|	РасходнаяНакладнаяКомплектующие.Всего КАК Всего,
		|	РасходнаяНакладнаяКомплектующие.ВсегоБезСкидки КАК ВсегоБезСкидки,
		|	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
		|	ВЫРАЗИТЬ(РасходнаяНакладнаяКомплектующие.КоличествоПродукции КАК ЧИСЛО(15, 2)) КАК КоличествоПродукции,
		|	РасходнаяНакладнаяКомплектующие.ВидКомплектации КАК ВидКомплектации,
		|	РасходнаяНакладнаяКомплектующие.КоличествоКомплектующих КАК КоличествоКомплектующих,
		|	РасходнаяНакладнаяКомплектующие.ТребуетсяМаркировка КАК ТребуетсяМаркировка
		|ПОМЕСТИТЬ ВТКомплектующие
		|ИЗ
		|	&Комплектующие КАК РасходнаяНакладнаяКомплектующие
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.номенклатура КАК номенклатура,
		|	ВЫРАЗИТЬ(ВТТовары.Количество КАК ЧИСЛО(15, 0)) КАК Количество
		|ПОМЕСТИТЬ ВТПродукция
		|ИЗ
		|	&Товары КАК ВТТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТКомплектующие.Номенклатура КАК Номенклатура,
		|	ВТКомплектующие.Количество КАК Количество,
		|	ВТКомплектующие.Единица КАК Единица,
		|	ВТКомплектующие.Коэффициент КАК Коэффициент,
		|	ВТКомплектующие.ЦенаБезСкидки КАК ЦенаБезСкидки,
		|	ВТКомплектующие.Цена КАК Цена,
		|	ВТКомплектующие.Сумма КАК Сумма,
		|	ВТКомплектующие.СтавкаНДС КАК СтавкаНДС,
		|	ВТКомплектующие.НДС КАК НДС,
		|	ВТКомплектующие.Всего КАК Всего,
		|	ВТКомплектующие.ВсегоБезСкидки КАК ВсегоБезСкидки,
		|	ВТКомплектующие.Продукция КАК Продукция,
		|	ВТКомплектующие.ВидКомплектации КАК ВидКомплектации,
		|	ВТКомплектующие.КоличествоКомплектующих КАК КоличествоКомплектующих,
		|	ВТКомплектующие.ТребуетсяМаркировка КАК ТребуетсяМаркировка,
		|	ВТПродукция.Количество КАК КоличествоПродукции
		|ИЗ
		|	ВТКомплектующие КАК ВТКомплектующие
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПродукция КАК ВТПродукция
		|		ПО (ВТПродукция.номенклатура = ВТКомплектующие.Продукция)
		|ИТОГИ
		|	СУММА(Количество),
		|	МАКСИМУМ(КоличествоПродукции)
		|ПО
		|	Продукция";
		Запрос.УстановитьПараметр("Комплектующие",РНК.Комплектующие.Выгрузить());
		Запрос.УстановитьПараметр("Товары",РНК.Товары.Выгрузить());
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаПродукция = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		МассивТоваров = Новый Массив; 
		
		КоличествоКомплект = 0; 
		ТаблицаТоваров = Новый ТаблицаЗначений; 
		ТаблицаТоваров.Колонки.Добавить("Номенклатура");
		ТаблицаТоваров.Колонки.Добавить("Количество");
		
		Пока ВыборкаПродукция.Следующий() Цикл
			
			КоличествоКомлплектующих =  ВыборкаПродукция.Количество; 
			КоличествоПродукции = ВыборкаПродукция.КоличествоПродукции; 
			
			Если КоличествоКомплект + КоличествоКомлплектующих > 10000 Тогда 
				
				МассивТоваров.Добавить(ТаблицаТоваров); 
				
				ТаблицаТоваров = Новый ТаблицаЗначений; 
				ТаблицаТоваров.Колонки.Добавить("Номенклатура");
				ТаблицаТоваров.Колонки.Добавить("Количество");
				
				КоличествоКомплект = 0; 
				
			КонецЕсли; 
			
			КоличествоКомплект = КоличествоКомплект + КоличествоКомлплектующих; 
			
			НоваяСтрокаТЧ = ТаблицаТоваров.Добавить(); 
			НоваяСтрокаТЧ.Номенклатура = ВыборкаПродукция.Продукция; 
			НоваяСтрокаТЧ.Количество = КоличествоПродукции; 
			
			//ВыборкаДетальныеЗаписи = ВыборкаПродукция.Выбрать();
			
			//Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			//	 
			//КонецЦикла;
		КонецЦикла;
		
		МассивТоваров.Добавить(ТаблицаТоваров);
		
		Для каждого ТЧРНК Из МассивТоваров Цикл
			
			РНКСозданный = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, ТЧРНК,
			ДополнительныеРеквизитыРНК,, Комментарий, Истина, Истина, Истина,Ложь);	
			
			Если РНКСозданный <> Неопределено Тогда
			
				МассивРНК.Добавить(РНКСозданный); 	
			
			КонецЕсли;
		КонецЦикла;
		
		Возврат МассивРНК; 
		
	Иначе 
		МассивРНК.Добавить(РНК);
		Возврат МассивРНК; 
	КонецЕсли;

КонецФункции // РазделитьРНКПоКолмплектующим()

&НаСервере
Процедура РасчетОстатковШтукиСМаркировкой(Запрос, МассивСкладыСМарками, МенеджерВременныхТаблиц)
	
	//////////////////////////////////////////////////////////
	//Склады с маркировкой  
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	МАКСИМУМ(Матрица.Ссылка) КАК Матрица
	|ПОМЕСТИТЬ ВТМатрица
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица КАК Матрица
	|		ПО МатрицаПунктыДоставки.Ссылка = Матрица.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИнетМагазины КАК ИнетМагазиныСпр
	|		ПО (НЕ ИнетМагазиныСпр.ПометкаУдаления)
	|			И (ИнетМагазиныСпр.Контрагент = &Контрагент)
	|			И (ИнетМагазиныСпр.Организация = &Организация)
	|			И (ИнетМагазиныСпр.ПунктДоставки = МатрицаПунктыДоставки.ПунктДоставки)
	|ГДЕ
	|	Матрица.Проведен
	|	И Матрица.Дата <= &ТекущаяДата
	|	И Матрица.ДатаОкончания >= &ТекущаяДата
	|	И Матрица.Контрагент = &Контрагент
	|	И НЕ Матрица.Акция
	|	И Матрица.ПостояннаяАкция = &ПостояннаяАкция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.МинимальноеКоличество КАК МинимальноеКоличество
	|ПОМЕСТИТЬ ВтМинимальныеКоличестваFBS
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМатрица КАК ВТМатрица
	|		ПО МатрицаТовары.Ссылка = ВТМатрица.Матрица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ПО (ВТТоварыДляОтработки.Номенклатура = МатрицаТовары.Номенклатура)
	|ГДЕ
	|	МатрицаТовары.МинимальноеКоличество <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляОтработки.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиБазовыйСклад
	|ИЗ
	|	ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад = &СкладМаркировки
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТоварыДляОтработки.Номенклатура
	|						ИЗ
	|							ВТТоварыДляОтработки КАК ВТТоварыДляОтработки)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад = &СкладМаркировки
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТоварыДляОтработки.Номенклатура
	|							ИЗ
	|								ВТТоварыДляОтработки КАК ВТТоварыДляОтработки)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО ВТТоварыДляОтработки.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляОтработки.Номенклатура КАК Номенклатура,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиНаДрСкладахНЕFBS
	|ИЗ
	|	ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&СкладыМаркировки)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТоварыДляОтработки.Номенклатура
	|						ИЗ
	|							ВТТоварыДляОтработки КАК ВТТоварыДляОтработки)
	|					И НЕ Склад.ЭтоСкладFBS) КАК ОстаткиТМЦОстаткиДрСкладыНеFBS
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&СкладыМаркировки)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТоварыДляОтработки.Номенклатура
	|							ИЗ
	|								ВТТоварыДляОтработки КАК ВТТоварыДляОтработки)
	|						И НЕ Склад.ЭтоСкладFBS) КАК РезервыТМЦОстаткиДрСкладыНеFBS
	|			ПО ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура = РезервыТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|				И ОстаткиТМЦОстаткиДрСкладыНеFBS.Склад = РезервыТМЦОстаткиДрСкладыНеFBS.Склад
	|		ПО ВТТоварыДляОтработки.Номенклатура = ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
