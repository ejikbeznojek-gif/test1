КонецПроцедуры

&НаСервере
Процедура РасчетОстатковШтукиБезмарок(Запрос, МассивСкладыБезМарок, МенеджерВременныхТаблиц)
	
	///////////////////////////////////////////////////////////
	//Без марок 
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ВТТоварыДляОтработки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВТТоварыДляОтработки.Номенклатура КАК Комплектующее,
	|	ВТТоварыДляОтработки.Количество - ЕСТЬNULL(ВТТоварыСМаркировкой.Количество, 0) - ЕСТЬNULL(ВТТоварыНекорректныеМаркиКонечная.Количество, 0) КАК Количество,
	|	ВТТоварыДляОтработки.Количество - ЕСТЬNULL(ВТТоварыСМаркировкой.Количество, 0) - ЕСТЬNULL(ВТТоварыНекорректныеМаркиКонечная.Количество, 0) КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ ВТТоварыДляБезмарок
	|ИЗ
	|	ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыСМаркировкой КАК ВТТоварыСМаркировкой
	|		ПО (ВТТоварыСМаркировкой.Номенклатура = ВТТоварыДляОтработки.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыНекорректныеМаркиКонечная КАК ВТТоварыНекорректныеМаркиКонечная
	|		ПО (ВТТоварыНекорректныеМаркиКонечная.Номенклатура = ВТТоварыДляОтработки.Номенклатура)
	|ГДЕ
	|	ВТТоварыДляОтработки.Количество - ЕСТЬNULL(ВТТоварыСМаркировкой.Количество, 0) - ЕСТЬNULL(ВТТоварыНекорректныеМаркиКонечная.Количество, 0) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляБезмарок.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиБазовыйСкладБезмарок
	|ИЗ
	|	ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад = &СкладБезМарок
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТоварыДляБезмарок.Номенклатура
	|						ИЗ
	|							ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад = &СкладБезМарок
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТоварыДляБезмарок.Номенклатура
	|							ИЗ
	|								ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляБезмарок.Номенклатура КАК Номенклатура,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиНаДрСкладахНЕFBSБезмарок
	|ИЗ
	|	ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&СкладыБезМарок)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТоварыДляБезмарок.Номенклатура
	|						ИЗ
	|							ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)
	|					И НЕ Склад.ЭтоСкладFBS) КАК ОстаткиТМЦОстаткиДрСкладыНеFBS
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&СкладыБезМарок)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТоварыДляБезмарок.Номенклатура
	|							ИЗ
	|								ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)
	|						И НЕ Склад.ЭтоСкладFBS) КАК РезервыТМЦОстаткиДрСкладыНеFBS
	|			ПО ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура = РезервыТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|				И ОстаткиТМЦОстаткиДрСкладыНеFBS.Склад = РезервыТМЦОстаткиДрСкладыНеFBS.Склад
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ОстаткиТМЦОстаткиДрСкладыНеFBS.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТТоварыДляБезмарок.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляБезмарок.Номенклатура КАК Номенклатура,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиНаДрСкладахFBSБезмарок
	|ИЗ
	|	ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад В (&СкладыБезМарок)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТТоварыДляБезмарок.Номенклатура
	|						ИЗ
	|							ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)
	|					И Склад.ЭтоСкладFBS) КАК ОстаткиТМЦОстаткиДрСкладыFBS
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад В (&СкладыБезМарок)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТТоварыДляБезмарок.Номенклатура
	|							ИЗ
	|								ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок)
	|						И Склад.ЭтоСкладFBS) КАК РезервыТМЦОстаткиДрСкладыFBS
	|			ПО ОстаткиТМЦОстаткиДрСкладыFBS.Номенклатура = РезервыТМЦОстаткиДрСкладыFBS.Номенклатура
	|				И ОстаткиТМЦОстаткиДрСкладыFBS.Склад = РезервыТМЦОстаткиДрСкладыFBS.Склад
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ОстаткиТМЦОстаткиДрСкладыFBS.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТТоварыДляБезмарок.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыДляБезмарок.Номенклатура КАК Номенклатура,
	|	ВТТоварыДляБезмарок.Комплектующее КАК Комплектующее,
	|	ВТТоварыДляБезмарок.Количество КАК Количество,
	|	ВТТоварыДляБезмарок.КоличествоКомплектующих КАК КоличествоКомплектующих,
	|	ЕСТЬNULL(ВТОстаткиБазовыйСклад.Остаток, 0) КАК ОстатокБазовыйСклад,
	|	ЕСТЬNULL(ВТОстаткиНаДрСкладахНЕFBS.Остаток, 0) + ВЫБОР
	|		КОГДА ВтМинимальныеКоличестваFBS.Номенклатура ЕСТЬ NULL
	|			ТОГДА ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0)
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0) < ЕСТЬNULL(ВтМинимальныеКоличестваFBS.МинимальноеКоличество, 0)
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0) - ЕСТЬNULL(ВтМинимальныеКоличестваFBS.МинимальноеКоличество, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК ОстатокНаДрСкладах,
	|	ВТМинимальныеКоличества.МинКоличество КАК МинКоличествоПродукции
	|ПОМЕСТИТЬ ВТТоварыБезмарок
	|ИЗ
	|	ВТТоварыДляБезмарок КАК ВТТоварыДляБезмарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиБазовыйСкладБезмарок КАК ВТОстаткиБазовыйСклад
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ВТОстаткиБазовыйСклад.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиНаДрСкладахНЕFBSБезмарок КАК ВТОстаткиНаДрСкладахНЕFBS
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ВТОстаткиНаДрСкладахНЕFBS.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиНаДрСкладахFBSБезмарок КАК ВТОстаткиНаДрСкладахFBS
	|		ПО ВТТоварыДляБезмарок.Номенклатура = ВТОстаткиНаДрСкладахFBS.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМинимальныеКоличества КАК ВТМинимальныеКоличества
	|		ПО (ВТМинимальныеКоличества.ВидНоменклатуры = ВТТоварыДляБезмарок.Номенклатура.Родитель.ФР_ВидНоменклатуры)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтМинимальныеКоличестваFBS КАК ВтМинимальныеКоличестваFBS
	|		ПО (ВтМинимальныеКоличестваFBS.Номенклатура = ВТТоварыДляБезмарок.Номенклатура)
	|ГДЕ
	|	ЕСТЬNULL(ВТОстаткиБазовыйСклад.Остаток, 0) + ЕСТЬNULL(ВТОстаткиНаДрСкладахНЕFBS.Остаток, 0) + ВЫБОР
	|			КОГДА ВтМинимальныеКоличестваFBS.Номенклатура ЕСТЬ NULL
	|				ТОГДА ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0)
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0) < ЕСТЬNULL(ВтМинимальныеКоличестваFBS.МинимальноеКоличество, 0)
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(ВТОстаткиНаДрСкладахFBS.Остаток, 0) - ЕСТЬNULL(ВтМинимальныеКоличестваFBS.МинимальноеКоличество, 0)
	|				КОНЕЦ
	|		КОНЕЦ > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыБезмарок.Номенклатура КАК Номенклатура,
	|	ВТТоварыБезмарок.Комплектующее КАК Комплектующее,
	|	ВТТоварыБезмарок.Количество КАК Количество,
	|	ВТТоварыБезмарок.КоличествоКомплектующих КАК КоличествоКомплектующих,
	|	ВТТоварыБезмарок.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
	|	ВТТоварыБезмарок.ОстатокНаДрСкладах КАК Остаток,
	|	ВТТоварыБезмарок.МинКоличествоПродукции КАК МинКоличествоПродукции,
	|	ВЫБОР
	|		КОГДА ВТТоварыБезмарок.МинКоличествоПродукции ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьМИН,
	|	0 КАК НужноПереместить
	|ИЗ
	|	ВТТоварыБезмарок КАК ВТТоварыБезмарок"; 
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДатаСеанса()); 
	//Запрос.УстановитьПараметр("ВсеСклады",МассивВсеСклады);
	Запрос.УстановитьПараметр("СкладыБезМарок",МассивСкладыБезМарок);
	Запрос.УстановитьПараметр("СкладБезМарок",Объект.СкладБезМарок);
	РезультатЗапроса = Запрос.Выполнить();
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ОстаткиКомплектБезмарок = РезультатЗапроса.Выгрузить();
	ОстаткиКомплектБезмарок.Колонки.Добавить("НеХватает"); 
	
	ОстаткиКомплектБезмарокКопия = ОстаткиКомплектБезмарок.Скопировать();
	
	КорректировкаОстатковШтукиПоСкладам(ОстаткиКомплектБезмарок,ОстаткиКомплектБезмарокКопия); 		 
	Объект.БезМарок.Загрузить(ОстаткиКомплектБезмарок);

КонецПроцедуры


