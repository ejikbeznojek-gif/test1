		Если тзБезМарок.Количество() > 0 Тогда
			
			РНК_Спайки_НемаркированныйТовар = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзБезМарок,
			ДополнительныеРеквизитыРНК,, "Без Марок", Истина, Истина, Истина, Ложь);
			
			Если РНК_Спайки_НемаркированныйТовар <> Неопределено Тогда
				//++Данилова Е.В. 13.11.2025 HELP-7698 
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_НемаркированныйТовар,"Без марок");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла;
				//Данилова Е.В. 17.10.2025 HELP-5978
				//МассивРНК.Добавить(РНК_Спайки_НемаркированныйТовар); 				
				//--Данилова Е.В. 13.11.2025
				//Если НЕ РНК_Спайки_НемаркированныйТовар.Проведен Тогда 			
				//	
				//	РНК_Объект = РНК_Спайки_НемаркированныйТовар.ПолучитьОбъект(); 
				//	Попытка
				//		РНК_Объект.Заблокировать();
				//	Исключение
				//		СообщитьИзМодуля("Не могу заблокировать " + Строка(РНК_Объект)); 			
				//	КонецПопытки;
				//	
				//	Попытка
				//		РНК_Объект.Проведен = Истина;
				//		РНК_Объект.ЗаписьБезКонтроляПолномочий();
				//		РНК_Объект.Разблокировать();
				//	Исключение
				//		СообщитьИзМодуля("Не могу провести " + Строка(РНК_Объект)); 		
				//		
				//	КонецПопытки;
				//	
				//	
				//КонецЕсли; 
				////--Данилова Е.В. 10.10.2025
				//НоваяСтрока = Объект.РасходныеНакладные.Добавить();
				//НоваяСтрока.НакладнаяПриемник = РНК_Спайки_НемаркированныйТовар;
			КонецЕсли; 
			//--Данилова Е.В. 17.10.2025
		КонецЕсли;
		
	КонецЕсли;
	//Данилова Е.В. 24.10.2025 HELP-7587
	//Если Объект.СМарками.Количество() > 0 Тогда
	Если Объект.СМарками.Количество() > 0 
		И НЕ Объект.ТолькоПоСмешанным Тогда
		
		ДополнительныеРеквизитыРНК.Вставить("Склад", Объект.СкладМаркировки);
		
		тзСМарками = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(Объект.СМарками.Выгрузить(), Объект.НакладнаяИсточник.Товары.Выгрузить());
		
		Если тзСМарками.Количество() > 0 Тогда
			
			РНК_Спайки_МаркированныйТовар = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Объект.НакладнаяИсточник, тзСМарками,
			ДополнительныеРеквизитыРНК,, "С Марками", Истина, Истина, Истина, Ложь);
			
			Если РНК_Спайки_МаркированныйТовар <> Неопределено Тогда
				//++Данилова Е.В. 13.11.2025 HELP-7698 
				МассивРНКНовые = РазделитьРНКПоКомплектующим(РНК_Спайки_МаркированныйТовар,"С марками");
				Для каждого НовыйРНК Из МассивРНКНовые Цикл
				
					МассивРНК.Добавить(НовыйРНК);	
				
				КонецЦикла;
