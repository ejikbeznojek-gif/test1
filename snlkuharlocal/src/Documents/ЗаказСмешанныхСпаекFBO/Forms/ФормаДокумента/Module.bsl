&НаСервере
Процедура ПроверитьОстаткиИВывестиОшибки(ТекстОшибки,РНКСсылка)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
		|	РасходнаяНакладнаяТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&ТЧТовары КАК РасходнаяНакладнаяТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	СУММА(ВТТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТТоварыГруппировка
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТоварыГруппировка.Номенклатура КАК Номенклатура,
		|	ВТТоварыГруппировка.Количество КАК Количество,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) КАК Остаток,
		|	ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Резерв,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
		|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) - ВТТоварыГруппировка.Количество КАК Разница
		|ИЗ
		|	ВТТоварыГруппировка КАК ВТТоварыГруппировка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
		|				&ДатаДокумента,
		|				Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТТовары.Номенклатура
		|						ИЗ
		|							ВТТоварыГруппировка КАК ВТТовары)
		|					И Склад = &Склад) КАК ОстаткиТМЦОстатки
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|					&ДатаДокумента,
		|					Номенклатура В
		|							(ВЫБРАТЬ
		|								ВТТовары.Номенклатура
		|							ИЗ
		|								ВТТоварыГруппировка КАК ВТТовары)
		|						И Склад = &Склад) КАК РезервыТМЦОстатки
		|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
		|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
		|		ПО ВТТоварыГруппировка.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
		|ГДЕ
		|	(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) < 0
		|			ИЛИ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
		|			ИЛИ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
		|			ИЛИ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) - ВТТоварыГруппировка.Количество < 0)";
	
	Запрос.УстановитьПараметр("ДатаДокумента", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Склад", РНКСсылка.Склад);
	Если РНКСсылка.ОтгрузкаКомплектов Тогда
		
		Запрос.УстановитьПараметр("ТЧТовары", РНКСсылка.Комплектующие.выгрузить());	
	Иначе
		Запрос.УстановитьПараметр("ТЧТовары", РНКСсылка.Товары.выгрузить());	
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Текстошибки = ""; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.Остаток < 0  Тогда 
			ТекстОшибки = ТекстОшибки + "По номенклатуре " + Строка(ВыборкаДетальныеЗаписи.Номенклатура) + " отрицательный остаток " + Строка(ВыборкаДетальныеЗаписи.Остаток) + Символы.ПС; 
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.Резерв < 0  Тогда	
			
			ТекстОшибки = ТекстОшибки + "По номенклатуре " + Строка(ВыборкаДетальныеЗаписи.Номенклатура) + " отрицательный резерв " + Строка(ВыборкаДетальныеЗаписи.Резерв) + Символы.ПС; 
			
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.СвободныйОстаток < 0  Тогда	
			
			ТекстОшибки = ТекстОшибки + "По номенклатуре " + Строка(ВыборкаДетальныеЗаписи.Номенклатура) + " отрицательный свободный остаток " + Строка(ВыборкаДетальныеЗаписи.СвободныйОстаток) + Символы.ПС; 
			
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.Разница < 0  Тогда	
			
			ТекстОшибки = ТекстОшибки + "По номенклатуре " + Строка(ВыборкаДетальныеЗаписи.Номенклатура) + " отрицательная разница по остаткам " + Строка(ВыборкаДетальныеЗаписи.Разница) + Символы.ПС; 
			
       	КонецЕсли;
		
	КонецЦикла; 


КонецПроцедуры // ПроверитьОстаткиИВывестиОшибки()

#КонецОбласти

