#Область ОбработкаВыбора

&НаКлиенте
Процедура НакладнаяИсточникОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	НакладнаяИсточникОбработкаВыбораНаКлиенте(ВыбранноеЗначение);

	
КонецПроцедуры

&НаКлиенте
Процедура НакладнаяИсточникОбработкаВыбораНаКлиенте(ВыбранноеЗначение)
	
	//Перем МассивМаркированныхСкладов, МассивНемаркированныхСкладов, тзКомплектующие, тзУпаковка;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		//++Данилова Е.В. 01.11.2025 HELP-7698 
		ЗаполнитьТоварыПоРНК(); 
		//--Данилова Е.В. 01.11.2025
		МассивНемаркированныхСкладов = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
		МассивНемаркированныхСкладов.Добавить(Объект.СкладБезМарок);
		
		МассивМаркированныхСкладов = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
		МассивМаркированныхСкладов.Добавить(Объект.СкладМаркировки);
		
		//Данилова Е.В. 01.11.2025  HELP-7698 
		Если Объект.РежимРасчета = 1 Тогда  //смешанные спайки
			
			тзКомплектующие = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьСпайки(ВыбранноеЗначение, МассивНемаркированныхСкладов, МассивМаркированныхСкладов);
			
			ЗагрузитьТЧ_НаСервере(тзКомплектующие, "Спайки");
			
			////////////////////////////// УПАКОВКА //////////////////////////////////////////////////////////
			
			тзУпаковка = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьУпаковку(ВыбранноеЗначение, МассивНемаркированныхСкладов, МассивМаркированныхСкладов);
			
			ЗагрузитьТЧ_НаСервере(тзУпаковка, "Упаковка");	
			
		ИначеЕсли Объект.РежимРасчета = 2 Тогда	//спайки 		
			
			тзКомплектующие = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьСпайкиБезПризнакаМаркировки(ВыбранноеЗначение);
			
			ЗагрузитьТЧ_НаСервере(тзКомплектующие, "Спайки");
			
			тзУпаковка = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьУпаковкуБезПризнакаМаркировки(ВыбранноеЗначение);
			
			ЗагрузитьТЧ_НаСервере(тзУпаковка, "Упаковка");
			
		ИначеЕсли Объект.РежимРасчета = 3 Тогда //штуки
			
		КонецЕсли;
		
		
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураВозврата = Документы.ЗаказСмешанныхСпаекFBO.ЗаполнитьНастройки();
	//++Данилова Е.В. 07.11.2025 HELP-7698 
	Если Параметры.Ключ.Пустая() 
		ИЛИ (НЕ Объект.РасчетОстатковВыполнен 
		И НЕ Объект.РасчетВыполнен) Тогда 
		Если НЕ ЗначениеЗаполнено(Объект.СкладБезМарок) Тогда
			Объект.СкладБезМарок = СтруктураВозврата.СкладБезМарок;	
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.СкладМаркировки) Тогда
			Объект.СкладМаркировки = СтруктураВозврата.СкладМаркировки;	
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.СкладСмешанныеСпайки) Тогда
			Объект.СкладСмешанныеСпайки = СтруктураВозврата.СкладСмешанныеСпайки;	
		КонецЕсли;
		//++Данилова Е.В. 01.11.2025 HELP-7698 
		Если НЕ ЗначениеЗаполнено(Объект.СкладНекоррМарок) Тогда
			Объект.СкладНекоррМарок = СтруктураВозврата.СкладНекоррМарок;	
		КонецЕсли;
		//--Данилова Е.В. 01.11.2025
		
		Если Объект.ДоступныеСкладыБезМарок.Количество() = 0 Тогда
			Если ТипЗнч(СтруктураВозврата.ДоступныеСкладыБезМарок) = Тип("Массив") Тогда 
				//++Данилова Е.В. 26.12.2025 SNL-92 
				Приоритет = 1; 
				//--Данилова Е.В. 26.12.2025 
				Для Каждого Элемент ИЗ СтруктураВозврата.ДоступныеСкладыБезМарок Цикл
					НоваяСтрока = Объект.ДоступныеСкладыБезМарок.Добавить();
					НоваяСтрока.СкладБезМарок = Элемент;
					//++Данилова Е.В. 26.12.2025 SNL-92 
					НоваяСтрока.Приоритет = Приоритет;
					Приоритет = Приоритет + 1; 
					//--Данилова Е.В. 26.12.2025
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		//Данилова Е.В. 06.02.2026 
		СкладыДляРасчетаСпаек = Документы.ЗаказСмешанныхСпаекFBO.СкладДляРасчетаСпаек();
		Если Объект.ДоступныеСкладыМаркировка.Количество() = 0 Тогда
			Если ТипЗнч(СтруктураВозврата.ДоступныеСкладыМаркировка) = Тип("Массив") Тогда
				//++Данилова Е.В. 26.12.2025 SNL-92 
				Приоритет = 1; 
				//--Данилова Е.В. 26.12.2025
				Для Каждого Элемент ИЗ СтруктураВозврата.ДоступныеСкладыМаркировка Цикл
					НоваяСтрока = Объект.ДоступныеСкладыМаркировка.Добавить();
					НоваяСтрока.СкладМаркировки = Элемент;
					//++Данилова Е.В. 26.12.2025 SNL-92 
					НоваяСтрока.Приоритет = Приоритет;
					//Данилова Е.В. 06.02.2026
					если СкладыДляРасчетаСпаек.Найти(НоваяСтрока.СкладМаркировки) <> Неопределено Тогда
					//Если НоваяСтрока.СкладМаркировки = Документы.ЗаказСмешанныхСпаекFBO.СкладДляРасчетаСпаек()  Тогда
						
						НоваяСтрока.РасчетПоГотовымСпайкам = Истина; 	
						
					КонецЕсли;
					Приоритет = Приоритет + 1;
					//--Данилова Е.В. 26.12.2025
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	//++Данилова Е.В. 24.10.2025 HELP-7587  
	УстановитьДоступность();
	УстановитьВидимость(); 
	//--Данилова Е.В. 24.10.2025
	
КонецПроцедуры

#КонецОбласти

#Область КлиентСервер

&НаСервере
Процедура ЗагрузитьТЧ_НаСервере(тзКомплектующие, ИмяТабличнойЧасти = "Спайки")
	Объект[ИмяТабличнойЧасти].Загрузить(тзКомплектующие);	
КонецПроцедуры

&НаСервере
Функция ВыгрузитьТЧ_НаСервере(ИмяТабличнойЧасти = "Спайки")
	Возврат Объект[ИмяТабличнойЧасти].Выгрузить(); 	
КонецФункции

&НаСервере
Функция ВыгрузитьМассив_НаСервере(ИмяТабличнойЧасти = "Спайки", ИмяРеквизита = "Комплектующее")
	Возврат Объект[ИмяТабличнойЧасти].Выгрузить().ВыгрузитьКолонку(ИмяРеквизита);
КонецФункции

&НаСервере
Функция Объединить2Массива_НаСервере(МассивИсточник, МассивПриемник)
	МассивВозврата = Новый Массив;
	Для Каждого Элемент ИЗ МассивИсточник Цикл
		МассивВозврата.Добавить(Элемент);	
	КонецЦикла;
	Для Каждого Элемент ИЗ МассивПриемник Цикл
		МассивВозврата.Добавить(Элемент);	
	КонецЦикла;
	Возврат МассивВозврата;
КонецФункции

#КонецОбласти

#Область Команды

&НаКлиенте
Процедура РассортироватьСпайкиПоГруппам(Команда)
	
	РассортироватьСпайкиПоГруппамНаКлиенте();

	
КонецПроцедуры

//++Данилова Е.В. 03.10.2025 HELP-5978
&НаКлиенте
Процедура РассортироватьСпайкиПоГруппамНаКлиенте()
	                                                	
	Если Объект.Спайки.Количество() = 0 Тогда
		Сообщить("Не заполнена ТЧ <Спайки>!!!");
		//Возврат;
	КонецЕсли;
	
	тзСпайки = ВыгрузитьТЧ_НаСервере("Спайки");
	РассортироватьСпайкиПоГруппамНаСервере(тзСпайки); 
	
	//++Данилова Е.В. 03.10.2025 HELP-5978
	Объект.РасчетОстатковВыполнен = Ложь; 
	//--Данилова Е.В. 03.10.2025
	
	ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));

КонецПроцедуры 
//--Данилова Е.В. 03.10.2025

&НаКлиенте
Процедура РассчитатьОстатки(Команда)
	//++Данилова Е.В. 01.11.2025 HELP-7698
	Если Объект.РежимРасчета = 1 Тогда
		
		РасчетОстатковСмешанныеСпайки();
		
	ИначеЕсли Объект.РежимРасчета = 2 Тогда 
		
		РасчетОстатковСпайки(); 
		
	Иначе
		
		РасчетОстатковШтуки();
		
	КонецЕсли;
	

	//--Данилова Е.В. 01.11.2025
КонецПроцедуры

&НаКлиенте
Процедура РасчетОстатковСмешанныеСпайки() 
	
	
	//++Данилова Е.В. 03.10.2025 HELP-5978
	РассортироватьСпайкиПоГруппамНаКлиенте();
	//--Данилова Е.В. 03.10.2025
	
	Если Объект.БезМарок.Количество() > 0 Тогда
		
		МассивОстатков = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
		
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстатки(ВыгрузитьТЧ_НаСервере("БезМарок"), МассивОстатков, Объект.СкладБезМарок); 		
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(тзОстатки);
		
		
		ЗагрузитьТЧ_НаСервере(тзОстатки, "БезМарок");
		
	КонецЕсли;
	
	Если Объект.СМарками.Количество() > 0 Тогда
		
		МассивОстатков = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
		
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстатки(ВыгрузитьТЧ_НаСервере("СМарками"), МассивОстатков, Объект.СкладМаркировки);
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(тзОстатки);
		
		ЗагрузитьТЧ_НаСервере(тзОстатки, "СМарками");
		
	КонецЕсли;
	
	Если Объект.СмешанныеСпайки.Количество() > 0 Тогда
		
		МассивИсточник = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
		МассивПриемник = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
		МассивОстатков = Объединить2Массива_НаСервере(МассивИсточник, МассивПриемник);
		
		МассивОстатков.Добавить(Объект.СкладБезМарок);
		МассивОстатков.Добавить(Объект.СкладМаркировки);
		
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстатки(ВыгрузитьТЧ_НаСервере("СмешанныеСпайки"), МассивОстатков, Объект.СкладСмешанныеСпайки); 
		//++Данилова Е.В. 23.10.2025 HELP-5978 
		//тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(тзОстатки);
		тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(тзОстатки,Истина);
		//--Данилова Е.В. 23.10.2025
		ЗагрузитьТЧ_НаСервере(тзОстатки, "СмешанныеСпайки");
		
	КонецЕсли;
	
	//++Данилова Е.В. 03.10.2025 HELP-5978
	Объект.РасчетОстатковВыполнен = Истина; 
	//--Данилова Е.В. 03.10.2025
	
	ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
	
	//++Данилова Е.В. 03.10.2025 HELP-5978	
	ЗаполнитьУпаковкуСервер();
	//--Данилова Е.В. 03.10.2025

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьУпаковку(Команда)
	ЗаполнитьУпаковкуСервер();
КонецПроцедуры

&НаКлиенте
Процедура КомандаВыполнить(Команда)
	//++Данилова Е.В. 03.10.2025  HELP-5978 
	Если  НЕ Объект.РасчетОстатковВыполнен Тогда
		
		Сообщить("Не выполнен расчет остатков!!!");
		
		Возврат;	
		
	КонецЕсли;
	//--Данилова Е.В. 03.10.2025
	Если Объект.Спайки.Количество() = 0 
		//++Данилова Е.В. 07.11.2025 HELP-7698
		И Объект.РежимРасчета <> 3 Тогда 
		//--Данилова Е.В. 07.11.2025
		Сообщить("Не заполнена ТЧ <Спайки>!!!");
		Возврат;
	КонецЕсли;
	//++Данилова Е.В. 05.11.2025 HELP-7698 
	//++Данилова Е.В. 19.12.2025  HELP-8280 
	Если РНКИсточникПомеченНаУдаление() Тогда
		
		Сообщить("Снимите пометку на удаление с накладной источника!");
		
		Возврат;	
		
	КонецЕсли;
	//--Данилова Е.В. 19.12.2025 
	МассивПРМОбъекты = Неопределено;
	МассивРНКОбъекты = Неопределено; 
	Если Объект.РежимРасчета = 1  Тогда
		
		Если НеЗаполненРеквизитВТЧ("Упаковка", "СкладОтгрузки") Тогда
			
			Для Каждого Стр ИЗ Объект.Упаковка Цикл
				Если НЕ ЗначениеЗаполнено(Стр.СкладОтгрузки) Тогда
					Сообщить("Оприходуйте упаковку " + Строка(Стр.Комплектующее) + " в количестве " + Строка(Стр.Количество));	
				КонецЕсли;
			КонецЦикла;
			Возврат;
			
		КонецЕсли; 	
		
		ВыполнитьРасчетПоСмешаннымСпайкам(МассивПРМОбъекты, МассивРНКОбъекты); 
		
	ИначеЕсли Объект.РежимРасчета = 2  Тогда
		
		Если Объект.СпайкиБезУпаковки.Количество() > 0  Тогда
			
			ОповещениеВопрос = Новый ОписаниеОповещения("ПослеВыполнитьРежимРасчетаСпайки",ЭтаФорма); 
			ПоказатьВопрос(ОповещениеВопрос,"Необходимо указать спайки для отгрузки без упаковки, продолжить выполнение?",РежимДиалогаВопрос.ОКОтмена);
			Возврат; 
		Иначе 
			ВыполнитьРасчетПоСпайкам(МассивПРМОбъекты, МассивРНКОбъекты);	
		КонецЕсли;
		
	ИначеЕсли Объект.РежимРасчета = 3  Тогда	
		
		ВыполнитьРасчетПоСпайкам(МассивПРМОбъекты, МассивРНКОбъекты);
		
	КонецЕсли;
	//--Данилова Е.В. 05.11.2025
	
	//Данилова Е.В. 24.10.2025 HELP-7587 
	//++Данилова Е.В. 17.10.2025  HELP-5978
	РезультатСозданияДокументов = Ложь; 
	ЗаписатьПровестиДокументыРНКПРМ(МассивПРМОбъекты, МассивРНКОбъекты,РезультатСозданияДокументов); 
	//--Данилова Е.В. 17.10.2025
	Если РезультатСозданияДокументов Тогда
		Объект.РасчетВыполнен = Истина; 
		ПометитьНаУдалениеНакладнуюИсточник();
		СоздатьЗаписьВРССтатусыМарок(); 
		ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
	Иначе 
		ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
	КонецЕсли;
	//ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
	
КонецПроцедуры 

//++Данилова Е.В. 19.12.2025
Функция РНКИсточникПомеченНаУдаление()

	Возврат Объект.НакладнаяИсточник.ПометкаУдаления; 

КонецФункции // ()

//--Данилова Е.В. 19.12.2025 

//Данилова Е.В. 26.12.2025  SNL-92
&НаСервере    
Процедура ВыполнитьРасчетПоСмешаннымСпайкам(МассивПРМОбъекты, МассивРНКОбъекты) 
	
	//++Данилова Е.В. 17.10.2025  HELP-5978 
	МассивРНКОбъекты = СоздатьРНК_НаСервере();
	
	МассивПРМОбъекты = Новый Массив; 
	//--Данилова Е.В. 17.10.2025
	
	//ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
	//Данилова Е.В. 24.10.2025 HELP-7587
	//Если НадоСоздаватьПеремещениеПоТабличнойЧасти("БезМарок") Тогда
	Если НадоСоздаватьПеремещениеПоТабличнойЧасти("БезМарок") 
		И НЕ Объект.ТолькоПоСмешанным Тогда
		
		тзБезМарок = Документы.ЗаказСмешанныхСпаекFBO.ПреобразоватьТаблицуСпаекВТаблицуТовары(ВыгрузитьТЧ_НаСервере("БезМарок"));
		
		Если тзБезМарок.Количество() > 0 Тогда 
			//++Данилова Е.В. 17.10.2025 HELP-5978
			//++Данилова Е.В. 26.12.2025 SNL-92 
