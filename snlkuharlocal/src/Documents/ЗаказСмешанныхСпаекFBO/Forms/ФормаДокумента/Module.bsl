&НаСервере
Процедура ОчиститьТаблицыПередРасчетом()
	
	Объект.ГотовыеСпайки.Очистить();
	Объект.БезМарок.Очистить();
	Объект.СМарками.Очистить();
	Объект.НекорректныеМарки.Очистить();
	Объект.СмешанныеСпайки.Очистить();
	Объект.СпайкиБезУпаковки.Очистить(); 
	ОчиститьСкладОтгрузки();

