&НаСервере
Функция НадоСоздаватьПеремещениеПоТабличнойЧасти(ИмяТабличнойЧасти, ИмяРеквизита = "НужноПереместить")
	
	Для Каждого Стр ИЗ Объект[ИмяТабличнойЧасти] Цикл
		Если Стр[ИмяРеквизита] > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ЗаполнитьУпаковкуСервер()
	//++Данилова Е.В. 06.10.2025  HELP-5978 
	//тзУпаковка = Объект.Упаковка.Выгрузить(); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказСмешанныхСпаекFBOБезМарок.Номенклатура КАК Номенклатура,
		|	ЗаказСмешанныхСпаекFBOБезМарок.Количество КАК Количество
		|ПОМЕСТИТЬ ВтБезМарок
		|ИЗ
		|	&БезМарок КАК ЗаказСмешанныхСпаекFBOБезМарок
		|ГДЕ
		|	ЗаказСмешанныхСпаекFBOБезМарок.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказСмешанныхСпаекFBOСМарками.Номенклатура КАК Номенклатура,
		|	ЗаказСмешанныхСпаекFBOСМарками.Количество КАК Количество
		|ПОМЕСТИТЬ ВтСмарками
		|ИЗ
		|	&СМарками КАК ЗаказСмешанныхСпаекFBOСМарками
		|ГДЕ
		|	ЗаказСмешанныхСпаекFBOСМарками.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказСмешанныхСпаекFBOСмешанныеСпайки.Номенклатура КАК Номенклатура,
		|	ЗаказСмешанныхСпаекFBOСмешанныеСпайки.Количество КАК Количество
		|ПОМЕСТИТЬ ВтСмешанныеМарки
		|ИЗ
		|	&СмешанныеСпайки КАК ЗаказСмешанныхСпаекFBOСмешанныеСпайки
		|ГДЕ
		|	ЗаказСмешанныхСпаекFBOСмешанныеСпайки.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	СУММА(ВложенныйЗапрос.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТСпайки
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ВтБезМарок.Номенклатура КАК Номенклатура,
		|		ВтБезМарок.Количество КАК Количество
		|	ИЗ
		|		ВтБезМарок КАК ВтБезМарок
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ВтСмарками.Номенклатура,
		|		ВтСмарками.Количество
		|	ИЗ
		|		ВтСмарками КАК ВтСмарками
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ВтСмешанныеМарки.Номенклатура,
		|		ВтСмешанныеМарки.Количество
		|	ИЗ
		|		ВтСмешанныеМарки КАК ВтСмешанныеМарки) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказСмешанныхСпаекFBOУпаковка.Номенклатура КАК Номенклатура,
		|	ЗаказСмешанныхСпаекFBOУпаковка.Комплектующее КАК Комплектующее,
		|	ЗаказСмешанныхСпаекFBOУпаковка.ПризнакМаркировки КАК ПризнакМаркировки,
		|	ЗаказСмешанныхСпаекFBOУпаковка.Количество КАК Количество,
		|	ЗаказСмешанныхСпаекFBOУпаковка.КоличествоКомплектующих КАК КоличествоКомплектующих,
		|	ЗаказСмешанныхСпаекFBOУпаковка.НужноПереместить КАК НужноПереместить,
		|	ЗаказСмешанныхСпаекFBOУпаковка.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
		|	ЗаказСмешанныхСпаекFBOУпаковка.Остаток КАК Остаток,
		|	ЗаказСмешанныхСпаекFBOУпаковка.СкладОтгрузки КАК СкладОтгрузки
		|ПОМЕСТИТЬ ВтУпаковка
		|ИЗ
		|	&Упаковка КАК ЗаказСмешанныхСпаекFBOУпаковка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтУпаковка.Номенклатура КАК Номенклатура,
		|	ВтУпаковка.Комплектующее КАК Комплектующее,
		|	ВтУпаковка.ПризнакМаркировки КАК ПризнакМаркировки,
		|	ВТСпайки.Количество КАК Количество,
		|	ВЫБОР
		|		КОГДА ВтУпаковка.КоличествоКомплектующих = 0
		|				ИЛИ ВтУпаковка.Количество = 0
		|			ТОГДА 0
		|		ИНАЧЕ (ВЫРАЗИТЬ(ВтУпаковка.КоличествоКомплектующих / ВтУпаковка.Количество КАК ЧИСЛО(15, 0))) * ВТСпайки.Количество
		|	КОНЕЦ КАК КоличествоКомплектующих,
		|	ВтУпаковка.НужноПереместить КАК НужноПереместить,
		|	ВтУпаковка.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
		|	ВтУпаковка.Остаток КАК Остаток,
		|	ВтУпаковка.СкладОтгрузки КАК СкладОтгрузки
		|ИЗ
		|	ВтУпаковка КАК ВтУпаковка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСпайки КАК ВТСпайки
		|		ПО ВтУпаковка.Номенклатура = ВТСпайки.Номенклатура";
	
	Запрос.УстановитьПараметр("БезМарок",Объект.БезМарок.Выгрузить()); 
	Запрос.УстановитьПараметр("СМарками",Объект.СМарками.Выгрузить()); 
	Запрос.УстановитьПараметр("СмешанныеСпайки",Объект.СмешанныеСпайки.Выгрузить());
	Запрос.УстановитьПараметр("Упаковка",Объект.Упаковка.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Объект.Упаковка.Загрузить(РезультатЗапроса.Выгрузить()); 
	
    тзУпаковка = Объект.Упаковка.Выгрузить();
	//--Данилова Е.В. 06.10.2025
	
	тзУпаковкаСклад = Документы.ЗаказСмешанныхСпаекFBO.УстановитьСкладОтгрузкиДляУпаковки(тзУпаковка, Объект.БезМарок.Выгрузить(), Объект.СкладБезМарок);
	
	Для Каждого Стр ИЗ Объект.Упаковка Цикл
		НайденныеСтроки = тзУпаковкаСклад.НайтиСтроки(Новый Структура("Номенклатура, Комплектующее", Стр.Номенклатура, Стр.Комплектующее));
		Для Каждого НСтрока ИЗ НайденныеСтроки Цикл
			Если НЕ ЗначениеЗаполнено(Стр.СкладОтгрузки) Тогда
				Стр.СкладОтгрузки = НСтрока.СкладОтгрузки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	тзУпаковкаСклад = Документы.ЗаказСмешанныхСпаекFBO.УстановитьСкладОтгрузкиДляУпаковки(тзУпаковка, Объект.СМарками.Выгрузить(), Объект.СкладМаркировки);
	
	Для Каждого Стр ИЗ Объект.Упаковка Цикл
		НайденныеСтроки = тзУпаковкаСклад.НайтиСтроки(Новый Структура("Номенклатура, Комплектующее", Стр.Номенклатура, Стр.Комплектующее));
		Для Каждого НСтрока ИЗ НайденныеСтроки Цикл
			Если НЕ ЗначениеЗаполнено(Стр.СкладОтгрузки) Тогда
				Стр.СкладОтгрузки = НСтрока.СкладОтгрузки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	/////////////// ВЕРНЕМ СКЛАД СМЕШАННЫЕ СПАЙКИ //////////////////////////////////////////////////////////
	тзУпаковкаСклад = Документы.ЗаказСмешанныхСпаекFBO.УстановитьСкладОтгрузкиДляУпаковки(тзУпаковка, Объект.СмешанныеСпайки.Выгрузить(), Объект.СкладСмешанныеСпайки);
	
	Для Каждого Стр ИЗ Объект.Упаковка Цикл
		НайденныеСтроки = тзУпаковкаСклад.НайтиСтроки(Новый Структура("Номенклатура, Комплектующее", Стр.Номенклатура, Стр.Комплектующее));
		Для Каждого НСтрока ИЗ НайденныеСтроки Цикл
			Если НЕ ЗначениеЗаполнено(Стр.СкладОтгрузки) Тогда
				Стр.СкладОтгрузки = НСтрока.СкладОтгрузки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	////////////////////////// ОСТАТКИ /////////////////////////////////////////////////////////////////////
	
	Для Каждого Стр ИЗ Объект.Упаковка Цикл
		
		Если ЗначениеЗаполнено(Стр.СкладОтгрузки) Тогда
			
			МассивИсточник = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
			МассивПриемник = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
			МассивОстатков = Объединить2Массива_НаСервере(МассивИсточник, МассивПриемник);
			
			МассивОстатков.Добавить(Объект.СкладБезМарок);
			МассивОстатков.Добавить(Объект.СкладМаркировки);
			МассивОстатков.Добавить(Объект.СкладСмешанныеСпайки);
			
			ЗаполнениеДокументов.УдалитьЗначениеИзМассива(МассивОстатков, Стр.СкладОтгрузки);
			
			МассивСтрок = Новый Массив;
			МассивСтрок.Добавить(Стр);
			
			тзСтрока = Объект.Упаковка.Выгрузить(МассивСтрок,);	
			//Данилова Е.В. 24.10.2025 HELP-7587
			РасчетУпаковокПоСкладуСмешанСпаек = ложь; 
			Если Стр.СкладОтгрузки  = Объект.СкладСмешанныеСпайки Тогда
				
				РасчетУпаковокПоСкладуСмешанСпаек = Истина; 	
				
			КонецЕсли;
			тзОстатки = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстатки(тзСтрока, МассивОстатков, Стр.СкладОтгрузки,,РасчетУпаковокПоСкладуСмешанСпаек);
			
			Для Каждого СтрокаТЗ из тзОстатки Цикл
				ЗаполнитьЗначенияСвойств(Стр, СтрокаТЗ, "ОстатокБазовыйСклад,Остаток,НужноПереместить");
				//++Данилова Е.В. 10.11.2025 HELP-7698 
				Стр.ОстатокОбщий = СтрокаТЗ.ОстатокБазовыйСклад + СтрокаТЗ.Остаток;  
				//--Данилова Е.В. 10.11.2025
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	//++Данилова Е.В. 28.10.2025 HELP-7587
	//необходимо пересчитать кол-во, которое можно переместить
	КопияТЧУпаковка = Объект.Упаковка.Выгрузить(); 
	Для каждого  Стр ИЗ Объект.Упаковка  Цикл 	
		
		Если Стр.СкладОтгрузки  = Объект.СкладСмешанныеСпайки Тогда
			Стр.ОстатокБазовыйСклад = 0; 
		КонецЕсли;
		
		ОтборПоиск = Новый Структура("СкладОтгрузки,Комплектующее",Стр.СкладОтгрузки,Стр.Комплектующее); 
		СтрокиПоиск = КопияТЧУпаковка.НайтиСтроки(ОтборПоиск); 
		//++Данилова Е.В. 10.11.2025 HELP-7698 
		ОтборПоискКомплект = Новый Структура("Комплектующее",Стр.Комплектующее); 
		СтрокиПоискКомплект = КопияТЧУпаковка.НайтиСтроки(ОтборПоискКомплект); 
		СтрокаДляРасчетаОбщая = СтрокиПоискКомплект[0];
		//--Данилова Е.В. 10.11.2025
		//возьмем первую строку
		СтрокаДляРасчета = СтрокиПоиск[0];
		Если Стр.СкладОтгрузки  = Объект.СкладСмешанныеСпайки Тогда
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0;
			СтрокаДляРасчетаОбщая.ОстатокОбщий = СтрокаДляРасчета.ОстатокОбщий - СтрокаДляРасчета.ОстатокБазовыйСклад;  
		КонецЕсли;
		
		Если Стр.КоличествоКомплектующих > СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток 
			ИЛИ Стр.КоличествоКомплектующих > СтрокаДляРасчетаОбщая.ОстатокОбщий Тогда
			ВычестьОстаток = Мин(СтрокаДляРасчета.Остаток,СтрокаДляРасчетаОбщая.ОстатокОбщий -СтрокаДляРасчета.ОстатокБазовыйСклад);  
			Стр.НужноПереместить = ВычестьОстаток; //СтрокаДляРасчета.Остаток;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0;
			СтрокаДляРасчета.Остаток = 0;			 
			СтрокаДляРасчетаОбщая.ОстатокОбщий = 0; //СтрокаДляРасчетаОбщая.ОстатокОбщий - (СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток); 
			
		ИначеЕсли Стр.КоличествоКомплектующих <= СтрокаДляРасчета.ОстатокБазовыйСклад Тогда
			Стр.НужноПереместить = 0;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад  = СтрокаДляРасчета.ОстатокБазовыйСклад - Стр.КоличествоКомплектующих; 
			СтрокаДляРасчетаОбщая.ОстатокОбщий = СтрокаДляРасчетаОбщая.ОстатокОбщий  -  Стр.КоличествоКомплектующих; 
			
		ИначеЕсли Стр.КоличествоКомплектующих > СтрокаДляРасчета.ОстатокБазовыйСклад 
			И Стр.КоличествоКомплектующих <= СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток Тогда			
			 
			Стр.НужноПереместить = Стр.КоличествоКомплектующих - СтрокаДляРасчета.ОстатокБазовыйСклад;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0; 
			СтрокаДляРасчета.остаток = СтрокаДляРасчета.остаток - Стр.НужноПереместить;
			
			СтрокаДляРасчетаОбщая.ОстатокОбщий = СтрокаДляРасчетаОбщая.ОстатокОбщий  - СтрокаДляРасчета.ОстатокБазовыйСклад - Стр.НужноПереместить; 
		КонецЕсли;
		
		Для каждого СтрокаПоиск Из СтрокиПоиск Цикл
		
			СтрокаПоиск.ОстатокБазовыйСклад = СтрокаДляРасчета.ОстатокБазовыйСклад; 
		    СтрокаПоиск.Остаток = СтрокаДляРасчета.Остаток; 
			
		КонецЦикла;
		//++Данилова Е.В. 10.11.2025 HELP-7698 
		Для каждого СтрокаПоискКомплект Из СтрокиПоискКомплект Цикл
			
			СтрокаПоискКомплект.ОстатокОбщий = СтрокаДляРасчетаОбщая.ОстатокОбщий;
			 
			
		КонецЦикла;
		//--Данилова Е.В. 10.11.2025
		
		 
	КонецЦикла;
	
	//--Данилова Е.В. 28.10.2025
	
КонецФункции

&НаСервере
Функция НеЗаполненРеквизитВТЧ(ИмяТабличнойЧасти = "Упаковка", ИмяРеквизита = "СкладОтгрузки")
	
	Для Каждого Стр ИЗ Объект[ИмяТабличнойЧасти] Цикл
		Если НЕ ЗначениеЗаполнено(Стр[ИмяРеквизита]) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	//++Данилова Е.В. 24.10.2025 HELP-7587  
	УстановитьДоступность(); 
	//--Данилова Е.В. 24.10.2025
КонецПроцедуры

//++Данилова Е.В. 24.10.2025 HELP-7587
&НаСервере
Процедура УстановитьДоступность()

	ЭтаФорма.ТолькоПросмотр = Объект.РасчетВыполнен; 
	Элементы.КнопкаВыполнить.Доступность = Не объект.РасчетВыполнен;
	Элементы.КнопкаОстатки.Доступность = Не объект.РасчетВыполнен;

КонецПроцедуры

&НаСервере
Процедура ПометитьНаУдалениеНакладнуюИсточник()
	Если Объект.НакладнаяИсточник.Проведен Тогда
		
		ОбъектРНК = Объект.НакладнаяИсточник.ПолучитьОбъект(); 
		
		Попытка
			
			ОбъектРНК.Записать(РежимЗаписиДокумента.ОтменаПроведения);	
			
		Исключение
			Сообщить("Не удалось отменить проведение по исходной РНК " + ОписаниеОшибки());
			Возврат; 
		КонецПопытки;			
		
	КонецЕсли;
	
	ОбъектРНК = Объект.НакладнаяИсточник.ПолучитьОбъект();
	ОбъектРНК.ПометкаУдаления = истина;
	ОбъектРНК.ДополнительныеСвойства.Вставить("НепомечатьПодчиненные",истина);
	ОбъектРНК.ЗаписьБезКонтроляПолномочий();
	
	Попытка
		
		ОбъектРНК.Записать(РежимЗаписиДокумента.Запись);	
		
	Исключение
		Сообщить("Не удалось пометить на удаление исходную РНК " + ОписаниеОшибки());
		 
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЗаписьВРССтатусыМарок()
    
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ЗаказСмешанныхСпаекFBOПеремещения.ПеремещениеПриемник КАК Документ.Перемещение) КАК ПеремещениеПриемник
		|ПОМЕСТИТЬ ВтПРМ
		|ИЗ
		|	&Перемещения КАК ЗаказСмешанныхСпаекFBOПеремещения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВтПРМ.ПеремещениеПриемник КАК ПРМ
		|ИЗ
		|	ВтПРМ КАК ВтПРМ
		|ГДЕ
		|	ВтПРМ.ПеремещениеПриемник.Склад В(&СкладыБезМарок)
		|	И ВтПРМ.ПеремещениеПриемник.СкладПолучатель = &СкладПолучательСмешанныеСпайки
		//Данилова Е.В. 30.10.2025 HELP-7587
		|	И ВтПРМ.ПеремещениеПриемник.ТребуетсяМаркировка";
	
	Запрос.УстановитьПараметр("СкладПолучательСмешанныеСпайки", Объект.СкладСмешанныеСпайки);
	
	СкладыБезМарок = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
	СкладыБезМарок.Добавить(Объект.СкладБезМарок); 
	
	Запрос.УстановитьПараметр("СкладыБезМарок", СкладыБезМарок);
	Запрос.УстановитьПараметр("Перемещения", Объект.Перемещения.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой()  Тогда 
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий()  Цикл
			
			МенеджерЗаписи = РегистрыСведений.СтатусыЗаказаМарокДляДокументов.СоздатьМенеджерЗаписи(); 	
			МенеджерЗаписи.Накладная = Выборка.ПРМ; 
			МенеджерЗаписи.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.ТребуетсяЗаказМарок; 
			
			Попытка
				
				МенеджерЗаписи.Записать(); 
				
			Исключение
				ЗаписатьВЛог("Заказ смешанных спаек FBO","Не удалось создать запись в РС СтатусыЗаказаМарокДляДокументов для заказа марок " + Строка(Выборка.ПРМ),"Ошибка");
				Сообщить(ОписаниеОшибки()); 
			КонецПопытки; 		
			
		КонецЦикла;
		
	КонецЕсли;

	

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРНК(Команда)
	ТекущиеДанные = Элементы.РасходныеНакладные.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено  Тогда
	
		ОткрытьЗначение(ТекущиеДанные.НакладнаяПриемник); 	
	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПРМ(Команда)
	ТекущиеДанные = Элементы.Перемещения.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено  Тогда
	
		ОткрытьЗначение(ТекущиеДанные.ПеремещениеПриемник); 	
	
	КонецЕсли;
КонецПроцедуры
