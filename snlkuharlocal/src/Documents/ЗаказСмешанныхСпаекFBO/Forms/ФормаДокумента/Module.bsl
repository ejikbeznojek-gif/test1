&НаСервере
Процедура ЗаполнитьТоварыПоРНК()

	ОбъектДок = РеквизитФормыВЗначение("Объект"); 
	ОбъектДок.ЗаполнитьТоварыПоРНК(Объект.НакладнаяИсточник);
	Если НЕ ЗначениеЗаполнено(Объект.РежимРасчета) Тогда
		
		Объект.РежимРасчета = ОбъектДок.ВычислитьРежимРасчета(ОбъектДок.Товары);	
		
	КонецЕсли; 
	//ЗначениеВРеквизитФормы(ОбъектДок,"Объект"); 

КонецПроцедуры // ЗаполнитьТоварыПоРНК()

