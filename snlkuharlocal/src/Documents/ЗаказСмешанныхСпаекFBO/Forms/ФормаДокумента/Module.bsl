&НаСервере
Процедура РасчетОстатковШтуки()
 
	ОчиститьТаблицыПередРасчетом();
	
	МассивСкладыБезМарок = ВыгрузитьМассив_НаСервере("ДоступныеСкладыБезМарок", "СкладБезМарок");
	МассивСкладыСМарками = ВыгрузитьМассив_НаСервере("ДоступныеСкладыМаркировка", "СкладМаркировки");
	
	МассивВсеСклады = Объединить2Массива_НаСервере(МассивСкладыБезМарок, МассивСкладыСМарками);
	
	МассивВсеСклады.Добавить(Объект.СкладБезМарок);
	МассивВсеСклады.Добавить(Объект.СкладМаркировки);
	
	Запрос = Неопределено;
    МенеджерВременныхТаблиц = Неопределено;
    //ТоварыДляОбработки = Неопределено;
    РасчетОстатковПредварительныйРасчет(Запрос, МассивВсеСклады, МенеджерВременныхТаблиц); 	
	РасчетОстатковШтукиСМаркировкой(Запрос,МассивСкладыСМарками,МенеджерВременныхТаблиц); 
	РасчетОстатковШтукиНекорректныеМарки(Запрос,МенеджерВременныхТаблиц); 
	РасчетОстатковШтукиБезмарок(Запрос,МассивСкладыБезМарок,МенеджерВременныхТаблиц); 
	
	Объект.РасчетОстатковВыполнен = Истина; 
	
	ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
 
