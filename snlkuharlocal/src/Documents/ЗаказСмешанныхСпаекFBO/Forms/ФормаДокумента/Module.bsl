	|ВЫБРАТЬ
	|	ВТУпаковкиДляНекоррМарки.Номенклатура КАК Номенклатура,
	|	ВТУпаковкиДляНекоррМарки.Комплектующее КАК Комплектующее,
	|	ВТУпаковкиДляНекоррМарки.Количество КАК Количество,
	|	ВТУпаковкиДляНекоррМарки.КоличествоКомплектующих КАК КоличествоКомплектующих,
	|	ЕСТЬNULL(ВТУпаковкиДляНекоррМаркиОстаткиБазовыйСклад.ОстатокБазовыйСклад, 0) КАК ОстатокБазовыйСклад,
	|	ЕСТЬNULL(ВТУпаковкиДляНекоррМаркиОстаткиВсеСклады.Остаток, 0) КАК Остаток
	|ПОМЕСТИТЬ ВТУпаковкиДляНекоррМаркиОстатки
	|ИЗ
	|	ВТУпаковкиДляНекоррМарки КАК ВТУпаковкиДляНекоррМарки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУпаковкиДляНекоррМаркиОстаткиБазовыйСклад КАК ВТУпаковкиДляНекоррМаркиОстаткиБазовыйСклад
	|		ПО ВТУпаковкиДляНекоррМарки.Комплектующее = ВТУпаковкиДляНекоррМаркиОстаткиБазовыйСклад.Комплектующее
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУпаковкиДляНекоррМаркиОстаткиВсеСклады КАК ВТУпаковкиДляНекоррМаркиОстаткиВсеСклады
	|		ПО ВТУпаковкиДляНекоррМарки.Комплектующее = ВТУпаковкиДляНекоррМаркиОстаткиВсеСклады.Комплектующее
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеНекорректныеМарки.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТКомплектующиеНекорректныеМарки КАК ВТКомплектующиеНекорректныеМарки"; 
	
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДатаСеанса()); 
	Запрос.УстановитьПараметр("ВсеСклады",МассивВсеСклады);
	Запрос.УстановитьПараметр("СкладНеКорректныхМарок",Объект.СкладНекоррМарок);
	
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ОстаткиКомплектНекорректМарки = ПакетРезультатов[3].Выгрузить();	
	МассивСпаек = ПакетРезультатов[9].Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
	ТаблицаСпаекНекорректМарки = Документы.ЗаказСмешанныхСпаекFBO.ПодогнатьКоличествоСпаекКОстатку(ОстаткиКомплектНекорректМарки,ложь,МассивСпаек, истина); 
	Объект.НекорректныеМарки.Загрузить(ТаблицаСпаекНекорректМарки);
	
	ТаблицаСпаекНекорректМаркиКопия =  ТаблицаСпаекНекорректМарки; 
	ТаблицаСпаекНекорректМаркиКопия.Свернуть("Номенклатура,Количество");
	
	запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	
	//СКЛАД ОТГРУЗКИ Склад некоррект. марок  
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТоварыНеКорректМарки
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТТоварыНеКорректМарки.Номенклатура КАК Номенклатура,
	|	ВТТоварыНеКорректМарки.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТоварыНеКорректМаркиРазличные
	|ИЗ
	|	ВТТоварыНеКорректМарки КАК ВТТоварыНеКорректМарки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТУпаковкиДляНекоррМаркиОстатки.Номенклатура КАК Номенклатура,
	|	ВТУпаковкиДляНекоррМаркиОстатки.Комплектующее КАК Комплектующее,
	|	ВтТовары.Количество КАК Количество,
	|	ВтТовары.Количество КАК КоличествоКомплектующих,
	|	ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
	|	ВТУпаковкиДляНекоррМаркиОстатки.Остаток КАК Остаток,
	|	&СкладНеКорректМарок КАК СкладОтгрузки,
	|	ВЫБОР
	|		КОГДА ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад >= ВтТовары.Количество
	|			ТОГДА 0
	|		ИНАЧЕ ВтТовары.Количество - ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад
	|	КОНЕЦ КАК НужноПереместить
	|ИЗ
	|	ВТТоварыНеКорректМаркиРазличные КАК ВтТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУпаковкиДляНекоррМаркиОстатки КАК ВТУпаковкиДляНекоррМаркиОстатки
	|		ПО (ВТУпаковкиДляНекоррМаркиОстатки.Номенклатура = ВтТовары.Номенклатура)
	|ГДЕ
	|	ВТУпаковкиДляНекоррМаркиОстатки.Остаток + ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад >= ВтТовары.Количество
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТУпаковкиДляНекоррМаркиОстатки.Номенклатура КАК Номенклатура,
	|	ВТУпаковкиДляНекоррМаркиОстатки.Комплектующее КАК Комплектующее,
	|	ВтТовары.Количество КАК Количество,
	|	ВтТовары.Количество КАК КоличествоКомплектующих,
	|	ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад КАК ОстатокБазовыйСклад,
	|	ВТУпаковкиДляНекоррМаркиОстатки.Остаток КАК Остаток,
	|	&СкладНеКорректМарок КАК СкладОтгрузки,
	|	0 КАК НужноПереместить
	|ИЗ
	|	ВТТоварыНеКорректМаркиРазличные КАК ВтТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУпаковкиДляНекоррМаркиОстатки КАК ВТУпаковкиДляНекоррМаркиОстатки
	|		ПО (ВТУпаковкиДляНекоррМаркиОстатки.Номенклатура = ВтТовары.Номенклатура)
	|ГДЕ
	|	ВТУпаковкиДляНекоррМаркиОстатки.Остаток + ВТУпаковкиДляНекоррМаркиОстатки.ОстатокБазовыйСклад < ВтТовары.Количество"; 
	
	Запрос.УстановитьПараметр("СкладНеКорректМарок",Объект.СкладНекоррМарок);
	Запрос.УстановитьПараметр("Товары",ТаблицаСпаекНекорректМаркиКопия); 
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	
	ТЧУпаковкиХватает = ПакетЗапросов[2].Выгрузить(); 
	ТЧУпаковкиХватает.Колонки.Добавить("НеХватает");
	
	ТЧУпаковкиХватаетКопия = ТЧУпаковкиХватает.Скопировать();
	
	КорректировкаОстатковСпайкиПоУпаковкам(ТЧУпаковкиХватает,ТЧУпаковкиХватаетКопия); 
	
	ВыборкаУпаковкиНеХватает = ПакетЗапросов[3].Выбрать(); 
	
	Пока ВыборкаУпаковкиНеХватает.Следующий() Цикл
		
		НоваяСтрНеХватает = Объект.СпайкиБезУпаковки.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрНеХватает,ВыборкаУпаковкиНеХватает);  	
		
		ОтборПродукция = Новый Структура("Номенклатура",ВыборкаУпаковкиНеХватает.Номенклатура); 
		СтрокиБезМарок = Объект.НекорректныеМарки.НайтиСтроки(ОтборПродукция);
		Для каждого СтрокаБезМарок Из СтрокиБезМарок Цикл
			
			СтрокаБезМарок.БезУпаковки = истина; 	
			
		КонецЦикла;
	КонецЦикла;
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;

КонецПроцедуры

&НаСервере
Процедура РасчетОстатковСпайкиБезМаркировки(Запрос, МассивВсеСклады, МассивСкладыБезМарок, МенеджерВременныхТаблиц)
	
	//////////////////////////////////////////////////////////
	//Склады без маркировки  
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ЗаказСмешанныхСпаекFBOСпайки.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ЗаказСмешанныхСпаекFBOСпайки.Комплектующее КАК Комплектующее,
	|	ЗаказСмешанныхСпаекFBOСпайки.Количество КАК Количество,
	|	ЗаказСмешанныхСпаекFBOСпайки.КоличествоКомплектующих КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ ВТКомплектующие
	|ИЗ
	|	&Спайки КАК ЗаказСмешанныхСпаекFBOСпайки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТКомплектующие.Номенклатура КАК Номенклатура,
	|	ВТКомплектующие.Комплектующее КАК Комплектующее,
	|	ВТКомплектующие.Количество - ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|			ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|		ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР
	|		КОГДА ВТГотовыеСпайки.Номенклатура ЕСТЬ NULL
	|			ТОГДА ВТКомплектующие.КоличествоКомплектующих
	|		ИНАЧЕ (ВТКомплектующие.Количество - ВЫБОР
	|				КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|					ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|				ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|			КОНЕЦ) * ВТКомплектующие.КоличествоКомплектующих / ВТКомплектующие.Количество
	|	КОНЕЦ КАК КоличествоКомплектующих
	|ПОМЕСТИТЬ ВТКомплектующиеДляБезМарок
	|ИЗ
	|	ВТКомплектующие КАК ВТКомплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыДляОтработки КАК ВТТоварыДляОтработки
	|		ПО (ВТТоварыДляОтработки.Номенклатура = ВТКомплектующие.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТГотовыеСпайки КАК ВТГотовыеСпайки
	|		ПО (ВТГотовыеСпайки.Номенклатура = ВТКомплектующие.Номенклатура)
	|ГДЕ
	|	ВТКомплектующие.Количество - ВЫБОР
	|			КОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0) < ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|				ТОГДА ЕСТЬNULL(ВТГотовыеСпайки.Количество, 0)
	|			ИНАЧЕ ЕСТЬNULL(ВТГотовыеСпайки.Остаток, 0)
	|		КОНЕЦ > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Матрица.Ссылка) КАК Матрица
	|ПОМЕСТИТЬ ВТМатрица
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица КАК Матрица
	|		ПО МатрицаПунктыДоставки.Ссылка = Матрица.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИнетМагазины КАК ИнетМагазиныСпр
	|		ПО (НЕ ИнетМагазиныСпр.ПометкаУдаления)
	|			И (ИнетМагазиныСпр.Контрагент = &Контрагент)
	|			И (ИнетМагазиныСпр.Организация = &Организация)
	|			И (ИнетМагазиныСпр.ПунктДоставки = МатрицаПунктыДоставки.ПунктДоставки)
	|ГДЕ
	|	Матрица.Проведен
	|	И Матрица.Дата <= &ТекущаяДата
	|	И Матрица.ДатаОкончания >= &ТекущаяДата
	|	И Матрица.Контрагент = &Контрагент
	|	И НЕ Матрица.Акция
	|	И Матрица.ПостояннаяАкция = &ПостояннаяАкция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.МинимальноеКоличество КАК МинимальноеКоличество
	|ПОМЕСТИТЬ ВтМинимальныеКоличестваFBS
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМатрица КАК ВТМатрица
	|		ПО МатрицаТовары.Ссылка = ВТМатрица.Матрица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомплектующие КАК ВТТоварыДляОтработки
	|		ПО (ВТТоварыДляОтработки.Комплектующее = МатрицаТовары.Номенклатура)
	|ГДЕ
	|	МатрицаТовары.МинимальноеКоличество <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеДляБезМарок.Комплектующее КАК Комплектующее,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|			КОНЕЦ
	|	КОНЕЦ КАК Остаток
	|ПОМЕСТИТЬ ВТОстаткиБазовыйСклад
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ВТКомплектующиеДляБезМарок.Комплектующее КАК Комплектующее
	|	ИЗ
	|		ВТКомплектующиеДляБезМарок КАК ВТКомплектующиеДляБезМарок) КАК ВТКомплектующиеДляБезМарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТекущаяДата,
	|				Склад = &СкладБезМарок
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТКомплектующиеДляБезМарок.Комплектующее
	|						ИЗ
	|							ВТКомплектующиеДляБезМарок КАК ВТКомплектующиеДляБезМарок)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТекущаяДата,
	|					Склад = &СкладБезМарок
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								ВТКомплектующиеДляБезМарок.Комплектующее
	|							ИЗ
	|								ВТКомплектующиеДляБезМарок КАК ВТКомплектующиеДляБезМарок)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО ВТКомплектующиеДляБезМарок.Комплектующее = ОстаткиТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТКомплектующиеДляБезМарок.Комплектующее КАК Комплектующее,
	|	СУММА(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(РезервыТМЦОстаткиДрСкладыНеFBS.КоличествоОстаток, 0)
	|				КОНЕЦ
	|		КОНЕЦ) КАК Остаток
