 &НаСервере
 Процедура УстановитьВидимость()
 
 	Элементы.СпайкиПризнакМаркировки.Видимость 		= Объект.РежимРасчета = 1;
	Элементы.БезМарокПризнакМаркировки.Видимость 	= Объект.РежимРасчета = 1;
	Элементы.СМаркамиПризнакМаркировки.Видимость 	= Объект.РежимРасчета = 1;
	Элементы.УпаковкаПризнакМаркировки.Видимость   =  Объект.РежимРасчета = 1;
	//потом раскомментировать 
	Элементы.ГруппаСмешанныеСпайки.Видимость		= Объект.РежимРасчета = 1;
	Элементы.ГруппаГотовыеСпайки.Видимость 			= Объект.РежимРасчета = 2;
	Элементы.ГруппаСпайкиБезУпаковок.Видимость 		= Объект.РежимРасчета = 2;
	Элементы.ГруппаНекорректныеМарки.Видимость      = Объект.РежимРасчета <> 1;
	
 КонецПроцедуры // УстановитьВидимость()

&НаСервере
 Процедура РежимРасчетаПриИзмененииНаСервере()
	 УстановитьВидимость();
 КонецПроцедуры

&НаКлиенте
 Процедура РежимРасчетаПриИзменении(Элемент)
	 РежимРасчетаПриИзмененииНаСервере();
	 НакладнаяИсточникОбработкаВыбораНаКлиенте(Объект.НакладнаяИсточник); 
 КонецПроцедуры

&НаКлиенте
 Процедура ЖурналИзменений(Команда)
	 ОткрытьЖурналРегистрации(Объект.Ссылка); 
 КонецПроцедуры
 
