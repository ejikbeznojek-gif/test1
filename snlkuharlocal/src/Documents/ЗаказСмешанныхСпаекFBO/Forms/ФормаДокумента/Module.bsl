 //
 // Параметры:
 //  <Параметр1>  - <Тип.Вид> - <описание параметра>
 //                 <продолжение описания параметра>
 //  <Параметр2>  - <Тип.Вид> - <описание параметра>
 //                 <продолжение описания параметра>
 //
 &НаСервере
 Процедура УдалитьИзРНККомплектующиеУпаковки(Знач РНКОбъект)
 
	 СкладОтгрузки = РНКОбъект.Склад; 
	 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	ЗаказСмешанныхСпаекFBOСпайкиБезУпаковки.Номенклатура КАК Номенклатура,
	 |	ЗаказСмешанныхСпаекFBOСпайкиБезУпаковки.Комплектующее КАК Комплектующее,
	 |	ЗаказСмешанныхСпаекFBOСпайкиБезУпаковки.Отгрузить КАК Отгрузить,
	 |	ЗаказСмешанныхСпаекFBOСпайкиБезУпаковки.СкладОтгрузки КАК СкладОтгрузки
	 |ПОМЕСТИТЬ ВТСпайкиБезУпаковки
	 |ИЗ
	 |	&СпайкиБезУпаковки КАК ЗаказСмешанныхСпаекFBOСпайкиБезУпаковки
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВТСпайкиБезУпаковки.Номенклатура КАК Номенклатура,
	 |	ВТСпайкиБезУпаковки.Комплектующее КАК Комплектующее
	 |ИЗ
	 |	ВТСпайкиБезУпаковки КАК ВТСпайкиБезУпаковки
	 |ГДЕ
	 |	ВТСпайкиБезУпаковки.Отгрузить = ИСТИНА
	 |	И ВТСпайкиБезУпаковки.СкладОтгрузки = &СкладОтгрузки";
	 
	 
	 Запрос.УстановитьПараметр("СкладОтгрузки", СкладОтгрузки);
	 Запрос.УстановитьПараметр("СпайкиБезУпаковки", Объект.СпайкиБезУпаковки.Выгрузить());
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 
	 ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	 
	 Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 ОтборВРНК = Новый Структура("Продукция,Номенклатура",ВыборкаДетальныеЗаписи.Номенклатура,ВыборкаДетальныеЗаписи.Комплектующее); 
		 
		 СтрокиУпаковок = РНКОбъект.Комплектующие.найтиСтроки(ОтборВРНК);
		 Для каждого СтрокаУпаковок Из СтрокиУпаковок Цикл
			 
			 РНКОбъект.Комплектующие.Удалить(СтрокаУпаковок); 	
			 
		 КонецЦикла;
	 КонецЦикла;
	 
 
 КонецПроцедуры // УдалитьИзРНККомплектующиеУпаковки()
 
