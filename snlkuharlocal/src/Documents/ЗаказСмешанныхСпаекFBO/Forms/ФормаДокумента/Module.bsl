&НаКлиенте
Процедура ПослеВыполнитьРежимРасчетаСпайки(ОтветНаВопрос,ДопПараметры) Экспорт 
	
	Если ОтветНаВопрос = КодВозвратаДиалога.ОК  Тогда
		
		МассивПРМОбъекты = Неопределено;
		МассивРНКОбъекты = Неопределено;	
		ВыполнитьРасчетПоСпайкам(МассивПРМОбъекты, МассивРНКОбъекты);
		РезультатСозданияДокументов = Ложь; 
		ЗаписатьПровестиДокументыРНКПРМ(МассивПРМОбъекты, МассивРНКОбъекты,РезультатСозданияДокументов); 
		
		Если РезультатСозданияДокументов Тогда
			Объект.РасчетВыполнен = Истина; 
			ПометитьНаУдалениеНакладнуюИсточник();
			СоздатьЗаписьВРССтатусыМарок(); 
			ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
		Иначе 
			ЗаполнениеДокументов.ЗаписатьФорму(ЭтаФорма, Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		КонецЕсли;
	КонецЕсли;

	

КонецПроцедуры // ПослеВыполнитьРежимРасчетаСпайки()

&НаСервере
Процедура КорректировкаОстатковШтукиПоСкладам(Знач ТЧОстатков, Знач ТЧОстатковКопия)
	
	Для каждого  Стр ИЗ ТЧОстатков  Цикл	
			
		Стр.НеХватает = Ложь;
		
		ОтборПоиск = Новый Структура("Номенклатура",Стр.Номенклатура); 
		СтрокиПоиск = ТЧОстатковКопия.НайтиСтроки(ОтборПоиск);
		//возьмем первую строку
		СтрокаДляРасчета = СтрокиПоиск[0];
		
		Если СтрокаДляРасчета.ОстатокБазовыйСклад = 0 
			И СтрокаДляРасчета.Остаток = 0 Тогда
			
			Стр.НеХватает = Истина;
			
			Продолжить; 
			
		КонецЕсли;
		
		Если Стр.Количество > СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток Тогда  		
			
			Стр.Количество = СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток; 
			Стр.КоличествоКомплектующих = Стр.Количество;
			
			Стр.НужноПереместить = СтрокаДляРасчета.Остаток; 
			
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0; 
			СтрокаДляРасчета.Остаток = 0; 
			
			Если Стр.ЕстьМИН
				И Стр.Количество < Стр.МинКоличествоПродукции Тогда
			
				Стр.НеХватает = Истина;
				Продолжить; 
			
			КонецЕсли;
			
		ИначеЕсли Стр.Количество <= СтрокаДляРасчета.ОстатокБазовыйСклад Тогда
			
			Стр.НужноПереместить = 0;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад  = СтрокаДляРасчета.ОстатокБазовыйСклад - Стр.Количество; 
			
		ИначеЕсли Стр.Количество > СтрокаДляРасчета.ОстатокБазовыйСклад 
			И Стр.Количество <= СтрокаДляРасчета.ОстатокБазовыйСклад + СтрокаДляРасчета.Остаток Тогда
			
			Стр.НужноПереместить = Стр.Количество - СтрокаДляРасчета.ОстатокБазовыйСклад;
			
			СтрокаДляРасчета.ОстатокБазовыйСклад = 0; 
			СтрокаДляРасчета.остаток = СтрокаДляРасчета.остаток - Стр.НужноПереместить; 	
		КонецЕсли;
		
		Для каждого СтрокаПоиск Из СтрокиПоиск Цикл
			
			СтрокаПоиск.ОстатокБазовыйСклад = СтрокаДляРасчета.ОстатокБазовыйСклад; 
			СтрокаПоиск.Остаток = СтрокаДляРасчета.Остаток; 
			
		КонецЦикла;	 
	КонецЦикла;
	
	ОтборНеХватает = Новый Структура("НеХватает",Истина);  
	СтрокиНеХватает = ТЧОстатков.НайтиСтроки(ОтборНеХватает);
	
	Для каждого СтрокаНеХватает Из СтрокиНеХватает Цикл
	
		ТЧОстатков.Удалить(СтрокаНеХватает); 	
	
	КонецЦикла;
КонецПроцедуры

