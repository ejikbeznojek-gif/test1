Функция ПолучитьДатыПланирования() Экспорт
	Если Полугодие=1 Тогда
		Дата1	= НачалоГода(Дата);
		Дата2	= КонецМесяца(ДобавитьМесяц(Дата1,5));	
	Иначе
		Дата1	= ДобавитьМесяц(НачалоГода(Дата),6);
		Дата2	= КонецГода(Дата1);	
	КонецЕсли;
	
	Дата11	= ДобавитьМесяц(Дата1,-12);
	Дата12	= ДобавитьМесяц(Дата2,-12);	
		
	Дата21	= ДобавитьМесяц(Дата1,-24);
	Дата22	= ДобавитьМесяц(Дата2,-24);
	
	// Кухарь А.Ю.  25.01.2024 начало
	//
	если ЗначениеЗаполнено(ДатаНачалаПродаж) и ЗначениеЗаполнено(ДатаОкончанияПродаж) тогда
		Дата21	= '19900101';
		Дата22	= '19900201';	
		Дата11	= ДатаНачалаПродаж;
		Дата12	= КонецДня(ДатаОкончанияПродаж);	
	КонецЕсли;
	// Кухарь А.Ю.  25.01.2024 конец
	
	
	Возврат Новый Структура("Дата1,Дата2,Дата11,Дата12,Дата21,Дата22",Дата1,Дата2,Дата11,Дата12,Дата21,Дата22);
КонецФункции //ПолучитьДатыПланирования()

Процедура РаспределитьПоБазе(СтрокиБазы,Знач Суммы,КолонкаБазы="БазаРаспределения",Фильтр=Неопределено,ИмяРаспределения="") Экспорт	
	Если Фильтр<>Неопределено Тогда
		ТекСтрокиБазы=СтрокиБазы.НайтиСтроки(Фильтр);	
	Иначе
		ТекСтрокиБазы=СтрокиБазы;		
	КонецЕсли; 
	
	База=0;
	Для Каждого СтрокаБазы Из ТекСтрокиБазы Цикл
		База=База+СтрокаБазы[КолонкаБазы];	
	КонецЦикла;	
	
	Если База=0 Тогда
		Сообщить("Нулевая база распределения ! "+ИмяРаспределения,СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;	
	
	Распределено=Новый Соответствие;
	Для Каждого Элемент Из Суммы Цикл
		Распределено.Вставить(Элемент.Ключ,0);			
	КонецЦикла; 
	
	МаксСтрока=Неопределено;МаксСумма=-1000000000000000000000000000000;
	Для Каждого СтрокаБазы Из ТекСтрокиБазы Цикл
		Для Каждого Элемент Из Суммы Цикл			
			СтрокаБазы[Элемент.Ключ]=Элемент.Значение*СтрокаБазы[КолонкаБазы]/База;					
			Распределено.Вставить(Элемент.Ключ,Распределено.Получить(Элемент.Ключ)+СтрокаБазы[Элемент.Ключ]);
		КонецЦикла;
		
		Если СтрокаБазы[КолонкаБазы]>МаксСумма Тогда
			МаксСумма	=СтрокаБазы[КолонкаБазы];
			МаксСтрока	=СтрокаБазы;
		КонецЕсли; 
	КонецЦикла;	
	
	Если МаксСтрока<>Неопределено Тогда
		Для Каждого Элемент Из Суммы Цикл
			Дельта=Элемент.Значение-Распределено.Получить(Элемент.Ключ);
			МаксСтрока[Элемент.Ключ]=МаксСтрока[Элемент.Ключ]+Дельта;
			//Если ПараметрыСеанса.Отладка Тогда
			//	Сообщить("Дельта по распределению "+ИмяРаспределения+" "+Элемент.Ключ+" "+Дельта);		
			//КонецЕсли;		
		КонецЦикла;
	КонецЕсли;	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)			
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ЕстьИзменения		=Модифицированность();
	НужноВыгружать		=Ложь;
		
	Если НЕ ОбменДанными.Загрузка Тогда		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;		

	Если Отказ Тогда Возврат КонецЕсли;
		
	Если ЕстьИзменения Тогда		
		СуммаДокумента		= ПланПродаж.Итог("Всего");
		//ГруппыТоваров		= ГруппыТоваровДокумента(ЭтотОбъект,"Состав",?(Детальный,"Номенклатура","Модель"));
		
		ПланПродаж.Сортировать("Контрагент,Бренд,ТипТовара");	
	Иначе
		Если (НЕ Ссылка.Проведен И РежимЗаписи=РежимЗаписиДокумента.Проведение) ИЛИ Ссылка.ПометкаУдаления<>ПометкаУдаления Тогда
			НужноВыгружать=Истина;			
		КонецЕсли;		
	КонецЕсли;	
	
КонецПроцедуры

Процедура РаспределитьПоМесяцам(Элемент=Неопределено)
	

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ДатыПланирования=ПолучитьДатыПланирования();
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ Бренд,ТипТовара ПОМЕСТИТЬ Товары ИЗ &Товары КАК Товары
	|;	
	|ВЫБРАТЬ 
	|	Бренд,ТипТовара,
	|	Период КАК Период,
	|	Округ,
	|	Коэффициент
	|ИЗ
	|	РегистрСведений.КоэффициентыСезонности
	|ГДЕ
	|	Период МЕЖДУ &Дата1 И &Дата2
	|	И (Бренд,ТипТовара) В (ВЫБРАТЬ РАЗЛИЧНЫЕ Бренд,ТипТовара ИЗ Товары)	
	|";
	
	ДатыПланирования=ПолучитьДатыПланирования();	
	
	Запрос.УстановитьПараметр("Дата1",	ДатыПланирования.Дата1);
	Запрос.УстановитьПараметр("Дата2",	ДатыПланирования.Дата2);
	
	Запрос.УстановитьПараметр("Товары",	Товары);
	
	Результат	= Запрос.Выполнить();
	
	ТБ=ПланПродаж.Выгрузить(,"Бренд,ТипТовара,Округ");
	ТБ.Свернуть("Бренд,ТипТовара,Округ");
	
	ТР=Запрос.Выполнить().Выгрузить();
	ТР.Колонки.Добавить("Сумма",ПолучитьОписаниеТиповЧисла(12,0));
	
	ТР.Индексы.Добавить("Бренд,ТипТовара,Округ");
	
	ДвиженияПоРег=Движения.ПланПродажПоКлиентам;
	ДвиженияПоРег.Очистить();
	
	Для Каждого СтрокаТБ Из ТБ Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Фильтр=Новый Структура("Бренд,ТипТовара,Округ");	
		ЗаполнитьЗначенияСвойств(Фильтр,СтрокаТБ);
		
		СтрокиПлана=ПланПродаж.НайтиСтроки(Фильтр);
		Для Каждого СтрокаПлана Из СтрокиПлана Цикл
			ТР.ЗаполнитьЗначения(0,"Сумма");
			РаспределитьПоБазе(ТР,Новый Структура("Сумма",СтрокаПлана.Всего),"Коэффициент",Фильтр,""+СтрокаПлана.Контрагент);
			Для Каждого СтрокаТР Из ТР Цикл
				Если СтрокаТР.Сумма<>0 Тогда
					Движение		= ДвиженияПоРег.Добавить();
					
					ЗаполнитьЗначенияСвойств(Движение,СтрокаТР);					
					
					Движение.Подразделение	= Подразделение;
					Движение.Контрагент		= СтрокаПлана.Контрагент;
				КонецЕсли;				
			КонецЦикла; 
		КонецЦикла;	
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		Валюта 	= Основание.Валюта;
		ИБ 		= Основание.ИБ;
		Склад 	= Основание.Склад;
		ТипЦен 	= Основание.ТипЦен;
		
		Для Каждого СтрокаИст Из Основание.Товары  Цикл
			Если СтрокаИст.Количество=0 Тогда Продолжить КонецЕсли;
			
			СтрокаТЧ=ПланПродаж.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаИст);
		КонецЦикла; 
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьРеквизитыСтроки(СтрокаПП) Экспорт
	Контрагент				= СтрокаПП.Контрагент;
	
	Реквизиты	= Новый Структура("Округ,КоличествоТМ,Менеджер",Контрагент.Регион.Округ,Контрагент.КоличествоТорговыхМарок,Контрагент.Менеджер);
	ЗаполнитьЗначенияСвойств(СтрокаПП,Реквизиты);
КонецПроцедуры

Процедура ЗаполнитьПродажиКлиентов() Экспорт
	ДатыПланирования= ПолучитьДатыПланирования();
	Запрос			= СоздатьЗапросПоПродажам(ДатыПланирования,ПланПродаж.ВыгрузитьКолонку("Контрагент"));	
	
	ВыборкаПоПокупателям=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Контрагент");
	Пока ВыборкаПоПокупателям.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();		
		#КОНЕЦЕСЛИ 
		
		ВыборкаПоБрендам	= ВыборкаПоПокупателям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Бренд");	
		Пока ВыборкаПоБрендам.Следующий() Цикл
			ВыборкаПоТипуТовара=ВыборкаПоБрендам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ТипТовара");
			Пока ВыборкаПоТипуТовара.Следующий() Цикл				
				СтруктураПоиска=Новый Структура("Контрагент,Бренд,ТипТовара");				
				ЗаполнитьЗначенияСвойств(СтруктураПоиска,ВыборкаПоТипуТовара);
				СтрокиТЧ=ПланПродаж.НайтиСтроки(СтруктураПоиска);
				Для Каждого СтрокаТЧ Из СтрокиТЧ Цикл
					СтрокаТЧ.КоэффициентУдорожания	= ВыборкаПоТипуТовара.КоэффициентУдорожания;				
					СтрокаТЧ.Всего					= ВыборкаПоТипуТовара.Оборот;														
					
					ВыборкаПоПГ=ВыборкаПоТипуТовара.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Год");						
					Пока ВыборкаПоПГ.Следующий() Цикл
						Если ВыборкаПоПГ.Год=1 Тогда
							СтрокаТЧ.ФактГод_1=ВыборкаПоПГ.Оборот;
						ИначеЕсли ВыборкаПоПГ.Год=2 Тогда
							СтрокаТЧ.ФактГод_2=ВыборкаПоПГ.Оборот;				
						КонецЕсли;
					КонецЦикла;
					
					СтрокаТЧ.КоличествоТМ	= ВыборкаПоПокупателям.КоличествоТМ;
					СтрокаТЧ.НачалоПродаж	= ВыборкаПоПокупателям.НачалоПродаж;
				
					СтрокаТЧ.Коэффициент		= 100+2.5*СтрокаТЧ.КоличествоТМ;
				
					Если СтрокаТЧ.НачалоПродаж>ДатыПланирования.Дата11 Тогда
						СтрокаТЧ.МесяцевПродаж=Месяц(ДатыПланирования.Дата12)-Месяц(СтрокаТЧ.НачалоПродаж)+1;
					ИначеЕсли СтрокаТЧ.НачалоПродаж>ДатыПланирования.Дата21 Тогда		
						СтрокаТЧ.МесяцевПродаж=Месяц(ДатыПланирования.Дата22)-Месяц(СтрокаТЧ.НачалоПродаж)+1+6;
					Иначе
						СтрокаТЧ.МесяцевПродаж=12;					
					КонецЕсли; 
				КонецЦикла;				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Функция СоздатьЗапросПоПродажам(ДатыПланирования,СписокКонтрагентов=Неопределено) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ Бренд,ТипТовара ПОМЕСТИТЬ Товары ИЗ &Товары КАК Товары
	|;
	|ВЫБРАТЬ Подразделение ПОМЕСТИТЬ Подразделения ИЗ &Подразделения КАК Подразделения
	|;	
	|ВЫБРАТЬ	
	|	Сводный.Год,
	|	Сводный.Бренд,
	|	Сводный.ТипТовара,	
	|	Сводный.Контрагент,		
	|	Сводный.Контрагент.Регион.Округ КАК Округ,		
	|
	|	МАКСИМУМ(IsNULL(КоэффУД.Коэффициент,100))	КАК КоэффициентУдорожания,
	|	МАКСИМУМ(КоличествоТМ)						КАК КоличествоТМ,
	|	МИНИМУМ(Сводный.ПериодМесяц)				КАК НачалоПродаж,		
	|	СУММА(Оборот)								КАК Оборот	
	|ИЗ
	|(
	|ВЫБРАТЬ
	|	1 КАК Год,
	|	ПериодМесяц,		
	|	Номенклатура.Родитель.БрендДляПлана			КАК Бренд,
	|	Номенклатура.Родитель.ТипНоменклатуры	 	КАК ТипТовара,
	|	Подразделение,
	|	Покупатель.Ведущий 							КАК Контрагент,		
	|	Покупатель.Ведущий.КоличествоТорговыхМарок 	КАК КоличествоТМ,
	|	
	|	ПериодМесяц									КАК НачалоПродаж,		
	|	ОборотОборот 								КАК Оборот		
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(&Дата11,&Дата12,Авто,
	|		Подразделение В (ВЫБРАТЬ РАЗЛИЧНЫЕ Подразделение ИЗ Подразделения)
	|		И (Номенклатура.Родитель.БрендДляПлана,Номенклатура.Родитель.ТипНоменклатуры) В (ВЫБРАТЬ РАЗЛИЧНЫЕ Бренд,ТипТовара ИЗ Товары)
	|	"+	?(ЗначениеЗаполнено(СписокКонтрагентов),"И Покупатель.Ведущий В (&СписокКонтрагентов)","")+"
	|	) КАК ПродажиОбороты
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	2 КАК Год,
	|	ПериодМесяц,		
	|	Номенклатура.Родитель.БрендДляПлана			КАК Бренд,
	|	Номенклатура.Родитель.ТипНоменклатуры	 	КАК ТипТовара,
	|	Подразделение,
	|	Покупатель.Ведущий 							КАК Контрагент,		
	|	Покупатель.Ведущий.КоличествоТорговыхМарок 	КАК КоличествоТМ,
	|	
	|	ПериодМесяц									КАК НачалоПродаж,		
	|	ОборотОборот 								КАК Оборот		
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(&Дата21,&Дата22,Авто,
	|		Подразделение В (ВЫБРАТЬ РАЗЛИЧНЫЕ Подразделение ИЗ Подразделения)
	|		И (Номенклатура.Родитель.БрендДляПлана,Номенклатура.Родитель.ТипНоменклатуры) В (ВЫБРАТЬ РАЗЛИЧНЫЕ Бренд,ТипТовара ИЗ Товары)
	|	"+	?(ЗначениеЗаполнено(СписокКонтрагентов),"И Покупатель.Ведущий В (&СписокКонтрагентов)","")+"
	|	) КАК ПродажиОбороты
	|) КАК Сводный
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.КоэффициентыУдорожания КАК КоэффУД
	|ПО
	|	Сводный.Бренд		= КоэффУД.Бренд
	|	И Сводный.ТипТовара	= КоэффУД.ТипТовара		
	|	И КоэффУД.Период	= НАЧАЛОПЕРИОДА(&Дата1,Год)
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Год,	
	|	Сводный.Контрагент,
	|	Сводный.Бренд,
	|	Сводный.ТипТовара
	|АВТОУПОРЯДОЧИВАНИЕ
	|ИТОГИ 
	|	СУММА(Оборот),
	|	МИНИМУМ(НачалоПродаж),
	|	МАКСИМУМ(КоличествоТМ),
	|	МАКСИМУМ(КоэффициентУдорожания), 
	|	МАКСИМУМ(Округ)
	|ПО 
	|	Сводный.Контрагент,Сводный.Бренд,Сводный.ТипТовара,Сводный.Год
	|";	
	
	
	Запрос.УстановитьПараметр("Подразделения",	Подразделения);
	Запрос.УстановитьПараметр("Товары",			Товары);
	Если ЗначениеЗаполнено(СписокКонтрагентов) Тогда
		Запрос.УстановитьПараметр("СписокКонтрагентов",	СписокКонтрагентов);	
	КонецЕсли; 
	
	
	Для Каждого Элемент Из ДатыПланирования Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);	
	КонецЦикла;
	
	Возврат Запрос;
КонецФункции //СоздатьЗапросПоПродажам()

