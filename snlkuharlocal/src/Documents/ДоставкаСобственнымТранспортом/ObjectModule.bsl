Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
		ПериодРасходовТранспорт = Неопределено;
		Для Каждого СтрокаТЧ Из Услуги Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.ПериодРасходов) Тогда
				ПериодРасходовТранспорт = СтрокаТЧ.ПериодРасходов ;	
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ПериодРасходовТранспорт = Неопределено Тогда
			ПериодРасходовТранспорт = '00010101';
		КонецЕсли;
		
		
		ВсегоРаспределено = 0;
		Движение = Неопределено;
		ТЗ=ДокументыТранспортнойкомпании.Выгрузить();
		ТЗ.Свернуть("ПунктДоставки","Количество");
		тз.Колонки.Добавить("КоэффициентСложности");
		Для каждого СтрТЗ из тз цикл
			если СтрТЗ.ПунктДоставки.КоэффициентСложностиДоставки=Справочники.КоэффициентыСложностиДоставки.ПустаяСсылка() тогда
				СтрТЗ.КоэффициентСложности=1.6;
			иначе
				СтрТЗ.КоэффициентСложности=СтрТЗ.ПунктДоставки.КоэффициентСложностиДоставки.КоэффициентСложности;
			КонецЕсли;	
			если СтрТЗ.Количество>20000 тогда
				СтрТЗ.КоэффициентСложности=СтрТЗ.КоэффициентСложности+6.4;
			ИначеЕсли СтрТЗ.Количество>10000 тогда
				СтрТЗ.КоэффициентСложности=СтрТЗ.КоэффициентСложности+4.8;
			ИначеЕсли СтрТЗ.Количество>5000 тогда
				СтрТЗ.КоэффициентСложности=СтрТЗ.КоэффициентСложности+3.2;			
			ИначеЕсли СтрТЗ.Количество>1500 тогда
				СтрТЗ.КоэффициентСложности=СтрТЗ.КоэффициентСложности+1.6;			
			КонецЕсли;	
		КонецЦикла;	
		ОбщийКоэффициентСложности=ТЗ.Итог("КоэффициентСложности");
		
		//Теперь размазываем ещё и по услугам пропорционально сумме
		для каждого СтрУслуги из Услуги цикл
			Коэффициент=СтрУслуги.Всего/СуммаДокумента;
			
			для каждого Накл из ДокументыТранспортнойкомпании цикл
				если накл.Документ=Неопределено тогда Продолжить;
				КонецЕсли;
				Движение = Движения.РаспределениеУСОпоНакладным.Добавить();	
				Движение.ВидДвижения		= ВидДвиженияНакопления.Приход;		
				Движение.Период				=Дата;	
				Движение.Накладная=накл.Документ.Ссылка;
				Движение.ОбъемНаладной=Накл.Объем;
				СтрокаСвернТЗ=тз.Найти(накл.ПунктДоставки);
				ТекКоэффициентСложности=СтрокаСвернТЗ.КоэффициентСложности;
				КоэффКоличества=Накл.Количество/СтрокаСвернТЗ.Количество;							
				
				ТекКоэффициентСложности=КоэффКоличества*ТекКоэффициентСложности;
				
				Движение.РаспределеннаяСумма=Окр(ТекКоэффициентСложности*СуммаДокумента/ОбщийКоэффициентСложности,2);
				
				//Размазываем отдельно по услугам
				Движение.РаспределеннаяСумма=Движение.РаспределеннаяСумма*Коэффициент;
				Движение.ВидУслуги=СтрУслуги.ВидУслуги;
				
				
				ВсегоРаспределено = ВсегоРаспределено + Движение.РаспределеннаяСумма;
				
				если накл.Документ.метаданные().имя<>"ЗаявкаВТранспортныйОтдел" тогда 
					движение.СуммаНакладной=Накл.Документ.СуммаДокумента;
					если Накл.Документ.ПунктДоставки.ТипДоставки<>Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
						движение.ПунктДоставки=Накл.Документ.ПунктДоставки;           
					Иначе 
						движение.ПунктДоставки=Накл.Документ.ПунктДоставки.ПунктПерегруза;
					КонецЕсли;
				иначе
					движение.СуммаНакладной=0;
					движение.ПунктДоставки=Накл.Документ.ПунктДоставкиПолучатель;
				КонецЕсли;	
				движение.КоличествоНакладной=Накл.Документ.КоличествоДокумента;
				движение.КоличествоКоробок=Накл.Документ.КоличествоКоробок;
				движение.ДатаОтгрузки=Накл.Документ.ДатаОтгрузки;
				Если ЗначениеЗаполнено(Накл.ПериодРасходов) Тогда
					Движение.ПериодРасходов = Накл.ПериодРасходов;
				Иначе
					Движение.ПериодРасходов = ПериодРасходовТранспорт;
				КонецЕсли;
				
				если накл.Документ.метаданные().имя<>"Перемещение" и накл.Документ.метаданные().имя<>"ЗаявкаВТранспортныйОтдел" тогда
					движение.Контрагент=накл.Документ.Контрагент;
					движение.Подразделение=накл.Документ.Подразделение;
				ИначеЕсли накл.Документ.метаданные().имя="ЗаявкаВТранспортныйОтдел" тогда	
					если накл.Документ.отправитель.Метаданные().Имя="Контрагенты" тогда
						движение.Контрагент=накл.Документ.отправитель;
						если  накл.Документ.Получатель.Метаданные().Имя="Контрагенты" тогда
							движение.Подразделение=накл.Документ.Получатель.Менеджер.Подразделение;
						иначе
							движение.Подразделение=накл.Документ.Получатель.Подразделение;
						КонецЕсли;

					ИначеЕсли накл.Документ.получатель.Метаданные().Имя="Контрагенты" тогда
						движение.Контрагент=накл.Документ.получатель;
						движение.Подразделение=накл.Документ.Отправитель.Подразделение;
					иначе
						движение.Подразделение=накл.Документ.Получатель.Подразделение;				
					КонецЕсли;
					если накл.Документ.Подразделение<>справочники.Подразделения.ПустаяСсылка() тогда
						движение.Подразделение=накл.Документ.Подразделение;
					КонецЕсли;
				иначе
					движение.Подразделение=накл.Документ.складполучатель.Подразделение;	
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;	
		Если ВсегоРаспределено <> СуммаДокумента И Движение <> Неопределено И Дата >= '20130701' Тогда
			Движение.РаспределеннаяСумма = Движение.РаспределеннаяСумма + (СуммаДокумента-ВсегоРаспределено);	
		КонецЕсли;
	
КонецПроцедуры


