Процедура ЗаполнитьНоменклатуру(Паллета,Накладная = неопределено) Экспорт
	//++Данилова Е.В. 05.02.2026 OUT-19 
	Если Накладная <> Неопределено Тогда
		СтрокиНакладной = Паллета.Товары.НайтиСтроки(Новый Структура("Накладная",Накладная));
		Для каждого СтрокаНакладной Из СтрокиНакладной Цикл
		
			Паллета.Товары.Удалить(СтрокаНакладной); 	
		
		КонецЦикла;
		//как заглушка, чтобы избежать сейчас пустых строк по накладной 
		СтрокиНакладной = Паллета.Товары.НайтиСтроки(Новый Структура("Накладная",Неопределено));
		Для каждого СтрокаНакладной Из СтрокиНакладной Цикл
		
			Паллета.Товары.Удалить(СтрокаНакладной); 	
		
		КонецЦикла;
	Иначе
		Паллета.Товары.Очистить();
	КонецЕсли;
	//--Данилова Е.В. 05.02.2026
	СписокЛН = Паллета.ЛистыНабора.Выгрузить(); 
	//++Данилова Е.В. 04.02.2026 OUT-191
	//СписокЛН.Свернуть("ЛистНабора");
	СписокЛН.Свернуть("ЛистНабора,Документ");
	//--Данилова Е.В. 04.02.2026
	
	ТЗ = Новый ТаблицаЗначений;
	
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Количество");
	//++Данилова Е.В. 04.02.2026 OUT-191
	ТЗ.Колонки.Добавить("Накладная");
	//--Данилова Е.В. 04.02.2026
	
	Для Каждого СтрокаТЗ Из СписокЛН Цикл
		
		ЛН = СтрокаТЗ.ЛистНабора;
		
		Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда			
			
			МассСтрок = Паллета.ЛистыНабора.НайтиСтроки(Новый Структура("ЛистНабора", ЛН));
			СписокКоробок = ПолучитьСписокШКкоробокЛистаНабораПаллетная(ЛН); 		
			Для Каждого СтрМассСтрок Из МассСтрок Цикл
				
				СтрокаКоробки = СписокКоробок.Найти(СтрМассСтрок.ШКЛистаНабора);
				
				Если СтрокаКоробки <> Неопределено Тогда
					
					СтрТЗ = ТЗ.Добавить();
					
					СтрТЗ.Номенклатура = СтрокаКоробки.номенклатура;
					СтрТЗ.количество = СтрокаКоробки.КоличествоВКоробе;
					//++Данилова Е.В. 04.02.2026 OUT-191
					СтрТЗ.Накладная = СтрокаТЗ.Документ; 
					//--Данилова Е.В. 04.02.2026
					
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтрТЧТоварыЛН Из ЛН.Товары Цикл
				
				СтрТЗ = ТЗ.Добавить();
				
				СтрТЗ.Номенклатура = СтрТЧТоварыЛН.Номенклатура;
				СтрТЗ.Количество = СтрТЧТоварыЛН.Количество;
				//++Данилова Е.В. 04.02.2026 OUT-191
				СтрТЗ.Накладная = СтрокаТЗ.Документ; 
				//--Данилова Е.В. 04.02.2026

				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	//++Данилова Е.В. 04.02.2026 OUT-191
	//ТЗ.Свернуть("Номенклатура","Количество");
	ТЗ.Свернуть("Номенклатура,Накладная","Количество");
	//++Данилова Е.В. 24.03.2026 ASU-2089
	ТЗ.Колонки.Добавить("Продукция",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Если ЗначениеЗаполнено(Накладная) Тогда 
		ЗаполнитьПродукцииВТаблицеТоваровПоНакладной(ТЗ,Накладная);
	Иначе
		ТЗНаклКопия = ТЗ.Скопировать(,"Накладная"); 
		ТЗНаклКопия.Свернуть("Накладная");
		МассивНакладных = ТЗНаклКопия.ВыгрузитьКолонку("Накладная"); 
		Для каждого НакладнаяИз Из МассивНакладных Цикл
		
			ЗаполнитьПродукцииВТаблицеТоваровПоНакладной(ТЗ,НакладнаяИз);	
		
		КонецЦикла;
		
	КонецЕсли;
	//--Данилова Е.В. 24.03.2026 
	Если Накладная <> Неопределено Тогда 
		СтрокиНакладной = ТЗ.НайтиСтроки(новый Структура("Накладная",Накладная)); 
		Для каждого СтрокаНакладной Из СтрокиНакладной Цикл
			
			НоваяСтрока = Паллета.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаНакладной); 	
			
		КонецЦикла;
		
	Иначе 	
		Паллета.Товары.Загрузить(ТЗ);
	КонецЕсли;
	//--Данилова Е.В. 04.02.2026
КонецПроцедуры

// Кельманов А.В. - HELP-2579 - 2025.01.16
Функция ПолучитьСписокШКкоробокЛистаНабораПаллетная(ЛН) Экспорт 
	//++Данилова Е.В. 23.04.2026  MARK-3539
	Если ТипЗнч(ЛН)=Тип("ДокументСсылка.ЛистНабора") Тогда
		ТипДокумента="ЛистНабора";
	иначе
		ТипДокумента="ЛистПереукладки";
	КонецЕсли;
	//--Данилова Е.В. 23.04.2026 	
	ТЗ = Новый таблицазначений;
	
	ТЗ.Колонки.Добавить("НомерКоробкиЛН");	
	ТЗ.Колонки.Добавить("НомерКоробки");
	ТЗ.Колонки.Добавить("ШК");		
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("КоличествоВКоробе");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	СУММА(ЛистНабора.КоличествоКоробок) КАК КоличествоКоробок
	|ИЗ
	|	Документ.ЛистНабора КАК ЛистНабора
	|ГДЕ
	|	ЛистНабора.Проведен
	|	И ЛистНабора.Дата < &Дата
	|	И ЛистНабора.ДокОснование = &ДокОснование
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("ДокОснование", ЛН.ДокОснование);
	Запрос.УстановитьПараметр("Дата", ЛН.Дата);
	//++Данилова Е.В. 23.04.2026 MARK-3539
	Запрос.Текст=СтрЗаменить(запрос.Текст,"ЛистНабора",ТипДокумента);
	//НомерНачКоробки = 1;
	//--Данилова Е.В. 23.04.2026
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока РезультатЗапроса.Следующий() Цикл
		
		Если РезультатЗапроса.КоличествоКоробок = Null Тогда 
			
			Продолжить;
			
		КонецЕсли;
		//++Данилова Е.В. 23.04.2026 MARK-3539
		//НомерНачКоробки = НомерНачКоробки + РезультатЗапроса.КоличествоКоробок;
		//--Данилова Е.В. 23.04.2026
	КонецЦикла;
    //++Данилова Е.В. 23.04.2026 MARK-3539
	//Запрос = Новый Запрос;
	//
	//Запрос.Текст = "ВЫБРАТЬ
	//|	ЛистНабора.Номер,
	//|	ЛистНабора.КоличествоКоробок
	//|ИЗ
	//|	Документ.ЛистНабора КАК ЛистНабора
	//|ГДЕ
	//|	ЛистНабора.Проведен
	//|	И ЛистНабора.Дата = &Дата
	//|	И ЛистНабора.ДокОснование = &ДокОснование
	//|	И ЛистНабора.Ссылка <> &Ссылка
	//|АВТОУПОРЯДОЧИВАНИЕ";
	//
	//Запрос.УстановитьПараметр("ДокОснование",ЛН.ДокОснование);
	//Запрос.УстановитьПараметр("Дата", ЛН.Дата);
	//Запрос.УстановитьПараметр("Ссылка", ЛН.Ссылка);
	//
	//Рез = Запрос.Выполнить().Выбрать();
	//
	//Пока Рез.Следующий() Цикл
	//	
	//	Если Число(Прав(Рез.Номер, 5)) < Число(Прав(ЛН.Номер, 5)) Тогда
	//		
	//		НомерНачКоробки = НомерНачКоробки + Рез.КоличествоКоробок;
	//		
	//	КонецЕсли;
	//	
	//КонецЦикла;
    //--Данилова Е.В. 23.04.2026
	Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда
		
		ТабНоменклатурыПоКоробам = Новый ТаблицаЗначений;
		
		ТабНоменклатурыПоКоробам.Колонки.Добавить("Номенклатура");
		ТабНоменклатурыПоКоробам.Колонки.Добавить("КоличествоВКоробе");
		
		Для Каждого СтрокаТЧ Из ЛН.Товары Цикл
			
			КоличествоКоробов = ?(СтрокаТЧ.ШтВКоробе = 0, СтрокаТЧ.Количество, СтрокаТЧ.Количество / СтрокаТЧ.ШтВКоробе);
			
			// Кухарь А.Ю.  24.05.2026 начало
			// HELP-9898
			если КоличествоКоробов < 1 и КоличествоКоробов > 0 тогда  
				СтрокаТЧ.ШтВКоробе =  СтрокаТЧ.Количество;
				КоличествоКоробов  = 1;
			КонецЕсли;
			// Кухарь А.Ю.  24.05.2026 конец
			
			Для СчКоробов = 1 По КоличествоКоробов Цикл
				
				СтрТабНом = ТабНоменклатурыПоКоробам.Добавить();
				
				СтрТабНом.Номенклатура = СтрокаТЧ.Номенклатура;
				СтрТабНом.КоличествоВКоробе = ?(СтрокаТЧ.ШтВКоробе = 0, 1, СтрокаТЧ.ШтВКоробе);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;

	Для Сч = 1 По ЛН.КоличествоКоробок Цикл 
		
		СтрТЗ = ТЗ.Добавить();
		
		СтрТЗ.НомерКоробкиЛН = Сч;
		//++Данилова Е.В. 23.04.2026 MARK-3539
		НомерКоробки = 0; 
		Если ТипДокумента = "ЛистНабора" тогда 
			ТекШК = ЛН.ШКЛистаНабора + формат(Сч, "ЧЦ=5; ЧВН=");
			СтрокаНумерации = ЛН.НомераКоробок.Получить(Сч-1); 
			Если СтрокаНумерации <> неопределено Тогда
				
				НомерКоробки = СтрокаНумерации.НомерКоробки; 	
				
			КонецЕсли;
		Иначе
			//для отсканированной коробки в лп кодируется лист и номер коробки
			НомерКоробки = ЛН.НомерКоробки;
			ТекШК = ЗакодироватьЛистИКоробкуВСтроку(ЛН,НомерКоробки); 		 
		КонецЕсли;
		
		//--Данилова Е.В. 23.04.2026
		//++Данилова Е.В. 23.04.2026 MARK-3539 
		Если ТипДокумента = "ЛистНабора" тогда 
			// Кухарь А.Ю.  11.02.2026 начало   
			//ТекШК = ТекШК + КонтрольныйСимволEAN(ТекШК, 13); 
			// HELP-8843
			если СтрДлина(ТекШК) > 5 тогда 
				ТекШК = ТекШК + КонтрольныйСимволEAN(ТекШК, 13);        
			иначе 
				//++Данилова Е.В. 23.04.2026 MARK-3539
				//ТекШК = ЗакодироватьЛистИКоробкуВСтроку(ЛН,НомерНачКоробки + Сч - 1);
				ТекШК = ЗакодироватьЛистИКоробкуВСтроку(ЛН,НомерКоробки);
				//--Данилова Е.В. 23.04.2026 
			КонецЕсли; 
			// Кухарь А.Ю.  11.02.2026 конец
		КонецЕсли;
		//--Данилова Е.В. 23.04.2026 
		
		СтрТЗ.ШК = ТекШК;
		//++Данилова Е.В. 23.04.2026 MARK-3539
		//СтрТЗ.НомерКоробки = НомерНачКоробки + Сч - 1;
		СтрТЗ.НомерКоробки = НомерКоробки;
		//--Данилова Е.В. 23.04.2026
		Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда
			
			СтрТЗ.Номенклатура = ТабНоменклатурыПоКоробам.Получить(Сч - 1).Номенклатура;
			СтрТЗ.КоличествоВКоробе = ТабНоменклатурыПоКоробам.Получить(Сч - 1).КоличествоВКоробе;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТЗ;	

КонецФункции 

