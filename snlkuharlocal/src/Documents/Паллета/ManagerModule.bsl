//++Данилова Е.В. 24.03.2026 ASU-2089  
 Процедура ЗаполнитьПродукцииВТаблицеТоваровПоНакладной(ТЗТовары,Знач Накладная) экспорт
     ТЗТоварыКопия = ТЗТовары.Скопировать(); 
	 
	 СтрокиНакладной = ТЗТовары.НайтиСтроки(Новый Структура("Накладная",Накладная));
	 Для каждого СтрокаНакладной Из СтрокиНакладной Цикл
		 
		 ТЗТовары.Удалить(СтрокаНакладной); 	
		 
	 КонецЦикла; 
	 
	 Запрос = Новый Запрос;
	 Если Накладная.ОтгрузкаКомплектов Тогда 		 
		 Запрос.Текст = 
		 "ВЫБРАТЬ
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
		 |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
		 |	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
		 |ИЗ
		 |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		 |ГДЕ
		 |	РасходнаяНакладнаяКомплектующие.Ссылка = &Ссылка
		 |
		 |СГРУППИРОВАТЬ ПО
		 |	РасходнаяНакладнаяКомплектующие.Продукция,
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура";
		 
		 Запрос.УстановитьПараметр("Ссылка", Накладная); 	  	 	 
		 
	 Иначе 
		 Запрос.Текст = 
		 "ВЫБРАТЬ
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Продукция,
		 |	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
		 |ИЗ
		 |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяКомплектующие
		 |ГДЕ
		 |	РасходнаяНакладнаяКомплектующие.Ссылка = &Ссылка
		 |
		 |СГРУППИРОВАТЬ ПО
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура,
		 |	РасходнаяНакладнаяКомплектующие.Номенклатура";
		 
		 Запрос.УстановитьПараметр("Ссылка", Накладная); 		 
		 
	 КонецЕсли;
	 
	 ТаблицаТоваров = Запрос.Выполнить().Выгрузить();
	 ТаблицаТоваров.Колонки.Добавить("ЕстьВЛН",Новый ОписаниеТипов("Булево"));
	  
	  
	 Для каждого СтрокаТоваров  Из ТЗТоварыКопия Цикл
		 Если СтрокаТоваров.Накладная <> Накладная  Тогда
			 
			 Продолжить; 	
			 
		 КонецЕсли;
		 КоличествоТовараВПаллете = СтрокаТоваров.Количество;
		 Отбор = Новый Структура("Номенклатура",СтрокаТоваров.Номенклатура);
		 СтрокиНайденные = ТаблицаТоваров.НайтиСтроки(Отбор);
		 
		 Для каждого СтрокаНайденные Из СтрокиНайденные Цикл 
			 
			 Если КоличествоТовараВПаллете = 0 Тогда
				 
				 Прервать; 
				 
				 
			 КонецЕсли;
			 
			 Кол = Мин(КоличествоТовараВПаллете,СтрокаНайденные.Количество);
			
			 
			 НоваяСтрока = ТЗТовары.Добавить(); 
			 ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТоваров); 
			 НоваяСтрока.Количество = Кол; 
			 НоваяСтрока.Продукция = СтрокаНайденные.Продукция; 
			 
			 КоличествоТовараВПаллете = КоличествоТовараВПаллете - Кол; 
			 
		 КонецЦикла;
		 
	 КонецЦикла;

	 
 КонецПроцедуры
 //--Данилова Е.В. 24.03.2026 
 
 //Валетов + Фоновая запись паллет
 Процедура  ФоновоеПроведениеПаллет(ТабПаллет) Экспорт  
	 Накладная = ТабПаллет.Документ;
	 НовоеСостояние = ТабПаллет.НовоеСостояние;  
	 КолОшибокПРоведения = 0;
	 КолОшибокБлокировок = 0;
	 
	 //ПланНабора 
	 Запрос = Новый Запрос;
	 запрос.Текст = "ВЫБРАТЬ
	 |	ПланНабора.Ссылка КАК Ссылка
	 |ИЗ
	 |	Документ.ПланНабора КАК ПланНабора
	 |ГДЕ
	 |	ПланНабора.Проведен
	 |	И ПланНабора.ДокОснование = &РНК";
	 запрос.УстановитьПараметр("РНК",Накладная);
	 
	 результат=запрос.Выполнить().Выбрать();
	 пока результат.Следующий() цикл
		 
		 ПланНабора = результат.ссылка.ПолучитьОбъект();
		 Для Каждого СтрТБ Из ПланНабора.тБрэндов Цикл
			 Если Не ЗначениеЗаполнено(СтрТБ.НачалоПаллетирования) Тогда
				 СтрТБ.НачалоПаллетирования=ТекущаяДата();
			 КонецЕсли;
			 СтрТБ.Состояние=НовоеСостояние;
		 КонецЦикла;
		 Попытка
			 ПланНабора.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);  
		 Исключение 
			 КолОшибокПРоведения = КолОшибокПРоведения + 1;
			 Если СтрНайти(ОписаниеОшибки(),"блокиров") > 0 Тогда
				 КолОшибокБлокировок = КолОшибокБлокировок + 1;
			 КонецЕсли;
		 КонецПопытки;
	 КонецЦикла;
	 
	 //ЗНБ 
	 Запрос=новый запрос;
	 запрос.Текст= "ВЫБРАТЬ
	 |	ЗаданиеНабора.Ссылка КАК Ссылка
	 |ИЗ
	 |	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	 |ГДЕ
	 |	ЗаданиеНабора.Накладная = &Накладная
	 |	И ЗаданиеНабора.Проведен
	 |	И ЗаданиеНабора.СостояниеНакладной <> &СостояниеНакладной";
	 запрос.УстановитьПараметр("Накладная",Накладная);
	 запрос.УстановитьПараметр("СостояниеНакладной",НовоеСостояние);
	 результат=запрос.Выполнить().Выбрать();
	 пока результат.Следующий() цикл
		 ЗНБ=результат.ссылка.получитьобъект();
		 ЗНБ.СостояниеНакладной=НовоеСостояние;
		 ЗНБ.ОбменДанными.Загрузка=Истина; 
		 Попытка
			 знб.Записать();
		 Исключение 
			 КолОшибокПРоведения = КолОшибокПРоведения + 1;
			 Если СтрНайти(ОписаниеОшибки(),"блокиров") > 0 Тогда
				 КолОшибокБлокировок = КолОшибокБлокировок + 1;
			 КонецЕсли;
		 КонецПопытки;
	 КонецЦикла;  
	 
	 ТЗНеизменяемыхРеквизитов=новый ТаблицаЗначений;
	 ТЗНеизменяемыхРеквизитов.Колонки.Добавить("ИмяРеквизита");
	 СтрТЗ=ТЗНеизменяемыхРеквизитов.Добавить();
	 СтрТЗ.ИмяРеквизита="КоличествоКоробок";
	 СтрТЗ=ТЗНеизменяемыхРеквизитов.Добавить();
	 СтрТЗ.ИмяРеквизита="Трудозатраты";
	 
	 ДокументОбъект = Накладная.ПОлучитьОбъект(); 
	 Попытка 
		 ДокументОбъект.ЗаписьБезКонтроляПолномочий(ТЗНеизменяемыхРеквизитов); 
	 Исключение 
		 КолОшибокПРоведения = КолОшибокПРоведения + 1;
		 Если СтрНайти(ОписаниеОшибки(),"блокиров") > 0 Тогда
			 КолОшибокБлокировок = КолОшибокБлокировок + 1;
		 КонецЕсли;
	 КонецПопытки;   
	 
	 
 КонецПроцедуры
