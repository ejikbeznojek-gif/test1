 //++Данилова Е.В. 05.03.2026 SNL-157 
 Функция РаспределитьSSCCКодыПоНакладной(Знач Накладная) Экспорт
	 
	 РезультатРаспределения = МаркировкаКС.СтруктураРезультата(Истина); 
	 	 
	 КолвоКодов = 0;
	 //проверим СИСИ кода
	 
	 Запрос = Новый Запрос;
	 
	 Запрос.Текст = "ВЫБРАТЬ
	 |	РеквизитыРНКПНКПРМ.ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &текдок
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита ПОДОБНО &рек";
	
	Запрос.УстановитьПараметр("ТекДок", Накладная);
	Запрос.УстановитьПараметр("рек", "СерийныйНомерУпаковки%");
	
	РезКоды = Запрос.Выполнить().Выгрузить();
	
	КолКодов = РезКоды.Количество();
	
	Если КолКодов = 0 Тогда
		Возврат РезультатРаспределения;
	КонецЕсли; 
	
	// Ихсанов Д. А. Начало 28.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7656
	// Получение данных по наличию экспозиторв по накладной
	МенеджерЗаписи = РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Документ = Накладная;
	МенеджерЗаписи.ИмяРеквизита = "Экспозитор";
	МенеджерЗаписи.Прочитать();
	
	лЭкспозитор = Неопределено;
	Если МенеджерЗаписи.Выбран()
		И ТипЗнч(МенеджерЗаписи.ЗначениеРеквизита) = Тип("СправочникСсылка.Номенклатура") Тогда
		лЭкспозитор = МенеджерЗаписи.ЗначениеРеквизита;
	КонецЕсли;
	// Ихсанов Д. А. Конец  28.10.2025
	
	// для клиента Лента, делаем распределение по листам Палетта. На складе.
	
	// Кухарь А.Ю.  10.04.2024 начало
	//	Если  КолКодов>1 и контрагент.Код = "SSR-1593"  и планыобмена.Основной.ЭтотУзел().ТипУзла = перечисления.ТипУзлаИБ.Склад  тогда  
	//++Данилова Е.В. 04.02.2026 
	Если ФормироватьНаборКодовАгрегацииНаПаллету(Накладная,Неопределено) Тогда 
		РезультатРаспределения = РаспределитьSSCCВРазрезеАртикуловВПаллете(РезКоды,Накладная);
	Иначе
		РезультатРаспределения = РаспределитьSSCCПоПаллетам(РезКоды,Накладная); 
	КонецЕсли;	
	//--Данилова Е.В. 04.02.2026  
	
	Возврат РезультатРаспределения; 
КонецФункции

Функция РаспределитьSSCCВРазрезеАртикуловВПаллете(РезКоды,Знач Накладная)  
	
	РезультатРаспределения = МаркировкаКС.СтруктураРезультата(ложь); 
	
	КолКодов = РезКоды.Количество(); 
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПаллетаЛистыНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|ГДЕ
	|	ПаллетаЛистыНабора.ЛистНабора.ДокОснование = &ТекРНК
	|	И ПаллетаЛистыНабора.Ссылка.Проведен";
	
	Запрос.УстановитьПараметр("ТекРНК", Накладная);
	
	РезПалетты = Запрос.Выполнить().Выгрузить();
	
	Для Каждого ТекПалетта Из РезПалетты Цикл
		
		Док = ТекПалетта.Ссылка.ПолучитьОбъект();    
		
		//++Данилова Е.В. 05.02.2026 OUT-191 						
		Документы.Паллета.ЗаполнитьНоменклатуру(Док,Накладная); 
		//--Данилова Е.В. 05.02.2026 
		Попытка
			// Кухарь А.Ю.  16.03.2026 начало
			если не Док.ДополнительныеСвойства.Свойство("НеКонтролироватьНаличиеКодовАгрегации") тогда
				Док.ДополнительныеСвойства.Вставить("НеКонтролироватьНаличиеКодовАгрегации",Истина)           
			КонецЕсли; 
			док.ДополнительныеСвойства.НеКонтролироватьНаличиеКодовАгрегации = Истина;  	 
			// Кухарь А.Ю.  16.03.2026 конец
			Док.Записать();	
			
		Исключение
			РезультатРаспределения.Ошибки.Добавить("Не удалось заполнить номенклатуру по  документу " + Строка(Док.ссылка) + " " +  ОписаниеОшибки());
		КонецПопытки;
		
		
	КонецЦикла;
	
	Если РезультатРаспределения.Ошибки.Количество() > 0 Тогда
	
		Возврат РезультатРаспределения; 	
	
	КонецЕсли;
	
	СтруктураДанных = Новый Структура("Номенклатура, ПунктДоставки, Договор, Дата, Контрагент, ПостояннаяАкция");
	
	ЗаполнитьЗначенияСвойств(СтруктураДанных, Накладная);
	
	ЗапросНоменклатура = Новый Запрос;
	
	ЗапросНоменклатура.Текст =
	"ВЫБРАТЬ
	|	ТЗ_Паллеты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Паллеты
	|ИЗ
	|	&ТЗ_Паллеты КАК ТЗ_Паллеты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	//++Данилова Е.В. 24.03.2026 ASU-2089  
	//|	ПаллетаТовары.Номенклатура КАК Номенклатура
	|	ПаллетаТовары.Продукция КАК Номенклатура
	//--Данилова Е.В. 24.03.2026 
	|ИЗ
	|	ВТ_Паллеты КАК ВТ_Паллеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Паллета.Товары КАК ПаллетаТовары
	|		ПО ВТ_Паллеты.Ссылка = ПаллетаТовары.Ссылка 
	//++Данилова Е.В. 04.02.2026 OUT-191
	|ГДЕ
	|	ПаллетаТовары.Накладная = &Накладная";
	ЗапросНоменклатура.УстановитьПараметр("Накладная", Накладная);
	//--Данилова Е.В. 04.02.2026 
	
	ЗапросНоменклатура.УстановитьПараметр("ТЗ_Паллеты", РезПалетты);
	
	ТЗ_Номенклатура = ЗапросНоменклатура.Выполнить().Выгрузить();
	
	МассивНоменклатуры = ТЗ_Номенклатура.ВыгрузитьКолонку("Номенклатура");
	
	СтруктураДанных.Номенклатура = МассивНоменклатуры;
	
	ТЗ_Матриц = ПолучитьТаблицуМатрицСрезПоследних(СтруктураДанных);
	
	ЗапросАртикулыКонтрагента = Новый Запрос;
	
	ЗапросАртикулыКонтрагента.Текст = "ВЫБРАТЬ
	|	ТЗ_Паллеты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Паллеты
	|ИЗ
	|	&ТЗ_Паллеты КАК ТЗ_Паллеты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗ_Матриц.Номенклатура КАК Номенклатура,
	|	ТЗ_Матриц.АртикулКонтрагента КАК АртикулКонтрагента
	|ПОМЕСТИТЬ ВТ_Матриц
	|ИЗ
	|	&ТЗ_Матриц КАК ТЗ_Матриц
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПаллетаТовары.Ссылка КАК Паллета,
	//++Данилова Е.В. 24.03.2026 ASU-2089
	//|	ПаллетаТовары.Номенклатура КАК Номенклатура,
	|	ПаллетаТовары.Продукция КАК Номенклатура,
	//--Данилова Е.В. 24.03.2026 
	|	ВТ_Матриц.АртикулКонтрагента КАК АртикулКонтрагента
	|ИЗ
	|	ВТ_Паллеты КАК ВТ_Паллеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Паллета.Товары КАК ПаллетаТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Матриц КАК ВТ_Матриц
	//++Данилова Е.В. 24.03.2026 ASU-2089 
	//|			ПО ПаллетаТовары.Номенклатура = ВТ_Матриц.Номенклатура
	|			ПО ПаллетаТовары.Продукция = ВТ_Матриц.Номенклатура
	//--Данилова Е.В. 24.03.2026 
	|		ПО ВТ_Паллеты.Ссылка = ПаллетаТовары.Ссылка
	//++Данилова Е.В. 04.02.2026 OUT-191
	|		И ПаллетаТовары.Накладная = &Накладная 
	//--Данилова Е.В. 04.02.2026 
	|
	|УПОРЯДОЧИТЬ ПО
	|	Паллета,
	|	ПаллетаТовары.НомерСтроки";
	
	ЗапросАртикулыКонтрагента.УстановитьПараметр("ТЗ_Паллеты", РезПалетты);		
	ЗапросАртикулыКонтрагента.УстановитьПараметр("ТЗ_Матриц", ТЗ_Матриц);
	//++Данилова Е.В. 04.02.2026 OUT-191
	ЗапросАртикулыКонтрагента.УстановитьПараметр("Накладная", Накладная);
	//--Данилова Е.В. 04.02.2026
	
	ТЗ_ПаллетыНоменклатураАртикулы = ЗапросАртикулыКонтрагента.Выполнить().Выгрузить();
	ТЗ_ПаллетыАртикулы = ТЗ_ПаллетыНоменклатураАртикулы.Скопировать();
	ТЗ_ПаллетыАртикулы.Свернуть("Паллета, АртикулКонтрагента");
	ТЗ_ПаллетыАртикулы.Колонки.Добавить("SSCCКод", Новый ОписаниеТипов("Строка"));
	
	ПаллетыАртикулыКоличество = ТЗ_ПаллетыАртикулы.Количество();
	
	Если ПаллетыАртикулыКоличество <> КолКодов Тогда
		
		//Предупреждение("Кол-во SSCC кодов документа: " + КолКодов + "; Требуется SSCC кодов: " + ПаллетыАртикулыКоличество);
		РезультатРаспределения.Ошибки.Добавить("Кол-во SSCC кодов документа: " + КолКодов + "; Требуется SSCC кодов: " + ПаллетыАртикулыКоличество); 
		Возврат РезультатРаспределения;
		
	Иначе
		
		Счетчик = 0;
		
		Для Каждого Стр Из ТЗ_ПаллетыАртикулы Цикл
			
			Стр.SSCCкод = РезКоды[Счетчик].ЗначениеРеквизита;
			
			Счетчик = Счетчик + 1;
			
		Конеццикла;
		
		Для Каждого ТекПалетта Из РезПалетты Цикл
			
			Док = ТекПалетта.Ссылка.ПолучитьОбъект();
			
			//++Данилова Е.В. 04.02.2026 OUT-191  
			СтрокиТоваровРНК = Док.Товары.НайтиСтроки(новый Структура("Накладная",Накладная)); 
			//Для Каждого СтрТовары Из Док.Товары Цикл
			Для Каждого СтрТовары Из СтрокиТоваровРНК Цикл
				//--Данилова Е.В. 04.02.2026
				//++Данилова Е.В. 24.03.2026 ASU-2089
				//ПаллетаНоменклатура = Новый Структура("Паллета, Номенклатура", ТекПалетта.Ссылка, СтрТовары.Номенклатура);
				ПаллетаНоменклатура = Новый Структура("Паллета, Номенклатура", ТекПалетта.Ссылка, СтрТовары.Продукция);
				//--Данилова Е.В. 24.03.2026 
				СтрокиАртикул = ТЗ_ПаллетыНоменклатураАртикулы.НайтиСтроки(ПаллетаНоменклатура);
				
				АртикулКонтрагента = СтрокиАртикул[0].АртикулКонтрагента;
				
				ПаллетаАртикул = Новый Структура("Паллета, АртикулКонтрагента", ТекПалетта.Ссылка, АртикулКонтрагента);
				
				СтрокиSSCCКод = ТЗ_ПаллетыАртикулы.НайтиСтроки(ПаллетаАртикул);
				
				СтрТовары.SSCCКод = СтрокиSSCCКод[0].SSCCКод;
				
			Конеццикла;
			
			Попытка
				// Кухарь А.Ю.  16.03.2026 начало
				если не Док.ДополнительныеСвойства.Свойство("НеКонтролироватьНаличиеКодовАгрегации") тогда
					Док.ДополнительныеСвойства.Вставить("НеКонтролироватьНаличиеКодовАгрегации",Истина)           
				КонецЕсли; 
				док.ДополнительныеСвойства.НеКонтролироватьНаличиеКодовАгрегации = Истина;  	 
				// Кухарь А.Ю.  16.03.2026 конец
				
				Док.Записать();	
				
			Исключение
				РезультатРаспределения.Ошибки.Добавить("Не удалось записать документ: " + Строка(Док.ссылка) + " " +  ОписаниеОшибки()); 
			КонецПопытки;
			
			
		КонецЦикла;
		
	КонецЕсли; 
	
	РезультатРаспределения.Успешно = РезультатРаспределения.Ошибки.Количество() = 0; 
	Возврат РезультатРаспределения; 
	
КонецФункции

Функция РаспределитьSSCCПоПаллетам(РезКоды,Знач Накладная)
	
	РезультатРаспределения = МаркировкаКС.СтруктураРезультата(ложь); 
	
	КолКодов = РезКоды.Количество(); 
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПаллетаЛистыНабора.Ссылка
	|ИЗ
	|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|ГДЕ
	|	ПаллетаЛистыНабора.ЛистНабора.ДокОснование = &ТекРНК
	//нечаева 27,12,16+++
	|	И ПаллетаЛистыНабора.Ссылка.Проведен = истина";
	//нечаева 27,12,16---
	
	Запрос.УстановитьПараметр("ТекРНК", Накладная);
	
	РезПалетты = Запрос.Выполнить().Выгрузить();
	
	КолПаллет = РезПалетты.Количество();
	
	Если колПаллет <> КолКодов Тогда
		
		//Предупреждение("Не совпадает кол-во паллет и SSCC кодов документа!");
		РезультатРаспределения.Ошибки.Добавить("Не совпадает кол-во паллет и SSCC кодов документа!"); 
		Возврат РезультатРаспределения;  		
		
	Иначе
		
		рр = 0;
		
		Для Каждого ТекПалетта Из РезПалетты Цикл
			
			Док = ТекПалетта.Ссылка.ПолучитьОбъект();
			
			//++Данилова Е.В. 09.02.2026 OUT-191 						
			Документы.Паллета.ЗаполнитьНоменклатуру(Док,Накладная);
			
			Для каждого СтрокаТоваров  Из Док.Товары Цикл
			
				СтрокаТоваров.SSCCКод = РезКоды[рр].ЗначениеРеквизита; 	
			
			КонецЦикла;
			//--Данилова Е.В. 09.02.2026
			
			Док.SSCCкод = РезКоды[рр].ЗначениеРеквизита;  
			Попытка
				// Кухарь А.Ю.  16.03.2026 начало
				если не Док.ДополнительныеСвойства.Свойство("НеКонтролироватьНаличиеКодовАгрегации") тогда
					Док.ДополнительныеСвойства.Вставить("НеКонтролироватьНаличиеКодовАгрегации",Истина)           
				КонецЕсли; 
				док.ДополнительныеСвойства.НеКонтролироватьНаличиеКодовАгрегации = Истина;  	 
				// Кухарь А.Ю.  16.03.2026 конец
				
				Док.Записать();	
				
			Исключение
				РезультатРаспределения.Ошибки.Добавить("Не удалось записать документ: " + Строка(Док.ссылка) + " " +  ОписаниеОшибки());
			КонецПопытки;
			
			
			рр = рр + 1;
			
		КонецЦикла;
		
	КонецЕсли; 
	
	РезультатРаспределения.Успешно = РезультатРаспределения.Ошибки.Количество() = 0; 
	Возврат РезультатРаспределения;

КонецФункции

