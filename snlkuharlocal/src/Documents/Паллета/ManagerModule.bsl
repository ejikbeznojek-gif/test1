 //++Данилова Е.В. 05.02.2026   OUT-19 
 Функция ПолучитьТЗТоварыПоПаллете(Паллета) Экспорт
	 
	СписокЛН = Паллета.ЛистыНабора.Выгрузить(); 	
	СписокЛН.Свернуть("ЛистНабора,Документ");	
	
	ТЗ = Новый ТаблицаЗначений;
	
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Количество");	
	ТЗ.Колонки.Добавить("Накладная");
	
	
	Для Каждого СтрокаТЗ Из СписокЛН Цикл
		
		ЛН = СтрокаТЗ.ЛистНабора;
		
		Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда			
			
			МассСтрок = Паллета.ЛистыНабора.НайтиСтроки(Новый Структура("ЛистНабора", ЛН));
			
			СписокКоробок = ПолучитьСписокШКкоробокЛистаНабораПаллетная(ЛН);
			
			Для Каждого СтрМассСтрок Из МассСтрок Цикл
				
				СтрокаКоробки = СписокКоробок.Найти(СтрМассСтрок.ШКЛистаНабора);
				
				Если СтрокаКоробки <> Неопределено Тогда
					
					СтрТЗ = ТЗ.Добавить();
					
					СтрТЗ.Номенклатура = СтрокаКоробки.номенклатура;
					СтрТЗ.количество = СтрокаКоробки.КоличествоВКоробе;
					СтрТЗ.Накладная = СтрокаТЗ.Документ;  								
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтрТЧТоварыЛН Из ЛН.Товары Цикл
				
				СтрТЗ = ТЗ.Добавить();
				
				СтрТЗ.Номенклатура = СтрТЧТоварыЛН.Номенклатура;
				СтрТЗ.Количество = СтрТЧТоварыЛН.Количество;
				СтрТЗ.Накладная = СтрокаТЗ.Документ; 		

				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТЗ.Свернуть("Номенклатура,Накладная","Количество");
	
	Возврат ТЗ; 
	
КонецФункции
