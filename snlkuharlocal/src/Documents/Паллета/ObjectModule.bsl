Функция БронированиеКодаЧЗПаллеты( Знач МассивАртикулов, Накладная, Знач ТипУпаковки,СоответствиеАртикулКМ)
	
	КоличествоКодовДляБронирования = МассивАртикулов.Количество();
	СтруктураВозврата=новый Структура("Успех,Ошибка",Истина,"");	
	
	рБронирования = Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляМультиПаллеты(Ссылка, Накладная,КоличествоКодовДляБронирования,ТипУпаковки);
	
	Если рБронирования.Успешно тогда			
		КодыАгрегации = рБронирования.Данные;		
		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Паллета.Ссылка КАК Ссылка,
		|	ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты КАК ШтрихкодУпаковкиПаллеты
		|ИЗ
		|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Паллета КАК Паллета
		|		ПО ПаллетаЛистыНабора.Ссылка = Паллета.Ссылка
		|ГДЕ
		|	Паллета.Ссылка <> &Ссылка
		|	И Паллета.Проведен
		|	И ПаллетаЛистыНабора.ШтрихкодУпаковкиПаллеты В(&КодыАгрегации)";
		запрос.УстановитьПараметр("КодыАгрегации",КодыАгрегации);
		запрос.УстановитьПараметр("Ссылка",Ссылка);
		Выборка=запрос.Выполнить().Выбрать();
		МассивОшибок = Новый Массив; 
		пока выборка.Следующий() Цикл
			
			МассивОшибок.Добавить(СтрШаблон("Обнаружен дубль кода %1 в %2",выборка.ШтрихкодУпаковкиПаллеты,выборка.ссылка));
			
		КонецЦикла;
		
		Если МассивОшибок.Количество() > 0  Тогда
			СтруктураВозврата.успех=ложь;
			СтруктураВозврата.Ошибка = СтрСоединить(МассивОшибок,","); 	
			возврат СтруктураВозврата;
		КонецЕсли;
		
		Если КодыАгрегации.Количество() <> КоличествоКодовДляБронирования Тогда
			
			СтруктураВозврата.успех=ложь;
			СтруктураВозврата.Ошибка = "Не совпадает количество необходимых кодов ЧЗ и заброниваронное количество кодов!"; 
			Возврат СтруктураВозврата; 
			
		КонецЕсли; 	
		
		Сч = 0; 
		Для каждого АртикулИзМассива Из МассивАртикулов Цикл
			
			СоответствиеАртикулКМ.Вставить(АртикулИзМассива,КодыАгрегации[Сч]); 	
			
			Сч = Сч +1 ; 
		КонецЦикла;
	Иначе
		ТекстСообщения = СтрСоединить(рБронирования.Ошибки, Символы.ПС);
		СтруктураВозврата.успех=ложь;
		СтруктураВозврата.Ошибка=ТекстСообщения;
		возврат СтруктураВозврата;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции


