Процедура ОбновитьСостоянияЗНБ (НовоеСостояние,Накладная)
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Накладная = &Накладная
	|	И ЗаданиеНабора.Проведен
	|	И ЗаданиеНабора.СостояниеНакладной <> &СостояниеНакладной";
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("СостояниеНакладной",НовоеСостояние);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		ЗНБ=результат.ссылка.получитьобъект();
		ЗНБ.СостояниеНакладной=НовоеСостояние;
		ЗНБ.ОбменДанными.Загрузка=Истина;
		знб.Записать();
	КонецЦикла;
КонецПроцедуры
// Кухарь А.Ю. 30.03.2021 конец


// Кухарь А.Ю.  31.01.2025 начало
