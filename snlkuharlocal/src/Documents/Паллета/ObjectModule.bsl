Функция ЗаполнитьАгрегациюПаллетыПоНакладной (знач ПравилаРаботыСАгрегациейЧЗ,знач Накладная) 
	СтруктураВозврата=новый Структура("Успех,Ошибка",Истина,"");
	
	ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(Накладная);
	ПерваяКоробка=ЛистыНабора[0].ЛистНабора;
	если ТипЗнч(ПерваяКоробка)=Тип("ДокументСсылка.ЛистНабора") тогда
		ТипДокумента="ЛистНабора";
	иначе
		ТипДокумента="ЛистПереукладки";
	КонецЕсли;
	
	запрос=новый запрос;
	если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок тогда
		запрос.Текст="ВЫБРАТЬ
		|	ТЗ.ЛистНабора КАК Коробка
		|ПОМЕСТИТЬ Коробки
		|ИЗ
		|	&ЛистыНабора КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////             
		// Кухарь А.Ю.  06.11.2025 начало
		// HELP-7763
		//|ВЫБРАТЬ
		//|	Коробки.Коробка.КодАгрегации КАК ШтрихкодУпаковки,
		//|	Коробки.Коробка как Коробка
		//|ИЗ
		//|	Коробки КАК Коробки"		 	
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки, Коробки.Коробка.КодАгрегации) КАК ШтрихкодУпаковки,
		|	Коробки.Коробка КАК Коробка
		|ИЗ
		|	Коробки КАК Коробки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
		|		ПО Коробки.Коробка = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка";   
		// Кухарь А.Ю.  06.11.2025 конец
		запрос.УстановитьПараметр("ЛистыНабора",ЛистыНабора);
		//++Данилова Е.В. 22.04.2026 MARK-3539
		запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ЛистНабора","Документ." + ТипДокумента);
		//--Данилова Е.В. 22.04.2026 
		
	Иначе
		запрос.Текст="ВЫБРАТЬ
		|	ТЧ.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		|	ТЧ.Ссылка КАК Коробка
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ТЧ
		|ГДЕ
		|	ТЧ.Ссылка В(&СписокДокументов)";
		запрос.УстановитьПараметр("СписокДокументов",ЛистыНабора.ВыгрузитьКолонку("ЛистНабора"));
		если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков тогда
			запрос.Текст=СтрЗаменить(запрос.Текст,"ТЧ.ШтрихкодУпаковки","ТЧ.ШтрихкодБлочка");
		КонецЕсли;
		запрос.Текст=СтрЗаменить(запрос.Текст,"ЛистНабора",ТипДокумента);
		
	КонецЕсли;
	
	ТаблицаКодов=запрос.Выполнить().Выгрузить();
	
	МассивПустыхКодов=ТаблицаКодов.НайтиСтроки(новый Структура("ШтрихкодУпаковки",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка()));
	если МассивПустыхКодов.Количество()>0 тогда
		МассивОшибки=новый Массив;
		для каждого СтрМасс из МассивПустыхКодов цикл
			если МассивОшибки.Найти(Строка(СтрМасс.Коробка)) = Неопределено тогда
				МассивОшибки.Добавить(Строка(СтрМасс.коробка));
			КонецЕсли;
			СтруктураВозврата.успех=ложь;
			СтруктураВозврата.Ошибка="Обнаружены коробки с пустым кодом ЧЗ"+Символы.ПС+СтрСоединить(МассивОшибки,символы.ПС);
			возврат СтруктураВозврата;
		КонецЦикла;
	КонецЕсли;
	
	//// Кухарь А.Ю.  11.02.2025 начало
	//// MARK-1251
	//ЗНМ	= НайтиДокумент("ЗаданиеНаМаркировку", Новый Структура("ДокОснование", ДокОснование));
	//если не ЗначениеЗаполнено(ЗНМ) тогда
	//	ЗНМ=Документы.ЗаданиеНаМаркировку.Создать_ЗаданиеНаМаркировку(ДокОснование);
	//КонецЕсли;	 
	//// Кухарь А.Ю.  11.02.2025 конец
	
	
	
	Запрос.Текст="ВЫБРАТЬ
	|	ТЧ.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ТЧ
	|ГДЕ
	|	ТЧ.Ссылка В(&Коробки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧ.Номенклатура";
	
	запрос.Текст=СтрЗаменить(запрос.Текст,"ЛистНабора",ТипДокумента);
	запрос.УстановитьПараметр("Коробки",ЛистыНабора.ВыгрузитьКолонку("ЛистНабора"));
	ТЗНоменклатура=запрос.Выполнить().Выгрузить();  
		
	//если не ПравилаРаботыСАгрегациейЧЗ.ПриАгрегацииСворачиватьПоНаименованиюКонтрагента тогда	
	
	
	если ТЗНоменклатура.Количество()>1 тогда 
		ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
	иначе	
		ТипУпаковки=Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	КонецЕсли;
	//++Данилова Е.В. 04.02.2026 OUT-191 
	//++Данилова Е.В. 14.01.2026 ASU-2089 
	//Если ПравилаРаботыСАгрегациейЧЗ.ФормироватьНаборКодовАгрегацииНаПаллету Тогда
	Если Документы.Паллета.ФормироватьНаборКодовАгрегацииНаПаллету(Накладная,ПравилаРаботыСАгрегациейЧЗ) Тогда 
	//--Данилова Е.В. 04.02.2026
		СтруктураВозврата = ЗаполнитьАгрегациюМультиПаллетыПоНакладной(Накладная,ТипУпаковки); 
		
		Возврат СтруктураВозврата; 
	
	КонецЕсли; 
	//--Данилова Е.В. 14.01.2026 
	
	//НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	рБронирования = Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляПалеты(Ссылка, Накладная,ТипУпаковки);			
	Если рБронирования.Успешно тогда			
		КодАгрегации = рБронирования.Данные;		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		|	Паллета.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Паллета КАК Паллета
		|ГДЕ
		|	Паллета.Ссылка <> &Ссылка
		|	И Паллета.Проведен
		|	И Паллета.ЛистыНабора.ШтрихкодУпаковкиПаллеты = &КодАгрегации";
		запрос.УстановитьПараметр("КодАгрегации",КодАгрегации);
		запрос.УстановитьПараметр("Ссылка",Ссылка);
		Выборка=запрос.Выполнить().Выбрать();
		пока выборка.Следующий() Цикл 
			//ОтменитьТранзакцию();
			СтруктураВозврата.успех=ложь;
			СтруктураВозврата.Ошибка=СтрШаблон("Обнаружен дубль кода %1 в %2",КодАгрегации,выборка.ссылка);
			возврат СтруктураВозврата;
		КонецЦикла;	
		//ЗафиксироватьТранзакцию();
		
		
		Для каждого СтрТЧ из ЛистыНабора цикл
			СтрТЧ.ШтрихкодУпаковкиПаллеты=КодАгрегации;
		КонецЦикла;	
		
		ОбменДанными.Загрузка=Истина;
		Записать();	
	Иначе
		ТекстСообщения = СтрСоединить(рБронирования.Ошибки, Символы.ПС);
		СтруктураВозврата.успех=ложь;
		СтруктураВозврата.Ошибка=ТекстСообщения;
		возврат СтруктураВозврата;
	КонецЕсли;
	
	//Иначе
	//	СтруктураВозврата.успех=ложь;
	//	СтруктураВозврата.Ошибка="Свёртка по наименованию пока не реализована";
	//	возврат СтруктураВозврата;	
	//КонецЕсли;
	
	возврат СтруктураВозврата;
КонецФункции

Функция ОбработатьАгрегацииПаллет (ЗаполнятьАгрегации=ложь)  экспорт
	ТЗНакладных=ЛистыНабора.Выгрузить(,"Документ");
	ТЗНакладных.Свернуть("Документ");
	КоличествоДокументов=ТЗНакладных.Количество();
	для каждого ТекСтрока из ТЗНакладных цикл
		ТекНакладная=ТекСтрока.Документ;
		если ТипЗнч(ТекНакладная) <> тип("ДокументСсылка.РасходнаяНакладная") тогда
			Продолжить;
		КонецЕсли;
		ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ТекНакладная);
		если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет тогда	
			если КоличествоДокументов>1 тогда
				ВызватьИсключение "Обнаружено требование агрегации в паллеты по "+ТекНакладная+". В паллете не должно быть других документов";
			КонецЕсли;
			            		 
			если ЗаполнятьАгрегации и не ПроверитьНаличиеАгрегаций() тогда 		 
				РезультатЗаполнения=ЗаполнитьАгрегациюПаллетыПоНакладной(ПравилаРаботыСАгрегациейЧЗ,ТекНакладная);
				
				если не РезультатЗаполнения.Успех тогда 
					ВызватьИсключение РезультатЗаполнения.Ошибка;
				иначе
					ОбменДанными.Загрузка=Истина;
					Записать();
					Возврат Истина;
					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли; 	 
	КонецЦикла;
	возврат Истина;
КонецФункции

Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	// Кухарь А.Ю. 08.02.2025 начало
	если ПроверитьНаличиеАгрегаций() тогда
		ВызватьИсключение "Заполнены агрегации, отмена проведения запрещена";
	КонецЕсли;
	// Кухарь А.Ю. 08.02.2025 конец
	
КонецПроцедуры

