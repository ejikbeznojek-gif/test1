// Кухарь А.Ю. 03.03.2021 начало
// Оптимизация  - старая процедура  ОбработатьТекущиеПланНабораИНакладнуюСтарая
//процедура ОбработатьТекущиеПланНабораИНакладную (Накладная=Неопределено)
процедура ОбработатьТекущиеПланНабораИНакладную (СтрокаТаблицыСНакладной=Неопределено)
	Накладная=СтрокаТаблицыСНакладной.Документ;
	СостояниеНакладной=СтрокаТаблицыСНакладной.СостояниеНакладной; 
	НужноПаллетирование=СтрокаТаблицыСНакладной.НужноПаллетирование;
	
	если СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаТаблицыСНакладной.КоличествоКоробокНакладной<>СтрокаТаблицыСНакладной.КоличествоКоробокНаПаллетах тогда
		ВсеВПаллетах=ложь;
		НовоеСостояние=Перечисления.СостоянияНакладной.Паллетирование;
	иначе
		ВсеВПаллетах=Истина;
		//Валетов + 17,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404
		//НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;       
		
		//Кухарь А.Ю. 31.10.2025 начало
		// HELP-5404    
		//Если ТипЗнч(Накладная) = Тип("ДокументСсылка.РасходнаяНакладная") И Накладная.ТребуетсяМаркировка Тогда
		
		ПереводитьВОжиданиеОбработкиЧЗ = ложь;
		если ТипЗнч(Накладная) =Тип("ДокументСсылка.РасходнаяНакладная") тогда 
			Контрагент=ПолучитьРеквизитШапки(Накладная,"Контрагент","Документ");
			ПереводитьВОжиданиеОбработкиЧЗ=ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(Контрагент,"ПереводитьВОжиданиеОбработкиЧЗ",Ложь);
		КонецЕсли;	       
		Если ТипЗнч(Накладная) = Тип("ДокументСсылка.РасходнаяНакладная") И Накладная.ТребуетсяМаркировка и ПереводитьВОжиданиеОбработкиЧЗ Тогда
			//Кухарь А.Ю. 31.10.2025 конец
			
			НовоеСостояние=Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ;
		Иначе
			НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
		КонецЕсли;

	КонецЕсли;
	
	ПланНабора=СтрокаТаблицыСНакладной.ПланНабора;
	если ПланНабора.пустая() тогда
		Возврат;
	КонецЕсли;
	
	
	
	если СтрокаТаблицыСНакладной=Неопределено тогда
		Накладная=ДокОснование;
	КонецЕсли;
	
	
	//Кухарь А.Ю.  29.05.2025 начало
	ПисатьОтложенно = ложь;
	если ТипЗнч(Накладная) = Тип("ДокументСсылка.РасходнаяНакладная") тогда
		ПисатьОтложенно = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(Контрагент,"ОбрабатыватьПаллетыОтложенно",Ложь); 	
	КонецЕсли;
	//если ПисатьОтложенно тогда
	//	РегистрыСведений.ЗаданиеНаСменуСтатусовНакладной.СоздатьЗаданиеНаСменуСтатуса(Накладная,НовоеСостояние);   
	//	Возврат;
	//КонецЕсли;
	//Кухарь А.Ю.  29.05.2025 конец
	
	Если СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеПаллетирования тогда					
		если ВсеВПаллетах и ОкончаниеПаллетирования<>ПустаяДата() тогда
			ОбъемПаллет=0;
			КоличествоПаллет=0;
			РасчитатьОбъемИКоличествоПаллет (СтрокаТаблицыСНакладной,ОбъемПаллет,КоличествоПаллет);	
			НакладнаяОбъект=Накладная.ПолучитьОбъект();
			НакладнаяОбъект.КоличествоПаллет=КоличествоПаллет;
			НакладнаяОбъект.ОбъемПаллет=ОбъемПаллет;						
		иначе
			НакладнаяОбъект=Накладная.ПолучитьОбъект();
		КонецЕсли;
		
		НакладнаяОбъект.СостояниеНакладной=НовоеСостояние;
		
		// Шворобей ВЮ 19.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5152
		/////////////////////////////////////////////////////////////////////////////////////
		// Вот здесь Ожидание Паллетирования
		/////////////////////////////////////////////////////////////////////////////////////
		Попытка
			НакладнаяОбъект.ЗаписьБезКонтроляПолномочий(ТЗНеизменяемыхРеквизитов);
		Исключение
			МаркировкаКС.СообщитьПользователю("Не могу провести документ " + Строка(НакладнаяОбъект) + ": " + ОписаниеОшибки());
			Если НакладнаяОбъект.ДополнительныеСвойства.Свойство("ТекстОшибки") Тогда
				СообщитьИзМодуля(НакладнаяОбъект.ДополнительныеСвойства.ТекстОшибки);
			Иначе
				СообщитьИзМодуля("РНК не переводится в РГ при записи Паллеты!!!");
			КонецЕсли;
		КонецПопытки;
		// Шворобей ВЮ 19.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5152
		
		ПланНабора=ПланНабора.ПолучитьОбъект();
		для каждого СтрТБ из ПланНабора.тБрэндов цикл
			если не ЗначениеЗаполнено(СтрТБ.НачалоПаллетирования) тогда
				СтрТБ.НачалоПаллетирования=Дата;
			КонецЕсли;
			СтрТБ.Состояние=НовоеСостояние;
			если не ЗначениеЗаполнено(СтрТБ.Паллетировщик) тогда
				СтрТБ.Паллетировщик=Паллетировщик;
			КонецЕсли;
		КонецЦикла;	
		ПланНабора.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);
		
		ТребуетсяЗамерВремени=Истина; 
		
		ОбновитьСостоянияЗНБ (НовоеСостояние,Накладная);
		
		
		// Кухарь А.Ю.  15.02.2023 начало
		// 	ИначеЕсли СостояниеНакладной=Перечисления.СостоянияНакладной.Паллетирование  тогда	//Для любой накладной в состоянии паллетирование
	ИначеЕсли СостояниеНакладной=Перечисления.СостоянияНакладной.Паллетирование или СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке или СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена 
		//Валетов + 17,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404 
			или СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ
			//Валетов -
			тогда	//Для любой накладной в состоянии паллетирование
		
		
		// Кухарь А.Ю.  15.02.2023 конец
		// Кухарь А.Ю.  15.02.2023 начало
		если   СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке или СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена
			//Валетов + 17,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404 
			или СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ
			//Валетов -
			тогда
			НовоеСостояние=СостояниеНакладной
		КонецЕсли;
		// Кухарь А.Ю.  15.02.2023 конец
		
		
		если не ВсеВПаллетах или ОкончаниеПаллетирования=ПустаяДата() тогда //Ничего не делаем до последней паллеты
			Возврат;
		КонецЕсли;
		ОбъемПаллет=0;
		КоличествоПаллет=0;
		РасчитатьОбъемИКоличествоПаллет (СтрокаТаблицыСНакладной,ОбъемПаллет,КоличествоПаллет);		
		
