	Иначе
		Если Документ.ПунктДоставки.ПунктПерегруза.пустая() Тогда
			НастоящийПунктДоставки = Документ.ПунктДоставки;
		Иначе
			НастоящийПунктДоставки = Документ.ПунктДоставки.ПунктПерегруза;
		КонецЕсли;
	КонецЕсли;   
	
	Если НЕ ПунктДоставки.Пустая() И ПунктДоставки <> НастоящийПунктДоставки Тогда
		если документ.контрагент.код<>"SSP-3698" 
