процедура РаботаСПланомНабораИНакладной ()   экспорт
	// Кухарь А.Ю. 05.03.2021 начало
	// оптимизация. Не будем пересчитывать короба, т.к. они уже пересчитались в ожидании паллетирования
	ТЗНеизменяемыхРеквизитов=новый ТаблицаЗначений;
	ТЗНеизменяемыхРеквизитов.Колонки.Добавить("ИмяРеквизита");
	СтрТЗ=ТЗНеизменяемыхРеквизитов.Добавить();
	СтрТЗ.ИмяРеквизита="КоличествоКоробок";
	СтрТЗ=ТЗНеизменяемыхРеквизитов.Добавить();
	СтрТЗ.ИмяРеквизита="Трудозатраты";
	// Кухарь А.Ю. 05.03.2021 конец
	
	
	ТЗНакладных=ЗаполнитьТЗНакладныхДополнительнойИнформацией();
	//Валетов + 22,04,2026 ФЗП 
	ПисатьОтложенно = Ложь;
	ТабФоновойЗаписи = Новый ТаблицаЗначений;
	ТабФоновойЗаписи.Колонки.Добавить("Документ");
	ТабФоновойЗаписи.Колонки.Добавить("СтароеСостояние");
	ТабФоновойЗаписи.Колонки.Добавить("НовоеСостояние");

	для Каждого СтрТЗ из ТЗНакладных цикл
		Накладная=СтрТЗ.Документ;
		если Накладная.метаданные().имя="РасходнаяНакладная" или Накладная.метаданные().имя="Перемещение" тогда     
			
			ПисатьОтложенно=ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(Накладная.Контрагент,"ОбрабатыватьПаллетыОтложенно",Ложь); 	
			Если ПисатьОтложенно И СтрТЗ.КоличествоКоробокНаПаллетах = СтрТЗ.КоличествоКоробокНакладной Тогда 
				НовСтрТабФоновойЗаписи = ТабФоновойЗаписи.Добавить();
				НовСтрТабФоновойЗаписи.Документ = Накладная;
				НовСтрТабФоновойЗаписи.СтароеСостояние = СтрТЗ.СостояниеНакладной;
				НовСтрТабФоновойЗаписи.НовоеСостояние = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;  
				Продолжить;
			КонецЕсли;
	
			ОбработатьТекущиеПланНабораИНакладную(СтрТЗ);
		КонецЕсли;
	КонецЦикла;  
	Если ТабФоновойЗаписи.Количество() > 0 Тогда 
		ПараметрыФоновойФормы = Новый Структура;
		ПараметрыФоновойФормы.Вставить("ТипОперации","Смена состояний накладных");
		ПараметрыФоновойФормы.Вставить("ТекстСообщения","Выполняется смена состояний накладных. Чтобы не искать потом проблемные паллеты в заполненной машине, дождитесь окончания операции.");
		ПараметрыФоновойФормы.Вставить("ТаблицаДок",ТабФоновойЗаписи);
		ПараметрыФоновойФормы.Вставить("Результат",Неопределено);			
		
		ОткрытьФорму("ОбщаяФорма.ФоноваяЗаписьПаллет", ПараметрыФоновойФормы);  
	КонецЕсли;
	
КонецПроцедуры
