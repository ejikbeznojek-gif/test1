		Возврат СтруктураВозврата;
	КонецЕсли;
	
	если РеальноеПаллетирование и ЛистыНабора.Количество()>0 и ДокОснование<>Документ тогда
		СтруктураВозврата.Ошибки.Добавить("Паллета привязана к другой накладной - "+ДокОснование.Метаданные().Имя+" "+ДокОснование.Номер);
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если НайденнаяСтрока = Неопределено Тогда
		// Кельманов А.В. - HELP-6313 - 2025.12.09 {
		Если ЭтоВычитание Тогда
			СтруктураВозврата.Ошибки.Добавить("Вычитаемая коробка не найдена!");	
			Возврат СтруктураВозврата;					
		КонецЕсли;
		// Кельманов А.В. - HELP-6313 - 2025.12.09 }
		НайденнаяСтрока = ЛистыНабора.Добавить();   
	Иначе
		// Кельманов А.В. - HELP-6313 - 2025.12.09 {
		Если ЭтоВычитание Тогда
			СтруктураВозврата.Успех = Истина;
			ЛистыНабора.Удалить(НайденнаяСтрока);
			Возврат СтруктураВозврата;					
		КонецЕсли;
		// Кельманов А.В. - HELP-6313 - 2025.12.09 }
		Если ЛистыНабора.Индекс(НайденнаяСтрока)+1=ЛистыНабора.Количество() Тогда
		Иначе
			СтруктураВозврата.Ошибки.Добавить("2й раз отсканировали ШК от коробки "+НомерКоробки+" .Нужно проверить что эту коробку не положили 2й раз.");	
			Возврат СтруктураВозврата;					
		КонецЕсли;	
	КонецЕсли;
	НайденнаяСтрока.ЛистНабора = ЛистНабора;
	НайденнаяСтрока.ШКЛистаНабора = Данные;
	НайденнаяСтрока.Получатель = Документ.ПунктДоставки.Владелец;
	НайденнаяСтрока.Документ = Документ;
	НайденнаяСтрока.ПунктДоставки = Документ.ПунктДоставки;
	НайденнаяСтрока.ВремяСканирования = ТекущаяДата();
	НайденнаяСтрока.Описание = НомерКоробки;
	СостояниеНакладной = Перечисления.СостоянияНакладной.Сканирование;
	СтруктураВозврата.успех = Истина;  
	
	возврат СтруктураВозврата;
КонецФункции
