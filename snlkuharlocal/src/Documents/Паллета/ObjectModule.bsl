Функция ПроверитьЧтоВсеКоробаВПаллетах (Накладная=Неопределено)  
	//кухарь 21.12.16 конец
	
	КоличествоКоробокВПаллетах=0;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ПаллетаЛистыНабора.НомерСтроки) КАК КоличествоКоробок
	|ИЗ
	|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|ГДЕ
	|	ПаллетаЛистыНабора.Ссылка.Проведен
	|	И ПаллетаЛистыНабора.Ссылка.ОкончаниеПаллетирования <> &ПустаяДата
	|	И ПаллетаЛистыНабора.Ссылка <> &Ссылка
	//Кухарь 11.01.17 начало
	|	И ПаллетаЛистыНабора.Документ = &ДокОснование";
	//|	И ПаллетаЛистыНабора.Ссылка.ДокОснование = &ДокОснование
	////Кухарь 26.12.17 начало
	////Оптимизация
	//|	И ПаллетаЛистыНабора.Ссылка.Дата >= &Дата1";
	////Кухарь 26.12.17 конец			
	//Кухарь 11.01.17 конец
	//кухарь 21.12.16 начало
	//запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	если Накладная=Неопределено  тогда
		Накладная=ДокОснование
	КонецЕсли;
	запрос.УстановитьПараметр("ДокОснование",Накладная);
	//Кухарь 26.12.17 начало
	//Оптимизация
	//запрос.УстановитьПараметр("Дата1",Константы.ДатаЗапретаРедактирования.Получить()-30*24*3600);					
	//Кухарь 26.12.17 конец		
	//кухарь 21.12.16 конец
	запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	запрос.УстановитьПараметр("Ссылка",Ссылка);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		КоличествоКоробокВПаллетах=КоличествоКоробокВПаллетах+результат.КоличествоКоробок;
	КонецЦикла;
	
	//Кухарь 11.01.17 начало
	// Забыл про кросс докинг
	//КоличествоКоробокВПаллетах=КоличествоКоробокВПаллетах+ЛистыНабора.Количество();
	отбор=новый Структура;
	отбор.Вставить("Документ",Накладная);
	СтрокиТекНакл=ЛистыНабора.НайтиСтроки(отбор);
	КоличествоКоробокВПаллетах=КоличествоКоробокВПаллетах+СтрокиТекНакл.Количество();
	//Кухарь 11.01.17 конец
	
	ОбИКол=ПолучитьКоличествоИОбъемКоробовИзРегистра(Накладная);
	КоличествоКоробокНакладной=ОбИКол.КоличествоКоробок;
	
	если КоличествоКоробокВПаллетах<>КоличествоКоробокНакладной тогда
		Возврат ложь;
	иначе
		Возврат Истина;
	КонецЕсли;
	
	
	
КонецФункции
