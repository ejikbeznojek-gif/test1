		НаборЗаписей = РегистрыСведений.СтатусГотовностиКОтгрузкеЧЗ.СоздатьНаборЗаписей();
		//Валетов + 15,10,2025  HELP-5404  Добавил обход ТЧ, чтоб всегда был ДокОснования
		Для Каждого СтрТовары ИЗ ЛистыНабора Цикл  			
			НаборЗаписей.Отбор.Документ.Установить(СтрТовары.Документ);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() > 0 Тогда
				НоваяЗапись = НаборЗаписей[0];
				Если НоваяЗапись.СтатусЧЗ = Перечисления.СтатусыГотовностиКОтгрузкеЧЗ.Обработано Тогда
					НоваяЗапись.СтатусЧЗ = Перечисления.СтатусыГотовностиКОтгрузкеЧЗ.ОжиданиеОбработкиЧЗ;
					НаборЗаписей.Записать();
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//Валетов -
КонецПроцедуры


Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ПрописатьИнформациюШКЛН();
	
	если не ПараметрыСеанса.ЗапущенаОбработка и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.Склад  тогда
		
		//Кухарь 26.12.16 конце	
		если дата>=ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования() тогда
			РаботаСПланомНабораИНакладной();	
		КонецЕсли;
		//Кухарь 21.12.16 конец	
		
		//Кухарь 19.03.17 начало
		//Для подсчёта количества паллет	
		СписокШК= ЛистыНабора.ВыгрузитьКолонку("ШКЛистаНабора");
		Запрос=новый запрос; 
		Запрос.Текст="ВЫБРАТЬ
		|	ОстаткиЗХОстатки.ШККоробки КАК ШККоробки,
		|	ОстаткиЗХОстатки.ЗонаХранения КАК ЗонаХранения,
		|	ОстаткиЗХОстатки.КоличествоКоробокОстаток КАК Количество,
		|	ОстаткиЗХОстатки.ШКПаллеты
		|ИЗ
		|	РегистрНакопления.ОстаткиЗХ.Остатки(&Дата, ШККоробки В (&Шк)) КАК ОстаткиЗХОстатки
		|ГДЕ
		|	ОстаткиЗХОстатки.КоличествоКоробокОстаток > 0";				 
		Запрос.УстановитьПараметр("ШК",СписокШК);	
		Запрос.УстановитьПараметр("Дата",Дата);
		ЕстьНаОстатках=запрос.Выполнить().Выгрузить();
		
		Для каждого ТекСтрока из ЕстьНаОстатках цикл
			Движение = Движения.ОстаткиЗХ.Добавить();
			ЗаполнитьЗначенияСвойств(движение,ТекСтрока);
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период = Дата;
			Движение.ЗонаХранения = ТекСтрока.ЗонаХранения;
			Движение.КоличествоКоробок = ТекСтрока.Количество;
		КонецЦикла;
	КонецЕсли;
	//Проводки по остаткам адресного хранения номенклатуры
	если ЗначениеЗаполнено(ДатаОкончанияХранения) тогда
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		|	АдресноеХранениеОстаткиОстаткиИОбороты.ЗонаХранения КАК ЗонаХранения
		|ИЗ
		|	РегистрНакопления.АдресноеХранениеОстатки.ОстаткиИОбороты(&Дата1, &Дата2, Регистратор, , Номенклатура В (&Номенклатура)) КАК АдресноеХранениеОстаткиОстаткиИОбороты
		|ГДЕ
		|	АдресноеХранениеОстаткиОстаткиИОбороты.Регистратор.Паллета = &Паллета
		|	И АдресноеХранениеОстаткиОстаткиИОбороты.Регистратор.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	АдресноеХранениеОстаткиОстаткиИОбороты.Период УБЫВ";
		запрос.УстановитьПараметр("Номенклатура",Товары.ВыгрузитьКолонку("Номенклатура"));
		запрос.УстановитьПараметр("Дата1",НачалоПаллетирования);					 
		запрос.УстановитьПараметр("Дата2",ОкончаниеПаллетирования);		
		запрос.УстановитьПараметр("Паллета",Ссылка);				
		Результат=запрос.Выполнить().Выбрать();
		пока Результат.Следующий() цикл
			ЗонаХранения=Результат.ЗонаХранения;
			для каждого СтрТЧ из Товары цикл
				если СтрТЧ.Количество=0 тогда Продолжить;КонецЕсли;	
				Движение = Движения.АдресноеХранениеОстатки.Добавить();
				ЗаполнитьЗначенияСвойств(движение,СтрТЧ);	
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.Период = Дата;
				Движение.ЗонаХранения = ЗонаХранения;
				//Движение.Паллета=Ссылка;
				Движение.КодОперации=Перечисления.КодыОперацийОстатки.Перемещение;		
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	если ТребуетсяЗамерВремени тогда
		ТЗ=ЛистыНабора.Выгрузить(,"Документ");
		ТЗ.Свернуть("Документ");
		ВсегоНакладных=ТЗ.Количество();
		Запись=РегистрыСведений.ЗамерПроизводительности.СоздатьМенеджерЗаписи();
		запись.ВидДокумента=Метаданные().Имя;
		запись.ДатаЗамера=ДатаНачалаЗамера;
		запись.НомерДокумента=Номер;
		запись.ИмяКомпьютера= ИмяКомпьютера();
		запись.ВремяПроведения =  ТекущаяДата()-ДатаНачалаЗамера;
		запись.Пользователь=ПараметрыСеанса.Пользователь; 	
		запись.КоличествоСтрок = ВсегоНакладных;
		запись.Записать();
	КонецЕсли;  

КонецПроцедуры

