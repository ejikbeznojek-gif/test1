Функция ЗаполнитьТЗНакладныхДополнительнойИнформацией()
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ПаллетаЛистыНабор.Документ КАК Документ
	|ПОМЕСТИТЬ ВремТЗ
	|ИЗ
	|	&ТЗПолная КАК ПаллетаЛистыНабор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т1.Документ КАК Документ,
	|	КОЛИЧЕСТВО(т1.КоличествоКоробок) КАК КоличествоКоробокНаПаллетах,
	|	т1.Документ.КоличествоКоробок КАК КоличествоКоробокНакладной
	|ПОМЕСТИТЬ ТЗКоробокНаПаллетах
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПаллетаЛистыНабора.Документ КАК Документ,
	|		ПаллетаЛистыНабора.Документ КАК КоличествоКоробок
	|	ИЗ
	|		Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|	ГДЕ
	|		ПаллетаЛистыНабора.Ссылка.Проведен
	|		И ПаллетаЛистыНабора.Ссылка.ОкончаниеПаллетирования <> &ПустаяДата
	|		И ПаллетаЛистыНабора.Ссылка <> &Ссылка
	|		И ПаллетаЛистыНабора.Документ В(&СписокНакладных)
	|		И ПаллетаЛистыНабора.Ссылка.Дата >= &ДатаНачалаПоиска
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПаллетаЛистыНабора.Документ,
	|		ПаллетаЛистыНабора.Документ
	|	ИЗ
	|		ВремТЗ КАК ПаллетаЛистыНабора) КАК т1
	|
	|СГРУППИРОВАТЬ ПО
	|	т1.Документ,
	|	т1.Документ.КоличествоКоробок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ПланНабора.Ссылка, &ПустойПланНабора) КАК ПланНабора,
	|	ТЗКоробокНаПаллетах.Документ КАК Документ,
	|	ТЗКоробокНаПаллетах.КоличествоКоробокНаПаллетах КАК КоличествоКоробокНаПаллетах,
	|	ТЗКоробокНаПаллетах.КоличествоКоробокНакладной КАК КоличествоКоробокНакладной,
	|	ВЫБОР
	|		КОГДА ТЗКоробокНаПаллетах.Документ ССЫЛКА Документ.РасходнаяНакладная
	|			ТОГДА ВЫРАЗИТЬ(ТЗКоробокНаПаллетах.Документ КАК Документ.РасходнаяНакладная).СостояниеНакладной
	|		КОГДА ТЗКоробокНаПаллетах.Документ ССЫЛКА Документ.Перемещение
	|			ТОГДА ВЫРАЗИТЬ(ТЗКоробокНаПаллетах.Документ КАК Документ.Перемещение).СостояниеНакладной
	|	КОНЕЦ КАК СостояниеНакладной,
	|	ВЫБОР
	|		КОГДА ТЗКоробокНаПаллетах.Документ ССЫЛКА Документ.РасходнаяНакладная
	|			ТОГДА ВЫРАЗИТЬ(ТЗКоробокНаПаллетах.Документ КАК Документ.РасходнаяНакладная).НужноПаллетирование
	|		КОГДА ТЗКоробокНаПаллетах.Документ ССЫЛКА Документ.Перемещение
	|			ТОГДА ВЫРАЗИТЬ(ТЗКоробокНаПаллетах.Документ КАК Документ.Перемещение).НужноПаллетирование
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НужноПаллетирование
	|ИЗ
	|	ТЗКоробокНаПаллетах КАК ТЗКоробокНаПаллетах
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
	|		ПО ТЗКоробокНаПаллетах.Документ = ПланНабора.Накладная
	|			И (ПланНабора.Накладная.Проведен)
	|			И (ПланНабора.Накладная.Дата > &ДатаНачалаПоиска)
	|			И (ПланНабора.Проведен)";
	
	ТЗПолная=ЛистыНабора.Выгрузить(,"Документ");
	
	Запрос.УстановитьПараметр("СписокНакладных",ТЗПолная.ВыгрузитьКолонку("Документ"));
	Запрос.УстановитьПараметр("ТЗПолная",ТЗПолная);
	Запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	запрос.УстановитьПараметр("ПустойПланНабора",документы.ПланНабора.ПустаяСсылка());
	Запрос.УстановитьПараметр("ДатаНачалаПоиска",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-30*24*3600);
	
	возврат запрос.Выполнить().Выгрузить();
	
КонецФункции 

Процедура РасчитатьОбъемИКоличествоПаллет (СтрокаТаблицыСНакладной,ОбъемПаллет,КоличествоПаллет)
	
	Накладная= СтрокаТаблицыСНакладной.Документ;	
	КоличествоКоробокНакладной= СтрокаТаблицыСНакладной.КоличествоКоробокНакладной;
	КоличествоКоробокТекушейНакладнойВТекущейПаллете=ЛистыНабора.НайтиСтроки(новый Структура("Документ",Накладная)).Количество();
	КоличествоКоробовТекущейПаллеты=ЛистыНабора.Количество();
	если КоличествоКоробовТекущейПаллеты=0 тогда Возврат;КонецЕсли;	
	ПропорцияПаллеты=КоличествоКоробокТекушейНакладнойВТекущейПаллете/КоличествоКоробовТекущейПаллеты;
	КоличествоПаллет=Окр(ПропорцияПаллеты,4);
	ОбъемПаллет=Окр(Объем*ПропорцияПаллеты,4);
	если КоличествоКоробокНакладной = КоличествоКоробокТекушейНакладнойВТекущейПаллете тогда
		Возврат;
	КонецЕсли;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Паллета.Ссылка) КАК КоличествоПаллет,
	|	СУММА(Паллета.Объем) КАК ОбъемПаллет
	|ИЗ
	|	Документ.Паллета КАК Паллета
	|ГДЕ
	|	Паллета.Проведен
	|	И Паллета.РеальноеПаллетирование
	|	И Паллета.ДокОснование = &ДокОснование
	|	И Паллета.Ссылка <> &Ссылка"; 
	запрос.УстановитьПараметр("ДокОснование",Накладная);	
	запрос.УстановитьПараметр("Ссылка",Ссылка);		
	результат2=запрос.Выполнить().Выбрать();
	НакладнаяОбъект=Накладная.ПолучитьОбъект();
	пока результат2.Следующий() цикл		
		//Кухарь 24.03.2021 начало
		//Если паллет не было, то конфигураторная ошибка.
		если результат2.ОбъемПаллет=null тогда Продолжить;КонецЕсли;	
		//Кухарь 24.03.2021 конец
		
		КоличествоПаллет=КоличествоПаллет+результат2.КоличествоПаллет;
		ОбъемПаллет=ОбъемПаллет+результат2.ОбъемПаллет;
	КонецЦикла;
	
	КоличествоСборныхПаллет=0;
	ОбъемСборныхПаллет=0;
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Паллета.Ссылка КАК Паллета
	|ИЗ
	|	Документ.Паллета КАК Паллета
	|ГДЕ
	|	Паллета.Проведен
	|	И НЕ Паллета.РеальноеПаллетирование
	|	И Паллета.ОкончаниеПаллетирования <> &ПустаяДата
	|	И Паллета.ЛистыНабора.Документ = &ДокОснование
	|	И Паллета.Дата >= &Дата1
	|	И Паллета.Ссылка <> &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Паллета.Ссылка";
	запрос.УстановитьПараметр("ДокОснование",Накладная);
	запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	запрос.УстановитьПараметр("Ссылка",Ссылка);	
	запрос.УстановитьПараметр("Дата1",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-30*24*3600);										
	результат2=запрос.Выполнить().Выбрать();
	пока результат2.Следующий() цикл
		//если результат2.ОбъемПаллет=null тогда Продолжить;КонецЕсли;
		
		Отбор=новый Структура;
		Отбор.Вставить("Документ",Накладная);
		МассСтрок=результат2.паллета.ЛистыНабора.НайтиСтроки(Отбор);
		кусок=Окр(МассСтрок.количество()/результат2.паллета.ЛистыНабора.количество(),4);
		ОбъемСборныхПаллет=ОбъемСборныхПаллет+результат2.паллета.Объем*кусок;
		КоличествоСборныхПаллет=КоличествоСборныхПаллет+кусок;					
	КонецЦикла;
	КоличествоПаллет=КоличествоПаллет+КоличествоСборныхПаллет;
	ОбъемПаллет=ОбъемПаллет+ОбъемСборныхПаллет;
	
КонецПроцедуры
// Кухарь А.Ю. 03.03.2021 конец


