		Исключение
			МаркировкаКС.СообщитьПользователю("Не могу провести документ " + Строка(НакладнаяОбъект) + ": " + ОписаниеОшибки());
		КонецПопытки;
		// Шворобей ВЮ 19.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5152
		
