//MARK-1251
Функция ПроверитьНаличиеАгрегаций () Экспорт
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ТЧ.ШтрихкодУпаковкиПаллеты КАК ШтрихкодУпаковкиПаллеты
	|ПОМЕСТИТЬ ВремТЗ
	|ИЗ
	|	Документ.Паллета.ЛистыНабора КАК ТЧ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ первые 1
	|	ВремТЗ.ШтрихкодУпаковкиПаллеты КАК ШтрихкодУпаковкиПаллеты
	|ИЗ
	|	ВремТЗ КАК ВремТЗ
	|ГДЕ
	|	ВремТЗ.ШтрихкодУпаковкиПаллеты <> &ПустойШК";
	Запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.Паллета.ЛистыНабора","&ТЧ");
	запрос.УстановитьПараметр("ТЧ",ЛистыНабора.Выгрузить(,"ШтрихкодУпаковкиПаллеты"));
	запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
	
	Выборка=запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		возврат Истина;
	КонецЦикла;
	
	возврат ложь;
	
КонецФункции

// Кухарь А.Ю.  11.02.2025 конец 

// Кухарь А.Ю.  10.06.2025 начало
Функция ПолучитьТаблицуАртикуловПаллеты (Паллета, Знач Накладная)
	если ложь тогда Паллета = документы.Паллета.СоздатьДокумент();КонецЕсли;
	СтруктураДанных = Новый Структура("Номенклатура, ПунктДоставки, Договор, Дата, Контрагент, ПостояннаяАкция");
	
	ЗаполнитьЗначенияСвойств(СтруктураДанных, Накладная);
	
	ЗапросНоменклатура = Новый Запрос;
	
	
	ТЗ_Номенклатура = Паллета.Товары.Выгрузить(); 
	//++Данилова Е.В. 24.03.2026 ASU-2089
	//ТЗ_Номенклатура.свернуть("Номенклатура");
	ТЗ_Номенклатура.свернуть("Продукция");
	//--Данилова Е.В. 24.03.2026 
	МассивНоменклатуры = ТЗ_Номенклатура.ВыгрузитьКолонку("Продукция");	
	СтруктураДанных.Номенклатура = МассивНоменклатуры;
	
	ТЗ_Матриц = ПолучитьТаблицуМатрицСрезПоследних(СтруктураДанных);
	
	ТЗ_Матриц.Свернуть("АртикулКонтрагента");
	возврат ТЗ_Матриц;
	
КонецФункции
