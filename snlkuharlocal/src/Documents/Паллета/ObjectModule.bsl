	КонецЕсли;
	Если НЕ Документ.Проведен Тогда
		СтруктураВозврата.Ошибки.Добавить("Документ отгрузки не проведен! ЛН: "+ЛистНабора+ " к документу "+Документ);
		Возврат СтруктураВозврата;
	КонецЕсли;
