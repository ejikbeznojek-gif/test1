		КонецЕсли;
		//Кухарь 09.08.19 начало
		//По просьбе егоровой добавим контрагента и состояние коррекции		
		//ТекстПисьма="Коррекция "+Номер+" была "+?(ВидУведомления="Уведомление об отработке коррекции"," отработана "," отклонена ")+" пользователем "+ПараметрыСеанса.Пользователь;
		ТекстПисьма="Коррекция "+Номер+ТекстКонтрагента+" была "+?(ВидУведомления="Уведомление об отработке коррекции"," отработана "," отклонена ")+" пользователем "+ПараметрыСеанса.Пользователь+ТекстСостоянияКоррекции;		
		//Кухарь 09.08.19 конец	
		
	ИначеЕсли ВидУведомления="Уведомление об утверждении коррекции"  тогда
