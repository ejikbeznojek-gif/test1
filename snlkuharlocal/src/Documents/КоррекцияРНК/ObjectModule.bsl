				ИначеЕсли ИмяРеквизита="ВремяПерегруза" тогда	
					//Кухарь 07.03.19 начало
				ИначеЕсли ИмяРеквизита="КоличествоДокумента" или ИмяРеквизита="КоличествоКоробок" тогда
					СтрТЧ.ЦО=истина;	
				ИначеЕсли ИмяРеквизита="Отправитель" или 
					ИмяРеквизита="ПунктДоставкиОтправитель" или 
					ИмяРеквизита="ТранспортнаяКомпанияОтправитель" или 
					ИмяРеквизита="ПунктПерегрузаОтправитель" или 
					ИмяРеквизита="ПунктДоставкиПолучатель" или 
					ИмяРеквизита="Содержание" или 					
					ИмяРеквизита="ТранспортнаяКомпанияПолучатель" тогда 
					
					СтрТЧ.ЦО=истина;
					СтрТЧ.ОВЛ=Истина;
					
				ИначеЕсли ИмяРеквизита="Получатель" или ИмяРеквизита="Объем" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ОВЛ=Истина;
					СтрТЧ.СК=Истина;
				ИначеЕсли ИмяРеквизита="КоличествоКоробок" тогда
					СтрТЧ.ЦО=истина;
					//Кухарь 07.03.19 конец
				КонецЕсли; 	       //////////////////////////////////////Все ЗТО конец
				
			КонецЕсли;
			
		КонецЕсли; // Отгружен
		
	КонецЦикла;
	
	//Заполним табличную часть Согласования если она пустая
	если Согласования.Количество()=0 тогда
		МассСтрок=ТЗРаспределения.найтистроки(Новый Структура("ПРО",Истина));
		если МассСтрок.количество()>0 тогда
			СтрТЧ=Согласования.Добавить();
			СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SSP-0145");  //Претензионно-ревизионный отдел
		КонецЕсли;	
		
		МассСтрок=ТЗРаспределения.найтистроки(Новый Структура("ЦО",Истина));
		если МассСтрок.количество()>0 тогда
			СтрТЧ=Согласования.Добавить();
			СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SSP-0001");  //ЦО (Управление)
		КонецЕсли;	
		
		МассСтрок=ТЗРаспределения.найтистроки(Новый Структура("ОВЛ",Истина));
		если МассСтрок.количество()>0 тогда
			СтрТЧ=Согласования.Добавить();
			СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0434");  //ОВЛ
		КонецЕсли;	
		
		МассСтрок=ТЗРаспределения.найтистроки(Новый Структура("СК",Истина));
		если МассСтрок.количество()>0 тогда
			СтрТЧ=Согласования.Добавить();
			СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0436");  //Складской Комплекс Общие
		КонецЕсли;	
		
		//Кухарь 10.01.19 начало
		//Создание записей в РС ПисьмаНаОтправку
		СформироватьУведомление("Уведомление об утверждении коррекции");	
		//Кухарь 10.01.19 конец
		
	КонецЕсли;
	
	
	Возврат ТЗРаспределения;	
КонецФункции



//ЭтоПоследнееИзменение это значит что этот человек поставил последнюю галку
//B ему нужно получить полный (без отбора по полномочиям) список реквизитов  для изменения  в накладной
Функция ПолучитьТЗДоступныхКИзменениюРеквизитов (ЭтоПоследнееИзменение=ложь) экспорт
	ТЗКонечная=новый ТаблицаЗначений;
	ТЗКонечная.Колонки.Добавить("ИмяРеквизита");
	ТЗРеквизитов=ПолучитьРаспределениеРеквизитовПоПолномочиям();
	Если  ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработка") или ЭтоПоследнееИзменение Тогда
		МассСтрок=ТЗРеквизитов.найтистроки(Новый Структура("ПРО",Истина));
		Для каждого СтрМасс из МассСтрок цикл
			СтрТЗ=ТЗКонечная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ,СтрМасс);
		КонецЦикла;
	КонецЕсли;	
	Если  ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаЦО") или ЭтоПоследнееИзменение Тогда
		МассСтрок=ТЗРеквизитов.найтистроки(Новый Структура("ЦО",Истина));
		Для каждого СтрМасс из МассСтрок цикл
			СтрТЗ=ТЗКонечная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ,СтрМасс);
		КонецЦикла;
	КонецЕсли;	
	Если  ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаОВЛ") или ЭтоПоследнееИзменение Тогда
		МассСтрок=ТЗРеквизитов.найтистроки(Новый Структура("ОВЛ",Истина));
		Для каждого СтрМасс из МассСтрок цикл
			СтрТЗ=ТЗКонечная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ,СтрМасс);
		КонецЦикла;	
	КонецЕсли;
	Если  ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаСК") или ЭтоПоследнееИзменение Тогда
		МассСтрок=ТЗРеквизитов.найтистроки(Новый Структура("СК",Истина));
		Для каждого СтрМасс из МассСтрок цикл
			СтрТЗ=ТЗКонечная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЗ,СтрМасс);
		КонецЦикла;
	КонецЕсли;
	
	ТЗКонечная.Свернуть("ИмяРеквизита");
	Возврат ТЗКонечная;
КонецФункции

//Кухарь 18.02.19 начало
//Накладую могут отгрузить после отработки коррекций, для отработанной корр список реквизитов нужно заполнять по другом
Функция ПолучитьТЗИзмененныхРеквизитовВОтработаннойКоррекции()  экспорт
	ТипДокумента=ДокОснование.Метаданные().Имя;	
	ТЗРеквизитов=новый ТаблицаЗначений;
	ТЗРеквизитов.Колонки.Добавить("ИмяРеквизита");
	для каждого ТекРеквизит из  Метаданные().Реквизиты цикл
		если ПолучитьПризнакПропускаемогоВКоррекцииРеквизита(ТекРеквизит.Имя) тогда
			Продолжить;
		КонецЕсли;		
		ИмяИзменяемогоРеквизит=Метаданные().Реквизиты.Найти(ТекРеквизит.Имя+"ДоИзменения");	
		если ИмяИзменяемогоРеквизит=Неопределено тогда Продолжить;КонецЕсли;
		ЗначениеИзменяемогоРеквизита=ЭтотОбъект[ИмяИзменяемогоРеквизит.имя];
		ЗначениеТекущегоРеквизита=ЭтотОбъект[ТекРеквизит.имя];	
		если ЗначениеИзменяемогоРеквизита=ЗначениеТекущегоРеквизита тогда Продолжить;КонецЕсли;	
		СтрТЧ=ТЗРеквизитов.Добавить();	
		ИмяРеквизита=ТекРеквизит.имя;
		СтрТЧ.ИмяРеквизита=ИмяРеквизита;				
	КонецЦикла;
	Возврат ТЗРеквизитов;	
КонецФункции
//Кухарь 18.02.19 конец

Функция ОтработатьКусокКоррекции (СтруктураРеквизитовДляИзменения = Неопределено) Экспорт
	
	ДатаОтгрузкиПрисутствует = Ложь;
	ЗапретСогласования = Ложь;
	
	Если ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработка") тогда
		СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SSP-0145"));  //Претензионно-ревизионный отдел
		если СтрТЧ<>Неопределено и  не СтрТЧ.Согласовано тогда
			СтрТЧ.Согласовано=Истина;
			СтрТЧ.АвторСогласования=ПараметрыСеанса.Пользователь.ФизЛицо;
			// Кухарь А.Ю. 25.08.2021 начало
			//По просьбе Лисицкого М.В.
			СтрТЧ.ДатаСогласования=ТекущаяДата(); 
			//Кухарь А.Ю.  25.08.2021 конец			
		КонецЕсли;
	КонецЕсли;	
	
	Если ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаЦО") тогда
		СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SSP-0001"));  //ЦО (Управление)
		если СтрТЧ<>Неопределено и    не СтрТЧ.Согласовано тогда
			СтрТЧ.Согласовано=Истина;
			СтрТЧ.АвторСогласования=ПараметрыСеанса.Пользователь.ФизЛицо;
			// Кухарь А.Ю. 25.08.2021 начало
			//По просьбе Лисицкого М.В.
			СтрТЧ.ДатаСогласования=ТекущаяДата(); 
			//Кухарь А.Ю.  25.08.2021 конец			
		КонецЕсли;
	КонецЕсли;	
	
	Если ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаОВЛ") тогда
		СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0434"));  //ОВЛ
		если  СтрТЧ<>Неопределено и   не СтрТЧ.Согласовано тогда
			СтрТЧ.Согласовано=Истина;
			СтрТЧ.АвторСогласования=ПараметрыСеанса.Пользователь.ФизЛицо;
			// Кухарь А.Ю. 25.08.2021 начало
			//По просьбе Лисицкого М.В.
			СтрТЧ.ДатаСогласования=ТекущаяДата(); 
			//Кухарь А.Ю.  25.08.2021 конец			
		КонецЕсли;
	КонецЕсли;	
	
	Если ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаСК") тогда
		СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0436"));  //Складской Комплекс Общие
		
		///////////////////////////////////////////////////////////////////////////////
		// Шворобей ВЮ 14.05.2024 ++
		Если  СтрТЧ <> Неопределено Тогда
			
			Если  СтруктураРеквизитовДляИзменения <> Неопределено И  ТипЗнч(СтруктураРеквизитовДляИзменения) = Тип("Структура") Тогда
				Если СтруктураРеквизитовДляИзменения.Свойство("СписокРеквизитовДляИзменения") Тогда
					ТаблицаРеквизитовДляИзменения = СтруктураРеквизитовДляИзменения.СписокРеквизитовДляИзменения;
					НайденнаяСтрокаТЧ = ТаблицаРеквизитовДляИзменения.Найти("ДатаОтгрузки", "ИмяРеквизита");
					Если НайденнаяСтрокаТЧ <> Неопределено Тогда
						ДатаОтгрузкиПрисутствует = Истина;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		
	    	ЗапретитьИзменениеДатыОтгрузки = Документы.КоррекцияРНК.ЗапретНаСменуДатыОтгрузки(ДокОснование);
			// Кухарь А.Ю. 20.05.2024 начало
			//  ЗапретСогласования = ДатаОтгрузкиПрисутствует И ЗапретитьИзменениеДатыОтгрузки;
			Если ДатаОтгрузкиПрисутствует И ЗапретитьИзменениеДатыОтгрузки Тогда
				СообщитьИзМодуля("Накладная проходила паллетирование. Не забудьте проверить, что нет проблем с паллетами.");
			КонецЕсли; 
			// Кухарь А.Ю. 20.05.2024 конец

			
			//Если ЗапретСогласования Тогда
			//	СообщитьИзМодуля("Склад не может согласовывать изменение Даты Отгрузки");
			//	СтрТЧ.Согласовано = Ложь;
			//Иначе
				Если НЕ СтрТЧ.Согласовано Тогда
					СтрТЧ.Согласовано = Истина;
					СтрТЧ.АвторСогласования=ПараметрыСеанса.Пользователь.ФизЛицо;
					// Кухарь А.Ю. 25.08.2021 начало
					//По просьбе Лисицкого М.В.
					СтрТЧ.ДатаСогласования=ТекущаяДата(); 
					//Кухарь А.Ю.  25.08.2021 конец			
				КонецЕсли;
			//КонецЕсли;
		///////////////////////////////////////////////////////////////////////////////
		
		КонецЕсли;
	КонецЕсли;
	
	МассНесогласованных=Согласования.НайтиСтроки(новый Структура("Согласовано",ложь));
	
	Если МассНесогласованных.Количество() = 0 И НЕ ЗапретСогласования Тогда
		ОтработатьКоррекциюЦеликом();
	Иначе
		Записать(РежимЗаписиДокумента.Запись);			
	КонецЕсли;
	// Кухарь А.Ю. 12.05.2022 начало
	//
	Если ВозниклаОшибка = Истина Тогда
		Возврат Ложь;
	КонецЕсли;
	// Кухарь А.Ю. 12.05.2022 конец
	
	возврат Истина;
КонецФункции

Функция ОтклонитьКусокКоррекции () экспорт
	СостояниеКоррекции = Перечисления.СостоянияКоррекции.Отклонена;
	Отработал=ПараметрыСеанса.Пользователь.ФизЛицо;
	Отработана=Истина;
	Записать(РежимЗаписиДокумента.Запись);
	//Кухарь 10.01.19 начало
	//Создание записей в РС ПисьмаНаОтправку
	СформироватьУведомление("Уведомление об отклонении коррекции");	
	//Кухарь 10.01.19 конец
	Возврат Истина;
КонецФункции


Процедура ОтработатьКоррекциюЦеликом() экспорт 
	
	// Кельманов А.В. - HELP-2272 - 2024.12.04 {
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") И ДокОснование.Отгружен = Перечисления.Отгружен.Отгружен 
		И ВидОплаты <> ВидОплатыДоИзменения Тогда
		
		СообщитьИзМодуля("Нельзя изменять вид оплаты в отгруженной РНК!");
		
		ВозниклаОшибка = Истина;
		
		Возврат;
		
	КонецЕсли;
	// Кельманов А.В. - HELP-2272 - 2024.12.04 }
	
	СписокРеквизитовДляИзменения=новый ТаблицаЗначений;
	СписокРеквизитовДляИзменения.Колонки.Добавить("ИмяРеквизита");
	СписокРеквизитовДляИзменения.Колонки.Добавить("СинонимРеквизита");
	СписокРеквизитовДляИзменения.Колонки.Добавить("ДоИзменения");
	СписокРеквизитовДляИзменения.Колонки.Добавить("ПослеИзменения");
	СписокРеквизитовДляИзменения.Колонки.Добавить("ВНакладной");
	
	ТЗРеквизитов=ПолучитьТЗДоступныхКИзменениюРеквизитов(Истина);	
	для каждого ТекРеквизит из  ТЗРеквизитов цикл
		ИмяИзменяемогоРеквизит=Метаданные().Реквизиты.Найти(ТекРеквизит.ИмяРеквизита+"ДоИзменения");	
		если ИмяИзменяемогоРеквизит=Неопределено тогда Продолжить;КонецЕсли;
		ЗначениеИзменяемогоРеквизита=ЭтотОбъект[ИмяИзменяемогоРеквизит.имя];
		ЗначениеТекущегоРеквизита=ЭтотОбъект[ТекРеквизит.ИмяРеквизита];	
		если ЗначениеИзменяемогоРеквизита<>ЗначениеТекущегоРеквизита тогда
			СтрТЧ=СписокРеквизитовДляИзменения.Добавить();
			СтрТЧ.ИмяРеквизита=ТекРеквизит.ИмяРеквизита;
			СтрТЧ.СинонимРеквизита=Метаданные().Реквизиты.Найти(ТекРеквизит.ИмяРеквизита).синоним;
			СтрТЧ.ДоИзменения=ЗначениеИзменяемогоРеквизита;
			СтрТЧ.ПослеИзменения=ЗначениеТекущегоРеквизита;
			СтрТЧ.ВНакладной=ДокОснование[ТекРеквизит.ИмяРеквизита];	
		КонецЕсли;	
	КонецЦикла;
	
	НачатьТранзакцию();
	//Кухарь 17.01.19 начало
	//УстановитьДатуАвизацииДокумента(ДокОснованиеОбъект.Ссылка,ДатаПриемки);
	НужноОтработатьДатуАвизации=ложь;
	//Кухарь 17.01.19 конец
	
	
	если ДатаОтгрузки<>ДатаОтгрузкиДоИзменения тогда
		ИзменениеЗоГиСФ(ДокОснование);
	КонецЕсли;
	
	ДокОснованиеОбъект=ДокОснование.ПолучитьОбъект();
	
	для каждого ТекРеквизит из  СписокРеквизитовДляИзменения цикл
		ЗначениеТекущегоРеквизита=ЭтотОбъект[ТекРеквизит.ИмяРеквизита];	
		ДокОснованиеОбъект[ТекРеквизит.ИмяРеквизита]=ЗначениеТекущегоРеквизита;	
		если ТекРеквизит.ИмяРеквизита="ДатаПриемки" тогда
			//Кухарь 17.01.19 начало
			//УстановитьДатуАвизацииДокумента(ДокОснованиеОбъект.Ссылка,ДатаПриемки);
			ДокОснованиеОбъект.ДатаПриемки=ДатаПриемки;
			//Кухарь 17.01.19 конец
		ИначеЕсли  ТекРеквизит.ИмяРеквизита="СуммаДокумента" тогда
			Для Каждого строкаТЧ Из Товары Цикл
				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("Номенклатура", строкаТЧ.Номенклатура);
				попытка
					СтрокаДокОснования = ДокОснованиеОбъект.Товары.НайтиСтроки(ПараметрыОтбора).Получить(0);
				исключение
					СообщитьИзМодуля("Невозможно принять коррекцию! Номенклатуры "+ строкаТЧ.Номенклатура+ "  нет в исходной накладной!");
					ОтменитьТранзакцию();
				конецПопытки;		
				СтрокаДокОснования.Цена = строкаТЧ.Цена;
				СтрокаДокОснования.ЦенаБезСкидки = строкаТЧ.ЦенаБезСкидки;
