		ДопСписок3=СформСписокПолучат(Справочники.ТипыРассылок.УведомлениеОбУтвержденииКоррекции,Справочники.Подразделения.НайтиПоКоду("SMN-0436"));
		СписокПолномочий=новый СписокЗначений;
