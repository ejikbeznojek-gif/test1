	КонецЕсли;
	//Кухарь 25.04.19 конец
	
	
	если ИмяРеквизита="Автор" или
		ИмяРеквизита="Валюта" или
		ИмяРеквизита="ДатаОформления" или
		ИмяРеквизита="ИБ" или
		ИмяРеквизита="Курс" или
		//ИмяРеквизита="Организация" или
		ИмяРеквизита="Склад" или
		//ИмяРеквизита="ТипЦен" или
		ИмяРеквизита="СостояниеНакладной" или
		//ИмяРеквизита="Скидка" или
		ИмяРеквизита="БанковскийСчет" или
		ИмяРеквизита="Отгружен" или
		ИмяРеквизита="ГруппыТоваров" или
		//ИмяРеквизита="ТипСкидок" или
		ИмяРеквизита="ДокОснование" или
		ИмяРеквизита="КоличествоДокумента" или	
		ИмяРеквизита="Регион" или	
		ИмяРеквизита="ОбъемКоробов" или
		//ИмяРеквизита="ТипЦенРаспродажа" или
		ИмяРеквизита="РайонДоставки" или
		ИмяРеквизита="КоличествоКоробок" или
		ИмяРеквизита="ДопСкидкаНаНакладную" или
		ИмяРеквизита="КодОперации" или
		ИмяРеквизита="неКонтролироватьДублиСтрок" или
		ИмяРеквизита="НулеваяСтавкаНДС" или
		ИмяРеквизита="Согласована" или
		ИмяРеквизита="Отработана" или
		ИмяРеквизита="СостояниеКоррекции" или
		ИмяРеквизита="Утвердил" или
		ИмяРеквизита="Отработал" или
		ИмяРеквизита="СтрокаИзменений" или
		ИмяРеквизита="ГТ" или
		ИмяРеквизита="ГТД" или
