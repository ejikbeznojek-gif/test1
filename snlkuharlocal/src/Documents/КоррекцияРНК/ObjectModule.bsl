		СтрокаТЧ.КоличествоВДокументе = 0;
		СтрокаТЧ.Всего = СтрокаТЗ.Всего;
		СтрокаТЧ.ВсегоИсх = 0;
		СтрокаТЧ.ВсегоВДокументе = 0;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ ИЗ ТоварыДоИзменения Цикл
		СтрокаТЧ = ТЧ.Добавить();
		СтрокаТЧ.НомерСтроки = СтрокаТЗ.НомерСтроки;
		СтрокаТЧ.Номенклатура = СтрокаТЗ.Номенклатура;
		СтрокаТЧ.Количество = 0;
		СтрокаТЧ.КоличествоИсх = СтрокаТЗ.Количество;
		СтрокаТЧ.КоличествоВДокументе = 0;
		СтрокаТЧ.Всего = 0;
		СтрокаТЧ.ВсегоИсх = СтрокаТЗ.Всего;
		СтрокаТЧ.ВсегоВДокументе = 0;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ ИЗ ДокОснование.Товары Цикл
		СтрокаТЧ = ТЧ.Добавить();
		СтрокаТЧ.НомерСтроки = СтрокаТЗ.НомерСтроки;
		СтрокаТЧ.Номенклатура = СтрокаТЗ.Номенклатура;
		СтрокаТЧ.Количество = 0;
		СтрокаТЧ.КоличествоИсх = 0;
		СтрокаТЧ.КоличествоВДокументе = СтрокаТЗ.Количество;
		СтрокаТЧ.Всего = 0;
		СтрокаТЧ.ВсегоИсх = 0;
		СтрокаТЧ.ВсегоВДокументе = СтрокаТЗ.Всего;
	КонецЦикла;
	
	ТЧ.Свернуть("НомерСтроки,Номенклатура","Количество,КоличествоИсх,КоличествоВДокументе,Всего,ВсегоИсх,ВсегоВДокументе");
	ТЧ.Сортировать("НомерСтроки");
	//ТаблицаТоваров.Колонки.Добавить("НомерСтроки");
	//ТаблицаТоваров.Колонки.Добавить("Номенклатура");
	//ТаблицаТоваров.Колонки.Добавить("Количество");
	//ТаблицаТоваров.Колонки.Добавить("КоличествоИсх");
	//ТаблицаТоваров.Колонки.Добавить("КоличествоВДокументе");
	//ТаблицаТоваров.Колонки.Добавить("Всего");
	//ТаблицаТоваров.Колонки.Добавить("ВсегоИсх");
	//ТаблицаТоваров.Колонки.Добавить("ВсегоВДокументе");
	ЕстьИзменения = Ложь;
	ЕстьНепринятыеИзменения = Ложь;
	Для Каждого СтрокаТЧ ИЗ ТЧ Цикл
		Если СтрокаТЧ.Количество <> СтрокаТЧ.количествоИсх ИЛИ СтрокаТЧ.Всего <> СтрокаТЧ.ВсегоИсх Тогда
			ЕстьИзменения = Истина;	
		КонецЕсли;
		Если СтрокаТЧ.Количество <> СтрокаТЧ.КоличествоВДокументе ИЛИ СтрокаТЧ.Всего <> СтрокаТЧ.ВсегоВДокументе Тогда
			ЕстьНепринятыеИзменения = Истина;	
		КонецЕсли;
		
	КонецЦикла;
	Если ЕстьИзменения Тогда
		ЕСЛИ ЕстьНепринятыеИзменения Тогда
			Возврат 2;
		Иначе
			Возврат 1;
		КонецЕсли;
	Иначе
		Возврат 3;
	КонецЕсли;
	
КонецФункции


