Процедура ИзменениеЗоГиСФ(ИзмДок) Экспорт 
	//Катаев+ 20/08/14 По СФ только для РНК
	Если ТипЗнч(ИзмДок) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		запросСФ=новый Запрос;
		запросСФ.Текст="ВЫБРАТЬ
		|	СчетФактураНакладные.Ссылка как СФ
		|ИЗ
		|	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
		|ГДЕ
		|	СчетФактураНакладные.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
		|	И СчетФактураНакладные.Ссылка.Проведен = Истина
		|	И СчетФактураНакладные.Накладная = &Накладная";
		запросСФ.УстановитьПараметр("Дата1",НачалоДня(ДатаОтгрузкиДоИзменения));
		запросСФ.УстановитьПараметр("Дата2",КонецДня(ДатаОтгрузкиДоИзменения));
		запросСФ.УстановитьПараметр("Накладная",ИзмДок);
		результатСФ=запросСФ.Выполнить().Выгрузить();
		Для каждого стСФ из результатСФ цикл
			СФ=стСФ.сф.получитьобъект();
			//сф=документы.СчетФактура.НайтиПоНомеру().ПолучитьОбъект();
			сф.Проведен=ложь;
			сф.ПометкаУдаления=Истина;
			сф.записать();
			Сообщить("Счёт-фактура: "+сф.номер+" помечена на удаление");
		КонецЦикла;
		
		//кухарь 28.10.2013 начало 
		ДокОснование.получитьобъект().УстановитьСостояниеДокументов(Перечисления.СостояниеДокументов.НеВыписаны);
		//кухарь 28.10.2013 конец
	КонецЕсли;
	//Катаев- 20/08/14
	
	//кухарь 04.12.13 начало
	//ставим не отгружать
	если КонецДня(ДатаОтгрузкиДоИзменения)>КонецДня(ТекущаяДата()) тогда
		ЗапросЗОГ=новый запрос;
		ЗапросЗОГ.Текст= "ВЫБРАТЬ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка как ЗОГ,
		|	ЗаявкаНаОтгрузкуНакладные.НомерСтроки как НомерСтроки
		|ИЗ
		|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
		|ГДЕ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
		|	И ЗаявкаНаОтгрузкуНакладные.Накладная = &Накладная
		|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен = Истина";
		запросЗОГ.УстановитьПараметр("Дата1",НачалоДня(ДатаОтгрузкиДоИзменения));
		запросЗОГ.УстановитьПараметр("Дата2",КонецДня(ДатаОтгрузкиДоИзменения));
		запросЗОГ.УстановитьПараметр("Накладная",ИзмДок);
		
		результатЗОГ=ЗапросЗОГ.Выполнить().Выгрузить();
		для каждого текЗог из результатЗОГ цикл
			ЗОГ=текЗог.зог.получитьобъект();
			зог.накладные.получить(текЗог.НомерСтроки-1).НеОтгружать=истина;
			//Кухарь 12.01.19 начало
			//ЗОГ.записать();
			ЗОГ.ЗаписьБезКонтроляПолномочий();
			//Кухарь 12.01.19 конец
		КонецЦикла;
	КонецЕсли;
	//кухарь 04.12.13 конец
	
	
	запросНовыйЗог=новый запрос;
	запросНовыйЗог.Текст="ВЫБРАТЬ
	|	ЗаявкаНаОтгрузку.Ссылка как ЗОГ
	|ИЗ
	|	Документ.ЗаявкаНаОтгрузку КАК ЗаявкаНаОтгрузку
	|ГДЕ
	|	ЗаявкаНаОтгрузку.Проведен = истина
	|	И ЗаявкаНаОтгрузку.ДатаОтгрузки = &ДатаОтгрузки
	|	И ЗаявкаНаОтгрузку.Склад = &Склад";
	запросНовыйЗог.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	запросНовыйЗог.УстановитьПараметр("Склад",Склад);
	результНовыйЗог=запросНовыйЗог.Выполнить().Выгрузить();
	если результНовыйЗог.Количество()=1 тогда
		ЗОГ=результНовыйЗог.Получить(0).зог.получитьобъект();
		если ЗОГ.накладные.найти(ИзмДок.номер)=Неопределено тогда
			
			НВЗ=ЗОГ.накладные.добавить();
			//НВЗ.накладная=ИзмДок;
			ЗОГ.ЗаполнитьСтрокуПоНакладной(НВЗ,ИзмДок);
			НВЗ.неотгружать=ложь;
			//Кухарь 12.01.19 начало
			//ЗОГ.записать();
			ЗОГ.ЗаписьБезКонтроляПолномочий();
			//Кухарь 12.01.19 конец
			
		иначе
			ЗОГ.накладные.найти(ИзмДок.номер).неотгружать=ложь;
			Сообщить(ЗОГ.номер+ " уже содержит данную накладную");
			//Кухарь 12.01.19 начало
			//ЗОГ.записать();
			ЗОГ.ЗаписьБезКонтроляПолномочий();
			//Кухарь 12.01.19 конец
			
		КонецЕсли;
	ИначеЕсли результНовыйЗог.Количество()>1 тогда
		Сообщить("Имеется несколько заявок на отгрузку на этот день, обратитесь в техподдержку");
	Иначе
		Сообщить("ЗОГ не сформирован, накладная не добавлена, проконтролируйте добавление накладной в ЗОГ после его формирования");
	КонецЕсли;
	
	//Документы.ЗаявкаВТранспортныйОтдел.НайтиПоРеквизиту("Номер","SEM-00021");
	
КонецПроцедуры
