Функция ПреобразоватьТаблицуВHTMLText(ТЗ,ДопТекст,ТЗИзменений) 
	р = 3;
	Ответ = "<HTML><HEAD><BODY>"+ДопТекст+"<TABLE border=1><TBODY>";
	
	Ответ=Ответ+"<TR bgcolor=#FFFF99>";	
	Ответ=Ответ+"<TD><P><FONT size=3> Склад </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Группа товаров </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Номер </FONT></TD>";	
	// Кухарь А.Ю. 29.03.2021 начало
	если ДокОснование.метаданные().имя = "РасходнаяНакладная" тогда
		Ответ=Ответ+"<TD><P><FONT size=3> Вид оплаты </FONT></TD>";	 
	КонецЕсли;
	// Кухарь А.Ю. 29.03.2021 конец
	
	Ответ=Ответ+"<TD><P><FONT size=3> Состояние накладной </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Дата отгрузки </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Получатель </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Тип доставки </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Пункт доставки </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Кол-во </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Объем </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Автор корреции </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Изменяемые реквизиты </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Текущее значение </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Новое значение </FONT></TD>";
	Ответ=Ответ+"</TR>";
	
	для каждого СтрокаТаблицы из ТЗ	цикл
		Ответ=Ответ+"<TR>";
		для каждого Колонка из ТЗ.колонки цикл
			если Колонка.имя="Накладная" тогда Прервать;КонецЕсли;
			Ответ=Ответ+"<TD><P><FONT size=3>"+СтрокаТаблицы[Колонка.имя]+"</FONT></P></TD>";
		КонецЦикла;
		Ответ=Ответ+"</TR>";
		
		
		МассСтрок=ТЗИзменений.НайтиСтроки(новый Структура("Накладная",СтрокаТаблицы.Накладная));
		если МассСтрок.количество()>0 тогда
			для каждого СтрМассива из МассСтрок цикл
				Ответ=Ответ+"<TR>";	
				
				// Кухарь А.Ю. 09.04.2021 начало
				//Добавилась колонка, нужно на 1 пустую ячейку больше
				// 	для сч=1 по 11 цикл 
				если ДокОснование.метаданные().имя = "РасходнаяНакладная" тогда
					ПустыхКолонок=12;	 
				иначе
					ПустыхКолонок=11;
				КонецЕсли;
				для сч=1 по ПустыхКолонок цикл 
					// Кухарь А.Ю. 09.04.2021 конец 
					Ответ=Ответ+"<TD><P><FONT size=3>"+""+"</FONT></P></TD>";
				КонецЦикла;
				
				Ответ=Ответ+"<TD><P><FONT size=3>"+СтрМассива.СинонимРеквизита+"</FONT></P></TD>";
				Ответ=Ответ+"<TD><P><FONT size=3>"+СтрМассива.ДоИзменения+"</FONT></P></TD>";
				Ответ=Ответ+"<TD><P><FONT size=3>"+СтрМассива.ПослеИзменения+"</FONT></P></TD>";
				
				Ответ=Ответ+"</TR>";
				
			КонецЦикла;
			
		КонецЕсли;
		
		
		
	КонецЦикла;		
	Ответ  =Ответ+"</TBODY></TABLE></BODY></HTML>";
	Возврат Ответ;
КонецФункции
//Кухарь 15.01.19 конец
