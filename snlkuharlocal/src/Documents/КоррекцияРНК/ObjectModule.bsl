Функция ПолучитьРаспределениеРеквизитовПоПолномочиям() Экспорт
	
	ТипДокумента=ДокОснование.Метаданные().Имя;	
	Если ТипДокумента="РасходнаяНакладная" или ТипДокумента="Перемещение" тогда
		СостояниеДокумента=ДокОснование.Отгружен;	
	иначе
		СостояниеДокумента=Перечисления.Отгружен.Резерв;
	КонецЕсли;
	
	ТЗРаспределения = Новый ТаблицаЗначений;
	ТЗРаспределения.Колонки.Добавить("ИмяРеквизита");
	ТЗРаспределения.Колонки.Добавить("ЦО");
	ТЗРаспределения.Колонки.Добавить("СК");
	ТЗРаспределения.Колонки.Добавить("ОВЛ");
	ТЗРаспределения.Колонки.Добавить("ПРО");
	
	для каждого ТекРеквизит из  Метаданные().Реквизиты цикл
		если ПолучитьПризнакПропускаемогоВКоррекцииРеквизита(ТекРеквизит.Имя) тогда
			Продолжить;
		КонецЕсли;		
		ИмяИзменяемогоРеквизит=Метаданные().Реквизиты.Найти(ТекРеквизит.Имя+"ДоИзменения");	
		если ИмяИзменяемогоРеквизит=Неопределено тогда Продолжить;КонецЕсли;
		ЗначениеИзменяемогоРеквизита=ЭтотОбъект[ИмяИзменяемогоРеквизит.имя];
		ЗначениеТекущегоРеквизита=ЭтотОбъект[ТекРеквизит.имя];
		
		если ЗначениеИзменяемогоРеквизита=ЗначениеТекущегоРеквизита тогда Продолжить;КонецЕсли;
		
		СтрТЧ=ТЗРаспределения.Добавить();
		СтрТЧ.ЦО=ложь;
		СтрТЧ.СК=ложь;
		СтрТЧ.ОВЛ=ложь;
		СтрТЧ.ПРО=ложь;	
		
		ИмяРеквизита=ТекРеквизит.имя;
		СтрТЧ.ИмяРеквизита=ИмяРеквизита;
		
		Если СостояниеДокумента = Перечисления.Отгружен.Отгружен Тогда
			
			Если ТипДокумента="РасходнаяНакладная" тогда  //////////////////////////////////////Отгруженные РНК начало
				если ИмяРеквизита="ДатаПриемки" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ОВЛ=Истина;
				ИначеЕсли ИмяРеквизита="ДатаЗаказа" тогда	
				ИначеЕсли ИмяРеквизита="ДатаОплаты" тогда
					СтрТЧ.ЦО=истина;
				ИначеЕсли ИмяРеквизита="ДатаОтгрузки" тогда
					//// Здесь так и должно быть? Ничего не происходит?????
				ИначеЕсли ИмяРеквизита="Договор" тогда	
					СтрТЧ.ЦО=истина;
					СтрТЧ.ПРО=Истина;
				ИначеЕсли ИмяРеквизита="Комментарий" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ОВЛ=истина;
				ИначеЕсли ИмяРеквизита="Менеджер" тогда	
					СтрТЧ.ЦО=истина;
				ИначеЕсли ИмяРеквизита="НомерЗаказа" тогда
				ИначеЕсли ИмяРеквизита="Организация" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ПРО=Истина;
				ИначеЕсли ИмяРеквизита="ОтсрочкаПлатежа" тогда	
					СтрТЧ.ЦО=истина;
					//Кухарь 14.01.18 начало
					//Согласование ПРО тут не нужно
					//СтрТЧ.ПРО=Истина;
					//Кухарь 14.01.18 конец
				ИначеЕсли ИмяРеквизита="Подразделение" тогда	
					СтрТЧ.ЦО=истина;
				ИначеЕсли ИмяРеквизита="Контрагент" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ПРО=Истина;
				ИначеЕсли ИмяРеквизита="ПунктДоставки" тогда
					СтрТЧ.ЦО=истина;
					СтрТЧ.ОВЛ=истина;
					СтрТЧ.ПРО=Истина;
				ИначеЕсли ИмяРеквизита="ПунктПерегруза" тогда
					// Кухарь А.Ю. 17.02.2020 начало
					//  СтрТЧ.ЦО=истина;				
					если не ПунктДоставки.ДоставкаЗаНашСчет тогда
						СтрТЧ.ЦО=истина;
					КонецЕсли;
					// Кухарь А.Ю. 17.02.2020 конец
					СтрТЧ.ОВЛ=истина;
					//Кухарь 14.01.18 начало
					//Согласование ПРО тут не нужно
					//СтрТЧ.ПРО=Истина;
					//Кухарь 14.01.18 конец
					
				ИначеЕсли ИмяРеквизита="СуммаДокумента" тогда	
				ИначеЕсли ИмяРеквизита="ТранспортнаяКомпания" тогда
					// Кухарь А.Ю. 17.02.2020 начало
					//  СтрТЧ.ЦО=истина;				
