Функция ОтработатьТовары (ДокОснованиеОбъект)
	Для Каждого строкаТЧ Из Товары Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Номенклатура", строкаТЧ.Номенклатура);
		попытка
			СтрокаДокОснования = ДокОснованиеОбъект.Товары.НайтиСтроки(ПараметрыОтбора).Получить(0);
		исключение
			СообщитьИзМодуля("Невозможно принять коррекцию! Номенклатуры "+ строкаТЧ.Номенклатура+ "  нет в исходной накладной!");
			возврат ложь;
		конецПопытки;		
		СтрокаДокОснования.Цена = строкаТЧ.Цена;
		СтрокаДокОснования.ЦенаБезСкидки = строкаТЧ.ЦенаБезСкидки;
		СтрокаДокОснования.СтавкаНДС = строкаТЧ.СтавкаНДС;
		СтрокаДокОснования.Сумма 			= СтрокаДокОснования.Цена * СтрокаДокОснования.Количество;
		СтавкаНДС=ПроцентНДСпоСтавке(СтрокаДокОснования.СтавкаНДС);			
		СтрокаДокОснования.НДС	=СтрокаДокОснования.Сумма*СтавкаНДС/(1+СтавкаНДС);			
		СтрокаДокОснования.Всего	=СтрокаДокОснования.Сумма;
		СтрокаДокОснования.Сумма  =СтрокаДокОснования.Всего-СтрокаДокОснования.НДС; 
		СтрокаДокОснования.ВсегоБезБонуса =  СтрокаДокОснования.Всего;
		СтрокаДокОснования.ЦенаБезБонуса = СтрокаДокОснования.Цена;
		СтрокаДокОснования.Скидка =  строкаТЧ.Скидка;
		СтрокаДокОснования.ТипЦен = строкаТЧ.ТипЦен;
		Если ДокОснованиеОбъект.Контрагент.НДС_Сверху Тогда
			//Кухарь 01.04.19 начало
			//ЦенаБезНДС = Окр(СтрокаДокОснования.Цена*(1-СтавкаНДС/(1+СтавкаНДС)),2);
			ЦенаБезНДС = Окр(СтрокаДокОснования.Цена/(1+СтавкаНДС),2);					
			//Кухарь 01.04.19 конец	
			ВсегоБезНДС = ЦенаБезНДС*СтрокаДокОснования.Количество;
			СтрокаДокОснования.НДС = ВсегоБезНДС*СтавкаНДС;
			СтрокаДокОснования.Всего = ВсегоБезНДС + СтрокаДокОснования.НДС;
			СтрокаДокОснования.Сумма = ВсегоБезНДС;			
		КонецЕсли;
	КонецЦикла;
	
	ДокОснованиеОбъект.Скидка = Скидка;
	ДокОснованиеОбъект.ТипЦен = ТипЦен;
	ДокОснованиеОбъект.ТипЦенРаспродажа = ТипЦенРаспродажа;
	ДокОснованиеОбъект.ТипСкидок = ТипСкидок;
	ДокОснованиеОбъект.ДопСкидкаНаНакладную = ДопСкидкаНаНакладную;
	Возврат Истина;
КонецФункции
