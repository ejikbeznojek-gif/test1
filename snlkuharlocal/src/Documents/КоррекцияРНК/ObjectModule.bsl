	если ДокОснование.Метаданные().Имя="ЗаявкаВТранспортныйОтдел" тогда
		если ИмяРеквизита<>"Отправитель" и
			ИмяРеквизита<>"ПунктДоставкиОтправитель" и
			ИмяРеквизита<>"ТранспортнаяКомпанияОтправитель" и
			ИмяРеквизита<>"ПунктПерегрузаОтправитель" и
			ИмяРеквизита<>"ПунктДоставкиПолучатель" и
			ИмяРеквизита<>"ТранспортнаяКомпанияПолучатель" и
			ИмяРеквизита<>"Подразделение" и
			ИмяРеквизита<>"Менеджер" и
			ИмяРеквизита<>"ДатаПриемки" и
			ИмяРеквизита<>"ОбъемКоробов" и
			ИмяРеквизита<>"КоличествоКоробок" и
			ИмяРеквизита<>"КоличествоДокумента" и
			ИмяРеквизита<>"Содержание" и
			ИмяРеквизита<>"ДатаОтгрузки" тогда
			Возврат Истина
		иначе
			возврат ложь;
		КонецЕсли;
	КонецЕсли;
	//Кухарь 07.08.19 конец	
	
	//Кухарь 25.04.19 начало
	если ДокОснование.Метаданные().Имя="Перемещение" и не ЕстьРеквизитДокумента(ИмяРеквизита,ДокОснование.Метаданные()) тогда
