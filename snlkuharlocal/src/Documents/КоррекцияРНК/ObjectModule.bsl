Процедура УстановитьСостояниеДокументов(НовоеСостояниеДокументов) Экспорт
	//крохин начало 09.02.2011
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//СостояниеДокументов=НовоеСостояниеДокументов;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда
		Если	ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение  Тогда
			НеКонтролироватьЗапись=Истина;
			СостояниеДокументов=НовоеСостояниеДокументов;
			Записать();
			НеКонтролироватьЗапись=Ложь;	
		КонецЕсли;
	Иначе
		НеКонтролироватьЗапись=Истина;
		СостояниеДокументов=НовоеСостояниеДокументов;
		Записать();
		НеКонтролироватьЗапись=Ложь;
	КонецЕсли;
	//крохин конец 09.02.2011
	
КонецПроцедуры

Процедура УстановитьДатуНомерСчета(НоваяДатасчета,НовыйНомерСчета)   Экспорт
	//крохин начало 09.02.2011
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//НомерСчета=НовыйНомерСчета;
	//ДатаСчета= НоваяДатасчета;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда
		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			НеКонтролироватьЗапись=Истина;
			НомерСчета=НовыйНомерСчета;
			ДатаСчета= НоваяДатасчета;
			Записать();
			НеКонтролироватьЗапись=Ложь;
		КонецЕсли;	
	Иначе
		НеКонтролироватьЗапись=Истина;
		НомерСчета=НовыйНомерСчета;
		ДатаСчета= НоваяДатасчета;
		Записать();
		НеКонтролироватьЗапись=Ложь;
	КонецЕсли;
	//крохин конец 09.02.2011
КонецПроцедуры


Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	КонтрольДатыЗапрета(ЭтотОбъект,Отказ);			
	Если Отказ Тогда Возврат КонецЕсли; 
		
	// Кельманов А.В. - HELP-2272 - 2024.12.04 {
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") И ДокОснование.Отгружен = Перечисления.Отгружен.Отгружен 
		И ВидОплаты <> ВидОплатыДоИзменения Тогда
		
		СообщитьИзМодуля("Нельзя изменять вид оплаты в отгруженной РНК!");
		
		Отказ = Истина;
		
		Возврат;
		
	КонецЕсли;
	// Кельманов А.В. - HELP-2272 - 2024.12.04 }
	
	//Кухарь 07.03.19 начало
	//Коррекции на основании ЗТО
	если ДокОснование.Метаданные().Имя<>"ЗаявкаВТранспортныйОтдел"  тогда
		//Кухарь 07.03.19 конец
		
		СуммаДокумента		= Товары.Итог("Всего");
		ОбъемДокумента		= Товары.Итог("Объем");
		КоличествоДокумента = Товары.Итог("Количество");
		ГруппыТоваров		= ГруппыТоваровДокумента(ЭтотОбъект);
		
		
		//крохин начало 10.04.2013
		СуммаДокументаДоИзменения = ТоварыДоИзменения.Итог("Всего");
		//крохин конец 10.04.2013
		
		
		//		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
		
		//крохин начало 10.12.2012
		
		//Кухарь 07.03.19 начало
		//Коррекции на основании ЗТО
	КонецЕсли;
	//Кухарь 07.03.19 конец
	
	//Кухарь 07.12.18 начало
	//Заполним согласования	
	если СостояниеКоррекции=Перечисления.СостоянияКоррекции.Утверждена тогда
		ТЗ=ПолучитьРаспределениеРеквизитовПоПолномочиям();
		если Согласования.Количество()=0 тогда
			Отказ=Истина;
			СообщитьИзМодуля("Нельзя утверждать коррекции без изменений");
		КонецЕсли;	 
	КонецЕсли;	
	//Кухарь 07.12.18 конец
	
	//Кухарь 14.01.19 начало
	если Отказ<>Истина тогда
		//Кухарь 14.01.19 конец
		
		//Кухарь 10.12.18 начало
		//Отработано будем ставить по кнопке отработать ткт
		//Кухарь 14.01.18 начало
		//Менять состояние коррекции нужно не только при согласовании коррекции
		//Если (Проведен ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение) и Согласована и ссылка.Согласована=Ложь  Тогда
		Если (Проведен ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение) и СостояниеКоррекции<>ДокОснование.СостояниеКоррекции и СостояниеКоррекции<>Перечисления.СостоянияКоррекции.Принята  Тогда	
			//Кухарь 14.01.18 конец
			дата=ТекущаяДата();
			//Кухарь 10.12.18 конец
			
			НакладнаяОбъект = ДокОснование.ПолучитьОбъект();
			НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);
		КонецЕсли;
		//Кухарь 14.01.19 начало
	КонецЕсли;
	//Кухарь 14.01.19 конец
	
	//крохин конец 10.12.2012
	
	//крохин начало 26.03.2013
	//строка изменений
	Если НЕ ОбменДанными.Загрузка И Модифицированность() Тогда
		//		Если НЕ ОбменДанными.Загрузка Тогда
		СтрокаИзменений = "";
		Если Контрагент <> КонтрагентДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Контрагент,";
		КонецЕсли;
		
		Если Договор <> ДоговорДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Договор,";
		КонецЕсли;
		
		
		Если ДатаОплаты <>ДатаОплатыДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ДатаОплаты,";
		КонецЕсли;
		
		
		
		
		Если ОтсрочкаПлатежа <>ОтсрочкаПлатежаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ОтсрочкаПлатежа,";
		КонецЕсли;
		
		
		
		Если Менеджер <> МенеджерДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Менеджер,";
		КонецЕсли;
		
		
		Если Комментарий <> КомментарийДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Комментарий,";
		КонецЕсли;
		
		
		
		Если ДатаЗаказа <> ДатаЗаказаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ДатаЗаказа,";
		КонецЕсли;
		
		
		
		
		Если НомерЗаказа <> НомерЗаказаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "НомерЗаказа,";
		КонецЕсли;
		
		
		
		Если Подразделение <> ПодразделениеДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Подразделение,";
		КонецЕсли;
		
		
		Если Организация <> ОрганизацияДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Контрагент,";
		КонецЕсли;
		
		Если ДатаОтгрузки <> ДатаОтгрузкиДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ДатаОтгрузки,";
			
		КонецЕсли;
		
		//Кухарь 05.02.18 начало
		//ещё 2 поля для РНК
		Если АдресПерегруза <> АдресПерегрузаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "АдресПерегруза,";		
		КонецЕсли;
		
		Если ВремяПерегруза <> ВремяПерегрузаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ВремяПерегруза,";
		КонецЕсли;
		//Кухарь 05.02.18 конец
		
		
		Если ПунктДоставки <> ПунктДоставкиДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ПунктДоставки,";
		КонецЕсли;
		Если ТранспортнаяКомпания  <> ТранспортнаяКомпанияДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ТранспортнаяКомпания,";
		КонецЕсли;
		Если Скидка  <> СкидкаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "Скидка,";
		КонецЕсли;
		Если ПунктПерегруза  <> ПунктПерегрузаДоИзменения Тогда
			СтрокаИзменений = СтрокаИзменений + "ПунктПерегруза,";
		КонецЕсли;
		
		//Кухарь 25.06.18 начало	
		//ещё 1 реквизит меняется коррекцией
		если ТипДоставки<>ТипДоставкиДоИзменения  тогда
			СтрокаИзменений = СтрокаИзменений+ "ТипДоставки"
		КонецЕсли;	
		//Кухарь 25.06.18 конец
		
		
		Если  ЕстьИзмененияТЧТовары() <> 3 Тогда
			СтрокаИзменений = СтрокаИзменений + "ТабличнаяЧасть,";
		КонецЕсли;
	КонецЕсли;
	Если Не ПустаяСтрока(СтрокаИзменений) Тогда
		СтрокаИзменений = Лев(СтрокаИзменений,СтрДлина(СтрокаИзменений)-1);
	КонецЕсли;
	//крохин конец 26.03.2013
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
КонецПроцедуры

//Кухарь 02.10.19 начало
//Для вызова из обработок
//Процедура ОбработкаЗаполнения(Основание) 
Процедура ОбработкаЗаполнения(Основание) экспорт
	//Кухарь 02.10.19 конец
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	//Катаев+ 18/12/14 До окончания тестирования в основной базе закрыл возможность создавать коррекцию на основании ПРМ и ПНК
	//Если ТипЗнч(Основание.Ссылка) <> Тип("ДокументСсылка.РасходнаяНакладная") Тогда
	//	Если ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы())) = ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить())) Тогда
	//		Возврат;
	//	КонецЕсли;
	//КонецЕсли;
	//Ктатаев- 18/12/14
	//крохин начало 19.12.2011
	//проверка на существование неотработанных коррекций
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	КоррекцияРНК.Ссылка
	|ИЗ
	|	Документ.КоррекцияРНК КАК КоррекцияРНК
	|ГДЕ
	|	КоррекцияРНК.Проведен
	|	И КоррекцияРНК.ДокОснование = &ДокОснование
	|	И НЕ КоррекцияРНК.Отработана";
	Запрос.УстановитьПараметр("ДокОснование",Основание);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		#Если Клиент Тогда
			Сообщить("По этому документу уже существует неотработанная коррекция. Открыт существующий документ");
			ФормаПретензии = Выборка.Ссылка.ПолучитьФорму("ФормаДокумента");
			ФормаПретензии.Открыть();
		#КонецЕсли
		Возврат;
	КонецЦикла;
	//крохин конец 19.12.2011
	
	Если Основание.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе Тогда
		#Если Клиент Тогда
			Сообщить("Накладные в состоянии ""в работе"" корректируются без заявки!");
		#КонецЕсли
		
		Возврат;
	КонецЕсли;
	
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	ВариантЗаполнения=Неопределено;
	ВариантЗаполнения="Целиком";
	#ЕСЛИ КЛИЕНТ ТОГДА
		//	ВариантЗаполнения=ВыбратьВариантЗаполнения();
	#КОНЕЦЕСЛИ
	
	ДокОснование	= Основание;
	//Кухарь 04.03.19 начало
	//Теперь есть коррекции на основании ЗТО
	//ИБ				= Основание.ИБ;
	ИБ				= ПолучитьРеквизитОбъекта(ДокОснование,"ИБ");
	//Кухарь 04.03.19 конец	
	Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование,"Контрагент");
	Договор			= ПолучитьРеквизитОбъекта(ДокОснование,"Договор");
	ЛевыйКонтрагент = ПолучитьРеквизитОбъекта(ДокОснование,"ЛевыйКонтрагент");
	ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");
	Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	//кухарь 29.01.15 начало	
	ДатаПриемки=ОпределитьДатуАвизацииДокумента(ДокОснование);	
	//кухарь 29.01.15 конец
	
	БанковскийСчет	= ПолучитьРеквизитОбъекта(ДокОснование,"БанковскийСчет");		
	ОтсрочкаПлатежа = ПолучитьРеквизитОбъекта(ДокОснование,"ОтсрочкаПлатежа");			
	
	
	Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");		
	//Катаев+ 08/10/14
	//Если ВидОснования="Перемещение" Тогда
	//	Склад		= ДокОснование.СкладПолучатель;	
	//Иначе		
	//	Склад		= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");	
	//КонецЕсли;	
	Склад		= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");
	//Катаев- 08/10/14
	//крохин начало 05.03.2011
	//подразделение не копируем  
	//++Данилова Е.В. 29.09.2025 HELP-7048
	//Подразделение = Менеджер.Подразделение; 
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер);
	//--Данилова Е.В. 29.09.2025
	Если Подразделение = Справочники.Подразделения.ПустаяСсылка() Тогда
		Подразделение = Склад.Подразделение;
	КонецЕсли;
	//крохин конец 05.03.2011
	
	
	//крохин начало
	//Группы товаров пересчитаем заново
	//ГруппыТоваров	= ПолучитьРеквизитОбъекта(ДокОснование,"ГруппыТоваров");
	//крохин конец
	
	ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");
	//крохин начало 14.02.2013
	//доп.скидка
	ДопСкидкаНаНакладную = ПолучитьРеквизитОбъекта(ДокОснование,"ДопСкидкаНаНакладную");
	//крохин конец 14.02.2013
	
	ТранспортнаяКомпания = ПолучитьРеквизитОбъекта(ДокОснование,"ТранспортнаяКомпания");
	//крохин начало 28.02.2013
	ПунктПерегруза = ПолучитьРеквизитОбъекта(ДокОснование,"ПунктПерегруза");
	//крохин конец 28.02.2013
	
	//Кухарь 25.06.18 начало	
	//ещё 1 реквизит меняется коррекцией
	ТипДоставки=ПолучитьРеквизитОбъекта(ДокОснование,"ТипДоставки");		
	//Кухарь 25.06.18 конец
	
	
	Если ВидОснования="ПриходнаяНакладная" И НЕ ПолучитьПолномочиеПользователя("ВидимостьПриходныхЦен") Тогда
		ОбнулитьЦены=Истина;	
	Иначе
		ОбнулитьЦены=Ложь;	
	КонецЕсли;
	
	//Комментарий=Комментарий+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");
	//Кухарь 04.03.19 начало
	//Теперь есть коррекции на основании ЗТО	
	если ВидОснования<>"ЗаявкаВТранспортныйОтдел" тогда
		//Кухарь 04.03.19 конец		
		Для Каждого исхСтрокаТЧ Из ДокОснование.Товары Цикл
			
			СтрокаТЧ = Товары.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);
			
		КонецЦикла;	
		//Кухарь 04.03.19 начало
