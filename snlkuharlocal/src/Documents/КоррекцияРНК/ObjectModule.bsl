		Иначе 
			ТекстСостояниеКоррекции=" - принята.";		
		КонецЕсли;	
		
		ТекстСостоянияКоррекции=Символы.ПС+"Состояние"+ТекстСостояниеКоррекции;
	иначе
		ТекстСостоянияКоррекции="";
	КонецЕсли;
	//Кухарь 09.08.19 конец
	
	
	
	если ВидУведомления="Уведомление об отработке коррекции" или ВидУведомления="Уведомление об отклонении коррекции" тогда	
