// возвращает таблицу данных документа для сравнения
Функция ПолучитьДанныеДляСверкиДокументов(ВидДокумента, Дата1, Дата2, Подразделение) Экспорт
	
	Попытка	
		ТекстЗапроса = Документы[ВидДокумента].ПолучитьТекстЗапросаДляСверки();
	Исключение
		ТекстЗапроса = "";
	КонецПопытки;	
	
	Если НЕ ЗначениеЗаполнено(ТекстЗапроса) Тогда
		
		ТекстЗапроса = "
		|ВЫБРАТЬ
		|	Ссылка,
		|	Номер,
		|	Дата,
		|	Проведен,
		|	#СтрокаРеквизитов#
		|ИЗ
		|	Документ.#ИмяДокумента# КАК ТаблицаДокумента
		|ГДЕ
		|	ТаблицаДокумента.Дата МЕЖДУ &Дата1 И &Дата2
		|	И ТаблицаДокумента.Подразделение В (&Подразделение, ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка))";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#СтрокаРеквизитов#",	Документы[ВидДокумента].ПолучитьРеквизитыДляСверки());
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ИмяДокумента#",		ВидДокумента);
		
	КонецЕсли;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Запрос.УстановитьПараметр("Подразделение",	Подразделение);
	Запрос.УстановитьПараметр("Дата1",			Дата1);
	Запрос.УстановитьПараметр("Дата2",			Дата2);
	
	ТД = Запрос.Выполнить().Выгрузить();
	
	ТД.Колонки.Ссылка.Имя = "Ссылка_";	
	ТД.Колонки.Добавить("Ссылка");
	Для Каждого СтрокаТД Из ТД Цикл
		СтрокаТД.Ссылка = Новый Структура("Вид,Ссылка","Документ."+ВидДокумента, СтрокаТД.Ссылка_.УникальныйИдентификатор());	
	КонецЦикла;
	
	ТД.Колонки.Удалить(ТД.Колонки.Ссылка_);
	
	Возврат ТД;
	
КонецФункции

