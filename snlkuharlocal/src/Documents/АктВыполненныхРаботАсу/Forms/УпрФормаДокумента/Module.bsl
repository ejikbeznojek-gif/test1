&НаСервере
Процедура ЗаполнитьПрикрепленныеФайлы()
	объект.ВложенныеФайлы.Очистить();
	если не объект.Ссылка.Пустая() тогда
		запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрикрепленныеФайлы.ИмяФайла КАК ИмяФайла
		|ИЗ
		|	РегистрСведений.ПрикрепленныеФайлы КАК ПрикрепленныеФайлы
		|ГДЕ
		|	ПрикрепленныеФайлы.Владелец = &Владелец";
		запрос.УстановитьПараметр("Владелец",объект.Ссылка);
		Результат=запрос.Выполнить().Выбрать();
		пока Результат.Следующий() цикл
			СтрТЧ=объект.ВложенныеФайлы.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЧ,Результат);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

