&НаСервере
Процедура СкопироватьФайлНаСервере(ФайлДляСервера,ПутьКФайлу)
	ДД=ПолучитьИзВременногоХранилища(ФайлДляСервера);
	ДД.записать(ПутьКФайлу);
КонецПроцедуры

&НаСервере
Функция ПолучитьФайлССервера (ПутьКФайлу)
	Файл = новый Файл(ПутьКФайлу);
	если файл.Существует() тогда			
		ДД=новый ДвоичныеДанные(ПутьКФайлу);
		ФайлДляСервера=ПоместитьВоВременноеХранилище(ДД,новый УникальныйИдентификатор);
		Возврат ФайлДляСервера;
	иначе
		возврат Неопределено;
	КонецЕсли;			
КонецФункции

&НаКлиенте
Процедура ОткрытьФайл(Команда)
	
	ТекущаяСтрока=Элементы.ВложенныеФайлы.ТекущиеДанные;
	если ТекущаяСтрока<>Неопределено тогда
		ИмяФайла=ТекущаяСтрока.ИмяФайла;
		
		КорневойКаталог = ПолучитьКаталогСохраненияПрикрепленныхФайлов(Объект.Ссылка);
		
		// Кухарь А.Ю. 06.04.2021 начало
		//Файл = новый Файл(КорневойКаталог+"\"+ИмяФайла);
		//если файл.Существует() тогда
		//	ЗапуститьПриложение(КорневойКаталог+"\"+ИмяФайла);
		//КонецЕсли;		
		Хран=ПолучитьФайлССервера (КорневойКаталог+"\"+ИмяФайла);
		если Хран<>Неопределено тогда
			ДД=ПолучитьИзВременногоХранилища(Хран);
			ДД.записать(КаталогВременныхФайлов()+"\"+ИмяФайла);
			ЗапуститьПриложение(КаталогВременныхФайлов()+"\"+ИмяФайла);
		КонецЕсли;		
		// Кухарь А.Ю. 06.04.2021 конец
	КонецЕсли;
КонецПроцедуры


&наКлиенте
Функция ПолучитьКаталогСохраненияПрикрепленныхФайлов (Документ)
	
	если ложь тогда документ=Документы.ВзаимодействиеСКонтрагентом.ПустаяСсылка();КонецЕсли;
	КорневойКаталог = Константы.КаталогВнешнихОтчетов.Получить();
	КаталогДокумента=КорневойКаталог+"Акт Выполненых работ\"+Документ.Метаданные().Имя+" "+Документ.Номер;
	
	Файл=новый Файл(КаталогДокумента);
	если  не Файл.Существует() тогда
		СоздатьКаталог(КаталогДокумента);
	КонецЕсли;
	возврат КаталогДокумента;
	
КонецФункции


