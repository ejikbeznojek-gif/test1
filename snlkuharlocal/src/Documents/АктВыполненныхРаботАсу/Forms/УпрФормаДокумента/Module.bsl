
&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если не ПроверкаЗаполненностиЭлементов() тогда
		Отказ=Истина;
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Функция ПроверкаЗаполненностиЭлементов()
	Результат=Истина;
	если Не ЗначениеЗаполнено(Объект.СостояниеЗадачи) тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заполните состояние задачи";
		Сообщение.Сообщить();
		Результат= ложь;
	КонецЕсли;
	
	если Не ЗначениеЗаполнено(Объект.Исполнитель) тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заполните исполнителя";
		Сообщение.Сообщить();
		Результат= ложь;
	КонецЕсли;
	
	если Не ЗначениеЗаполнено(Объект.ОписаниеВыполнения) тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заполните описание выполнения";
		Сообщение.Сообщить();
		Результат= ложь;
	КонецЕсли;
	
	
	возврат Результат;
КонецФункции


