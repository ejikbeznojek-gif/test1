Функция ПечатьДокумента(ДокументСсылка, ЗаголовокОтчета = "Товары", Макет = Неопределено) Экспорт
	
	Если Макет <> Неопределено Тогда
		СхемаКомпоновкиДанных = Макет;	
	Иначе
		СхемаКомпоновкиДанных = ПолучитьМакет("Макет");
	КонецЕсли;
	Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	
	ЭлементПараметраДанных = Настройки.ПараметрыДанных.Элементы.Найти("Ссылка");
	
	Если ЭлементПараметраДанных = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЭлементПараметраДанных.Значение = ДокументСсылка;
	ЭлементПараметраДанных.Использование = Истина;
	
	ЗначениеПараметра = Настройки.ПараметрыВывода.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Title"));

	ЗначениеПараметра.Значение = Строка(ДокументСсылка);
	ЗначениеПараметра.Использование = Истина;

	КомпоновщикМакета	= Новый КомпоновщикМакетаКомпоновкиДанных;
	ДанныеРасшифровки	= Новый ДанныеРасшифровкиКомпоновкиДанных;	
	МакетКомпоновки		= КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);
	
	ДокументРезультат = Новый ТабличныйДокумент;
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки, Истина);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	АдресРасшифровки = ПоместитьВоВременноеХранилище(ДанныеРасшифровки, Новый УникальныйИдентификатор);
	
	ЗаполнениеДокументов.НапечататьТабличныйДокумент(ДокументРезультат,,,ЗаголовокОтчета, , ,АдресРасшифровки);
	
КонецФункции
