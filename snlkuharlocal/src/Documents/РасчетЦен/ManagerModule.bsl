
Функция СоздатьПрайсы(ДокументСсылка) Экспорт
	
	НачатьТранзакцию();
	
	Для Каждого Стр Из ДокументСсылка.ТипыЦен Цикл
		// +++ { [14.06.2022]
		//Прайс = СоздатьДокументПрайсЛист(ДокументСсылка, Стр.ТипЦен);
		Если Стр.ОсновнойПрайсЛист.Пустая() Тогда
			Прайс = СоздатьДокументПрайсЛист(ДокументСсылка, Стр.ТипЦен);
		Иначе	
			Прайс = ИзменитьДокументПрайсЛист(ДокументСсылка, Стр.ТипЦен,Стр.ОсновнойПрайсЛист);
		КонецЕсли;
		// } +++ [14.06.2022]
		Если Прайс = Неопределено Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		иначе
			СообщитьИзМодуля(""+Прайс);
		КонецЕсли;
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();
	
	Возврат Истина;
	
КонецФункции

Функция СоздатьДокументПрайсЛист(ДокументСсылка, ТипЦен)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.УстановитьПараметр("ТипЦен", ТипЦен);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасчетЦенТовары.НомерСтроки КАК НомерСтроки,
	|	РасчетЦенТовары.Номенклатура КАК Номенклатура,
	|	РасчетЦенТовары.ТипЦен КАК ТипЦен,
	|	РасчетЦенТовары.Цена КАК Цена
	|ИЗ
	|	Документ.РасчетЦен.Товары КАК РасчетЦенТовары
	|ГДЕ
	|	РасчетЦенТовары.Ссылка = &ДокументСсылка
	|	И РасчетЦенТовары.ТипЦен = &ТипЦен
	// Кухарь А.Ю.  21.06.2022 начало
	//Пустые цены не пишем
		|	И РасчетЦенТовары.Цена <> 0
	// Кухарь А.Ю.  21.06.2022 конец	
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	ПрайсОбъект = Документы.ПрайсЛист.СоздатьДокумент();
	ПрайсОбъект.Дата = ?(ЗначениеЗаполнено(ДокументСсылка.ДатаНачалаПрайсов), ДокументСсылка.ДатаНачалаПрайсов, НачалоДня(ТекущаяДата()));
	ПрайсОбъект.Дата2 = ?(ЗначениеЗаполнено(ДокументСсылка.ДатаОкончанияПрайсов), ДокументСсылка.ДатаОкончанияПрайсов, КонецГода(ТекущаяДата() + 31536000));
	
	ПрайсОбъект.Автор = ПараметрыСеанса.Пользователь;
	ПрайсОбъект.ДокОснование = ДокументСсылка;
	ПрайсОбъект.Комментарий = ДокументСсылка.Комментарий;
	
	ПрайсОбъект.ТипЦен = ТипЦен;
	
	ПрайсОбъект.Организация = Справочники.Организации.НайтиПоКоду("SS-001");
    ПрайсОбъект.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
	
	ПрайсОбъект.Валюта = ТипЦен.Валюта;
	ПрайсОбъект.Курс = ПолучитьКурсВалюты_ПоРусски(ПрайсОбъект.Валюта, ТекущаяДата());

	Попытка
		ПрайсОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Товары = Запрос.Выполнить().Выгрузить();
	
	Набор = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	Набор.Отбор.Прайс.Установить(ПрайсОбъект.Ссылка);
	
	Для Каждого СтрокаТовары ИЗ Товары Цикл
		НоваяЗапись = Набор.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТовары);
		НоваяЗапись.Период = ПрайсОбъект.Дата;
		НоваяЗапись.Прайс = ПрайсОбъект.Ссылка;
		НоваяЗапись.УровеньДоступа = ТипЦен.УровеньДоступа;
		
		Уровень = СтрокаТовары.Номенклатура.Уровень();
		Если Уровень = 0 Тогда
			НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура;                                    
		ИначеЕсли Уровень = 1 Тогда
			НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель;                                             
			НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура;                                           
		ИначеЕсли Уровень = 2 Тогда
			НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель.Родитель;
			НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура.Родитель;
			НоваяЗапись.Модель = НоваяЗапись.Номенклатура;
		//крохин начало 31.01.2022	
	    //ИначеЕсли Уровень = 3 Тогда
		ИначеЕсли Уровень >= 3 Тогда
		//крохин конец 31.01.2022
			НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель.Родитель.Родитель;
			НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура.Родитель.Родитель;
			НоваяЗапись.Модель = НоваяЗапись.Номенклатура.Родитель;                      
		КонецЕсли;
	КонецЦикла;
	
	Попытка
		Набор.Записать(Истина);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ПрайсОбъект.Ссылка;
	
КонецФункции
