Функция ИзменитьДокументПрайсЛист(ДокументСсылка, ТипЦен, ПрайсЛист)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.УстановитьПараметр("ТипЦен", ТипЦен);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасчетЦенТовары.НомерСтроки КАК НомерСтроки,
	|	РасчетЦенТовары.Номенклатура КАК Номенклатура,
	|	РасчетЦенТовары.ТипЦен КАК ТипЦен,
	|	РасчетЦенТовары.Цена КАК Цена
	|ИЗ
	|	Документ.РасчетЦен.Товары КАК РасчетЦенТовары
	|ГДЕ
	|	РасчетЦенТовары.Ссылка = &ДокументСсылка
	|	И РасчетЦенТовары.ТипЦен = &ТипЦен
	// Кухарь А.Ю.  21.06.2022 начало
	//Пустые цены не пишем
	|	И РасчетЦенТовары.Цена <> 0
	// Кухарь А.Ю.  21.06.2022 конец		
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Если ПрайсЛист.ДокОснование <> ДокументСсылка Тогда
		ПрайсОбъект = ПрайсЛист.ПолучитьОбъект();
		ПрайсОбъект.ДокОснование = ДокументСсылка;
		Попытка
			ПрайсОбъект.Записать(РежимЗаписиДокумента.Запись);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Товары = Запрос.Выполнить().Выгрузить();
	
	Набор = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	
	Для Каждого СтрокаТовары ИЗ Товары Цикл
		Набор.Отбор.Прайс.Установить(ПрайсЛист);
		Набор.Отбор.ТипЦен.Установить(СтрокаТовары.ТипЦен);
		Набор.Отбор.Номенклатура.Установить(СтрокаТовары.Номенклатура);
		Набор.Прочитать();
		Если Набор.Количество()=0 Тогда
			НоваяЗапись = Набор.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТовары);
			НоваяЗапись.Период = ПрайсЛист.Дата;
			НоваяЗапись.Прайс = ПрайсЛист;
			НоваяЗапись.УровеньДоступа = ТипЦен.УровеньДоступа;
			
			Уровень = СтрокаТовары.Номенклатура.Уровень();
			Если Уровень = 0 Тогда
				НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура;                                    
			ИначеЕсли Уровень = 1 Тогда
				НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель;                                             
				НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура;                                           
			ИначеЕсли Уровень = 2 Тогда
				НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель.Родитель;
				НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура.Родитель;
				НоваяЗапись.Модель = НоваяЗапись.Номенклатура;
			ИначеЕсли Уровень = 3 Тогда
				НоваяЗапись.ТипТовара = НоваяЗапись.Номенклатура.Родитель.Родитель.Родитель;
				НоваяЗапись.Брэнд = НоваяЗапись.Номенклатура.Родитель.Родитель;
				НоваяЗапись.Модель = НоваяЗапись.Номенклатура.Родитель;                      
			КонецЕсли;
		Иначе
			Для Каждого Запись ИЗ Набор Цикл
				Запись.Цена = СтрокаТовары.Цена;
				Запись.Период = ПрайсЛист.Дата;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Попытка
		Набор.Записать(Истина);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ПрайсЛист;
	
КонецФункции
// }Кузнецов Сергей Владимирович +++ [14.06.2022]

