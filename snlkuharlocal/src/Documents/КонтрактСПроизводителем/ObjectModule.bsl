		ЗаполнитьТЧКомплектующие();
		 
		ПроверитьТЧКомплектующие(Отказ);
		
		
	КонецЕсли;
	//--Данилова Е.В. 28.07.2025
    //++Данилова Е.В. 13.03.2026 MARK-3512 
	Если Не Отказ Тогда
		СостояниеПроверкиДляЗаполнения = СостояниеПроверкиМарокНаТСД; 
		ОбменДаннымиПоAPI_ТСД.ПолучитьСостояниеПроверкиМарокНаТСД(Контрагент,СостояниеПроверкиДляЗаполнения);
		Если СостояниеПроверкиДляЗаполнения <> СостояниеПроверкиМарокНаТСД Тогда
		
			СостояниеПроверкиМарокНаТСД = СостояниеПроверкиДляЗаполнения; 	
		
		КонецЕсли;
	КонецЕсли;
