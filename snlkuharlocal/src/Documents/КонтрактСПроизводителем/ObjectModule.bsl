Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НЕ обменданными.Загрузка и ПараметрыСеанса.ЭтотУзел.ТипУзла <> Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
	  Сообщить("Этот документ можно менять только в ЦО!");Отказ=ИСТИНА;Возврат;	
	Конецесли;
	
	ЕстьИзменения		=Модифицированность();	
	
	Если НЕ ОбменДанными.Загрузка Тогда
		Если НеКонтролироватьЗапись Тогда
		Иначе
			//крохин начало 09.03.2017
			//раскомментировал проверку, посмотрим, зачем её убирали
			//КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
			КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
			//крохин конец 09.03.2017
			МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
			МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		КонецЕсли;		
		
		Если Отказ Тогда Возврат КонецЕсли;		
	КонецЕсли;	
	
	Если ЕстьИзменения Тогда 
		СуммаДокумента		= Товары.Итог("Всего");
		ОбъемДокумента		= Товары.Итог("Объем");
		КоличествоДокумента = Товары.Итог("Количество");		
		
		ГруппыТоваров   	= ГруппыТоваровДокумента(ЭтотОбъект);		
		//Катаев+ 05/12/13  Делаем проверку на отрицательные значения по партиям
		Если Не ОбменДанными.Загрузка Тогда //Катаев+ 19/02/14 При обмене проверку делать не будем
		Запрос=новый запрос;
		запрос.Текст=
		"ВЫБРАТЬ
		|	ПартииОстатки.Партия КАК им7,
		|	ПартииОстатки.Номенклатура,
		|	ПартииОстатки.ШтВКоробе,
		|	СУММА(ПартииОстатки.КоличествоОстаток - ВЫБОР
		|			КОГДА (НЕ ПартииРезерв.КоличествоОстаток ЕСТЬ NULL )
		|				ТОГДА ПартииРезерв.КоличествоОстаток
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Количество
		|ИЗ
		|	РегистрНакопления.Партии.Остатки(&Кон, Склад = &Склад) КАК ПартииОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Партии.Остатки(&Кон, Склад = &СкладРезерв) КАК ПартииРезерв
		|		ПО ПартииОстатки.Номенклатура = ПартииРезерв.Номенклатура
		|			И ПартииОстатки.Партия = ПартииРезерв.Партия
		|			И ПартииОстатки.ШтВКоробе = ПартииРезерв.ШтВКоробе
		|
		|СГРУППИРОВАТЬ ПО
		|	ПартииОстатки.Партия,
		|	ПартииОстатки.Номенклатура,
		|	ПартииОстатки.ШтВКоробе";
					 
		Запрос.УстановитьПараметр("Кон",Новый граница(Дата,видграницы.Исключая));
		//крохин начало 29.04.2015
		//для закрывающих КП другая проверка
		//Запрос.УстановитьПараметр("Склад",Склад.ФизическийСклад);
		//Запрос.УстановитьПараметр("СкладРезерв",Склад);
