				КонецЕсли;
			Иначе
				Сообщить("По номенклатуре "+стр.Номенклатура+" в партии "+стр.Им7+" недостаточно товара" );
				Отказ = Истина;
			КонецЕсли;
		//крохин начало 29.04.2015
		//Отказ - после перебора номеналатуры
		//	Если Отказ Тогда
		//		Возврат;
		//	КонецЕсли;
		//КонецЦикла;
		КонецЦикла;
		Если Отказ Тогда
			Возврат;
       	КонецЕсли;
		//крохин конец 29.04.2015
		КонецЕсли;	
		//Катаев- 05/12/13
	КонецЕсли;	
	//крохин начало 16.06.2011
	//регистрация изменений для Риги
	ЕстьИзменения		=Модифицированность();	
	НужноВыгружать		=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;
	//++Данилова Е.В. 13.03.2026 MARK-3512 
	Если ЕстьИзменения 
		И НЕ обменданными.Загрузка Тогда
		
		ДатаИзменения = ТекущаяДатаСеанса(); 	
		
	КонецЕсли;
	//--Данилова Е.В. 13.03.2026
   //крохин конец 16.06.2011 
   //++Данилова Е.В. 28.07.2025  HELP-6187
	Если ЕстьИзменения
