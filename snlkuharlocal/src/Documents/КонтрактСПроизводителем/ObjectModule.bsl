Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
		
	ВидОснования	= Основание.Метаданные().Имя;		
	ДокОснование	= Основание;	
	
	РеквизитыОснования=Новый Структура("Организация,Подразделение,Склад,Контрагент,Договор,Менеджер,ТипЦен,ТипСкидок,Скидка,Контракт");
	ЗаполнитьЗначенияСвойств(РеквизитыОснования,Основание);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект,РеквизитыОснования);	
	
	Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");	
	//удалить
	Комментарий = ДокОснование.Комментарий;
	//удалить
	ОстаткиЗаказов=РегистрыНакопления.ЗаказыПоставщикам.Остатки(,Новый Структура("Заказ",Основание),"Номенклатура","Количество");
	
	//Мессерле- должны сканировать
	Если  НЕ(ВидОснования="КонтрактСПроизводителем" и Основание.состояниезаказа=перечисления.СостояниеЗаказаПоставщику.Закрыт и Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСкладРезерв) тогда
		Для Каждого исхСтрокаТЧ Из Основание.Товары Цикл
			СтрокаОстатка=ОстаткиЗаказов.Найти(исхСтрокаТЧ.Номенклатура,"Номенклатура");
			Если СтрокаОстатка=Неопределено ИЛИ СтрокаОстатка.Количество<=0 Тогда Продолжить; КонецЕсли; 
			
			СтрокаТЧ = Товары.Добавить();		
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);
			СтрокаТЧ.ЗаявкаПоставщику=Основание;
			
			СтрокаТЧ.Количество=СтрокаОстатка.Количество;
			СтрокаТЧ.Заявка =  СтрокаОстатка.Количество;
			СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаОстатка.Количество; 
			РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);		
			
		КонецЦикла;	
	Конецесли;  //Мессерле- должны сканировать

	//крохин начало
	СтрокаЗаявок = ЗаявкиНаПроизводство.Добавить();
	СтрокаЗаявок.ЗаявкаНаПроизводство = Основание;
	//крохин конец
	//крохин начало 17.02.2011
	//заполняем ЕТА по ЗАП
	ДатаПоступления = ДокОснование.ДатаПоступления;
	//крохин конец 17.02.2011
	//Катаев+ 05/05/14
	Если ВидОснования = "ЗаявкаНаПроизводство" Тогда
		Валюта = ДокОснование.Валюта;
	КонецЕсли;
	//Катаев- 05/05/14
КонецПроцедуры

