		//крохин конец 29.04.2015
		Остпартий=Запрос.Выполнить().Выгрузить();
		Для Каждого стр из ТоварыПартии Цикл
			Отбор=новый структура;
			отбор.Вставить("Им7",стр.Им7);
			отбор.Вставить("Номенклатура",стр.Номенклатура);
			отбор.Вставить("ШтВкоробе",стр.ШтукВкоробе);
			НайденныеСтроки = Остпартий.НайтиСтроки(Отбор);
			
			Если НайденныеСтроки.Количество() <> 0 Тогда
