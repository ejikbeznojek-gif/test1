Функция ОпределитьЗаданиеНабора()       
	Результат = Документы.ЗаданиеНабора.ПустаяСсылка();
	
	Если ЗаданияНабора.Количество() = 1 Тогда     
		Результат = ЗаданияНабора[0].ЗаданиеНабора;		
	ИначеЕсли ЗаданияНабора.Количество() > 1 Тогда		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Товары_ЛН ИЗ &Товары КАК Товары
		|;                                                      
		|ВЫБРАТЬ Ссылка, Номенклатура ПОМЕСТИТЬ ВТ_Товары_ЗНБ ИЗ Документ.ЗаданиеНабора.Товары ГДЕ Ссылка В (&мЗНБ) И Количество > 0
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ		
		|	ВТ_Товары_ЗНБ.Ссылка КАК ЗНБ,
		|	ВЫБОР 
		|		КОГДА ВТ_Товары_ЛН.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар) ТОГДА 0
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Приоритет
		|ИЗ
		|	ВТ_Товары_ЗНБ
		|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
		|	ВТ_Товары_ЛН
		|ПО		
		|	ВТ_Товары_ЛН.Номенклатура = ВТ_Товары_ЗНБ.Номенклатура
		|	И ВТ_Товары_ЗНБ.Ссылка.Накладная = &ДокОснование
		|	И (
		|		(&ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка) И НЕ ВТ_Товары_ЗНБ.Ссылка.ЭтоБлочки)
		|		ИЛИ                                                                          
		|		(&ТипШК <> ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка) И ВТ_Товары_ЗНБ.Ссылка.ЭтоБлочки)
		|	)
		|УПОРЯДОЧИТЬ ПО 
		|	Приоритет
		|";
		
		Запрос.УстановитьПараметр("Товары", Товары);
		Запрос.УстановитьПараметр("ТипШК", 	ТипШК); 
		Запрос.УстановитьПараметр("мЗНБ", 	ЗаданияНабора.ВыгрузитьКолонку("ЗаданиеНабора"));
		Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ЗНБ) Тогда
			Результат = Выборка.ЗНБ;					
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ОпределитьЗаданиеНабора()

Процедура ЗаполнениеЛНПриЗагрузкеСТСД() Экспорт
	если ДокОснование.Метаданные().Имя="ЗаданиеНабора" тогда
		
		если дата<НачалоМесяца(ТекущаяДата()) тогда
			дата=НачалоМесяца(ТекущаяДата());
		КонецЕсли;
		
		ДокОснование=ДокОснование.Накладная;
		если ЭтоНовый() Тогда 
			УстановитьНовыйНомер(СокрЛП(ДокОснование.Номер)+"/");	
			Автор=ПараметрыСеанса.Пользователь; 
		КонецЕсли;
		
		Сканировщик=Наборщик;	
		ТребуетПроверки=ложь;
		КоличествоКоробок	= 0; 
		если ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда
			ЭтоКороба=Истина;
			// Для заполнения штук в коробе из ШК
			Запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			|	ШтрихКоды.Наименование КАК ШК,
			|	ШтрихКоды.ШтВКоробе КАК ШтВКоробе
			|ИЗ
			|	Справочник.ШтрихКоды КАК ШтрихКоды
			|ГДЕ
			|	ШтрихКоды.Владелец В(&Номенклатура)
			|	И ШтрихКоды.ШтВКоробе > 0
			|	И ШтрихКоды.ТипШК = &ТипШК";
			запрос.УстановитьПараметр("Номенклатура",товары.ВыгрузитьКолонку("Номенклатура"));
			запрос.УстановитьПараметр("ТипШК",Перечисления.ТипыШтрихКодов.Коробка);
			ТабШтукВКоробеШК=запрос.Выполнить().Выгрузить();
		иначе
			ЭтоКороба=ложь;
		КонецЕсли;

		// Заполнение стандартных реквизитов		
		Для каждого СтрТЧ из Товары цикл
			ПриИзмененииНоменклатурыТабЧасти(СтрТЧ,ЭтотОбъект);
			РассчитатьСуммуТабЧасти(СтрТЧ, ЭтотОбъект);
			если ЭтоКороба тогда
				// Для заполнения штук в коробе из ШК
				СтрокаТабШтукВКоробеШК=ТабШтукВКоробеШК.Найти(СтрТЧ.ШК,"ШК");
				если СтрокаТабШтукВКоробеШК<>Неопределено тогда
					СтрТЧ.ШтВКоробе= СтрокаТабШтукВКоробеШК.ШтВКоробе;
				КонецЕсли;			 

				Количествокоробок=КоличествоКоробок+?(СтрТЧ.ШтВКоробе=0,СтрТЧ.Количество,СтрТЧ.Количество/СтрТЧ.ШтВКоробе);
			КонецЕсли;
		КонецЦикла;

		если не ЭтоКороба тогда		
			Если ТипКороба <> Справочники.ТипыКоробов.ЗаведениеВручную Тогда	
				ОбъемКоробов =?(ТипКороба.Пустая(),ОбъемДокумента,ТипКороба.Объем);
			КонецЕсли;
			КоличествоКоробок=1;
		иначе 
			ОбъемКоробов=Товары.Итог("Объем");
		КонецЕсли;	 
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокОснование,"ИБ,Склад");
		КоличествоДокумента=Товары.Итог("Количество");
		
	КонецЕсли;
КонецПроцедуры

Функция ПереклейкаНеНужна() экспорт
	ВидДокументаОснования=ОбщегоНазначения_ПИ.ПолучитьИмяДокумента(ДокОснование);
	ПереклейкаНеНужна=Ложь;
	Если ВидДокументаОснования="РасходнаяНакладная" И ПолучитьРеквизитШапки(ДокОснование,"ОтгрузкаКомплектов")=Истина Тогда		
		ОбщегоНазначения_ПИ.ПереклейкаНеНужна(ДокОснование);
	КонецЕсли;
	
	Возврат ПереклейкаНеНужна;	
КонецФункции // ()


Функция ПроверитьСоответствиеМатрицеИзМодуля(ЧастьНоменклатурыПоМатрице=ложь,ПереклейкаНенужна=ложь)	   экспорт
	ТекстПредупреждения="";
	ВсеХорошо 	= Истина;
	
	ВсеХорошоКратностьКороба = Истина; 
	СтруктураВозврата=новый Структура("ВсеХорошо,ВсеХорошоКратностьКороба,ТекстПредупреждения",Истина,Истина,"");
	
	ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(ДокОснование);
	если ДопПараметрыНакладной.ЗаполнятьПереклейку = ложь или ДопПараметрыНакладной.ОтгрузкаFBS тогда
		возврат СтруктураВозврата;
	КонецЕсли;

	если ТипШК<>Перечисления.ТипыШтрихКодов.Коробка тогда
		НужноПроверятьКратностьКоробаИзМатрицы=ложь;
	ИначеЕсли  ПрочитатьЗначениеРеквизитаПНКПРМРНК("НеПроверятьКратностьКороба",ДокОснование) = Истина тогда
		НужноПроверятьКратностьКоробаИзМатрицы=ложь;		
	иначе
		НужноПроверятьКратностьКоробаИзМатрицы=Истина;
	КонецЕсли;
	
	Запрос			= Новый Запрос;				
	Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
	|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
	|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
	|	МатрицаТовары.Номенклатура.Родитель.ШтукВКоробке КАК КратностьКоробкиИзНоменклатуры,
	|	МатрицаТовары.Ссылка КАК Ссылка,
	|	МатрицаТовары.Ссылка.Дата КАК Дата
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата";	
	
	Запрос.УстановитьПараметр("ПостояннаяАкция",		ДокОснование.ПостояннаяАкция);		 
	
	Запрос.УстановитьПараметр("Дата2",			НачалоДня(Дата));
	Запрос.УстановитьПараметр("Дата1",			КонецДня(Дата));
	Запрос.УстановитьПараметр("Контрагент",		ДокОснование.Контрагент);		
	Запрос.УстановитьПараметр("ПунктДоставки",	ДокОснование.ПунктДоставки);				
	Запрос.УстановитьПараметр("Договор",		ДокОснование.Договор);		
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	ПереклейкаНеНужна=ПереклейкаНеНужна();
	Для Каждого СтрокаТЧ Из Товары Цикл
		
		Если СтрокаТЧ.Количество = 0 Тогда Продолжить КонецЕсли;
		Если ДокОснование.ОтгрузкаКомплектов Тогда
			НадоКонтролировать = Ложь;
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Продукция", СтрокаТЧ.Номенклатура);
			НайденныеСтроки = ДокОснование.Комплектующие.НайтиСтроки(ПараметрыОтбора);
			Для СЧ = 0 По НайденныеСтроки.Количество()-1 Цикл
				НайденнаяСтрока = НайденныеСтроки.Получить(Сч);
				Если НайденнаяСтрока.Номенклатура = НайденнаяСтрока.продукция Тогда
					НадоКонтролировать = Истина;
				КонецЕсли;
			КонецЦикла;
			Если НЕ НадоКонтролировать Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Отбор = новый Структура;
		Отбор.Вставить("Номенклатура",СтрокаТЧ.Номенклатура);
		СтрокиМатриц = ТЗ.НайтиСтроки(Отбор); 
		Если СтрокиМатриц.Количество() = 0 Тогда
			если ЧастьНоменклатурыПоМатрице<>Истина тогда
				
				ВсеХорошо = Ложь;
				СообщитьИзМодуля("в матрице отсутствует номенклатура "+СтрокаТЧ.Номенклатура+ ". Номер строки: "+СтрокаТЧ.НомерСтроки);
				ТекстПредупреждения=ТекстПредупреждения+"в матрице отсутствует номенклатура "+СтрокаТЧ.Номенклатура+ ". Номер строки: "+СтрокаТЧ.НомерСтроки+Символы.ПС;
			КонецЕсли;	
		Иначе
			ШКСовпадают = Ложь;
			
			// Проверим, что не сканировали коробами товар, у которого кратность короба заполнена от заводской
			если ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда
				если НужноПроверятьКратностьКоробаИзМатрицы тогда				 
					ПерваяСтрокаМатрицы=СтрокиМатриц.Получить(0);
					если ПерваяСтрокаМатрицы.КратностьКоробки>0  и ПерваяСтрокаМатрицы.КратностьКоробки<>ПерваяСтрокаМатрицы.КратностьКоробкиИзНоменклатуры тогда	
						ВсеХорошоКратностьКороба=Ложь;
						ТекстСообщенияВрем="в матрице отличается кратность коробки от заводской. "+СтрокаТЧ.Номенклатура+ ". Номер строки: "+СтрокаТЧ.НомерСтроки;
						СообщитьИзМодуля(ТекстСообщенияВрем);
						ТекстПредупреждения=ТекстПредупреждения+ТекстСообщенияВрем+Символы.ПС;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если СтрокаТЧ.ТипШК = Перечисления.ТипыШтрихКодов.Штука ИЛИ СтрокаТЧ.ТипШК.Пустая() Тогда					
				Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
					ТекШКМатрицы = СтрокаМатриц.ШККонтрагента;
					СтрокаТЧ.ШКМатрицы = ТекШКМатрицы;	
					СтрокаТЧ.ШККонтрагентаДополнительный = СтрокаМатриц.ШККонтрагентаДополнительный;					
				КонецЦикла;
			Иначе
				ТекШКШтуки 				= ПолучитьШтрихКодТовара(СтрокаТЧ.Номенклатура);
				КоличествоШКШтуки 		= 0;
				ЗапросКоличествоШКШтуки	= Новый Запрос;
				ЗапросКоличествоШКШтуки.Текст="
				|ВЫБРАТЬ
				|    Ссылка,
				|	Наименование
				|ИЗ
				|	Справочник.ШтрихКоды КАК ШтрихКоды
				|ГДЕ
				|	Владелец = &Владелец
				|	И ТипШК = &ТипШК";
				
				ЗапросКоличествоШКШтуки.УстановитьПараметр("Владелец",СтрокаТЧ.Номенклатура);
				ЗапросКоличествоШКШтуки.УстановитьПараметр("ТипШК",Перечисления.ТипыШтрихКодов.Штука);
				ВыборкаКоличествоШКШтуки = ЗапросКоличествоШКШтуки.Выполнить().Выбрать();
				КоличествоШКШтуки = ВыборкаКоличествоШКШтуки.Количество();
				Если КоличествоШКШтуки = 1 Тогда						
					Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
						ТекШКМатрицы 		= СтрокаМатриц.ШККонтрагента;
						СтрокаТЧ.ШКМатрицы 	= ТекШКМатрицы;
						СтрокаТЧ.ШККонтрагентаДополнительный = СтрокаМатриц.ШККонтрагентаДополнительный;	
					КонецЦикла;
				Иначе						
					Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
						ТекШКМатрицы 		= СтрокаМатриц.ШККонтрагента;
						СтрокаТЧ.ШКМатрицы 	= ТекШКМатрицы;
						СтрокаТЧ.ШККонтрагентаДополнительный = СтрокаМатриц.ШККонтрагентаДополнительный;							
						Прервать;
					КонецЦикла;						
					СообщитьИзМодуля("по номенклатуре "+СтрокаТЧ.Номенклатура+ "заведено "+КоличествоШКШтуки +" ШК штуки, проверьте штрихкод на соответствие матрице. Номер строки "+СтрокаТЧ.НомерСтроки);
				КонецЕсли;					
			Конецесли;				
		КонецЕсли;			
	КонецЦикла;	
	
	СтруктураВозврата.ВсеХорошо=ВсеХорошо;
	СтруктураВозврата.ВсеХорошоКратностьКороба=ВсеХорошоКратностьКороба;
	СтруктураВозврата.ТекстПредупреждения=ТекстПредупреждения; 
	
	возврат СтруктураВозврата;
КонецФункции 


// Кухарь А.Ю.  16.03.2024 начало
// Общие проверки перед записью ЛН

Функция КонтрольКорректностиСканированияЧЗВЛЗ() Экспорт
	
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("Документ.ЛистНабора.КонтрольКорректностиСканированияЧЗВЛЗ", Новый Структура("Ссылка", Ссылка));	
	
	Результат=Новый Структура("Успех,Ошибки",Истина,"");
	МассивОшибок=новый Массив;
	
	ВидНакладной=ДокОснование.метаданные().имя;
	
	ДатаОтгрузки=ПустаяДата();
	КонтрагентРаботаетСМаркировкой=ложь; 
	ТребуетсяМаркировкаПриоритетПНК = Ложь;
	если ВидНакладной = "РасходнаяНакладная" 
		или ВидНакладной="ПриходнаяНакладная" 
		или ВидНакладной = "Перемещение" 
		или ВидНакладной="СписаниеТМЦ" 
		тогда
		если ЕстьРеквизитДокумента("ДатаОтгрузки",ДокОснование.Метаданные()) тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокОснование,"ДатаОтгрузки,Контрагент.РаботаСМаркированнымТоваромПодтверждена","Документ");
			ДатаОтгрузки=РеквизитыШапки.ДатаОтгрузки;
		иначе
			ДатаОтгрузки=Дата;
		КонецЕсли;
		если ТипЗнч(ДокОснование)<>Тип("ДокументСсылка.ПриходнаяНакладная") тогда 
			КонтрагентРаботаетСМаркировкой= ПолучитьРеквизитШапки(ДокОснование,"ТребуетсяМаркировка","Документ"); 
		иначе
			КонтрагентРаботаетСМаркировкой=РеквизитыШапки.Контрагент_РаботаСМаркированнымТоваромПодтверждена;
		КонецЕсли;	
		
		если  ТипЗнч(ДокОснование)=Тип("ДокументСсылка.ПриходнаяНакладная") тогда
			Если ПолучитьРеквизитШапки(ДокОснование,"КодОперации","Документ") = Перечисления.КодыОперацийОстатки.ЗакупкаР тогда
				КонтрагентРаботаетСМаркировкой=Истина;
			КонецЕсли;
			 
			Если ПолучитьРеквизитШапки(ДокОснование,"ТребуетсяМаркировкаПриоритет","Документ") = Истина Тогда
			
				КонтрагентРаботаетСМаркировкой=Истина;	
			    ТребуетсяМаркировкаПриоритетПНК = Истина; 
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	если ДатаОтгрузки=ПустаяДата() тогда
		ДатаОтгрузки=ТекущаяДата();
	КонецЕсли;

	ЕстьКМП=ложь;
	если ВидНакладной = "РасходнаяНакладная" или ВидНакладной = "Перемещение"   тогда
		если ВидНакладной = "РасходнаяНакладная"  тогда
			ЕстьКМП=ПолучитьРеквизитШапки(ДокОснование,"ОтгрузкаКомплектов","Документ");
			если ЕстьКМП тогда
				ИмяТоварнойТЧ="Комплектующие";
			иначе
				ИмяТоварнойТЧ="Товары";
			КонецЕсли;
		иначе
			ИмяТоварнойТЧ="Товары";
		КонецЕсли;    
		ТаблицаПереопределяемыхДат=МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(ДокОснование,ИмяТоварнойТЧ, Товары);
	иначе
		ТаблицаПереопределяемыхДат = новый ТаблицаЗначений;
	КонецЕсли;
	
	Запрос=новый запрос;// Сверим что по количеству ТЧ марок сходится с товарами
	
	если ТаблицаПереопределяемыхДат = Неопределено или ТаблицаПереопределяемыхДат.Количество()=0 тогда 		
		запрос.Текст="ВЫБРАТЬ
		|	ЛН.Количество КАК Количество,
		|	ЛН.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТоварыЛН
		|ИЗ
		|	Документ.ЛистНабора.Товары КАК ЛН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ТоварыЛН.Количество) КАК Количество,
		|	ТоварыЛН.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТоварыЛН_ЧЗ
		|ИЗ
		|	ТоварыЛН КАК ТоварыЛН
		|ГДЕ
		|	ТоварыЛН.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> &ПустаяДата  
		|	И (ТоварыЛН.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <= &ДатаОтгрузки  ИЛИ &ТребуетсяМаркировкаПриоритетПНК)
		|	И (&КонтрагентРаботаетСМаркировкой
		|			ИЛИ ТоварыЛН.Номенклатура.ОтгрузкаТолькоЧерезЧЗ)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыЛН.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛНШтрихкодыКоробокДляАгрегации.НовыйКодКоробки КАК НовыйКодКоробки,
		|	ЛНШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки КАК ИсходныйКодКоробки
		|ПОМЕСТИТЬ ВТШтрихкодыКоробокДляАгрегации
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛНШтрихкодыКоробокДляАгрегации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛН.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		|	ЛН.Количество КАК Количество
		|ПОМЕСТИТЬ МаркиБезГруппировкиПромежуточная
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ВТШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки, ЛН.ШтрихкодУпаковки) КАК ШтрихкодУпаковки,
		|	ЛН.Количество КАК Количество
		|ПОМЕСТИТЬ МаркиБезГруппировки
		|ИЗ
		|	МаркиБезГруппировкиПромежуточная КАК ЛН
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтрихкодыКоробокДляАгрегации КАК ВТШтрихкодыКоробокДляАгрегации
		|		ПО ЛН.ШтрихкодУпаковки = ВТШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаркиБезГруппировки.ШтрихкодУпаковки.Владелец КАК Номенклатура,
		|	СУММА(МаркиБезГруппировки.Количество) КАК Количество
		|ПОМЕСТИТЬ НоменклатураИзМарок
		|ИЗ
		|	МаркиБезГруппировки КАК МаркиБезГруппировки  
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркиБезГруппировки.ШтрихкодУпаковки.Владелец
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(НоменклатураИзМарок.Номенклатура, ТоварыЛН_ЧЗ.Номенклатура) КАК Номенклатура,
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) - ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) КАК Дельта
		|,
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) КАК НоменклатураИзМарокКоличество,
		|	ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) КАК ТоварыЛН_ЧЗКоличество
		|ИЗ
		|	НоменклатураИзМарок КАК НоменклатураИзМарок
		|		ПОЛНОЕ СОЕДИНЕНИЕ ТоварыЛН_ЧЗ КАК ТоварыЛН_ЧЗ
		|		ПО НоменклатураИзМарок.Номенклатура = ТоварыЛН_ЧЗ.Номенклатура
		|ГДЕ
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) - ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) <> 0";
	иначе
		Запрос.Текст 	= "ВЫБРАТЬ
		|	ТаблицаДат.Номенклатура КАК Номенклатура,
		|	ТаблицаДат.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ТаблицаСДатами
		|ИЗ
		|	&ТаблицаПереопределяемыхДат КАК ТаблицаДат
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛН.Количество КАК Количество,
		|	ЛН.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТоварыЛН
		|ИЗ
		|	Документ.ЛистНабора.Товары КАК ЛН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ТоварыЛН.Количество) КАК Количество,
		|	ТоварыЛН.Номенклатура КАК Номенклатура,
		|	ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ТоварыЛН_ЧЗ
		|ИЗ
		|	ТоварыЛН КАК ТоварыЛН
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСДатами КАК ТаблицаСДатами
		|		ПО ТоварыЛН.Номенклатура = ТаблицаСДатами.Номенклатура
		|ГДЕ
		|	ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ТоварыЛН.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой) <> &ПустаяДата
		|	И ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ТоварыЛН.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой) <= &ДатаОтгрузки
		|	И (&КонтрагентРаботаетСМаркировкой
		|			ИЛИ ТоварыЛН.Номенклатура.ОтгрузкаТолькоЧерезЧЗ)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыЛН.Номенклатура,
		|	ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой
		|;
		|
		|//////////////////////////////////////////////////////////////////////////////// 
		|ВЫБРАТЬ
		|	ЛНШтрихкодыКоробокДляАгрегации.НовыйКодКоробки КАК НовыйКодКоробки,
		|	ЛНШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки КАК ИсходныйКодКоробки
		|ПОМЕСТИТЬ ВТШтрихкодыКоробокДляАгрегации
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛНШтрихкодыКоробокДляАгрегации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛН.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		|	ЛН.Количество КАК Количество
		|ПОМЕСТИТЬ МаркиБезГруппировкиПромежуточная
		|ИЗ
		|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ВТШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки, ЛН.ШтрихкодУпаковки) КАК ШтрихкодУпаковки,
		|	ЛН.Количество КАК Количество
		|ПОМЕСТИТЬ МаркиБезГруппировки
		|ИЗ
		|	МаркиБезГруппировкиПромежуточная КАК ЛН
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтрихкодыКоробокДляАгрегации КАК ВТШтрихкодыКоробокДляАгрегации
		|		ПО ЛН.ШтрихкодУпаковки = ВТШтрихкодыКоробокДляАгрегации.НовыйКодКоробки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаркиБезГруппировки.ШтрихкодУпаковки.Владелец КАК Номенклатура,
		|	СУММА(МаркиБезГруппировки.Количество) КАК Количество
		|ПОМЕСТИТЬ НоменклатураИзМарок
		|ИЗ
		|	МаркиБезГруппировки КАК МаркиБезГруппировки
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркиБезГруппировки.ШтрихкодУпаковки.Владелец
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(НоменклатураИзМарок.Номенклатура, ТоварыЛН_ЧЗ.Номенклатура) КАК Номенклатура,
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) - ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) КАК Дельта
		|,
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) КАК НоменклатураИзМарокКоличество,
		|	ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) КАК ТоварыЛН_ЧЗКоличество
		|ИЗ
		|	НоменклатураИзМарок КАК НоменклатураИзМарок
		|		ПОЛНОЕ СОЕДИНЕНИЕ ТоварыЛН_ЧЗ КАК ТоварыЛН_ЧЗ
		|		ПО НоменклатураИзМарок.Номенклатура = ТоварыЛН_ЧЗ.Номенклатура
		|ГДЕ
		|	ЕСТЬNULL(НоменклатураИзМарок.Количество, 0) - ЕСТЬNULL(ТоварыЛН_ЧЗ.Количество, 0) <> 0";
		запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат",ТаблицаПереопределяемыхДат)
		
	КонецЕсли;
	
	запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ЛистНабора.Товары КАК ЛН","&Товары КАК ЛН");
	запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛН","&ШтрихкодыУпаковок КАК ЛН");
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛНШтрихкодыКоробокДляАгрегации","&ШтрихкодыКоробокДляАгрегации КАК ЛНШтрихкодыКоробокДляАгрегации"); 
	запрос.УстановитьПараметр("ШтрихкодыКоробокДляАгрегации",ШтрихкодыКоробокДляАгрегации); 
	
	запрос.УстановитьПараметр("Товары",Товары);
	запрос.УстановитьПараметр("ШтрихкодыУпаковок",ШтрихкодыУпаковок);	 
	запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	запрос.УстановитьПараметр("КонтрагентРаботаетСМаркировкой",КонтрагентРаботаетСМаркировкой);
	запрос.УстановитьПараметр("ТребуетсяМаркировкаПриоритетПНК",ТребуетсяМаркировкаПриоритетПНК);
	
	ДопПараметры=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(ДокОснование);
	
	ПропускатьПроверкуНаКоличествоМарок = (ТипШК <> Перечисления.ТипыШтрихКодов.Штука);  
	
	
	если не ДопПараметры.НанесениеКодовНеОбязательно и не (ДопПараметры.ПроверятьСодержимоеТарыЧЗ или ДопПараметры.ПроверятьВложениеЭкспозитораЧЗ)   
		И НЕ ПропускатьПроверкуНаКоличествоМарок тогда
		
		Выборка=запрос.Выполнить().Выбрать();
		
		пока Выборка.Следующий() цикл
			
			Если не Выборка.Номенклатура.ОтгрузкаТолькоЧерезЧЗ Тогда 

				МассивОшибок.Добавить(СтрШаблон("Обнаружены расхождения по кодам ЧЗ у номенклатуры %1 в размере %2 штук. Штрихкоды упаковок: %3 шт. Товары: %4 шт.",
				Выборка.Номенклатура, Выборка.Дельта, Выборка.НоменклатураИзМарокКоличество, Выборка.ТоварыЛН_ЧЗКоличество));
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ИмяДокумента=ОбщегоНазначения_ПИ.ПолучитьИмяДокумента(ДокОснование);
	
	если ИмяДокумента="РасходнаяНакладная"  тогда	
		если ШтрихкодыУпаковок.Количество()>0 Тогда
			
			Запрос.Текст =
			   "ВЫБРАТЬ
			 |	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШКУпаковки,
			 |	ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК ДокОснование,
			 |	ЛистНабораШтрихкодыУпаковок.Ссылка.Дата КАК Дата
			 |ИЗ
			 |	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
			 |ГДЕ
			 |	ЛистНабораШтрихкодыУпаковок.Ссылка.Дата >= &Дата
			 |	И ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование ССЫЛКА Документ.РасходнаяНакладная
			 |	И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки В(&ШтрихкодыУпаковки)
			 |	И ЛистНабораШтрихкодыУпаковок.Ссылка <> &Ссылка
			 |	И ЛистНабораШтрихкодыУпаковок.Ссылка.Проведен
			 |	И ВЫРАЗИТЬ(ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).Проведен
			 |	И НЕ ВЫРАЗИТЬ(ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).СостояниеНакладной В (&СостоянияОтгружены)";
			СостоянияОтгружены = Новый Массив;
			СостоянияОтгружены.Добавить(Перечисления.СостоянияНакладной.ГотоваКОтгрузке);
			СостоянияОтгружены.Добавить(Перечисления.СостоянияНакладной.Отгружена);
			ДатаПроверки = Константы.ДатаЗапретаРедактирования.Получить();
			Запрос.УстановитьПараметр("СостоянияОтгружены",СостоянияОтгружены); 
			Запрос.УстановитьПараметр("Дата", ДатаПроверки - 86400*30);
			запрос.УстановитьПараметр("ШтрихкодыУпаковки",ШтрихкодыУпаковок.ВыгрузитьКолонку("ШтрихкодУпаковки"));
			запрос.УстановитьПараметр("Ссылка",Ссылка);	
			
			выборка=запрос.Выполнить().Выбрать();			
			
			пока Выборка.Следующий() цикл
				МассивОшибок.Добавить(СтрШаблон("Марка %1 обнаружена в другом документе %2 требуется убрать эту марку либо из неё, либо из %3", Выборка.ШКУпаковки, Выборка.ДокОснование, ДокОснование));
			КонецЦикла;

			// Сверим коды наборов отдельно
			если ИмяДокумента="РасходнаяНакладная" и ЕстьКМП тогда 
				
				запрос.Текст="ВЫБРАТЬ
				|	ТЧ.ШтрихкодНабора КАК ШтрихкодНабора
				|ПОМЕСТИТЬ ВТ
				|ИЗ
				|	&ТЧ КАК ТЧ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ВТ.ШтрихкодНабора КАК ШтрихкодНабора
				|ИЗ
				|	ВТ КАК ВТ
				|ГДЕ
				|	НЕ ВТ.ШтрихкодНабора = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.пустаяссылка)";
				запрос.УстановитьПараметр("ТЧ",ШтрихкодыУпаковок.Выгрузить(,"ШтрихкодНабора"));
				МассивКодовНабора = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодНабора");
				если МассивКодовНабора.Количество()>0 тогда
					запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	ЛистНабораШтрихкодыУпаковок.ШтрихкодНабора КАК ШКУпаковки,
					|	ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК ДокОснование,
					|	ЛистНабораШтрихкодыУпаковок.Ссылка.Дата КАК Дата
					|ИЗ
					|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
					|ГДЕ
					|	ЛистНабораШтрихкодыУпаковок.Ссылка.Дата >= &Дата
					|	И ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование ССЫЛКА Документ.РасходнаяНакладная
					|	И ЛистНабораШтрихкодыУпаковок.ШтрихкодНабора В(&ШтрихкодыУпаковки)
					|	И ЛистНабораШтрихкодыУпаковок.Ссылка <> &Ссылка
					|	И ЛистНабораШтрихкодыУпаковок.Ссылка.Проведен
					|	И ВЫРАЗИТЬ(ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).Проведен
					|	И НЕ ВЫРАЗИТЬ(ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).СостояниеНакладной В (&СостоянияОтгружены)";
					запрос.УстановитьПараметр("ШтрихкодыУпаковки",МассивКодовНабора);			
					
					Выборка = Запрос.Выполнить().Выбрать();
					
					Пока Выборка.Следующий() Цикл
						МассивОшибок.Добавить(СтрШаблон("Марка %1 обнаружена в другом документе %2 требуется убрать эту марку либо из неё, либо из %3", Выборка.ШКУпаковки, Выборка.ДокОснование, ДокОснование));
					КонецЦикла;
				КонецЕсли; 
			КонецЕсли;
			ПроверкаОтсканированныхЗаводскихКоробок(МассивОшибок); 
		КонецЕсли;

	КонецЕсли;

	//По остальным видам накладных просто пока будем следить, что нет в соседних ЛН от этой накладной
	если ШтрихкодыУпаковок.Количество()>0 Тогда              
		//++Ратманов 26.03.2026
		запрос.Текст="ВЫБРАТЬ
		             |	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		             |	&Ссылка КАК Ссылка
		             |ПОМЕСТИТЬ ВремТЗ
		             |ИЗ
		             |	&ТЗ КАК ЛистНабораШтрихкодыУпаковок
		             |;
		             |
		             |////////////////////////////////////////////////////////////////////////////////
		             |ВЫБРАТЬ
		             |	ЕСТЬNULL(ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод, ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки) КАК ШКУпаковки,
		             |	ЛистНабораШтрихкодыУпаковок.Ссылка КАК ЛН
		             |ПОМЕСТИТЬ ШКТекЛН
		             |ИЗ
		             |	ВремТЗ КАК ЛистНабораШтрихкодыУпаковок
		             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		             |		ПО ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
		             |
		             |ИНДЕКСИРОВАТЬ ПО
		             |	ШКУпаковки
		             |;
		             |
		             |////////////////////////////////////////////////////////////////////////////////
		             |ВЫБРАТЬ
		             |	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		             |	ЛистНабораШтрихкодыУпаковок.Ссылка КАК ЛН
		             |ПОМЕСТИТЬ ШКДругихЛННеРазвернуто
		             |ИЗ
		             |	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		             |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
		             |		ПО (ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка)
		             |ГДЕ
		             |	ЛистНабора.Проведен
		             |	И НЕ ЛистНабораШтрихкодыУпаковок.Ссылка = &Ссылка
		             |	И ЛистНабора.ДокОснование = &ДокОснование
		             |
		             |ИНДЕКСИРОВАТЬ ПО
		             |	ШтрихкодУпаковки
		             |;
		             |
		             |////////////////////////////////////////////////////////////////////////////////
		             |ВЫБРАТЬ
		             |	ЕСТЬNULL(ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод, ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки) КАК ШКУпаковки,
		             |	ЛистНабораШтрихкодыУпаковок.ЛН КАК ЛН
		             |ПОМЕСТИТЬ ШКДругихЛН
		             |ИЗ
		             |	ШКДругихЛННеРазвернуто КАК ЛистНабораШтрихкодыУпаковок
		             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		             |		ПО ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
		             |
		             |ИНДЕКСИРОВАТЬ ПО
		             |	ШКУпаковки
		             |;
		             |
		             |////////////////////////////////////////////////////////////////////////////////
		             |ВЫБРАТЬ
		             |	ШКДругихЛН.ШКУпаковки КАК ШКУпаковки,
		             |	ШКДругихЛН.ЛН КАК ЛН
		             |ИЗ
		             |	ШКДругихЛН КАК ШКДругихЛН
		             |		ЛЕВОЕ СОЕДИНЕНИЕ ШКТекЛН КАК ШКТекЛН
		             |		ПО ШКДругихЛН.ШКУпаковки = ШКТекЛН.ШКУпаковки
		             |ГДЕ
		             |	НЕ ШКТекЛН.ШКУпаковки ЕСТЬ NULL";
		запрос.УстановитьПараметр("Ссылка",Ссылка);
		запрос.УстановитьПараметр("ТЗ",ШтрихкодыУпаковок);
		запрос.УстановитьПараметр("ДокОснование",ДокОснование);
		
		выборка=запрос.Выполнить().Выбрать();
		пока Выборка.Следующий() цикл
			МассивОшибок.Добавить(СтрШаблон("Марка %1 обнаружена в другом ЛН %2 требуется убрать эту марку либо из него, либо из %3",Выборка.ШКУпаковки,Выборка.лн,Ссылка));
		КонецЦикла;	
	КонецЕсли;

	если МассивОшибок.Количество()>0 тогда
		Результат.Успех=ложь;
		Результат.Ошибки=СтрСоединить(МассивОшибок,Символы.ПС);
	КонецЕсли;   
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	
	возврат Результат;

КонецФункции



Процедура ЗаполнитьДокументАгрегации () Экспорт 
	если КодАгрегации=Неопределено тогда
		возврат;
	КонецЕсли;
	
	ТЗТовары=товары.Выгрузить(,"Номенклатура");
	ТЗТовары.Свернуть("Номенклатура");
	если ТЗТовары.Количество()>1 тогда 
		ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
	иначе	
		ТипУпаковки=Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	КонецЕсли;	
	
	ДокМаркировки	= НайтиДокумент("МаркировкаТоваровИСМП", Новый Структура("ДокументОснование,ВидОперации,ТипУпаковки,Проведен", ДокОснование, Перечисления.ВидыОперацийМаркировки.Агрегация, ТипУпаковки,Истина));			
	если не ЗначениеЗаполнено(ДокМаркировки) тогда					
		ДокМаркировкиОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();						
		ЗаполнитьШапкуДокумента(ДокМаркировкиОбъект, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац);					
		ДокМаркировкиОбъект.Дата						= ТекущаяДата();
		ДокМаркировкиОбъект.Статус					= Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки;				
		ДокМаркировкиОбъект.ДокументОснование 		= ДокОснование;
		ДокМаркировкиОбъект.ТипУпаковки				= ТипУпаковки;
		ДокМаркировкиОбъект.ВидОперации				= Перечисления.ВидыОперацийМаркировки.Агрегация;
		ДокМаркировкиОбъект.ВидОперацииИСМП			= Перечисления.ВидыОперацийИСМП.Агрегация;
		ДокМаркировкиОбъект.ПодразделениеНанесения	= ПолучитьРеквизитШапки(ДокОснование,"Склад.Подразделение","Документ");						
		ДокМаркировкиОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	иначе
		ДокМаркировкиОбъект=ДокМаркировки.получитьОбъект();
	КонецЕсли;
	
	если ложь тогда ДокМаркировкиОбъект=документы.МаркировкаТоваровИСМП.СоздатьДокумент();КонецЕсли;
	СтрокаТЧ=ДокМаркировкиОбъект.ШтрихкодыКоробок.Найти(КодАгрегации,"ШтрихкодКоробки");
	если СтрокаТЧ<>Неопределено тогда
		если СтрокаТЧ.ДокументОснование<>Ссылка тогда
			ВызватьИсключение "Кривые коды агрегации!!! обратитесь к разработчикам";
			
		КонецЕсли;
	иначе
		СтрТЧ=ДокМаркировкиОбъект.ШтрихкодыКоробок.Добавить();
		СтрТЧ.ШтрихкодКоробки=КодАгрегации;
		СтрТЧ.ДокументОснование=Ссылка;
		ДокМаркировкиОбъект.Записать();	
	КонецЕсли;
	
КонецПроцедуры


Процедура ОбновитьШтрихкодыКоробокДляАгрегации()

	МассивДляУдаления = Новый Массив;
	МассивШК = ШтрихкодыУпаковок.ВыгрузитьКолонку("ШтрихкодУпаковки"); 
	
	Для каждого СтрокаШК  Из ШтрихкодыКоробокДляАгрегации Цикл
		
		Если МассивШК.Найти(СтрокаШК.НовыйКодКоробки) = неопределено Тогда
			
			МассивДляУдаления.Добавить(СтрокаШК); 
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Для каждого СтрокаДляУдаления  Из МассивДляУдаления Цикл
		
		ШтрихкодыКоробокДляАгрегации.Удалить(СтрокаДляУдаления); 
		
	КонецЦикла;
	
	ДополнительныеАгрегации = ШтрихкодыКоробокДляАгрегации.Количество() > 0; 

КонецПроцедуры 

Функция ПроверкаОтсканированныхЗаводскихКоробок(МассивОшибок)

	ОбновитьШтрихкодыКоробокДляАгрегации(); 
	
	ДатаПроверки = Константы.ДатаЗапретаРедактирования.Получить();
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистНабораШтрихкодыУпаковок.ИсходныйКодКоробки КАК ШКУпаковки,
	|	ЛистНабораШтрихкодыУпаковок.Ссылка КАК ЛН,
	|	ЛистНабора.Дата КАК Дата
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыУпаковок
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
	|		ПО (ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка)
	|ГДЕ
	|	ЛистНабора.Дата >= &Дата
	|	И ЛистНабора.ДокОснование ССЫЛКА Документ.РасходнаяНакладная
	|	И ЛистНабораШтрихкодыУпаковок.ИсходныйКодКоробки В(&ШтрихкодыУпаковки)
	|	И ЛистНабораШтрихкодыУпаковок.Ссылка <> &Ссылка
	|	И ЛистНабора.Проведен"; 
	Запрос.УстановитьПараметр("ШтрихкодыУпаковки",ШтрихкодыКоробокДляАгрегации.ВыгрузитьКолонку("ИсходныйКодКоробки"));
	Запрос.УстановитьПараметр("Дата", ДатаПроверки - 86400*30);
	Запрос.УстановитьПараметр("Ссылка",Ссылка);	
	
	Выборка =Запрос.Выполнить().Выбрать();  
	Пока Выборка.Следующий() Цикл
		МассивОшибок.Добавить(СтрШаблон("Старая коробка %1 обнаружена в другом ЛН %2 требуется убрать эту марку либо из него, либо из %3",Выборка.ШКУпаковки,Выборка.ЛН,Ссылка));
