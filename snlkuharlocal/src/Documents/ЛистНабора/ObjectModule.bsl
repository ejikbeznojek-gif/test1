Перем НужноВыгружать; //нечаева 02,09,16---
Перем ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН;
Перем ПланНабора;
// Кухарь А.Ю. 17.01.2020 начало
//Переход на ЗНБ
Перем ОтсканировалиНеТотЗНБ;
// Кухарь А.Ю. 17.01.2020 конец

Перем ЕстьЛистыПереукладки;

// Кухарь А.Ю.  25.02.2025 начало
Перем УпрощеннаяЗапись; 
// Кухарь А.Ю.  25.02.2025 конец

Перем ЭтоЗагрузкаСТСД; // Кельманов А.В. - HELP-7030 - 2025.09.18

//Кухарь 26.09.16 начало
//Процедура ОбработкаПроведения(Отказ, РежимПроведения)
Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;		
	
	Если УпрощеннаяЗапись = Истина Тогда
		Возврат;
	КонецЕсли; 
	
	// Кельманов А.В. - HELP-7030 - 2025.09.18 {
	Если ЭтоЗагрузкаСТСД = Истина Тогда
		Возврат;
	КонецЕсли; 
	// Кельманов А.В. - HELP-7030 - 2025.09.18 }
	
	Если ТипЗнч(ДокОснование)=Тип("ДокументСсылка.Инвентаризация") Тогда //по инвентаризациям не проверяем расхождения и перебор
		Возврат;	
	КонецЕсли; 	
	
	Если Склад.ТипСклада=Перечисления.ТипСклада.ВнешнийСклад тогда
		Если НЕ ЗначениеЗаполнено(им7) тогда
			Сообщить("Не задан ИМ7!");Отказ=Истина;Возврат;
		Конецесли;
	Конецесли;	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН=ОбщегоНазначения_ПИ.ЭтоУзел_ODN_или_OD7() И ЗаданияНабора.Количество()>0; 
	
	ДокОснованиеОбъект		=ДокОснование.ПолучитьОбъект();
	ВидДокументаОснования	=ДокОснование.Метаданные().Имя;
	
	
	//нечаева 13,10,16+++
	#Если Клиент Тогда
		ОбработкаСравненияЛН			= Обработки.СравнениеЛистовНабора.Создать();	
		ОбработкаСравненияЛН.Документ	= ДокОснование;
		
		Ошибки							= ОбработкаСравненияЛН.ПолучитьОшибкиНабора();		
		ЕстьОшибки						= Ошибки.Ошибки;
		
		Если ЕстьОшибки И Ошибки.ТП.Количество()>0 Тогда
			ОбработкаСравненияЛН.ВывестиТаблицуОшибок(Ошибки.ТП,"Перебор");	
		КонецЕсли;	
		
		ВидДокументаОснования	= ДокОснование.Метаданные().Имя;
		Если ВидДокументаОснования="КонтрактСПроизводителем" ИЛИ ВидДокументаОснования="ЗаказПоставщику" Тогда //Мессерле
			Возврат;
		КонецЕсли;	
		
		ДокОснованиеОбъект		= ДокОснование.ПолучитьОбъект();	
		ЕстьЛистыПереукладки	= ЕстьЛистыПереукладки();	
		
		БылоСостояние			= ДокОснованиеОбъект.СостояниеНакладной;
		Если ВидДокументаОснования="Перемещение" Тогда
			Если ДокОснованиеОбъект.Склад.КодФизическогоУзла<>ПараметрыСеанса.ЭтотУзел.Код Тогда
				//+HELP-2709 20250207 Михайловский
				Если (Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение) И НЕ ЗначениеЗаполнено(ДокОснованиеОбъект.Склад.КодФизическогоУзла) Тогда
					БылоСостояние		=ДокОснованиеОбъект.СостояниеНакладной;
					//-HELP-2709 20250207 Михайловский
				Иначе	
					БылоСостояние		=ДокОснованиеОбъект.СостояниеНакладнойУПолучателя;
				КонецЕсли;
			КонецЕсли;
			
			ЗаписатьВРегистр_Реквизиты_ТЧ_Товары_РНКПРМ(); //Катаев+ 28/01/14 Заносим в регистр сведений данные о листе набора		
		КонецЕсли;
		
		Если НЕ СостояниеДопустимо(БылоСостояние,ВидДокументаОснования) Тогда			
			СообщитьОбОшибке("Недопустимое состояние документа основания ! Состояние: "+БылоСостояние,Отказ);
			Возврат;								
		КонецЕсли; 
		
		НовоеСостояние			= БылоСостояние;
		НадоЗаписатьВДокумент	= Ложь;
		
		Если ВидДокументаОснования="ПриходнаяНакладная" Тогда			
			Если ЕстьОшибки Тогда
				НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;				
			Иначе
				НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКПриемке;				
			КонецЕсли;
			
			//крохин начало 22.09.2014
			Если НЕ ЕстьОшибки ИЛИ (ЕстьОшибки И БылоСостояние  <> Перечисления.СостоянияНакладной.Сканирование) Тогда
				НадоЗаписатьВДокумент=Истина;
			КонецЕсли;
			
			ЗаписатьКоличествоИОбъемКоробовВРегистр(ДокОснованиеОбъект,Ошибки.КоличествоКоробок,Ошибки.ОбъемКоробов);
		ИначеЕсли ВидДокументаОснования="РасходнаяНакладная" Тогда			
			//крохин начало 11.12.2013
			//в ODN состояния меняем планом набора, если есть				
			Если НЕ ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда				
				Если ЕстьОшибки Тогда
					НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;
				Иначе
					Если ТребуетсяДопОбработка(ДокОснование) Тогда
						НовоеСостояние=Перечисления.СостоянияНакладной.ДопОбработка;
					Иначе
						НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;							
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;				
			//крохин конец 11.12.2013				
			
			Если НЕ ЕстьЛистыПереукладки Тогда								
				Если НЕ ЕстьОшибки ИЛИ (ЕстьОшибки И БылоСостояние  <> Перечисления.СостоянияНакладной.Сканирование) Тогда					
					Если НЕ ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда
						НадоЗаписатьВДокумент=Истина;
					КонецЕсли;
				КонецЕсли;
				
				Если НЕ ЕстьОшибки И ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда					
					если НовоеСостояние<>БылоСостояние тогда
						НадоЗаписатьВДокумент=Истина;
					КонецЕсли; 
				КонецЕсли;
				//запись количества коробок и объёма коробок в регистр, чтобы уйти от реквизитов
				ЗаписатьКоличествоИОбъемКоробовВРегистр(ДокОснованиеОбъект,Ошибки.КоличествоКоробок,Ошибки.ОбъемКоробов);					
			КонецЕсли;
			
		ИначеЕсли ВидДокументаОснования="Перемещение" Тогда
			Если ДокОснованиеОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда				
				//в ODN состояния меняем планом набора, если есть				
				Если НЕ ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда									
					Если ЕстьОшибки Тогда
						НовоеСостояние	=Перечисления.СостоянияНакладной.Сканирование;							
					Иначе						
						НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
						Если ТребуетсяДопОбработка(ДокОснование) И НЕ ДокОснование.Склад.ТипСклада=Перечисления.ТипСклада.РозничныйТЦ Тогда
							НовоеСостояние=Перечисления.СостоянияНакладной.ДопОбработка;								
						КонецЕсли;
					КонецЕсли;					
				КонецЕсли;
				//крохин конец 11.12.2013				
				
				Если НЕ ЕстьОшибки ИЛИ (ЕстьОшибки И ДокОснованиеОбъект.Ссылка.СостояниеНакладной  <> Перечисления.СостоянияНакладной.Сканирование) Тогда					
					Если НЕ ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда	
						// Кухарь А.Ю. 24.03.2021 начало
						// НадоЗаписатьВДокумент=Истина;
						если НовоеСостояние<>БылоСостояние тогда
							НадоЗаписатьВДокумент=Истина;
						КонецЕсли; 
						// Кухарь А.Ю. 24.03.2021 конец					
					КонецЕсли;
				КонецЕсли;
				
				Если НЕ ЕстьОшибки И ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН Тогда					
					НадоЗаписатьВДокумент=Истина;
				КонецЕсли;				
				
				ЗаписатьКоличествоИОбъемКоробовВРегистр(ДокОснованиеОбъект,Ошибки.КоличествоКоробок,Ошибки.ОбъемКоробов);				
			Иначе
				Если ЕстьОшибки Тогда
					НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;
				Иначе
					НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКПриемке;
				КонецЕсли;				
				
				Если БылоСостояние<>НовоеСостояние Тогда
					НадоЗаписатьВДокумент=Истина;
				КонецЕсли;				
			КонецЕсли;			
		ИначеЕсли ВидДокументаОснования="ПродажаИМ" Тогда			
			НадоЗаписатьВДокумент=Истина;
			Если ЕстьОшибки Тогда
				НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;
			Иначе
				НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
			КонецЕсли;			
		КонецЕсли;	
		
		Если НадоЗаписатьВДокумент Тогда
			//Кухарь 16.12.19 начало
			//ДокОснованиеОбъект.СостояниеНакладной             =НовоеСостояние;
			если ВидДокументаОснования="Перемещение" и ДокОснованиеОбъект.Склад.КодФизическогоУзла<>ПараметрыСеанса.ЭтотУзел.Код тогда
				//+HELP-2709 20250207 Михайловский
				Если (Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение) И НЕ ЗначениеЗаполнено(ДокОснованиеОбъект.Склад.КодФизическогоУзла) Тогда
					ИмяРеквизитаСостояния="СостояниеНакладной";
					Если НовоеСостояние=Перечисления.СостоянияНакладной.ГотоваКПриемке Тогда
						НовоеСостояние = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
					КонецЕсли;	
				Иначе
					//-HELP-2709 20250207 Михайловский
					ИмяРеквизитаСостояния="СостояниеНакладнойУПолучателя";
				КонецЕсли;
			иначе
				ИмяРеквизитаСостояния="СостояниеНакладной";
			КонецЕсли;
			ДокОснованиеОбъект[ИмяРеквизитаСостояния]=НовоеСостояние;
			//Кухарь 16.12.19 конец                            
			
			ДокОснованиеОбъект.КоличествоКоробок    =Ошибки.КоличествоКоробок;
			ДокОснованиеОбъект.ОбъемКоробов                                             =Ошибки.ОбъемКоробов;
			
			ДокОснованиеОбъект.Записать();                                                       
		КонецЕсли;
		
	# КонецЕсли
	//нечаева 13,10,16---	
	
	//крохин начало 17.10.2013
	//контроль строк плана набора	
	Если ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН  Тогда
		ОбработатьПланНабора (ВидДокументаОснования);	 
	КонецЕсли;			
	//крохин конец 17.10.2013	
КонецПроцедуры //ОбработкаПроведения(Отказ, РежимПроведения) Экспорт


Процедура ЗаписатьВРегистр_Реквизиты_ТЧ_Товары_РНКПРМ()
	ОчиститьРегистр_РеквизитыТЧ_Товары_РНКПНКПРМ();	
	Если ДокОснование.СкладПолучатель.ТипСклада = Перечисления.ТипСклада.ПалетноеХранение Тогда
		НаборЗаписей = РегистрыСведений.РеквизитыТЧ_Товары_РНКПНКПРМ.СоздатьНаборЗаписей();
		// Кухарь А.Ю. 26.08.2021 начало
		//
		НаборЗаписей.Отбор.Документ.Установить(ДокОснование,Истина);			
		НаборЗаписей.Отбор.ИмяРеквизита.Установить("Номер ЛН "+Номер+" от "+Формат(Дата, "ДЛФ=Д"),Истина);			 
		// Кухарь А.Ю. 26.08.2021 конец
		
		НаборЗаписей.Прочитать();
		//Катаев+ 07/02/14 В одном ЛН может быть несколько одинаковых номенклатур с различными ШК
		//Для Каждого стрТовара из Товары Цикл
		тз = Товары.Выгрузить();
		тз.Свернуть("Номенклатура", "Количество");
		Для Каждого стрТовара из тз Цикл
			//Катаев- 07/02/14
			стр = НаборЗаписей.Добавить();
			
			стр.Активность 			= Истина;
			стр.Документ			= ДокОснование;
			стр.Номенклатура 		= стрТовара.Номенклатура;
			стр.ИмяРеквизита 		= "Номер ЛН "+Номер+" от "+Формат(Дата, "ДЛФ=Д");
			стр.ЗначениеРеквизита 	= стрТовара.Количество;
		КонецЦикла;
		НаборЗаписей.Записать();
		
		//Катаев+ 07/02/14 Регистрируем записи из набора записей в SNL
		// Кухарь А.Ю. 26.08.2021 начало
		//
		если ложь тогда
			
			// Кухарь А.Ю. 26.08.2021 конец
			
			УзелSNL=ПланыОбмена.Основной.НайтиПоКоду("SNL");
			тзНаборЗаписей = НаборЗаписей.Выгрузить();
			Для Каждого Выборка Из тзНаборЗаписей Цикл
				НаборЗаписей.Отбор.Документ.Установить(Выборка.Документ,Истина);			
				НаборЗаписей.Отбор.Номенклатура.Установить(Выборка.Номенклатура,Истина);			
				НаборЗаписей.Отбор.ИмяРеквизита.Установить(Выборка.ИмяРеквизита,Истина);			
				
				НаборЗаписей.Прочитать();
				
				НаборЗаписей.ОбменДанными.Получатели.Добавить(УзелSNL);			  
				ПланыОбмена.ЗарегистрироватьИзменения(УзелSNL,НаборЗаписей);			
			КонецЦикла;
			//Катаев- 07/04/14
			// Кухарь А.Ю. 26.08.2021 начало
			//
		КонецЕсли; 
		// Кухарь А.Ю. 26.08.2021 конец
		
	КонецЕсли;
	
КонецПроцедуры


//Кухарь 26.09.16 начало
//Процедура ОбработкаУдаленияПроведения(Отказ)
Процедура ОбработкаУдаленияПроведения(Отказ) экспорт
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;	
	
	ЕстьЛистыПереукладки=ЕстьЛистыПереукладки();
	
	ДокОснованиеМетаДок	= ДокОснование.Метаданные();
	ДокОснованиеОбъект	= ДокОснование.ПолучитьОбъект();
	ВидОснования		= ДокОснованиеМетаДок.Имя;
	
	//Кухарь 20.08.14 начало		
	Если НЕ ЕстьЛистыПереукладки Тогда	
		Если ЕстьРеквизитДокумента("ОбъемКоробов",ДокОснованиеМетаДок) Тогда
			ДокОснованиеОбъект.ОбъемКоробов		=ДокОснованиеОбъект.ОбъемКоробов	-ОбъемКоробов;	
		КонецЕсли;		
		Если ЕстьРеквизитДокумента("КоличествоКоробок",ДокОснованиеОбъект.Метаданные()) Тогда
			ДокОснованиеОбъект.КоличествоКоробок=ДокОснованиеОбъект.КоличествоКоробок-КоличествоКоробок;	
		КонецЕсли;		
	КонецЕсли;
	//Кухарь 20.08.14 конец
	
	Попытка
		ДокОснованиеОбъект.Записать(РежимЗаписиДокумента.Запись);	
		Если ЕстьРеквизитДокумента("КоличествоКоробок",ДокОснованиеМетаДок) Тогда
			ЗаписатьКоличествоИОбъемКоробовВРегистр(ДокОснованиеОбъект,ДокОснованиеОбъект.КоличествоКоробок,ДокОснованиеОбъект.ОбъемКоробов);
		КонецЕсли;	
	Исключение
		СообщитьОбОшибке("Ошибка при корректировке объема накладной ! "+ОписаниеОшибки(),Отказ);
	КонецПопытки;
	
	//Катаев+ 28/01/14 Удаляем записи из регистра сведений	
	Если ВидОснования="Перемещение" Тогда
		ОчиститьРегистр_РеквизитыТЧ_Товары_РНКПНКПРМ();	
	КонецЕсли;	
	//Катаев- 28/01/14	
	
	// Кухарь А.Ю.  12.12.2024 начало
	если ВидОснования="РасходнаяНакладная" тогда
		если КодАгрегации<>Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() тогда
			СообщитьИзМодуля("У этого ЛН установлен код агрегации, распроведение запрещено.");
			отказ=Истина;
		КонецЕсли;
		
		// Кухарь А.Ю. 01.03.2025 начало
		// 
