	для Каждого СтрПер из Переклейка цикл
		Отбор=новый Структура;
		Отбор.Вставить("ШтрихКод",СтрПер.ШтрихКод);
		Отбор.Вставить("ДобавленоВРучную",ложь);
		МассСтрок=СтараяТЗПереклейки.НайтиСтроки(отбор);
		КоличествоТЗПер=0;
		для каждого СтрМасс из МассСтрок цикл
			если СтрПер.заявка=СтрМасс.Количество тогда
				КоличествоТЗПер=СтрМасс.количество;
			иначе 
				Продолжить;
			КонецЕсли;
		КонецЦикла;
		СтрПер.Количество=КоличествоТЗПер;	
	КонецЦикла;
	отбор=новый Структура;
	Отбор.Вставить("ДобавленоВРучную",Истина);
	МассСтарыхСтрока=СтараяТЗПереклейки.НайтиСтроки(Отбор);
	для каждого СтрТЗ из МассСтарыхСтрока цикл
		СтрТЧ=Переклейка.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТч,СтрТз);
	КонецЦикла;
	Отбор=новый Структура("Заявка",0);
	МассНулей=ТЗПереклейки.НайтиСтроки(Отбор);
	для каждого СтрНулей из МассНулей цикл
		Инд=ТЗПереклейки.Индекс(СтрНулей);
		ТЗПереклейки.Удалить(Инд);
	КонецЦикла;
КонецПроцедуры


Функция ПолучитьШККонтрагентаИзМатрицы(Номенклатура)
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= "
	|ВЫБРАТЬ
	|	МатрицаТовары.ШККонтрагента
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ПО 
	|	МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &ДатаОкончания
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Номенклатура = &Номенклатура";
	запрос.УстановитьПараметр("ПунктДоставки",ДокОснование.ПунктДоставки);
	Запрос.УстановитьПараметр("Дата",ДокОснование.Дата);
	Запрос.УстановитьПараметр("ДатаОкончания",ДокОснование.Дата);
	Запрос.УстановитьПараметр("Договор",ДокОснование.договор);	
	Запрос.УстановитьПараметр("Контрагент",ДокОснование.Контрагент);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Попытка
		Если ДокОснование.Ссылка.ПостояннаяАкция Тогда
			Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
		Иначе
			Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		если СокрЛП(результат.ШККонтрагента)<>"" тогда
			Возврат результат.ШККонтрагента;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ""
КонецФункции	

Процедура 	ЗаполнитьШКМатрицы ()
	запрос=новый запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
	|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Номенклатура В(&Номенклатура)";
	
	
	Попытка
		Если ДокОснование.Ссылка.ПостояннаяАкция Тогда
			Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
		Иначе
			Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
		КонецЕсли;
	Исключение
	КонецПопытки;	
	
	
	Запрос.УстановитьПараметр("Дата2",НачалоДня(Дата));
	Запрос.УстановитьПараметр("Дата1",КонецДня(Дата));
	Запрос.УстановитьПараметр("Контрагент",ДокОснование.Контрагент);
	Запрос.УстановитьПараметр("ПунктДоставки",ДокОснование.ПунктДоставки);
	Запрос.УстановитьПараметр("Договор",ДокОснование.Договор);
	Запрос.УстановитьПараметр("Номенклатура",Товары.ВыгрузитьКолонку("Номенклатура"));
	
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("ШККонтрагента");
	ТЗ.Колонки.Добавить("КратностьКоробки");
	Пока Выборка.Следующий() Цикл
		СтрокаТЗ = ТЗ.Добавить();
		СтрокаТЗ.Номенклатура = Выборка.Номенклатура;
		СтрокаТЗ.ШККонтрагента = Выборка.ШККонтрагента;
		СтрокаТЗ.КратностьКоробки = Выборка.КратностьКоробки;			
	КонецЦикла;
	
	
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.Количество = 0 Тогда Продолжить Конецесли;
		Если ДокОснование.ОтгрузкаКомплектов Тогда
			НадоКонтролировать = Ложь;
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Продукция", СтрокаТЧ.Номенклатура);
			НайденныеСтроки = ДокОснование.Комплектующие.НайтиСтроки(ПараметрыОтбора);
			Для СЧ = 0 По НайденныеСтроки.Количество()-1 Цикл
				НайденнаяСтрока = НайденныеСтроки.Получить(Сч);
				Если НайденнаяСтрока.Номенклатура = НайденнаяСтрока.продукция Тогда
					НадоКонтролировать = Истина;
				КонецЕсли;
			КонецЦикла;
			Если НЕ НадоКонтролировать Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Отбор = новый Структура;
		Отбор.Вставить("Номенклатура",СтрокаТЧ.Номенклатура);
		СтрокиМатриц = ТЗ.НайтиСтроки(Отбор); 
		Если СтрокиМатриц.Количество() = 0 Тогда
			ВсеХорошо = Ложь;			
		Иначе
			ШКСовпадают = Ложь;
			Если СтрокаТЧ.ТипШК = Перечисления.ТипыШтрихКодов.Штука ИЛИ СтрокаТЧ.ТипШК.Пустая() Тогда
				Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
					ТекШКМатрицы = СтрокаМатриц.ШККонтрагента;
					СтрокаТЧ.ШКМатрицы = ТекШКМатрицы;
					
				КонецЦикла;
			Иначе
				ТекШКШтуки = ПолучитьШтрихКодТовара(СтрокаТЧ.Номенклатура);
				КоличествоШКШтуки = 0;
				ЗапросКоличествоШКШтуки=Новый Запрос;
				ЗапросКоличествоШКШтуки.Текст="
				|ВЫБРАТЬ
				|    Ссылка,
				|	Наименование
				|ИЗ
				|	Справочник.ШтрихКоды КАК ШтрихКоды
				|ГДЕ
				|	Владелец = &Владелец
				|	И ТипШК = &ТипШК";
				
				ЗапросКоличествоШКШтуки.УстановитьПараметр("Владелец",СтрокаТЧ.Номенклатура);
				ЗапросКоличествоШКШтуки.УстановитьПараметр("ТипШК",Перечисления.ТипыШтрихКодов.Штука);
				ВыборкаКоличествоШКШтуки = ЗапросКоличествоШКШтуки.Выполнить().Выбрать();
				КоличествоШКШтуки = ВыборкаКоличествоШКШтуки.Количество();
				Если КоличествоШКШтуки = 1 Тогда
					Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
						ТекШКМатрицы = СтрокаМатриц.ШККонтрагента;
						СтрокаТЧ.ШКМатрицы = ТекШКМатрицы;
					КонецЦикла;
				Иначе
					Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
						ТекШКМатрицы = СтрокаМатриц.ШККонтрагента;
						СтрокаТЧ.ШКМатрицы = ТекШКМатрицы;
						Прервать;
					КонецЦикла;
					Сообщить("по номенклатуре "+СтрокаТЧ.Номенклатура+ "заведено "+КоличествоШКШтуки +" ШК штуки, проверьте штрихкод на соответствие матрице. Номер строки "+СтрокаТЧ.НомерСтроки);
				КонецЕсли;				
			Конецесли;
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры

Функция ЕстьЛистыПереукладки() Экспорт
	ЛП=ПолучитьЛистыПереукладки(ДокОснование);
	Возврат ЛП.Количество()>0;
КонецФункции //ЕстьЛистыПереукладки()

Функция СостояниеДопустимо(Состояние,ВидДокументаОснования)
	Результат=Истина;
	Если ВидДокументаОснования="ПриходнаяНакладная" Тогда
		Если Состояние=Перечисления.СостоянияНакладной.Принята Тогда
			Результат=Ложь;
		КонецЕсли;
	ИначеЕсли ВидДокументаОснования="РасходнаяНакладная" Тогда
		Если Состояние=Перечисления.СостоянияНакладной.Отгружена Тогда
			Результат=Ложь;
		КонецЕсли;
	ИначеЕсли ВидДокументаОснования="Перемещение" Тогда
		КодСкладаОтправителя=ПолучитьРеквизитШапки(ДокОснование,"Склад.КодФизическогоУзла","Документ");
		Если КодСкладаОтправителя=ПараметрыСеанса.ЭтотУзел.Код Тогда
			Если Состояние=Перечисления.СостоянияНакладной.Отгружена Тогда
				Результат=Истина;
			КонецЕсли;
		Иначе
			Если Состояние=Перечисления.СостоянияНакладной.Принята Тогда
				Результат=Истина;
			КонецЕсли;			
		КонецЕсли;		
	ИначеЕсли ВидДокументаОснования="ПродажаИМ" Тогда		
		Если Состояние=Перечисления.СостоянияНакладной.Отгружена Тогда
			Результат=Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()


Функция ПолучитьЧисловыеКодыСтрокПН()
	МР=Новый Массив;	
	Для Каждого СтрокаТЧ Из СтрокиПлановНабора Цикл
		МР.Добавить(Число(СтрокаТЧ.НомерСтрокиПланаНабора));	
	КонецЦикла;	
	Возврат МР;
КонецФункции //ПолучитьЧисловыеКодыСтрокПН() 


Процедура ДозаполнитьШтВКоробе()	
	ОтборПоНулям=Новый Структура;
	ОтборПоНулям.Вставить("ШтВКоробе",0);
	ТЗНулей		=Товары.НайтиСтроки(ОтборПоНулям);
	Для Каждого СтрТЗ из ТЗНулей цикл
		СтрТЗ.ШтВКоробе=СтрТЗ.Номенклатура.Родитель.ШтукВКоробке;
	КонецЦикла;
КонецПроцедуры

Функция ЕстьПаузаВСканировании() Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка	
	|ИЗ
	|	Документ.ПланНабора.тБрэндов
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокОснование
	|	И НомерСтроки В (&СписокНомеров)
	|	И НачалоОстановкиСканирования>ДАТАВРЕМЯ(1,1,1)
	|";
	
	Запрос.УстановитьПараметр("ДокОснование",	ДокОснование);
	Запрос.УстановитьПараметр("СписокНомеров",	ПолучитьЧисловыеКодыСтрокПН());	
	
	Результат=Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
КонецФункции //ЕстьПаузаВСканировании()

Процедура ОбработатьПланНабора (ВидДокументаОснования)
	
	Если СтрНайти("Перемещение,РасходнаяНакладная,Комплектация",ВидДокументаОснования)<>0 Тогда
		ПланНабора=НайтиДокумент("ПланНабора",Новый Структура("ДокОснование,Проведен",ДокОснование,Истина));	 
		
		ЗНБсОшибками = ПроверитьОшибкиПоЗНБ();	 			
		ВремяОкончания 		= ТекущаяДата();
		ПланНабораОбъект 	= ПланНабора.ПолучитьОбъект();
		
		для каждого СтрЗНБ из ЗаданияНабора цикл
			ЗНБ=СтрЗНБ.ЗаданиеНабора;		
			Если ОтсканировалиНеТотЗНБ=Истина Тогда
				Отказ 		= Истина;				
				#Если Клиент Тогда
					Сообщить("Не совпадает номенклатура в планах набора и листе набора! Пересканируйте планы набора!");						
				#КонецЕсли	
				Отказ = Истина;	
			КонецЕсли;		
			СтароеСостояние=ЗНБ.СостояниеНакладной;
			если СтароеСостояние=Перечисления.СостоянияНакладной.ОжиданиеНабора или СтароеСостояние=Перечисления.СостоянияНакладной.ВНаборе тогда
				#Если Клиент Тогда
					Сообщить("Не закончен набор! Завершение сканирования невозможно!");	
				#КонецЕсли
				Продолжить;
			КонецЕсли;		
			
			если ПолучитьНомерСостоянияНакладной(СтароеСостояние)>745 тогда
				Продолжить;
			КонецЕсли;	
			
			СтрТЗ=ЗНБсОшибками.найти(ЗНБ);	
			если СтрТЗ=Неопределено тогда
				НовоеСостояние=ПолучитьНовоеСостояниеЗНБ (ЗНБ,Перечисления.СостоянияНакладной.Сканирование);
				НужноЗаканчиватьСканирование=Истина;	
			иначе
				НовоеСостояние=Перечисления.СостоянияНакладной.Сканирование;
				НужноЗаканчиватьСканирование=ложь;
			КонецЕсли;		
			
			если НовоеСостояние<>СтароеСостояние тогда			
				МассСтрок=ПланНабораОбъект.тБрэндов.найтистроки(новый Структура("НомерЧасти",ЗНБ.НомерЧасти)); 
				
				//Тимофеев Ю.А. 21.04.2026
				//https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-105
				ADRESS.СнятьЗанятостьСотрудника(МассСтрок,Ссылка,"Лист набора");
				//Тимофеев Ю.А. 21.04.2026 
				
				для каждого СтрокаПН из МассСтрок цикл
					СтрокаПН.Состояние 				= НовоеСостояние;
					если НужноЗаканчиватьСканирование=Истина тогда
						СтрокаПН.ОкончаниеСканировки	= ВремяОкончания;
						СтрокаПН.СканировкаЗакончена	= Истина;
						СтрокаПН.ВремяТекущегоСостояния = ВремяОкончания; 
						
						 
						
						если СтрокаПН.НачалоСканировки=ПустаяДата() тогда
							СтрокаПН.НачалоСканировки=ВремяОкончания-1;
						КонецЕсли;
					КонецЕсли;					
				КонецЦикла;		 
			КонецЕсли;
		КонецЦикла;
		
		если ПланНабораОбъект.Модифицированность() тогда
			ПланНабораОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;			
КонецПроцедуры


//СОБЫТИЯ ДОКУМЕНТА
Процедура ОбработкаЗаполнения(Основание)
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Основание) Тогда Возврат КонецЕсли; 
	
	ДокОснование	= Основание.Ссылка;
	
	ВидОснования	= ДокОснование.Метаданные().Имя;
	Если НЕ (ВидОснования="КонтрактСПроизводителем" или  ВидОснования="ЗаказПоставщику") тогда
		ИБ			= Основание.ИБ;
	Конецесли;
	Склад			= ДокОснование.Склад;		
	
	Если ВидОснования="Перемещение" Тогда
		РеквизитыШапки=ПолучитьРеквизитыШапки(ДокОснование,"Склад,СкладПолучатель","Документ");
		Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			СкладПользователя=ПолучитьЗначениеПоУмолчанию("ОсновнойСклад");
			Если ЗначениеЗаполнено(СкладПользователя) Тогда
				Если РеквизитыШапки.Склад=СкладПользователя Тогда
					//оставляем как есть склад документа
				ИначеЕсли РеквизитыШапки.СкладПолучатель=СкладПользователя Тогда
					Склад = РеквизитыШапки.СкладПолучатель;
				КонецЕсли; 			
			Иначе				
				Если РеквизитыШапки.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					//если для полдьзователя не задан склад то считаем что лист набора на отгрузку 
					//оставляем как есть склад документа
				ИначеЕсли РеквизитыШапки.СкладПолучатель.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					Склад = РеквизитыШапки.СкладПолучатель;									
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.

	//Чтобы ничего не происходило, когда я обработкой заполняю ошибки сотрудников
	Если  ПараметрыСеанса.ЗапущенаОбработка Тогда Возврат КонецЕсли;

	Если Модифицированность() Тогда	
		ЗаданиеНабора = ОпределитьЗаданиеНабора();
	КонецЕсли;	
	
	если ТипШК<>Перечисления.ТипыШтрихКодов.Коробка тогда
		КоличествоКоробок = 1;
	КонецЕсли;

	Если ДополнительныеСвойства.Свойство("ЗагрузкаСТСД") Тогда
		ЭтоЗагрузкаСТСД = ДополнительныеСвойства.ЗагрузкаСТСД;
	Иначе
		ЭтоЗагрузкаСТСД = Ложь;
	КонецЕсли;

	Если (СозданНаТСД И ОбменДанными.Загрузка) Или ЭтоЗагрузкаСТСД Тогда
		ЗаполнениеЛНПриЗагрузкеСТСД();	
	КонецЕсли; 

	Если ДополнительныеСвойства.Свойство("УпрощенныйРежим") Тогда
		УпрощеннаяЗапись = ДополнительныеСвойства.УпрощенныйРежим;
	Иначе
		УпрощеннаяЗапись = Ложь;
	КонецЕсли;
	
	
	
	Если РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения Или (СозданНаТСД И ОбменДанными.Загрузка) Или ЭтоЗагрузкаСТСД Тогда

		НеобходимостьПроверки = новый Структура("Успех",Истина);
		если НеобходимостьПроверки.Успех  тогда		
			
			если ТипЗнч(ДокОснование)=Тип("ДокументСсылка.ПриходнаяНакладная")  
				или (ТипЗнч(ДокОснование)=Тип("ДокументСсылка.РасходнаяНакладная") и ПолучитьРеквизитШапки(ДокОснование,"ТребуетсяМаркировка","Документ"))
				тогда 			 
				если не ОтключитьКонтрольСканирования и не УпрощеннаяЗапись тогда

					РезультатПРоверки = КонтрольКорректностиСканированияЧЗВЛЗ();    
					
					Если Не РезультатПРоверки.Успех Тогда
						
						Отказ = Истина;
						
						ВызватьИсключение РезультатПРоверки.Ошибки;
						
					КонецЕсли;

				КонецЕсли;

			КонецЕсли; 

		КонецЕсли;
		
	КонецЕсли;

	// Кельманов А.В. - Оптимизация работы - 2026.04.23 {
	//Если ОбменДанными.Загрузка Или ЭтоЗагрузкаСТСД Тогда Возврат КонецЕсли;
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 }

	КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
	МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
	МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
	ЕстьИзменения	= Модифицированность();

	Если Отказ Тогда Возврат КонецЕсли;
	ЭтоУзел_ODN_или_OD7_И_ЕстьСтрокиПН=ОбщегоНазначения_ПИ.ЭтоУзел_ODN_или_OD7() И ЗаданияНабора.Количество()>0;

	ВидДокументаОснования=ДокОснование.Метаданные().Имя;
	
	
	// Кухарь А.Ю.  11.04.2026 начало
	//HELP-9419
	Если ВидДокументаОснования = "РасходнаяНакладная" и РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения и Модифицированность() тогда 
		НачальноеКоличествоСтрокКоробок = 0;
		ТекущееКоличествоСтрокКоробок 	= 0;	  
		
		Если не ЭтоНовый() тогда 
			Запрос = новый запрос;
			запрос.Текст = "ВЫБРАТЬ
			|	КОЛИЧЕСТВО(ЛистНабораНомераКоробок.НомерСтроки) КАК КоличествоСтрок
			|ИЗ
			|	Документ.ЛистНабора.НомераКоробок КАК ЛистНабораНомераКоробок
			|ГДЕ
			|	ЛистНабораНомераКоробок.Ссылка = &Ссылка";
			запрос.УстановитьПараметр("Ссылка",Ссылка); 
			Выборка = запрос.Выполнить().Выбрать(); 
			пока Выборка.Следующий() цикл    
				НачальноеКоличествоСтрокКоробок = Выборка.КоличествоСтрок;
			КонецЦикла;	
			
			ТекущееКоличествоСтрокКоробок = НомераКоробок.Количество();			
		КонецЕсли;   
		если ТекущееКоличествоСтрокКоробок > НачальноеКоличествоСтрокКоробок тогда 
			Результат = КонтрольДублейСтрокКоробовЛиста(ЭтотОбъект);
			Если не Результат.Успех тогда  
				ТекстОшибки = "Не удалось записать ЛН "+Номер+" "+СтрСоединить(Результат.Ошибки,Символы.ПС);
                НомераКоробок.Очистить();
				#Если Клиент тогда
					Сообщить(ТекстОшибки);
					отказ = Истина;
				#Иначе
					ВызватьИсключение ТекстОшибки;
				#КонецЕсли
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	// Кухарь А.Ю.  11.04.2026 конец
	
	
	если ЕстьИзменения тогда 
		КоличествоДокумента =Товары.Итог("Количество");	
		ГруппыТоваров		=ГруппыТоваровДокумента(ЭтотОбъект);	 

		//На всякий проверим на нули в колонке шт. в коробе и перезаполним	
		ДозаполнитьШтВКоробе();	
		
		ОбъемДокумента	= Товары.Итог("Объем");	
		Если ТипШК=Перечисления.ТипыШтрихКодов.Коробка Тогда
			ОбъемКоробов		= ОбъемДокумента;	
			
			КоличествоКоробок	= 0;			
			Для Каждого СтрокаТз из Товары цикл
				Количествокоробок=Количествокоробок+?(СтрокаТЗ.ШтВКоробе=0,СтрокаТз.Количество,СтрокаТз.Количество/СтрокаТз.ШтВКоробе);
			КонецЦикла;
		Иначе		
			//возможно заведение объема вручную		
			Если ТипКороба <> Справочники.ТипыКоробов.ЗаведениеВручную Тогда	
				ОбъемКоробов =?(ТипКороба.Пустая(),ОбъемДокумента,ТипКороба.Объем);
			КонецЕсли;
			КоличествоКоробок=1;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(Им7) тогда
			Для Каждого стр из товары цикл
				Если НЕ ЗначениеЗаполнено(стр.ШтВКоробе) тогда
					Сообщить("Не заполнены шт. в коробке для "+стр.Номенклатура);
					Отказ=Истина;
					Возврат;
				Конецесли;	
			Конеццикла;	
		Конецесли;	
	КонецЕсли; 

	Если Не ЭтоНовый() Тогда
		ОбновитьШтрихкодыКоробокДляАгрегации();	
	КонецЕсли; 

	Если Не Отказ 
		И (ПометкаУдаления 
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения) Тогда
		
		НомераКоробок.Очистить(); 
		
		//++Данилова Е.В. 28.04.2026 HELP-9565 
		РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(ссылка); 
		//--Данилова Е.В. 28.04.2026 
		//++Данилова Е.В. 19.05.2026 HELP-9825 перенесла в при записи 
		//++Данилова Е.В. 08.05.2026 HELP-9716 
	//Иначе 
	//	Если НЕ ЭтоНовый()
	//		И ЗначениеЗаполнено(ДокОснование) 
	//		И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
	//		Обработки.ПечатьЛистаНабора.ПроверитьЗанятыеНомераБезЗаписиВЛист(ДокОснование,ссылка);
	//	КонецЕсли;
		//--Данилова Е.В. 08.05.2026 
		//--Данилова Е.В. 19.05.2026 
	КонецЕсли;
	
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 {
	//если УпрощеннаяЗапись тогда
	Если УпрощеннаяЗапись Или ЭтоЗагрузкаСТСД Тогда
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 }
		Возврат;
	КонецЕсли;

	СформироватьШКЛистаНабора();		
	
	Если ЭтоНовый() И ВидДокументаОснования<>"ПриходнаяНакладная"  тогда     	 

		Дата=ТекущаяДата();		

		если  не ОбщегоНазначения_ПИ.ПечататьКоробныеЭтикеткиНовойКомпонентой(ДокОснование) тогда
			Если ШКЛистаНабора="" И ОбщегоНазначения_ПИ.ЭтоУзел_Склад() тогда
				ЛН=Документы.ЛистНабора.НайтиПоРеквизиту("ШКЛистаНабора",ШКЛистаНабора);
				Если НЕ ЛН.Пустая() Тогда
					#Если клиент тогда
						Сообщить("Сбой формирования ШК, попробуйте записать ЛН ещё раз."); 
					#КонецЕсли
					ШКЛистаНабора="";
					Отказ=Истина;
				КонецЕсли;
			КонецЕсли;   
		КонецЕсли;
	КонецЕсли;

	ПереклейкаОтсканирована=Истина; 

	#Если клиент тогда
		
		Если ОбщегоНазначения_ПИ.ЭтоУзел_ODN_или_OD7() И ВидДокументаОснования <> "ПриходнаяНакладная" Тогда
			если ЗаданияНабора.Количество()>0 тогда
				//Иногда не заполняется ШК матрицы в перед записью на форме
				Если ВидДокументаОснования="РасходнаяНакладная" и ЭтотОбъект.ДокОснование.Контрагент.ИспользоватьНоменклатурнуюМатрицу Тогда
					Если Товары.Количество()>0 тогда
						Если Товары[0].ШКМатрицы="" тогда
							ЗаполнитьШКМатрицы();
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				Если ЕстьПаузаВСканировании() тогда
					Отказ=Истина;
					Сообщить("Для строк плана набора из этого ЛН сканирование приостановлено. Перед началом работы с этими строками плана набора, нужно отсканировать ШК снятия паузы и ШК плана набора.");
				КонецЕсли;
				
			КонецЕсли;

			Если ЕстьИзменения И ВидДокументаОснования = "РасходнаяНакладная" и РежимЗаписи<>РежимЗаписиДокумента.ОтменаПроведения Тогда			

				ДопПараметрыНакладной= ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(ДокОснование);
				если ДопПараметрыНакладной.ЗаполнятьПереклейку тогда	
					ЗаполнитьТЧПереклейка();	
				КонецЕсли;
				
				//Валетов + 19,05,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9821  
				Если ЗначениеЗаполнено(Ссылка.Завершен) И Ссылка.Завершен И НЕ Завершен Тогда 
					ПереклейкаОтсканирована = Истина;
				Иначе
					Для Каждого СтрТЧ из Переклейка цикл
						Если СтрТЧ.Заявка<>СтрТЧ.Количество тогда
							// Для ЛН с ТСД. Проверка что отсканировали переклейку						
							ПереклейкаОтсканирована=Ложь;					
							
							#если клиент тогда
								Сообщить("Не отсканировано "+СтрТЧ.Номенклатура.Наименование+" во вкладке переклейка.");
								Отказ=Истина;
							#КонецЕсли
						КонецЕсли;
					КонецЦикла;   
				КонецЕсли;

				если ПереклейкаОтсканирована  тогда
					ТребуетПроверки=Ложь;
				КонецЕсли;

				СостояниеНакладной=ПолучитьРеквизитШапки(ДокОснование,"СостояниеНакладной","Документ");
				если СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке или СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена тогда
					НужноЗапрещать=Истина;
					
					если не ЭтоНовый() и РежимЗаписи<>РежимЗаписиДокумента.ОтменаПроведения тогда
						НачРеквизиты= ПолучитьРеквизитыШапки(Ссылка,Новый Структура("КоличествоКоробок,КоличествоДокумента"),"Документ");
						НачКоличествоКоробок	=НачРеквизиты.КоличествоКоробок; 
						НачКоличествоДокумента			=НачРеквизиты.КоличествоДокумента;
						если КоличествоДокумента = НачКоличествоДокумента и КоличествоКоробок = НачКоличествоКоробок тогда
							НужноЗапрещать=Ложь;
						КонецЕсли;
						
					КонецЕсли;
					
					если НужноЗапрещать тогда
						Отказ=Истина;
						#если клиент тогда
							Сообщить("Запрещено менять ЛН в готовых накладных. Обратитесь к администратору.");
						#КонецЕсли
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;

	#КонецЕсли

	ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ДокОснование);	
	МассивСообщений=новый Массив;                 
	если РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения тогда
		
		если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков тогда
			запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Лист.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
			|	Лист.Ссылка.Номер КАК Номер
			|ИЗ
			|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК Лист
			|ГДЕ
			|	Лист.Ссылка <> &Ссылка
			|	И Лист.Ссылка.Проведен
			|	И Лист.ШтрихкодБлочка В(&ШтрихкодБлочка)
			|	И Лист.ШтрихкодБлочка <> &ПустойШК		
			|	И Лист.Ссылка.Дата >= &Дата";
			запрос.УстановитьПараметр("Ссылка",Ссылка);
			запрос.УстановитьПараметр("ШтрихкодБлочка",ШтрихкодыУпаковок.Выгрузить().ВыгрузитьКолонку("ШтрихкодБлочка"));
			запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
			запрос.УстановитьПараметр("Дата",Дата-5*86400);
			Выборка = запрос.Выполнить().Выбрать(); 
			пока Выборка.Следующий() цикл
				МассивСообщений.Добавить("Обнаружены дубли кодов блочка в других ЛН - "+Выборка.Номер+"______"+Выборка.ШтрихкодУпаковки);	
			КонецЦикла;	
		КонецЕсли;
		если ЗначениеЗаполнено(КодАгрегации) тогда
			Запрос=новый запрос;
			запрос.Текст=  "ВЫБРАТЬ
			|	Лист.Ссылка.Номер КАК Ссылка
			|ИЗ
			|	Документ.ЛистНабора КАК Лист
			|ГДЕ
			|	Лист.Ссылка <> &Ссылка
			|	И Лист.КодАгрегации = &КодАгрегации
			|	И Лист.Дата >= &Дата
			|	И Лист.Проведен";
			запрос.УстановитьПараметр("Ссылка",Ссылка);
			запрос.УстановитьПараметр("КодАгрегации",КодАгрегации);
			запрос.УстановитьПараметр("Дата",Дата-14*86400);
			Выборка = запрос.Выполнить().Выбрать(); 
			пока Выборка.Следующий() цикл
				МассивСообщений.Добавить("Обнаружены дубли агрегационных кодов в других ЛП - "+Выборка.Номер);
			КонецЦикла;		
		КонецЕсли; 
	КонецЕсли;

	Если ВидДокументаОснования = "Инвентаризация" Тогда
		МассивСкладов = новый Массив; 
		МассивСкладов.Добавить(ДокОснование.Склад); 
		МассивСкладов.Добавить(ДокОснование.Склад.ФизическийСклад);
		РезПроверки = Обработки.ПланИнвентаризации.ПроверитьВозможностьЗаполненияИНВ(ЭтотОбъект,Товары.Выгрузить(,"Номенклатура").ВыгрузитьКолонку("Номенклатура"),МассивСкладов); 	
		Если Не РезПроверки.Успех Тогда
			
			Для каждого СтрОшибка Из РезПроверки.Ошибки Цикл				
				МассивСообщений.Добавить(СтрОшибка); 					
			КонецЦикла;		
			
		КонецЕсли;
	КонецЕсли;
	
	если МассивСообщений.Количество()>0 тогда
		отказ=Истина;
		СообщитьИзМодуля(СтрСоединить(МассивСообщений,символы.ПС));           
		пВыполнения 		= инт_ДлительныеОперации.ПараметрыВыполненияВФоне();			
		КоличествоПотоков	= 1;			
		пПроцедуры = Новый Массив;
		пПроцедуры.Добавить("Отладка");	
		пПроцедуры.Добавить(СтрШаблон("Ошибка записи ЛН %1 по %2 по причине %3",Номер,ДокОснование,СтрСоединить(МассивСообщений,", ")));	
		пПроцедуры.Добавить("Информация");	
		рЗапуска = инт_ДлительныеОперации.ВыполнитьВФоне("РегистрыСведений.Логи.ЗаписатьВЛогФоново", пПроцедуры, пВыполнения);				

	КонецЕсли;

КонецПроцедуры

Процедура ПриЗаписи(Отказ)	        
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если Завершен И Проведен Тогда                                         
		//+++Чирков 16.04.2026 - оказывается  есть проведенные ЛН к удаленным накладным 
		// которые еще и перезаписывают ..... их не надо регистрировать
		Если ПолучитьРеквизитШапки(ДокОснование, "Проведен") = Истина Тогда
		//---Чирков
			Если НЕ РегистрыСведений.ОтгружаемыеКодыМаркировки.ЕстьЗаписиПроверкиДокумента(Ссылка) Тогда
				РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьЗадачуПроверкиДокумента(Ссылка);
			КонецЕсли;
			
			МаркировкаС.ПроверитьКМпоДокументу(Ссылка, Новый Структура("ОтложеннаяПроверка", Истина));
		КонецЕсли;	
	Иначе         
		Если РегистрыСведений.ОтгружаемыеКодыМаркировки.ЕстьЗаписиПроверкиДокумента(Ссылка) Тогда
			РегистрыСведений.ОтгружаемыеКодыМаркировки.УдалитьЗаписиПоДокументу(Ссылка);
		КонецЕсли;		
		РегистрыСведений.СтатусыПроверкиКМвЧЗ.УдалитьРезультатПроверкиДокументаПоЧЗ(Ссылка);
	КонецЕсли;
	//++Данилова Е.В. 19.05.2026 HELP-9825 
	Если НЕ ЭтоНовый()
		И ЗначениеЗаполнено(ДокОснование) 
		И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
		Обработки.ПечатьЛистаНабора.ПроверитьЗанятыеНомераБезЗаписиВЛист(ДокОснование,ссылка);
	КонецЕсли;
	//--Данилова Е.В. 19.05.2026 
КонецПроцедуры

