Процедура СформироватьШКЛистаНабора() Экспорт
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 	
	Если НЕ ПустаяСтрока(ШКЛистаНабора) Тогда Возврат КонецЕсли;

	// Кухарь А.Ю. 25.07.2025 начало  
	//HELP-4418
	//новой компонентой печатаем либо код из реквизита КодАгрегации, либо QR в который вшит УИД этого документа + номер коробки
	если ОбщегоНазначения_ПИ.ПечататьКоробныеЭтикеткиНовойКомпонентой(ДокОснование) тогда
		Возврат;
	КонецЕсли;
	// Кухарь А.Ю. 25.07.2025 конец
	
	Подразделение			= ПараметрыСеанса.ЭтотУзел.Подразделение;
	
	Если ОбщегоНазначения_ПИ.ЭтоУзел_Склад() ИЛИ (ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение И Подразделение.ЕстьВыделенныйСклад) Тогда
		
		Отбор	= Новый Структура("Подразделение,Год",Подразделение,НачалоГода(Дата));
		Запись	= РегистрыСведений.ШКЛистаНабора.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись,Отбор);	
		
		НомерШК = 0;
		
		Попытка
			НачатьТранзакцию();
			
			Запись.Прочитать();
			Если Запись.Подразделение.Пустая() Тогда				
				ЗаполнитьЗначенияСвойств(Запись,Отбор);
				Запись.НомерШК=1000;
			КонецЕсли;	
			Запись.НомерШК=(Формат(Запись.НомерШК+1,"ЧЦ=6; ЧДЦ=0; ЧВН=; ЧГ="));
			Запись.Записать();
			
			НомерШК = Число(Запись.НомерШК);
			
			ЗафиксироватьТранзакцию();
		Исключение		
			ЗаписатьВЛог("ошибка записи последнего номера ШК ЛН","ШК: "+НомерШК + " .ЛН : " +Номер+" Код поиска 6. ","Информация") ;
			ОтменитьТранзакцию();
		КонецПопытки;
		
		Если НомерШК<>0 Тогда
			ПрефиксШК		= Прав(Строка(Год(ТекущаяДата())),1);		
			если ПрефиксШК="0" тогда
				ПрефиксШК="5";
			КонецЕсли;
			ШКЛистаНабора 	= ПрефиксШК + (Формат(НомерШК,"ЧЦ=6; ЧДЦ=0; ЧВН=; ЧГ="));					
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры
