Процедура ПрописатьНомераКоробокЛН()	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,ТипШК,КоличествоКоробок
	|ИЗ
	|	Документ.ЛистНабора
	|ГДЕ
	|	ДокОснование = &ДокОснование  
	|	И Проведен
	|УПОРЯДОЧИТЬ ПО
	|	Номер
	|АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	//крохин конец 15.11.2013
	Сч = 1;
	Пока Выборка.Следующий() Цикл
		ТекЛистНабора = Выборка.Ссылка;
		
		НаборЗаписей = РегистрыСведений.ИнформацияШКЛН.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ШКЛистаНабора.Установить(Выборка.ШКЛистаНабора,Истина);		
		НаборЗаписей.Прочитать();
		
		СписокШК = Новый Соответствие;
		Для Каждого Запись ИЗ НаборЗаписей Цикл
			СписокШК.Вставить(Запись.НомерКоробкиЛН,Запись.ШК);	 
		КонецЦикла;
		
		Если Выборка.ТипШК=Перечисления.ТипыШтрихКодов.Коробка Тогда
			
			Для Счетчик=1 По Выборка.КоличествоКоробок Цикл	
				ТекШКЛистаНабора = СписокШК.Получить(""+Счетчик);
				Если ТекШКЛистаНабора <> Неопределено Тогда
					НовыйНаборЗаписей = РегистрыСведений.ИнформацияШКЛН.СоздатьНаборЗаписей();
					НовыйНаборЗаписей.Отбор.ШКЛистаНабора.Установить(Выборка.ШКЛистаНабора,Истина);					
					НовыйНаборЗаписей.Отбор.ШК.Установить(ТекШКЛистаНабора,Истина);
					
					НовыйНаборЗаписей.Прочитать();
					Для Каждого Запись Из НовыйНаборЗаписей Цикл
						Запись.НомерКоробки = Сч;
					КонецЦикла;
					Сч = Сч + 1;
					НовыйНаборЗаписей.Записать();
					//крохин начало 09.12.2013
					//коробок больше, чем было
				Иначе	
					//крохин конец 09.12.2013
				КонецЕсли;
			КонецЦикла;
		Иначе
			ТекШКЛистаНабора 	= Выборка.ШКЛистаНабора;
			НовыйНаборЗаписей 	= РегистрыСведений.ИнформацияШКЛН.СоздатьНаборЗаписей();
			
			НовыйНаборЗаписей.Отбор.ШКЛистаНабора.Установить(Выборка.ШКЛистаНабора,Истина);			
			НовыйНаборЗаписей.Отбор.ШК.Установить(ТекШКЛистаНабора,Истина);			
			НовыйНаборЗаписей.Прочитать();
			Для Каждого Запись Из НовыйНаборЗаписей Цикл
				Запись.НомерКоробки = Сч;
			КонецЦикла;
			НовыйНаборЗаписей.Записать();
			Сч = Сч + 1;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьТаблицуСтрокПН()
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка.ДокОснование		КАК Накладная,
	|	0 						КАК НомерСтрокиПН_Число,
	|   НомерСтрокиПланаНабора	КАК НомерСтрокиПН_Строка
	|ИЗ
	|	Документ.ЛистНабора.СтрокиПлановНабора
	|ГДЕ
	|	Ссылка=&Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	НомераСтрок=Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ Из НомераСтрок Цикл
		СтрокаТЧ.НомерСтрокиПН_Число=Число(СтрокаТЧ.НомерСтрокиПН_Строка);	
	КонецЦикла;	
	
	Возврат НомераСтрок;
КонецФункции //ПолучитьТаблицуСтрокПН()

Функция ПроверитьОшибкиПоПланамНабора()
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ * ПОМЕСТИТЬ НомераСтрок ИЗ &НомераСтрок КАК НомераСтрок
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеСтрокиЛН.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ СписокЛН
	|ИЗ
	|	Документ.ЛистНабора.СтрокиПлановНабора КАК ВсеСтрокиЛН		
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	НомераСтрок	
	|ПО
	|	ВсеСтрокиЛН.Ссылка.ДокОснование		=НомераСтрок.Накладная		
	|	И (ВсеСтрокиЛН.Ссылка.Проведен ИЛИ ВсеСтрокиЛН.Ссылка=&Ссылка)
	|	И ВсеСтрокиЛН.НомерСтрокиПланаНабора=НомераСтрок.НомерСтрокиПН_Строка
	|;
	|ВЫБРАТЬ
	|	Коллекция,
	|	СУММА(КоличествоПлан) 	КАК КоличествоПлан,
	|	СУММА(КоличествоФакт) 	КАК КоличествоФакт,
	|	СУММА(КоличествоПлан)-СУММА(КоличествоФакт) КАК Отклонение
	|ИЗ
	|(	
	|ВЫБРАТЬ
	|	ВЫБОР КОГДА Коллекция.ЭтоГруппа ТОГДА Коллекция ИНАЧЕ Коллекция.Родитель.Родитель КОНЕЦ КАК Коллекция,	
	|	Количество	КАК КоличествоПлан,
	|	0			КАК КоличествоФакт	
	|ИЗ 
	|	Документ.ПланНабора.тБрэндов КАК тБрэндов
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	НомераСтрок
	|ПО
	|	тБрэндов.Ссылка.ДокОснование	= НомераСтрок.Накладная	
	|	И тБрэндов.НомерСтроки			= НомераСтрок.НомерСтрокиПН_Число	
	|	И тБрэндов.Ссылка.Проведен
	|ОБЪЕДИНИТЬ ВСЕ 
	|ВЫБРАТЬ
	|	Номенклатура.Родитель.Родитель,	
	|	0			КАК КоличествоПлан,
	|	Количество	КАК КоличествоФакт	
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ТЧТовары
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	СписокЛН 
	|ПО
	|	ТЧТовары.Ссылка=СписокЛН.Ссылка
	|) КАК Сводный
	|СГРУППИРОВАТЬ ПО 
	|	Коллекция
	|ИМЕЮЩИЕ 
	|	СУММА(КоличествоПлан)<>СУММА(КоличествоФакт) 
	|";	
	
	Запрос.УстановитьПараметр("Ссылка", 		Ссылка);
	Запрос.УстановитьПараметр("НомераСтрок",	ПолучитьТаблицуСтрокПН());
	
	Результат	= Запрос.Выполнить();	
	Выборка		= Результат.Выбрать();
	
	Возврат	(Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Отклонение)); 	
КонецФункции
