				Отказ=Истина;
			#КонецЕсли
		КонецЕсли;
			//Кухарь 05.06.17 конец
		//Кухарь 02.05.17 начало
	КонецЕсли;
	//Кухарь 02.05.17  конец
	
	//Валетов + 29,04,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9445
