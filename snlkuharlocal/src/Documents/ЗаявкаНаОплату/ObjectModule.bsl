			ДокФлоу_Сервер.ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);
		КонецЕсли;        		
	КонецЕсли;
	// Кухарь А.Ю.  14.05.2026 конец
	
	// Кухарь А.Ю.  29.05.2026 начало     
	// Наряд 0000000053
	если МассивОшибокИсключения.Количество()> 0 тогда
		ВызватьИсключение "Не удалось записать документ по причине ошибок - "+СтрСоединить(МассивОшибокИсключения,",");
	КонецЕсли;
	// Кухарь А.Ю.  29.05.2026 конец
	
