Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь) Экспорт 
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		НаборЗаписей.Очистить();
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
	КонецЦикла;	
КонецПроцедуры 

Процедура ОбработкаПроведения(Отказ, РежимПроведения)  экспорт 
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Отказ=Ложь;
	ДвиженияПоРегистрам=Неопределено;
	ТаблицаСписания=неопределено;
	
	РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,,ТаблицаСписания);	
	Результат=РезультатПроведения["Результат"];
	
	#Если Клиент Тогда
		Если Результат<0 Тогда		
			Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));		
			ВывестиТрассировку(РезультатПроведения["ТОшибок"],?(Отказ,-2,Результат));			
		КонецЕсли; 
		
	#КонецЕсли
	
	//Если Результат<0 Тогда		
	//	Отказ=Истина;		
	//КонецЕсли; 
	
	Если НЕ Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
		
		Если СостояниеНакладной=Перечисления.СостоянияНакладной.Доставлена Тогда
			ДвиженияПоВзаиморасчетам=Неопределено;
			
			СформироватьДвиженияПоЗатратам(ТаблицаСписания);
			
			РезультатПроведения=ПроведениеПоРегистрамВзаиморасчетов(Ссылка,ДвиженияПоВзаиморасчетам);
			ВыполнитьДвиженияПоРегистрам(ДвиженияПоВзаиморасчетам,ОбменДанными.Загрузка);
		КонецЕсли;		
		
	КонецЕсли; 
	
	//Мессерле 05,05,12 - фиг его знает надо ли вообще
	для каждого стр из товары цикл
		Если стр.Номенклатура=справочники.Номенклатура.НайтиПоКоду("SNL-288462") тогда //Под.серт.ИМ 9999
			ДвижОстатки=Движения.ОстаткиТМЦ.ДобавитьРасход();
			движостатки.Количество=стр.Количество;
			движостатки.КодОперации=перечисления.КодыОперацийОстатки.Реализация;
			движостатки.Подразделение=Подразделение;
			движостатки.Склад=Склад;
			движостатки.Номенклатура=стр.Номенклатура;
			движостатки.Отправитель=контрагент;
			движостатки.Период=дата;
			движостатки.Регистратор=ссылка;
		Конецесли;
	Конеццикла;

   	
	
	 Если ОбменДанными.Загрузка Тогда
          Движения.Взаиморасчеты.Записать();
          Движения.Затраты.Записать();
		  Движения.ОстаткиТМЦ.Записать();
		  Движения.Профит.Записать();
		  Движения.РезервыТМЦ.Записать();
     КонецЕсли;
	
	
КонецПроцедуры





Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если ЭтоНовый() И Организация.Пустая() И НЕ Склад.Пустая() И НЕ Склад.Организация.Пустая() Тогда
		Организация=Склад.Организация;
	КонецЕсли;
	
	Если ЭтоНовый() или СтатьяЗатрат.Пустая() или ТранзитныйСклад.Пустая() Тогда
		СтатьяЗатрат=Справочники.СтатьиЗатрат.НайтиПоКоду("320 520");
		ТранзитныйСклад=Справочники.Склады.НайтиПоКоду("SSR-49");
		ВидОплаты=перечисления.ВидыОплаты.БН;
	КонецЕсли;
	
	Если видОплаты=перечисления.ВидыОплаты.НАЛ Тогда
		ВидОплаты=перечисления.ВидыОплаты.БН;
	КонецЕсли;
	
	
	ЕстьИзменения = Модифицированность();
	
	//Если НЕ ОбменДанными.Загрузка Тогда		
	//	  КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
	//	МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
	//	МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);
	//КонецЕсли;	
	
	Если Отказ Тогда Возврат КонецЕсли;	
	
	//Если НЕ ЕстьИзменения Тогда Возврат КонецЕсли;	
	//крохин начало 17.02.2012
	//СуммаДокумента				= Товары.Итог("Всего")+Услуги.Итог("Всего")-СуммаБонуса;	
	СуммаДокумента              =  Товары.Итог("Всего")+Услуги.Итог("Всего")-СуммаБонуса-СуммаОплатыСертификатом;
	//крохин конец 17.02.2012
	ОбъемДокумента				= Товары.Итог("Объем");
	КоличествоДокумента 		= Товары.Итог("Количество")+услуги.Итог("Количество");
	ГруппыТоваров				= ГруппыТоваровДокумента(ЭтотОбъект);	
	
	
	
	//ищем признак скидки на первый заказ при загрузке и перезаписываем цены. ставим скидку 10 %
	//
	Скидка10=Справочники.Номенклатура.НайтиПоКоду("SNL-232812");
	ПоискСкидки=Услуги.Найти(Скидка10,"Номенклатура");
	
	Если ПоискСкидки <> Неопределено Тогда
		// проставляем скидку удаляем строку
		Для каждого ТекСтрока из Товары Цикл
			
			Если ТекСтрока.Номенклатура.Код="SNL-096562" или (ТекСтрока.Номенклатура.Код="SNL-095774") или (ТекСтрока.Номенклатура.Код="SNL-096577") или (ТекСтрока.Номенклатура.Код="SNL-096561") 
				или (ТекСтрока.Номенклатура.Код="SNL-231090") Тогда
				ТекСтрока.Скидка=-1;
			Иначе
				ТекСтрока.Скидка=10;
			КонецЕсли;
			РассчитатьСуммуТабЧасти(ТекСтрока, ЭтотОбъект);
			
		КонецЦикла;	
		//удаляем строку
		НомерСтроки=ПоискСкидки.НомерСтроки;
		Услуги.Удалить(НомерСтроки-1);
		
	КонецЕсли;
	
	//крохин начало 17.02.2012
	//деактивация электронного сертификата
	Если СостояниеНакладной = Перечисления.СостоянияНакладной.Доставлена Тогда
	Если НЕ ЭлектронныйСертификат.Пустая() И НЕ ЭлектронныйСертификат.Использован Тогда
		ЭлектронныйСертификатОбъект = ЭлектронныйСертификат.ПолучитьОбъект();
		ЭлектронныйСертификатОбъект.ДатаПогашения = Дата;
		ЭлектронныйСертификатОбъект.ДокументПогашения = Ссылка;
		ЭлектронныйСертификатОбъект.Использован = Истина;
		ЭлектронныйСертификатОбъект.Записать();
	КонецЕсли;	
	КонецЕсли;
	//крохин конец 17.02.2012
	
	//крохин начало 30.05.2012
	//запретим записывать документ началом дня
	Если Дата >= '20120501' И Дата = НачалоДня(Дата) Тогда
	Дата = Дата + 1;	
	КонецЕсли;
	//крохин конец 30.05.2012

		
	//ЗаписатьВЛог("ОбменССайтом",""+РежимЗаписи+" "+СостояниеНакладной+" проведен - "+Проведен,"");
	ЕстьИзменения		=Модифицированность();	
	НужноВыгружать		=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	
	Если НЕ ОбменДанными.Загрузка Тогда		
		Если НеКонтролироватьЗапись Тогда
		Иначе
			КонтрольДатыЗапрета(ЭтотОбъект,Отказ);			
			МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
			МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		КонецЕсли;		
		
		Если Отказ Тогда Возврат КонецЕсли; 
		
	КонецЕсли;	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
		//Катаев+ 08/10/14
		Если Не ЭтотОбъект.Ссылка.Пустая() Тогда
			НужноВыгружать = Ложь;
		КонецЕсли;
		//Катаев- 08/10/14
	КонецЕсли;
	
	
	
	
КонецПроцедуры

