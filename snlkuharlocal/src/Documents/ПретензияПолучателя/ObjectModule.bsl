Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
		
	ВидОснования	= Основание.Метаданные().Имя;
		
	ДокОснование	= Основание;
	



	
	
	// Катаев+ 19/03/13  Добавил заполнение на основании акта приемки
	Если ВидОснования = "АктПриемки" Тогда
		Если ДокОснование.РНК.Пустая() Тогда
			Сообщить("В акте приемки отсутствует РНК. Создание документа запрещено");
			мСозданиеНевозможно=Истина;
			Возврат;
		Конецесли;
		ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");			
		Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"Менеджер");			
		Организация		= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"Организация");	
		ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"ТипЦен");
		ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"ТипСкидок");
		// нечаева 14,08,19+++
		Склад		= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"Склад");
		// нечаева 14,08,19---

		//12.03.14 нечаева - цены слетают ++
		//Скидка			= ПолучитьРеквизитОбъекта(ДокОснование.РНК,"Скидка");
		//12.03.14 нечаева - цены слетают --
	Иначе
		ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");			
		Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");			
		Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");	
		ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
		ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
		//12.03.14 нечаева - цены слетают ++
		//Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");
		//12.03.14 нечаева - цены слетают --
	КонецЕсли;
	// Катаев- 19/03/13 
	
	//крохин начало 29.01.2013
	//менеджер, для отчета "продажи"
	Менеджер			= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	//крохин конец 29.01.2013
		
	Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");		
	
	Если ВидОснования="ПриходнаяНакладная" ИЛИ ВидОснования="РасходнаяНакладная" Тогда
		Корреспондент	= ДокОснование.Контрагент;		
		Склад			= ДокОснование.Склад;
		//крохин начало 06.03.2012
		ВидОплаты = ДокОснование.ВидОплаты;
	//крохин конец 06.03.2012
	//крохин начало 24.05.2012
	ДатаОплаты = Докоснование.ДатаОплаты;
	//крохин конец 24.05.2012
	ИначеЕсли ВидОснования="Перемещение" Тогда
		Корреспондент	= ДокОснование.СкладПолучатель;
		Склад			= ДокОснование.Склад;
	// Катаев+ 19/03/13 
	ИначеЕсли Видоснования="АктПриемки"	 Тогда
		Корреспондент	= ДокОснование.Контрагент;		
		Склад			= ДокОснование.Склад;
		ДатаОплаты = ДокОснование.РНК.ДатаОплаты;
		// нечаева 14,08,19+++
		Склад		= ДокОснование.РНК.Склад;
		// нечаева 14,08,19---

		//Катаев- 19/03/13
	Иначе
		Склад			= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");		
	КонецЕсли;	
	
	Если ВидОснования="ПриходнаяНакладная" И ДокОснование.КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР Тогда
		Поставщику=Истина;
		
		Для Каждого ИсхСтрокаТЧ ИЗ ДокОснование.Товары Цикл
			Если ИсхСтрокаТЧ.ПодтвержденнаяЗаявка<>ИсхСтрокаТЧ.Количество Тогда
				СтрокаТЧ=Товары.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,ИсхСтрокаТЧ,,"Количество");
				
				СтрокаТЧ.КоличествоИсх	=ИсхСтрокаТЧ.ПодтвержденнаяЗаявка;
				СтрокаТЧ.КоличествоФакт	=ИсхСтрокаТЧ.Количество;
				СтрокаТЧ.Количество		=СтрокаТЧ.КоличествоФакт-СтрокаТЧ.КоличествоИсх;				
				
				РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);
			КонецЕсли; 			
		КонецЦикла;
	ИначеЕсли ВидОснования="Перемещение" Тогда
		Для Каждого ИсхСтрокаТЧ ИЗ ДокОснование.Товары Цикл
			Если ИсхСтрокаТЧ.ПодтвержденнаяЗаявка<>ИсхСтрокаТЧ.Количество Тогда
				СтрокаТЧ=Товары.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,ИсхСтрокаТЧ,,"Количество");
				
				СтрокаТЧ.КоличествоИсх	=ИсхСтрокаТЧ.ПодтвержденнаяЗаявка;
				СтрокаТЧ.КоличествоФакт	=ИсхСтрокаТЧ.Количество;
				СтрокаТЧ.Количество		=СтрокаТЧ.КоличествоИсх-СтрокаТЧ.КоличествоФакт;				
				
				РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; 
	//крохин начало 20.11.2011
	Если ВидОснования="РасходнаяНакладная" И КонецДня(Константы.ДатаЗапретаРедактирования.Получить()) >= ДокОснование.Дата Тогда
		ВидРекламации = Перечисления.ВидыРекламаций.Вычерк;
	Иначе
		ВидРекламации = Перечисления.ВидыРекламаций.Рекламация;
	КонецЕсли;
	//крохин конец 20.11.2011
	
	
	//Катаев+ 19/03/13 Заполнение ТЧ на основании АктаПриемки и РНК
	
	
	// нечаева 24,02,016 убрала рнк из заполнения, не правильно считает нач. остаток, если несколько вычерков
	//Если ВидОснования="РасходнаяНакладная" Или ВидОснования="АктПриемки" Тогда // было
	Если  ВидОснования="АктПриемки" Тогда
		Если ВидОснования = "АктПриемки" Тогда
			РНК = ДокОснование.РНК;
			ДокОснование = ДокОснование.РНК;
		Иначе
			РНК =ДокОснование;
		КонецЕсли;
		Запрос = новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РасхожденияПоАктуОстатки.Номенклатура,
		|	РасхожденияПоАктуОстатки.ОтправленоОстаток,
		|	РасхожденияПоАктуОстатки.ПринятоОстаток
		|ИЗ
		|	РегистрНакопления.РасхожденияПоАкту.Остатки(, РНК = &РНК) КАК РасхожденияПоАктуОстатки";
		Запрос.УстановитьПараметр("РНК", РНК);
		Выборка = запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ=Товары.Добавить();
			СтрокаТЧ.Номенклатура = Выборка.Номенклатура;
			СтрокаТЧ.КоличествоИсх = Выборка.ОтправленоОстаток;
			СтрокаТЧ.КоличествоФакт = Выборка.ПринятоОстаток;
			СтрокаТЧ.Количество	= СтрокаТЧ.КоличествоИсх-СтрокаТЧ.КоличествоФакт;				
		КонецЦикла;
	КонецЕсли;
	
	//Катаев- 19/03/13
	
	//крохин начало 05.05.2020
	//комиссионная торговля
	Если ВидОснования="РасходнаяНакладная" И  ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
	СкладКомиссия = ДокОснование.СкладКомиссия;
	//ДоговорКомиссия = ДокОснование.ДоговорКомиссия;
	КонецЕсли;
	//крохин конец 05.05.2020
	
	
КонецПроцедуры


