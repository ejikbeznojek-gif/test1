Процедура ОтправкаУведомленияПретензияПокупателя() Экспорт
	
	ПослатьПисьмо = Ложь;
	
	Если СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.НаРассмотренииПРО Тогда	
		ТемаПисьма = "Уведомление о создании претензии покупателя";
		ТекстПисьма = "Создан новый документ ПрП "+Номер+ "("+ДокОснование+", "+Корреспондент+")";
		ПослатьПисьмо = Истина;	
	КонецЕсли;
	
	Если СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.НаРассмотренииРуководителяПодразделения Тогда
		ТемаПисьма = "Уведомление о необходимости согласования претензии покупателя руководителем подразделения";
		
		ТекстПисьма = "По документу ПрП "+Номер+ "("+ДокОснование+", "+Корреспондент+") требуется решение руководителя";
		ПослатьПисьмо = Истина;
		
	КонецЕсли;
	
	Если СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.ОформлениеРКМ Тогда
		ТемаПисьма = "Уведомление о необходимости создания РКМ по претензии покупателя";
		
		ТекстПисьма = "Требуется корректировка по документу ПрП "+Номер+ "("+ДокОснование+", "+Корреспондент+")";
		ПослатьПисьмо = Истина;	
	КонецЕсли;
	
	Если СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.ОформлениеДокументов Тогда
		ТемаПисьма = "Уведомление о необходимости создания заявки на ТСД по претензии покупателя";
		
		ТекстПисьма = "Проведена корректировка по документу ПрП "+Номер+ "("+ДокОснование+", "+Корреспондент+"). Требуется создать заявку на выписку документов";
		ПослатьПисьмо = Истина;	
	КонецЕсли;
	
	Если ПослатьПисьмо Тогда
		СписокПолучателей = СформСписокПолучат(Справочники.ТипыРассылок.ПисьмоОТестировании);
		// "krohin@collant.ru"
		ОшибкиУведомления = СформироватьВнутреннееУведомление (СписокПолучателей,ТекстПисьма,ТемаПисьма);
	КонецЕсли;
	
КонецПроцедуры





