	// Ихсанов Д. А. Конец 18.11.2025
	
КонецПроцедуры

Процедура ОбновитьСостоянияСтрокПН()
	ТекНомер=ПолучитьНомерСостоянияНакладной(СостояниеНакладной);
	ПН_Объект=ДокументОснование.ПолучитьОбъект();	
	Для Каждого СтрокаПН Из ПН_Объект.тБрэндов Цикл
		Если СтрокаПН.НомерЧасти=НомерЧасти И ТекНомер>ПолучитьНомерСостоянияНакладной(СтрокаПН.Состояние) Тогда
			//Кухарь 24.12.19 начало
			//Иногда записывать ПН не нужно а при установке состояния даже на такое же, модифицированность устанавливается
			если СтрокаПН.Состояние=СостояниеНакладной тогда
				Продолжить;
			КонецЕсли;
			//Кухарь 24.12.19 конец
			
			СтрокаПН.Состояние=СостояниеНакладной;	
		КонецЕсли; 	
	КонецЦикла; 
	
	Если ПН_Объект.Модифицированность() Тогда
		ПН_Объект.Записать();	
	КонецЕсли; 
КонецПроцедуры


