Процедура ЗарегистрироватьОбъектыКВыгрузке(УзелТСД)
	ТЧ=Товары.Выгрузить();
	// Кухарь А.Ю. 16.01.2020 начало
	//  	ТЧ.Свернуть("Номенклатура,Единица");
	ТЧ.Свернуть("Номенклатура"); 
	// Кухарь А.Ю. 16.01.2020 конец
	
	
	Для Каждого СтрокаТЧ Из ТЧ Цикл
