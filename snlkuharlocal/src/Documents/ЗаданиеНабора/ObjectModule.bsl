Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения)<>Тип("ДокументСсылка.ПланНабора") Тогда Возврат КонецЕсли;
	
	Автор=ПараметрыСеанса.Пользователь;
	//+++Чирков 11.07.2025
	РабочееМесто = ПараметрыСеанса.РабочееМестоКлиента;
	//---Чирков 11.07.2025
	
	Если ТипЗнч(ДанныеЗаполнения)=Тип("ДокументСсылка.ПланНабора") Тогда
		ДокументОснование=ДанныеЗаполнения;
		Если 1=2 Тогда
			ДанныеЗаполнения=Документы.ПланНабора.СоздатьДокумент();		
		КонецЕсли;		
		
		Склад	= ДанныеЗаполнения.Склад;
		
		Если ТипЗнч(ДанныеЗаполнения.Накладная)=Тип("ДокументСсылка.РасходнаяНакладная") Тогда			
			ИмяРеквизита="Контрагент";			
		Иначе
			ИмяРеквизита="СкладПолучатель";			
		КонецЕсли; 
				
		//// Кухарь А.Ю. 16.03.2021 начало
		//Перенёс в ПН. Потому что там ряд других реквизитов заполняется. Чтобы заполнять одним запросом
		////Получатель=ПолучитьРеквизитШапки(ДанныеЗаполнения.Накладная,ИмяРеквизита,"Документ");
		//СписокРеквизитов=Новый Соответствие;
		//СписокРеквизитов.Вставить(ИмяРеквизита,"Получатель");
		//СписокРеквизитов.Вставить("ДатаОтгрузки","ДатаОтгрузки");	
		//Реквизиты=ПолучитьРеквизитыШапки(Накладная,СписокРеквизитов,"Документ");
		//Получатель=Реквизиты.получатель;
		//ДатаОтгрузки=Реквизиты.ДатаОтгрузки;	
		//// Кухарь А.Ю. 16.03.2021 конец
		
		
		Товары.Очистить();
		Для Каждого СтрокаИст Из ДанныеЗаполнения.тБрэндов Цикл
			СтрокаПол=Товары.Добавить();			
			
			СтрокаПол.Номенклатура	= СтрокаИст.Коллекция;
			СтрокаПол.Количество	= СтрокаИст.Количество;
			//СтрокаПол.Единица		= СтрокаИст.
		КонецЦикла;
		
		//  25.08.2020 кухарь начало
		СозданоОбработкойПополнения = ДанныеЗаполнения.СозданоОбработкойПополнения; 
		//  25.08.2020 кухарь конец
		
		
	КонецЕсли; 	
КонецПроцедуры

