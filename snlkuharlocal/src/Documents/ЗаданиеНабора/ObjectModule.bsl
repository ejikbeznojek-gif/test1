Процедура ЗаполнитьОбъемы()
	ШаблонРеквизитов=Новый Соответствие();
	ШаблонРеквизитов.Вставить("Родитель.ШтукВКоробке","ШтукВКоробке");
	ШаблонРеквизитов.Вставить("Родитель.ОбъемКоробки","ОбъемКоробки");
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		Реквизиты=ПолучитьРеквизитыШапки(СтрокаТЧ.Номенклатура,ШаблонРеквизитов);
		СтрокаТЧ.Объем=СтрокаТЧ.Количество*Реквизиты.ОбъемКоробки/?(ЗначениеЗаполнено(Реквизиты.ШтукВКоробке),Реквизиты.ШтукВКоробке,1);		
	КонецЦикла;	 
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения) 
	
	если ОбменДанными.Загрузка тогда
		Возврат;
	КонецЕсли;
	
	КонтрольДатыЗапрета(ЭтотОбъект,Отказ);	 
	ДопПараметрыНакладной= ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);

	
	РеквизитыНакладной= ПолучитьРеквизитыШапки(Накладная,Новый Структура("СостояниеНакладной,Проведен"),"Документ");
	НакладнаяСостояние	=РеквизитыНакладной.СостояниеНакладной; 
	НакладнаяПроведен				=РеквизитыНакладной.проведен;
	если НакладнаяСостояние=Перечисления.СостоянияНакладной.Отгружена тогда
		если НеКонтролироватьОтгруженНакладных<>Истина тогда
			если СостояниеНакладной<> Перечисления.СостоянияНакладной.Отгружена тогда
				СообщитьИзМодуля("Нельзя записывать ЗНБ отгруженной накладной, в состоянии отличном от Отгружено.");
				отказ=Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	если ЭтоНовый() тогда					
		если ДокументОснование.Метаданные().Имя="ПланНабора" и ДокументОснование.СозданоОбработкойПополнения тогда
			СозданоОбработкойПополнения=Истина;
		КонецЕсли;
		
		если НакладнаяСостояние=Перечисления.СостоянияНакладной.Отгружена тогда
			СообщитьИзМодуля("Нельзя создавать ЗНБ к отгруженным накладным");	
			отказ = Истина;			
		КонецЕсли; 
		
		если не НакладнаяПроведен тогда
			СообщитьИзМодуля("Нельзя создавать ЗНБ к непроведённым накладным");	
			отказ = Истина;			
		КонецЕсли; 		
		НачСостНакладной=Неопределено;
		
		//+++Чирков 10.02.2026
		ДатаСоздания = ТекущаяДата();
		//---Чирков 10.02.2026
	Иначе
		НачРеквизиты= ПолучитьРеквизитыШапки(Ссылка,Новый Структура("СостояниеНакладной,Дата"),"Документ");
		НачСостНакладной	=НачРеквизиты.СостояниеНакладной; 
		НачДата				=НачРеквизиты.дата;
		
		если РежимЗаписи=РежимЗаписиДокумента.Проведение тогда
			если не НакладнаяПроведен тогда
				СообщитьИзМодуля("Нельзя создавать ЗНБ к непроведённым накладным");	
				отказ = Истина;			
			КонецЕсли; 		
		КонецЕсли;
		
		// Кухарь А.Ю.  11.11.2024 начало
		//
		если НачСостНакладной=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ или НачСостНакладной=Перечисления.СостоянияНакладной.КомплектацияЧЗ тогда
			если ПолучитьНомерСостоянияНакладной(СостояниеНакладной)>755 тогда
				ФормированиеНаборовЧЗЗавершено = Истина;
			КонецЕсли;
		КонецЕсли;
		// Кухарь А.Ю.  11.11.2024 конец
		
		
	КонецЕсли; 
	
	если ЭтоНовый() и Накладная.Метаданные().Имя="Перемещение" 
		и (накладная.Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада или накладная.СкладПолучатель.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада )
		 и не СозданоОбработкойПополнения 
		тогда	
		СообщитьИзМодуля("Для внутренних перемещений ЗНБ не нужны.");	
		отказ = Истина;
	КонецЕсли;
	
	
	если Проведен и РежимЗаписи=РежимЗаписиДокумента.Запись и НачСостНакладной<>Перечисления.СостоянияНакладной.ВНаборе
		и СостояниеНакладной=Перечисления.СостоянияНакладной.ВНаборе тогда	 
		Дата=ТекущаяДата();
		РежимЗаписи=РежимЗаписиДокумента.Проведение;
	КонецЕсли; 
	
	если ЭтоНовый() и не Накладная.Проведен  и не СозданоОбработкойПополнения тогда
		СообщитьИзМодуля("Нельзя создавать ЗНБ к распроведённым накладным.");
		Отказ=Истина;		
	КонецЕсли;	 
	
	если не ЭтоНовый() и СостояниеНакладной<>Перечисления.СостоянияНакладной.ОжиданиеНабора 
			и СостояниеНакладной<>Перечисления.СостоянияНакладной.ПолученоСкладом 
			и СостояниеНакладной<>Перечисления.СостоянияНакладной.СформированыЗаданияНабора
			 и СостояниеНакладной<>Перечисления.СостоянияНакладной.Отгружена
			тогда	 
		
		СписокДоступныхСостояний = ПроверитьБлокировкуВыдачейВНабор(Ссылка);
		если СписокДоступныхСостояний <> Неопределено тогда
	 
			если СписокДоступныхСостояний.найти(НачСостНакладной) = Неопределено и НачСостНакладной<> Перечисления.СостоянияНакладной.Отгружена тогда
				Сообщить("Накладная заблокирована для изменений документом: Блокировка выдачи в набор");
				отказ=Истина;
			ИначеЕсли 	СписокДоступныхСостояний.найти(СостояниеНакладной) = Неопределено и СостояниеНакладной<> Перечисления.СостоянияНакладной.Отгружена тогда
				Сообщить("Накладную нельзя записать в текущем статусе. Данный статус накладной запрещён документом: Блокировка выдачи в набор");
				отказ=Истина;
			КонецЕсли;
		КонецЕсли;			

	КонецЕсли;
	//++Данилова Е.В. 28.01.2026 SNL-109
	Если не ЭтоНовый() Тогда 
		
		Если СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеНабора
			И НачСостНакладной <>Перечисления.СостоянияНакладной.ОжиданиеНабора Тогда
			
			РезПроверки = Обработки.ПланИнвентаризации.ПроверитьДокументНаОтсутствиеБлокировок(ссылка);
			
			Если Не РезПроверки.Успех Тогда
				
				Сообщить("Накладная заблокирована для смены статуса в ""ожидание набора"" документом: Блокировка выдачи в набор. Заблокированные товары:");
				Сообщить(СтрСоединить(РезПроверки.Ошибки,Символы.ПС));
				//++Данилова Е.В. 11.03.2026 SNL-159 
				Если ЗначениеЗаполнено(РезПроверки.ДопТекстОшибки) Тогда
				
					Сообщить(РезПроверки.ДопТекстОшибки); 	
				
				КонецЕсли;
				//--Данилова Е.В. 11.03.2026 
				
				Отказ = истина; 
				
			КонецЕсли;
			
		КонецЕсли;
