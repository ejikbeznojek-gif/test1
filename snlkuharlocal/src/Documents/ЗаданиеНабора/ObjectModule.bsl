Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	ДвиженияПоРегистрам=Неопределено;
	
	Если СостояниеНакладной=Перечисления.СостоянияНакладной.СформированыЗаданияНабора 
		или СостояниеНакладной=Перечисления.СостоянияНакладной.ПроверенаПоОстаткам 
		или СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеНабора	 
		или СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоСкладом	 
		Или СостояниеНакладной=Перечисления.СостоянияНакладной.Отменена	 
		или СостояниеНакладной=Перечисления.СостоянияНакладной.ПустаяСсылка() 
		ИЛИ СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена Тогда
		Возврат;	
	КонецЕсли;

	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам);	
	
	Результат=РезультатПроведения["Результат"];
	
	Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда		
		Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));		
		
		ВывестиТрассировку(РезультатПроведения["ТОшибок"],?(Отказ,-2,Результат));			
	КонецЕсли; 
	
	Если НЕ Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);		
	КонецЕсли;	
	
КонецПроцедуры

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь,Очищать=Истина)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Продолжить  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];
		
		Если Очищать Тогда
			НаборЗаписей.Очистить();
		КонецЕсли;		
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

