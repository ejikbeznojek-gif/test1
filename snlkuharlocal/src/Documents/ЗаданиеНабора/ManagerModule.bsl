Процедура УстановкаСтадийРаботыСНаборамиЧЗ(Знач ВсёСошлось, Знач ЛистСборкиКомплектовЧЗ, Знач Накладная, Знач ТекущееСостояние, Знач ТекущееФормированиеНаборовЧЗЗавершено, Знач ТекущийЗНБ)
	
	//Перем ЗНБОбъект, Комплектовщик, НовоеСостояние, НужноЗаписывать, СтрокаТЧ;
	
	если ВсёСошлось и не ТекущееФормированиеНаборовЧЗЗавершено тогда
		НужноЗаписывать=Истина;
	ИначеЕсли ТекущееСостояние=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ тогда
		НужноЗаписывать=Истина;
	иначе
		НужноЗаписывать=Ложь;
	КонецЕсли;
	
	если не НужноЗаписывать тогда
		Возврат;
	КонецЕсли;
	
	НомерЧасти=ПолучитьРеквизитШапки(ТекущийЗНБ,"НомерЧасти","Документ");
	
	если НужноЗаписывать тогда
		если ЛистСборкиКомплектовЧЗ=Неопределено тогда
			Комплектовщик=Справочники.ФизическиеЛица.ПустаяСсылка();
		иначе
			Комплектовщик=ПолучитьРеквизитШапки(ЛистСборкиКомплектовЧЗ,"Автор.ФизЛицо","Документ");
		КонецЕсли;
		если ВсёСошлось тогда
			//Кухарь А.Ю. 27.02.2026 начало
			//если ТекущееСостояние=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ 
			//	или ТекущееСостояние=Перечисления.СостоянияНакладной.КомплектацияЧЗ тогда
			//	НовоеСостояние=ПолучитьНовоеСостояниеЗНБ(ТекущийЗНБ,Перечисления.СостоянияНакладной.КомплектацияЧЗ);				
			//иначе
			//	ВызватьИсключение "Не корректное состояние ЗНБ для проведения комплектации набора. Текущее состояние - "+ТекущееСостояние+ ". Корректное состояние ожидание комплектации или комплектация. "+Строка(ТекущийЗНБ) ;
			//КонецЕсли;
			//ЗаполнитьКомплектовщиковЧЗПН(Накладная,НомерЧасти,Комплектовщик,ложь,НовоеСостояние);	
			если ТекущееСостояние=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ 
				или ТекущееСостояние=Перечисления.СостоянияНакладной.КомплектацияЧЗ тогда
				НовоеСостояние=ПолучитьНовоеСостояниеЗНБ(ТекущийЗНБ,Перечисления.СостоянияНакладной.КомплектацияЧЗ);				
				ЗаполнитьКомплектовщиковЧЗПН(Накладная,НомерЧасти,Комплектовщик,ложь,НовоеСостояние);
			КонецЕсли; 
			//Кухарь А.Ю.  27.02.2026 конец
		иначе
			если ТекущееСостояние=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ тогда
				ЗаполнитьКомплектовщиковЧЗПН(Накладная,НомерЧасти,Комплектовщик,Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьКомплектовщиковЧЗПН(Накладная,НомерЧасти,Комплектовщик,ЭтоНачало,Состояние=Неопределено)
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПланНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	ПланНабора.Проведен
	|	И ПланНабора.Накладная = &Накладная";
	запрос.УстановитьПараметр("Накладная",Накладная);
	Выборка=запрос.Выполнить().Выбрать();
	ДатаОперации=ТекущаяДата();
	ПНОбъект=Неопределено;
	пока Выборка.Следующий() цикл
		ПНОбъект=Выборка.Ссылка.ПолучитьОбъект();
		МассСтрок=ПНОбъект.тБрэндов.НайтиСтроки(Новый Структура("НомерЧасти",НомерЧасти));
		Для каждого СтрМасс из МассСтрок цикл
			если ЭтоНачало тогда
				СтрМасс.НачалоКомплектации=ДатаОперации;
				СтрМасс.Состояние=Перечисления.СостоянияНакладной.КомплектацияЧЗ;
				СтрМасс.Комплектовщик=Комплектовщик;
			Иначе
				СтрМасс.ОкончаниеКомплектации=ДатаОперации;
				если Состояние<>Неопределено тогда
					СтрМасс.Состояние=Состояние;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	если ПНОбъект<>Неопределено тогда
		ПНОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
КонецПроцедуры 
