		КонецЕсли;
		
		ЗНБОбъект=знб.ПолучитьОбъект();
		ЗНБОбъект.ЗагруженИзТСД=Истина;
		ЗНБОбъект.ОбменДанными.Загрузка = Истина;
		ЗНБОбъект.Записать();
		
	КонецЕсли;

	если ДанныеШапка.СозданоОбработкойПополнения и не ЕстьОшибки тогда
		если ТипЗнч(ДанныеШапка.Накладная)=Тип("ДокументСсылка.Перемещение") тогда
			ПРМОбъект=ДанныеШапка.Накладная.ПолучитьОбъект();
			если ложь тогда ПРМОбъект=документы.Перемещение.СоздатьДокумент();КонецЕсли;
			если ПРМОбъект.СостояниеНакладной<>Перечисления.СостоянияНакладной.Отгружена тогда
				ПРМОбъект.СостояниеНакладной= Перечисления.СостоянияНакладной.Отгружена;
			КонецЕсли;
			
			если ПРМОбъект.СостояниеНакладнойУПолучателя<>Перечисления.СостоянияНакладной.Принята тогда
				ПРМОбъект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.Принята;
			КонецЕсли;
			
			если ПРМОбъект.Отгружен<>Перечисления.Отгружен.Отгружен тогда
				ПРМОбъект.Отгружен=Перечисления.Отгружен.Отгружен
			КонецЕсли;
			
			если ПРМОбъект.Модифицированность() тогда
				ПРМОбъект.Записать(?(ПРМОбъект.Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	
КонецПроцедуры
