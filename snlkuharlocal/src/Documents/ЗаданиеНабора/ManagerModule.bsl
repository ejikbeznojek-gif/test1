// Кельманов А.В. - ASU-1695 - 2025.01.22
Функция ПроверитьСтатусыКодовЧЗВЛН(ЗНБ, ТекстОшибки = "", МассивОбъектовСОшибками = Неопределено) Экспорт
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("Документ.ЗаданиеНабора.ПроверитьСтатусыКодовЧЗВЛН", Новый Структура("Ссылка", ЗНБ));	
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистНабора.Ссылка КАК ЛН,
	               |	ЛистНабора_ШК.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	               |	ЛистНабора_ШК.ШтрихкодУпаковки.СпособВводаВОборот КАК СпособВводаВОборот,
	               |	ЛистНабора_ШК.ШтрихкодУпаковки.ТипШК КАК ТипШК
	               |ПОМЕСТИТЬ ВТ_КодыЧЗ
	               |ИЗ
	               |	Документ.ЛистНабора КАК ЛистНабора
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ЗаданияНабора КАК ЛистНабора_ЗНБ
	               |		ПО ЛистНабора.Ссылка = ЛистНабора_ЗНБ.Ссылка
	               |			И (ЛистНабора_ЗНБ.ЗаданиеНабора = &ЗНБ)
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабора_ШК
	               |		ПО ЛистНабора.Ссылка = ЛистНабора_ШК.Ссылка
	               |ГДЕ
	               |	ЛистНабора.Проведен
	               |	И ЛистНабора.Дата >= &Дата
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	ШтрихкодУпаковки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_КодыЧЗ.ЛН КАК ЛН,
	               |	ВТ_КодыЧЗ.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	               |	ВТ_КодыЧЗ.СпособВводаВОборот КАК СпособВводаВОборот,
	               |	ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) КАК Статус
	               |ИЗ
	               |	ВТ_КодыЧЗ КАК ВТ_КодыЧЗ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКМ_Факт.СрезПоследних КАК СтатусыКМ_ФактСрезПоследних
	               |		ПО ВТ_КодыЧЗ.ШтрихкодУпаковки = СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки
	               |ГДЕ
	               |	НЕ ВЫБОР
	               |				КОГДА ВТ_КодыЧЗ.СпособВводаВОборот В (ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Импорт), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.ПокупкаВРФ), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Производство))
	               |					ТОГДА ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) В (ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ВОбороте), ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Расформирован))
	               |							ИЛИ ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Списан)
	               |								И ВТ_КодыЧЗ.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	               |				КОГДА ВТ_КодыЧЗ.СпособВводаВОборот В (ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Перемаркировка))
	               |					ТОГДА ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) В (ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ВОбороте), ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Нанесен), ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Расформирован), ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Распечатан))
	               |							ИЛИ ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Списан)
	               |								И ВТ_КодыЧЗ.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	               |			КОНЕЦ
	               |	И НЕ(ЕСТЬNULL(СтатусыКМ_ФактСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Вложен)
	               |				И ВТ_КодыЧЗ.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	               |				И &ОтгрузкаКомплектов)";
	
	Запрос.УстановитьПараметр("Дата", ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования() - 30 * 24 * 3600);
	Запрос.УстановитьПараметр("ЗНБ", ЗНБ);
	
	// Кельманов А.В. - Для накладных FBS со спайками статус Вложен - 2025.02.27 {
	ПолныеДанные = Документы.ПолныеДанныеЗаданияНабора.ПолучитьДокументПоЗНБ(ЗНБ);
	
	Если ЗначениеЗаполнено(ПолныеДанные) Тогда
		
		Запрос.УстановитьПараметр("ОтгрузкаКомплектов", ПолныеДанные.ОтгрузкаКомплектов);
		
	Иначе
		
		Запрос.УстановитьПараметр("ОтгрузкаКомплектов", Ложь);
		
	КонецЕсли;
	// Кельманов А.В. - Для накладных FBS со спайками статус Вложен - 2025.02.27 }
	
	Результат = Запрос.Выполнить();
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);
	
	Если Результат.Пустой() Тогда
		
		Возврат Истина;
		
	Иначе
		
		Если МассивОбъектовСОшибками = Неопределено Тогда
			
			МассивОбъектовСОшибками = Новый Массив;
			
		КонецЕсли;
		
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ТекстОшибки = ТекстОшибки + "Код: " + Выборка.ШтрихкодУпаковки + "; Статус: " + Выборка.Статус + Символы.ПС;
			
			НайденныйЛН = МассивОбъектовСОшибками.Найти(Выборка.ЛН);
			
			Если НайденныйЛН = Неопределено Тогда
				
				МассивОбъектовСОшибками.Добавить(Выборка.ЛН);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

