				СтрМасс.НачалоСканировки=НачалоСканирования;
				СтрМасс.ОкончаниеСканировки=ОкончаниеСканирования;
				СтрМасс.Сканировщик=Сканировщик;
				СтрМасс.СканировкаЗакончена = Истина;			
