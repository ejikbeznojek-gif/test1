	если ТипНакладной = "РасходнаяНакладная" тогда
		
		
		ЧастьНоменклатурыПоМатрице=ложь;
		запрос.Текст="ВЫБРАТЬ
		|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как ЧастьНоменклатурыПоМатрице
		|ИЗ
		|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
		|ГДЕ
		|	РеквизитыРНКПНКПРМ.Документ = &Документ
		|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = ""ЧастьНоменклатурыПоМатрице"""; 
		запрос.УстановитьПараметр("Документ",ДанныеШапка.Накладная);
		результат=запрос.Выполнить().выбрать();
		пока результат.Следующий() цикл
			если результат.ЧастьНоменклатурыПоМатрице=истина тогда
				ЧастьНоменклатурыПоМатрице=истина;
			КонецЕсли;
		КонецЦикла;
		
		
		запрос.Текст="ВЫБРАТЬ
		|	РасходнаяНакладная.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
		|	РасходнаяНакладная.Контрагент.ИспользоватьНоменклатурнуюМатрицу КАК ИспользоватьНоменклатурнуюМатрицу,
