	МассивСостоянийНакладной=новый Массив;
	МассивСостоянийНакладной.Добавить(Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ);
	МассивСостоянийНакладной.Добавить(Перечисления.СостоянияНакладной.КомплектацияЧЗ);
	
	
	//Получим номенклатуру (комплектующую), в рамках которой всё сравниваем+++
	запрос=новый запрос;
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("МассивСостоянийНакладной",МассивСостоянийНакладной);
	запрос.УстановитьПараметр("ЛистСборкиКомплектовЧЗ",ЛистСборкиКомплектовЧЗ);	
	запрос.УстановитьПараметр("ЗаданиеНаСборкуКомплектовЧЗ",ЗаданиеНаСборкуКомплектовЧЗ);	
	
	// Кухарь А.Ю. 20.11.2024 начало
	//
	если ЛистСборкиКомплектовЧЗ=Неопределено тогда
		Запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура
		|ИЗ
		|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
		|ГДЕ
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗаданиеНаСборкуКомплектовЧЗ
