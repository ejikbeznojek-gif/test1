Функция СоздатьПеремещениеПодсортировки(ТЗдляПРМ,ФизСклад,ВиртСклад,РеквизитыШапки) Экспорт	
	
	ТЗдляПРМ.Свернуть("Номенклатура","Количество");
	
	НеПринятыеПРМ	= ПолучитьНепринятыеПРМ(ВиртСклад,ФизСклад);	
	
	Подсортировка								= Документы.Перемещение.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(Подсортировка,РеквизитыШапки);
	
	Подсортировка.Склад							= ВиртСклад;
	Подсортировка.СкладПолучатель				= ФизСклад;
	
	Подсортировка.Менеджер						= ПараметрыСеанса.Пользователь.ФизЛицо;
	Подсортировка.Автор							= ПараметрыСеанса.Пользователь;
	Подсортировка.ПунктДоставки					= ПолучитьПунктДоставки(ФизСклад);
	Подсортировка.Комментарий					= РеквизитыШапки.СтрокаКомментария;
	Подсортировка.СостояниеНакладной			= Перечисления.СостоянияНакладной.ВРаботе;
	
	Подсортировка.СостояниеНакладнойУПолучателя	= Перечисления.СостоянияНакладной.ВРаботе;
	Подсортировка.Отгружен						= Перечисления.Отгружен.Резерв;
	Подсортировка.Дата							= РеквизитыШапки.Дата;
	
	УстановитьНомер(Подсортировка);
	
	Для Каждого СтрТзПрм Из ТЗдляПРМ Цикл		
		СтруктураОтбора=Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура",СтрТзПрм.номенклатура);			
		
		СтрокиИзПрм=НеПринятыеПРМ.НайтиСтроки(СтруктураОтбора);
		Если СтрокиИзПрм.Количество()=1 тогда
			СтрокаИзДругогоПРМ=СтрокиИзПрм[0];
			Если СтрокаИзДругогоПРМ.Количество>0 тогда
				СтрТзПрм.Количество=СтрТзПрм.Количество-СтрокаИзДругогоПРМ.Количество;
				Если СтрТзПрм.Количество<=0 Тогда Продолжить КонецЕсли;					
			КонецЕсли;
		КонецЕсли;			
		
		КоличествоВУпаковке=СтрТзПрм.Номенклатура.Родитель.ШтукВКоробке;
		Если КоличествоВУпаковке=0 Тогда
			КолКратноКоробу=СтрТзПрм.Количество;
		Иначе			
			КолКратноКоробу=Цел(СтрТзПрм.Количество/КоличествоВУпаковке)*КоличествоВУпаковке;
			Если КолКратноКоробу<СтрТзПрм.Количество Тогда
				КолКратноКоробу=КолКратноКоробу+КоличествоВУпаковке;
			КонецЕсли;
		КонецЕсли;
		
		СтрТЧ										=Подсортировка.Товары.Добавить();
		
		СтрТЧ.Номенклатура							= СтрТзПрм.Номенклатура;
		СтрТЧ.Заявка								= КолКратноКоробу;
		стртч.ПодтвержденнаяЗаявка					= КолКратноКоробу;
		СтрТЧ.ПодтвержденнаяЗаявкаПеремещения		= КолКратноКоробу;
		СтрТЧ.Количество							= КолКратноКоробу;		
		
		ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, Подсортировка);
		РассчитатьСуммуТабЧасти(СтрТЧ, Подсортировка);		
	КонецЦикла;
	
	Если Подсортировка.Товары.Количество()=0 Тогда Возврат Документы.Перемещение.ПустаяСсылка() КонецЕсли; 
	
	Подсортировка.Записать(РежимЗаписиДокумента.Запись);	
	
	ТО	= ПолучитьОстаткиТМЦ(Подсортировка,Ложь,Подсортировка.Склад);
	Для Каждого СтрокаТЧ Из Подсортировка.Товары Цикл
		СтруктураОтбора=Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура",СтрокаТЧ.Номенклатура);	
		
		СтрокиОстатков=ТО.НайтиСтроки(СтруктураОтбора);
		Если СтрокиОстатков.Количество()>0 тогда			
			СвободныйОстаток=СтрокиОстатков[0].Остаток-СтрокиОстатков[0].Резерв;
		Иначе
			СвободныйОстаток=0;
		КонецЕсли;
		
		Если СтрокаТЧ.Количество>СвободныйОстаток Тогда
			СтрокаТЧ.ПодтвержденнаяЗаявка	= СвободныйОстаток;
			СтрокаТЧ.Количество				= СвободныйОстаток;		
		КонецЕсли;	
	КонецЦикла;	
	
	ТекДата=ТекущаяДата();
	Пока ТекущаяДата()-ТекДата < 1 Цикл КонецЦикла; //Задержка записи - клинит регистр состояний
	
	// Кухарь А.Ю. 29.07.2020 начало
	// 	Подсортировка.СостояниеНакладной	= Перечисления.СостоянияНакладной.ПроверенаПоОстаткам;
	Подсортировка.СостояниеНакладной	= Перечисления.СостоянияНакладной.ОжиданиеНабора;	 
	// Кухарь А.Ю. 29.07.2020 конец
	
	Подсортировка.Записать();	
	
	Возврат Подсортировка.Ссылка;
КонецФункции

Функция ПолучитьНепринятыеПРМ(СкладОтправитель,СкладПолучатель)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура 		КАК Номенклатура,
	|	СУММА(Количество) 	КАК Количество
	|ИЗ
	|	Документ.Перемещение.Товары КАК ПеремещениеТовары
	|ГДЕ	
	|	Ссылка.Дата >= &Дата
	|	И Ссылка.Склад = &Склад
	|	И Ссылка.СкладПолучатель = &СкладПолучатель	
	|	И Ссылка.Отгружен = ЗНАЧЕНИЕ(Перечисление.Отгружен.Резерв)
	|	И Ссылка.Проведен
	|СГРУППИРОВАТЬ ПО 
	|	Номенклатура
	|";
	
	Запрос.УстановитьПараметр("Дата",			ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());
	
	Запрос.УстановитьПараметр("Склад",			СкладОтправитель);	
	Запрос.УстановитьПараметр("СкладПолучатель",СкладПолучатель);
	
	Возврат	Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьНепринятыеПРМ(СкладОтправитель,СкладПолучатель)

Функция ПолучитьПунктДоставки(мСклад)
	Результат=Справочники.ПунктыДоставки.ПустаяСсылка();	
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка
	|ИЗ
	|	Справочник.ПунктыДоставки
	|ГДЕ
	|	Владелец = &Владелец
	|	И НЕ ПометкаУдаления
	|";
	Запрос.УстановитьПараметр("Владелец",мСклад);	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат=Выборка.Ссылка;
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьПунктДоставки(Склад)

