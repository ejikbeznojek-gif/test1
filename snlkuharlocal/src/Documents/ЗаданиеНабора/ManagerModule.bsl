Функция НайтиЭлементПечатнойФормы()
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка
	|ИЗ	
	|	Справочник.ВнешниеОтчеты
	|ГДЕ
	|	ВидДокумента=""ЗаданиеНабора""
	|	И ВидОбработки=""Печать""
	|	И НЕ ПометкаУдаления 	
	|";
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.ВнешниеОтчеты.ПустаяСсылка();
	КонецЕсли;
КонецФункции //НайтиЭлементПечатнойФормы()

Функция Печать(Ссылка,ДопПараметры=Неопределено) Экспорт	
	ТД=Неопределено;	
	
	ЭлементОбработки	= НайтиЭлементПечатнойФормы();
	
	Если ЭлементОбработки.Пустая() Тогда Возврат ТД КонецЕсли;	
	
	ИмяОбработки=ЭлементОбработки.ИмяФайла;	
	Внешняя=Ложь;
	Если Лев(ИмяОбработки,3)="ВН_" Тогда
		ИмяОбработки=Сред(ИмяОбработки,4);	
		Внешняя=Истина;
	КонецЕсли; 
	
	ОбработкаПечати=Неопределено;
	Если Внешняя Тогда
		ДопКаталог="PrnForms\";
		ИмяФайлаОбработки	=Константы.КаталогВнешнихОтчетов.Получить()+ДопКаталог+ИмяОбработки+".epf";
		ФайлОбработки		=Новый Файл(ИмяФайлаОбработки);
		Если ФайлОбработки.Существует() Тогда
			ОбработкаПечати=ВнешниеОбработки.Создать(ИмяФайлаОбработки);	
		КонецЕсли;
	Иначе
		ОбработкаПечати=Обработки[ИмяОбработки];
	КонецЕсли;	
	
	ФормаПечати=ОбработкаПечати.ПолучитьФорму("ЗаданиеНабора");
	
	Возврат ФормаПечати.Печать(Ссылка,ДопПараметры);
КонецФункции // ()

