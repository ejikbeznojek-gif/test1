		МассивНоменклатуры=запрос.Выполнить().Выгрузить().выгрузитьколонку("Номенклатура");
		запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);	

	иначе
	Запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	|ГДЕ
	|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЛистСборкиКомплектовЧЗ";
	МассивНоменклатуры=запрос.Выполнить().Выгрузить().выгрузитьколонку("Номенклатура");
	запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);	
		
	КонецЕсли;
	// Кухарь А.Ю. 20.11.2024 конец
	
	//Получим номенклатуру (комплектующую), в рамках которой всё сравниваем--
	
	
	
	//Получим количество требуемое для наборов из всех ЗНБ +++
	//В 1ю очередь выберем ЗНБ, по которым уже всё завершено
	запрос.Текст="ВЫБРАТЬ
	             |	ЗНБ.Ссылка КАК Ссылка
	             |ПОМЕСТИТЬ ЗНБ
	             |ИЗ
	             |	Документ.ЗаданиеНабора КАК ЗНБ
	             |ГДЕ
	             |	ЗНБ.Накладная = &Накладная
	             |	И ЗНБ.Проведен
	             |	И ЗНБ.Товары.Номенклатура В(&МассивНоменклатуры)
	             |	И ЗНБ.Товары.КоличествоДляНаборов > 0
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
	             |	ЗаданиеНабораТовары.КоличествоДляНаборов КАК КоличествоДляНаборов,
	             |	ЗНБ.Ссылка КАК Ссылка,
	             |	ЗНБ.Ссылка.ФормированиеНаборовЧЗЗавершено КАК ФормированиеНаборовЧЗЗавершено,
	             |	ЗНБ.Ссылка.СостояниеНакладной КАК СостояниеНакладной
	             |ИЗ
	             |	ЗНБ КАК ЗНБ
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	             |		ПО ЗНБ.Ссылка = ЗаданиеНабораТовары.Ссылка
	             |			И (ЗаданиеНабораТовары.КоличествоДляНаборов > 0)
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ФормированиеНаборовЧЗЗавершено УБЫВ,
	             |	Ссылка";
	
	ТаблицаЗНБ=запрос.Выполнить().Выгрузить();
	запрос.УстановитьПараметр("МассивНоменклатуры",ТаблицаЗНБ.ВыгрузитьКолонку("Номенклатура"));	

	//Получим количество требуемое для наборов из всех ЗНБ---

	
	
	//Получим количество из всех листов ранее проведённых + переданный лист +++
	Запрос.Текст="ВЫБРАТЬ
	|	т1.Номенклатура КАК Номенклатура,
	|	СУММА(т1.Количество) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(1) КАК Количество,
	|		ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура
	|	ИЗ
	|		Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	|	ГДЕ
	|		ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗаданиеНаСборкуКомплектовЧЗ
	|		И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
	|		И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Ссылка <> &ЛистСборкиКомплектовЧЗ
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		СУММА(1),
	|		ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	|	ИЗ
	|		Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	|	ГДЕ
	|		ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Ссылка = &ЛистСборкиКомплектовЧЗ
