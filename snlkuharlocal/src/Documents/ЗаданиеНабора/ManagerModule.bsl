Процедура УстановитьСостояниеБлокировки (ЗНБ_Ссылка,СостояниеНакладной)    экспорт
	если ложь тогда ЗНБ_Ссылка=документы.ЗаданиеНабора.ПустаяСсылка();КонецЕсли;
	если ЗНБ_Ссылка.СостояниеНакладной=СостояниеНакладной тогда
		СообщитьИзМодуля("ЗНБ уже переведены в состояние "+строка(СостояниеНакладной));
		Возврат;
	КонецЕсли;
	СтрТЧ=ЗНБ_Ссылка.ПланируемыеСостояния.Найти(ЗНБ_Ссылка.СостояниеНакладной);
	если СтрТЧ=Неопределено тогда
		СообщитьИзМодуля("В планируемых состояниях не найдено текущего состояния");
		возврат;
	КонецЕсли;
	Индекс=ЗНБ_Ссылка.ПланируемыеСостояния.Индекс(СтрТЧ);
	
	ЗНБ_Объект=ЗНБ_Ссылка.ПолучитьОбъект();
	СтрТЧ=ЗНБ_Объект.ПланируемыеСостояния.Вставить(Индекс+1); //Вставляем строчку так, чтобы была возможность понять какая была предыдущая
	СтрТЧ.Состояние=СостояниеНакладной;
	СтрТЧ.Пропустить=Истина;  //Пропустить мы ставим, чтобы после отката на предыдущее состояние, проскочить состояние блокировки
	ЗНБ_Объект.СостояниеНакладной=СостояниеНакладной;
	ЗНБ_Объект.Записать(РежимЗаписиДокумента.запись);
	
	
КонецПроцедуры

// Кухарь А.Ю. 02.11.2021 начало
// Процедура ВернутьПредыдущееСостояние (ЗНБ_Ссылка) экспорт
Процедура ВернутьПредыдущееСостояние (ЗНБ_Ссылка,ОтборПоТекущемуСостоянию=Неопределено) экспорт	 
	// Кухарь А.Ю. 02.11.2021 конец
	
	если ложь тогда ЗНБ_Ссылка=документы.ЗаданиеНабора.ПустаяСсылка();КонецЕсли;
	ТекущееСостояние=ЗНБ_Ссылка.СостояниеНакладной;
	// Кухарь А.Ю. 02.11.2021 начало
	// На случай если руками уже что-то изменили. Т
	если ОтборПоТекущемуСостоянию<>Неопределено и ТекущееСостояние<>ОтборПоТекущемуСостоянию тогда
		Возврат;
	КонецЕсли;
	// Кухарь А.Ю. 02.11.2021 конец
	
	МассСтрокЗНБ=ЗНБ_Ссылка.ПланируемыеСостояния.НайтиСтроки(Новый Структура("Состояние",ТекущееСостояние));
	Индекс=0;
	Для каждого СтрМасс из МассСтрокЗНБ цикл  //Блокировок могло быть несколько ищем последнюю строку
		Индекс=ЗНБ_Ссылка.ПланируемыеСостояния.Индекс(СтрМасс);
	КонецЦикла;
	если Индекс=0 тогда //Либо это 1 строка либо строк нет.
		СообщитьИзМодуля("Не найдено предыдущее состояние");
		Возврат;
	КонецЕсли;
	
	ЗНБ_Объект=ЗНБ_Ссылка.ПолучитьОбъект();
	// Кухарь А.Ю. 02.11.2021 начало
	//Иногда строчки нужно пропускать
	// НовоеСостояние=ЗНБ_Объект.ПланируемыеСостояния.Получить(Индекс-1).Состояние;//Состояние из предыдущей строчки
	МожноЗаписывать=ложь;
	пока Индекс>1 цикл
		Индекс=Индекс-1;
		ПредыдущаяСтрочка=ЗНБ_Объект.ПланируемыеСостояния.Получить(Индекс);
		если ПредыдущаяСтрочка.Пропустить тогда
			Продолжить;
		КонецЕсли;
		НовоеСостояние=ПредыдущаяСтрочка.Состояние;
		если НовоеСостояние=ТекущееСостояние тогда
			Продолжить;
		КонецЕсли;	
		МожноЗаписывать=Истина;
		Прервать;
	КонецЦикла;
	Если не МожноЗаписывать тогда Возврат;КонецЕсли;
	// Кухарь А.Ю. 02.11.2021 конец
	
	
	ЗНБ_Объект.СостояниеНакладной=НовоеСостояние;
	
	// Кельманов А.В. - HELP-9213 - 2026.03.19 {
	//ЗНБ_Объект.Записать(РежимЗаписиДокумента.запись);
	Если ЗНБ_Объект.Проведен Тогда
		ЗНБ_Объект.Записать(РежимЗаписиДокумента.Проведение);
	Иначе
		ЗНБ_Объект.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
	// Кельманов А.В. - HELP-9213 - 2026.03.19 }
	
КонецПроцедуры
