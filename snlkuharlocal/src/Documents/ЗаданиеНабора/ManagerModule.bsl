Процедура СформироватьЭтикеткуFBS(ТабДок,СтрокаТЗ)
	
	
	ПолноеИмяФайла	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить()+"PrnForms\РаботаСЗаказомКлиента.epf");
	ОбработкаПечати=ВнешниеОбработки.Создать(ПолноеИмяФайла);
	Макет=ОбработкаПечати.ПолучитьМакет("ШКВайлдберисПакетная");
	
	
	ОблСтрока=макет.ПолучитьОбласть("Строка");
	ЗаполнитьЗначенияСвойств(ОблСтрока.Параметры,СтрокаТЗ);
	Для Каждого Рисунок Из ОблСтрока.Рисунки Цикл				
		ОбъектШК			=Рисунок.Объект;
		ОбъектШК.Сообщение	= СтрокаТЗ.ШтрихКод;
	КонецЦикла;
	ТабДок.Вывести(ОблСтрока);
	ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	
КонецПроцедуры


Функция ПолучитьТоварыФБСпоЗНБ(ЗНБСсылка,ДопПараметрыНакладной,Накладная)
	если ложь тогда ЗНБСсылка=документы.ЗаданиеНабора.ПустаяСсылка();КонецЕсли;
	МассивТоваров=ЗНБСсылка.товары.ВыгрузитьКолонку("Номенклатура");
	
	Накладная=ПолучитьРеквизитШапки(ЗНБСсылка,"Накладная","Документ");
	Запрос=новый запрос;
	Запрос.УстановитьПараметр("Накладная",Накладная);
	
	Если ДопПараметрыНакладной.ОтгрузкаКомплектов тогда
		Запрос.Текст="ВЫБРАТЬ различные
		|	РасходнаяНакладнаяКомплектующие.Продукция КАК Номенклатура
		|ИЗ
		|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		|ГДЕ
		|	РасходнаяНакладнаяКомплектующие.Номенклатура В(&Номенклатура)
		|	И РасходнаяНакладнаяКомплектующие.Ссылка = &Накладная";
		запрос.УстановитьПараметр("Номенклатура",МассивТоваров);
		МассивТоваров=запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");		
	КонецЕсли;
	
	Запрос.Текст="ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказКлиентаFBSТовары.Количество) КАК Количество,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаFBSТовары.Номенклатура.ВидКомплекта = &ПустойКомплект
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЭтоКомплект,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Наименование КАК ПолеСортировки4,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Наименование КАК ПолеСортировки3,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Родитель.Наименование КАК ПолеСортировки2,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Родитель.Родитель.Наименование КАК ПолеСортировки1,
	|	ЗаказКлиентаFBSТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование = &Накладная
	|	И ЗаказКлиентаFBSТовары.Номенклатура В(&Номенклатура)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.Номенклатура,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Наименование,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Наименование,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Родитель.Наименование,
	|	ЗаказКлиентаFBSТовары.Номенклатура.Родитель.Родитель.Родитель.Родитель.Наименование,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаFBSТовары.Номенклатура.ВидКомплекта = &ПустойКомплект
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ЗаказКлиентаFBSТовары.ПрефиксЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.ШтрихКод,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПолеСортировки1,
	|	ПолеСортировки2,
	|	ПолеСортировки3,
	|	ПолеСортировки4";
	запрос.УстановитьПараметр("Номенклатура",МассивТоваров);
	запрос.УстановитьПараметр("ПустойКомплект",Перечисления.ВидыКомплектов.ПустаяСсылка());
	
	возврат Запрос.Выполнить().Выгрузить();
	
	
КонецФункции


Процедура ПропуститьСканированиеЗНБ (ЗНБ)  Экспорт 
	ЗаписыватьВЛог=Истина;
	если ЗаписыватьВЛог тогда
		ЗаписатьВЛог("Отладка","Начало пропуска сканирования -"+ЗНБ,"Информация");
	КонецЕсли;
	если Константы.РежимРаботыБезСканирования.Получить()=ложь тогда
		СообщитьИзМодуля("Пропускать сканирование запрещено. Обратитесь к администраторам склада");
		если ЗаписыватьВЛог тогда		
			ЗаписатьВЛог("Отладка","Константа РежимРаботыБезСканирования = ложь. "+ЗНБ,"Информация");
		КонецЕсли;
		
		
		Возврат;
	КонецЕсли;
	
	ЗНБОбъект=ЗНБ.получитьобъект();
	если ложь тогда  ЗНБОбъект=документы.ЗаданиеНабора.СоздатьДокумент();КонецЕсли;
	ТЗДопустимыхСостояний=ПолучитьТЗСостоянийДляПропускаСканирования();	
	СтрокаТекущегоСостояния=ТЗДопустимыхСостояний.найти(ЗНБОбъект.СостояниеНакладной);
	если СтрокаТекущегоСостояния=Неопределено тогда
		СообщитьИзМодуля("Пропускать сканирование можно в состоянии ожидание сканирования.");
		если ЗаписыватьВЛог тогда		
			ЗаписатьВЛог("Отладка","Неправильное состояние ЗНБ - "+ЗНБОбъект.СостояниеНакладной+", "+ЗНБ,"Информация");
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	СтрТЧ=ЗНБОбъект.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.ОжиданиеСканирования,"Состояние");
	если СтрТЧ<>Неопределено тогда
		СтрТЧ.Пропустить=Истина;
	КонецЕсли;
	
	СтрТЧ=ЗНБОбъект.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.Сканирование,"Состояние");
	если СтрТЧ<>Неопределено тогда
		СтрТЧ.Пропустить=Истина;
	КонецЕсли;
	
	НачатьТранзакцию();
	ЗНБОбъект.ЗаписатьЗНББезКонтроляСостояний(РежимЗаписиДокумента.Запись);
	ТекДата=ТекущаяДата();	
	если СтрокаТекущегоСостояния.ПереводитьДальше тогда	
		НовоеСостояние=ПолучитьНовоеСостояниеЗНБ(ЗНБ);
		ТекНомер=ПолучитьНомерСостоянияНакладной(НовоеСостояние);	
		ПН_Объект=ЗНБОбъект.ДокументОснование.ПолучитьОбъект();	
		МассивСтрокПН=ПН_Объект.тБрэндов.НайтиСтроки(новый Структура("НомерЧасти",ЗНБОбъект.НомерЧасти));
		Для Каждого СтрокаПН Из МассивСтрокПН Цикл
			Если  ТекНомер>ПолучитьНомерСостоянияНакладной(СтрокаПН.Состояние) Тогда
				СтрокаПН.Состояние=НовоеСостояние;	
				СтрокаПН.НачалоСканировки=ТекДата;
				СтрокаПН.ОкончаниеСканировки=ТекДата;
				СтрокаПН.СканировкаЗакончена=Истина;
				СтрокаПН.Сканировщик=СтрокаПН.Наборщик;		
			КонецЕсли; 	
		КонецЦикла; 	
		Если ПН_Объект.Модифицированность() Тогда
			ПН_Объект.Записать();	
		КонецЕсли; 
	КонецЕсли;
	ЗафиксироватьТранзакцию();
	
	если ЗаписыватьВЛог тогда		
		ЗаписатьВЛог("Отладка","Успешное окончание пропуска сканирования -"+ЗНБ,"Информация");
	КонецЕсли;
	
КонецПроцедуры

