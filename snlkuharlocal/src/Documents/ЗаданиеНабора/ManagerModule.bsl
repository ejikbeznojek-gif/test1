Процедура НапечататьЭтикеткуСШКМатрицы(Номенклатура,ЭтоКомплект,ТЗМатрицы,ТабДок,Количество)
	
	
	СтрокаМатрицы=ТЗМатрицы.Найти(Номенклатура,"Номенклатура");
	Если СтрокаМатрицы=Неопределено тогда
		СообщитьИзМодуля(""+Номенклатура+" нет в матрице. Этикетка не распечатана.");
		Возврат;
	КонецЕсли;
	
	
	
	НаборПолей=новый Структура("КодПроизводителя,Модель,ЦветБольшой,РазмерБольшой,РусскоеНаименованиеЦвета,РусскийПроизводитель,ДатаИзготовления,НаименованиеНоменклатуры,РазмерКомплекта");
	НаборПолей.ДатаИзготовления = НРег(Формат(ТекущаяДата() -90*24*60*60,"ДФ=MMMM")+ " "+Формат(НачалоМесяца(ТекущаяДата() -90*24*60*60),"ДФ=yyyy")+ " г.");
	ЗаполнитьЗначенияСвойств(НаборПолей,СтрокаМатрицы);
	НаборПолей.РазмерБольшой=ВРег(СтрокаМатрицы.Размер);
	НаборПолей.ЦветБольшой=ВРег(СтрокаМатрицы.Цвет);
	НаборПолей.РусскоеНаименованиеЦвета=ВРег(СтрокаМатрицы.РусскоеНаименованиеЦвета);
	
	ПолноеИмяФайла	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить()+"PrnForms\РаботаСЗаказомКлиента.epf");
	ОбработкаПечати=ВнешниеОбработки.Создать(ПолноеИмяФайла);
	если ЭтоКомплект тогда
		Макет=ОбработкаПечати.ПолучитьМакет("ЭтикеткаКомплект");
		НаборПолей.РазмерКомплекта=ПолучитьРеквизитШапки(Номенклатура,"Родитель.ШтукВКомплекте","Справочник"); 
	иначе
		Макет=ОбработкаПечати.ПолучитьМакет("Этикетка1_2х0_85_ЕАС");
	КонецЕсли;
	если ложь тогда
		ТД=новый ТабличныйДокумент;
		ОблЭтикетка=тд.Область("");
	КонецЕсли;
	ОблЭтикетка=макет.получитьобласть("Строка");
	ОблЭтикетка.параметры.заполнить(НаборПолей);
	Для Каждого Рисунок Из ОблЭтикетка.Рисунки Цикл	
		Если Лев(Рисунок.Имя,6)="Объект" Тогда
			ОбъектШК			=Рисунок.Объект;
			ОбъектШК.Сообщение	=СтрокаМатрицы.ШККонтрагента;
		КонецЕсли;
	КонецЦикла;
	для сч=1 по Количество цикл
		ТабДок.Вывести(ОблЭтикетка);
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;
	
КонецПроцедуры

Функция ЗаполнитьТаблицуДанныхМатрицы (Накладная,ТЗТоваров)
	РеквизитыШапки=ПолучитьРеквизитыШапки(Накладная,"Контрагент,ПунктДоставки,Договор,Дата,ПостояннаяАкция","Документ");
	
	Запрос			= Новый Запрос;				
	Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
	|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
	|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
	|	МатрицаТовары.Номенклатура.Родитель КАК Модель,
	|	МатрицаТовары.Номенклатура.КодПроизводителя КАК КодПроизводителя,
	|	МатрицаТовары.Номенклатура.Цвет.Наименование КАК Цвет,
	|	""Размер:"" + МатрицаТовары.Номенклатура.Размер.Наименование КАК Размер,
	|	ВЫРАЗИТЬ(МатрицаТовары.Номенклатура.Цвет.РусскоеНаименование КАК СТРОКА(30)) КАК РусскоеНаименованиеЦвета,
	|	МатрицаТовары.Номенклатура.Наименование КАК НаименованиеНоменклатуры,
	|	0 КАК РазмерКомплекта
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Номенклатура В(&Номенклатура)
	|	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция";
	
	Запрос.УстановитьПараметр("Дата2",			НачалоДня(РеквизитыШапки.Дата));
	Запрос.УстановитьПараметр("Дата1",			КонецДня(РеквизитыШапки.Дата));
	Запрос.УстановитьПараметр("Контрагент",		РеквизитыШапки.Контрагент);		
	Запрос.УстановитьПараметр("ПунктДоставки",	РеквизитыШапки.ПунктДоставки);				
	Запрос.УстановитьПараметр("Договор",		РеквизитыШапки.Договор);		
