Функция ПолучитьСоздатьПолныеДанныеЗаданияНабора (ЗНБСсылка,Перезаполнять=ложь) экспорт

	// Кельманов А.В. - Оптимизация работы - 2025.04.16 {
	ЗаказКлиентаFBS = ОбщегоНазначения_ПИ.ПолучитьЗаказКлиентаFBSПоНакладной(ЗНБСсылка.Накладная);
	
	Если ЗаказКлиентаFBS = Неопределено Тогда
		
		Сообщить("Отсутствует документ Заказ клиента FBS.");
		
		Возврат Неопределено;
		
	КонецЕсли;
	// Кельманов А.В. - Оптимизация работы - 2025.04.16 }
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПолныеДанныеЗаданияНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПолныеДанныеЗаданияНабора КАК ПолныеДанныеЗаданияНабора
	|ГДЕ
	|	ПолныеДанныеЗаданияНабора.Проведен
	|	И ПолныеДанныеЗаданияНабора.ДокОснование = &ДокОснование";
	
	запрос.УстановитьПараметр("ДокОснование",ЗНБСсылка);
	результат=запрос.Выполнить().Выбрать();
	ПолныеДанныеЗаданияНабораОбъект=Неопределено;
	пока результат.Следующий() цикл
		ПолныеДанныеЗаданияНабораОбъект=результат.ссылка.получитьобъект();
	КонецЦикла;
	
	
	если ПолныеДанныеЗаданияНабораОбъект = Неопределено тогда
		Перезаполнять=Истина;
		ПолныеДанныеЗаданияНабораОбъект=документы.ПолныеДанныеЗаданияНабора.СоздатьДокумент();
		УстановитьНомерДокументаКлиентСервер(ПолныеДанныеЗаданияНабораОбъект);
		ПолныеДанныеЗаданияНабораОбъект.ДокОснование=ЗНБСсылка;
	КонецЕсли;
	
	если Перезаполнять тогда
		ПолныеДанныеЗаданияНабораОбъект.ОбработкаЗаполнения(ЗНБСсылка,"",ложь);
	КонецЕсли;
	
	
	если ПолныеДанныеЗаданияНабораОбъект.ДокОснование=ЗНБСсылка тогда		
		возврат ПолныеДанныеЗаданияНабораОбъект.Ссылка;
	иначе
		возврат Неопределено;
	КонецЕсли;
	
КонецФункции
