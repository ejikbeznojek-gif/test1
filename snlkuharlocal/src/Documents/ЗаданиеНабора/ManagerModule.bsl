	Запрос.УстановитьПараметр("Дата", ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования() - 30 * 24 * 3600);
	Запрос.УстановитьПараметр("ЗНБ", ЗНБ);	
	
	Результат = Запрос.Выполнить();
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  
	
	Если Результат.Пустой() Тогда
		
		Возврат Истина;
		
	Иначе
		
		Если МассивОбъектовСОшибками = Неопределено Тогда
			
			МассивОбъектовСОшибками = Новый Массив;
			
		КонецЕсли;
		
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ТекстОшибки = ТекстОшибки + "Был ошибочно отсканирован вложенный код ЧЗ: " + Выборка.ШтрихкодУпаковки + Символы.ПС;
			
			НайденныйЛН = МассивОбъектовСОшибками.Найти(Выборка.ЛН);
			
			Если НайденныйЛН = Неопределено Тогда
				
				МассивОбъектовСОшибками.Добавить(Выборка.ЛН);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Кельманов А.В. - ASU-1695 - 2025.01.22
Функция КонтрольКорректностиСканированияЧЗВЛЗ_ПоВсемЛН(ЗНБ, ТекстОшибки = "", МассивОбъектовСОшибками = Неопределено) Экспорт
    ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("Документ.ЗаданиеНабора.КонтрольКорректностиСканированияЧЗВЛЗ_ПоВсемЛН", Новый Структура("Ссылка", ЗНБ));	
	
	РезультатПроверкиУспех = Истина;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистНабора.Ссылка КАК ЛН
	               |ИЗ
	               |	Документ.ЛистНабора КАК ЛистНабора
	               |ГДЕ
	               |	ЛистНабора.Проведен
	               |	И ЛистНабора.Дата >= &Дата
	               |	И ЛистНабора.ЗаданияНабора.ЗаданиеНабора = &ЗНБ";
	
	Запрос.УстановитьПараметр("Дата", ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования() - 30 * 24 * 3600);
	Запрос.УстановитьПараметр("ЗНБ", ЗНБ);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ЛН = Выборка.ЛН;
		
		ШтрихкодыУпаковок = ЛН.ШтрихкодыУпаковок;
		
		Если ШтрихкодыУпаковок.Количество() > 0 Тогда
			
			ЛН_Объект = ЛН.ПолучитьОбъект();
			
			РезультатПРоверки = ЛН_Объект.КонтрольКорректностиСканированияЧЗВЛЗ();
			
			Если Не РезультатПроверки.Успех Тогда
				
				Если МассивОбъектовСОшибками = Неопределено Тогда
					
					МассивОбъектовСОшибками = Новый Массив;
					
				КонецЕсли;
				
				НайденныйЛН = МассивОбъектовСОшибками.Найти(Выборка.ЛН);
				
				Если НайденныйЛН = Неопределено Тогда
					
					МассивОбъектовСОшибками.Добавить(Выборка.ЛН);
					
				КонецЕсли;
				
				РезультатПроверкиУспех = Ложь;
				
				ТекстОшибки = ТекстОшибки + РезультатПРоверки.Ошибки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);  

	Возврат РезультатПроверкиУспех;
	
КонецФункции

