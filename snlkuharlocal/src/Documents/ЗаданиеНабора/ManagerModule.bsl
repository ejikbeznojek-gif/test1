Функция ПолучитьЛистМаркировкиДляЗНБ(ЗНБ) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНабора.ЗНМ КАК ЗНМ,
	               |	ЛистМаркировки.Ссылка КАК ЛМ
	               |ИЗ
	               |	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистМаркировки КАК ЛистМаркировки
	               |		ПО ЗаданиеНабора.ЗНМ = ЛистМаркировки.ДокОснование
	               |ГДЕ
	               |	ЗаданиеНабора.Ссылка = &ЗНБ
	               |	И НЕ ЗаданиеНабора.Склад.ЭтоСкладМаркированногоТовара
	               |	И ЗаданиеНабора.ЗНМ.Проведен
	               |	И ЛистМаркировки.Проведен";
	
	Запрос.УстановитьПараметр("ЗНБ", ЗНБ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Выборка.ЛМ;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
