&НаСервере
Процедура ЗаполнитьПлановуюДатуТЧТаймигнга()
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	ЭтапыРазработкиНоменклатуры.Ссылка КАК Ссылка,
	                |	ЭтапыРазработкиНоменклатуры.НомерЭтапа КАК НомерЭтапа,
	                |	ЭтапыРазработкиНоменклатуры.Длительность КАК Длительность
	                |ИЗ
	                |	Справочник.ЭтапыРазработкиНоменклатуры КАК ЭтапыРазработкиНоменклатуры
	                |ГДЕ
	                |	НЕ ЭтапыРазработкиНоменклатуры.ПометкаУдаления
	                |	И ЭтапыРазработкиНоменклатуры.Ссылка В ИЕРАРХИИ(&Этап)
	                |	И НЕ ЭтапыРазработкиНоменклатуры.ЭтоГруппа
	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	НомерЭтапа";
	Запрос.УстановитьПараметр("Этап",Объект.ГруппаТайминга);
	Выборка = Запрос.Выполнить().Выбрать();
	ДатаПрошлогоЭтапа = Неопределено;
	Пока Выборка.Следующий() Цикл
		НовСтр = Объект.Тайминг.Добавить();
		НовСтр.ЭтапРазработки = Выборка.Ссылка; 
		Если ЗначениеЗаполнено(Объект.Дата) Тогда
			КоличествоДней = Число(Выборка.Длительность) * 86400;
			Если ДатаПрошлогоЭтапа  = Неопределено Тогда				
				НовСтр.ПлановаяДата = Объект.Дата + КоличествоДней;
				НовСтр.РасчетнаяДата = НовСтр.ПлановаяДата;
			Иначе
				НовСтр.ПлановаяДата = ДатаПрошлогоЭтапа + КоличествоДней;
				НовСтр.РасчетнаяДата = НовСтр.ПлановаяДата;
			КонецЕсли;
			ДатаПрошлогоЭтапа = НовСтр.ПлановаяДата;
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ГруппаТаймингаПриИзменении(Элемент)
	Если Объект.Тайминг.Количество() = 0 Тогда
		ЗаполнитьПлановуюДатуТЧТаймигнга(); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТаймингФактическаяДатаПриИзменении(Элемент)
	ТекСтрока = Элементы.Тайминг.ТекущиеДанные;  
	НоваяДата = ТекСтрока.ФактическаяДата;
	Для Каждого Стр из Объект.Тайминг Цикл
		Если Стр.НомерСтроки > ТекСтрока.номерстроки Тогда 
			РасчетнаяДлительность = ПолучитьДлительностьТаймингаПоМаршруту(Объект.Маршрут,СТр.ЭтапРазработки);
			КоличествоДней = Число(РасчетнаяДлительность) * 86400;
			Стр.РасчетнаяДата = НоваяДата + КоличествоДней; 
			НоваяДата = Стр.РасчетнаяДата;
		КонецЕсли;
				
	КонецЦикла;
	
КонецПроцедуры

