&НаСервере
Процедура ИсторияНаСервере() экспорт
	
	СхемаКомпоновкиДанных = Документы.РазработкаНовойНоменклатуры.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);
	МакетКомпоновки.ЗначенияПараметров.ДокРазработки.Значение = Объект.Ссылка;
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);
	
	Результат = Элементы.Результат;
	Результат.Очистить();
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(Результат);
	
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьМодель(Команда)
	Если НЕ ЗначениеЗаполнено(Объект.Артикул) Тогда
		НовМодель = Справочники.Номенклатура.СоздатьГруппу();
		НовМодель.ЭтоМодель = Истина;
		//НовМодель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар;
		//НовМодель.Брэнд = Объект.Брэнд;
		НовМодель.Наименование = Объект.НаименованиеАртикула;
		НовМодель.Записать();
		ФормаВвода = НовМодель.ПолучитьФорму("УстановкаРеквизитов",НовМодель);
		ФормаВвода.ЭлементыФормы.Брэнд.Значение = Объект.Брэнд;
		ФормаВвода.ЭлементыФормы.БрендДляСайта.Значение = Объект.Брэнд;
		ФормаВвода.ЭлементыФормы.ПоловозрастнойПризнак.Значение = Объект.ПолоВозрастнойПризнак;
		ФормаВвода.Владелец = НовМодель.Ссылка;
		ФормаВвода.ОткрытьМодально();
		Объект.Артикул = НовМодель.Ссылка;
	Иначе
		Объект.Артикул.ПолучитьФорму().Открыть();
	КонецЕсли;
КонецПроцедуры

