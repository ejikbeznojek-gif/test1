&НаКлиенте
Функция ПолучитьДокументАссортиментныйКомитет() 
	
	Если Объект.АссортиментныйКомитет.Количество() > 0 Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Активен", Истина);
		НайденныеСтроки = Объект.АссортиментныйКомитет.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.количество() = 0 Тогда
			ДокАссортиментныйКомитет = Документы.АссортиментныйКомитет.СоздатьДокумент();
			ДокАссортиментныйКомитет.Дата = ТекущаяДатаСеанса();
			ДокАссортиментныйКомитет.Записать(РежимЗаписиДокумента.Проведение);
			НоваяСтрока = Объект.АссортиментныйКомитет.Добавить();
			НоваяСтрока.Документ = ДокАссортиментныйКомитет.Ссылка;
			НоваяСтрока.Активен = Истина;
		КонецЕсли;
		
		Для Каждого Стр Из НайденныеСтроки Цикл
			
			ДокАссортиментныйКомитет = Стр.Документ;
		КонецЦикла;
		
	Иначе
		ДокАссортиментныйКомитет = Документы.АссортиментныйКомитет.СоздатьДокумент();
		//ДокАссортиментныйКомитет.УстановитьНовыйНомер();
		ДокАссортиментныйКомитет.Дата = ТекущаяДатаСеанса();
		ДокАссортиментныйКомитет.Записать(РежимЗаписиДокумента.Проведение);
		НоваяСтрока = Объект.АссортиментныйКомитет.Добавить();
		НоваяСтрока.Документ = ДокАссортиментныйКомитет.Ссылка;
		НоваяСтрока.Активен = Истина;
	КонецЕсли;
	
	Возврат ДокАссортиментныйКомитет.Ссылка;
КонецФункции

