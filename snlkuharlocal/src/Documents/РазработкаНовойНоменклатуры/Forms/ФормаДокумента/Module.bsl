//	УдалитьИзВременногоХранилища(ФайлКартинки);
	
	ОбъектДляЗаписи.ПериодПроведенияАссортиментногоКомитета = ПериодПроведенияАссортиментногоКомитета;
	ОбъектДляЗаписи.СтатусВыполнения = СтатусВыполнения;
	ОбъектДляЗаписи.ПодразделенияПродаж.Загрузить(ПодразделенияПродаж.Выгрузить());
	ОбъектДляЗаписи.ПараметрыТовара.Загрузить(ПараметрыТовара.Выгрузить());
