

&НаКлиенте
Перем ТекущийДокАссортиментныйКомитет;


&НаКлиенте
Процедура КартинкаФотоАналогаНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь; 
	Режим = РежимДиалогаВыбораФайла.Открытие; 
	ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим); 
	ДиалогОткрытия.ПолноеИмяФайла = ""; 
	Фильтр = "Файл картинки (*.jpg);(*.png);(*.bmp)|*.jpg;*.png;*.bmp"; 
	ДиалогОткрытия.Фильтр = Фильтр; 
	ДиалогОткрытия.МножественныйВыбор = Ложь; 
	ДиалогОткрытия.Заголовок = "Выберете файл для загрузки"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗагрузкиФайла",ЭтаФорма); 
	ДиалогОткрытия.Показать(ОписаниеОповещения);
КонецПроцедуры

&НаКлиенте 
Процедура ПослеЗагрузкиФайла(ВыбранныйФайл,ДопПараметр) Экспорт 
	Если ВыбранныйФайл = Неопределено Тогда 
		Возврат; 
	КонецЕсли; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПомещенияФайла", ЭтаФорма); 
	НачатьПомещениеФайла(ОписаниеОповещения,, ВыбранныйФайл[0], Ложь, УникальныйИдентификатор); 
КонецПроцедуры

&НаКлиенте 
Процедура ПослеПомещенияФайла(Результат, Адрес, ВыбранноеИмяФайла,ДопПараметры) Экспорт 
	Если Не Результат Тогда 
		Возврат; 
	КонецЕсли; 
	Если ЭтаФорма.ТекущийЭлемент.Имя = "КартинкаФотоАналога" Тогда
		КартинкаФотоАналога = Адрес; 
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "КартинкаРеференсУпаковки" Тогда
		КартинкаРеференсУпаковки = Адрес;
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "картинкаРеференсФотоСессии" Тогда
		картинкаРеференсФотоСессии = Адрес;
	ИначеЕсли ЭтаФорма.ТекущийЭлемент.Имя = "ДизайнМакетКартинка" Тогда
		ДизайнМакетКартинка = Адрес;
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ЭтоАдресВременногоХранилища(КартинкаФотоАналога)  Тогда 
		ФайлКартинки = ПолучитьИзВременногоХранилища(КартинкаФотоАналога); 
		ТекущийОбъект.ФотоАналога = Новый ХранилищеЗначения(ФайлКартинки); 
		УдалитьИзВременногоХранилища(КартинкаФотоАналога); 
		//КартинкаФотоАналога = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ФотоАналога"); 
	КонецЕсли;
	Если ЭтоАдресВременногоХранилища(КартинкаРеференсУпаковки)  Тогда 
		ФайлКартинки = ПолучитьИзВременногоХранилища(КартинкаРеференсУпаковки); 
		ТекущийОбъект.РеференсУпаковки = Новый ХранилищеЗначения(ФайлКартинки); 
		УдалитьИзВременногоХранилища(КартинкаРеференсУпаковки); 
		//КартинкаРеференсУпаковки = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсУпаковки"); 
	КонецЕсли;
	Если ЭтоАдресВременногоХранилища(КартинкаРеференсФотоСессии)  Тогда 
		ФайлКартинки = ПолучитьИзВременногоХранилища(КартинкаРеференсФотоСессии); 
		ТекущийОбъект.РеференсФотоСессии = Новый ХранилищеЗначения(ФайлКартинки); 
		УдалитьИзВременногоХранилища(КартинкаРеференсФотоСессии); 
		//КартинкаРеференсФотоСессии = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсФотоСессии"); 
	КонецЕсли;
	Если ЭтоАдресВременногоХранилища(ДизайнМакетКартинка)  Тогда 
		ФайлКартинки = ПолучитьИзВременногоХранилища(ДизайнМакетКартинка); 
		ТекущийОбъект.ДизайнМакет = Новый ХранилищеЗначения(ФайлКартинки); 
		УдалитьИзВременногоХранилища(ДизайнМакетКартинка); 
		ДизайнМакетКартинка = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ДизайнМакет"); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	КартинкаФотоАналога = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ФотоАналога");
	КартинкаРеференсУпаковки = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсУпаковки");
	КартинкаРеференсФотоСессии = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсФотоСессии");
	ДизайнМакетКартинка = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ДизайнМакет");
	ЗаписатьДанныеФормыВДокументАссортиментныйКомитет(ТекущийДокАссортиментныйКомитет);
	
	//Если Объект.Тайминг.Количество() < 1 И ЗначениеЗаполнено(Объект.Дата) Тогда
	//	ЗаполнитьПлановуюДатуТЧТаймигнга();
	//КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//ОбновитьНумерациюОбъектов();
	Если Объект.Ссылка.Пустая() Тогда 
		Объект.ТекущаяСтадияДокумента = 1;
		Объект.Автор = ПараметрыСеанса.Пользователь;
	КонецЕсли;
	КартинкаФотоАналога = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ФотоАналога");
	КартинкаРеференсУпаковки = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсУпаковки");
	КартинкаРеференсФотоСессии = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"РеференсФотоСессии");
	ДизайнМакетКартинка = ПолучитьНавигационнуюСсылку(Объект.Ссылка,"ДизайнМакет");
КонецПроцедуры


