&НаКлиенте
Процедура ПрекратитьРазработку(Команда)
	СтатусВыполнения = Перечисления.СтатусыАссортиментногоКомитета.ПрекратитьРазработку;
	ПараметрыОтбора = Новый Структура;
	//ПараметрыОтбора.Вставить("Документ", ТекущийДокАссортиментныйКомитет);
	ПараметрыОтбора.Вставить("Активен", Истина);
	НайденныеСтроки = Объект.АссортиментныйКомитет.НайтиСтроки(ПараметрыОтбора);
	Для Каждого Стр Из НайденныеСтроки Цикл
		Стр.Статус = Перечисления.СтатусыАссортиментногоКомитета.ПрекратитьРазработку;
		//Стр.Активен = Ложь;
	КонецЦикла;
	ЗаписатьДанныеФормыВДокументАссортиментныйКомитет(ТекущийДокАссортиментныйКомитет);
	Объект.ТекущаяСтадияДокумента = 4;
	Записать();
	Элементы.ПрекратитьРазработку.ЦветФона = ЦветаСтиля.ЦветАкцента;
	Элементы.ПрекратитьРазработку.ЦветРамки = ЦветаСтиля.ЦветАкцента;
КонецПроцедуры

&НаКлиенте
Процедура ПринятьКДоработке(Команда)
	СтатусВыполнения = Перечисления.СтатусыАссортиментногоКомитета.ПринятьКДороботке;
	ПараметрыОтбора = Новый Структура;
	//ПараметрыОтбора.Вставить("Документ", ТекущийДокАссортиментныйКомитет);
	ПараметрыОтбора.Вставить("Активен", Истина);
	НайденныеСтроки = Объект.АссортиментныйКомитет.НайтиСтроки(ПараметрыОтбора);
	Для Каждого Стр Из НайденныеСтроки Цикл
		Стр.Статус = Перечисления.СтатусыАссортиментногоКомитета.ПринятьКДороботке;
		Стр.Активен = Ложь;
	КонецЦикла;
	ЗаписатьДанныеФормыВДокументАссортиментныйКомитет(ТекущийДокАссортиментныйКомитет);
	Записать();
	ТемаПисьма = "Решение Ассортиментного комитета по Разработке Номенклатуры: " + Объект.Номер + " от "+ Объект.Дата;
	ТекстПисьма = " АссортиментныйКомитет "+ ПериодПроведенияАссортиментногоКомитета+ " принял решение о необходимости доработки " + Объект.Номер + " от "+ Объект.Дата;  
	//ОповеститьИсполнителя(Объект.ОтветственноеЛицоПЗО,ТекстПисьма,ТемаПисьма);
	Элементы.ПринятьКДоработке.ЦветФона = ЦветаСтиля.ЦветАкцента;
	Элементы.ПринятьКДоработке.ЦветРамки = ЦветаСтиля.ЦветАкцента;
КонецПроцедуры

