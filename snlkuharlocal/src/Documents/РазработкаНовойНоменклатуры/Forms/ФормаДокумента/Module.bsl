КонецПроцедуры       

&НаСервере
Процедура ЗаполнитьПлановуюДатуТЧТаймингаПоМаршруту()
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	ЭтапыРазработкиНоменклатурыДанные.Ссылка КАК Ссылка,
	                |	ЭтапыРазработкиНоменклатурыДанные.Длительность КАК Длительность,
	                |	ЭтапыРазработкиНоменклатурыДанные.Ссылка.НомерЭтапа КАК НомерЭтапа,
	                |	ЭтапыРазработкиНоменклатурыДанные.Отдел КАК Отдел
	                |ИЗ
	                |	Справочник.ЭтапыРазработкиНоменклатуры.Данные КАК ЭтапыРазработкиНоменклатурыДанные
	                |ГДЕ
	                |	ЭтапыРазработкиНоменклатурыДанные.Маршрут = &Маршрут
	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	НомерЭтапа";
	Запрос.УстановитьПараметр("Маршрут",Объект.Маршрут);
	Выборка = Запрос.Выполнить().Выбрать();
	ДатаПрошлогоЭтапа = Неопределено;
	Пока Выборка.Следующий() Цикл
		НовСтр = Объект.Тайминг.Добавить();
		НовСтр.ЭтапРазработки = Выборка.Ссылка;
		НовСтр.Отдел = Выборка.Отдел;
		НовСтр.Статус = Перечисления.СостоянияДляЗаявок.ВРаботе;
		Если ЗначениеЗаполнено(Объект.Дата) Тогда
			КоличествоДней = Число(Выборка.Длительность) * 86400;
			Если ДатаПрошлогоЭтапа  = Неопределено Тогда				
				НовСтр.ПлановаяДата = Объект.Дата + КоличествоДней;
				НовСтр.РасчетнаяДата = НовСтр.ПлановаяДата;
			Иначе
				НовСтр.ПлановаяДата = ДатаПрошлогоЭтапа + КоличествоДней;
				НовСтр.РасчетнаяДата = НовСтр.ПлановаяДата;
			КонецЕсли;
			ДатаПрошлогоЭтапа = НовСтр.ПлановаяДата;
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьДлительностьТаймингаПоМаршруту(МаршрутЗапроса,ЭтапЗапроса)
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	ЭтапыРазработкиНоменклатурыДанные.Ссылка КАК Ссылка,
	                |	ЭтапыРазработкиНоменклатурыДанные.Длительность КАК Длительность,
	                |	ЭтапыРазработкиНоменклатурыДанные.Отдел КАК Отдел
	                |ИЗ
	                |	Справочник.ЭтапыРазработкиНоменклатуры.Данные КАК ЭтапыРазработкиНоменклатурыДанные
	                |ГДЕ
	                |	ЭтапыРазработкиНоменклатурыДанные.Маршрут = &Маршрут
	                |	И ЭтапыРазработкиНоменклатурыДанные.Ссылка = &Этап";
	Запрос.УстановитьПараметр("Маршрут",МаршрутЗапроса);
	Запрос.УстановитьПараметр("Этап",ЭтапЗапроса);
	Выборка = Запрос.Выполнить().Выбрать();
	Если  Выборка.Следующий() Тогда
        Возврат Выборка.Длительность;
	Иначе 
		Возврат 0;
	КонецЕсли; 	
	
КонецФункции

&НаСервере
Функция ПользовательИзПодразеденияОтделаЗакупок(Пользователь) 

	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ РАЗЛИЧНЫЕ
	                |	Подразделения.Ссылка КАК Ссылка
	                |ИЗ
	                |	Справочник.Подразделения КАК Подразделения
	                |ГДЕ
	                |	Подразделения.Ссылка В ИЕРАРХИИ(&ПодразделениеДЗП)
	                |	И НЕ Подразделения.ПометкаУдаления
	                |	И НЕ Подразделения.ЭтоГруппа";
	Запрос.УстановитьПараметр("ПодразделениеДЗП",Справочники.Подразделения.НайтиПоКоду("GRP-0436")); // Департамент закупок и производства
	//	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	МассивПодразделений = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	МассивПодразделений.Добавить(Справочники.Подразделения.НайтиПоКоду("SSP-0355"));  //Отдел категорийных менеджеров
	Если МассивПодразделений.Найти(Пользователь.ФизЛицо.Подразделение) = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

