		Если НЕ (СтрокаТЧ.Сертификат.ОплатаНеБолее30Процентов) и СтрокаТЧ.Сертификат.подарок Тогда
			
			
			НовСтр = СписокПодСертБезПроц.Добавить() ;
			НовСтр.номерСтроки = Строкатч.НомерСтроки;
			НовСтр.сертификат = СтрокаТЧ.Сертификат;
			НовСтр.Номинал = СтрокаТЧ.Номинал;
			НовСтр.СуммаОплаты = 0;
			
		КонецЕсли;  
		
	КонецЦикла;		
	СуммаПодарочСертификПодаркиБезПроцента = СписокПодСертБезПроц.Итог("Номинал");
