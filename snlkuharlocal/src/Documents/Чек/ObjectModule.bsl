Функция ЗаписатьДК()
	ДКОбъект = Дк.ПолучитьОбъект();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ДисконтныеКартыЧеки.Сумма КАК Итого
	|ИЗ
	|	Справочник.ДисконтныеКарты.Чеки КАК ДисконтныеКартыЧеки
	|ГДЕ
	|	ДисконтныеКартыЧеки.Ссылка = &ДК
	|	И ДисконтныеКартыЧеки.НомерЧека = &Чек
	|	И ДисконтныеКартыЧеки.ДатаЧека = &ДатаЧека";
	Запрос.УстановитьПараметр("Чек",Ссылка.Номер);
	Запрос.УстановитьПараметр("ДатаЧека",Ссылка.Дата);
	Запрос.УстановитьПараметр("ДК",ДК);
	Выборка = Запрос.Выполнить().Выбрать();
	Если  Выборка.Следующий() Тогда
		Если Выборка.Итого <> СуммаДокумента Тогда
			Сообщить("Изменение суммы чека, пробитого по ДК, невозможно");
			Возврат Истина;
		иначе
			Возврат Ложь;
		Конецесли;
	иначе
		Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
			СуммаСкидки = Товары.Итог("ВсегоБезСкидки")-Товары.Итог("Всего");
			
			СтрокаЧековДК = ДКОбъект.Чеки.Добавить();
			//СтрокаЧековДК.Чек = Ссылка;
			СтрокаЧековДК.ДатаЧека = Ссылка.Дата;
			СтрокаЧековДК.НомерЧека = Ссылка.Номер;
			СтрокаЧековДК.Количество = КоличествоДокумента;
			СтрокаЧековДК.Кассир = ПараметрыСеанса.Пользователь;
			СтрокаЧековДК.Подразделение = Склад.Подразделение;
			СтрокаЧековДК.Продавец = Продавец;
			СтрокаЧековДК.ПроцентСкидки = Скидка;
			СтрокаЧековДК.Сумма = СуммаДокумента;
			СтрокаЧековДК.СуммаСкидки =  СуммаСкидки;
		иначе
			СуммаСкидки = Товары.Итог("ВсегоБезСкидки")-Товары.Итог("Всего");
			
			СтрокаЧековДК = ДКОбъект.Чеки.Добавить();
			//СтрокаЧековДК.Чек = Ссылка;
			СтрокаЧековДК.ДатаЧека = Ссылка.Дата;
			СтрокаЧековДК.НомерЧека = Ссылка.Номер;
			СтрокаЧековДК.Количество = -КоличествоДокумента;
			СтрокаЧековДК.Кассир = ПараметрыСеанса.Пользователь;
			СтрокаЧековДК.Подразделение = Склад.Подразделение;
			СтрокаЧековДК.Продавец = Продавец;
			СтрокаЧековДК.ПроцентСкидки = Скидка;
			СтрокаЧековДК.Сумма = -СуммаДокумента;
			СтрокаЧековДК.СуммаСкидки =  -СуммаСкидки;
			
			
		КонецЕсли;
		
		Для Каждого СтрокаТоваров Из Товары Цикл
			Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
				
				СтрокаПокупкиДК = ДКОбъект.Покупки.Добавить();
