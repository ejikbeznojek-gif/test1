		Если СуммаКРаспределению>0 Тогда
			
			Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
				
				Если НЕ (СтрокаТЧ.сертификат.Подарок = истина и СтрокаТЧ.сертификат.ОплатаНеБолее30Процентов= ложь)Тогда
					продолжить;
				КонецЕсли;
				
				СуммаЗачета=Макс(Мин(СтрокаТЧ.Номинал,СуммаКРаспределению),0); // сумма учтенная по текущему сертификату
				Если СтрокаТЧ.СуммаОплатыСертификатами<>СуммаЗачета Тогда
					СтрокаТЧ.СуммаОплатыСертификатами=СуммаЗачета;
				КонецЕсли;		
				
				Учтено = Учтено+СуммаЗачета;
				СуммаКРаспределению=СуммаКРаспределению-СуммаЗачета;
				
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	//пересчитаем итоги.
	Если СуммаОплатыСертификатами<>ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами") Тогда
			СуммаОплатыСертификатами=ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");	
	КонецЕсли;
    
