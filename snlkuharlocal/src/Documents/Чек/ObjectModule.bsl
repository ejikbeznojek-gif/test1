Функция ПолучитьПараметрыСертификатов(АкцияСертификатыИзЧека,СуммаДенег)
	ПараметрыСертификатов = Новый Структура;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	АкцииПараметрыСертификатовИзЧека.НоминалСертификата,
	|	АкцииПараметрыСертификатовИзЧека.КоличествоСертификатов,
	|	АкцииПараметрыСертификатовИзЧека.СуммаДенег КАК СуммаДенег
	|ИЗ
	|	Справочник.Акции.ПараметрыСертификатовИзЧека КАК АкцииПараметрыСертификатовИзЧека
	|ГДЕ
	|	АкцииПараметрыСертификатовИзЧека.Ссылка = &Акция
	|	И АкцииПараметрыСертификатовИзЧека.СуммаДенег <= &СуммаДенег
	|
	|УПОРЯДОЧИТЬ ПО
	|	СуммаДенег УБЫВ
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Акция",АкцияСертификатыИзЧека);
	запрос.УстановитьПараметр("СуммаДенег",СуммаДенег);
	
	Выборка = запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПараметрыСертификатов.Вставить("КоличествоСертификатов",Выборка.КоличествоСертификатов);
		ПараметрыСертификатов.Вставить("СуммаСертификата",Выборка.НоминалСертификата);
	Иначе
		ПараметрыСертификатов.Вставить("КоличествоСертификатов",0);
		ПараметрыСертификатов.Вставить("СуммаСертификата",0);
		
	КонецЕсли;
	Возврат ПараметрыСертификатов;
	
КонецФункции

