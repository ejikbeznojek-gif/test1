	Если     СписокПодСертНеПод.Итог("Номинал")>0 Тогда
		
		СуммаКРаспределению =  Макс(Мин((СуммаДокумента - ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами")), СписокПодСертНеПод.Итог("Номинал") ),0);
		
		Если СуммаКРаспределению>0 Тогда
			
			Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
				
				Если СтрокаТЧ.сертификат.Подарок = истина   Тогда
					продолжить;
				КонецЕсли;
				
				СуммаЗачета=Макс(Мин(СтрокаТЧ.Номинал,СуммаКРаспределению),0); // сумма учтенная по текущему сертификату
				Если СтрокаТЧ.СуммаОплатыСертификатами<>СуммаЗачета Тогда
					СтрокаТЧ.СуммаОплатыСертификатами=СуммаЗачета;
				КонецЕсли;		
				
				Учтено = Учтено+СуммаЗачета;
				СуммаКРаспределению=СуммаКРаспределению-СуммаЗачета;
				
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	// и третий тип  отовариваем сертификаты подарки без % скидки, если они есть..
	Если СписокПодСертБезПроц.Итог("Номинал")>0 Тогда
