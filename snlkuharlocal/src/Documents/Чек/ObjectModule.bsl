		// распределим  сумму,  с учетом того, что оплалить можно не более 30% от  оставшейся суммы чека.
		//Берем от суммы документа только 30%
		СуммаКоторуюНадоПогаситьОтЧека=Окр(СуммаДокумента*СписокПодСертСоСк[0].ПроцентОплаты/100,0);
		
		СуммаПогашенияСерСоСк = Макс( Мин(СуммаВозможнойОплатыСертСоСк,СуммаКоторуюНадоПогаситьОтЧека),0);
		
		СуммаКРаспределению = СуммаПогашенияСерСоСк;	//сколько нужно денег по сертификатам погасить.
		
		Учтено2 = 0; // сколько уже учли сумм по сертификатам. от каждого берем только с нужным процентом!!
		Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
			
			Если СтрокаТЧ.сертификат.ОплатаНеБолее30Процентов= ложь   Тогда
