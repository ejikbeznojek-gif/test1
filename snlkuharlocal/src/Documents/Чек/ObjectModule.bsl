 Функция АкцияПлПодарки()

	//АкцияПластиковыеСертификатыПодарки = Подразделение.АкцияСертификатыИзЧека;
	//нечаева 11,12,13 +++
	АкцияПластиковыеСертификатыПодарки = Подразделение.АкцияСертификатыПластиковые; //.АкцияСертификатыИзЧека;
	//нечаева 11,12,13 ---
	
	
	Если КодОперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда
		АкцияПластиковыеСертификатыПодарки = Справочники.Акции.ПустаяСсылка();
	КонецЕсли;
	
	Если НЕ АкцияПластиковыеСертификатыПодарки.Пустая() И (АкцияПластиковыеСертификатыПодарки.ДатаНачала>Дата ИЛИ АкцияПластиковыеСертификатыПодарки.ДатаОкончания<Дата) Тогда		
		АкцияПластиковыеСертификатыПодарки=Справочники.Акции.ПустаяСсылка();
	КонецЕсли;
	
	Если НЕ АкцияПластиковыеСертификатыПодарки.Пустая() И АкцияПластиковыеСертификатыПодарки.ПроверятьВремя Тогда	
		ВремяНачала = АкцияПластиковыеСертификатыПодарки.ВремяНачала - Дата(1,1,1);
		ВремяОкончания =  АкцияПластиковыеСертификатыПодарки.Времяокончания - Дата(1,1,1);
		ТекущееВремя = ТекущаяДата() - НачалоДня(ТекущаяДата());
		Если ВремяНачала > ТекущееВремя ИЛИ ВремяОкончания < ТекущееВремя Тогда
			АкцияПластиковыеСертификатыПодарки=Справочники.Акции.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	Если Не АкцияПластиковыеСертификатыПодарки.Пустая() И АкцияПластиковыеСертификатыПодарки.ДатыАктивности.Количество() > 0 Тогда
		ДеньСовпадает = Ложь; 
		Для Каждого СтрокаАкций Из АкцияПластиковыеСертификатыПодарки.ДатыАктивности Цикл
			Если НачалоДня(Дата) = НачалоДня(СтрокаАкций.Дата) Тогда
				ДеньСовпадает = Истина;
			КонецЕсли;				
		КонецЦикла;
		Если НЕ ДеньСовпадает Тогда
			АкцияПластиковыеСертификатыПодарки=Справочники.Акции.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
	
	Если Акция.ВыдаватьПластиковыеСертификаты Тогда
		АкцияПластиковыеСертификатыПодарки = Акция;
	КонецЕсли;
	
	Если АкцияПластиковыеСертификатыПодарки.ТолькоДляЧастногоЛица И Контрагент <> Подразделение.ЧастноеЛицо Тогда
		АкцияПластиковыеСертификатыПодарки = Справочники.Акции.ПустаяСсылка();
	КонецЕсли;		
	//крохин конец 15.11.2012

	возврат АкцияПластиковыеСертификатыПодарки;
	
