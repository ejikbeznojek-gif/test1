	//-------------------------------------------------------------------------
	// обнулим суммы к оплате по сертификатам, при сканировании следующего
	
	Если модифицированность() =ложь Тогда
		возврат;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
		
		СтрокаТЧ.СуммаОплатыСертификатами = 0;
		
	КонецЦикла;		
    	
	//-------------------------------------------------------------------------
	
	// нечаева 18,10,17++++
