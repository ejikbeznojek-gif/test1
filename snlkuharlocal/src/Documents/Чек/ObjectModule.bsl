Функция ПробитьПогашениеСертификатов(СтрокаФР)	
	СписокТоваров=Новый ТаблицаЗначений;
	СписокТоваров.Колонки.Добавить("Номенклатура");
	СписокТоваров.Колонки.Добавить("Количество",	ПолучитьОписаниеТиповЧисла(19,2));
	СписокТоваров.Колонки.Добавить("Цена",			ПолучитьОписаниеТиповЧисла(19,2));
	СписокТоваров.Колонки.Добавить("Скидка",		ПолучитьОписаниеТиповЧисла(19,2));
	СписокТоваров.Колонки.Добавить("СтавкаНДС");
	СписокТоваров.Колонки.Добавить("Секция");	
	СписокТоваров.Колонки.Добавить("СуммаСкидки",	ПолучитьОписаниеТиповЧисла(19,2));
	
	СуммаСертификатов=0;
	
	Для Каждого СтрокаСертификатов Из ПодарочныеСертификаты Цикл
		Если НЕ СтрокаСертификатов.Сертификат.Пустая() Тогда
			
			//крохин начало 30.01.2017
			//с 01.02.2017г пробиваем сумму оплаты, а не номинал
			//СуммаСертификатов=СуммаСертификатов+СтрокаСертификатов.Номинал;
			СуммаСертификатов=СуммаСертификатов+СтрокаСертификатов.СуммаОплатыСертификатами;
			//крохин конец 30.01.2017
			
			ЭлементСписка = СписокТоваров.Добавить();
			
			ЭлементСписка.Номенклатура	= "Серт. №: "+СтрокаСертификатов.Сертификат+", номинал: "+СтрокаСертификатов.Номинал;
			ЭлементСписка.Количество	= 1;
			//крохин начало 30.01.2017
			//с 01.02.2017г пробиваем сумму оплаты, а не номинал
			//ЭлементСписка.Цена			= СтрокаСертификатов.Номинал;
			ЭлементСписка.Цена			= СтрокаСертификатов.СуммаОплатыСертификатами;
			//крохин конец 30.01.2017
			ЭлементСписка.Скидка		= 0;	
			//крохин начало 21.12.2018
			//изменение ставки НДС
			//ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.НДС18;
			//крохин начало 21.01.2018
			//ошибка
		//	Если Дата >= '20190101' Тогда
		//	ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.НДС20;	
		//ИначеЕсли ПараметрыСеанса.ЭтотУзел.Подразделение.НулеваяСтавкаНДСвЧеке Тогда
		//	ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.БезНДС;
		    Если Дата >= '20190101' Тогда
				Если ПараметрыСеанса.ЭтотУзел.Подразделение.НулеваяСтавкаНДСвЧеке Тогда
				ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.БезНДС;
					Иначе
			    ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.НДС20;	
		        КонецЕсли;
			//крохин конец 21.01.2018
			Иначе
			ЭлементСписка.СтавкаНДС		= Перечисления.СтавкиНДС.НДС18;	
			КонецЕсли; 
			//крохин конец 21.12.2018
			ЭлементСписка.Секция		= 2;			
		КонецЕсли;	
	КонецЦикла;	
	
	Если СуммаСертификатов=0 Тогда Возврат "" КонецЕсли; 
	
	Параметры  = Новый Структура();
	
	Параметры.Вставить("СписокТоваров",  СписокТоваров);
	Параметры.Вставить("НомерСекции",    НомерСекции);
	Параметры.Вставить("ЧекНаВозврат",   Истина);
	Параметры.Вставить("ПолученоНАЛ",    0);
	Параметры.Вставить("ПолученоБН",	 0);
	Параметры.Вставить("ПолученоСер1", 	 0);
	Параметры.Вставить("ПолученоСер2", 	 СуммаСертификатов);	
	
	Параметры.Вставить("НДС",            18);
	
	Ответ="";
	глТорговоеОборудование.ПечататьЧек(СтрокаФР, Параметры, Ответ);	
	
	//задержка
	//крохин начало
	//Дата0=ТекущаяДата();
	//Пока (ТекущаяДата()-Дата0)<2 Цикл			
	//КонецЦикла; 	//задержка
	Дата0=ТекущаяДата();
	Задержка = Макс(ПодарочныеСертификаты.Количество(),5);
	Пока (ТекущаяДата()-Дата0)< Задержка Цикл			
		#Если Клиент Тогда
			Состояние("задержка печати чека. Осталось "+(Задержка -(ТекущаяДата()-Дата0))+ " секунд");		 
		#КонецЕсли		
	КонецЦикла;
	//крохин конец
	
	Возврат Ответ;	
КонецФункции //ПробитьВозвратСертификатов()

Функция ПечатьЧекаНаФР(Модель, НомерЛУ, КассаККМ)
	Ответ       = "";		
	СтрокаФР  	= глТорговоеОборудование.млФР.Найти(КассаККМ, "КассаККМ");		
	НомерСекции	= 1;
	
	//крохин начало 20.05.2021
	//сертификаты больше не пробиваются отдельным чеком
	//Ответ		= ПробитьПогашениеСертификатов(СтрокаФР);
	//крохин конец 20.05.2021
	Если НЕ ПустаяСтрока(Ответ) Тогда
		Возврат Ответ;	
	КонецЕсли;
	
	Если ВидОплаты=Перечисления.ВидыОплаты.НАЛ Тогда
		ПолученоНал	= СуммаОплаты;
		ПолученоБН  = 0;		
	Иначе
		ПолученоНал	= 0;
		ПолученоБН  = СуммаОплаты;		
	КонецЕсли;	
	
	ПолученоСер1	= 0;
	ПолученоСер2	= 0;
	Для Каждого СтрокаСерт Из ПодарочныеСертификаты Цикл
		Если СтрокаСерт.Сертификат.Пустая() Тогда
			ПолученоСер1		= ПолученоСер1+СтрокаСерт.СуммаОплатыСертификатами;		
		Иначе
			ПолученоСер2		= ПолученоСер2+СтрокаСерт.СуммаОплатыСертификатами;					
		КонецЕсли;		
	КонецЦикла;
	
	//кухарь баллы
	если КодОперации=Перечисления.КодыОперацийОстатки.Реализация тогда
		отбор=новый Структура;
		отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
		отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
		отбор.Вставить("Отменена",ложь);
		ТрОплаты=ТранзакцииБН.найтистроки(отбор);
		если ТрОплаты.Количество()>0 тогда
			ОплатилиБалами = ТрОплаты.получить(0).СуммаТранзакции; 
		иначе
			ОплатилиБалами=0;
		КонецЕсли;
	иначе
