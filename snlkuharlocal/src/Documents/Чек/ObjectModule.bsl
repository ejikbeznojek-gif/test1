Функция ПровестиИРаспечататьЧек(Ответ, Отказ,ВремяНачалаПечатиЧека = Неопределено) Экспорт
	
	Перем ФискальныйРегистратор;
	Перем Параметры;
	Перем Ошибки;
	
	Ошибки = "";
	Отказ  = Ложь;
	ФР	   = Неопределено;
	//крохин начало
	//поправим очередность проверок
	//Если (СуммаОплаты+СуммаОплатыСертификатами)<Товары.Итог("Всего") Тогда
	//	Ошибки=" - Сумма оплаты меньше суммы чека !";	
	//КонецЕсли; 
	
	//// Попытка провести документ
	//Попытка
	//	Записать(РежимЗаписиДокумента.Проведение);
	//Исключение
	//	Ошибки = " - Не удалось провести документ.";
	//	ЗаписатьВЛог("Ошибки чеков",Ошибки+" "+ОписаниеОшибки(),"Ошибка");		
	//КонецПопытки;
	
	//кухарь баллы 03.07.13 начало
	//Если (СуммаОплаты+СуммаОплатыСертификатами)<Товары.Итог("Всего") Тогдажж			
	если КодОперации=Перечисления.КодыОперацийОстатки.Реализация тогда
		отбор=новый Структура;
		отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
		отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
		отбор.Вставить("Отменена",ложь);
		ТрОплаты=ТранзакцииБН.найтистроки(отбор);
		если ТрОплаты.Количество()>0 тогда
			ОплатилиБалами = ТрОплаты.получить(0).СуммаТранзакции; 
		иначе
			ОплатилиБалами=0;
		КонецЕсли;
	иначе
		отбор=новый Структура;
		отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
		отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
		отбор.Вставить("Отменена",ложь);
		ТрОплаты=ДокОснование.ТранзакцииБН.найтистроки(отбор);
		если ТрОплаты.Количество()>0 тогда
			ОплатилиБалами = Окр(СуммаДокумента*(ТрОплаты.получить(0).СуммаТранзакции)/ДокОснование.СуммаДокумента,2); 
		иначе
			ОплатилиБалами=0;
		КонецЕсли;
	КонецЕсли;
	
	Если (СуммаОплаты+СуммаОплатыСертификатами+ОплатилиБалами)<Товары.Итог("Всего") Тогда
		Ошибки=" - Сумма оплаты меньше суммы чека !";	
	КонецЕсли; 
	//кухарь баллы 03.07.13 конец
	// Попытка провести документ
	Если ПустаяСтрока(Ошибки) Тогда
		Попытка
			Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Ошибки = " - Не удалось провести документ.";
			ЗаписатьВЛог("Ошибки чеков",Ошибки+" "+ОписаниеОшибки(),"Ошибка");		
		КонецПопытки;
	КонецЕсли;
	//крохин конец
	
	// Если Документ проведён и не пробит чек
	Если ПустаяСтрока(Ошибки) И (НЕ ЧекПробитНаККМ) Тогда
		
		// Если торговое оборудование подключено
		Если глТорговоеОборудование <> Неопределено Тогда
			ФР = глТорговоеОборудование.млФР.Найти(КассаККМ,"КассаККМ");
			// Есть на чём пробивать 
			Если ФР <> Неопределено Тогда
				
				// Предпринимаем попытку печати чека на ФР
				Параметры = Новый Структура();
				Параметры.Вставить("НомерСекции", НомерСекции);
				Параметры.Вставить("КассаККМ",    КассаККМ);
				
				//крохин начало 20.02.2013
				//время открытия чека
				Если ТекущаяДата() - ВремяНачалаПечатиЧека > 0 Тогда
					ЗаписатьВЛог("ПробитиеЧека","Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера()+" Чек: "+ Номер+" Время: "+(ТекущаяДата() - ВремяНачалаПечатиЧека)+ " сек.","Информация",,,ТекущаяДата() - ВремяНачалаПечатиЧека);
				КонецЕсли;
				//крохин конец 20.02.2013
				
				Ответ     = ПечатьЧекаНаФР(ФР.Модель,ФР.НомерЛУ,КассаККМ);
				
				Если ПустаяСтрока(Ответ) Тогда
					
					// Чек напечатан, пытаемся записать документ с обновлёнными
					// значениями реквизитов
					Попытка
						Записать(РежимЗаписиДокумента.Запись);
						//крохин начало 18.05.2011
						//гасим сертификаты
						Ошибки=ПогаситьВернутьСертификаты();
						//крохин конец 18.05.2011
					Исключение
						Если Не ПустаяСтрока(Ошибки) Тогда
							Ошибки = Ошибки + "
							|";
						КонецЕсли;
						Ошибки = Ошибки + " - Не удалось записать чек с признаком ""ЧекПробитНаККМ"" = Истина.";
						ЗаписатьВЛог("Ошибки чеков",Ошибки+" "+ОписаниеОшибки(),"Ошибка");		
						Отказ  = Истина;
					КонецПопытки;
					
				Иначе
					
					// Чек напечатать не удалось
					Если Не ПустаяСтрока(Ошибки) Тогда
						Ошибки = Ошибки + "
						|";
					КонецЕсли;
					Ошибки = Ошибки + " - Не удалось напечатать чек: " + Ответ;
					//кухарь сообщение об отмене БН платежа 15.05.13 начало
					//если ЭтотОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН тогда
					//	Ошибки=Ошибки+ " возможно стоит сделать отмену платежа";
					//КонецЕсли;
					//кухарь сообщение об отмене БН платежа 15.05.13  конец 
					ЗаписатьВЛог("Ошибки чеков",Ошибки+ " .Номер Чека: "+Номер,"Ошибка");
					
					// Попытка распровести документ
					Попытка
						Записать(РежимЗаписиДокумента.ОтменаПроведения);
					Исключение
						Ошибки = Ошибки + "
						| - Не удалось отменить проведение документа.";
						ЗаписатьВЛог("Ошибки чеков",Ошибки+" "+ОписаниеОшибки(),"Ошибка");		
						Отказ = Истина;
					КонецПопытки;
					
				КонецЕсли; // ПустаяСтрока(Ответ)
			Иначе
				//эта ерунда из-за Лиги в которой нету кассы - удалить в обязательном порядке
				ЧекПробитНаККМ=Истина;
				Записать(РежимЗаписиДокумента.Запись);				
			КонецЕсли; // ФискальныйРегистратор <> Неопределено
		КонецЕсли; // глТорговоеОборудование <> Неопределено
		
	КонецЕсли; // ПустаяСтрока(Ошибки) И (Не ЧекПробитНаККМ)	
	
	Если ФР=Неопределено И КассаККМ.ПодключенФР И ПустаяСтрока(Ошибки) И НЕ ЧекПробитНаККМ Тогда
		Ошибки="К кассе: """+КассаККМ+""" не подключен фискальный регистратор !";		
	КонецЕсли; 
	
	Если ПустаяСтрока(Ошибки) Тогда
		// Успешное завершение операции
		Ответ = "";
		Отказ = Ложь;
		Возврат Истина;
	Иначе
		// Неудачное завершение операции
		Ответ = ?(Отказ,
		"Были обнаружены ошибки, которые могут привести к расхождениям в данных
		|информационной базы и ленты контрольно-кассового аппарата:",
		"Были обнаружены следующие ошибки:") + "
		|" + Ошибки;
		Возврат Ложь;
	КонецЕсли; // ПустаяСтрока(Ошибки)
	
КонецФункции

