	СуммаЧека = СуммаДокумента;
	
	
	// тут пока просто собираем данные в разные ТЗ, по разным типам сертификатов.
	СуммаПодарочСертификСоСкидкой30 = 0;
	СписокПодСертСоСк = Новый ТаблицаЗначений;
	СписокПодСертСоСк.Колонки.Добавить("НомерСтроки");
	СписокПодСертСоСк.Колонки.Добавить("Сертификат");
	СписокПодСертСоСк.Колонки.Добавить("ПроцентОплаты");
	СписокПодСертСоСк.Колонки.Добавить("Номинал");
	СписокПодСертСоСк.Колонки.Добавить("СуммаОплаты");
	
	Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
		
		Если НЕ СтрокаТЧ.Сертификат.ОплатаНеБолее30Процентов Тогда
			продолжить;
		КонецЕсли;  
		
		НовСтр = СписокПодСертСоСк.Добавить() ;
		НовСтр.номерСтроки = Строкатч.НомерСтроки;
		НовСтр.сертификат = СтрокаТЧ.Сертификат;
		НовСтр.ПроцентОплаты = СтрокаТЧ.Сертификат.МаксимальныйПроцентОтоваривания;
		НовСтр.Номинал = СтрокаТЧ.Номинал;
		НовСтр.СуммаОплаты = 0;
		
	КонецЦикла;		
	СписокПодСертСоСк.Сортировать("Номинал Убыв");
	СуммаПодарочСертификСоСкидкой30 = СписокПодСертСоСк.Итог("Номинал");
	СуммаВозможнойОплатыСертСоСк = 0;
	
	Если СуммаПодарочСертификСоСкидкой30>0 Тогда 
		СуммаВозможнойОплатыСертСоСк = Окр(СуммаДокумента/100*СписокПодСертСоСк[0].ПроцентОплаты,0); // до целых округлим
	КонецЕсли;	
      	
	
	// 2 - учитываем сертификаты, не подарки
	СуммаПодарочНеПод = 0;
	СписокПодСертНеПод = Новый ТаблицаЗначений;
	СписокПодСертНеПод.Колонки.Добавить("НомерСтроки");
	СписокПодСертНеПод.Колонки.Добавить("Сертификат");
	СписокПодСертНеПод.Колонки.Добавить("ПроцентОплаты");
	СписокПодСертНеПод.Колонки.Добавить("Номинал");
	СписокПодСертНеПод.Колонки.Добавить("СуммаОплаты");
	
