Функция ПроверитьСертификаты()
	Ответ = "";
	//использованные
	Для Каждого СтрокаТЧ Из Товары Цикл
		
		Если НЕ СтрокаТЧ.Сертификат.Пустая() Тогда
			СертификатОбъект=СтрокаТЧ.Сертификат.ПолучитьОбъект();
			
			Если СертификатОбъект.Использован Тогда
				Если СертификатОбъект.НомерЧекаПогашения<>Номер Тогда
					Ответ=Ответ+?(ПустаяСтрока(Ответ),"",Символы.ПС)+"Сертификат: "+СертификатОбъект+" уже использован !";					
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаТЧ Из ПодарочныеСертификаты Цикл
		
		Если НЕ СтрокаТЧ.Сертификат.Пустая() Тогда
			СертификатОбъект=СтрокаТЧ.Сертификат.ПолучитьОбъект();
			
			Если СертификатОбъект.Использован Тогда
				Если СертификатОбъект.НомерЧекаПогашения<>Номер Тогда
					Ответ=Ответ+?(ПустаяСтрока(Ответ),"",Символы.ПС)+"Сертификат: "+СертификатОбъект+" уже использован !";					
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ответ;
