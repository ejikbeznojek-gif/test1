Функция ПолучитьТекстЧека()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТекстДляЧеков.Текст
	|ИЗ
	|	Справочник.ТекстДляЧеков КАК ТекстДляЧеков
	|ГДЕ
	|	ТекстДляЧеков.Активность";
	
	Выборка = запрос.Выполнить().Выбрать();
	
	МаксЗначение = Выборка.Количество();
	Если МаксЗначение = 0 Тогда
		//Возврат "";	
	КонецЕсли;
	
	
	СлучайноеЧисло = ТекущаяДата();
	СлучайноеЧисло = Секунда(СлучайноеЧисло)+Минута(СлучайноеЧисло)*60+Час(СлучайноеЧисло)*60*60;
	
	НомерСтроки =  1 + СлучайноеЧисло - Цел(СлучайноеЧисло/МаксЗначение)*МаксЗначение;
	
	ТекСтрока = 1;
	Пока Выборка.Следующий() Цикл
		Если ТекСтрока = НомерСтроки Тогда
			Возврат Выборка.Текст;
		КонецЕсли;
		ТекСтрока = ТекСтрока + 1;	
	КонецЦикла;
	
	Возврат "Пусть всегда будет солнце!";
	
	
	//Возврат "Пусть всегда будет солнце!";	
КонецФункции

