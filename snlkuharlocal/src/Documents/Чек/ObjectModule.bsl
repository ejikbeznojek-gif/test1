Функция ПолучитьПараметрыКупона(АкцияПечатьКупонаНаСкидку)
      СкидкаПоАкции = 0;
	  ШККупона = "";
Для каждого Текстрока из АкцияПечатьКупонаНаСкидку.КупоныНаСкидку цикл
	Если Текстрока.подразделение <> Подразделение Тогда 
		Продолжить;
	КонецЕсли;
	
		Если СуммаДокумента>=Текстрока.Сумма  тогда
			СкидкаПоАкции= ТекСтрока.скидка;
			ШККупона = Текстрока.ШК;
		конецЕсли;
		
	КонецЦикла;
	Если СкидкаПоАкции > 0 Тогда
		//"^" используется вместо переноса строки
		ТекстКупона = "ВАША ПЕРСОНАЛЬНАЯ СКИДКА^"+СкидкаПоАкции+"%^";
		Если ЗначениеЗаполнено(АкцияПечатьКупонаНаСкидку.ДатаНачалаПродажКупон) Тогда
		ТекстКупона = ТекстКупона + "Срок действия с " +формат(АкцияПечатьКупонаНаСкидку.ДатаНачалаПродажКупон,"ДФ=dd.MM.yyyy") +" по " + Формат(АкцияПечатьКупонаНаСкидку.ДатаОкончанияПродажКупон,"ДФ=dd.MM.yyyy")+"^";	
		КонецЕсли;
        ТекстКупона = ТекстКупона + "Скидка не суммируется с иными скидками и предложениями^";
		ТекстКупона = ТекстКупона + "Воспользоваться предложением вы можете в ТЦ ""Стильпарк"", "+Склад.Адрес;
     ПараметрыКупона = Новый Структура;          
	 
	 ПараметрыКупона.Вставить("ТекстКупона",ТекстКупона);
	 ПараметрыКупона.Вставить("ШККупона",ШККупона);
	 Возврат ПараметрыКупона;
 Иначе
	 Возврат Неопределено;
	 КонецЕсли;
	 
КонецФункции

