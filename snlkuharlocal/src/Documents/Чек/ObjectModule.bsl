Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если НЕ ПустаяСтрока(ДК)   Тогда
		Если Дк.ЧленКлуба ИЛИ Дк.ЧленКлубаГП Тогда
			Отказ = Ложь;
			Если Отказ Тогда
				Возврат;
			КонецЕсли;
		Конецесли;
	КонецЕсли;
	Если Акция = Справочники.Акции.НайтиПоКоду("SNL-00042") Тогда;
		ДКобъект = дк.ПолучитьОбъект();
	
		Если Дата>='20140101' Тогда
			// чтобы записать только 1 раз
			Запрос=Новый запрос;
			Запрос.Текст="ВЫБРАТЬ
			             |	ДисконтныеКартыИспользованныеДР.Год КАК Год
			             |ИЗ
			             |	Справочник.ДисконтныеКарты.ИспользованныеДР КАК ДисконтныеКартыИспользованныеДР
			             |ГДЕ
			             |	ДисконтныеКартыИспользованныеДР.Ссылка = &ТекДК
			             |	И НачалоПериода(ДисконтныеКартыИспользованныеДР.Год,Год) = &ТекГОд";
			Запрос.УстановитьПараметр("ТекДК",ДК);
			Запрос.УстановитьПараметр("ТекГод",НачалоГода(Дата));
			Рез=Запрос.Выполнить().Выбрать();
			Если Рез.Следующий() Тогда
				ДРПокупателяИспользован = истина;
			Иначе
				СтрДР=ДКобъект.ИспользованныеДР.Добавить();
				СтрДр.Год = Дата;
			КонецЕсли;
       Иначе
								
		 	ДКобъект.ИспользованДР2010 = Истина;
		КонецЕсли;
		// Нечаева 16,12,13 ---
		
		ДКобъект.Записать();
	Конецесли;
	//крохин начало 18.05.2011
	//по некоторым акциям меняем скидку
	Если НЕ ДК.Пустая() Тогда
		ДКобъект = дк.ПолучитьОбъект();
			
		Если Акция.СкидкаДК > ДКОбъект.Скидка И Акция.СкидкаДК > ДКОбъект.СкидкаСтарая Тогда
			ДКОбъект.СкидкаСтарая = Акция.СкидкаДК;
			ДКобъект.Записать();
			Сообщить("Изменена скидка ДК с " + МАКС(ДКОбъект.Скидка,ДКобъект.СкидкаСтарая) + "% на "  +Акция.СкидкаДК+ "%");
		КонецЕсли;
		//по некоторым акциям меняем скидку от суммы чека
		Если Акция.ИзмененияСкидкиДК.Количество() > 0 Тогда
			ИзменениеСкидки = 0;
			Для Каждого СтрокаИзмененийСкидкиДК ИЗ Акция.ИзмененияСкидкиДК Цикл
				Если Товары.Итог("Всего") >= СтрокаИзмененийСкидкиДК.СуммаЧека Тогда
					ИзменениеСкидки = Макс(ИзменениеСкидки,СтрокаИзмененийСкидкиДК.СкидкаДК);	
				КонецЕсли;
			КонецЦикла;
			Если ИзменениеСкидки > ДКОбъект.Скидка И ИзменениеСкидки > ДКОбъект.СкидкаСтарая Тогда
				ДКОбъект.СкидкаСтарая = ИзменениеСкидки;
				Сообщить("Изменена скидка ДК с " + МАКС(ДКОбъект.Скидка,ДКобъект.СкидкаСтарая) + "% на "  +ИзменениеСкидки+ "%");
				ДКобъект.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ДвиженияПоРегистрам=Неопределено;
	
	РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам);	
	Результат=РезультатПроведения["Результат"];
	
	Если Результат<0 Тогда		
		Отказ=Ложь;		
	КонецЕсли; 
	
	Если НЕ Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам);
		Ошибки=ПроверитьСертификаты();
		Если НЕ ПустаяСтрока(Ошибки) Тогда
			СообщитьОбОшибке(Ошибки);
			Отказ=Истина;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

