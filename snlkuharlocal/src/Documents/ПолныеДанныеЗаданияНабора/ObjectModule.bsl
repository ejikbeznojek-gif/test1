
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)  экспорт
	если ТипЗнч(ДанныеЗаполнения)<>Тип("ДокументСсылка.ЗаданиеНабора") тогда
		СообщитьИзМодуля("Документ полные данные ЗНБ вводится только на основании ЗНБ");
		Возврат;
	КонецЕсли;
	
	
	
	ДокОснование=ДанныеЗаполнения;
	
	
	СтруктураРеквизитовЗНБ=ПолучитьРеквизитыШапки(ДокОснование,"Накладная,Получатель,Склад,Получатель.Код","Документ");
	Накладная=СтруктураРеквизитовЗНБ.Накладная;
	Контрагент=СтруктураРеквизитовЗНБ.Получатель;
	Склад=СтруктураРеквизитовЗНБ.Склад;
	// Кухарь А.Ю.  22.03.2024 начало
	//
	КодКонтрагента=СтруктураРеквизитовЗНБ.Получатель_Код;
	
	// Кухарь А.Ю.  06.08.2024 начало
	// если КодКонтрагента="SSR-9059" тогда //WB
	если КодКонтрагента="SSR-9059" или КодКонтрагента="SST-1208"  тогда //WB
		// Кухарь А.Ю.  06.08.2024 конец
		
		ПроверятьСуффикс=Истина;
	иначе
		ПроверятьСуффикс=Ложь;
	КонецЕсли;
	// Кухарь А.Ю.  22.03.2024 конец
	
	
	если ТипЗнч(Накладная) <> Тип("ДокументСсылка.РасходнаяНакладная") тогда		
		СообщитьИзМодуля("Документ полные данные ЗНБ вводится только к РНК.");
		Возврат;
	КонецЕсли;
	
	РеквизитыНакладной=ПолучитьРеквизитыШапки(Накладная,"ОтгрузкаКомплектов","Документ");
	ОтгрузкаКомплектов=РеквизитыНакладной.ОтгрузкаКомплектов;
	
	//если не ОтгрузкаКомплектов  тогда
	//	СообщитьИзМодуля("Накладная вводится только накладные с комплектацией.");
	//	Возврат;		
	//КонецЕсли;
	
	
	ЗаказКлиентаFBS=ОбщегоНазначения_ПИ.ПолучитьЗаказКлиентаFBSПоНакладной(Накладная);
	если ЗаказКлиентаFBS=Неопределено тогда
		СообщитьИзМодуля("Отсутствует документ заказ клиента FBS. Документ полные данные ЗНБ - не заполнен.");
		Возврат;
	КонецЕсли;
	
	
	
	запрос=новый запрос; //Сформируем массив номенклатуры для отбора по ТЧ КМП РНК
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	             |ИЗ
	             |	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	             |ГДЕ
	             |	ЗаданиеНабораТовары.Ссылка = &Ссылка
	             |	И ЗаданиеНабораТовары.Количество > 0
	             |	И ЗаданиеНабораТовары.Номенклатура.Родитель.ВидНоменклатуры = &Товар";
	запрос.УстановитьПараметр("Ссылка",ДокОснование);
	// Кухарь А.Ю.  27.03.2023 начало
	запрос.УстановитьПараметр("Товар",Перечисления.ВидыНоменклаутры.Товар);
	// Кухарь А.Ю.  27.03.2023 конец
	
	МассивНоменклатуры=запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
	
	//Сформируем массив Продукции для отбора по заказу клиента FBS
	
	запрос.Текст="ВЫБРАТЬ различные
	|	ТЧ.Продукция КАК Продукция
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК ТЧ
	|ГДЕ
	|	ТЧ.КоличествоПродукции > 0
	|	И ТЧ.Ссылка = &Ссылка
	|	И ТЧ.Номенклатура В(&Номенклатура)";
	если не ОтгрузкаКомплектов тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.РасходнаяНакладная.Комплектующие","Документ.РасходнаяНакладная.Товары");
		запрос.Текст=СтрЗаменить(запрос.Текст,"ТЧ.Продукция КАК Продукция","ТЧ.Номенклатура КАК Продукция");
		запрос.Текст=СтрЗаменить(запрос.Текст,"ТЧ.КоличествоПродукции > 0","ТЧ.Количество > 0");
	КонецЕсли;
	запрос.УстановитьПараметр("Ссылка",Накладная);
	запрос.УстановитьПараметр("Номенклатура",МассивНоменклатуры);
	МассивПродукции= запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Продукция");
	
	
	запрос.Текст="ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКодFBS,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказаFBS,
	|	ЗаказКлиентаFBSТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка = &Ссылка
	|	И ЗаказКлиентаFBSТовары.Номенклатура В(&Номенклатура)
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен
	|	И НЕ ЗаказКлиентаFBSТовары.ВычеркОфис
	|	И НЕ ЗаказКлиентаFBSТовары.ВычеркСклад
	|	И ЗаказКлиентаFBSТовары.Количество > 0";
	запрос.УстановитьПараметр("Ссылка",ЗаказКлиентаFBS);
	запрос.УстановитьПараметр("Номенклатура",МассивПродукции);
	
	Товары.Загрузить(запрос.Выполнить().Выгрузить());
	
	// Кухарь А.Ю.  22.03.2024 начало
	//
	если ПроверятьСуффикс тогда
		МассСтрокСОшибкой=Товары.НайтиСтроки(новый Структура("СуффиксЗаказа",""));
		если МассСтрокСОшибкой.Количество()>0 тогда
			СообщитьИзМодуля("Не заполнен суффикс заказа по некоторым строкам заказов. Попробуйте чуть позже");
			Возврат;		
		КонецЕсли;
	КонецЕсли;
	// Кухарь А.Ю.  22.03.2024 конец
	
	// Кельманов А.В. - HELP-6307 - 2025.08.07 {
	//Запрос.Текст = "ВЫБРАТЬ
	//|	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Номенклатура,
	//|	ПолныеДанныеЗаданияНабораТовары.Количество КАК Количество,
	//|	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS КАК НомерЗаказаFBS,
	//|	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS КАК ШтрихКодFBS,
	//|	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	//|	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа КАК СуффиксЗаказа
	//|ПОМЕСТИТЬ ВремТЗ
	//|ИЗ
	//|	&ТЧТовары КАК ПолныеДанныеЗаданияНабораТовары
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Продукция,
	//|	ЕСТЬNULL(НоменклатураКоплектующие.Номенклатура, ПолныеДанныеЗаданияНабораТовары.Номенклатура) КАК Номенклатура,
	//|	СУММА(ВЫБОР
	//|			КОГДА НоменклатураКоплектующие.Количество ЕСТЬ NULL
	//|				ТОГДА ПолныеДанныеЗаданияНабораТовары.Количество
	//|			ИНАЧЕ НоменклатураКоплектующие.Количество * ПолныеДанныеЗаданияНабораТовары.Количество
	//|		КОНЕЦ) КАК Количество,
	//|	ПолныеДанныеЗаданияНабораТовары.Количество КАК КоличествоПродукции,
	//|	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS КАК НомерЗаказаFBS,
	//|	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS КАК ШтрихКодFBS,
	//|	ВЫБОР
	//|		КОГДА НоменклатураКоплектующие.Номенклатура ЕСТЬ NULL
	//|				ИЛИ НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = &Товар
	//|			ТОГДА ИСТИНА
	//|		ИНАЧЕ ЛОЖЬ
	//|	КОНЕЦ КАК ЭтоТовар,
	//|	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	//|	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа КАК СуффиксЗаказа
	//|ИЗ
	//|	ВремТЗ КАК ПолныеДанныеЗаданияНабораТовары
	//|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	//|		ПО ПолныеДанныеЗаданияНабораТовары.Номенклатура = НоменклатураКоплектующие.Ссылка
	//// Кельманов А.В. - HELP-2976 - 2025.03.04 {
	//|			И (ПолныеДанныеЗаданияНабораТовары.Номенклатура.ВидКомплекта <> ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	//// Кельманов А.В. - HELP-2976 - 2025.03.04 }
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	ПолныеДанныеЗаданияНабораТовары.Номенклатура,
	//|	ЕСТЬNULL(НоменклатураКоплектующие.Номенклатура, ПолныеДанныеЗаданияНабораТовары.Номенклатура),
	//|	ПолныеДанныеЗаданияНабораТовары.Количество,
	//|	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS,
	//|	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS,
	//|	ВЫБОР
	//|		КОГДА НоменклатураКоплектующие.Номенклатура ЕСТЬ NULL
	//|				ИЛИ НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = &Товар
	//|			ТОГДА ИСТИНА
	//|		ИНАЧЕ ЛОЖЬ
	//|	КОНЕЦ,
	//|	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа,
	//|	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа";
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Номенклатура,
	               |	ПолныеДанныеЗаданияНабораТовары.Количество КАК Количество,
	               |	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS КАК НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа КАК СуффиксЗаказа
	               |ПОМЕСТИТЬ ВремТЗ
	               |ИЗ
	               |	&ТЧТовары КАК ПолныеДанныеЗаданияНабораТовары
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
	               |	СУММА(РасходнаяНакладнаяКомплектующие.КоличествоПродукции) КАК КоличествоПродукции
	               |ПОМЕСТИТЬ ВТ_КоличествоПродукции
	               |ИЗ
	               |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	               |ГДЕ
	               |	РасходнаяНакладнаяКомплектующие.Ссылка = &Накладная
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	РасходнаяНакладнаяКомплектующие.Продукция
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
	               |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ВТ_КоличествоПродукции.КоличествоПродукции, 0) = 0
	               |			ТОГДА 0
	               |		ИНАЧЕ РасходнаяНакладнаяКомплектующие.Количество / ВТ_КоличествоПродукции.КоличествоПродукции
	               |	КОНЕЦ КАК Количество
	               |ПОМЕСТИТЬ ВТ_Комплектующие
	               |ИЗ
	               |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КоличествоПродукции КАК ВТ_КоличествоПродукции
	               |		ПО РасходнаяНакладнаяКомплектующие.Продукция = ВТ_КоличествоПродукции.Продукция
	               |ГДЕ
	               |	РасходнаяНакладнаяКомплектующие.Ссылка = &Накладная
	               |	И ВЫБОР
	               |			КОГДА ЕСТЬNULL(ВТ_КоличествоПродукции.КоличествоПродукции, 0) = 0
	               |				ТОГДА 0
	               |			ИНАЧЕ РасходнаяНакладнаяКомплектующие.Количество / ВТ_КоличествоПродукции.КоличествоПродукции
	               |		КОНЕЦ > 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Продукция,
	               |	ЕСТЬNULL(ВТ_Комплектующие.Номенклатура, ПолныеДанныеЗаданияНабораТовары.Номенклатура) КАК Номенклатура,
	               |	СУММА(ВЫБОР
	               |			КОГДА ВТ_Комплектующие.Количество ЕСТЬ NULL
	               |				ТОГДА ПолныеДанныеЗаданияНабораТовары.Количество
	               |			ИНАЧЕ ВТ_Комплектующие.Количество * ПолныеДанныеЗаданияНабораТовары.Количество
	               |		КОНЕЦ) КАК Количество,
	               |	ПолныеДанныеЗаданияНабораТовары.Количество КАК КоличествоПродукции,
	               |	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS КАК НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ВЫБОР
	               |		КОГДА ВТ_Комплектующие.Номенклатура ЕСТЬ NULL
	               |				ИЛИ ВТ_Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК ЭтоТовар,
	               |	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа КАК СуффиксЗаказа
	               |ИЗ
	               |	ВремТЗ КАК ПолныеДанныеЗаданияНабораТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Комплектующие КАК ВТ_Комплектующие
	               |		ПО ПолныеДанныеЗаданияНабораТовары.Номенклатура = ВТ_Комплектующие.Продукция
	               |			И (ПолныеДанныеЗаданияНабораТовары.Номенклатура.ВидКомплекта <> ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПолныеДанныеЗаданияНабораТовары.Номенклатура,
	               |	ЕСТЬNULL(ВТ_Комплектующие.Номенклатура, ПолныеДанныеЗаданияНабораТовары.Номенклатура),
	               |	ПолныеДанныеЗаданияНабораТовары.Количество,
	               |	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS,
	               |	ВЫБОР
	               |		КОГДА ВТ_Комплектующие.Номенклатура ЕСТЬ NULL
	               |				ИЛИ ВТ_Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ,
	               |	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа";
					
	Запрос.УстановитьПараметр("Накладная", Накладная);
	// Кельманов А.В. - HELP-6307 - 2025.08.07 }
					
	Запрос.УстановитьПараметр("Товар", Перечисления.ВидыНоменклаутры.Товар);
	Запрос.УстановитьПараметр("ТЧТовары", Товары);
	
	Комплектующие.Загрузить(Запрос.Выполнить().Выгрузить());
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокОснование, "Накладная,Склад");
	Контрагент = Контрагент;
	
	ОбновитьШКИзМатрицы();
	
	Дата = ТекущаяДата();
	ЭтотОбъект.Проведен = Истина;
	ЭтотОбъект.Записать();
	
КонецПроцедуры


Процедура ПеречитатьДанныеЗаказаFBS () экспорт
	запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКодFBS,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказаFBS,
	|	ЗаказКлиентаFBSТовары.Отменен КАК Отменен,
	|	ЗаказКлиентаFBSТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка = &Ссылка
	|	И ЗаказКлиентаFBSТовары.Номенклатура В(&Номенклатура)";
	запрос.УстановитьПараметр("Номенклатура",товары.ВыгрузитьКолонку("Номенклатура"));
	запрос.УстановитьПараметр("Ссылка",ЗаказКлиентаFBS);
	ТЗДанныеFBS = запрос.Выполнить().Выгрузить();
	Для каждого СтрТЧ из Товары цикл
		если СтрТЧ.НомерЗаказаFBS="" тогда
			СообщитьИзМодуля("В строке "+СтрТЧ.НомерСтроки+" пустой номер заказа");
			Продолжить;
		КонецЕсли;
		
		МассДанныхFBS=ТЗДанныеFBS.НайтиСтроки(новый Структура("НомерЗаказаFBS,Номенклатура",СтрТЧ.НомерЗаказаFBS,СтрТЧ.Номенклатура));
		если МассДанныхFBS.Количество()<>1 тогда
			СообщитьИзМодуля("Сбой расчёта по заказу №"+СтрТЧ.НомерЗаказаFBS+" номенклатуре "+СтрТЧ.Номенклатура);
			Продолжить;
		КонецЕсли;
		
		
		СтрДанныхFBS=МассДанныхFBS.Получить(0);
		ЗаполнитьЗначенияСвойств(СтрТЧ,СтрДанныхFBS,"ПрефиксЗаказа,СуффиксЗаказа,ШтрихКодFBS");
		
		если СтрДанныхFBS.Отменен<> Истина тогда
			СтрДанныхFBS.Количество=0;
		КонецЕсли;
		
		если СтрДанныхFBS.Количество<>СтрТЧ.Количество тогда
			СтрТЧ.Количество=СтрДанныхFBS.Количество;
		КонецЕсли;
		
		МассСтрокКМП=Комплектующие.НайтиСтроки(новый Структура("Продукция,НомерЗаказаFBS",СтрТЧ.Номенклатура,СтрТЧ.НомерЗаказаFBS));
		Кратность=ПолучитьРеквизитШапки(СтрТЧ.Номенклатура,"Родитель.ШтукВКомплекте","Справочник");
		если Кратность=0 тогда Кратность=1 КонецЕсли;
		
		для каждого СтрКМП из Комплектующие цикл		
			СтрКМП.КоличествоПродукции=СтрТЧ.Количество;
			СтрКМП.Количество=СтрТЧ.Количество*Кратность;     
		КонецЦикла;					
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьШКИзМатрицы () экспорт
	
	// Кельманов А.В. - HELP-3209 - 2025.03.06 {
	//ТаблицаДанныхМатрицы = ЗаполнитьТаблицуДанныхМатрицы();
	СтруктураДанных = Новый Структура("Номенклатура, ПунктДоставки, Договор, Дата, Контрагент, ПостояннаяАкция");
	
	ЗаполнитьЗначенияСвойств(СтруктураДанных, Накладная);
		
	МассивНоменклатуры = Товары.ВыгрузитьКолонку("Номенклатура");
	
	СтруктураДанных.Номенклатура = МассивНоменклатуры;
	
	ТаблицаДанныхМатрицы = ПолучитьТаблицуМатрицСрезПоследних(СтруктураДанных);
	// Кельманов А.В. - HELP-3209 - 2025.03.06 }
	
	Для Каждого СтрТЧ Из Товары Цикл
		
		СтрМатрицы = ТаблицаДанныхМатрицы.Найти(СтрТЧ.Номенклатура, "Номенклатура");
		
		Если СтрМатрицы <> Неопределено Тогда
			
			// Кельманов А.В. - HELP-3209 - 2025.03.06 {
			//СтрТЧ.ШтрихКод = СтрМатрицы.ШтрихКод;
			СтрТЧ.ШтрихКод = СтрМатрицы.ШККонтрагента;
			// Кельманов А.В. - HELP-3209 - 2025.03.06 }
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры



Функция ЗаполнитьТаблицуДанныхМатрицы () экспорт 
	
	РеквизитыШапки=ПолучитьРеквизитыШапки(Накладная,"ПунктДоставки,Договор,ПостояннаяАкция,Дата","Документ");
	Запрос			= Новый Запрос;				
	Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	
	|	МатрицаТовары.Номенклатура.Цвет.Наименование КАК Цвет,
	|	МатрицаТовары.Номенклатура.Родитель КАК Модель,
	|	МатрицаТовары.Номенклатура.КодПроизводителя КАК КодПроизводителя,					  
	|	""Размер:"" + МатрицаТовары.Номенклатура.Размер.Наименование КАК Размер,
	|	ВЫРАЗИТЬ(МатрицаТовары.Номенклатура.Цвет.РусскоеНаименование КАК СТРОКА(30)) КАК РусскоеНаименованиеЦвета,
	|	МатрицаТовары.Номенклатура.Наименование КАК НаименованиеНоменклатуры,	
	|	МатрицаТовары.ШККонтрагента КАК ШтрихКод
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Номенклатура В(&Номенклатура)
	|	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция";
	
	Запрос.УстановитьПараметр("Дата2",			РеквизитыШапки.Дата);
	Запрос.УстановитьПараметр("Дата1",			РеквизитыШапки.Дата);
	Запрос.УстановитьПараметр("Контрагент",		Контрагент);		
	Запрос.УстановитьПараметр("ПунктДоставки",	РеквизитыШапки.ПунктДоставки);			
	Запрос.УстановитьПараметр("Договор",		РеквизитыШапки.Договор);		
	запрос.УстановитьПараметр("Номенклатура",	товары.ВыгрузитьКолонку("Номенклатура"));
	запрос.УстановитьПараметр("ПостояннаяАкция",РеквизитыШапки.ПостояннаяАкция);
	
	ТаблицаДанныхМатрицы = Запрос.Выполнить().Выгрузить();
	
	возврат ТаблицаДанныхМатрицы;
	
КонецФункции

