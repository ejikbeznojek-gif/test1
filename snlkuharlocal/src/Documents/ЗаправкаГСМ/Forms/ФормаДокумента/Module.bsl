&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ТекОстаток1=ПоказанияНачальныхОстатков(Объект.Автомобиль, НачалоДня(Объект.Дата));
	ТекОстаток2=ПоказанияНачальныхОстатков(Объект.Автомобиль, КонецДня(Объект.Дата));

	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	              |	ПутевойЛист.Ссылка КАК Ссылка,
	              |	ПутевойЛист.Дата КАК Дата
	              |ИЗ
	              |	Документ.ПутевойЛист КАК ПутевойЛист
	              |ГДЕ
	              |	ПутевойЛист.Дата >= &Дата
	              |	И ПутевойЛист.Автомобиль = &Автомобиль
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Дата";

	запрос.УстановитьПараметр("Дата",НачалоДня(объект.Дата));	
	запрос.УстановитьПараметр("Автомобиль",Объект.Автомобиль);
	результат=запрос.Выполнить().Выбрать();
	ПараметрыСеанса.Ошибки="";
	пока результат.Следующий() цикл
		Путевка=результат.ссылка.получитьобъект();
		если ложь тогда Путевка =Документы.ПутевойЛист.СоздатьДокумент();КонецЕсли;
		РежимЗаписи=?(Путевка.Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись);
		СтарыйОстатокТопливаВыезд= Путевка.ОстатокТопливаВыезд;
		СтарыйОстатокТопливаВозврат=Путевка.ОстатокТопливаВозврат;
		
		
		Путевка.ЗаправкаНаМаршруте=ПолучитьЗаправку(результат.ссылка);
		Путевка.ОстатокТопливаВыезд=ПоказанияНачальныхОстатков(Путевка.Автомобиль, НачалоДня(Путевка.Дата));
		Путевка.ОстатокТопливаВозврат=Путевка.ОстатокТопливаВыезд+Путевка.ЗаправкаНаМаршруте-Путевка.Расход;


		если СтарыйОстатокТопливаВозврат<>Путевка.ОстатокТопливаВозврат или СтарыйОстатокТопливаВозврат<>Путевка.ОстатокТопливаВыезд тогда
			Путевка.Записать(РежимЗаписи);
			
			ПараметрыСеанса.Ошибки=ПараметрыСеанса.Ошибки+"Перерасчитаны данные "+Путевка+" выезд с " +СтарыйОстатокТопливаВыезд+" на "+Путевка.ОстатокТопливаВыезд +". возврат с "
			+СтарыйОстатокТопливаВозврат+" на "+Путевка.ОстатокТопливаВозврат+Символы.ПС;	
		КонецЕсли;

	КонецЦикла;
	
	
	
КонецПроцедуры



