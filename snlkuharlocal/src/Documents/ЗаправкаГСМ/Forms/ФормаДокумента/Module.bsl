Функция ПолучитьЗаправку(Путевка)
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	              |	ЗаправкаГСМ.Ссылка КАК Ссылка,
	              |	ЗаправкаГСМ.Количество КАК Количество
	              |ИЗ
	              |	Документ.ЗаправкаГСМ КАК ЗаправкаГСМ
	              |ГДЕ
	              |	ЗаправкаГСМ.Проведен
	              |	И ЗаправкаГСМ.кДокументу = &Путевка";
	запрос.УстановитьПараметр("Путевка",Путевка);
	результат=запрос.Выполнить().выбрать();

	
	пока результат.Следующий() цикл
		возврат результат.Количество;
	КонецЦикла;
	
	возврат 0;
	
КонецФункции
	
	
	
Функция ЕстьИзмененияПоБензину()
	ЕстьИзменения=ложь;

	если Объект.Количество<>Объект.Ссылка.Количество или Объект.Автомобиль<>Объект.ссылка.Автомобиль или НачалоДня(объект.Дата)<>НачалоДня(Объект.ссылка.Дата)  тогда
		ЕстьИзменения=Истина;
	КонецЕсли;	
	
	Возврат ЕстьИзменения;
	
КонецФункции


