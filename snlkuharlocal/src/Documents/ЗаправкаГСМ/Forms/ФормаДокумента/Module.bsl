	ТекОстаток2=ПоказанияНачальныхОстатков(Объект.Автомобиль, КонецДня(Объект.Дата));
	
	
	Если ЕстьИзмененияПоБензину() тогда
		ЕстьИзмененияПоБензину=Истина
		//Объект.ОстатокТопливаВыезд = МодульПутевогоЛиста.ПоказанияНачальныхОстатков(Объект.Автомобиль, Объект.Дата);
	иначе
		ЕстьИзмененияПоБензину=Ложь;
	КонецЕсли;
	
	

КонецПроцедуры


