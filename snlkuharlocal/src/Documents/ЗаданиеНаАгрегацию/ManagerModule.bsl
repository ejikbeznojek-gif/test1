Процедура ЗаполнитьЛистПереукладкиПоЗНА (Лист,СтруктураДанныхЗНА)  
	
	
	если ложь тогда Лист=Документы.ЛистПереукладки.СоздатьДокумент();   КонецЕсли;
	
	если не лист.ЭтоНовый() тогда 
		для каждого Реквизит из Лист.Метаданные().Реквизиты цикл    
			лист[Реквизит.имя]=Неопределено;	
		КонецЦикла;  		
		
		для каждого ТЧ из Лист.Метаданные().ТабличныеЧасти цикл    
			лист[тч.имя].очистить();	
		КонецЦикла;    
	КонецЕсли;
	
	
	Лист.ПометкаУдаления						 = ложь;    
	Лист.Проведен								 = Истина;
	Лист.Автор									 = ПараметрыСеанса.Пользователь;
	Лист.КоличествоДокумента					 = 0;
	Лист.ТипКороба								 = СтруктураДанныхЗНА.ТипКороба;	
	Лист.ОбъемДокумента							 = СтруктураДанныхЗНА.ТипКороба_Объем;	
	Лист.ТипШК									 = Перечисления.ТипыШтрихКодов.Штука;  	
	Лист.Дата									 = ТекущаяДата();
	Лист.ДокОснование							 = СтруктураДанныхЗНА.ДокОснование;
	лист.ЗагруженИзТСД							 = ложь;
	лист.ОтправленНаТСД							 = ложь;
	лист.ЗаданиеНаАгрегацию						 = СтруктураДанныхЗНА.Ссылка;
	лист.КодАгрегации							 = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
	Лист.Сканировщик							 = Справочники.ФизическиеЛица.ПустаяСсылка();
	для каждого СтрТЗ из СтруктураДанныхЗНА.Товары цикл
		СтрТЧ=Лист.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЧ,СтрТЗ);
	КонецЦикла;
	//++Данилова Е.В. 29.08.2025 HELP-6414 
	Если СтруктураДанныхЗНА.Свойство("СодержимоеБлочка") Тогда
	
		Лист.СодержимоеБлочка.Загрузить(СтруктураДанныхЗНА.СодержимоеБлочка); 
	
	КонецЕсли;
	Если СтруктураДанныхЗНА.Свойство("БлочкиВсего") Тогда
	
		Лист.БлочкиВсего.Загрузить(СтруктураДанныхЗНА.БлочкиВсего); 
	
	КонецЕсли;
	//--Данилова Е.В. 29.08.2025
	
	
КонецПроцедуры

