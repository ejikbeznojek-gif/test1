Функция РаспровестиЗНАПоНакладной (Знач Накладная,РаспроводитьВсеДокументы = ложь,ОписаниеНоменклатурыСтрокой="")  экспорт  
	СтруктураВозврата = новый Структура("Успех,Ошибки",Ложь,новый Массив);
	
	Запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНаАгрегацию.Ссылка КАК Ссылка,
	|	ЗаданиеНаАгрегацию.Проведен КАК Проведен
	|ИЗ
	|	Документ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию
	|ГДЕ
	|	ЗаданиеНаАгрегацию.ДокОснование = &Накладная
	|	И (ЗаданиеНаАгрегацию.ОписаниеНоменклатурыСтрокой = &ОписаниеНоменклатурыСтрокой
	|			ИЛИ &РаспроводитьВсеДокументы)"; 
	
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("РаспроводитьВсеДокументы",РаспроводитьВсеДокументы);
	запрос.УстановитьПараметр("ОписаниеНоменклатурыСтрокой",ОписаниеНоменклатурыСтрокой);     
	запрос.Выполнить().Выбрать();
	
	Выборка = запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл        
		если выборка.проведен тогда
			ЗНАОбъект = выборка.Ссылка.ПолучитьОбъект();
			ЗНАОбъект.Проведен = ложь;
			попытка
				ЗНАОбъект.Записать();  
			Исключение      
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не удалось записать %1 из-за %2",Выборка.ссылка,ОписаниеОшибки()));  
				Продолжить;
			КонецПопытки;
		КонецЕсли;
		ТЗЛистов = ПолучитьВсеЛистыПереукладкиПоЗНА(Выборка.Ссылка);
		Для каждого СтрТЗ из ТЗЛистов цикл    
			Если не СтрТЗ.Проведен тогда Продолжить;КонецЕсли;
			ЛистОбъект = СтрТЗ.Лист.ПолучитьОбъект();
			ЛистОбъект.КодАгрегации = Неопределено;     
			ЛистОбъект.Проведен = ложь;
			
			попытка
				ЛистОбъект.ПростоЗаписать(); 
			Исключение      
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не удалось записать %1 из-за %2",СтрТЗ.Лист,ОписаниеОшибки()));  
				Продолжить;
			КонецПопытки;		
		КонецЦикла;          
		МассивЛистов = ТЗЛистов.ВыгрузитьКолонку("Лист");
		
		ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, Перечисления.ТипыШтрихКодов.Коробка);	  
		если ЗначениеЗаполнено(ОперАгрегации) тогда
			Результат = Документы.МаркировкаТоваровИСМП.УбратьМассивЛистовИзПакетнойАгрегации(ОперАгрегации, МассивЛистов);   
			если не Результат.Успех тогда    
				МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,Результат);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;  
	
	если СтруктураВозврата.Ошибки.Количество() = 0 тогда 
		СтруктураВозврата.Успех = Истина;
	КонецЕсли;                           
	возврат СтруктураВозврата;
	
КонецФункции

//++Данилова Е.В. 05.05.2026 SNL-201
Функция ПроверитьКоличествоКодовДляБронирования(СтруктураДанныхЗНА,ДобавлятьКСуществующим)
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,новый Массив);
	КоличествоНеобходимыхКоробок = СтруктураДанныхЗНА.КоличествоКоробок;
	Если СтруктураДанныхЗНА.ДобавлятьКСуществующим Тогда
		КоличествоНеобходимыхКоробок = КоличествоНеобходимыхКоробок - СтруктураДанныхЗНА.КоличествоСуществующихЛистов; 	
	КонецЕсли;
	 
	ВсегоБлочковНаЛист = 0;
	Если СтруктураДанныхЗНА.Свойство("БлочкиВсего") И СтруктураДанныхЗНА.БлочкиВсего.Количество() > 0 Тогда

		ВсегоБлочковНаЛист = СтруктураДанныхЗНА.БлочкиВсего.Итог("Количество");

	КонецЕсли;
	ВсегоБлочковНаЛисты = ВсегоБлочковНаЛист * КоличествоНеобходимыхКоробок; 
	Если КоличествоНеобходимыхКоробок  = 0 Тогда
		СтруктураВозврата.Успех = Ложь; 
		СтруктураВозврата.Ошибки.Добавить("Количество необходимых коробов равно 0"); 
		Возврат СтруктураВозврата; 
	КонецЕсли;
	Если ВсегоБлочковНаЛисты > 0 Тогда
		ТипШК = Перечисления.ТипыШтрихКодов.Блочок;
		ОперАгрегацииБлочок = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(СтруктураДанныхЗНА.ДокОснование,
			ТипШК);
		Если Не ЗначениеЗаполнено(ОперАгрегацииБлочок) Тогда
			СтруктураВозврата.Ошибки.Добавить("Не найдена операция маркировки с типом ШК ""Блочок""");
		Иначе 
			КолКодовДоступных =  КоличествоДоступныхКодовДляБронирования(ОперАгрегацииБлочок);
			Если КолКодовДоступных < ВсегоБлочковНаЛисты Тогда
				НеобходимоеКолКодов = ВсегоБлочковНаЛисты - КолКодовДоступных;
				ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
				ДопПараметры = Новый Структура("Добавлять", Истина);

				РезБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыАгрегации(ТипШК,
					ТипУпаковки, необходимоеКолКодов, ОперАгрегацииБлочок, ДопПараметры);
				Если РезБронирования.Успешно Тогда
					ОперАгрегацииОбъект = ОперАгрегацииБлочок.ПолучитьОбъект();

					Для Каждого СтрМасс Из РезБронирования.Данные Цикл
						СтрТЧ = ОперАгрегацииОбъект.ШтрихкодыКоробок.Добавить();
						СтрТЧ.ДатаДобавления  = ТекущаяДатаСеанса();
						СтрТЧ.ШтрихкодКоробки = СтрМасс;
					КонецЦикла;
					Попытка
						ОперАгрегацииОбъект.Записать();
					Исключение

						СтруктураВозврата.Ошибки.Добавить("Не удалось заброниваровать короба для агрегации. "
							+ ОписаниеОшибки());
					КонецПопытки;
				Иначе
					СтруктураВозврата.ошибки.добавить(СтрСоединить(РезБронирования.Ошибки, символы.ПС));
				КонецЕсли;

			КонецЕсли;

		КонецЕсли;
		
		
	КонецЕсли; 
	
	ТипШК = Перечисления.ТипыШтрихКодов.Коробка;
	ОперАгрегацииКоробка = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(СтруктураДанныхЗНА.ДокОснование, ТипШК);
	Если Не ЗначениеЗаполнено(ОперАгрегацииКоробка) Тогда
		СтруктураВозврата.Ошибки.Добавить("Не найдена операция маркировки с типом ШК ""Коробка""");
	Иначе
		КолКодовДоступных =  КоличествоДоступныхКодовДляБронирования(ОперАгрегацииКоробка);
		Если КолКодовДоступных < КоличествоНеобходимыхКоробок Тогда
			НеобходимоеКолКодов = КоличествоНеобходимыхКоробок - КолКодовДоступных;
			ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;			
			ДопПараметры = Новый Структура("Добавлять", Истина);
			
			РезБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыАгрегации(ТипШК,
				ТипУпаковки, необходимоеКолКодов, ОперАгрегацииКоробка, ДопПараметры);
			Если РезБронирования.Успешно Тогда
				ОперАгрегацииОбъект = ОперАгрегацииКоробка.ПолучитьОбъект();

				Для Каждого СтрМасс Из РезБронирования.Данные Цикл
					СтрТЧ = ОперАгрегацииОбъект.ШтрихкодыКоробок.Добавить();
					СтрТЧ.ДатаДобавления  = ТекущаяДатаСеанса();
					СтрТЧ.ШтрихкодКоробки = СтрМасс;
				КонецЦикла;
				Попытка
					ОперАгрегацииОбъект.Записать();
				Исключение

					СтруктураВозврата.Ошибки.Добавить("Не удалось заброниваровать короба для агрегации. "
						+ ОписаниеОшибки());
				КонецПопытки;
			Иначе
				СтруктураВозврата.ошибки.добавить(СтрСоединить(РезБронирования.Ошибки, символы.ПС));
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;
	СтруктураВозврата.Успех = СтруктураВозврата.Ошибки.Количество() = 0; 
	Возврат СтруктураВозврата; 
КонецФункции

Функция КоличествоДоступныхКодовДляБронирования(ДокМаркировки)
	Запрос = Новый запрос;
	Запрос.Текст= "ВЫБРАТЬ
				  |	ТЧ.НомерСтроки КАК НомерСтроки,
				  |	ТЧ.ШтрихкодКоробки КАК ШтрихкодКоробки,
				  |	ТЧ.ДокументОснование КАК ДокументОснование
				  |ПОМЕСТИТЬ ВТ
				  |ИЗ
				  |	&ШтрихкодыКоробок КАК ТЧ
				  |ГДЕ
				  |	(ТЧ.ДокументОснование = НЕОПРЕДЕЛЕНО)	            
				  |;
				  |
				  |////////////////////////////////////////////////////////////////////////////////
				  |ВЫБРАТЬ различные 
				  |	
				  |	ВТ.ШтрихкодКоробки КАК ШтрихкодКоробки
				  |ИЗ
				  |	ВТ КАК ВТ
				  |
				  |";
	Запрос.УстановитьПараметр("ШтрихкодыКоробок",ДокМаркировки.ШтрихкодыКоробок.выгрузить());
	  
	Возврат Запрос.Выполнить().Выгрузить().Количество(); 
	  
КонецФункции
