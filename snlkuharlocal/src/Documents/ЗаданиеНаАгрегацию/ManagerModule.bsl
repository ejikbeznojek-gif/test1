
	   
	   
	   

Функция НайтиСоздатьЗНАПоНакладнойИСтруктуреПараметров (Знач Накладная,СтруктураПараметров)  экспорт  
	
	СтруктураВозврата 	 = новый Структура("Успех,Ошибки,Данные",Ложь,новый Массив,Неопределено);  
	//++Данилова Е.В. 27.04.2026  SNL-202
	ПроверятьКороб = Истина; 
	Если СтруктураПараметров.Свойство("НеПроверятьКороб") 
		И СтруктураПараметров.НеПроверятьКороб Тогда
		ПроверятьКороб = Ложь; 
	КонецЕсли; 
	//--Данилова Е.В. 27.04.2026 
	если не СтруктураПараметров.Свойство("ТипКороба") тогда  
		СтруктураВозврата.Ошибки.добавить("Пустой тип короба");
		//++Данилова Е.В. 27.04.2026  SNL-202
		//ИначеЕсли 	не ЗначениеЗаполнено(СтруктураПараметров.ТипКороба) тогда
	ИначеЕсли ПроверятьКороб	
		И не ЗначениеЗаполнено(СтруктураПараметров.ТипКороба) тогда 
		//--Данилова Е.В. 27.04.2026
		СтруктураВозврата.Ошибки.добавить("Пустой тип короба");	
	КонецЕсли; 
	
	если не СтруктураПараметров.Свойство("Товары")  тогда  
		СтруктураВозврата.Ошибки.добавить("Пустая таблица номенклатуры");	
	КонецЕсли;      
	
	
	если не СтруктураПараметров.Свойство("КоличествоКоробок") тогда  
		СтруктураВозврата.Ошибки.добавить("Пустое количество коробок");	
	КонецЕсли;
	
	если СтруктураВозврата.Ошибки.количество()>0 тогда
		возврат СтруктураВозврата;
	КонецЕсли;
	//++Данилова Е.В. 29.08.2025  HELP-6414 
	НеРазворачиватьКП = Ложь; 
	Если СтруктураПараметров.Свойство("НеРазворачиватьКП") Тогда
	
		НеРазворачиватьКП = СтруктураПараметров.НеРазворачиватьКП; 	
	
	КонецЕсли;
	//--Данилова Е.В. 29.08.2025
	ОтгрузкаКомплектов = ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов","Документ");
	если ОтгрузкаКомплектов 
		//++Данилова Е.В. 29.08.2025  HELP-6414
		И НЕ НеРазворачиватьКП  
		//--Данилова Е.В. 29.08.2025
		тогда
		СтруктураПараметров.Товары = РазвернутьТоварыВКомплектующие(Накладная, СтруктураПараметров.Товары);
	КонецЕсли;
	
	
	ТипКороба = СтруктураПараметров.ТипКороба;
	
	ТаблицаНоменклатуры  = СтруктураПараметров.Товары;      
	если ТаблицаНоменклатуры.Количество() = 0 тогда 
		СтруктураВозврата.Ошибки.добавить("Пустая таблица номенклатура");
		возврат СтруктураВозврата;
	КонецЕсли;
	КоличествоКоробок	 = СтруктураПараметров.КоличествоКоробок;
	
	ОписаниеНоменклатурыСтрокой = СгенерироватьНоменклатурноеОписаниеЗадание(ТаблицаНоменклатуры);
	запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНаАгрегацию.Ссылка КАК ЗНА
	               |ИЗ
	               |	Документ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию
	               |ГДЕ
	               |	ЗаданиеНаАгрегацию.Проведен
	               |	И ЗаданиеНаАгрегацию.ТипКороба = &ТипКороба
	               |	И ЗаданиеНаАгрегацию.ДокОснование = &Накладная  
				   //++Данилова Е.В. 27.04.2026 SNL-202
				  // |    И ЗаданиеНаАгрегацию.ОписаниеНоменклатурыСтрокой = &ОписаниеНоменклатурыСтрокой
	               |	И ВЫБОР
	               |			КОГДА &ПроверятьКороб
	               |				ТОГДА ЗаданиеНаАгрегацию.ОписаниеНоменклатурыСтрокой = &ОписаниеНоменклатурыСтрокой
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
				  //--Данилова Е.В. 27.04.2026 
	запрос.УстановитьПараметр("ТипКороба",ТипКороба);
	запрос.УстановитьПараметр("Накладная",Накладная); 
	запрос.УстановитьПараметр("ОписаниеНоменклатурыСтрокой",ОписаниеНоменклатурыСтрокой);
	//++Данилова Е.В. 27.04.2026 SNL-202 
	запрос.УстановитьПараметр("ПроверятьКороб",ПроверятьКороб);
	//--Данилова Е.В. 27.04.2026
	Выборка = запрос.Выполнить().Выбрать();   
	ЗНА = Неопределено;
	пока выборка.Следующий() цикл  
		ЗНА = Выборка.ЗНА;
	КонецЦикла;
	
	если ЗНА = Неопределено тогда
		ЗНАОбъект = документы.ЗаданиеНаАгрегацию.СоздатьДокумент();   
	Иначе
		ЗНАОбъект = ЗНА.ПолучитьОбъект();
		ЗНАОбъект.Товары.Очистить(); 
		//++Данилова Е.В. 29.08.2025 HELP-6414 
		ЗНАОбъект.СодержимоеБлочка.Очистить();
		ЗНАОбъект.БлочкиВсего.Очистить();
		//--Данилова Е.В. 29.08.2025
	КонецЕсли;
	
	ЗНАОбъект.ОбработкаЗаполнения(Накладная,"",Истина);   
	ЗНАОбъект.КоличествоКоробок  = КоличествоКоробок;
	ЗНАОбъект.ТипКороба			 = ТипКороба;
	
	
	для каждого СтрокаНоменклатуры из ТаблицаНоменклатуры цикл   
		СтрТЧ = ЗНАОбъект.Товары.Добавить();     
		ЗаполнитьЗначенияСвойств(СтрТЧ,СтрокаНоменклатуры);
		
	КонецЦикла;
	//++Данилова Е.В. 29.08.2025  HELP-6414 
	Если СтруктураПараметров.Свойство("СодержимоеБлочка") Тогда 
		
		СодержимоеБлочкаТЗ = СтруктураПараметров.СодержимоеБлочка;		 
	    ЗНАОбъект.СодержимоеБлочка.Загрузить(СодержимоеБлочкаТЗ); 
		
	КонецЕсли;
	
    Если СтруктураПараметров.Свойство("БлочкиВсего") Тогда 
		
		БлочкиВсегоТЗ = СтруктураПараметров.БлочкиВсего;		 
	    ЗНАОбъект.БлочкиВсего.Загрузить(БлочкиВсегоТЗ); 
		
	КонецЕсли;
	//--Данилова Е.В. 29.08.2025
	
	ЗНАОбъект.Проведен = Истина; 
	//++Данилова Е.В. 27.04.2026 SNL-202 
	Если НЕ ПроверятьКороб Тогда
	
		ЗНАОбъект.ПроизвольнаяКоробка = истина; 	
	
	КонецЕсли;
	//--Данилова Е.В. 27.04.2026 
	попытка 
		//++Данилова Е.В. 27.04.2026 SNL-202 
		ЗНАОбъект.ДополнительныеСвойства.Вставить("ПроверятьКороб",ПроверятьКороб); 
		//--Данилова Е.В. 27.04.2026 
		ЗНАОбъект.Записать();   
		ЗНА = ЗНАОбъект.Ссылка;
	Исключение                 
		ТекстОшибки = "Не удалось записать ЗНА. "+ОписаниеОшибки();
		СтруктураВозврата.Ошибки.добавить(ТекстОшибки);			
	КонецПопытки;        
	
	если СтруктураВозврата.Ошибки.количество()=0 тогда
		СтруктураВозврата.Данные = ЗНА;
		СтруктураВозврата.Успех	 = Истина; 
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции

Функция РазвернутьТоварыВКомплектующие (Знач Накладная,Знач Товары)  
	ТоварыВозвращаемые = Товары.Скопировать();
	ТоварыВозвращаемые.Очистить();

	Запрос = новый запрос;
	запрос.Текст ="ВЫБРАТЬ
	              |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
	              |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
	              |	РасходнаяНакладнаяКомплектующие.Количество КАК Количество,
	              |	РасходнаяНакладнаяКомплектующие.КоличествоПродукции КАК КоличествоПродукции
	              |ИЗ
	              |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	              |ГДЕ
	              |	РасходнаяНакладнаяКомплектующие.Ссылка = &Накладная
	              |	И РасходнаяНакладнаяКомплектующие.Количество > 0
	              |	И РасходнаяНакладнаяКомплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)";
	запрос.УстановитьПараметр("Накладная",Накладная);      
	ТаблицаНакладной = запрос.Выполнить().Выгрузить();
	Для каждого СтрТЗ из Товары цикл 
		МассивСтрок = ТаблицаНакладной.НайтиСтроки(Новый Структура("Продукция",СтрТЗ.Номенклатура));
		КоличествоПродукции = 0;       
		
		Для каждого СтрМасс из МассивСтрок цикл    
			КоличествоПродукции = КоличествоПродукции + СтрМасс.КоличествоПродукции; 
		КонецЦикла;  
		если КоличествоПродукции = 0 тогда Продолжить; КонецЕсли;
		
		Для каждого СтрМасс из МассивСтрок цикл    
			СтрТЗВозвращаемая = ТоварыВозвращаемые.Добавить();  
			СтрТЗВозвращаемая.Номенклатура = СтрМасс.Номенклатура;
			СтрТЗВозвращаемая.Количество = Окр(СтрТЗ.Количество*(СтрМасс.Количество/КоличествоПродукции),0); 
		КонецЦикла; 		
		
	КонецЦикла;
	
	возврат ТоварыВозвращаемые;
КонецФункции


Функция ЗаполнитьЛистыПереукладкиПоЗНА (Знач ЗаданиеНаАгрегацию,Знач ДобавлятьКСуществующим = ложь)  Экспорт        
	если ложь тогда ЗаданиеНаАгрегацию = документы.ЗаданиеНаАгрегацию.НайтиПоНомеру("");КонецЕсли;
	
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,новый Массив);
	
	ТаблицаЛистов = ПолучитьТекущиеЛистыПереукладкиПоЗНА(ЗаданиеНаАгрегацию);
	КоличествоСуществующихЛистов = ТаблицаЛистов.количество();  	
	
	СтруктураДанныхЗНА = ПолучитьРеквизитыШапки(ЗаданиеНаАгрегацию,"АгрегацииЗаполнены,ДокОснование,Ссылка,ТипКороба,ТипКороба.Объем,КоличествоКоробок,ЛистыСозданы"); 	       
	СтруктураДанныхЗНА.Вставить("ДобавлятьКСуществующим",ДобавлятьКСуществующим);	
	СтруктураДанныхЗНА.Вставить("Товары",ПолучитьТоварыЗНА(ЗаданиеНаАгрегацию));
	СтруктураДанныхЗНА.Вставить("ДобавлятьКСуществующим",ДобавлятьКСуществующим);		
	СтруктураДанныхЗНА.Вставить("КоличествоСуществующихЛистов",КоличествоСуществующихЛистов);	
	СтруктураДанныхЗНА.Вставить("ТаблицаЛистов",ТаблицаЛистов);
	//++Данилова Е.В. 29.08.2025 HELP-6414
	СтруктураДанныхЗНА.Вставить("СодержимоеБлочка",ЗаданиеНаАгрегацию.СодержимоеБлочка.Выгрузить());
	СтруктураДанныхЗНА.Вставить("БлочкиВсего",ЗаданиеНаАгрегацию.БлочкиВсего.Выгрузить());
	//--Данилова Е.В. 29.08.2025 
	
	
	если КоличествоСуществующихЛистов>=СтруктураДанныхЗНА.КоличествоКоробок и ДобавлятьКСуществующим тогда  
		СтруктураВозврата.Ошибки.Добавить("Количество существующих листов больше или равно количеству требуемых. Пересоздайте их заново, воспользовавшись кнопкой очистки листов.");	
	КонецЕсли;   
	//++Данилова Е.В. 05.05.2026 SNL-201 
	РезультатПроверкиКолКодов = ПроверитьКоличествоКодовДляБронирования(СтруктураДанныхЗНА,ДобавлятьКСуществующим); 
	Если НЕ РезультатПроверкиКолКодов.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,РезультатПроверкиКолКодов);
		возврат СтруктураВозврата;
	КонецЕсли;
	//--Данилова Е.В. 05.05.2026
	РезультатВыполненияСоздатьЛисты = СоздатьЛистыПереукладкиПоЗНА(ЗаданиеНаАгрегацию, СтруктураДанныхЗНА);     	
	если не РезультатВыполненияСоздатьЛисты.Успех тогда  
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,РезультатВыполненияСоздатьЛисты);
	КонецЕсли;  
	
	если РезультатВыполненияСоздатьЛисты.Успех тогда 
		СтруктураДанныхЗНА.Вставить("ТаблицаЛистов",ПолучитьТекущиеЛистыПереукладкиПоЗНА(ЗаданиеНаАгрегацию));
		РезультатВыполненияЗаполнитьАгрегации = ЗаполнитьАгрегацииКоробовВЛистахПоЗНА(ЗаданиеНаАгрегацию, СтруктураДанныхЗНА);     	
		если не РезультатВыполненияЗаполнитьАгрегации.Успех тогда  
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,РезультатВыполненияЗаполнитьАгрегации);
		КонецЕсли;  
	КонецЕсли;
	
	
	если СтруктураВозврата.Ошибки.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь;   
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции     


Функция СоздатьЛистыПереукладкиПоЗНА (Знач ЗаданиеНаАгрегацию,Знач СтруктураДанныхЗНА)
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,новый Массив);
	если СтруктураДанныхЗНА.ЛистыСозданы и не СтруктураДанныхЗНА.ДобавлятьКСуществующим тогда 
		НужноСоздаватьЛисты = ложь;	
	иначе
		НужноСоздаватьЛисты = Истина;
	КонецЕсли;
	
	если НужноСоздаватьЛисты тогда		
		
		
		если СтруктураДанныхЗНА.ДобавлятьКСуществующим тогда   
			НачальныйНомерКоробки = СтруктураДанныхЗНА.КоличествоСуществующихЛистов+1;
		иначе
			НачальныйНомерКоробки = 1;
		КонецЕсли;		                 
		
		ЗаданиеНаАгрегациюОбъект = ЗаданиеНаАгрегацию.ПолучитьОбъект();	 
		ЗаданиеНаАгрегациюОбъект.ЛистыСозданы = ложь;           
		
		попытка
			ЗаданиеНаАгрегациюОбъект.Записать(); 
		Исключение 
			СтруктураВозврата.Ошибки.Добавить("Не удалось записать ЗНА перед созданием листов "+ЗаданиеНаАгрегацию+". "+ОписаниеОшибки());    
			СтруктураВозврата.Успех = ложь;
			возврат СтруктураВозврата;
		КонецПопытки;

		МаксимальныйНомерКоробки = документы.ЛистПереукладки.ПолучитьМаксимальныйНомерКоробкиПоНакладной(СтруктураДанныхЗНА.ДокОснование);
		СквознойНомерКоробки = МаксимальныйНомерКоробки+1;
		
		для сч = НачальныйНомерКоробки по СтруктураДанныхЗНА.КоличествоКоробок цикл         
			ТекущийЛистОбъект = Неопределено;		
			если не СтруктураДанныхЗНА.ДобавлятьКСуществующим  тогда
				если НачальныйНомерКоробки  < СтруктураДанныхЗНА.КоличествоСуществующихЛистов тогда
					ТекущийЛистОбъект = СтруктураДанныхЗНА.ТаблицаЛистов[НачальныйНомерКоробки].Лист.ПолучитьОбъект();   
				КонецЕсли;      
			КонецЕсли; 
			
			если ТекущийЛистОбъект = Неопределено тогда   
				ТекущийЛистОбъект = Документы.ЛистПереукладки.СоздатьДокумент();
			КонецЕсли;                
			
			ЗаполнитьЛистПереукладкиПоЗНА(ТекущийЛистОбъект,СтруктураДанныхЗНА);   	  
			ТекущийЛистОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим",Истина);
			//++Данилова Е.В. 05.05.2026 SNL-201 
			//номер коробки заполняется позже   			
			//ТекущийЛистОбъект.НомерКоробки = СквознойНомерКоробки;
			//--Данилова Е.В. 05.05.2026 
			ТекущийЛистОбъект.Проведен = Истина;
			попытка
				ТекущийЛистОбъект.Записать();	      
			Исключение     
				СтруктураВозврата.Ошибки.Добавить("Не удалось записать листы переукладки попробуйте ещё раз");  
				Прервать;
			КонецПопытки;   
			
			СквознойНомерКоробки = СквознойНомерКоробки+1;
		КонецЦикла;    
		
		Если СтруктураВозврата.Ошибки.Количество()=0 тогда		
			ЗаданиеНаАгрегациюОбъект.ЛистыСозданы = Истина;	
			попытка
				ЗаданиеНаАгрегациюОбъект.Записать(); 
			Исключение 
				СтруктураВозврата.Ошибки.Добавить("Не удалось записать ЗНА после создания листов "+ЗаданиеНаАгрегацию+". "+ОписаниеОшибки());  
			КонецПопытки;
		КонецЕсли;                  
		
	КонецЕсли;
	
	если СтруктураВозврата.Ошибки.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь; 
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаполнитьАгрегацииКоробовВЛистахПоЗНА (Знач ЗаданиеНаАгрегацию,Знач СтруктураДанныхЗНА)  Экспорт        
	если ложь тогда ЗаданиеНаАгрегацию = документы.ЗаданиеНаАгрегацию.НайтиПоНомеру("");КонецЕсли;
	
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,новый Массив);
	ТаблицаЛистов = СтруктураДанныхЗНА.ТаблицаЛистов;
	КоличествоСуществующихЛистов = ТаблицаЛистов.количество();  
	
	если СтруктураДанныхЗНА.АгрегацииЗаполнены тогда 
		НужноЗаполнятьАгрегации = ложь;	
	иначе
		НужноЗаполнятьАгрегации = Истина;
	КонецЕсли;
	
	если НужноЗаполнятьАгрегации тогда
		
		МассивСтрокТребующихАгрегации  = ТаблицаЛистов.НайтиСтроки(новый Структура("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка())); 
		МассивЛистовТребующихАгрегации = новый Массив;		
		
		для каждого ТекСтрока из МассивСтрокТребующихАгрегации цикл
			МассивЛистовТребующихАгрегации.Добавить(ТекСтрока.Лист);		
		КонецЦикла;
		
		//++Данилова Е.В. 29.08.2025 HELP-6414
		ВсегоБлочковНаЛист = 0; 
		Если СтруктураДанныхЗНА.Свойство("БлочкиВсего")
			И СтруктураДанныхЗНА.БлочкиВсего.Количество() > 0  Тогда
			
			ВсегоБлочковНаЛист = СтруктураДанныхЗНА.БлочкиВсего.Итог("Количество"); 	
			
		КонецЕсли;
		ВсегоБлочковНаЛисты = ВсегоБлочковНаЛист * МассивЛистовТребующихАгрегации.Количество(); 
		//--Данилова Е.В. 29.08.2025
		
		РезультатБронирования 			= Документы.МаркировкаТоваровИСМП.ПолучитьТаблицуРанееЗабронированныхКодовАгрегацииДляМассиваЛистов(МассивЛистовТребующихАгрегации,
		СтруктураДанныхЗНА.ДокОснование
		,Перечисления.ТипыШтрихКодов.Коробка);
		//++Данилова Е.В. 29.08.2025 HELP-6414
		РезультатБронированияБлочков = Новый Структура("Успех,Данные,Ошибки",Истина,Новый ТаблицаЗначений, Новый Массив);  
		Если  ВсегоБлочковНаЛисты > 0 Тогда
			
			РезультатБронированияБлочков = Документы.МаркировкаТоваровИСМП.ПолучитьТаблицуРанееЗабронированныхКодовАгрегацииДляМассиваЛистов(МассивЛистовТребующихАгрегации,
			СтруктураДанныхЗНА.ДокОснование
			,Перечисления.ТипыШтрихКодов.Блочок
			,ВсегоБлочковНаЛисты);	
			
		КонецЕсли;
		//--Данилова Е.В. 29.08.2025 
		
		если РезультатБронирования.Успех 
			И РезультатБронированияБлочков.Успех тогда  //Данилова Е.В. 29.08.2025 HELP-6414
			КодыАгрегацииУстановленыВезде = Истина;
			Для Каждого ТекЛист из МассивЛистовТребующихАгрегации цикл
				ТекЛистОбъект		 = ТекЛист.ПолучитьОбъект();
				если ложь тогда ТекЛистОбъект = документы.ЛистПереукладки.СоздатьДокумент();КонецЕсли; 
				СтрокаДанных 	  	 = РезультатБронирования.Данные.Найти(ТекЛист);
				если СтрокаДанных 	 = Неопределено или СтрокаДанных.КодАгрегации = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() тогда
					КодыАгрегацииУстановленыВезде = ложь;   
					СтруктураВозврата.Ошибки.добавить("Не удалось получить код агрегации к "+ТекЛист);
					Продолжить;
				КонецЕсли;
				
				ТекЛистОбъект.КодАгрегации = СтрокаДанных.КодАгрегации;
				ТекЛистОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим",Истина);
				//++Данилова Е.В. 29.08.2025 HELP-6414
				ТекЛистОбъект.ШтрихкодыУпаковокБлочков.Очистить();
				Если РезультатБронированияБлочков.Данные.Количество() > 0  Тогда
					
					СтрокиШКБл = РезультатБронированияБлочков.Данные.НайтиСтроки(Новый Структура("Лист",ТекЛист)); 	
					
					Для каждого  СтрокаШКБл Из СтрокиШКБл Цикл
						
						СтрокаШКБлочков = ТекЛистОбъект.ШтрихкодыУпаковокБлочков.Добавить(); 		
						СтрокаШКБлочков.ШтрихкодУпаковки = СтрокаШКБл.КодАгрегации; 	
						
					КонецЦикла;	
					 	
					
				КонецЕсли;
				//--Данилова Е.В. 29.08.2025
				попытка
					ТекЛистОбъект.Записать();
				Исключение    
					СтруктураВозврата.Ошибки.добавить("Не удалось записать после получения кода агрегации "+ТекЛист+". "+ОписаниеОшибки());
					Продолжить;
				КонецПопытки;			
			КонецЦикла;   
			
			если СтруктураВозврата.Ошибки.Количество()=0 тогда    
				ЗаданиеНаАгрегациюОбъект   					= ЗаданиеНаАгрегацию.ПолучитьОбъект();
				ЗаданиеНаАгрегациюОбъект.АгрегацииЗаполнены = Истина;                 
				Попытка
					  ЗаданиеНаАгрегациюОбъект.Записать(РежимЗаписиДокумента.Запись);
				Исключение       
					 СтруктураВозврата.Ошибки.добавить("Не удалось записать после получения кода агрегации "+ЗаданиеНаАгрегацию+". "+ОписаниеОшибки());
				КонецПопытки;
			КонецЕсли;
			
			
		иначе
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,РезультатБронирования);
			//++Данилова Е.В. 02.09.2025  HELP-6414
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,РезультатБронированияБлочков);
			//--Данилова Е.В. 02.09.2025
		КонецЕсли;
		
	КонецЕсли;
	
	если СтруктураВозврата.Ошибки.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь;  
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции     




Функция ПолучитьТоварыЗНА (ЗаданиеНаАгрегацию)     
	Запрос = новый запрос;    
	запрос.УстановитьПараметр("ЗаданиеНаАгрегацию",ЗаданиеНаАгрегацию);
	запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНаАгрегациюТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаданиеНаАгрегациюТовары.Количество) КАК Количество,
