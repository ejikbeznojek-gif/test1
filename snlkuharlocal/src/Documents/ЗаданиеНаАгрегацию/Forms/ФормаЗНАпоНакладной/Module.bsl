&НаСервереБезКонтекста
Процедура ПерезаполнитьНумерациюКоробовНаСервере(Накладная)
	Документы.ЛистПереукладки.ПереномероватьВсеКоробкиНакладной(Накладная);	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВернутьЛистВРаботуНаСервере(Лист)
	Документы.ЛистПереукладки.ВернутьЛистОтЗНАВРаботу(Лист);
КонецПроцедуры

&НаКлиенте
Процедура ВернутьЛистВРаботу(Команда) 
	ТекущаяСтрока = Элементы.СписокЛистовПереукладки.ТекущиеДанные;    
	если ТекущаяСтрока<>Неопределено тогда
		ВернутьЛистВРаботуНаСервере(ТекущаяСтрока.Ссылка);
		элементы.СписокЛистовПереукладки.Обновить();         
	КонецЕсли;
КонецПроцедуры




&НаСервере
Процедура РассчитатьИтоги() 
	
	
	Схема = Элементы.СписокЗНА.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки = Элементы.СписокЗНА.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	ЭтаФорма.Элементы.СписокЗНАЗаявка.ТекстПодвала =  Формат(Результат.Итог("Заявка"));        
	ЭтаФорма.Элементы.СписокЗНАВРаботеНаТСД.ТекстПодвала =  Формат(Результат.Итог("ВРаботеНаТСД"));
	ЭтаФорма.Элементы.СписокЗНАСобрано.ТекстПодвала =  Формат(Результат.Итог("Собрано"));         
	
	
	
	
	
	
	
	КМП = ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов");
	если КМП тогда
		Схема = Элементы.ПланФактКомплектующие.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
		Настройки = Элементы.ПланФактКомплектующие.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
		ЭтаФорма.Элементы.ПланФактКомплектующиеЗаявка.ТекстПодвала =  Формат(Результат.Итог("Заявка"));        
		ЭтаФорма.Элементы.ПланФактКомплектующиеВРаботеНаТСД.ТекстПодвала =  Формат(Результат.Итог("ВРаботеНаТСД"));
		ЭтаФорма.Элементы.ПланФактКомплектующиеСобрано.ТекстПодвала =  Формат(Результат.Итог("Собрано"));    
	иначе   
		Схема = Элементы.ПланФакт.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
		Настройки = Элементы.ПланФакт.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
		ЭтаФорма.Элементы.ПланФактЗаявка.ТекстПодвала =  Формат(Результат.Итог("Заявка"));        
		ЭтаФорма.Элементы.ПланФактВРаботеНаТСД.ТекстПодвала =  Формат(Результат.Итог("ВРаботеНаТСД"));
		ЭтаФорма.Элементы.ПланФактСобрано.ТекстПодвала =  Формат(Результат.Итог("Собрано"));    			
	КонецЕсли; 	
	
КонецПроцедуры



&НаСервере
Функция ЗаполнитьЛистыПереукладкиНаСервере()  
	СтруктураВозврата = новый Структура("Успех,Ошибки",ложь,новый Массив);
	запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНаАгрегацию.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию
	|ГДЕ
	|	ЗаданиеНаАгрегацию.Проведен
	|	И ЗаданиеНаАгрегацию.ДокОснование = &ДокОснование
	|	И НЕ ЗаданиеНаАгрегацию.АгрегацииЗаполнены";
	запрос.УстановитьПараметр("ДокОснование",Накладная);
	Выборка = запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл   
		Результат = документы.ЗаданиеНаАгрегацию.ЗаполнитьЛистыПереукладкиПоЗНА(Выборка.Ссылка);
		если не Результат.Успех тогда      
			СтруктураВозврата.Ошибки.Добавить(""+Выборка.Ссылка);	
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата,Результат);
		иначе    
			ЗНАОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ЗНАОбъект.АгрегацииЗаполнены = Истина;     
			ЗНАОбъект.ЛистыСозданы = Истина;
			ЗНАОбъект.Записать();
		КонецЕсли;
	КонецЦикла;
	если СтруктураВозврата.Ошибки.Количество() = 0 тогда
		СтруктураВозврата.Успех = Истина;
	КонецЕсли;                           
	возврат СтруктураВозврата;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьЛистыПереукладки(Команда) 
	если не ЗначениеЗаполнено(Накладная) тогда
		Возврат;
	КонецЕсли;
	
	Результат = ЗаполнитьЛистыПереукладкиНаСервере();
	если не Результат.Успех тогда
		Сообщить(СтрСоединить(Результат.Ошибки,символы.ПС));
	КонецЕсли;
	элементы.СписокЗНА.Обновить();
	
КонецПроцедуры    

&НаСервере
Функция СформироватьQRНаСервере(ЗНА) 
	
	ОбработкаФормированияКартинки = Обработки.СформироватьКартинкуКодаШКQR.Создать();
	Эталон = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьМакет("Эталон");
	ММвВПикселе = Эталон.Рисунки.Квадрат100Пикселей.Высота / 100;
	
	
	Схема = Элементы.СписокЗНА.ПолучитьИсполняемуюСхемуКомпоновкиДанных();	
	Настройки = Элементы.СписокЗНА.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	Если Результат.Количество() = 0 Тогда
		Возврат Новый ТабличныйДокумент;
	Иначе 
		ЗНА = Результат.Получить(0).ЗаданиеНаАгрегацию;
	КонецЕсли;

	ТД = Новый ТабличныйДокумент;
	ТД.ИмяПараметровПечати = "ПечатьЗНА";
	
	СтруктураДанныхКомпонентыПечати = ОбработкаФормированияКартинки.ПолучитьКомпонентуФормированияDataMatrixКода();	
	
	//СформироватьQRНаСервере(); 
	
	Макет = Документы.ЗаданиеНаАгрегацию.ПолучитьМакет("Макет");
	
	ОблШапка = Макет.ПолучитьОбласть("Шапка");
	
	ЗаполнитьЗначенияСвойств(ОблШапка.Параметры, ЗНА);
	
	ТД.Вывести(ОблШапка);
	
	ОблЭтикетка = Макет.ПолучитьОбласть("Строка");      

	// Кельманов А.В. - Исправление ошибки - 2025.11.07 {
	//ЗаполнитьЗначенияСвойств(ОблЭтикетка.Параметры,ЗНА);
	// Кельманов А.В. - Исправление ошибки - 2025.11.07 }
	
	Счетчик = 0; // Кельманов А.В. - SNL-207 - 2026.04.22
	
	Для Каждого Строка Из Результат Цикл
		
		ЗНА = Строка.ЗаданиеНаАгрегацию;
		
		// Кельманов А.В. - Исправление ошибки - 2025.11.07 {
		ЗаполнитьЗначенияСвойств(ОблЭтикетка.Параметры, ЗНА);
		// Кельманов А.В. - Исправление ошибки - 2025.11.07 }
		
		Строка = ЗначениеВСтрокуВнутр(ЗНА);     
		Строка = стрзаменить(Строка, "¶", "");
		Строка = стрзаменить(Строка, Символы.ПС, "");
		
		МассСтрок = Новый Массив;
		
		Для Каждого СтрТЧ Из ЗНА.Товары цикл
			МассСтрок.Добавить("" + СтрТЧ.Номенклатура + " - " + Строка(СтрТЧ.Количество));
		КонецЦикла;
		
		ОблЭтикетка.Параметры.ТаблицаНоменклатуры = СтрСоединить(МассСтрок, Символы.ПС);
		
		Рисунок = ОблЭтикетка.Рисунки.QRКод; 		
		ДопПараметры = Новый Структура;	
		КартинкаКода = ОбработкаФормированияКартинки.СформироватьКартинкуШК_DataMatrix(СтруктураДанныхКомпонентыПечати, Строка, ДопПараметры);  
		Рисунок.Картинка = КартинкаКода;        

		ТД.Вывести(ОблЭтикетка);
		
		// Кельманов А.В. - SNL-207 - 2026.04.22 {
		Счетчик = Счетчик + 1;
		
		Если Счетчик % 2 = 0 Тогда
			
			ТД.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЕсли;
		// Кельманов А.В. - SNL-207 - 2026.04.22 }
		
	КонецЦикла;
	
	Возврат ТД;
	
КонецФункции

&НаКлиенте
Процедура СформироватьQR(Команда) 
		
	ТекущаяСтрока = Элементы.СписокЗНА.ТекущиеДанные;   
	ПравилаЧЗ = ПолучитьРеквизитыШапки(ТекущаяСтрока.ЗаданиеНаАгрегацию,"ДокОснование.ПравилаАгрегацииЧестногоЗнака.ТребуетсяАгрегацияБлочков,ДокОснование.ПравилаАгрегацииЧестногоЗнака.ТребуетсяАгрегацияКоробок");
	
	// Кельманов А.В. - Оптимизация работы - 2025.11.07 {
	//Если ПравилаЧЗ.ДокОснование_ПравилаАгрегацииЧестногоЗнака_ТребуетсяАгрегацияБлочков = Истина тогда     
	//	Сообщить("Работа с блочками пока не реализована");
	//	Возврат;
	//КонецЕсли; 
	// Кельманов А.В. - Оптимизация работы - 2025.11.07 }
	
	Если не ПравилаЧЗ.ДокОснование_ПравилаАгрегацииЧестногоЗнака_ТребуетсяАгрегацияКоробок = Истина тогда     
		Сообщить("В правилах агрегации нет коробок");
		Возврат;
	КонецЕсли; 
	
	
	если ТекущаяСтрока<>Неопределено тогда
		ТД = СформироватьQRНаСервере(ТекущаяСтрока.ЗаданиеНаАгрегацию);	  
		ТД.показать();        
	КонецЕсли;
	
	
КонецПроцедуры


