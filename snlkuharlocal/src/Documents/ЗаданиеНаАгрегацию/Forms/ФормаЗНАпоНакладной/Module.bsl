&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)         
	Накладная = Параметры.ДанныеЗаполнения.Накладная;
	
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(ПланФакт, 		"Ссылка", Накладная);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(ПланФактКомплектующие, 		"Ссылка", Накладная);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(СписокЗНА, 		"Ссылка", Накладная);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(СписокЛистовПереукладки, 		"Ссылка", Накладная);
	УправлениеВидимостью();
	РассчитатьИтоги();
КонецПроцедуры


&НаСервере
Процедура УправлениеВидимостью()   
	
	если ЗначениеЗаполнено(Накладная) тогда
		КМП = ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов");
		если КМП тогда
			Элементы.ПланФакт.Видимость = ложь;
		иначе        
			Элементы.ПланФактКомплектующие.Видимость = ложь;
		КонецЕсли;                
	КонецЕсли;  
КонецПроцедуры

&НаКлиенте
Процедура СписокЗНАВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущаяСтрока = Элементы.СписокЗНА.ТекущиеДанные;   
	ОткрытьЗначение(ТекущаяСтрока.ЗаданиеНаАгрегацию);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокЛистовПереукладкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущаяСтрока = Элементы.СписокЛистовПереукладки.ТекущиеДанные;   
	ОткрытьЗначение(ТекущаяСтрока.ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
КонецПроцедуры          

&НаКлиенте
