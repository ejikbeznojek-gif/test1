  <autoFillCheck>true</autoFillCheck>
  <allowFormCustomize>true</allowFormCustomize>
  <enabled>true</enabled>
  <showTitle>true</showTitle>
  <showCloseButton>true</showCloseButton>
  <attributes>
    <name>ПланФакт</name>
    <title>
      <key>ru</key>
      <value>Список листов переукладки</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ТЗСводная.Номенклатура КАК Номенклатура,
	СУММА(ТЗСводная.Заявка) КАК Заявка,
	СУММА(ТЗСводная.ВРаботеНаТСД) КАК ВРаботеНаТСД,
	СУММА(ТЗСводная.Собрано) КАК Собрано
ИЗ
	(ВЫБРАТЬ
		Товары.Номенклатура КАК Номенклатура,
		Товары.Количество КАК Заявка,
		0 КАК ВРаботеНаТСД,
		0 КАК Собрано
	ИЗ
		Документ.РасходнаяНакладная.Товары КАК Товары
	ГДЕ
		Товары.Ссылка = &amp;Ссылка
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ЛистПереукладкиТовары.Номенклатура,
		0,
		ВЫБОР
			КОГДА ЛистПереукладкиТовары.Ссылка.ОтправленНаТСД
					И ЛистПереукладкиТовары.Количество &lt;> ЛистПереукладкиТовары.Отсканировано
				ТОГДА ЛистПереукладкиТовары.Количество
			ИНАЧЕ 0
		КОНЕЦ,
		ЛистПереукладкиТовары.Отсканировано
	ИЗ
		Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	ГДЕ
		ЛистПереукладкиТовары.Ссылка.Проведен
		И ЛистПереукладкиТовары.Ссылка.ДокОснование = &amp;ссылка) КАК ТЗСводная

СГРУППИРОВАТЬ ПО
	ТЗСводная.Номенклатура</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>СписокЛистовПереукладки</name>
    <title>
      <key>ru</key>
      <value>Список листов переукладки</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЛистПереукладки.Ссылка КАК Ссылка,
	ЛистПереукладки.Проведен КАК Проведен,
	ЛистПереукладки.КоличествоДокумента КАК КоличествоДокумента,
	ЛистПереукладки.ГруппыТоваров КАК ГруппыТоваров,
	ЛистПереукладки.ОтправленНаТСД КАК ОтправленНаТСД,
	ЛистПереукладки.ЗагруженИзТСД КАК ЗагруженИзТСД,
	ЛистПереукладки.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию,
	ЛистПереукладки.УзелТСД КАК УзелТСД,
	ЛистПереукладки.НомерКоробки КАК НомерКоробки,
	ЛистПереукладки.СканировщикФизЛицо КАК Сканировщик
ИЗ
	Документ.ЛистПереукладки КАК ЛистПереукладки
ГДЕ
	ЛистПереукладки.Ссылка.ДокОснование = &amp;Ссылка
	И ЛистПереукладки.Проведен</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>ПланФактКомплектующие</name>
    <title>
      <key>ru</key>
      <value>Список листов переукладки</value>
    </title>
    <id>3</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ТЗСводная.Номенклатура КАК Номенклатура,
	СУММА(ТЗСводная.Заявка) КАК Заявка,
	СУММА(ТЗСводная.ВРаботеНаТСД) КАК ВРаботеНаТСД,
	СУММА(ТЗСводная.Собрано) КАК Собрано
ИЗ
	(ВЫБРАТЬ
		Товары.Номенклатура КАК Номенклатура,
		Товары.Количество КАК Заявка,
		0 КАК ВРаботеНаТСД,
		0 КАК Собрано
	ИЗ
		Документ.РасходнаяНакладная.Комплектующие КАК Товары
	ГДЕ
		Товары.Ссылка = &amp;Ссылка
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ЛистПереукладкиТовары.Номенклатура,
		0,
		ВЫБОР
			КОГДА ЛистПереукладкиТовары.Ссылка.ОтправленНаТСД
					И ЛистПереукладкиТовары.Количество &lt;> ЛистПереукладкиТовары.Отсканировано
				ТОГДА ЛистПереукладкиТовары.Количество
			ИНАЧЕ 0
		КОНЕЦ,
		ЛистПереукладкиТовары.Отсканировано
	ИЗ
		Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	ГДЕ
		ЛистПереукладкиТовары.Ссылка.Проведен
		И ЛистПереукладкиТовары.Ссылка.ДокОснование = &amp;ссылка) КАК ТЗСводная

СГРУППИРОВАТЬ ПО
	ТЗСводная.Номенклатура</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>СписокЗНА</name>
    <title>
      <key>ru</key>
      <value>Список ЗНА</value>
    </title>
    <id>4</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СУММА(ЗНМ.Заявка) КАК Заявка,
	СУММА(ЗНМ.ВРаботеНаТСД) КАК ВРаботеНаТСД,
	СУММА(ЗНМ.Собрано) КАК Собрано,
	ЗНМ.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию,
	ЗНМ.ЗаданиеНаАгрегацию.АгрегацииЗаполнены КАК АгрегацииЗаполнены,
	ЗНМ.ЗаданиеНаАгрегацию.ЛистыСозданы КАК ЛистыСозданы
ИЗ
	(ВЫБРАТЬ
		ЗаданиеНаАгрегациюТовары.Номенклатура КАК Номенклатура,
		ЗаданиеНаАгрегациюТовары.Количество * ЗаданиеНаАгрегациюТовары.Ссылка.КоличествоКоробок КАК Заявка,
		0 КАК ВРаботеНаТСД,
		0 КАК Собрано,
		ЗаданиеНаАгрегациюТовары.Ссылка КАК ЗаданиеНаАгрегацию
	ИЗ
		Документ.ЗаданиеНаАгрегацию.Товары КАК ЗаданиеНаАгрегациюТовары
	ГДЕ
		ЗаданиеНаАгрегациюТовары.Ссылка.ДокОснование = &amp;Ссылка
		И ЗаданиеНаАгрегациюТовары.Ссылка.Проведен
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ЛистПереукладкиТовары.Номенклатура,
		0,
		ВЫБОР
			КОГДА ЛистПереукладкиТовары.Ссылка.ОтправленНаТСД
					И ЛистПереукладкиТовары.Количество &lt;> ЛистПереукладкиТовары.Отсканировано
				ТОГДА ЛистПереукладкиТовары.Количество
			ИНАЧЕ 0
		КОНЕЦ,
		ЛистПереукладкиТовары.Отсканировано,
		ЛистПереукладкиТовары.Ссылка.ЗаданиеНаАгрегацию
	ИЗ
		Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	ГДЕ
		ЛистПереукладкиТовары.Ссылка.Проведен
		И ЛистПереукладкиТовары.Ссылка.ДокОснование = &amp;ссылка) КАК ЗНМ

СГРУППИРОВАТЬ ПО
	ЗНМ.ЗаданиеНаАгрегацию,
	ЗНМ.ЗаданиеНаАгрегацию.АгрегацииЗаполнены,
	ЗНМ.ЗаданиеНаАгрегацию.ЛистыСозданы</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
