&НаКлиенте
Процедура ВернутьКодыЧЗВРезерв(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ДокОснование) Тогда
		
		Сообщить("Не указан док.основание!");
		
		Возврат;
		
	КонецЕсли;
	
	ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Объект.ДокОснование);
	
	Если Не ДопПараметрыНакладной.ОтгрузкаFBS Тогда
		
		Сообщить("Очистка разрешена только для FBS!");
		
		Возврат;
		
	КонецЕсли;
		
	ТекстОповещения = ВернутьКодыЧЗВРезервНаСервере();
	
	Если ЗначениеЗаполнено(ТекстОповещения) Тогда
		
		Сообщить(ТекстОповещения);
		
	КонецЕсли;
	
КонецПроцедуры

// Кельманов А.В. - ИЗМ-0000000063 - 2026.06.22
&НаСервере
Функция ВернутьКодыЧЗВРезервНаСервере()
	
	ТекстОповещения = "";
	МассивТекстов = Новый Массив;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Лист.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки КАК Лист
	|ГДЕ
	|	Лист.ДокОснование = &Накладная
	|	И Лист.Проведен";
	
	Запрос.УстановитьПараметр("Накладная", Объект.ДокОснование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ЛистОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		ЛистОбъект.ШтрихкодыУпаковок.Очистить();
		ЛистОбъект.Товары.Очистить();
		
		ЛистОбъект.ЛСК = ПредопределенноеЗначение("Документ.ЛистСборкиКомплектовЧЗ.ПустаяСсылка");
		ЛистОбъект.Завершен = Ложь;
		ЛистОбъект.Проведен = Ложь;
		ЛистОбъект.ПометкаУдаления = Истина;
		
		ЛистОбъект.Записать();
		
		МассивТекстов.Добавить("Очищен "+ЛистОбъект);
		
	КонецЦикла;
	
	Если ПолучитьРеквизитШапки(Объект.ДокОснование, "ОтгрузкаКомплектов", "Документ") Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	Лист.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистСборкиКомплектовЧЗ КАК Лист
		|ГДЕ
		|	Лист.ДокОснование.ДокОснование = &Накладная
		|	И Лист.Проведен";
		
		Запрос.УстановитьПараметр("Накладная", Объект.ДокОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ЛистОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ЛистОбъект.ШтрихкодыУпаковок.Очистить();
			ЛистОбъект.Товары.Очистить();
			
			ЛистОбъект.ЛистНабора = Неопределено; // Кельманов А.В. - Оптимизация работы - 2026.07.08
			
			ЛистОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			МассивТекстов.Добавить("Очищен " + ЛистОбъект);
			
		КонецЦикла;

		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	ЗСБ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаданиеНаСборкуКомплектовЧЗ КАК ЗСБ
		|ГДЕ
		|	ЗСБ.ДокОснование = &Накладная
		|	И ЗСБ.Проведен";
		
		Запрос.УстановитьПараметр("Накладная", Объект.ДокОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ДокОбъект.ШтрихкодыУпаковок.Очистить();
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			МассивТекстов.Добавить("Очищен " + ДокОбъект);
			
		КонецЦикла;

		Документы.ЗаданиеНаСборкуКомплектовЧЗ.НайтиСоздатьДокНаРезервированиеКомплектовПодОтгрузку(Объект.ДокОснование);
		
	КонецЕсли;
	
	Если МассивТекстов.Количество() > 0 Тогда                 
		
		ТекстОповещения = СтрСоединить(МассивТекстов, Символы.ПС);
		
	КонецЕсли;
	
	Возврат ТекстОповещения;
	
КонецФункции
