&НаКлиенте
Процедура ЗаполнитьЛистыПереукладки(Команда)
	Результат = ЗаполнитьЛистыПереукладкиНаСервере();
	если не Результат.Успех тогда
		Сообщить(СтрСоединить(Результат.Ошибки,символы.ПС));
	КонецЕсли;
КонецПроцедуры

