  <attributes>
    <name>СписокЛистовПереукладки</name>
    <title>
      <key>ru</key>
      <value>Список листов переукладки</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЛистПереукладки.Ссылка КАК Ссылка,
	ЛистПереукладки.Проведен КАК Проведен,
	ЛистПереукладки.Автор КАК Автор,
	ЛистПереукладки.КоличествоДокумента КАК КоличествоДокумента,
	ЛистПереукладки.ГруппыТоваров КАК ГруппыТоваров,
	ЛистПереукладки.ОтправленНаТСД КАК ОтправленНаТСД,
	ЛистПереукладки.ЗагруженИзТСД КАК ЗагруженИзТСД,
	ЛистПереукладки.ЗаданиеНаАгрегацию КАК ЗаданиеНаАгрегацию,
	ЛистПереукладки.РабочееМесто КАК РабочееМесто,
	ЛистПереукладки.СканировщикФизЛицо КАК Сканировщик,
	ЛистПереукладки.НомерКоробки КАК НомерКоробки
ИЗ
	Документ.ЛистПереукладки КАК ЛистПереукладки
ГДЕ
	ЛистПереукладки.ЗаданиеНаАгрегацию = &amp;Ссылка</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>ПланФакт</name>
    <title>
      <key>ru</key>
      <value>Список листов переукладки</value>
    </title>
    <id>3</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ТЗСводная.Номенклатура КАК Номенклатура,
	СУММА(ТЗСводная.Заявка) КАК Заявка,
	СУММА(ТЗСводная.ВРаботеНаТСД) КАК ВРаботеНаТСД,
	СУММА(ТЗСводная.Собрано) КАК Собрано
ИЗ
	(ВЫБРАТЬ
		ЗаданиеНаАгрегациюТовары.Номенклатура КАК Номенклатура,
		ЗаданиеНаАгрегациюТовары.Количество * ЗаданиеНаАгрегациюТовары.Ссылка.КоличествоКоробок КАК Заявка,
		0 КАК ВРаботеНаТСД,
		0 КАК Собрано
	ИЗ
		Документ.ЗаданиеНаАгрегацию.Товары КАК ЗаданиеНаАгрегациюТовары
	ГДЕ
		ЗаданиеНаАгрегациюТовары.Ссылка = &amp;Ссылка
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ЛистПереукладкиТовары.Номенклатура,
		0,
		ВЫБОР
			КОГДА ЛистПереукладкиТовары.Ссылка.ОтправленНаТСД
					И ЛистПереукладкиТовары.Количество &lt;> ЛистПереукладкиТовары.Отсканировано
				ТОГДА ЛистПереукладкиТовары.Количество
			ИНАЧЕ 0
		КОНЕЦ,
		ЛистПереукладкиТовары.Отсканировано
	ИЗ
		Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	ГДЕ
		ЛистПереукладкиТовары.Ссылка.Проведен
		И ЛистПереукладкиТовары.Ссылка.ЗаданиеНаАгрегацию = &amp;ссылка) КАК ТЗСводная

СГРУППИРОВАТЬ ПО
	ТЗСводная.Номенклатура</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
