Процедура ПрописатьЗначенияВычерковВРегистр() Экспорт
	
	// проставляем доп. реквизиты в РКм и КЦН.
	ТекущаяДатаЗапрета=КонецДня(Константы.ДатаЗапретаРедактирования.Получить());
	
	Для каждого ТекСтрока из  заявка цикл
		
		Если ТекСтрока.Накладная.метаданные().Имя = "РасходнаяНакладная" или текстрока.УчитыватьВРНК.Пустая() Тогда
			продолжить;
		КонецЕсли;
		
		// проверим, что документы в открытом периоде.
		ДатаДок = ТекСтрока.Накладная.Дата;
		ПустоеЗначениеУчета = ПолучитьДанныеРегистраУчитыватьВычерки(ТекСтрока.Накладная);
		// пока не было записи у документа в регистр учитывать в рнк.
		Если  (ДатаДок>ТекущаяДатаЗапрета и ПустоеЗначениеУчета = перечисления.УчитыватьВРНК.ПустаяСсылка()) 
			//1. для сотрудников ПРО разрешаем менять значение в ркм и кнц в открытом периоде.
			//2. в закрытом только у сотрудников бухгалтерии это право
			ИЛИ (ДатаДок>ТекущаяДатаЗапрета и ПолучитьПолномочиеПользователя("РедактированиеВидаПечатиДокУКонтрагента"))
			или (ПолучитьПолномочиеПользователя("РедактированиеВычерковБухгалтериейВЗакрытомПериоде"))
			Тогда
			
			// нечаева 22,11,16+++
			// переделываем на регистр.
			НаборЗаписей = РегистрыСведений.УчитыватьВычеркиВТорг12.СоздатьНаборЗаписей(); 
			
			НаборЗаписей.Отбор.Документ.Установить(ТекСтрока.Накладная); 
			
			НоваяЗапись = НаборЗаписей.Добавить(); 
			НоваяЗапись.Значение = Текстрока.УчитыватьВРНК; 
			НоваяЗапись.Документ = ТекСтрока.Накладная; 
			НоваяЗапись.ДатаУстановкиРеквизита = текущаяДата();
			
			НаборЗаписей.Записать(); 
			
			// нечаева 22,11,16---
			
			// помечаем на удаление КСФ, если статус "Учитывать в Торг-12".
			Если ТекСтрока.УчитыватьВРНК = перечисления.УчитыватьВРНК.УчитыватьВТорг12  Тогда
				// помечаем на удаление					
				КСФ=Неопределено;
											
				// по указанию от Коноваловой, больше не помечаем на удаление
				// Нечаева 25,12,24 +++
				//КСФ=КСчетФактураНакладной(ТекСтрока.Ссылка,);
				//Если НЕ КСФ.Пустая() Тогда
				//	// снимаем проведение
				//	КСФ_Объект=КСФ.ссылка.получитьОбъект();
				//	КСФ_Объект.пометкаУдаления = истина;
				//	КСФ_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения,РежимПроведенияДокумента.Неоперативный);
				//КонецЕсли;
				// Нечаева 25,12,24 ---

			иначе
				// проводим
				КСФ=Неопределено;
				
				КСФ=КСчетФактураНакладной(ТекСтрока.Накладная.Ссылка,);
				//крохин начало 10.06.2019
				//проводим только непроведенные
				//Если НЕ КСФ.Пустая() Тогда
				Если НЕ КСФ.пустая() И НЕ КСФ.Проведен Тогда
				//крохин конец 10.06.2019	
					// снимаем проведение
					КСФ_Объект=КСФ.ссылка.получитьОбъект();
					КСФ_Объект.пометкаУдаления = ложь;
					КСФ_Объект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
				КонецЕсли;	
			КонецЕсли;
			
			
		иначе
			//сообщить("Статус документа вычерка не записан, закрытый период. Обратитесь в отдел ПРО."+ТекСтрока.Накладная);  
			//Отказ = истина;
			// на период тестов оставим сообщение
		КонецЕсли;
		
		//для сотрудников ПРО разрешаем менять в открытом периоде данные, по РКМ и КЦН, в заявке на ТСД.
		// в закрытом только у сотрудников бухгалтерии это право
		//или ПолучитьПолномочиеПользователя("РедактированиеВидаПечатиДокУКонтрагента") Тогда
		
		
	КонецЦикла;
	
КонецПроцедуры
