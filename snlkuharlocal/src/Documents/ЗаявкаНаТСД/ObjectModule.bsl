Процедура ПриКопировании(ОбъектКопирования)
	Для Каждого стр из Заявка Цикл
		стр.Выполнено = Ложь;
		стр.ДатаИсполнения = Дата(1,1,1);
		стр.Исполнитель = Справочники.Пользователи.ПустаяСсылка();
		//нечаева 20,12,16 +++
		Если Стр.Накладная.Метаданные().имя = "КЦН" или Стр.Накладная.Метаданные().имя = "РКМ" Тогда
			стр.УчитыватьВРНК = ПолучитьДанныеРегистраУчитыватьВычерки(Стр.Накладная);
			Если стр.УчитыватьВРНК = перечисления.УчитыватьВРНК.ПустаяСсылка() Тогда
				стр.УчитыватьВРНК = Перечисления.УчитыватьВРНК.КСФ;
			КонецЕсли;
		КонецЕсли;
		//нечаева 20,12,16 --
		
	КонецЦикла;
КонецПроцедуры //Катаев- 14/04/14


Функция ПолучитьНомерМетро(Накладная)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &Документ
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита";
	Запрос.УстановитьПараметр("ИмяРеквизита", "НомерПриемкиМетро");
	//крохин начало 25.07.2017
	//для РКМ и КЦН номер приемки из РНК
	//Запрос.УстановитьПараметр("Документ", Накладная);
	Если Накладная.Метаданные().Имя = "РасходнаяНакладная" Тогда
		Запрос.УстановитьПараметр("Документ", Накладная);
	Иначе
	    Запрос.УстановитьПараметр("Документ", Накладная.ДокОснование);	
	КонецЕсли;
	//крохин конец 25.07.2017
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЗначениеРеквизита;
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции
