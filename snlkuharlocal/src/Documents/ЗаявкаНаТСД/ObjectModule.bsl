Функция ПолучитьДанныеРегистраУчитыватьВычерки(Док) Экспорт
	
	УчитыватьВРНк = Перечисления.УчитыватьВРНК.ПустаяСсылка();
	
	запрос  = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	УчитыватьВычеркиВТорг12.Значение
	|ИЗ
	|	РегистрСведений.УчитыватьВычеркиВТорг12 КАК УчитыватьВычеркиВТорг12
	|ГДЕ
	|	УчитыватьВычеркиВТорг12.Документ.ссылка = &Документ";
	
	Запрос.УстановитьПараметр("Документ",Док.ссылка);
	Рез = Запрос.Выполнить().выбрать();
	Если Рез.Следующий() Тогда
		УчитыватьВРНК = Рез.Значение;
	КонецЕсли;
	
	возврат учитыватьВРНК;
	
КонецФункции
