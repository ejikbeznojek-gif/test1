Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ВсеИсполнено = Истина;
	колЗ = Заявка.Количество();
	Если колЗ <> 0 Тогда
		кол = 0;
		Для каждого стр из Заявка  Цикл
			Если не стр.Выполнено Тогда
				ВсеИсполнено = Ложь;
				кол = кол+1;
			КонецЕсли;
		КонецЦикла;
		Если Не ВсеИсполнено Тогда
			Если кол <> колЗ тогда
				СостояниеДокумента = "Выполнена частично";
			КонецЕсли;
		Иначе
			СостояниеДокумента = "Выполнена";
		КонецЕсли;
	КонецЕсли;
	//Кухарь 25.04.18 Начало
	//Будем фиксировать сколько заняла печать каждой накладной
	Трудозатраты=Заявка.Итог("Трудозатраты");
	//Кухарь 25.04.18 Конец
	
	//крохин начало 14.06.2020
	//требуется изменение статуса претензии
	Если Не ОбменДанными.Загрузка И РежимЗаписи=РежимЗаписиДокумента.Проведение Тогда
		Для Каждого СтрокаЗаявки Из Заявка Цикл
			Если СтрокаЗаявки.Накладная.Метаданные().Имя = "РекламационнаяНакладная" Тогда
				ПретензияПолучателя = СтрокаЗаявки.Накладная.ПретензияПолучателя;
				Если НЕ ПретензияПолучателя.Пустая() И ПретензияПолучателя.Проведен  И ПретензияПолучателя.СтатусПретензии <> Перечисления.СтатусыПретензииПокупателя.Завершена Тогда
					КоличествоПретензияПолучателя = 0;
					ВсегоПретензияПолучателя = 0;
					ДокПретензияПолучателя = ПретензияПолучателя.ПолучитьОбъект();
					Для Каждого СтрокаТЧ Из ПретензияПолучателя.Товары Цикл
						Если СтрокаТЧ.Решение = Перечисления.СостоянияКоррекции.Принята Тогда
							КоличествоПретензияПолучателя = КоличествоПретензияПолучателя + СтрокаТЧ.Количество;
							ВсегоПретензияПолучателя = ВсегоПретензияПолучателя + СтрокаТЧ.Всего;
						КонецЕсли;
					КонецЦикла;
					Если СтрокаЗаявки.Накладная.КоличествоДокумента = КоличествоПретензияПолучателя И СтрокаЗаявки.Накладная.СуммаДокумента = ВсегоПретензияПолучателя Тогда
						ДокПретензияПолучателя.СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.Завершена;
						ДокПретензияПолучателя.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//крохин конец 14.06.2020
	
	
КонецПроцедуры

