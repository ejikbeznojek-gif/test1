Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	
	Если ПланыОбмена.Основной.ЭтотУзел() <> ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
		УзелПолучатель = ПланыОбмена.Основной.НайтиПоКоду("SNL");
		ПланыОбмена.ЗарегистрироватьИзменения(УзелПолучатель, ЭтотОбъект.Ссылка);
	КонецЕсли;
	
	// это в ЦО должно происходить?
	
	Если НЕ ОбменДанными.Загрузка Тогда
				
		#если клиент Тогда
			
			// только если в документе поменяли значение. тогда только Кудряшов может.
			// Для все строк проверим изменение
			НетИзмененийСтатусовВычерков = истина;
			
			Для каждого ТекСтрока из  заявка цикл
				
				Если ТекСтрока.Накладная.метаданные().Имя = "РасходнаяНакладная" или текстрока.УчитыватьВРНК.Пустая() Тогда
					продолжить;
				КонецЕсли;
				
				ТекЗначениеУчета = ПолучитьДанныеРегистраУчитыватьВычерки(ТекСтрока.Накладная);
				// сравним из регистра, и из строки
				Если  ТекЗначениеУчета <> перечисления.УчитыватьВРНК.ПустаяСсылка() Тогда
					
					Если ТекСтрока.УчитыватьВРНК <> ТекЗначениеУчета тогда
						// если значения поменялись
						НетИзмененийСтатусовВычерков = Ложь;
						
					КонецЕсли;
				иначе
					//если пустые значения есть, то пишем изменения.
					НетИзмененийСтатусовВычерков = Ложь;
				КонецЕсли;
				
			КонецЦикла;
			
			
			Если Не НетИзмененийСтатусовВычерков Тогда
				
				ПрописатьЗначенияВычерковВРегистр();
				
			КонецЕсли;
			
		#КонецЕсли
		//нечаева 16,12,16--
		Для Каждого СтрокаНакладной Из Заявка Цикл
			
			Если СтрокаНакладной.Накладная.Метаданные().Имя = "РасходнаяНакладная" Тогда
				продолжить;
			КонецЕсли;	
			
			// получаем статус РКМ и КЦН
			ЗнРеквизита = ПолучитьДанныеРегистраУчитыватьВычерки(СтрокаНакладной.Накладная);
			
			Если ЗнРеквизита = перечисления.УчитыватьВРНК.УчитыватьВТорг12 Тогда
				
				Накладная=СтрокаНакладной.Накладная.ДокОснование; // для РНК ставим этот статус
				Если Накладная<>Неопределено И ЕстьРеквизитДокумента("СостояниеДокументов",Накладная.Метаданные()) Тогда
					НакладнаяОбъект = Накладная.ПолучитьОбъект();
					НакладнаяОбъект.УстановитьСостояниеДокументов(Перечисления.СостояниеДокументов.ВнесеныИзменения,Неопределено,Истина);
				КонецЕсли;
				
			КонецЕсли;
			
			
		КонецЦикла;

		
		
	КонецЕсли;	
	// 25,11,16--- 
	
	
	
КонецПроцедуры

