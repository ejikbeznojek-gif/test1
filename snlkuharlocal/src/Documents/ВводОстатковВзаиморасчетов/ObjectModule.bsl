Перем НеКонтролироватьЗапись;
//Катаев- 08/08/14

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	//Катаев+ 08/08/14 Добавил проверку на атвоматическое создание документа на основании "Передача контрагента
	//Если НЕ ОбменДанными.Загрузка Тогда
	Если НЕ ОбменДанными.Загрузка и Не НеКонтролироватьЗапись Тогда
		//Катаев- 08/08/14
		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;
	
	СуммаДокумента=Взаиморасчеты.Итог("СуммаУпр");	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	Если ВводОстатков Тогда Возврат КонецЕсли; 
	
	Для Каждого СтрокаТЧ Из Взаиморасчеты Цикл
		Движение=Движения.Взаиморасчеты.Добавить();	
		
		Движение.Период			=Дата;
		
			Если Не ПустаяСтрока(СтрокаТЧ.ДокументЗакрытогоПериода) И СтрокаТЧ.ДатаНачалаЗадолженности = Дата(1,1,1) Тогда
			дд = Число(Лев(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,19),2));
			мм = Число(Лев(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,16),2));
			гг = Число(Лев(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,13),4));
			чч = Число(Лев(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,8),2));
			мн = Число(Лев(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,5),2));
			ск = Число(Прав(СтрокаТЧ.ДокументЗакрытогоПериода,2));
			попытка
				ТекДата=Дата(гг, мм, дд, чч, мн, ск);
			Исключение
				дд=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,19,2));
				мм=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,22,2));
				гг=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,25,4));
				чч=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,29,2));
				мн=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,32,2));
				ск=число(сред(СтрокаТЧ.ДокументЗакрытогоПериода,35,2));
				ТекДата=Дата(гг, мм, дд, чч, мн, ск);
			КонецПопытки;
			Движение.Дата_НачалаЗадолженности = ТекДата;
		КонецЕсли;
		
		Движение.Контрагент		=СтрокаТЧ.Контрагент;
		Движение.Договор		=СтрокаТЧ.Договор;
		
		Если СтрокаТЧ.СуммаУпр>0 Тогда
			Движение.СуммаУпр		=СтрокаТЧ.СуммаУпр;
			Движение.СуммаВал		=СтрокаТЧ.СуммаВал;				
			
			Движение.ВидДвижения	=ВидДвиженияНакопления.Приход;
		Иначе
			Движение.СуммаУпр		=-СтрокаТЧ.СуммаУпр;
			Движение.СуммаВал		=-СтрокаТЧ.СуммаВал;				
			
			Движение.ВидДвижения	=ВидДвиженияНакопления.Расход;		
		КонецЕсли;		
		Движение.Дата_НачалаЗадолженности = СтрокаТЧ.ДатаНачалаЗадолженности;
		Движение.Документ_ЗакрытогоПериода = СтрокаТЧ.ДокументЗакрытогоПериода;
	КонецЦикла; 
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
КонецПроцедуры

Процедура ЗаписатьБезПроверки(РежимПроведения) Экспорт
	НеКонтролироватьЗапись = Истина;
	ЭтотОбъект.Записать(РежимПроведения);
	НеКонтролироватьЗапись = Ложь;
КонецПроцедуры

НеКонтролироватьЗапись = Ложь;