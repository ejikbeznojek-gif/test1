Функция ПроверитьОбновитьСостояние(ЗаданиеНаСборку) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Различные Ссылка) КАК КолЛистовСборки
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ.Товары
	|ГДЕ
	|	Ссылка.ДокОснование = &ЗаданиеНаСборку
	|;
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(КолПлан) КАК КолПлан,
	|	СУММА(КолФакт) КАК КолФакт
	|ИЗ
	|(
	|	ВЫБРАТЬ
	|		Номенклатура,
	|		Количество*Коэффициент	КАК КолПлан,
	|		0						КАК КолФакт
	|	ИЗ
	|		Документ.ЗаданиеНаСборкуКомплектовЧЗ.Товары
	|	ГДЕ
	|		Ссылка = &ЗаданиеНаСборку	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	ВЫБРАТЬ
	|		Номенклатура,
	|		0						КАК КолПлан,
	|		Количество*Коэффициент	КАК КолФакт
	|	ИЗ
	|		Документ.ЛистСборкиКомплектовЧЗ.Товары
	|	ГДЕ
	|		Ссылка.ДокОснование = &ЗаданиеНаСборку
	|		И Ссылка.Завершен
	|) КАК Сводный
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ИМЕЮЩИЕ
	|	СУММА(КолПлан) <> СУММА(КолФакт)
	|";
	
	Запрос.УстановитьПараметр("ЗаданиеНаСборку", ЗаданиеНаСборку);	
	
	рЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка 		= рЗапроса[0].Выбрать();
	СборкаНачата	= (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КолЛистовСборки)); 	
	
	Завершен		= (рЗапроса[1].Выбрать().Количество() = 0);
	
	ТекСостояние	= ПолучитьРеквизитШапки(ЗаданиеНаСборку, "СостояниеНакладной");
	НовСостояние	= ТекСостояние;	
	Если Завершен Тогда
		Если ТекСостояние<>Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда
			НовСостояние = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
		КонецЕсли; 			
	Иначе
		Если СборкаНачата Тогда
			Если ТекСостояние <> Перечисления.СостоянияНакладной.Сканирование Тогда
				НовСостояние = Перечисления.СостоянияНакладной.Сканирование;			
			КонецЕсли;		
		КонецЕсли;
	КонецЕсли;
	
	Если ТекСостояние <> НовСостояние Тогда
		УстановитьРеквизитШапки(ЗаданиеНаСборку, "СостояниеНакладной", НовСостояние);	
	КонецЕсли; 
	
КонецФункции

