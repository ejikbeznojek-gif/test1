Функция ЗаполнитьКодыЧЗВЗСБ(ДокументЗСБ_Объект, ДокОснование_ссылка) Экспорт

	СтруктураОтвета=новый Структура("Успех,Ошибки,Ссылка",Истина,"");
	
	ТаблицаПереопределяемыхДат=МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(ДокОснование_ссылка,"Товары");	
	
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ТЗ.Номенклатура КАК Номенклатура,
	             |	ТЗ.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
	             |ПОМЕСТИТЬ ТЗ_ДатМаркировки
	             |ИЗ
	             |	&ТаблицаПереопределяемыхДат КАК ТЗ
	             |ГДЕ
	             |	ТЗ.ДатаНачалаРаботыСМаркировкой <= &ДатаПроверки
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.Владелец КАК Продукция,
	             |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта) КАК КоличествоВЛСК
	             |ПОМЕСТИТЬ ВТ_НоменклатураВЛСК
	             |ИЗ
	             |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	             |ГДЕ
	             |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗСБ
	             |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
	             |	И НЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.ВерсияДанных ЕСТЬ NULL
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.Владелец
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	             |	РасходнаяНакладнаяТовары.Количество - ЕСТЬNULL(ВТ_НоменклатураВЛСК.КоличествоВЛСК, 0) КАК Количество
	             |ПОМЕСТИТЬ ТЧ_Накладной
	             |ИЗ
	             |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	             |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НоменклатураВЛСК КАК ВТ_НоменклатураВЛСК
	             |		ПО РасходнаяНакладнаяТовары.Номенклатура = ВТ_НоменклатураВЛСК.Продукция
	             |ГДЕ
	             |	РасходнаяНакладнаяТовары.Ссылка = &ДокОснование_ссылка
	             |	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидКомплекта = &Комплект
	             |	И РасходнаяНакладнаяТовары.Количество - ЕСТЬNULL(ВТ_НоменклатураВЛСК.КоличествоВЛСК, 0) > 0
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ТЧ_Накладной.Номенклатура КАК Номенклатура,
	             |	ТЧ_Накладной.Количество КАК Количество
	             |ИЗ
	             |	ТЗ_ДатМаркировки КАК ТЗ_ДатМаркировки
	             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЧ_Накладной КАК ТЧ_Накладной
	             |		ПО ТЗ_ДатМаркировки.Номенклатура = ТЧ_Накладной.Номенклатура";
	запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат",ТаблицаПереопределяемыхДат);
	запрос.УстановитьПараметр("Комплект",Перечисления.ВидыКомплектов.Комплект);
	запрос.УстановитьПараметр("ДокОснование_ссылка",ДокОснование_ссылка);
	запрос.УстановитьПараметр("ЗСБ",ДокументЗСБ_Объект.Ссылка);
	
	// Кельманов А.В. - HELP-4849 - 2026.04.28 {
	//запрос.УстановитьПараметр("ДатаПроверки",ПолучитьРеквизитШапки(ДокОснование_ссылка,"ДатаОтгрузки","Документ"));
	Если ТипЗнч(ДокОснование_ссылка) = Тип("ДокументСсылка.Комплектация") Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "РасходнаяНакладная", "Комплектация");
		
		Запрос.УстановитьПараметр("ДатаПроверки", ПолучитьРеквизитШапки(ДокОснование_ссылка, "Дата", "Документ"));
		
	Иначе
		
		Запрос.УстановитьПараметр("ДатаПроверки", ПолучитьРеквизитШапки(ДокОснование_ссылка, "ДатаОтгрузки", "Документ"));
		
	КонецЕсли;
	// Кельманов А.В. - HELP-4849 - 2026.04.28 }
	
	Выборка=запрос.Выполнить().Выбрать();
	
	   
	// Кухарь А.Ю.  29.03.2025 начало
	МассивНоменклатуры=новый Массив;
	пока Выборка.Следующий() цикл
		для сч=1 по Выборка.Количество цикл
			МассивНоменклатуры.Добавить(Выборка.Номенклатура);
		КонецЦикла;
	КонецЦикла;
	
	Выборка.Сбросить();
	
	ДопПараметры=новый Структура("НовыйСтатус,ТипКода,Добавлять"
	,Перечисления.СтатусыКодовМаркировкиФакт.Зарезервирован,Перечисления.ТипыКодовМаркировки.Набор,Истина);
	
	РезультатПолученияКодов=Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(МассивНоменклатуры,ДокументЗСБ_Объект.Ссылка,ДопПараметры);		
	если не РезультатПолученияКодов.Успешно тогда
		Сообщить(СтрСоединить(РезультатПолученияКодов.Ошибки,символы.ПС));
		СтруктураОтвета.Успех=ложь;
		возврат СтруктураОтвета;
	иначе
		пока Выборка.Следующий() цикл		
			Для каждого СтрокаДанных из РезультатПолученияКодов.Данные.получить(Выборка.Номенклатура) цикл
				СтрТЧ=ДокументЗСБ_Объект.ШтрихкодыУпаковок.Добавить();
				СтрТЧ.ШтрихкодУпаковки=СтрокаДанных;
				СтрТЧ.ЗабронированПодСборку = Истина;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;	
	
	ДокументЗСБ_Объект.Проведен=Истина;
	ДокументЗСБ_Объект.Записать();
	
	// Кухарь А.Ю. 20.10.2025 начало 
	//HELP-7517
	СтруктураОтвета.Ссылка = ДокументЗСБ_Объект.Ссылка;
	// Кухарь А.Ю. 20.10.2025 конец
	
	СтруктураОтвета.Ошибки=СтрСоединить(РезультатПолученияКодов.Ошибки,Символы.ПС);
	возврат СтруктураОтвета;
	
КонецФункции

