Функция НайтиСоздатьЗаданиеНаСборку(ДокОснование) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ЗначениеЗаполнено(ДокОснование) Тогда
		ТипОснования = ТипЗнч(ДокОснование); 
		Если Метаданные.Документы.ЗаданиеНаСборкуКомплектовЧЗ.Реквизиты.ДокОснование.Тип.СодержитТип(ТипОснования) Тогда
			ТребуетсяМаркировка = Истина;
			
			Если ЕстьРеквизитДокумента("ТребуетсяМаркировка", Метаданные.НайтиПоТипу(ТипОснования)) Тогда
				ТребуетсяМаркировка = ПолучитьРеквизитШапки(ДокОснование, "ТребуетсяМаркировка"); 			
			КонецЕсли; 
			
			Если ТребуетсяМаркировка Тогда
				Задание = ЗСБЧЗПоОснованию(ДокОснование);
				Если ЗначениеЗаполнено(Задание) Тогда
					Результат.Данные = Задание;
				Иначе
					// Кельманов А.В. - HELP-5168 - 2025.06.03 {
					//ДокОбъект = Документы.ЗаданиеНаСборкуКомплектовЧЗ.СоздатьДокумент();
					//ДокОбъект.Заполнить(ДокОснование);			
					//
					//Попытка			
					//	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);			
					//	Результат.Данные = ДокОбъект.Ссылка;
					//Исключение
					//	Результат.Ошибки.Добавить("Не удалось провести задание ! " + ОписаниеОшибки());			
					//КонецПопытки;
					СтруктураОтвета = НайтиСоздатьДокНаРезервированиеКомплектовПодОтгрузку(ДокОснование);
					
					Если СтруктураОтвета.Успех Тогда
						Результат.Данные = СтруктураОтвета.Ссылка;
					Иначе
						Результат.Ошибки.Добавить(СтруктураОтвета.Ошибки);
					КонецЕсли;
					// Кельманов А.В. - HELP-5168 - 2025.06.03 }
				КонецЕсли;
			Иначе
				Результат.Ошибки.Добавить("По выбранному документу маркировка не требуется !");
			КонецЕсли;
		Иначе	
			Результат.Ошибки.Добавить(СтрШаблон("Не допустимый тип основания для ЗСБ: '%1' !", ТипОснования));
		КонецЕсли;		
	Иначе
		Результат.Ошибки.Добавить("Не указано основание для ЗСБ !");
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;	
КонецФункции //НайтиСоздатьЗадание(ДокОснование)
 

// Кельманов А.В. - MARK-766 - 2025.01.28
Функция ЗСБЧЗПоОснованию(Основание) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНаСборкуКомплектовЧЗ.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ЗаданиеНаСборкуКомплектовЧЗ КАК ЗаданиеНаСборкуКомплектовЧЗ
	               |ГДЕ
	               |	ЗаданиеНаСборкуКомплектовЧЗ.Проведен
	               |	И ЗаданиеНаСборкуКомплектовЧЗ.ДокОснование = &ДокОснование";
	
	Запрос.УстановитьПараметр("ДокОснование", Основание);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Выборка.Ссылка;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Кельманов А.В. - MARK-766 - 2025.01.30
Функция ПроверитьЗСБЧЗ(ЗСБЧЗ, Основание) Экспорт
	
	ТекстОшибки = "";
	
	Если ЗСБЧЗ = Неопределено Тогда
		
		ЗСБЧЗ = Документы.ЗаданиеНаСборкуКомплектовЧЗ.ПустаяСсылка();
		
	КонецЕсли;
	
	ТаблицаПереопределяемыхДат = МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(Основание, "Товары");	
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
	               |ПОМЕСТИТЬ ТЗ_ДатМаркировки
	               |ИЗ
	               |	&ТаблицаПереопределяемыхДат КАК ТЗ
	               |ГДЕ
	               |	ТЗ.ДатаНачалаРаботыСМаркировкой <= &ДатаПроверки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	               |	РасходнаяНакладнаяТовары.Количество КАК Количество
	               |ПОМЕСТИТЬ ТЧ_Накладной
	               |ИЗ
	               |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	               |ГДЕ
	               |	РасходнаяНакладнаяТовары.Ссылка = &Основание
	               |	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидКомплекта = &Комплект
	               |	И РасходнаяНакладнаяТовары.Количество > 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЧ_Накладной.Номенклатура КАК Номенклатура,
	               |	СУММА(ТЧ_Накладной.Количество) КАК Количество
	               |ПОМЕСТИТЬ ВТ_ТребуютсяКодыЧЗ
	               |ИЗ
	               |	ТЗ_ДатМаркировки КАК ТЗ_ДатМаркировки
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЧ_Накладной КАК ТЧ_Накладной
	               |		ПО ТЗ_ДатМаркировки.Номенклатура = ТЧ_Накладной.Номенклатура
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТЧ_Накладной.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК ШтрихкодУпаковкиВладелец,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки) КАК КоличествоКодовВЗСБ
	               |ПОМЕСТИТЬ ВТ_КодыЗСБ
	               |ИЗ
	               |	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок
	               |ГДЕ
	               |	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЗСБЧЗ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ТребуютсяКодыЧЗ.Номенклатура КАК Номенклатура,
	               |	ВТ_ТребуютсяКодыЧЗ.Количество КАК Количество,
	               |	ЕСТЬNULL(ВТ_КодыЗСБ.КоличествоКодовВЗСБ, 0) КАК КоличествоКодовВЗСБ
	               |ИЗ
	               |	ВТ_ТребуютсяКодыЧЗ КАК ВТ_ТребуютсяКодыЧЗ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КодыЗСБ КАК ВТ_КодыЗСБ
	               |		ПО ВТ_ТребуютсяКодыЧЗ.Номенклатура = ВТ_КодыЗСБ.ШтрихкодУпаковкиВладелец
	               |ГДЕ
	               |	ВТ_ТребуютсяКодыЧЗ.Количество > ЕСТЬNULL(ВТ_КодыЗСБ.КоличествоКодовВЗСБ, 0)";
	
	Запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат", ТаблицаПереопределяемыхДат);
	Запрос.УстановитьПараметр("Комплект", Перечисления.ВидыКомплектов.Комплект);
	Запрос.УстановитьПараметр("Основание", Основание);
	Запрос.УстановитьПараметр("ЗСБЧЗ", ЗСБЧЗ);
	Запрос.УстановитьПараметр("ДатаПроверки", ПолучитьРеквизитШапки(Основание, "ДатаОтгрузки", "Документ"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ТекстОшибки = ТекстОшибки + СтрШаблон("Для спайки %1 в ЗСБ недостаточно кодов. Необходимо - %2, в ЗСБ - %3",
		Выборка.Номенклатура, Выборка.Количество, Выборка.КоличествоКодовВЗСБ) + Символы.ПС;
		
	КонецЦикла;
	
	Возврат ТекстОшибки;
	
КонецФункции



