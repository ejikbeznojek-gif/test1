Функция СоздатьРазагрегациюГотовыхНаборов(Знач ЗСБ) Экспорт
	 
	 Результат = МаркировкаКС.СтруктураРезультата();
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ РАЗЛИЧНЫЕ
	 //|	ВложенныеШтрихкодыШК.Штрихкод КАК ШтрихкодУпаковки,
	 |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	 |ИЗ
	 |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	 |		ПО (СпрНоменклатура.Ссылка = ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец)
	 |			И (СпрНоменклатура.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкодыШК
	 |		ПО (ВложенныеШтрихкодыШК.Ссылка = ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки)
	 |ГДЕ
	 |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗаданиеНаСборку
	 |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Завершен
	 |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
	 |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)";
	 
	 Запрос.УстановитьПараметр("ЗаданиеНаСборку", ЗСБ);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 
	 Если НЕ РезультатЗапроса.Пустой() Тогда
		 
		 ШКДляМаркировкиТоваров = РезультатЗапроса.Выгрузить(); 
		 
		 Запрос = Новый Запрос;
		 Запрос.Текст = 
		 "ВЫБРАТЬ
		 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка КАК Ссылка
		 |ИЗ
		 |	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		 |ГДЕ
		 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ДокументОснование = &ЗаданиеНаСборку
		 |	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.Проведен
		 |	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.РасформированиеУпаковки)
		 |
		 |СГРУППИРОВАТЬ ПО
		 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка";
		 
		 Запрос.УстановитьПараметр("ЗаданиеНаСборку", ЗСБ);
		 
		 Выборка = Запрос.Выполнить().Выбрать(); 
		 
		 Если Выборка.Следующий() Тогда
			 
			 рШапки		= ПолучитьРеквизитыШапки(Выборка.ссылка, "Статус"); 
			 
			 Если рШапки.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда 			
				 ДокМаркировкиОбъект = Выборка.ссылка.ПолучитьОбъект();
				 ДокМаркировкиОбъект.Товары.Очистить();
				 ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить(); 
			 Иначе
				 
				 ТекстОшибки = СтрШаблон("Недопустимый статус документа: '%1' !", рШапки.Статус);
				 Результат.Ошибки.Добавить(ТекстОшибки);
				 Результат.Успешно = Ложь; 
				 
				 Возврат Результат; 
			 КонецЕсли;
		 Иначе 
			 ДокМаркировкиОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент(); 
		 КонецЕсли;
		 
		 ДокМаркировкиОбъект.Дата	= ТекущаяДатаСеанса(); 			
		 
		 ДокМаркировкиОбъект.Организация	= ЗСБ.Организация;
		 
		 Если ДокМаркировкиОбъект.Организация = Маркировка_ПИ.ОрганизацияБТК() Тогда
			 ДокМаркировкиОбъект.Организация = Маркировка_ПИ.ОрганизацияЕЕЭ();	
		 КонецЕсли;
		 ДокМаркировкиОбъект.ДополнительныеСвойства.Вставить("ЗаполнятьТолькоШапку", Истина);
		 ДокМаркировкиОбъект.Заполнить(ЗСБ);
		 ДокМаркировкиОбъект.ДокументОснование = ЗСБ;
		 ДокМаркировкиОбъект.ПодразделениеНанесения = ЗСБ.Докоснование.Склад.Подразделение;
		 
		 
		 ДокМаркировкиОбъект.ВидОперации		= Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки;
		 ДокМаркировкиОбъект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки;
		 ДокМаркировкиОбъект.Статус			= Перечисления.СтатусыДокументовМаркировки.КОбработке;
		 
		 ДокМаркировкиОбъект.ШтрихкодыУпаковок.Загрузить(ШКДляМаркировкиТоваров); 
		 
		 Попытка
			 ДокМаркировкиОбъект.Записать(РежимЗаписиДокумента.Проведение);
			 Результат.Данные = ДокМаркировкиОбъект.Ссылка;
			 Результат.ОбработаноОбъектов = 1;
		 Исключение
			 
			 ТекстОшибки = "Ошибка проведения документа разагрегации!!! Описание ошибки: " +ОписаниеОшибки(); 
			 Результат.Ошибки.Добавить(ТекстОшибки);
		   
		 КонецПопытки;
		 
	 КонецЕсли;
	 
	 Результат.Успешно = (Результат.Ошибки.Количество() = 0); 
	 
	 Возврат Результат;
КонецФункции 

