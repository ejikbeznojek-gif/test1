Функция ЗарезервироватьКМ(ЗСБ_Ссылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура				КАК Номенклатура,	
	|	СУММА(ТребутсяКМ)			КАК ТребутсяКМ,
	|	СУММА(ЗарезервированоКМ)	КАК ЗарезервированоКМ
	|ИЗ
	|(
	|ВЫБРАТЬ
	|	Номенклатура							КАК Номенклатура,	
	|	0										КАК ТребутсяКМ,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихКодУпаковки)	КАК ЗарезервированоКМ
	|ИЗ
	|	РегистрСведений.РезервыКМ	
	|ГДЕ
	|	Регистратор = &ЗСБ_Ссылка
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Количество	КАК ТребутсяКМ,
	|	0			КАК ЗарезервированоКМ
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.Товары
	|ГДЕ
	|	Ссылка = &ЗСБ_Ссылка
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Количество	КАК ТребутсяКМ,
	|	0			КАК ЗарезервированоКМ
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.Комплектующие
	|ГДЕ
	|	Ссылка = &ЗСБ_Ссылка
	|	И НЕ Ссылка.ИспользоватьМаркированыеКомплектующие
	|) КАК Сводный
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|";
		
	Запрос.УстановитьПараметр("ЗСБ_Ссылка", ЗСБ_Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Количество = Выборка.ТребутсяКМ - Выборка.ЗарезервированоКМ;
		Если Количество > 0 Тогда
			рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Выборка.Номенклатура, ЗСБ_Ссылка, Новый Структура("Количество", Количество));					
			Если рБронирования.Успешно Тогда
			Иначе
				МаркировкаКС.ВывестиОшибки(рБронирования);			
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;	
КонецФункции //ЗарезервироватьКМ(ЗСБ_Ссылка) Экспорт
