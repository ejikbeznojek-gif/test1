Функция ЗаполнитьТЧПоОснованию() Экспорт
// Кельманов А.В. - для возможности заполнить ТЧ по нажатию кнопки - 2025.04.01 }
	Запрос 		 = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	Номенклатура,
	|	Количество КАК Количество,	
	|	Единица, 
	//Валетов + 09,12,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8085
	//|	Коэффициент
	|	1 КАК Коэффициент
	//Валетов -
	|ИЗ
	|	" + ДокОснование.Метаданные().ПолноеИмя() + ".Товары
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|	И ТребуетсяМаркировка
	|	И Количество > 0	
	|;
	|ВЫБРАТЬ
	|	Продукция,
	|	Номенклатура,
	|	Количество КАК Количество,
	|	Единица,
	//Валетов + 09,12,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8085
	//|	Коэффициент
	|	1 КАК Коэффициент
	//Валетов -
	|ИЗ
	|	" + ДокОснование.Метаданные().ПолноеИмя() + ".Комплектующие
	|ГДЕ
	|	Ссылка = &Ссылка	
	|	И Продукция.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|	И ТребуетсяМаркировка
	|	И Количество > 0
	|";		
	
	Запрос.УстановитьПараметр("Ссылка", ДокОснование);
	
	// Кельманов А.В. - HELP-4849 - 2026.04.28 {
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.Комплектация") Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ТребуетсяМаркировка", "");
		
	КонецЕсли;
	// Кельманов А.В. - HELP-4849 - 2026.04.28 }
	
	рЗапроса = Запрос.ВыполнитьПакет();	
	
	Товары.Очистить();
	Комплектующие.Очистить();	
	
	Товары.Загрузить(рЗапроса[0].Выгрузить());
	Комплектующие.Загрузить(рЗапроса[1].Выгрузить());	
КонецФункции //ЗаполнитьТЧПоОснованию()

Процедура ОбработкаУдаленияПроведения(Отказ)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	Если ШтрихкодыУпаковок.Количество() > 0 Тогда
		Сообщить("Запрещено распроводить документ c заполненной ТЧ 'ШтрихкодыУпаковок' !");
		Отказ = Истина;	
	КонецЕсли;
КонецПроцедуры //ОбработкаУдаленияПроведения(Отказ)