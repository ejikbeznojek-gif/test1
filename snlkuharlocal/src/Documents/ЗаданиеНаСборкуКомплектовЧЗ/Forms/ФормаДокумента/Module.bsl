&НаКлиенте
Процедура ЗавершитьМаркировку(Команда)
	Если Модифицированность ИЛИ НЕ Объект.Проведен Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
	
	рПроверки = ВсеЛистыСборкиЗавершены();
	Если рПроверки.Успешно Тогда
		рЗавершения = ЗавершитьМаркировку_НаСервере();
		Если рЗавершения.Успешно Тогда	
			Сообщить("Маркировка завершена.", СтатусСообщения.Информация);
			Сообщить("Сформировано: "+ рЗавершения.ОбработаноОбъектов+" агрегаций.", СтатусСообщения.Информация);
			
			Закрыть();
		Иначе		
			Сообщить(СтрСоединить(рЗавершения.Ошибки, Символы.ПС), СтатусСообщения.Важное);	
		КонецЕсли;
	Иначе
		Сообщить("Обнаружены ошибки ЛМО !", СтатусСообщения.Важное);
		Сообщить(СтрСоединить(рПроверки.Ошибки, Символы.ПС));
	КонецЕсли; 	
	 
КонецПроцедуры

&НаСервере
Функция ВсеЛистыСборкиЗавершены()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,Проведен,Завершен
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ
	|ГДЕ
	|	ДокОснование = &ДокОснование	
	|	И НЕ (Завершен И Проведен)
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", Объект.Ссылка);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ Выборка.Проведен Тогда		
			Результат.Ошибки.Добавить("ЛМО не проведен: " + Выборка.Ссылка + " !");
		КонецЕсли; 					
		Если НЕ Выборка.Завершен Тогда		                                 
			Результат.Ошибки.Добавить("ЛМО не завершен: " + Выборка.Ссылка + " !");
		КонецЕсли;
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ВсеЛистыСборкиЗавершены()
	
&НаСервере
Функция ЗавершитьМаркировку_НаСервере()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	рАгрегации = Документы.ЗаданиеНаМаркировку.Создать_Агрегации(Объект.Ссылка);
	Если рАгрегации.Успешно Тогда
		Результат.ОбработаноОбъектов = рАгрегации.ОбработаноОбъектов;
		
		Объект.СостояниеНакладной 		= Перечисления.СостоянияНакладной.Отгружена;
		Объект.СформированыАгрегации    = Истина;
		Записать();
		
		рХКМ = Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ЗМО(Объект.Ссылка);
		Если НЕ рХКМ.Успешно Тогда
			МаркировкаКС.ДобавитьОшибки(Результат, рХКМ);					
		КонецЕсли; 
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рАгрегации);		
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ЗавершитьМаркировку_НаСервере()

