	КонецЕсли;

	ВыборкаЛСК = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	МассивТекстов = Новый Массив;
	
	Пока ВыборкаЛСК.Следующий() Цикл
		
		ЛСКОбъект = ВыборкаЛСК.ЛСК.ПолучитьОбъект();
		
		Если ЗначениеЗаполнено(ВыбраннаяСпайка) Тогда
			
			Выборка = ВыборкаЛСК.Выбрать();
			
			Пока Выборка.Следующий() Цикл
				
				ПараметрыПоиска = Новый Структура("ШтрихкодУпаковки, ШтрихкодКомплекта", Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(), Выборка.ШтрихкодКомплекта);
				
				МассивСтрокДляУдаления = ЛСКОбъект.ШтрихкодыУпаковок.НайтиСтроки(ПараметрыПоиска);
				
				Для Каждого Строка Из МассивСтрокДляУдаления Цикл
					
					ЛСКОбъект.ШтрихкодыУпаковок.Удалить(Строка);
					
				КонецЦикла;
				
			КонецЦикла;
			
		Иначе
			
			ПараметрыПоиска = Новый Структура("ШтрихкодУпаковки", Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
			
			МассивСтрокДляУдаления = ЛСКОбъект.ШтрихкодыУпаковок.НайтиСтроки(ПараметрыПоиска);
			
			Для Каждого Строка Из МассивСтрокДляУдаления Цикл
				
				ЛСКОбъект.ШтрихкодыУпаковок.Удалить(Строка);
				
			КонецЦикла;
			
		КонецЕсли;
		
		Попытка
			
			ЛСКОбъект.Записать(РежимЗаписиДокумента.Проведение);
						
			Если ЗначениеЗаполнено(ВыбраннаяСпайка) Тогда
				
				МассивТекстов.Добавить("В ЛСК " + ЛСКОбъект.Номер + " для продукции " + ВыбраннаяСпайка + " строки с пустыми кодами комплектующих удалены!");
				
			Иначе
				
				МассивТекстов.Добавить("В ЛСК " + ЛСКОбъект.Номер + " строки с пустыми кодами комплектующих удалены!");
				
			КонецЕсли;
			
		Исключение
			
			МассивТекстов.Добавить("Не удалось записать ЛСК " + ЛСКОбъект.Номер + ": " + ОписаниеОшибки());
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если МассивТекстов.Количество() > 0 Тогда
		
		ТекстСообщения = СтрСоединить(МассивТекстов, Символы.ПС);
		
	КонецЕсли;
	// Кельманов А.В. - ИЗМ-0000000141 - 2026.06.24 }
	
КонецПроцедуры

