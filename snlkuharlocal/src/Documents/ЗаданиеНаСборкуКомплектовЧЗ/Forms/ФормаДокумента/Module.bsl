&НаКлиенте
Процедура Товары_Номенклатура_ПриИзменении(Элемент)
	ТекДанные = Элементы.Продукция.ТекущиеДанные;
	
	Если ТекДанные<>Неопределено Тогда
		Если ЗначениеЗаполнено(ТекДанные.Номенклатура) Тогда
			рНоменклатуры = ПолучитьРеквизитыШапки(ТекДанные.Номенклатура, "ОсновнаяЕдиница,ОсновнаяЕдиница.Коэффициент");					
			ТекДанные.Единица 		= рНоменклатуры.ОсновнаяЕдиница;
			ТекДанные.Коэффициент 	= рНоменклатуры.ОсновнаяЕдиница_Коэффициент;
		Иначе
			ТекДанные.Единица 		= Неопределено;
			ТекДанные.Коэффициент 	= 1;			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

