	ПродукцияТекДанные = Элементы.Продукция.ТекущиеДанные;
	
	Если ПродукцияТекДанные <> Неопределено Тогда
		
		ВыбраннаяСпайка = ПродукцияТекДанные.Номенклатура;
		
		Если ЗначениеЗаполнено(ВыбраннаяСпайка) Тогда
			
			ТекстСообщения = "";
			
			УдалитьИзЛСКСтрокиСПустымиКодамиКомплектующихНаСервере(, ВыбраннаяСпайка, ТекстСообщения);
			
			Если ЗначениеЗаполнено(ТекстСообщения) Тогда
				
				Сообщить(ТекстСообщения);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
