&НаСервере
Процедура ОбновитьКоличествоСобраных_НаСервере()
	рСборки = ПолучитьКоличествоСобраных();
	Для Каждого СтрокаТЧ Из Объект.Товары Цикл
		СтрокаТЧ.СобраноКомплектов = рСборки[СтрокаТЧ.Номенклатура];			
		
		Если СтрокаТЧ.СобраноКомплектов > СтрокаТЧ.Количество Тогда
			СтрокаТЧ.ИндексКартинки = 0; //+			
		ИначеЕсли СтрокаТЧ.СобраноКомплектов < СтрокаТЧ.Количество Тогда
			СтрокаТЧ.ИндексКартинки = 2; //-
		Иначе
			СтрокаТЧ.ИндексКартинки = -1;		
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ТоварыСобраноКомплектов.ТекстПодвала = Формат(Объект.Товары.Итог("СобраноКомплектов"), "ЧРГ=' '; ЧГ=3,0");
КонецПроцедуры //ОбновитьКоличествоСобраных_НаСервере()

&НаСервере
Функция ПолучитьКоличествоСобраных()
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ
	|	ШтрихкодКомплекта.Владелец КАК Продукция,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодКомплекта) КАК СобраноШК
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокОснование
	|	//И Ссылка.Завершен
	|	И Ссылка.Проведен
	|	И НЕ ШтрихкодКомплекта.ВерсияДанных ЕСТЬ NULL			
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодКомплекта.Владелец
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", Объект.Ссылка);
	
	Результат = Новый Соответствие;
	
	Выборка	= Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат[Выборка.Продукция] = Выборка.СобраноШК;	
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ПолучитьКоличествоСобраных_НаСервере()

