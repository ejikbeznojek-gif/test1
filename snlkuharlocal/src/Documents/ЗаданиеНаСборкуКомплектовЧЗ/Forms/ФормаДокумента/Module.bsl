&НаКлиенте
Процедура СоздатьЛистСборки(Команда)
	
	Ошибки = "";
	ТекущиеДанные = Элементы.Продукция.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда                         
		Ошибки = "Не выбрана строка комплекта !";
	ИначеЕсли НЕ ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
		Ошибки = "В выбраной строке не заполнен комплект !";
	КонецЕсли;
	Если НЕ ПустаяСтрока(Ошибки) Тогда
		ПоказатьПредупреждение(, Ошибки);
		Возврат;	
	КонецЕсли;	
	
	Если Объект.Ссылка.Пустая() ИЛИ НЕ Объект.Проведен  Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
	
	// Кельманов А.В. - HELP-4221 - 2025.07.17 {
	//пФормыЛСК = Новый Структура("Основание", Новый Структура("ДокОснование,Продукция,фРежим", Объект.Ссылка, ТекущиеДанные.Номенклатура, 2));
	Если ЭтоСкладМаркированногоТовара Тогда
		пФормыЛСК = Новый Структура("Основание", Новый Структура("ДокОснование,Продукция,фРежим", Объект.Ссылка, Неопределено, 0));
	Иначе
		пФормыЛСК = Новый Структура("Основание", Новый Структура("ДокОснование,Продукция,фРежим", Объект.Ссылка, ТекущиеДанные.Номенклатура, 2));
	КонецЕсли;
	// Кельманов А.В. - HELP-4221 - 2025.07.17 }
	
	ОткрытьФорму("Документ.ЛистСборкиКомплектовЧЗ.ФормаОбъекта", пФормыЛСК);
	
КонецПроцедуры

