Функция НайтиЛистПоКодуАгрегации(Знач КодАгрегации) Экспорт 
	Если Не ЗначениеЗаполнено(КодАгрегации) Тогда
		Возврат Неопределено; 
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|		ПО (ПриходнаяНакладная.Ссылка = ЛистНабора.ДокОснование)
		|			И (ПриходнаяНакладная.Проведен)
		|			И (ПриходнаяНакладная.КодОперации = &КодОперации)
		|ГДЕ
		|	ЛистНабора.КодАгрегации = &КодАгрегации
		|	И ЛистНабора.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛистНабора.Ссылка
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|		ПО (ПриходнаяНакладная.Ссылка = ЛистНабора.ДокОснование)
		|			И (ПриходнаяНакладная.Проведен)
		|			И (ПриходнаяНакладная.КодОперации = &КодОперации)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|		ПО (ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка)
		|ГДЕ
		|	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = &КодАгрегации
		|	И ЛистНабора.Проведен";
	
	Запрос.УстановитьПараметр("КодАгрегации", КодАгрегации);
	Запрос.УстановитьПараметр("КодОперации", Перечисления.КодыОперацийОстатки.ЗакупкаР);
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ссылка; 
	КонецЕсли;
	
	Возврат неопределено; 


КонецФункции // НайтиЛистПоКодуАгрегации()

