
#Область ТекстыЗапросов

Функция ТекстЗапроса_НайтиНоменклатуруПоОсновномуШК() Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ЕСТЬNULL(ШтрихКоды.Владелец.Родитель.ШтукВКоробке, 0) КАК ДополнительныйПараметр,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.Владелец <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Успех
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	НЕ ШтрихКоды.ПометкаУдаления
	|	И (ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)  
	// +++ {Кузнецов Сергей Владимирович [06.05.2025] (HELP-4610)
	|			ИЛИ ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
	// }Кузнецов Сергей Владимирович +++ [06.05.2025]
	|	И ШтрихКоды.Наименование = &Данные";

	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапроса_НайтиНоменклатуруШтукаЧЗ() Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Упаковка.Владелец КАК Номенклатура,
	|	Упаковка.Ссылка КАК ДополнительныйПараметр,
	|	ВЫБОР
	|		КОГДА Упаковка.Владелец <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|				И Упаковка.Ссылка <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Успех
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК Упаковка
	|ГДЕ
	|	НЕ Упаковка.ПометкаУдаления
	|	И Упаковка.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И Упаковка.Наименование = &Данные";
	
	Возврат ТекстЗапроса;
	
КонецФункции

