Функция ПолучитьСтруктуруВозврата(Данные, ТекстЗапроса) Экспорт
	
	СтруктураВозврата = Новый Структура("Номенклатура, ДополнительныйПараметр, Успех", Неопределено, Неопределено, Ложь);
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Данные", Данные);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция НайтиКоличествоЗаводское(КодАгрегации) Экспорт
	
	МассивНоменклатуры = Новый Массив;
	
	СтруктураВозврата = Новый Структура("КоличествоЗаводское, МассивНоменклатуры", 0, МассивНоменклатуры);
	
	Если НЕ ЗначениеЗаполнено(КодАгрегации) Тогда
		Сообщить("Не заполнен Код Агрегации!!!");
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КодАгрегации", КодАгрегации);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ВложенныеШтрихкоды.Штрихкод) КАК КоличествоЗаводское
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|ГДЕ
	|	ВложенныеШтрихкоды.Ссылка = &КодАгрегации";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		СтруктураВозврата.Вставить("КоличествоЗаводское", Выборка.КоличествоЗаводское);
	КонецЦикла;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВложенныеТовары.Номенклатура КАК Номенклатура,
	|	ВложенныеТовары.Количество КАК Количество
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеТовары КАК ВложенныеТовары
	|ГДЕ
	|	ВложенныеТовары.Ссылка = &КодАгрегации";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Количество() > 0 Тогда
	
		Пока Выборка.Следующий() Цикл
			СтруктураСтроки = Новый Структура("Номенклатура, Количество");
			СтруктураСтроки.Вставить("Номенклатура", Выборка.Номенклатура);
			СтруктураСтроки.Вставить("Количество", Выборка.Количество);
			МассивНоменклатуры.Добавить(СтруктураСтроки);
		КонецЦикла;
	
		СтруктураВозврата.Вставить("МассивНоменклатуры", МассивНоменклатуры);
	
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область Расчет

Функция КоличествоНеправильногоСодержимогоКоробки(НоменклатураОсновная, тзШтрихкодыУпаковок) Экспорт
	
	Если НЕ ЗначениеЗаполнено(НоменклатураОсновная) Тогда
		Сообщить("Не заполнена Номенклатура основная!!");
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НоменклатураОсновная", НоменклатураОсновная);
	Запрос.УстановитьПараметр("тзШтрихкодыУпаковок", тзШтрихкодыУпаковок);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	|	1 КАК Количество
	|ПОМЕСТИТЬ вр_ШтрихкодыУпаковок
	|ИЗ
	|	&тзШтрихкодыУпаковок КАК тзШтрихкодыУпаковок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	СУММА(вр_ШтрихкодыУпаковок.Количество) КАК Количество
	|ПОМЕСТИТЬ тзвр_ШтрихкодыУпаковок
	|ИЗ
	|	вр_ШтрихкодыУпаковок КАК вр_ШтрихкодыУпаковок
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(вр_ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец) = ТИП(Справочник.Номенклатура)
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тзвр_ШтрихкодыУпаковок.Номенклатура КАК Номенклатура,
	|	СУММА(тзвр_ШтрихкодыУпаковок.Количество) КАК Количество
	|ПОМЕСТИТЬ вр_Количество
	|ИЗ
	|	тзвр_ШтрихкодыУпаковок КАК тзвр_ШтрихкодыУпаковок
	|ГДЕ
	|	тзвр_ШтрихкодыУпаковок.Номенклатура <> &НоменклатураОсновная
	|
	|СГРУППИРОВАТЬ ПО
	|	тзвр_ШтрихкодыУпаковок.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(вр_Количество.Количество) КАК КоличествоНеправильногоСодержимогоКоробки
	|ИЗ
	|	вр_Количество КАК вр_Количество";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.КоличествоНеправильногоСодержимогоКоробки;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

Функция ОтклонениеОтЗаводскогоКоличества(КоличествоЗаводское, тзШтрихкодыУпаковок) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзШтрихкодыУпаковок", тзШтрихкодыУпаковок);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	|	1 КАК Количество
	|ПОМЕСТИТЬ вр_ШтрихкодыУпаковок
	|ИЗ
	|	&тзШтрихкодыУпаковок КАК тзШтрихкодыУпаковок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	СУММА(вр_ШтрихкодыУпаковок.Количество) КАК Количество
	|ПОМЕСТИТЬ тзвр_ШтрихкодыУпаковок
	|ИЗ
	|	вр_ШтрихкодыУпаковок КАК вр_ШтрихкодыУпаковок
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(тзвр_ШтрихкодыУпаковок.Количество) КАК КоличествоШК
	|ИЗ
	|	тзвр_ШтрихкодыУпаковок КАК тзвр_ШтрихкодыУпаковок";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Возврат КоличествоЗаводское - Выборка.КоличествоШК;
	КонецЦикла;
	
	Возврат КоличествоЗаводское;
	
КонецФункции

Функция КоличествоНеверныхШтучныхКодов(КодАгрегации, тзШтрихкодыУпаковок) Экспорт
	
	Если НЕ ЗначениеЗаполнено(КодАгрегации) Тогда
		Сообщить("Не заполнен Код Агрегации!!!");
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КодАгрегации", КодАгрегации);
	Запрос.УстановитьПараметр("тзШтрихкодыУпаковок", тзШтрихкодыУпаковок);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК ШтрихкодУпаковки,
	|	1 КАК Количество
	|ПОМЕСТИТЬ вр_ШтрихкодыУпаковок
	|ИЗ
	|	&тзШтрихкодыУпаковок КАК тзШтрихкодыУпаковок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	вр_ШтрихкодыУпаковок.Количество КАК Количество
	|ПОМЕСТИТЬ вт_Штрихкоды
	|ИЗ
	|	вр_ШтрихкодыУпаковок КАК вр_ШтрихкодыУпаковок
	|ГДЕ
	|	НЕ вр_ШтрихкодыУпаковок.ШтрихкодУпаковки В
	|				(ВЫБРАТЬ
	|					ВложенныеШтрихкоды.Штрихкод КАК ШтрихкодыАгрегации
	|				ИЗ
	|					Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды
	|				ГДЕ
	|					ВложенныеШтрихкоды.Ссылка = &КодАгрегации)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(вт_Штрихкоды.Количество) КАК КоличествоНеверныхШтучныхКодов
	|ИЗ
	|	вт_Штрихкоды КАК вт_Штрихкоды";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.КоличествоНеверныхШтучныхКодов;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

#КонецОбласти

