#Область ОбработчикиФормы

&НаКлиенте
Процедура СканировщикОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		Объект.Сканировщик = ВыбранноеЗначение;
		
		НайденныеСтроки = Объект.СоставБригады.НайтиСтроки(Новый Структура("Сотрудник", ВыбранноеЗначение));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = Объект.СоставБригады.Добавить();
			НоваяСтрока.Сотрудник = ВыбранноеЗначение;
			Если ЗначениеЗаполнено(Объект.НачалоСканирования) Тогда
				НоваяСтрока.ДатаНачала = Объект.НачалоСканирования;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоставБригадыСотрудникОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		НайденныеСтроки = Объект.СоставБригады.НайтиСтроки(Новый Структура("Сотрудник", ВыбранноеЗначение));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			ТекущиеДанные = Элементы.СоставБригады.ТекущиеДанные;
			ТекущиеДанные.Сотрудник = ВыбранноеЗначение;
			ТекущиеДанные.ДатаНачала = Объект.НачалоСканирования;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект.Сканировщик) Тогда
			Объект.Сканировщик = ВыбранноеЗначение;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КодАгрегацииОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		Объект.КодАгрегации = ВыбранноеЗначение;
		//++Данилова Е.В. 05.05.2026 SNL-219 
		ЛистПоКоду = Документы.ПроверкаПоставкиМаркированногоТовара.НайтиЛистПоКодуАгрегации(Объект.КодАгрегации);
		Если ЗначениеЗаполнено(ЛистПоКоду) Тогда
			
			Объект.ДокОснование = ЛистПоКоду; 	 
			
		КонецЕсли;
		//--Данилова Е.В. 05.05.2026
		
		Объект.НоменклатураОсновная = ЗначениеРеквизитаОбъекта(Объект.КодАгрегации, "Владелец");
		
		Объект.КоличествоЗаводское = ЗначениеРеквизитаОбъекта(Объект.КодАгрегации, "Количество");
		
		СтруктураВозврата = Документы.ПроверкаПоставкиМаркированногоТовара.НайтиКоличествоЗаводское(Объект.КодАгрегации);
		
		Если Объект.КоличествоЗаводское = 0 Тогда
			Объект.КоличествоЗаводское = СтруктураВозврата.КоличествоЗаводское;
		КонецЕсли;
		
		Для Каждого СтруктураСтроки ИЗ СтруктураВозврата.МассивНоменклатуры Цикл
		
			НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", СтруктураСтроки.Номенклатура));
		
			Если НайденныеСтроки.Количество() = 0 Тогда
				ЗаполнитьЗначенияСвойств(Объект.Товары.Добавить(), СтруктураСтроки);
			КонецЕсли;
		
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокОснованиеОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		Объект.ДокОснование = ВыбранноеЗначение;     
		//Кухарь А.Ю.  12.05.2026 начало
		// SNL-219                       
		ДокОснованиеПриИзменении(Неопределено);
		//Кухарь А.Ю.  12.05.2026 конец
		
		
		ОчиститьРеквизитыФормы();
		
		ЗаполнитьНаСервере(ВыбранноеЗначение);
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере(ВыбранноеЗначение)
	
	Значение = РеквизитФормыВЗначение("Объект");
	Значение.Заполнить(ВыбранноеЗначение);
	ЗначениеВРеквизитФормы(Значение,"Объект"); 
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьРеквизитыФормы()
	
	Если ЗначениеЗаполнено(Объект.КодАгрегации) Тогда
		Объект.КодАгрегации = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.НоменклатураОсновная) Тогда
		Объект.НоменклатураОсновная = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Сканировщик) Тогда
		Объект.Сканировщик = Неопределено;
	КонецЕсли;
	
	Если Объект.СоставБригады.Количество() > 0 Тогда
		Объект.СоставБригады.Очистить();
	КонецЕсли;
	
	Объект.ЕстьОшибки = Ложь;
	Объект.НеПолныйКороб = Ложь;
	
	Объект.КоличествоЗаводское = 0;
	Объект.КоличествоЛинейныхШК = 0;
	Объект.КоличествоНеверныхШтучныхКодов = 0;
	Объект.КоличествоНеправильногоСодержимогоКоробки = 0;
	Объект.ОтклонениеОтЗаводскогоКоличества = 0;
	
	Объект.НачалоСканирования = ТекущаяДатаСеанса();
	Объект.ОкончаниеСканирования = ПустаяДата();
	
КонецПроцедуры

&НаКлиенте
Процедура ДокОснованиеПриИзменении(Элемент)
	//Кухарь А.Ю.  12.05.2026 начало
	// SNL-219                       
	если ЗначениеЗаполнено(Объект.ДокОснование)  тогда
		Накладная = ПолучитьРеквизитШапки(Объект.ДокОснование,"ДокОснование","Документ");
		если ТипЗнч(Накладная) = Тип("ДокументСсылка.ПриходнаяНакладная") тогда
			объект.Накладная = Накладная;
		иначе      
			объект.Накладная = документы.ПриходнаяНакладная.ПустаяСсылка();
		КонецЕсли;
	иначе
		объект.Накладная = документы.ПриходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	//Кухарь А.Ю.  12.05.2026 конец
КонецПроцедуры

#КонецОбласти
