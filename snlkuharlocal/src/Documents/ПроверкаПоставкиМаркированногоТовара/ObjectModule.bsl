
#Область СобытияДокумента

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Префикс = Маркировка_ПИ.ЭтотУзел_Код("Основной")+"-";
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения) Тогда Возврат; КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	
	ДокОснование = ДанныеЗаполнения;
	
	Дата = ТекущаяДатаСеанса();
	НачалоСканирования = ТекущаяДатаСеанса();
	
	УстановитьНовыйНомер();
	
	Если ЗначениеЗаполнено(Сканировщик) Тогда
	
		НайденныеСтроки = СоставБригады.НайтиСтроки(Новый Структура("Сотрудник", Сканировщик));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = СоставБригады.Добавить();
			НоваяСтрока.Сотрудник = Сканировщик;
		КонецЕсли;
		
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	
	Товары.Загрузить(ДокОснование.Товары.Выгрузить());
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	ШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ВЫРАЗИТЬ(ШтрихкодыУпаковок.ШтрихкодУпаковки.ЗначениеШтрихкода КАК СТРОКА(31)) КАК ТекстQR
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|ГДЕ
	|	ШтрихкодыУпаковок.Ссылка = &ДокОснование";
	
	УстановитьПривилегированныйРежим(Истина);
	тзШтрихкодыУпаковок = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ШтрихкодыУпаковок.Загрузить(тзШтрихкодыУпаковок);
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	//  КодАгрегации - НЕ Штука (Блочок или Коробка)
	///////////////////////////////////////////////////////////////////////////////////////////////
	
	Если Товары.Количество() > 0 Тогда
		НоменклатураОсновная = Товары[0].Номенклатура;
	КонецЕсли;
	
	Если ШтрихкодыУпаковок.Количество() > 0 Тогда
		Для Каждого Стр ИЗ ШтрихкодыУпаковок Цикл
			Если Стр.ШтрихкодУпаковки.ТипШК <> Перечисления.ТипыШтрихКодов.Штука Тогда
				КодАгрегации = Стр.ШтрихкодУпаковки;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если НЕ ЗначениеЗаполнено(Сканировщик) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен <Сканировщик> !!!";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(НоменклатураОсновная) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнена <Номенклатура Основная> !!!";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КодАгрегации) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен <Код Агрегации> !!!";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

