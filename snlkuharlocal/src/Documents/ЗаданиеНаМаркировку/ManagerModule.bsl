#Область СозданиеДокументов


Функция Создать_ЗаданиеНаМаркировку(ДокОснование_ссылка) Экспорт
	
	//Кухарь 13.01.2025 начало	
	// Кухарь А.Ю.  14.01.2025 начало
	//
	если ТипЗнч(ДокОснование_ссылка)=Тип("ДокументСсылка.РасходнаяНакладная") тогда
		ИспользоватьПереопределениеДатМаркировки=Истина;
	иначе
		ИспользоватьПереопределениеДатМаркировки=ложь;
	КонецЕсли;
	// Кухарь А.Ю.  14.01.2025 конец
	
	
	Запрос=новый запрос;
	запрос.Текст=  "ВЫБРАТЬ
	|	ЗаданиеНаМаркировку.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
	|ГДЕ
	|	ЗаданиеНаМаркировку.ДокОснование = &ДокОснование_ссылка" ;
	запрос.УстановитьПараметр("ДокОснование_ссылка",ДокОснование_ссылка);
	Выборка=запрос.Выполнить().Выбрать();
	ЗНМОбъект=Неопределено;
	пока Выборка.Следующий() цикл
		ЗНМОбъект=выборка.ссылка.получитьобъект();
		ЗНМОбъект.ПометкаУдаления=Ложь;
		ЗНМОбъект.Товары.Очистить();
		
	КонецЦикла;
	если ЗНМОбъект=Неопределено тогда
		ЗНМОбъект=Документы.ЗаданиеНаМаркировку.СоздатьДокумент();
		
		//Чирков+++ 26.02.2025
		ЗаполнитьШапкуДокумента(ЗНМОбъект, ПараметрыСеанса.Пользователь);
		//Чирков--- 26.02.2025
	КонецЕсли;
	
	
	ЗНМОбъект.Автор=ПараметрыСеанса.Пользователь;
	
	если ИспользоватьПереопределениеДатМаркировки тогда
		если ПолучитьРеквизитШапки(ДокОснование_ссылка,"ОтгрузкаКомплектов","Документ") тогда
			ИмяТЧ="Комплектующие";
		иначе
			ИмяТЧ="Товары";  
		КонецЕсли;
	иначе
		ИмяТЧ="Товары";  
	КонецЕсли;
	
	
	//Кухарь 05.09.2024 начало	
	если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад тогда
		Запрос.Текст="ВЫБРАТЬ
		|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
		|	СУММА(ЗаданиеНабораТовары.Количество) КАК Количество,
		|	ЗаданиеНабораТовары.Номенклатура.ОсновнаяЕдиница КАК Единица,
		|	ЗаданиеНабораТовары.Номенклатура.Коэффициент КАК Коэффициент
		|ИЗ
		|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|ГДЕ
		|	ЗаданиеНабораТовары.Ссылка.ТребуетсяМаркировка
		|	И ЗаданиеНабораТовары.Ссылка.Накладная = &ДокОснование_ссылка
		|	И ЗаданиеНабораТовары.Ссылка.Проведен
		|	И ЗаданиеНабораТовары.Ссылка.Дата >= &Дата
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаданиеНабораТовары.Номенклатура";
		запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
	иначе  
		//крохин начало 03.07.2025
		//HELP-5849
	    ВидДокумента	= ДокОснование_ссылка.Метаданные().Имя;
		//крохин конец 03.07.2025
		Запрос.Текст="ВЫБРАТЬ
		|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
		|	РасходнаяНакладнаяТовары.Количество КАК Количество,
		|	РасходнаяНакладнаяТовары.Единица КАК Единица,
		|	РасходнаяНакладнаяТовары.Коэффициент КАК Коэффициент
		|ИЗ
		//крохин начало 03.07.2025
		//HELP-5849
	//	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары 
	    |	Документ."+ВидДокумента+".Товары КАК РасходнаяНакладнаяТовары 
		//крохин конец 03.07.2025
		|ГДЕ
		|	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
		|	И РасходнаяНакладнаяТовары.Количество > 0
		|	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> &ПустаяДата";    
		// Кухарь А.Ю.  07.07.2025 начало
		//|	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой < РасходнаяНакладнаяТовары.Ссылка.ДатаОтгрузки";
		// Кухарь А.Ю.  07.07.2025 конец
		
		запрос.УстановитьПараметр("Ссылка",ДокОснование_ссылка);
		запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
		
		// Кухарь А.Ю.  19.01.2025 начало
		если ИмяТЧ = "Комплектующие" тогда
			запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.РасходнаяНакладная.Товары","Документ.РасходнаяНакладная.Комплектующие");
		КонецЕсли;
		// Кухарь А.Ю.  19.01.2025 конец


	КонецЕсли;
	//Кухарь 05.09.20204 начало	

	
	
	//Кухарь 13.01.2025 начало	
	//Даты из контрагентов и матриц
	если ИспользоватьПереопределениеДатМаркировки тогда
		ТаблицаПереопределяемыхДат=МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(ДокОснование_ссылка,ИмяТЧ);
	иначе
		ТаблицаПереопределяемыхДат=Неопределено;
	КонецЕсли;
	
	если ТаблицаПереопределяемыхДат<>Неопределено и ТаблицаПереопределяемыхДат.количество()> 0 тогда
		ТЗИсходная=запрос.Выполнить().Выгрузить();
		Запрос.Текст="ВЫБРАТЬ
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.Количество КАК Количество,
		|	ТЧ.Единица КАК Единица,
		|	ТЧ.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой,
		|	ТЧ.Коэффициент КАК Коэффициент
		|ПОМЕСТИТЬ ВремТЗИсходная
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК ТЧ
		|ГДЕ
		|	ТЧ.Ссылка = &Ссылка
		|	И ТЧ.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗПереопределяемая.Номенклатура КАК Номенклатура,
		|	ТЗПереопределяемая.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ВремТЗПереопределяемая
		|ИЗ
		|	&ТаблицаПереопределяемыхДат КАК ТЗПереопределяемая
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВремТЗПереопределяемая.Номенклатура КАК Номенклатура,
		|	ВремТЗПереопределяемая.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой,
		|	ВремТЗИсходная.Количество КАК Количество,
		|	ВремТЗИсходная.Единица КАК Единица,
		|	ВремТЗИсходная.Коэффициент КАК Коэффициент
		|ИЗ
		|	ВремТЗПереопределяемая КАК ВремТЗПереопределяемая
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВремТЗИсходная КАК ВремТЗИсходная
		|		ПО ВремТЗПереопределяемая.Номенклатура = ВремТЗИсходная.Номенклатура
		|ГДЕ
		|	ВремТЗПереопределяемая.ДатаНачалаРаботыСМаркировкой <= &ДатаНачалаРаботыСМаркировкой";
		запрос.УстановитьПараметр("Ссылка",ДокОснование_ссылка);
		запрос.УстановитьПараметр("ДатаНачалаРаботыСМаркировкой",ПолучитьРеквизитШапки(ДокОснование_ссылка,"ДатаОтгрузки","Документ"));		
		запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат",ТаблицаПереопределяемыхДат);
		
		// Кухарь А.Ю.  19.01.2025 начало
		если ИмяТЧ = "Комплектующие" тогда
			запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.РасходнаяНакладная.Товары","Документ.РасходнаяНакладная.Комплектующие");
		КонецЕсли;
		// Кухарь А.Ю.  19.01.2025 конец
		
	КонецЕсли;
	//Кухарь 13.01.2025 конец			
	ЗНМОбъект.Товары.Загрузить(запрос.Выполнить().Выгрузить());
	ЗНМОбъект.Дата=ТекущаяДатаСеанса();
	ЗНМОбъект.ДокОснование=ДокОснование_ссылка;
	ЗНМОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Возврат ЗНМОбъект.Ссылка;
	
	
КонецФункции //Создать_ЗаданиеНаМаркировку(ЗаданиеНабора_Ссылка) Экспорт

Функция Создать_Агрегации(ЗаданиеНаМаркировку_Ссылка, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	рШапки = ПолучитьРеквизитыШапки(ЗаданиеНаМаркировку_Ссылка, "фУпрощенныйРежим,фАгрегироватьБлочки,фАгрегироватьПалеты,фАгрегироватьКоробки"); 
	
	Если рШапки.фУпрощенныйРежим И рШапки.фАгрегироватьБлочки Тогда
		ДанныеЗаполнения = рШапки;
		ДанныеЗаполнения.Вставить("ДокументОснование",	ЗаданиеНаМаркировку_Ссылка);		
		ДанныеЗаполнения.Вставить("ТипШК",				Перечисления.ТипыШтрихКодов.Блочок);
		
		рСоздания = НайтиСоздатьДокАгрегации(ЗаданиеНаМаркировку_Ссылка, ДанныеЗаполнения.ТипШК);
		Если рСоздания.Успешно Тогда
			ДокОбъект = рСоздания.Данные;	
			
			ДокОбъект.Заполнить(ДанныеЗаполнения);
			
			ДокОбъект.Статус = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус", Перечисления.СтатусыДокументовМаркировки.ВРаботе);
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			
			Результат.Данные = ДокОбъект.Ссылка;
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;		
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рСоздания);	
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ рШапки.фУпрощенныйРежим ИЛИ рШапки.фАгрегироватьКоробки Тогда
		рСоздания = НайтиСоздатьДокАгрегации(ЗаданиеНаМаркировку_Ссылка, Перечисления.ТипыШтрихКодов.Коробка);
		Если рСоздания.Успешно Тогда
			ДанныеЗаполнения = рШапки;
			ДанныеЗаполнения.Вставить("ДокументОснование",	ЗаданиеНаМаркировку_Ссылка);		
			ДанныеЗаполнения.Вставить("ТипШК",				Перечисления.ТипыШтрихКодов.Коробка);
			
			ДокОбъект = рСоздания.Данные;	
			
			ДокОбъект.Заполнить(ДанныеЗаполнения);
			
			ДокОбъект.Статус = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус", Перечисления.СтатусыДокументовМаркировки.ВРаботе);
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			
			Результат.Данные = ДокОбъект.Ссылка;
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;		
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рСоздания);	
		КонецЕсли;	
	КонецЕсли;	
	
	Если рШапки.фУпрощенныйРежим И рШапки.фАгрегироватьПалеты Тогда
		ДанныеЗаполнения = рШапки;
		ДанныеЗаполнения.Вставить("ДокументОснование", 	ЗаданиеНаМаркировку_Ссылка);		
		ДанныеЗаполнения.Вставить("ТипШК",				Перечисления.ТипыШтрихКодов.Палета);
		
		рСоздания = НайтиСоздатьДокАгрегации(ЗаданиеНаМаркировку_Ссылка, ДанныеЗаполнения.ТипШК);
		Если рСоздания.Успешно Тогда
			ДокОбъект = рСоздания.Данные;	
			
			ДокОбъект.Заполнить(ДанныеЗаполнения);
			
			ДокОбъект.Статус = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус", Перечисления.СтатусыДокументовМаркировки.ВРаботе);
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			
			Результат.Данные = ДокОбъект.Ссылка;
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;		
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рСоздания);	
		КонецЕсли;
	КонецЕсли;	
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;	
КонецФункции //Создать_Агрегации(ЗаданиеНаМаркировку_Ссылка) Экспорт

Функция НайтиСоздатьДокАгрегации(ДокументОснование, Знач ТипШК = Неопределено)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ТипШК = Неопределено Тогда
		ТипШК = Перечисления.ТипыШтрихКодов.Коробка;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|   Ссылка,
	|   Статус	
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП
	|ГДЕ
	|	ДокументОснование = &ДокументОснование	
	|	И ТипШК = &ТипШК
	|УПОРЯДОЧИТЬ ПО
	|	ПометкаУдаления
	|";
	
	Запрос.УстановитьПараметр("ДокументОснование",	ДокументОснование);
	Запрос.УстановитьПараметр("ТипШК", 				ТипШК);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Если Выборка.Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
			ТекстОшибки = СтрШаблон("Недопустимый статус существующего документа маркировки ! %1, статус: %2 !", Выборка.Ссылка, Выборка.Статус);
					
			Результат.Успешно = Ложь;
			Результат.Ошибки.Добавить(ТекстОшибки);
		Иначе
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
		КонецЕсли;
	Иначе
		ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();		
		
		ДокОбъект.ДокументОснование = ДокументОснование;
		ДокОбъект.ТипШК				= ТипШК;
	КонецЕсли;
	
	Результат.Данные = ДокОбъект;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьДокАгрегации(ДокументОснование)


// Кухарь А.Ю.  19.01.2025 начало
//
Функция НайтиСоздатьДокументДляМаркировкиПодОтгрузку (Накладная) экспорт
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ЗаданиеНаМаркировку.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
	|ГДЕ
	|	ЗаданиеНаМаркировку.ДокОснование = &ДокОснование
	//       |	И ЗаданиеНаМаркировку.Проведен
	|	И не ЗаданиеНаМаркировку.ПометкаУдаления";
	запрос.УстановитьПараметр("ДокОснование",Накладная);
	Выборка=запрос.Выполнить().Выбрать();
	если Выборка.Количество()=0 тогда
		док=Документы.ЗаданиеНаМаркировку.Создать_ЗаданиеНаМаркировку(Накладная);
		Возврат док;
	КонецЕсли;
	
	пока Выборка.Следующий() цикл
		возврат Выборка.ссылка;
	КонецЦикла;
	
	
КонецФункции
 
Функция ДобавитьКодыАгрегаций(ДокСсылка, Коды, ДокументОснование = Неопределено) Экспорт
	Если ТипЗнч(Коды) = Тип("Массив") Тогда
		МассивКодов =  Коды;
	Иначе
		МассивКодов = Новый Массив;
		МассивКодов.Добавить(Коды);	
	КонецЕсли; 
	
	ДокОбъект = ДокСсылка.ПолучитьОбъект();
	Если 1=2 Тогда
		ДокОбъект = Документы.ЗаданиеНаМаркировку.СоздатьДокумент();	
	КонецЕсли;
	
	Для Каждого ШтрихКодКоробки Из МассивКодов Цикл
		Если ТипЗнч(ШтрихКодКоробки) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") И ЗначениеЗаполнено(ШтрихКодКоробки) Тогда
			Если ДокОбъект.ШтрихкодыКоробок.Найти(ШтрихКодКоробки, "ШтрихкодКоробки") = Неопределено Тогда
