	|		ПО ШКУпаковокЗНМ.Ссылка.ДокОснование = вр_ТоварыРНК.РНК
	|			И ШКУпаковокЗНМ.ШтрихкодУпаковки.Владелец = вр_ТоварыРНК.Номенклатура
	|ГДЕ
	|	ШКУпаковокЗНМ.Ссылка <> &ДокСсылка
	 
	// Кухарь А.Ю.  13.10.2025 начало  
	//HELP-6865
	// по мне не нужно условие на проведение ДОКОСНОВАНИЯ. Либо нужно но не тут, а в момент создания ЗНМ.
	// |	И ШКУпаковокЗНМ.Ссылка.ДокОснование.Проведен 
	|	И ШКУпаковокЗНМ.Ссылка.ДокОснование = &ДокОснование
	// Кухарь А.Ю.  13.10.2025 конец
	
	|
	|СГРУППИРОВАТЬ ПО
	|	ШКУпаковокЗНМ.Ссылка,
	|	ШКУпаковокЗНМ.ШтрихкодУпаковки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ДругиеЗНМ.Номенклатура КАК Номенклатура,
	|	СУММА(вр_ДругиеЗНМ.КоличествоВДругихЗНМ) КАК КоличествоВДругихЗНМ
	|ПОМЕСТИТЬ тзвр_ДругиеЗНМ
	|ИЗ
	|	вр_ДругиеЗНМ КАК вр_ДругиеЗНМ
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_ДругиеЗНМ.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокОМ.ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокОМ.ШтрихкодУпаковки) КАК КоличествоОМ
	|ПОМЕСТИТЬ вр_ШК_ОМ_РНК
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ШтрихкодыУпаковокОМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_ТоварыРНК КАК вр_ТоварыРНК
	|		ПО ШтрихкодыУпаковокОМ.Ссылка.ДокументОснование = вр_ТоварыРНК.РНК
	|			И ШтрихкодыУпаковокОМ.ШтрихкодУпаковки.Владелец = вр_ТоварыРНК.Номенклатура
	|ГДЕ
	|	ШтрихкодыУпаковокОМ.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И ШтрихкодыУпаковокОМ.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И ШтрихкодыУпаковокОМ.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодыУпаковокОМ.ШтрихкодУпаковки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаркировкаТоваровИСМПШтрихкодыКоробок.ШтрихкодКоробки.Владелец КАК Номенклатура,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод) КАК КоличествоУпаковок
	|ПОМЕСТИТЬ вр_ШтрихКодыКоробок
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыКоробок КАК МаркировкаТоваровИСМПШтрихкодыКоробок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО МаркировкаТоваровИСМПШтрихкодыКоробок.Ссылка = МаркировкаТоваровИСМП.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|		ПО (МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка)
	|			И (МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки = МаркировкаТоваровИСМПШтрихкодыКоробок.ШтрихкодКоробки)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|		ПО МаркировкаТоваровИСМПШтрихкодыКоробок.ШтрихкодКоробки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_ТоварыРНК КАК вр_ТоварыРНК
	|		ПО МаркировкаТоваровИСМПШтрихкодыКоробок.Ссылка.ДокументОснование = вр_ТоварыРНК.РНК
	|			И МаркировкаТоваровИСМПШтрихкодыКоробок.ШтрихкодКоробки.Владелец = вр_ТоварыРНК.Номенклатура
	|ГДЕ
	|	МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И МаркировкаТоваровИСМП.ТипШК В (ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка), ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок))
	|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	МаркировкаТоваровИСМПШтрихкодыКоробок.ШтрихкодКоробки.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ТоварыИсточник.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(вр_ТоварыРНК.КоличествоРНК, 0) КАК КоличествоРНК,
	|	ЕСТЬNULL(вр_ТоварыИсточник.КоличествоЗНМ, 0) КАК КоличествоЗНМ,
	|	ЕСТЬNULL(тзвр_ДругиеЗНМ.КоличествоВДругихЗНМ, 0) КАК КоличествоВДругихЗНМ,
	|	ЕСТЬNULL(вр_ШК_ОМ_РНК.КоличествоОМ, 0) КАК КоличествоОМ,
	|	ЕСТЬNULL(вр_ШтрихКодыКоробок.КоличествоУпаковок, 0) КАК КоличествоУпаковокОМ,
	|	ЕСТЬNULL(вр_ТоварыРНК.КоличествоРНК, 0) - ЕСТЬNULL(вр_ТоварыИсточник.КоличествоЗНМ, 0) - ЕСТЬNULL(тзвр_ДругиеЗНМ.КоличествоВДругихЗНМ, 0) - ЕСТЬNULL(вр_ШК_ОМ_РНК.КоличествоОМ, 0) - ЕСТЬNULL(вр_ШтрихКодыКоробок.КоличествоУпаковок, 0) КАК Разница
	|ПОМЕСТИТЬ вр_Итоги
	|ИЗ
	|	вр_ТоварыИсточник КАК вр_ТоварыИсточник
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ТоварыРНК КАК вр_ТоварыРНК
	|		ПО вр_ТоварыИсточник.Номенклатура = вр_ТоварыРНК.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ тзвр_ДругиеЗНМ КАК тзвр_ДругиеЗНМ
	|		ПО вр_ТоварыИсточник.Номенклатура = тзвр_ДругиеЗНМ.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ШК_ОМ_РНК КАК вр_ШК_ОМ_РНК
	|		ПО вр_ТоварыИсточник.Номенклатура = вр_ШК_ОМ_РНК.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ШтрихКодыКоробок КАК вр_ШтрихКодыКоробок
	|		ПО вр_ТоварыИсточник.Номенклатура = вр_ШтрихКодыКоробок.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Итоги.Номенклатура КАК Номенклатура,
	|	СУММА(вр_Итоги.КоличествоРНК) КАК КоличествоРНК,
	|	СУММА(вр_Итоги.КоличествоЗНМ) КАК КоличествоЗНМ,
	|	СУММА(вр_Итоги.КоличествоВДругихЗНМ) КАК КоличествоВДругихЗНМ,
	|	СУММА(вр_Итоги.КоличествоОМ) КАК КоличествоОМ,
	|	СУММА(вр_Итоги.КоличествоУпаковокОМ) КАК КоличествоУпаковокОМ
	|ИЗ
	|	вр_Итоги КАК вр_Итоги
	|ГДЕ
	|	вр_Итоги.Разница < 0
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Итоги.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивПакета = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТЗ_ДругиеЗНМ = МассивПакета[2].Выгрузить();
	ТЗ_Сводная = МассивПакета[6].Выгрузить();
	ТЗ_Разница = МассивПакета[7].Выгрузить();
	
	СтруктураВозврата.Вставить("ТЗ_ДругиеЗНМ", ТЗ_ДругиеЗНМ);
	СтруктураВозврата.Вставить("ТЗ_Сводная", ТЗ_Сводная);
	СтруктураВозврата.Вставить("ТЗ_Разница", ТЗ_Разница);

