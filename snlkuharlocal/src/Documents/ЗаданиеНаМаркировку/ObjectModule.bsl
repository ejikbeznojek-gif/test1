#Область СобытияОбъекта

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	ЗаполнитьШапкуДокумента(ЭтотОбъект, ПараметрыСеанса.Пользователь);
	
	ДокОснование	= ДанныеЗаполнения;
	Если НЕ ЗначениеЗаполнено(ДокОснование) Тогда Возврат КонецЕсли;	
	
	ТипОснования = ТипЗнч(ДокОснование); 
	
	Если ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		//Валетов + 26,11,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7985 
		ДокСМаркировкой = ПолучитьРеквизитШапки(ДокОснование,"ТребуетсяМаркировка","Документ");
		Если НЕ ДокСМаркировкой Тогда 
			СообщитьИзМодуля("РНК не требует маркирвоки, ЗНМ по ней сформирован не будет!");
			Возврат;
		КонецЕсли;
		//Валетов -			
		ЗаполнитьПоРНК();	
		//Валетов + 06,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6363
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаМаркировкуТовары.Ссылка КАК Ссылка,
		|	СУММА(ЗаданиеНаМаркировкуТовары.Количество) КАК Количество
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.Товары КАК ЗаданиеНаМаркировкуТовары
		|ГДЕ
		|	ЗаданиеНаМаркировкуТовары.Ссылка.Проведен
		|	И ЗаданиеНаМаркировкуТовары.Ссылка.ДокОснование = &ДокОснование
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаданиеНаМаркировкуТовары.Ссылка";
		Запрос.УстановитьПараметр("ДокОснование",ДокОснование);
		Результат = запрос.Выполнить().Выгрузить();
		Если ДокОснование.КоличествоДокумента <= Результат.Итог("Количество") Тогда
			СообщитьИзМодуля("ЗНМ не создан! По данному ПРМ уже есть ЗНМ на общее количество: " +  Результат.Итог("Количество"));
			Возврат;
		КонецЕсли;
		//Валетов - 
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)          
	Если СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена 
		И ВсеКодыВСтатусеНанесен(Ссылка)	//Иногда перепроводят документы в промежуточных стадиях - тогда нужно переформировывать движения
		Тогда 
		Возврат;
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	СформироватьДвижения();	
КонецПроцедуры

Функция ПолучитьУникальныеЗначенияКолонки(ИмяКолонки)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	" + ИмяКолонки + "
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &Ссылка	
	|	И " + ИмяКолонки + " <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|УПОРЯДОЧИТЬ ПО
	|	" + ИмяКолонки + ".Наименование
	|";	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(ИмяКолонки);
КонецФункции //ПолучитьУникальныеЗначенияКолонки(ИмяКолонки)

Процедура ЗаписатьСтатусКодов(МассивКодов, НЗ, Статус)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка	КАК ШтрихКодУпаковки,
	|	ТипШК	КАК ТипШК
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	Ссылка В (&МассивКодов)
	|";
	
	Запрос.УстановитьПараметр("МассивКодов", МассивКодов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл	
		Движение = НЗ.Добавить();		
		
		Движение.Период				= Дата;
		
		Движение.ШтрихКодУпаковки	= Выборка.ШтрихКодУпаковки;		
		Движение.ТипШК				= Выборка.ТипШК;
		
		Движение.Местонахождение	= Подразделение;
		Движение.Статус				= Статус;
	КонецЦикла;
КонецПроцедуры //ЗаписатьСтатусКодов(МассивКодов, Статус)
 
Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс);	
	КонецЕсли; 
	Префикс = Префикс+Маркировка_ПИ.ЭтотУзел_Код("Основной")+"-";
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Автор 					= ПараметрыСеанса.Пользователь;
	Комментарий 			= "";
	СостояниеНакладной 		= Перечисления.СостоянияНакладной.ВРаботе;
	СформированыАгрегации   = Ложь;
	
	Товары.Очистить();
	ШтрихкодыУпаковок.Очистить();
	ШтрихкодыКоробок.Очистить();
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	
	ОбновитьСтатусыНанесения();
	
	Если Модифицированность() Тогда
		Если фУпрощенныйРежим Тогда
		Иначе
			КоличествоДокумента = ШтрихкодыУпаковок.Количество();	
			Если КоличествоДокумента > 0 тогда
				ЗаполнитьТоварыПоКМ(ЭтотОбъект);
			КонецЕсли;		
		КонецЕсли;
		
		// Кухарь А.Ю.  19.04.2025 начало
		// ОбновитьСоставКоробок();
		если  фАгрегироватьКоробки или фАгрегироватьБлочки или фАгрегироватьПалеты Тогда 
			ОбновитьСоставКоробок();
		КонецЕсли;	 
		// Кухарь А.Ю.  19.04.2025 конец     
		
		// Кухарь А.Ю. 24.10.2025 начало
		// HELP-7623
		если ДатаНачалаСканирования = ПустаяДата() и ШтрихкодыУпаковок.Количество()> 0 тогда  
			ДатаНачалаСканирования = ТекущаяДата();
		КонецЕсли;
		// Кухарь А.Ю. 24.10.2025 конец
		
	КонецЕсли;	

	
	
КонецПроцедуры

