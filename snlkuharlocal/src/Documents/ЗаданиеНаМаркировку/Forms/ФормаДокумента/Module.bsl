&НаКлиенте
Процедура ПовторнаяПечать(Режим = "Коды")
	КодыМаркировки  = Новый Соответствие;
	ЛистыУпаковки	= Новый Соответствие;
	
	Для Каждого ИдСтроки Из Элементы.ШтрихкодыУпаковок.ВыделенныеСтроки Цикл
		СтрокаТЧ = Объект.ШтрихкодыУпаковок.НайтиПоИдентификатору(ИдСтроки);
		
		КодыМаркировки[СтрокаТЧ.ШтрихкодУпаковки]	= Истина;		
		ЛистыУпаковки[СтрокаТЧ.ЛистМаркировки]		= Истина;
	КонецЦикла;
	
	Если ЛистыУпаковки.Количество() = 0 Тогда
		Сообщить("Не выбран лист маркировки для печати !", СтатусСообщения.Важное);
	ИначеЕсли ЛистыУпаковки.Количество() = 1 Тогда		
		Для Каждого КиЗ Из ЛистыУпаковки Цикл	
			ЛистУпаковки = КиЗ.Ключ;
			
			Если Режим = "Коды" Тогда
				ОтменитьПечатьКодов(КодыМаркировки);
			Иначе
				ОтменитьПечатьЛистаМаркировки(КиЗ.Ключ);
			КонецЕсли; 			
			
			Если Режим = "Коды" Тогда
				Для Каждого КиЗ Из КодыМаркировки Цикл				
					ЗаписатьВЛог("Повторная печать КМ", ""+КиЗ, "Предупреждение");
				КонецЦикла;
			Иначе
				ЗаписатьВЛог("Повторная печать КМ", "" + ЛистУпаковки, "Предупреждение");
			КонецЕсли; 
			
			рПечати = НапечататьКодыПоЛН_НаСервере(ЛистУпаковки);	
			Если рПечати.Успешно Тогда
				Если фПечататьЛентуСразуНаПинтер Тогда
					рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
				Иначе					
					рПечати.Данные.Показать("Этикетки по ЛМ: " + ТекущийЛистМаркировки);
				КонецЕсли; 				
			Иначе
				Сообщить(СтрСоединить(рПечати.Ошибки, Символы.ПС), СтатусСообщения.Важное); 
			КонецЕсли;
		КонецЦикла;		
	Иначе
		Сообщить("Выбраны КМ из нескольких листов маркировки ! Печать невозможна !", СтатусСообщения.Важное);
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция ОтменитьПечатьКодов(КодыМаркировки)
	Изменили = Ложь;
	Для Каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок Цикл
		Если КодыМаркировки[СтрокаТЧ.ШтрихкодУпаковки] = Истина И СтрокаТЧ.Распечатан Тогда
			СтрокаТЧ.Распечатан = Ложь;
			Изменили = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Если Изменили Тогда
		Записать(Новый Структура("РежимЗаписиДокумента", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
КонецФункции //ОтменитьПечатьКодов(КодыМаркировки)
 
&НаСервере
Функция ОтменитьПечатьЛистаМаркировки(ЛистМаркировки)
	Изменили = Ложь;
	Для Каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ЛистМаркировки", ЛистМаркировки)) Цикл		
		СтрокаТЧ.Распечатан = Ложь;
		Изменили = Истина;		
	КонецЦикла;
	
	Если Изменили Тогда
		Записать(Новый Структура("РежимЗаписиДокумента", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
КонецФункции //ОтменитьПечатьЛМ(ЛистМаркировки)

&НаКлиенте
Процедура Номенклатура_ПриИзменении(Элемент) 
	// Ихсанов Д. А. 04.01.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8436
	// Закомментировал проверку, возникала ошибка при сканировании
	//Валетов + 02,12,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3315
	//Запрещаем маркировать в ЗНМ Спайки   ВЕРНУЛ ПРОВЕРКУ     
	рШапки = ПолучитьРеквизитыШапки(Объект.Номенклатура, "ВидКомплекта,Родитель.ВидНоменклатуры");
	Если (рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.АссортитоКомплектов 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
		И рШапки.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
		СообщитьИзМодуля("Комплекты (спайки) и Ассортито необходимо маркировать через ЗСБ+ЛСК.");
		Возврат;
	КонецЕсли;
	//Валетов -
	Если ТипЗнч(Объект.ДокОснование) = Тип("ДокументСсылка.Перемещение") Тогда 
		ТЧОснования = Объект.ДокОснование.Товары.ВыгрузитьКолонку("Номенклатура");
		Если ТЧОснования.Найти(Объект.Номенклатура) = Неопределено Тогда 
			СообщитьИзМодуля("Номенклатура не найдена в докумеенте основании! Выберите другую."); 
			Объект.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
			Возврат;
		КонецЕсли; 	
	КонецЕсли;	
	//Валетов -
	
	НоменклатураПриИзменении_НаСервере();
	ЭтаФорма.ТекущийЭлемент = Элементы.КоличествоДокумента;
КонецПроцедуры

&НаКлиенте
Функция ПересчетУпаковок()
	Объект.КоличествоБлочков = 0;
	Объект.КоличествоКоробок = 0;	
	
	Если Объект.фАгрегироватьБлочки Тогда		
		Если Объект.ШтукВБлочке > 0 Тогда		
			Объект.КоличествоБлочков = Объект.КоличествоДокумента / Объект.ШтукВБлочке;
		КонецЕсли; 
	Иначе
		Объект.КоличествоБлочков = 0;			
	КонецЕсли;
	
	Если Объект.ШтукВКоробке > 0 Тогда
		Объект.КоличествоКоробок = Объект.КоличествоДокумента / Объект.ШтукВКоробке;			
	КонецЕсли;
	
	Если Объект.фАгрегироватьПалеты Тогда
		Если Объект.ШтукНаПалете > 0 Тогда
			Объект.КоличествоПалет = Объект.КоличествоДокумента / Объект.ШтукНаПалете;
		КонецЕсли;
	Иначе
		Объект.КоличествоПалет = 0;		
	КонецЕсли;	
КонецФункции //ПересчетУпаковок()
 
&НаСервере
Процедура НоменклатураПриИзменении_НаСервере()
	рШапки = ПолучитьРеквизитыШапки(Объект.Номенклатура, "Родитель.ШтукВКоробке,Родитель.ШтукВКоробочке");
	
	Объект.ШтукВБлочке 	= рШапки.Родитель_ШтукВКоробочке;
	Объект.ШтукВКоробке = рШапки.Родитель_ШтукВКоробке;
КонецПроцедуры

&НаКлиенте
Процедура КоличествоДокумента_ПриИзменении(Элемент)
	ПересчетУпаковок();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАгрегации(Команда)
	//Валетов + 30,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3473
	//Запрещаем маркировать в ЗНМ Спайки      
	рШапки = ПолучитьРеквизитыШапки(Объект.Номенклатура, "ВидКомплекта,Родитель.ВидНоменклатуры");
	Если (рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.АссортитоКомплектов 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
		И рШапки.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
		СообщитьИзМодуля("Комплекты (спайки) и Ассортито необходимо маркировать через ЗСБ+ЛСК.");
		Возврат;
	КонецЕсли;
	//Валетов -
	
	// Шворобей ВЮ 01.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	Если ЗначениеЗаполнено(Объект.ДокОснование) И ТипЗнч(Объект.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Если ПроверитьНоменклатуруЗНМ_НаОснованииРНК() = Истина Тогда Возврат; КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 01.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	
	рПроверки = ПроверитьКратность();
	
	Если рПроверки.Успешно Тогда
		Ответ = Вопрос("Отменить операцию нельзя. Проверьте значения параметров - если все правильно - нажмите 'Да'.", РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Подтверждение параметров");
		Если Ответ = КодВозвратаДиалога.Да Тогда
			рЗаполнения = ЗаполнитьАгрегации_НаСервере();
			Если рЗаполнения.Успешно Тогда
				Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеДопОбработки;
				УправлениеВидимостью();
			Иначе
				МаркировкаКС.ВывестиОшибки(рЗаполнения);
			КонецЕсли;
		КонецЕсли;	
	Иначе
		МаркировкаКС.ВывестиОшибки(рПроверки);		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьАгрегации_НаСервере()
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Объект.ШтрихкодыУпаковок.Очистить();		
	Объект.Дата = ТекущаяДата();
	Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	
	рРасчета = ПолучитьЗабронироватьТаблицуАгрегации(Объект.КоличествоДокумента, Объект.КоличествоКоробок, Объект.КоличествоПалет, Объект.КоличествоБлочков);
	Если рРасчета.Успешно Тогда
		ДокОбъект = РеквизитФормыВЗначение("Объект");
		
		ДокОбъект.ШтрихкодыУпаковок.Загрузить(рРасчета.Данные);		
		
		Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ДопОбработка;
		Объект.ШтрихкодыУпаковок.Загрузить(рРасчета.Данные);		
		
		Записать();		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рРасчета);
		ЗаписатьПроНехваткуКодов(Объект.Номенклатура, рРасчета);
		
		РегистрыСведений.СтатусыКМ_Факт.ОчиститьДвижения(Объект.Ссылка);
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;	
КонецФункции //ЗаполнитьАгрегации_НаСервере()

