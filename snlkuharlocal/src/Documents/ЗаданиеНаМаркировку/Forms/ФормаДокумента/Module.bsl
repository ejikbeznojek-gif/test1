&НаКлиенте
Процедура ЗавершитьМаркировку(Команда)
    // Кухарь А.Ю. 24.10.2025 начало
	// HELP-7623
	если не ЗначениеЗаполнено(Объект.ДатаНачалаСканирования) тогда   
		Сообщить("Не заполнена дата начала сканирования. Попробуйте перезаписать документ, и после этого ещё раз нажмите завершить маркировку.");
		Возврат;
	КонецЕсли;
	// Кухарь А.Ю. 24.10.2025 конец
	
	
	Если Объект.ШтрихкодыУпаковок.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Невозможно завершить маркировку ! Документ пустой !");
		Возврат;	
	КонецЕсли;
	
	Если Модифицированность ИЛИ НЕ Объект.Проведен Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
	
	рПроверки = ВсеЛистыМаркировкиЗавершены();
	Если рПроверки.Успешно Тогда     
		
		
		рЗавершения = ЗавершитьМаркировку_НаСервере();
		Если рЗавершения.Успешно Тогда	
			Сообщить("Маркировка завершена.", СтатусСообщения.Информация);
			Сообщить("Сформировано: "+ рЗавершения.ОбработаноОбъектов+" агрегаций.", СтатусСообщения.Информация);
			// Кухарь А.Ю. 06.05.2025 начало
			если не ЗначениеЗаполнено(объект.Исполнитель) тогда    
				Сообщить("Не указан исполнитель, ваши достижения не будут учтены при формировании отчётов по трудозатратам. Для установки исполнителя отсканируйте ШК сотрудника.");
			КонецЕсли;
			// Кухарь А.Ю. 06.05.2025 конец
			//++Данилова Е.В. 20.05.2026 MARK-3615 
			Если ТипЗнч(Объект.ДокОснование) = Тип("ДокументСсылка.Перемаркировка") Тогда
				Документы.Перемаркировка.ЗавершитьПеремаркировку(Объект.ДокОснование); 
			КонецЕсли;
			//--Данилова Е.В. 20.05.2026	
			Закрыть();
		Иначе		
			Сообщить(СтрСоединить(рЗавершения.Ошибки, Символы.ПС), СтатусСообщения.Важное);	
		КонецЕсли;
	Иначе
		Сообщить("Обнаружены ошибки ЛМО !", СтатусСообщения.Важное);
		Сообщить(СтрСоединить(рПроверки.Ошибки, Символы.ПС));
	КонецЕсли; 	
	 
КонецПроцедуры

&НаСервере
Функция ВсеЛистыМаркировкиЗавершены()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,Проведен,Завершен
	|ИЗ
	|	Документ.ЛистМаркировкиОстатков
	|ГДЕ
	|	ДокОснование = &ДокОснование	
	|	И НЕ (Завершен И Проведен)
	|	И НЕ Отменен
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", Объект.Ссылка);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ Выборка.Проведен Тогда		
			Результат.Ошибки.Добавить("ЛМО не проведен: " + Выборка.Ссылка + " !");
		КонецЕсли; 					
		Если НЕ Выборка.Завершен Тогда		                                 
			Результат.Ошибки.Добавить("ЛМО не завершен: " + Выборка.Ссылка + " !");
		КонецЕсли;
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ВсеЛистыМаркировкиЗавершены()
	
&НаСервере
Функция ЗавершитьМаркировку_НаСервере()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если НужноАгрегировать() Тогда			
		рАгрегации = Документы.ЗаданиеНаМаркировку.Создать_Агрегации(Объект.Ссылка, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки)); //+++Чирков 20.05.2025 - Петров просил ставить агрегации в ОжиданиеОтложеннойОбработки
		Если рАгрегации.Успешно Тогда
			Если Объект.фУпрощенныйРежим Тогда
				рОбработки = ДозаполнитьКодыАгрегатов();	
				Если НЕ рОбработки.Успешно Тогда				
					Возврат рОбработки;			
				КонецЕсли; 
			КонецЕсли;			
			
			Результат.ОбработаноОбъектов = рАгрегации.ОбработаноОбъектов;			
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рАгрегации);		
		КонецЕсли;		
	КонецЕсли;
	
	Если Результат.Ошибки.Количество() = 0 Тогда
	    Объект.СостояниеНакладной 		= Перечисления.СостоянияНакладной.Отгружена;
		Объект.СформированыАгрегации    = Истина;      
		
		// Кухарь А.Ю. 06.05.2025 начало
		если объект.ДатаОкончанияСканирования=ПустаяДата() тогда
			Объект.ДатаОкончанияСканирования=ТекущаяДата();
		КонецЕсли;
		// Кухарь А.Ю. 06.05.2025 конец
		
		
		Записать();
			
		рХКМ = Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ЗМО(Объект.Ссылка);
		Если НЕ рХКМ.Успешно Тогда
			МаркировкаКС.ДобавитьОшибки(Результат, рХКМ);					
		КонецЕсли;
		 
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ЗавершитьМаркировку_НаСервере()

&НаСервере
Функция НужноАгрегировать()
	Результат = Ложь;
	Если Объект.фУпрощенныйРежим Тогда
		Результат = (Объект.фАгрегироватьБлочки ИЛИ Объект.фАгрегироватьКоробки ИЛИ Объект.фАгрегироватьПалеты);
	Иначе
		Результат = ЕстьЗавершенныеЛМО();
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НужноАгрегировать()
 

&НаСервере
Функция ЕстьЗавершенныеЛМО()
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(*) КАК КоличествоЛМ
	|ИЗ
	|	Документ.ЛистМаркировкиОстатков КАК ЛистМаркировкиОстатков
	|ГДЕ
	|	ДокОснование = &ДокОснование
	|	И Завершен
	|	И НеПолный = Ложь
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", Объект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КоличествоЛМ) Тогда
		Результат = Истина;			
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ЕстьЗавершенныеЛМО()

&НаСервере
Функция ДозаполнитьКодыАгрегатов()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если Объект.фАгрегироватьБлочки Тогда
		рКолонки = ДозаполнитьКодыАгрегатов_ПоКолонке("ШтрихкодБлочка");
		Если НЕ рКолонки.Успешно Тогда
			МаркировкаКС.ДобавитьОшибки(Результат, рКолонки);		
		КонецЕсли; 
	КонецЕсли; 
	
	Если Объект.фАгрегироватьКоробки Тогда
		рКолонки = ДозаполнитьКодыАгрегатов_ПоКолонке("ШтрихкодКоробки");
		Если НЕ рКолонки.Успешно Тогда
			МаркировкаКС.ДобавитьОшибки(Результат, рКолонки);		
		КонецЕсли;
	КонецЕсли;	
	
	Если Объект.фАгрегироватьПалеты Тогда
		рКолонки = ДозаполнитьКодыАгрегатов_ПоКолонке("ШтрихкодПалеты");
		Если НЕ рКолонки.Успешно Тогда
			МаркировкаКС.ДобавитьОшибки(Результат, рКолонки);		
		КонецЕсли; 
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ДозаполнитьКодыАгрегатов_ПоКолонке(ИмяКолонки)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИмяКолонки				КАК ШтрихКод,
	|	ИмяКолонки.Владелец 	КАК НоменклатураТек,
	|	ИмяКолонки.Владелец.Код КАК НоменклатураТек_Код
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И ИмяКолонки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И ИмяКолонки.Владелец <> &Номенклатура
	|";	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИмяКолонки", ИмяКолонки);
	
	Запрос.УстановитьПараметр("Ссылка",		  Объект.Ссылка);
	Запрос.УстановитьПараметр("Номенклатура", Объект.Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.НоменклатураТек) Тогда
			ТекстОшибки = СтрШаблон("Код агрегата: %1 принадлежит другой номенклатуре (%2 (%3)) !", 
			// Кельманов А.В. - HELP-3081 - 2025.02.27 {
			//Выборка.ШтрихкодБлочка, Выборка.НоменклатураТек, Выборка.НоменклатураТек_Код);
			Выборка.ШтрихКод, Выборка.НоменклатураТек, Выборка.НоменклатураТек_Код);
			// Кельманов А.В. - HELP-3081 - 2025.02.27 }
			Результат.Ошибки.Добавить(ТекстОшибки);
		Иначе
			УстановитьРеквизитыОбъекта(Выборка.ШтрихКод, Новый Структура("Владелец", Объект.Номенклатура));		
		КонецЕсли; 			
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ДозаполнитьКодыАгрегатов_ПоКолонке(ИмяКолонки)
 
