&НаКлиенте
Процедура ПечатьВсехКодов(Команда)              
	//Валетов + 30,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3473
	//Запрещаем маркировать в ЗНМ Спайки      
	рШапки = ПолучитьРеквизитыШапки(Объект.Номенклатура, "ВидКомплекта,Родитель.ВидНоменклатуры");
	Если (рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.АссортитоКомплектов 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
		И рШапки.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
		СообщитьИзМодуля("Комплекты (спайки) и Ассортито необходимо маркировать через ЗСБ+ЛСК.");
		Возврат;
	КонецЕсли;
	//Валетов -

	// Кухарь А.Ю. 06.05.2025 начало
	Если объект.ДатаНачалаСканирования = ПустаяДата() Тогда
		Объект.ДатаНачалаСканирования = ТекущаяДата();
	КонецЕсли;
	// Кухарь А.Ю. 06.05.2025 конец
	
	// Шворобей ВЮ 03.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	Если Объект.ШтрихкодыУпаковок.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не заполнены коды маркировки !");		
		Возврат;			
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДокОснование) И ТипЗнч(Объект.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Если ПроверитьНоменклатуруЗНМ_НаОснованииРНК() = Истина Тогда Возврат; КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 03.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	
	Если НЕ МаркировкаК.ЗаписатьИзмененныйОбъектВУпрФорме(ЭтаФорма, Истина) Тогда Возврат; КонецЕсли;
	
	Номера = Новый Соответствие;
	Для Каждого Строка Из Объект.ШтрихкодыУпаковок Цикл
		Если Объект.фАгрегироватьПалеты Тогда
			Если ЗначениеЗаполнено(Строка.НомерПалеты) Тогда
				Номера[Строка.НомерПалеты] = Истина;
			КонецЕсли; 
		Иначе
			Если ЗначениеЗаполнено(Строка.НомерКоробки) Тогда
				Номера[Строка.НомерКоробки] = Истина;
			КонецЕсли;					
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КиЗ Из Номера Цикл
		ТекНомер = КиЗ.Ключ;
		Если Объект.фАгрегироватьПалеты Тогда
			рПечати = НапечататьКодыПоПалетам_НаСервере(ТекНомер, , ,Истина);
		Иначе
			рПечати = НапечататьКодыПоПалетам_НаСервере(0, ТекНомер, ,Истина);
		КонецЕсли;
		
		Если рПечати.Успешно Тогда     			
			Если фПечататьЛентуСразуНаПинтер Тогда
				рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
			Иначе
				рПечати.Данные.Показать("Все этикетки по ЗНМ №: " + Объект.Номер);				
			КонецЕсли;			
		Иначе
			МаркировкаКС.ВывестиОшибки(рПечати.Ошибки);
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура фУпрощенныйРежим_ПриИзменении(Элемент)
	Если Объект.фУпрощенныйРежим Тогда	
		фПечататьЛентуСразуНаПринтер = Ложь;
	КонецЕсли;
	
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура СоздатьБитыйЛН(Команда)
	ТекДанные = Элементы.ШтрихкодыУпаковок.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекДанные.ЛистМаркировки) И НЕ МаркировкаС.ОбъектСуществует(ТекДанные.ЛистМаркировки) Тогда
			Если ЗначениеЗаполнено(ТекДанные.ШтрихкодУпаковки) Тогда
				ЛМ = СоздатьЛистМаркировки(ТекДанные.ШтрихкодУпаковки.Владелец, Новый Структура("СсылкаНового", ТекДанные.ЛистМаркировки));
				Сообщить("Создан ЛМ: " + ЛМ, СтатусСообщения.Информация);
			КонецЕсли; 			
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьКодКоробки(Команда)
	Если Объект.Ссылка.Пустая()  Тогда
		ПоказатьПредупреждение(, "Документ не записан !");
		Возврат;	
	КонецЕсли;
	
	ТекДанные = Элементы.ШтрихкодыУпаковок.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекДанные.ШтрихкодКоробки) Тогда
		рЗамены = ЗаменитьКодКоробки_НаСервере(ТекДанные.ШтрихкодКоробки);				
		Если рЗамены.Успешно Тогда
		Иначе
			МаркировкаКС.ВывестиОшибки(рЗамены);
		КонецЕсли; 
	Иначе
		ПоказатьПредупреждение(, "Не указан код коробки в выбраной строке !");
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция ЗаменитьКодКоробки_НаСервере(ШтрихкодКоробкиСтарый)
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	рПолучения = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныйКодАгрегации(Перечисления.ТипыШтрихКодов.Коробка, Перечисления.ТипыУпаковок.МонотоварнаяУпаковка, Объект.Ссылка, Новый Структура("Добавлять", Истина));
	
	Если рПолучения.Успешно Тогда
		ШтрихкодКоробкиНовый = рПолучения.Данные;
		СтрокиТЧ = Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодКоробки", ШтрихкодКоробкиСтарый));	
		Для Каждого СтрокаТЧ Из СтрокиТЧ Цикл
			СтрокаТЧ.ШтрихкодКоробки = ШтрихкодКоробкиНовый;
		КонецЦикла; 
		
		Попытка
		    Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
		Исключение
			Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
			Результат.Ошибки.Добавить("Не удалось провести документ ! " + ОписаниеОшибки());		
		КонецПопытки;
		
		УстановитьРеквизитыОбъекта(ШтрихкодКоробкиНовый, Новый Структура("Владелец", ПолучитьРеквизитШапки(ШтрихкодКоробкиСтарый, "Владелец")));
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;	
КонецФункции

&НаСервереБезКонтекста
Функция СоздатьАгрегацию_НаСервере(ЗНМ_Ссылка)
	Возврат Документы.ЗаданиеНаМаркировку.Создать_Агрегации(ЗНМ_Ссылка, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.КОбработке));	
КонецФункции

&НаКлиенте
Процедура СоздатьАгрегацию(Команда)
	Если МаркировкаК.ЗаписатьИзмененныйОбъектВУпрФорме(ЭтаФорма) Тогда
		рСоздания = СоздатьАгрегацию_НаСервере(Объект.Ссылка);
		Если рСоздания.Успешно Тогда
			Сообщить("Оформлена агрегация: " + рСоздания.Данные);
		Иначе
			МаркировкаКС.ВывестиОшибки(рСоздания);
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

