#Область СобытияФормы
	
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка.Пустая() Тогда
		СсылкаДляОтбора = Документы.ЗаданиеНаМаркировку.ПолучитьСсылку(Новый УникальныйИдентификатор);
		Объект.фУпрощенныйРежим = Истина;
	Иначе                 
		СсылкаДляОтбора = Объект.Ссылка;		
	КонецЕсли;
	
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(СписокЛМО, 			"ДокОснование", СсылкаДляОтбора);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(СписокЛистыМаркировки, 	"ДокОснование", СсылкаДляОтбора);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(СписокАгрегаций, 		"ДокОснование", СсылкаДляОтбора);
	
	УправлениеВидимостью();
	
	фПечататьЛентуСразуНаПринтер = НЕ Объект.фУпрощенныйРежим;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	Если ТолькоПросмотр Тогда Возврат КонецЕсли;	
	Если НЕ ВводДоступен() Тогда Возврат КонецЕсли;
	
	Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	
	Данные = Лев(СтрЗаменить(Данные, Символы.ПС, ""), 31);
	
	глТорговоеОборудование.СканерПосылкаДанных(1);
	глСобытиеСканераОтработано = Истина;
	
	// Кухарь А.Ю. 06.05.2025 начало
	если Лев(Данные,3)="777" тогда 
		Объект.Исполнитель = НайтиФизЛицоПоШК(Данные); 
		Сообщить("Установлен сотрудник - "+Объект.Исполнитель);
		Возврат;
	КонецЕсли;
	// Кухарь А.Ю. 06.05.2025 конец
			
	
	Если Объект.фУпрощенныйРежим И Объект.СостояниеНакладной <> Перечисления.СостоянияНакладной.ВРаботе Тогда
		Возврат;	
	КонецЕсли; 
	
	Если СтрДлина(Данные)> 13 Тогда
		
		Сообщить("В данном документе разрешено сканировать только EAN 13 !", СтатусСообщения.Важное);
		
	Иначе
		
		ТекущаяНоменклатура = НайтиТоварПоШтрихКоду(Данные, Неопределено, 0, Неопределено, Ложь);
		
		Если Объект.фУпрощенныйРежим Тогда
			
			Объект.Номенклатура = ТекущаяНоменклатура;
			
			НоменклатураПриИзменении_НаСервере(); // Кельманов А.В. - HELP-6652 - 2025.08.19
			
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Объект.фУпрощенныйРежим Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.Номенклатура;	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура УправлениеВидимостью()
	фКоробки = Истина;
	
	Если РольДоступна("Администратор") Тогда	
		Элементы.СостояниеНакладной.ТолькоПросмотр		= ТолькоПросмотр;	
		
		//Элементы.ШтрихкодыУпаковок.ТолькоПросмотр		= ТолькоПросмотр;
		//Элементы.ШтрихкодыУпаковок.ИзменятьСоставСтрок= Истина;
		
		Элементы.ШтрихкодыУпаковокРаспечатан.Доступность = Истина;
	КонецЕсли;
	
	Если Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена Тогда
		Если НЕ РольДоступна("Администратор") Тогда
			ТолькоПросмотр 								= Истина;
			Элементы.кнНапечататьКодыПоЛН.Доступность 	= Ложь;
		КонецЕсли;
		
		Элементы.кнЗавершитьМаркировку.Доступность = Ложь;
		Элементы.кмЗаменитьКодКоробки.Доступность = Ложь;
	КонецЕсли; 
	
	Если Объект.СостояниеНакладной <> Перечисления.СостоянияНакладной.ВРаботе Тогда		
		Элементы.кнЗаполнитьАгрегации.Доступность		= Ложь;
		Элементы.фУпрощенныйРежим.Доступность			= Ложь;
				
		Элементы.гМаркировкаУпрощенная.ТолькоПросмотр 	= Истина;
		Элементы.Номер.ТолькоПросмотр		= Истина;
		Элементы.Дата.ТолькоПросмотр		= Истина;
		Элементы.Комментарий.ТолькоПросмотр	= Истина;
		
		Элементы.ШтрихкодыУпаковок.ТолькоПросмотр = Истина;
		
		Элементы.Организация.ТолькоПросмотр 	= Истина;
		Элементы.Подразделение.ТолькоПросмотр	= Истина;
	КонецЕсли;	
	
	Элементы.кнНапечататьЛенту.Видимость		= НЕ Объект.фУпрощенныйРежим;
	Элементы.кнНапечататьПалеты.Видимость		= Объект.фУпрощенныйРежим;
	
	Элементы.кнЗаполнитьАгрегации.Видимость		= Объект.фУпрощенныйРежим;
	Элементы.гМаркировкаОбычная.Видимость		= НЕ Объект.фУпрощенныйРежим;
	Элементы.гМаркировкаУпрощенная.Видимость	= Объект.фУпрощенныйРежим;
	Элементы.КоличествоШтукВЛенте.Видимость		= НЕ Объект.фУпрощенныйРежим;
	
	Элементы.ШтукВБлочке.Доступность	= Объект.фАгрегироватьБлочки;
	Элементы.ШтукНаПалете.Доступность	= Объект.фАгрегироватьПалеты;
	Элементы.КоличествоПалет.Доступность= Объект.фАгрегироватьПалеты;
	
	Элементы.кмПалетныйРежим.Видимость	= Объект.фУпрощенныйРежим;
	Элементы.кмОбычныйРежим.Видимость	= НЕ Объект.фУпрощенныйРежим;      
	
	
	// Кухарь А.Ю. 06.05.2025 начало
	Элементы.ДатаНачалаСканирования.Видимость	 = ЗначениеЗаполнено(Объект.ДатаНачалаСканирования);
 	Элементы.ДатаОкончанияСканирования.Видимость = ЗначениеЗаполнено(Объект.ДатаОкончанияСканирования); 
	элементы.Исполнитель.Видимость 		 = ЗначениеЗаполнено(Объект.Исполнитель); 
	// Кухарь А.Ю. 06.05.2025 конец
	
	// Шворобей ВЮ 03.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	Элементы.кнНапечататьПалеты.Доступность = Объект.фУпрощенныйРежим И Объект.ШтрихкодыУпаковок.Количество() > 0;
	// Шворобей ВЮ 03.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	
КонецПроцедуры

&НаКлиенте
Процедура НапечататьЛенту(Команда)
	//Валетов + 30,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3473
	//Запрещаем маркировать в ЗНМ Спайки      
	рШапки = ПолучитьРеквизитыШапки(Объект.Номенклатура, "ВидКомплекта,Родитель.ВидНоменклатуры");
	Если (рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.АссортитоКомплектов 
		ИЛИ рШапки.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
		И рШапки.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
		СообщитьИзМодуля("Комплекты (спайки) и Ассортито необходимо маркировать через ЗСБ+ЛСК.");
		Возврат;
	КонецЕсли;
	//Валетов -
	
	// Кухарь А.Ю. 06.05.2025 начало
	Если Объект.ДатаНачалаСканирования = ПустаяДата() Тогда
		Объект.ДатаНачалаСканирования = ТекущаяДата();
	КонецЕсли;
	// Кухарь А.Ю. 06.05.2025 конец
	
	Ошибки = "";
	Если ТекущаяНоменклатура.Пустая() Тогда
		Ошибки = "Не выбрана номенклатура !";
	Иначе
		Если КоличествоШтукВЛенте = 0  Тогда
			КоличествоШтукВЛенте = ПолучитьРеквизитШапки(ТекущаяНоменклатура, "Родитель.ШтукВКоробке");	
		КонецЕсли;
		Если КоличествоШтукВЛенте = 0 Тогда
			Ошибки = "Нулевое количество штук в ленте !";			
		КонецЕсли;		
	КонецЕсли;    
	
	Если НЕ ПустаяСтрока(Ошибки) Тогда
		ПоказатьПредупреждение(, Ошибки);
		Возврат;	
	КонецЕсли;
	
	// Шворобей ВЮ 01.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
	Если ЗначениеЗаполнено(Объект.ДокОснование) И ТипЗнч(Объект.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Если ПроверитьНоменклатуруЗНМ_НаОснованииРНК() = Истина Тогда Возврат; КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 01.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4874
		
	Если Объект.Ссылка.Пустая() Тогда	
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	ИначеЕсли Модифицированность Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));	
	КонецЕсли;
	
	рЗаполнения = ЗаполнитьКодыНовойЛенты(ТекущаяНоменклатура, КоличествоШтукВЛенте);
	Если рЗаполнения.Успешно Тогда		
		Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.Сканирование;  		
		Записать();		
		ТекущийЛистМаркировки = рЗаполнения.ЛистМаркировки;	
		
		рПечати = НапечататьКодыПоЛН_НаСервере(ТекущийЛистМаркировки);					
		Если рПечати.Успешно Тогда
			Если фПечататьЛентуСразуНаПинтер Тогда
				рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
			Иначе					
				рПечати.Данные.Показать("Этикетки по ЛМ: " + ТекущийЛистМаркировки);
			КонецЕсли; 				
		Иначе
			Сообщить(СтрСоединить(рПечати.Ошибки, Символы.ПС), СтатусСообщения.Важное); 
		КонецЕсли;
		
		ОткрытьФорму("Документ.ЛистМаркировкиОстатков.Форма.ФормаДокумента", Новый Структура("Ключ", ТекущийЛистМаркировки), ЭтаФорма, 1, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		Сообщить(СтрСоединить(рЗаполнения.Ошибки, Символы.ПС), СтатусСообщения.Важное);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура НапечататьПалеты(Команда)
	Если Объект.Ссылка.Пустая() Тогда
		ПоказатьПредупреждение(, "Документ не записан !");
		Возврат;
	КонецЕсли;
	
	Если Объект.ШтрихкодыУпаковок.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не заполнены коды маркировки !");		
		Возврат;			
	КонецЕсли;
	
	Если Модифицированность Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
	КонецЕсли;
	
	Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ДопОбработка;
	Записать();	
	
	рПечати = НапечататьКодыПоПалетам_НаСервере();		
	Если рПечати.Успешно Тогда
		Если фПечататьЛентуСразуНаПинтер Тогда
			рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
		Иначе					
			рПечати.Данные.Показать("Этикетки по ЗНМ: " + Объект.Номер);
		КонецЕсли; 				
	Иначе
		Сообщить(СтрСоединить(рПечати.Ошибки, Символы.ПС), СтатусСообщения.Важное); 
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьКодыНовойЛенты(ВыбНоменклатура, Знач КолШтук = 0)	
	Если КолШтук = 0 Тогда
		Результат = ЗаполнитьКодыНовойЛенты_Коробка(ВыбНоменклатура);
	Иначе
		Результат = ЗаполнитьКодыНовойЛенты_ПроизвольноеКоличество(ВыбНоменклатура, КолШтук);		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗаполнитьКодыНовойЛенты(ВыбНоменклатура)

&НаСервере
Функция ЗаполнитьКодыНовойЛенты_Коробка(ВыбНоменклатура)	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ШтукВКоробке	= ПолучитьРеквизитШапки(ВыбНоменклатура, "Родитель.ШтукВКоробке");	
	
	ЛистМаркировки	= СоздатьЛистМаркировки(ВыбНоменклатура);	
	
	рПолучения = ПолучитьЗабронироватьСвободныеКодыАгрегации(Перечисления.ТипыШтрихКодов.Коробка, 1);
	Если рПолучения.Успешно Тогда
		ШтрихкодКоробки = рПолучения.Данные[0];
		
		ТекстСообщения = СтрШаблон("Получение КМ коробки, получено: %2 кодов.", ВыбНоменклатура, ШтукВКоробке);
		ЗаписатьВЛог("Получение свободных КМ", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000);
		
		рПолучения = ПолучитьЗабронироватьСвободныеКодыШтук(ВыбНоменклатура, ШтукВКоробке, Объект.Подразделение);
		Если рПолучения.Успешно Тогда
			КодыШтук = рПолучения.Данные;		
			
			Для Каждого КиЗ Из рПолучения.Данные Цикл
				Для Каждого ШтрихКодУпаковки Из КиЗ.Значение Цикл
					СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();
					
					СтрокаТЧ.ШтрихкодУпаковки	= ШтрихКодУпаковки;
					СтрокаТЧ.ШтрихкодКоробки	= ШтрихкодКоробки;
					СтрокаТЧ.ЛистМаркировки		= ЛистМаркировки;				
					СтрокаТЧ.ДатаБронированияКМ = ТекущаяДата();
				КонецЦикла;
			КонецЦикла;			
			
			ТекстСообщения = СтрШаблон("Получение КМ по ном. %1, получено: %2 кодов.", ВыбНоменклатура, ШтукВКоробке);
			ЗаписатьВЛог("Получение свободных КМ", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало)/1000);
			
			Если Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе Тогда
				Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.Сканирование; 			
			КонецЕсли; 
			
			Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Проведение));
			
			Результат.Вставить("ЛистМаркировки", ЛистМаркировки);
		Иначе			
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
			ЗаписатьПроНехваткуКодов(ВыбНоменклатура, рПолучения);
		КонецЕсли;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
	КонецЕсли;	
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Результат.Успешно = Ложь;		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ЗаполнитьКодыНовойЛенты(ВыбНоменклатура)

&НаСервере
Функция ЗаполнитьКодыНовойЛенты_ПроизвольноеКоличество(ВыбНоменклатура, КолШтук)
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат = МаркировкаКС.СтруктураРезультата();	
		
	рПолучения = ПолучитьЗабронироватьСвободныеКодыШтук(ВыбНоменклатура, КолШтук, Объект.Подразделение);
	Если рПолучения.Успешно Тогда		
		ЛМО_Ссылка	= СоздатьЛистМаркировки(ВыбНоменклатура, Новый Структура("НеПолный", (КолШтук < ШтукВКоробке(ВыбНоменклатура))));
		
		Для Каждого КиЗ Из рПолучения.Данные Цикл
			Для Каждого ШтрихКодУпаковки Из КиЗ.Значение Цикл
				СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();
				
				СтрокаТЧ.ШтрихкодУпаковки	= ШтрихКодУпаковки;			
				СтрокаТЧ.ЛистМаркировки		= ЛМО_Ссылка;
				СтрокаТЧ.ДатаБронированияКМ = ТекущаяДата();
			КонецЦикла;
		КонецЦикла;		
		
		Если Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе Тогда
			Объект.СостояниеНакладной = Перечисления.СостоянияНакладной.Сканирование; 			
		КонецЕсли; 
		
		Записать();
		
		Результат.Вставить("ЛистМаркировки", ЛМО_Ссылка);
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		ЗаписатьПроНехваткуКодов(ВыбНоменклатура, рПолучения);
	КонецЕсли;	
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Результат.Успешно = Ложь;		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗаполнитьКодыНовойЛенты_ПроизвольноеКоличество(ВыбНоменклатура, КолШтук)

&НаСервере
Процедура ЗаписатьПроНехваткуКодов(Номенклатура, рПолучения)
	ТекстСообщения = СтрШаблон(
		"Недостаточно кодов ЧЗ по ном.: %1 (%2). 
		|Док. бронирования: %3, основание: %4 !", 
		Номенклатура, ПолучитьРеквизитШапки(Номенклатура, "Код"), Объект.Ссылка, Объект.ДокОснование
	);
	
	ТекстСообщения = ТекстСообщения + "
	|" + СтрСоединить(рПолучения.Ошибки, Символы.ПС);
	
	ЗаписатьВЛог("Нехватка КМ", ТекстСообщения, "Ошибка");
КонецПроцедуры //ЗаписатьПроНехваткуКодов(Номенклатура, рПолучения) 

