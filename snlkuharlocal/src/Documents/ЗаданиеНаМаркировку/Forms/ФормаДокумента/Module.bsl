		пБронирования.Вставить("НовыйСтатус", Перечисления.СтатусыКодовМаркировкиФакт.Нанесен);	
	КонецЕсли;
	Возврат Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Номенклатура, Объект.Ссылка, пБронирования);
КонецФункции
	
&НаСервере
Функция ПолучитьЗабронироватьТаблицуАгрегации(КолШтук, КолКоробок, КолПалет = 0, КолБлочков = 0)	
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если Объект.ШтукВКоробке = 0 Тогда
		Результат.Ошибки.Добавить("Не указано количество штук в коробке !");
		Результат.Успешно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	КодыПалет	= Новый Массив;
	КодыКоробок	= Новый Массив;
	КодыБлочков = Новый Массив;
	КодыШтук	= Новый Массив;
	
	ТР = Новый ТаблицаЗначений;
	ТР.Колонки.Добавить("ШтрихКодУпаковки");
	ТР.Колонки.Добавить("ШтрихКодКоробки");	
	ТР.Колонки.Добавить("НомерКоробки");
			
	Если КолБлочков > 0 Тогда
		рПолучения = ПолучитьЗабронироватьСвободныеКодыАгрегации(Перечисления.ТипыШтрихКодов.Блочок, КолБлочков);			
		Если рПолучения.Успешно Тогда
			КодыБлочков = рПолучения.Данные;
			ТР.Колонки.Добавить("ШтрихКодБлочка");
			ТР.Колонки.Добавить("НомерБлочка");
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		КонецЕсли;
	КонецЕсли;			
	
	Если КолПалет > 0 Тогда
		рПолучения = ПолучитьЗабронироватьСвободныеКодыАгрегации(Перечисления.ТипыШтрихКодов.Палета, КолПалет);
		Если рПолучения.Успешно Тогда
			КодыПалет = рПолучения.Данные;
			
			ТР.Колонки.Добавить("ШтрихКодПалеты");
			ТР.Колонки.Добавить("НомерПалеты");
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		КонецЕсли;	
	КонецЕсли; 
	
	Если КолКоробок > 0 И Объект.фАгрегироватьКоробки Тогда
		рПолучения = ПолучитьЗабронироватьСвободныеКодыАгрегации(Перечисления.ТипыШтрихКодов.Коробка, КолКоробок);
		Если рПолучения.Успешно Тогда
			КодыКоробок = рПолучения.Данные;
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		КонецЕсли;	
	КонецЕсли;	
	
	рПолучения = ПолучитьЗабронироватьСвободныеКодыШтук(Объект.Номенклатура, КолШтук, Объект.Подразделение);
	Если рПолучения.Успешно Тогда
		КодыШтук = рПолучения.Данные[Объект.Номенклатура];
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);		
	КонецЕсли;
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Результат.Успешно = Ложь;
		Возврат Результат;		
	КонецЕсли;	
	
	Сч = 0;
	Для Каждого ШтрихКодУпаковки Из КодыШтук Цикл
		СтрокаТР = ТР.Добавить();
		
		СтрокаТР.ШтрихКодУпаковки 	= ШтрихКодУпаковки;
		
		СтрокаТР.НомерКоробки		= Цел(Сч/Объект.ШтукВКоробке)+1;
		
		Если Объект.фАгрегироватьКоробки > 0 Тогда		
			СтрокаТР.ШтрихКодКоробки	= КодыКоробок[СтрокаТР.НомерКоробки-1];
		КонецЕсли;		
		
		Если КолБлочков > 0 Тогда			
			СтрокаТР.НомерБлочка	= Цел(Сч/Объект.ШтукВБлочке)+1;
			СтрокаТР.ШтрихКодБлочка = КодыБлочков[СтрокаТР.НомерБлочка-1];
		КонецЕсли; 
		
		Если КолПалет > 0 Тогда			
			СтрокаТР.НомерПалеты	= Цел(Сч/Объект.ШтукНаПалете)+1;
			СтрокаТР.ШтрихКодПалеты = КодыПалет[СтрокаТР.НомерПалеты-1];
		КонецЕсли;
		
		Сч = Сч + 1;
	КонецЦикла;
	
	Записать();
	
	Результат.Данные = ТР;
	
	Возврат Результат;
КонецФункции //ПолучитьКодыДляКоробки(ВыбНоменклатура)

&НаКлиенте
Функция ПроверитьКратность()
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если Объект.Номенклатура.Пустая() Тогда
		Результат.Ошибки.Добавить("Не выбрана номенклатура !");	
	КонецЕсли; 
	
	Если Объект.фАгрегироватьКоробки Тогда
		Если Объект.ШтукВКоробке = 0 Тогда		
			Результат.Ошибки.Добавить("Не указано количество штук в коробке !");
		Иначе		
			мКолКоробок = Объект.КоличествоДокумента / Объект.ШтукВКоробке;
			Если мКолКоробок <> Цел(мКолКоробок) Тогда
				Результат.Ошибки.Добавить("Дробное количество коробок !");
			КонецЕсли;
		КонецЕсли; 	
	КонецЕсли;
	
	Если Объект.фАгрегироватьБлочки Тогда
		Если Объект.ШтукВБлочке = 0 Тогда		
			Результат.Ошибки.Добавить("Не указано количество штук в блочке !");
		Иначе
			мКолБлочков = Объект.КоличествоДокумента / Объект.ШтукВБлочке;
			Если мКолБлочков = Цел(мКолБлочков) Тогда
				мКолКоробок = мКолБлочков / Объект.КоличествоКоробок;
				Если мКолКоробок <> Цел(мКолКоробок) Тогда
					Результат.Ошибки.Добавить("Дробное количество коробок по блочкам !");									
				КонецЕсли; 
			Иначе				
				Результат.Ошибки.Добавить("Дробное количество штук на блочок !");
			КонецЕсли;			
		КонецЕсли;	
	КонецЕсли; 
	
	Если Объект.фАгрегироватьПалеты Тогда
		Если Объект.КоличествоПалет = 0  Тогда					
			Результат.Ошибки.Добавить("Не указано количество палет !");			
		Иначе
			Если Объект.ШтукНаПалете = 0 Тогда		
				Результат.Ошибки.Добавить("Не указано количество штук на палете !");
			Иначе
				мКолПалет = Объект.КоличествоДокумента / Объект.ШтукНаПалете;
				Если мКолПалет = Цел(мКолПалет) Тогда
					мКоробокНаПалету = Объект.КоличествоКоробок / Объект.КоличествоПалет;
					Если мКоробокНаПалету <> Цел(мКоробокНаПалету) Тогда
						Результат.Ошибки.Добавить("Дробное количество коробок на палете !");									
					КонецЕсли; 
				Иначе				
					Результат.Ошибки.Добавить("Дробное количество штук на палете !");
				КонецЕсли;			
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	
	Результат.Успешно = ( Результат.Ошибки.Количество() = 0 );
	
	Возврат Результат;
КонецФункции //ПроверитьКратность()

&НаСервере
Функция СоздатьЛистМаркировки(Номенклатура, ДопПараметры = Неопределено)
	ЛН_Объект = Документы.ЛистМаркировкиОстатков.СоздатьДокумент();	
	ЛН_Объект.Заполнить(Объект.Ссылка); 	
	
	ЛН_Объект.Дата			= ТекущаяДата();	
	//+++Чирков 30.09.2025 - иногда колотят пальцами по кнопкам так, что получаются одинаковые даты ЗНМ и ЛМО
	Если ЛН_Объект.Дата = Объект.Дата Тогда
		ЛН_Объект.Дата = ЛН_Объект.Дата + 1;
	КонецЕсли;
	//---Чирков 30.09.2025
	ЛН_Объект.Номенклатура	= Номенклатура;
	
	СсылкаНового = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "СсылкаНового");
	Если ЗначениеЗаполнено(СсылкаНового) Тогда
		ЛН_Объект.УстановитьСсылкуНового(СсылкаНового);			
	КонецЕсли;
	
	ЛН_Объект.НеПолный = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "НеПолный", Ложь);	
	
	ЛН_Объект.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат ЛН_Объект.Ссылка;	
КонецФункции //СоздатьЛистМаркировки() 

