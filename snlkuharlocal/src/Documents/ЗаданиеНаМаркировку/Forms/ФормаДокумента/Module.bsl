&НаКлиенте
Процедура ШтрихкодыУпаковок_Выбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если ВыбраннаяСтрока<>Неопределено И Поле <> Неопределено Тогда
		ДанныеСтроки = Объект.ШтрихкодыУпаковок.НайтиПоИдентификатору(ВыбраннаяСтрока);		
		
		Реквизит = Сред(Поле.Имя, СтрДлина(Элемент.Имя)+1);	
		
		Если СтрНачинаетсяС(Реквизит, "ШтрихкодУпаковкиВладелецРодитель") Тогда
			Значение = ПолучитьРеквизитШапки(ДанныеСтроки.ШтрихкодУпаковки, "Владелец.Родитель");
		ИначеЕсли СтрНачинаетсяС(Реквизит, "ШтрихкодУпаковкиВладелец") Тогда	
			Значение = ПолучитьРеквизитШапки(ДанныеСтроки.ШтрихкодУпаковки, "Владелец");
		ИначеЕсли СтрНачинаетсяС(Реквизит, "ШтрихкодУпаковки") Тогда			
			Значение = ДанныеСтроки.ШтрихкодУпаковки;
		Иначе
			Значение = ДанныеСтроки[Реквизит]; 
		КонецЕсли;	
		
		ПоказатьЗначение(, Значение);
	КонецЕсли;
КонецПроцедуры

