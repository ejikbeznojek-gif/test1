&НаКлиенте
Процедура ПовторнаяПечать_Штуки(Команда)
	сКодыМаркировки = Новый Соответствие;
	КодыМаркировки = Новый Массив;
	
	Для Каждого ИдСтроки Из Элементы.ШтрихкодыУпаковок.ВыделенныеСтроки Цикл
		СтрокаТЧ = Объект.ШтрихкодыУпаковок.НайтиПоИдентификатору(ИдСтроки);		
		
		сКодыМаркировки[СтрокаТЧ.ШтрихкодУпаковки] = Истина;	
		КодыМаркировки.Добавить(СтрокаТЧ.ШтрихкодУпаковки);
	КонецЦикла;
	
	Если КодыМаркировки.Количество() = 0 Тогда Возврат КонецЕсли;
	
	Если НЕ МаркировкаК.ЗаписатьИзмененныйОбъектВУпрФорме(ЭтаФорма, Истина) Тогда Возврат КонецЕсли;
	
	ОтменитьПечатьКодов(сКодыМаркировки);
	
	рПечати = НапечататьКМ_НаСервере(КодыМаркировки, ПредопределенноеЗначение("Документ.ЛистМаркировкиОстатков.ПустаяСсылка"));
	Если рПечати.Успешно Тогда
		Если фПечататьЛентуСразуНаПинтер Тогда
			рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);			
		Иначе			
			рПечати.Данные.Показать("Этикети по КМ: " + СтрСоединить(КодыМаркировки, ","));
		КонецЕсли; 	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция НапечататьКодыПоЛН_НаСервере(ЛистМаркировки, ИмяМакета = "Этикетка_25_25_Остатки", СразуНаПринтер = Ложь)	
	Результат		= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(ЛистМаркировки) Тогда
		рПолучения		= ПолучитьКодыПоЛМ(ЛистМаркировки);
		ШтукВКоробке	= рПолучения.ШтукВКоробке;
	
		Если рПолучения.ШтрихКодыУпаковок.Количество() = 0 Тогда
			Результат.Ошибки.Добавить("Не найдено нераспечатанных КМ по листу маркировки: " + ЛистМаркировки);
		КонецЕсли;
	Иначе
		Результат.Ошибки.Добавить("Не выбран лист маркировки !");	
	КонецЕсли; 
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	НомерЛН 		= ПолучитьРеквизитШапки(ЛистМаркировки, "Номер");
	НомерКоробки    = Число(СтрРазделить(НомерЛН,"/")[1]);
	
	ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
	Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
	
	ТД = Новый ТабличныйДокумент;
	ТД.ОтображатьСетку		= Ложь;
	ТД.ОтображатьЗаголовки	= Ложь;
	// Смирнов М.Ю. 29.05.2025 HELP-3868 начало
	//ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_" + ИмяМакета;
	ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЗНМ_ЛН" + ИмяМакета;
	// Смирнов М.Ю. 29.05.2025 HELP-3868 конец
	
	РаспечатанныеКМ = Новый Соответствие;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ДанныеДляПечати	= Неопределено;
	ВсегоСтрок		= рПолучения.ШтрихКодыУпаковок.Количество();
	НомерШтуки  	= 1;
	Для Каждого ДанныеДляПечати Из рПолучения.ШтрихКодыУпаковок Цикл		
		НомерШтуки 		= ДанныеДляПечати.НомерСтроки - рПолучения.ПерваяСтрока + 1;
		
		ДопПараметры	= Новый Структура("НомерШтуки,НомерКоробки,ШтукВКоробке", НомерШтуки, НомерКоробки, ШтукВКоробке);
		Область 		= ОбработкаПечати.СформироватьЭтикету(Макет, ДанныеДляПечати, ДопПараметры);
		
		ТД.Вывести(Область);
		ТД.ВывестиГоризонтальныйРазделительСтраниц();
		
		Если фДублироватьКМ Тогда		
			ТД.Вывести(Область);
			ТД.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;		
		
		РаспечатанныеКМ[ДанныеДляПечати.ШтрихКодУпаковки] = Истина; 
	КонецЦикла;
	
	Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	ЗаписатьВЛог("Печать КМ", СтрШаблон("Сформировано: %1 этикеток ЧЗ. Скорость: %2 этикеток/сек.", Формат(ВсегоСтрок/Время, "ЧДЦ=0; ЧРГ=' '; ЧГ=3,0")), , , , Время);
	
	ЗаписатьРаспечатанныеКоды(РаспечатанныеКМ);
	
	Если рПолучения.ШтрихКодыУпаковок.Количество() = рПолучения.ШтукВКоробке И НЕ рПолучения.НеПолный Тогда
		ДопПараметры = Новый Структура("Артикул", МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеДляПечати,"Артикул", ""));
		// Кухарь А.Ю.  02.02.2025 начало
		Если СтрНайти(ИмяМакета,"25_25")>0 или СтрНайти(ИмяМакета,"25_50")>0 тогда
			ДопПараметры.Вставить("ОтображатьТекст",ложь);
		КонецЕсли;
		// Кухарь А.Ю.  02.02.2025 конец
		
		Область = ОбработкаПечати.СформироватьКА(Макет, рПолучения.ШтрихКодКоробки, НомерКоробки, ШтукВКоробке, ДопПараметры);	
		ТД.Вывести(Область);
	КонецЕсли;	
	
	Результат.Данные 	= ТД;
	Результат.Успешно 	= Истина;
	
	Возврат Результат;
КонецФункции //НапечататьКодыПоЛН_НаСервере(ЛистМаркировки, ИмяМакета	= "Этикетка_25_25_Остатки")

&НаСервере
Функция НапечататьКодыПоПалетам_НаСервере(НомерПалеты = 0, НомерКоробки = 0, НомерБлочка = 0, Повторно = Ложь, ИмяМакета = "Этикетка_25_25_Остатки")
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Данные = ПолучитьКодыПалеты(НомерПалеты, НомерКоробки, НомерБлочка, , Повторно);	
	
	ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
	Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
	
	ТД = Новый ТабличныйДокумент;
	ТД.ОтображатьСетку		= Ложь;
	ТД.ОтображатьЗаголовки	= Ложь;
	// Смирнов М.Ю. 29.05.2025 HELP-3868 начало
	ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЗНМ_ПАЛЕТ" + ИмяМакета;
	// Смирнов М.Ю. 29.05.2025 HELP-3868 конец
	
	РаспечатанныеКМ = Новый Соответствие;
	НомерШтуки  	= 1;	
	
	ВсегоСтрок 	= 0;
	Сч			= 0;
	Для Каждого Строка_Палета Из Данные.Строки Цикл
		ВсегоСтрок = Строка_Палета.ШтрихКодУпаковки;
	КонецЦикла;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Для Каждого Строка_Палета Из Данные.Строки Цикл
		Для Каждого Строка_Коробка Из Строка_Палета.Строки Цикл
			ПерваяСтрока = Строка_Коробка.НомерСтроки;
			Для Каждого Строка_Блочок Из Строка_Коробка.Строки Цикл
				Для Каждого Строка_КМ Из Строка_Блочок.Строки Цикл			
					НомерШтуки 		= Строка_КМ.НомерСтроки - ПерваяСтрока + 1;
					
					ДопПараметры	= Новый Структура(
					"НомерШтуки,НомерБлочка,НомерКоробки,НомерПалеты,ШтукВБлочке,ШтукВКоробке",
					НомерШтуки, Строка_КМ.НомерБлочка, Строка_КМ.НомерКоробки, Строка_КМ.НомерПалеты, Объект.ШтукВБлочке, Объект.ШтукВКоробке
					);
					Область 		= ОбработкаПечати.СформироватьЭтикету(Макет, Строка_КМ, ДопПараметры);
					
					ТД.Вывести(Область);
					ТД.ВывестиГоризонтальныйРазделительСтраниц();
					
					Если фДублироватьКМ Тогда		
						ТД.Вывести(Область);
						ТД.ВывестиГоризонтальныйРазделительСтраниц();
					КонецЕсли;
					
					РаспечатанныеКМ[Строка_КМ.ШтрихКодУпаковки] = Истина;
					Сч = Сч + 1;
					
					Если Сч % 10 = 0 Тогда						
						#ЕСЛИ ТолстыйКлиентОбычноеПриложение ТОГДА						
						Состояние(СтрШаблон("Выведено %1 из %2.", Сч, ВсегоСтрок));		
						#КОНЕЦЕСЛИ
					КонецЕсли; 
				КонецЦикла; 
				
				Если ЗначениеЗаполнено(Строка_Блочок.ШтрихКодБлочка) Тогда
					ДопПараметры = Новый Структура("ТипШК,НомерБлочка,Артикул,Цвет,Размер", Перечисления.ТипыШтрихКодов.Блочок); 
					ЗаполнитьЗначенияСвойств(ДопПараметры, Строка_Блочок);
					
					Область = ОбработкаПечати.СформироватьКА(Макет, Строка_Блочок.ШтрихкодБлочка, НомерКоробки, Объект.ШтукВКоробке, ДопПараметры);
					
					ТД.Вывести(Область);			
					ТД.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;		
			КонецЦикла; 
			
			//Валетов + 18,03,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8970
			// БЫЛО  Если НомерБлочка = 0 Тогда //Все блочки - нужно вывести код коробки  
			Если НомерБлочка = 0 И Объект.фАгрегироватьКоробки Тогда  //Для печати штук если нет коробов не выводим код коробки
			//Валетов -
				// Смирнов М.Ю. 21.07.2025 HELP-5941 начало
				//ДопПараметры 	= Новый Структура("ТипШК,Артикул,Цвет,Размер", Перечисления.ТипыШтрихКодов.Коробка);
				ДопПараметры 	= Новый Структура("ТипШК,Артикул,Цвет,Размер,ПечататьQR", Перечисления.ТипыШтрихКодов.Коробка); 
				ДопПараметры.ПечататьQR = Истина;
				// Смирнов М.Ю. 21.07.2025 HELP-5941 конец
				ЗаполнитьЗначенияСвойств(ДопПараметры, Строка_Коробка);
				
				// Кухарь А.Ю.  02.02.2025 начало
				//
				Если СтрНайти(ИмяМакета,"25_25")>0 или СтрНайти(ИмяМакета,"25_50")>0 тогда
					ДопПараметры.Вставить("ОтображатьТекст",ложь);
				КонецЕсли;
				// Кухарь А.Ю.  02.02.2025 конец
				
				Область 		= ОбработкаПечати.СформироватьКА(Макет, Строка_Коробка.ШтрихКодКоробки, Строка_Коробка.НомерКоробки, Объект.ШтукВКоробке, ДопПараметры);
				
				ТД.Вывести(Область);
				ТД.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
		КонецЦикла;
		
		Если (НомерБлочка = 0) И (НомерКоробки = 0) И ЗначениеЗаполнено(Строка_Палета.ШтрихКодПалеты) Тогда //Все коробки - нужно вывести код палеты
			ДопПараметры 	= Новый Структура("ТипШК,НомерПалеты,Артикул,Цвет,Размер", Перечисления.ТипыШтрихКодов.Палета);
			ЗаполнитьЗначенияСвойств(ДопПараметры, Строка_Палета);
			
			Область 		= ОбработкаПечати.СформироватьКА(Макет, Строка_Палета.ШтрихКодПалеты, Строка_Палета.НомерПалеты, Объект.ШтукВКоробке, ДопПараметры);
			
			ТД.Вывести(Область);					
			ТД.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли; 
	КонецЦикла;
	
	Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	Время = ?(Время = 0, 0.001, Время);
	ЗаписатьВЛог("Печать КМ", СтрШаблон("Сформировано: %1 этикеток ЧЗ. Скорость: %2 этикеток/сек.", ВсегоСтрок, Формат(ВсегоСтрок/Время, "ЧДЦ=0; ЧРГ=' '; ЧГ=3,0")), , , , Время);
	
	ЗаписатьРаспечатанныеКоды(РаспечатанныеКМ);	
	
	Результат.Данные 	= ТД;
	Результат.Успешно 	= Истина;
	
	Возврат Результат;
КонецФункции //НапечататьКодыПоЛН_НаСервере(ЛистМаркировки, ИмяМакета	= "Этикетка_25_25_Остатки")

&НаСервере
Функция НапечататьКМ_НаСервере(КодыМаркировки, ЛистМаркировки, ИмяМакета = "Этикетка_25_25_Остатки")	
	Результат		= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(КодыМаркировки) Тогда		
		рПолучения		= ПолучитьКодыПоЛМ(ЛистМаркировки, КодыМаркировки);
		ШтукВКоробке	= рПолучения.ШтукВКоробке;
	
		Если рПолучения.ШтрихКодыУпаковок.Количество() = 0 Тогда
			Результат.Ошибки.Добавить("Не найдено нераспечатанных КМ по листу маркировки: " + ЛистМаркировки);
		КонецЕсли;
	Иначе		
		Результат.Ошибки.Добавить("Не выбраны коды маркировки для печати !");	
	КонецЕсли; 
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЛистМаркировки) Тогда
		НомерЛН 		= ПолучитьРеквизитШапки(ЛистМаркировки, "Номер");
		НомерКоробки    = Число(СтрРазделить(НомерЛН,"/")[1]);	
		НачСтрокиКоробок= Неопределено;
	Иначе		
		НомерКоробки    = 0;
		НачСтрокиКоробок= НачСтрокиКоробок(КодыМаркировки);
	КонецЕсли;
	
	ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
	Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
	
	ТД = Новый ТабличныйДокумент;
	ТД.ОтображатьСетку		= Ложь;
	ТД.ОтображатьЗаголовки	= Ложь;	
	// Смирнов М.Ю. 29.05.2025 HELP-3868 начало
	ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЗНМ_КМ"+ИмяМакета;
	// Смирнов М.Ю. 29.05.2025 HELP-3868 конец
	
	РаспечатанныеКМ = Новый Соответствие;
	
	ДанныеДляПечати	= Неопределено;	
	Для Каждого ДанныеДляПечати Из рПолучения.ШтрихКодыУпаковок Цикл
		НомерШтуки		= ДанныеДляПечати.НомерСтроки - рПолучения.ПерваяСтрока + 1;
		ДопПараметры	= Новый Структура("НомерШтуки,НомерКоробки,ШтукВКоробке", НомерШтуки, НомерКоробки, ШтукВКоробке);
		Если НомерКоробки = 0 Тогда		
			НачалоКоробки 	= МаркировкаКС.ПолучитьЗначениеПараметра(НачСтрокиКоробок, ДанныеДляПечати.ШтрихКодУпаковки, ДанныеДляПечати.НомерСтроки);
			
			ДопПараметры.Вставить("НомерШтуки", 	ДанныеДляПечати.НомерСтроки - НачалоКоробки + 1);
			ДопПараметры.Вставить("НомерКоробки",	ДанныеДляПечати.НомерКоробки);
		КонецЕсли; 
		Область 		= ОбработкаПечати.СформироватьЭтикету(Макет, ДанныеДляПечати, ДопПараметры);
		
		ТД.Вывести(Область);
		ТД.ВывестиГоризонтальныйРазделительСтраниц();
		
		Если фДублироватьКМ Тогда
			ТД.Вывести(Область);
			ТД.ВывестиГоризонтальныйРазделительСтраниц();					
		КонецЕсли; 
		
		НомерШтуки = НомерШтуки + 1;		
		
		РаспечатанныеКМ[ДанныеДляПечати.ШтрихКодУпаковки] = Истина; 
	КонецЦикла; 
	
	ЗаписатьРаспечатанныеКоды(РаспечатанныеКМ);
	
	Результат.Данные 	= ТД;
	Результат.Успешно 	= Истина;
	
	Возврат Результат;
КонецФункции //НапечататьКодыПоЛН_НаСервере(ЛистМаркировки, ИмяМакета	= "Этикетка_25_25_Остатки")

&НаСервере
Процедура ЗаписатьРаспечатанныеКоды(РаспечатанныеКМ)
	Изменили = Ложь;
	Для Каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок Цикл
		Если РаспечатанныеКМ[СтрокаТЧ.ШтрихкодУпаковки] = Истина И НЕ СтрокаТЧ.Распечатан Тогда
			СтрокаТЧ.Распечатан = Истина;		
			Изменили = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Если Изменили Тогда		
		Записать(Новый Структура("РежимЗаписиДокумента", ?(Объект.фУпрощенныйРежим, РежимЗаписиДокумента.Запись, РежимЗаписиДокумента.Проведение)));
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ШтукВКоробке(Номенклатура)
	Возврат ПолучитьРеквизитШапки(Номенклатура, "Родитель.ШтукВКоробке");
КонецФункции //ШтукВКоробке(Номенклатура)
 
&НаСервере
Функция ПолучитьКодыПоЛМ(ЛистМаркировки, КодыМаркировки = Неопределено)
	Результат = Новый Структура("Успешно,ШтрихКодКоробки,ШтрихКодыУпаковок,ШтукВКоробке,ПерваяСтрока,НеПолный", 
		Истина, Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(), Новый Массив, 0, 1, Ложь);			
	
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	НомерСтроки							КАК ПерваяСтрока,
	|	ШтрихкодКоробки.Наименование 		КАК ШтрихкодКоробки,
	|	ЛистМаркировки.КоличествоДокумента	КАК КоличествоШтукВЛМО,
	|	ЛистМаркировки.НеПолный				КАК НеПолный
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка			 = &Ссылка
	|	И ЛистМаркировки = &ЛистМаркировки
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|;
	|ВЫБРАТЬ
	|	НомерСтроки,
	|	ШтрихкодУпаковки.Владелец							КАК Номенклатура,
	|	ШтрихкодУпаковки.Владелец.Родитель.КодПроизводителя	КАК Артикул,
	|	ШтрихкодУпаковки.Владелец.Цвет						КАК Цвет,
	|	ШтрихкодУпаковки.Владелец.Размер					КАК Размер,
	|	ШтрихкодУпаковки,	
	|	ШтрихкодУпаковки.ЗначениеШтрихкода					КАК ЗначениеКМ,
	|	НомерКоробки,
	|	НомерБлочка,
	|	НомерПалеты
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка				= &Ссылка
	|	И ЛистМаркировки	= &ЛистМаркировки
	|	И НЕ Распечатан 
	|	И (ШтрихкодУпаковки В (&КодыМаркировки) ИЛИ &ВсеКодыПоЛМ)	
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|ИТОГИ 
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки) 
	|ПО
	|	Номенклатура
	|";
	
	Запрос.УстановитьПараметр("Ссылка", 			Объект.Ссылка);
	Запрос.УстановитьПараметр("ЛистМаркировки", 	ЛистМаркировки);
	Запрос.УстановитьПараметр("КодыМаркировки",		КодыМаркировки);
	Запрос.УстановитьПараметр("ВсеКодыПоЛМ",		(КодыМаркировки = Неопределено));
	
	рЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = рЗапроса[0].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ШтрихКодКоробки) Тогда
			Результат.ШтрихкодКоробки 	= Выборка.ШтрихкодКоробки;			
		КонецЕсли;	
		Результат.ПерваяСтрока 	= Выборка.ПерваяСтрока;
		Результат.ШтукВКоробке	= Выборка.КоличествоШтукВЛМО;
		Результат.НеПолный		= Выборка.НеПолный;
	КонецЦикла; 	
	
	ШтукВКоробке 	= 0;	
	Выборка_Номенклатура	= рЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
	Пока Выборка_Номенклатура.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(Результат.ШтукВКоробке) Тогда		
			Результат.ШтукВКоробке = ПолучитьРеквизитШапки(Выборка_Номенклатура.Номенклатура, "Родитель.ШтукВКоробке");
		КонецЕсли;
		
		Выборка = Выборка_Номенклатура.Выбрать();
		Пока Выборка.Следующий() Цикл		
			ДанныеШК = Новый Структура("ШтрихКодУпаковки,ЗначениеКМ,Артикул,Цвет,Размер,НомерСтроки,НомерКоробки,НомерБлочка,НомерПалеты");
			ЗаполнитьЗначенияСвойств(ДанныеШК, Выборка);
			Результат.ШтрихКодыУпаковок.Добавить(ДанныеШК);
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция НачСтрокиКоробок(КодыМаркировки)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	| 	ШтрихкодУпаковки,
	|	ШтрихкодКоробки
	|ПОМЕСТИТЬ ВТ_КодыКоробок
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка	= &Ссылка		
	|	И ШтрихкодУпаковки В (&КодыМаркировки)	
	|;
	|ВЫБРАТЬ
	|	ВТ_КодыКоробок.ШтрихкодУпаковки	КАК ШтрихкодУпаковки,
	|	ВТ_КодыКоробок.ШтрихкодКоробки	КАК ШтрихкодКоробки,
	|	МИНИМУМ(ТЧ.НомерСтроки)			КАК НачалоКоробки	
	|ИЗ
	|	ВТ_КодыКоробок
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ТЧ
	|ПО
	|	ТЧ.Ссылка	= &Ссылка
	|	И ТЧ.ШтрихкодКоробки = ВТ_КодыКоробок.ШтрихкодКоробки
	|СГРУППИРОВАТЬ ПО
	|	ВТ_КодыКоробок.ШтрихкодУпаковки,
	|	ВТ_КодыКоробок.ШтрихкодКоробки
	|";
	
	Запрос.УстановитьПараметр("Ссылка", 		Объект.Ссылка);
	Запрос.УстановитьПараметр("КодыМаркировки", КодыМаркировки);
	
	Результат = Новый Соответствие;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат[Выборка.ШтрихкодУпаковки] = Выборка.НачалоКоробки;			
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //НачСтрокиКоробок(КодыМаркировки)
 

