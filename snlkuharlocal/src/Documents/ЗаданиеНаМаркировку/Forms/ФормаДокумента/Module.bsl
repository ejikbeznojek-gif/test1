&НаКлиенте
Функция ПроверитьНоменклатуруЗНМ_НаОснованииРНК()

	// Кухарь А.Ю.  16.09.2025 начало
	ДанныеЗамера	= ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("Документ.ЗаданиеНаМаркировку.ПроверитьНоменклатуруЗНМ_НаОснованииРНК",новый Структура("Ссылка",Объект.Ссылка));
	// Кухарь А.Ю.  16.09.2025 конец
	
	
	ТекНоменклатура = ?(Объект.фУпрощенныйРежим, Объект.Номенклатура, ТекущаяНоменклатура);
	
	ТекКоличество = ?(Объект.фУпрощенныйРежим, Объект.КоличествоДокумента, КоличествоШтукВЛенте);
	
	СтруктураВозврата = Неопределено;
	
	Если Параметры.Ключ.Пустая() Тогда
		СтруктураВозврата = Документы.ЗаданиеНаМаркировку.КонтрольНоменклатурыПоЗНМ(Объект.ДокОснование, ТекНоменклатура, ТекКоличество);
	Иначе
		СтруктураВозврата = Документы.ЗаданиеНаМаркировку.КонтрольНоменклатурыПоЗНМ_ПоСсылке(Объект.Ссылка, ТекНоменклатура);	
	КонецЕсли;
	
	Если ТипЗнч(СтруктураВозврата.ТЗ_Разница) = Тип("ТаблицаЗначений") И СтруктураВозврата.ТЗ_Разница.Количество() > 0 Тогда
		
		МассивСообщений = Новый Массив;
		
		Для Каждого Стр ИЗ СтруктураВозврата.ТЗ_Разница Цикл
			
			МассивСообщений.Добавить("Номенклатура " + Строка(Стр.Номенклатура));
			МассивСообщений.Добавить("Кол-во в РНК = " + Строка(Стр.КоличествоРНК) + ", в этом ЗНМ " + Строка(Стр.КоличествоЗНМ));
			
			Если Стр.КоличествоВДругихЗНМ > 0 Тогда
				МассивСообщений.Добавить("Количество в других ЗНМ " + Строка(Стр.КоличествоВДругихЗНМ));
			КонецЕсли;
			
			Если Стр.КоличествоОМ > 0 Тогда
				МассивСообщений.Добавить("Количество в других ОМ " + Строка(Стр.КоличествоОМ));
			КонецЕсли;
			
		КонецЦикла;
		
		ТекстСообщение = СтрСоединить(МассивСообщений, Символы.ПС);
		Сообщить(ТекстСообщение);
		
		Отказ = Истина;
	Иначе
		Отказ = Ложь;
		
	КонецЕсли;
	// Кухарь А.Ю.  16.09.2025 начало
	ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерФункции(ДанныеЗамера);
	// Кухарь А.Ю.  16.09.2025 конец
	
	
	Возврат Отказ;
	
КонецФункции
