Функция ПолучитьМаксимальныйНомерШКЛН(ПрефиксШК)
	
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШКЛистаНабора.НомерШК
	|ИЗ
	|	РегистрСведений.ШКЛистаНабора КАК ШКЛистаНабора
	|ГДЕ
	|	ШКЛистаНабора.Подразделение = &Подразделение
	|	И ШКЛистаНабора.Год = &Год
	|АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("Год",НачалоГода(Дата));
	Запрос.УстановитьПараметр("Подразделение",ПараметрыСеанса.ЭтотУзел.Подразделение);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		Возврат Число(Выборка.НомерШК);	
	Иначе
		Возврат 0;
	КонецЕсли; 
	
КонецФункции

Функция ЗаписатьКоробку(ШКЛистаНабора,НомерШК=1)
	
	
	
	ПрефиксШК = Формат(Дата,"ДФ=yy")+Прав(ПараметрыСеанса.ЭтотУзел.Подразделение.ЧисловойКодСклада,3);
	НомерШК=ПолучитьМаксимальныйНомерШКЛН(ПрефиксШК)+1;
	ШККоробки = ПрефиксШК + (Формат(НомерШК,"ЧЦ=7; ЧДЦ=0; ЧВН=; ЧГ="));
	ШККоробки=ШККоробки+КонтрольныйСимволEAN(ШККоробки,13);

	НаборЗаписей = РегистрыСведений.ШКЛистаНабора.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.подразделение.Использование = Истина;
	НаборЗаписей.Отбор.подразделение.Значение = ПараметрыСеанса.ЭтотУзел.Подразделение;
	НаборЗаписей.Отбор.Год.Использование = Истина;
	НаборЗаписей.Отбор.Год.Значение = НачалоГода(Дата);	
	НаборЗаписей.Очистить();
	
	Запись = НаборЗаписей.Добавить();
	Запись.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение;
	Запись.Год = НачалоГода(Дата);
	Запись.НомерШК = НомерШК;
	
	Если  НомерШК > 1000 Тогда
		попытка
			НаборЗаписей.Записать();
		Исключение
			ЗаписатьВЛог("дубль ШК ЛН","Не удалось сделать запись в ШКЛистовНабора "+ЭтотОбъект.Метаданные().Имя+" "+ЭтотОбъект.Номер,"Информация") ;
		КонецПопытки;
	Иначе
		ЗаписатьВЛог("ошибка записи последнего номера ШК ЛН","ШК: "+НомерШК + " .ЛН : " +Номер,"Информация") ;
	КонецЕсли;
	
    	
	НаборЗаписей = РегистрыСведений.ИнформацияШКЛН.СоздатьНаборЗаписей();	
	НаборЗаписей.Отбор.ШК.Значение = ШККоробки;					 
	НаборЗаписей.Отбор.ШКЛистаНабора.Значение= ШКЛистаНабора;
	НаборЗаписей.Отбор.ШКЛистаНабора.Использование = Истина;
	НаборЗаписей.Отбор.ШК.Использование = Истина;
	НаборЗаписей.Очистить();
	
	
	Запись = НаборЗаписей.Добавить();
	Запись.ШК = ШККоробки;
	Запись.ШКЛистаНабора = ШКЛистаНабора;
	Запись.НомерЛН = Номер;
	Запись.ВидНакладной = ЭтотОбъект.Метаданные().Синоним;
	Запись.НомерНакладной = Номер;
	Запись.Количество = 1;
	Запись.ГруппыТоваров = "";
	Запись.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение;
	Запись.КоличествоКоробок = 1;
	запись.НомерКоробкиЛН = 1;
	Запись.НомерКоробки = 1;
	запись.Год=НачалоГода(ТекущаяДата());
	НаборЗаписей.Записать();

КонецФункции

