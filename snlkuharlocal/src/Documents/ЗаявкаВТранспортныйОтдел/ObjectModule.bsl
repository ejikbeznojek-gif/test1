Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.      
	
	//Кухарь А.Ю.  07.05.2026 начало
	// HELP-9698	        
	СформироватьШКЗНО();
	//Кухарь А.Ю.  07.05.2026 конец
	
	ЕстьИзменения				= Модифицированность();
	
	Если НЕ ОбменДанными.Загрузка Тогда		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		
		Если Отказ Тогда Возврат КонецЕсли; 		
	КонецЕсли;	
	
	Если НЕ ЕстьИзменения Тогда Возврат КонецЕсли;
	//крохин начало  
	//Валетов + 09,06,2026 Наряд 0000001060 Проблема 0000000083
	Если Проведен ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
	КонецЕсли;
	//крохин конец
	//кухарь 25.05.16 начало
	//Дата авизации в ЗТО
	Если НЕ ОбменДанными.Загрузка и ПараметрыСеанса.ТипУзла= Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда	
		РасчДатаАвизации=ОпределитьДатуАвизацииДокумента(ЭтотОбъект);
		если РасчДатаАвизации<>ДатаПриемки тогда
			УстановитьДатуАвизацииДокумента(ЭтотОбъект.Ссылка,РасчДатаАвизации);
			ДатаПриемки=РасчДатаАвизации;
		КонецЕсли;
	КонецЕсли;
	//кухарь 25.05.16 конец
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Если 1=2 Тогда
			Основание=Документы.ПриходнаяНакладная.СоздатьДокумент();		
		КонецЕсли; 
		
		ДокОснование		= Основание;		
		
		Подразделение		= Основание.Склад.Подразделение;
		
		Отправитель					= Основание.Контрагент;		
		ПунктДоставкиОтправитель    = Основание.ПунктДоставки;
		
		КоличествоДокумента			= Основание.КоличествоДокумента;
		ОбъемДокумента				= Основание.ОбъемДокумента;		
		
		Комментарий 		= "На основании: "+Основание;		
	КонецЕсли;
	//Кухарь 13.12.15 начало
	ШтрихКод="";
	//Кухарь 13.12.15 конец
КонецПроцедуры

