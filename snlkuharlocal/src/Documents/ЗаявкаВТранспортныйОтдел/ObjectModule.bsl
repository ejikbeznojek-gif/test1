Процедура СформироватьШКЗНО() Экспорт   
	если ЗначениеЗаполнено(ШтрихКод) тогда
		Попытка
			ШтрихКод1=Число(ШтрихКод);
			ШтрихКод1=СтрЗаменить(ШтрихКод," ","");
			если СтрДлина(ШтрихКод1)<>13 тогда
				ШтрихКод="";
			КонецЕсли;
		Исключение
			ШтрихКод="";
		КонецПопытки;
	КонецЕсли;		
	
	если ШтрихКод="" тогда
		ПрефиксШК = Формат(Дата,"ДФ=yy")+Прав(ПараметрыСеанса.ЭтотУзел.Подразделение.ЧисловойКодСклада,3);
		НомерШК=ПолучитьМаксимальныйНомерШКЛН(ПрефиксШК)+1;
		ШКЗНО = ПрефиксШК + (Формат(НомерШК,"ЧЦ=7; ЧДЦ=0; ЧВН=; ЧГ="));
		ШКЗНО=ШКЗНО+КонтрольныйСимволEAN(ШКЗНО,13);
		ШтрихКод=ШКЗНО;
	КонецЕсли;      
	
КонецПроцедуры	
