Процедура ОбработкаЗаполнения(Основание)
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	ВариантЗаполнения=Неопределено;
	#ЕСЛИ КЛИЕНТ ТОГДА
		ВариантЗаполнения=ВыбратьВариантЗаполнения();
	#КОНЕЦЕСЛИ
	
	ДокОснование	= Основание;
	
	ИБ				= Основание.ИБ;
	
	Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование,"Контрагент");
	Договор			= ПолучитьРеквизитОбъекта(ДокОснование,"Договор");
	ЛевыйКонтрагент = ПолучитьРеквизитОбъекта(ДокОснование,"ЛевыйКонтрагент");
	ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");
	Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	
	БанковскийСчет	= ПолучитьРеквизитОбъекта(ДокОснование,"БанковскийСчет");		
	ОтсрочкаПлатежа = ПолучитьРеквизитОбъекта(ДокОснование,"ОтсрочкаПлатежа");			
	ВидОплаты		= ПолучитьРеквизитОбъекта(ДокОснование,"ВидОплаты");		
	
	Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");		
	Если ВидОснования="Перемещение" Тогда
		Склад		= ДокОснование.СкладПолучатель;	
	Иначе		
		Склад		= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");	
	КонецЕсли;	
	//крохин начало 05.03.2011
	//подразделение не копируем 
	//++Данилова Е.В. 29.09.2025 HELP-7048
	//Подразделение = Менеджер.Подразделение;
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер);
	//--Данилова Е.В. 29.09.2025
	Если Подразделение = Справочники.Подразделения.ПустаяСсылка() Тогда
		Подразделение = Склад.Подразделение;
	КонецЕсли;
	//крохин конец 05.03.2011
	
	//крохин начало
	//Группы товаров пересчитаем заново
	//ГруппыТоваров	= ПолучитьРеквизитОбъекта(ДокОснование,"ГруппыТоваров");
	//крохин конец
	
	ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");	
	
	ТранспортнаяКомпания = ПолучитьРеквизитОбъекта(ДокОснование,"ТранспортнаяКомпания");
	
	Если ВидОснования="ПриходнаяНакладная" И НЕ ПолучитьПолномочиеПользователя("ВидимостьПриходныхЦен") Тогда
		ОбнулитьЦены=Истина;	
	Иначе
		ОбнулитьЦены=Ложь;	
	КонецЕсли;
	
	Комментарий=Комментарий+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");
	
	Для Каждого исхСтрокаТЧ Из ДокОснование.Товары Цикл
		СтрокаТЧ = Товары.Добавить();
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);	
		Если ВариантЗаполнения="НехватающиеЗаявка" Тогда
			СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.Заявка-исхСтрокаТЧ.Количество;
			СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
			СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
		ИначеЕсли ВариантЗаполнения="НехватающиеПодтверждение" Тогда
			СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.ПодтвержденнаяЗаявка-исхСтрокаТЧ.Количество;
			СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
			СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
		ИначеЕсли ВариантЗаполнения="Целиком" Тогда			
			Если СтрокаТЧ.Заявка=0 Тогда
				СтрокаТЧ.Заявка	=СтрокаТЧ.Количество;			
			КонецЕсли;
			Если СтрокаТЧ.ПодтвержденнаяЗаявка=0 Тогда
				СтрокаТЧ.ПодтвержденнаяЗаявка=СтрокаТЧ.Количество;
			КонецЕсли;
			
		КонецЕсли;		
		
		Если ОбнулитьЦены Тогда
			СтрокаТЧ.Цена=0;		
			СтрокаТЧ.ЦенаБезСкидки=0;
		КонецЕсли;
		
		Если СтрокаТЧ.Количество=0 Тогда
			Товары.Удалить(СтрокаТЧ);	
		Иначе
			РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);
		КонецЕсли; 
	КонецЦикла;	
	
	//крохин начало
	ГруппыТоваров	=ГруппыТоваровДокумента(ЭтотОбъект);
	Если Дата >= '20101001' Тогда
		СекторХранения = СекторХраненияДокумента(ЭтотОбъект);
	КонецЕсли;
	//крохин конец
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Организация			=Неопределено;
	СостояниеНакладной	=Неопределено;
	Отгружен			=Неопределено;
	СостояниеДокументов	=Неопределено;	
	
	ДатаОтгрузки		=Неопределено;
	ДатаОплаты			=Неопределено;
	ДатаВыгрузки		=Неопределено;
	ДатаОформления		=Неопределено;
	
	Автор				=Неопределено;
	
	// Кельманов А.В. - ASU-1087 - 2024.11.28 {
	КодВторичногоКонтрагента = "";
	НаименованиеВторичногоКонтрагента = "";
	НомерЗаказаВторичногоКонтрагента = "";	
	ИсточникЗаказа = Перечисления.ИсточникЗаказа.РучнойВвод;
	// Кельманов А.В. - ASU-1087 - 2024.11.28 }
	
	Если Менеджер.Пустая() Тогда
		Менеджер=?(ПунктДоставки.Менеджер.Пустая(),Контрагент.Менеджер,ПунктДоставки.Менеджер);
	КонецЕсли;
	//крохин начало
	//++Данилова Е.В. 29.09.2025 HELP-7048
	//Подразделение = Менеджер.Подразделение;
	Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Менеджер);
	//--Данилова Е.В. 29.09.2025
	Если Подразделение = Справочники.Подразделения.ПустаяСсылка() Тогда
		Подразделение = Склад.Подразделение;
	КонецЕсли;
	//крохин конец
	
	Если Договор.Пустая() Или Договор.НеИспользовать Тогда
		Договор=Контрагент.ОсновнойДоговор;			
	КонецЕсли; 
	//крохин начало
	//только предоплата
	Если Контрагент.Ведущий.ТолькоПредоплата Тогда
		ОтсрочкаПлатежа = Справочники.ОтсрочкиПлатежа.НайтиПоКоду("1");	
	КонецЕсли;
	//крохин конец
	
	//крохин начало 15.04.2021
	ЗаявкаНаПроизводство = Неопределено;
	//крохин конец 15.04.2021
	
	// ++ Шворобей ВЮ 14.02.2022
	Контрагенты.Очистить();
	РасходныеНакладные.Очистить();
	ДополнительныеСклады.Очистить();
	ДополнительныеДвижения.Очистить();
	// ++ Шворобей ВЮ 14.02.2022
	
	// Шворобей ВЮ 28.12.2023 ++
	ПоставщикПоАгентскойСхеме = Неопределено;
	ПересчитатьТабличнуюЧасть(Товары);
	// Шворобей ВЮ 28.12.2023 ++
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	ДвиженияПоРегистрам = Неопределено;
	РезультатПроведения = ПроведениеПоРегистрамЗаказыКонтрагентов(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);
	ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);
	
	Если НЕ b2b_Дозаказ Тогда
		ДвиженияПоРегистрам = Неопределено;
		РезультатПроведения = ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);
	КонецЕсли;
КонецПроцедуры

