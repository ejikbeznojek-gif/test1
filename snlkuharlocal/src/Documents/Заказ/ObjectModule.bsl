Процедура УстановитьСостояниеДокументов(НовоеСостояниеДокументов) Экспорт
	//крохин начало 09.02.2011
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//СостояниеДокументов=НовоеСостояниеДокументов;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
		Отказ = Истина;
