			Записать();
			НеКонтролироватьЗапись=Ложь;	
		КонецЕсли;
	Иначе
		НеКонтролироватьЗапись=Истина;
		СостояниеДокументов=НовоеСостояниеДокументов;
		Записать();
		НеКонтролироватьЗапись=Ложь;
	КонецЕсли;
	//крохин конец 09.02.2011
	
