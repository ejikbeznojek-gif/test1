		ЗаявкаНаПроизводство = ЗАП;
		СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ЗаказаноПоставщику;
		Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
	КонецЕсли;
КонецПроцедуры
