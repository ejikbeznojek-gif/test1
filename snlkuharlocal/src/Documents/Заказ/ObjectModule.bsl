Процедура ЗаписатьВТаблицуОшибок(ТО,Объект,ТипОшибки,НомерСтроки,СтруктураТовара = Неопределено,Остаток=0,Резерв=0)
	
	Если ТипЗнч(ТО)<>Тип("ТаблицаЗначений") Тогда
		
		ТО = Новый ТаблицаЗначений;	
		
		ТО.Колонки.Добавить("Объект");		
		ТО.Колонки.Добавить("ТипОшибки");
		ТО.Колонки.Добавить("НомерСтроки");		
		ТО.Колонки.Добавить("Склад");		
		ТО.Колонки.Добавить("Номенклатура");		
		ТО.Колонки.Добавить("Количество");
		ТО.Колонки.Добавить("Остаток");
		ТО.Колонки.Добавить("Резерв");
		ТО.Колонки.Добавить("ВиртуальныйРезерв");		
	КонецЕсли;
	
	СтрокаТО=ТО.Добавить();
	
	СтрокаТО.Объект				=Объект.Ссылка;
	СтрокаТО.ТипОшибки			=ТипОшибки;
	
	Если СтруктураТовара<>Неопределено Тогда
		СтрокаТО.Склад			= СтруктураТовара.Склад;
		СтрокаТО.Номенклатура	= СтруктураТовара.Номенклатура;
		СтрокаТО.Количество		= СтруктураТовара.Количество;	
	КонецЕсли;	
	
	СтрокаТО.Остаток			=Остаток;
	СтрокаТО.Резерв				=Резерв;
	
КонецПроцедуры // ЗаписатьВтаблицуОшибок()



// Кухарь А.Ю.  19.04.2023 начало
//
Функция ПолучитьСтруктуруИзменений (РежимЗаписи)
	СтруктураИзменений=новый Структура("Проведен,СостояниеНакладной,Товары",Ложь,Ложь,Ложь);
	если ЭтоНовый() тогда
		СтруктураИзменений.Проведен=Истина;
		СтруктураИзменений.СостояниеНакладной=Истина;
		СтруктураИзменений.Товары=Истина;
		возврат СтруктураИзменений;
	КонецЕсли;

	
	Запрос=новый запрос;
	запрос.УстановитьПараметр("Ссылка",Ссылка);
	запрос.Текст="ВЫБРАТЬ
	|	Заказ.Проведен КАК Проведен,
	|	Заказ.СостояниеНакладной КАК СостояниеНакладной
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Ссылка = &Ссылка";
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл	
		если СостояниеНакладной<>результат.СостояниеНакладной тогда
			СтруктураИзменений.СостояниеНакладной=Истина;
		КонецЕсли;
		
		если РежимЗаписи=РежимЗаписиДокумента.Проведение тогда
			ОбъектПроведен=Истина;
		ИначеЕсли РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения тогда
			ОбъектПроведен=Ложь;
		иначе
			ОбъектПроведен=Проведен	
		КонецЕсли;
		если результат.Проведен <> ОбъектПроведен тогда
			СтруктураИзменений.Проведен =Истина;
		КонецЕсли;
		
		
	КонецЦикла;
	
	
	
	запрос.Текст="ВЫБРАТЬ
	|	ЗаказТовары.Номенклатура КАК Номенклатура,
	|	ЗаказТовары.Количество КАК Количество
	|ИЗ
	|	Документ.Заказ.Товары КАК ЗаказТовары
	|ГДЕ
	|	ЗаказТовары.Ссылка = &Ссылка";
	
	
	
	ТЧ_Товары = Товары.Выгрузить(, "Номенклатура, Количество");
	если ЗаполнениеДокументов.РазницаТаблицЗначений(ТЧ_Товары, запрос.Выполнить().Выгрузить(),"Номенклатура, Количество").количество() > 0 тогда
		СтруктураИзменений.Товары=Истина;
	КонецЕсли;
	
	
	
	возврат СтруктураИзменений;
	
	
	
КонецФункции
