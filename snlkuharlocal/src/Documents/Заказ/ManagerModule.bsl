
Функция ОпределитьПризнакЗаказаССайта(ЗаказСсылка) Экспорт
	
	МассивЗаказов = Новый Массив;
	МассивЗаказов.Добавить(ЗаказСсылка);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК ДокументСсылка
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КатегорииОбъектов КАК КатегорииОбъектов
	|		ПО (КатегорииОбъектов.Объект = Заказ.Ссылка)
	|			И (КатегорииОбъектов.Категория = ЗНАЧЕНИЕ(Справочник.КатегорииОбъектов.ЗаказСWEBСайта))
	|ГДЕ
	|	Заказ.Ссылка В(&МассивЗаказов)
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	Рез = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ?(НЕ Рез.Пустой(), Истина, Ложь);
	
КонецФункции

Функция ПолучитьСтруктуруОстатков(ЗаказСсылка, МассивСкладов = Неопределено, МассивНоменклатуры = Неопределено, ВидДокумента = "Заказ") Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", ЗаказСсылка.Дата);
	Запрос.УстановитьПараметр("Ссылка", ЗаказСсылка);
	
	Если МассивСкладов = Неопределено Тогда
		МассивСкладов = Новый Массив;
		МассивСкладов.Добавить(ЗаказСсылка.Склад);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	ТекстНоменклатуры = "";
	Если МассивНоменклатуры <> Неопределено Тогда
		ТекстНоменклатуры = "И Номенклатура В (&МассивНоменклатуры)";
		Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);
	Иначе
		ТекстНоменклатуры = "И Номенклатура В
		|						(ВЫБРАТЬ
		|							Товары.Номенклатура КАК Номенклатура
		|						ИЗ
		|							Документ." + ВидДокумента + ".Товары КАК Товары
		|						ГДЕ
		|							Товары.Ссылка = &Ссылка)";
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура("ТаблицаОстатков, ТаблицаНехватки");
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, Товары.Номенклатура) КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < ЕСТЬNULL(Товары.Количество, 0)
	|			ТОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)
	|		ИНАЧЕ ЕСТЬNULL(Товары.Количество, 0)
	|	КОНЕЦ КАК Количество,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < ЕСТЬNULL(Товары.Количество, 0)
	|			ТОГДА ЕСТЬNULL(Товары.Количество, 0) - (ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0))
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Нехватка
	|ИЗ
	|	Документ." + ВидДокумента + ".Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&Дата,
	|				Склад В (&МассивСкладов)
	|					" + ТекстНоменклатуры + "
	|					) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	//Кухарь А.Ю.  02.05.2023 начало
	//	|					&Дата,
	|					,	 
	//Кухарь А.Ю.  02.05.2023 конец	
	|					Склад В (&МассивСкладов)
	|						" + ТекстНоменклатуры + "
	|						) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ПО Товары.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|ГДЕ
	|	Товары.Ссылка = &Ссылка";
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаОстатков = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТаблицаНехватки = ТаблицаОстатков.СкопироватьКолонки();
	Для Каждого Стр ИЗ ТаблицаОстатков Цикл
		Если Стр.Нехватка > 0 Тогда
			ЗаполнитьЗначенияСвойств(ТаблицаНехватки.Добавить(), Стр);
		КонецЕсли;
	КонецЦикла;
	
	СтруктураВозврата.Вставить("ТаблицаОстатков", ТаблицаОстатков);
	СтруктураВозврата.Вставить("ТаблицаНехватки", ТаблицаНехватки);
	
	Возврат СтруктураВозврата;
	
КонецФункции

///////// ТАБЛИЦА НЕХВАТКИ ///////////////////////////////////////////////////////////////////////////
