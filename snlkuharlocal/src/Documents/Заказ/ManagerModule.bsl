Функция ОтменитьЗаказ(ЗаказСсылка) Экспорт
	
	ФлагПроведен = ЗаказСсылка.Проведен;
	
	ЗаказОбъект = ЗаказСсылка.ПолучитьОбъект();
	Если ЗаказОбъект <> Неопределено Тогда
		
		Попытка
			ЗаказОбъект.Заблокировать();
		Исключение
			Возврат Ложь;
		КонецПопытки;
		
		ЗаказОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененЦО;
		
		УстановитьПривилегированныйРежим(Истина);
		Попытка
			ЗаказОбъект.Записать(?(ФлагПроведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
			ЗаказОбъект.Разблокировать();
			СообщитьИзМодуля("Документ " + Строка(ЗаказОбъект) + " отменен.");
		Исключение
			Возврат Ложь;
		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции
