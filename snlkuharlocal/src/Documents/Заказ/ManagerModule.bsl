	 |			ЛЕВОЕ СОЕДИНЕНИЕ РезервыДляВычитания КАК РезервыДляВычитания
	 |			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыДляВычитания.Номенклатура
	 |		ПО ТаблицаНехватки.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	 |			И (ОстаткиТМЦОстатки.КоличествоОстаток > 0)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	ЕСТЬNULL(ТаблицаНехватки.Номенклатура, ОстаткиТМЦОстатки.Номенклатура)"; 
	
	//--Данилова Е.В. 09.04.2025
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаОстатков = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТаблицаНехватки =  ТаблицаОстатков.СкопироватьКолонки();
	Для Каждого Стр ИЗ ТаблицаОстатков Цикл
		Если Стр.Нехватка > 0 Тогда
			ЗаполнитьЗначенияСвойств(ТаблицаНехватки.Добавить(), Стр);
		КонецЕсли;
	КонецЦикла;
	
	СтруктураВозврата.Вставить("ТаблицаОстатков", ТаблицаОстатков);
	СтруктураВозврата.Вставить("ТаблицаНехватки", ТаблицаНехватки);
	
	Возврат СтруктураВозврата;
	
КонецФункции

//--Данилова Е.В. 01.04.2025
	// Кухарь А.Ю.  29.08.2023 начало
	//  Функция ОбработатьЗаказПриСозданииРНК(ЗаказСсылка) Экспорт
Функция ОбработатьЗаказПриСозданииРНК(ЗаказСсылка,РНКСсылка=Неопределено) Экспорт
	// Кухарь А.Ю.  29.08.2023 конец
	
	
	ЗаказОбъект = ЗаказСсылка.ПолучитьОбъект();
	Если ЗаказОбъект <> Неопределено Тогда
		
		Попытка
			ЗаказОбъект.Заблокировать();
		Исключение
			Возврат Ложь;
		КонецПопытки;
		
		ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ;
		// Кухарь А.Ю.  29.08.2023 начало
		//
		если ложь тогда ЗаказОбъект=документы.Заказ.СоздатьДокумент();КонецЕсли;
		если РНКСсылка<>Неопределено тогда
			СтрТЧ=ЗаказОбъект.РасходныеНакладные.Найти(РНКСсылка,"Документ");
			если СтрТЧ=Неопределено тогда
				СтрТЧ=ЗаказОбъект.РасходныеНакладные.Добавить();
				СтрТЧ.Документ=РНКСсылка;
			КонецЕсли;
			
		КонецЕсли;
		// Кухарь А.Ю.  29.08.2023 конец
		
		УстановитьПривилегированныйРежим(Истина);
		Попытка
			ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
			ЗаказОбъект.Разблокировать();
		Исключение
			Возврат Ложь;
		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

