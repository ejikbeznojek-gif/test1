Функция ОбщиеПроверкиПолучитьСтруктуру(МассивЗаказов) Экспорт
	
	МассивКонтрагентов = Новый Массив;
	МассивСкладов = Новый Массив;
	МассивСостоянийСогласования = Новый Массив;
	МассивПроведения = Новый Массив;
	МассивЗаполнения = Новый Массив;
	МассивРНК = Новый Массив;
	МассивМенеджеров = Новый Массив;
	//++Данилова Е.В. 01.04.2025 HELP-3176
	МассивСкладовМаркировки = Новый Массив;
	//--Данилова Е.В. 01.04.2025
	
	СтруктураОтвета = Новый Структура("МассивКонтрагентов, МассивСкладов, МассивСостоянийСогласования, МассивПроведения, МассивЗаполнения, МассивРНК, МассивМенеджеров");
	
	Для Каждого Заказ Из МассивЗаказов Цикл
		
		НайденныйКонтрагент = МассивКонтрагентов.Найти(Заказ.Контрагент);
		Если НайденныйКонтрагент = Неопределено Тогда
			МассивКонтрагентов.Добавить(Заказ.Контрагент);
		КонецЕсли;
		
		НайденныйМенеджер = МассивМенеджеров.Найти(Заказ.Менеджер);
		Если НайденныйМенеджер = Неопределено И Заказ.Менеджер <> Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
			МассивМенеджеров.Добавить(Заказ.Менеджер);
		КонецЕсли;
		
		НайденныйСклад = МассивСкладов.Найти(Заказ.Склад);
		Если НайденныйСклад = Неопределено Тогда
			МассивСкладов.Добавить(Заказ.Склад);
		КонецЕсли;
		
		НайденноеСостояние = МассивСостоянийСогласования.Найти(Заказ.СостояниеСогласования);
		Если НайденноеСостояние = Неопределено Тогда
			МассивСостоянийСогласования.Добавить(Заказ.СостояниеСогласования);
		КонецЕсли;
		
		НайденноеСостояниеПроведения = МассивПроведения.Найти(Заказ.Проведен);
		Если НайденноеСостояниеПроведения = Неопределено Тогда
			МассивПроведения.Добавить(Заказ.Проведен);
		КонецЕсли;
		
		ФлагЗаполнения = Заказ.РасходныеНакладные.Количество() > 0;
		НайденноеСостояниеЗаполнения = МассивЗаполнения.Найти(ФлагЗаполнения);
		Если НайденноеСостояниеЗаполнения = Неопределено Тогда
			МассивЗаполнения.Добавить(ФлагЗаполнения);
		КонецЕсли;
		
		Для Каждого СтрокаРНК ИЗ Заказ.РасходныеНакладные Цикл
			НайденнаяРНК = МассивРНК.Найти(СтрокаРНК.Документ);
			Если НайденнаяРНК = Неопределено Тогда
				МассивРНК.Добавить(СтрокаРНК.Документ);
			КонецЕсли;
		КонецЦикла;
		//++Данилова Е.В. 01.04.2025 HELP-3176
		НайденныйСклад = МассивСкладовМаркировки.Найти(Заказ.СкладМаркировки);
		Если НайденныйСклад = Неопределено Тогда
			МассивСкладовМаркировки.Добавить(Заказ.СкладМаркировки);
		КонецЕсли;
		//--Данилова Е.В. 01.04.2025
		
	КонецЦикла;
	
	СтруктураОтвета.Вставить("МассивКонтрагентов", МассивКонтрагентов);
	СтруктураОтвета.Вставить("МассивСкладов", МассивСкладов);
	СтруктураОтвета.Вставить("МассивСостоянийСогласования", МассивСостоянийСогласования);
	СтруктураОтвета.Вставить("МассивПроведения", МассивПроведения);
	СтруктураОтвета.Вставить("МассивЗаполнения", МассивЗаполнения);
	СтруктураОтвета.Вставить("МассивРНК", МассивРНК);
	СтруктураОтвета.Вставить("МассивМенеджеров", МассивМенеджеров);
	//++Данилова Е.В. 01.04.2025 HELP-3176
	СтруктураОтвета.Вставить("МассивСкладовМаркировки", МассивСкладовМаркировки);
	//--Данилова Е.В. 01.04.2025
	Возврат СтруктураОтвета;
	
КонецФункции

Функция ПроверкаОстатковПоДополнительнымДвижениям(МассивЗаказов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивРегистраторов", МассивЗаказов);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказДополнительныеСклады.Склад КАК Склад
	|ПОМЕСТИТЬ ТаблицаСклады
	|ИЗ
	|	Документ.Заказ.ДополнительныеСклады КАК ЗаказДополнительныеСклады
	|ГДЕ
	|	ЗаказДополнительныеСклады.Ссылка В(&МассивРегистраторов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Заказ.Склад
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Ссылка В(&МассивРегистраторов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаСклады.Склад КАК Склад
	|ИЗ
	|	ТаблицаСклады КАК ТаблицаСклады";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивСкладов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	УстановитьПривилегированныйРежим(Ложь);
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказДополнительныеДвижения.Количество) КАК Количество,
	|	ЗаказДополнительныеДвижения.Склад КАК Склад
	|ПОМЕСТИТЬ ТЗЗаказа
	|ИЗ
	|	Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|ГДЕ
	|	ЗаказДополнительныеДвижения.Ссылка В(&МассивРегистраторов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказДополнительныеДвижения.Номенклатура,
	|	ЗаказДополнительныеДвижения.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РезервыТМЦ.Склад КАК Склад,
	|	РезервыТМЦ.Номенклатура КАК Номенклатура,
	|	СУММА(РезервыТМЦ.Количество) КАК Количество
	|ПОМЕСТИТЬ ТЗРезервовЗаказа
	|ИЗ
	|	РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|ГДЕ
	|	РезервыТМЦ.Регистратор В(&МассивРегистраторов)
	|
	|СГРУППИРОВАТЬ ПО
	|	РезервыТМЦ.Склад,
	|	РезервыТМЦ.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, РезервыТМЦОстатки.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Склад, РезервыТМЦОстатки.Склад) КАК Склад,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(ТЗРезервовЗаказа.Количество, 0)) КАК Остаток
	|ПОМЕСТИТЬ ТЗОстатков
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад В (&МассивСкладов)
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура
	|					ИЗ
	|						Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|					ГДЕ
	|						ЗаказДополнительныеДвижения.Ссылка В (&МассивРегистраторов))) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура
	|						ИЗ
	|							Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|						ГДЕ
	|							ЗаказДополнительныеДвижения.Ссылка В (&МассивРегистраторов))) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|			И ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗРезервовЗаказа КАК ТЗРезервовЗаказа
	|		ПО ОстаткиТМЦОстатки.Склад = ТЗРезервовЗаказа.Склад
	|			И ОстаткиТМЦОстатки.Номенклатура = ТЗРезервовЗаказа.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, РезервыТМЦОстатки.Номенклатура),
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Склад, РезервыТМЦОстатки.Склад)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗЗаказа.Номенклатура КАК Номенклатура,
	|	ТЗЗаказа.Количество КАК Количество,
	|	ТЗЗаказа.Склад КАК Склад,
	|	ЕСТЬNULL(ТЗОстатков.Остаток, 0) КАК Остаток
	|ИЗ
	|	ТЗЗаказа КАК ТЗЗаказа
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗОстатков КАК ТЗОстатков
	|		ПО ТЗЗаказа.Номенклатура = ТЗОстатков.Номенклатура
	|			И ТЗЗаказа.Склад = ТЗОстатков.Склад
	|ГДЕ
	|	ЕСТЬNULL(ТЗОстатков.Остаток, 0) < 0";			  
	
	Ошибки="";
	МассивОшибок = Новый Массив;
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Результат.Следующий() Цикл
		МассивОшибок.Добавить("По номенклатуре "+Результат.Номенклатура+", на складе "+Результат.Склад+" недостаточно товара. На остатках - "+Результат.Остаток+" , требуется "+Результат.Количество);
	КонецЦикла;
	
	Если МассивОшибок.Количество()>0 Тогда
		Ошибки = СтрСоединить(МассивОшибок, Символы.ПС);
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции

