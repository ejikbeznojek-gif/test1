	запрос.УстановитьПараметр("МассивСкладов",МассивСкладов);
	
	
	// Кухарь А.Ю.  02.05.2023 начало
	запрос.УстановитьПараметр("ОставлятьНули",ОставлятьНули);	 
	// Кухарь А.Ю.  02.05.2023 конец
	
	// Кухарь А.Ю.  19.04.2023 конец
	
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	///////////////////////////////////////////////////////////////////////////////////////////////////
	
	
	// Кухарь А.Ю.  19.04.2023 начало
	// 	Запрос.УстановитьПараметр("Дата", ЗаказСсылка.Дата);
	если ДатаОстатков=Неопределено тогда
		Запрос.УстановитьПараметр("Дата", ЗаказСсылка.Дата);
	иначе
		Запрос.УстановитьПараметр("Дата", ДатаОстатков);
	КонецЕсли;
	// Кухарь А.Ю.  19.04.2023 конец
	
	
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("МассивНоменклатуры", ТаблицаНехватки.ВыгрузитьКолонку("Номенклатура"));
	
	//++Данилова Е.В. 09.04.2025 HELP-4082
	// Шворобей ВЮ 07.02.2023 ++
