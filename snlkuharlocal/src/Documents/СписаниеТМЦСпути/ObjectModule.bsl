Процедура ПровестиСторно(Отказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", ДокОснование);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказыПоставщикам.Период КАК Период,
	|	ЗаказыПоставщикам.Регистратор КАК Регистратор,
	|	ЗаказыПоставщикам.ВидДвижения КАК ВидДвижения,
	|	ЗаказыПоставщикам.Склад КАК Склад,
	|	ЗаказыПоставщикам.Заказ КАК Заказ,
	|	ЗаказыПоставщикам.Контракт КАК Контракт,
	|	ЗаказыПоставщикам.Номенклатура КАК Номенклатура,
	|	ЗаказыПоставщикам.Количество КАК Количество,
	|	ЗаказыПоставщикам.СуммаРуб КАК СуммаРуб,
	|	ЗаказыПоставщикам.СуммаUSD КАК СуммаUSD,
	|	ЗаказыПоставщикам.СуммаEUR КАК СуммаEUR,
	|	ЗаказыПоставщикам.Отправитель КАК Отправитель,
	|	ЗаказыПоставщикам.ВалютаДокумента КАК ВалютаДокумента,
	|	ЗаказыПоставщикам.СуммаДокумента КАК СуммаДокумента,
	|	ВЫРАЗИТЬ(Товары.Цена КАК ЧИСЛО(15, 2)) КАК ЦенаИзДокумента,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ЗаказыПоставщикам.СуммаРуб, 0) / ЕСТЬNULL(ЗаказыПоставщикам.Количество, 1) КАК ЧИСЛО(15, 2)) КАК Цена,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ЗаказыПоставщикам.СуммаUSD, 0) / ЕСТЬNULL(ЗаказыПоставщикам.Количество, 1) КАК ЧИСЛО(15, 2)) КАК ЦенаUSD,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ЗаказыПоставщикам.СуммаEUR, 0) / ЕСТЬNULL(ЗаказыПоставщикам.Количество, 1) КАК ЧИСЛО(15, 2)) КАК ЦенаEUR
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам КАК ЗаказыПоставщикам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СписаниеТМЦСпути.Товары КАК Товары
	|		ПО ЗаказыПоставщикам.Номенклатура = Товары.Номенклатура
	|			И ЗаказыПоставщикам.Регистратор = Товары.Ссылка.ДокОснование
	|ГДЕ
	|	ЗаказыПоставщикам.Регистратор = &Регистратор
	|	И Товары.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗ_Движения = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТЗ_Движения.Количество() = 0 Тогда
		СообщитьИзМодуля("Нет движений для Сторно!!");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	////////// ПОЙДЕМ ПО ТЧ ТОВАРЫ ///////////////////////////////////////////////////////////
	
	Для Каждого СтрокаТЧ ИЗ Товары Цикл
		
		Если СтрокаТЧ.Количество > 0 Тогда
			
			СтруктураПоиска = Новый Структура("Номенклатура, Цена", СтрокаТЧ.Номенклатура, СтрокаТЧ.Цена);
			НайденныеСтроки = ТЗ_Движения.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() = 0 Тогда
				СообщитьИзМодуля("Нет движений для Сторно по номенклатуре " + Строка(СтрокаТЧ.Номенклатура) + " и цене " + Строка(СтрокаТЧ.Цена) + " !!");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			
			КоличествоКУбыванию = СтрокаТЧ.Количество;
			
			Для Каждого Стр ИЗ НайденныеСтроки Цикл
				
				Движение = Движения.ЗаказыПоставщикам.Добавить();
				ЗаполнитьЗначенияСвойств(Движение, Стр);
				
				Движение.ВидДвижения = ?(Стр.ВидДвижения = ВидДвиженияНакопления.Приход, ВидДвиженияНакопления.Расход, ВидДвиженияНакопления.Приход);
				Движение.Период = Дата;
				Движение.Регистратор = Ссылка;
				
				///////////////////////////////////////////////////////////////////////////////////
				
				Если КоличествоКУбыванию < Стр.Количество Тогда
					
					Движение.Количество = КоличествоКУбыванию;
					Движение.СуммаРуб = Стр.Цена * КоличествоКУбыванию;
					Движение.СуммаUSD = Стр.ЦенаUSD * КоличествоКУбыванию;
					Движение.СуммаEUR = Стр.ЦенаEUR * КоличествоКУбыванию;
					Прервать;
					
				КонецЕсли;
				
				КоличествоКУбыванию = КоличествоКУбыванию - Стр.Количество;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСторно(ДокОснование) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", ДокОснование);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказыПоставщикам.Период КАК Период,
	|	ЗаказыПоставщикам.Регистратор КАК Регистратор,
	|	ЗаказыПоставщикам.ВидДвижения КАК ВидДвижения,
	|	ЗаказыПоставщикам.Склад КАК Склад,
	|	ЗаказыПоставщикам.Номенклатура КАК Номенклатура,
	|	ЗаказыПоставщикам.Заказ КАК Заказ,
	|	ЗаказыПоставщикам.Количество КАК Количество,
	|	ЗаказыПоставщикам.СуммаРуб КАК Всего,
	|	ЗаказыПоставщикам.СуммаUSD КАК СуммаUSD,
	|	ЗаказыПоставщикам.СуммаEUR КАК СуммаEUR,
	|	ЗаказыПоставщикам.Отправитель КАК Отправитель,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ЗаказыПоставщикам.СуммаРуб, 0) / ЕСТЬNULL(ЗаказыПоставщикам.Количество, 1) КАК ЧИСЛО(15, 2)) КАК Цена,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(Товары.Цена, 0) КАК ЧИСЛО(15, 2)) КАК ЦенаИзДокумента,
	|	1 КАК Коэффициент
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам КАК ЗаказыПоставщикам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК Товары
	|		ПО ЗаказыПоставщикам.Номенклатура = Товары.Номенклатура
	|			И ЗаказыПоставщикам.Регистратор = Товары.Ссылка
	|ГДЕ
	|	ЗаказыПоставщикам.Регистратор = &Регистратор
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|АВТОУПОРЯДОЧИВАНИЕ";
		
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
		
	Товары.Очистить();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
		ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ,ЭтотОбъект);
		РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект,"ОтВсего");
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ЭтотОбъект);
	КонецЦикла;
	
КонецПроцедуры

