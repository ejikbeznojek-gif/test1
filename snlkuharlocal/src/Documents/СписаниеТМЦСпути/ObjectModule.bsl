////////  СОБЫТИЯ ОБЪЕКТА ////////////////////////////////////////////////////////
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ЕстьИзменения	=Модифицированность();
	
	КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
	МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
	МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);
	
	Если Отказ Тогда Возврат КонецЕсли;		
	
	Если ЕстьИзменения Тогда
		
		СуммаДокумента = ?(Товары.Итог("ВсегоСКомпенсацией") > 0, Товары.Итог("ВсегоСКомпенсацией") * ДокОснование.Курс, Товары.Итог("Всего"));
		
		СуммаПоставщика = ?(Товары.Итог("ВсегоСКомпенсацией") > 0, Товары.Итог("ВсегоСКомпенсацией"), Товары.Итог("СуммаПоставщика"));
		
		ОбъемДокумента = Товары.Итог("Объем");
		КоличествоДокумента = Товары.Итог("Количество");
				
		ГруппыТоваров = ГруппыТоваровДокумента(ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)	
	Автор				=Неопределено;	
	Дата				=Неопределено;
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание) = Тип("Структура") Тогда Возврат КонецЕсли;
	
	Если Основание = Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования = Основание.Метаданные().Имя;
		
	ДокОснование	= Основание;
	Дата = ТекущаяДатаСеанса();
	
	Если ЕстьРеквизитДокумента("КонтрагентКомпенсация", Основание.Метаданные()) Тогда
		КонтрагентКомпенсация = Основание.КонтрагентКомпенсация;		
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("ДоговорКомпенсация", Основание.Метаданные()) Тогда
		ДоговорКомпенсация = Основание.ДоговорКомпенсация;		
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("ТипЦенКомпенсация", Основание.Метаданные()) Тогда
		ТипЦенКомпенсация = Основание.ТипЦенКомпенсация;		
	КонецЕсли;
	
	// Шворобей ВЮ 13.12.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1637
	// Шворобей ВЮ 04.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-407
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КонтрактСПроизводителемТовары.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(КонтрактСПроизводителемТовары.Цена, 0) КАК Цена
	|ПОМЕСТИТЬ тзНоменклатураКП
	|ИЗ
	|	Документ.КонтрактСПроизводителем.Товары КАК КонтрактСПроизводителемТовары
	|ГДЕ
	|	КонтрактСПроизводителемТовары.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ЗаказПоставщикуТовары.ЗаявкаПоставщику КАК ЗаявкаПоставщику
	|			ИЗ
	|				Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|			ГДЕ
	|				ЗаказПоставщикуТовары.Ссылка = &ДокОснование)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Заказ КАК Заказ,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Количество,
	|	ЕСТЬNULL(Остатки.СуммаОстаток, 0) КАК Всего,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(ЕСТЬNULL(Остатки.СуммаОстаток, 0) / ВЫБОР
	|					КОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1) <> 0
	|						ТОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1)
	|					ИНАЧЕ 1
	|				КОНЕЦ КАК ЧИСЛО(10, 2))) <> 0
	|			ТОГДА ВЫРАЗИТЬ(ЕСТЬNULL(Остатки.СуммаОстаток, 0) / ВЫБОР
	|						КОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1) <> 0
	|							ТОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1)
	|						ИНАЧЕ 1
	|					КОНЕЦ КАК ЧИСЛО(10, 2))
	|		ИНАЧЕ тзНоменклатураКП.Цена
	|	КОНЕЦ КАК Цена,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(Остатки.СуммаОстаток, 0) / ВЫБОР
	|			КОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1) <> 0
	|				ТОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1)
	|			ИНАЧЕ 1
	|		КОНЕЦ КАК ЧИСЛО(10, 2)) КАК ЦенаЗПС,
	|	тзНоменклатураКП.Цена КАК ЦенаКП,
	|	ЕСТЬNULL(Остатки.СуммаПоставщикаОстаток, 0) КАК СуммаПоставщика,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Товары.Единица, ЗНАЧЕНИЕ(Справочник.Единицы.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Единицы.ПустаяСсылка)
	|			ТОГДА Единицы.Ссылка
	|		ИНАЧЕ Товары.Единица
	|	КОНЕЦ КАК Единица,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Товары.Коэффициент, 0) = 0
	|			ТОГДА 1
	|		ИНАЧЕ ЕСТЬNULL(Товары.Коэффициент, 1)
	|	КОНЕЦ КАК Коэффициент,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(Остатки.СуммаОстаток, 0) / ВЫБОР
	|			КОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1) <> 0
	|				ТОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 1)
	|			ИНАЧЕ 1
	|		КОНЕЦ КАК ЧИСЛО(10, 2)) КАК ЦенаБезСкидки,
	|	ЕСТЬNULL(Товары.ЦенаСКомпенсацией, 0) КАК ЦенаСКомпенсацией,
	|	ЕСТЬNULL(Товары.ЦенаКомпенсации, 0) КАК ЦенаКомпенсации,
	|	ЕСТЬNULL(Товары.Компенсация, 0) * ЕСТЬNULL(Остатки.КоличествоОстаток, 0) / ВЫБОР
	|		КОГДА ЕСТЬNULL(Товары.Количество, 1) <> 0
	|			ТОГДА ЕСТЬNULL(Товары.Количество, 1)
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Компенсация,
	|	ЕСТЬNULL(Товары.ВсегоСКомпенсацией, 0) * ЕСТЬNULL(Остатки.КоличествоОстаток, 0) / ВЫБОР
	|		КОГДА ЕСТЬNULL(Товары.Количество, 1) <> 0
	|			ТОГДА ЕСТЬNULL(Товары.Количество, 1)
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК ВсегоСКомпенсацией,
	|	Товары.СтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	РегистрНакопления.ТоварыВПути.Остатки(&Период, Заказ = &ДокОснование) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК Товары
	|		ПО Остатки.Заказ = Товары.Ссылка
	|			И Остатки.Номенклатура = Товары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Единицы КАК Единицы
	|		ПО Остатки.Номенклатура = Единицы.Владелец
	// +++ {Кузнецов Сергей Владимирович [01.04.2025] HELP-3786
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ тзНоменклатураКП КАК тзНоменклатураКП
	|		ЛЕВОЕ СОЕДИНЕНИЕ тзНоменклатураКП КАК тзНоменклатураКП
	// }Кузнецов Сергей Владимирович +++ [01.04.2025]
	|		ПО Остатки.Номенклатура = тзНоменклатураКП.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) <> 0";
	// Шворобей ВЮ 04.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-407

	УстановитьПривилегированныйРежим(Истина);
	ТО = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Товары.Очистить();
	Для Каждого СтрокаТО Из ТО Цикл	
		
		СтрокаТЧ = Товары.Добавить();
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТО);
		
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);
		
		// +++ {Кузнецов Сергей Владимирович [01.04.2025] HELP-3783
		//СтрокаТЧ.СуммаПоставщика = СтрокаТЧ.Всего;
		// }Кузнецов Сергей Владимирович +++ [01.04.2025]		
					
	КонецЦикла;
	
	ДополнительныеСвойства.Вставить("ЗаполненНаОсновании", Истина);
	// Шворобей ВЮ 13.12.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1637
	
	Если ВидОснования="ЗаказПоставщику" Тогда
		Контрагент	=Основание.Контрагент;	
		Договор		=Основание.Договор;
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	// Шворобей ВЮ 15.01.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-165
	// Соответственно, для СПП – не давать проводить СПП раньше, чем ПНК.
	#Если Клиент Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	СписаниеТМЦСпути.Ссылка КАК СПП,
		|	СписаниеТМЦСпути.ДокОснование КАК ЗПС,
		|	СписаниеТМЦСпути.Дата КАК ДатаСПП
		|ПОМЕСТИТЬ ТабСПП
		|ИЗ
		|	Документ.СписаниеТМЦСпути КАК СписаниеТМЦСпути
		|ГДЕ
		|	СписаниеТМЦСпути.ДокОснование <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
		|	И СписаниеТМЦСпути.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТабСПП.СПП КАК СПП,
		|	ТабСПП.ЗПС КАК ЗПС,
		|	ЗаказыПоставщикам.Ссылка КАК ПНК,
		|	ТабСПП.ДатаСПП КАК ДатаСПП,
		|	ЗаказыПоставщикам.Ссылка.Дата КАК ДатаПНК,
		|	ВЫБОР
		|		КОГДА ТабСПП.ДатаСПП < ЗаказыПоставщикам.Ссылка.Дата
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ПризнакДатаРаньше
		|ИЗ
		|	ТабСПП КАК ТабСПП
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.ЗаказыПоставщикам КАК ЗаказыПоставщикам
		|		ПО ТабСПП.ЗПС = ЗаказыПоставщикам.ЗПС
		|			И (ЗаказыПоставщикам.Ссылка.Проведен)
		|			И (ТабСПП.ДатаСПП <= ЗаказыПоставщикам.Ссылка.Дата)";
		
		УстановитьПривилегированныйРежим(Истина);
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);
		
		Если Выборка.Количество() > 0 Тогда
			Пока Выборка.Следующий() Цикл
				СообщитьИзМодуля("Есть " + Строка(Выборка.ПНК) + " с Датой позже, чем Дата СПП!!!");
			КонецЦикла;
			СообщитьИзМодуля("Либо перенесите дату ПНК, либо перенесите дату СПП");
			Отказ = Истина;
		КонецЕсли;
		
	#КонецЕсли
	// Шворобей ВЮ 15.01.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-165
	
	Если СторноЗПС Тогда
		ПровестиСторно(Отказ);
		Возврат;
	КонецЕсли;
	
	ДвиженияПоРегистрам = Неопределено;
	
	ТО=РегистрыНакопления.ТоварыВПути.Остатки(,Новый Структура("Заказ",ДокОснование));
		
	Для Каждого СтрокаТЧ Из Товары Цикл
		СтрокаОстатка=ТО.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");	
		
		Если СтрокаОстатка=Неопределено Тогда
			СуммаПоставщика	=0;		
			Сумма			=0;
			Количество		=0;			
		Иначе
			СуммаПоставщика	=СтрокаОстатка.СуммаПоставщика;
			Сумма			=СтрокаОстатка.Сумма;
			Количество		=СтрокаОстатка.Количество;
		КонецЕсли; 
		
		Если Количество=0 Тогда
			Если СтрокаОстатка=Неопределено Тогда
				СтрокаТЧ.Всего				=0;						
				СтрокаТЧ.СуммаПоставщика	=0;						
			Иначе
				Если СтрокаОстатка.Количество=СтрокаТЧ.Количество Тогда
					СтрокаТЧ.Всего				=СтрокаОстатка.Сумма;
					
					СтрокаТЧ.СуммаПоставщика	=СтрокаОстатка.СуммаПоставщика;
				КонецЕсли;			
			КонецЕсли;			
		Иначе
			СтрокаТЧ.Всего				=СтрокаТЧ.Количество*Сумма/Количество;						
				
			СтрокаТЧ.СуммаПоставщика	=СтрокаТЧ.Количество*СуммаПоставщика/Количество;
		КонецЕсли; 
		
		РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект,"ОтВсего");	    
	КонецЦикла;
	
	СуммаПоставщика =Товары.Итог("СуммаПоставщика");
	СуммаДокумента	=Товары.Итог("Всего");
	
	Записать();
	
	ВалютаЗаказа	= ДокОснование.Валюта;
	КурсЗаказа	= ДокОснование.Курс;
	
	ВалютаУпр	= ПараметрыСеанса.ВалютаУпр_2009;
	КурсУпр	= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	ТЗ=Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("СтатьяЗатрат");
	ТЗ.Колонки.Добавить("Подразделение");
	ТЗ.Колонки.Добавить("Сумма",ПолучитьОписаниеТиповЧисла(19,2));
	ТЗ.Колонки.Добавить("СуммаПоставщика",ПолучитьОписаниеТиповЧисла(19,2));
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		СтрокаТЗ=ТЗ.Добавить();
		
		СтрокаТЗ.Подразделение	=?(ЗначениеЗаполнено(СтрокаТЧ.Подразделение),СтрокаТЧ.Подразделение,Подразделение);
		СтрокаТЗ.СтатьяЗатрат	=?(ЗначениеЗаполнено(СтрокаТЧ.СтатьяЗатрат),СтрокаТЧ.СтатьяЗатрат,СтатьяЗатрат);
		
		Если СписатьСПоставщика ИЛИ СтрокаТЧ.СписатьСПоставщика Тогда
			СтрокаТЗ.СуммаПоставщика	= СтрокаТЧ.СуммаПоставщика;			
		КонецЕсли;
		
		СтрокаТЗ.Сумма= СтрокаТЧ.Всего-глПересчет(СтрокаТЗ.СуммаПоставщика,ВалютаЗаказа,КурсЗаказа,ВалютаУпр,КурсУпр);					
		
		
		//ТОВАР В ПУТИ
		Если СтрокаТЧ.Количество<>0 ИЛИ СтрокаТЧ.Всего<>0 ИЛИ СтрокаТЧ.СуммаПоставщика<>0 Тогда
			Движение=Движения.ТоварыВПути.Добавить();
			
			Движение.Период				=Дата;
			Движение.ВидДвижения		=ВидДвиженияНакопления.Расход;
			
			Движение.Заказ				=ДокОснование;
			Движение.Номенклатура		=СтрокаТЧ.Номенклатура;
			
			Движение.Количество			=СтрокаТЧ.Количество;
			Движение.Сумма				=СтрокаТЧ.Всего;
			Движение.СуммаПоставщика	=СтрокаТЧ.СуммаПоставщика;			
		КонецЕсли;		
	КонецЦикла; 
	
	ТЗ.Свернуть("Подразделение,СтатьяЗатрат","Сумма,СуммаПоставщика");
	
	//ЗАТРАТЫ
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		Если СтрокаТЗ.Сумма<>0 Тогда
			Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
			
			Движение.Подразделение	= СтрокаТЗ.Подразделение;
			Движение.СтатьяЗатрат	= СтрокаТЗ.СтатьяЗатрат;
			
			Движение.СуммаУпр		= СтрокаТЗ.Сумма;	
			
			Движение.СуммаДокумента	= СтрокаТЗ.Сумма;
			Движение.ВалютаДокумента= ВалютаУпр;	
					//крохин начало
		Движение.Комментарий        = Комментарий;
		//крохин конец

			
			Движение.ДатаЗаписи		=ТекущаяДата();	
		КонецЕсли;
	КонецЦикла;	
	
	//ВЗАИМОРАСЧЕТЫ
	СуммаВзаиморасчетов=ТЗ.Итог("СуммаПоставщика");
	Если СуммаВзаиморасчетов<>0 Тогда
		Движение=Движения.Взаиморасчеты.Добавить();	
		
		Движение.Период		=Дата;
		Движение.ВидДвижения=ВидДвиженияНакопления.Приход;	
		
		Движение.Контрагент	=?(Контрагент.Ведущий.Пустая(),Контрагент,Контрагент.Ведущий);
		Движение.Договор	=ДокОснование.Договор;
			//крохин начало 28.08.2011
        // Движение.СуммаВал	=СуммаВзаиморасчетов;
		Если ДокОснование.Валюта = ПолучитьВалютуРасчетов(Договор) ИЛИ Дата < '20110801' Тогда
		Движение.СуммаВал	=СуммаВзаиморасчетов;
	Иначе
		Движение.СуммаВал = СуммаВзаиморасчетов/КурсЗаказа;
	КонецЕсли;	
	    //крохин конец 28.08.2011
		Движение.СуммаУпр	=глПересчет(СуммаВзаиморасчетов,ВалютаЗаказа,КурсЗаказа,ВалютаУпр,КурсУпр);
		Движение.СуммаДокумента	=СписатьСПоставщика;
		Движение.ВалютаДокумента=ВалютаЗаказа;
	КонецЕсли;
	
	// Шворобей ВЮ 31.10.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1637
	// КОМПЕНСАЦИЯ
	Если ЗначениеЗаполнено(КонтрагентКомпенсация) И ЗначениеЗаполнено(ДоговорКомпенсация) Тогда
		
		//СумКомпВал = Товары.Итог("Компенсация");
		//крохин, сумма только по строкам с галкой "списать с поставщика"
		СумКомпВал = 0;
		Для Каждого СтрокаТЧ Из Товары Цикл
			Если СтрокаТЧ.СписатьСПоставщика Тогда
				СумКомпВал = СумКомпВал + СтрокаТЧ.Компенсация;	
			КонецЕсли;
		КонецЦикла;
		
		СуммаУпр = глПересчет(СумКомпВал, ВалютаЗаказа, КурсЗаказа, ВалютаУпр, КурсУпр);
		
		Если СумКомпВал > 0 Тогда
			ДвижениеПриход = Движения.Взаиморасчеты.Добавить();
			
			ДвижениеПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
			ДвижениеПриход.Контрагент = ?(Контрагент.Ведущий.Пустая(), Контрагент, Контрагент.Ведущий);
			ДвижениеПриход.Договор = Договор;
			ДвижениеПриход.Период = Дата;
			ДвижениеПриход.СуммаВал = СумКомпВал;
			ДвижениеПриход.СуммаУпр = СуммаУпр;
			ДвижениеПриход.СуммаДокумента = СуммаДокумента;
			ДвижениеПриход.Регистратор = Ссылка;
			ДвижениеПриход.ВалютаДокумента = ВалютаЗаказа;
			
			ДвижениеРасход = Движения.Взаиморасчеты.Добавить();
			
			ДвижениеРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
			ДвижениеРасход.Контрагент = КонтрагентКомпенсация;
			ДвижениеРасход.Договор = ДоговорКомпенсация;
			ДвижениеРасход.Период = Дата;
			ДвижениеРасход.СуммаВал = СумКомпВал;
			ДвижениеРасход.СуммаУпр = СуммаУпр;
			ДвижениеРасход.СуммаДокумента = СуммаДокумента;
			ДвижениеРасход.Регистратор = Ссылка;
			ДвижениеРасход.ВалютаДокумента = ВалютаЗаказа;
			
			Движения.Взаиморасчеты.Записать();
		КонецЕсли;	
	КонецЕсли;
	// Шворобей ВЮ 31.10.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1637
	
КонецПроцедуры

