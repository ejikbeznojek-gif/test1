
#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	ИмяКолонки = Элемент.ТекущийЭлемент.Имя;
	
	Если ИмяКолонки <> "Отменен" И ИмяКолонки <> "ВычеркСклад"
		И ИмяКолонки <> "ВычеркОфис" И ИмяКолонки <> "ПереданоНаСайт" Тогда
		Возврат;
	КонецЕсли;
	
	СообщениеПользователю = ТоварыПриОкончанииРедактированияНаСервере(Объект.Ссылка, ТекущаяСтрока[ИмяКолонки],
		ИмяКолонки, Элемент.Имя, ТекущаяСтрока.НомерЗаказа);
	Если ЗначениеЗаполнено(СообщениеПользователю) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СообщениеПользователю;
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Товары при окончании редактирования на сервере.
&НаСервере
Функция ТоварыПриОкончанииРедактированияНаСервере(Ссылка, ДанныеТекущейКолонки, ИмяКолонки, // ИмяТабличнойЧасти...)
	ИмяТабличнойЧасти, НомерЗаказа)
	
	ТабличнаяЧастьТовары = ЗначенияРеквизитовОбъекта(Ссылка, ИмяТабличнойЧасти)[ИмяТабличнойЧасти].Выгрузить();
	
	СтрокаТабличнойЧасти = ТабличнаяЧастьТовары.Найти(НомерЗаказа, "НомерЗаказа");
	Если ДанныеТекущейКолонки <> СтрокаТабличнойЧасти[ИмяКолонки]
		И ИмяКолонки = "Отменен" Тогда
		ДанныеТекущейКолонки = СтрокаТабличнойЧасти[ИмяКолонки];
		
		Возврат "Запрещено устанавливать признак отмены интерактивно!
		|Для установки признака вычерка используйте поле ВычеркСклад.
		|Для применения изменений используйте кнопку ""Заполнить по заказу клиента FBS"" на форме РНК.
		|";
	ИначеЕсли ДанныеТекущейКолонки <> СтрокаТабличнойЧасти[ИмяКолонки]
		И (ИмяКолонки = "ВычеркСклад" Или ИмяКолонки = "ВычеркОфис")
		И СтрокаТабличнойЧасти.Отменен Тогда
		ДанныеТекущейКолонки = СтрокаТабличнойЧасти[ИмяКолонки];
		
		Возврат "Данный заказ уже отменен!
		|Нельзя изменять признак вычерка для заказа, по которому уже была выполнена отмена!
		|";
	ИначеЕсли ДанныеТекущейКолонки <> СтрокаТабличнойЧасти[ИмяКолонки]
		И ИмяКолонки = "ПереданоНаСайт" Тогда
		ДанныеТекущейКолонки = СтрокаТабличнойЧасти[ИмяКолонки];
		
		Возврат "Нельзя изменить значение служебного поля!
		|Признак ""Передано на сайт"" необходим для правильной отмены товара на сайте.
		|Значением этого поля управляет пользователь Automat.
		|";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции // ТоварыПриОкончанииРедактированияНаСервере()

#КонецОбласти
