 Функция ПроверитьСФ ()
	 Запрос = Новый Запрос;
	 Запрос.Текст = "ВЫБРАТЬ
	 |	СчетФактураНакладные.Ссылка КАК Ссылка
	 |ИЗ
	 |	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
	 |ГДЕ
	 |	СчетФактураНакладные.Ссылка.Проведен
	 |	И СчетФактураНакладные.Накладная В(&Накладная)
	 |	И НАЧАЛОПЕРИОДА(СчетФактураНакладные.Ссылка.Дата, ДЕНЬ) < &ДатаОтгрузки";
	 Запрос.УстановитьПараметр("Накладная",ТЗНакладных.выгрузитьколонку("Накладная"));
	 запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	 Выборка = запрос.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
		 Сообщить("Существует счет-фактура с датой, меньшей даты документа. Удалите счет-фактуру перед изменением даты отгрузки");			
		 Возврат ложь;	
	 КонецЦикла;
	 возврат Истина;
 КонецФункции
 
 
 Функция ПроверитьОстаткиТоваров() 
	 // Кухарь А.Ю. 19.03.2021 начало
	 // пока что отключил для ускорения
	 возврат Истина;
	 // Кухарь А.Ю. 19.03.2021 конец
	 
	 
	 Запрос=новый запрос;
	 запрос.Текст="ВЫБРАТЬ
	 |	ТЗ.Накладная КАК Накладная
	 |ПОМЕСТИТЬ ТЗНоменклатуры
	 |ИЗ
	 |	&ТЗ КАК ТЗ
	 |ГДЕ
	 |	(ТЗ.Накладная ССЫЛКА Документ.РасходнаяНакладная
	 |			ИЛИ ТЗ.Накладная ССЫЛКА Документ.Перемещение)
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
	 |	СУММА(ЗаданиеНабораТовары.Количество) КАК Количество,
	 |	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0)) КАК КоличествоОстаток,
	 |	СУММА(ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК КоличествоОстаток1
	 |ИЗ
	 |	ТЗНоменклатуры КАК ТЗНоменклатуры
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	 |		ПО ТЗНоменклатуры.Накладная = ЗаданиеНабораТовары.Ссылка.Накладная,
	 |	РегистрНакопления.ОстаткиТМЦ.Остатки(&ДатаОтгрузки, Склад = &Склад) КАК ОстаткиТМЦОстатки,
	 |	РегистрНакопления.РезервыТМЦ.Остатки КАК РезервыТМЦОстатки
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	ЗаданиеНабораТовары.Номенклатура
	 |
	 |ИМЕЮЩИЕ
	 |	СУММА(ЗаданиеНабораТовары.Количество) > СУММА(ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) + СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0))";
	 запрос.УстановитьПараметр("ТЗ",ТЗНакладных);
	 запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	 запрос.УстановитьПараметр("Склад",ПараметрыСеанса.ЭтотУзел.Подразделение.ОсновнойСклад);
	 результат=запрос.Выполнить().выбрать();
	 ОстатковХватает=Истина;
	 пока результат.Следующий() цикл
		 Сообщить("Недостаточно товара на остатках "+результат.номенклатура);
		 ОстатковХватает=Ложь;
	 КонецЦикла;
	 возврат ОстатковХватает;
	 
	 
	 
	 
	 
