 Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	 //++Ратманов управляемые блокировки
	 Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		 Отказ = Истина;
		 Возврат;
	 КонецЕсли;	
	 Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		 Отказ = Истина;
		 Возврат;
	 КонецЕсли;	
	 //--Ратманов управляемые блокировки
	 СписокШК=ЛистыНабора.ВыгрузитьКолонку("ШККоробки");
	 
	 Запрос=новый запрос; 
	 Запрос.Текст="ВЫБРАТЬ
	 |	ОстаткиЗХОстатки.ШККоробки КАК ШККоробки,
	 |	ОстаткиЗХОстатки.ЗонаХранения КАК ЗонаХранения,
	 |	ОстаткиЗХОстатки.КоличествоКоробокОстаток КАК Количество,
	 |	ОстаткиЗХОстатки.ШКПаллеты
	 |ИЗ
	 |	РегистрНакопления.ОстаткиЗХ.Остатки(&Дата, ШККоробки В (&Шк)) КАК ОстаткиЗХОстатки
	 |ГДЕ
	 |	ОстаткиЗХОстатки.КоличествоКоробокОстаток > 0";				 
	 Запрос.УстановитьПараметр("ШК",СписокШК);	
	 Запрос.УстановитьПараметр("Дата",Дата);
	 ЕстьНаОстатках=запрос.Выполнить().Выгрузить();
	 
	 Для каждого ТекСтрока из ЕстьНаОстатках цикл
		 Движение = Движения.ОстаткиЗХ.Добавить();
		 ЗаполнитьЗначенияСвойств(движение,ТекСтрока);
		 Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		 Движение.Период = Дата;
		 Движение.ЗонаХранения = ТекСтрока.ЗонаХранения;
		 Движение.КоличествоКоробок = ТекСтрока.Количество;
	 КонецЦикла;
	 если РазрешитьИзменениеМаршурта тогда
		 ОбработкаРазрешенияИзмененияМаршрута();
	 КонецЕсли;
	 если ТребуетсяЗамерВремени тогда
		 ВсегоНакладных=Заявка.Количество();
		 Запись=РегистрыСведений.ЗамерПроизводительности.СоздатьМенеджерЗаписи();
		 запись.ВидДокумента=Метаданные().Имя;
		 запись.ДатаЗамера=ДатаНачалаЗамера;
		 запись.НомерДокумента=Номер;
		 запись.ИмяКомпьютера= ИмяКомпьютера();
		 запись.ВремяПроведения =  ТекущаяДата()-ДатаНачалаЗамера;
		 запись.Пользователь=ПараметрыСеанса.Пользователь; 	
		 запись.КоличествоСтрок = ВсегоНакладных;
		 запись.Записать();
	 КонецЕсли;
 КонецПроцедуры
 
 Процедура ОбработкаУдаленияПроведения(Отказ)
