 Процедура РазблокироватьМарщрут() 
	 запрос=новый запрос;
	 запрос.текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	 |	ЗаявкаНаОтгрузкуНакладные.Ссылка КАК ЗОГ,
	 // Кухарь А.Ю. 24.02.2021 начало
	 //
	 //|	ЗаявкаНаОтгрузкуНакладные.НомерНакладной КАК НомерНакладной,
	 //|	ЗаявкаНаОтгрузкуНакладные.ВидНакладной КАК ВидНакладной,
	 // Кухарь А.Ю. 24.02.2021 конец
	 |	ЗаявкаНаОтгрузкуНакладные.Автомобиль КАК Автомобиль,
	 |	ЗаявкаНаОтгрузкуНакладные.НомерХодки КАК НомерХодки
	 
	 
	 |ИЗ
	 |	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
	 |ГДЕ
	 |	ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен = ИСТИНА
	 |	И ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	 |	И ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль
	 |	И ЗаявкаНаОтгрузкуНакладные.НомерХодки = &НомерХодки
	 |
	 |УПОРЯДОЧИТЬ ПО
	 |	ЗОГ";
	 
	 запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	 запрос.УстановитьПараметр("Автомобиль",Автомобиль);
	 //Кухарь 18.04.16 начало
	 //Разблокируем теперь не весь маршрут, а только эту ходку.
	 запрос.УстановитьПараметр("НомерХодки",НомерХодки);
	 //Кухарь 18.04.16 конец
	 результат=запрос.Выполнить().Выгрузить();
	 
	 //кухарь 13.04.15 начало 
	 //Для каждого СтрТЗ из ТЗНакладных цикл
	 
	 
	 Для каждого СтрТЗ из результат цикл
		 ЗОГОбъект=СтрТЗ.ЗОГ.получитьобъект();
		 МассСтрока=ЗОГОбъект.Накладные.НайтиСтроки(новый Структура("Автомобиль,НомерХодки",СтрТЗ.Автомобиль,СтрТЗ.НомерХодки));
		 для каждого СтрМасс из МассСтрока цикл
