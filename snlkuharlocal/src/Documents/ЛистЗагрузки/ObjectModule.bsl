 //Модуль "ВОЗВРАТ ПАЛЛЕТ после сдачи постаки
 //При записи ЛЗ в состоянии «ожидание сканирования», 
 //нужно смотреть нет ли в ТЧ Накладные от этого листа загрузки 
 //Расходных накладных (РНК) с пунктом доставки, 
 //имеющих признак «требуется забирать паллеты после сдачи поставки». 
 
 Процедура ЗаполнитьПаллетыКВозвратуПоНакладным()
	 
	 //Выгрузим данные по ПНК если уже не в первый раз заполняем
	 ВрТБВозвратПаллет=ВозвратПаллет.Выгрузить();
	 ВозвратПаллет.Очистить();
	 //Выгрузим данные по ПНК если уже не в первый раз заполняем
	 
	 
	 РезультатВыгрузкиРНК = ПолучимВсеНакладныеРНКПоДокументу();  
	 
	 Если РезультатВыгрузкиРНК.Количество()=0 Тогда
		 Возврат;
	 КонецЕсли;
	 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = "ВЫБРАТЬ
	 |	НужныеПункты.ПунктДоставки КАК ПунктДоставки
	 |ПОМЕСТИТЬ ЗабиратьПаллеты
	 |ИЗ
	 |	(ВЫБРАТЬ
	 |		ЛистЗагрузкиЗаявка.ПунктДоставки КАК ПунктДоставки
	 |	ИЗ
	 |		Документ.ЛистЗагрузки.Заявка КАК ЛистЗагрузкиЗаявка
	 |	ГДЕ
	 |		ЛистЗагрузкиЗаявка.Ссылка = &Ссылка
	 |	
	 |	СГРУППИРОВАТЬ ПО
	 |		ЛистЗагрузкиЗаявка.ПунктДоставки) КАК НужныеПункты
	 |ГДЕ
	 |	НужныеПункты.ПунктДоставки.ТребуетсяЗабиратьПалетты
	 |
	 |ИНДЕКСИРОВАТЬ ПО
	 |	ПунктДоставки
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЛистЗагрузкиЗаявка.ПунктДоставки КАК ПунктДоставки,
	 |	ЛистЗагрузкиЗаявка.НомерНакладной КАК НомерНакладной,
	 |	ЛистЗагрузкиЗаявка.ДатаНакладной КАК ДатаНакладной
	 |ИЗ
	 |	Документ.ЛистЗагрузки.Заявка КАК ЛистЗагрузкиЗаявка
	 |ГДЕ
	 |	ЛистЗагрузкиЗаявка.ВидНакладной = &ВидНакладной
	 |	И ЛистЗагрузкиЗаявка.ПунктДоставки В
	 |			(ВЫБРАТЬ
	 |				ЗабиратьПаллеты.ПунктДоставки КАК ПунктДоставки
	 |			ИЗ
	 |				ЗабиратьПаллеты КАК ЗабиратьПаллеты)
	 |	И ЛистЗагрузкиЗаявка.Ссылка = &Ссылка
	 |ИТОГИ ПО
	 |	ПунктДоставки";
	 //Параметры запроса
	 Запрос.УстановитьПараметр("ВидНакладной","РНК");// Строка
	 Запрос.УстановитьПараметр("Ссылка",Ссылка);// Лист загрузки
	 Результат = Запрос.Выполнить();
	 
	 
	 //Получаем выборку в разрезе Пункт доставки - Накладные 	
	 Выборка = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 	
	 //Найдем номенклатуру ПАЛЛЕТЫ по коду
	 ТоварПаллеты = Справочники.Номенклатура.НайтиПоКоду("ODB-000325");     
	 
	 Пока Выборка.Следующий() Цикл
		 
		 ТекПунктДоставки=Выборка.ПунктДоставки;
		 
		 ВыборкаНакладныхПоПункту = Выборка.Выбрать();
		 //счетчик паллет по каждому пункту доставки
		 КолвоПаллетПоПункту      = 0; 		
		 //сохраним одну из , что заполнить на основании ее параметры ПНК
		 ТекущаяРНК               = Документы.РасходнаяНакладная.ПустаяСсылка();
		 
		 Пока ВыборкаНакладныхПоПункту.Следующий() Цикл			
			 //вернем КоличествоПаллет по  накладной РНК по номеру и дате , так как прямой ссылки нет
			 
			 СтруктураРНК =РезультатВыгрузкиРНК.Найти(ВыборкаНакладныхПоПункту.НомерНакладной,"НомерНакладной");
			 
			 //неопределено или структрура 			
			 Если СтруктураРНК<>Неопределено Тогда 						
				 КолвоПаллетПоПункту = КолвоПаллетПоПункту+СтруктураРНК.КоличествоПаллет;
				 ТекущаяРНК          = СтруктураРНК.Накладная;
			 Иначе
				 //по идеи сюда не должно попасть  найдем отдельным запросом
				 СтруктураРНК=ВернутьКоличествоПаллетИСсылкуРНК(ВыборкаНакладныхПоПункту.НомерНакладной,ВыборкаНакладныхПоПункту.ДатаНакладной);
				 Если СтруктураРНК<>Неопределено Тогда 						
					 КолвоПаллетПоПункту = КолвоПаллетПоПункту+СтруктураРНК.КоличествоПаллет;
					 ТекущаяРНК          = СтруктураРНК.Накладная;
				 КонецЕсли; 				
			 КонецЕсли;    			
		 КонецЦикла;  
		 
		 
		 //поиск накладной
		 
		 УжеЕстьНакладная = ВрТБВозвратПаллет.Найти(ТекПунктДоставки,"ПунктДоставки");
		 
		 НовПНК=Неопределено;
		 
		 Если УжеЕстьНакладная<>Неопределено Тогда			
			 Если ЗначениеЗаполнено(УжеЕстьНакладная.ПНК) Тогда
				 НовПНК=	УжеЕстьНакладная.ПНК.ПолучитьОбъект();
				 
				 //снимем пометку удаления , если документ был помечен на удаление
				 Если НовПНК.ПометкаУдаления Тогда			
					 НовПНК.УстановитьПометкуУдаления(Ложь);
				 КонецЕсли;
				 //снимем пометку удаления   
			 КонецЕсли;
		 КонецЕсли;   		
		 
		 Если КолвоПаллетПоПункту>0 Тогда //тогда,нужно создать ПНК
			 
			 
			 Если НовПНК=Неопределено Тогда 						  				
				 НовПНК=Документы.ПриходнаяНакладная.СоздатьДокумент(); 								
				 НовПНК.Дата       = ТекущаяДата();
				 НовПНК.Комментарий= "Расчетное количество паллет: "+Формат(КолвоПаллетПоПункту,"ЧЦ=10; ЧДЦ=4; ЧГ=");				
				 
				 //стандартные процедуры создание документа
				 ЗаполнитьШапкуДокумента(НовПНК, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "");					
				 // +++ {Кузнецов Сергей Владимирович [10.01.2024]
				 //УстановитьНомерДокумента(НовПНК);  
				 #Если Клиент Тогда
					 УстановитьНомерДокумента(НовПНК);  
				 #Иначе
					 ПрефиксИБ=ПараметрыСеанса.ЭтотУзел.Код;
					 КодИБ=?(ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение,ПрефиксИБ,ПараметрыСеанса.ЭтотУзел.Код);			
					 Если ПрефиксИБ = "EKT" Тогда
						 КодИБ = ПрефиксИБ;	
						 ПрефиксИБ = "SST";
					 КонецЕсли; 
					 УстановитьНовыйНомер(КодИБ+"-");
				 #КонецЕсли
				 // }Кузнецов Сергей Владимирович +++ [10.01.2024]
				 //стандартные процедуры создание документа
				 
				 НовПНК.СостояниеНакладной      = Перечисления.СостоянияНакладной.Принята; 			
				 НовПНК.ПунктДоставки           = ТекПунктДоставки;
				 НовПНК.КодОперации             = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
				 НовПНК.Склад                   = ТекущаяРНК.Склад;
				 НовПНК.Контрагент              = ТекущаяРНК.Контрагент;
				 НовПНК.ДатаОтгрузки            = ТекущаяРНК.ДатаОтгрузки;
				 НовПНК.Договор                 = ТекущаяРНК.Договор;
				 НовПНК.Менеджер                = ТекущаяРНК.Менеджер;
				 НовПНК.Подразделение           = ТекущаяРНК.Подразделение;
				 НовПНК.ТипДоставки             = ТекПунктДоставки.ТипДоставки;  
				 
			 КонецЕсли;  			 
			 
			 //очистим табличную часть
			 НовПНК.Товары.Очистить();
			 
			 НовСтрокаТовары                = НовПНК.Товары.Добавить();
			 НовСтрокаТовары.Номенклатура   = ТоварПаллеты;	
			 НовСтрокаТовары.Единица        = ТоварПаллеты.ОсновнаяЕдиница;
			 КолвоПаллет                    = Окр(КолвоПаллетПоПункту,0,РежимОкругления.Окр15как20);
			 КолвоПаллет                    = ?(КолвоПаллет=0,1,КолвоПаллет);  //лучше пусть будет больше
			 
			 НовСтрокаТовары.Количество               = КолвоПаллет; 
			 НовСтрокаТовары.Заявка                   = КолвоПаллет;
			 НовСтрокаТовары.ПодтвержденнаяЗаявка     = КолвоПаллет;
			 
			 //стандартные процедура заполнения строки табличной части
			 ПриИзмененииНоменклатурыТабЧасти(НовСтрокаТовары, НовПНК);
			 РассчитатьСуммуТабЧасти(НовСтрокаТовары,          НовПНК);
			 //стандартные процедура заполнения строки табличной части
			 
			 //по аналогии проведения			
			 НовПНК.ОбменДанными.Загрузка=истина;
			 НовПНК.Проведен=Истина; 
			 НовПНК.Записать();   
			 НовПНК.ОбработкаПроведения(ложь,РежимПроведенияДокумента.Неоперативный); 
			 //по аналогии проведения
			 
			 НовСтрПНК                  = ВозвратПаллет.Добавить();
			 НовСтрПНК.ПунктДоставки    = ТекПунктДоставки;
			 НовСтрПНК.ВидНакладной     = "ПНК";
			 НовСтрПНК.ПНК              = НовПНК.Ссылка;     //вопрос нужно ли добавлять ссылку, потом удалять будет обработкой
			 НовСтрПНК.НомерНакладной   = НовПНК.Номер;
			 НовСтрПНК.ДатаНакладной    = НовПНК.Дата;
			 НовСтрПНК.КоличествоПаллет = КолвоПаллет;
		 Иначе
			 Если НовПНК<>Неопределено Тогда
				 //пометим на удаление
				 НовПНК.УстановитьПометкуУдаления(Истина);
				 //удалим из временной таблицы
				 ВрТБВозвратПаллет.Удалить(УжеЕстьНакладная);
			 КонецЕсли;			
		 КонецЕсли;   		
		 
	 КонецЦикла;   	
	 
	 //пометим на удаление оставшиеся без присмотра ПНК  	
	 Для Каждого УдВозврПаллет из ВрТБВозвратПаллет Цикл
		 Если ЗначениеЗаполнено(УдВозврПаллет.ПНК) Тогда			
			 НовПНК=УдВозврПаллет.ПНК.ПолучитьОбъект();
			 НовПНК.УстановитьПометкуУдаления(Истина);
		 КонецЕсли;
	 КонецЦикла;
	 ВрТБВозвратПаллет=Неопределено;
	 
 КонецПроцедуры  
 
 Функция ПолучимВсеНакладныеРНКПоДокументу()
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = "ВЫБРАТЬ
	 |	ВложенныйЗапрос.Накладная КАК Накладная,
	 |	ВложенныйЗапрос.НомерНакладной КАК НомерНакладной,
	 |	ВложенныйЗапрос.Получатель КАК Получатель,
	 |	ВложенныйЗапрос.КоличествоПаллет КАК КоличествоПаллет
	 |ИЗ
	 |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	 |		ЗаявкаНаОтгрузкуНакладные.Накладная КАК Накладная,
	 |		ЗаявкаНаОтгрузкуНакладные.НомерНакладной КАК НомерНакладной,
	 |		ЗаявкаНаОтгрузкуНакладные.Получатель КАК Получатель,
	 |		ВЫБОР
	 |			КОГДА ЗаявкаНаОтгрузкуНакладные.Накладная ССЫЛКА Документ.РасходнаяНакладная
	 |				ТОГДА ЗаявкаНаОтгрузкуНакладные.Накладная.КоличествоПаллет
	 |			ИНАЧЕ 0
	 |		КОНЕЦ КАК КоличествоПаллет
	 |	ИЗ
	 |		Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
	 |	ГДЕ
	 |		ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль
	 |		И ЗаявкаНаОтгрузкуНакладные.ВидНакладной = ""РНК""
	 |		И НЕ ЗаявкаНаОтгрузкуНакладные.НеОтгружать
	 |		И ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	 |		И ЗаявкаНаОтгрузкуНакладные.НомерХодки = &НомерХодки) КАК ВложенныйЗапрос
	 |ГДЕ
	 |	ВложенныйЗапрос.КоличествоПаллет > 0";
	 
	 //Параметры запроса
	 Запрос.УстановитьПараметр("Автомобиль"  ,Ссылка.Автомобиль);// Автомобили
	 Запрос.УстановитьПараметр("ДатаОтгрузки",Ссылка.ДатаОтгрузки);// Дата
	 Запрос.УстановитьПараметр("НомерХодки"  ,Ссылка.НомерХодки);// Число
	 РезультатВыгрузкиРНК = Запрос.Выполнить().Выгрузить();
	 
	 Возврат  РезультатВыгрузкиРНК;
	 
 КонецФункции
 
 
