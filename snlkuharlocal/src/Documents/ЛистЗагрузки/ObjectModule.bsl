	 |	И КОНЕЦПЕРИОДА(Регистратор.ДатаОплаты,День) >= &Дата2	
	 //крохин конец 10.07.2016
	 |	И (Регистратор Ссылка Документ.РасходнаяНакладная ИЛИ Регистратор Ссылка Документ.ВводОстатковВзаиморасчетов)
	 //крохин конец 10.02.2016
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 |	И Договор.ВидДоговора_Новый = &ВидДоговораПродажа
	 //крохин конец 30.01.2013
	 |	И Контрагент=&Контрагент	
	 |ОБЪЕДИНИТЬ ВСЕ
	 |ВЫБРАТЬ	
	 |	0 КАК НепрОтгр,	
	 |	IsNull(СуммаВалКонечныйОстаток,0) КАК ДолгКон
	 |ИЗ
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 //|	РегистрНакопления.Взаиморасчеты.ОстаткиИОбороты(, &Дата2,Период,,Контрагент=&Контрагент)
	 |	РегистрНакопления.Взаиморасчеты.ОстаткиИОбороты(, &Дата2,Период,,Контрагент=&Контрагент И Договор.ВидДоговора_Новый = &ВидДоговораПродажа)
	 //крохин конец 30.01.2013	
	 |ИТОГИ
	 |	СУММА(ДолгКон),СУММА(НепрОтгр) 		
	 |ПО ОБЩИЕ";	
	 
	 Запрос.УстановитьПараметр("Приход",ВидДвиженияНакопления.Приход);
	 
	 ДатаКонтроля=КонецДня(ТекущаяДата())-24*60*60*Константы.ЛьготныхДнейКонтроляПросроченнойЗадолженноси.Получить();
	 
	 Запрос.УстановитьПараметр("Дата2",ДатаКонтроля);
	 Запрос.УстановитьПараметр("Контрагент",ВыбКонтрагент);
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 запрос.УстановитьПараметр("ВидДоговораПродажа",Справочники.ВидыДоговоров.Товары_Продажа);
	 //крохин конец 30.01.2013
	 
	 ПросроченнаяЗадолженность=0;
	 
	 Выборка=Запрос.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
		 Если Выборка.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда	
			 ПросроченнаяЗадолженность=Макс(0,Выборка.ДолгКон-Выборка.НепрОтгр);	
			 Прервать;
		 КонецЕсли;	
	 КонецЦикла;	
	 
	 Можно=Истина;
	 
	 Если ПросроченнаяЗадолженность>0 Тогда
		 Можно=Накладная.ОтгружатьСПросроченнойЗадолженостью;
		 
		 // +++ {Кузнецов [22.12.2022]
		 #Если Клиент Тогда
			 Предупреждение("На "+ДатаКонтроля+" просроченная задолженность 
			 |по контрагенту """+СокрЛП(ВыбКонтрагент)+""" ("+СокрЛП(ВыбКонтрагент.Код)+") 
			 |составляет: "+Формат(ПросроченнаяЗадолженность,"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+".
			 |"+?(НЕ Можно,"Недостаточно полномочий для отправки накладной на склад !",""));		
		 #КонецЕсли
		 // }Кузнецов +++ [22.12.2022] 
	 КонецЕсли; 
	 
	 Возврат Можно;
 КонецФункции // КонтрольПросроченнойЗадолженности()
 
 Функция КонтрольЛимитаКредитаНов(Накладная)
	 ВыбКонтрагент=?(ЗначениеЗаполнено(Накладная.Контрагент.Ведущий),Накладная.Контрагент.Ведущий,Накладная.Контрагент);
	 
	 ЕстьКонтроль=ПолучитьГрупповоеСвойствоОбъекта(ВыбКонтрагент,ПланыВидовХарактеристик.СвойстваОбъектов.КонтрольЛимитаЗадолженности);
	 //крохин начало
	 //для бесплатной рекламы контроль не нужен
	 //Если ЕстьКонтроль=Неопределено ИЛИ ЕстьКонтроль=Ложь Тогда Возврат Истина КонецЕсли; 
	 ТолькоРеклама = Истина;
	 Для Каждого СтрокаТЧ Из Накладная.Товары Цикл
		 Если СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.РекламаБесплатная Тогда
			 ТолькоРеклама = Ложь;	
		 КонецЕсли;
	 КонецЦикла;
	 Если ЕстьКонтроль=Неопределено ИЛИ ЕстьКонтроль=Ложь ИЛИ ТолькоРеклама Тогда Возврат Истина КонецЕсли; 
	 //крохин конец
	 
	 Запрос=Новый Запрос;	
	 Запрос.Текст="	
	 |ВЫБРАТЬ	
	 |	КодЦБ,
	 |	ВалютаКредита КАК ВалютаРасчетов,
	 |	СУММА(ЛимитКредита)	КАК ЛимитКредита,
	 |	СУММА(ВЫБОР КОГДА ДопСоглашение ТОГДА ЛимитКредита ИНАЧЕ 0 КОНЕЦ) КАК ЛимитКредитаПоДопСоглашению
	 |ИЗ 
	 |	Справочник.Договоры	
	 |ГДЕ
	 |	КодЦБ=&КодЦБ
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 |	И ВидДоговора_Новый = &ВидДоговораПродажа	
	 //крохин конец 30.01.2013
	 |	И НЕ ПометкаУдаления
	 |	И НЕ НеИспользовать	
	 |СГРУППИРОВАТЬ ПО 
	 |	КодЦБ,ВалютаКредита";	
	 
	 ДатаКонтроля=КонецДня(ТекущаяДата());
	 
	 Запрос.УстановитьПараметр("КодЦБ",ВыбКонтрагент.Код);
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 запрос.УстановитьПараметр("ВидДоговораПродажа",Справочники.ВидыДоговоров.Товары_Продажа);
	 //крохин конец 30.01.2013
	 
	 
	 ВалютаИтогов=ПараметрыСеанса.ВалютаУпр_2009;
	 
	 ЛимитКредита				= 0;
	 ЛимитКредитаПоДопСоглашению = 0;
	 
	 Выборка=Запрос.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
		 ЛимитКредита				= ЛимитКредита					+глПересчет(Выборка.ЛимитКредита,					Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);
		 ЛимитКредитаПоДопСоглашению = ЛимитКредитаПоДопСоглашению	+глПересчет(Выборка.ЛимитКредитаПоДопСоглашению,	Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);		
	 КонецЦикла;	
	 
	 Запрос=Новый Запрос;
	 Запрос.Текст="
	 |ВЫБРАТЬ
	 |	Договор,
	 |	Договор.ВалютаКредита	КАК ВалютаРасчетов,
	 |	СуммаВалОстаток КАК ОбщийДолг,
	 |	ВЫБОР КОГДА Договор.ДопСоглашение ТОГДА 1 ИНАЧЕ 0 КОНЕЦ*СуммаВалОстаток КАК ДолгПоДопСоглашению 
	 |ИЗ
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 //|	РегистрНакопления.Взаиморасчеты.Остатки(&ДатаКонтроля, Контрагент = &Контрагент) КАК ВзаиморасчетыОстатки
	 |	РегистрНакопления.Взаиморасчеты.Остатки(&ДатаКонтроля, Контрагент = &Контрагент И Договор.ВидДоговора_Новый = &ВидДоговораПродажа) КАК ВзаиморасчетыОстатки
	 //крохин конец 30.01.2013
	 |ОБЪЕДИНИТЬ ВСЕ
	 |ВЫБРАТЬ
	 |	Договор,
	 |	Договор.ВалютаКредита	КАК ВалютаРасчетов,
	 |	СуммаДокумента 			КАК ОбщийДолг,
	 |	ВЫБОР КОГДА Договор.ДопСоглашение ТОГДА 1 ИНАЧЕ 0 КОНЕЦ*СуммаДокумента КАК ДолгПоДопСоглашению 
	 |ИЗ
	 |	Документ.РасходнаяНакладная
	 |ГДЕ
	 |	Проведен
	 |	И Отгружен=ЗНАЧЕНИЕ(Перечисление.Отгружен.Резерв)
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 |	И Договор.ВидДоговора_Новый = &ВидДоговораПродажа	
	 //крохин конец 30.01.2013
	 |	И (
	 |		СостояниеНакладной<>ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ВРаботе)
	 |   	ИЛИ Ссылка=&Накладная
	 |	) 	
	 |	И (
	 |	Контрагент.Ведущий	=&Контрагент
	 |	ИЛИ Контрагент		=&Контрагент
	 |	)";
	 
	 Запрос.УстановитьПараметр("ДатаКонтроля",	ДатаКонтроля);
	 Запрос.УстановитьПараметр("Контрагент",		ВыбКонтрагент);	
	 Запрос.УстановитьПараметр("Накладная",		Накладная);		
	 //крохин начало 30.01.2013
	 //только по договорам "продажа"
	 запрос.УстановитьПараметр("ВидДоговораПродажа",Справочники.ВидыДоговоров.Товары_Продажа);
	 //крохин конец 30.01.2013
	 
	 
	 ОбщийДолг=0;
	 ДолгПоДопСоглашению=0;
	 Выборка=Запрос.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
		 ОбщийДолг			=ОбщийДолг			+глПересчет(Выборка.ОбщийДолг,			Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);			
		 ДолгПоДопСоглашению	=ДолгПоДопСоглашению+глПересчет(Выборка.ДолгПоДопСоглашению,Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);
	 КонецЦикла; 
	 
	 Можно=Истина;
	 
	 Если ОбщийДолг>ЛимитКредита Тогда
		 Можно=Накладная.ОтгружатьСПревышениемЛимитаКредита;
		 
		 // +++ {Кузнецов [22.12.2022]
		 #Если Клиент Тогда
			 Предупреждение("На "+ДатаКонтроля+" задолженность 
			 |по контрагенту """+СокрЛП(ВыбКонтрагент)+""" ("+СокрЛП(ВыбКонтрагент.Код)+")
			 |составляет: "+Формат(ОбщийДолг,"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |Доступный лимит: "+Формат(ЛимитКредита,"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |Лимит превышен на : "+Формат((ОбщийДолг-ЛимитКредита),"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |"+?(НЕ Можно,"
			 |Недостаточно полномочий для отправки накладной на склад !",""));		
		 #КонецЕсли
		 // }Кузнецов +++ [22.12.2022] 
		 
	 ИначеЕсли ДолгПоДопСоглашению>ЛимитКредитаПоДопСоглашению И Накладная.Договор.ДопСоглашение И Накладная.Дата>='20091001' Тогда
		 Можно=Накладная.ОтгружатьСПревышениемЛимитаКредита;
		 
		 // +++ {Кузнецов [22.12.2022]
		 #Если Клиент Тогда
			 Предупреждение("На "+ДатаКонтроля+" задолженность по доп. соглашению
			 |по контрагенту """+СокрЛП(ВыбКонтрагент)+""" ("+СокрЛП(ВыбКонтрагент.Код)+")
			 |составляет: "+Формат(ДолгПоДопСоглашению,"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |Доступный лимит по доп. соглашению: "+Формат(ЛимитКредитаПоДопСоглашению,"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |Лимит превышен на : "+Формат((ДолгПоДопСоглашению-ЛимитКредитаПоДопСоглашению),"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0")+" "+ВалютаИтогов+".
			 |"+?(НЕ Можно,"
			 |Недостаточно полномочий для отправки накладной на склад !",""));		
		 #КонецЕсли
		 // }Кузнецов +++ [22.12.2022]
		 
	 КонецЕсли; 
	 
	 Возврат Можно;
 КонецФункции
 Функция КонтрольНулевыхЦенВНакладной(Накладная)
	 Можно=Истина;
	 
	 Если НЕ Накладная.ОтгружатьПоНулевымЦенам Тогда 		
		 
		 Стр="";
		 
		 Для Каждого СтрокаТЧ Из Накладная.Товары Цикл
			 //крохин начало 08.09.2017
			 //МБП тоже не проверяем
			 //Если СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.РекламаБесплатная И СтрокаТЧ.Цена = 0  И СтрокаТЧ.Количество <> 0 Тогда	
			 Если (СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.РекламаБесплатная И СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.МБП)И СтрокаТЧ.Цена = 0  И СтрокаТЧ.Количество <> 0 Тогда
				 //крохин конец 08.09.2017	
				 Можно=Ложь;
				 
				 Стр=Стр+"Нулевые цены в накладной !";
				 
				 Стр=Стр+Символы.ПС+"Стр. №: "+СтрокаТЧ.НомерСтроки+", ном.: "+СтрокаТЧ.Номенклатура;		
			 КонецЕсли; 
		 КонецЦикла;
		 Если НЕ ПустаяСтрока(Стр) Тогда    
			 // +++ {Кузнецов [22.12.2022]
			 #Если Клиент Тогда
				 Предупреждение(Стр);	
			 #КонецЕсли
			 // }Кузнецов +++ [22.12.2022]
		 КонецЕсли;
	 КонецЕсли; 
	 
	 Возврат Можно;
 КонецФункции 
