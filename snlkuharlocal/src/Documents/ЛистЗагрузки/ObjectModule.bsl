 функция УстановитьШКЛЗ ()
	 Запрос=Новый Запрос;
	 Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	 |	ПОДСТРОКА(ЛистЗагрузки.ШтрихКод, 4, 9) КАК НомерШК
	 |ИЗ
	 |	Документ.ЛистЗагрузки КАК ЛистЗагрузки
	 |ГДЕ
	 |	ПОДСТРОКА(ЛистЗагрузки.ШтрихКод, 1, 3) = ""444""
	 |
	 |УПОРЯДОЧИТЬ ПО
	 |	НомерШК УБЫВ";
	 
	 Выборка=Запрос.Выполнить().Выбрать();
	 Если Выборка.Следующий() Тогда
		 НомерШК =  Число(Выборка.НомерШК);	
	 Иначе
		 НомерШК = "000000000";
	 КонецЕсли; 
	 
	 НомерШК=НомерШК+1;
	 ШтрихКод = "444" + Формат(НомерШК,"ЧЦ=9; ЧРГ=; ЧВН=; ЧГ=0");
	 ШтрихКод = ШтрихКод + КонтрольныйСимволEAN(Число(ШтрихКод),13);
	 Возврат ШтрихКод;
 КонецФункции
