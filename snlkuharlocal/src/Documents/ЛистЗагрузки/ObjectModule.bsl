Функция ОбновитьКоличестваРНКиЛН() Экспорт	 
	Данные = ПолучитьКоличестваРНКиЛН();
	
	КоличествоЛН		= Данные.КоличествоЛН;	
	КоличествоНакладных = Данные.КоличествоНакладных;
КонецФункции
	
Функция ПолучитьКоличестваРНКиЛН()	 
	Результат = Новый Структура("КоличествоЛН,КоличествоНакладных", 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ЛистыНабора ИЗ &ЛистыНабора КАК ЛистыНабора
	|;
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШККоробки) КАК Количество
	|ИЗ
	|	ВТ_ЛистыНабора
	|ГДЕ
	|	ШККоробки <> """"	
	|;
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ НомерНакладной) КАК Количество
	|ИЗ
	|	ВТ_ЛистыНабора
	|ГДЕ
	|	НомерНакладной <> """"	
	|";
	
	Запрос.УстановитьПараметр("ЛистыНабора", ЛистыНабора);
	рЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка 	= рЗапроса[рЗапроса.ВГраница()-1].Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Результат.КоличествоЛН = Выборка.Количество;	
	КонецЕсли;
	Выборка 	= рЗапроса[рЗапроса.ВГраница()-0].Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Результат.КоличествоНакладных = Выборка.Количество;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьКоличестваРНКиЛН()
