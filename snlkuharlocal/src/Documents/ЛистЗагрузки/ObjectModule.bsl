 функция ПолучитьРеквизитРНКПНКПРМ(Документ,ИмяРеквизита)
	 
	 ЗначениеРеквизита = неопределено;
	 
	 ПоискНомера=новый Запрос;
	 ПоискНомера.Текст="ВЫБРАТЬ
	 |	РеквизитыРНКПНКПРМ.ЗначениеРеквизита КАК ЗначениеРекв
	 |ИЗ
	 |	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	 |ГДЕ
	 |	РеквизитыРНКПНКПРМ.Документ = &Документ
	 |	И РеквизитыРНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита";
	 ПоискНомера.УстановитьПараметр("Документ", Документ);
	 ПоискНомера.УстановитьПараметр("ИмяРеквизита",ИмяРеквизита);
	 СписокНомеров=ПоискНомера.Выполнить().Выбрать();
	 
	 Пока СписокНомеров.Следующий() Цикл
		 
		 ЗначениеРеквизита = СписокНомеров.ЗначениеРекв;
		 
	 КонецЦикла;
	 возврат ЗначениеРеквизита; 
	 
 конецФункции
