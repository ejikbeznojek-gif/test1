 Функция ДобавитьКоробкуВЛЗ(Знач Лист, Знач НомерКоробки, Знач ШК, Знач ШКПаллеты) экспорт
	 СтруктураВозврата=новый Структура("Ошибки,Успех",Новый Массив,Ложь);
	 
	 КонецСтроки=СтрНайти(ШК,"}}}");
	 если КонецСтроки > 0 тогда
		 ШК = Сред(ШК,1,КонецСтроки+2);
	 КонецЕсли;
	 
	 Накладная=ПолучитьРеквизитШапки(Лист,"ДокОснование","Документ");
	 ВидНакладной=накладная.метаданные().синоним;
	 ОтборДляЗаявки=новый Структура;
	 ОтборДляЗаявки.Вставить("НомерНакладной",накладная.номер);
	 ОтборДляЗаявки.Вставить("ВидНакладной",ВидНакладной);
	 МассивСтрокЗаявки=Заявка.НайтиСтроки(ОтборДляЗаявки);
	 Если МассивСтрокЗаявки.Количество()=0 тогда
		 СтруктураВозврата.Ошибки.Добавить("Накладной нет в заявке");
		 Возврат СтруктураВозврата;	
	 ИначеЕсли МассивСтрокЗаявки.Получить(0).КоличествоКоробок = 0 тогда
		 СтруктураВозврата.Ошибки.Добавить("Эту накладную не надо сканировать!");
		 Возврат СтруктураВозврата		
	 КонецЕсли;
	 
	 если НомерКоробки > накладная.КоличествоКоробок тогда
		 СтруктураВозврата.Ошибки.Добавить("Ошибка считывания ШК, попробуйте ещё раз отсканировать ШК");
		 Возврат СтруктураВозврата;
	 КонецЕсли;
	 
	 // Кухарь А.Ю.  07.09.2025 начало
	 если ЛистыНабора.НайтиСтроки(новый Структура("НомерНакладной,НомерКоробки",накладная.номер,НомерКоробки)).Количество()> 0 тогда 
		 СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Коробка %1 от накладной %2 уже сканировалась в этот документ",НомерКоробки,накладная.номер));
	 КонецЕсли;
	 // Кухарь А.Ю.  07.09.2025 конец
	 
	 //Валетов + 20,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8534 
	 ЕстьПовторяющиесяСтроки = ЛистыНабора.НайтиСтроки(Новый Структура("НомерНакладной, ШККоробки", Накладная.Номер, ШК));
	 Если ЕстьПовторяющиесяСтроки.Количество()> 0 Тогда 
		 СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Коробка с ШК %1 уже отсканирована в этот документ",ШК));
		 Возврат СтруктураВозврата
	 КонецЕсли;
	 //Валетов -  
	 
	 СтрЛистаНабора=ЛистыНабора.Добавить();
	 СтрЛистаНабора.ШККоробки=ШК;
	 СтрЛистаНабора.НомерКоробки=НомерКоробки;
	 СтрЛистаНабора.ВидНакладной=ВидНакладной;
	 СтрЛистаНабора.НомерНакладной=накладная.номер;
	 СтрЛистаНабора.ВремяСканирования=ТекущаяДата();
	 СтрЛистаНабора.Получатель=МассивСтрокЗаявки.получить(0).Получатель;
	 
	 СтрЛистаНабора.ПунктДоставки=МассивСтрокЗаявки.получить(0).ПунктДоставки;
	 СтрЛистаНабора.ДатаНакладной=накладная.дата;
	 СтрЛистаНабора.ШКПаллеты=ШКПаллеты;
	 
	 СтруктураВозврата.Успех=Истина;
	 возврат СтруктураВозврата;
 КонецФункции
 
