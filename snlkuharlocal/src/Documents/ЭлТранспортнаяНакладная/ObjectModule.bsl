

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если ОбменДанными.Загрузка Тогда
	Иначе
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);			
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);	
		
		//Кухарь 23.04.17 начало
		//2 новых реквизита
		если ЭтоНовый() тогда
			Автор=ПараметрыСеанса.Пользователь;
		КонецЕсли;
		АвторПоследнегоИзменения=ПараметрыСеанса.Пользователь;
		
		//По просьбе Лисицкого, для отчётов
		ДатаПоследнегоИзменения=ТекущаяДата();
		Если ЗаказнаяМашина.Водитель.НеИспользовать Тогда
			#Если Клиент Тогда
				Сообщить("Ошибка: выбран запрещенный к использованию водитель: "+ЗаказнаяМашина.Водитель+"!");	
			#КонецЕсли
			Отказ = Истина;	
		КонецЕсли;
	КонецЕсли;		
	
	Если Отказ Тогда Возврат КонецЕсли; 
	
	ЕстьИзменения		=Модифицированность();	
	НужноВыгружать		=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;
	
	
КонецПроцедуры


Функция ПолучитьКоличествоИОбъемПаллет (Получатель)
	
	Запрос=новый запрос;
	Запрос.Текст= "ВЫБРАТЬ
	|	ЗаявкаНаОтгрузкуНакладные.Получатель КАК Получатель,
	|	СУММА(ВЫБОР
	|			КОГДА ЗаявкаНаОтгрузкуНакладные.Накладная ССЫЛКА Документ.РасходнаяНакладная
	|				ТОГДА ВЫРАЗИТЬ(ЗаявкаНаОтгрузкуНакладные.Накладная КАК Документ.РасходнаяНакладная).КоличествоПаллет
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КоличествоПаллет,
	|	СУММА(ВЫБОР
	|			КОГДА ЗаявкаНаОтгрузкуНакладные.Накладная ССЫЛКА Документ.РасходнаяНакладная
	|				ТОГДА ВЫРАЗИТЬ(ЗаявкаНаОтгрузкуНакладные.Накладная КАК Документ.РасходнаяНакладная).ОбъемПаллет
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ОбъемПаллет
	|ИЗ
	|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
	|ГДЕ
	|	ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен
	|	И НЕ ЗаявкаНаОтгрузкуНакладные.НеОтгружать
	|	И ЗаявкаНаОтгрузкуНакладные.Получатель = &Получатель
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаОтгрузкуНакладные.Получатель";
	запрос.УстановитьПараметр("ДатаОтгрузки",НачалоДня(дата));
	запрос.УстановитьПараметр("Получатель",Получатель);
	Возврат запрос.Выполнить().Выгрузить();
	
КонецФункции



