
Функция СоздатьДокументРекламационнаяНакладная(ДокСсылка, ДополнительныеРеквизиты = Неопределено, Проводить = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда Возврат Неопределено; КонецЕсли;
	
	ДокРекламация = СоздатьИзменитьДокумент(ДокСсылка, "РекламационнаяНакладная");
	Если ДокРекламация <> Неопределено Тогда
		
		ЗаполнитьШапкуДокумента(ДокРекламация, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
		
		ДокРекламация.Заполнить(ДокСсылка);
		
		Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
			Для Каждого Элемент из ДополнительныеРеквизиты Цикл
				//УстановитьНезаполненныйРеквизитШапки(ДокРекламация, Элемент.Ключ, Элемент.Значение);
				Если ЕстьРеквизитДокумента(Элемент.Ключ, ДокРекламация.Метаданные()) Тогда
					ДокРекламация[Элемент.Ключ] = Элемент.Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Попытка
			Если Проводить Тогда
				ДокРекламация.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				ДокРекламация.ОбменДанными.Загрузка = Истина;
				ДокРекламация.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			СообщитьИзМодуля("" + Строка(ДокРекламация));
			Возврат ДокРекламация.Ссылка;		
		Исключение
			ДокРекламация.ОбменДанными.Загрузка = Истина;
			ДокРекламация.Записать(РежимЗаписиДокумента.Запись);
			СообщитьИзМодуля(ОписаниеОшибки());
			Возврат ДокРекламация.Ссылка;
		КонецПопытки;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СоздатьИзменитьДокумент(ДокСсылка = Неопределено, ВидДокумента = "РекламационнаяНакладная", ФлагТолькоПроведенные = Ложь, ФлагБезПомеченныхНаУдаление = Истина, СоздаватьНовый = Ложь) Экспорт
	
	Если ДокСсылка = Неопределено ИЛИ СоздаватьНовый Тогда
		НовыйДок = Неопределено;
	Иначе
		НовыйДок = ЗаполнениеДокументов.НайтиПодчиненныйДокумент(ДокСсылка, ВидДокумента, ФлагТолькоПроведенные, ФлагБезПомеченныхНаУдаление);
	КонецЕсли;
	
	Если НовыйДок = Неопределено Тогда
		НовыйДокОбъект = Документы[ВидДокумента].СоздатьДокумент();
		НовыйДокОбъект.Дата = ТекущаяДатаСеанса();
		КодИБ = ПараметрыСеанса.ЭтотУзел.Код;
		НовыйДокОбъект.УстановитьНовыйНомер(КодИБ + "-");		
	Иначе
		НовыйДокОбъект = НовыйДок.ПолучитьОбъект();
	КонецЕсли;
	
	Возврат НовыйДокОбъект;
	
КонецФункции

