Процедура СформироватьОтбивку(ДокСсылка, ТекстОтбивки = "", Полномочие = "ДокументКоррекцияОбработка", Автор = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Если ТипЗнч(Полномочие)=Тип("Строка") Тогда
		Полномочие=ПланыВидовХарактеристик.ПолномочияПользователей[Полномочие];	
	КонецЕсли;	
	Запрос.УстановитьПараметр("Полномочие"   , Полномочие);
	Запрос.УстановитьПараметр("Автор" , Автор);
	Если Автор = Неопределено Тогда
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫРАЗИТЬ(ПолномочияПользователей.Пользователь.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК ЕМэйл
		|ИЗ
		|	РегистрСведений.ПолномочияПользователей КАК ПолномочияПользователей
		|ГДЕ
		|	ПолномочияПользователей.Полномочие = &Полномочие
		|	И (ВЫРАЗИТЬ(ПолномочияПользователей.Пользователь.ФизЛицо.ЕМэйл КАК СТРОКА(100))) <> """"
		|	И ПолномочияПользователей.Значение = ИСТИНА
		|";
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫРАЗИТЬ(Пользователи.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК Емэйл
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.Ссылка = &Автор
		|	И НЕ Пользователи.ПометкаУдаления
		|	И (ВЫРАЗИТЬ(Пользователи.ФизЛицо.ЕМэйл КАК СТРОКА(100))) <> """"
		|";
	КонецЕсли;
	
	Массив = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ЕМэйл");
	СписокПолучателей = Новый СписокЗначений;
	Для Каждого Элемент Из Массив Цикл
		СписокПолучателей.Добавить(Элемент);	
	КонецЦикла;
	
	Если СписокПолучателей.Количество() > 0 Тогда
		
		ТекстПисьма = "Документ " + Строка(ДокСсылка) + ". " + ТекстОтбивки;
		
		СформироватьВнутреннееУведомление(СписокПолучателей, ТекстПисьма, ТекстПисьма, ДокСсылка);
		
	КонецЕсли;
	
КонецПроцедуры

