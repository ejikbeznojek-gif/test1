Функция СоздатьДокументКорректировочнаяСФ(РекламацияСсылка) Экспорт
	
	КСФ = КСчетФактураНакладной(РекламацияСсылка);
	
	Если КСФ.Пустая() Тогда
		КСФ_Объект = Документы.КорректировочныйСчетФактура.СоздатьДокумент();
	Иначе
		КСФ_Объект = КСФ.Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьШапкуДокумента(КСФ_Объект, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
	
	КСФ_Объект.Дата = ТекущаяДатаСеанса();
	
	КСФ_Объект.Заполнить(РекламацияСсылка);
	
	УстановитьНомерДокументаКлиентСервер(КСФ_Объект);
	
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	Попытка
		КСФ_Объект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		СообщитьИзМодуля("" + Строка(КСФ_Объект));
	Исключение
		КСФ_Объект.ОбменДанными.Загрузка = Истина;
		КСФ_Объект.Записать(РежимЗаписиДокумента.Запись);
		СообщитьИзМодуля(ОписаниеОшибки());
	КонецПопытки;
	
	Возврат ?(КСФ_Объект = Неопределено, Неопределено, КСФ_Объект.Ссылка);
	
КонецФункции