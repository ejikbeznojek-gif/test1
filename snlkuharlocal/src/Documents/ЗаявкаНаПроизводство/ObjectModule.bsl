Процедура ПроверитьТЧКомплектующие(Отказ)

	
	КоличествоКомплектующих = Комплектующие.Итог("Количество");
	
	КоличествоКомплектующихДляСверки = Товары.Итог("КоличествоКомплектующих");
	
	Если КоличествоКомплектующихДляСверки = 0 Тогда
		Для каждого СтрокаТЧ из Товары цикл
			ЗаполнитьКоличествоКомплектующихПоСтроке(СтрокаТЧ);		
		КонецЦикла;			
	КонецЕсли;
	
	Если не ОбменДанными.Загрузка тогда
		Если Товары.Итог("КоличествоКомплектующих") <> Комплектующие.Итог("Количество") тогда
			СообщитьИзМодуля("Не совпадает количество комплектующих в таблице состав и в таблице комплектующие");
			Отказ = Истина; 
		КонецЕсли;
		
		//ТЧНоменклатура = Товары.Выгрузить(,"Номенклатура");
		//ТЧНоменклатура.Свернуть("Номенклатура"); 
		МассивНоменклатуры = ПолучитьМассивНоменклатуры("Товары","Номенклатура");//ТЧНоменклатура.ВыгрузитьКолонку("Номенклатура"); 
		
		//ТЧПродукции = Комплектующие.Выгрузить(,"Продукция"); 
		//ТЧПродукции.Свернуть("Продукция"); 	
		
		МассивПродукции = ПолучитьМассивНоменклатуры("Комплектующие","Продукция");//ТЧПродукции.ВыгрузитьКолонку("Продукция");
		
		Если МассивНоменклатуры.Количество() <>  МассивПродукции.Количество() Тогда
			
			Отказ = истина; 
			Сообщить("Не совпадает номенклатура на закладке Состав и Комплектующие");
		Иначе 
			Для каждого ЭлементТовара Из МассивНоменклатуры Цикл
				
				Если МассивПродукции.Найти(ЭлементТовара) = неопределено Тогда
					
					Отказ = Истина; 	
					
					Сообщить("Не совпадает номенклатура на закладке Состав:" +Строка(ЭлементТовара)  + " и Комплектующие: не найдено");
					
				КонецЕсли;	
				
			КонецЦикла; 
			
			Для каждого ЭлементТовара Из МассивПродукции Цикл
				
				Если МассивНоменклатуры.Найти(ЭлементТовара) = неопределено Тогда
					
					Отказ = Истина; 	
					
					Сообщить("Не совпадает номенклатура на закладке Комплектующие:" +Строка(ЭлементТовара)  + " и Состав: не найдено");
					
				КонецЕсли;	
				
			КонецЦикла;

		КонецЕсли;
		
	КонецЕсли;                                
	

КонецПроцедуры

Процедура ДвижениеПоЗаказамПоставщикам(ИмяТЧДляДвижений,ИмяРНакопления)
	
	Доллары		= Справочники.Валюты.НайтиПоКоду("840");
	Евро		= Справочники.Валюты.НайтиПоКоду("978");
	
	КурсВалюты	= ПолучитьКурсВалюты_ПоРусски(Валюта,Дата);
	
	ВалютаУпр	= ?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	КурсДоллара	= ПолучитьКурсВалюты(Доллары,Дата).Курс;
	КурсЕвро	= ПолучитьКурсВалюты(Евро,Дата).Курс;
	Рубли		= ПараметрыСеанса.ВалютаНац;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкаНаПроизводствоКомплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаявкаНаПроизводствоКомплектующие.Количество) КАК Количество,
	|	ЗаявкаНаПроизводствоКомплектующие.Единица КАК Единица,
	|	ЗаявкаНаПроизводствоКомплектующие.Коэффициент КАК Коэффициент,
	|	МАКСИМУМ(ЗаявкаНаПроизводствоКомплектующие.Цена) КАК Цена,
	|	СУММА(ЗаявкаНаПроизводствоКомплектующие.Сумма) КАК Сумма,
	|	СУММА(ЗаявкаНаПроизводствоКомплектующие.Всего) КАК Всего
	|ИЗ
	|	Документ.ЗаявкаНаПроизводство.%ИмяТЧДляДвижений% КАК ЗаявкаНаПроизводствоКомплектующие
	|ГДЕ
	|	ЗаявкаНаПроизводствоКомплектующие.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаПроизводствоКомплектующие.Единица,
	|	ЗаявкаНаПроизводствоКомплектующие.Номенклатура,
	|	ЗаявкаНаПроизводствоКомплектующие.Коэффициент";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяТЧДляДвижений%",ИмяТЧДляДвижений); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтрокаТЧ = РезультатЗапроса.Выбрать(); 
	
	//Для Каждого СтрокаТЧ Из Товары Цикл
	Пока СтрокаТЧ.Следующий() Цикл
		//--Данилова Е.В. 29.07.2025
		Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли; 					
		
		//Движение=Движения.ЗаказыПоставщикам.Добавить();
		Движение=Движения[ИмяРНакопления].Добавить();
		
		Движение.Период			=Дата;
		Движение.ВидДвижения	=ВидДвиженияНакопления.Приход;
		
		Движение.Склад			= Склад;
		Движение.Номенклатура	= СтрокаТЧ.Номенклатура;
		Движение.Заказ			= Ссылка;
		
		Движение.Количество		= СтрокаТЧ.Количество;				
		Движение.СуммаРуб		= глПересчет(СтрокаТЧ.Всего,Валюта,Курс,Рубли,	Курс);
		Движение.СуммаEUR		= глПересчет(СтрокаТЧ.Всего,Валюта,Курс,Евро,	КурсЕвро);
		Движение.СуммаUSD		= глПересчет(СтрокаТЧ.Всего,Валюта,Курс,Доллары,КурсДоллара);
		
		Движение.Отправитель	= Контрагент;
	КонецЦикла;
	

КонецПроцедуры

Функция ПолучитьМассивНоменклатуры(ИмяТЧ,ИмяКолонки)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаявкаНаПроизводствоТовары.%ИмяКолонки% КАК Номенклатура,
		|	ЗаявкаНаПроизводствоТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ЗаявкаНаПроизводствоТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|ГДЕ
		|	ВТТовары.Количество > 0
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)"; 	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяКолонки%",ИмяКолонки);
	
	Запрос.УстановитьПараметр("Товары",ЭтотОбъект[ИмяТЧ].Выгрузить()); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура"); 


КонецФункции 

