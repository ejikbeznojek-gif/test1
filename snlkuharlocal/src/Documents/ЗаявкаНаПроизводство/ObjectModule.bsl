Процедура ОбновитьДанныеЗаказов()
Запрос = Новый Запрос;
Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
               |	ЗаявкаНаПроизводствоТовары.ЗаказКонтрагента КАК ЗаказКонтрагента
               |ИЗ
               |	Документ.ЗаявкаНаПроизводство.Товары КАК ЗаявкаНаПроизводствоТовары
               |ГДЕ
               |	ЗаявкаНаПроизводствоТовары.ЗаказКонтрагента <> &ЗаказКонтрагента
               |	И ЗаявкаНаПроизводствоТовары.Ссылка = &Ссылка";
Запрос.УстановитьПараметр("Ссылка",Ссылка);
Запрос.УстановитьПараметр("ЗаказКонтрагента",Документы.Заказ.ПустаяСсылка());
Выборка = Запрос.Выполнить().Выбрать();

Пока Выборка.Следующий() Цикл
ДокЗаказ = Выборка.ЗаказКонтрагента.ПолучитьОбъект();
ДокЗаказ.УстановитьЗаказ(Ссылка);
КонецЦикла;
КонецПроцедуры

