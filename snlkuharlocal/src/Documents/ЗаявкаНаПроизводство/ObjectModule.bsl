Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
		
	ВидОснования	= Основание.Метаданные().Имя;		
	ДокОснование	= Основание;	
	ИБ				= Основание.ИБ;
		
	Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование,"Контрагент");	
	Договор			= ПолучитьРеквизитОбъекта(ДокОснование,"Договор");
	
	Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	
	Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");		
	Склад			= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");	
	
	ГруппыТоваров	= ПолучитьРеквизитОбъекта(ДокОснование,"ГруппыТоваров");
	
	ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	Скидка1			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");	
	
	Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy")+". "+ДокОснование.Комментарий;	
		
	Для Каждого исхСтрокаТЧ Из ДокОснование.Товары Цикл
		СтрокаТЧ = Товары.Добавить();		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);		
		строкатч.Остаток = СтрокаТЧ.Количество;	
			Если СтрокаТЧ.Количество=0 Тогда
			Товары.Удалить(СтрокаТЧ);	
		Иначе
			РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);
		КонецЕсли; 
	КонецЦикла;	
КонецПроцедуры

