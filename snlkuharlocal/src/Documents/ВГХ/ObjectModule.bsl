
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВГХ.Номенклатура КАК Номенклатура,
	|	ВГХ.Регистратор.Дата КАК РегистраторДата,
	|	ВГХ.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрСведений.ВГХ КАК ВГХ
	|ГДЕ
	|	ВГХ.Номенклатура = &Номенклатура
	|	И ВГХ.Регистратор <> &Ссылка";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);  	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	НужноПровести=Истина;
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 	
		Если ВыборкаДетальныеЗаписи.РегистраторДата>Дата ТОгда
			НужноПровести=Ложь; 
		Иначе 
			
			//Отменим проведение если уже есть такой документ
			Регистратор = ВыборкаДетальныеЗаписи.Регистратор;
			ОбРег= Регистратор.ПолучитьОбъект();
			ОбРег.Записать(РежимЗаписиДокумента.ОтменаПроведения);			
			
			НужноПровести=Истина;
		КонецЕсли;  		
	КонецЕсли;    
	
	Если НужноПровести Тогда
		
		Движения.ВГХ.Записывать = Истина;
		Движения.ВГХ.Очистить();
		
		Для каждого ТекСтрока Из Данные Цикл
			
			Если ТекСтрока.ЗначениеВГХ>0 Тогда
				Движение = Движения.ВГХ.Добавить();
				Движение.Регистратор      = Ссылка;  
				Движение.Автор            = Автор; 
				Движение.НачалоРабот      = НачалоРабот;
				Движение.ОкончаниеРабот   = ОкончаниеРабот;
				Движение.Номенклатура     = Номенклатура;
				Движение.ВидВГХ           = ТекСтрока.ВидВГХ;
				Движение.ЗначениеВГХ      = ТекСтрока.ЗначениеВГХ;   					  
			КонецЕсли;
			
		КонецЦикла;
		
	КОнецЕсли;

	
КонецПроцедуры
