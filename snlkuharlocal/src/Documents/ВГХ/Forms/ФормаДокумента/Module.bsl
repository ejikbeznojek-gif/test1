
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьТЗДокумента();
КонецПроцедуры    


&НаСервере
Процедура ЗаполнитьТЗДокумента() 
	
	ТЗВГХ.Очистить();   
	
	Макет=Документы.ВГХ.ПолучитьМакет("МакетВГХ");
	
	Высотка = Макет.ВысотаТаблицы;
	
	для сч=1 по Высотка Цикл      
		
		Если Объект.ШтукВКоробке=0 	и Макет.Область(Сч,6).Текст= "Коробка" Тогда	
			Продолжить;
		КонецЕсли; 
		
		Если Объект.ШтукВКоробочке=0 	и Макет.Область(Сч,6).Текст= "Блочок" Тогда	
			Продолжить;
		КонецЕсли;    
		
		Если Не Объект.МаркетПлейс и Макет.Область(Сч,7).Текст= "МаркетПлейс" Тогда	
			Продолжить;
		КонецЕсли; 		
		
		новстр              = ТЗВГХ.Добавить();
		НовСтр.ВидВГХ       = Макет.Область(Сч,1).Текст;
		НовСтр.Наименование = Макет.Область(Сч,2).Текст;
		
	КонецЦикла;  
	
	
	 


КонецПроцедуры      


&НаКлиенте
Процедура ЗаполнитьТЗДокументаНаКлиенте() 
	
	Для каждого стр из Объект.Данные Цикл   
		
		Если Лев(стр.ВидВГХ,5)="Объем" Тогда
			 Этаформа[стр.ВидВГХ]= Стр.ЗначениеВГХ;
			 Продолжить;
		КОнецЕсли;

		
		Отбор = Новый Структура();
		Отбор.Вставить("ВидВГХ",стр.ВидВГХ);
		Строки = ТЗВГХ.НайтиСтроки(Отбор);
		Если Строки.Количество() > 0 Тогда
			Строки[0].ЗначениеВГХ = Стр.ЗначениеВГХ;
		КонецЕсли;
		
	КонецЦикла;	
КонецПроцедуры      



&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)  
	Объект.Данные.Очистить();
	
	Для каждого стр из ТЗВГХ Цикл
		
		Если Стр.ЗначениеВГХ<>0 Тогда
			
			НосТр = Объект.Данные.Добавить();
			ЗаполнитьЗначенияСвойств(НосТр,Стр);
			
		КонецЕсли;
	КонецЦикла;   
	
    ПересчитатьОбъемы();
	 
	
	Если Объект.ШтукВКоробке>0 Тогда
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ШтукВКоробке";
		НосТр.ЗначениеВГХ =Объект.ШтукВКоробке; 
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ОбъемШтукиРасч";
		НосТр.ЗначениеВГХ =ОбъемШтукиРасч;
		
	КонецЕсли;   
	
	
	Если Объект.ШтукВКоробочке>0 Тогда    
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ШтукВКоробочке";
		НосТр.ЗначениеВГХ =Объект.ШтукВКоробочке;  
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ОбъемБлочкаРасч";
		НосТр.ЗначениеВГХ =ОбъемБлочкаРасч;
		
	КонецЕсли;    
	
	
	Если ОбъемКоробки>0 Тогда    
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ОбъемКоробки";
		НосТр.ЗначениеВГХ =ОбъемКоробки;  
		
	КонецЕсли;   
	
	Если ОбъемБлочка>0 Тогда    
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ОбъемБлочка";
		НосТр.ЗначениеВГХ =ОбъемБлочка;  
		
	КонецЕсли;
	
	
	Если ОбъемШтуки>0 Тогда    
		
		НосТр = Объект.Данные.Добавить();
		НосТр.ВидВГХ     ="ОбъемШтуки";
		НосТр.ЗначениеВГХ =ОбъемШтуки;  
		
	КонецЕсли;      		
	
КонецПроцедуры

