&НаКлиенте
Процедура ПересчитатьОбъемы()
	
	ОбъемШтуки();	
	ОбъемБлочка();
	ОбъемКоробки(); 
	ОбъемБлочкаРасчетный();
	ОбъемШтукаРасчетный();
КонецПроцедуры



&НаКлиенте
Процедура ОбъемШтуки()
	
	Отбор = Новый Структура();
	Отбор.Вставить("ВидВГХ","ДлинаШтуки"); 
	
	СтрокиП = ТЗВГХ.НайтиСтроки(Отбор);
	Если СтрокиП.Количество() > 0 Тогда
		ДлинаШтуки =СтрокиП[0].ЗначениеВГХ; 
		
		Если ДлинаШтуки >0 Тогда
			
			Отбор = Новый Структура();
			Отбор.Вставить("ВидВГХ","ШиринаШтуки"); 
			
			СтрокиП = ТЗВГХ.НайтиСтроки(Отбор);
			Если СтрокиП.Количество() > 0 Тогда
				ШиринаШтуки =СтрокиП[0].ЗначениеВГХ; 
				
				Если ШиринаШтуки >0 Тогда
					
					Отбор = Новый Структура();
					Отбор.Вставить("ВидВГХ","ВысотаШтуки"); 
					
					СтрокиП = ТЗВГХ.НайтиСтроки(Отбор);
					Если СтрокиП.Количество() > 0 Тогда
						ВысотаШтуки =СтрокиП[0].ЗначениеВГХ; 
						
						Если ВысотаШтуки >0 Тогда
							
							ОбъемШтуки =(ШиринаШтуки*ВысотаШтуки*ДлинаШтуки)/1000000;
							
						КонецЕсли;  						
					КонецЕсли;      					
				КонецЕсли;          				
			КонецЕсли;              			
		КонецЕсли;                  		
	КонецЕсли;                      	
	
КонецПроцедуры


