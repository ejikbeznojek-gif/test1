Процедура ЗарегистрироватьКонтрагентов(сзКонтрагенты, сзКонтрагентыИнт, Отказ)
	Если ПолучитьПолномочиеПользователя("РедактированиеИнтегральныхКонтрагентов", ПараметрыСеанса.Пользователь) Тогда
		Отказ = Ложь;
		//Проставляем узлы в контрагенте и интегральном контрагенте
		спр = Контрагент.ПолучитьОбъект();
		ДобавитьУзлы(спр, УзелДляДобавления);
		УдалитьУзлы(спр, УзелДляУдаления);
		спр.Записать();
		//Катаев+ 22/01/14 Для случая если интегральных контрагентов несколько и они не объеденины папкой
		//спр =  КонтрагентИнт.ПолучитьОбъект();
		//ДобавитьУзлы(спр, УзелДляДобавления);
		//УдалитьУзлы(спр, УзелДляУдаления);
		//спр.Записать();
		Если КонтрагентИнт.Пустая() Тогда
			Для Каждого стр из сзКонтрагентыИнт Цикл
				спр =  стр.Значение.ПолучитьОбъект();
				ДобавитьУзлы(спр, УзелДляДобавления);
				УдалитьУзлы(спр, УзелДляУдаления);
				спр.Записать();
			КонецЦикла;
		Иначе
			спр =  КонтрагентИнт.ПолучитьОбъект();
			ДобавитьУзлы(спр, УзелДляДобавления);
			УдалитьУзлы(спр, УзелДляУдаления);
			спр.Записать();
		КонецЕсли;
		//Катаев- 22/01/14
		//Для группы производим запись элементов для автоматической регистрации в узлах
		Если Контрагент.ЭтоГруппа Тогда
			Для Каждого стр из  сзКонтрагенты Цикл
				спр = стр.Значение.ПолучитьОбъект();
				спр.Записать()
			КонецЦикла;
		КонецЕсли;
		Если КонтрагентИнт.ЭтоГруппа Тогда
			Для Каждого стр из  сзКонтрагентыИнт Цикл
				спр = стр.Значение.ПолучитьОбъект();
				спр.Записать();
			КонецЦикла;
		КонецЕсли;
	Иначе
		Сообщить("Отсутствует разрещение за запись интегрального контаргента. В проведении документа отказано. Обратитесь в ТП");
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

