Процедура ОбработкаПроведения(Отказ, РежимПроведения)Экспорт
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	Если ПланыОбмена.Основной.ЭтотУзел().Код = "SNL" Тогда
		сзКонтрагенты = ПолучитьКонтрагентов(Контрагент);
		Если КонтрагентИнт.Пустая() Тогда
			сзКонтрагентыИнт = ПолучитьИнтКонтрагентов(Контрагент);
		Иначе
			сзКонтрагентыИнт = ПолучитьКонтрагентов(КонтрагентИнт);
		КонецЕсли;
		ТипЦен = ПолучитьТипы(сзКонтрагенты);
		ЗарегистрироватьКонтрагентов(сзКонтрагенты, сзКонтрагентыИнт, Отказ);
		Если Не Отказ Тогда
			сзПрайс = ПолучитьПрайсы(ТипЦен);
			сзМатрицы = ПолучитьМатрицы(сзКонтрагенты);
			сзАртикулы = ПолучитьАртикулы(сзКонтрагенты);
			сзШК = ПолучитьШК(сзКонтрагенты);
			//Регистрация Матрицы
			Для Каждого стр из сзМатрицы Цикл
				Объект = стр.Значение.ПолучитьОбъект();
				тзПодр = Объект.Подразделения.Выгрузить();
				ДанныеИзменены = Ложь;
				Для Каждого узел из УзелДляДобавления Цикл
					УзелОбмена = ПланыОбмена.Основной.НайтиПоКоду(Узел.КодУзла);
					Если тзПодр.Найти(УзелОбмена,"Подразделение") = Неопределено Тогда
						стр = тзПодр.Добавить();
						стр.Подразделение = УзелОбмена;
						ДанныеИзменены = Истина;
					КонецЕсли;
				КонецЦикла;
				Если ДанныеИзменены Тогда
					Объект.Подразделения.Загрузить(тзПодр);
					Объект.Записать();
				КонецЕсли;
			КонецЦикла;
			Для Каждого узел из УзелДляДобавления Цикл
				УзелОбмена = ПланыОбмена.Основной.НайтиПоКоду(Узел.КодУзла);
				//Регистрация Прайса
				Для Каждого стр из сзПрайс Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, стр.Значение);
					//Катаев+ 23/04/14 Регистрируем еще и регистр сведений по прайсу
					Набор=РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
					Набор.Отбор.Прайс.Установить(стр.Значение);
					Набор.Прочитать();
					тзНабор = Набор.Выгрузить();
					Для Каждого Запись Из тзНабор Цикл
						Набор.Отбор.Прайс.установить(Запись.Прайс);
						Набор.Отбор.Прайс.Использование=Истина;
						Набор.Отбор.ТипЦен.установить(Запись.ТипЦен);
						Набор.Отбор.ТипЦен.Использование=Истина;
						Набор.Отбор.Номенклатура.установить(Запись.Номенклатура);
						Набор.Отбор.Номенклатура.Использование=Истина;
						Набор.Отбор.Период.Установить(Запись.Период);
						Набор.Отбор.Период.Использование=Истина;
						Набор.Прочитать();
						Набор.ОбменДанными.Получатели.Добавить(УзелОбмена);			  
						ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, Набор);
					КонецЦикла;	
					//Катаев- 23/04/14
				КонецЦикла;
				//Регистрация Артикула
				Для Каждого стр из сзАртикулы Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, стр.Значение);
				КонецЦикла;
				//Регистрация ШК
				Для Каждого стр из сзШК Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, стр.Значение);
				КонецЦикла;
				//Регистрация Типа цен
				тз = УзелОбмена.ТипыЦен.Выгрузить();
				ОбъектУзла = УзелОбмена.ПолучитьОбъект();
				ДанныеИзменены = Ложь;
				Для Каждого стр из ТипЦен Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, стр.Значение);
					Если тз.Найти(стр.Значение, "ТипЦен") = Неопределено Тогда
						стрТипЦен = тз.Добавить();
						стрТипЦен.ТипЦен = стр.Значение;
						ДанныеИзменены = Истина;
					КонецЕсли;
				КонецЦикла;
				Если ДанныеИзменены Тогда
					ОбъектУзла.ТипыЦен.Загрузить(тз);
					ОбъектУзла.Записать();
				КонецЕсли;
				//катаев+ 31/12/14 Добавил регистрацию этого файла в узле
				ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, ЭтотОбъект.Ссылка);
				//Катаев- 31/12/13
			КонецЦикла;
			ЗарегистрироватьВзаиморасчеты(сзКонтрагентыИнт);
		КонецЕсли;
	Иначе
		СоздатьДокумент = Ложь;
		Запрос = Новый Запрос;
		//Катаев+ 25/08/14
		//Запрос.Текст =
		//"ВЫБРАТЬ
		//|	ВзаиморасчетыОстатки.Договор,
		//|	ВзаиморасчетыОстатки.СуммаУпрОстаток КАК СуммаУпрФилиал,
		//|	ВзаиморасчетыОстатки.Контрагент
		//|ИЗ
		//|	РегистрНакопления.Взаиморасчеты.Остатки(&Дата, Контрагент В ИЕРАРХИИ (&Контрагент)) КАК ВзаиморасчетыОстатки";
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВзаиморасчетыОстатки.Договор,
		|	ВзаиморасчетыОстатки.СуммаУпрОстаток КАК СуммаУпрФилиал,
		|	ВзаиморасчетыОстатки.Контрагент
		|ИЗ
		|	РегистрНакопления.Взаиморасчеты.Остатки(
		|			&Дата,
		|			Контрагент В ИЕРАРХИИ (&Контрагент)
		//крохин начало 11.09.2018
		//измерения удалены
		//|				И ДокументЗакрытогоПериода = """"
		//крохин конец 11.09.2018
		|) КАК ВзаиморасчетыОстатки";
		//Катаев- 25/08/14
