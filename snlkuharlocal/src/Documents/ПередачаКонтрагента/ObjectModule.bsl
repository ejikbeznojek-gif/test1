Процедура УдалитьУзлы(спр, УзелДляУдаления)
	тз = спр.РегиональныеУзлы.Выгрузить();
	Для Каждого узел из УзелДляУдаления Цикл
		стр = тз.Найти(узел.КодУзла, "КодУзла");
		Если стр <> Неопределено Тогда
			тз.Удалить(стр);
		КонецЕсли;
	КонецЦикла;
	спр.РегиональныеУзлы.Очистить();
	спр.РегиональныеУзлы.Загрузить(тз);
	спр.Записать();
Конецпроцедуры

Процедура ДобавитьУзлы(спр, УзелДляДобавления)
	тз = спр.РегиональныеУзлы.Выгрузить();
	Для Каждого узел из УзелДляДобавления Цикл
		стр = тз.Найти(узел.КодУзла, "КодУзла");
		Если стр = Неопределено Тогда
			стр = тз.Добавить();
			стр.КодУзла = узел.КодУзла;
		КонецЕсли;
	КонецЦикла;
	спр.РегиональныеУзлы.Очистить();
	спр.РегиональныеУзлы.Загрузить(тз);
	спр.Записать();
Конецпроцедуры
