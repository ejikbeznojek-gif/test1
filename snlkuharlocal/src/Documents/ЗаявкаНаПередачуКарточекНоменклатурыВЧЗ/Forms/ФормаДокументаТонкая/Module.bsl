&НаКлиенте
Процедура ТоварыГТИНПриИзменении(Элемент)
	ТекСтрока = Элементы.Товары.ТекущиеДанные; 
	НоменклатураОб = ТекСтрока.Номенклатура.ПолучитьОбъект();
	Если Не ЗначениеЗаполнено(НоменклатураОб.ГТИН) И ЗначениеЗаполнено(ТекСтрока.ГТИН) Тогда
		НоменклатураОб.ГТИН = СокрЛП(ТекСтрока.ГТИН); 
		НоменклатураОб.Записать();
	КонецЕсли;	
КонецПроцедуры 
