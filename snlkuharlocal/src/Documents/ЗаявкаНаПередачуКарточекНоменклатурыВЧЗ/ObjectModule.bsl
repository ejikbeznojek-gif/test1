#Область СобытияДокумента


Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	
	Если Модифицированность() Тогда	
		ГруппыТоваров 		= ГруппыТоваровДокумента(ЭтотОбъект);		
		КоличествоДокумента = Товары.Количество();
	КонецЕсли;	
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс)+"-";	
	КонецЕсли; 
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Автор	= ПараметрыСеанса.Пользователь;
	Статус	= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
	ИД_ДокументаЧЗ = Неопределено;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)	
	Если Товары.Количество() = 0 Тогда Возврат КонецЕсли;
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	рПроверки = Документы.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.ПроверитьДублиКарточек(Ссылка);
	Если НЕ рПроверки.Успешно Тогда
		Отказ = Истина;
		МаркировкаКС.ВывестиОшибки(рПроверки);
	КонецЕсли; 
	
	КодыГТИН = Новый Соответствие;
	
	НЗ = Движения.СтатусыНоменклатуры_ЧЗ;
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Статус) Тогда Продолжить КонецЕсли;
		
		Запись = НЗ.Добавить();			
		Запись.Период		= Дата;
		
		Запись.Организация	= Организация;
		Запись.Номенклатура = СтрокаТЧ.Номенклатура;
		
		Запись.Статус		= СтрокаТЧ.Статус;		
	КонецЦикла;	
	
	Снять_ЭтоКодGS1();
	Записать_ЭтоКодGS1();
КонецПроцедуры


#КонецОбласти 


Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	ЗаполнитьШапкуДокумента(ЭтотОбъект, ПараметрыСеанса.Пользователь);
	
	Статус  			= Перечисления.СтатусыДокументовМаркировки.ВРаботе;	
	
	ТипОснования 		= ТипЗнч(ДанныеЗаполнения);	
	ДокументОснование	= ДанныеЗаполнения;
	
	Если ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		Организация	= ДанныеЗаполнения.Организация;
		ЗаполнитьПоТоварамОснования();
		
	ИначеЕсли ТипОснования = Тип("СправочникСсылка.Номенклатура") Тогда
		
		ЗаполнитьПоТоварамМодели(ДанныеЗаполнения);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоТоварамОснования(ИмяТЧ = "Товары")
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура,
	|	Номенклатура.ГТИН КАК ГТИН
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеСоздана)			
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);	
	
	Товары.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла; 	

КонецПроцедуры

Процедура ЗаполнитьПоТоварамМодели(Модель)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка 		КАК Номенклатура,
	|	Ссылка.ГТИН КАК ГТИН
	|ИЗ
	|	Справочник.Номенклатура
	|ГДЕ
	|	Ссылка В ИЕРАРХИИ (&Модель)
	|	И НЕ ЭтоГруппа
	//|	И НЕ СнятСПроизводства	
	|	И СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеСоздана)			
	|УПОРЯДОЧИТЬ ПО
	|	Родитель.Наименование,
	|	Наименование
	|";
	
	Запрос.УстановитьПараметр("Модель", Модель);	
	
	Товары.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЧ = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла; 	

КонецПроцедуры //ЗаполнитьПоТоварамМодели(Модель)

Процедура Снять_ЭтоКодGS1()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура 						КАК Номенклатура,	
	|	ШтрихКоды.Ссылка							КАК ШтрихКод
	|ИЗ
	|	Документ.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.Товары КАК Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ПО
	|	ШтрихКоды.Владелец 	= Товары.Номенклатура
	|ГДЕ	
	|	Товары.Ссылка = &Ссылка	
	|	И ШтрихКоды.ЭтоКодGS1 = Истина
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ШК_Объект = Выборка.ШтрихКод.ПолучитьОбъект();
		ШК_Объект.ЭтоКодGS1 = Ложь;
		
		ШК_Объект.Записать();
	КонецЦикла; 
КонецПроцедуры	
	
Процедура Записать_ЭтоКодGS1()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура 						КАК Номенклатура,
	|	ПОДСТРОКА(Товары.Номенклатура.ГТИН,2,13)	КАК ГТИН,
	|	ШтрихКоды.Ссылка							КАК ШтрихКод
	|ИЗ
	|	Документ.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.Товары КАК Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ПО
	|	ШтрихКоды.Владелец 			= Товары.Номенклатура
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.ТипШК 			= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)	
	|	И ШтрихКоды.Наименование	= ПОДСТРОКА(Товары.Номенклатура.ГТИН,2,13)
	|ГДЕ	
	|	Товары.Ссылка = &Ссылка	
	|	И ( 
	|		Товары.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НаМодерации) 
	|		ИЛИ Товары.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована) 
	|	)	
	|	И Товары.Номенклатура.ГТИН <> """"
	|	И (ШтрихКоды.ВерсияДанных ЕСТЬ NULL ИЛИ НЕ ШтрихКоды.ЭтоКодGS1 = Истина)
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ШтрихКод) Тогда
			ШК_Объект = Выборка.ШтрихКод.ПолучитьОбъект();
		Иначе
			ШК_Объект = Справочники.ШтрихКоды.СоздатьЭлемент();			
		
			ШК_Объект.Владелец 		= Выборка.Номенклатура;
			ШК_Объект.Наименование  = Выборка.ГТИН;
			ШК_Объект.ТипШК			= Перечисления.ТипыШтрихКодов.Штука;
			ШК_Объект.ВидШК			= Перечисления.ВидыШК.Дополнительный;		
			ШК_Объект.ФорматШК		= Перечисления.ФорматыШК.EAN13;
		КонецЕсли; 
		
		ШК_Объект.ЭтоКодGS1		= Истина;		
		ШК_Объект.Записать();
	КонецЦикла;
КонецПроцедуры

