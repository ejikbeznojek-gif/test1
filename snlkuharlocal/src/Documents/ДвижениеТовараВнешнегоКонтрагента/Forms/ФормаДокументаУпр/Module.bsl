		Сообщить("Необходимо записать документ!");
		Возврат;
	КонецЕсли;
	СозданныеРНК = Новый Массив; 
	СоздатьРНКНаСервере(СозданныеРНК);
	Если СозданныеРНК.Количество() > 0  Тогда
		
		Для каждого РНКСозданное Из СозданныеРНК Цикл
			
			ОткрытьЗначение(РНКСозданное); 
			
