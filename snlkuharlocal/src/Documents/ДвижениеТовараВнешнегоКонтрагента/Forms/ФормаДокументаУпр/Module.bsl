//Данилова Е.В. 17.06.2026 0000000008 изм. процедуры на функцию
&НаСервере
//Процедура ПолучитьОстаткиНаСервере(СписокНоменклатуры,Склад,МасивНакладных,ФлагФизСклад = Ложь,МассивДополнительныхСкладов=Неопределено)
Функция ПолучитьОстаткиНаСервере(СписокНоменклатуры,Склад,МасивНакладных,ФлагФизСклад = Ложь,МассивДополнительныхСкладов=Неопределено)
	//++Данилова Е.В. 17.06.2026 №0000000008
	КэшОстатков = Новый Соответствие; 
	
	//Если СписокНоменклатуры.ВГраница()<0 Тогда Возврат КонецЕсли; 
	//Если НЕ ЗначениеЗаполнено(Склад) Тогда Возврат КонецЕсли; 
	
	Если СписокНоменклатуры.ВГраница()<0 Тогда
		Возврат КэшОстатков 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда 
		Возврат КэшОстатков 
	КонецЕсли;
	
	//--Данилова Е.В. 17.06.2026
	МассивСкладов = Новый Массив();
	 
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Сводный.Номенклатура.Код77 КАК Код77,
	|	Сводный.Номенклатура КАК Номенклатура,
	|	СУММА(Сводный.Остаток) КАК Остаток,
	|	СУММА(Сводный.Резерв) КАК Резерв,
	|	СУММА(Сводный.ВиртуальныйРезерв) КАК ВиртуальныйРезерв
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Остатки.Номенклатура, Резервы.Номенклатура) КАК Номенклатура,
	|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	|		0 КАК ВиртуальныйРезерв
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В (&СписокНоменклатуры)) КАК Остатки
	|			ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В (&СписокНоменклатуры)) КАК Резервы
	|			ПО Остатки.Номенклатура = Резервы.Номенклатура
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ОстаткиТМЦ.Номенклатура,
	|		ОстаткиТМЦ.Количество,
	|		0,
	|		0
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|	ГДЕ
	|		ОстаткиТМЦ.Регистратор в (&Регистратор)
	|		И ОстаткиТМЦ.Склад В(&МассивСкладов)
	|		И ОстаткиТМЦ.ВидДвижения = &Расход
	|		И ОстаткиТМЦ.Номенклатура В(&СписокНоменклатуры)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыТМЦ.Номенклатура,
	|		0,
	|		-РезервыТМЦ.Количество,
	|		0
	|	ИЗ
	|		РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|	ГДЕ
	|		РезервыТМЦ.Регистратор В (&Регистратор)
	|		И РезервыТМЦ.Склад В(&МассивСкладов)
	|		И РезервыТМЦ.Номенклатура В(&СписокНоменклатуры)) КАК Сводный
	|
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Номенклатура,
	|	Сводный.Номенклатура.Код77
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сводный.Номенклатура";
	
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);	
	Запрос.УстановитьПараметр("Регистратор",МасивНакладных);
	Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
	
	
	Если НЕ Склад.ФизическийСклад.Пустая() И ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение и склад.ВидСклада<>Перечисления.ВидСклада.ВиртуальныйДляСклада Тогда
		
		МассивСкладов.Добавить(Склад.ФизическийСклад);				
	Иначе
		МассивСкладов.Добавить(Склад);				
	КонецЕсли;
	
	
	если МассивДополнительныхСкладов<>Неопределено тогда
		для каждого СтрМасс из МассивДополнительныхСкладов цикл
			МассивСкладов.Добавить(СтрМасс);
		КонецЦикла;
	КонецЕсли;	
	
	Если ФлагФизСклад И НЕ Склад.ФизическийСклад.Пустая() Тогда
		МассивСкладов.Добавить(Склад.ФизическийСклад);
