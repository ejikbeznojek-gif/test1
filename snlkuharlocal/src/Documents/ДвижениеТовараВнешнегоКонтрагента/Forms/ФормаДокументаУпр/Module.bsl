//   <Тип.Вид>   - <описание возвращаемого значения>
//
&НаСервере
Функция МассивТоваровДокумента()

	Возврат Объект.Товары.Выгрузить(,"Номенклатура").ВыгрузитьКолонку("Номенклатура"); 

КонецФункции // МассивТоваровДокумента()


// <Описание функции>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
&НаСервереБезКонтекста
Функция ПолучитьРеквизитыТоваров(Знач МассивТоваров)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Номенклатура,
		|	Номенклатура.ЭтоГруппа КАК ЭтоГруппа,
		|	Номенклатура.Родитель КАК Модель,
		|	Номенклатура.Родитель.КолКоробовВПаллете КАК КолКоробовВПаллете,
		|	Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
		|	Номенклатура.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
		|	Номенклатура.Родитель.Коллекция КАК Коллекция,
		|	Номенклатура.ГТИН КАК ГТИН,
		|	Номенклатура.КатегорияМаркетПлейсы КАК КатегорияМаркетПлейсы
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&МассивТоваров)";
	
	Запрос.УстановитьПараметр("МассивТоваров", МассивТоваров);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	СоответствиеТоварыРеквизиты = Новый Соответствие; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Структура = ВернутьСтруктуруРеквизитыТоваров(); 
		ЗаполнитьЗначенияСвойств(Структура,ВыборкаДетальныеЗаписи); 
		СоответствиеТоварыРеквизиты.Вставить(ВыборкаДетальныеЗаписи.Номенклатура,Структура); 
		
	КонецЦикла; 
    Возврат СоответствиеТоварыРеквизиты; 
КонецФункции // ПолучитьРеквизитыТоваров() 

