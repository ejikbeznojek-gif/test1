Процедура ПослеВыбораМатрицыВСтроке(ВыбранноеЗначение,ДопПараметры) Экспорт
	Если ВыбранноеЗначение = неопределено  Тогда
		Возврат; 
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.Матрица") Тогда
	
		СтрокаПоИдентификатору = Объект.Товары.НайтиПоИдентификатору(ДопПараметры);
		СтрокаПоИдентификатору.НоменклатурнаяМатрица =  ВыбранноеЗначение; 
		
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокМатрицПоТовару(ПараметрыМатрицы)
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Номенклатура", ПараметрыМатрицы.Номенклатура);
	Запрос.УстановитьПараметр("Контрагент",ПараметрыМатрицы.Контрагент);
	Запрос.УстановитьПараметр("Договор",ПараметрыМатрицы.Договор);
	Запрос.УстановитьПараметр("ПунктДоставки",ПараметрыМатрицы.ПунктДоставки);
	Запрос.УстановитьПараметр("Дата",ПараметрыМатрицы.Дата);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МатрицаТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Номенклатура = &Номенклатура
	|	И МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Дата <= &Дата
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|
	|УПОРЯДОЧИТЬ ПО
	|	МатрицаТовары.Ссылка.Дата
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	СписокСсылок = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СписокСсылок.Добавить(Выборка.Ссылка);
	КонецЦикла;
	Возврат СписокСсылок; 
КонецФункции
&НаКлиенте
Функция ПолучитьНастройкиКомпоновкиДляРНКВПути()
	
	НастройкиКомпоновки = Новый НастройкиКомпоновкиДанных;
	Склад = ПолучитьСкладФБО(); 
    
	ГруппаОтбора = НастройкиКомпоновки.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Склад");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = Склад;

	ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Контрагент");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = Объект.Контрагент;
	
	Возврат НастройкиКомпоновки; 
КонецФункции
