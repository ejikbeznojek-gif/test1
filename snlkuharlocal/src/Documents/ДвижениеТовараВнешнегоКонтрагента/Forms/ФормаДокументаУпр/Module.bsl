&НаКлиенте
Процедура ТоварыКоробокНаПаллетеПриИзмененииНаКлиенте()
	//Текущиеданные = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки); 
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	ВремСтрока = СтрочкиИзменённыеРуками.НайтиСтроки(Новый Структура("Номенклатура",ТекущиеДанные.Номенклатура));
	если ВремСтрока.Количество() = 0 тогда 
		НоваяСтрока = СтрочкиИзменённыеРуками.добавить();
		НоваяСтрока.Номенклатура = ТекущиеДанные.Номенклатура;
		новаяСтрока.КратностьПаллеты = ТекущиеДанные.КоробокНаПаллете; 
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКОтгрузкеПриИзмененииНаКлиенте(Текущиеданные,СоответствиеРеквизитыТоваров)
	если Текущиеданные.КОтгрузке>0 тогда
		ШтукВКоробе = СоответствиеРеквизитыТоваров.Получить(Текущиеданные.Номенклатура).ШтукВКоробке;
		если ШтукВКоробе>0 тогда
			Текущиеданные.КоробокКОтгрузке = Текущиеданные.КОтгрузке/ШтукВКоробе;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоробокКОтгрузкеПриИзмененииНаКлиенте(Текущиеданные,СоответствиеРеквизитыТоваров)
	 
	КратностьКоробки = СоответствиеРеквизитыТоваров.Получить(Текущиеданные.номенклатура).ШтукВКоробке;
	если КратностьКоробки=0 тогда
		КратностьКоробки=1;
	КонецЕсли;
	Текущиеданные.КОтгрузке =   Текущиеданные.коробокКОтгрузке * КратностьКоробки;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПаллетКОтгрузкеПриИзмененииНаКлиенте(ТекСтрока)
	НовоеЗначениеПаллет=ТекСтрока.ПаллетКОтгрузке;
	если ВыводитьДанныеМатриц тогда
		СтрокаМатрицы=ТЗМатриц.найти(ТекСтрока.Номенклатура);
		если СтрокаМатрицы<>Неопределено тогда
			если ТекСтрока.СпособПоставки=ПредопределенноеЗначение("Перечисление.СпособПоставкиКонтрагенту.МоноПаллета") тогда
				КратностьПаллеты = СтрокаМатрицы.КратностьПаллеты;
				если КратностьПаллеты>0 тогда
					ТекСтрока.КОтгрузке=КратностьПаллеты*НовоеЗначениеПаллет; 
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	

КонецПроцедуры

