//	ОформитьСтрокиДобавитьОстатки(СоответствиеРеквизитыТоваров,ДваСклада,ПерезаполнитьВсе,СтрокаТоваров); 
//КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриИзмененииНаКлиенте(ПерезаполнитьВсе = истина,СтрокаТоваров = неопределено)
	Если ТипЗнч(ТЗМатриц) <> Тип("ТаблицаЗначений") и ВыводитьДанныеМатриц тогда
		ЗаполнитьТаблицуПечатиПоМатрице();
	КонецЕсли;
	Если ПерезаполнитьВсе Тогда
		
		МассивТоваров = МассивТоваровДокумента(); 
		СоответствиеРеквизитыТоваров = ПолучитьРеквизитыТоваров(МассивТоваров); 
		Для Каждого СтрокаТовара Из Объект.Товары Цикл

			Если Не ЗначениеЗаполнено(СтрокаТовара.Номенклатура) Тогда

				Продолжить;

			КонецЕсли;
			СтрокаТоваровПриИзмененииНаКлиенте(СтрокаТовара,СоответствиеРеквизитыТоваров);
		КонецЦикла;
	ИначеЕсли  СтрокаТоваров <> неопределено  Тогда 
		ТекущиеДанные = Объект.Товары.НайтиПоИдентификатору(СтрокаТоваров);
		Если ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
			СоответствиеРеквизитыТоваров = ПолучитьРеквизитыТоваров(ТекущиеДанные.Номенклатура);
			СтрокаТоваровПриИзмененииНаКлиенте(ТекущиеДанные,СоответствиеРеквизитыТоваров);
		КонецЕсли;
	КонецЕсли;
	
	ОформитьСтрокиДобавитьОстаткиНаКлиенте(СоответствиеРеквизитыТоваров,ДваСклада,ПерезаполнитьВсе,СтрокаТоваров); 
КонецПроцедуры

&НаКлиенте
Процедура СтрокаТоваровПриИзмененииНаКлиенте(СтрокаТовара,СоответствиеРеквизитыТоваров)
	
	//МодельНоменклатуры = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(СтрокаТовара.Номенклатура, "Родитель");
	МодельНоменклатуры = СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).Модель; 
	ВремСтрока = СтрочкиИзменённыеРуками.НайтиСтроки(Новый Структура("Номенклатура", СтрокаТовара.Номенклатура));

	Если ВремСтрока.Количество() = 0 Или Не ЗначениеЗаполнено(ВремСтрока[0].КратностьПаллеты) Тогда
		КратностьПаллеты = СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).КолКоробовВПаллете;
	Иначе
		КратностьПаллеты = ВремСтрока[0].КратностьПаллеты;
	КонецЕсли;

	СтрокаТовара.КоробокНаПаллете = КратностьПаллеты;

	Отгружается = СтрокаТовара.КОтгрузке;
	//ШтукВКоробке = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(МодельНоменклатуры, "ШтукВКоробке");
	//ШтукВКоробочке = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(МодельНоменклатуры, "ШтукВКоробочке");
    ШтукВКоробке 	=  СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).ШтукВКоробке; 
	ШтукВКоробочке 	=  СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).ШтукВКоробочке; 
	
	КоличествоКоробок = Окр(?(ШтукВКоробке > 0, Отгружается / ШтукВКоробке, 0), 2);
	КоличествоБлочков = Окр(?(ШтукВКоробочке > 0, Отгружается / ШтукВКоробочке, 0), 2);

	СтрокаТовара.КратностьБлочка 	= ШтукВКоробочке;
	СтрокаТовара.КоличествоБлочков  = КоличествоБлочков;
	СтрокаТовара.ПаллетКОтгрузке 	= Окр(?(КратностьПаллеты > 0, КоличествоКоробок / КратностьПаллеты, 0), 2);

	Номенклатура = СтрокаТовара.Номенклатура;
	Если ВыводитьДанныеМатриц Тогда

		СтрокаМатрицы = ТЗМатриц.Найти(Номенклатура);
		Если СтрокаМатрицы <> Неопределено Тогда
			СтрокаТовара.КратностьПаллетыИзМатрицы  = СтрокаМатрицы.КратностьПаллеты;

			СтрокаТовара.ПаллетКОтгрузке = Окр(?(СтрокаМатрицы.КратностьПаллеты > 0, Отгружается
				/ СтрокаМатрицы.КратностьПаллеты, 0), 2);		
							
			//++Данилова Е.В. 17.06.2026 №0000000008
			СтрокаТовара.КодПроизводителя = СокрЛП(СтрокаМатрицы.КодПроизводителяКонтрагента); 
			//--Данилова Е.В. 17.06.2026 
			Если СтрокаТовара.СпособПоставки = ПредопределенноеЗначение("Перечисление.СпособПоставкиКонтрагенту.МоноПаллета") Тогда
				КратностьПаллеты = СтрокаМатрицы.КратностьПаллеты;
				Если КратностьПаллеты > 0 Тогда
					СтрокаТовара.ПаллетКОтгрузке = Окр(СтрокаТовара.КОтгрузке / КратностьПаллеты, 2);
				КонецЕсли;
			КонецЕсли;

			СтрокаТовара.ПорядокУчастияВАкции = СтрокаМатрицы.ПорядокУчастияВАкции;

			СтрокаТовара.НаименованиеКонтрагента = СокрЛП(СтрокаМатрицы.НаименованиеКонтрагента);
		КонецЕсли;
	КонецЕсли;
	Если СтрокаТовара.КоличествоПлан <> 0 Тогда 
		СтрокаТовара.КоличествоПланМакс =  СтрокаТовара.Количество/СтрокаТовара.КоличествоПлан;
	Конецесли;
	Если  СтрокаТовара.НедостающееКоличество <> 0 Тогда 
		СтрокаТовара.КОтгрузкеСоотношение = СтрокаТовара.КОтгрузке/СтрокаТовара.НедостающееКоличество;
	КонецЕсли;
	//СтрокаТовара.Коллекция = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(МодельНоменклатуры, "Коллекция"); 
	СтрокаТовара.Коллекция 		=  СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).Коллекция;
	СтрокаТовара.ГТИН 			= СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).ГТИН; 
	СтрокаТовара.КатегорияМП 	=  СоответствиеРеквизитыТоваров.Получить(СтрокаТовара.Номенклатура).КатегорияМаркетПлейсы;
	///////////////////присвоение цвета
	
	УстановкаЦветаПоСтроке(СтрокаТовара);

КонецПроцедуры

&НаКлиенте
Процедура УстановкаЦветаПоСтроке(Знач СтрокаТовара)
	
	Если СтрокаТовара.НедостающееКоличество > 0 И СтрокаТовара.КОтгрузке > 0 И СтрокаТовара.КОтгрузкеСоотношение > 1.5 Тогда 
		СтрокаТовара.Цвет = "Светло-желтый"; 
	ИначеЕсли СтрокаТовара.ОстатокКонтрагента = 0 И СтрокаТовара.Количество = 0 Тогда 
		СтрокаТовара.Цвет = "Коралловый";
	ИначеЕсли  СтрокаТовара.КоличествоПланМакс > 1.2 И СтрокаТовара.КоличествоПлан > 0  Тогда 
		СтрокаТовара.Цвет = "Персиковый"; 
	//ИначеЕсли  СтрокаТовара.НеХватаетОстатка Тогда 
	//	СтрокаТовара.Цвет = "Желтый"; 
	ИначеЕсли СтрокаТовара.ВыделятьВДокументах Тогда 	
		СтрокаТовара.Цвет = "Хаки";  
	Иначе 
		СтрокаТовара.Цвет = "Без цвета"; 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОформитьСтрокиДобавитьОстаткиНаКлиенте(СоответствиеРеквизитыТоваров, ВДваСклада = Ложь,ПерезаполнитьВсе = Ложь,СтрокаТоваров = неопределено)
	
	Если НЕ ВДваСклада Тогда 
		Возврат; 
	КонецЕсли;
	
	//++Данилова Е.В. 17.06.2026 №0000000008
	Если КэшОстатковСДвухСкладов = неопределено Тогда 
		КэшОстатковСДвухСкладов = Новый Структура("КэшОстатков",Новый Соответствие);
	КонецЕсли;
	//--Данилова Е.В. 17.06.2026
	СписокНоменклатурыСДвухСкладов = Новый Массив;
	Если ПерезаполнитьВсе Тогда
		Для Каждого СтрокаТовара Из Объект.Товары Цикл
			Номенклатура = СтрокаТовара.Номенклатура;
            ЭтоГруппа = СоответствиеРеквизитыТоваров.Получить(Номенклатура).ЭтоГруппа; 
			Если ЭтоГруппа Тогда 
				Продолжить;
			КонецЕсли
			;

			Если КэшОстатковСДвухСкладов.КэшОстатков.Получить(Номенклатура) = Неопределено Тогда
				СписокНоменклатурыСДвухСкладов.Добавить(Номенклатура);
			КонецЕсли;
            
		КонецЦикла;
	ИначеЕсли СтрокаТоваров <> неопределено Тогда  
		ТекущиеДанные = Объект.Товары.НайтиПоИдентификатору(СтрокаТоваров);
		Если ТекущиеДанные = Неопределено ИЛИ НЕ ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
			Возврат; 
		КонецЕсли;
		
		Номенклатура = ТекущиеДанные.Номенклатура;
        ЭтоГруппа = СоответствиеРеквизитыТоваров.Получить(Номенклатура).ЭтоГруппа;
		//Если ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(Номенклатура,"ЭтоГруппа") Тогда
		Если ЭтоГруппа Тогда 
			Возврат; 
		КонецЕсли;

		Если КэшОстатковСДвухСкладов.КэшОстатков.Получить(Номенклатура) = Неопределено Тогда
			СписокНоменклатурыСДвухСкладов.Добавить(Номенклатура);
		КонецЕсли;
	КонецЕсли;
	
	#Область Склады
	//++Данилова Е.В. 17.06.2026 №0000000008
	Если СписокНоменклатурыСДвухСкладов.Количество() > 0 Тогда  	
		МассивСкладов = Неопределено;
		СкладДоп = Неопределено;
		МассивСкладовДляРасчетаОстатков(МассивСкладов, СкладДоп);
		//++Данилова Е.В. 17.06.2026 №0000000008
		//ПолучитьОстаткиНаСервере(СписокНоменклатурыСДвухСкладов, СкладДоп, Объект.ссылка, КэшОстатковСДвухСкладов, Ложь,
		//	МассивСкладов);
		ДанныеПоОстаткам = ПолучитьОстаткиНаСервере(СписокНоменклатурыСДвухСкладов, СкладДоп, Объект.ссылка, Ложь,
		МассивСкладов);
		Для каждого ЭлСоответствия  Из ДанныеПоОстаткам Цикл
			
			КэшОстатковСДвухСкладов.КэшОстатков.Вставить(ЭлСоответствия.Ключ,ЭлСоответствия.Значение); 		
			
		КонецЦикла;  
		
	КонецЕсли;
	//--Данилова Е.В. 17.06.2026
	#КонецОбласти	
	
	Если ПерезаполнитьВсе Тогда
		Для Каждого СтрокаТовара Из Объект.Товары Цикл
			
			СтрокаКэшаСДвухСкладов = КэшОстатковСДвухСкладов.КэшОстатков.Получить(СтрокаТовара.Номенклатура);

			СвободныйОстатокСДвухСкладов = ?(СтрокаКэшаСДвухСкладов <> Неопределено,
				СтрокаКэшаСДвухСкладов.СвободныйОстаток, 0);
			СтрокаТовара.ОстФизСкл = СвободныйОстатокСДвухСкладов;
			СтрокаТовара.НеХватаетОстатка = СвободныйОстатокСДвухСкладов < СтрокаТовара.Количество;

			УстановкаЦветаПоСтроке(СтрокаТовара);

		КонецЦикла;
	ИначеЕсли СтрокаТовара <> неопределено Тогда 
		ТекущиеДанные = Объект.Товары.НайтиПоИдентификатору(СтрокаТоваров);
		СтрокаКэшаСДвухСкладов = КэшОстатковСДвухСкладов.КэшОстатков.Получить(ТекущиеДанные.Номенклатура);

		СвободныйОстатокСДвухСкладов = ?(СтрокаКэшаСДвухСкладов <> Неопределено,
			СтрокаКэшаСДвухСкладов.СвободныйОстаток, 0);
		ТекущиеДанные.ОстФизСкл = СвободныйОстатокСДвухСкладов;
		ТекущиеДанные.НеХватаетОстатка = СвободныйОстатокСДвухСкладов < ТекущиеДанные.Количество;
		УстановкаЦветаПоСтроке(ТекущиеДанные);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура МассивСкладовДляРасчетаОстатков(МассивСкладов, СкладДоп)
	
	Перем МаркировкаСкладЧасцыFBS, МаркировкаСкладЧасцыДИП, МаркировкаСкладЧасцыДОП, МаркировкаСкладЧасцыНекорректныеМарки, МаркировкаСкладЧасцыОсновной, СкладОсновной, СкладФБС;
	
	СкладДоп = Справочники.склады.НайтиПоКоду("STC-60");
	СкладФБС = Справочники.Склады.НайтиПоКоду("STD-13"); 
	СкладОсновной = Справочники.Склады.НайтиПоКоду("STA-48");
	
	
	МаркировкаСкладЧасцыFBS = Справочники.Склады.НайтиПоКоду("STЕ-03");
	МаркировкаСкладЧасцыДОП = Справочники.Склады.НайтиПоКоду("STD-99");
	
	МаркировкаСкладЧасцыДИП = Справочники.Склады.НайтиПоКоду("STЕ-49");
	
	МаркировкаСкладЧасцыНекорректныеМарки = Справочники.Склады.НайтиПоКоду("STЕ-15");
	МаркировкаСкладЧасцыОсновной = Справочники.Склады.НайтиПоКоду("STD-95"); 
	
	
	МассивСкладов = Новый Массив;
	
	МассивСкладов.Добавить(СкладДоп);
	МассивСкладов.Добавить(СкладОсновной);
	МассивСкладов.Добавить(СкладФБС);
	
	МассивСкладов.Добавить(МаркировкаСкладЧасцыFBS);
	МассивСкладов.Добавить(МаркировкаСкладЧасцыДОП);
	
	МассивСкладов.Добавить(МаркировкаСкладЧасцыДИП);
	
	МассивСкладов.Добавить(МаркировкаСкладЧасцыНекорректныеМарки);
	МассивСкладов.Добавить(МаркировкаСкладЧасцыОсновной);
	
КонецПроцедуры



// <Описание функции>
