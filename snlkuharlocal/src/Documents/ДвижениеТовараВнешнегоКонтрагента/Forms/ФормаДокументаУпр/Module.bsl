&НаСервере
Процедура СоздатьРНКИзЗаявокНаСервере()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокОснование", Объект.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаявкаНаПерепаковку.Ссылка КАК ДокЗаявка
	|ИЗ
	|	Документ.ЗаявкаНаПерепаковку КАК ЗаявкаНаПерепаковку
	|ГДЕ
	|	ЗаявкаНаПерепаковку.ДокОснование = &ДокОснование
	|	И ЗаявкаНаПерепаковку.Проведен
	|	И ЗаявкаНаПерепаковку.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаПерепаковку.Закрыта)
	|	И ЕСТЬNULL(ЗаявкаНаПерепаковку.Комплектация, ЗНАЧЕНИЕ(Документ.Комплектация.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Документ.Комплектация.ПустаяСсылка)
	|	И ЕСТЬNULL(ЗаявкаНаПерепаковку.РасходнаяНакладная, ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)) = ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)
	|
	|ДЛЯ ИЗМЕНЕНИЯ
	|	Документ.ЗаявкаНаПерепаковку";

	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);

	Пока Выборка.Следующий() Цикл

		НачатьТранзакцию();

		ЗаявкаОбъект = Выборка.ДокЗаявка.ПолучитьОбъект();
		Если ЗаявкаОбъект <> Неопределено Тогда

			ЗаявкаОбъект.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.Отработана;

			Попытка
				ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				Пока ТранзакцияАктивна() Цикл
					ОтменитьТранзакцию();
				КонецЦикла;
				Сообщить("Во время транзакции произошла ошибка." + ОписаниеОшибки());
				Продолжить;
			КонецПопытки;

			ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной", Перечисления.СостоянияНакладной.ВРаботе);

			Накладная = Документы.ЗаявкаНаПерепаковку.СоздатьРасходнуюНакладную(Выборка.ДокЗаявка,
				Выборка.ДокЗаявка.Товары.Выгрузить(), ДополнительныеРеквизиты, Истина);

			Если Накладная <> Неопределено Тогда

				ЗаявкаОбъект.РасходнаяНакладная = Накладная;

				Попытка
					ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					Пока ТранзакцияАктивна() Цикл
						ОтменитьТранзакцию();
					КонецЦикла;
					Сообщить("Во время транзакции произошла ошибка." + ОписаниеОшибки());
					Продолжить;
				КонецПопытки;

			КонецЕсли;

		КонецЕсли;

		ЗафиксироватьТранзакцию();

		Сообщить(Строка(Выборка.ДокЗаявка));
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура СообщитьДокументыПутиНаСервере(ИдентификаторСтроки)
	СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки); 
	ТекНоменклатура = СтрокаТовара.Номенклатура;

	Если Объект.Общий Тогда
		ОтключитьКонтрольПунктовДоставки = Истина;
	Иначе
		ОтключитьКонтрольПунктовДоставки = Ложь;
	КонецЕсли;

	СписокПД = Новый СписокЗначений;
	СписокПД.Добавить(Объект.ПунктДоставки);
	Запрос = Новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
				  |	РеквизитыСправочников.Справочник КАК ПД
				  |ИЗ
				  |	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
				  |ГДЕ
				  |	РеквизитыСправочников.ЗначениеРеквизита = &Справочник
				  |	И РеквизитыСправочников.ИмяРеквизита = ""Связанный адрес""";
	запрос.УстановитьПараметр("Справочник", Объект.ПунктДоставки);
	Результат=запрос.Выполнить().Выбрать();
	Пока результат.Следующий() Цикл
		СписокПД.Добавить(результат.ПД);
	КонецЦикла;

	запрос=Новый запрос;
	запрос.Текст= "ВЫБРАТЬ
				  |	СУММА(т1.Количество) КАК Количество,
				  |	т1.Номенклатура КАК Номенклатура,
				  |	т1.Ссылка КАК Ссылка
				  |ИЗ
				  |	(ВЫБРАТЬ
				  |		СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество,
				  |		РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
				  |		РасходнаяНакладнаяТовары.Ссылка КАК Ссылка
				  |	ИЗ
				  |		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
				  |	ГДЕ
				  |		(РасходнаяНакладнаяТовары.Ссылка В (&списокРНК)
				  |				ИЛИ РасходнаяНакладнаяТовары.Ссылка.Проведен
				  |					И РасходнаяНакладнаяТовары.Ссылка.КодОперации = &КодОперации
				  |					И РасходнаяНакладнаяТовары.Ссылка.Контрагент = &Контрагент
				  |					И (РасходнаяНакладнаяТовары.Ссылка.ПунктДоставки В (&ПунктДоставки)
				  |						ИЛИ &ОтключитьКонтрольПунктовДоставки)
				  |					И РасходнаяНакладнаяТовары.Количество > 0
				  |					И (РасходнаяНакладнаяТовары.Ссылка.Отгружен = &Резерв
				  |						ИЛИ РасходнаяНакладнаяТовары.Ссылка.ДатаОтгрузки = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)))
				  |		И РасходнаяНакладнаяТовары.Номенклатура В(&Номенклатура)
				  |		И РасходнаяНакладнаяТовары.Ссылка.Дата >= &Дата
				  |	
				  |	СГРУППИРОВАТЬ ПО
				  |		РасходнаяНакладнаяТовары.Номенклатура,
				  |		РасходнаяНакладнаяТовары.Ссылка
				  |	
				  |	ОБЪЕДИНИТЬ ВСЕ
				  |	
				  |	ВЫБРАТЬ
				  |		СУММА(Товары.Количество),
				  |		Товары.Номенклатура,
				  |		Товары.Ссылка
				  |	ИЗ
				  |		Документ.Комплектация.Товары КАК Товары
				  |	ГДЕ
				  |		Товары.Ссылка В(&списокРНК)
				  |		И Товары.Номенклатура В(&Номенклатура)
				  |		И Товары.Ссылка.Отгружен = &Резерв
				  |	
				  |	СГРУППИРОВАТЬ ПО
				  |		Товары.Номенклатура,
				  |		Товары.Ссылка) КАК т1
				  |
				  |СГРУППИРОВАТЬ ПО
				  |	т1.Номенклатура,
				  |	т1.Ссылка";
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	запрос.УстановитьПараметр("ПунктДоставки", СписокПД);
	запрос.УстановитьПараметр("Дата", Константы.ДатаЗапретаРедактирования.Получить() - 30 * 24 * 3600);
	запрос.УстановитьПараметр("Номенклатура", ТекНоменклатура);
	запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	запрос.УстановитьПараметр("Резерв", Перечисления.Отгружен.Резерв);
	запрос.УстановитьПараметр("списокРНК", Объект.РНКПути.Выгрузить().ВыгрузитьКолонку("Накладная"));
	Запрос.УстановитьПараметр("КодОперации", Перечисления.КодыОперацийОстатки.Комиссия);

	запрос.УстановитьПараметр("ОтключитьКонтрольПунктовДоставки", ОтключитьКонтрольПунктовДоставки);

	ТЗТоваровВпути = запрос.Выполнить().Выгрузить();
	Для Каждого СтрТЗ Из ТЗТоваровВпути Цикл
		Сообщить("" + СтрТЗ.Ссылка + " - " + Строка(СтрТЗ.Количество));
	КонецЦикла;

КонецПроцедуры

