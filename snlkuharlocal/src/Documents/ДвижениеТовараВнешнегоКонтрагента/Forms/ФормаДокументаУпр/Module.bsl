&НаСервере
Функция ПолучитьСкладФБО()
	
	Запрос=Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ первые 1
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка КАК Ссылка,
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.СоздаватьПодсортировкиFBO КАК СоздаватьПодсортировкиFBO,
	|	ИнетМагазиныСкладыПодсортировкиFBO.Склад КАК Склад
	|ИЗ
	|	Справочник.ИнетМагазины.СкладыПодсортировкиFBO КАК ИнетМагазиныСкладыПодсортировкиFBO
	|ГДЕ
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.Контрагент = &Контрагент";
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Результат=запрос.Выполнить().Выбрать();
	пока Результат.Следующий() цикл
		возврат Результат.склад;
	КонецЦикла;
	
КонецФункции

