&НаСервереБезКонтекста
Функция ВернутьСтруктуруРеквизитыТоваров()

	Структура = Новый Структура; 
	Структура.Вставить("ЭтоГруппа",ложь);
	Структура.Вставить("Модель");
	Структура.Вставить("КолКоробовВПаллете",0);
	Структура.Вставить("ШтукВКоробке",0);
	Структура.Вставить("ШтукВКоробочке",0);
	Структура.Вставить("Коллекция");
	Структура.Вставить("ГТИН");
	Структура.Вставить("КатегорияМаркетПлейсы");
	
	Возврат Структура; 

КонецФункции // ВернутьСтруктуруРеквизитыТоваров()



