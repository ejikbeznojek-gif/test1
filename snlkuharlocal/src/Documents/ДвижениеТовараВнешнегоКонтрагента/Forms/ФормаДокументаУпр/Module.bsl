Процедура ПослеВыбораРНКВпути(ВыбранноеЗначение,ДопПараметры) Экспорт
	Если ТипЗНЧ(ВыбранноеЗначение) = Тип("Массив") Тогда
		Для Каждого Значение Из ВыбранноеЗначение Цикл
			Отбор = Новый структура("Накладная",Значение); 
			Если Объект.РНКПути.НайтиСтроки(Отбор).Количество() = 0 Тогда
				СтрокаТЧ = Объект.РНКПути.Добавить();			
				СтрокаТЧ.Накладная = Значение;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Функция ПроверитьЦеныПоМатрицеПередСозданиемЗаказовFBO()
      
	Если ТЗМатриц = Неопределено 
		ИЛИ ТипЗНЧ(ТЗМатриц) <> Тип("ТаблицаЗначений") Тогда
		
		ЗаполнитьТаблицуПечатиПоМатрице(); 	
		
	КонецЕсли; 
	
	ЕстьНулевыеЦены  = Ложь; 
	
	Отбор = Новый Структура("Цена",0);
	СтрокиСНулевойЦеной = ТЗМатриц.НайтиСтроки(Отбор);
	
	МассивТоваровСНулЦенами = Новый Массив; 
	Для каждого СтрокаСНулевойЦеной  Из СтрокиСНулевойЦеной Цикл
	
		СтрокиТоваров = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура",СтрокаСНулевойЦеной.Номенклатура)); 	
		Для каждого СтрокаТоваров Из СтрокиТоваров Цикл
			
			Если СтрокаТоваров.КОтгрузке > 0  Тогда 				
				
				МассивТоваровСНулЦенами.Добавить(СтрокаСНулевойЦеной.Номенклатура);  	
				
			КонецЕсли;	
			
		КонецЦикла;
	КонецЦикла;
	
	Если МассивТоваровСНулЦенами.Количество() > 0 Тогда
	
		Запрос			= Новый Запрос;				
		Запрос.Текст 	= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МатрицаТовары.Ссылка КАК Ссылка,
		|	МатрицаТовары.Номенклатура КАК Номенклатура,
		|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
		|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(150)) КАК АртикулКонтрагента,
		|	МатрицаТовары.Цена КАК Цена,
		|	МатрицаТовары.Кратность КАК Кратность,
		|	МатрицаТовары.МинимальноеКоличество КАК МинимальноеКоличество,
		|	МатрицаТовары.ЦенаПосредника КАК ЦенаПосредника,
		|	МатрицаТовары.ШККонтрагентаБлочок КАК ШККонтрагентаБлочок,
		|	МатрицаТовары.ШККонтрагентаКоробка КАК ШККонтрагентаКоробка,
		|	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
		|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеКонтрагента КАК СТРОКА(150)) КАК НаименованиеКонтрагента,
		|	ВЫРАЗИТЬ(МатрицаТовары.КодПроизводителяКонтрагента КАК СТРОКА(150)) КАК КодПроизводителяКонтрагента,
		|	МатрицаТовары.ШКСпайки КАК ШКСпайки,
		|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
		|	МатрицаТовары.Ссылка.Дата КАК ДатаМатрицы,
		|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеБрендаДляКонтрагента КАК СТРОКА(150)) КАК НаименованиеБрендаДляКонтрагента,
		|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеЦветаДляКонтрагента КАК СТРОКА(150)) КАК НаименованиеЦветаДляКонтрагента,
		|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеРазмераДляКонтрагента КАК СТРОКА(150)) КАК НаименованиеРазмераДляКонтрагента,
		|	ВЫРАЗИТЬ(МатрицаТовары.ТипТовараДляКонтрагента КАК СТРОКА(150)) КАК ТипТовараДляКонтрагента,
		|	МатрицаТовары.КратностьПаллеты КАК КратностьПаллеты,
		|	МатрицаТовары.ПорядокУчастияВАкции КАК ПорядокУчастияВАкции,
		|	МатрицаТовары.Номенклатура.Родитель.Коллекция КАК Коллекция
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
		|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
		|ГДЕ
		|	МатрицаТовары.Ссылка.Проведен
		|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
		|	И МатрицаТовары.Ссылка.Договор = &Договор
		|	И МатрицаТовары.Ссылка.Дата <= &Дата1
		|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
		|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
		|	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция
		|	И МатрицаТовары.Номенклатура В(&Номенклатура)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаМатрицы УБЫВ";
		
		Запрос.УстановитьПараметр("Дата2",			НачалоДня(Объект.Дата));
		Запрос.УстановитьПараметр("Дата1",			КонецДня(Объект.Дата));
		Запрос.УстановитьПараметр("Контрагент",		Объект.Контрагент);		
		Запрос.УстановитьПараметр("ПунктДоставки",	Справочники.ПунктыДоставки.ПустаяСсылка());				
		Запрос.УстановитьПараметр("Договор",		Объект.Договор);	
		Запрос.УстановитьПараметр("ПостояннаяАкция",		ложь);	
		Запрос.УстановитьПараметр("Номенклатура",	МассивТоваровСНулЦенами);	
		
		
		ТЗМатрицБезПунктовДоставки = Запрос.Выполнить().Выгрузить();
		
		Отбор = Новый Структура("Цена",0);
		СтрокиСНулевойЦеной = ТЗМатрицБезПунктовДоставки.НайтиСтроки(Отбор);
		
		МассивТоваровСНулЦенами = Новый Массив; 
		Для Каждого СтрокаСНулевойЦеной Из СтрокиСНулевойЦеной Цикл

			СтрокиТоваров = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаСНулевойЦеной.Номенклатура));
			Для Каждого СтрокаТоваров Из СтрокиТоваров Цикл

				Если СтрокаТоваров.КОтгрузке > 0 Тогда

					Сообщить("По номенклатуре " + Строка(СтрокаСНулевойЦеной.Номенклатура)
						+ " не найдена цена по матрице,№ стр." + Строка(СтрокаТоваров.НомерСтроки));

					ЕстьНулевыеЦены = Истина;

				КонецЕсли;

			КонецЦикла;
		КонецЦикла;
		
	
	КонецЕсли;
	 
	Возврат НЕ ЕстьНулевыеЦены;  
	 
 
 КонецФункции // ПроверитьЦеныПоМатрицеПередСозданиемЗаказовFBO()
 

