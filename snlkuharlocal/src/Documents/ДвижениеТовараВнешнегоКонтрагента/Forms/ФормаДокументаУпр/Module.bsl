&НаКлиенте
Процедура ТоварыНоменклатурнаяМатрицаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь; 
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	ИдентификаторСтроки = ТекущиеДанные.ПолучитьИдентификатор(); 
	
	ПараметрыМатрицы = Новый Структура();
	ПараметрыМатрицы.Вставить("Номенклатура",ТекущиеДанные.Номенклатура);
	ПараметрыМатрицы.Вставить("Контрагент",Объект.Контрагент);
	ПараметрыМатрицы.Вставить("Договор",Объект.Договор);
	ПараметрыМатрицы.Вставить("ПунктДоставки",Объект.ПунктДоставки);
	ПараметрыМатрицы.Вставить("Дата",КонецДня(Объект.Дата)); 
	МассивМатриц = ПолучитьСписокМатрицПоТовару(ПараметрыМатрицы); 
	Если МассивМатриц.Количество() > 0 Тогда
		НастройкиКомпоновки = ПолучитьНастройкиКомпоновкиДляМатриц(МассивМатриц);
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("РежимВыбора", Истина);
		ПараметрыОткрытияФормы.Вставить("МножественныйВыбор", Ложь);
		ПараметрыОткрытияФормы.Вставить("ЗакрыватьПриВыборе", Истина);
		ПараметрыОткрытияФормы.Вставить("ФиксированныеНастройки", НастройкиКомпоновки);
		ОповещениеЗакрытия = Новый ОписаниеОповещения("ПослеВыбораМатрицыВСтроке", ЭтотОбъект,ИдентификаторСтроки);
		ОткрытьФорму("Документ.Матрица.Форма.ФормаВыбораУпр", ПараметрыОткрытияФормы, ЭтотОбъект, , , ,
			ОповещениеЗакрытия);
	КонецЕсли;
КонецПроцедуры

