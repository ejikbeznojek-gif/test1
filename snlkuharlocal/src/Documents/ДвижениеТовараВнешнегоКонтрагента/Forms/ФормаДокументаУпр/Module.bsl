&НаКлиенте
Процедура ПересчитатьИтогиНаКлиенте()
    
    КоличествоИтог = 0;
    КоличествоКОтгрузкеИтог = 0;
    СуммаИтог = 0; 
    ОстатокКонтрагентаИтог = 0; 
    НедостающееКоличествоИтог = 0; 
    ВПутиИтог = 0; 
    КоличествоПланИтог = 0; 

	ТаблицаФормы 	= Элементы.Товары;
	ДанныеТаблицы 	= Объект.Товары;

	Для Каждого СтрокаТаблицы Из ДанныеТаблицы Цикл
        
        ИдентификаторСтроки = СтрокаТаблицы.ПолучитьИдентификатор();
        
        Если ТаблицаФормы.ПроверитьСтроку(ИдентификаторСтроки) = Истина Тогда
        	
			КоличествоИтог 				= КоличествоИтог + СтрокаТаблицы.Количество;
			КоличествоКОтгрузкеИтог 	= КоличествоКОтгрузкеИтог + СтрокаТаблицы.КОтгрузке; 
			СуммаИтог 					= СуммаИтог + СтрокаТаблицы.Сумма; 
			ОстатокКонтрагентаИтог 		= ОстатокКонтрагентаИтог + СтрокаТаблицы.ОстатокКонтрагента; 
			НедостающееКоличествоИтог 	= НедостающееКоличествоИтог + СтрокаТаблицы.НедостающееКоличество;
			ВПутиИтог					= ВПутиИтог + СтрокаТаблицы.ВПути;  
			КоличествоПланИтог 			= КоличествоПланИтог + СтрокаТаблицы.КоличествоПлан; 
        
        КонецЕсли;

	КонецЦикла;
    
    
	//Элементы.ТоварыКоличество.ТекстПодвала 	= Формат(КоличествоИтог, "ЧГ=3,0");
	//Элементы.ТоварыКОтгрузке.ТекстПодвала 	= Формат(КоличествоКОтгрузкеИтог, "ЧГ=3,0");
	//Элементы.ТоварыСумма.ТекстПодвала 	= Формат(СуммаИтог, "ЧГ=3,0");
