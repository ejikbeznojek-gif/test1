Процедура СоздатьЗаказыFBO(Знач МассивРНК) Экспорт
    НачатьТранзакцию();
	МассивЗаказов = Новый Массив; 
	Для каждого РНК Из МассивРНК Цикл
		
		НовыйДокумент = Документы.ЗаказСмешанныхСпаекFBO.СоздатьДокумент(); 
		НовыйДокумент.Заполнить(РНК);
		НовыйДокумент.Дата = ТекущаяДатаСеанса(); 
		НовыйДокумент.Автор = ПараметрыСеанса.Пользователь; 
		
		Попытка
		
			НовыйДокумент.Записать(); 	
		    МассивЗаказов.Добавить(НовыйДокумент.Ссылка); 
		Исключение
		     ОтменитьТранзакцию();
			 Сообщить(ОписаниеОшибки()); 
		КонецПопытки;
	КонецЦикла;
	
	Если ТранзакцияАктивна()  Тогда
	
		ЗафиксироватьТранзакцию();	
		
		Сообщить("Созданы заказы FBO:" + Символы.ПС + СтрСоединить(МассивЗаказов,Символы.ПС));
		
	КонецЕсли;

КонецПроцедуры  

Процедура ЗаполнитьКомплектующиеПоРНК(Знач МассивРНК) Экспорт 
	
	Для каждого РНК Из МассивРНК Цикл
	
		РНКОбъект = РНК.ПолучитьОбъект(); 
		ЗаполнениеДокументов.ЗаполнитьТЧКомплектующие(РНКОбъект);
	    Попытка
		
			РНКОбъект.Записать(); 	
		    
		Исключение
		     
			 Сообщить("Не удалось заполнить ТЧ Комплектующие по " + Строка(РНК)); 
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

