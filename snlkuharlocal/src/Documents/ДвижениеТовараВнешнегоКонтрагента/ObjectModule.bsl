//Михайловский С. 20220224 +++
//   "ЗаявкаНаПерепаковку"
//   "РНК"
//   Шворобей ВЮ 01.11.2022 ++
Функция ОбработатьРНК(РНКСсыл,МСкл, КакойДокументСоздавать = "РНК",ДокументРНКСозданный = неопределено) //Данилова Е.В. 01.11.2025 HELP-7698
	
	Рез="";
	ЕстьДопСкл=Ложь;
	Если НЕ МСкл=неопределено Тогда
		ЕстьДопСкл=МСкл.Количество();
	КонецЕсли;	
	
	ТЗНом=РНКСсыл.Товары.Выгрузить();
	// Шворобей ВЮ 28.10.2022 ++
	Если КакойДокументСоздавать = "РНК" Тогда
		Для Каждого ТСтр Из ТЗНом Цикл
			ТСтр.Количество=ТСтр.Заявка;
		КонецЦикла;
	КонецЕсли;
	// Шворобей ВЮ 28.10.2022 ++	
	ТЗНом.Свернуть("Номенклатура","Количество");
	СпН = ТЗНом.ВыгрузитьКолонку("Номенклатура");
	
	Если ЕстьДопСкл Тогда
		Запрос1=Новый Запрос;
		Запрос1.Текст =
		"ВЫБРАТЬ
		//|	СУММА(Остатки.СуммаОстаток) КАК СебестоимостьБух,
		|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
		|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
		|	Остатки.Склад КАК Склад,
		|	Остатки.Номенклатура КАК Номенклатура
		//|	ПОМЕСТИТЬ ВТ_ОстСкл
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В (&Склады)
		|				И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад В (&Склады)
		|					И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Резервы
		|		ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			И Остатки.Склад = Резервы.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура,
		|	Остатки.Склад
		
		|";
		
		Запрос1.УстановитьПараметр("ном",СпН);
		Запрос1.УстановитьПараметр("Склады",МСкл);
		ТЗОстДоп=Запрос1.Выполнить().Выгрузить();
	КонецЕсли;
	
	Запрос=Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗНом.Номенклатура КАК Номенклатура,
	|	ТЗНом.Количество КАК Количество
	|ПОМЕСТИТЬ ВТ_НомДок
	|ИЗ
	|	&ТЗНом КАК ТЗНом
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
	|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
	|	ЛОЖЬ КАК Комплект,
	|	Остатки.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_ОстСкл
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад В ИЕРАРХИИ (&Склад)
	|				И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				,
	|				Склад В ИЕРАРХИИ (&Склад)
	|					И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Резервы
	|		ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			И Остатки.Склад = Резервы.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НомДок.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОстСкл.КолКонФакт, 0) КАК Доступно,
	|	НомДок.Количество - ЕСТЬNULL(ОстСкл.КолКонФакт, 0) КАК НеХват,
	|	0 КАК Добавка,
	|	0 КАК Добавка1,
	|	ЛОЖЬ КАК ПолнПодпит,
	|	ВЫБОР
	|		КОГДА &Провод
	|			ТОГДА НомДок.Количество
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК УжеРезерв
	|ИЗ
	|	ВТ_НомДок КАК НомДок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстСкл КАК ОстСкл
	|		ПО НомДок.Номенклатура = ОстСкл.Номенклатура
	|ГДЕ
	|	НомДок.Количество > ЕСТЬNULL(ОстСкл.КолКонФакт, 0) + ВЫБОР
	|			КОГДА &Провод
	|				ТОГДА НомДок.Количество
	|			ИНАЧЕ 0
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ном",СпН);
	Запрос.УстановитьПараметр("Склад",РНКСсыл.Склад);
	Запрос.УстановитьПараметр("Провод",РНКСсыл.Проведен);
	Запрос.УстановитьПараметр("ТЗНом",ТЗНом);
	
	ТЗКорр=Запрос.Выполнить().Выгрузить();
	Если НЕ ТЗКорр.Количество() Тогда
		ДокРНК1=РНКСсыл.ПолучитьОбъект();
		
		Если КакойДокументСоздавать = "РНК" Тогда
			ДокРНК1.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе;
		КонецЕсли;
		ДокРНК1.Дата=ТекущаяДатаСеанса();
		ДокРНК1.Записать(РежимЗаписиДокумента.Проведение);
		//ЗаписатьВЛог("ВБрз","Окончание выполнения. Задача: Контроль остатка ВБ Переведено в состояние КОтправкеНаСклад! 2  ","Информация");
		Рез="Документ " + Строка(РНКСсыл) + " не требует модификации";
		Возврат Рез;
	КонецЕсли;
	
	Если ЕстьДопСкл Тогда
		СоздПРМ=Ложь;
		ТЗОстДоп1=ТЗОстДоп.Скопировать();
		ТЗОстДоп1.Свернуть("Номенклатура","КолКонФакт");
		Для Каждого ТекСтр Из ТЗКорр Цикл
			Найды=ТЗОстДоп1.НайтиСтроки(Новый Структура("Номенклатура",ТекСтр.Номенклатура));
			Если Найды.Количество() Тогда
				
				Если ТекСтр.НеХват>Найды[0].КолКонФакт Тогда
					ТекСтр.Добавка=Найды[0].КолКонФакт;
				Иначе
					ТекСтр.Добавка=ТекСтр.НеХват;
				КонецЕсли;	
				Если НЕ ТекСтр.Добавка=0 Тогда
					СоздПРМ=Истина;
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла;
		
		Если СоздПРМ Тогда
			МасСклПост=Новый Массив;
			
			Для Каждого ТекСтр Из ТЗКорр Цикл
				Если ТекСтр.Добавка>0 Тогда
					Найды=ТЗОстДоп.НайтиСтроки(Новый Структура("Номенклатура",ТекСтр.Номенклатура));
					Для Каждого Найд Из Найды Цикл
						Если МасСклПост.Найти(Найд.Склад)=неопределено Тогда
							МасСклПост.Добавить(Найд.Склад);	
							
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			Для Каждого Скл Из МасСклПост Цикл
				//Михайловский С. корректировка 20220519 +++
				Если НЕ (Скл=РНКСсыл.Склад) Тогда
					//Михайловский С. корректировка 20220519 ---	
					Подсортировка=документы.Перемещение.СоздатьДокумент();
					Подсортировка.СкладПолучатель=РНКСсыл.Склад;
					Подсортировка.Склад=Скл;
					Подсортировка.ИБ=РНКСсыл.иб;
					Подсортировка.Менеджер=ПараметрыСеанса.Пользователь.ФизЛицо;
					Подсортировка.Автор=ПараметрыСеанса.Пользователь;
					Подсортировка.Организация=РНКСсыл.организация;
					Подсортировка.ПунктДоставки=РНКСсыл.ПунктДоставки;
					Подсортировка.Комментарий="Создано обработкой при разбивке док-тов";
					Подсортировка.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
					Подсортировка.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.ВРаботе;
					Подсортировка.Отгружен=Перечисления.Отгружен.Отгружен;
					Подсортировка.ДокОснование=РНКСсыл;
					Подсортировка.Дата=ТекущаяДата();
					Подсортировка.Валюта=Справочники.Валюты.НайтиПоКоду("810");
					Подсортировка.Курс=1;
					
					УстановитьНомерДокументаКлиентСервер(Подсортировка);
					
					Для Каждого ТекСтр Из ТЗКорр Цикл
						Если ТекСтр.Добавка>0 Тогда
							Найды=ТЗОстДоп.НайтиСтроки(Новый Структура("Номенклатура, Склад",ТекСтр.Номенклатура, Скл));
							Если Найды.Количество() Тогда
								СтрокаТЗДляПРМ=Найды[0];
								Ост1=ТекСтр.Добавка-ТекСтр.Добавка1;
								Если (Ост1)>0 Тогда
									Ост2=СтрокаТЗДляПРМ.КолКонФакт;
									Если Ост1>Ост2 Тогда
										ТКоличество=Ост2;
									Иначе
										ТКоличество=Ост1;
									КонецЕсли;	
									//Для Каждого СтрокаТЗДляПРМ Из Найды Цикл
									СтрТЧ=Подсортировка.Товары.Добавить();
									СтрТЧ.Номенклатура=СтрокаТЗДляПРМ.номенклатура;
									СтрТЧ.Заявка=ТКоличество;
									стртч.ПодтвержденнаяЗаявка=ТКоличество;			
									стртч.ПодтвержденнаяЗаявкаПеремещения=ТКоличество;
									СтрТЧ.Количество=ТКоличество;				
									ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, Подсортировка);
									РассчитатьСуммуТабЧасти(СтрТЧ, Подсортировка);
									//КонецЦикла;
									ТекСтр.Добавка1=ТекСтр.Добавка1+ТКоличество;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
					Если Подсортировка.Товары.Количество() Тогда
						Подсортировка.Дата=ТекущаяДата();
						Подсортировка.Записать(РежимЗаписиДокумента.Проведение);
						// Кухарь 16.03.2022 начало
						//
						//++Данилова Е.В. 17.06.2026 №0000000008
						//СообщитьИзМодуля(""+Подсортировка);
						Сообщить(""+Подсортировка); 
						//--Данилова Е.В. 17.06.2026 
						
						// Кухарь  16.03.2022 конец
						
						
					КонецЕсли;	
					//Михайловский С. корректировка 20220519 +++	
				КонецЕсли;
				//Михайловский С. корректировка 20220519 ---
			КонецЦикла;
			
		КонецЕсли;	
	КонецЕсли;
	
	// Шворобей ВЮ 01.11.2022 ++
	ЕстьПозиции=Ложь; ЕстьПозиции1=Ложь;
	Для Каждого ТекСтр Из ТЗКорр Цикл
		Если ТекСтр.НеХват > ТекСтр.Добавка1 Тогда
			ЕстьПозиции = Истина;
		КонецЕсли;
		Если ТекСтр.Добавка1>0 Тогда
			ЕстьПозиции1=Истина;
		КонецЕсли;	
	КонецЦикла;
	// Шворобей ВЮ 01.11.2022 ++
	
	// Шворобей ВЮ 01.11.2022 ++
	//Для Каждого ТекСтр Из ТЗКорр Цикл
	//	Если ТекСтр.Добавка1>0 Тогда
	//		ЕстьПозиции1=Истина;
	//	КонецЕсли;	
	//КонецЦикла;
	// Не надо одну и ту же ТЧ 2 раза обходить :-)
	
	Если ЕстьПозиции И ЕстьПозиции1 Тогда
		Попытка
			НачатьТранзакцию();
			
			// Шворобей ВЮ 01.11.2022 ++
			Если КакойДокументСоздавать = "РНК" Тогда
				ДокРНК2=Документы.РасходнаяНакладная.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ДокРНК2,РНКСсыл);
				ДокРНК2.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
			ИначеЕсли КакойДокументСоздавать = "ЗаявкаНаПерепаковку" Тогда
				ДокРНК2 = Документы.ЗаявкаНаПерепаковку.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ДокРНК2,РНКСсыл);
				ДокРНК2.ДокОснование = Ссылка;
				ДокРНК2.Автор = ПараметрыСеанса.Пользователь;
			КонецЕсли;
			
			ДокРНК2.Товары.Очистить();
			Для Каждого ТекСтр Из ТЗКорр Цикл
				Если ТекСтр.НеХват>ТекСтр.Добавка1 Тогда
					Кол=ТекСтр.НеХват-ТекСтр.Добавка1;
					СтрТЧ=ДокРНК2.Товары.Добавить();
					СтрТЧ.Номенклатура=ТекСтр.Номенклатура;
					СтрТЧ.Количество=Кол;
					Если КакойДокументСоздавать = "РНК" Тогда
						СтрТЧ.Заявка=Кол;
						СтрТЧ.ПодтвержденнаяЗаявка = Кол;
						ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокРНК2);
						РассчитатьСуммуТабЧасти(СтрТЧ, ДокРНК2);
					КонецЕсли;
				КонецЕсли;	
			КонецЦикла;
			
