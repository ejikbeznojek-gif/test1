Процедура РасчитатьТолькоКороба () экспорт
	ТЗМатрицы=ПолучитьТЗМатриц();	
	
	для каждого СтрТЧ из Товары цикл
		Номенклатура=СтрТЧ.Номенклатура;
		СтрМатрицы=ТЗМатрицы.найти(Номенклатура);
		
		если СтрМатрицы=Неопределено тогда
			Продолжить;		
		иначе		
		КонецЕсли;		
		
		
		// Кухарь А.Ю. 12.03.2021 начало
		// Количество коробов теперь реквизит ТЧ
		если СтрТЧ.КОтгрузке>0 тогда
			ШтукВКоробе=СтрМатрицы.КратностьКоробкиИзНоменклатуры;
			если ШтукВКоробе>0 тогда
				СтрТЧ.КоробокКОтгрузке=СтрТЧ.КОтгрузке/ШтукВКоробе;
			КонецЕсли;
		КонецЕсли;
		// Кухарь А.Ю. 12.03.2021 конец
		
		
	КонецЦикла;
	
КонецПроцедуры

