Функция ПолучитьТЗМатриц ()
	
	Запрос	= Новый Запрос;				
	Запрос.Текст 	=
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Ссылка КАК Ссылка,
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробкеИзНоменклатуры,
	|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
	|	МатрицаТовары.МинимальныйОстатокВДнях КАК МинимальныйОстатокВДнях,
	|	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
	|	МатрицаТовары.КратностьПаллеты КАК КратностьПаллеты,
	|	МатрицаТовары.СпособПоставки КАК СпособПоставки,
	|	МатрицаТовары.Ссылка.Дата КАК ДатаМатрицы,
	|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
	|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеБрендаДляКонтрагента КАК СТРОКА(200)) КАК НаименованиеБрендаДляКонтрагента,
	|	МатрицаТовары.Номенклатура.Родитель.ШтукВКоробке КАК КратностьКоробкиИзНоменклатуры,
	|	МатрицаТовары.ВыделятьВДокументах КАК ВыделятьВДокументах,
	|	МатрицаТовары.ПунктДоставки КАК ПунктДоставки,
	|	МатрицаТовары.Цена КАК Цена,
	|	ВЫРАЗИТЬ(МатрицаТовары.ТипТовараДляКонтрагента КАК СТРОКА(250)) КАК ТипТовараДляКонтрагента
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаТовары.Номенклатура В(&Номенклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаМатрицы УБЫВ";
	
	Запрос.УстановитьПараметр("Дата2",			НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Дата1",			КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Контрагент",		Контрагент);	
	запрос.УстановитьПараметр("ПунктДоставки",ПунктДоставки);
	запрос.УстановитьПараметр("Договор",Договор);
	запрос.УстановитьПараметр("Номенклатура",Товары.ВыгрузитьКолонку("Номенклатура"));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции


// Кухарь А.Ю. 22.09.2025 начало   
// ASU-2504
// Функция ПолучитьТоварыВПути ()
Функция ПолучитьТоварыВПути (ДополнительныеПараметры = Неопределено)    
	ОтключитьКонтрольПунктовДоставки = ложь;
	если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") тогда   
		если ДополнительныеПараметры.Свойство("ОтключитьКонтрольПунктовДоставки") тогда 
			ОтключитьКонтрольПунктовДоставки = ДополнительныеПараметры.ОтключитьКонтрольПунктовДоставки; 
		КонецЕсли;
	КонецЕсли;
	// Кухарь А.Ю. 22.09.2025 конец
	
	СписокПД=новый СписокЗначений;
	СписокПД.Добавить(ПунктДоставки);
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РеквизитыСправочников.Справочник КАК ПД
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ЗначениеРеквизита = &Справочник
	|	И РеквизитыСправочников.ИмяРеквизита = ""Связанный адрес""";	
	запрос.УстановитьПараметр("Справочник",ПунктДоставки);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		СписокПД.Добавить(результат.ПД);
	КонецЦикла;
	
	запрос=новый запрос;
	
	запрос.Текст= "ВЫБРАТЬ
	              |	СУММА(т1.Количество) КАК Количество,
	              |	т1.Номенклатура КАК Номенклатура
	              |ИЗ
	              |	(ВЫБРАТЬ
	              |		СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество,
	              |		РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура
	              |	ИЗ
	              |		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	              |	ГДЕ
	              |		(РасходнаяНакладнаяТовары.Ссылка В (&списокРНК)
	              |				ИЛИ РасходнаяНакладнаяТовары.Ссылка.Проведен
	              |					И РасходнаяНакладнаяТовары.Ссылка.КодОперации = &КодОперации
	              |					И РасходнаяНакладнаяТовары.Ссылка.Контрагент = &Контрагент
	              |					И (РасходнаяНакладнаяТовары.Ссылка.ПунктДоставки В (&ПунктДоставки)
	              |						ИЛИ &ОтключитьКонтрольПунктовДоставки)
	              |					И РасходнаяНакладнаяТовары.Количество > 0
	              |					И (РасходнаяНакладнаяТовары.Ссылка.Отгружен = &Резерв
	              |						ИЛИ РасходнаяНакладнаяТовары.Ссылка.ДатаОтгрузки = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)))
	              |		И РасходнаяНакладнаяТовары.Номенклатура В(&Номенклатура)
	              |		И РасходнаяНакладнаяТовары.Ссылка.Дата >= &Дата
	              |		И НЕ РасходнаяНакладнаяТовары.Ссылка.Склад.ЭтоСкладFBS
	              |	
	              |	СГРУППИРОВАТЬ ПО
	              |		РасходнаяНакладнаяТовары.Номенклатура
	              |	
	              |	ОБЪЕДИНИТЬ ВСЕ
	              |	
	              |	ВЫБРАТЬ
	              |		СУММА(Товары.Количество),
	              |		Товары.Номенклатура
	              |	ИЗ
	              |		Документ.Комплектация.Товары КАК Товары
	              |	ГДЕ
	              |		Товары.Ссылка В(&списокРНК)
	              |		И Товары.Номенклатура В(&Номенклатура)
	              |		И Товары.Ссылка.Отгружен = &Резерв
	              |	
	              |	СГРУППИРОВАТЬ ПО
	              |		Товары.Номенклатура) КАК т1
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	т1.Номенклатура"; 
	// Кухарь А.Ю. 18.08.2021 конец
	
	Запрос.УстановитьПараметр("Контрагент",		Контрагент);	
	запрос.УстановитьПараметр("ПунктДоставки",СписокПД);
	запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить()-30*24*3600);
	запрос.УстановитьПараметр("Номенклатура",Товары.ВыгрузитьКолонку("Номенклатура"));
	запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	запрос.УстановитьПараметр("Резерв",Перечисления.Отгружен.Резерв);
	запрос.УстановитьПараметр("списокРНК",РНКПути.ВыгрузитьКолонку("Накладная"));
	Запрос.УстановитьПараметр("КодОперации",		Перечисления.КодыОперацийОстатки.Комиссия);
	// Кухарь А.Ю. 22.09.2025 начало
	// ASU-2504
	Запрос.УстановитьПараметр("ОтключитьКонтрольПунктовДоставки",		ОтключитьКонтрольПунктовДоставки);
	// Кухарь А.Ю. 22.09.2025 конец
	
	ТЗТоваровВпути=запрос.Выполнить().Выгрузить();	
	Для каждого СтрТЗ из ТоварыВПути цикл
		СтрПути=ТЗТоваровВпути.Найти(СтрТЗ.номенклатура);
		если СтрПути=Неопределено тогда
			СтрПути=ТЗТоваровВпути.Добавить();
			ЗаполнитьЗначенияСвойств(СтрПути,СтрТЗ);
		иначе
			СтрПути.Количество=СтрПути.количество+СтрТЗ.Количество;
		КонецЕсли;						
	КонецЦикла;
	Возврат ТЗТоваровВпути;

КонецФункции
