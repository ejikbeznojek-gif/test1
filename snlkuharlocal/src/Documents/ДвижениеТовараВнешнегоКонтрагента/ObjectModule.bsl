	ТекстЗапроса = ""; 
	НомерРНК = 1; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Для каждого РНКОб Из МассивРНК Цикл
		
		ТекстЗапросаN =  
		"ВЫБРАТЬ
		|	НакладнаяТовары.Номенклатура КАК Номенклатура,
		|	НакладнаяТовары.Количество КАК Количество,
		|	НакладнаяТовары.Всего КАК Всего,
		|	НакладнаяТовары.Заявка КАК Заявка,
		|	НакладнаяТовары.ПодтвержденнаяЗаявка КАК ПодтвержденнаяЗаявка
		|ПОМЕСТИТЬ ВТТоварыN
		|ИЗ
		|	&ТоварыN КАК НакладнаяТовары; "; 
		
		ТекстЗапросаN = СтрЗаменить(ТекстЗапросаN,"ВТТоварыN", "ВТТовары" + Строка(НомерРНК));
		ТекстЗапросаN = СтрЗаменить(ТекстЗапросаN,"ТоварыN", "Товары" + Строка(НомерРНК));
		Запрос.УстановитьПараметр("Товары" + Строка(НомерРНК),РНКОб.Товары.выгрузить()); 
		ТекстЗапроса = ТекстЗапроса + ТекстЗапросаN; 
		НомерРНК = НомерРНК + 1;
	КонецЦикла;

	Запрос.Текст = ТекстЗапроса; 
