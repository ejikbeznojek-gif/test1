Функция ПолучитьНастройкиИзИнтернетМагазина()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнетМагазины.РазбиватьПоВидуСпаек КАК РазбиватьНакладныеПоВидуСпаек,
		|	ИнетМагазины.СоздаватьПодсортировкиFBO КАК СоздаватьПодсортировкиFBO,
		|	ИнетМагазины.РазбиватьПоЛимитуКоличество1 КАК РазбиватьПоЛимитуКоличество,
		|	ИнетМагазины.ЛимитПоКоличеству1 КАК ЛимитПоКоличеству
		|ИЗ
		|	Справочник.ИнетМагазины КАК ИнетМагазины
		|ГДЕ
		|	ИнетМагазины.Контрагент = &Контрагент
		|	И ИнетМагазины.Организация = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИнетМагазиныСкладыПодсортировкиFBO.Склад КАК Склад
		|ИЗ
		|	Справочник.ИнетМагазины.СкладыПодсортировкиFBO КАК ИнетМагазиныСкладыПодсортировкиFBO
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИнетМагазины КАК ИнетМагазины
		|		ПО ИнетМагазиныСкладыПодсортировкиFBO.Ссылка = ИнетМагазины.Ссылка
		|ГДЕ
		|	ИнетМагазины.Контрагент = &Контрагент
		|	И ИнетМагазины.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Организация", Константы.ОсновнаяОрганизацияУправленческогоУчета.Получить());
	
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	
	Настройки = Новый Структура("РазбиватьНакладныеПоВидуСпаек,СоздаватьПодсортировкиFBO,РазбиватьПоЛимитуКоличество,ЛимитПоКоличеству,Склады",ложь,ложь,ложь,0,Новый Массив); 
	
	ВыборкаОсновные = ПакетРезультатов[0].Выбрать(); 
	ТЧСклады = ПакетРезультатов[1].Выгрузить();
	Если ВыборкаОсновные.Следующий() Тогда
	
		ЗаполнитьЗначенияСвойств(Настройки,ВыборкаОсновные); 	
	
	КонецЕсли;
	Если ТЧСклады.Количество() > 0  Тогда
		Настройки.Склады = ТЧСклады.ВыгрузитьКолонку("Склад");; 
	КонецЕсли;
		
		
	Возврат Настройки; 

КонецФункции // ПолучитьНастройкиИзИнтернетМагазина()

Функция СоздатьНаборРНКПоКоличествуШтукВСпайке(НастройкиДляСозданияРНК)
	ОткатыватьТранзацию = ложь;
	
	РазбиватьКратноКоробу = Ложь; 
	//Данилова Е.В. 19.12.2025 HELP-8278 
	//без сохранения РНК промежуточных 
	//НачатьТранзакцию(); 
	
	
	МассивДокументов = Новый Массив;
	ЕстьРаздел = Истина;
	ЛимПоз = 5000;
	Если НастройкиДляСозданияРНК.РазбиватьПоЛимитуКоличество Тогда
		
		ЛимПоз = НастройкиДляСозданияРНК.ЛимитПоКоличеству; 	
		
	КонецЕсли;	
	
	
	// Шворобей ВЮ 18.01.2023 ++
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т1.Номенклатура КАК Номенклатура,
	|	т1.Номенклатура.Родитель.ШтукВКоробочке КАК ШтукВКоробочке,
	|	т1.Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	ВЫБОР
	|		КОГДА &РазбиватьКратноКоробу
	|			ТОГДА т1.ШтукВКоробке * т1.МножительДляКороба
	|		ИНАЧЕ т1.Количество
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР
	|		КОГДА т1.КоличествоЦветов = 0
	|			ТОГДА 1
	|		КОГДА &РазбиватьПоКоличествуЦветов
	|			ТОГДА т1.КоличествоЦветов
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК КоличествоЦветов,
	|	ВЫБОР
	|		КОГДА т1.КоличествоКМП = 0
	|			ТОГДА 0
	|		КОГДА &РазбиватьПоКоличествуВСпайке
	|			ТОГДА т1.КоличествоКМП
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК КоличествоКМП,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоСпособуПоставки
	|			ТОГДА т1.СпособПоставки
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособПоставкиКонтрагенту.Микс)
	|	КОНЕЦ КАК СпособПоставки,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоНоменклатурнымМатрицам
	|			ТОГДА ЕСТЬNULL(т1.НоменклатурнаяМатрица, ЗНАЧЕНИЕ(Документ.Матрица.ПустаяСсылка))
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.Матрица.ПустаяСсылка)
	|	КОНЕЦ КАК НоменклатурнаяМатрица,
	|	т1.ПунктДоставки КАК ПунктДоставки,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоНоменклатурнымМатрицам
	|			ТОГДА ЕСТЬNULL(т1.НоменклатурнаяМатрица.ПостояннаяАкция, ЛОЖЬ)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПостояннаяАкция,
	|	ВЫБОР
	|		КОГДА &РазбиватьНакладныеПоВидуСпаек
	|				И т1.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВидКомплекта,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(т1.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ЕСТЬNULL(т1.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) < &ТекущаяДата
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Маркировка,
	|	т1.Расходник КАК Расходник
	|ИЗ
	|	(ВЫБРАТЬ
	|		Товары.Номенклатура КАК Номенклатура,
	|		Товары.СпособПоставки КАК СпособПоставки,
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура.Цвет) КАК КоличествоЦветов,
	|		МАКСИМУМ(ЕСТЬNULL(Товары.КОтгрузке, 0)) КАК Количество,
	|		СУММА(ЕСТЬNULL(Комплектующие.Количество, 0)) КАК КоличествоКМП,
	|		МАКСИМУМ(ВЫБОР
	|				КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|					ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|				ИНАЧЕ ВЫБОР
	|						КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|							ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|						ИНАЧЕ 1
	|					КОНЕЦ
	|			КОНЕЦ) КАК ШтукВКоробке,
	|		МАКСИМУМ(ВЫБОР
	|				КОГДА ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ > 0
	|						И ЕСТЬNULL(Товары.КОтгрузке, 0) <> ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ
	|					ТОГДА (ВЫРАЗИТЬ(ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|								КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|									ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|								ИНАЧЕ ВЫБОР
	|										КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|											ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|										ИНАЧЕ 1
	|									КОНЕЦ
	|							КОНЕЦ - 0.5 КАК ЧИСЛО(15, 0))) + 1
	|				ИНАЧЕ ВЫРАЗИТЬ(ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ - 0.5 КАК ЧИСЛО(15, 0))
	|			КОНЕЦ) КАК МножительДляКороба,
	|		Товары.НоменклатурнаяМатрица КАК НоменклатурнаяМатрица,
	|		Товары.ПунктДоставки КАК ПунктДоставки,
	|		МАКСИМУМ(Расходники.Номенклатура) КАК Расходник
	|	ИЗ
	|		Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК Товары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|			ПО Товары.Номенклатура = Комплектующие.Ссылка
	|				И (Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар))
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК Расходники
	|			ПО Товары.Номенклатура = Расходники.Ссылка
	|				И (Расходники.Номенклатура.Родитель.ВидНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар))
	|	ГДЕ
	|		Товары.Ссылка = &Ссылка
	|		И Товары.КОтгрузке > 0
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Товары.Номенклатура,
	|		Товары.СпособПоставки,
	|		Товары.НоменклатурнаяМатрица,
	|		Товары.ПунктДоставки) КАК т1
	|ИТОГИ
	|	СУММА(Количество)
	|ПО
	|	СпособПоставки,
	|	КоличествоЦветов,
	|	КоличествоКМП,
	|	ПостояннаяАкция,
	|	НоменклатурнаяМатрица,
	|	ПунктДоставки,
	|	Маркировка,
	|	Расходник,
	|	Номенклатура";
	// Шворобей ВЮ 18.01.2023 ++
	
	// Кухарь А.Ю.  24.11.2022 начало
	//По просьбе Натальи вернул разбивку для ВБ
	// 	Запрос.УстановитьПараметр("РазбиватьПоСпособуПоставки",ложь);
	// Кухарь А.Ю.  06.08.2024 начало
	// 	Если Контрагент.Код="SSR-9059" тогда
	Если Контрагент.Код="SSR-9059" или Контрагент.Код="SST-1208" тогда
		// Кухарь А.Ю.  06.08.2024 конец
		
		Запрос.УстановитьПараметр("РазбиватьПоСпособуПоставки",Истина);
		// Малахов В.С. 18.01.24 начало
		//По просьбе Алины убрали разбивку для микс 3 паллеты 
		ОтклРазбивку=" и не т1.СпособПоставки=ЗНАЧЕНИЕ(Перечисление.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула)";
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"КОГДА &РазбиватьКратноКоробу","КОГДА &РазбиватьКратноКоробу"+ОтклРазбивку);
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"КОГДА &РазбиватьПоКоличествуЦветов","КОГДА &РазбиватьПоКоличествуЦветов"+ОтклРазбивку);
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"КОГДА &РазбиватьПоКоличествуВСпайке","КОГДА &РазбиватьПоКоличествуВСпайке"+ОтклРазбивку);
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"КОГДА &РазбиватьПоНоменклатурнымМатрицам","КОГДА &РазбиватьПоНоменклатурнымМатрицам"+ОтклРазбивку);
		//Малахов В.С. 18.01.24 конец
	иначе
		Запрос.УстановитьПараметр("РазбиватьПоСпособуПоставки",ложь);
	КонецЕсли;
	// Кухарь А.Ю.  24.11.2022 конец
	
	Запрос.УстановитьПараметр("РазбиватьКратноКоробу", РазбиватьКратноКоробу);
	Запрос.УстановитьПараметр("РазбиватьПоКоличествуВСпайке",Истина);
	Запрос.УстановитьПараметр("РазбиватьПоКоличествуЦветов",Истина);
	// Кухарь А.Ю.  10.09.2024 начало
	//
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата()); 
	// Кухарь А.Ю.  10.09.2024 конец
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	
	// Шворобей ВЮ 18.01.2023 ++
	Запрос.УстановитьПараметр("РазбиватьПоНоменклатурнымМатрицам", Истина);
	// Шворобей ВЮ 08.07.2024 ++
	Запрос.УстановитьПараметр("РазбиватьНакладныеПоВидуСпаек", Ложь);
	// Шворобей ВЮ 08.07.2024 ++
	
	ВыборкаСпособовПоставки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"СпособПоставки");  // 1  
	
	СоответствиеКМПРНК = Новый Соответствие; 
	
	Пока ВыборкаСпособовПоставки.Следующий() цикл
		
		// Кухарь А.Ю.  24.11.2022 начало
		//По просьбе Натальи вернул разбивку для ВБ
		// Кухарь А.Ю.  06.08.2024 начало
		// 	если Контрагент.Код="SSR-9059"  тогда
		если Контрагент.Код="SSR-9059" или Контрагент.Код="SST-1208"   тогда 
			// Кухарь А.Ю.  06.08.2024 конец
			
			КСпособПоставки=""+ВыборкаСпособовПоставки.СпособПоставки;
		иначе
			КСпособПоставки="";
		КонецЕсли;
		// Кухарь А.Ю.  24.11.2022 конец
		
		ВыборкаКоличествоЦветов=ВыборкаСпособовПоставки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"КоличествоЦветов");   // 2
		Пока ВыборкаКоличествоЦветов.Следующий() Цикл
			
			кКоличествоЦветов=", количество цветов "+ВыборкаКоличествоЦветов.КоличествоЦветов;
			
			ВыборкаВидовНоменклатуры=ВыборкаКоличествоЦветов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"КоличествоКМП");  // 3
			// Кухарь А.Ю. 17.02.2022 конец
			
			// Кухарь А.Ю. 12.11.2020 начало
			Пока ВыборкаВидовНоменклатуры.Следующий() Цикл
				// Кухарь А.Ю. 17.02.2022 начало
				//
				кКоличествоКМП=", количество КМП "+ВыборкаВидовНоменклатуры.КоличествоКМП;
				
				ВыборкаПоПостояннымАкциям = ВыборкаВидовНоменклатуры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ПостояннаяАкция");  // 4
				
				Пока ВыборкаПоПостояннымАкциям.Следующий() Цикл
					
					ВыборкаПоНоменклатурнымМатрицам = ВыборкаПоПостояннымАкциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НоменклатурнаяМатрица"); // 5
					
					Пока ВыборкаПоНоменклатурнымМатрицам.Следующий() Цикл
						//Михайловский С. 20230314 +++
						ВыборкаПоПунктамДоставки = ВыборкаПоНоменклатурнымМатрицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ПунктДоставки");   // 6
						
						Пока ВыборкаПоПунктамДоставки.Следующий() Цикл
						
							ВыборкаПоМаркировке = ВыборкаПоПунктамДоставки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Маркировка");  // 7
						
							Пока ВыборкаПоМаркировке.Следующий() Цикл
								
								кМаркировка = ?(ВыборкаПоМаркировке.Маркировка = Истина, ", товар маркирован", ", товар без маркировки");
								// Кухарь А.Ю. 26.03.2025 начало
								// ВыборкаНоменклатуры = ВыборкаПоМаркировке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");  // 8

								ВыборкаПоРасходнику=ВыборкаПоМаркировке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Расходник");  
								пока ВыборкаПоРасходнику.Следующий() цикл
									ВыборкаНоменклатуры = ВыборкаПоРасходнику.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");  // 9
									// Кухарь А.Ю. 26.03.2025 конец
									
									
									
									// Кухарь А.Ю. 12.11.2020 конец
									// Шворобей ВЮ 27.10.2022 ++
									//++Данилова Е.В. 19.12.2025  HELP-8278 
									
									МНовДок = СоздатьРНКНаСпособПоставки_Ф11(ВыборкаСпособовПоставки.СпособПоставки,ВыборкаПоПунктамДоставки.ПунктДоставки,
									ВыборкаНоменклатуры,ЕстьРаздел,ЛимПоз,КСпособПоставки + кКоличествоЦветов + кКоличествоКМП,,ложь); 								
									
									Если МНовДок.Количество() Тогда
										Для Каждого НовДок Из МНовДок Цикл
											МассивДокументов.Добавить(НовДок);
											
											МассивДокКМП = СоответствиеКМПРНК.Получить(ВыборкаВидовНоменклатуры.КоличествоКМП);
											Если МассивДокКМП = неопределено Тогда
												
												МассивДокКМП = Новый Массив; 	
												
											КонецЕсли;
											МассивДокКМП.Добавить(НовДок); 
											СоответствиеКМПРНК.Вставить(ВыборкаВидовНоменклатуры.КоличествоКМП,МассивДокКМП); 
											
										КонецЦикла;	
									КонецЕсли;
									// Кухарь А.Ю. 26.03.2025 начало
									// Пустая задача
								КонецЦикла; 
								// Кухарь А.Ю. 26.03.2025 конец
								
							КонецЦикла;
						
						КонецЦикла;
						
					КонецЦикла;
					
				КонецЦикла;
				// Шворобей ВЮ 27.10.2022 ++
			КонецЦикла; 
			// Кухарь А.Ю. 17.02.2022 начало
		КонецЦикла;
		// Кухарь А.Ю. 17.02.2022 конец
		
	КонецЦикла;
	//Данилова Е.В. 19.12.2025 HELP-8278
	//Если ТранзакцияАктивна() Тогда
	//	Если ОткатыватьТранзацию = Истина Тогда
	//		ОтменитьТранзакцию();
	//	Иначе
	//		ЗафиксироватьТранзакцию(); 
	//	КонецЕсли;
	//КонецЕсли;
	// Кухарь А.Ю. 24.05.2024 конец
	
	Возврат Новый Структура("СоответствиеКМПРНК,МассивДокументов",СоответствиеКМПРНК,МассивДокументов);

	
КонецФункции

Функция СоздатьНаборРНКНаНедостающееКоличество_Пред_РНК() 
	//Данилова Е.В. 19.12.2025 HELP-8278 
	//НачатьТранзакцию(); 
	РазбиватьКратноКоробу = ложь; 
	
	МассивДокументов = Новый Массив; 
	
	Запрос = Новый Запрос;
	// Шворобей ВЮ 18.01.2023 ++
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т1.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &РазбиватьКратноКоробу
	|			ТОГДА т1.ШтукВКоробке * т1.МножительДляКороба
	|		ИНАЧЕ т1.Количество
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР
	|		КОГДА т1.КоличествоЦветов = 0
	|			ТОГДА 1
	|		КОГДА &РазбиватьПоКоличествуЦветов
	|			ТОГДА т1.КоличествоЦветов
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК КоличествоЦветов,
	|	ВЫБОР
	|		КОГДА т1.КоличествоКМП = 0
	|			ТОГДА 0
	|		КОГДА &РазбиватьПоКоличествуВСпайке
	|			ТОГДА т1.КоличествоКМП
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК КоличествоКМП,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоСпособуПоставки
	|			ТОГДА т1.СпособПоставки
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СпособПоставкиКонтрагенту.Микс)
	|	КОНЕЦ КАК СпособПоставки,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоНоменклатурнымМатрицам
	|			ТОГДА ЕСТЬNULL(т1.НоменклатурнаяМатрица, ЗНАЧЕНИЕ(Документ.Матрица.ПустаяСсылка))
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.Матрица.ПустаяСсылка)
	|	КОНЕЦ КАК НоменклатурнаяМатрица,
	|	ВЫБОР
	|		КОГДА &РазбиватьПоНоменклатурнымМатрицам
	|			ТОГДА ЕСТЬNULL(т1.НоменклатурнаяМатрица.ПостояннаяАкция, ЛОЖЬ)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПостояннаяАкция,
	|	ВЫБОР
	|		КОГДА &РазбиватьНакладныеПоВидуСпаек
	|				И т1.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВидКомплекта,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(т1.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ЕСТЬNULL(т1.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) < &ТекущаяДата

	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Маркировка
	|ИЗ
	|	(ВЫБРАТЬ
	|		Товары.Номенклатура КАК Номенклатура,
	|		Товары.СпособПоставки КАК СпособПоставки,
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура.Цвет) КАК КоличествоЦветов,
	|		МАКСИМУМ(ЕСТЬNULL(Товары.КОтгрузке, 0)) КАК Количество,
	|		СУММА(ЕСТЬNULL(Комплектующие.Количество, 0)) КАК КоличествоКМП,
	|		МАКСИМУМ(ВЫБОР
	|				КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|					ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|				ИНАЧЕ ВЫБОР
	|						КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|							ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|						ИНАЧЕ 1
	|					КОНЕЦ
	|			КОНЕЦ) КАК ШтукВКоробке,
	|		МАКСИМУМ(ВЫБОР
	|				КОГДА ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ > 0
	|						И ЕСТЬNULL(Товары.КОтгрузке, 0) <> ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ
	|					ТОГДА (ВЫРАЗИТЬ(ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|								КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|									ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|								ИНАЧЕ ВЫБОР
	|										КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|											ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|										ИНАЧЕ 1
	|									КОНЕЦ
	|							КОНЕЦ - 0.5 КАК ЧИСЛО(15, 0))) + 1
	|				ИНАЧЕ ВЫРАЗИТЬ(ЕСТЬNULL(Товары.КОтгрузке, 0) / ВЫБОР
	|							КОГДА Товары.Номенклатура.Родитель.ШтукВКоробке <> 0
	|								ТОГДА Товары.Номенклатура.Родитель.ШтукВКоробке
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|										ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|									ИНАЧЕ 1
	|								КОНЕЦ
	|						КОНЕЦ - 0.5 КАК ЧИСЛО(15, 0))
	|			КОНЕЦ) КАК МножительДляКороба,
	|		Товары.НоменклатурнаяМатрица КАК НоменклатурнаяМатрица
	|	ИЗ
	|		Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК Товары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|			ПО Товары.Номенклатура = Комплектующие.Ссылка
	|				И (Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар))
	|	ГДЕ
	|		Товары.Ссылка = &Ссылка
	|		И Товары.КОтгрузке > 0
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Товары.Номенклатура,
	|		Товары.СпособПоставки,
	|		Товары.НоменклатурнаяМатрица) КАК т1
	|ИТОГИ
	|	СУММА(Количество)
	|ПО
	|	СпособПоставки,
	|	КоличествоЦветов,
	|	КоличествоКМП,
	|	ПостояннаяАкция,
	|	НоменклатурнаяМатрица,
	|	Маркировка,
	|	Номенклатура";
	// Шворобей ВЮ 18.01.2023 ++
	
	Запрос.УстановитьПараметр("РазбиватьКратноКоробу", РазбиватьКратноКоробу);
	Запрос.УстановитьПараметр("РазбиватьПоСпособуПоставки",ложь);
	Запрос.УстановитьПараметр("РазбиватьПоКоличествуВСпайке",Истина);
	Запрос.УстановитьПараметр("РазбиватьПоКоличествуЦветов",Истина);
	// Кухарь А.Ю.  10.09.2024 начало
	//
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	// Кухарь А.Ю.  10.09.2024 конец
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	
	// Кухарь А.Ю. 17.02.2022 конец
	Если Контрагент.Код="SSP-4991" тогда
		Запрос.УстановитьПараметр("РазбиватьПоСпособуПоставки",Ложь);
		Запрос.УстановитьПараметр("РазбиватьПоКоличествуВСпайке",ложь);
	КонецЕсли;
	// Кухарь А.Ю. 26.08.2021 конец
	
	// Шворобей ВЮ 08.07.2024 ++
	Запрос.УстановитьПараметр("РазбиватьНакладныеПоВидуСпаек", Ложь);
	// Шворобей ВЮ 08.07.2024 ++
	
	// Шворобей ВЮ 18.01.2023 ++
	Запрос.УстановитьПараметр("РазбиватьПоНоменклатурнымМатрицам", Истина);
	// Шворобей ВЮ 18.01.2023 ++
	СоответствиеКМПРНК = Новый Соответствие; 
	
	ВыборкаСпособовПоставки=запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"СпособПоставки");   // 1
	Пока ВыборкаСпособовПоставки.Следующий() Цикл
		КСпособПоставки="Поставка";		 
		
		ВыборкаКоличествоЦветов=ВыборкаСпособовПоставки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"КоличествоЦветов");  // 2
		Пока ВыборкаКоличествоЦветов.Следующий() Цикл
			
			кКоличествоЦветов=", количество цветов " + ВыборкаКоличествоЦветов.КоличествоЦветов;
			
			ВыборкаВидовНоменклатуры=ВыборкаКоличествоЦветов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"КоличествоКМП");  // 3
			
			// Кухарь А.Ю. 12.11.2020 начало
			Пока ВыборкаВидовНоменклатуры.Следующий() Цикл
				
				кКоличествоКМП=", количество КМП " + ВыборкаВидовНоменклатуры.КоличествоКМП;
				
				ВыборкаПоПостояннымАкциям = ВыборкаВидовНоменклатуры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ПостояннаяАкция");  // 4
				
				Пока ВыборкаПоПостояннымАкциям.Следующий() Цикл
					
					ВыборкаПоНоменклатурнымМатрицам = ВыборкаПоПостояннымАкциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НоменклатурнаяМатрица");  // 5
					// Кухарь А.Ю. 17.02.2022 конец
					
					Пока ВыборкаПоНоменклатурнымМатрицам.Следующий() Цикл
						
						ВыборкаПоМаркировке = ВыборкаПоНоменклатурнымМатрицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Маркировка");  // 6
						
						Пока ВыборкаПоМаркировке.Следующий() Цикл
							
							кМаркировка = ?(ВыборкаПоМаркировке.Маркировка = Истина, ", товар маркирован", ", товар без маркировки");
							
							ВыборкаНоменклатуры = ВыборкаПоМаркировке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");  // 7
							
							// Кухарь А.Ю. 12.11.2020 конец
							// Шворобей ВЮ 27.10.2022 ++
							
							РНКСозданный = СоздатьРНКНаСпособПоставки_Пред(ВыборкаСпособовПоставки.СпособПоставки,ВыборкаНоменклатуры,КСпособПоставки + кКоличествоЦветов + кКоличествоКМП);
							МассивДокументов.Добавить(РНКСозданный);
							
							МассивДокКМП = СоответствиеКМПРНК.Получить(ВыборкаВидовНоменклатуры.КоличествоКМП);
							Если МассивДокКМП = неопределено Тогда
								
								МассивДокКМП = Новый Массив; 	
								
							КонецЕсли;
							МассивДокКМП.Добавить(РНКСозданный); 
							СоответствиеКМПРНК.Вставить(ВыборкаВидовНоменклатуры.КоличествоКМП,МассивДокКМП);
						КонецЦикла;
						
					КонецЦикла;
					
				КонецЦикла;
				// Шворобей ВЮ 27.10.2022 ++
				// Кухарь А.Ю. 12.11.2020 начало
			КонецЦикла; 
			
		КонецЦикла;
		
	КонецЦикла; 
	//Данилова Е.В. 19.12.2025 HELP-8278
	//Если ТранзакцияАктивна() Тогда
	//	
	//	ЗафиксироватьТранзакцию();
	//Иначе 
	//	ОткатыватьТранзацию = истина; 
	//КонецЕсли;
	
	Возврат Новый Структура("МассивДокументов,СоответствиеКМПРНК",МассивДокументов,СоответствиеКМПРНК); 
КонецФункции 

Функция СоздатьРНКНаСпособПоставки_Пред(СпособПоставки,ВыборкаНоменклатуры,КомментарийРНК="")
	
	// Кухарь А.Ю. 17.02.2022 конец
	
	Рнк = документы.РасходнаяНакладная.СоздатьДокумент();
	Рнк.Контрагент=Контрагент;
	Рнк.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
	// Шворобей ВЮ 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2410
	Рнк.Дата = ТекущаяДатаСеанса();
	// Шворобей ВЮ 10.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396 
	//Рнк.ДатаОтгрузки = Рнк.Дата;
	// Шворобей ВЮ 10.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396 
	// Шворобей ВЮ 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2410
	рнк.ПунктДоставки=ПунктДоставки;
	рнк.Договор=Договор;
