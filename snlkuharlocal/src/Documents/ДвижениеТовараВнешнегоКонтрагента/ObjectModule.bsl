Функция КонтрольПоКолвоРНК(РНКСсыл,ЛимПоз)
	сообщить("Контроль кол-ва "+Строка(РНКСсыл));
	Рез=Новый Структура;
	
	//МасЗак=Новый Массив;
	МасРНК=Новый Массив;
	ЗаписатьВЛог("ВБрзВБО","Начало выполнения. Задача: Контроль колво ВБ.!  ","Информация");
	СостНакл=РНКСсыл.СостояниеНакладной;
	РЗ=РежимЗаписиДокумента.Запись;
	Если РНКСсыл.Проведен Тогда
		РЗ=РежимЗаписиДокумента.Проведение;
	КонецЕсли;	
	Компл=РНКСсыл.ОтгрузкаКомплектов;
	
	ДокРНК=РНКСсыл.ПолучитьОбъект();
	
	
	МасРНК.Добавить(РНКСсыл);
	
	//Рез.Вставить("МасЗак",МасЗак);
	Рез.Вставить("МасРНК",МасРНК);
	
	
	Если Компл Тогда
		ТЗНом1=РНКСсыл.Комплектующие.Выгрузить();
	Иначе
		ТЗНом1=РНКСсыл.Товары.Выгрузить();
	КонецЕсли;
	ТотКол=ТЗНом1.Итог("Количество");
	сообщить("ОКол "+Строка(ТотКол));
	к=ТЗНом1.Количество()-1;
	Если ТотКол<=ЛимПоз Тогда
		сообщить("Контроль кол-ва ок "+Строка(РНКСсыл));
		ЗаписатьВЛог("ВБрзВБО","Контроль кол-ва ок "+Строка(РНКСсыл)+"ОКол "+Строка(ТотКол),"Информация");
		
		//ДокРНК.СостояниеНакладной=СостНакл;
		//ДокРНК.Записать(РЗ);
		//ЗаписатьВЛог("ВБрз","Окончание выполнения. Задача: Контроль остатка ВБ Переведено в состояние КОтправкеНаСклад! 3 позиций менее предельного  ","Информация");
		Возврат Рез;
	КонецЕсли;	
	ЗаписатьВЛог("ВБрзВБО","Контроль кол-ва ок "+Строка(РНКСсыл)+" ОКол "+Строка(ТотКол),"Информация");
	МасНом=Новый Массив;
	НачатьТранзакцию();
	Попытка
		//чтоб не цеплять остатки на др. доки
		Если ДокРНК.Проведен Тогда
			ДокРНК.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
		Если Цел(ТотКол/ЛимПоз)=(ТотКол/ЛимПоз) Тогда
			КолИтер=Цел(ТотКол/ЛимПоз);
		Иначе	
			КолИтер=Цел(ТотКол/ЛимПоз)+1;
		КонецЕсли;	
		//ДокРНК=РНКСсыл.ПолучитьОбъект();
		н=КолИтер-1;
		ТекКол=ТотКол;
		ЛокКол=0;
		Пока н>0 Цикл
			
			//ДокЗак2=Документы.ЗаказКлиентаFBS.СоздатьДокумент();
			//ЗаполнитьЗначенияСвойств(ДокЗак2,ЗаказКФ);
			МасНом.Очистить();
			Пока Истина Цикл
				
				ТекСтр=ТЗНом1.Получить(к);
				ЛокКол=ЛокКол+ТекСтр.Количество;
				Если Компл Тогда
					Если МасНом.Найти(ТекСтр.Продукция)=неопределено Тогда
						МасНом.Добавить(ТекСтр.Продукция);
					КонецЕсли;
				Иначе	
					Если МасНом.Найти(ТекСтр.Номенклатура)=неопределено Тогда
						МасНом.Добавить(ТекСтр.Номенклатура);
					КонецЕсли;	
				КонецЕсли;	
				Если ((ТотКол-ЛокКол)<(ЛимПоз*н)) ИЛИ (к<=0) Тогда
					ЗаписатьВЛог("ВБрзВБО","Контроль кол-ва "+Строка(РНКСсыл)+" ОКол "+Строка(ТотКол)+" ТКол "+Строка(ЛокКол),"Информация");
					Прервать;
				КонецЕсли;
				к=к-1;
			КонецЦикла;
			Если МасНом.Количество() Тогда
				ДокРНК21=Документы.РасходнаяНакладная.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ДокРНК21,ДокРНК);
				// Кухарь А.Ю.  28.03.2024 начало
				если ЗначениеЗаполнено(Договор) тогда
					ДокРНК21.Организация=Договор.Организация; 
				КонецЕсли;
				// Кухарь А.Ю.  28.03.2024 конец
				
				
				ДокРНК21.Товары.Очистить();
				т=ДокРНК.Товары.Количество()-1;
				Пока т>=0 Цикл
					ТекСтр=ДокРНК.Товары.Получить(т);
					Ном=ТекСтр.Номенклатура;
					Если НЕ МасНом.Найти(Ном)=неопределено Тогда
						НовСтр=ДокРНК21.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(НовСтр,ТекСтр);
						ДокРНК.Товары.Удалить(т);
					КонецЕсли;
					т=т-1;
				КонецЦикла;	
				
				
				
				Если Компл Тогда
					ЗаполнитьКомплектующие(ДокРНК21);
				КонецЕсли;
				ДокРНК21.СостояниеНакладной=СостНакл;
				ДокРНК21.Дата=ТекущаяДатаСеанса();
				УстановитьНомерДокументаКлиентСервер(ДокРНК21);
				Если ДокРНК21.Товары.Количество() Тогда
					Попытка
						//ПунктДоставки_ПриИзменении(ДокРНК21.ПунктДоставки,ДокРНК21);
						ДокРНК21.Дата=ТекущаяДата();
						
						ДокРНК21.Комментарий=ДокРНК21.Комментарий+" исх. док-т "+Строка(РНКСсыл);
						ДокРНК21.Записать(РЗ);
					Исключение
						ДокРНК21.Проведен=Ложь;
						ДокРНК21.Записать(РежимЗаписиДокумента.Запись);
					КонецПопытки;
					сообщить("Контроль кол-ва добавляем "+Строка(ДокРНК21.Ссылка));			
					МасРНК.Добавить(ДокРНК21.Ссылка);
					ЗаписатьВЛог("ВБрзВБО","Контроль кол-ва  кол0  "+Строка(ДокРНК.Товары.Количество())+" Кол1 "+Строка(ДокРНК21.Товары.Количество()),"Информация");
				КонецЕсли;
			КонецЕсли;
			н=н-1;
		КонецЦикла;	
		
		Если Компл Тогда
			ЗаполнитьКомплектующие(ДокРНК);
		КонецЕсли;
		
		
		
		ДокРНК.СостояниеНакладной=СостНакл;
		//ДокРНК.Записать(РЗ);
		Попытка
			//ПунктДоставки_ПриИзменении(ДокРНК.ПунктДоставки,ДокРНК);
			ДокРНК.Дата=ТекущаяДата();
			ДокРНК.Записать(РЗ);
		Исключение
			ДокРНК.Проведен=Ложь;
			ДокРНК.Дата=ТекущаяДата();
			ДокРНК.Записать(РежимЗаписиДокумента.Запись);
		КонецПопытки;
		ЗаписатьВЛог("ВБрзВБО","Контроль кол-ва ок кол0  "+Строка(РНКСсыл.Товары.Количество())+" ОКол1 "+Строка(ДокРНК21.Товары.Количество()),"Информация");
		ЗафиксироватьТранзакцию();
	Исключение
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		ЗаписатьВЛог("ВБрзФБО"," !ошибка при формировании документов в ходе контроля кол-ва "+ ОписаниеОшибки(),"Информация");
	КонецПопытки;
	
	
	
	Рез.Вставить("МасРНК",МасРНК);
	Возврат Рез;
КонецФункции	

Процедура ЗаполнитьКомплектующие(РНК)
	
	РНК.Комплектующие.Очистить();
	
	// Кухарь А.Ю.  15.08.2022 начало
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураКоплектующие.Номенклатура КАК Запчасть,
	|	НоменклатураКоплектующие.Номенклатура.НоменклатураЗамены КАК ЗаменаЗапчасти,
	|	НоменклатураКоплектующие.Ссылка КАК Продукция
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка В(&СписокНоменклатуры)";
	запрос.УстановитьПараметр("СписокНоменклатуры",РНК.товары.ВыгрузитьКолонку("Номенклатура"));
	ТаблицаЗамен=запрос.Выполнить().Выгрузить();
	// Кухарь А.Ю.  15.08.2022 конец
	
	
	Для Каждого СтрокаТоваров Из РНК.Товары Цикл	
		
		Если СтрокаТоваров.Количество = 0 Тогда 
			Продолжить 
		КонецЕсли; 
		
		Номенклатура = СтрокаТоваров.Номенклатура;
		
		Если Номенклатура.Коплектующие.Количество() > 0 Тогда
			// комплект
			Для Каждого СтрокаКомплекта Из Номенклатура.Коплектующие Цикл
				Если СтрокаКомплекта.Количество = 0 Тогда 
					Продолжить 
				КонецЕсли; 
				
				СтрокаТЧ = РНК.Комплектующие.Добавить();	
				
				СтрокаТЧ.Продукция		= Номенклатура;
				СтрокаТЧ.Номенклатура	= СтрокаКомплекта.Номенклатура;
				
				// Кухарь А.Ю.  15.08.2022 начало
				СтрокаЗамены=ТаблицаЗамен.Найти(СтрокаТЧ.Номенклатура,"Запчасть");
				если СтрокаЗамены<>Неопределено и ЗначениеЗаполнено(СтрокаЗамены.ЗаменаЗапчасти) тогда
					СтрокаТЧ.Номенклатура	= СтрокаЗамены.ЗаменаЗапчасти;
				КонецЕсли;				
				// Кухарь А.Ю.  15.08.2022 конец
				
				
				ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ, РНК);
				
				СтрокаТЧ.Единица		= СтрокаКомплекта.Единица;
				СтрокаТЧ.Коэффициент	= СтрокаКомплекта.Коэффициент;
				СтрокаТЧ.Количество		= СтрокаКомплекта.Количество * СтрокаТоваров.Количество * СтрокаТоваров.Коэффициент; // и разделить на СтрокаКомплекта.Коэффициент?
				//нечаева 06,03,18+++
				РассчитатьСуммуТабЧасти(СтрокаТЧ, РНК);
				//нечаева 06,03,18---
				
				РНК.ОтгрузкаКомплектов =истина;
				
			КонецЦикла; 
		Иначе			
			// обычный товар
			СтрокаТЧ = РНК.Комплектующие.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТоваров);
			СтрокаТЧ.Продукция = Номенклатура;
		КонецЕсли;
		
	КонецЦикла;	
	
	//нечаева 02,02,21
	Если НЕ РНК.ОтгрузкаКомплектов =истина Тогда
		РНК.Комплектующие.Очистить();
	КонецЕсли;	
	// нечаева 02,02,21 ---
	
	
	
	
	
	
КонецПроцедуры

Процедура ПунктДоставки_ПриИзменении(ПунктДоставки,РНК) Экспорт
	//  19.08.2020 Кухарь конец
	
	
	
	//Кухарь 01.05.18 начало
	//Будем тип доставки фиксировать в документах
	ТипДоставки=ПунктДоставки.ТипДоставки;
	//Кухарь 01.05.18 конец
	
	
	Если НЕ ПунктДоставки.Пустая() Тогда
		
		
		НуженПересчетЦен=Ложь;
		
		Если ЗначениеЗаполнено(ПунктДоставки.Договор)  Тогда
			РНК.Договор=ПунктДоставки.Договор;
			//	РНК.Договор_ПриИзменении(Неопределено);
		КонецЕсли;
		
		//крохин конец 07.04.2011
		
		//доставка
		Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
			РНК.РайонДоставки=ПунктДоставки.РайонДоставки;			
		КонецЕсли;	
		Если ЗначениеЗаполнено(ПунктДоставки.Регион) Тогда
			рнк.Регион=ПунктДоставки.Регион;			
		КонецЕсли;	
		
		если РНК.ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
			Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
				РНК.ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
			иначе
				РНК.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
				РНК.ПунктПерегруза=ПунктДоставки.ПунктПерегруза;
			иначе
				РНК.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
			КонецЕсли;	
		иначе
			РНК.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();	
			РНК.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
		КонецЕсли;
		//Кухарь 26.01.16 конец
		
		Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
			РНК.Грузополучатель=ПунктДоставки.Грузополучатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
			РНК.Получатель=ПунктДоставки.Получатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ПунктДоставки.ОтсрочкаПлатежа) Тогда
			РНК.ОтсрочкаПлатежа=ПунктДоставки.ОтсрочкаПлатежа;		
		КонецЕсли;
		
		//типы цен скидки
		Если ЗначениеЗаполнено(ПунктДоставки.ТипЦен) И РНК.ТипЦен<>ПунктДоставки.ТипЦен Тогда
			РНК.ТипЦен=ПунктДоставки.ТипЦен;		
			РНК.НуженПересчетЦен=Истина;
		КонецЕсли; 
		Если ЗначениеЗаполнено(ПунктДоставки.ТипСкидок) И РНК.ТипСкидок<>ПунктДоставки.ТипСкидок Тогда
			РНК.ТипСкидок=ПунктДоставки.ТипСкидок;		
			РНК.НуженПересчетЦен=Истина;
		КонецЕсли;
		Если ПунктДоставки.Скидка<>0 И ПунктДоставки.Скидка<>РНК.Скидка Тогда
			РНК.Скидка=ПунктДоставки.Скидка;		
			РНК.НуженПересчетЦен=Истина;
		КонецЕсли;
		Если НуженПересчетЦен Тогда
			ПересчетТЧ(РНК,"Товары",РНК.Валюта,РНК.Валюта,РНК.Курс,РНК.Курс,Истина);			
		КонецЕсли;	
		//крохин начало 29.03.2011
		//ставка НДС
		//Если ПунктДоставки.НулеваяСтавкаНДС или Контрагент.НулеваяСтавкаНДС Тогда
		//	РНК.НулеваяСтавкаНДС = Истина;	
		//	НулеваяСтавкаНДСПриИзменении(Неопределено);
		//	//крохин начало 03.10.2012
		//ИначеЕсли НулеваяСтавкаНДС Тогда
		//	НулеваяСтавкаНДС = Ложь;
		//	НулеваяСтавкаНДСПриИзменении(Неопределено);
		//	//крохин конец 03.10.2012
		//КонецЕсли;
		//крохин конец 29.03.2011
		//УстановитьЗаголовокКнопкиЦеныВалюта(ЭтаФорма);
	КонецЕсли; 
	//крохин начало 15.04.2011
	//Доп. обработки, заполняем из пункта доставки, если они там есть
	//Если ДопОбработки.Количество()>0 Тогда
	//	Предупреждение("Доп. обработки будут перезаполнены по умолчанию из карточки контрагента !");
	//КонецЕсли;	
	РНК.ДопОбработки.Очистить();
	Если ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
		Для Каждого СтрокаТЧ Из Контрагент.ВидыДопОбработок Цикл
			СтрокаДО=РНК.ДопОбработки.Добавить();	
			СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
		КонецЦикла;
	Иначе
		Для Каждого СтрокаТЧ Из ПунктДоставки.ВидыДопОбработок Цикл
			СтрокаДО=РНК.ДопОбработки.Добавить();	
			СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
		КонецЦикла;
		
	КонецЕсли;
	//крохин конец 15.04.2011
	//крохин начало 29.04.2011
	КодПоставщикаПунктаДоставки=ПунктДоставки.КодПоставщика;
	Если НЕ КодПоставщикаПунктаДоставки.Пустая() И РНК.КодПоставщика<>КодПоставщикаПунктаДоставки Тогда
		РНК.КодПоставщика=КодПоставщикаПунктаДоставки;
	КонецЕсли; 
	//крохин конец 29.04.2011
	
	//
