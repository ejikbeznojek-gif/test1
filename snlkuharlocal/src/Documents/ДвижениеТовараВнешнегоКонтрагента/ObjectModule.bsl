	Иначе
		
		РезультатСтруктура = СоздатьНаборРНКНаНедостающееКоличество_Пред_РНК();
		
		МассивДокументов 	= РезультатСтруктура.МассивДокументов; 
		СоответствиеКМПРНК 	= РезультатСтруктура.СоответствиеКМПРНК;
		
		//Если ОткатыватьТранзацию<>Истина Тогда
			
		МассивРНКПослеОбъединения = Новый Массив;
		ОшибкаОбъединения = ложь; 
		Для каждого ЭлСоответствия Из  СоответствиеКМПРНК Цикл
			
			МассивРНКДляОб = ЭлСоответствия.Значение;
			ОтгрузкаКомплектов = Ложь; 
			Если ЭлСоответствия.Ключ > 0  Тогда
				
				ОтгрузкаКомплектов = Истина; 	
				
			КонецЕсли;
			РНКСозданные = ОбъединитьРНК(МассивРНКДляОб,ОтгрузкаКомплектов);
			Если РНКСозданные = неопределено Тогда
				
				Сообщить("Ошибка объединения РНК");
				ОшибкаОбъединения = истина; 
				Прервать; 
			Иначе 
				Для каждого НовыйРНК Из  РНКСозданные Цикл
					
					МассивРНКПослеОбъединения.Добавить(НовыйРНК); 	
					
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ОшибкаОбъединения Тогда
			
			МассивДокументов = 	МассивРНКПослеОбъединения; 
			
		КонецЕсли; 
		
		//КонецЕсли;

	КонецЕсли;
	
	Если ОткатыватьТранзацию<>Истина Тогда
	
		Возврат МассивДокументов; 	
	иначе 
		Возврат Неопределено; 
	КонецЕсли;


КонецФункции 

Функция ДобавитьСозданныеРНКВМассивРНК(МассивРНК,СоответствиеРНК1РНК2)
	МассивРНКНовый = МассивРНК; 
	Для каждого РНКСозданный Из МассивРНКНовый Цикл
		
		Если СоответствиеРНК1РНК2.Получить(РНКСозданный) <> неопределено Тогда
			
			МассивРНК.Добавить(СоответствиеРНК1РНК2.Получить(РНКСозданный)); 	
			
		КонецЕсли;
		
	КонецЦикла;

КонецФункции 

Функция ОбъединитьРНК(МассивРНК,ОтгрузкаКомплектов)  	
	//++Данилова Е.В. 19.12.2025 HELP-8278
	Если МассивРНК.Количество() = 0 Тогда
	
		Возврат Новый Массив; 	
	
