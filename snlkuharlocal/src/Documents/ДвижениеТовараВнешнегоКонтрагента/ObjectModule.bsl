
#Область ОписаниеПеременных
Перем СкладДОП;
// Кухарь А.Ю. 24.05.2024 начало
//
 Перем ОткатыватьТранзацию;
// Кухарь А.Ю. 24.05.2024 конец
#КонецОбласти



Процедура ОбработкаПроведения(Отказ, Режим)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Для Каждого ТекСтрокаТовары Из Товары Цикл
		
		Движение = Движения.ОстаткиТМЦВнешние.Добавить();
		Если КодОперации=перечисления.КодыОперацийОстатки.Реализация или НЕ ЗначениеЗаполнено(КодОперации) тогда
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		иначеесли КодОперации=перечисления.КодыОперацийОстатки.Закупка тогда
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		иначеЕсли  КодОперации=перечисления.КодыОперацийОстатки.Реализация тогда
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		иначе
			Сообщить("Некорректный код операции!");Оказ=ИСТИНА;Возврат;
		Конецесли;
		
		Движение.Период = Дата;
		Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
		Движение.Количество = ТекСтрокаТовары.Количество;
		Движение.Сумма = ТекСтрокаТовары.Сумма;
		Движение.Контрагент=Контрагент;
		Движение.ПокупательКонтрагента = ПокупательКонтрагента;
		
	КонецЦикла;
	
КонецПроцедуры

// Кухарь А.Ю. 22.09.2025 начало    
// ASU-2504
//Процедура РасчитатьДанныеПополнения (РасчитыватьТоварыВПути=Истина) экспорт 
Процедура РасчитатьДанныеПополнения (РасчитыватьТоварыВПути=Истина, ДополнительныеПараметры = Неопределено) экспорт 
	// Кухарь А.Ю. 22.09.2025 конец
	
	
	// Кухарь А.Ю. 19.08.2025 начало
	ТекОрганизация = ПолучитьРеквизитШапки(Договор,"Организация","Справочник");
	#Если Клиент тогда
		если не ЗначениеЗаполнено(ТекОрганизация) тогда 
			Сообщить("Не найдена организация по договору");
		КонецЕсли;
	#КонецЕсли  
	
	Запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	ПравилаПополненияСкладовМаркетплейсов.Ссылка КАК Ссылка,
	|	ПравилаПополненияСкладовМаркетплейсов.ДнейТоварногоЗапаса КАК ДнейТоварногоЗапаса,
	|	ПравилаПополненияСкладовМаркетплейсов.КатегорияМаркетПлейсы КАК КатегорияМаркетПлейсы
	|ИЗ
	|	Справочник.ПравилаПополненияСкладовМаркетплейсов КАК ПравилаПополненияСкладовМаркетплейсов
	|ГДЕ
	|	ПравилаПополненияСкладовМаркетплейсов.Контрагент = &Контрагент
	|	И ПравилаПополненияСкладовМаркетплейсов.Организация = &Организация
	|	И не ПравилаПополненияСкладовМаркетплейсов.ПометкаУдаления";     
	запрос.УстановитьПараметр("Организация",ТекОрганизация);  
	запрос.УстановитьПараметр("Контрагент",Контрагент);	
	ТаблицаПравилПоКатегориям = запрос.Выполнить().Выгрузить();
	// Кухарь А.Ю. 19.08.2025 конец
	
	
	ТЗМатрицы=ПолучитьТЗМатриц();   
	если РасчитыватьТоварыВПути тогда

		// Кухарь А.Ю. 22.09.2025 начало  
		// ASU-2504
		//ТЗВПути=ПолучитьТоварыВПути();
		ТЗВПути=ПолучитьТоварыВПути(ДополнительныеПараметры);
		// Кухарь А.Ю. 22.09.2025 конец
		
	КонецЕсли;	
	// Кухарь А.Ю.  09.04.2024 начало
	//	для каждого СтрТЧ из Товары цикл	
	Запрос=новый запрос;
	запрос.Текст="Выбрать * 
	|ПОМЕСТИТЬ ВТ 
	|из 
	|  &ТЗ как Товары 
	|; 
	|Выбрать *
	|, Номенклатура.КатегорияМаркетПлейсы как КатегорияМаркетПлейсы      
	|,Номенклатура.Родитель.ШтукВКоробке как ШтукВКоробкеИзНоменклатуры 
	|из ВТ как ВремТЗ";
	запрос.УстановитьПараметр("ТЗ",Товары);
	ТЗТовары=запрос.Выполнить().Выгрузить();
	для каждого СтрТЧ из ТЗТовары цикл
		// Кухарь А.Ю.  09.04.2024 конец
		
		// Кухарь А.Ю.  17.01.2024 начало
		если СтрТЧ.Количество>0 Тогда
			СтрТЧ.ОборачиваемостьВДнях=30*СтрТЧ.ОстатокКонтрагента/(СтрТЧ.Количество); 
		иначе
			СтрТЧ.ОборачиваемостьВДнях=0;
		КонецЕсли;
		// Кухарь А.Ю.  17.01.2024 конец
		
		Номенклатура=СтрТЧ.Номенклатура;
		СтрМатрицы=ТЗМатрицы.найти(Номенклатура);
		если РасчитыватьТоварыВПути тогда
			СтрВПути=ТЗВПути.найти(Номенклатура);
			Если СтрВПути=Неопределено тогда
				СтрТЧ.ВПути=0;
			иначе
				СтрТЧ.ВПути=СтрВПути.Количество;
			КонецЕсли;
		КонецЕсли;
		
		если СтрМатрицы=Неопределено тогда
			СтрТЧ.НедостающееКоличество=0;
			СтрТЧ.КОтгрузке=0;
			СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Микс;
			Продолжить;		
		иначе					
			//Михайловский С. 20230314 +++
			СтрТЧ.ПунктДоставки=СтрМатрицы.ПунктДоставки;
			//Михайловский С. 20230314 ---
			
			если СтрМатрицы.МинимальныйОстатокВДнях=0 и СтрТЧ.КоличествоПлан = 0 тогда
				СтрТЧ.НедостающееКоличество=0;
				СтрТЧ.КОтгрузке=0;
				//СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Микс;
				Продолжить;
			иначе			
			КонецЕсли;	
			ЗаполнитьЗначенияСвойств(СтрТЧ,СтрМатрицы);
		КонецЕсли;		
		
		если не ЗначениеЗаполнено(СтрТЧ.СпособПоставки) тогда
			СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Микс;
		КонецЕсли;             
		
		//Кухарь А.Ю. 01.08.2025 начало
		//HELP-6284 
		если СтрТЧ.КоличествоПлан>0 тогда      
			если ЗначениеЗаполнено(СтрТЧ.КатегорияМаркетПлейсы) тогда   
				Категория=СтрТЧ.КатегорияМаркетПлейсы;
			Иначе
				Категория=Неопределено;
			КонецЕсли;             
			
			
			
			// Кухарь А.Ю. 19.08.2025 начало  
			//если Категория = Перечисления.КатегорииABC.A тогда
			//	КоличествоДнейПоКатегории = 30;
			//ИначеЕсли Категория = Перечисления.КатегорииABC.B тогда 
			//	КоличествоДнейПоКатегории = 21;   
			//ИначеЕсли Категория = Перечисления.КатегорииABC.C тогда 
			//	КоличествоДнейПоКатегории = 14;			
			//Иначе  
			//	КоличествоДнейПоКатегории = 0;  
			//КонецЕсли;     
			СтрокаПравилКатегории = ТаблицаПравилПоКатегориям.Найти(Категория,"КатегорияМаркетПлейсы");
			если СтрокаПравилКатегории = Неопределено тогда  
				КоличествоДнейПоКатегории = 0;
			иначе 
				КоличествоДнейПоКатегории = СтрокаПравилКатегории.ДнейТоварногоЗапаса
			КонецЕсли;			 
			// Кухарь А.Ю. 19.08.2025 конец
			
			
			СтрТЧ.НедостающееКоличество=Макс(0,КоличествоДнейПоКатегории*(СтрТЧ.КоличествоПлан/30)-СтрТЧ.ВПути-СтрТЧ.ОстатокКонтрагента);   
			
			ШтукВКоробке =СтрМатрицы.КратностьКоробки;
			если ШтукВКоробке = 0 тогда
				ШтукВКоробке = СтрТЧ.ШтукВКоробкеИзНоменклатуры;
			КонецЕсли;

			
			если СтрТЧ.НедостающееКоличество>0 и ШтукВКоробке > 0 тогда  
				КолТары=СтрТЧ.НедостающееКоличество/ШтукВКоробке;
				если Цел(КолТары)<>КолТары тогда
					КолТары=Цел(КолТары)+1;
				КонецЕсли;   
				СтрТЧ.КОтгрузке=КолТары*ШтукВКоробке; 
				
				// Кухарь А.Ю. 22.09.2025 начало
				// ASU-2504
				если СтрТЧ.КОтгрузке>0 тогда
					если ШтукВКоробке>0 тогда
						СтрТЧ.КоробокКОтгрузке=СтрТЧ.КОтгрузке/ШтукВКоробке;
					КонецЕсли;
				КонецЕсли;			
				// Кухарь А.Ю. 22.09.2025 конец
				
		
			иначе
				СтрТЧ.КОтгрузке=0;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		//Кухарь А.Ю.  01.08.2025 конец
		
		
		
		// Кухарь А.Ю. 13.10.2020 начало
		//Некоторые позиции только начали продаваться, и средние продажи на основании 2 недель будут некорректны
		// СреднийРасход=СтрТЧ.Количество/КоличествоДнейПродаж;	
		если СтрТЧ.ДнейПродажИзФайла>0 и СтрТЧ.ДнейПродажИзФайла<КоличествоДнейПродаж тогда
			ДнейПродаж=СтрТЧ.ДнейПродажИзФайла;
		иначе
			ДнейПродаж=КоличествоДнейПродаж;
		КонецЕсли;
		
		если ДнейПродаж>0 тогда
			СреднийРасход=СтрТЧ.Количество/ДнейПродаж;
		иначе
			СреднийРасход=0;
		КонецЕсли;
		// Кухарь А.Ю. 13.10.2020 конец
		
		
		ТребуемоеКоличество=СтрМатрицы.МинимальныйОстатокВДнях*СреднийРасход;			
		НужноПополнить=ТребуемоеКоличество-СтрТЧ.ОстатокКонтрагента;
		
		// Кухарь А.Ю. 28.02.2023 начало
		// Наталья попросила сделать, чтобы если была продажа и товара на остатках < 5, то умножалось на 1.3
		если  СтрТЧ.ОстатокКонтрагента<5 тогда
			НужноПополнить=Окр(НужноПополнить*1.3,0);
		КонецЕсли;
		// Кухарь А.Ю. 28.02.2023 конец
		
		// Кухарь А.Ю. 08.10.2020 начало
		// Иногда товар давно не поставлялся, тогда в файле его нет а в матрицах есть. Будем отгружать 1 коробку
		если СреднийРасход=0 и СтрТЧ.ОстатокКонтрагента=0 и СтрМатрицы.МинимальныйОстатокВДнях>0 тогда
			СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноКороб;
			НужноПополнить=СтрМатрицы.КратностьКоробки;
		КонецЕсли;
		// Кухарь А.Ю. 08.10.2020 конец
		
		СтрТЧ.НедостающееКоличество=Макс(0,НужноПополнить-СтрТЧ.ВПути);
		СтрТЧ.КОтгрузке=СтрТЧ.НедостающееКоличество;
		
		
		
		
		
		//Кухарь А.Ю. 21.09.2023 начало
		//если СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноПаллета и СтрМатрицы.КратностьПаллеты>1 тогда
		если СтрТЧ.СпособПоставки =Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула тогда 
			// Кухарь А.Ю.  22.11.2023 начало
			//
			если СтрМатрицы.КратностьПаллеты=0 тогда
				Сообщить("Пустая кратность паллеты у "+СтрТЧ.Номенклатура);
				Продолжить;
			КонецЕсли;
			// Кухарь А.Ю.  22.11.2023 конец
			
			КолТары=СтрТЧ.НедостающееКоличество/СтрМатрицы.КратностьПаллеты;
			
			если КолТары>0.33333 тогда
				//СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноПаллета;
				СтрТЧ.КОтгрузке=СтрМатрицы.КратностьПаллеты/3;
				//++Данилова Е.В. 17.06.2026 №0000000008
				//СообщитьИзМодуля(СтрШаблон("У %1, количество больше 0.33 паллета, количество уменьшено до 0.33 паллеты",СтрТЧ.Номенклатура));
				Сообщить(СтрШаблон("У %1, количество больше 0.33 паллета, количество уменьшено до 0.33 паллеты",СтрТЧ.Номенклатура)); 
				//--Данилова Е.В. 17.06.2026 
			иначе
				если Цел(КолТары)<>КолТары тогда
					КолТары=Цел(КолТары)+1;
					СтрТЧ.КОтгрузке=КолТары*СтрМатрицы.КратностьПаллеты/3;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		//Кухарь А.Ю. 21.09.2023 конец
		
		если (СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноПаллета или СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Монопаллета120)  и СтрМатрицы.КратностьПаллеты>1 тогда
			//Кухарь А.Ю. 21.09.2023 конец	
			
			// Кухарь А.Ю.  22.11.2023 начало
			//
			если СтрМатрицы.КратностьПаллеты=0 тогда
				Сообщить("Пустая кратность паллеты у "+СтрТЧ.Номенклатура);
				Продолжить;
			КонецЕсли;
			// Кухарь А.Ю.  22.11.2023 конец
			
			КолТары=СтрТЧ.НедостающееКоличество/СтрМатрицы.КратностьПаллеты;
			если Цел(КолТары)<>КолТары тогда
				КолТары=Цел(КолТары)+1;
				СтрТЧ.КОтгрузке=КолТары*СтрМатрицы.КратностьПаллеты;
			КонецЕсли;
			
		КонецЕсли;	
		
		если СтрТЧ.ШтукВКоробкеИзНоменклатуры=0 тогда
			Сообщить(СтрШаблон("У номенклатуры %1 пустое количество штук в коробке в карточке.",СтрТЧ.Номенклатура));
		КонецЕсли;
		 
		
		
		КратностьОкругления=0;
		
		// Кухарь А.Ю.  17.10.2023 начало
		если СтрТЧ.СпособПоставки<>Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула и СтрМатрицы.ШтукВКоробкеИзНоменклатуры<>0 тогда 
			// Кухарь А.Ю.  17.10.2023 конец
			
			если Контрагент.Код="SSP-4991" тогда
				КратностьОкругления=5;
				
				// Кухарь А.Ю.  09.04.2024 начало
				//
				// Кухарь А.Ю.  06.08.2024 начало
				//ИначеЕсли Контрагент.Код="SSR-9059"  тогда 
			ИначеЕсли Контрагент.Код="SSR-9059" или Контрагент.Код="SST-1208"  тогда 
				
				
				// Кухарь А.Ю.  06.08.2024 конец
				
				// Кухарь А.Ю.  09.04.2024 конец
				
				КратностьОкругления=10;				
			КонецЕсли;
			
			// Кухарь А.Ю.  17.10.2023 начало
			//
		иначе
			КратностьОкругления=СтрМатрицы.ШтукВКоробкеИзНоменклатуры;
		КонецЕсли; 
		// Кухарь А.Ю.  17.10.2023 конец
		
		
		// Кухарь А.Ю.  09.04.2024 начало
		 
		// Кухарь А.Ю.  06.08.2024 начало
		// если Контрагент.Код= "SSR-9059" 
		если (Контрагент.Код= "SSR-9059" или Контрагент.Код= "SST-1208")
		// Кухарь А.Ю.  06.08.2024 конец			
			и СтрТЧ.СпособПоставки<>Перечисления.СпособПоставкиКонтрагенту.МоноПаллета
			и СтрТЧ.СпособПоставки<>Перечисления.СпособПоставкиКонтрагенту.Монопаллета120
			тогда
			//// Кухарь А.Ю.  17.04.2024 начало
			////
			//	Продолжить;		 
			//// Кухарь А.Ю.  17.04.2024 конец
			

		КонецЕсли;
		// Кухарь А.Ю.  09.04.2024 конец
			
		если КратностьОкругления>0 тогда
			КолТары=СтрТЧ.КОтгрузке/КратностьОкругления;
			если Цел(КолТары)<>КолТары тогда
				КолТары=Цел(КолТары)+1;
				СтрТЧ.КОтгрузке=КолТары*КратностьОкругления;
			КонецЕсли;		
		КонецЕсли;
		// Кухарь А.Ю. 12.10.2022 конец	
		
		
		// Кухарь А.Ю.  25.10.2022 начало
		// Увеличение количества от коэффициента установленного вручную
		если КоэффициентУвеличения=0 тогда
			КоэффициентУвеличения=1;
		КонецЕсли;
		
		//Кухарь А.Ю. 21.09.2023 начало
		//СтрТЧ.КОтгрузке = СтрТЧ.КОтгрузке*КоэффициентУвеличения;
		
		если СтрТЧ.СпособПоставки<>Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула тогда
			СтрТЧ.КОтгрузке = СтрТЧ.КОтгрузке*КоэффициентУвеличения;
		КонецЕсли;
		// Кухарь А.Ю.  25.10.2022 конец
		
		
		// Кухарь А.Ю. 26.08.2021 начало
		если не ЗначениеЗаполнено(СтрТЧ.СпособПоставки) тогда
			СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Микс
		КонецЕсли;
		// Кухарь А.Ю. 26.08.2021 конец 		
		
		// Кухарь А.Ю. 12.03.2021 начало
		// Количество коробов теперь реквизит ТЧ
		если СтрТЧ.КОтгрузке>0 тогда
			ШтукВКоробе=СтрМатрицы.КратностьКоробкиИзНоменклатуры;
			если ШтукВКоробе>0 тогда
				СтрТЧ.КоробокКОтгрузке=СтрТЧ.КОтгрузке/ШтукВКоробе;
			КонецЕсли;
		КонецЕсли;
		// Кухарь А.Ю. 12.03.2021 конец
		
		
		Если СтрТЧ.ШтукВКоробкеИзНоменклатуры>0 и (СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноКороб 
			или СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноПаллета 
			или СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.Монопаллета120)  
			тогда
			
			КолТары=СтрТЧ.НедостающееКоличество/СтрТЧ.ШтукВКоробкеИзНоменклатуры;
			
			если Цел(КолТары)<>КолТары тогда
				КолТары=Цел(КолТары)+1;		
				СтрТЧ.КОтгрузке=КолТары*СтрМатрицы.ШтукВКоробкеИзНоменклатуры;	
				
				// Кухарь А.Ю.  29.08.2024 начало
				СтрТЧ.КОтгрузке=СтрТЧ.КОтгрузке*КоэффициентУвеличения; 
				// Кухарь А.Ю.  29.08.2024 конец
				
			КонецЕсли;		
		КонецЕсли;	
		
		
	КонецЦикла;
	
	
	// Кухарь А.Ю.  09.04.2024 начало
	товары.Загрузить(ТЗТовары);	 
	// Кухарь А.Ю.  09.04.2024 конец
	

	
	
	РасчитатьМиксПаллеты();
	
	
КонецПроцедуры

// Кухарь А.Ю.  26.09.2023 начало
