Процедура РасчитатьМиксПаллеты()
	
	//Перем ВремТЗ, ВыборкаКоличествоКомплектующих, ВыборкаКоличествоЦветов, ВыборкаКратностьПаллеты, ВыборкаНоменклатура, ВыборкаНоменклатурнаяМатрица, ВыборкаПостояннаяАкция, ВыборкаПунктДоставки, Запрос, КолТары, МассивМикса, МассСтрок, СтрМасс, СтрТЧ;
	
	//Кухарь А.Ю. 21.09.2023 начало
	ВремТЗ=товары.Выгрузить(,"Номенклатура,КратностьПаллеты,СпособПоставки,КОтгрузке,ПунктДоставки,НоменклатурнаяМатрица");
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ТЗ.Номенклатура КАК Номенклатура,
	|	ТЗ.СпособПоставки КАК СпособПоставки,
	|	ТЗ.КратностьПаллеты КАК КратностьПаллеты,
	|	ТЗ.КОтгрузке КАК КОтгрузке,
	|	ТЗ.ПунктДоставки КАК ПунктДоставки,
	|	ТЗ.НоменклатурнаяМатрица КАК НоменклатурнаяМатрица
	|ПОМЕСТИТЬ ВремТЗ
	|ИЗ
	|	Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗСКМП.Номенклатура КАК Номенклатура,
	|	ТЗСКМП.Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробкеИзНоменклатуры
	|ИЗ
	|	ВремТЗ КАК ТЗСКМП
	|ГДЕ
	|	ТЗСКМП.СпособПоставки = &СпособПоставки
	|	И ТЗСКМП.КратностьПаллеты > 0
	|	И ТЗСКМП.КОтгрузке > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура ИЕРАРХИЯ";
	запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК ТЗ","&ТЗ как ТЗ");
	запрос.УстановитьПараметр("ТЗ",ВремТЗ);
	запрос.УстановитьПараметр("СпособПоставки",Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула);
	
	ТЗ=запрос.Выполнить().выгрузить();
	МассивМикса=новый Массив;			
	
	
	КоличествоСтрок=ТЗ.Количество();
	КоличествоСтрокНеКратное3=КоличествоСтрок-3*Цел(КоличествоСтрок/3);
	Если КоличествоСтрокНеКратное3>0 тогда
		НачальнаяСтрокаЛишнегоТовара=КоличествоСтрок-КоличествоСтрокНеКратное3;
		Для сч=НачальнаяСтрокаЛишнегоТовара по КоличествоСтрок-1 цикл
			Номенклатура=ТЗ.Получить(сч).номенклатура;
			//++Данилова Е.В. 17.06.2026 №0000000008
			//СообщитьИзМодуля("У "+Номенклатура+" не нашлось группы для формирования микса"); 
			Сообщить("У "+Номенклатура+" не нашлось группы для формирования микса"); 
			//--Данилова Е.В. 17.06.2026 
			МассСтрок=Товары.НайтиСтроки(новый Структура("Номенклатура,СпособПоставки",Номенклатура,Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула));
			для каждого СтрТЧ из МассСтрок цикл
				СтрТЧ.СпособПоставки=Перечисления.СпособПоставкиКонтрагенту.МоноПаллета;
				КолТары=СтрТЧ.НедостающееКоличество/СтрТЧ.КратностьПаллеты;
				если Цел(КолТары)<>КолТары тогда
					КолТары=Цел(КолТары)+1;
					СтрТЧ.КОтгрузке=КоэффициентУвеличения*КолТары*СтрТЧ.КратностьПаллеты;
				КонецЕсли;
			КонецЦикла;	
		КонецЦикла;
	иначе
		НачальнаяСтрокаЛишнегоТовара=КоличествоСтрок;
	КонецЕсли;
	
	сч=0;
	Для каждого ВыборкаНоменклатура из ТЗ цикл
		если сч=НачальнаяСтрокаЛишнегоТовара тогда
			Прервать;
		КонецЕсли;
		
		
		МассСтрок=Товары.НайтиСтроки(новый Структура("Номенклатура,СпособПоставки",ВыборкаНоменклатура.Номенклатура,Перечисления.СпособПоставкиКонтрагенту.МиксПаллеты3Артикула));
		для каждого СтрТЧ из МассСтрок цикл
			КолТары=СтрТЧ.НедостающееКоличество/СтрТЧ.КратностьПаллеты;
			если КолТары>0.333 или КолТары <0.3 тогда											
				
				СтараяОтгрузка=СтрТЧ.КОтгрузке;
				СтрТЧ.КОтгрузке=СтрТЧ.КратностьПаллеты/3;								
				КратностьОкругления=ВыборкаНоменклатура.ШтукВКоробкеИзНоменклатуры;
				если КратностьОкругления>0 тогда
					КолТары=СтрТЧ.КОтгрузке/КратностьОкругления;
					если Цел(КолТары)<>КолТары тогда
						КолТары=Цел(КолТары)+1;
						СтрТЧ.КОтгрузке=КолТары*КратностьОкругления;
					КонецЕсли;	
				КонецЕсли;
				если СтараяОтгрузка<>СтрТЧ.КОтгрузке тогда
					//++Данилова Е.В. 17.06.2026 №0000000008
					//СообщитьИзМодуля(СтрШаблон("У %1, количество больше 0.33 паллета, количество изменено на %2",ВыборкаНоменклатура.Номенклатура,СтрТЧ.КОтгрузке));
					Сообщить(СтрШаблон("У %1, количество больше 0.33 паллета, количество изменено на %2",ВыборкаНоменклатура.Номенклатура,СтрТЧ.КОтгрузке)); 
					//--Данилова Е.В. 17.06.2026 
				КонецЕсли;
			КонецЕсли;									
		КонецЦикла;
		сч=сч+1;
	КонецЦикла;
	
	
КонецПроцедуры

