Функция СоздатьНаборРНКСОбъединением() Экспорт 

	НастройкиДляСозданияРНК  = ПолучитьНастройкиИзИнтернетМагазина();
	
	Если НастройкиДляСозданияРНК.СоздаватьПодсортировкиFBO Тогда
		
		РезультатСтруктура = СоздатьНаборРНКПоКоличествуШтукВСпайке(НастройкиДляСозданияРНК);
		МассивДокументов = РезультатСтруктура.МассивДокументов; 
		СоответствиеКМПРНК = РезультатСтруктура.СоответствиеКМПРНК; 
		СоответствиеРНК1РНК2 = Новый Соответствие; 
		//Если ОткатыватьТранзацию<>Истина тогда 
		//++Данилова Е.В. 19.12.2025 HELP-8278 
		//Сооб = ""; 
		//Для Каждого Документ Из МассивДокументов Цикл
		//	ДокументРНКСозданный = Неопределено; 
		//	Сооб = Сооб+ОбработатьРНК(Документ,НастройкиДляСозданияРНК.Склады, "РНК",ДокументРНКСозданный) + Символы.ПС; 
		//	Если ДокументРНКСозданный <> Неопределено Тогда
		//		
		//		СоответствиеРНК1РНК2.Вставить(Документ,ДокументРНКСозданный); 	
		//		
		//	КонецЕсли;
		//КонецЦикла;	
		//Сообщить(Сооб);
		//--Данилова Е.В. 19.12.2025
		//Если ОткатыватьТранзацию<>Истина Тогда
		
		МассивРНКПослеОбъединения = Новый Массив;
		ОшибкаОбъединения = ложь; 
		Для каждого ЭлСоответствия Из  СоответствиеКМПРНК Цикл
			
			МассивРНКДляОб = ЭлСоответствия.Значение;
			//++Данилова Е.В. 19.12.2025 HELP-8278
			//ДобавитьСозданныеРНКВМассивРНК(МассивРНКДляОб,СоответствиеРНК1РНК2);
			//--Данилова Е.В. 19.12.2025 
			ОтгрузкаКомплектов = Ложь; 
			Если ЭлСоответствия.Ключ > 0  Тогда
				
				ОтгрузкаКомплектов = Истина; 	
				
			КонецЕсли;
			РНКСозданные = ОбъединитьРНК(МассивРНКДляОб,ОтгрузкаКомплектов);
			Если РНКСозданные = неопределено Тогда
				
				Сообщить("Ошибка объединения РНК");
				ОшибкаОбъединения = истина; 
				Прервать; 
			Иначе 
				Для каждого НовыйРНК Из  РНКСозданные Цикл
					
					МассивРНКПослеОбъединения.Добавить(НовыйРНК); 	
					
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ОшибкаОбъединения Тогда
			
			МассивДокументов = 	МассивРНКПослеОбъединения; 
			
		КонецЕсли; 
		
		//КонецЕсли;
		//КонецЕсли;  
		//
	ИначеЕсли НастройкиДляСозданияРНК.РазбиватьНакладныеПоВидуСпаек Тогда  
		
