		|				ТОГДА НакладнаяТовары.Номенклатура В ИЕРАРХИИ (&ГруппаБелье)
		|			ИНАЧЕ НЕ НакладнаяТовары.Номенклатура В ИЕРАРХИИ (&ГруппаБелье)
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	НакладнаяТовары.Номенклатура";
		
		ТекстЗапросаN = СтрЗаменить(ТекстЗапросаN,"ВТТоварыN", "ВТТовары" + Строка(НомерРНК1));		
		ТекстЗапроса = ТекстЗапроса + ТекстЗапросаN; 
		 
