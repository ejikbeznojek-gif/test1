		|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.Контрагент = &Контрагент";
		Запрос.УстановитьПараметр("Контрагент", Ссылка.Контрагент);
		ТЗ=Запрос.Выполнить().Выгрузить();
		Если ТЗ.Количество() Тогда
			Рез.Вставить("Разбивка",ТЗ[0].СоздаватьПодсортировкиFBO);
			Рез.Вставить("Склады",ТЗ.ВыгрузитьКолонку("Склад"));
		КонецЕсли;	
	Исключение
	КонецПопытки;
	Возврат Рез;
КонецФункции	
