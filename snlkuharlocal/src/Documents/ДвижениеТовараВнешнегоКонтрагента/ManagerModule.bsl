// Кухарь А.Ю. 26.03.2025 начало

Процедура ВыделитьКоличествоИзНакладной(Знач РНК,Лимит,МассивДокументов) экспорт

	РНКСтарая=РНК.ПолучитьОбъект();
	ПараметрыСеанса.ЗапущенаОбработка=Истина;
	
	ТаблицаТоваровДляНовойРНК=РНКСтарая.Товары.Выгрузить();
	ТаблицаТоваровДляНовойРНК.Очистить();
	ВремТЗ=ТаблицаТоваровДляНовойРНК.Скопировать();
	
	для каждого СтрТЧ из РНКСтарая.Товары цикл
		если СтрТЧ.Количество=0 тогда Продолжить;КонецЕсли;
		Коэффициент=СтрТЧ.КоличествоКомплектующих/СтрТЧ.Количество;
		если СтрТЧ.КоличествоКомплектующих> Лимит тогда
			КоличествоПорций=СтрТЧ.КоличествоКомплектующих/Лимит;
			если Цел(КоличествоПорций)<>КоличествоПорций тогда
				КоличествоПорций=Цел(КоличествоПорций)+1;
			КонецЕсли;	
			ОсталосьРаспределить=СтрТЧ.КоличествоКомплектующих;
			пока ОсталосьРаспределить>0 цикл
				СтрокаТаблицы=ТаблицаТоваровДляНовойРНК.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы,СтрТЧ);	
				СтрокаТаблицы.КоличествоКомплектующих=Мин(Лимит,ОсталосьРаспределить);
				СтрокаТаблицы.Количество=СтрокаТаблицы.КоличествоКомплектующих/Коэффициент;
				ОсталосьРаспределить=ОсталосьРаспределить-Лимит;
			КонецЦикла;
		иначе
			СтрокаТаблицы=ТаблицаТоваровДляНовойРНК.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы,СтрТЧ);		
		КонецЕсли;
		
	КонецЦикла;	
	
	ТаблицаТоваровДляНовойРНК.Сортировать("Количество Убыв");
	ТекущееКоличество=0;
	сч=1;
	ЛимитЭтойНакладнойВыбран=ложь;
	
	КоличествоСТрок=ТаблицаТоваровДляНовойРНК.Количество();
	для каждого СтрТЗ из ТаблицаТоваровДляНовойРНК цикл
		Коэффициент=СтрТЗ.КоличествоКомплектующих/СтрТЗ.Количество;

		если сч=КоличествоСтрок  тогда  
			ВремСтр=ВремТЗ.Добавить();
			ЗаполнитьЗначенияСвойств(ВремСтр,СтрТЗ);	
			ВремСтр.Количество=СтрТЗ.количество;				
			СоздатьРНКНаВыделяемоеКоличество(ВремТЗ,не ЛимитЭтойНакладнойВыбран,РНК,МассивДокументов);
			Продолжить;;
		КонецЕсли;
		
		если СтрТЗ.КоличествоКомплектующих = Лимит тогда
			ВремСтр=ВремТЗ.Добавить();
			ЗаполнитьЗначенияСвойств(ВремСтр,СтрТЗ);	
			ВремСтр.Количество=СтрТЗ.количество;			
			СоздатьРНКНаВыделяемоеКоличество (ВремТЗ,не ЛимитЭтойНакладнойВыбран,РНК,МассивДокументов);
			ВремТЗ.Очистить();
			ЛимитЭтойНакладнойВыбран=Истина;
			сч=сч+1;
			Продолжить;
		КонецЕсли;
		ВремСтр=ВремТЗ.Добавить();
		ЗаполнитьЗначенияСвойств(ВремСтр,СтрТЗ);	
		
		ТекущееКоличество=ТекущееКоличество+СтрТЗ.КоличествоКомплектующих;
		БудущееКоличество=ТекущееКоличество+ТаблицаТоваровДляНовойРНК.Получить(сч).КоличествоКомплектующих;
		если БудущееКоличество>Лимит тогда
			СоздатьРНКНаВыделяемоеКоличество(ВремТЗ,не ЛимитЭтойНакладнойВыбран,РНК,МассивДокументов);
			ВремТЗ.Очистить();
			ЛимитЭтойНакладнойВыбран=Истина;
			ТекущееКоличество=0;
		КонецЕсли;	
		
		сч=сч+1;	
	КонецЦикла;
	//ЗафиксироватьТранзакцию();
	ПараметрыСеанса.ЗапущенаОбработка=Ложь;

КонецПроцедуры

Процедура СоздатьРНКНаВыделяемоеКоличество (ТаблицаТоваровДляНовойРНК, ИспользоватьСтаруюРНК,РНК,МассивДокументов) экспорт
	
	если ИспользоватьСтаруюРНК тогда
		РНКНовая=РНК.ПолучитьОбъект();
	иначе
		РНКНовая=документы.РасходнаяНакладная.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(РНКНовая,РНК,,"Номер");
		РНКНовая.Дата=ТекущаяДата();
		УстановитьНомерДокументаКлиентСервер(РНКНовая); 
		
		РНКНовая.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
	КонецЕсли;
	РНКНовая.Товары.Загрузить(ТаблицаТоваровДляНовойРНК);
	для каждого СтрТЧ из РНКНовая.Товары цикл
		РассчитатьСуммуТабЧасти(СтрТЧ, РНКНовая);
	КонецЦикла;

	ЗаполнениеДокументов.ЗаполнитьТЧКомплектующие(РНКНовая); 
	МаркировкаКС.ЗаполнитьТабличныеЧастиПризнакомМаркировки(РНКНовая);	
	РНКНовая.Записать(РежимЗаписиДокумента.Запись);
	если не ИспользоватьСтаруюРНК тогда
		МассивДокументов.добавить(РНКНовая.Ссылка);
	КонецЕсли;
	Сообщить(""+РНКНовая);
КонецПроцедуры
 
