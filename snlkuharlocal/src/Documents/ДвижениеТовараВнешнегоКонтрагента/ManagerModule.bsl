Функция ПодготовитьИсходныеДанныеДляЗаявкиНаПерепаковку(ДокСсылка, ПорогЗакрытия = 50000, НадоРазбивать = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Контрагент", ДокСсылка.Контрагент);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка КАК Ссылка,
	|	ИнетМагазиныСкладыПодсортировкиFBO.Склад КАК Склад,
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.РазбиватьПоЛимитуКоличество1 КАК НадоРазбивать,
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.ЛимитПоКоличеству1 КАК ПорогЗакрытия
	|ИЗ
	|	Справочник.ИнетМагазины.СкладыПодсортировкиFBO КАК ИнетМагазиныСкладыПодсортировкиFBO
	|ГДЕ
	|	ИнетМагазиныСкладыПодсортировкиFBO.Ссылка.Контрагент = &Контрагент
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗ = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТЗ.Количество() Тогда
		ПорогЗакрытия = ТЗ[0].ПорогЗакрытия;
		НадоРазбивать = ТЗ[0].НадоРазбивать;
		МассивСкладов = ТЗ.ВыгрузитьКолонку("Склад");
	Иначе
		МассивСкладов = Новый Массив;
		МассивСкладов.Добавить(Справочники.Склады.НайтиПоКоду("STC-60"));
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////
	
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("Склад", МассивСкладов.Получить(0));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Товары.НомерСтроки) КАК НомерСтроки,
	|	МАКСИМУМ(ЕСТЬNULL(ОстаткиТМЦОстатки.Склад, &Склад)) КАК Склад,
	|	СУММА(ЕСТЬNULL(Товары.Количество, 0)) КАК КоличествоИсх,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК СвободныйОстаток,
	|	СУММА(ЕСТЬNULL(Товары.Количество, 0) - (ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0))) КАК НужноеКоличество,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке <> 0
	|				ТОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|						ТОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) КАК ШтукВКоробке,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте <> 0
	|				ТОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте <> 0
	|						ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) КАК ШтукВКомплекте,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура) КАК КоличествоСтрочек,
	|	МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 1)) КАК Кратность,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке <> 0
	|				ТОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|						ТОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) * КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура) / МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 1)) КАК КратностьКоробаСпайки,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке <> 0
	|				ТОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|						ТОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) * КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура) / МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 1)) / МАКСИМУМ(ВЫБОР
	|			КОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте <> 0
	|				ТОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте <> 0
	|						ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) КАК КоличествоПоКратности,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке <> 0
	|				ТОГДА Комплектующие.Номенклатура.Родитель.ШтукВКоробке
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|						ТОГДА Комплектующие.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) * КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Комплектующие.Номенклатура) / МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 1)) / МАКСИМУМ(ВЫБОР
	|			КОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте <> 0
	|				ТОГДА Товары.Номенклатура.Родитель.ШтукВКомплекте
	|			ИНАЧЕ ВЫБОР
	|					КОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте <> 0
	|						ТОГДА Товары.Номенклатура.Родитель.Родитель.ШтукВКомплекте
	|					ИНАЧЕ 1
	|				КОНЕЦ
	|		КОНЕЦ) КАК Количество
	|ИЗ
	|	Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
	|		ПО Товары.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(, Склад В (&МассивСкладов)) КАК РезервыТМЦОстатки
	|		ПО Товары.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|		ПО Товары.Номенклатура = Комплектующие.Ссылка
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|	И Товары.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|	И Товары.Количество > 0
	|	И ЕСТЬNULL(Товары.Количество, 0) - (ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) > 0
	|	И Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗ = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТЗ.Количество() = 0 Тогда Возврат Ложь; КонецЕсли;
	
	НачатьТранзакцию();
	
	Для Каждого СтрокаТоваров ИЗ ТЗ Цикл
		
		//////////////////////////// ВНАЧАЛЕ ИЗБАВИМСЯ ОТ ДРОБНЫХ ЧИСЕЛ //////////////////////////////
		Если НЕ ПроверкаЧислаНаЦелое(СтрокаТоваров.КоличествоПоКратности) Тогда
			СтрокаТоваров.КоличествоПоКратности = Цел(СтрокаТоваров.КоличествоПоКратности) + 1;
			СтрокаТоваров.Количество = СтрокаТоваров.КоличествоПоКратности;
			СтрокаТоваров.КратностьКоробаСпайки = СтрокаТоваров.Количество * СтрокаТоваров.ШтукВКомплекте;
		КонецЕсли;
		
		///////////////////////// ТЕПЕРЬ УЗНАЕМ, СКОЛЬКО НУЖНО СПАЕК /////////////////////////////////
		Если СтрокаТоваров.НужноеКоличество > СтрокаТоваров.КоличествоПоКратности Тогда
			Если СтрокаТоваров.НужноеКоличество % СтрокаТоваров.КоличествоПоКратности <> 0 Тогда
				СтрокаТоваров.Количество = ОКРУГЛТ(СтрокаТоваров.НужноеКоличество, СтрокаТоваров.КоличествоПоКратности) + СтрокаТоваров.КоличествоПоКратности;
			Иначе
				СтрокаТоваров.Количество = СтрокаТоваров.НужноеКоличество;
			КонецЕсли;
			СтрокаТоваров.КратностьКоробаСпайки = СтрокаТоваров.Количество * СтрокаТоваров.ШтукВКомплекте;
		КонецЕсли;
		
	КонецЦикла;
	
	//////////////////////////////////////////////////////////////////////////////////////////////////
	
	НадоРазбивать = ТЗ.Итог("КратностьКоробаСпайки") > ПорогЗакрытия;
	
	Если НЕ НадоРазбивать Тогда
		
		ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку");
		
		Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
			ДокЗаявка.ДокОснование = ДокСсылка;
		КонецЕсли;
		
		ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, ТЗ);
		
	Иначе ////////////// НАДО РАЗБИВАТЬ //////////////////////////////////////////////////////////////
		
		БуфернаяТаблица = Новый ТаблицаЗначений;
		БуфернаяТаблица.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		БуфернаяТаблица.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
		БуфернаяТаблица.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
		БуфернаяТаблица.Колонки.Добавить("КратностьКоробаСпайки", Новый ОписаниеТипов("Число"));
		
		ТаблицаКЗагрузке = БуфернаяТаблица.СкопироватьКолонки();
		
		///////////////////////////////////////////////////////////////////////////////////////////////////
		
		ТаблицаКЗагрузке.Очистить(); БуфернаяТаблица.Очистить();
		Для Каждого СтрокаТоваров ИЗ ТЗ Цикл
			
			НадоРаспределить = СтрокаТоваров.КратностьКоробаСпайки;
			
			Если НадоРаспределить <= ПорогЗакрытия - БуфернаяТаблица.Итог("КратностьКоробаСпайки") Тогда
				////////////////// ЗАПИХИВАЕМ В БУФЕРНУЮ ТАБЛИЦУ ////////////////////////////////////////////////////////////
				////////////////// СМОТРИМ, ТАМ ПУСТО ИЛИ УЖЕ ЧТО-ТО ЕСТЬ ///////////////////////////////////////////////////
				
				НоваяСтрока = БуфернаяТаблица.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
				
			Иначе ///////////// ЗДЕСЬ ПРИДЕТСЯ ДРОБИТЬ ///////////////////////////////////////////////////////////////////////
				/////////////// НАЙДЕМ КОЛИЧЕСТВО, СКОЛЬКО РАЗ БУДЕМ ДРОБИТЬ ОДИН ТОВАР //////////////////////////////////////
				
				////////////// ПРОВЕРИМ, РАЗДЕЛИТСЯ ЛИ НАЦЕЛО БЕЗ ОСТАТКА ////////////////////////////////////////////////////
				
				Если НадоРаспределить % ПорогЗакрытия = 0 Тогда
					КоличествоИтерацийДеления = Окр(НадоРаспределить / ПорогЗакрытия, 0, РежимОкругления.Окр15как10);
					ФлагПолностьюРазделилось = Истина;
				Иначе
					КоличествоИтерацийДеления = Окр(НадоРаспределить / ПорогЗакрытия, 0, РежимОкругления.Окр15как10) + 1;
					ФлагПолностьюРазделилось = Ложь;
				КонецЕсли;
				
				УжеРаспределено = 0;   // Считаем по Комплектующим
				Для й = 1 По КоличествоИтерацийДеления Цикл
					
					Если й < КоличествоИтерацийДеления Тогда  // ЕСЛИ НЕ ПОСЛЕДНЯЯ ИТЕРАЦИЯ, СОЗДАДИМ ЗАЯВКУ ПО ТОВАРУ
						
						ТаблицаКЗагрузке.Очистить();
						
						НоваяСтрока = ТаблицаКЗагрузке.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
						НоваяСтрока.Количество = Цел(ПорогЗакрытия / СтрокаТоваров.ШтукВКомплекте);
						УжеРаспределено = УжеРаспределено + СтрокаТоваров.КратностьКоробаСпайки;
						
						Если ТаблицаКЗагрузке.Количество() > 0 Тогда
							ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку",,,Истина);
							Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
								ДокЗаявка.ДокОснование = ДокСсылка;
							КонецЕсли;
							ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, ТаблицаКЗагрузке);
							Если ДокЗаявкаСсылка = Неопределено Тогда
								ОтменитьТранзакцию();
								Возврат Ложь;
							КонецЕсли;
							ТаблицаКЗагрузке.Очистить();
						КонецЕсли;
						
					ИначеЕсли й = КоличествоИтерацийДеления И ФлагПолностьюРазделилось Тогда
						////// ИТЕРАЦИЯ ПОСЛЕДНЯЯ, НО КОЛИЧЕСТВО РАЗДЕЛИЛОСЬ БЕЗ ОСТАТКА /////////////////////////////////////
						
						ТаблицаКЗагрузке.Очистить();
						
						// обычный товар
						НоваяСтрока = ТаблицаКЗагрузке.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
						НоваяСтрока.Количество = Цел(ПорогЗакрытия / СтрокаТоваров.ШтукВКомплекте);  // ???
						УжеРаспределено = УжеРаспределено + СтрокаТоваров.КратностьКоробаСпайки;
						
						Если ТаблицаКЗагрузке.Количество() > 0 Тогда
							ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку",,,Истина);
							Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
								ДокЗаявка.ДокОснование = ДокСсылка;
							КонецЕсли;
							ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, ТаблицаКЗагрузке);
							Если ДокЗаявкаСсылка = Неопределено Тогда
								ОтменитьТранзакцию();
								Возврат Ложь;
							КонецЕсли;
							ТаблицаКЗагрузке.Очистить();
						КонецЕсли;
						
					Иначе ////////////// ПОСЛЕДНЯЯ ИТЕРАЦИЯ И ЕСТЬ ОСТАТОК /////////////////////////////////////////////////////
						ОсталосьРаспределить = НадоРаспределить - УжеРаспределено;
						
						Если ОсталосьРаспределить <= 0 Тогда
							Продолжить;
						КонецЕсли;
						/////////////// НАДО ПОНЯТЬ, СМОЖЕМ МЫ ЗАПИХАТЬ В БУФЕРНУЮ ТАБЛИЦУ ИЛИ НЕТ //////////////////////////////
						ПоСколькоДробим = Окр(ОсталосьРаспределить / ?(СтрокаТоваров.ШтукВКомплекте = 0, 1, СтрокаТоваров.ШтукВКомплекте), 0, РежимОкругления.Окр15как10);
						
						ПомещаетсяВБуфернуюТаблицу = ОсталосьРаспределить < ПорогЗакрытия - БуфернаяТаблица.Итог("КратностьКоробаСпайки");
						
						Если НЕ ПомещаетсяВБуфернуюТаблицу Тогда
							/////////// НЕ ПОМЕЩАЕТСЯ В БУФЕРНУЮ ТАБЛИЦУ ////////////////////////////////////////////////////////
							///////// СКИДЫВАЕМ БУФЕР В ПЕРЕМЕЩЕНИЕ И ДЕЛАЕМ НОВУЮ БУФЕРНУЮ ТАБЛИЦУ /////////////////////////////
							/////////////////////////////////////////////////////////////////////////////////////////////////////
							
							Если БуфернаяТаблица.Количество() > 0 Тогда
								ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку",,,Истина);
								Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
									ДокЗаявка.ДокОснование = ДокСсылка;
								КонецЕсли;
								ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, БуфернаяТаблица);
								Если ДокЗаявкаСсылка = Неопределено Тогда
									ОтменитьТранзакцию();
									Возврат Ложь;
								КонецЕсли;
								БуфернаяТаблица.Очистить();
							КонецЕсли;
							
						КонецЕсли;
						
						НоваяСтрока = БуфернаяТаблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
						НоваяСтрока.Количество = ПоСколькоДробим;
						
					КонецЕсли;
					
				КонецЦикла;	
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ТаблицаКЗагрузке.Количество() > 0 Тогда
			ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку",,,Истина);
			Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
				ДокЗаявка.ДокОснование = ДокСсылка;
			КонецЕсли;
			ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, ТаблицаКЗагрузке);
			Если ДокЗаявкаСсылка = Неопределено Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли;
			ТаблицаКЗагрузке.Очистить();
		КонецЕсли;
		
		Если БуфернаяТаблица.Количество() > 0 Тогда
			ДокЗаявка = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "ЗаявкаНаПерепаковку",,,Истина);
			Если НЕ ЗначениеЗаполнено(ДокЗаявка.ДокОснование) Тогда
				ДокЗаявка.ДокОснование = ДокСсылка;
			КонецЕсли;
			ДокЗаявкаСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокЗаявка, БуфернаяТаблица);
			Если ДокЗаявкаСсылка = Неопределено Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли;
			БуфернаяТаблица.Очистить();
		КонецЕсли;
		
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
	Возврат Истина;
	
КонецФункции

Функция ПроверкаЧислаНаЦелое(ВходящееЧисло) Экспорт

   Возврат ВходящееЧисло = Цел(ВходящееЧисло); //Возвращает Булево

КонецФункции

