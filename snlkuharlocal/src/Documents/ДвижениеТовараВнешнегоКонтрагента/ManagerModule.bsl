Функция СоздатьЗаявкуНаПерепаковкуНаСпособПоставки(ДокОснование, ЗапросКЗагрузке, Склад, Комментарий = "") Экспорт
	
	ДокОбъект = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокОснование, "ЗаявкаНаПерепаковку",,,Истина);
	
	ДокОбъект.ДокОснование = ДокОснование;
	ДокОбъект.Склад = Склад;
	ДокОбъект.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.ВРаботе;
	ДокОбъект.Автор = ПараметрыСеанса.Пользователь;
	ДокОбъект.Комментарий = ?(СокрЛП(Комментарий) <> "", СокрЛП(Комментарий), "Создано на основании " + Строка(ДокОснование));
	
	ДокСсылка = ЗаполнитьЗаявкуНаПерепаковку(ДокОбъект, ЗапросКЗагрузке);
	
	Возврат ?(ДокСсылка = Неопределено, Неопределено, ДокСсылка);
	
КонецФункции

Функция СоздатьЗаявкуНаПерепаковкуНаСпособПоставки_Ф1(ДокОснование, ВыборкаНоменклатуры, Склад, Комментарий = "", ЕстьРаздел = Ложь, ЛимПоз = 10000000) Экспорт
	
	СчтКол = ?(ЕстьРаздел, ЛимПоз, 10000000);
	
	МассивДокументов = Новый Массив;	
	
	КоличествоНоменклатуры = ВыборкаНоменклатуры.Количество();
	
	ТекущаяПозиция = 0;
	Пока Истина Цикл
		
		ДокОбъект = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокОснование, "ЗаявкаНаПерепаковку",,,Истина);
	
		ДокОбъект.ДокОснование = ДокОснование;
		ДокОбъект.Склад = Склад;
		ДокОбъект.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.ВРаботе;
		ДокОбъект.Автор = ПараметрыСеанса.Пользователь;
		ДокОбъект.Комментарий = ?(СокрЛП(Комментарий) <> "", СокрЛП(Комментарий), "Создано на основании " + Строка(ДокОснование));
		
		ДокОбъект.Товары.Очистить();
		ДокОбъект.Комплектующие.Очистить();
		
		ВыборкаНоменклатуры.Сбросить();
		
		Счетчик = 0; ТекКол=0;
		Пока ВыборкаНоменклатуры.Следующий() Цикл
			
			Если Счетчик >= ТекущаяПозиция Тогда
				
				//////// ЗАПОЛНИМ НОМЕНКЛАТУРУ ////////////////////////////////////////////
				ЗаполнитьЗначенияСвойств(ДокОбъект.Товары.Добавить(), ВыборкаНоменклатуры);
				
				//////// ЗАПОЛНИМ КОМПЛЕКТУЮЩИЕ ///////////////////////////////////////////
				Если ВыборкаНоменклатуры.Номенклатура.Коплектующие.Количество() > 0 Тогда
					
					ТЗКомплекта = ВыборкаНоменклатуры.Номенклатура.Коплектующие.Выгрузить();
					// комплект
					Для Каждого СтрокаКомплекта ИЗ ТЗКомплекта Цикл
					
						Если СтрокаКомплекта.Количество = 0 Тогда 
							Продолжить; 
						КонецЕсли; 
					
						НоваяСтрока = ДокОбъект.Комплектующие.Добавить();
						НоваяСтрока.Номенклатура = СтрокаКомплекта.Номенклатура;
						НоваяСтрока.Количество	 = СтрокаКомплекта.Количество * ВыборкаНоменклатуры.Количество;
						НоваяСтрока.Продукция = ВыборкаНоменклатуры.Номенклатура;
						НоваяСтрока.КоличествоПродукции = ВыборкаНоменклатуры.Количество;
					
					КонецЦикла;
					
					ТекКол = ТекКол + ВыборкаНоменклатуры.Количество * ТЗКомплекта.Итог("Количество");
				Иначе
					// обычный товар
					НоваяСтрока = ДокОбъект.Комплектующие.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаНоменклатуры);
					НоваяСтрока.Продукция = ВыборкаНоменклатуры.Номенклатура;
					НоваяСтрока.КоличествоПродукции = ВыборкаНоменклатуры.Количество;
					
					ТекКол = ТекКол + ВыборкаНоменклатуры.Количество;
				КонецЕсли;
				
				ТекущаяПозиция = ТекущаяПозиция + 1;
			КонецЕсли;
			
			Если ТекКол > СчтКол Тогда
				Прервать;
			КонецЕсли;
			
			Счетчик = Счетчик + 1;
		КонецЦикла;
		
		// Шворобей ВЮ 29.11.2022 ++
		ДокОбъект.ПостобработкаКомплектующих();
		// Шворобей ВЮ 29.11.2022 ++
		
		Если ДокОбъект.Товары.Количество() > 0 Тогда
			
			Попытка
				ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
				СообщитьИзМодуля("" + ДокОбъект);
				МассивДокументов.Добавить(ДокОбъект.Ссылка);
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
		Если ТекущаяПозиция >= КоличествоНоменклатуры Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивДокументов;
	
КонецФункции

Функция ЗаполнитьЗаявкуНаПерепаковку(ДокОбъект, ВыборкаНоменклатуры) Экспорт
	
	Если ВыборкаНоменклатуры.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ДокОбъект <> Неопределено Тогда
		
		Попытка
			ДокОбъект.Заблокировать();
		Исключение
			Возврат Неопределено;
		КонецПопытки;
		
		ДокОбъект.Товары.Очистить();
		ДокОбъект.Комплектующие.Очистить();
		
		Пока ВыборкаНоменклатуры.Следующий() Цикл
			
			ЗаполнитьЗначенияСвойств(ДокОбъект.Товары.Добавить(), ВыборкаНоменклатуры);
			
			Если ВыборкаНоменклатуры.Номенклатура.Коплектующие.Количество() > 0 Тогда
				
				ТЗКомплекта = ВыборкаНоменклатуры.Номенклатура.Коплектующие.Выгрузить();
				// комплект
				Для Каждого СтрокаКомплекта Из ТЗКомплекта Цикл
					
					Если СтрокаКомплекта.Количество = 0 Тогда 
						Продолжить; 
					КонецЕсли; 
					
					НоваяСтрока = ДокОбъект.Комплектующие.Добавить();
					НоваяСтрока.Номенклатура = СтрокаКомплекта.Номенклатура;
					НоваяСтрока.Количество	 = СтрокаКомплекта.Количество * ВыборкаНоменклатуры.Количество;
					НоваяСтрока.Продукция = ВыборкаНоменклатуры.Номенклатура;
					НоваяСтрока.КоличествоПродукции = ВыборкаНоменклатуры.Количество;
					
				КонецЦикла; 
			Иначе			
				// обычный товар
				НоваяСтрока = ДокОбъект.Комплектующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаНоменклатуры);
				НоваяСтрока.Продукция = ВыборкаНоменклатуры.Номенклатура;
				НоваяСтрока.КоличествоПродукции = ВыборкаНоменклатуры.Количество;
			КонецЕсли;
			
		КонецЦикла;
		
		// Шворобей ВЮ 29.11.2022 ++
		ДокОбъект.ПостобработкаКомплектующих();
		// Шворобей ВЮ 29.11.2022 ++
	
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
			ДокОбъект.Разблокировать();
			СообщитьИзМодуля("" + ДокОбъект);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
		
		Возврат ДокОбъект.Ссылка;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

//////////////////////////////////////////////////////////////////////////////////////////////////////
