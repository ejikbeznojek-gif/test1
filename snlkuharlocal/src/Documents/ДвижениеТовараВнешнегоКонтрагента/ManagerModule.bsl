Функция СоздатьРазбивкуРНК_ПоВидуСпаек(ДокСсылка, РазбиватьПоМаркировке = Истина) Экспорт

	МассивВозврата = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДокСсылка.Дата);
	
	ДополнительныеРеквизиты = Новый Структура;
	ДополнительныеРеквизиты.Вставить("ОтсрочкаПлатежа", ДокСсылка.Договор.ОтсрочкаПлатежа);
	//++Данилова Е.В. 30.09.2025 HELP-7048
	//ДополнительныеРеквизиты.Вставить("Подразделение", ДокСсылка.Контрагент.Менеджер.Подразделение);
	ДополнительныеРеквизиты.Вставить("Подразделение", ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(ДокСсылка.Контрагент.Менеджер));
	//--Данилова Е.В. 30.09.2025
	ДополнительныеРеквизиты.Вставить("Менеджер", ДокСсылка.Контрагент.Менеджер);
	ДополнительныеРеквизиты.Вставить("КодОперации", Перечисления.КодыОперацийОстатки.Комиссия);
	ДополнительныеРеквизиты.Вставить("Склад", Справочники.Склады.НайтиПоКоду("STC-60"));
	ДополнительныеРеквизиты.Вставить("СостояниеНакладной", Перечисления.СостоянияНакладной.ВРаботе);
	// Шворобей ВЮ 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2410
	// Шворобей ВЮ 10.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396
	ДополнительныеРеквизиты.Вставить("ДатаОтгрузки", Дата(1,1,1));
	// Шворобей ВЮ 10.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396
	//ДополнительныеРеквизиты.Вставить("Комментарий", "");
	// Шворобей ВЮ 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2410
	
	// Шворобей ВЮ 24.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-3300
	ТекстСпайки = "Это спайки";
	ТекстНеСпайки = "Это не спайки";
	
	Запрос.УстановитьПараметр("МассивНоменклатуры", ДокСсылка.Товары.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Номенклатура.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|				И Номенклатура.Родитель.ТоварнаяГруппаВерхнегоУровня
	|			ТОГДА Номенклатура.Родитель
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Номенклатура.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|						И Номенклатура.Родитель.Родитель.ТоварнаяГруппаВерхнегоУровня
	|					ТОГДА Номенклатура.Родитель.Родитель
	|				ИНАЧЕ ВЫБОР
	|						КОГДА Номенклатура.Родитель.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|								И Номенклатура.Родитель.Родитель.Родитель.ТоварнаяГруппаВерхнегоУровня
	|							ТОГДА Номенклатура.Родитель.Родитель.Родитель
	|						ИНАЧЕ ВЫБОР
	|								КОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|										И Номенклатура.Родитель.Родитель.Родитель.Родитель.ТоварнаяГруппаВерхнегоУровня
	|									ТОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель
	|								ИНАЧЕ ВЫБОР
	|										КОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|												И Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.ТоварнаяГруппаВерхнегоУровня
	|											ТОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель
	|										ИНАЧЕ ВЫБОР
	|												КОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|														И Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.ТоварнаяГруппаВерхнегоУровня
	|													ТОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель
	|												ИНАЧЕ ""Не установлен""
	|											КОНЕЦ
	|									КОНЕЦ
	|							КОНЕЦ
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ГруппаТовараВерхнегоУровня
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&МассивНоменклатуры)";
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	НазваниеГруппыТовара = "";
	
	Если Результат.Следующий() Тогда 
    	НазваниеГруппыТовара = Строка(Результат.ГруппаТовараВерхнегоУровня); //Это и есть верхний уровень! 
	КонецЕсли; 	
	// Шворобей ВЮ 24.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-3300
	
	Если РазбиватьПоМаркировке Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(Товары.КОтгрузке, 0) КАК Количество,
		|	ВЫБОР
		|		КОГДА Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК ДатаОбязательнойМаркировки,
