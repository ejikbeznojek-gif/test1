///////////// СОЗДАТЬ ДОКУМЕНТЫ ///////////////////////////////////////////////////////////////////////////////////

// п.10 и п.12 
Функция СоздатьПеремещение(ДокументСсылка = Неопределено, ТаблицаКЗагрузке, СкладИсточник = Неопределено, СкладПолучатель = Неопределено,
			Комментарий = "", ДополнительныеРеквизиты = Неопределено, Проводить = Истина, СоздаватьНовый = Ложь) Экспорт
	
	Если ТаблицаКЗагрузке.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	Перемещение = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокументСсылка, "Перемещение",,,СоздаватьНовый);
	Перемещение.Дата = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	Перемещение.ДатаОтгрузки = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	Перемещение.ДатаПриемки = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	
	ЗаполнитьШапкуДокумента(Перемещение,ПараметрыСеанса.Пользователь);
	
	Перемещение.ДокОснование = ?(ДокументСсылка <> Неопределено, ДокументСсылка, Неопределено);
	Перемещение.ЗаявкаНаПерепаковку = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаявкаНаПерепаковку"), ДокументСсылка, Неопределено);
	
	Перемещение.СкладПолучатель = СкладПолучатель; // ДокументСсылка.Склад
	ОбменЭДО.УстановитьПунктДоставкиСб2б(Перемещение,"СкладПолучатель","ПунктДоставки");
	
	Перемещение.Валюта = Справочники.Валюты.НайтиПоКоду("810");
	Перемещение.Курс = 1;
		
	Перемещение.Склад = СкладИсточник;
	Перемещение.Комментарий = ?(СокрЛП(Комментарий) <> "", Комментарий, "Перемещение для Перепаковки" + Строка(ДокументСсылка));
	
	УстановитьНомерДокументаКлиентСервер(Перемещение);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			УстановитьРеквизитШапки(Перемещение, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Перемещение.Товары.Очистить();
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаКЗагрузке Цикл
		
		НоваяСтрока = Перемещение.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		
		Если ТаблицаКЗагрузке.Колонки.Найти("Заявка") = Неопределено Тогда
			НоваяСтрока.Заявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("ПодтвержденнаяЗаявка") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("ПодтвержденнаяЗаявкаПеремещения") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявкаПеремещения = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("Коэффициент") = Неопределено Тогда
			НоваяСтрока.Коэффициент = 1;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("Единица") = Неопределено Тогда
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЕсли;
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, Перемещение);
		РассчитатьСуммуТабЧасти(НоваяСтрока, Перемещение);	
		
	КонецЦикла;

	Попытка
		Перемещение.Записать(?(Проводить, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		СообщитьИзМодуля(""+Перемещение); 
		Возврат Перемещение.Ссылка;
	Исключение
		Перемещение.Записать();
		СообщитьИзМодуля(ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// п.11
Функция СоздатьКомплектацию(ДокСсылка, ТаблицаТоваров = Неопределено, ТаблицаКомплектующих = Неопределено, ДополнительныеРеквизиты = Неопределено) Экспорт
	
	Если ТаблицаТоваров.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	ДокКомпл = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "Комплектация");
	
	ЗаполнитьШапкуДокумента(ДокКомпл, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
	
	УстановитьНезаполненныйРеквизитШапки(ДокКомпл,"КодОперации", Перечисления.КодыОперацийОстатки.ЗакупкаР);
	УстановитьНезаполненныйРеквизитШапки(ДокКомпл,"ВидОплаты",ПолучитьЗначениеПоУмолчанию("ОсновнойВидОплаты"));
	
	ДокКомпл.ДокОснование = ДокСсылка;
	ДокКомпл.Склад = ДокСсылка.Склад;
	Если ЗначениеЗаполнено(ДокСсылка.ВходящееПРМТовар) Тогда
		ДокКомпл.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	Иначе
		ДокКомпл.СостояниеНакладной = Перечисления.СостоянияНакладной.ПолученоСкладом;
	КонецЕсли;
	
	УстановитьНомерДокументаКлиентСервер(ДокКомпл);
	ДокКомпл.Комментарий = "Создано документом " + Строка(ДокСсылка);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			ДокКомпл[Элемент.Ключ]=Элемент.Значение;
			//УстановитьНезаполненныйРеквизитШапки(ДокКомпл, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	ДокКомпл.Товары.Очистить();
	
	Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
		НоваяСтрока = ДокКомпл.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
		НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
		НоваяСтрока.Коэффициент = 1;
		НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		НоваяСтрока.Всего = НоваяСтрока.Количество;
		ЗаполнитьКоличествоКомплектующихПоСтроке(НоваяСтрока);
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокКомпл);
		РассчитатьСуммуТабЧасти(НоваяСтрока, ДокКомпл, "ОтВсего");
	КонецЦикла;
	
	////////////////// КОМПЛЕКТУЮЩИЕ /////////////////////////////////////////////////////////////////////////
	
	Если ТаблицаКомплектующих = Неопределено Тогда
		Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
			
			Если СтрокаТоваров.Номенклатура.Коплектующие.Количество() > 0 Тогда
				// комплект
				Для Каждого СтрокаКомплекта Из СтрокаТоваров.Номенклатура.Коплектующие Цикл
					
					Если СтрокаКомплекта.Количество = 0 Тогда 
						Продолжить; 
					КонецЕсли; 
					
					НоваяСтрока = ДокКомпл.Комплектующие.Добавить();
					НоваяСтрока.Номенклатура = СтрокаКомплекта.Номенклатура;
					НоваяСтрока.Количество	 = СтрокаКомплекта.Количество * СтрокаТоваров.Количество;
					НоваяСтрока.Продукция = СтрокаТоваров.Номенклатура;
					НоваяСтрока.Всего = НоваяСтрока.Количество;
					
				КонецЦикла; 
			Иначе			
				// обычный товар
				НоваяСтрока = ДокКомпл.Комплектующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
				НоваяСтрока.Продукция = СтрокаТоваров.Номенклатура;
				НоваяСтрока.Всего = НоваяСтрока.Количество;
			КонецЕсли;
			
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
			
		КонецЦикла;
	Иначе
		Для Каждого СтрокаТоваров ИЗ ТаблицаКомплектующих Цикл
			НоваяСтрока = ДокКомпл.Комплектующие.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
			НоваяСтрока.Всего = НоваяСтрока.Количество;
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого Стр ИЗ ДокКомпл.Комплектующие Цикл
		ЗаполнитьКоличествоКомплектующихПоСтроке(Стр);
		ПриИзмененииНоменклатурыТабЧасти(Стр, ДокКомпл);
		РассчитатьСуммуТабЧасти(Стр, ДокКомпл, "ОтВсего");
	КонецЦикла;
	
	Попытка
		ДокКомпл.Записать(РежимЗаписиДокумента.Проведение);
		СообщитьИзМодуля(""+ДокКомпл); 
		Возврат ДокКомпл.Ссылка;
	Исключение
		ДокКомпл.Записать();
		СообщитьИзМодуля(""+ДокКомпл); 
		Возврат ДокКомпл.Ссылка;
		//СообщитьИзМодуля(ОписаниеОшибки());
		//Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// п.13
Функция СоздатьСписаниеТМЦ(ДокСсылка, ТаблицаТоваров = Неопределено, Комментарий = "", ДополнительныеРеквизиты = Неопределено, Проводить = Ложь) Экспорт
	
	ДокСписание = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "СписаниеТМЦ");
	
	ЗаполнитьЗначенияСвойств(ДокСписание, ДокСсылка);
	
	ЗаполнитьШапкуДокумента(ДокСписание, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
	
	УстановитьНезаполненныйРеквизитШапки(ДокСписание,"ВидОплаты",	ПолучитьЗначениеПоУмолчанию("ОсновнойВидОплаты"));		
	
	ДокСписание.КодОперации = Перечисления.КодыОперацийОстатки.Списание;	
	ДокСписание.ДокОснование = ДокСсылка;
	
	УстановитьНомерДокументаКлиентСервер(ДокСписание);
	
	Если СокрЛП(Комментарий) <> "" Тогда
		ДокСписание.Комментарий = СокрЛП(Комментарий);
	Иначе
		ДокСписание.Комментарий = "Создано документом " + Строка(ДокСсылка);
	КонецЕсли;
	
	// Шворобей ВЮ 16.01.2023 ++
	Если ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
		Если ЕстьРеквизитДокумента("Подразделение", ДокСсылка.ДокОснование.Метаданные()) Тогда
			ДокСписание.Подразделение = ЗначениеРеквизитаОбъекта(ДокСсылка.ДокОснование, "Подразделение");		
		КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 16.01.2023 ++
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			ДокСписание[Элемент.Ключ]=Элемент.Значение;
		КонецЦикла;
	КонецЕсли;
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	Если ТаблицаТоваров <> Неопределено Тогда
		
		ДокСписание.Товары.Очистить();
		
		Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
			
			НоваяСтрока = ДокСписание.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
			
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
			НоваяСтрока.Всего = НоваяСтрока.Количество;
			
			/////////////////////////////////////////////////////////////////////////////////////////////////////
			//    НУЖНО БУДЕТ УСТАНОВИТЬ ЦЕНУ
			/////////////////////////////////////////////////////////////////////////////////////////////////////
			
			НоваяСтрока.Цена = ПолучитьЦенуИзДокументаОснования(НоваяСтрока.Номенклатура, ДокСсылка);
			
			ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокСписание);
			РассчитатьСуммуТабЧасти(НоваяСтрока, ДокСписание);
		КонецЦикла;
		
	КонецЕсли;
	
	// Шворобей ВЮ 08.02.2023 ++
	Если Проводить Тогда
		Попытка
			ДокСписание.Записать(РежимЗаписиДокумента.Проведение);
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		Исключение
			ДокСписание.Записать();
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		КонецПопытки;
	Иначе
		Попытка
			ДокСписание.Записать();
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		Исключение
			СообщитьИзМодуля("" + ОписаниеОшибки());
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	// Шворобей ВЮ 08.02.2023 ++
	
КонецФункции

// п.14
Функция СоздатьРасходнуюНакладную(ДокСсылка = Неопределено, ТаблицаТоваров, ДополнительныеРеквизиты = Неопределено,
	// Кухарь А.Ю. 06.09.2024 начало
	//+ параметр СообщатьОНулевыхЦенах
	//	Проводить = Ложь, Комментарий = "", ОтгрузкаКомплектов = Ложь, СоздаватьНовый = Ложь, ЗаполнитьДопОбработки = Ложь) Экспорт
	Проводить = Ложь, Комментарий = "", ОтгрузкаКомплектов = Ложь, СоздаватьНовый = Ложь, ЗаполнитьДопОбработки = Ложь, СообщатьОНулевыхЦенах=ложь) Экспорт	 
	// Кухарь А.Ю. 06.09.2024 конец
	
	
	Если ТаблицаТоваров.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	ДокРасходнаяНакладная = Документы.ЗаявкаНаРекламацию.СоздатьИзменитьДокумент(ДокСсылка, "РасходнаяНакладная", , , СоздаватьНовый);
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	МетаданныеДокСсылка = Неопределено;
	МетаданныеДокСсылка = ?(ДокСсылка <> Неопределено, ДокСсылка.Метаданные(), Неопределено);
	
	ЕстьРеквизитОснование = Ложь;
	Если МетаданныеДокСсылка <> Неопределено Тогда
		ЕстьРеквизитОснование = ЕстьРеквизитДокумента("ДокОснование", МетаданныеДокСсылка);
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	Если ДокСсылка <> Неопределено И ЕстьРеквизитОснование И ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
		ЗаполнитьЗначенияСвойств(ДокРасходнаяНакладная, ДокСсылка.ДокОснование);
	ИначеЕсли ДокСсылка <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ДокРасходнаяНакладная, ДокСсылка);
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	ЗаполнитьШапкуДокумента(ДокРасходнаяНакладная, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
	
	ДокРасходнаяНакладная.ДокОснование =  ?(ДокСсылка = Неопределено, Неопределено, ДокСсылка);
	ДокРасходнаяНакладная.Комментарий = ?(СокрЛП(Комментарий) <> "", Комментарий, "Создано документом " + Строка(ДокСсылка));
	
	УстановитьНомерДокументаКлиентСервер(ДокРасходнаяНакладная);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			УстановитьРеквизитШапки(ДокРасходнаяНакладная, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	// Шворобей ВЮ 29.11.2022 ++
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.СостояниеНакладной) Тогда
		ДокРасходнаяНакладная.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе;
	КонецЕсли;
	// Шворобей ВЮ 29.11.2022 ++
	
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ТипЦен) Тогда
		ДокРасходнаяНакладная.ТипЦен = ДокРасходнаяНакладная.Контрагент.ТипЦен;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ТипЦенРаспродажа) Тогда
		ДокРасходнаяНакладная.ТипЦенРаспродажа = ДокРасходнаяНакладная.Контрагент.ТипЦенРаспродажа;
	КонецЕсли;
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	ДокРасходнаяНакладная.Товары.Очистить();
	
	Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
		
		НоваяСтрока = ДокРасходнаяНакладная.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
		
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.СтавкаНДС) Тогда
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
		КонецЕсли;
		
		Если ТаблицаТоваров.Колонки.Найти("Коэффициент") = Неопределено Тогда
			НоваяСтрока.Коэффициент = 1;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("Единица") = Неопределено Тогда
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("Заявка") = Неопределено Тогда
			НоваяСтрока.Заявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("ПодтвержденнаяЗаявка") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		КонецЕсли;
		
		/////////////////////////////////////////////////////////////////////////////////////////////////////
		//    НУЖНО БУДЕТ УСТАНОВИТЬ ЦЕНУ
		/////////////////////////////////////////////////////////////////////////////////////////////////////
		
		Если ДокСсылка <> Неопределено И ЕстьРеквизитОснование И ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
			НоваяСтрока.Цена = ПолучитьЦенуИзДокументаОснования(НоваяСтрока.Номенклатура, ДокСсылка);
		КонецЕсли;
		
		НоваяСтрока.Всего = НоваяСтрока.Количество * НоваяСтрока.Цена;
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокРасходнаяНакладная);
		РассчитатьСуммуТабЧасти(НоваяСтрока, ДокРасходнаяНакладная);
		
	КонецЦикла;
	
	ДокРасходнаяНакладная.ОтгрузкаКомплектов = ОтгрузкаКомплектов;
	ДокРасходнаяНакладная.Комплектующие.Очистить();
	
	Если ОтгрузкаКомплектов Тогда
		ЗаполнениеДокументов.ЗаполнитьТЧКомплектующие(ДокРасходнаяНакладная);	
	КонецЕсли;
	
	ДокРасходнаяНакладная.ДопОбработки.Очистить();
	
	Если ЗаполнитьДопОбработки Тогда
		Если ДокРасходнаяНакладная.ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
			Для Каждого СтрокаТЧ Из ДокРасходнаяНакладная.Контрагент.ВидыДопОбработок Цикл
				СтрокаДО = ДокРасходнаяНакладная.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
			КонецЦикла;
		Иначе
			Для Каждого СтрокаТЧ Из ДокРасходнаяНакладная.ПунктДоставки.ВидыДопОбработок Цикл
				СтрокаДО = ДокРасходнаяНакладная.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	// Кухарь А.Ю. 06.09.2024 начало
	//
	если СообщатьОНулевыхЦенах тогда
		Запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ
		              |	ТЗ.Номенклатура КАК Номенклатура
		              |ПОМЕСТИТЬ ВремТЗ
		              |ИЗ
		              |	&ТЗ КАК ТЗ
		              |ГДЕ
		              |	ТЗ.Количество > 0
		              |	И ТЗ.Цена = 0
		              |;
		              |
		              |////////////////////////////////////////////////////////////////////////////////
		              |ВЫБРАТЬ
		              |	ВремТЗ.Номенклатура.Наименование КАК НаименованиеНоменклатуры
		              |ИЗ
		              |	ВремТЗ КАК ВремТЗ";
		Запрос.УстановитьПараметр("ТЗ",ДокРасходнаяНакладная.товары.выгрузить());
		ВыборкаПустыхЦен=запрос.Выполнить().Выбрать();
		пока ВыборкаПустыхЦен.Следующий() цикл
			Сообщить(СтрШаблон("Пустая цена у %1",ВыборкаПустыхЦен.НаименованиеНоменклатуры));
		КонецЦикла;
	КонецЕсли;
	// Кухарь А.Ю. 06.09.2024 конец
	
	Попытка
		// Шворобей ВЮ 29.11.2022 ++
		Если Проводить Тогда
			ДокРасходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ДокРасходнаяНакладная.Записать();
		КонецЕсли;
		// Шворобей ВЮ 29.11.2022 ++
		СообщитьИзМодуля("" + ДокРасходнаяНакладная);
		Возврат ДокРасходнаяНакладная.Ссылка;
	Исключение
		СообщитьИзМодуля(ОписаниеОшибки());
		Возврат Неопределено;	
	КонецПопытки;
	
КонецФункции

///////////// ПЕРЕМЕСТИТЬ КОМПЛЕКТУЮЩИЕ ////////////////////////////////////////////////////////////////////////////

Функция ПереместитьСоСкладовОстатковНаСкладПерепаковки(ДокСсылка) Экспорт
	
	СтруктураВозврата = Новый Структура("ТаблицаНехватки, Успешно", Неопределено, Ложь);
	
	//////////////// ВНАЧАЛЕ ПРОВЕРИМ, СКОЛЬКО УЖЕ ЕСТЬ НА СКЛАДЕ ПЕРЕПАКОВКИ ////////////////////////////////
	
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(ДокСсылка.Склад);
	
	СтруктураОстатковНаСкладеПерепаковки = ПолучитьСтруктуруОстатковНаСкладах(ДокСсылка, МассивСкладов);
	
	ТаблицаНехваткиНаСкладеПерепаковки = СтруктураОстатковНаСкладеПерепаковки.ТаблицаНехватки; // СКОЛЬКО НАМ НЕ ХВАТАЕТ ПЕРЕМЕСТИТЬ
	
	Если СтруктураОстатковНаСкладеПерепаковки.ТаблицаНехватки.Количество() = 0  Тогда
		СообщитьИзМодуля("Нечего перемещать!!!");
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	///////////////// НАДО ПЕРЕМЕЩАТЬ ПО ТАБЛИЦЕ НЕХВАТКИ ////////////////////////////////////////////////////
	
	Если ДокСсылка.СкладыОстатков.Количество() = 0 Тогда
		СообщитьИзМодуля("Не заполнены склады остатков!!!");
		Возврат СтруктураВозврата;	
	КонецЕсли;
	
	МассивСкладов = Новый Массив;
	Для Каждого Стр ИЗ ДокСсылка.СкладыОстатков Цикл
		МассивСкладов.Добавить(Стр.Склад);	
	КонецЦикла;
	
	//////////////// ИЩЕМ ОСТАТКИ НА СКЛАДАХ ОСТАТКОВ ПО ТАБЛИЦЕ НЕХВАТКИ ////////////////////////////////////
	
	СтруктураОстатковНаСкладах = ПолучитьСтруктуруОстатковНаСкладахПоТаблицеНехватки(ДокСсылка, МассивСкладов, СтруктураОстатковНаСкладеПерепаковки.ТаблицаНехватки);
	
	Если СтруктураОстатковНаСкладах.ТаблицаНехватки.Количество() > 0  Тогда
		СообщитьИзМодуля("Недостаточно свободных остатков на складах остатков!!!");
		СтруктураВозврата.Вставить("ТаблицаНехватки", СтруктураОстатковНаСкладах.ТаблицаНехватки); 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	//////////////// ПЕРЕМЕЩАЕМ ///////////////////////////////////////////////////////////////////////////////
	
	ТаблицаНехватки = ТаблицаНехваткиНаСкладеПерепаковки;
	
	Для Каждого Стр ИЗ ДокСсылка.СкладыОстатков Цикл
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
		Запрос.УстановитьПараметр("Дата", КонецДня(ДокСсылка.Дата));
		
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		Запрос.УстановитьПараметр("ТаблицаНехватки", ТаблицаНехватки);
		Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ ТаблицаНехватки ИЗ &ТаблицаНехватки КАК ТаблицаНехватки";
		
		УстановитьПривилегированныйРежим(Истина);
		Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Сводный.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) < СУММА(Сводный.Количество)
		|				И СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) > 0
		|			ТОГДА СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв)
		|		ИНАЧЕ ВЫБОР
		|				КОГДА СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) >= СУММА(Сводный.Количество)
		|					ТОГДА СУММА(Сводный.Количество)
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР
		|		КОГДА СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) < СУММА(Сводный.Количество)
		|			ТОГДА СУММА(Сводный.Количество) - (СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв))
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Нехватка
		|ИЗ
		|	(ВЫБРАТЬ
		|		ЕСТЬNULL(Остатки.Номенклатура, ТаблицаНехватки.Номенклатура) КАК Номенклатура,
		|		ЕСТЬNULL(ТаблицаНехватки.Количество, 0) КАК Количество,
		|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
		|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
		|		0 КАК ВиртуальныйРезерв
		|	ИЗ
		|		ТаблицаНехватки КАК ТаблицаНехватки
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата, Склад = &Склад) КАК Остатки
		|				ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Дата, Склад = &Склад) КАК Резервы
		|				ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			ПО (Остатки.Номенклатура = ТаблицаНехватки.Номенклатура)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЕСТЬNULL(ОстаткиТМЦ.Номенклатура, ТаблицаНехватки.Номенклатура),
		|		0,
		|		ЕСТЬNULL(ОстаткиТМЦ.Количество, 0),
		|		0,
		|		0
		|	ИЗ
		|		ТаблицаНехватки КАК ТаблицаНехватки
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
		|			ПО (ОстаткиТМЦ.Номенклатура = ТаблицаНехватки.Номенклатура)
		|	ГДЕ
		|		ОстаткиТМЦ.Регистратор = &ДокСсылка
		|		И ОстаткиТМЦ.Склад = &Склад
		|		И ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЕСТЬNULL(РезервыТМЦ.Номенклатура, ТаблицаНехватки.Номенклатура),
		|		0,
		|		0,
		|		-ЕСТЬNULL(РезервыТМЦ.Количество, 0),
		|		0
		|	ИЗ
		|		ТаблицаНехватки КАК ТаблицаНехватки
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
		|			ПО (РезервыТМЦ.Номенклатура = ТаблицаНехватки.Номенклатура)
		|	ГДЕ
		|		РезервыТМЦ.Регистратор = &ДокСсылка
		|		И РезервыТМЦ.Склад = &Склад) КАК Сводный
		|
		|СГРУППИРОВАТЬ ПО
		|	Сводный.Номенклатура";
		
		Запрос.УстановитьПараметр("Склад", Стр.Склад);
	
		УстановитьПривилегированныйРежим(Истина);
		ТаблицаКЗагрузке = Запрос.Выполнить().Выгрузить();
		УстановитьПривилегированныйРежим(Ложь);
		
		// Кухарь А.Ю. 04.05.2022 начало
		// Для того чтобы не создавать пустые ПРМ			
		Если ТаблицаКЗагрузке.Итог("Количество") = 0 Тогда
			Продолжить;
		КонецЕсли; 
		// Кухарь А.Ю. 04.05.2022 конец
		
		Если ТаблицаКЗагрузке.Количество() > 0 Тогда
			НачатьТранзакцию();
			ПеремещениеСсылка = СоздатьПеремещение(ДокСсылка, ТаблицаКЗагрузке, Стр.Склад, ДокСсылка.Склад, "Комплектующие на склад Перепаковки");   // Создаем по ТаблицаОстатков
			Если ПеремещениеСсылка = Неопределено Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли;
			СообщитьИзМодуля("Создан документ " + Строка(ПеремещениеСсылка));
			ЗафиксироватьТранзакцию();
		КонецЕсли;
		
		ТаблицаНехватки.Очистить();
		Для Каждого Стр ИЗ ТаблицаКЗагрузке Цикл
			Если Стр.Нехватка > 0 Тогда
				НоваяСтрока = ТаблицаНехватки.Добавить();
				НоваяСтрока.Номенклатура = Стр.Номенклатура;
				НоваяСтрока.Количество = Стр.Нехватка;
			КонецЕсли;
		КонецЦикла;
		
		Если ТаблицаНехватки.Количество() = 0 Тогда // Нечего перемещать, останавливаемся!
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТаблицаНехватки.Количество() > 0 Тогда
		СтруктураВозврата.Вставить("ТаблицаНехватки", ТаблицаНехватки);
		СтруктураВозврата.Вставить("Успешно", Ложь);
		Возврат СтруктураВозврата;
	Иначе
		СтруктураВозврата.Вставить("ТаблицаНехватки", Неопределено);
		СтруктураВозврата.Вставить("Успешно", Истина);
		Возврат СтруктураВозврата;
	КонецЕсли;
	
КонецФункции

Функция ЗакрытьЗаказ(ДокСсылка, ПорогЗакрытия = 50000) Экспорт
	
	НачатьТранзакцию();
	
	// 2. Меняется статус заявки на «закрыт»
	// 5. При проведении заявки в статусе "закрыт", резервы должны сниматься.
	
	ДокОбъект = ДокСсылка.ПолучитьОбъект();
	
	Если ДокОбъект <> Неопределено Тогда
		
		Попытка
			ДокОбъект.Заблокировать();
		Исключение
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецПопытки;
		
		ДокОбъект.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.Закрыта;
		
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			ДокОбъект.Разблокировать();
		Исключение
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	// 3. На каждый из складов в ТЧ товары создаётся документ в состоянии "получено складом".
	
	// a. Если тип склада «Перепаковка» создавать ПРМ со склада документа на склад из строчки на комплектующие. 
	// b. В иных случаях КМП по складу из документа.
	
	//////////////////////////////////// МАССИВ СКЛАДОВ ПЕРЕПАКОВКА ///////////////////////////////////////////////////
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.Текст = 	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Товары.Склад КАК Склад
	|ИЗ
	|	Документ.ЗаявкаНаПерепаковку.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &ДокСсылка
	|	И Товары.Склад.ТипСклада = ЗНАЧЕНИЕ(Перечисление.ТипСклада.Перепаковка)
	|	И Товары.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Склад";
	
	УстановитьПривилегированныйРежим(Истина);
