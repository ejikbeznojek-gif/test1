	Запрос.УстановитьПараметр("Склад",ДокСсылка.Склад); 
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаТоваров = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	МассивПродукция = ТаблицаТоваров.ВыгрузитьКолонку("Номенклатура");
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	*
	|ИЗ
	|	Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка = &ДокСсылка
	|	И Комплектующие.Продукция В(&МассивПродукция)";
	
	Запрос.УстановитьПараметр("МассивПродукция", ТаблицаТоваров.ВыгрузитьКолонку("Номенклатура"));
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаКомплектующих = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТаблицаТоваров.Количество() > 0 Тогда
		Комплектация = СоздатьКомплектацию(ДокСсылка, ТаблицаТоваров, ТаблицаКомплектующих);
		Если Комплектация = Неопределено Тогда
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
	Возврат Истина;
	
КонецФункции

