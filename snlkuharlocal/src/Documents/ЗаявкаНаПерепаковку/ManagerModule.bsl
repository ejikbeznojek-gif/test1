Функция ПолучитьСтруктуруОстатковНаСкладах(ДокументСсылка, МассивСкладов) Экспорт
	
	СтруктураОстатков = Новый Структура("ТаблицаОстатков, ТаблицаНехватки");
	
	// Проверим, достаточно ли Товара на складах
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", КонецДня(ДокументСсылка.Дата));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	// Кухарь А.Ю.  10.06.2022 начало
	// Для случаев, когда 1 запчасть в разных спайках, считает некорректно. Нужно схлопывать запчасти
	//Запрос.Текст = 
	//"ВЫБРАТЬ
	//|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, Комплектующие.Номенклатура) КАК Номенклатура,
	//|	ЕСТЬNULL(Комплектующие.Количество, 0) КАК Количество,
	//|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
	//|	ВЫБОР
	//|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < ЕСТЬNULL(Комплектующие.Количество, 0)
	//|			ТОГДА ЕСТЬNULL(Комплектующие.Количество, 0) - (ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0))
	//|		ИНАЧЕ 0
	//|	КОНЕЦ КАК Нехватка
	//|ИЗ
	//|	Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	//|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	//|				&Дата,
	//|				Склад В (&МассивСкладов)
	//|					И Номенклатура В
	//|						(ВЫБРАТЬ
	//|							Комплектующие.Номенклатура КАК Номенклатура
	//|						ИЗ
	//|							Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	//|						ГДЕ
	//|							Комплектующие.Ссылка = &Ссылка)) КАК ОстаткиТМЦОстатки
	//|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	//|					&Дата,
	//|					Склад В (&МассивСкладов)
	//|						И Номенклатура В
	//|							(ВЫБРАТЬ
	//|								Комплектующие.Номенклатура КАК Номенклатура
	//|							ИЗ
	//|								Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	//|							ГДЕ
	//|								Комплектующие.Ссылка = &Ссылка)) КАК РезервыТМЦОстатки
	//|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	//|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	//|		ПО Комплектующие.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	//|ГДЕ
	//|	Комплектующие.Ссылка = &Ссылка";
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(Комплектующие.Количество) КАК Количество
	|ПОМЕСТИТЬ ТЗКМП
	|ИЗ
	|	Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Комплектующие.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, Комплектующие.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(Комплектующие.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) < ЕСТЬNULL(Комплектующие.Количество, 0)
	|			ТОГДА ЕСТЬNULL(Комплектующие.Количество, 0) - (ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0))
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Нехватка
	|ИЗ
	|	ТЗКМП КАК Комплектующие
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&Дата,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							Комплектующие.Номенклатура КАК Номенклатура
	|						ИЗ
	|							Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	|						ГДЕ
	|							Комплектующие.Ссылка = &Ссылка)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&Дата,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В
	|							(ВЫБРАТЬ
	|								Комплектующие.Номенклатура КАК Номенклатура
	|							ИЗ
	|								Документ.ЗаявкаНаПерепаковку.Комплектующие КАК Комплектующие
	|							ГДЕ
	|								Комплектующие.Ссылка = &Ссылка)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|		ПО Комплектующие.Номенклатура = ОстаткиТМЦОстатки.Номенклатура";
	
	
	// Кухарь А.Ю.  10.06.2022 конец
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаЗапроса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТаблицаНехватки = ТаблицаЗапроса.СкопироватьКолонки();
	Для Каждого Стр ИЗ ТаблицаЗапроса Цикл
		Если Стр.Нехватка > 0 Тогда
			НоваяСтрока = ТаблицаНехватки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
			НоваяСтрока.Количество = Стр.Нехватка;
		КонецЕсли;
	КонецЦикла;
	
	СтруктураОстатков.Вставить("ТаблицаОстатков", ТаблицаЗапроса);
	СтруктураОстатков.Вставить("ТаблицаНехватки", ТаблицаНехватки);
	
	Возврат СтруктураОстатков;
	
КонецФункции

Функция ПолучитьСтруктуруОстатковНаСкладахПоТаблицеНехватки(ДокументСсылка, МассивСкладов, ТаблицаНехватки) Экспорт
	
	СтруктураОстатков = Новый Структура("ТаблицаОстатков, ТаблицаНехватки");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокСсылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Дата", КонецДня(ДокументСсылка.Дата));
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаНехватки", ТаблицаНехватки);
	Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ ТаблицаНехватки ИЗ &ТаблицаНехватки КАК ТаблицаНехватки";
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Сводный.Номенклатура КАК Номенклатура,
	|	СУММА(Сводный.Количество) КАК Количество,
	|	СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв) < СУММА(Сводный.Количество)
	|			ТОГДА СУММА(Сводный.Количество) - (СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) - СУММА(Сводный.ВиртуальныйРезерв))
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Нехватка
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Остатки.Номенклатура, ТаблицаНехватки.Номенклатура) КАК Номенклатура,
	|		ЕСТЬNULL(ТаблицаНехватки.Количество, 0) КАК Количество,
	|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	|		0 КАК ВиртуальныйРезерв
	|	ИЗ
	|		ТаблицаНехватки КАК ТаблицаНехватки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата, Склад В (&МассивСкладов)) КАК Остатки
	|				ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Дата, Склад В (&МассивСкладов)) КАК Резервы
	|				ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			ПО (Остатки.Номенклатура = ТаблицаНехватки.Номенклатура)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЕСТЬNULL(ОстаткиТМЦ.Номенклатура, ТаблицаНехватки.Номенклатура),
	|		0,
	|		ЕСТЬNULL(ОстаткиТМЦ.Количество, 0),
	|		0,
	|		0
	|	ИЗ
	|		ТаблицаНехватки КАК ТаблицаНехватки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|			ПО (ОстаткиТМЦ.Номенклатура = ТаблицаНехватки.Номенклатура)
	|	ГДЕ
	|		ОстаткиТМЦ.Регистратор = &ДокСсылка
	|		И ОстаткиТМЦ.Склад В(&МассивСкладов)
	|		И ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЕСТЬNULL(РезервыТМЦ.Номенклатура, ТаблицаНехватки.Номенклатура),
	|		0,
	|		0,
	|		-ЕСТЬNULL(РезервыТМЦ.Количество, 0),
	|		0
	|	ИЗ
	|		ТаблицаНехватки КАК ТаблицаНехватки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|			ПО (РезервыТМЦ.Номенклатура = ТаблицаНехватки.Номенклатура)
	|	ГДЕ
	|		РезервыТМЦ.Регистратор = &ДокСсылка
	|		И РезервыТМЦ.Склад В(&МассивСкладов)) КАК Сводный
	|
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Номенклатура";
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаЗапроса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТаблицаНехватки = ТаблицаЗапроса.СкопироватьКолонки();
	Для Каждого Стр ИЗ ТаблицаЗапроса Цикл
		Если Стр.Нехватка > 0 Тогда
			НоваяСтрока = ТаблицаНехватки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
			НоваяСтрока.Количество = Стр.Нехватка;
		КонецЕсли;
	КонецЦикла;
	
	СтруктураОстатков.Вставить("ТаблицаОстатков", ТаблицаЗапроса);
	СтруктураОстатков.Вставить("ТаблицаНехватки", ТаблицаНехватки);
	
	Возврат СтруктураОстатков;
	
КонецФункции

