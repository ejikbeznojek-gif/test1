Функция ПолучитьЦенуИзДокументаОснования(Номенклатура, ДокСсылка, ИмяТабличнойЧастиДокументаСсылка = "Товары", ИмяТабличнойЧастиДокументаОснования = "Товары") Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
		Возврат 0;
	КонецЕсли;
	
	ИмяДокументаСсылка = ДокСсылка.Метаданные().Имя;
	ИмяДокументаОснования = ДокСсылка.ДокОснование.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЧ.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(ТЧ_Основание.Цена, 0)) КАК Цена
	|ИЗ
	|	Документ." + ИмяДокументаСсылка + "." + ИмяТабличнойЧастиДокументаСсылка + " КАК ТЧ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ." + ИмяДокументаОснования + "." + ИмяТабличнойЧастиДокументаОснования + " КАК ТЧ_Основание
	|		ПО ТЧ.Номенклатура = ТЧ_Основание.Номенклатура
	|ГДЕ
	|	ТЧ.Ссылка = &ДокСсылка
	|	И ТЧ.Номенклатура = &Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧ.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции