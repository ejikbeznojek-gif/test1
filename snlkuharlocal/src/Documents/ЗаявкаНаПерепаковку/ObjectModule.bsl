Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Если НЕ Отказ Тогда
		
		// ++ Шворобей ВЮ 26.04.2022
		ДвиженияПоРегистрам = Неопределено;
		РезультатПроведения = ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам);
		Если РезультатПроведения.ТОшибок = Неопределено Тогда
			ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам, Истина, Истина);
		ИначеЕсли ТипЗнч(РезультатПроведения.ТОшибок) = Тип("ТаблицаЗначений") Тогда
			ВывестиТрассировку(РезультатПроведения.ТОшибок, РезультатПроведения.Результат);
			Отказ = Истина;
		КонецЕсли;
		// ++ Шворобей ВЮ 26.04.2022
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		Если Статус <> Перечисления.СтатусыЗаявокНаПерепаковку.ВРаботе Тогда
			Если Товары.Количество() > 0 Тогда
				Движения.СпайкиВПути.Записывать = Истина;
				Движения.СпайкиВПути.Очистить();
				Для Каждого ТекСтрокаТовары Из Товары Цикл
					Движение = Движения.СпайкиВПути.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = Дата;
					Движение.Регистратор = Ссылка;
					Движение.Заявка = Ссылка;
					Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
					Движение.Количество = ТекСтрокаТовары.Количество;
				КонецЦикла;
				Движения.СпайкиВПути.Записать(Истина);
			КонецЕсли;
		Иначе
			Движения.СпайкиВПути.Записывать = Истина;
			Движения.СпайкиВПути.Очистить();
			Движения.СпайкиВПути.Записать(Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать = Ложь, Очищать=Истина)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Продолжить  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];
		Если Очищать Тогда
			НаборЗаписей.Очистить();
		КонецЕсли;
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

