Процедура ЗаполнитьНоменклатуру() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Дата));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаГотовности));
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПланОтгрузокОбороты.Номенклатура КАК Номенклатура,
	|	ПланОтгрузокОбороты.Склад КАК Склад
	|ПОМЕСТИТЬ ТЗНоменклатура
	|ИЗ
	|	РегистрНакопления.ПланОтгрузок.Обороты(&НачалоПериода, &КонецПериода, Авто, ) КАК ПланОтгрузокОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланОтгрузокОбороты.Номенклатура,
	|	ПланОтгрузокОбороты.Склад
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Номенклатура,
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Склад
	|ИЗ
	|	РегистрСведений.МинимальныеОстаткиНаСкладах.СрезПоследних(&НачалоПериода, ) КАК МинимальныеОстаткиНаСкладахСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Номенклатура,
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЗНоменклатура.Номенклатура КАК Номенклатура
	|ИЗ
	|	ТЗНоменклатура КАК ТЗНоменклатура
	|ГДЕ
	|	ТЗНоменклатура.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗНоменклатура.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТЗНоменклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Товары.Очистить();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Товары.Добавить(), Выборка);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьКоличествоНаПерепаковку() Экспорт
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Дата));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаГотовности));
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК СвободныйОстаток
	|ПОМЕСТИТЬ СвободныеОстатки
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&НачалоПериода,
	|			Номенклатура = &Номенклатура
	|				И Склад = &Склад) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				&НачалоПериода,
	|				Номенклатура = &Номенклатура
	|					И Склад = &Склад) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(МинимальныеОстаткиНаСкладахСрезПоследних.Количество, 0)) КАК МинКоличество
	|ПОМЕСТИТЬ МинОстатки
	|ИЗ
	|	РегистрСведений.МинимальныеОстаткиНаСкладах.СрезПоследних(
	|			&НачалоПериода,
	|			Номенклатура = &Номенклатура
	|				И Склад = &Склад) КАК МинимальныеОстаткиНаСкладахСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	МинимальныеОстаткиНаСкладахСрезПоследних.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланОтгрузокОбороты.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ПланОтгрузокОбороты.КоличествоОборот, 0)) КАК ПланОтгрузки
	|ПОМЕСТИТЬ ПланыОтгрузок
	|ИЗ
	|	РегистрНакопления.ПланОтгрузок.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Авто,
	|			Номенклатура = &Номенклатура
	|				И Склад = &Склад) КАК ПланОтгрузокОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланОтгрузокОбороты.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СпайкиВПутиОстатки.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(СпайкиВПутиОстатки.КоличествоОстаток, 0)) КАК СпайкиОстаток
	|ПОМЕСТИТЬ СпайкиВПути
	|ИЗ
	|	РегистрНакопления.СпайкиВПути.Остатки(&КонецПериода, Номенклатура = &Номенклатура) КАК СпайкиВПутиОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	СпайкиВПутиОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланыОтгрузок.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(МинОстатки.МинКоличество, 0) - ЕСТЬNULL(СвободныеОстатки.СвободныйОстаток, 0) + ЕСТЬNULL(ПланыОтгрузок.ПланОтгрузки, 0) - ЕСТЬNULL(СпайкиВПути.СпайкиОстаток, 0) КАК Количество,
	|	ВЫБОР
	|		КОГДА ПланыОтгрузок.Номенклатура.ШтукВКомплекте <> 0
	|			ТОГДА ПланыОтгрузок.Номенклатура.ШтукВКомплекте
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ПланыОтгрузок.Номенклатура.Родитель.ШтукВКомплекте <> 0
	|					ТОГДА ПланыОтгрузок.Номенклатура.Родитель.ШтукВКомплекте
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ПланыОтгрузок.Номенклатура.Родитель.Родитель.ШтукВКомплекте <> 0
	|							ТОГДА ПланыОтгрузок.Номенклатура.Родитель.Родитель.ШтукВКомплекте
	|						ИНАЧЕ 1
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ * ВЫБОР
	|		КОГДА ПланыОтгрузок.Номенклатура.ШтукВКоробке <> 0
	|			ТОГДА ПланыОтгрузок.Номенклатура.ШтукВКоробке
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ПланыОтгрузок.Номенклатура.Родитель.ШтукВКоробке <> 0
	|					ТОГДА ПланыОтгрузок.Номенклатура.Родитель.ШтукВКоробке
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ПланыОтгрузок.Номенклатура.Родитель.Родитель.ШтукВКоробке <> 0
	|							ТОГДА ПланыОтгрузок.Номенклатура.Родитель.Родитель.ШтукВКоробке
	|						ИНАЧЕ 1
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК КратностьКомплекта
	|ИЗ
	|	ПланыОтгрузок КАК ПланыОтгрузок
	|		ЛЕВОЕ СОЕДИНЕНИЕ СвободныеОстатки КАК СвободныеОстатки
	|		ПО ПланыОтгрузок.Номенклатура = СвободныеОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ МинОстатки КАК МинОстатки
	|		ПО ПланыОтгрузок.Номенклатура = МинОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ СпайкиВПути КАК СпайкиВПути
	|		ПО ПланыОтгрузок.Номенклатура = СпайкиВПути.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СвободныеОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МинОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПланыОтгрузок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СпайкиВПути";
	
	Для Каждого Стр ИЗ Товары Цикл
		
		Запрос.УстановитьПараметр("Номенклатура", Стр.Номенклатура);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(Стр, Выборка);
			Если Выборка.Количество <= Выборка.КратностьКомплекта Тогда
				Стр.Количество = Выборка.КратностьКомплекта;
			Иначе // ДОПОЛНИТЬ ДО КРАТНОСТИ
				Если Выборка.Количество % Выборка.КратностьКомплекта = 0 Тогда
					КоличествоИтерацийДеления = Окр(Выборка.Количество / Выборка.КратностьКомплекта, 0, РежимОкругления.Окр15как10);
				Иначе
				    КоличествоИтерацийДеления = Окр(Выборка.Количество / Выборка.КратностьКомплекта, 0, РежимОкругления.Окр15как10) + 1;
				КонецЕсли;
				Для й = 1 По КоличествоИтерацийДеления Цикл
					Если Выборка.Количество <= Выборка.КратностьКомплекта * й Тогда
						Стр.Количество = Выборка.КратностьКомплекта * й;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьКомплектующие() Экспорт
	
	Если Товары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Комплектующие.Очистить();
	
	Для Каждого СтрокаТоваров Из Товары Цикл	
		
		Если СтрокаТоваров.Количество = 0 Тогда 
			Продолжить; 
		КонецЕсли; 
		
		Номенклатура = СтрокаТоваров.Номенклатура;
		
		Если Номенклатура.Коплектующие.Количество() > 0 
			//++Данилова Е.В. 05.02.2025
			И Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
			//--Данилова Е.В. 05.02.2025 
			// комплект
			Для Каждого СтрокаКомплекта Из Номенклатура.Коплектующие Цикл
				Если СтрокаКомплекта.Количество = 0 Тогда 
					Продолжить; 
				КонецЕсли; 
				
				СтрокаТЧ = Комплектующие.Добавить();	
				
				СтрокаТЧ.Продукция		= Номенклатура;
				СтрокаТЧ.Номенклатура	= СтрокаКомплекта.Номенклатура;
				
				ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ, ЭтотОбъект);
				
				СтрокаТЧ.Количество		= СтрокаКомплекта.Количество * СтрокаТоваров.Количество;
				СтрокаТЧ.КоличествоПродукции = СтрокаТоваров.Количество;
				
			КонецЦикла; 
		Иначе			
			// обычный товар
			СтрокаТЧ = Комплектующие.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТоваров);
			СтрокаТЧ.Продукция = Номенклатура;
			СтрокаТЧ.КоличествоПродукции = СтрокаТоваров.Количество;
			
		КонецЕсли;
		
	КонецЦикла;	

КонецПроцедуры

// Шворобей ВЮ 29.11.2022 ++
Функция ПостобработкаКомплектующих() Экспорт
	
	//// ВОТ ЗДЕСЬ РАЗБЕРЕМСЯ С КОЛИЧЕСТВОМ ЗАПЧАСТЕЙ /////////////////////////
		
	МассивПродукции = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(Комплектующие.ВыгрузитьКолонку("Продукция"));
		
	Для Каждого Продукция ИЗ МассивПродукции Цикл
		НайденныеСтроки = Комплектующие.НайтиСтроки(Новый Структура("Продукция", Продукция));
		Если НайденныеСтроки.Количество() > 1 Тогда
			счетчикТовара = 0;
			Для Каждого СтрокаТЧ ИЗ НайденныеСтроки Цикл
				Если ПолучитьРеквизитШапки(СтрокаТЧ.Номенклатура,"Родитель.ВидНоменклатуры")= Перечисления.ВидыНоменклаутры.Товар Тогда
					Если счетчикТовара > 0 Тогда
						СтрокаТЧ.КоличествоПродукции = 0;
					КонецЕсли;                                      
					счетчикТовара = счетчикТовара + 1;             
				Иначе
					СтрокаТЧ.КоличествоПродукции = 0;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
		
	Для Каждого СтрокаТЧ ИЗ Комплектующие Цикл
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);	
	КонецЦикла;
	
КонецФункции
