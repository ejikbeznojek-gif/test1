Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НЕ ОбменДанными.Загрузка Тогда
		
		ЕстьИзменения	= Модифицированность();	
		НужноВыгружать	= НужноВыгружатьДокумент(ЕстьИзменения, Ссылка, РежимЗаписи, ПометкаУдаления);
		
		//Кухарь А.Ю.  30.11.2022 начало
		Если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			если Статус=Перечисления.СтатусыЗаявокНаПерепаковку.Закрыта тогда
				НужноВыгружать=ложь;
			КонецЕсли;
		КонецЕсли;
		//Кухарь А.Ю.  30.11.2022 конец
		
		Если НужноВыгружать Тогда
			УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
		КонецЕсли;
		
		// Шворобей ВЮ 29.11.2022 ++
		Если ДополнительныеСвойства.Свойство("СтатусВРаботе") Тогда
			Статус = Перечисления.СтатусыЗаявокНаПерепаковку.ВРаботе;
		ИначеЕсли ТолькоТоварыВТабличнойЧасти(Товары) Тогда
			Статус = Перечисления.СтатусыЗаявокНаПерепаковку.Закрыта;
		КонецЕсли;
		
		Если ДатаГотовности <> ПолучитьРеквизитШапки(Ссылка, "ДатаГотовности") Тогда
			Адрес = СокрЛП(Автор.ФизЛицо.ЕМэйл);
			Если Адрес <> "" Тогда
				СписокПолучателей = Новый СписокЗначений;
				СписокПолучателей.Добавить(Адрес);
				ТемаПисьма = "У документа " + Строка(Ссылка) + " установлена дата готовности " + Строка(ДатаГотовности);
				ОшибкиУведомления = СформироватьВнутреннееУведомление(СписокПолучателей, ТемаПисьма, ТемаПисьма);
			КонецЕсли;
		КонецЕсли;
		// Шворобей ВЮ 29.11.2022 ++
		
		Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.Склад Тогда
			
			// 1.Проверяется, что во всех строчках товаров заполнен склад.
			
			Для Каждого Стр ИЗ Товары Цикл
				Если НЕ ЗначениеЗаполнено(Стр.Склад) Тогда
					СообщитьИзМодуля("В строке " + Строка(Стр.НомерСтроки) + " не заполнен Склад!");
					Отказ = Истина; Возврат;	
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Шворобей ВЮ 25.11.2022 ++
Процедура ПриЗаписи(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если Статус = Перечисления.СтатусыЗаявокНаПерепаковку.Закрыта Тогда
		Адрес = СокрЛП(Автор.ФизЛицо.ЕМэйл);
		Если Адрес <> "" Тогда
			СписокПолучателей = Новый СписокЗначений;
			СписокПолучателей.Добавить(Адрес);
			ТемаПисьма = "Закрыта заявка на перепаковку " + Строка(Ссылка) + " Можно создавать РНК";
			ТекстПисьма = ТемаПисьма;
			ОшибкиУведомления = СформироватьВнутреннееУведомление(СписокПолучателей, ТекстПисьма, ТемаПисьма);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
