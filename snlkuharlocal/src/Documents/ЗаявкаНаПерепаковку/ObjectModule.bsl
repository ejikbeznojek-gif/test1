Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено ИЛИ ДанныеЗаполнения.Пустая() Тогда Возврат КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	
	Внешний = Истина;
	Автор = ПараметрыСеанса.Пользователь;
	
	ДокОснование = ДанныеЗаполнения;
	
	Если ДанныеЗаполнения.Метаданные().ТабличныеЧасти.Найти("Товары") <> Неопределено Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДокСсылка", ДанныеЗаполнения);
		Запрос.УстановитьПараметр("Склад", Склад);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	*,
		|	&Склад КАК Склад
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &ДокСсылка
		|	И Товары.Количество > 0";
		
		УстановитьПривилегированныйРежим(Истина);
		Товары.Загрузить(Запрос.Выполнить().Выгрузить());
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Если ДанныеЗаполнения.Метаданные().ТабличныеЧасти.Найти("Комплектующие") <> Неопределено Тогда
		Комплектующие.Загрузить(ДанныеЗаполнения.Комплектующие.Выгрузить());
	КонецЕсли;
	
	Если ДанныеЗаполнения.Метаданные().Имя = "РасходнаяНакладная" Тогда
		ДополнительныеСвойства.Вставить("ПомечатьРНКНаУдаление", Истина);
		ДополнительныеСвойства.Вставить("РазрешитьВводДатыГотовности", Истина);
		ДополнительныеСвойства.Вставить("СтатусВРаботе", Истина)
	КонецЕсли;
	
КонецПроцедуры


