

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	 УправлениеВидимостью();
КонецПроцедуры



&НаКлиенте
Процедура УправлениеВидимостью()
	если не объект.ВидРасчетаЗаказа = Перечисления.ВидыРасчетаЗаказаНаПроизводство.РасчетПлановКомплектующихПоСпайкам тогда
		Элементы.ГруппаТовары.Видимость = ложь;
		элементы.ГруппаКомплектующие.Видимость = ложь;
	Иначе 
		Элементы.ГруппаТовары.Видимость = Истина;
		элементы.ГруппаКомплектующие.Видимость = Истина;
	КонецЕсли;    
	
	
	
	если не объект.ВидРасчетаЗаказа = Перечисления.ВидыРасчетаЗаказаНаПроизводство.РасчетУменьшенияПлановСпаекПоПрофицитуКомплектующих тогда
		Элементы.ГруппаПрофицитКомплектующих.Видимость = ложь;
		элементы.ГруппаПроцентСпаекСобираемыхНаСкладе.Видимость = ложь;          
		// Кухарь А.Ю. 05.12.2025 начало
		// OUT-171
		элементы.ГруппаПродукцияСНедостачейКомплектующих.Видимость = ложь;  
		// Кухарь А.Ю. 05.12.2025 конец
		
	Иначе 
		Элементы.ГруппаПрофицитКомплектующих.Видимость = Истина;
		элементы.ГруппаПроцентСпаекСобираемыхНаСкладе.Видимость = Истина;  
		// Кухарь А.Ю. 05.12.2025 начало
		// OUT-171
		элементы.ГруппаПродукцияСНедостачейКомплектующих.Видимость = Истина;  
		// Кухарь А.Ю. 05.12.2025 конец
		
	КонецЕсли;    	
	
КонецПроцедуры

