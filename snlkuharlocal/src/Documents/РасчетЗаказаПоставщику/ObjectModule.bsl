Процедура ЗаполнитьКомплектующие()  экспорт 
	Запрос = новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ТЧ.Номенклатура КАК Номенклатура,
	             |	ТЧ.Количество КАК Количество
	             |ПОМЕСТИТЬ Товары
	             |ИЗ
	             |	&Товары КАК ТЧ	             
	             | ;
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ВЫБОР
	             |		КОГДА Товары.Номенклатура.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	             |			ТОГДА ЕСТЬNULL(НоменклатураКоплектующие.Номенклатура, Товары.Номенклатура)
	             |		ИНАЧЕ Товары.Номенклатура
	             |	КОНЕЦ КАК Номенклатура,
	             |	ВЫБОР
	             |		КОГДА Товары.Номенклатура.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	             |			ТОГДА Товары.Количество * ЕСТЬNULL(НоменклатураКоплектующие.Количество, 1)
	             |		ИНАЧЕ Товары.Количество
	             |	КОНЕЦ КАК Количество,
	             |	Товары.Номенклатура КАК Продукция,
	             |	Товары.Количество КАК КоличествоПродукции
	             |ИЗ
	             |	Товары КАК Товары
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	             |		ПО Товары.Номенклатура = НоменклатураКоплектующие.Ссылка
	             |			И (НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = Значение(Перечисление.ВидыНоменклаутры.товар))"; 
	запрос.УстановитьПараметр("Товары",товары.Выгрузить());         
	Комплектующие.Загрузить(запрос.Выполнить().Выгрузить());
