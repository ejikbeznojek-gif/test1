Процедура СканированиеСтаройДК(Данные,ФормаДокумента,АкцияПоСкидкеДК=Неопределено) Экспорт 
	
	НачальнаяСкидка = 5;
	Если НЕ АкцияПоСкидкеДК=Неопределено  Тогда
		
		Если АкцияПоСкидкеДК.СкидкаДК>5 Тогда
			
			НачальнаяСкидка = АкцияПоСкидкеДК.СкидкаДК; 
			
		КонецЕсли;
		
	КонецЕсли;
	
	//НЕЧАЕВА 16,04,15 ++
	НачальнаяСкидка = 5;
	Если НЕ АкцияПоСкидкеДК=Неопределено  Тогда
		Если АкцияПоСкидкеДК.ИзменениеСкидокДКПроцент.Количество()>0 Тогда
			НачальнаяСкидка = ЭтотОбъект.Скидка; 
		КонецЕсли;
	КонецЕсли;
   	//НЕЧАЕВА 16,04,15 --
	
	ДК = Справочники.ДисконтныеКарты.НайтиПоКоду(Данные);
	Если ДК.Пустая() Тогда
		НомерКарты = Данные;
		Скидка = Макс(НачальнаяСкидка,Скидка);
		ТЦВыдачи = ?(ТЦВыдачи.Пустая(),ПараметрыСеанса.ЭтотУзел.Подразделение,ТЦВыдачи);
	Иначе
		ДисконтнаяКарта = ДК;
		НомерДоИзменения = ДК.Код;
		СкидкаДоИзменения = Макс(ДК.Скидка,ДК.СкидкаСтарая);
		Скидка = Макс(НачальнаяСкидка,СкидкаДоИзменения);
		Скидка = Макс(Скидка,ПолучитьСкидкуДК(ДК.ОбщаяСумма));
		//крохин начало 15.11.2012
		//не используется
		//Если НЕ ЗаявкаНаДКофис Тогда
		//Скидка = Мин(Скидка,15);	
		//КонецЕсли;
		//крохин конец 15.11.2012
		
		ИсточникИнформацииДоИзменения = ДК.ИсточникИнформации;
		ИсточникИнформации = ДК.ИсточникИнформации;
		Если НЕ ИсточникИнформации.Предопределенный Тогда
			ИсточникИнформации = ПолучитьИсточникИнформации(ИсточникИнформации);	
		КонецЕсли;
		
		ФИОДоИзменения = ДК.Наименование;
		ФИО = ДК.Наименование;
		ФИОслужебная = ФИО;
		Если ПустаяСтрока(Фамилия) Тогда
			Фамилия  = ВыделитьСлово(ФИОслужебная);
			Имя      = ВыделитьСлово(ФИОслужебная);
			Отчество = ВыделитьСлово(ФИОслужебная);
		КонецЕсли;
		ДРДоИзменения = ДК.ДатаРождения;
		ДР = ДК.ДатаРождения;
		ТЦВыдачиДоИзменения = ДК.ТЦВыдачи;
		ТЦВыдачи = ПараметрыСеанса.ЭтотУзел.Подразделение;
		СМСРассылкаДоИзменения = ДК.СМСРассылка;
		СМСРассылка = дк.СМСРассылка;
		ЭлектроннаяПочтаРассылкаДоИзменения = ДК.ЭлектроннаяПочтаРассылка;
		ЭлектроннаяПочтаРассылка = дк.ЭлектроннаяПочтаРассылка;
		ЕМэйлДоИзменения = ДК.ЕМэйл;
		ЕМэйл = ДК.ЕМэйл;
		Пол = ДК.Пол;
		ТЦРегистрации = ПараметрыСеанса.ЭтотУзел.Подразделение;
		//нечаева 14,06,17
		Акционная = ДК.АкционнаяДК;
		
		//----- нечаева 14,06,17---
		
		ИсхТелефон = ДК.Телефон;
		ТелефонДоИзменения = ФорматТелефона(ИсхТелефон);
		Если СтрДлина(ТелефонДоИзменения) = 10 Тогда
			Телефон = ТелефонДоИзменения;
		КонецЕсли;
	КонецЕсли;
	
	ЭлементыФормы =  ФормаДокумента.ЭлементыФормы;
	
	Если ПустаяСтрока(НомерДоИзменения) Тогда
		ЭлементыФормы.рРеквизитыДоИзменения.Видимость = Ложь;
