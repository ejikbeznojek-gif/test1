Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НЕ ОбменДанными.Загрузка Тогда		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);			
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
	КонецЕсли;
	
	ЕстьИзменения		=Модифицированность();	
	НужноВыгружать		=НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
	КонецЕсли;
	//крохин начало 24.10.2012
	//непроведенные документы не создают ДК
	//Если Ссылка.Отработано Тогда
	//ЗаписыватьДК = Ложь;
	//Иначе
	//ЗаписыватьДК = Истина;
	//КонецЕсли;
	Если ОбменДанными.Загрузка Тогда
		ЗаписыватьДК = Ложь;
	Иначе
		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ЗаписыватьДК = Истина;	
		Иначе
			Если Ссылка.Отработано И Проведен Тогда
				ЗаписыватьДК = Ложь;
			Иначе
				ЗаписыватьДК = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	//крохин конец 24.10.2012
	
	//крохин начало 24.10.2012
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ОбработкаЗаписиДК();	
	КонецЕсли;
	//крохин конец 24.10.2012
	
КонецПроцедуры

Процедура СканированиеСтаройДКcn(Данные,ФормаДокумента) Экспорт 
		ДК = Справочники.ДисконтныеКарты.НайтиПоКоду(Данные);
	Если ДК.Пустая() Тогда
	НомерКарты = Данные;
	Скидка = Макс(5,Скидка);
	ТЦВыдачи = ?(ТЦВыдачи.Пустая(),ПараметрыСеанса.ЭтотУзел.Подразделение,ТЦВыдачи);
    Иначе
	ДисконтнаяКарта = ДК;
	НомерДоИзменения = ДК.Код;
	СкидкаДоИзменения = Макс(ДК.Скидка,ДК.СкидкаСтарая);
	Скидка = Макс(5,СкидкаДоИзменения);
	Скидка = Макс(Скидка,ПолучитьСкидкуДК(ДК.ОбщаяСумма));
	//крохин начало 15.11.2012
	//не используется
	//Если НЕ ЗаявкаНаДКофис Тогда
	//Скидка = Мин(Скидка,15);	
