		Скидка = Неопределено;
		ИсточникИнформацииДоИзменения = Неопределено;
		ИсточникИнформации = Неопределено;
		ФИОДоИзменения = Неопределено;
		ФИО = Неопределено;
		Фамилия = Неопределено;
		Имя = Неопределено;
		Отчество = Неопределено;
		Пол = Неопределено;
		ДРДоИзменения = Неопределено;
		ДР = Неопределено;
		ТЦВыдачиДоИзменения = Неопределено;
		ТЦВыдачи = Неопределено;
		СМСРассылкаДоИзменения = Неопределено;
		СМСРассылка = Неопределено;
		ЭлектроннаяПочтаРассылкаДоИзменения = Неопределено;
		ЭлектроннаяПочтаРассылка = Неопределено;
		Отработано = Неопределено;
		ЗаявкаНаДКофис = Неопределено;
		ЕМэйлДоИзменения = Неопределено;
		ЕМэйл = Неопределено;
		ТелефонДоИзменения = Неопределено;
		Телефон = Неопределено;
		ТЦРегистрации = Неопределено;
		ПодтвержденаСтараяДК = Неопределено;
		ПодтвержденаНоваяДК = Неопределено;
		//нечаева 14,06,17++
		Акционная = Истина;
		//нечаева 29,01,18++
		ДатаОкончанияДействия = Дата(2018,12,31);
		//нечаева 29,01,18--
		//нечаева 14,06,17--
		
	КонецПроцедуры

	Процедура  ОбработкаЗаписиДК()  Экспорт

	Если НЕ ЗаписыватьДК Тогда Возврат КонецЕсли;
		//крохин начало 24.10.2012
		//в офисе правятся ДК любых ТЦ
		//Если ТЦРегистрации <> ПараметрыСеанса.ЭтотУзел.Подразделение Тогда Возврат КонецЕсли;
		Если ТЦРегистрации <> ПараметрыСеанса.ЭтотУзел.Подразделение Тогда
			Если ПараметрыСеанса.ТипУзла <> Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Возврат ;
			КонецЕсли;
		КонецЕсли;
		//крохин конец 24.10.2012
	Если ПустаяСтрока(НомерКарты) Тогда Возврат КонецЕсли;
	Если ЗаявкаНаДКофис Тогда
		Если НЕ ПодтвержденаНоваяДК ИЛИ НЕ ПодтвержденаСтараяДК Тогда
		Возврат;	
		КонецЕсли;
	КонецЕсли;
	Если ДисконтнаяКарта.Пустая() Тогда
				ДКОбъект = Справочники.ДисконтныеКарты.СоздатьЭлемент();	
	Иначе
		ДКОбъект = ДисконтнаяКарта.ПолучитьОбъект();	
	КонецЕсли;	
	//крохин начало 30.01.2013
	
	//крохин конец 30.01.2013
	Если НЕ ПустаяСтрока(НомерДоИзменения) Тогда 
		Если ДКОбъект.НомераДК.Количество() = 0 Тогда
		СтрокаНомерДК = ДКОбъект.НомераДК.Добавить();
			СтрокаНомерДК.НомерДК = НомерДоИзменения;
			СтрокаНомерДК.ДатаНачалаДействия = ДКОбъект.ДатаВступленияВКлуб;
			СтрокаНомерДК.ТЦРегистрации = ТЦВыдачиДоИзменения;
		КонецЕсли;
	КонецЕсли;
	    
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("НомерДК", НомерКарты);
		НайденныеСтроки = ДКОбъект.НомераДК.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтрокаНомерДК = ДКОбъект.НомераДК.Добавить();
			СтрокаНомерДК.НомерДК = НомерКарты;
			СтрокаНомерДК.ДатаНачалаДействия = Дата;
			СтрокаНомерДК.ТЦРегистрации = ТЦРегистрации;
			//крохин начало 30.01.2013
			//запретим менять номер ДК, если уже меняли
			МенятьНомерДК = Истина;
		Иначе
			МенятьНомерДК = Ложь;
			//крохин конец 30.01.2013
		КонецЕсли;
	ДКОбъект.Владелец = Справочники.Контрагенты.НайтиПоКоду("SSP-0019");
	//крохин начало 30.01.2013
	//запретим менять номер ДК, если уже меняли
	//ДКОбъект.Код = НомерКарты;
	Если МенятьНомерДК Тогда
	ДКОбъект.Код = НомерКарты;	
	КонецЕсли;
	//крохин конец 30.01.2013
	//крохин начало 30.01.2013
	//запретим уменьшать скидку 
	//ДКОбъект.Скидка = Скидка;
	ДКОбъект.Скидка = Макс(ДКОбъект.Скидка,Скидка);
	//крохин конец 30.01.2013
	ДКОбъект.СкидкаСтарая = Макс(ДКОбъект.Скидка,ДКОбъект.СкидкаСтарая);
	ДКОбъект.ИсточникИнформации = ИсточникИнформации;
	ДКОбъект.Наименование = ФИО;
	ДКОбъект.Фамилия = Фамилия;
	ДКОбъект.Имя = Имя;
	ДКОбъект.Отчество = Отчество;
	ДКОбъект.Пол = Пол;
	ДКОбъект.ДатаРождения = ДР;
	ДКОбъект.ТЦВыдачи = ТЦВыдачи;
	ДКОбъект.СМСРассылка = СМСРассылка;
	ДКОбъект.ЭлектроннаяПочтаРассылка = ЭлектроннаяПочтаРассылка;
	ИсхТелефон = Телефон;
	ДКОбъект.Телефон = ФорматТелефона(ИсхТелефон);
	ДКОбъект.ЕМэйл = ЕМэйл;
	//нечаева 14,06,17+++
	ДКОбъект.АкционнаяДК =  Акционная;
	ДКОбъект.ДатаОкончанияДействия = ДатаОкончанияДействия;
	//нечаева 03,07,17 +++
	ДКОбъект.БылаРанееКарта = БылаРанееКарта;
	//нечаева 03,07,17 ---
	
	//нечаева 14,06,17---
	
	
	Если ДКОбъект.ДатаВступленияВКлуб = '00010101' Тогда
		ДКОбъект.ДатаВступленияВКлуб = Дата;
	КонецЕсли;
	ДКОбъект.ЧленКлуба = Истина;
	ДКОбъект.ЧленКлуба2012 = Истина;
	//крохин начало 15.11.2012
	ДКОбъект.ПромоКарта = Ложь;
	//крохин конец 15.11.2012
	ДКОбъект.Записать();
	Если ДисконтнаяКарта <> ДКОбъект.Ссылка Тогда
		ДисконтнаяКарта = ДКОбъект.Ссылка;
	КонецЕсли;

КонецПроцедуры

