Функция ВыделитьСлово(ИсходнаяСтрока)
	
	Буфер = СокрЛ(ИсходнаяСтрока);
	ПозицияПослПробела = Найти(Буфер, " ");

	Если ПозицияПослПробела = 0 Тогда
		ИсходнаяСтрока = "";
		Возврат Буфер;
	КонецЕсли;
	
	ВыделенноеСлово = СокрЛП(Лев(Буфер, ПозицияПослПробела));
	ИсходнаяСтрока = Сред(ИсходнаяСтрока, ПозицияПослПробела + 1);
	
	Возврат ВыделенноеСлово;
	
КонецФункции



Функция ПолучитьИсточникИнформации(Источник) Экспорт
	Если Источник.Пустая() Тогда
	Возврат Справочники.ИсточникиИнформации.ПустаяСсылка();		
    КонецЕсли;
    //крохин начало 24.10.2012
	//временно вводим 2 непредопределенных
	//крохин начало 25.01.2015
	
	Если СокрЛП(Источник.Код) = "11"  ИЛИ СокрЛП(Источник.Код) = "12" 	Тогда
	//крохин конец 25.01.2015	
	Возврат Источник;	
	КонецЕсли;
	//крохн конец 24.10.2012
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ИсточникиИнформации.Ссылка
	               |ИЗ
	               |	Справочник.ИсточникиИнформации КАК ИсточникиИнформации
	               |ГДЕ
	               |	ИсточникиИнформации.Наименование ПОДОБНО &Наименование
	               |	И ИсточникиИнформации.Предопределенный";
				   Запрос.УстановитьПараметр("Наименование","%"+Источник.Наименование+"%");
				   Выборка = Запрос.Выполнить().Выбрать();
				   Если Выборка.Следующий() Тогда
					   Возврат Выборка.Ссылка;
				   Иначе
					   Возврат Справочники.ИсточникиИнформации.ПустаяСсылка();	
				   КонецЕсли; 
	
	
	
   КонецФункции


	   
  
Функция ФорматТелефона(ИсхТелефон) Экспорт
	ИсхТелефон = СтрЗаменить(ИсхТелефон,"(","");
	ИсхТелефон = СтрЗаменить(ИсхТелефон,")","");
	ИсхТелефон = СтрЗаменить(ИсхТелефон,"-","");
	Если СтрДлина(ИсхТелефон) = 10 Тогда
			Возврат ИсхТелефон;
		Иначеесли СтрДлина(ИсхТелефон) = 11 Тогда
			Возврат Прав(ИсхТелефон,10);
		иначе
			Возврат ИсхТелефон;
		КонецЕсли;
	КонецФункции

	Процедура ПриКопировании(ОбъектКопирования)
		ДисконтнаяКарта = Неопределено;
		НомерДоИзменения = Неопределено;
		НомерКарты = Неопределено;
