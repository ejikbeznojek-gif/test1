Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	ЕстьИзменения	= Модифицированность();
	НужноВыгружать	= НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	
	Если НЕ ОбменДанными.Загрузка Тогда
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;
	
	Если ЕстьИзменения Тогда 
		СуммаДокумента		= Товары.Итог("Всего");
		ОбъемДокумента		= Товары.Итог("Объем");
		КоличествоДокумента 		= Товары.Итог("Количество");
		СуммаОплатыСертификатами    = ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");
		
		ГруппыТоваров   	= ГруппыТоваровДокумента(ЭтотОбъект);	
	КонецЕсли; 
	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
		//Катаев+ 08/10/14
		Если Не ЭтотОбъект.Ссылка.Пустая() Тогда
			НужноВыгружать = Ложь;
		КонецЕсли;
		//Катаев- 08/10/14
	КонецЕсли;
	//+HELP-2684 20250204 Михайловский
	Если ЗначениеЗаполнено(Касса.ПодразделениеДляУчета) И (Дата>='20241201') И НЕ (Подразделение	= Касса.ПодразделениеДляУчета)  Тогда
		Подразделение	= Касса.ПодразделениеДляУчета;
		//+HELP-3018 20250318 Михайловский 
		Для Каждого ТСтр Из Товары Цикл
			Если НЕ (ТСтр.Подразделение = Подразделение) Тогда
				ТСтр.Подразделение = Подразделение;
			КонецЕсли;	
		КонецЦикла;
		//-HELP-3018 20250318 Михайловский
	КонецЕсли;
	//-HELP-2684 20250204 Михайловский
	
	//+HELP-5235 20250904 Михайловский
	Если СуммаОплатыБНПодели <> 0 И ЗначениеЗаполнено(ПроцентКомиссииПодели) Тогда
		 //СуммаОплатыБНПодели1 = Цел(СуммаОплатыБНПодели * (1 - (ПроцентКомиссииПодели / 100)));
		 СуммаОплатыБНПодели1 = Окр(СуммаОплатыБНПодели * (1 - (ПроцентКомиссииПодели / 100)), 2);
	КонецЕсли;	
	//-HELP-5235 20250904 Михайловский
	
КонецПроцедуры

