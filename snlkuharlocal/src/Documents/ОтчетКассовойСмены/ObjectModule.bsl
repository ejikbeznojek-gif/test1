Функция НайтиДоговорыПодели(Контрагент, Организация)
	Рез = Новый Структура("Основной, Комиссия", Справочники.Договоры.ПустаяСсылка(), Справочники.Договоры.ПустаяСсылка());
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Договоры.Ссылка КАК Ссылка,
	               |	Договоры.ДопСоглашение КАК ДопСоглашение
	               |ИЗ
	               |	Справочник.Договоры КАК Договоры
	               |ГДЕ
	               |	Договоры.Владелец = &Владелец
	               |	И Договоры.Организация = &Организация";
	Запрос.УстановитьПараметр("Владелец",Контрагент);
	Запрос.УстановитьПараметр("Организация",Организация);
	Выб = Запрос.Выполнить().Выбрать();	
	Пока Выб.Следующий() Цикл
		Если Выб.ДопСоглашение = Истина Тогда
			Рез.Комиссия = Выб.Ссылка;
		Иначе	
			Рез.Основной = Выб.Ссылка;
		КонецЕсли;	
	КонецЦикла;	
	Возврат Рез;
КонецФункции //-SNL-69 20251205 Михайловский

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		НаборЗаписей.Очистить();
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			//ДенежныеСредства
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли; 
	КонецЦикла;	
КонецПроцедуры 

Процедура УдалитьЧеки(Отказ)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НомерЧека,
	|	НомерЧекаККМ,	 
	|	Ссылка.Касса КАК Касса
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары КАК ОтчетКассовойСменыТовары
	|ГДЕ 
	|	Ссылка=&ОКС";
	
	Запрос.УстановитьПараметр("ОКС",Ссылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Чек=Документы.Чек.НайтиПоНомеру(Выборка.НомерЧека,Дата);
		Если Чек.Пустая() Тогда
			//крохин начало 08.02.2017
			//при обмене не нужно сообщений
			//Если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			Если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение  И НЕ ОбменДанными.Загрузка Тогда
			//крохин конец 08.02.2017	
				Сообщить("Не найден чек №: "+Выборка.НомерЧека);			
			КонецЕсли;			
		Иначе
			Если Чек.Проведен Тогда
				ЧекОбъект=Чек.ПолучитьОбъект();
				Попытка
					ЧекОбъект.УстановитьПометкуУдаления(Истина);		
				Исключение
					СообщитьОбОшибке("Не удалось удалить чек ! №: "+Чек.Номер+". "+ОписаниеОшибки(),Отказ);					
				КонецПопытки;				
			КонецЕсли; 			
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьДоговорЧЛ_ПК()
	Контрагент=Касса.ОсновнойПокупатель;
	НаименованиеДоговора=""+Подразделение+" пластиковые карты";
	Договор=Справочники.Договоры.НайтиПоНаименованию(НаименованиеДоговора,Истина,,Контрагент);
	Если Договор.Пустая() Тогда
		Договор=Справочники.Договоры.СоздатьЭлемент();	
		
		Договор.Владелец		= Контрагент;
		
		Договор.Наименование	= НаименованиеДоговора;
		Договор.Организация 	= Организация;
		Договор.КодЦБ			= Контрагент.КодЦБ;
		Договор.ВалютаКредита   = Валюта;
		Договор.ТипЦен			= Касса.ОсновнойТипЦен;
		Договор.ТипСкидок		= Касса.ОсновнойТипСкидок;
		
		Договор.Записать();
		
		Договор=Договор.Ссылка;
	КонецЕсли; 
	
	Возврат Договор;
КонецФункции 

Функция НайтиДоговор(Контрагент, Организация)
	Рез = Неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	       |	Договоры.Ссылка КАК Ссылка
	       |ИЗ
	       |	Справочник.Договоры КАК Договоры
	       |ГДЕ
	       |	Договоры.Владелец = &Владелец
	       |	И Договоры.Организация = &Организация";
	Запрос.УстановитьПараметр("Владелец",Контрагент);
	Запрос.УстановитьПараметр("Организация",Организация);
	Выб = Запрос.Выполнить().Выбрать();	
	Если Выб.Следующий() Тогда
		Рез = Выб.Ссылка;
	КонецЕсли;	
	Возврат Рез;
КонецФункции	

Процедура СформироватьДвиженияПоКассам(Записывать=Ложь,Корректировки=Ложь) Экспорт
	Если Корректировки Тогда
		СформироватьДвиженияПоВзаиморасчетам(Ложь);
	КонецЕсли;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	Контрагент,СУММА(Всего) КАК Всего
	|ИЗ
	|(
	|ВЫБРАТЬ
	|	Контрагент.Ведущий КАК Контрагент,
	|	Всего КАК Всего
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары
	|ГДЕ
	|	Ссылка = &Ссылка	
	|ОБЪЕДИНИТЬ ВСЕ 
	|ВЫБРАТЬ
	|	Контрагент.Ведущий КАК Контрагент,
	|	-СуммаОплатыСертификатами КАК Всего
	|ИЗ
	|	Документ.ОтчетКассовойСмены.ПодарочныеСертификаты
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И
	|	не ВидСертификата=Значение(Справочник.ВидыПодарочныхСертификатов.КупонНаСкидку)
	|) КАК Сводный
	|СГРУППИРОВАТЬ ПО
	|	Контрагент";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выборка=Запрос.Выполнить().Выбрать();
	
	СтатьяДДС = ?(ВидОплаты=Перечисления.ВидыОплаты.БН,Справочники.СтатьиЗатрат.ПриходОтПокупателейПК,Справочники.СтатьиЗатрат.Выручка);	
	
	ИтогоСуммаДС=0;
	
	ВалютаУпр	=ПараметрыСеанса.ВалютаУпр_2009;
	КурсУпр		=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	КурсВалюты	=ПолучитьКурсВалюты_ПоРусски(Валюта,Дата);
	
	
	
	// нечаева для сотрудника. 21,10,13 +++
	НовРез=запрос.Выполнить().Выгрузить();
	НовРез.Свернуть("Контрагент");
	ПрСотрудник=Ложь;
	Если НовРез.Количество()=1 Тогда
		контраг=Новрез.Получить(0).контрагент;
		Если Контраг=справочники.Контрагенты.НайтиПоКоду("SMN-0600") Тогда // только по сотруднику тогда вычитаем по нему сумму баллов
			ПрСотрудник=Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	// нечаева для сотрудника. 21,10,13
	Пока Выборка.Следующий() Цикл	
		//крохин начало
		Если Выборка.Всего = 0 Тогда Продолжить КонецЕсли;
		//крохин конец
		//крохин начало 24.09.2013
		//для частных лиц уменьшаем сумму ДС на потраченные "спасибо"
		Если Выборка.Контрагент = Подразделение.ЧастноеЛицо.Ведущий или ПрСотрудник Тогда
			//нечаева ++21,10,13
			//Если Выборка.контрагент.родитель = подразделение.частноелицо.ведущий.родитель  Тогда
			//нечаева --21,10,13
			Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
				//оплата баллами
				ИтогоСуммаДС = ИтогоСуммаДС - ОплаченоБаллами.Итог("ВсегоБаллов");
			Иначе
				//возврат оплаты баллами
				ИтогоСуммаДС = ИтогоСуммаДС - НачисленныеБаллы.Итог("ВсегоБаллов");
			КонецЕсли;
		КонецЕсли;
		//крохин конец 24.09.2013
		
		Движение=Движения.ДенежныеСредства.Добавить();		
		
		Движение.Период=Дата;
		
		Движение.ВидДвижения	= ?(КодОперации=Перечисления.КодыОперацийОстатки.Реализация,ВидДвиженияНакопления.Приход,ВидДвиженияНакопления.Расход);
		
		Движение.БанковскийСчет	= Касса;
		Движение.Валюта			= Валюта;
		
		//крохин начало 24.09.2013
		//для частных лиц уменьшаем сумму ДС на потраченные "спасибо"
		//Движение.Сумма			= Выборка.Всего;
		//Если Дата>='20090101' Тогда
		//	Движение.СуммаУпр	= глПересчет(Выборка.Всего,Валюта,КурсВалюты,ВалютаУпр,КурсУпр);		
		//КонецЕсли;
		//Движение.СуммаДокумента	= Выборка.Всего;
		СуммаПроводки = Выборка.Всего;
		Если Выборка.Контрагент = Подразделение.ЧастноеЛицо.Ведущий или ПрСотрудник Тогда			
			//нечаева  18,10,13 ++
			//Если Выборка.контрагент.родитель = подразделение.частноелицо.ведущий.родитель  Тогда
			//нечаева 18,10,13	--
			Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
				//оплата баллами
				СуммаПроводки = СуммаПроводки - ОплаченоБаллами.Итог("ВсегоБаллов");
			Иначе
				//возврат оплаты баллами
				СуммаПроводки = СуммаПроводки - НачисленныеБаллы.Итог("ВсегоБаллов");
			КонецЕсли;	
		КонецЕсли;
		//крохин начало 14.03.2022
		//смешанный вид оплаты
		//Если СуммаОплатыБН <> 0 Тогда
		//+HELP-7465 20251016 Михайловский
		//СуммаПроводки = СуммаПроводки - СуммаОплатыБН - СуммаОплатыБНПодели1;
		СуммаПроводки = СуммаПроводки - СуммаОплатыБН - СуммаОплатыБНПодели;
		//-HELP-7465 20251016 Михайловский
		СтатьяДДС = Справочники.СтатьиЗатрат.Выручка;
		//КонецЕсли;
		//крохин конец 14.03.2022
		Движение.Сумма			= СуммаПроводки;
		Если Дата>='20090101' Тогда
			Движение.СуммаУпр	= глПересчет(СуммаПроводки,Валюта,КурсВалюты,ВалютаУпр,КурсУпр);		
		КонецЕсли;
		Движение.СуммаДокумента	= СуммаПроводки;    
		//крохин конец 24.09.2013
		
		Движение.ВалютаДокумента= Валюта;
		
		Движение.Отправитель	= Выборка.Контрагент;		
		Движение.СтатьяДДС		= СтатьяДДС;
		//+HELP-2684 20250204 Михайловский
		Если ЗначениеЗаполнено(Касса.ПодразделениеДляУчета) И Дата>='20241201'  Тогда
			Движение.Подразделение	= Касса.ПодразделениеДляУчета;
		Иначе
			Движение.Подразделение	= Касса.Владелец;
		КонецЕсли;
		//-HELP-2684 20250204 Михайловский
		//крохин начало
		Движение.Комментарий        = "ОКС нал";
		//крохин конец
		
		//крохин начало 14.03.2022
		//смешанный вид оплаты
		Если СуммаОплатыБН <> 0 Тогда
			СуммаПроводки = СуммаОплатыБН;
			СтатьяДДС = ?(ВидОплаты=Перечисления.ВидыОплаты.БН,Справочники.СтатьиЗатрат.ПриходОтПокупателейПК,Справочники.СтатьиЗатрат.Выручка);
			
			Движение=Движения.ДенежныеСредства.Добавить();		
			
			Движение.Период=Дата;
			
			Движение.ВидДвижения	= ?(КодОперации=Перечисления.КодыОперацийОстатки.Реализация,ВидДвиженияНакопления.Приход,ВидДвиженияНакопления.Расход);
			
			Движение.БанковскийСчет	= Касса;
			Движение.Валюта			= Валюта;
			Движение.Сумма			= СуммаПроводки;
			Если Дата>='20090101' Тогда
				Движение.СуммаУпр	= глПересчет(СуммаПроводки,Валюта,КурсВалюты,ВалютаУпр,КурсУпр);		
			КонецЕсли;
			Движение.СуммаДокумента	= СуммаПроводки;    
			
			Движение.ВалютаДокумента= Валюта;
			
			Движение.Отправитель	= Выборка.Контрагент;		
			Движение.СтатьяДДС		= СтатьяДДС;
			//+HELP-2684 20250204 Михайловский
			Если ЗначениеЗаполнено(Касса.ПодразделениеДляУчета) И Дата>='20241201'  Тогда
				Движение.Подразделение	= Касса.ПодразделениеДляУчета;
			Иначе
				Движение.Подразделение	= Касса.Владелец;
			КонецЕсли;
			//-HELP-2684 20250204 Михайловский
			
			Движение.Комментарий        = "ОКС БН";
			
			
		КонецЕсли;
        //крохин конец 14.03.2022
		
		Если СуммаОплатыБНПодели <> 0 Тогда
			//+HELP-7465 20251016 Михайловский  
			//СуммаПроводки = СуммаОплатыБНПодели1;
			СуммаПроводки = СуммаОплатыБНПодели;
			//+HELP-7465 20251016 Михайловский
			СтатьяДДС = ?(ВидОплаты=Перечисления.ВидыОплаты.БН,Справочники.СтатьиЗатрат.ПриходОтПокупателейПК,Справочники.СтатьиЗатрат.Выручка);
			
