Функция РассчитатьСуммуСебестоимостиПоЧеку(ТС,СтрокаТС)
	СуммаЧека = 0;
	СебестоимостьЧека = 0;
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.НомерЧека = СтрокаТС.НомерЧека Тогда	
			СуммаЧека = СуммаЧека + СтрокаТЧ.Всего;	
			СтрокаСебестоимости=ТС.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");
			Если СтрокаТС <> Неопределено Тогда
				СебестоимостьЧека = СебестоимостьЧека +  СтрокаСебестоимости.СписанаСтоимость/СтрокаСебестоимости.Количество;
			Конецесли;
		КонецЕсли;	
	КонецЦикла;	
	Если СуммаЧека > 0 Тогда
		Процент = Мин(СтрокаТС.Номинал/СуммаЧека,1);
	Иначе
		Процент = 0;
	КонецЕсли;
	Возврат Окр(СебестоимостьЧека*Процент,2);
КонецФункции
