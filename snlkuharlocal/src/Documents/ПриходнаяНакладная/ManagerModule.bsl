
Функция СоздатьПеремещениеИзЛистовНабора(ДокСсылка, СкладНекондиции = Неопределено, ЭтоБрак = Истина) Экспорт
	
	Если СкладНекондиции = Неопределено Тогда
		СкладНекондиции = Справочники.Склады.НайтиПоКоду("STA-63");
	КонецЕсли;
	
	МВТ = Новый МенеджерВременныхТаблиц;
	МассивПеремещений = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ДокОснование", ДокСсылка);
	
	//   |	" + ?(ЭтоБрак, "И Товары.ЭтоБрак", "И Товары.ЭтоНекондиция") + "
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(Товары.Номенклатура.Родитель.Родитель.Родитель, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))) КАК Бренд,
	|	МАКСИМУМ(ЗНАЧЕНИЕ(Справочник.СектораХранения.ПустаяСсылка)) КАК СекторХранения,
	|	СУММА(Товары.Количество) КАК Количество,
	|	МАКСИМУМ(Товары.Единица) КАК Единица,
	|	МАКСИМУМ(Товары.Коэффициент) КАК Коэффициент
	|ПОМЕСТИТЬ ТЧ_Товары_Все
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка.ДокОснование = &ДокОснование
	|	И Товары.Ссылка.Проведен
	|	" + ?(ЭтоБрак, "И Товары.ЭтоБрак", "И Товары.ЭтоНекондиция") + "
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(Товары.Номенклатура.Родитель.Родитель.Родитель, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))) КАК Бренд,
	|	МАКСИМУМ(ЕСТЬNULL(РеквизитыСправочников.ЗначениеРеквизита, ЗНАЧЕНИЕ(Справочник.СектораХранения.ПустаяСсылка))) КАК СекторХранения,
	|	СУММА(Товары.Количество) КАК Количество,
	|	МАКСИМУМ(Товары.Единица) КАК Единица,
	|	МАКСИМУМ(Товары.Коэффициент) КАК Коэффициент
	|ПОМЕСТИТЬ ТЧ_Товары_Сектор
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|		ПО Товары.Номенклатура.Родитель.Родитель.Родитель = РеквизитыСправочников.Справочник
	|ГДЕ
	|	Товары.Ссылка.ДокОснование = &ДокОснование
	|	И Товары.Ссылка.Проведен
	|	И РеквизитыСправочников.ИмяРеквизита = ""СекторНоменклатуры""
	|	" + ?(ЭтоБрак, "И Товары.ЭтоБрак", "И Товары.ЭтоНекондиция") + "
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЧ_Товары_Все.Номенклатура КАК Номенклатура,
	|	ТЧ_Товары_Все.Бренд КАК Бренд,
	|	ВЫБОР
	|		КОГДА ТЧ_Товары_Сектор.СекторХранения <> ЗНАЧЕНИЕ(Справочник.СектораХранения.ПустаяСсылка)
	|			ТОГДА ТЧ_Товары_Сектор.СекторХранения
	|		ИНАЧЕ ТЧ_Товары_Все.СекторХранения
	|	КОНЕЦ КАК СекторХранения,
	|	ТЧ_Товары_Все.Количество КАК Количество,
	|	ТЧ_Товары_Все.Единица КАК Единица,
	|	ТЧ_Товары_Все.Коэффициент КАК Коэффициент
	|ПОМЕСТИТЬ ТЧ_Товары
	|ИЗ
	|	ТЧ_Товары_Все КАК ТЧ_Товары_Все
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЧ_Товары_Сектор КАК ТЧ_Товары_Сектор
	|		ПО ТЧ_Товары_Все.Номенклатура = ТЧ_Товары_Сектор.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЧ_Товары.Бренд КАК Бренд,
	|	ТЧ_Товары.СекторХранения КАК СекторХранения
	|ИЗ
	|	ТЧ_Товары КАК ТЧ_Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТЧ_Товары_Все
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТЧ_Товары_Сектор";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗТовары = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	МассивСекторовХранения = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(ТЗТовары.ВыгрузитьКолонку("СекторХранения"));
	
	Если МассивСекторовХранения.Количество() = 0 Тогда
		Сообщить("Не определили Сектора Хранения");
		Возврат МассивПеремещений;
	КонецЕсли;
	
	ЗапросСектор = Новый Запрос;
	ЗапросСектор.МенеджерВременныхТаблиц = МВТ;
	
	Для Каждого СекторХранения ИЗ МассивСекторовХранения Цикл
		
		ЗапросСектор.УстановитьПараметр("СекторХранения", СекторХранения);
		ЗапросСектор.Текст =
		"ВЫБРАТЬ
		|	ТЧ_Товары.Номенклатура КАК Номенклатура,
		|	ТЧ_Товары.Бренд КАК Бренд,
		|	ТЧ_Товары.СекторХранения КАК СекторХранения,
		|	ТЧ_Товары.Количество КАК Количество,
		|	ТЧ_Товары.Единица КАК Единица,
		|	ТЧ_Товары.Коэффициент КАК Коэффициент
		|ИЗ
		|	ТЧ_Товары КАК ТЧ_Товары
		|ГДЕ
		|	ТЧ_Товары.СекторХранения = &СекторХранения";
		
		УстановитьПривилегированныйРежим(Истина);
		ТЗТоварыСектор = ЗапросСектор.Выполнить().Выгрузить();
		УстановитьПривилегированныйРежим(Ложь);
		
		ДокПеремещение = Документы.ЗаявкаНаПерепаковку.СоздатьПеремещение(ДокСсылка, ТЗТоварыСектор, ДокСсылка.Склад, СкладНекондиции,
			"Создано Перемещение на " + ?(ЭтоБрак, "брак", "некондицию") +
			" из Листов набора, сектор " + ?(СекторХранения = Справочники.СектораХранения.ПустаяСсылка(), "Не указан", Строка(СекторХранения)),
			"ПолученоСкладом", Ложь, Истина);
		
		Если ДокПеремещение <> Неопределено Тогда
			МассивПеремещений.Добавить(ДокПеремещение);
			СообщитьИзМодуля("Создано Перемещение на " + ?(ЭтоБрак, "брак ", "некондицию ") + Строка(ДокПеремещение));
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат МассивПеремещений;
	
КонецФункции
 