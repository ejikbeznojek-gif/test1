Процедура ОбработкаЗаполнения(Основание)	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли; 
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	ДокОснование	= Основание;
	
	//кухарь 04.03.14 начало
	Если ВидОснования="ЛистНабора" тогда;
		ДокОснование=ДокОснование.ДокОснование;
		ВидОснования	= ДокОснование.Метаданные().Имя;	
	КонецЕсли;
	//кухарь 04.03.14
	
	
	Если ВидОснования="РекламационнаяНакладная" Тогда
		Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование.ДокОснование,"Контрагент");
		ЛевыйКонтрагент = ПолучитьРеквизитОбъекта(ДокОснование.ДокОснование,"ЛевыйКонтрагент");
	Иначе
		Контрагент 		= ПолучитьРеквизитОбъекта(ДокОснование,"Контрагент");	
		ЛевыйКонтрагент = ПолучитьРеквизитОбъекта(ДокОснование,"ЛевыйКонтрагент");
	КонецЕсли;
	
	Договор			= ПолучитьРеквизитОбъекта(ДокОснование,"Договор");
	
	ПунктДоставки	= ПолучитьРеквизитОбъекта(ДокОснование,"ПунктДоставки");
	Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	
	БанковскийСчет	= ПолучитьРеквизитОбъекта(ДокОснование,"БанковскийСчет");		
	ОтсрочкаПлатежа = ПолучитьРеквизитОбъекта(ДокОснование,"ОтсрочкаПлатежа");			
	ВидОплаты		= ПолучитьРеквизитОбъекта(ДокОснование,"ВидОплаты");		
	
	Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");
	Если ВидОснования="Перемещение" Тогда
		Склад		= ДокОснование.СкладПолучатель;	
	Иначе		
		Склад		= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");	
	КонецЕсли;	
	Подразделение	= ПолучитьРеквизитОбъекта(ДокОснование,"Подразделение");
	
	//крохин начало
	//Группы товаров пересчитаем заново
	//ГруппыТоваров	= ПолучитьРеквизитОбъекта(ДокОснование,"ГруппыТоваров");
	//крохин конец
	
	ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");	
	
	Валюта			= ПолучитьРеквизитОбъекта(ДокОснование,"Валюта");
	Курс			= ПолучитьРеквизитОбъекта(ДокОснование,"Курс");
	
	
	//крохин начало 03.10.2012
	//ставка НДС
	Если ПунктДоставки.НулеваяСтавкаНДС или Контрагент.НулеваяСтавкаНДС Тогда
		НулеваяСтавкаНДС = Истина;	
	Иначе
		НулеваяСтавкаНДС = Ложь;
	КонецЕсли;
	//крохин конец 03.10.2012
	
	
	Если ВидОснования="Чек" Тогда
		ВариантЗаполнения="Целиком";
		
		ЛевыйКонтрагент=Контрагент;
		//крохин начало 15.11.2012
		ВидОплаты = Перечисления.ВидыОплаты.БН;
		//крохин конец 15.11.2012
		
		//крохин начало 30.01.2013
		//договор и факт.адрес
		Если Договор.Пустая() Тогда
			Договор = ?(Контрагент.ОсновнойДоговорКасса.пустая(),Контрагент.ОсновнойДоговор,Контрагент.ОсновнойДоговорКасса);
		КонецЕсли;
		#ЕСЛИ КЛИЕНТ ТОГДА
			Если ПунктДоставки.Пустая() Тогда
				УстановитьПунктДоставки(ЭтотОбъект);	
			КонецЕсли;
		#КОНЕЦЕСЛИ
		//крохин конец 30.01.2013
		
		
	Иначе		
		#ЕСЛИ КЛИЕНТ ТОГДА
			//Мессерле 9999
			Если ДокОснование.Метаданные().Имя = "ЗаказПоставщику" Тогда
				Если Не ДокОснование.Проведен 	 тогда
					Отказ=ИСТИНА;
					Предупреждение("Основание не может быть помечено на удаление!");
					Возврат;
				Конецесли;	
				Заявка=ДокОснование.товары[0].ЗаявкаПоставщику;
				Если Заявка<>Неопределено и ДокОснование.склад=Справочники.Склады.НайтиПоКоду("SSP-04") тогда 	
					ВариантЗаполнения="Целиком";
				иначе	  
					ВариантЗаполнения=ВыбратьВариантЗаполнения();		
				Конецесли;
			КонецЕсли;
			//Мессерле 9999
		#КОНЕЦЕСЛИ
	КонецЕсли;
	//крохин начало 14.04.2011
	//добавил продажу ИМ
	//Если ВидОснования="РасходнаяНакладная" или ВидОснования="Чек" Тогда
	Если ВидОснования="РасходнаяНакладная" или ВидОснования="Чек" ИЛИ ВидОснования="ПродажаИМ" Тогда	
		//крохин конец 14.04.2011
		КодОперации		= Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
	Иначе
		КодОперации		= Перечисления.КодыОперацийОстатки.ЗакупкаР;
	КонецЕсли;	
	
	ТранспортнаяКомпания = ПолучитьРеквизитОбъекта(ДокОснование,"ТранспортнаяКомпания");
	
	Если ВариантЗаполнения="РазницаСНабором" Тогда
		Комментарий		= "Пересорт по "+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");		
	Иначе
		Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");	
	КонецЕсли; 
	
	Если ВидОснования="ЗаказПоставщику" Тогда
		Если Валюта<>ПараметрыСеанса.ВалютаНац Тогда
			Валюта	=ПараметрыСеанса.ВалютаНац;
			Курс	=ПолучитьКурсВалюты_ПоРусски(Валюта,Дата);		
		КонецЕсли; 
		Скидка=0;
	КонецЕсли;
	
	Если ВидОснования="ПриходнаяНакладная" И НЕ ПолучитьПолномочиеПользователя("ВидимостьПриходныхЦен") Тогда
		ОбнулитьЦены=Истина;	
	Иначе
		ОбнулитьЦены=Ложь;	
	КонецЕсли;
	
	Если ВариантЗаполнения="РазницаСНабором" Тогда
		Форма=Обработки.СравнениеЛистовНабора.ПолучитьФорму();		
		Форма.Документ		=ДокОснование;
		
		РезультатСравнения	=Форма.ПолучитьОшибкиНабора();	
		ТП					=РезультатСравнения.ТП;
		
		Дата				=ДокОснование.Дата;
		ДатаОтгрузки		=Дата;
	КонецЕсли;
	
	//крохин начало 16.06.2011
	Если ЕстьРеквизитДокумента("ДопСкидкаНаНакладную",ДокОснование.Метаданные()) Тогда
		ДопСкидкаНаНакладную =  ДокОснование.ДопСкидкаНаНакладную;
	КонецЕсли;
	//крохин конец 16.06.2011
	
	
	//кухарь 15.04.14 начало
	ЭтоФранч=ложь;
	Если ВидОснования="Перемещение"  Тогда
		если ДокОснование.СкладПолучатель=Справочники.Склады.НайтиПоКоду("SSX-66") тогда
			ЭтоФранч=Истина;
			ЭтотОбъект.КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
		КонецЕсли;
	КонецЕсли;
	
	//Шворобей ВЮ 12.12.2022 ++
	Если ВидОснования = "ЗаявкаНаВозвратОтПокупателя" Тогда
		ЭтоФранч = Истина;
		КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
		Заказ.Загрузить(Основание.Товары.Выгрузить());
		//+HELP-8926 20260327 Михайловский
		Запр = Новый Запрос;
		Запр.Текст =
		"ВЫБРАТЬ
		|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
		|ГДЕ
		|	ХранилищеКодовМаркировки.ДокОснование = &Основание";
		Запр.УстановитьПараметр("Основание", Основание);
		Выб = Запр.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Товары.Загрузить(Основание.Товары.Выгрузить());
		КонецЕсли;
		Для Каждого ТСтр Из Товары Цикл
			ТСтр.ЦенаВозврата = ТСтр.Цена;
		КонецЦикла;	
		//-HELP-8926 20260327 Михайловский
	КонецЕсли;
	//Шворобей ВЮ 12.12.2022 ++
	
	если не ЭтоФранч тогда
		//кухарь 15.04.14 конец
		
		Для Каждого исхСтрокаТЧ Из ДокОснование.Товары Цикл
			СтрокаТЧ = Товары.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);	
			//крохин начало 03.10.2012
			Если НулеваяСтавкаНДС Тогда
				СтрокаТЧ.СтавкаНДС = Перечисления.СтавкиНДС.НДС0;
			Иначе
				СтрокаТЧ.СтавкаНДС = СтрокаТЧ.Номенклатура.Родитель.СтавкаНДС;			
			КонецЕсли;
			//крохин конец 03.10.2012
			
			Если ВариантЗаполнения="НехватающиеЗаявка" Тогда
				СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.Заявка-исхСтрокаТЧ.Количество;
				СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
				СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
			ИначеЕсли ВариантЗаполнения="НехватающиеПодтверждение" Тогда
				СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.ПодтвержденнаяЗаявка-исхСтрокаТЧ.Количество;
				СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
				СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
			ИначеЕсли ВариантЗаполнения="Целиком" Тогда
				Если СтрокаТЧ.Заявка=0 Тогда
					СтрокаТЧ.Заявка	=СтрокаТЧ.Количество;			
				КонецЕсли;
				Если СтрокаТЧ.ПодтвержденнаяЗаявка=0 Тогда
					СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Количество;			
				КонецЕсли; 
			ИначеЕсли ВариантЗаполнения="РазницаСНабором" Тогда
				СтрокаТП=ТП.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");
				Если СтрокаТП=Неопределено Тогда
					СтрокаТЧ.Количество=0;	
				Иначе
					СтрокаТЧ.Количество				=-СтрокаТП.Разница;
					СтрокаТЧ.Заявка					=-СтрокаТП.Разница;
					СтрокаТЧ.ПодтвержденнаяЗаявка	=-СтрокаТП.Разница;
				КонецЕсли;			
			КонецЕсли;	
			
			//крохин начало 14.06.2012
			//ЛН
			Если ДокОснование.Метаданные().Имя = "ЛистНабора" Тогда
				СтрокаТЧ.Заявка					=СтрокаТЧ.Количество;
				СтрокаТЧ.ПодтвержденнаяЗаявка	=СтрокаТЧ.Количество;
			КонецЕсли;
			//крохин конец 14.06.2012
			
			Если ОбнулитьЦены Тогда
				СтрокаТЧ.Цена=0;		
				СтрокаТЧ.ЦенаБезСкидки=0;
			КонецЕсли;	
			
			Если СтрокаТЧ.Количество=0 Тогда
				Товары.Удалить(СтрокаТЧ);	
			Иначе
				Если СтрокаТЧ.СтавкаНДС.Пустая() Тогда
					СтрокаТЧ.СтавкаНДС=ПолучитьСтавкуНДС(СтрокаТЧ.Номенклатура);			
				КонецЕсли; 
				Если ВидОснования="ЗаказПоставщику" И НЕ ОбнулитьЦены Тогда
					СтрокаТЧ.ВсегоБезСкидки	=исхСтрокаТЧ.Всего;
					СтрокаТЧ.Всего			=исхСтрокаТЧ.Всего;				
					СтрокаТЧ.Скидка			=0;
					Если ДокОснование.Валюта<>Валюта Тогда
						СтрокаТЧ.Всего=глПересчет(СтрокаТЧ.Всего,ДокОснование.Валюта,ДокОснование.Курс,Валюта,Курс);				
					КонецЕсли;				
					РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект,"ОтВсего");
				Иначе	
					Если ВидОснования="ВводОстатковТМЦ" Тогда
						РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект,"ОтВсего");
					Иначе
						//было РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);			
						// нечаева +++ 24,06,13
						Если ВидОснования="Чек" Тогда
							Если Не исхСтрокаТЧ.Акция.пустая() Тогда
