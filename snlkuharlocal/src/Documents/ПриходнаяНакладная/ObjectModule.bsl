	//крохин конец 02.03.2011
	
КонецПроцедуры

Процедура ПересчетДопРасходов() Экспорт
	СуммаДопРасходов=0;	
	Для Каждого СтрокаДР Из ДопРасходы Цикл
		СуммаДопРасходов=СуммаДопРасходов+глПересчет(СтрокаДР.Всего,СтрокаДР.Валюта,СтрокаДР.Курс,Валюта,Курс);
	КонецЦикла;
	
	Всего=Товары.Итог("Всего");
	Если Всего=0 ИЛИ СуммаДопРасходов=0 Тогда Возврат КонецЕсли; 
	
	МаксРасходы=-10000000000000;
	СтрокаМаксРасходы=Неопределено;
	Для Каждого СтрокаТЧ ИЗ Товары Цикл
		СтрокаТЧ.ДопРасходы=СтрокаТЧ.Всего*СуммаДопРасходов/Всего;
		Если СтрокаТЧ.ДопРасходы>МаксРасходы Тогда
			МаксРасходы=СтрокаТЧ.ДопРасходы;		
			СтрокаМаксРасходы=СтрокаТЧ;
		КонецЕсли;		
	КонецЦикла;	
	
	Хвост=СуммаДопРасходов-Товары.Итог("ДопРасходы");
	Если Хвост<>0 И СтрокаМаксРасходы<>Неопределено Тогда
		СтрокаМаксРасходы.ДопРасходы=СтрокаМаксРасходы.ДопРасходы+Хвост;
	КонецЕсли; 
КонецПроцедуры

Процедура ПровестиПоТоварамВПути(ЗаписыватьДвижения=Ложь) Экспорт
	Если ТипЗнч(ДокОснование)<>Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ НЕ ДокОснование.Проведен Тогда 
		Если ЗаписыватьДвижения Тогда
			Движения.ТоварыВПути.Очистить();
			Движения.ТоварыВПути.Записать();	
			
			Возврат;
		КонецЕсли;	
	КонецЕсли; 
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	Номенклатура.Родитель				КАК Модель,
	|	СУММА(Количество)					КАК Количество,
	|	СУММА(РасчетнаяСумма)				КАК Сумма,
	|	СУММА(Всего+ДопРасходыПоИнвойсу)	КАК СуммаПоставщика,
	|	ВЫБОР КОГДА СУММА(Количество)<>0 ТОГДА СУММА(РасчетнаяСумма)/СУММА(Количество) КОНЕЦ КАК ЦенаПрихода,
	|	ВЫБОР КОГДА СУММА(Количество)<>0 ТОГДА СУММА(Всего+ДопРасходыПоИнвойсу)/СУММА(Количество) КОНЕЦ КАК ЦенаПоставщика
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары
	|ГДЕ
	|	Ссылка.Машина=&Машина	
	|	И Ссылка.Проведен
	|СГРУППИРОВАТЬ ПО Номенклатура.Родитель";
	
	Запрос.УстановитьПараметр("Машина",ДокОснование.Машина);
	
	ВыборкаЦен=Запрос.Выполнить().Выбрать();
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Заказ,
	|	Номенклатура,
	|	КоличествоОстаток		КАК КолКон,
	|	СуммаОстаток			КАК СумКон,
	|	СуммаПоставщикаОстаток  КАК СумПостКон
	|ИЗ
	//крохин начало 15.04.2015
	//|	РегистрНакопления.ТоварыВПути.Остатки(&Дата1,Заказ.Машина=&Машина";
	|	РегистрНакопления.ТоварыВПути.Остатки(&Дата1,Заказ.Машина В (&Машина)";
	//крохин конец 15.04.2015
	Если ЗначениеНеЗаполнено(ДокОснование.Машина) Тогда
		Запрос.Текст=Запрос.Текст+" И Заказ=&Заказ ";		
	КонецЕсли;	
	Запрос.Текст=Запрос.Текст+"
	| И Номенклатура В (ВЫБРАТЬ РАЗЛИЧНЫЕ Номенклатура ИЗ Документ.ПриходнаяНакладная.Товары ГДЕ Ссылка=&Ссылка)) КАК ТоварыВПутиОстатки	
	|УПОРЯДОЧИТЬ ПО Заказ.Дата,Заказ.Номер
	|ИТОГИ СУММА(КолКон),СУММА(СумКон),СУММА(СумПостКон) ПО Номенклатура";
	
	Запрос.УстановитьПараметр("Дата1",МоментВремени());
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	//крохин начало 15.04.2015
	//Запрос.УстановитьПараметр("Машина",ДокОснование.Машина);
	СписокМашин = новый СписокЗначений;
	Для Каждого СтрокаТЧ Из ЗаказыПоставщикам Цикл
		СписокМашин.Добавить(СтрокаТЧ.ЗПС.Машина);
	КонецЦикла;
	//крохин начало 29.04.2015
	Если НЕ ЗначениеНеЗаполнено(ДокОснование.Машина) Тогда
		СписокМашин.Добавить(Докоснование.Машина);	
	КонецЕсли;
	//крохин конец 29.04.2015
	
	Запрос.УстановитьПараметр("Машина",СписокМашин);
	//крохин конец 15.04.2015
	Запрос.УстановитьПараметр("Заказ",ДокОснование);
	
	ТО=Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОшибкиОкругления=0;
	
	ВалютаУпр	=ПараметрыСеанса.ВалютаУпр_2009;
	КурсУпр		=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.Количество>0 Тогда
			НужноСписать=СтрокаТЧ.Количество;
			Если НужноСписать=0 Тогда Продолжить КонецЕсли; 
			
			СтрокаОстатка=ТО.Строки.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");			
			
			Если СтрокаОстатка<>Неопределено Тогда				
				Для Каждого СтрокаЗаказа Из СтрокаОстатка.Строки Цикл
					Если НужноСписать<=0 Тогда Прервать КонецЕсли;				
					
					ТекКол			= Макс(0,Мин(НужноСписать,СтрокаЗаказа.КолКон));					
					ТекСуммаПрихода	= 0;
					ТекСуммаПути	= Окр(?(ТекКол=СтрокаЗаказа.КолКон,СтрокаЗаказа.СумКон,		ТекКол*СтрокаЗаказа.СумКон/СтрокаЗаказа.КолКон),2,1);
					ТекСуммаПост	= Окр(?(ТекКол=СтрокаЗаказа.КолКон,СтрокаЗаказа.СумПостКон,	ТекКол*СтрокаЗаказа.СумПостКон/СтрокаЗаказа.КолКон),2,1);
					
					ДвижениеПоПути=Неопределено;
					
					Если ТекКол<>0 Тогда
						ТекСуммаПрихода					= глПересчет(СтрокаТЧ.Цена*ТекКол,Валюта,Курс,ВалютаУпр,КурсУпр);
						
						ДвижениеПоПути=Движения.ТоварыВПути.Добавить();					
						
						ДвижениеПоПути.Период			=Дата;
						
						ДвижениеПоПути.ВидДвижения		=ВидДвиженияНакопления.Расход;
						ДвижениеПоПути.Заказ			=СтрокаЗаказа.Заказ;
						ДвижениеПоПути.Номенклатура		=СтрокаТЧ.Номенклатура;
						ДвижениеПоПути.Количество		=ТекКол;
						ДвижениеПоПути.Сумма			=ТекСуммаПути;
						ДвижениеПоПути.СуммаПоставщика	=ТекСуммаПост;						
						
						ОшибкиОкругления				=ОшибкиОкругления+(ТекСуммаПути-ТекСуммаПрихода);
					КонецЕсли;					
					
					СтрокаЗаказа.КолКон		=СтрокаЗаказа.КолКон		- ТекКол;
					СтрокаЗаказа.СумКон		=СтрокаЗаказа.СумКон		- ТекСуммаПути;
					СтрокаЗаказа.СумПостКон	=СтрокаЗаказа.СумПостКон	- ТекСуммаПост;
					
					НужноСписать=НужноСписать-ТекКол;					
				КонецЦикла;
				
				Если НужноСписать>0 Тогда
					ВыборкаЦен.Сбросить();
					Если ВыборкаЦен.НайтиСледующий(СтрокаТЧ.Номенклатура.Родитель,"Модель") Тогда
						ЦенаПоставщика=ВыборкаЦен.ЦенаПоставщика;
						//мессерле 26.06.12
						//косяк в коде		
					иначе 
						ЦенаПоставщика=0;
						//мессерле	
					КонецЕсли;
					
					Движение=Движения.ТоварыВПути.Добавить();					
					
					Движение.Период			=Дата;
					Движение.ВидДвижения	=ВидДвиженияНакопления.Расход;
					Движение.Заказ			=СтрокаЗаказа.Заказ;
					Движение.Номенклатура	=СтрокаТЧ.Номенклатура;
					Движение.Количество		=НужноСписать;
					Движение.Сумма			=глПересчет(СтрокаТЧ.Цена*НужноСписать,Валюта,Курс,ВалютаУпр,КурсУпр);
					Движение.СуммаПоставщика=НужноСписать*ЦенаПоставщика;					
				КонецЕсли;
			Иначе
				Движение=Движения.ТоварыВПути.Добавить();
				
				Движение.Период			=Дата;
				
				Движение.ВидДвижения	=ВидДвиженияНакопления.Расход;
				Движение.Заказ			=ДокОснование;
				Движение.Номенклатура	=СтрокаТЧ.Номенклатура;
				Движение.Количество		=СтрокаТЧ.Количество;
				
				Движение.Сумма			=глПересчет(СтрокаТЧ.Всего,Валюта,Курс,ВалютаУпр,КурсУпр);
				Движение.СуммаПоставщика=0;
			КонецЕсли;		
		КонецЕсли;	
	КонецЦикла; 
	
	Если ОшибкиОкругления<>0 Тогда		
		Движение=Движения.Затраты.Добавить();
		
		Движение.Период			= Дата;
		
		Движение.Подразделение	= Подразделение;
		Движение.СтатьяЗатрат   = Константы.СтатьяЗатратПоОкруглениямТовараВПути.Получить();
		
		Движение.СуммаУпр		= ОшибкиОкругления;
		
		Движение.ВалютаДокумента= ПараметрыСеанса.ВалютаУпр_2009;
		Движение.СуммаДокумента	= ОшибкиОкругления;
		
		//крохин начало
		Движение.Комментарий        = "Ошибки округления в ПНК";
		//крохин конец
		
	КонецЕсли;	
	
	Если ЗаписыватьДвижения Тогда
		Движения.ТоварыВПути.Записать();	
		Движения.Затраты.Записать();
	КонецЕсли; 
КонецПроцедуры

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		НаборЗаписей.Очистить();
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

Процедура ПровестиПоГТД(Записывать=Ложь) Экспорт
	Если ГТД.Пустая() Тогда	
		Движения.ОстаткиГТД.Очистить();
	Иначе
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура.Родитель КАК Модель,
		|	СУММА(Количество) КАК Количество
		|ИЗ
		|	Документ.ПриходнаяНакладная.Товары
		|ГДЕ
		|	Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Номенклатура.Родитель";
		
		Запрос.УстановитьПараметр("Ссылка",Ссылка);
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.Количество<>0 Тогда
				Движение=Движения.ОстаткиГТД.Добавить();				
				
				Движение.Период=НачалоДня(Дата);
				Движение.ВидДвижения	=ВидДвиженияНакопления.Приход;
				
				Движение.Номенклатура	=Выборка.Модель;
				Движение.ГТД			=ГТД;
				Движение.Количество		=Выборка.Количество;			
			КонецЕсли;	
		КонецЦикла;		
	КонецЕсли;
	Если Записывать Тогда
		Движения.ОстаткиГТД.Записать();	
	КонецЕсли; 
КонецПроцедуры


//СОБЫТИЯ ОБЪЕКТА
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	

	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;

	ДополнительныеСвойства.Вставить("Начало", ТекущаяУниверсальнаяДатаВМиллисекундах());	
	ДополнительныеСвойства.Вставить("НачСостНакладной", Ссылка.СостояниеНакладной); //Ратманов 14.04.2026	

	если Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение и ЭтоНовый() тогда
		#Если клиент тогда
			Сообщить("В ЦО запрещено создание документов по виртуальным складам");
		#КонецЕсли
		отказ=Истина;
	КонецЕсли;

	Если КодОперации = Перечисления.КодыОперацийОстатки.Комиссия И Не ЗначениеЗаполнено(СкладКомиссия) Тогда
		
		СообщитьИзМодуля("Не заполнен реквизит ""Склад комиссия""!");
			
		Отказ = Истина;
		
		Возврат;
		
	КонецЕсли;

