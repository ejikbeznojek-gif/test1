						|	Претензия.ДокОснование = &ДокОснование
						|	И Претензия.Проведен";
						Запрос.УстановитьПараметр("ДокОснование",Ссылка);
						Выборка = запрос.Выполнить().Выбрать();
						Пока Выборка.Следующий() Цикл
							ДокПретензияОбъект = Выборка.Ссылка.ПолучитьОбъект();
							Если НачалоДня(ДокПретензияОбъект.Дата) <> НачалоДня(Дата) Тогда
								РежимЗаписиПретензии = ?(ДокПретензияОбъект.проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись);	
								ДокПретензияОбъект.Дата = КонецДня(Дата);
								ДокПретензияОбъект.записать(РежимЗаписиПретензии);
								#Если Клиент Тогда
									сообщить("изменена дата ПРТ "+ДокПретензияОбъект.номер + " к ПНК "+Номер);
								#КонецЕсли
							КонецЕсли;
						КонецЦикла;
						
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		//Периодически кривой объём
		если СостояниеНакладной=Перечисления.СостоянияНакладной.Принята и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.Склад тогда
			СтрокаТЗ=ФинальныйПересчетКоробокИОбъемов(ЭтотОбъект);
			КоличествоКоробок=СтрокаТЗ.КоличествоКоробок;
