					Партия1.ОбменДанными.Загрузка=ИСТИНА;
					Партия1.Записать();
					Партия1.ОбменДанными.Загрузка=ЛОЖЬ;
					партия=партия1.Ссылка;
					Сообщить("Создана новая партия. ЗАПОЛНИТЕ в ней ИМ7!");
					фор=партия.ПолучитьФорму("ФормаЭлемента");
					фор.Открыть();
				иначе
					Партия=Партия;
				Конецесли;	
			Конецесли;
		Конецесли;	
		
		// Скопировал из РНК. Чтобы ПНК в работе писались текущей датой
		Если
			(ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение  ИЛИ ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение)
			И СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе 
			И НеКонтролироватьТА=Ложь 
			И РежимЗаписи=РежимЗаписиДокумента.Проведение
			И Дата<ТекущаяДата()		
			И НЕ ПараметрыСеанса.ОтключитьКонтрольРезервов
			Тогда
			если не ПараметрыСеанса.ЗапущенаОбработка тогда
				Ответ=Вопрос("Резервные накладные корректируются только на текущую дату ! Изменить дату на текущую ?",РежимДиалогаВопрос.ОКОтмена,10);				
				Если Ответ=КодВозвратаДиалога.ОК Тогда
					мТекущаяДатаДокумента = Дата;
					Дата					=ТекущаяДата();
					Если ПроверитьНомерДокумента(ЭтотОбъект, мТекущаяДатаДокумента) Тогда		
						мТекущаяДатаДокумента	=Дата;			
					Иначе		
						Дата					=мТекущаяДатаДокумента;
					КонецЕсли;
				Иначе
					Сообщить("Истёк таймаут вопроса на смену даты.");
					Отказ=Истина;					
					Возврат;		
				КонецЕсли; 
			иначе
				Дата=ТекущаяДата();
			КонецЕсли;
		КонецЕсли;		
		
		
	#Конецесли
	
	//Мессерле 
	Ном=-1000000;
	Для Каждого СтрокаТЧ Из Товары Цикл			
		
		Если Сокрлп(СтрокаТЧ.ИдСтроки)<>"" тогда
			поз=Найти(СтрокаТЧ.ИдСтроки,"*");
