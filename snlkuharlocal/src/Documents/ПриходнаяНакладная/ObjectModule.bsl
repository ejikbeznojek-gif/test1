	КонецЕсли;
	// Кухарь А.Ю.  31.03.2026 конец
	

	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если Проведен И СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе Тогда
		
		Если ЗначениеЗаполнено(ДокОснование) И ТипЗнч(ДокОснование)=Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Если ДокОснование.СостояниеЗаказа<>Перечисления.СостояниеЗаказаПоставщику.Получен Тогда
				ЗаказПоставщику=ДокОснование.ПолучитьОбъект();			
				Если ЗаказПоставщику<>Неопределено Тогда //на случай битых ссылок на складах
					ЗаказПоставщику.СостояниеЗаказа=Перечисления.СостояниеЗаказаПоставщику.Получен;
					ЗаказПоставщику.Записать(?(ЗаказПоставщику.Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));						
				КонецЕсли;			
			КонецЕсли;	
		КонецЕсли;
		
		Для Каждого СтрокаТЧ Из ЗаказыПоставщикам Цикл
			Если НЕ СтрокаТЧ.ЗПС.Пустая() И СтрокаТЧ.ЗПС.СостояниеЗаказа<>Перечисления.СостояниеЗаказаПоставщику.Получен Тогда				
				ЗаказПоставщику=СтрокаТЧ.ЗПС.ПолучитьОбъект();					
				Если ЗаказПоставщику<>Неопределено Тогда //на случай битых ссылок на складах
					ЗаказПоставщику.СостояниеЗаказа=Перечисления.СостояниеЗаказаПоставщику.Получен;
					ЗаказПоставщику.Записать(?(ЗаказПоставщику.Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
				Конецесли;
			КонецЕсли;
		КонецЦикла; 
	КонецЕсли;
	
	Если ДополнительныеСвойства.НачСостНакладной<>СостояниеНакладной Тогда
		ЗаписатьИзменениеСостоянияНакладной(Ссылка,СостояниеНакладной);
	КонецЕсли;
	
	// +++ 2012-01-18, Родионов, "заполнение первичной группы номенклатуры при приемке ПНК"
	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение
		И (СостояниеНакладной = Перечисления.СостоянияНакладной.Принята ИЛИ СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКПриемке) Тогда

		ЗаполнитьПервичнуюГруппуНоменклатуры(Товары.ВыгрузитьКолонку("Номенклатура"));

	КонецЕсли;
	// "заполнение первичной группы номенклатуры при приемке ПНК", Родионов, 2012-01-18 +++

	Если НужноВыгружать Тогда
		ЗанестиФилиалыВРегистрПолучателей(ЭтотОбъект);
	КонецЕсли;

	Если Не Отказ 
		И (КодОперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя
		ИЛИ КодОперации = Перечисления.КодыОперацийОстатки.Комиссия)
		И НЕ ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда 
		
		Если  СостояниеНакладной = Перечисления.СостоянияНакладной.Принята 
			И ДополнительныеСвойства.НачСостНакладной <> СостояниеНакладной 
			И ОбщегоНазначения_ПИ.ЕстьЛНСМаркировкой(Ссылка)
			И не Документы.ХранилищеКодовМаркировки.ПроверитьНаличиеХКМ(Ссылка,Перечисления.ПланФакт.Факт) Тогда
			
			РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ПНК_Факт(Ссылка);	
			если не РезультатРаботыСХКМ.Успешно тогда
				РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
				СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				отказ = Истина;	
			КонецЕсли;		
		КонецЕсли; 
		
		
		Если ДополнительныеСвойства.НачСостНакладной = Перечисления.СостоянияНакладной.Принята
			И ДополнительныеСвойства.НачСостНакладной <> СостояниеНакладной 
			И Документы.ХранилищеКодовМаркировки.ПроверитьНаличиеХКМ(Ссылка,Перечисления.ПланФакт.Факт) Тогда   		
			
			РезультатРаботыСХКМ	=	Документы.ХранилищеКодовМаркировки.Отменить_ХКМ_к_НАК(Ссылка,Перечисления.ПланФакт.Факт);				 		
			если не РезультатРаботыСХКМ.Успешно тогда
				РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось отменить хранилище кодов маркировки");
				СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				отказ = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

