Процедура УстановитьСостояниеОжиданиеОбработкиЧЗ() 
    НачСостояние = Ссылка.СостояниеНакладной; 
	УстановленноеСостояние = СостояниеНакладной; 
	
	Если НачСостояние <> УстановленноеСостояние
		И НачСостояние = Перечисления.СостоянияНакладной.Сканирование
		И УстановленноеСостояние = Перечисления.СостоянияНакладной.ГотоваКПриемке 
		И КодОперации = Перечисления.КодыОперацийОстатки.ЗакупкаР
		И ТребуетсяМаркировка 
		И Организация <> Справочники.Организации.НайтиПоКоду("SS-001") 
		И НЕ ОбработаноЧЗ Тогда
	
		СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ; 
		
	//Валетов+ 17.06.2026 Проблема 0000000079
	ИначеЕсли НачСостояние <> УстановленноеСостояние
		И НачСостояние = Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ
		И (УстановленноеСостояние = Перечисления.СостоянияНакладной.ГотоваКПриемке ИЛИ УстановленноеСостояние = Перечисления.СостоянияНакладной.Принята) 
		И КодОперации = Перечисления.КодыОперацийОстатки.ЗакупкаР 
