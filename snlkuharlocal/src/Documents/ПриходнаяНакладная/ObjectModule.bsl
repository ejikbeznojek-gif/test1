КонецПроцедуры 

Процедура ЗаполнитьОМАгрегацияПоКоробкам() 
	
	Запрос = новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	МаркировкаТоваровИСМП.Ссылка КАК ДокМаркировки,
	             |	МаркировкаТоваровИСМП.Статус КАК Статус
	             |ИЗ
	             |	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	             |ГДЕ
	             |	МаркировкаТоваровИСМП.Проведен
	             |	И МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
	             |	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	             |	И МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)";
	Запрос.УстановитьПараметр("ДокументОснование",Ссылка);
	Выборка = запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
	
		ЗаписатьВЛог("Отладка","Начало заполнений агрегации Коробка по ПНК "+Номер,"Информация");	
		
		ДокМаркировки = Выборка.ДокМаркировки;
		
		Запрос = новый запрос;
		запрос.Текст=
		"ВЫБРАТЬ
		|	Лист.Ссылка КАК ДокументОснование,
		|	Лист.КодАгрегации КАК ШтрихкодКоробки
		|ИЗ
		|	Документ.ЛистНабора КАК Лист
		|ГДЕ
		|	Лист.Проведен
		|	И Лист.КодАгрегации <> &КодАгрегации
		|	И Лист.ДокОснование = &ДокОснование"; 
		запрос.УстановитьПараметр("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
		запрос.УстановитьПараметр("ДокОснование",Ссылка);
		ДокМаркировкиОбъект = ДокМаркировки.получитьобъект();
		ДокМаркировкиОбъект.ШтрихкодыКоробок.Загрузить(запрос.Выполнить().Выгрузить());
		ДокМаркировкиОбъект.ШтрихкодыУпаковок.Очистить();
		ДокМаркировкиОбъект.Дата = ТекущаяДата(); 
		ДокМаркировкиОбъект.Записать();		
		 
		РезультатСоздания = Документы.МаркировкаТоваровИСМП.ЗаполнитьШтрихкодыУпаковокПоЛистамНабора(ДокМаркировки,Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
				
		если не РезультатСоздания.Успешно тогда
			СообщитьИзМодуля(СтрСоединить(РезультатСоздания.Ошибки,","));
			ЗаписатьВЛог("Отладка","Ошибка заполнений агрегации Коробка по ПНК "+Номер+". Заполнение агрегации "+ДокМаркировки+". Тип - Коробка." 
			+ " Ошибка - "+СтрСоединить(РезультатСоздания.Ошибки,","),"Информация");					
			отказ=Истина;  
		иначе
			ЗаписатьВЛог("Отладка","Функция заполнения агрегации вернула успешное заполнений агрегации Коробка по ПНК "+Номер+". Заполнение агрегации "+ДокМаркировки+". Тип - Коробка ","Информация");
		КонецЕсли;
	КонецЕсли;
	
	
