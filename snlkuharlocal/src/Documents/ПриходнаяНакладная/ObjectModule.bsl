Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	//кухарь 13.05.14 начало
	#если клиент тогда
		Запрос=новый Запрос;
		запрос.Текст="ВЫБРАТЬ
		|	РекламационнаяНакладная.Ссылка
		|ИЗ
		|	Документ.РекламационнаяНакладная КАК РекламационнаяНакладная
		|ГДЕ
		|	РекламационнаяНакладная.Проведен
		|	И РекламационнаяНакладная.ДокОснование = &ДокОснование";
		запрос.УстановитьПараметр("ДокОснование",ЭтотОбъект.Ссылка);
		результат=запрос.Выполнить().Выгрузить();
		если результат.Количество()>0 тогда
			сообщить("Существуют не удалённые рекламации к этой ПНК. Удалите их перед удалением накладной");
			отказ=Истина;
		КонецЕсли;
	#КонецЕсли
	//кухарь 13.05.14 конец
	
	
	ОчиститьДвиженияДокументаПоИстории(Ссылка);	
	
