					ДатаПервойРКМ = ПолучитьРеквизитШапки(ПерваяРКМ,"Дата","Документ");
					если ЗначениеЗаполнено(ДатаПервойРКМ) и ДатаПервойРКМ <> Дата тогда 
						Дата = ДатаПервойРКМ;
