		КонецЕсли;
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект,"ОтВсего");
	КонецЦикла;
	//крохин конец 03.10.2012
	//Кухарь 19.01.18 начало
	ГосНомерАМЭкспедитора="";
	ФиоЭкспедитора="";
	ТелефонЭкспедитора="";
	ВремяПерегруза="";
	
	//Кухарь 19.01.18 конец	
		
//Кухарь 16.01.19 начало
ТрудозатратыНаТермоусадку=0;
ТрудозатратыНаДО=0;
ТрудозатратыНаНабор=0;
ТрудозатратыНаПаллетирование=0;
ТрудозатратыНаСканирование=0;
ВремяНаДО=0;
ВремяНаНабор=0;
ВремяНаПаллетирование=0;
ВремяНаСканирование=0;
ВремяНаТермоусадку=0;
//Кухарь 16.01.19 конец

//крохин начало 26.01.2022
ЗаказыПоставщикам.Очистить();
ДокОснование = Неопределено;
//крохин конец 26.01.2022

//крохин начало 05.04.2022
Рекламации.Очистить();
Заказ.Очистить();
//крохин конец 05.04.2022

	
