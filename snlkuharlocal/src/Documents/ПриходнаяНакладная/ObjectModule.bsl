			СтрокаТЧ.СуммаПоДокументам=СтрокаТЧ.ПодтвержденнаяЗаявка*СтрокаТЧ.Цена;		
		КонецЦикла;
		
		СуммаДокумента		= Товары.Итог("Всего");
