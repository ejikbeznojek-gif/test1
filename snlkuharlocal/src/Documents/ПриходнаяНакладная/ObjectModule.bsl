Функция ЗаписатьДК()
	//крохин начало 20.10.2011
	//в офисе ДК не перезаписываем
	Если ПараметрыСеанса.ТипУзла <> Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда 
		Возврат Ложь;	 
	КонецЕсли;
	//крохин конец 20.10.2011
	ДКОбъект = Дк.ПолучитьОбъект();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ДисконтныеКартыЧеки.Сумма КАК Итого
	|ИЗ
	|	Справочник.ДисконтныеКарты.Чеки КАК ДисконтныеКартыЧеки
	|ГДЕ
	|	ДисконтныеКартыЧеки.Ссылка = &ДК
	|	И ДисконтныеКартыЧеки.НомерЧека = &Чек
	|	И ДисконтныеКартыЧеки.ДатаЧека = &ДатаЧека";
	Запрос.УстановитьПараметр("Чек",Ссылка.Номер);
	Запрос.УстановитьПараметр("ДК",ДК);
	Запрос.УстановитьПараметр("ДатаЧека",Ссылка.Дата);
	Выборка = Запрос.Выполнить().Выбрать();
	Если  Выборка.Следующий() Тогда
		Если Выборка.Итого <> -СуммаДокумента Тогда
			#Если Клиент Тогда
				Сообщить("Изменение суммы чека, пробитого по ДК, невозможно");
			#КонецЕсли
			Возврат Истина;
		иначе
			Возврат Ложь;
		Конецесли;
	иначе
		Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
			СуммаСкидки = Товары.Итог("ВсегоБезСкидки")-Товары.Итог("Всего");
			
			СтрокаЧековДК = ДКОбъект.Чеки.Добавить();
			СтрокаЧековДК.ДатаЧека = Ссылка.Дата;
			СтрокаЧековДК.НомерЧека = Ссылка.Номер;
			СтрокаЧековДК.Количество = КоличествоДокумента;
			СтрокаЧековДК.Кассир = ПараметрыСеанса.Пользователь;
			СтрокаЧековДК.Подразделение = Склад.Подразделение;
			СтрокаЧековДК.ПроцентСкидки = Скидка;
			СтрокаЧековДК.Сумма = СуммаДокумента;
			СтрокаЧековДК.СуммаСкидки =  СуммаСкидки;
		иначе
			СуммаСкидки = Товары.Итог("ВсегоБезСкидки")-Товары.Итог("Всего");
			
			СтрокаЧековДК = ДКОбъект.Чеки.Добавить();
			СтрокаЧековДК.ДатаЧека = Ссылка.Дата;
			СтрокаЧековДК.НомерЧека = Ссылка.Номер;
			СтрокаЧековДК.Количество = -КоличествоДокумента;
			СтрокаЧековДК.Кассир = ПараметрыСеанса.Пользователь;
			СтрокаЧековДК.Подразделение = Склад.Подразделение;
			СтрокаЧековДК.ПроцентСкидки = Скидка;
			СтрокаЧековДК.Сумма = -СуммаДокумента;
			СтрокаЧековДК.СуммаСкидки =  -СуммаСкидки;
			
		КонецЕсли;
		
		Для Каждого СтрокаТоваров Из Товары Цикл
			Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
				
				СтрокаПокупкиДК = ДКОбъект.Покупки.Добавить();
				СтрокаПокупкиДК.Количество = СтрокаТоваров.Количество;
				СтрокаПокупкиДК.Номенклатура = СтрокаТоваров.Номенклатура;
				СтрокаПокупкиДК.Сумма = СтрокаТоваров.Всего;
				СтрокаПокупкиДК.СуммаСкидки = СтрокаТоваров.ВсегоБезСкидки - СтрокаТоваров.Всего  ;
			иначе
				СтрокаПокупкиДК = ДКОбъект.Покупки.Добавить();
				СтрокаПокупкиДК.Количество = -СтрокаТоваров.Количество;
				СтрокаПокупкиДК.Номенклатура = СтрокаТоваров.Номенклатура;
				СтрокаПокупкиДК.Сумма = -СтрокаТоваров.Всего;
				СтрокаПокупкиДК.СуммаСкидки = -(СтрокаТоваров.ВсегоБезСкидки - СтрокаТоваров.Всего)  ;
			КонецЕсли;
			
		КонецЦикла;
		
		ДКОбъект.Покупки.Свернуть("Номенклатура","Количество,Сумма,СуммаСкидки");
		Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
			ДКОбъект.ОбщаяСумма = ДКОбъект.ОбщаяСумма + СуммаДокумента;
			ДКОбъект.ОбщееКоличество = ДКОбъект.ОбщееКоличество + КоличествоДокумента;
		Иначе
			ДКОбъект.ОбщаяСумма = ДКОбъект.ОбщаяСумма - СуммаДокумента;
			ДКОбъект.ОбщееКоличество = ДКОбъект.ОбщееКоличество - КоличествоДокумента;
			
		КонецЕсли;
		Если КодОперации = Перечисления.КодыОперацийОстатки.Реализация Тогда
			Если ВидОплаты = Перечисления.ВидыОплаты.БН Тогда
				ДКОбъект.СуммаБН = ДКОбъект.СуммаБН + СуммаДокумента;
			иначе
				ДКОбъект.СуммаНал = ДКОбъект.СуммаНал + СуммаДокумента;
			КонецЕсли;
		иначе
			Если ВидОплаты = Перечисления.ВидыОплаты.БН Тогда
				ДКОбъект.СуммаБН = ДКОбъект.СуммаБН - СуммаДокумента;
			иначе
				ДКОбъект.СуммаНал = ДКОбъект.СуммаНал - СуммаДокумента;
			КонецЕсли;
			
			
		Конецесли;
		ДКОбъект.Записать();
		Возврат Ложь;
	КонецЕсли;
КонецФункции


Функция РассчитатьСкидкуДК(ОбщаяСумма)
	Если ДК.ЧленКлуба Тогда
		Если ОбщаяСумма < 15000 тогда
			//крохин начало 16.02.2012
			//начальная скидка изменилась
			//Возврат 3;
			Если Дата >= '20120217' Тогда 
				Возврат 5;
			Иначе
				Возврат 3;
			КонецЕсли;
			//крохин конец 16.02.2012
		ИначеЕсли ОбщаяСумма < 30000 Тогда 
			Возврат 5;
		ИначеЕсли ОбщаяСумма < 45000 Тогда
			Возврат 10;
		Иначе
			Возврат 15;
		Конецесли;	
	ИначеЕсли дк.ЧленКлубаГП Тогда
		Если ОбщаяСумма < 3000 тогда
			Возврат 3;
		ИначеЕсли ОбщаяСумма < 10000 Тогда 
			Возврат 5;
		ИначеЕсли ОбщаяСумма < 15000 Тогда
			Возврат 10;
		Иначе
			Возврат 15;
		Конецесли;		
	Иначе 
		Возврат 3;
	КонецЕсли;
	
КонецФункции

