			КонецЕсли;
			ОбъемКоробов=СтрокаТЗ.ОбъемКоробов;
			ЗаписатьКоличествоИОбъемКоробовВРегистр (ЭтотОбъект.Ссылка,СтрокаТЗ.КоличествоКоробок,СтрокаТЗ.ОбъемКоробов);	
		КонецЕсли;	
	
	КонецЕсли; 
	#Если Клиент тогда
