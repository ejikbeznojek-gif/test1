				ЧислоИд=Число(Сред(СтрокаТЧ.ИдСтроки,поз+1,10));
			исключение
				Сообщить("В документе "+ссылка+" Неправильный ИД строки "+СтрокаТЧ.ИдСтроки+".Перешлите это сообщение в отдел техподдержки!");
				ЧислоИд=0;
			Конецпопытки;
			Если ном<ЧислоИД тогда
				ном=ЧислоИД;
			Конецесли;
		Конецесли;
		
	КонецЦикла;
	
	ном=?(ном<0,0,ном+1);
	Для Каждого СтрокаТЧ Из Товары Цикл			
		
		Если Сокрлп(СтрокаТЧ.ИдСтроки)="" тогда
			СтрокаТЧ.ИдСтроки=""+Параметрысеанса.ЭтотУзел.Код+"*"+ном;
			ном=ном+1;
