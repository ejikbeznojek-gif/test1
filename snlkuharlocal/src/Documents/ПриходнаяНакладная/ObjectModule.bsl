Процедура ЗаписьБезКонтроляПолномочий (ТЗПараметров=Неопределено)   экспорт
	ТЗНеизменяемыхРеквизитов=ТЗПараметров;
	//Кухарь 17.01.19 конец

	если дата>Константы.ДатаЗапретаРедактирования.Получить() тогда
		НеКонтролироватьЗапись = Истина;
	иначе
		НеКонтролироватьЗапись = ложь;
	КонецЕсли;	
	Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
	НеКонтролироватьЗапись = Ложь;	
КонецПроцедуры


Процедура ПеренестиРезерв() Экспорт
	НеКонтролироватьТА=Истина;
	//крохин начало 06.11.2012
	//при переносе резерва меняется курс
	Доллары					= Справочники.Валюты.НайтиПоКоду("840");
	Курс=ПолучитьКурсВалюты(?(Валюта=ПараметрыСеанса.ВалютаНац,Доллары,Валюта),Дата).Курс;
	//крохин конец 06.11.2012
	Записать(?(Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись));
	НеКонтролироватьТА=Ложь;
КонецПроцедуры 

Процедура УстановитьСостояниеДокументов(НовоеСостояниеДокументов) Экспорт
	//крохин начало 02.03.2011
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//СостояниеДокументов=НовоеСостояниеДокументов;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
		Отказ = Истина;
	КонецЕсли;
	Если Отказ Тогда
		Если	ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение  Тогда
			НеКонтролироватьЗапись=Истина;
			СостояниеДокументов=НовоеСостояниеДокументов;
			Записать();
			НеКонтролироватьЗапись=Ложь;	
		КонецЕсли;
	Иначе
		НеКонтролироватьЗапись=Истина;
		СостояниеДокументов=НовоеСостояниеДокументов;
		Записать();
		НеКонтролироватьЗапись=Ложь;
	КонецЕсли;
	//крохин конец 02.03.2011
КонецПроцедуры

Процедура УстановитьГТД(НоваяГТД) Экспорт
	
	//за датой запрета записываем реквизиты только в ЦО
	//НеКонтролироватьЗапись=Истина;
	//ГТД=НоваяГТД;
	//Записать();
	//НеКонтролироватьЗапись=Ложь;
	Отказ = Ложь;
	Если ЭтотОбъект.Дата<=ПолучитьДатуЗапретаРедактирования(ЭтотОбъект) Тогда
