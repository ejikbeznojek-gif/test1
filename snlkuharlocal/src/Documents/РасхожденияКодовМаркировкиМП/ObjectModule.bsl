Функция ТаблицаЗначенийВТабличныйДокумент(ТаблицаДанных)
	
	ПостроительОтчета = Новый ПостроительОтчета;
	ПостроительОтчета.ВыводитьЗаголовокОтчета = Ложь;
	ПостроительОтчета.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТаблицаДанных);
	ДокументРезультат = Новый ТабличныйДокумент;
	Оформление = ПолучитьМакетОформления(СтандартноеОформление.Асфальт);
	ПостроительОтчета.МакетОформления = Оформление;
	УФ = ПостроительОтчета.УсловноеОформление;
	УФ.Очистить();
	
	ПостроительОтчета.Выполнить();
	ПостроительОтчета.ОформитьМакет();    
	Построительотчета.Вывести(ДокументРезультат);
	Возврат ДокументРезультат;
	
КонецФункции


Функция РазницаТаблицЗначений(Таблица0, Таблица1, Измерения) Экспорт
	состояние("Сверка кодов");
	ВсеКолонки = "";
	Для Каждого Колонка Из Таблица0.Колонки Цикл 
		ВсеКолонки = ВсеКолонки + ", " + Колонка.Имя
	КонецЦикла;
	ВсеКолонки = Сред(ВсеКолонки, 2);
	
	Таблица = Таблица1.Скопировать();    
	
	Таблица.Колонки.Добавить("Знак", Новый ОписаниеТипов("Число"));
	
	Таблица.ЗаполнитьЗначения(1, "Знак"); // принадлежность к нашей или их таблице.
	
	Для Каждого Строка Из Таблица0 Цикл ЗаполнитьЗначенияСвойств(Таблица.Добавить(), Строка) КонецЦикла;
	
	Таблица.Колонки.Добавить("Счёт");
	Таблица.ЗаполнитьЗначения(1, "Счёт"); // признак, что дубли
	
	Таблица.Свернуть(ВсеКолонки, "Знак, Счёт");   
	//Таблица = новый таблицаЗначений;
	//таблица.колонки.Удалить(1);
	
	Ответ = Таблица.Скопировать(Новый Структура("Счёт", 1), ВсеКолонки + ", Знак");
	ТаблицаМарокХКМ = Таблица.Скопировать(Новый Структура("Счёт", 2), ВсеКолонки + ", Знак"); // только марки, которые совпадают и у них, и у нас.

	Ответ.Сортировать(Измерения);
	Ответ.колонки.добавить("НеНайдено");
	Для каждого Строка из Ответ цикл
		Если Строка.Знак = 1 ТОгда Строка.НеНайдено = "нет в нашем файле"; Иначе Строка.НеНайдено = "нет в файле ВБ";   конецЕсли;	
	КонецЦикла;
	// Ответ.колонки.Удалить(1);
	
	Возврат Ответ
	
