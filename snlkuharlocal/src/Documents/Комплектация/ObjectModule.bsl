Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	если ОбщегоНазначения_ПИ.ЭтоУзел_ODN_или_OD7() тогда 
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ЗаданиеНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|ГДЕ
		|	ЗаданиеНабора.Проведен
		|	И ЗаданиеНабора.Накладная = &Накладная";
		запрос.УстановитьПараметр("Накладная",ЭтотОбъект.Ссылка);
		результат=запрос.Выполнить().Выбрать();
		пока результат.Следующий() цикл
			ЗНБ=результат.Ссылка.получитьобъект();
			если ложь тогда ЗНБ=Документы.ЗаданиеНабора.ПустаяСсылка().ПолучитьОбъект();КонецЕсли;
			ЗНБ.УстановитьПометкуУдаления(Истина);	
		КонецЦикла;
	КонецЕсли;
	//Кухарь 03.12.19 конец	
	
КонецПроцедуры

