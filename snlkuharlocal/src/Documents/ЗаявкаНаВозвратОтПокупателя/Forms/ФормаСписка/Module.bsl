
&НаКлиенте
Процедура РаспределениеЗНВ(Команда)
	
	Если Элементы.Список.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СсылкаНаОбъект = Элементы.Список.ТекущиеДанные.Ссылка;
	
	Если ЗначениеНеЗаполнено(СсылкаНаОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ФормаОбработки =  Обработки.РаспределениеВозвратаПоРекламациям.ПолучитьФорму("Форма");
	ФормаОбработки.ДокОбъект = СсылкаНаОбъект;
	ФормаОбработки.Открыть();
	
КонецПроцедуры
