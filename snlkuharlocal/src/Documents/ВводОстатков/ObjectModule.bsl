
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	МетаДок=Метаданные.Документы.ВводОстатков;
	
	Для Каждого МетаТЧ ИЗ МетаДок.ТабличныеЧасти Цикл 
		ИмяТЧ=МетаТЧ.Имя;
		Если ИмяТЧ="История" Тогда Продолжить КонецЕсли; 
		
		ТЧ=ЭтотОбъект[ИмяТЧ];
		
		Если ТЧ.Количество()>0 Тогда
			НЗ=Движения[ИмяТЧ];
			Если 1=2 Тогда
				НЗ=РегистрыНакопления.ТоварыВПути.СоздатьНаборЗаписей();			
			КонецЕсли; 
			
			//НЗ.Отбор.Регистратор.Установить(Ссылка,Истина);
			НЗ.Загрузить(ТЧ.Выгрузить());			
			Для Каждого Движение Из НЗ Цикл
				Движение.Регистратор=Ссылка;
				Движение.Период		=Дата;
				Движение.ВидДвижения=ВидДвиженияНакопления.Приход;			
			КонецЦикла;			
		КонецЕсли; 
	КонецЦикла;
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки

	Если История.Количество()>0 Тогда
		НЗ=РегистрыСведений.История.СоздатьНаборЗаписей();	
		НЗ.Отбор.Документ.Установить(Ссылка,Истина);
		
		НЗ.Загрузить(История.Выгрузить());	
		Для Каждого Запись Из НЗ Цикл
			Запись.Период	=Дата;		
			Запись.Документ	=Ссылка;
		КонецЦикла;
		
		НЗ.Записать();
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	ОчиститьДвиженияДокументаПоИстории(Ссылка);	
КонецПроцедуры
