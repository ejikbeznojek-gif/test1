Процедура ОбработкаЗаполнения(Основание) 	Экспорт 
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
//крохин конец 05.06.2019	
	ВидОснования = Основание.Метаданные().Имя;
	
	ИБ			 = Основание.ИБ; 
	ДокументОснования = основание;
	
	Если ВидОснования = "РасходнаяНакладная" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		ДокументОснование  = Основание.ссылка;
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;
	ИначеЕсли ВидОснования = "КорректировкаЦенВНакладной" Тогда				
		Контрагент   = Основание.Корреспондент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		ДокументОснование  =Основание.ДокОснование.ссылка;
	
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;
	ИначеЕсли ВидОснования = "РекламационнаяНакладная" Тогда
		
		Контрагент   = Основание.Корреспондент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;
		
		Если ЗначениеЗаполнено(Основание.ДокОснование) Тогда
			ДокументОснование = Основание.ДокОснование;
		КонецЕсли;
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ = Неопределено Тогда
			СтрокаТЧ = Накладные.Добавить();
			СтрокаТЧ.Накладная = Основание;			
		КонецЕсли;
	//Валетов + 10,12,2025 SNL-72  
		Если ЗначениеЗаполнено(Основание.ДокОснование) И ТипЗнч(Основание.ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Поставщику = Истина;
		КонецЕсли; 
	ИначеЕсли ВидОснования = "ПриходнаяНакладная" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		ДокументОснование  = Основание.ссылка;
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;  
		Поставщику = Истина;
		//Валетов -
	КонецЕсли;	
	
	Для Каждого СтрокаТЧ Из Накладные Цикл
		РасчетСтроки(СтрокаТЧ);	
	КонецЦикла; 
	
КонецПроцедуры
