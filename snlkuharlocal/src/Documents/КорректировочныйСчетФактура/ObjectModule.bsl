						сообщить("КСФ по складу "+Склад + " редактируются только в соответствующем подразделении");
					#КОНЕЦЕСЛИ	
					Отказ = Истина;	
					
				КонецЕсли;
			ИначеЕсли ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
				//крохин начало 11.04.2013
				//СФ можно редактировать только свои
				//Если Склад.ТипСклада <> Перечисления.ТипСклада.Филиал И Склад.ТипСклада <> Перечисления.ТипСклада.ОптовыйТЦ Тогда
				Если Склад.Подразделение <> ПараметрыСеанса.ЭтотУзел.Подразделение Тогда
					//крохин конец 11.04.2013
					#Если КЛИЕНТ Тогда
						сообщить("КСФ по складу "+Склад + " редактируются только в офисе");
					#КОНЕЦЕСЛИ	
					Отказ = Истина;	
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		//крохин конец 16.02.2012
		
		//нечаева 24,11,16+++
	//	КонтрольДатыЗапрета(ЭтотОбъект,Отказ); 
		//нечаева 24,11,16--- не контролируем для КСФ
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		КонтрольДублейСФ(ЭтотОбъект,Отказ);		
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;
	
	Если ЕстьИзменения Тогда		
		СуммаБезНДС18		=Накладные.Итог("СуммаБезНДС18");
		НДС18				=Накладные.Итог("НДС18");
		СуммаБезНДС10		=Накладные.Итог("СуммаБезНДС10");
		НДС10				=Накладные.Итог("НДС10");
		СуммаСовсемБезНДС	=Накладные.Итог("СуммаСовсемБезНДС");
		Всего				=СуммаБезНДС18+НДС18+СуммаБезНДС10+НДС10+СуммаСовсемБезНДС;
		
		Для Каждого СтрокаТЧ Из Накладные Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.Накладная.Номер) Тогда
				Если СтрокаТЧ.Накладная.Метаданные().Имя="Перемещение" Тогда
					Контрагент=ПолучитьКонтрагентаСклада(СтрокаТЧ.Накладная.СкладПолучатель);						
				Иначе
					Контрагент=СтрокаТЧ.Накладная.Корреспондент;
				КонецЕсли;		
				
				Прервать;			
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;	
	
КонецПроцедуры

