Функция ПолучитьКонтрагентаСклада(Склад)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	ЗначенияСвойствОбъектов.Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Объект
	|	И ЗначенияСвойствОбъектов.Свойство = &Свойство";
	
	Запрос.УстановитьПараметр("Объект",Склад);
	Запрос.УстановитьПараметр("Свойство",ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Контрагент получатель"));
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Значение;
	КонецЦикла; 
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
КонецФункции //ПолучитьКонтрагентаСклада(Склад)

Процедура РасчетСтроки(СтрокаТЧ) Экспорт
	СтрокаТЧ.СуммаБезНДС18		=0;
	СтрокаТЧ.НДС18				=0;
	СтрокаТЧ.СуммаБезНДС10		=0;
	СтрокаТЧ.НДС10				=0;
	СтрокаТЧ.СуммаСовсемБезНДС	=0;
	
	Если СтрокаТЧ.Накладная<>Неопределено И НЕ СтрокаТЧ.Накладная.Пустая() Тогда
		ТабСтавок=СтрокаТЧ.Накладная.Товары.Выгрузить();
		ТабСтавок.Свернуть("СтавкаНДС","Всего,НДС");	
		
		СтрокаТЧ.Всего=ТабСтавок.Итог("Всего");		
		
		Для Каждого СтрокаСтавок Из ТабСтавок Цикл
			//крохин начало 08.01.2019
			//Если СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС18 Тогда
			Если СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС18 ИЛИ СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС20 Тогда
			//крохин конец 08.01.2019	
				СтрокаТЧ.СуммаБезНДС18	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				СтрокаТЧ.НДС18			= СтрокаСтавок.НДС;			
			ИначеЕсли СтрокаСтавок.СтавкаНДС=Перечисления.СтавкиНДС.НДС10 Тогда
				СтрокаТЧ.СуммаБезНДС10	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				СтрокаТЧ.НДС10			= СтрокаСтавок.НДС;
			//крохин начало 15.02.2019	
		//ИначеЕсли СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.БезНДС Тогда
		//для иностранцев
		ИначеЕсли СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.БезНДС ИЛИ СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.НДС0 Тогда
		//крохин конец 15.02.2019
				СтрокаТЧ.СуммаСовсемБезНДС	= СтрокаСтавок.Всего;			
			КонецЕсли;			
		КонецЦикла; 
	КонецЕсли;
КонецПроцедуры

Функция КонтрольДублейСФ(СФОбъект,Отказ,Дубли=Неопределено) Экспорт	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка КАК СФ,
	|	Накладная
	|ИЗ
	|	Документ.КорректировочныйСчетФактура.Накладные КАК СчетФактураНакладные
	|ГДЕ
	|	Накладная В(&Накладные)
	|	И НЕ Ссылка.ПометкаУдаления
	|	И Ссылка <> &Ссылка
	|	И Ссылка.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Накладные",СФОбъект.Накладные.ВыгрузитьКолонку("Накладная"));
	Запрос.УстановитьПараметр("Ссылка",СФОбъект.Ссылка);
	Запрос.УстановитьПараметр("Организация",СФОбъект.Организация);
	
	ЕстьДубли=Ложь;	
	
	Дубли=Новый Массив;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Сообщить("На корректирующий документ: "+Выборка.Накладная+", по организации: """+СФОбъект.Организация+"""
		|	уже выписана КСФ: "+Выборка.СФ,СтатусСообщения.Важное);		
		ЕстьДубли=Истина;	
		
		Дубли.Добавить(Выборка.СФ);
	КонецЦикла;
	
	Если НЕ Отказ И ЕстьДубли Тогда
		Отказ=Истина;
	КонецЕсли;	
	
	Возврат НЕ ЕстьДубли;
КонецФункции //КонтрольДублейСФ(СФОбъект,Отказ)

