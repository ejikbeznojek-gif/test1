	//если РежимЗаписи=РежимЗаписиДокумента.Проведение и НЕ накладные[0].накладная.Проведен   Тогда
	//		Сообщить("Документ основание не проведен! Проведите документ основание");
	//		Отказ=истина;
	//		возврат;
	//КонецЕсли;
	//
	//если РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения и накладные[0].накладная.Проведен Тогда
	//		Сообщить("Документ основание проведен! Распроведите документ основание");
	//		Отказ=истина;
