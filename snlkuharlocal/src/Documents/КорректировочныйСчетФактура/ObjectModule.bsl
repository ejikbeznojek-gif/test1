		Запрос= Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		               |	СчетФактураНакладные.Ссылка
		               |ИЗ
		               |	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
		               |ГДЕ
		               |	СчетФактураНакладные.Накладная = &ТекДок
		               |	И СчетФактураНакладные.Ссылка.Проведен = ИСТИНА";
		запрос.УстановитьПараметр("ТекДок",ДокРНК);			   
		Рез = Запрос.Выполнить().Выбрать();
		Если ДокументОснование= документы.РасходнаяНакладная.ПустаяСсылка() Тогда
			ДокументОснование = ДокРНК;
		КонецЕсли;	
			
		Если рез.Количество()= 0 Тогда
			сообщить("Не создана СФ, к документу РНК! КСФ создать не возможно.");
			возврат;
		КонецЕсли;
    КонецЕсли;	
	
	
	
	Если НЕ ОбменДанными.Загрузка Тогда
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			//Отказ=НЕ ПолучитьПолномочиеПользователя("ВыпискаСФвОфисе");
			Если Отказ Тогда
				Сообщить("Недостаточно полномочий для оформления СФ в офисной базе !",СтатусСообщения.Важное);			
			КонецЕсли;		
		КонецЕсли;
		
		//крохин начало 16.02.2012
		//запретим редактировать филиальные СФ в офисе и офисные - в филиале
		Если  НЕ ОбменДанными.Загрузка Тогда
			Если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
				Если Склад.ТипСклада = Перечисления.ТипСклада.Филиал ИЛИ Склад.ТипСклада = Перечисления.ТипСклада.ОптовыйТЦ Тогда
