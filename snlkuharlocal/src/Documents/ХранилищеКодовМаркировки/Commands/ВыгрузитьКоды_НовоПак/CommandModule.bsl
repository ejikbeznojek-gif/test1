
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	//Вставить содержимое обработчика.
	//ПараметрыФормы = Новый Структура("", );
	//ОткрытьФорму("Документ.ХранилищеКодовМаркировки.ФормаСписка", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
	ИмяПараметра	= "КаталогВыгрузкиХКМ_НовоПак";
	КаталогВыгрузки = ВосстановитьЗначение(ИмяПараметра);	
	
	КаталогВыгрузки = ВыборКаталога_(КаталогВыгрузки);
	Если ЗначениеЗаполнено(КаталогВыгрузки) Тогда
		СохранитьЗначение(ИмяПараметра, КаталогВыгрузки);
		ВыгрузитьКоды(ПараметрКоманды, КаталогВыгрузки);		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Функция ВыборКаталога_(Каталог = "", ПроверятьСуществование = Истина) Экспорт
	Результат										= ""; 
	
	ДиалогФыбораФайла								=	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	
	ДиалогФыбораФайла.Заголовок						=	"Выберите каталог";		
	//ДиалогФыбораФайла.ПолноеИмяФайла				=	Элемент.Значение;
	ДиалогФыбораФайла.ПроверятьСуществованиеФайла	=	ПроверятьСуществование;
	ДиалогФыбораФайла.Каталог						=	Каталог;
	
	Если ДиалогФыбораФайла.Выбрать() Тогда
		Результат = ДиалогФыбораФайла.Каталог + "\";
	КонецЕсли;	

	Возврат Результат;
КонецФункции // ()

&НаКлиенте
Процедура ВыгрузитьКоды(ХКМСсылка, КаталогВыгрузки)
	Данные 		= ПолучитьДанныеКодов(ХКМСсылка);
	
	НомерПРМ 	= ПолучитьРеквизитШапки(ХКМСсылка, "ДокОснование.Номер");
	ИмяФайла 	= СтрШаблон(КаталогВыгрузки + "Коды_ПРМ_%1.json", НомерПРМ);	
	
	Для каждого ЭлементДанных Из Данные.ДанныеШтук Цикл
		Номенклатура = ЭлементДанных.Номенклатура;
		
		ИмяФайла = СформироватьИмяФайла(Номенклатура.Родитель.КодПроизводителя, Номенклатура.Цвет, Номенклатура.Размер, "json");
		ИмяФайла = ПолноеИмяФайла(КаталогВыгрузки, ИмяФайла); 
	
		ЭлементДанных.КодыШтук.Записать(ИмяФайла);
		Сообщить("Записаны коды штук: " + ИмяФайла, СтатусСообщения.Информация);
	КонецЦикла;	
	
	ИмяФайла = СтрШаблон(КаталогВыгрузки + "Короба_ПРМ_%1.json", НомерПРМ);	
	
	Данные.КодыКоробок.Записать(ИмяФайла);
	
	Сообщить("Записаны коды коробов: " + ИмяФайла, СтатусСообщения.Информация);
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеКодов(ХКМСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,
	|	ШтрихкодУпаковки,
	|	ШтрихкодУпаковки.Владелец							КАК Номенклатура,	
	|	ШтрихкодУпаковки.Владелец.Родитель.КодПроизводителя КАК Артикул,
	|	ШтрихкодУпаковки.Владелец.Родитель.Наименование 	КАК Модель_Наименование,
	|	ШтрихкодУпаковки.Владелец.Код						КАК Номенклатура_Код,
	|	ШтрихкодУпаковки.Владелец.Наименование				КАК Номенклатура_Наименование,	
	|	ШтрихкодУпаковки.ЗначениеШтрихкода 					КАК ЗначениеШтрихкода
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ХКМСсылка
	|ИТОГИ ПО
	|	Номенклатура
	|";
	
	Запрос.УстановитьПараметр("ХКМСсылка", ХКМСсылка);
	
	ДанныеШтук = Новый Массив;	
	
	Выборка_Номенклатура = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
	Пока Выборка_Номенклатура.Следующий() Цикл
		КодыШтук = Новый Массив;
		
		Выборка = Выборка_Номенклатура.Выбрать();
		Пока Выборка.Следующий() Цикл			
			Данные = Новый Структура("ref_id,model,sku,code",
			Выборка.Артикул, Выборка.Модель_Наименование, Выборка.Номенклатура_Наименование, Выборка.Номенклатура_Код);
			
			СтрокаКМ = СокрЛП(ПолучитьСтрокуИзДвоичныхДанных(Base64Значение(Выборка.ЗначениеШтрихкода)));
			Данные.Вставить("full_code", СтрокаКМ);
			
			//Части = СтрРазделить(СтрокаКМ, Символ(29));		
			//ГТИН 	= Сред(СтрШК,	3,	14);
			//СН	= Сред(СтрШК,	19,	13);		
			//Если Части.Количество() = 3 Тогда
			//	Данные.Вставить("gtin", 	Сред(Части[0],	3,	14));
			//	Данные.Вставить("serial",	Сред(Части[0],	19,	13));
			//	Данные.Вставить("vcode1", 	Сред(Части[1],	3));
			//	Данные.Вставить("vcode2", 	Сред(Части[2],	3));			
			//КонецЕсли;
			
			КодыШтук.Добавить(Данные);
		КонецЦикла;
		
		ДанныеШтук.Добавить(
			Новый Структура("Номенклатура,КодыШтук", 
				Выборка_Номенклатура.Номенклатура, 
				ПолучитьДвоичныеДанныеИзСтроки(МаркировкаКС.ЗаписатьЖСОН(КодыШтук))
			)
		);
	КонецЦикла;
	
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	ШтрихкодКоробки.Наименование КАК КодКоробки
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ХКМСсылка
	|	И ШтрихкодКоробки<>ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)  
	|";
	
	КодыКоробок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("КодКоробки");
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеШтук", 	ДанныеШтук);
	Результат.Вставить("КодыКоробок", 	ПолучитьДвоичныеДанныеИзСтроки(МаркировкаКС.ЗаписатьЖСОН(КодыКоробок)));
		
	Возврат Результат;	
КонецФункции //ПолучитьДанныеКодов(ХКМСсылка)

&НаКлиенте
Функция СформироватьИмяФайла(Знач Артикул, Знач Цвет, Знач Размер, Расширение) Экспорт
	Артикул	= УдалитьМусорИзСтроки(Артикул);
	Цвет	= УдалитьМусорИзСтроки(Цвет);
	Размер	= УдалитьМусорИзСтроки(Размер);
	
	ИмяФайла	= СтрШаблон("%1_%2_%3.%4", Артикул, Цвет, Размер, Расширение);	
	
	Возврат ИмяФайла;
КонецФункции //СформироватьИмяФайла(Знач Артикул, Знач Цвет, Знач Размер, Расширение) Экспорт

&НаКлиенте
Функция УдалитьМусорИзСтроки(Знач ВходСтрока)
	Результат = СокрЛП(""+ВходСтрока);
	
	Результат = СтрЗаменить(Результат, "/", 	"");
	Результат = СтрЗаменить(Результат, "\", 	"");
	Результат = СтрЗаменить(Результат, ":", 	"");
	Результат = СтрЗаменить(Результат, ";", 	"_");
	Результат = СтрЗаменить(Результат, """",	"");
	Результат = СтрЗаменить(Результат, "'", 	"");	
	Результат = СтрЗаменить(Результат, "<", 	"");
	Результат = СтрЗаменить(Результат, ">", 	"");
	Результат = СтрЗаменить(Результат, "|", 	"");
	Результат = СтрЗаменить(Результат, "?", 	"");
	Результат = СтрЗаменить(Результат, "*", 	"");
	
	Возврат СокрЛП(Результат);
КонецФункции //УдалитьМусорИзСтроки(Знач ВходСтрока) 

&НаКлиенте
Функция ПолноеИмяФайла(ИмяКаталога, ИмяФайла) Экспорт
	мКаталогВыгрузки = СокрЛП(ИмяКаталога);
	РП = ПолучитьРазделительПутиКлиента();
	Если НЕ СтрЗаканчиваетсяНа(мКаталогВыгрузки, РП) Тогда
		мКаталогВыгрузки = мКаталогВыгрузки + РП;	
	КонецЕсли;
	
	Возврат мКаталогВыгрузки + ИмяФайла;
КонецФункции //ПолноеИмяФайла(ИмяКаталога, ИмяФайла)