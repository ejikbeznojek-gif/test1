Процедура УстановитьПолучателейИзменений(ДокОбъект)	Экспорт
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	мПолучателей = СписокПолучателейИзменений(ДокОбъект);
	Для Каждого УзелПолучатель Из мПолучателей Цикл
		ДокОбъект.ОбменДанными.Получатели.Добавить(УзелПолучатель);
	КонецЦикла;	
	
	//Отправка подтверждений о приеме накладных складом или магазином
КонецПроцедуры

Функция СписокПолучателейИзменений(ДокОбъект, ДопИнфо = Неопределено)
	СписокПолучателей = Новый Массив;	
	
	ТипУзла				= Маркировка_ПИ.ТипТекущегоУзла();
	
	ТипОснования		= ТипЗнч(ДокОбъект.ДокОснование);
	Если ДокОбъект.КодУзлаСоздания <> Маркировка_ПИ.ЭтотУзел_Код() Тогда
		Если ТипОснования = Тип("ДокументСсылка.Перемещение") И ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			//Перемещения маршрутизируются в ЦО
		Иначе
			Возврат СписокПолучателей 	
		КонецЕсли;
	КонецЕсли;
		
	ЭтотУзел			= Маркировка_ПИ.ЭтотУзел();	
	УправляющийУзел		= Маркировка_ПИ.УправляющийУзел();	
	
	ОбменДанными		= ДокОбъект.ОбменДанными;
	Отправитель			= ОбменДанными.Отправитель;
	Загрузка			= ОбменДанными.Загрузка;
	
	УзелСклада			= ПланыОбмена.Основной.ПустаяСсылка();	
	ДокОснование		= ДокОбъект.ДокОснование;
	Если ЗначениеЗаполнено(ДокОснование) Тогда		
		Если ЕстьРеквизитДокумента("Склад", ДокОснование.Метаданные()) Тогда
			Склад				= ПолучитьРеквизитШапки(ДокОснование, "Склад");
			УзелСклада			= Маркировка_ПИ.УзелСклада(Склад);			
		ИначеЕсли ЕстьРеквизитДокумента("Подразделение", ДокОснование.Метаданные()) Тогда
			Подразделение		= ПолучитьРеквизитШапки(ДокОснование, "Подразделение");
			УзелСклада			= Маркировка_ПИ.УзелПодразделения(Подразделение);
		КонецЕсли;
	КонецЕсли;	
	
	Если ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") 
		ИЛИ ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда		
	
		Если ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСклада, Отправитель, Загрузка);				
		ИначеЕсли ТипУзла = Перечисления.ТипУзлаИБ.Склад 
			ИЛИ ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда				
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УправляющийУзел, Отправитель, Загрузка);					
		КонецЕсли;		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Если ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			УзелСклада = Маркировка_ПИ.УзелСклада(Справочники.Склады.НайтиПоКоду("STA-48")); //Склад Часцы (Основной)
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСклада, Отправитель, Загрузка);
		КонецЕсли;	
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
		Если ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			//крохин начало 24.12.2024
			//опечатка
			//рШапки = ПолучитьРеквизитыШапки(ДокОбъект.ДокОснование, "Операция,СкладПолучатель");
			//Если рШапки.Операция = Перечисления.СкладскиеОперации.Отгрузка Тогда
			//	УзелСклада = Маркировка_ПИ.УзелСклада(рШапки.СкладПолучатель);			
			//КонецЕсли; 
			рШапки = ПолучитьРеквизитыШапки(ДокОбъект.Ссылка, "Операция");
			рШапкиДокОснования = ПолучитьРеквизитыШапки(ДокОбъект.ДокОснование, "СкладПолучатель");
			Если рШапки.Операция = Перечисления.СкладскиеОперации.Отгрузка Тогда
				УзелСклада = Маркировка_ПИ.УзелСклада(рШапкиДокОснования.СкладПолучатель);			
			КонецЕсли; 
			//крохин конец 24.12.2024
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УзелСклада, Отправитель, Загрузка);
		Иначе
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УправляющийУзел, Отправитель, Загрузка);
		КонецЕсли;		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		Если ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			//Маркировки в офисе ????
		Иначе
			МаркировкаС.ДобавитьУзелВПолучателей(СписокПолучателей, УправляющийУзел, Отправитель, Загрузка);			
		КонецЕсли;		
	КонецЕсли;		
	
	Возврат ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(СписокПолучателей, Истина);	
КонецФункции //СписокПолучателейИзменений(ДокОбъект, ДопИнфо = Неопределено)

Функция ПолучитьКМпоПНК_Импорт(ПНК_Ссылка)	
	МаксЧислоКодов = 50000;
	
	Запрос = Новый Запрос(ТекстЗапроса_КМ_ПНК_Импорт_САгрегатами());
	Запрос.УстановитьПараметр("ПНК_Ссылка", ПНК_Ссылка);	
	
	Результат = Новый Массив;
	мКоды = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		мКоды.Добавить(Выборка.ШтрихкодУпаковки);
		
		Если мКоды.Количество()>=МаксЧислоКодов Тогда
			Результат.Добавить(мКоды);		
			мКоды = Новый Массив;
		КонецЕсли; 		
	КонецЦикла; 
	
	Если мКоды.Количество() > 0 Тогда
		Результат.Добавить(мКоды);
	КонецЕсли; 	
	
	Возврат Результат;
КонецФункции //ПолучитьКМпоПНК()

Функция ПолучитьКМПоОтчетамОНанесении(ТаблицаАгрегаций)	
	МаксЧислоКодов = 50000;
	
	Запрос = Новый Запрос(ТекстЗапроса_КМ_ЗПС_Импорт_ПоОтчетамОНанесении());	
	Запрос.УстановитьПараметр("ТаблицаАгрегаций",	ТаблицаАгрегаций);	
	
	Результат = Новый Массив;
	мКоды = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		мКоды.Добавить(Новый Структура("ШтрихкодКоробки,ШтрихкодУпаковки", Выборка.ШтрихкодКоробки, Выборка.ШтрихкодУпаковки));
		
		Если мКоды.Количество()>=МаксЧислоКодов Тогда
			Результат.Добавить(мКоды);		
			мКоды = Новый Массив;
		КонецЕсли; 		
	КонецЦикла; 
	
	Если мКоды.Количество() > 0 Тогда
		Результат.Добавить(мКоды);
	КонецЕсли; 	
	
	Возврат Результат;
КонецФункции //ПолучитьКМпоПНК()

Функция ПолучитьКМпоЛистуНабора(ЛистНабора) Экспорт	
	Запрос = Запрос_КМ_ПоЛистуНабора(ЛистНабора);	
	
	КоличествоНоменклатуры = 0;
	КодыМаркировки = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТипЗаписи() = ТипЗаписиЗапроса.ОбщийИтог Тогда
			КоличествоНоменклатуры = Выборка.Номенклатура;
		Иначе			
			КодыМаркировки.Добавить(Выборка.ШтрихкодУпаковки);						
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Новый Структура("КоличествоНоменклатуры,КодыМаркировки", КоличествоНоменклатуры, КодыМаркировки);
КонецФункции //ПолучитьКМпоЛистуНабора()

Функция ПолучитьКМпоЛистамНабора(ДокОтгрузки, МаксЧислоКодов = 50000) Экспорт	
	Запрос = Новый Запрос;
	
	// Кухарь А.Ю. 12.02.2025 начало
	//	Если ЕстьЛистыПереукладки(ДокОтгрузки) Тогда
	
	ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ДокОтгрузки);
	
	если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет тогда
		
		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_Паллеты();
		//Валетов + 25,12,2025 ПУСТАЯ ЗАДАЧА Добавление для экспозиторов
	ИначеЕсли ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок 
		Тогда  
		
		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛНКоробами(ДокОтгрузки); 
		//Валетов -
		// Кухарь А.Ю.  29.03.2025 начало
	иначеесли ОбщегоНазначения_ПИ.ВНакладнойТолькоСпайки(ДокОтгрузки)
		и не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет 
		и  не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок
		и  не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков
		тогда
		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЗСБ();
		// Кухарь А.Ю.  29.03.2025 конец
		
		// Кухарь А.Ю.  30.04.2025 начало
	иначеесли ОбщегоНазначения_ПИ.ВНакладнойНетСпаек(ДокОтгрузки) 
		и не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет
		и не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок
		и не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков 
		и не ПравилаРаботыСАгрегациейЧЗ.РазворачиватьАгрегациюДоШтук 
		тогда

		// Кухарь А.Ю.  16.05.2026 начало      
		//OUT-216
		// 		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛНБезВсего();	
		если ИспользоватьЛНТолькоДляНабора(ДокОтгрузки) тогда  
			Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛПБезВсего();
		иначе    
			Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛНБезВсего();
		КонецЕсли;
		// Кухарь А.Ю.  16.05.2026 конец
		
		// Кухарь А.Ю.  30.04.2025 конец
    //++Данилова Е.В. 02.04.2026  MARK-3539
	//иначеЕсли ЕстьЛистыПереукладки(ДокОтгрузки) Тогда
	иначеЕсли ЕстьЛистыПереукладки(ДокОтгрузки) 
		ИЛИ (МаркировкаС.ЕстьЛПСКодамиЧЗ(ДокОтгрузки) 
		и ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков) Тогда
	//--Данилова Е.В. 02.04.2026 
		
		// Кухарь А.Ю. 12.02.2025 конец
		
		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛП();
	Иначе
		Запрос.Текст = ТекстЗапроса_КМ_ПоДокументуОтгрузки_ЛН(ДокОтгрузки);	
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("ДокОтгрузки", ДокОтгрузки); 
	//++Данилова Е.В. 02.04.2026 MARK-3539
	Запрос.УстановитьПараметр("АгрегацииВЛП",МаркировкаС.ЕстьЛПСКодамиЧЗ(ДокОтгрузки));
	//--Данилова Е.В. 02.04.2026 
	Запрос.УстановитьПараметр("РазворачиватьАгрегациюДоШтук",ПравилаРаботыСАгрегациейЧЗ.РазворачиватьАгрегациюДоШтук);
	
	Результат	= Новый Массив;
	мКоды 		= Новый Массив;
	Выборка 	= Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		//Валетов+ 21,05,2025 Разворачивание Коробов до штук
		//https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5113
		//Было  мКоды.Добавить(Выборка.ШтрихкодУпаковки);
		 
		// Кухарь А.Ю.  26.02.2026 начало
		// Если Выборка.ШтрихкодУпаковки.ТипШК = Перечисления.ТипыШтрихКодов.Коробка   
		Если Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка   
			// Кухарь А.Ю.  26.02.2026 конец
			
			И ТипЗнч(ДокОтгрузки) = Тип("ДокументСсылка.РасходнаяНакладная")  //Исключаем ХКМ к СПН, ПНК и РКМ
			И МаксЧислоКодов > 0 											  //Исключаем заполнение док. Маркировка Товаров ИСМП
			И НЕ ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок 
			И ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад 		  //Тут не уверен, но лучше ограничить 
			И ДокОтгрузки.Дата > НачалоДня(Дата('20250501')) Тогда 
			Для Каждого ЭлКороба Из Выборка.ШтрихкодУпаковки.ВложенныеШтрихкоды Цикл
				мКоды.Добавить(ЭлКороба.Штрихкод);	
			КонецЦикла;
		Иначе
			мКоды.Добавить(Выборка.ШтрихкодУпаковки);  
		КонецЕсли;
		//Валетов -	
		
		Если мКоды.Количество() >= МаксЧислоКодов И МаксЧислоКодов > 0 Тогда
			Результат.Добавить(мКоды);		
			мКоды = Новый Массив;
		КонецЕсли; 		
	КонецЦикла; 
	
	Если МаксЧислоКодов>0 Тогда	
		Если мКоды.Количество() > 0 Тогда
			Результат.Добавить(мКоды);
		КонецЕсли; 		
	Иначе            
		Результат = мКоды;		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьКМпоЛистамНабора()

