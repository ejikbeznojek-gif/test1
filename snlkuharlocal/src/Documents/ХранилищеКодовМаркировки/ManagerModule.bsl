Функция ЗарегистрироватьКодыНаСклад(ХКМ_Ссылка) Экспорт
	Результат 	= МаркировкаКС.СтруктураРезультата(Ложь);
	
	рШапки		= Неопределено;
	Если ЗначениеЗаполнено(ХКМ_Ссылка) Тогда		
		рШапки = ПолучитьРеквизитыШапки(ХКМ_Ссылка, "ПланФакт,Проведен,ДокОснование,ДокОснование.Склад");		
	Иначе
		Результат.Ошибки.Добавить("Недопустимый тип документа: '" + ТипЗнч(ХКМ_Ссылка)+"' !");
	КонецЕсли;
	
	Если рШапки<>Неопределено Тогда
		ТипОснования = ТипЗнч(рШапки.ДокОснование);
		Если НЕ (                                                                        
				ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная")
				ИЛИ ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") 
			) Тогда
			Результат.Ошибки.Добавить("Недопустимый тип основания ХКМ: '" + ТипОснования+"' !");
		ИначеЕсли рШапки.ПланФакт <> Перечисления.ПланФакт.План Тогда
			//Результат.Ошибки.Добавить("Регистрация ШК КМ выполняется только для ХКМ 'План' !");
		КонецЕсли;
		
		Если НЕ рШапки.Проведен Тогда
			Результат.Ошибки.Добавить("ХКМ не проведен !");		
		КонецЕсли; 
	КонецЕсли;
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	Склад 		= рШапки.ДокОснование_Склад;
	Если ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда		
		УзелСклада	= Маркировка_ПИ.УзелПоКоду("OD7cz", "ДанныеЧЗ");		
	Иначе		
		УзелСклада	= Маркировка_ПИ.УзелСклада(Склад, "ДанныеЧЗ");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(УзелСклада) Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Невозможно определить узел получатель для склада: '%1' !", Склад));
		Возврат Результат;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ШтрихКоды
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок 
	|ГДЕ	
	|	Ссылка = &ХКМ_Ссылка
	|;	
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ШтрихКоды
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихКод КАК ШтрихкодУпаковки
	|ИЗ	
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды
	|ГДЕ
	|	Ссылка В (ВЫБРАТЬ ШтрихкодУпаковки ИЗ ВТ_ШтрихКоды)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодКоробки	
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок 
	|ГДЕ	
	|	Ссылка = &ХКМ_Ссылка
	|	И ШтрихкодКоробки.ВерсияДанных ЕСТЬ НЕ NULL
	|";
	
	Запрос.УстановитьПараметр("ХКМ_Ссылка", ХКМ_Ссылка);
	
	рЗапроса = Запрос.Выполнить();
	
	мКодов = рЗапроса.Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	ОбменДаннымиЧЗ.УстановитьПолучателей(УзелСклада, мКодов);
		
	Результат.Успешно	= Истина;
	Результат.Данные	= УзелСклада;
	Результат.ОбработаноОбъектов = мКодов.Количество();
	
	Возврат Результат; 
КонецФункции //ЗарегистрироватьКодыНаСклад()

Функция ОпределитьОтправителяПолучателя(ДокОснование) Экспорт
	ТипОснования 	= ТипЗнч(ДокОснование);
	
	Отправитель		= Неопределено;
	Получатель		= Неопределено;
	
	ПолучательКонтрагент 	= Неопределено;
	ОтправительКонтрагент 	= Неопределено;
	
	МетаДокОснование = Метаданные.НайтиПоТипу(ТипОснования);
	Если МетаДокОснование <> Неопределено И МаркировкаС.ОбъектСуществует(ДокОснование) Тогда
		ВидОснования = МетаДокОснование.Имя;
		Если ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Реквизиты = "Контрагент,Склад";
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
			Реквизиты = "Подразделение,Подразделение";						
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ") Тогда
			Реквизиты = "Подразделение,Подразделение";
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Реквизиты = "Контрагент,Склад";
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			Реквизиты = "Склад,Контрагент";
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
			Реквизиты = "Склад,СкладПолучатель,Склад.КонтрагентДляПеремещений,СкладПолучатель.КонтрагентДляПеремещений";
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеТМЦ") Тогда
			Реквизиты = "Склад,СтатьяЗатрат";
		Иначе
			Реквизиты = "";			
		КонецЕсли;
		
		Части = СтрРазделить(Реквизиты, ",");
		Если Части.Количество() >= 2 Тогда			
			Реквизиты = Новый Соответствие;
			Реквизиты[СокрЛП(Части[0])] = "Отправитель";
			Реквизиты[СокрЛП(Части[1])] = "Получатель";
			
			Для Сч = 2 По Части.ВГраница() Цикл
				Реквизиты[Части[Сч]] = СтрЗаменить(Части[Сч], ".", "_"); 			
			КонецЦикла; 
			
			РеквизитыШ = ПолучитьРеквизитыШапки(ДокОснование, Реквизиты); 		
			Если НЕ РеквизитыШ.Свойство("Отправитель") Тогда
				РеквизитыШ.Вставить("Отправитель", РеквизитыШ.Получатель);
			КонецЕсли;
			
			ОтправительКонтрагент	= МаркировкаКС.ПолучитьЗначениеПараметра(РеквизитыШ, "Склад_КонтрагентДляПеремещений");
			ПолучательКонтрагент	= МаркировкаКС.ПолучитьЗначениеПараметра(РеквизитыШ, "СкладПолучатель_КонтрагентДляПеремещений");
			
			Отправитель = ?(ЗначениеЗаполнено(ОтправительКонтрагент),	ОтправительКонтрагент,	РеквизитыШ.Отправитель);
			Получатель 	= ?(ЗначениеЗаполнено(ПолучательКонтрагент),	ПолучательКонтрагент,	РеквизитыШ.Получатель);
			
			Отправитель = ?(ТипЗнч(Отправитель) = Тип("СправочникСсылка.Склады"), Маркировка_ПИ.ФизическоеПодразделениеСклада(Отправитель),	Отправитель);
			Получатель	= ?(ТипЗнч(Получатель)	= Тип("СправочникСсылка.Склады"), Маркировка_ПИ.ФизическоеПодразделениеСклада(Получатель),	Получатель);		
		КонецЕсли;			
	КонецЕсли;
	
	Возврат Новый Структура("Отправитель,Получатель", Отправитель, Получатель);
КонецФункции //ОпределитьОтправителяПолучателя(ДокОснование) Экспорт

#Область СозданиеДокументов

Функция Создать_ХКМ_к_ПНК(ПНК_Ссылка, Знач ЭтоИмпорт = Ложь) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	Если ЭтоИмпорт Тогда
		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Результат = Создать_ХКМ_к_ПНК_Импорт(ПНК_Ссылка);
		Иначе
			Результат.Ошибки.Добавить("Создавать ХКМ к ПНК по импорту можно только в управляющих подразделениях !");											
		КонецЕсли; 
	Иначе
		Результат = Создать_ХКМ_к_ПНК_Факт(ПНК_Ссылка);
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //Создать_ХКМ_к_ПНК(ПНК_Ссылка)

Функция Создать_ХКМ_к_ПНК_Импорт(ПНК_Ссылка) Экспорт
	Результат	= МаркировкаКС.СтруктураРезультата(Ложь);
	
	ТекСтатус	= ПолучитьРеквизитШапки(ПНК_Ссылка, "СостояниеНакладной");
	
	ПланФакт	= Перечисления.ПланФакт.Факт;
	
	Если ТекСтатус = Перечисления.СостоянияНакладной.ВРаботе Тогда
		ТекстОшибки = "Формирование ХКМ невозможно для документа в статусе 'В работе'.";
		Результат.Ошибки.Добавить(ТекстОшибки);
		Возврат Результат;	
	КонецЕсли;
	
	рОчистки = ОчиститьПодчиненныеХКМ(ПНК_Ссылка, ПланФакт);
	Если рОчистки.Успешно Тогда		
		СуществующиеДокументы	= рОчистки.СуществующиеДокументы;		
		ПорцииКодов				= ПолучитьКМпоПНК_Импорт(ПНК_Ссылка);
		
		Сч = 0;
		Для Каждого Порция Из ПорцииКодов Цикл		
			Сч = Сч + 1;		
		
			ДокСсылка = СуществующиеДокументы[Сч];					
			Если ДокСсылка <> Неопределено Тогда
				ДокОбъект = ДокСсылка.ПолучитьОбъект();
			Иначе				
				ДокОбъект = Документы.ХранилищеКодовМаркировки.СоздатьДокумент();
				
				ДокОбъект.Дата	= ТекущаяДата();
				ДокОбъект.Заполнить(Новый Структура("ДокОснование,ТолькоШапка", ПНК_Ссылка, Истина));
			КонецЕсли;			
			
			ДокОбъект.ПланФакт	= Перечисления.ПланФакт.Факт;
			ДокОбъект.Операция	= Перечисления.СкладскиеОперации.Приемка;
			
			ДокОбъект.Товары.Очистить();
			ДокОбъект.ШтрихкодыУпаковок.Очистить();
			
			Для Каждого ШтрихКодУпаковки Из Порция Цикл
				СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();		
				СтрокаТЧ.ШтрихкодУпаковки = ШтрихКодУпаковки;
			КонецЦикла; 
			
			ДокОбъект.ПометкаУдаления = Ложь;
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные заказы на КМ !");
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);	
	
	Возврат Результат;
	
КонецФункции //Создать_ХКМ_к_ПНК_План(ПНК_Ссылка)

Функция Создать_ХКМ_к_ЗПС_Импорт_ПоОтчетам(ЗПС_Ссылка, ТаблицаАгрегаций) Экспорт
	Результат	= МаркировкаКС.СтруктураРезультата(Ложь);
	
	ТекСостояние= ПолучитьРеквизитШапки(ЗПС_Ссылка, "СостояниеЗаказа");
	
	ПланФакт	= Перечисления.ПланФакт.Факт;
	
	Если ТекСостояние = Перечисления.СостояниеЗаказаПоставщику.ВРаботе Тогда
		ТекстОшибки = "Формирование ХКМ невозможно для документа в статусе 'В работе'.";
		Результат.Ошибки.Добавить(ТекстОшибки);
		Возврат Результат;	
	КонецЕсли;
	
	рОчистки = ОчиститьПодчиненныеХКМ(ЗПС_Ссылка, ПланФакт);
	Если рОчистки.Успешно Тогда		
		СуществующиеДокументы	= рОчистки.СуществующиеДокументы;		
		ПорцииКодов				= ПолучитьКМПоОтчетамОНанесении(ТаблицаАгрегаций);
		
		Сч = 0;
		Для Каждого Порция Из ПорцииКодов Цикл		
			Сч = Сч + 1;		
		
			ДокСсылка = СуществующиеДокументы[Сч];					
			Если ДокСсылка <> Неопределено Тогда
				ДокОбъект = ДокСсылка.ПолучитьОбъект();
			Иначе				
				ДокОбъект = Документы.ХранилищеКодовМаркировки.СоздатьДокумент();
				
				ДокОбъект.Дата	= ТекущаяДата();
