			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные ХКМ !");
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);	
	
	Возврат Результат;	
КонецФункции //Создать_ХКМ_к_ЗМО(ЗМО_Ссылка)

Функция Отменить_ХКМ_к_НАК(Док_Ссылка, ПланФакт) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	рОчистки = ОчиститьПодчиненныеХКМ(Док_Ссылка, ПланФакт);
	Если рОчистки.Успешно Тогда			
		Результат.ОбработаноОбъектов = рОчистки.ОбработаноОбъектов;
	Иначе		
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные ХКМ к документу: "+Док_Ссылка);
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);	
	
	Возврат Результат;
	
КонецФункции //Отменить_ХКМ_к_НАК(Док_Ссылка)

