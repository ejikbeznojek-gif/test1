	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|   ШтрихкодУпаковки.Владелец КАК Номенклатура,
	|	ШтрихкодУпаковки,
	|	НомерЗаказа,
