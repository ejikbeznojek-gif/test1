	Запрос.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
	|ГДЕ
	|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка.ДокОснование = &ДокОтгрузки
	|	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Проведен
	|	И (ЛистПереукладкиШтрихкодыУпаковок.Ссылка.КодАгрегации <> &КодАгрегации
	|			ИЛИ ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодБлочка <> &КодАгрегации
	|			ИЛИ ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(перечисление.ТипыШтрихКодов.Коробка))";
	//Валетов -
			   
	запрос.УстановитьПараметр("КодАгрегации",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
	//Кухарь 23.12.2024 конец	
	
	Запрос.УстановитьПараметр("ДокОтгрузки", ДокОтгрузки);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка));
КонецФункции //ЕстьЛистыПереукладки(ДокОтгрузки) Экспорт 

