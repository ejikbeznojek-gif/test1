Функция ПолучитьКМпоХКМ(ДокОтгрузки, МаксЧислоКодов = 50000) Экспорт	
	Запрос = Новый Запрос(ТекстЗапроса_КМ_ПоДокументуОтгрузки_ХКМ());
	Запрос.УстановитьПараметр("ДокОтгрузки", ДокОтгрузки);	
	
	Результат	= Новый Массив;
	мКоды 		= Новый Массив;
	Выборка 	= Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		мКоды.Добавить(Выборка.ШтрихкодУпаковки);
		
		Если мКоды.Количество() >= МаксЧислоКодов И МаксЧислоКодов > 0 Тогда
			Результат.Добавить(мКоды);		
			мКоды = Новый Массив;
		КонецЕсли; 		
	КонецЦикла; 
	
	Если МаксЧислоКодов>0 Тогда	
		Если мКоды.Количество() > 0 Тогда
			Результат.Добавить(мКоды);
		КонецЕсли; 		
	Иначе            
		Результат = мКоды;		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьКМпоХКМ()

