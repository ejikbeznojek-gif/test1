Функция ТекстЗапроса_КМ_ЗПС_Импорт_САгрегатами() Экспорт
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодУпаковки КАК ШтрихкодУпаковкиХКМ
	|ПОМЕСТИТЬ ВТ_ОформленныеХКМ
	|ИЗ
	|  	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка.ДокОснование = &ЗПС_Ссылка
	|	И Ссылка <> &ТекущийХКМ
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодУпаковки
	|;	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ШтрихкодУпаковки.Владелец.Родитель	КАК Модель,
	|	ШтрихкодУпаковки.Владелец 			КАК Номенклатура,	
	|	ШтрихкодУпаковки					КАК ШтрихкодУпаковки,
	|	ШтрихкодКоробки				 		КАК ШтрихкодКоробки,
	|	1									КАК КоличествоКМ
	|ИЗ 
	|	Документ.МаркировкаТоваровИСМП.ШтрихКодыУпаковок КАК Агрегации
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_ОформленныеХКМ
	|ПО
	|	Агрегации.ШтрихкодУпаковки = ВТ_ОформленныеХКМ.ШтрихкодУпаковкиХКМ	
	|ГДЕ
	|	Агрегации.Ссылка.ДокументОснование = &ЗПС_Ссылка
	|	И (
	|		Агрегации.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки) 
	|		ИЛИ Агрегации.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан) 
	|	)	
	|	И Агрегации.Ссылка.ВидОПерации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И Агрегации.Ссылка.Проведен
	|	И ВТ_ОформленныеХКМ.ШтрихкодУпаковкиХКМ ЕСТЬ NULL
	|УПОРЯДОЧИТЬ ПО
	|	Агрегации.ШтрихкодУпаковки.Владелец.Наименование,
	|	Агрегации.ШтрихкодКоробки.Наименование,		
	|	Агрегации.ШтрихкодУпаковки.Наименование
	|ИТОГИ СУММА(КоличествоКМ) ПО	
	|	Модель,
	|	Номенклатура
	|";	
	
	Возврат ТекстЗапроса;
КонецФункции // ТекстЗапроса_КМ_ПНК_Импорт_САгрегатами(ПНК_Ссылка) Экспорт

