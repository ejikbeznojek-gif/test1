Функция ЗарегистрироватьКоробкиНаСклад(ХКМ_Ссылка) Экспорт
	Результат 	= МаркировкаКС.СтруктураРезультата(Ложь);
	
	рШапки		= Неопределено;
	Если ЗначениеЗаполнено(ХКМ_Ссылка) Тогда		
		рШапки = ПолучитьРеквизитыШапки(ХКМ_Ссылка, "ПланФакт,Проведен,ДокОснование,ДокОснование.Склад");		
	Иначе
		Результат.Ошибки.Добавить("Недопустимый тип документа: '" + ТипЗнч(ХКМ_Ссылка)+"' !");
	КонецЕсли;
	
	Если рШапки <> Неопределено Тогда
		ТипОснования = ТипЗнч(рШапки.ДокОснование);
		Если ТипОснования <> Тип("ДокументСсылка.ЗаказПоставщику") Тогда			
			Результат.Ошибки.Добавить("Недопустимый тип основания ХКМ: '" + ТипОснования+"', ожидаемый тип 'ЗаказПоставщику' !");
		ИначеЕсли рШапки.ПланФакт <> Перечисления.ПланФакт.Факт Тогда
			Результат.Ошибки.Добавить("Регистрация ШК КМ выполняется только для ХКМ 'Факт' !");
		КонецЕсли;
		
		Если НЕ рШапки.Проведен Тогда
			Результат.Ошибки.Добавить("ХКМ не проведен !");		
		КонецЕсли; 
	КонецЕсли; 
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;	
	КонецЕсли;
	
	УзелСклада	= Маркировка_ПИ.УзелПоКоду("OD7cz", "ДанныеЧЗ");
	
	Если НЕ ЗначениеЗаполнено(УзелСклада) Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить("Невозможно определить узел : 'OD7cz' !");
		Возврат Результат;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодКоробки	КАК КМ
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок 
	|ГДЕ	
	|	Ссылка = &ХКМ_Ссылка
	|	И НЕ ШтрихкодКоробки.ВерсияДанных ЕСТЬ NULL
	|";
	
	Запрос.УстановитьПараметр("ХКМ_Ссылка", ХКМ_Ссылка);
	
	рЗапроса	= Запрос.Выполнить();	
	мКодов		= рЗапроса.Выгрузить().ВыгрузитьКолонку("КМ");	
	
	ОбменДаннымиЧЗ.УстановитьПолучателей(УзелСклада, мКодов);
	
	Результат.Успешно	= Истина;
	Результат.Данные	= УзелСклада;
	Результат.ОбработаноОбъектов = мКодов.Количество();
	
	Возврат Результат; 
КонецФункции //ЗарегистрироватьКоробкиНаСклад()

Функция ПолучитьКМДляПроверки(ДокСсылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ		
	|	ШтрихкодКоробки.Наименование КАК КМ
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И ШтрихкодКоробки.Наименование ЕСТЬ НЕ NULL
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ		
	|	ШтрихкодУпаковки.Наименование КАК КМ
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)		
	|	И ШтрихкодУпаковки.Наименование ЕСТЬ НЕ NULL
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ		
	|	ШтрихкодНабора.Наименование КАК КМ
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И ШтрихкодНабора <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)	
	|	И ШтрихкодНабора.Наименование ЕСТЬ НЕ NULL
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("КМ");
КонецФункции //ПолучитьКМДляПроверки(ДокСсылка) Экспорт

Функция ПолучитьТаблицуКМДокумента(ДокСсылка, ДопПараметры = Неопределено) Экспорт	
	Запрос = Новый Запрос;
	Запрос.Текст = " 	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ       
	|	ШтрихкодУпаковки
	|ИЗ	
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И (
	|		ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|		ИЛИ ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|	)
	|";
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	мШтрихКоды = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	
	тШК = Новый ТаблицаЗначений;
	тШК.Колонки.Добавить("ШтрихКодУпаковки", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));

	Для Каждого ШтрихКодУпаковки Из Документы.МаркировкаТоваровИСМП.ПолучитьВложенныеКоды(мШтрихКоды) Цикл
		СтрокаТ = тШК.Добавить();
		СтрокаТ.ШтрихкодУпаковки = ШтрихкодУпаковки;
	КонецЦикла;  
	
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ШК ИЗ &тШК КАК тШК
	|;                                        
	|ВЫБРАТЬ РАЗЛИЧНЫЕ       
	|	ШтрихкодУпаковки	
	|ИЗ	
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)	
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихКодУпаковки КАК ШтрихКодУпаковки
	|ИЗ
	|	ВТ_ШК
	|ГДЕ
	|	ВТ_ШК.ШтрихКодУпаковки ЕСТЬ НЕ NULL 
	|";	
	
	Запрос.УстановитьПараметр("тШК", тШК);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьТаблицуКМДокумента()
