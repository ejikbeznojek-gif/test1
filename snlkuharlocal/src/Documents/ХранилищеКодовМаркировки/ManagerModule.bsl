Функция ОчиститьПодчиненныеХКМ(ДокОснование, ПланФакт, Операция=Неопределено)	
// Кухарь А.Ю. 10.03.2025 конец
	
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
	|ГДЕ
	|	ХранилищеКодовМаркировки.ДокОснование = &ДокОснование
	|	И ХранилищеКодовМаркировки.Операция = &Операция
	|	И ХранилищеКодовМаркировки.ПланФакт = &ПланФакт";
	// Кухарь А.Ю. 10.03.2025 начало
	если Операция=Неопределено тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"И ХранилищеКодовМаркировки.Операция = &Операция","");
	иначе
		запрос.УстановитьПараметр("Операция",Операция);
	КонецЕсли;
	// Кухарь А.Ю. 10.03.2025 конец
	
	
	Запрос.УстановитьПараметр("ДокОснование",	ДокОснование);
	Запрос.УстановитьПараметр("ПланФакт",		ПланФакт);
	
	СуществующиеДокументы = Новый Соответствие;
	
	Сч = 1;
		
	НачатьТранзакцию();
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Если ДокОбъект.Проведен Тогда
			ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);		
		КонецЕсли;
		
		ДокОбъект.Товары.Очистить();
		ДокОбъект.ШтрихкодыУпаковок.Очистить();
		ДокОбъект.Проведен			= Ложь;
		ДокОбъект.ПометкаУдаления 	= Истина;
	
		ДокОбъект.Записать();		
		
		СуществующиеДокументы[Сч] = ДокОбъект.Ссылка;
		Сч	= Сч+1;
	КонецЦикла;		
	
	ЗафиксироватьТранзакцию();	

	Результат.Вставить("СуществующиеДокументы", СуществующиеДокументы);

	Возврат Результат;
КонецФункции //ОчиститьПодчиненныеХКМ(ДокОснование)


Функция ПроверитьНаличиеХКМ(ДокОснование, ПланФакт=Неопределено,ОтборПоОтправителю = Неопределено, ОтборПоПолучателю = Неопределено) экспорт
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ первые 1
	|	ХКМ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки КАК ХКМ
	|ГДЕ
	|	ХКМ.ДокОснование = &ДокОснование
	|	И ХКМ.ПланФакт = &ПланФакт
	|	И ХКМ.Отправитель = &ОтборПоОтправителю
	|	И ХКМ.Получатель = &ОтборПоПолучателю
	|	И ХКМ.Проведен";
	запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	если ПланФакт=Неопределено тогда
		запрос.Текст=СтрЗаменить(Запрос.Текст,"И ХКМ.ПланФакт = &ПланФакт","");
	иначе
		запрос.УстановитьПараметр("ПланФакт",ПланФакт);
	КонецЕсли;                         
	если ОтборПоОтправителю=Неопределено тогда
		запрос.Текст=СтрЗаменить(Запрос.Текст,"И ХКМ.Отправитель = &ОтборПоОтправителю","");
	иначе
		запрос.УстановитьПараметр("ОтборПоОтправителю",ОтборПоОтправителю);
	КонецЕсли;
	
	если ОтборПоПолучателю=Неопределено тогда
		запрос.Текст=СтрЗаменить(Запрос.Текст,"И ХКМ.Получатель = &ОтборПоПолучателю","");
	иначе
		запрос.УстановитьПараметр("ОтборПоПолучателю",ОтборПоПолучателю);
	КонецЕсли;
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		возврат Истина;
	КонецЦикла;
	
	Возврат ложь;
	
КонецФункции


