Функция ЗаполнитьПоЗаданиюНаМаркировку(ДокОтгрузки)
	Запрос = Новый Запрос(Документы.ХранилищеКодовМаркировки.ТекстЗапроса_КМ_ПоЗаданиеНаМаркировку());
	Запрос.УстановитьПараметр("ДокОтгрузки", ДокОтгрузки);
	Если ЗначениеЗаполнено(ДокОтгрузки) И ТипЗнч(ДокОтгрузки) = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		Накладная = ПолучитьРеквизитШапки(ДокОтгрузки, "ДокОснование");
		Если ТипЗнч(Накладная) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			Операция = Перечисления.СкладскиеОперации.Отгрузка;		
		КонецЕсли; 
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() <= 75000 Тогда
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
			
			СтрокаТЧ.ШтрихкодУпаковки	= Выборка.ШтрихкодУпаковки;	
			СтрокаТЧ.ШтрихкодКоробки    = Выборка.ШтрихкодКоробки;
		КонецЦикла;			
	КонецЕсли;	
КонецФункции //ЗаполнитьПоЗаданиеНаМаркировку(ПНК_Ссылка)

