
#Область СобытияДокумента


Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)	
	Автор 			 = ПараметрыСеанса.Пользователь;
	ТипОснования	 = ТипЗнч(ДанныеЗаполнения);
		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ДокОснование 	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеЗаполнения, "ДокОснование");
		ТолькоШапка		= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеЗаполнения, "ТолькоШапка", Ложь);
	Иначе		
		ДокОснование 	= ДанныеЗаполнения;		
		ТолькоШапка		= Ложь;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ДокОснование) Тогда Возврат КонецЕсли;
	
	Организация = ПолучитьРеквизитШапки(ДокОснование, "Организация");
	
	ЗаполнитьОтправителяПолучателя();
	
	Если ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		ПланФакт	= Перечисления.ПланФакт.Факт;
		Операция	= Перечисления.СкладскиеОперации.Приемка;
		Если ТолькоШапка Тогда Возврат КонецЕсли;
		
		ЗаполнитьПоЗПС_Импорт(ДокОснование)
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		ПланФакт	= Перечисления.ПланФакт.Факт;
		
		Операция = Перечисления.СкладскиеОперации.Приемка;
		Если ТолькоШапка Тогда Возврат КонецЕсли;		
		
		ЗаполнитьПоЛНкНакладной(ДокОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		ПланФакт = Перечисления.ПланФакт.Факт;
		Операция	= Перечисления.СкладскиеОперации.Отгрузка;
		Если ТолькоШапка Тогда Возврат КонецЕсли; 
		
		ЗаполнитьПоЛНкНакладной(ДокОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.Перемещение") Тогда
		рШапки = ПолучитьРеквизитыШапки(ДокОснование, "Склад.КодФизическогоУзла,СкладПолучатель.КодФизическогоУзла", "Документ");		
		
		// Кухарь А.Ю. 27.12.2024 начало
		//
		если рШапки.Склад_КодФизическогоУзла="" тогда
			рШапки.Склад_КодФизическогоУзла="SNL";
		КонецЕсли;
		если рШапки.СкладПолучатель_КодФизическогоУзла="" тогда
			рШапки.СкладПолучатель_КодФизическогоУзла="SNL";
		КонецЕсли;
		
		// Кухарь А.Ю. 27.12.2024 конец
		
		Если ОбщегоНазначения_ПИ.ЭтотУзелКод("Основной") = рШапки.Склад_КодФизическогоУзла Тогда
			ПланФакт = Перечисления.ПланФакт.Факт;
			Операция = Перечисления.СкладскиеОперации.Отгрузка;
		ИначеЕсли ОбщегоНазначения_ПИ.ЭтотУзелКод("Основной") = рШапки.СкладПолучатель_КодФизическогоУзла Тогда			
			ПланФакт = Перечисления.ПланФакт.Факт;		
			Операция = Перечисления.СкладскиеОперации.Приемка;	
		Иначе
			Сообщить("ХКМ создаются только на складе отправителе или получателе !", СтатусСообщения.Важное);
		КонецЕсли;
		
		Если ТолькоШапка Тогда Возврат КонецЕсли; 
		
		ЗаполнитьПоЛНкНакладной(ДокОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеТМЦ") Тогда
		ПланФакт = Перечисления.ПланФакт.Факт;
		Операция = Перечисления.СкладскиеОперации.Отгрузка;
		Если ТолькоШапка Тогда Возврат КонецЕсли;
		
		ЗаполнитьПоЛНкНакладной(ДокОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		ПланФакт = Перечисления.ПланФакт.Факт;
		Операция = Перечисления.СкладскиеОперации.ОтгрузкаПриемка;
		Если ТолькоШапка Тогда Возврат КонецЕсли;
		
		ЗаполнитьПоЗаданиюНаМаркировку(ДокОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ") Тогда
		ПланФакт = Перечисления.ПланФакт.Факт;
		Операция = Перечисления.СкладскиеОперации.Приемка;
		Если ТолькоШапка Тогда Возврат КонецЕсли;
		
		ЗаполнитьПоЗаданиюНаСборку(ДокОснование);
	КонецЕсли;	
КонецПроцедуры

//+++Чирков 17.03.2026
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	рПроверки = лМожноЗаписатьДокумент();
	Если Не рПроверки.Успешно Тогда
		ТекстОшибки = СтрСоединить(рПроверки.Ошибки, Символы.ПС);
		ЗаписатьВЛог("ОбменДанными", ТекстОшибки, "Ошибка");
		Отказ = Истина;                         
		ВызватьИсключение ТекстОшибки;
		Возврат;
	КонецЕсли; 
			
	Если ЭтоНовый() Тогда
		КодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код();		
	КонецЕсли;
		
	ЕстьИзменения	= Модифицированность();
	Если ЕстьИзменения Тогда	
		ЗаполнитьКоличестваКМ();	
		ЗаполнитьТовары();
	КонецЕсли; 
	
	НужноВыгружать	= НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	ДополнительныеСвойства.Вставить("НужноВыгружать", НужноВыгружать);
	
	Если КодОперации.Пустая() И ЗначениеЗаполнено(ДокОснование) И ЕстьРеквизитДокумента("КодОперации", ДокОснование.Метаданные()) Тогда
		КодОперации = ПолучитьРеквизитШапки(ДокОснование, "КодОперации");
	КонецЕсли; 
		
	Если НужноВыгружать Тогда
		Документы.ХранилищеКодовМаркировки.УстановитьПолучателейИзменений(ЭтотОбъект);		
	КонецЕсли;
			
КонецПроцедуры
//---Чирков 17.03.2026

Процедура ПриЗаписи(Отказ)
	Если Проведен И (ЭтоЗавершенныйВозврат() ИЛИ ЭтоПринятоеПеремещение()) Тогда
		РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьЗадачуОчисткиОтгружаемыхКМДокумента(Ссылка);			
	КонецЕсли;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	КодУзлаСоздания = ОбщегоНазначения_ПИ.ЭтотУзелКод("Основной");
	Автор 			= ПараметрыСеанса.Пользователь;
	
	ШтрихкодыУпаковок.Очистить();
	Товары.Очистить();
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Префикс = Маркировка_ПИ.ЭтотУзел_Код("Основной")+"-";
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	
	СтатусКМ 		= Неопределено;	
	Местонахождение = Неопределено;	
	ВПути			= Ложь;
	
	Движения.СтатусыКМ_Факт.Очистить();
	Движения.СтатусыКМ_Факт_А.Очистить();
	
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Если ПланФакт = Перечисления.ПланФакт.Факт Тогда
		КонецЕсли;		
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Если ПланФакт = Перечисления.ПланФакт.Факт Тогда
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;
			рШапки = ПолучитьРеквизитыШапки(ДокОснование, "Склад,Склад.ФизическийСклад,КодОперации,ДокОснование");		
			Местонахождение = ?(ЗначениеЗаполнено(рШапки.Склад_ФизическийСклад), рШапки.Склад_ФизическийСклад, рШапки.Склад);			
			Местонахождение = Маркировка_ПИ.ФизическоеПодразделениеСклада(Местонахождение);

			рМестоПоложения = ПолучитьРеквизитыШапки(рШапки.Склад, "СкладБухгалтерии,КарантинЧЗ");

			Если рМестоПоложения.КарантинЧЗ тогда
				//++Данилова Е.В. 16.12.2025 MARK-3378 
				СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Карантин;
				//--Данилова Е.В. 16.12.2025 
			Иначе								
				Местонахождение = Получатель;				
			КонецЕсли;
		ИначеЕсли ПланФакт = Перечисления.ПланФакт.План Тогда
			
		КонецЕсли;		
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") 

	Тогда
		СтатусКМ		= Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю;		
		Местонахождение = Получатель;
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.Перемещение") Тогда		
		рШапки 			= ПолучитьРеквизитыШапки(ДокОснование, "СкладПолучатель");
		Местонахождение = Получатель;
		
		Если ЭтоСкладКарантина(рШапки.СкладПолучатель) Тогда                        
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Карантин;		
		Иначе
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;
		КонецЕсли;
		
		ВПути = (Операция = Перечисления.СкладскиеОперации.Отгрузка);		
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.СписаниеТМЦ") Тогда		
		рШапки = ПолучитьРеквизитыШапки(ДокОснование, "СтатьяЗатрат");
		Местонахождение = рШапки.СтатьяЗатрат;
		
		СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Списан;
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда		
		рШапки = ПолучитьРеквизитыШапки(ДокОснование, "Подразделение");
		Местонахождение = Получатель;
		
		Если КодУзлаСоздания<>Маркировка_ПИ.ЭтотУзел_Код() Тогда
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Нанесен;			
		КонецЕсли;	
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ОтчетКассовойСмены") Тогда 
		Если Операция = Перечисления.СкладскиеОперации.Приемка Тогда			
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;
			Местонахождение = Получатель;
		Иначе
			//+20251113 корр. Михайловский
			//СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю;
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Выбыл;  
			//-20251113 корр. Михайловский
			Местонахождение = Получатель;			
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РекламационнаяНакладная") Тогда 
		Если Операция = Перечисления.СкладскиеОперации.Приемка Тогда			
			СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;
			Местонахождение = Получатель;
		Иначе
			//+HELP-7109 20251112 Михайловский
			//СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю; 
			СтатусКМ = ?(ТипЗнч(ДокОснование.ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная"), Перечисления.СтатусыКодовМаркировкиФакт.ВозвращенПоставщику, Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю);
			//-HELP-7109 20251112 Михайловский
			Местонахождение = Получатель;			
		КонецЕсли;
    //Валетов + 09,07,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5737
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.МаркировкаОстатковТЦ") Тогда
		СтатусКМ		= Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;		
		Местонахождение = Получатель;
	//Валетов -	
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(СтатусКМ) Тогда
		НЗ = Движения.СтатусыКМ_Факт;
		
		//ТЧ                                     
		
		Для Каждого СтрокаШК Из ПолучитьТаблицуШК(Ссылка) Цикл
			Движение = НЗ.Добавить();
				
			Движение.Период 			= Дата;
			
			Движение.ШтрихКодУпаковки	= СтрокаШК.ШтрихкодУпаковки;
			Движение.Номенклатура		= СтрокаШК.Номенклатура;
			Движение.ТипШК				= СтрокаШК.ТипШК;
			
			//Валетов+ 01,11,2024 Для ХКМ к ОКС.Движения будут зависеть от Значения Операция в ТЧ ШтрихкодыУпаковок, а для начала заполним СтатусКМ
			Если ЗначениеЗаполнено(СтрокаШК.Операция) И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ОтчетКассовойСмены") Тогда
				Если СтрокаШК.Операция = Перечисления.СкладскиеОперации.Отгрузка Тогда
					Движение.Статус			= СтатусКМ;			
				Иначе
					Движение.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;					
				КонецЕсли;
				
				Движение.Местонахождение	= Местонахождение;
				Движение.ВПути				= ВПути;
			//Валетов + 22,02,2025
			//ПУСТАЯ ЗАДАЧА Добавление движения ХКМ для РКМ с пересортом. Одна КМ "+" на склад, вторая "-" покупателю. 
			ИначеЕсли ЗначениеЗаполнено(СтрокаШК.Операция) И ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РекламационнаяНакладная") Тогда
				
				Если СтрокаШК.Операция = Перечисления.СкладскиеОперации.Отгрузка Тогда
					//+HELP-7109 20251112 Михайловский
					//Движение.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю;
			   		Движение.Статус = ?(ТипЗнч(ДокОснование.ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная"), Перечисления.СтатусыКодовМаркировкиФакт.ВозвращенПоставщику, Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю);
					//Местонахождение			= Отправитель;
					//-HELP-7109 20251112 Михайловский
				Иначе
					Движение.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте;
				КонецЕсли;
				Движение.Местонахождение	= Местонахождение;
				Движение.ВПути				= ВПути;
			Иначе
			//Валетов- 01,11,2024
				Движение.Статус				= СтатусКМ;			
				Движение.Местонахождение	= Местонахождение;
				Движение.ВПути				= ВПути;
			КонецЕсли;
			
			//+++Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок
			Если СтрокаШК.ТипШК <> Перечисления.ТипыШтрихКодов.Штука Тогда
				Движение_Кор = Движения.СтатусыКМ_Факт_А.Добавить();
				ЗаполнитьЗначенияСвойств(Движение_Кор, Движение);
				
				Движение_Кор.СпособВводаВОборот = СтрокаШК.СпособВводаВОборот;
				//+++Чирков 01.12.2025 ТипУпаковки - убираем
				//Движение_Кор.ТипУпаковки 		= СтрокаШК.ТипУпаковки;
				//---Чирков 01.12.2025
			КонецЕсли;			
			//---Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок
		КонецЦикла;	
		
		//Вложенные коды
		ВложенныеКоды = ПолучитьВыборкуВложенныхКодов();
		Для Каждого СтрокаК Из ВложенныеКоды Цикл		
			Движение = Движения.СтатусыКМ_Факт.Добавить();
			
			Движение.Период 			= Дата;
			
			Движение.ШтрихКодУпаковки	= СтрокаК.ШтрихкодУпаковки;
			Движение.ТипШК				= СтрокаК.ТипШК;
			Движение.Номенклатура		= СтрокаК.Номенклатура;
			
			Движение.Статус				= СтатусКМ;			
			Движение.Местонахождение	= Местонахождение;			
			Движение.ВПути				= ВПути;
			
			//+++Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
			Если СтрокаК.ТипШК <> Перечисления.ТипыШтрихКодов.Штука Тогда
				Движение_Кор = Движения.СтатусыКМ_Факт_А.Добавить();
				ЗаполнитьЗначенияСвойств(Движение_Кор, Движение);
				
				Движение_Кор.СпособВводаВОборот = СтрокаК.СпособВводаВОборот;
				//+++Чирков 01.12.2025 ТипУпаковки - убираем
				//Движение_Кор.ТипУпаковки 		= СтрокаК.ТипУпаковки;
				//---Чирков 01.12.2025
			КонецЕсли;			
			//---Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
		КонецЦикла;
		
		//Коды коробок
		тКоробок = МаркировкаС.ПолучитьДанныеКоробок(Ссылка, "ШтрихКодыУпаковок");
		Для Каждого СтрокаКоробки Из тКоробок Цикл			
			Движение = Движения.СтатусыКМ_Факт.Добавить();
			
			Движение.Период 			= Дата;
			
			Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихкодКоробки;
			Движение.ТипШК				= СтрокаКоробки.ТипШК;
			
			Движение.Статус				= СтатусКМ;
			Движение.Местонахождение	= Местонахождение;
			Движение.ВПути				= ВПути;			
			
			//СтатусыКМ_Факт_А
			Движение = Движения.СтатусыКМ_Факт_А.Добавить();
			
			Движение.Период 			= Дата;
			
			Движение.СпособВводаВОборот = СтрокаКоробки.СпособВводаВОборот;	
			Движение.ТипШК				= СтрокаКоробки.ТипШК;
			//+++Чирков 01.12.2025 ТипУпаковки - убираем
			//Движение.ТипУпаковки		= СтрокаКоробки.ТипУпаковки;
			//--Чирков 01.12.2025
			Движение.ШтрихКодУпаковки	= СтрокаКоробки.ШтрихкодКоробки;
			
			Движение.Статус				= СтатусКМ;
			Движение.Местонахождение	= Местонахождение;
			Движение.ВПути				= ВПути;
		КонецЦикла; 
	КонецЕсли;		
	
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная")
		ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.Перемещение")
		ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ОприходованиеТМЦ")
		ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.СписаниеТМЦ")
		//ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная")
		ИЛИ ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ОтчетКассовойСмены") Тогда
			
		РасформироватьКоробки(Отправитель);		
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаданиеНаСборкуКомплектовЧЗ") Тогда
		Если КодУзлаСоздания <> Маркировка_ПИ.ЭтотУзел_Код("Основной") Тогда
			СформироватьДвиженияПоЗСБ();
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		Если КодУзлаСоздания <> Маркировка_ПИ.ЭтотУзел_Код("Основной") Тогда
			СформироватьДвиженияПоЗМО();
		КонецЕсли;
	КонецЕсли; 
	
	МаркировкаКС.СохранитьОтложенныеДвижения(ЭтотОбъект, Отказ);
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	Движения.СтатусыКМ_Факт.Очистить();
	Движения.СтатусыКМ_Факт_А.Очистить();
	Движения.ОстаткиДоступныхКМ.Очистить();
	
	МаркировкаКС.СохранитьОтложенныеДвижения(ЭтотОбъект, Отказ);	
КонецПроцедуры


