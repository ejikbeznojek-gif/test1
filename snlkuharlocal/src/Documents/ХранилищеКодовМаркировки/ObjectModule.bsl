	// Кухарь А.Ю.  16.06.2025 конец
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() <= 75000 Тогда
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
			СтрокаТЧ.ШтрихкодУпаковки = Выборка.ШтрихкодУпаковки;	
		КонецЦикла;			
	КонецЕсли;	
КонецФункции //ЗаполнитьПоЛНкНакладной(ДокОтгрузки)

