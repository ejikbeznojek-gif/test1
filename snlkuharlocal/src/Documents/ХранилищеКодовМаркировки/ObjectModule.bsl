Функция ПолучитьТаблицуШК(ДокСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки					КАК ШтрихкодУпаковки,
	//+++Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
	|	ШтрихкодУпаковки.СпособВводаВОборот КАК СпособВводаВОборот,
	//---Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок
	//+++Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	|	ШтрихкодУпаковки.ТипУпаковки		КАК ТипУпаковки,		                   
	//---Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок	
	|	ШтрихкодУпаковки.ТипШК				КАК ТипШК,
	|	ВЫБОР 
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар) 
	|			ТОГДА ШтрихкодУпаковки.Владелец
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор) 
	|			ТОГДА ШтрихкодУпаковки.Владелец
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)	
	|	КОНЕЦ						КАК Номенклатура,
	|	Операция					КАК Операция,
	|	КодКомплектующегоНеНанесен	КАК КодКомплектующегоНеНанесен
	|ИЗ
	|	" +  ДокСсылка.Метаданные().ПолноеИмя() + ".ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";	
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьТаблицуШК(ДокСсылка)

Процедура СформироватьДвиженияПоЗСБ()
	КодыНаборов = Новый Соответствие;
	Для Каждого СтрокаТЧ Из ПолучитьТаблицуШК(Ссылка) Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодНабора) Тогда
			КодыНаборов[СтрокаТЧ.ШтрихкодНабора] = Истина;
		КонецЕсли;
		
		Если СтрокаТЧ.КодКомплектующегоНеНанесен Тогда		
			Запись = Движения.СтатусыКМ_Факт.Добавить();
			Запись.Период = Дата -1;
			
			Запись.ШтрихКодУпаковки	= СтрокаТЧ.ШтрихкодУпаковки;
			Запись.ТипШК			= СтрокаТЧ.ТипШК;
			Запись.Номенклатура		= СтрокаТЧ.Номенклатура;
			
			Запись.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально;
			Запись.Местонахождение	= Получатель;
		КонецЕсли;
		
		Запись = Движения.СтатусыКМ_Факт.Добавить();
		Запись.Период = Дата;
		
		Запись.ШтрихКодУпаковки	= СтрокаТЧ.ШтрихкодУпаковки;
		Запись.ТипШК			= СтрокаТЧ.ТипШК;
		Запись.Номенклатура		= СтрокаТЧ.Номенклатура;
		
		Запись.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.Вложен;
		Запись.Местонахождение	= Получатель;		
	КонецЦикла;
	
	Для Каждого КиЗ Из КодыНаборов Цикл
		ШтрихкодНабора = КиЗ.Ключ;
		
		Запись = Движения.СтатусыКМ_Факт.Добавить();
		Запись.Период = Дата -1;
		Запись.ШтрихКодУпаковки	= ШтрихкодНабора;
		Запись.Статус			= Перечисления.СтатусыКодовМаркировкиФакт.Нанесен;
		Запись.Местонахождение	= Получатель;
	КонецЦикла;	
КонецПроцедуры

Процедура СформироватьДвиженияПоЗМО()		
	Для Каждого СтрокаШК Из ПолучитьТаблицуШК(Ссылка) Цикл		
		Движение = Движения.СтатусыКМ_Факт.Добавить();
		
		Движение.Период 			= Дата;
		
		Движение.ШтрихКодУпаковки	= СтрокаШК.ШтрихкодУпаковки;
		Движение.ТипШК				= СтрокаШК.ТипШК;
		Движение.Номенклатура		= СтрокаШК.Номенклатура;
		
		Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.Нанесен;
		Движение.Местонахождение	= Получатель;		
		
		//+++Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
		Если СтрокаШК.ТипШК <> Перечисления.ТипыШтрихКодов.Штука Тогда
			Движение_Кор = Движения.СтатусыКМ_Факт_А.Добавить();
			ЗаполнитьЗначенияСвойств(Движение_Кор, Движение);
				
			Движение_Кор.СпособВводаВОборот = СтрокаШК.СпособВводаВОборот;
			//+++Чирков 01.12.2025 ТипУпаковки - убираем
			//Движение_Кор.ТипУпаковки 		= СтрокаШК.ТипУпаковки;
			//---Чирков 01.12.2025
		КонецЕсли;
		//---Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
	КонецЦикла;		
КонецПроцедуры

Функция ЗаполнитьКоличестваКМ() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ШК ИЗ &ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки.ТипКода КАК ТипКода,
	|	СУММА(1) КАК Количество
	|ИЗ
	|	ВТ_ШК	
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодУпаковки.ТипКода	
	|";
	
	Запрос.УстановитьПараметр("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	Выборка = Запрос.Выполнить().Выбрать();
	
	КоличествоГрупповыхКМ	= 0;
	КоличествоШтучныхКМ	    = 0;
	
	Пока Выборка.Следующий() Цикл		
		Если Выборка.ТипКода = Перечисления.ТипыКодовМаркировки.АТК Тогда
			//АТК тут вообще делать нечего, по идее ....
		ИначеЕсли Выборка.ТипКода = Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка Тогда
			КоличествоГрупповыхКМ = Выборка.Количество;
		Иначе
			КоличествоШтучныхКМ = Выборка.Количество;	
		КонецЕсли;
	КонецЦикла;
	
	КоличествоДокумента = КоличествоГрупповыхКМ + КоличествоШтучныхКМ;
КонецФункции //ЗаполнитьКоличстваКМ()

Функция ЗаполнитьПоЗПС_Импорт(ЗПС_Ссылка) Экспорт	
	РеквизитыШ = ПолучитьРеквизитыШапки(ЗПС_Ссылка, "Склад.Подразделение,Контрагент");
	
	Запрос = Новый Запрос(Документы.ХранилищеКодовМаркировки.ТекстЗапроса_КМ_ЗПС_Импорт_САгрегатами());
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);
	Запрос.УстановитьПараметр("ТекущийХКМ",	Ссылка);
	
	ШтрихкодыУпаковок.Очистить();
	
	рЗапроса	= Запрос.Выполнить();
	
	ВсегоКодов	= 0; 
	МаксКолНаДокумент = 90000;
	
	Выборка_Модель = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Модель");
	Пока Выборка_Модель.Следующий() Цикл
		Выборка_Номенклатура = Выборка_Модель.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
		Пока Выборка_Номенклатура.Следующий() Цикл
			Выборка 	= Выборка_Номенклатура.Выбрать();
			ВсегоКодов 	= ВсегоКодов + Выборка.Количество();			
			
			Если ВсегоКодов < МаксКолНаДокумент Тогда
				Пока Выборка.Следующий() Цикл
					СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);				
				КонецЦикла;							
			Иначе
				Если ШтрихкодыУпаковок.Количество() = 0 Тогда //Монопозиция с количеством > 100 000 - КРУТО !
					Пока Выборка.Следующий() И ШтрихкодыУпаковок.Количество() < МаксКолНаДокумент Цикл
						СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);										
					КонецЦикла;				
				КонецЕсли;
				
				ТекстПредупреждения = СтрШаблон("В заказе более " + Формат(МаксКолНаДокумент, "ЧРГ=' '; ЧГ=3,0") + " кодов маркировки. 
				|В текущий документ добавлено %1 кодов.
				|Запишите текущий документ и оформите еще один (или несколько) ХКМ на оставшиеся коды заказа.
				|", ШтрихкодыУпаковок.Количество());
				
				#ЕСЛИ КЛИЕНТ ТОГДА
				ПоказатьПредупреждение(, ТекстПредупреждения);				
				#ИНАЧЕ
				Сообщить(ТекстПредупреждения, СтатусСообщения.Важное);
				#КОНЕЦЕСЛИ
				
				Возврат ШтрихкодыУпаковок.Количество();
			КонецЕсли; 								
		КонецЦикла; 
	КонецЦикла;	
	
КонецФункции //ЗаполнитьПоЗПС_Импорт(ЗПС_Ссылка) Экспорт

Функция ЗаполнитьПоПНК_Импорт(ПНК_Ссылка) Экспорт
	Запрос = Новый Запрос(Документы.ХранилищеКодовМаркировки.ТекстЗапроса_КМ_ПНК_Импорт_САгрегатами());
	Запрос.УстановитьПараметр("ПНК_Ссылка", ПНК_Ссылка);
	
	ШтрихкодыУпаковок.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() <= 50000 Тогда
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = ШтрихкодыУпаковок.Добавить();
			СтрокаТЧ.ШтрихкодУпаковки = Выборка.ШтрихкодУпаковки;	
		КонецЦикла;			
	КонецЕсли;	
КонецФункции //ЗаполнитьПоПНК_Импорт(ПНК_Ссылка)

