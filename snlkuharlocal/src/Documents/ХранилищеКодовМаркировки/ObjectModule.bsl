Функция ЗаполнитьТовары()
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ШК ИЗ &ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|;	
	|ВЫБРАТЬ
	|	ШтрихКодУпаковки.Владелец	КАК Номенклатура,		
	|	СУММА(1) 					КАК Количество
	|ПОМЕСТИТЬ ВТ_НоменклатураПоШтукам
	|ИЗ
	|	ВТ_ШК	
	|ГДЕ
	|	ШтрихКодУпаковки.ТипКода <> ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)	
	|СГРУППИРОВАТЬ ПО
	|	ШтрихкодУпаковки.Владелец
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихКодУпаковки КАК ШтрихКодКоробки
	|ИЗ
	|	ВТ_ШК	
	|ГДЕ
	|	ШтрихКодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|";
			
	Запрос.УстановитьПараметр("ШтрихкодыУпаковок", ШтрихкодыУпаковок);
	
	рЗапроса = Запрос.ВыполнитьПакет();   
	
	ШтрихКодыКоробок = рЗапроса[рЗапроса.ВГраница()].Выгрузить().ВыгрузитьКолонку("ШтрихКодКоробки");
	Если ШтрихКодыКоробок.Количество() > 0 Тогда		
		мВложенныеШК = Документы.МаркировкаТоваровИСМП.ПолучитьВложенныеКоды(ШтрихКодыКоробок);
		
		ВложенныеШК = Новый ТаблицаЗначений;
		ВложенныеШК.Колонки.Добавить("ШтрихКодУпаковки", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));
		
		Для каждого ШтрихКодУпаковки Из мВложенныеШК Цикл
			СтрокаШК = ВложенныеШК.Добавить();
			СтрокаШК.ШтрихКодУпаковки = ШтрихКодУпаковки;
		КонецЦикла;
	
		Запрос.УстановитьПараметр("ВложенныеШК", ВложенныеШК);
		
		Запрос.Текст = "
		|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ВложенныеШК ИЗ &ВложенныеШК КАК ВложенныеШК
		|;
		|ВЫБРАТЬ
		|	Номенклатура		КАК Номенклатура,
		|	СУММА(Количество)	КАК Количество
		|ПОМЕСТИТЬ ВТ_НоменклатураХКМ
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	ШтрихКодУпаковки.Владелец	КАК Номенклатура,
		|	1							КАК Количество
		|ИЗ
		|	ВТ_ВложенныеШК
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ
		|	Номенклатура				КАК Номенклатура,
		|	Количество					КАК Количество
		|ИЗ
		|	ВТ_НоменклатураПоШтукам
		|) КАК Сводный
		|СГРУППИРОВАТЬ ПО
		|	Номенклатура		
		|";
	Иначе
		Запрос.Текст = "		
		|ВЫБРАТЬ
		|	Номенклатура				КАК Номенклатура,
		|	Количество					КАК Количество
		|ПОМЕСТИТЬ ВТ_НоменклатураХКМ
		|ИЗ
		|	ВТ_НоменклатураПоШтукам		
		|";		
	КонецЕсли;	                     
	
	Запрос.Текст = Запрос.Текст + "
	|;
	|ВЫБРАТЬ
	|	Номенклатура 				КАК Номенклатура,
	|	МАКСИМУМ(Единицы.Ссылка) 	КАК Единица
	|ПОМЕСТИТЬ ВТ_Единицы
	|ИЗ
	|	ВТ_НоменклатураХКМ
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	Справочник.Единицы КАК Единицы
	|ПО
	|	ВТ_НоменклатураХКМ.Номенклатура = Единицы.Владелец
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|ВЫБРАТЬ
	|	ВТ_НоменклатураХКМ.*,
	|	ВТ_Единицы.Единица,	
	|	1 КАК Коэффициент
	|ИЗ
	|	ВТ_НоменклатураХКМ
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_Единицы
	|ПО
	|	ВТ_НоменклатураХКМ.Номенклатура = ВТ_Единицы.Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_НоменклатураХКМ.Номенклатура.Наименование	
	|";	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Товары.Очистить();
	
	Пока Выборка.Следующий() Цикл		
		СтрокаТЧ = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
	КонецЦикла;

КонецФункции // ЗаполнитьТовары()

Функция лМожноЗаписатьДокумент()
	Результат = Новый Структура("Успешно,Ошибки", Истина, Новый Массив);
	
	Если ЭтоНовый() Тогда
		мКодУзлаСоздания = КодУзлаСоздания;
	Иначе 
		мКодУзлаСоздания = ПолучитьРеквизитШапки(Ссылка, "КодУзлаСоздания");
	КонецЕсли;		
		
	Если ОбменДанными.Загрузка Тогда
		УзелОтправитель = ОбменДанными.Отправитель;
		Если ЗначениеЗаполнено(УзелОтправитель) Тогда
			Если УзелОтправитель.Код <> мКодУзлаСоздания Тогда
				Если УзелОтправитель.Код = "CO_FR" Тогда
				Иначе					
					Результат.Успешно = Ложь;							
					Результат.Ошибки.Добавить("Нельзя перезаписывать ХКМ созданный в другом узле ! "+Ссылка+" создан: "+мКодУзлаСоздания);
				КонецЕсли;
			ИначеЕсли мКодУзлаСоздания = Маркировка_ПИ.ЭтотУзел_Код() Тогда
				Результат.Успешно = Ложь;							
				Результат.Ошибки.Добавить("Можно загружать только ХКМ созданные в других узлах ! "+ЭтотОбъект+" узел отправитель: "+УзелОтправитель.Код+", код узла создания: "+мКодУзлаСоздания);
			КонецЕсли; 			 
		КонецЕсли;
	Иначе
		Если НЕ ЭтоНовый() Тогда
			Если мКодУзлаСоздания<>Маркировка_ПИ.ЭтотУзел_Код() И Модифицированность() Тогда
				Результат.Успешно = Ложь;
				Результат.Ошибки.Добавить("Нельзя изменять ХКМ созданный в другом узле ! "+Ссылка+" создан: "+мКодУзлаСоздания);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ПараметрыСеанса.ОтключитьКонтрольДЗР Тогда 
			//Валетов + 17,07,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5947
		  //Если Дата <= КонецДня(ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()) Тогда
		  Если Дата <= ОбщегоНазначения_ПИ.ПолучитьДатуЗапретаРедактирования_ПИ(ЭтотОбъект.Метаданные().Имя) Тогда 
			//Валетов -
			  Результат.Успешно = Ложь;
			  Результат.Ошибки.Добавить("Нарушение ДЗР !");
		  КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()

Функция ПолучитьВыборкуВложенныхКодов()	
	Запрос = Новый Запрос;
	Запрос.Текст = " 	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ       
	|	ШтрихкодУпаковки
	|ИЗ	
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И (
	|		ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка) 
	//++Данилова Е.В. 16.12.2025  MARK-3378
	//|		ИЛИ ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)	
	//--Данилова Е.В. 16.12.2025
	|	)
	|";
	Запрос.УстановитьПараметр("ДокСсылка", Ссылка);
	
	мШтрихКоды = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	
	тШК = Новый ТаблицаЗначений;
	тШК.Колонки.Добавить("ШтрихКодУпаковки", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));

	Для Каждого ШтрихКодУпаковки Из Документы.МаркировкаТоваровИСМП.ПолучитьВложенныеКоды(мШтрихКоды) Цикл
		СтрокаТ = тШК.Добавить();
		СтрокаТ.ШтрихкодУпаковки = ШтрихкодУпаковки;
	КонецЦикла;  
	
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ШК ИЗ &тШК КАК тШК
	|;                                        
	|ВЫБРАТЬ РАЗЛИЧНЫЕ       
	|	ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ДанныеТЧ
	|ИЗ	
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|ИНДЕКСИРОВАТЬ ПО
	|	ШтрихкодУпаковки
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ШК.ШтрихКодУпаковки						КАК ШтрихКодУпаковки,
	|	ВТ_ШК.ШтрихКодУпаковки.ТипШК 				КАК ТипШК,
	//+++Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
	|	ВТ_ШК.ШтрихКодУпаковки.СпособВводаВОборот 	КАК СпособВводаВОборот,
	//---Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок
	//+++Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	|	ВТ_ШК.ШтрихКодУпаковки.ТипУпаковки 			КАК ТипУпаковки,                            
	//--Чирков 29.09.2025 выравнивание движений по статусам в регистрах штук и коробок
	|	ВЫБОР 
	|		КОГДА ВТ_ШК.ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар) 
	|			ТОГДА ВТ_ШК.ШтрихкодУпаковки.Владелец
	|		КОГДА ВТ_ШК.ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор) 
	|			ТОГДА ВТ_ШК.ШтрихкодУпаковки.Владелец
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)	
	|	КОНЕЦ							КАК Номенклатура	
	|ИЗ
	|	ВТ_ШК              
	//Из-за буйных фантазий Крохина и Нечаевой - нужно проверять не напихали-ли какого-нибудь мусора в ТЧ
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	ВТ_ДанныеТЧ
	|ПО            
	|	ВТ_ДанныеТЧ.ШтрихКодУпаковки = ВТ_ШК.ШтрихКодУпаковки
	|ГДЕ
	|	ВТ_ДанныеТЧ.ШтрихКодУпаковки ЕСТЬ NULL 
	|";	
	
	Запрос.УстановитьПараметр("тШК", тШК);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьВыборкуВложенныхКодов()

Функция ЭтоСкладКарантина(Склад)
	Если ЗначениеЗаполнено(Склад) Тогда
		Результат = ПолучитьРеквизитШапки(Склад, "КарантинЧЗ", "Справочник");
	Иначе
		Результат = Ложь;
	КонецЕсли;
	Возврат Результат;
КонецФункции //ЭтоСкладКарантина(Склад)

Функция ЗаполнитьОтправителяПолучателя() Экспорт
	рПолучения = Документы.ХранилищеКодовМаркировки.ОпределитьОтправителяПолучателя(ДокОснование);
	
	Отправитель = рПолучения.Отправитель;
	Получатель	= рПолучения.Получатель;
КонецФункции //ЗаполнитьОтправителяПолучателя()

Функция РасформироватьКоробки(Местонахождение)
	//+++Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
	СтатусКМ = Перечисления.СтатусыКодовМаркировкиФакт.Выбыл;
	
	Для Каждого СтрокаШК Из ПолучитьКодыКоробок() Цикл
		Движение = Движения.СтатусыКМ_Факт.Добавить();		
			
		Движение.Период 			= Дата;
			
		Движение.ШтрихКодУпаковки	= СтрокаШК.ШтрихкодКоробки;				
			
		Движение.Статус				= СтатусКМ;			
		Движение.ТипШК				= СтрокаШК.ТипШК;
		Движение.Местонахождение	= Местонахождение;			
		Движение.ВПути				= Ложь;
		
		Если СтрокаШК.ТипШК <> Перечисления.ТипыШтрихКодов.Штука Тогда
			Движение_Кор = Движения.СтатусыКМ_Факт_А.Добавить();
			ЗаполнитьЗначенияСвойств(Движение_Кор, Движение);
			
			Движение_Кор.СпособВводаВОборот = СтрокаШК.СпособВводаВОборот;
			//+++Чирков 01.12.2025 ТипУпаковки - убираем
			//Движение_Кор.ТипУпаковки 		= СтрокаШК.ТипУпаковки;
			//---Чирков 01.12.2025
		КонецЕсли;
	КонецЦикла;
	//---Чирков 21.08.2025 выравнивание движений по статусам в регистрах штук и коробок	
КонецФункции //РасформироватьКоробки()
 
Функция ПолучитьКодыКоробок()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ВложенныеШтрихкоды.Ссылка 						КАК ШтрихкодКоробки,
	|	ВложенныеШтрихкоды.Ссылка.ТипШК 				КАК ТипШК,
	|	ВложенныеШтрихкоды.Ссылка.СпособВводаВОборот	КАК СпособВводаВОборот,
	|	ВложенныеШтрихкоды.Ссылка.ТипУпаковки			КАК ТипУпаковки	
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ШК_ХКМ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ВложенныеШтрихкоды   	
	|ПО 
	|	ШК_ХКМ.ШтрихкодУпаковки = ВложенныеШтрихкоды.Штрихкод	                        
	//+++Чирков 13.01.2026 - задача MARK-3417 - исключить наборы
	|	И ВложенныеШтрихкоды.Ссылка.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	//---Чирков 13.01.2026 - задача MARK-3417 - исключить наборы
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.СтатусыКМ_Факт КАК Статусы
    |ПО 
	|	ВложенныеШтрихкоды.Ссылка = Статусы.ШтрихКодУпаковки
	|	И Статусы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Выбыл)	
	//+++Чирков 29.01.2026 - коробка выбывает 1 раз а коды из нее могут быть в нескольких ХКМ - если выбыла в другом документе - то этого достаточно
	//|	И Статусы.Период < &МоментВремени
	|	И Статусы.Регистратор <> &Ссылка
	//---Чирков 29.01.2026
	|ГДЕ
	|	ШК_ХКМ.Ссылка = &Ссылка	
	|	И Статусы.Статус ЕСТЬ NULL
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодКоробки
	|";
	
	Запрос.УстановитьПараметр("МоментВремени", 	Дата);	
	Запрос.УстановитьПараметр("Ссылка", 		Ссылка);	
	
	Возврат Запрос.Выполнить().Выгрузить();	
КонецФункции //ПолучитьКодыКоробок()