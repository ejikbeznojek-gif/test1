Функция ПроходыНочнойСмены(Проходы1,Проходы2) 
	//Пытаемся отсечь проходы следующей ночной смены
	ПроходыДоКонцаСмены = Новый Массив;  
	ИндексЭлемента =-1;
	МассивПроходов = РазложитьСтрокуВМассивПодстрок1(Проходы2,Символы.ПС);
	Для каждого ЭлементМассива Из МассивПроходов Цикл
		ИндексЭлемента =ИндексЭлемента + 1;
		ИндексСледующегоЭлемента =ИндексЭлемента + 1;
		ВремяПрохода = СтрокаВоВремя(ЭлементМассива);    
		ВремяПрохода = ВремяПрохода+86400;
		ПроходыДоКонцаСмены.Добавить(ЭлементМассива);
		Если НЕ ИндексСледующегоЭлемента= МассивПроходов.Количество() Тогда
			ВремяСледующегоПрохода = СтрокаВоВремя(МассивПроходов[ИндексСледующегоЭлемента]);	  
			Если ВремяСледующегоПрохода - ВремяПрохода > 8*3600 Тогда
				Прервать;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	//Пытаемся добавить проходы ночной смены до 00 часов
	МассивПроходов = РазложитьСтрокуВМассивПодстрок1(Проходы1,Символы.ПС);              
	ИндексПоследнего = МассивПроходов.ВГраница();
	
	Для Индекс = -ИндексПоследнего По 0 Цикл
		Значение = МассивПроходов[-Индекс];
		
		Время = СтрокаВоВремя(Значение);
