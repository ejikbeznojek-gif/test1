		// 		СтруктураПрисутствие = ЧислоВоВремя(ТекущиеДанные.Выход - ТекущиеДанные.Вход);
		Если (ТипСмены = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена или  ТипСмены = Перечисления.СостояниеТабеля.НочнаяСмена) и (ТекущиеДанные.Выход - ТекущиеДанные.Вход)<0 Тогда
			СтруктураПрисутствие = ЧислоВоВремя(86400+(ТекущиеДанные.Выход - ТекущиеДанные.Вход));	
		иначе    
			СтруктураПрисутствие = ЧислоВоВремя(ТекущиеДанные.Выход - ТекущиеДанные.Вход);
		КонецЕсли; 
		// Кухарь А.Ю.  29.08.2025 конец
		
		ТекущиеДанные.Присутствие = Дата(1,1,1,СтруктураПрисутствие.Часы, СтруктураПрисутствие.Минуты,0);
		Если ТекущиеДанные.Выход > ВремяНачало Тогда
			СтруктураОтработано = ЧислоВоВремя(ТекущиеДанные.Выход - Макс(ТекущиеДанные.Вход,ВремяНачало));
			ТекущиеДанные.Отработано = Дата(1,1,1,СтруктураОтработано.Часы, СтруктураОтработано.Минуты,0);
		КонецЕсли;
		Если НЕ тзПроходы.Индекс(ТекущиеДанные) = тзПроходы.Количество() - 1 И ТекущиеДанные.Выход<ВремяОкончание И ТекущиеДанные.Выход>ВремяНачало И НЕ тзПроходы[тзПроходы.Индекс(ТекущиеДанные)+1].Вход = Дата(1,1,1) Тогда
			СтруктураОтсутствие = ЧислоВоВремя(тзПроходы[тзПроходы.Индекс(ТекущиеДанные)+1].Вход - ТекущиеДанные.Выход);  
			ТекущиеДанные.Отсутствие = Дата(1,1,1,СтруктураОтсутствие.Часы, СтруктураОтсутствие.Минуты,0);
		Иначе
			ТекущиеДанные.Отсутствие = Дата(1,1,1);
		КонецЕсли;
		Если ТекущиеДанные.Выход > ВремяОкончание Тогда
			СтруктураПереработка = ЧислоВоВремя(ТекущиеДанные.Выход - Макс(ТекущиеДанные.Вход,ВремяОкончание));	
			ТекущиеДанные.Переработка = Дата(1,1,1,СтруктураПереработка.Часы, СтруктураПереработка.Минуты,0);	
			ТекущиеДанные.Отработано = ТекущиеДанные.Отработано - (Дата(1,1,1,СтруктураПереработка.Часы, СтруктураПереработка.Минуты,0)-Дата(1,1,1));	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
//&НаСервере
Процедура ПересчитатьИтоги()               
	Если тзПроходы.Количество() = 0 Тогда
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыВход.ТекстПодвала = "";  
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыВыход.ТекстПодвала = "";  
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыПрисутствие.ТекстПодвала = "";  
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыОтсутствие.ТекстПодвала = "";  
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыОтработано.ТекстПодвала = "";       
		Отработано = 0;       
		Переработка = Дата(1,1,1);
		ОтработанноеВремя = Дата(1,1,1);
	Иначе		
		Если НЕ тзПроходы[0].Вход = Дата(1,1,1) Тогда
			Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыВход.ТекстПодвала = Формат(тзПроходы[0].Вход,"ДФ=Ч:мм");  
		КонецЕсли;
		Если НЕ тзПроходы[тзПроходы.Количество()-1].Выход = Дата(1,1,1) Тогда
			Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыВыход.ТекстПодвала = Формат(тзПроходы[тзПроходы.Количество()-1].Выход,"ДФ=Ч:мм");  
		КонецЕсли;
		Переработка = Дата(1,1,1);
		Для Индекс = 0 По  тзПроходы.Количество()-1 Цикл     
			тзПроходы[Индекс].Номер = Индекс + 1;	
			ПересчитатьСтроку(тзПроходы[Индекс]);
			Переработка = Переработка + (тзПроходы[Индекс].Переработка - Дата(1,1,1)) ;
			
			Если Индекс = 0 Тогда
				Отсутствие = тзПроходы[Индекс].Отсутствие;
				ПрисутствиеИтог = тзПроходы[Индекс].Присутствие;
				ОтработаноИтог = тзПроходы[Индекс].Отработано;
			Иначе
				Отсутствие = Отсутствие + (тзПроходы[Индекс].Отсутствие - Дата(1,1,1));
				ПрисутствиеИтог = ПрисутствиеИтог + (тзПроходы[Индекс].Присутствие - Дата(1,1,1));
				ОтработаноИтог = ОтработаноИтог + (тзПроходы[Индекс].Отработано - Дата(1,1,1));
			КонецЕсли;
		КонецЦикла;
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыПрисутствие.ТекстПодвала = Формат(ПрисутствиеИтог,"ДФ=Ч:мм");  
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыОтсутствие.ТекстПодвала = Формат(Отсутствие,"ДФ=Ч:мм");  
		Если Вездеход Тогда
			Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыОтработано.ТекстПодвала = Формат(тзПроходы[тзПроходы.Количество()-1].Выход-(тзПроходы[0].Вход-Дата(1,1,1)),"ДФ=Ч:мм");  
		Иначе		
			Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыОтработано.ТекстПодвала = Формат(?(Отсутствие>Дата(1,1,1,1,0,0),ОтработаноИтог,ОтработаноИтог+(Отсутствие-Дата(1,1,1))-3600),"ДФ=Ч:мм");  
		КонецЕсли;
		Элементы.тзПроходы.ПодчиненныеЭлементы.тзПроходыПереработка.ТекстПодвала = Формат(Переработка,"ДФ=Ч:мм");  
	КонецЕсли;
	Строка = тзИтоги[0];
	ПереработкаЧас = Час(Переработка);
	ПереработкаМинуты = Минута(Переработка);
	Если ПереработкаМинуты>40 Тогда
		ПереработкаЧас = ПереработкаЧас+1;	
	КонецЕсли;
	Если Смена = Перечисления.СостояниеТабеля.ВыходнойДень 
		ИЛИ Смена = Перечисления.СостояниеТабеля.Больничный 
		ИЛИ Смена = Перечисления.СостояниеТабеля.ОтпускОчередной 
		Тогда
		ВсегоПереработка = ?(Отсутствие>Дата(1,1,1,1,0,0),ОтработаноИтог,ОтработаноИтог+(Отсутствие-Дата(1,1,1))-3600) + (Переработка-Дата(1,1,1));
		ВсегоПереработкаЧас = Час(ВсегоПереработка);
		ВсегоПереработкаМинуты = Минута(ВсегоПереработка);
		Если ВсегоПереработкаМинуты>40 Тогда
			ВсегоПереработкаЧас = ВсегоПереработкаЧас+1;	
		КонецЕсли;
		
		Строка.Переработка = Дата(1,1,1,ВсегоПереработкаЧас,0,0); 
	Иначе		
		Строка.Переработка = Дата(1,1,1,ПереработкаЧас,0,0); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура тзПроходыПослеУдаления(Элемент)
	ПересчитатьИтоги();
КонецПроцедуры

&НаКлиенте
Процедура тзИтогиСменаПриИзменении(Элемент)   
	Если Элементы.тзИтоги.ТекущиеДанные.Заголовок = "СКУД" Тогда
		Если Элементы.тзИтоги.ТекущиеДанные.Смена = Перечисления.СостояниеТабеля.РабочийДень1 Тогда
			Элементы.ГруппаПроходы2.Видимость = Ложь;                    
			ТипСмены = Перечисления.СостояниеТабеля.РабочийДень1;
		ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Смена = Перечисления.СостояниеТабеля.РабочийДень2 Тогда
			Элементы.ГруппаПроходы2.Видимость = Ложь;                    
			ТипСмены = Перечисления.СостояниеТабеля.РабочийДень2;
		ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Смена = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена Тогда		     
			Элементы.ГруппаПроходы2.Видимость = Истина;
			ТипСмены = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена; 
			// Кухарь А.Ю. 02.09.2025 начало
			// Пустая задача
		ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Смена = Перечисления.СостояниеТабеля.ДневнаяСмена Тогда		     
			Элементы.ГруппаПроходы2.Видимость = Ложь;                    
			ТипСмены = Перечисления.СостояниеТабеля.ДневнаяСмена;		
		ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Смена = Перечисления.СостояниеТабеля.НочнаяСмена Тогда		     
			Элементы.ГруппаПроходы2.Видимость = Ложь;                    
			ТипСмены = Перечисления.СостояниеТабеля.ДневнаяСмена;
			// Кухарь А.Ю. 02.09.2025 конец
			
		ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Смена.Пустая() Тогда	
			ТипСмены = Перечисления.СостояниеТабеля.ПустаяСсылка();
			Предупреждение("Выберите смену СКУД");
			Возврат;
		КонецЕсли;    
	ИначеЕсли Элементы.тзИтоги.ТекущиеДанные.Заголовок = "Табель" Тогда  
		Смена = Элементы.тзИтоги.ТекущиеДанные.Смена;
	КонецЕсли;
	ПересчитатьИтоги();
КонецПроцедуры

