Функция МассивВСтроку(Массив) 
	МассивСтрокой ="";
	Индекс = 0;
	Для каждого ЭлементМассива Из Массив Цикл
		Индекс = Индекс+1;
		Если Индекс = Массив.Количество() Тогда
			МассивСтрокой = МассивСтрокой + ЭлементМассива;	
		Иначе		
			МассивСтрокой = МассивСтрокой + ЭлементМассива + Символы.ПС;	
		КонецЕсли;
	КонецЦикла;
	Возврат МассивСтрокой;
КонецФункции

