&НаСервереБезКонтекста
Функция СтрокаВоВремя(Строка) 
	
	СтрВремя = СтрЗаменить(СтрЗаменить(Строка," вход","")," выход","");
	МассивВремя = РазложитьСтрокуВМассивПодстрок1(СтрВремя,":");
	ВремяЧас = Число(МассивВремя[0]);
	ВремяМин = Число(МассивВремя[1]);
	Время = Дата(1,1,1,ВремяЧас,ВремяМин,0);
	
	Возврат Время;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЧислоВоВремя(Знач КоличествоСекунд)
	
	Перем Часы, Минуты, Секунды;
	
	//получаем часы
	Часы = Цел(КоличествоСекунд / 3600);
	//считаем остаток
	КоличествоСекунд = КоличествоСекунд % 3600;
	//получаем минуты
	Минуты = Цел(КоличествоСекунд / 60);//в минуте 60 сек
	//остались секунды
	Секунды = КоличествоСекунд % 60;
	
	Возврат Новый Структура("Часы, Минуты, Секунды", Часы, Минуты, Секунды);
	
КонецФункции

