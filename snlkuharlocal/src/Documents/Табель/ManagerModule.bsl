Процедура ПересчитатьДанныеВремениСтроки(ТекущиеДанные) экспорт     
	ТипСмены = ТекущиеДанные.ТипСмены;
	
	если не ЗначениеЗаполнено(ТипСмены) тогда
		ТипСмены = ТекущиеДанные.Значение;
	КонецЕсли;
	
	Проходы1 = СтрЗаменить(ТекущиеДанные.ПроходыСКУД1,"¶",Символы.ПС); 
	Проходы2 = СтрЗаменить(ТекущиеДанные.ПроходыСКУД2,"¶",Символы.ПС);       	
	
	Если ТипСмены = Перечисления.СостояниеТабеля.НочнаяСмена или  ТипСмены = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена Тогда     
		МассивПроходов = ПроходыНочнойСмены(Проходы1,Проходы2);
	Иначе	
		МассивПроходов = РазложитьСтрокуВМассивПодстрок1(Проходы1, Символы.ПС);
	КонецЕсли; 
	
	Вездеход = ПолучитьРеквизитШапки(ТекущиеДанные.Сотрудник,"ПропускВездеход","Справочник");
	
	
	СтруктураПроходов = СтрокаПроходыВСтруктуру(МассивПроходов,ТипСмены);
	тзПроходы =СтруктураПроходов.тз;  
	
	если тзПроходы.количество() = 0 тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Выход = СтруктураПроходов.ВремяВыхода;
	ТекущиеДанные.Вход = СтруктураПроходов.ВремяВхода;

	
	
	
		
	Если НЕ ТекущиеДанные.Вход = Дата(1,1,1) И НЕ ТекущиеДанные.Выход = Дата(1,1,1) Тогда        
		ЭтоБылВыходной = ложь;
		Если ТипСмены = Перечисления.СостояниеТабеля.ДневнаяСмена Тогда
			ВремяНачало = Дата(1,1,1,8,0,0);	
			ВремяОкончание = Дата(1,1,1,20,0,0);	
		ИначеЕсли ТипСмены = Перечисления.СостояниеТабеля.НочнаяСмена Тогда
			ВремяНачало = Дата(1,1,1,20,0,0);	
			ВремяОкончание = Дата(1,1,2,8,0,0);    
		ИначеЕсли ТипСмены = Перечисления.СостояниеТабеля.РабочийДень1 Тогда
			ВремяНачало = Дата(1,1,1,8,0,0);	
			ВремяОкончание = Дата(1,1,1,17,0,0);  
		ИначеЕсли ТипСмены = Перечисления.СостояниеТабеля.РабочийДень2 Тогда
			ВремяНачало = Дата(1,1,1,13,0,0);	
			ВремяОкончание = Дата(1,1,1,22,0,0);  
		ИначеЕсли ТипСмены = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена Тогда
			ВремяНачало = Дата(1,1,1,20,0,0);	
			ВремяОкончание = Дата(1,1,2,8,0,0);  
		иначе     
			ЭтоБылВыходной = Истина;
			ВремяНачало = ПустаяДата();	
			ВремяОкончание = ПустаяДата();  
		КонецЕсли;
		
  
		Переработка = Дата(1,1,1);
		Для Индекс = 0 По  тзПроходы.Количество()-1 Цикл      
			тзПроходы[Индекс].Номер = Индекс + 1;	
			ПересчитатьСтроку(тзПроходы[Индекс],тзПроходы,ТипСмены);

			Переработка = Переработка + (тзПроходы[Индекс].Переработка - Дата(1,1,1)) ;
			
			Если Индекс = 0 Тогда
				Отсутствие = тзПроходы[Индекс].Отсутствие;
				ПрисутствиеИтог = тзПроходы[Индекс].Присутствие;
				ОтработаноИтог = тзПроходы[Индекс].Отработано;
			Иначе
				Отсутствие = Отсутствие + (тзПроходы[Индекс].Отсутствие - Дата(1,1,1));
				ПрисутствиеИтог = ПрисутствиеИтог + (тзПроходы[Индекс].Присутствие - Дата(1,1,1));
				ОтработаноИтог = ОтработаноИтог + (тзПроходы[Индекс].Отработано - Дата(1,1,1));
			КонецЕсли;
		КонецЦикла;	
		Если Вездеход Тогда
			ТекущиеДанные.ОтработанноеВремя = тзПроходы[тзПроходы.Количество()-1].Выход-(тзПроходы[0].Вход-Дата(1,1,1));  
		Иначе		
			ТекущиеДанные.ОтработанноеВремя = ?(Отсутствие>Дата(1,1,1,1,0,0),ОтработаноИтог,ОтработаноИтог+(Отсутствие-Дата(1,1,1))-3600);  
		КонецЕсли;
		

		ПереработкаЧас = Час(Переработка);
		ПереработкаМинуты = Минута(Переработка);
		Если ПереработкаМинуты>40 Тогда
			ПереработкаЧас = ПереработкаЧас+1;	
		КонецЕсли;
		Если ТипСмены = Перечисления.СостояниеТабеля.ВыходнойДень 
			ИЛИ ТипСмены = Перечисления.СостояниеТабеля.Больничный 
			ИЛИ ТипСмены = Перечисления.СостояниеТабеля.ОтпускОчередной 
			Тогда
			ВсегоПереработка = ?(Отсутствие>Дата(1,1,1,1,0,0),ОтработаноИтог,ОтработаноИтог+(Отсутствие-Дата(1,1,1))-3600) + (Переработка-Дата(1,1,1));
			ВсегоПереработкаЧас = Час(ВсегоПереработка);
			ВсегоПереработкаМинуты = Минута(ВсегоПереработка);
			Если ВсегоПереработкаМинуты>40 Тогда
				ВсегоПереработкаЧас = ВсегоПереработкаЧас+1;	
			КонецЕсли;
			
			Переработка = Дата(1,1,1,ВсегоПереработкаЧас,0,0); 
		Иначе		
			Переработка = Дата(1,1,1,ПереработкаЧас,0,0); 
		КонецЕсли;
		
		
		//////////////////////////////////////////////////////
		//
		//Если (ТипСмены = Перечисления.СостояниеТабеля.РабочийДеньНочнаяСмена или  ТипСмены = Перечисления.СостояниеТабеля.НочнаяСмена) и (ТекущиеДанные.Выход - ТекущиеДанные.Вход)<0 Тогда
		//	СтруктураПрисутствие = ЧислоВоВремя(86400+(ТекущиеДанные.Выход - ТекущиеДанные.Вход));	
		//иначе    
		//	//СтруктураПрисутствие = ЧислоВоВремя(ТекущиеДанные.Выход - ТекущиеДанные.Вход);    
		//	СтруктураПрисутствие = ЧислоВоВремя(СекундОтработано);
		//КонецЕсли; 
		//
		//Присутствие = Дата(1,1,1,СтруктураПрисутствие.Часы, СтруктураПрисутствие.Минуты,0); 
		//
		//Отсутствие = СекундОтсутствия;
		//Отсутствие = Макс(0,Отсутствие - 3600);  
		//ЧасыОтсутствие = Отсутствие/3600;
		//если ЧасыОтсутствие - Цел(ЧасыОтсутствие)>0.6666 тогда 
		//	ЧасыОтсутствие = Цел(ЧасыОтсутствие)+1;
		//иначе			
		//	ЧасыОтсутствие = Цел(ЧасыОтсутствие);			
		//КонецЕсли;        
		//Отсутствие = ЧасыОтсутствие*3600;
		
		//Если ТекущиеДанные.Выход > ВремяНачало Тогда
			//СтруктураОтработано = ЧислоВоВремя(ТекущиеДанные.Выход - Макс(ТекущиеДанные.Вход,ВремяНачало));  
			//если Вездеход тогда    
			//	СтруктураОтработано = ЧислоВоВремя(СтруктураПроходов.Отработано-3600);
			//иначе    
			//	СтруктураОтработано = ЧислоВоВремя(СтруктураПроходов.Отработано - Отсутствие);  
			//КонецЕсли;       
			//
			//ТекущиеДанные.ОтработанноеВремя = Дата(1,1,1,СтруктураОтработано.Часы, СтруктураОтработано.Минуты,0);   
			//ТекущиеДанные.ОтработанноеВремя = Отработано;

		//КонецЕсли;     
		
		
		//Если НЕ тзПроходы.Индекс(ТекущиеДанные) = тзПроходы.Количество() - 1 И ТекущиеДанные.Выход<ВремяОкончание И ТекущиеДанные.Выход>ВремяНачало И НЕ тзПроходы[тзПроходы.Индекс(ТекущиеДанные)+1].Вход = Дата(1,1,1) Тогда
		//	//СтруктураОтсутствие = ЧислоВоВремя(тзПроходы[тзПроходы.Индекс(ТекущиеДанные)+1].Вход - ТекущиеДанные.Выход);    
		//	//СтруктураОтсутствие = ЧислоВоВремя(ТекущиеДанные.Выход - тзПроходы[тзПроходы.Индекс(ТекущиеДанные)+1].Вход );   
		//	СтруктураОтсутствие = ЧислоВоВремя(СтруктураПроходов.Отсутствие);
		//	Отсутствие = Дата(1,1,1,СтруктураОтсутствие.Часы, СтруктураОтсутствие.Минуты,0);
		//Иначе
		//	Отсутствие = Дата(1,1,1);
		//КонецЕсли;     
		
		
		//Если ТекущиеДанные.Выход > ВремяОкончание Тогда
