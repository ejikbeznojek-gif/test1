Функция СпособВводаВОборотДляСпайкиПоВидуКомплекта(ПараметрыДокумента) Экспорт     
	//Валетов + 26,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3546
	//Если НЕ ПараметрыДокумента.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда
	Если ПараметрыДокумента.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект 
		ИЛИ ПараметрыДокумента.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда  
	ИначеЕсли ПараметрыДокумента.ВидКомплекта = Перечисления.ВидыКомплектов.Товар
		И ТипЗнч(ПараметрыДокумента.ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") 
		И ПараметрыДокумента.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Производство Тогда
		Возврат Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка;
	Иначе
	//Валетов -	
		Возврат ПараметрыДокумента.СпособВводаВОборот; 	
	
	КонецЕсли;
	
	
	Запрос = Новый Запрос;
	запрос.Текст = "ВЫБРАТЬ
	               |	РеквизитыСправочников.Справочник КАК Справочник,
	               |	РеквизитыСправочников.ИмяРеквизита КАК ИмяРеквизита,
	               |	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	               |ИЗ
	               |	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	               |ГДЕ
	               |	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	               |	И РеквизитыСправочников.ЗначениеРеквизита = &ЗначениеРеквизита
	               |	И РеквизитыСправочников.Справочник = &Организация";
	Запрос.УстановитьПараметр("ЗначениеРеквизита",истина);
	Запрос.УстановитьПараметр("ИмяРеквизита","Организация_импорт_спаек");
	Запрос.УстановитьПараметр("Организация",ПараметрыДокумента.Организация); 
	
	РезультатЗапроса = Запрос.Выполнить(); 
	
	ОрганизацияИмпорт = НЕ РезультатЗапроса.Пустой();   
	
    ДокОснованиеИмпорт = ТипЗнч(ПараметрыДокумента.ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") 
	ИЛИ  ТипЗнч(ПараметрыДокумента.ДокументОснование) = Тип("ДокументСсылка.КонтрактСПроизводителем");
	
	Если ОрганизацияИмпорт 
		ИЛИ ДокОснованиеИмпорт Тогда
	
		Возврат Перечисления.СпособыВводаВОборотСУЗ.Импорт; 	
	Иначе 
		Возврат Перечисления.СпособыВводаВОборотСУЗ.Производство;
	КонецЕсли;
КонецФункции


