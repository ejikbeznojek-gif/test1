Функция ОбновитьКоличествоПолученныхКодов(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если НЕ (ЗначениеЗаполнено(ДокСсылка) И ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ")) Тогда 
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Возврат Результат;	
	КонецЕсли;
	//++Данилова Е.В. 03.04.2025 ASU-2175 
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//               |	СУММА(Сводный.КолЗаказано) КАК КолЗаказано,
	//               |	СУММА(Сводный.КолЗаписано) КАК КолЗаписано
	//               |ИЗ
	//               |	(ВЫБРАТЬ
	//               |		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.КоличествоДокумента КАК КолЗаказано,
	//               |		0 КАК КолЗаписано
	//               |	ИЗ
	//               |		Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	//               |	ГДЕ
	//               |		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка = &ДокСсылка
	//               |	
	//               |	ОБЪЕДИНИТЬ ВСЕ
	//               |	
	//               |	ВЫБРАТЬ
	//               |		СправНоменклатураКомплектующие.Количество * ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Количество,
	//               |		0
	//               |	ИЗ
	//               |		Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
	//               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправНоменклатура
	//               |			ПО (СправНоменклатура.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура)
	//               |				И (СправНоменклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	//               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК СправНоменклатураКомплектующие
	//               |			ПО (СправНоменклатура.Ссылка = СправНоменклатураКомплектующие.Ссылка)
	//               |	ГДЕ
	//               |		ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Ссылка = &ДокСсылка
	//               |	
	//               |	ОБЪЕДИНИТЬ ВСЕ
	//               |	
	//               |	ВЫБРАТЬ
	//               |		0,
	//               |		СУММА(1)
	//               |	ИЗ
	//               |		Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	//               |	ГДЕ
	//               |		ШтрихкодыУпаковокТоваров.ЗаказКМ = &ДокСсылка) КАК Сводный";
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СУММА(Сводный.КолЗаказано) КАК КолЗаказано,
	|	СУММА(Сводный.КолЗаписано) КАК КолЗаписано
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.КоличествоДокумента КАК КолЗаказано,
	|		0 КАК КолЗаписано
	|	ИЗ
	|		Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|	ГДЕ
	|		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка = &ДокСсылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		0,
	|		СУММА(1)
	|	ИЗ
	|		Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|	ГДЕ
	|		ШтрихкодыУпаковокТоваров.ЗаказКМ = &ДокСсылка) КАК Сводный";

	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ПолученоКодов = Выборка.КолЗаписано;
		Если Выборка.КолЗаказано = ПолученоКодов Тогда
			рШапки = ПолучитьРеквизитыШапки(ДокСсылка, "Статус,ПолученоКодов,Проведен");
			Если рШапки.Статус <> Перечисления.СтатусыДокументовМаркировки.Обработан 
				ИЛИ рШапки.ПолученоКодов <> Выборка.КолЗаписано Тогда
				
				РежимЗаписи = ?(рШапки.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
				Реквизиты 	= Новый Структура("Статус,ПолученоКодов,ТекстОшибки", Перечисления.СтатусыДокументовМаркировки.Обработан, ПолученоКодов, "");
				
				УстановитьРеквизитыОбъекта(ДокСсылка, Реквизиты, РежимЗаписи);
				
				#ЕСЛИ Клиент ТОГДА
					ОповеститьОбИзменении(ДокСсылка);
				#КОНЕЦЕСЛИ
				
				//++Данилова Е.В. 30.01.2025
				ОбновлятьПолученоКомплектГН = ДокСсылка.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект
				ИЛИ (ЗначениеЗаполнено(ДокСсылка.ДокументОснование)
				И ТипЗнч(ДокСсылка.ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") 
				И ДокСсылка.ДокументОснование.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект); 
				//++Данилова Е.В. 03.06.2025 MARK-2355 
				ОбновлятьПолученоКомплектСпайка = КомплектСпайка_Импорт(ДокСсылка)
				ИЛИ (ЗначениеЗаполнено(ДокСсылка.ДокументОснование)
				И ТипЗнч(ДокСсылка.ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") 
				И КомплектСпайка_Импорт(ДокСсылка.ДокументОснование));
				//--Данилова Е.В. 03.06.2025
				//++Данилова Е.В. 29.05.2026 MARK-3615
				ОбновлятьПолученоСпайкиПеремарк = КомплектСпайка_ПоПеремаркировке(ДокСсылка) Или (ЗначениеЗаполнено(
					ДокСсылка.ДокументОснование) И ТипЗнч(ДокСсылка.ДокументОснование) = Тип(
					"ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") И КомплектСпайка_ПоПеремаркировке(ДокСсылка.ДокументОснование)); 
				//--Данилова Е.В. 29.05.2026 
				Если ОбновлятьПолученоКомплектГН 
					ИЛИ ОбновлятьПолученоКомплектСпайка 
					//++Данилова Е.В. 29.05.2026 MARK-3615
					ИЛИ ОбновлятьПолученоСпайкиПеремарк Тогда 					 					
//					ДокументГН = ?(ДокСсылка.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект 
//					ИЛИ КомплектСпайка_Импорт(ДокСсылка),ДокСсылка,ДокСсылка.ДокументОснование); //MARK-2355
					ДокументГН = ?(ДокСсылка.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект
						Или КомплектСпайка_Импорт(ДокСсылка) Или КомплектСпайка_ПоПеремаркировке(ДокСсылка), ДокСсылка,
						ДокСсылка.ДокументОснование); 			
					//--Данилова Е.В. 29.05.2026
					ОбновитьПолученоКодовКомплектующихПоЗаказуКМГН(ДокументГН);//при записи формируем операции маркировки  
					
					ОперацияМаркировкиСтруктураДанных = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОперацияМаркировкиПоГотовымНаборам(ДокументГН); 
					Если  ОперацияМаркировкиСтруктураДанных <> Неопределено Тогда
						Если ЗначениеЗаполнено(ОперацияМаркировкиСтруктураДанных.ДокВводВОборот) Тогда
							
							ТекстСообщения = "Оформлен/изменен документ ввода в оборот комплектующих: " + ОперацияМаркировкиСтруктураДанных.ДокВводВОборот; 
							Результат.Сообщения.Добавить(ТекстСообщения);
							
						КонецЕсли;
						
						
						Если ЗначениеЗаполнено(ОперацияМаркировкиСтруктураДанных.ДокФормированиеНабора) Тогда
							
							ТекстСообщения = "Оформлен/изменен документ формирования набора: " + ОперацияМаркировкиСтруктураДанных.ДокФормированиеНабора; 
							Результат.Сообщения.Добавить(ТекстСообщения);
							
							
						КонецЕсли;
						
					КонецЕсли;
					
					
				КонецЕсли;
				//--Данилова Е.В. 30.01.2025

			КонецЕсли; 
			ТекстСообщения = СтрШаблон("По документу: %1 загружены все коды маркировки ( %2 шт. ).", ДокСсылка, ПолученоКодов);
			Результат.Сообщения.Добавить(ТекстСообщения);
			Результат.Успешно = Истина;
			
		Иначе			
			УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("ПолученоКодов", ПолученоКодов));			
			
			ТекстСообщения = СтрШаблон("По документу: %1 загружено %2 из %3 кодов маркировки.", ДокСсылка, ПолученоКодов, Выборка.КолЗаказано);
			Результат.Сообщения.Добавить(ТекстСообщения);
			Результат.Успешно = Истина;
		КонецЕсли;
	КонецЕсли;                                                                 
	
	Возврат Результат;
КонецФункции //ОбновитьКоличествоПолученныхКодов(ДокСсылка) Экспорт

Функция ОперацияМаркировкиПоГотовымНаборам(Знач ЗаказКМ, БезПроверкиСтатуса = Ложь)  Экспорт
	
	Если БезПроверкиСтатуса 
		//++Данилова Е.В. 26.03.2025
		//ИЛИ (ЗаказКМ.ВидНоменклатурыЧЗВДокументе = Перечисления.ВидыНоменклатурыЧЗ.Набор
		ИЛИ ((ЗаказКМ.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект ИЛИ КомплектСпайка_Импорт(ЗаказКМ))
		//--Данилова Е.В. 26.03.2025
		И ЗаказКМ.статус = Перечисления.СтатусыДокументовМаркировки.Обработан)  Тогда
		
		 Запрос = Новый запрос;
		 Запрос.УстановитьПараметр("ДокументОснование",ЗаказКМ);
		 Запрос.Текст = 
		  "ВЫБРАТЬ РАЗЛИЧНЫЕ
		  |	ЕСТЬNULL(МаркировкаТоваровИСМПВводВОборот.Ссылка, ЗНАЧЕНИЕ(Документ.МаркировкаТоваровИСМП.ПустаяСсылка)) КАК ДокВводВОборот,
		  |	ЕСТЬNULL(МаркировкаТоваровИСМПФормированиеНабора.Ссылка, ЗНАЧЕНИЕ(Документ.МаркировкаТоваровИСМП.ПустаяСсылка)) КАК ДокФормированиеНабора
		  |ИЗ
		  |	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПВводВОборот
		  |		ПО МаркировкаТоваровИСМП.Ссылка = МаркировкаТоваровИСМПВводВОборот.Ссылка
		  |			И (МаркировкаТоваровИСМПВводВОборот.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВОборот)  
		  //Валетов + 17,03,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3577 Перенесу в Хранилище как Женя отдаст объект. Андрей, не затирай!  
		  |				ИЛИ МаркировкаТоваровИСМПВводВОборот.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Перемаркировка)) 
		  //Валетов -
		  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПФормированиеНабора
		  |		ПО МаркировкаТоваровИСМП.Ссылка = МаркировкаТоваровИСМПФормированиеНабора.Ссылка
		  |			И (МаркировкаТоваровИСМПФормированиеНабора.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ФормированиеНабора))
		  |ГДЕ
		  |	МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
		  |	И МаркировкаТоваровИСМП.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВОборот), ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ФормированиеНабора))
		  |	И НЕ МаркировкаТоваровИСМП.ПометкаУдаления"; 
		
		Выборка = Запрос.Выполнить().Выбрать();
		СтруктураДокументы = Новый Структура("ДокВводВОборот,ДокФормированиеНабора",неопределено,Неопределено); 
		Пока Выборка.Следующий() Цикл
			
			Если ЗначениеЗаполнено(Выборка.ДокВводВОборот) Тогда
				
				СтруктураДокументы.ДокВводВОборот = Выборка.ДокВводВОборот; 
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Выборка.ДокФормированиеНабора) Тогда
				
				СтруктураДокументы.ДокФормированиеНабора = Выборка.ДокФормированиеНабора; 
				
			КонецЕсли;		
			
		КонецЦикла;
		
		Возврат  СтруктураДокументы; 
	КонецЕсли;
	
	Возврат Неопределено; 

КонецФункции

Функция ЗагрузитьКодыИзЛогов(ДокСсылка, ПерезаписыватьКМ, АдресВозврата = Неопределено) Экспорт
	ЗаписатьВЛог("Отладка", "Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ЗагрузитьКодыИзЛогов", "Информация");
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Начало			= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ОбработкаАПИ 	= МаркировкаВС.СоздатьОбработкуАПИ();
	МассивИД 		= ОбработкаАПИ.ПолучитьМассивЗаписейЗагрузкиКМ(ДокСсылка);
	
	ИмяМетода   = "МаркировкаС.ЗагрузитьКодыИзТаблицы";
	ОтборФЗ 	= Новый Структура("Состояние,ИмяМетода", СостояниеФоновогоЗадания.Активно, ИмяМетода);
	
	ВсегоСтрок	= 0;
		
	Если МассивИД.Количество() > 0 Тогда		
		ТК 				= ОбработкаАПИ.ПрочитатьКодыИзЛогов(МассивИД);
		ВсегоСтрок 		= ТК.Количество();		
		РазмерПорции	= ОпределитьРазмерПорции(ВсегоСтрок);
		ВсегоПорций		= Цел(ВсегоСтрок/РазмерПорции)+?(ВсегоСтрок%РазмерПорции =0,0,1);
		НомерПорции		= 0;
		
		ТекПорция 		= ТК.СкопироватьКолонки();		
		
		мЗадания 			= Новый Массив;
		АдресаРезультатов   = Новый Соответствие;
		Для Каждого СтрокаТК Из ТК Цикл
			СтрокаПорции = ТекПорция.Добавить();		
			ЗаполнитьЗначенияСвойств(СтрокаПорции, СтрокаТК);
			
			Если ТекПорция.Количество() >= РазмерПорции ИЛИ ТК.Индекс(СтрокаТК) = (ВсегоСтрок - 1) Тогда
				СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
				Пока СписокФЗ.Количество() > 10 Цикл
					ФоновыеЗадания.ОжидатьЗавершенияВыполнения(СписокФЗ, 5);
					СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
				КонецЦикла;
				
				АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
				
				пЗадания = Новый Массив;
				пЗадания.Добавить(ТекПорция);
				пЗадания.Добавить(ПерезаписыватьКМ);
				пЗадания.Добавить(АдресРезультата);
				
				НомерПорции		= НомерПорции + 1;
				НаименованиеФЗ	= СтрШаблон("Загрузка КМ по заказу %1, порция %2 из %3. Размер порции: %4.", ДокСсылка, НомерПорции, ВсегоПорций, ТекПорция.Количество());
				ФЗ = ФоновыеЗадания.Выполнить(ИмяМетода, пЗадания, ""+ДокСсылка.УникальныйИдентификатор()+"_"+НомерПорции, НаименованиеФЗ);
				мЗадания.Добавить(ФЗ);
				
				АдресаРезультатов[ФЗ.УникальныйИдентификатор] = АдресРезультата;
				
				ТекПорция.Очистить();
			КонецЕсли; 
		КонецЦикла;
		
		Результаты = инт_ДлительныеОперации.ОжидатьЗавершенияЗаданий(мЗадания);
		Для Каждого ФЗ Из Результаты Цикл
			Если ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
				рЗагрузки = ПолучитьИзВременногоХранилища(АдресаРезультатов[ФЗ.УникальныйИдентификатор]);
				ТекстСообщения = СтрШаблон(ФЗ.Наименование + " Загружено %2 КМ.", ДокСсылка, рЗагрузки.ОбработаноОбъектов);
				ЗаписатьВЛог("Загрузка КМ", ТекстСообщения, "Информация");
			Иначе
				Если ФЗ.Состояние  = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
					ЗаписатьВЛог("Загрузка КМ", "Ошибка ФЗ: " + инт_ДлительныеОперации.ОписаниеОшибкиФЗ(ФЗ), "Ошибка");
				Иначе					
					ЗаписатьВЛог("Загрузка КМ", "Недопустимое состояние ФЗ: " + ФЗ.Состояние, "Ошибка");
				КонецЕсли;				
			КонецЕсли;			
		КонецЦикла; 
		
		ОбновитьКоличествоПолученныхКодов(ДокСсылка);
		
		Результат.Успешно = Истина;
	Иначе
		ТекстСообщения = СтрШаблон("Не обнаружено полученных кодов по документу: '%1' !", ДокСсылка);
		Результат.Ошибки.Добавить(ТекстСообщения);								
	КонецЕсли;
	
	Результат.ОбработаноОбъектов	= ВсегоСтрок;
	Результат.ВремяВыполнения 		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;

	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);			
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗагрузитьКодыИзЛогов(ДокСсылка, ПерезаписыватьКМ, АдресВозврата = Неопределено) Экспорт

Функция ОпределитьВидКомплекта(мНоменклатура) Экспорт
	Результат = Перечисления.ВидыКомплектов.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Родитель.ВидКомплекта КАК ВидКомплекта
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В (&мНоменклатура)
	|";
	
	Запрос.УстановитьПараметр("мНоменклатура", мНоменклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 1 И Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ВидКомплекта) Тогда
		Результат = Выборка.ВидКомплекта;	
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //ОпределитьВидКомплекта(мНоменклатура) Экспорт

Функция ОпределитьВидНоменклатурыЧЗ(ВидКомплекта) Экспорт
	ВидНоменклатурыЧЗВДокументе = Перечисления.ВидыНоменклатурыЧЗ.ПустаяСсылка();
	
	Если ВидКомплекта = Перечисления.ВидыКомплектов.Товар Тогда
		ВидНоменклатурыЧЗВДокументе = Перечисления.ВидыНоменклатурыЧЗ.Единица;
	ИначеЕсли ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
		ВидНоменклатурыЧЗВДокументе = Перечисления.ВидыНоменклатурыЧЗ.Набор;
	Иначе
		ВидНоменклатурыЧЗВДокументе = Перечисления.ВидыНоменклатурыЧЗ.Набор;
	КонецЕсли;
	
	Возврат ВидНоменклатурыЧЗВДокументе;
КонецФункции //ОпределитьВидКомплекта(ВидКомплекта) Экспорт 

Функция ОпределитьРазмерПорции(ВсегоСтрок, МаксЧислоПотоков = 5, МинРазмерПорции = 500) //В заказе макс. 50000 - грузим максимум в 5 потоков 	
	Потоков = 0;	
	РазмерПорции = 0;

	Если ВсегоСтрок = 0 Тогда
		Потоков = 0;
	ИначеЕсли ВсегоСтрок < МинРазмерПорции Тогда	
		Потоков = 1;	
	Иначе
		Потоков = Цел(ВсегоСтрок/МинРазмерПорции);
		Если ВсегоСтрок/(Потоков*МинРазмерПорции) > 1.3 Тогда
			Потоков = Потоков + 1;		
		КонецЕсли;	
	КонецЕсли;

	Потоков = Мин(МаксЧислоПотоков, Потоков);

	Если Потоков > 0 Тогда
		РазмерПорции = Цел(ВсегоСтрок/Потоков);
		Если Потоков*РазмерПорции < ВсегоСтрок Тогда
			РазмерПорции = РазмерПорции + 1;		
		КонецЕсли;	
	КонецЕсли;
	
	Возврат РазмерПорции;
КонецФункции //ОпределитьРазмерПорции()

