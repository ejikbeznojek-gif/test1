Процедура ЗаполнитьШтрихкодыУпаковокПоГотовымНаборамМКМ(ДокументМаркировки, ЗаказКМГН) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТКомплекты
	               |ИЗ
	               |	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	               |		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	               |ГДЕ
	               |	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка = &ЗаказНаЭмиссию
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	НоменклатураСпр.Ссылка КАК ГотовыйКомплект,
	               |	НоменклатураСпр.Номенклатура КАК Номенклатура,
	               |	НоменклатураСпр.Количество КАК Количество
	               |ПОМЕСТИТЬ ВТСоответствиеГККомплектующие
	               |ИЗ
	               |	Справочник.Номенклатура.Коплектующие КАК НоменклатураСпр
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомплекты КАК ВТКомплекты
	               |		ПО (ВТКомплекты.Номенклатура = НоменклатураСпр.Ссылка)
	               |ГДЕ
	               |	НЕ(НоменклатураСпр.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	               |				ИЛИ НоменклатураСпр.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихкодУпаковки,
	               |	ШтрихкодыУпаковокТоваров.Владелец КАК Номенклатура
	               |ПОМЕСТИТЬ ВТШтрихКодыПоКомплектующим
	               |ИЗ
	               |	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	               |ГДЕ
	               |	ШтрихкодыУпаковокТоваров.ЗаказКМ.ДокументОснование = &ЗаказНаЭмиссию
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихкодУпаковки,
	               |	ШтрихкодыУпаковокТоваров.Владелец КАК Номенклатура
	               |ПОМЕСТИТЬ ВТШтрихКодыПоКомплектам
	               |ИЗ
	               |	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	               |ГДЕ
	               |	ШтрихкодыУпаковокТоваров.ЗаказКМ = &ЗаказНаЭмиссию
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТСоответствиеГККомплектующие.ГотовыйКомплект КАК ГотовыйКомплект,
	               |	ВТСоответствиеГККомплектующие.Номенклатура КАК Номенклатура,
	               |	ВТШтрихКодыПоКомплектам.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	               |	ВТСоответствиеГККомплектующие.Количество КАК Количество
	               |ИЗ
	               |	ВТСоответствиеГККомплектующие КАК ВТСоответствиеГККомплектующие
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтрихКодыПоКомплектам КАК ВТШтрихКодыПоКомплектам
	               |		ПО (ВТШтрихКодыПоКомплектам.Номенклатура = ВТСоответствиеГККомплектующие.ГотовыйКомплект)
	               |ИТОГИ
	               |	МАКСИМУМ(Количество)
	               |ПО
	               |	ГотовыйКомплект,
	               |	ШтрихкодУпаковки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ВТСоответствиеГККомплектующие.Номенклатура КАК Номенклатура,
	               |	ВТШтрихКодыПоКомплектующим.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	               |ИЗ
	               |	ВТСоответствиеГККомплектующие КАК ВТСоответствиеГККомплектующие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТШтрихКодыПоКомплектующим КАК ВТШтрихКодыПоКомплектующим
	               |		ПО (ВТШтрихКодыПоКомплектующим.Номенклатура = ВТСоответствиеГККомплектующие.Номенклатура)";   
	               
	
	Запрос.УстановитьПараметр("ЗаказНаЭмиссию", ЗаказКМГН);
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 	
	
	ВыборкаКомплектыИтоги 		= ПакетЗапросов[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	//
	ТаблицаШККомплектующие = ПакетЗапросов[5].Выгрузить(); //                           Выбрать(); 
    ТаблицаШККомплектующие.Индексы.Добавить("Номенклатура");
		
	Пока ВыборкаКомплектыИтоги.Следующий() Цикл 
		
		ВыборкаШКУпаковки = ВыборкаКомплектыИтоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		
		Пока ВыборкаШКУпаковки.Следующий() Цикл   			 
			
			ВыборкаНоменклатураГК =  ВыборкаШКУпаковки.Выбрать(); 
			
			Пока ВыборкаНоменклатураГК.Следующий() Цикл 			
				
				Отбор = Новый Структура; 
				Отбор.Вставить("Номенклатура",ВыборкаНоменклатураГК.Номенклатура);
				//
				КоличествоНеобходимое = ВыборкаНоменклатураГК.количество;
				
				СтрокиШК = ТаблицаШККомплектующие.НайтиСтроки(Отбор);
				
				Для каждого СтрокаШК  Из СтрокиШК Цикл
					Если КоличествоНеобходимое = 0 Тогда
						
						Прервать; 	
						
					КонецЕсли;
					НоваяСтрокаТП = ДокументМаркировки.ШтрихкодыУпаковок.Добавить(); // ТаблицаПодготовка.Добавить();
					НоваяСтрокаТП.ШтрихкодНабора 	= ВыборкаШКУпаковки.ШтрихкодУпаковки;
					НоваяСтрокаТП.ШтрихкодУпаковки 	= СтрокаШК.ШтрихкодУпаковки;
					
					ТаблицаШККомплектующие.Удалить(СтрокаШК); 
					
					КоличествоНеобходимое = КоличествоНеобходимое - 1; 
				КонецЦикла;
			КонецЦикла;
			
		КонецЦикла;
		
		
	КонецЦикла;	 		
	 

КонецПроцедуры

Процедура ЗаполнитьТоварыМаркировкиПоКомплектующим(ДокументМаркировки,ШтрихкодыУпаковокТЧ)
	
	//++Данилова Е.В. 04.06.2025 MARK-2355
	ЭтоКомплектСпайка = Ложь; 
	ДокОснование = ДокументМаркировки.ДокументОснование; 
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") 
		И ДокОснование.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда
		
		ЭтоКомплектСпайка = истина; 	
		
	КонецЕсли;
	//--Данилова Е.В. 04.06.2025
	Для каждого СтрокаУпаковки Из ШтрихкодыУпаковокТЧ Цикл 
		//++Данилова Е.В. 04.06.2025 MARK-2355
		Если ЭтоКомплектСпайка Тогда
		    РазныеТНВЭДВКомплекте = ПолучитьРеквизитШапки(СтрокаУпаковки.ШтрихкодУпаковки.Владелец,"РазныеТНВЭДВКомплекте"); 
			Если НЕ РазныеТНВЭДВКомплекте Тогда 	
				Продолжить; 	
			КонецЕсли;
		КонецЕсли;
		//--Данилова Е.В. 04.06.2025
		НоваяСтрока = ДокументМаркировки.ШтрихкодыУпаковок.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаУпаковки,"ШтрихкодУпаковки"); 
	КонецЦикла;

КонецПроцедуры

