	               |	ВТСоответствиеГККомплектующие КАК ВТСоответствиеГККомплектующие
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтрихКодыПоКомплектам КАК ВТШтрихКодыПоКомплектам
	               |		ПО (ВТШтрихКодыПоКомплектам.Номенклатура = ВТСоответствиеГККомплектующие.ГотовыйКомплект)
	               |ИТОГИ
	               |	МАКСИМУМ(Количество)
	               |ПО
	               |	ГотовыйКомплект,
	               |	ШтрихкодУпаковки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ВТСоответствиеГККомплектующие.Номенклатура КАК Номенклатура,
	               |	ВТШтрихКодыПоКомплектующим.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	               |ИЗ
	               |	ВТСоответствиеГККомплектующие КАК ВТСоответствиеГККомплектующие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТШтрихКодыПоКомплектующим КАК ВТШтрихКодыПоКомплектующим
	               |		ПО (ВТШтрихКодыПоКомплектующим.Номенклатура = ВТСоответствиеГККомплектующие.Номенклатура)";   
	               
	
	Запрос.УстановитьПараметр("ЗаказНаЭмиссию", ЗаказКМГН);
	
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 	
	
	ВыборкаКомплектыИтоги 		= ПакетЗапросов[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	//
	ТаблицаШККомплектующие = ПакетЗапросов[5].Выгрузить(); //                           Выбрать(); 
    ТаблицаШККомплектующие.Индексы.Добавить("Номенклатура");
	
	НовыйДокументМаркировки = Документы.МаркировкаТоваровИСМП.СоздатьДокумент(); 
	ТаблицаШКУпаковок = НовыйДокументМаркировки.ШтрихкодыУпаковок.Выгрузить();
	//Данилова Е.В. 11.09.2025 без задачи, ограничение ЧЗ
	КоличествоСтрокВодномДокументе =  30000; //70000;
	
	МассивДокументовСозданных = Новый Массив; 
	
    РезультатОчистки = Документы.МаркировкаТоваровИСМП.ОчиститьПодчиненныеДокументыМаркировки(ЗаказКМГН,Перечисления.ВидыОперацийИСМП.ФормированиеНабора); 
	Если РезультатОчистки.Успешно Тогда 	
		
		ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(Перечисления.ВидыОперацийИСМП.ФормированиеНабора,ЗаказКМГН);

      	МассивДокументовСозданных.Добавить(ДокументМаркировки); 
		
		Пока ВыборкаКомплектыИтоги.Следующий() Цикл 
			
			ВыборкаШКУпаковки = ВыборкаКомплектыИтоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
			
			Пока ВыборкаШКУпаковки.Следующий() Цикл   			 
				
				ВыборкаНоменклатураГК =  ВыборкаШКУпаковки.Выбрать(); 
				
				Пока ВыборкаНоменклатураГК.Следующий() Цикл 			
					
					Отбор = Новый Структура; 
					Отбор.Вставить("Номенклатура",ВыборкаНоменклатураГК.Номенклатура);
					//
					КоличествоНеобходимое = ВыборкаНоменклатураГК.количество;
					
					Если КоличествоНеобходимое + ДокументМаркировки.ШтрихкодыУпаковок.Количество() > КоличествоСтрокВодномДокументе Тогда
						
						ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(Перечисления.ВидыОперацийИСМП.ФормированиеНабора,ЗаказКМГН);	
						
						МассивДокументовСозданных.Добавить(ДокументМаркировки);	
						
					КонецЕсли;
					
					СтрокиШК = ТаблицаШККомплектующие.НайтиСтроки(Отбор);
					
					Для каждого СтрокаШК  Из СтрокиШК Цикл
						Если КоличествоНеобходимое = 0 Тогда
							
							Прервать; 	
							
						КонецЕсли;
						
						Если КоличествоСтрокВодномДокументе = ДокументМаркировки.ШтрихкодыУпаковок.Количество() Тогда
						
							ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(Перечисления.ВидыОперацийИСМП.ФормированиеНабора,ЗаказКМГН);	
							
							МассивДокументовСозданных.Добавить(ДокументМаркировки); 
						КонецЕсли; 
						
						НоваяСтрокаТП = ДокументМаркировки.ШтрихкодыУпаковок.Добавить(); // ТаблицаПодготовка.Добавить();
						НоваяСтрокаТП.ШтрихкодНабора 	= ВыборкаШКУпаковки.ШтрихкодУпаковки;
						НоваяСтрокаТП.ШтрихкодУпаковки 	= СтрокаШК.ШтрихкодУпаковки;
						
						СтрокаДобавленная = ТаблицаШКУпаковок.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаДобавленная,НоваяСтрокаТП); 
						
						ТаблицаШККомплектующие.Удалить(СтрокаШК); 
						
						КоличествоНеобходимое = КоличествоНеобходимое - 1; 
					КонецЦикла;
				КонецЦикла;
				
			КонецЦикла;
			
			
		КонецЦикла;	 	
	КонецЕсли; 
	
	
	/////////////////////////////
	//создание вводов в оборот 
	Если ТаблицаШКУпаковок.Количество() > 0 Тогда
		ВидОперацииИСМП = ?(ЗаказКМГН.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт, 
		Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт, 
		//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
		//Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков  
		Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно
		);
		РезультатОчистки = Документы.МаркировкаТоваровИСМП.ОчиститьПодчиненныеДокументыМаркировки(ЗаказКМГН,ВидОперацииИСМП); 
		Если РезультатОчистки.Успешно Тогда
			
			ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(ВидОперацииИСМП,ЗаказКМГН);
			МассивДокументовСозданных.Добавить(ДокументМаркировки); 
			//Данилова Е.В. 11.09.2025 без задачи, ограничение ЧЗ
			КоличествоСтрокВодномДокументе =  30000; //70000;
			Для каждого СтрокаШК Из ТаблицаШКУпаковок Цикл
				
				Если КоличествоСтрокВодномДокументе = ДокументМаркировки.ШтрихкодыУпаковок.Количество() Тогда
					
					ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(ВидОперацииИСМП,ЗаказКМГН);	
					МассивДокументовСозданных.Добавить(ДокументМаркировки); 
					
				КонецЕсли;
				НоваяСтрока = ДокументМаркировки.ШтрихкодыУпаковок.Добавить(); 
				ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаШК,"ШтрихкодУпаковки");	
				
			КонецЦикла;
			
		КонецЕсли;
		
		Для каждого ЭлементМассива  Из МассивДокументовСозданных Цикл
			
			Попытка
				
				ЭлементМассива.Записать(РежимЗаписиДокумента.Проведение);
				
				
			Исключение
				Сообщить(ОписаниеОшибки());
				ЗаписатьВЛог("МаркировкаГН","Не удалось сформировать формирование набора и ввод в оборот по " + Строка(ЗаказКМГН),"Ошибка"); 
			КонецПопытки;
			
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция СоздатьНовыйДокументМаркировкиШапка(Знач ВидОперацииИСМП,Знач ЗаказКМГН) 
		
	ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();  
	ДокОбъект.ДокументОснование = ЗаказКМГН; 
	ДокОбъект.Дата =  ТекущаяДатаСеанса(); 
	ДокОбъект.Комментарий = ЗаказКМГН.Комментарий;
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ФормированиеНабора Тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.ФормированиеНабора; 
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков 
		ИЛИ ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт Тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.ВводВОборот;
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.Агрегация;
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.Перемаркировка;
	//Валетов-	
	КонецЕсли;
	
	ДокОбъект.ВидОперации 			= ВидОперации; 
	ДокОбъект.ВидОперацииИСМП		= ВидОперацииИСМП; 
	
	ДокОбъект.Статус				= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
	ДокОбъект.Автор 				= ПараметрыСеанса.Пользователь;		
	ДокОбъект.Организация 			= ЗаказКМГН.Организация; 
	ДокОбъект.ТипУпаковки 			= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	ДокОбъект.ТипШК					= Перечисления.ТипыШтрихКодов.Коробка; 	 
	ДокОбъект.ПодразделениеНанесения = ЗаказКМГН.ПодразделениеНанесения;
	
	Возврат ДокОбъект; 
	
КонецФункции



