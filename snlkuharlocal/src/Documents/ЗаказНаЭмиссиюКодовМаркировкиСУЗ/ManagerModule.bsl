Функция ОтправитьНаОбработкуВСУЗ(ДокСсылка, ДопПараметры = неопределено,АдресВозврата = Неопределено) Экспорт
		
	ЗаписатьВЛог("Отладка", "Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОтправитьНаОбработкуВСУЗ", "Информация");
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	//Валетов + 18,07,2025 ПУСТАЯ ЗАДАЧА 
	Если ЗначениеЗаполнено(ДокСсылка.ИД_ДокументаЧЗ) 
		И ДокСсылка.Статус =  Перечисления.СтатусыДокументовМаркировки.Обрабатывается Тогда  
		Возврат Результат;
	КонецЕсли;
	//Валетов -
	
	Начало			= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ИмяМетода   = "МаркировкаВС.ОтправитьНаОбработку_ЗаказКМ";
	ОтборФЗ 	= Новый Структура("Состояние,ИмяМетода", СостояниеФоновогоЗадания.Активно, ИмяМетода);
	
	СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	Пока СписокФЗ.Количество() > 10 Цикл  //пока оставлю 10
		ФоновыеЗадания.ОжидатьЗавершенияВыполнения(СписокФЗ, 5);
		СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	КонецЦикла;
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
	
	пЗадания = Новый Массив;
	пЗадания.Добавить(ДокСсылка);
	пЗадания.Добавить(ДопПараметры);
	пЗадания.Добавить(АдресРезультата);
	
	мЗадания 			= Новый Массив;
	АдресаРезультатов   = Новый Соответствие;	
	
	
	НаименованиеФЗ	= СтрШаблон("Отпр. на обр. в ЧЗ %1",ДокСсылка);
	ФЗ = ФоновыеЗадания.Выполнить(ИмяМетода, пЗадания, ""+ДокСсылка.УникальныйИдентификатор(), НаименованиеФЗ);
	мЗадания.Добавить(ФЗ);
	
	АдресаРезультатов[ФЗ.УникальныйИдентификатор] = АдресРезультата;
	Результаты = инт_ДлительныеОперации.ОжидатьЗавершенияЗаданий(мЗадания); //будет одно
	Для Каждого ФЗ Из Результаты Цикл
		Если ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			рЗагрузки = ПолучитьИзВременногоХранилища(АдресаРезультатов[ФЗ.УникальныйИдентификатор]);
			ТекстСообщения = СтрШаблон(ФЗ.Наименование + " Отработан в ЧЗ %1.", ДокСсылка);
			ЗаписатьВЛог("Отпр. на обр. в ЧЗ", ТекстСообщения, "Информация");
		Иначе
			Если ФЗ.Состояние  = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
				ЗаписатьВЛог("Отпр. на обр. в ЧЗ", "Ошибка ФЗ: " + инт_ДлительныеОперации.ОписаниеОшибкиФЗ(ФЗ), "Ошибка");
			Иначе					
				ЗаписатьВЛог("Отпр. на обр. в ЧЗ", "Недопустимое состояние ФЗ: " + ФЗ.Состояние, "Ошибка");
			КонецЕсли;				
		КонецЕсли;			
	КонецЦикла; 
	
	Результат.Успешно = Истина;
	//
	Результат.ВремяВыполнения 		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	//
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);			
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗагрузитьКодыИзЛогов(ДокСсылка, ПерезаписыватьКМ, АдресВозврата = Неопределено) Экспорт

Функция ПолучитьКМ_Очереди(ДокСсылка, ДопПараметры = неопределено, АдресВозврата = Неопределено) Экспорт
	
	ЗаписатьВЛог("Отладка", "Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолучитьКМ_Очереди", "Информация");
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Начало			= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ИмяМетода   = "МаркировкаВС.ПолучитьРезультаты_ЗаказКМ";
	ОтборФЗ 	= Новый Структура("Состояние,ИмяМетода", СостояниеФоновогоЗадания.Активно, ИмяМетода);
	
	СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	Пока СписокФЗ.Количество() > 10 Цикл  //пока оставлю 10
		ФоновыеЗадания.ОжидатьЗавершенияВыполнения(СписокФЗ, 5);
		СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	КонецЦикла;
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
	
	пЗадания = Новый Массив;
	пЗадания.Добавить(ДокСсылка);
	пЗадания.Добавить(ДопПараметры); 
	пЗадания.Добавить(АдресРезультата);
	
	мЗадания 			= Новый Массив;
	АдресаРезультатов   = Новый Соответствие;	
	
	
	НаименованиеФЗ	= СтрШаблон("Получение КМ по Заказу КМ %1",ДокСсылка);
	ФЗ = ФоновыеЗадания.Выполнить(ИмяМетода, пЗадания, ""+ДокСсылка.УникальныйИдентификатор(), НаименованиеФЗ);
	мЗадания.Добавить(ФЗ);
	
	АдресаРезультатов[ФЗ.УникальныйИдентификатор] = АдресРезультата;
	Результаты = инт_ДлительныеОперации.ОжидатьЗавершенияЗаданий(мЗадания); //будет одно
	Для Каждого ФЗ Из Результаты Цикл
		Если ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			рЗагрузки = ПолучитьИзВременногоХранилища(АдресаРезультатов[ФЗ.УникальныйИдентификатор]);
			
			Если НЕ рЗагрузки.Успешно Тогда
				
				Если рЗагрузки.Ошибки.Количество()>0 Тогда
					ТекстОшибки = СтрСоединить(рЗагрузки.Ошибки, Символы.ПС);
				Иначе
					ТекстОшибки = Неопределено;				
				КонецЕсли; 
				УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("Статус,ТекстОшибки", Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки, ТекстОшибки));
				
				ТемаПисьма = "Ошибка получения КМ из ЧЗ (Регламент обработки заказов КМ)";
				ТекстПисьма = СтрШаблон("ФЗ:%1. Ошибка в документе заказ КМ %2: %3",НаименованиеФЗ,ДокСсылка, ТекстОшибки); 
				
				СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма); 
			Иначе 
				ТекстСообщения = СтрШаблон(ФЗ.Наименование + " Получены КМ из ЧЗ %1.", ДокСсылка);
				ЗаписатьВЛог("Получить КМ из ЧЗ", ТекстСообщения, "Информация");
				
			КонецЕсли;
			
		Иначе
			Если ФЗ.Состояние  = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
				ЗаписатьВЛог("Получить КМ из ЧЗ", "Ошибка ФЗ: " + инт_ДлительныеОперации.ОписаниеОшибкиФЗ(ФЗ), "Ошибка");
			Иначе					
				ЗаписатьВЛог("Получить КМ из ЧЗ", "Недопустимое состояние ФЗ: " + ФЗ.Состояние, "Ошибка");
			КонецЕсли;				
		КонецЕсли;			
	КонецЦикла; 
	
	Результат.Успешно = Истина;
	//
	Результат.ВремяВыполнения 		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	//
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);			
	КонецЕсли;
	
	Возврат Результат;

КонецФункции // ()

Функция ОтправитьНаОбработкуВСУЗИСМП(ДокСсылка,ДопПараметры = неопределено, АдресВозврата = Неопределено) Экспорт 

	ЗаписатьВЛог("Отладка", "Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОтправитьНаОбработкуВСУЗИСМП", "Информация");
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Начало			= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ИмяМетода   = "МаркировкаВС.ОтправитьНаОбработку_ОперМаркировки";
	ОтборФЗ 	= Новый Структура("Состояние,ИмяМетода", СостояниеФоновогоЗадания.Активно, ИмяМетода);
	
	СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	Пока СписокФЗ.Количество() > 10 Цикл  //пока оставлю 10
		ФоновыеЗадания.ОжидатьЗавершенияВыполнения(СписокФЗ, 5);
		СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	КонецЦикла;
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
	
	пЗадания = Новый Массив;
	пЗадания.Добавить(ДокСсылка);
	пЗадания.Добавить(ДопПараметры);
	пЗадания.Добавить(АдресРезультата);
	
	мЗадания 			= Новый Массив;
	АдресаРезультатов   = Новый Соответствие;	
	
	
	НаименованиеФЗ	= СтрШаблон("Отпр. на обр. в ЧЗ %1",ДокСсылка);
	ФЗ = ФоновыеЗадания.Выполнить(ИмяМетода, пЗадания, ""+ДокСсылка.УникальныйИдентификатор(), НаименованиеФЗ);
	мЗадания.Добавить(ФЗ);
	
	АдресаРезультатов[ФЗ.УникальныйИдентификатор] = АдресРезультата;
	Результаты = инт_ДлительныеОперации.ОжидатьЗавершенияЗаданий(мЗадания); //будет одно
	Для Каждого ФЗ Из Результаты Цикл
		Если ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			рЗагрузки = ПолучитьИзВременногоХранилища(АдресаРезультатов[ФЗ.УникальныйИдентификатор]);
			ТекстСообщения = СтрШаблон(ФЗ.Наименование + " Отправлен на отработку в ЧЗ %1.", ДокСсылка);
			ЗаписатьВЛог("Получить КМ из ЧЗ", ТекстСообщения, "Информация");
		Иначе
			Если ФЗ.Состояние  = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
				ЗаписатьВЛог("Отпр. на обр. в ЧЗ Опер. Маркировка", "Ошибка ФЗ: " + инт_ДлительныеОперации.ОписаниеОшибкиФЗ(ФЗ), "Ошибка");
			Иначе					
				ЗаписатьВЛог("Отпр. на обр. в ЧЗ Опер. Маркировка", "Недопустимое состояние ФЗ: " + ФЗ.Состояние, "Ошибка");
			КонецЕсли;				
		КонецЕсли;			
	КонецЦикла; 
	
	Результат.Успешно = Истина;
	//
	Результат.ВремяВыполнения 		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	//
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);			
	КонецЕсли;
	
	Возврат Результат;
	

КонецФункции // () 

Функция ПолучитьРезультаты_ОперМаркировки(ДокСсылка,ДопПараметры = неопределено, АдресВозврата = Неопределено) Экспорт 

	ЗаписатьВЛог("Отладка", "Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолучитьРезультаты_ОперМаркировки", "Информация");
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Начало			= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ИмяМетода   = "МаркировкаВС.ПолучитьРезультаты_ОперМаркировки";
	ОтборФЗ 	= Новый Структура("Состояние,ИмяМетода", СостояниеФоновогоЗадания.Активно, ИмяМетода);
	
	СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	Пока СписокФЗ.Количество() > 10 Цикл  //пока оставлю 10
		ФоновыеЗадания.ОжидатьЗавершенияВыполнения(СписокФЗ, 5);
		СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	КонецЦикла;
	
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
	
	пЗадания = Новый Массив;
	пЗадания.Добавить(ДокСсылка);
	пЗадания.Добавить(ДопПараметры); 
	пЗадания.Добавить(АдресРезультата);
	
	мЗадания 			= Новый Массив;
	АдресаРезультатов   = Новый Соответствие;	
	
	
	НаименованиеФЗ	= СтрШаблон("Получение результатов по операции маркировки %1",ДокСсылка);
	ФЗ = ФоновыеЗадания.Выполнить(ИмяМетода, пЗадания, ""+ДокСсылка.УникальныйИдентификатор(), НаименованиеФЗ);
	мЗадания.Добавить(ФЗ);
	
	АдресаРезультатов[ФЗ.УникальныйИдентификатор] = АдресРезультата;
	Результаты = инт_ДлительныеОперации.ОжидатьЗавершенияЗаданий(мЗадания); //будет одно
	Для Каждого ФЗ Из Результаты Цикл
		Если ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			рЗагрузки = ПолучитьИзВременногоХранилища(АдресаРезультатов[ФЗ.УникальныйИдентификатор]);
			
			Если рЗагрузки.Успешно Тогда
				ТекстСообщения = СтрШаблон(ФЗ.Наименование + " Получен результат из ЧЗ по маркировке %1.", ДокСсылка);
				ЗаписатьВЛог("Получить результат из ЧЗ по маркировке", ТекстСообщения, "Информация");	
			Иначе
				ТекстОшибки = СтрСоединить(рЗагрузки.Ошибки, Символы.ПС);
				
				Если ТекстОшибки = "404" Тогда
					УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("ТекстОшибки", ТекстОшибки));
				Иначе
					УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("Статус,ТекстОшибки", Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки, ТекстОшибки));
				
					ТемаПисьма = "Ошибка получения рез. обработки из ЧЗ (Регламент обработки опер. маркировки)";
					ТекстПисьма = СтрШаблон("ФЗ:%1. Ошибка в документе ""Операция маркировка"" %2: %3",НаименованиеФЗ,ДокСсылка, ТекстОшибки); 
				
					СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма);				
				КонецЕсли;				
			КонецЕсли;
		Иначе
			Если ФЗ.Состояние  = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
				ЗаписатьВЛог("Получить результат из ЧЗ по маркировке", "Ошибка ФЗ: " + инт_ДлительныеОперации.ОписаниеОшибкиФЗ(ФЗ), "Ошибка");
			Иначе					
				ЗаписатьВЛог("Получить результат из ЧЗ по маркировке", "Недопустимое состояние ФЗ: " + ФЗ.Состояние, "Ошибка");
			КонецЕсли;				
		КонецЕсли;			
	КонецЦикла; 
	
	Результат.Успешно = Истина;
	//
	Результат.ВремяВыполнения 		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	//
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);			
	КонецЕсли;
	
	Возврат Результат;


КонецФункции // ПолучитьРезультаты_ОперМаркировки()

Процедура СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма, Основание = "Регламент по обработке Заказов КМ") Экспорт

	СписокПолучателей = Новый СписокЗначений; 	
	СписокПолучателей.Добавить("mark@collant.ru");
		
	СформироватьВнутреннееУведомление(СписокПолучателей, ТекстПисьма, ТемаПисьма,Основание); 

КонецПроцедуры

