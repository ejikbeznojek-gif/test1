	Если ТаблицаКомплектующие <> Неопределено Тогда
		тТовары = ТаблицаКомплектующие;
	Иначе 
	//--Данилова Е.В. 19.05.2026

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	НоменклатураКоплектующие.Номенклатура КАК Номенклатура,
		|	СУММА(НоменклатураКоплектующие.Количество * ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Количество) КАК Количество
		|ИЗ
		|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура = НоменклатураСпр.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|		ПО (НоменклатураКоплектующие.Ссылка = НоменклатураСпр.Ссылка)
		|ГДЕ
		|	НоменклатураСпр.ВидКомплекта = &ВидКомплекта
		|	И ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Ссылка = &Ссылка
		|	И НоменклатураКоплектующие.Номенклатура.Родитель.ТНВЭД <> ЗНАЧЕНИЕ(Справочник.ТНВЭД.ПустаяСсылка)
		|	И НЕ(НоменклатураКоплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
		|				ИЛИ НоменклатураКоплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
		|
		|СГРУППИРОВАТЬ ПО
		|	НоменклатураКоплектующие.Номенклатура";
		Запрос.УстановитьПараметр("Ссылка", ЗаказКМ_Ссылка); 
 	//++Данилова Е.В. 03.06.2025  MARK-2355
		Запрос.УстановитьПараметр("ВидКомплекта", ВидКомплекта);
	//--Данилова Е.В. 03.06.2025
		тТовары = Запрос.Выполнить().Выгрузить();
	//++Данилова Е.В. 19.05.2026 MARK-3615
	КонецЕсли;	
	//--Данилова Е.В. 19.05.2026
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Части ИЗ &Части КАК Части
	|;	
	|ВЫБРАТЬ
	|	Номенклатура.ГТИН КАК ГТИН,
	|	*
	|ИЗ
	|	ВТ_Части
	|ИТОГИ ПО
	|	Часть
	|";
	
	Запрос.УстановитьПараметр("Части", МаркировкаВС.РазбитьТЧнаЧасти(тТовары, 5, 5000)) ; 
	
	рОчистки = ОчиститьПодчиненныеЗаказы(ЗаказКМ_Ссылка);
	Если рОчистки.Успешно Тогда
		СуществующиеЗаказы = рОчистки.СуществующиеЗаказы;		
		
		рЗапроса 		= Запрос.Выполнить();	
		Выборка_Часть 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Часть");	
		
		Если рЗапроса.Пустой() Тогда
			Результат.Ошибки.Добавить("Не найдено данных для обработки !");		
		КонецЕсли;
		НачатьТранзакцию(); 
		Пока Выборка_Часть.Следующий() Цикл
			ДокСсылка = СуществующиеЗаказы[Выборка_Часть.Часть];					
			Если ДокСсылка = Неопределено Тогда
				ДокОбъект = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
				//++Данилова Е.В. 16.05.2025  MARK-1675
				ДокОбъект.СозданАвтоматически = Истина;
				//--Данилова Е.В. 16.05.2025
				ДокОбъект.Дата	= ТекущаяДата();
				ДокОбъект.Заполнить(ЗаказКМ_Ссылка);
			Иначе
				ДокОбъект = ДокСсылка.ПолучитьОбъект();
			КонецЕсли; 
			
			ДокОбъект.Товары.Очистить();
			
			Выборка = Выборка_Часть.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаТЧ = ДокОбъект.Товары.Добавить();			
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
			КонецЦикла; 
			//++Данилова Е.В. 19.05.2026 MARK-3615
			ДокОбъект.Статус = Статус; 
			//--Данилова Е.В. 19.05.2026 
			ДокОбъект.ПометкаУдаления = Ложь;
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1; 
			//++Данилова Е.В. 09.04.2025 MARK-1946
			Результат.Данные.Добавить(ДокОбъект.ссылка); 
			//--Данилова Е.В. 09.04.2025
		КонецЦикла;
		Если ТранзакцияАктивна() Тогда
		
			ЗафиксироватьТранзакцию();
		
		КонецЕсли;
	Иначе
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные заказы на КМ !");
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);	
	
	Возврат Результат;
	
КонецФункции //СоздатьЗаказыКЗПС(ЗПС_Ссылка)

Процедура ОбновитьПолученоКодовКомплектующихПоЗаказуКМГН(Знач ДокСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолученоКодов) КАК ПолученоКодов
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|ГДЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен
	|	И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокСсылка);
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	ПолученоКодовКомплект = 0; 
	
	Если Выборка.Следующий() Тогда
		
		ПолученоКодовКомплект = Выборка.ПолученоКодов; 
		
	КонецЕсли;
	
	РежимЗаписи = ?(ДокСсылка.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
	Реквизиты 	= Новый Структура("ПолученоКодовКомплект", ПолученоКодовКомплект);
	
	УстановитьРеквизитыОбъекта(ДокСсылка, Реквизиты, РежимЗаписи);
	
	#ЕСЛИ Клиент ТОГДА
		ОповеститьОбИзменении(ДокСсылка);
	#КОНЕЦЕСЛИ
	Если  ДокСсылка.ПолученоКодовКомплект  = ДокСсылка.КоличествоКомплект Тогда
		 //++Данилова Е.В. 06.10.2025 MARK-2834
