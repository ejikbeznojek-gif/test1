Процедура СоздатьВводВОборотПоСпайкамПоПеремаркировке(Знач ЗаказКМГН)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ссылка КАК ЗаказКМ
				   |ПОМЕСТИТЬ ВТЗаказыКМ
				   |ИЗ
				   |	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
				   |ГДЕ
				   |	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = &ЗаказНаЭмиссию
				   |	И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен
				   |	И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихкодУпаковки
				   |ИЗ
				   |	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЗаказыКМ КАК ВТЗаказыКМ
				   |		ПО ВТЗаказыКМ.ЗаказКМ = ШтрихкодыУпаковокТоваров.ЗаказКМ";   
	               
	
	Запрос.УстановитьПараметр("ЗаказНаЭмиссию", ЗаказКМГН);
	РезультатЗапроса = Запрос.Выполнить(); 
	
	 			
	МассивДокументовСозданных = новый Массив();
	Если не РезультатЗапроса.Пустой() Тогда
		
		ВидОперацииИСМП = ?(ЗаказКМГН.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт, 
		Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт, 		  
		Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно
		);
		РезультатОчистки = Документы.МаркировкаТоваровИСМП.ОчиститьПодчиненныеДокументыМаркировки(ЗаказКМГН,ВидОперацииИСМП); 
		Если РезультатОчистки.Успешно Тогда
			
			ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(ВидОперацииИСМП,ЗаказКМГН);
			МассивДокументовСозданных.Добавить(ДокументМаркировки); 
			
			КоличествоСтрокВодномДокументе =  30000; 
			
			СтрокаШК = РезультатЗапроса.Выбрать();
			Пока СтрокаШК.Следующий() Цикл

				Если КоличествоСтрокВодномДокументе = ДокументМаркировки.ШтрихкодыУпаковок.Количество() Тогда

					ДокументМаркировки = СоздатьНовыйДокументМаркировкиШапка(ВидОперацииИСМП, ЗаказКМГН);
					МассивДокументовСозданных.Добавить(ДокументМаркировки);

				КонецЕсли;
				НоваяСтрока = ДокументМаркировки.ШтрихкодыУпаковок.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаШК, "ШтрихкодУпаковки");

			КонецЦикла;
			
		КонецЕсли;
		
		Для Каждого ЭлементМассива Из МассивДокументовСозданных Цикл

			Попытка

				ЭлементМассива.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				Сообщить(ОписаниеОшибки());
				ЗаписатьВЛог("МаркировкаГН", "Не удалось сформировать ввод в оборот (перемаркировка) по " + Строка(
					ЗаказКМГН), "Ошибка");
			КонецПопытки;

		КонецЦикла;
	КонецЕсли;
КонецПроцедуры
