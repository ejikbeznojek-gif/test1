			ИЛИ КомплектСпайка_Импорт(ДокСсылка) Тогда
		//--Данилова Е.В. 03.06.2025
			Результат.Успешно = Истина;
		Иначе			
			ТекстОшибки = СтрШаблон("Не допустимый вид комплекта: %1, вид комплекта: '%2', должен быть: 'Готовый комплект'.", ДокСсылка, Реквизиты.ВидКомплекта);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли;
	Иначе
		Результат.Ошибки.Добавить("Документ не проведен.");
	КонецЕсли;
	
	Возврат Результат;
КонецФункции
