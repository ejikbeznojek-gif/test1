Процедура СоздатьЗаполнитьШапкуДокМаркировкиГН(ДокОбъект,ВидОперацииИСМП,ЗаказКМГН) Экспорт

	ПоляПоиска = Новый Структура("ДокументОснование,ВидОперацииИСМП,ПометкаУдаления", ЗаказКМГН, ВидОперацииИСМП,ЛОЖЬ);
	
	ДокМаркировка =  НайтиДокумент("МаркировкаТоваровИСМП", ПоляПоиска);
	
	Если ЗначениеЗаполнено(ДокМаркировка) Тогда
		Реквизиты = ПолучитьРеквизитыШапки(ДокМаркировка, "Статус");			
		Если Реквизиты.Статус<>Перечисления.СтатусыДокументовМаркировки.ВРаботе  
			И ВидОперацииИСМП <> Перечисления.ВидыОперацийИСМП.Агрегация Тогда 
			
			ТекстОшибки = СтрШаблон("Невозможно перезаполнить формирование набора: %1, недопустимый статус: '%2'.", ДокМаркировка, Реквизиты.Статус);
			Возврат ;
		ИначеЕсли  ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация 
			И (Реквизиты.Статус<>Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки
			И Реквизиты.Статус<>Перечисления.СтатусыДокументовМаркировки.ВРаботе) Тогда 
			ТекстОшибки = СтрШаблон("Невозможно перезаполнить агрегеацию: %1, недопустимый статус: '%2'.", ДокМаркировка, Реквизиты.Статус);
			Возврат ;
		КонецЕсли; 
		ДокОбъект = ДокМаркировка.ПолучитьОбъект();
	Иначе
		ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент(); 
		//++Данилова Е.В. 16.05.2025 MARK-1675
		ДокОбъект.СозданАвтоматически = Истина;
		//--Данилова Е.В. 16.05.2025
	КонецЕсли;
	
	ДокОбъект.ДокументОснование = ЗаказКМГН; 
	ДокОбъект.Дата =  ТекущаяДатаСеанса(); 
	ДокОбъект.Комментарий = ЗаказКМГН.Комментарий;
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ФормированиеНабора Тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.ФормированиеНабора; 
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков 
		ИЛИ ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт Тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.ВводВОборот;
		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Агрегация тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.Агрегация;
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно тогда
		
		ВидОперации 			= Перечисления.ВидыОперацийМаркировки.Перемаркировка;
	//Валетов-
	Иначе 
		Возврат ; 
	КонецЕсли;
	
