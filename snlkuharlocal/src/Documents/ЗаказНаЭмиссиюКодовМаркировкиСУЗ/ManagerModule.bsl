Функция СоздатьЗаказыКЗПС(ЗПС_Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	ТекСтатус = ПолучитьРеквизитШапки(ЗПС_Ссылка, "СтатусМаркировки", "Документ");
	
	Если ТекСтатус<>Перечисления.СтатусыДоков_Маркировка.ВРаботе Тогда
		ТекстОшибки = СтрШаблон("Недопустимый статус маркировки ЗПС: '%1', формирование КМ возможно только для статуса: 'В работе'.", ТекСтатус);
		Результат.Ошибки.Добавить(ТекстОшибки);
		Возврат Результат;	
	КонецЕсли; 
	//++Данилова Е.В. 27.03.2025 MARK-1288
	//Запрос = Новый Запрос;
	//Запрос.Текст = "
	//|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Части ИЗ &Части КАК Части
	//|;	
	//|ВЫБРАТЬ
	//|	Номенклатура.ГТИН КАК ГТИН,
	//|	*
	//|ИЗ
	//|	ВТ_Части
	//|ИТОГИ ПО
	//|	Часть
	//|";
	//
	
	//тТовары = МаркировкаВС.ПолучитьМаркируемыеТоварыДокумента(ЗПС_Ссылка);
	 
	//ЗапросТоваров = Новый Запрос;
	//ЗапросТоваров.Текст = "ВЫБРАТЬ
	//|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	//|	СУММА(ЗаказПоставщикуТовары.Количество) КАК Количество
	//|ИЗ
	//|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправочник
	//|		ПО ЗаказПоставщикуТовары.Номенклатура = НоменклатураСправочник.Ссылка
	//|			И (НоменклатураСправочник.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	//|ГДЕ
	//|	ЗаказПоставщикуТовары.Ссылка = &ДокСсылка
	//|	И НЕ(ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	//|				ИЛИ ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	ЗаказПоставщикуТовары.Номенклатура
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	ЗаказПоставщикуТовары.Номенклатура.Наименование";
	//
	//ЗапросТоваров.УстановитьПараметр("ДокСсылка", ЗПС_Ссылка);	
	//
	//тТоварыГН  = ЗапросТоваров.Выполнить().Выгрузить();
	
	//ЗапросТоваров = Новый Запрос;
	//ЗапросТоваров.Текст = "ВЫБРАТЬ
	//|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	//|	СУММА(ЗаказПоставщикуТовары.Количество) КАК Количество
	//|ИЗ
	//|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправочник
	//|		ПО ЗаказПоставщикуТовары.Номенклатура = НоменклатураСправочник.Ссылка
	//|			И (НоменклатураСправочник.ВидКомплекта <> ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	//|ГДЕ
	//|	ЗаказПоставщикуТовары.Ссылка = &ДокСсылка
	//|	И НЕ(ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	//|				ИЛИ ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	ЗаказПоставщикуТовары.Номенклатура
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	ЗаказПоставщикуТовары.Номенклатура.Наименование";
	//
	//ЗапросТоваров.УстановитьПараметр("ДокСсылка", ЗПС_Ссылка);	
	//
	//тТовары  = ЗапросТоваров.Выполнить().Выгрузить();
	//
	
	ЗапросТоваров = Новый Запрос;
	ЗапросТоваров.Текст = "ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказПоставщикуТовары.Количество) КАК Количество,
	|	НоменклатураСправочник.Родитель.ВидКомплекта КАК ВидКомплекта
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправочник
	|		ПО ЗаказПоставщикуТовары.Номенклатура = НоменклатураСправочник.Ссылка
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка = &ДокСсылка
	|	И НЕ(ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|				ИЛИ ЗаказПоставщикуТовары.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказПоставщикуТовары.Номенклатура,
	|	НоменклатураСправочник.Родитель.ВидКомплекта
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаказПоставщикуТовары.Номенклатура.Наименование
	|ИТОГИ ПО
	|	ВидКомплекта";
	
	ЗапросТоваров.УстановитьПараметр("ДокСсылка", ЗПС_Ссылка);
	
	ИтогиПоВидамКомплектов = ЗапросТоваров.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,0));
	
	МассивТаблицТоваров = Новый Массив; 
	Пока ИтогиПоВидамКомплектов.Следующий() Цикл
		
		ТЧТовары = Новый ТаблицаЗначений; 
		ТЧТовары.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура")); 
		ТЧТовары.Колонки.Добавить("Количество",ОписаниеТиповЧисло);
		
		Выборка  = ИтогиПоВидамКомплектов.Выбрать(); 
		Пока Выборка.Следующий() Цикл
			
			НоваяСтрока = ТЧТовары.Добавить(); 
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка); 
			
		КонецЦикла;
		
		МассивТаблицТоваров.Добавить(ТЧТовары); 
		
	КонецЦикла;
	 
	МассивЧастей 	= Новый Массив; 
	Сч 				= 1;
	Часть 			= 0;
	
	Запрос = Новый Запрос;
	ТекстЗапроса = ""; 
	
	Если МассивТаблицТоваров.Количество() = 0 Тогда
	
		Результат.Ошибки.Добавить("Не найдены товары для формирования Заказов КМ");
		
		Возврат Результат; 
	
	КонецЕсли;
	
	Для каждого ТЧМассива Из  МассивТаблицТоваров Цикл
		
		Части = МаркировкаВС.РазбитьТЧнаЧасти(ТЧМассива, 5, 5000,Часть);
		
		ТекстЗапроса = ТекстЗапроса + 
		"ВЫБРАТЬ
		|	* 
		|ПОМЕСТИТЬ ВТ_Части"+Строка(Сч)+"
		|ИЗ
		|	&Части"+Строка(Сч)+" КАК Части
		|;"; 
		
		Запрос.УстановитьПараметр("Части" + Строка(Сч),Части); 
		Сч = Сч + 1; 
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + 
	
	" ВЫБРАТЬ
	|	* 
	|ПОМЕСТИТЬ ВТ_Части  
	|ИЗ
	|	ВТ_Части1  "; 
	
	
	Для Кол = 2 По Сч-1 Цикл
		
		ТекстЗапроса = ТекстЗапроса + " 
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	ВТ_Части"+Строка(Кол)+" 
		| ";  
		
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + " 	
	|; 
	| ВЫБРАТЬ
	|	Номенклатура.ГТИН КАК ГТИН,
	|	*
	|ИЗ
	|	ВТ_Части
	|ИТОГИ ПО
	|	Часть
	|"; 
	Запрос.Текст = ТекстЗапроса; 

	//Запрос.УстановитьПараметр("Части", МаркировкаВС.РазбитьТЧнаЧасти(тТовары, 10, 5000));
	//--Данилова Е.В. 27.03.2025

	рОчистки = ОчиститьПодчиненныеЗаказы(ЗПС_Ссылка);
	Если рОчистки.Успешно Тогда
		СуществующиеЗаказы = рОчистки.СуществующиеЗаказы;		
		
		рЗапроса 		= Запрос.Выполнить();	
		Выборка_Часть 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Часть");	
		
		Если рЗапроса.Пустой() Тогда
			Результат.Ошибки.Добавить("Не найдено данных для обработки !");		
		КонецЕсли;
		
		Пока Выборка_Часть.Следующий() Цикл
			ДокСсылка = СуществующиеЗаказы[Выборка_Часть.Часть];					
			Если ДокСсылка = Неопределено Тогда
				ДокОбъект = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
				
				ДокОбъект.Дата	= ТекущаяДата();
				ДокОбъект.Заполнить(ЗПС_Ссылка);
			Иначе
				ДокОбъект = ДокСсылка.ПолучитьОбъект();
			КонецЕсли; 
			
			ДокОбъект.Товары.Очистить();
			
			Выборка = Выборка_Часть.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаТЧ = ДокОбъект.Товары.Добавить();			
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
			КонецЦикла; 
			
			ДокОбъект.ПометкаУдаления = Ложь;
			ДокОбъект.Записать();
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		КонецЦикла;  			
	Иначе
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные заказы на КМ !");
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);	
	
	Возврат Результат;
	
КонецФункции //СоздатьЗаказыКЗПС(ЗПС_Ссылка)

Функция СоздатьЗаказыДляКП(КП_Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	рПроверки = ПроверитьСостояниеКП(КП_Ссылка);	
	
	Если НЕ рПроверки.Успешно Тогда		
		Возврат рПроверки;		
	КонецЕсли;	

	рОчистки = ОчиститьПодчиненныеЗаказы(КП_Ссылка);
	Если рОчистки.Успешно Тогда
		СуществующиеЗаказы = рОчистки.СуществующиеЗаказы;		
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	Номенклатура.Родитель.ВидКомплекта КАК ВидКомплекта,
		|	Номенклатура,
		|	СУММА(Количество) КАК Количество	
		|ИЗ
		|	Документ.КонтрактСПроизводителем.Товары	
		|ГДЕ
		|	Ссылка = &ДокСсылка
		|	И НЕ (
		|		Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
		|		ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)
		|	)	
		|СГРУППИРОВАТЬ ПО	
		|	Номенклатура		
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура.Наименование
		|ИТОГИ ПО
		|	ВидКомплекта
		|";
		
		Запрос.УстановитьПараметр("ДокСсылка", КП_Ссылка);
		
		ОбработаноЧастей = 0;	
		
		рЗапроса = Запрос.Выполнить();
		
		Если рЗапроса.Пустой() Тогда
			Результат.Ошибки.Добавить("Не найдено данных для обработки !");
		Иначе
			Выборка_ВидКомплекта = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидКомплекта"); 
			Пока Выборка_ВидКомплекта.Следующий() Цикл
				тТовары = Новый ТаблицаЗначений;
				
				тТовары.Колонки.Добавить("Номенклатура",	Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
				тТовары.Колонки.Добавить("Количество",		ПолучитьОписаниеТиповЧисла(10,0));
				
				Выборка = Выборка_ВидКомплекта.Выбрать();
				Пока Выборка.Следующий() Цикл
					СтрокаТЧ = тТовары.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
				КонецЦикла;			                            
				
				ОбработаноЧастей = ОбработаноЧастей + СоздатьЗаказыПоТоварам(КП_Ссылка, тТовары, СуществующиеЗаказы, ОбработаноЧастей);
			КонецЦикла;			
		КонецЕсли;	
	Иначе
		Результат.Успешно = Ложь;
		
		Результат.Ошибки.Добавить("Не удалось очистить подчиненные заказы на КМ !");
		МаркировкаКС.ДобавитьОшибки(Результат, рОчистки);
	КонецЕсли;       
	
	Результат.ОбработаноОбъектов = ОбработаноЧастей;
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов > 0);	
	
	Возврат Результат;	
КонецФункции //СоздатьЗаказыКЗПС(ЗПС_Ссылка)

Функция ПроверитьСостояниеКП(КП_Ссылка)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	рШапки = ПолучитьРеквизитыШапки(КП_Ссылка, "Организация,Организация.ИНН,СостояниеЗаказа", "Документ");
	ТекСтатус = рШапки.СостояниеЗаказа;
	
	Если СокрЛП(рШапки.Организация_ИНН) = "7717115270" Тогда //По ЕЕЭ запрещено заказывать коды по КП
		ТекстОшибки = СтрШаблон("Запрещено создание заказов КМ по организации: '%1' !", рШапки.Организация);
		Результат.Ошибки.Добавить(ТекстОшибки);  
		//Валетов + 21,04,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3669
		Результат.Успешно = Ложь;
		Возврат Результат;   
		//Валетов -
	Иначе	
		ДопустимыеСтатусы = Новый Соответствие;
		ДопустимыеСтатусы[Перечисления.СостояниеЗаказаПоставщику.ПодтвержденныйЗаказ] 	= Истина;
		ДопустимыеСтатусы[Перечисления.СостояниеЗаказаПоставщику.ВПроизводстве] 		= Истина;	
		
		Если ДопустимыеСтатусы[ТекСтатус] = Неопределено Тогда
			СтрокиС = Новый Массив;
			Для каждого КиЗ Из ДопустимыеСтатусы Цикл
				СтрокиС.Добавить(КиЗ.Ключ);		
			КонецЦикла;
			
			ТекстОшибки = СтрШаблон("Недопустимый статус маркировки КП: '%1', формирование КМ возможно только для статусов: '%2'.", ТекСтатус, СтрСоединить(СтрокиС,"','"));		
			Результат.Ошибки.Добавить(ТекстОшибки);		
		КонецЕсли;	                               
		
	КонецЕсли;

	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПроверитьСостояниеКП(КП_Ссылка)


Функция СоздатьЗаказыПоТоварам(ДокОснование, тТовары, СуществующиеЗаказы, НачальнаяЧасть = 0)	
	Запрос = Новый Запрос;	
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	* 
	|ПОМЕСТИТЬ ВТ_Части
	|ИЗ
	|	&Части КАК Части	
	|; 
	| ВЫБРАТЬ
	|	Номенклатура.ГТИН КАК ГТИН,
	|	*
	|ИЗ
	|	ВТ_Части
	|ИТОГИ ПО
	|	Часть
	|";
	Запрос.УстановитьПараметр("Части", МаркировкаВС.РазбитьТЧнаЧасти(тТовары, 10, 5000));
	
	рЗапроса 		= Запрос.Выполнить();	
	Выборка_Часть 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Часть");		
		
	ОбработаноЧастей = Выборка_Часть.Количество();
	
	Пока Выборка_Часть.Следующий() Цикл
		ДокСсылка = СуществующиеЗаказы[Выборка_Часть.Часть + НачальнаяЧасть];					
		Если ДокСсылка = Неопределено Тогда
			ДокОбъект = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
			
			ДокОбъект.Дата	= ТекущаяДата();
			ДокОбъект.Заполнить(ДокОснование);
		Иначе
			ДокОбъект = ДокСсылка.ПолучитьОбъект();
		КонецЕсли; 
		
		ДокОбъект.Товары.Очистить();
		
		Выборка = Выборка_Часть.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = ДокОбъект.Товары.Добавить();			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
		КонецЦикла; 
		
		ДокОбъект.ПометкаУдаления = Ложь;
		ДокОбъект.Записать();		
	КонецЦикла;
	
	Возврат ОбработаноЧастей;
КонецФункции //СоздатьЗаказыПоТоварам(ДокОснование, тТовары, СуществующиеЗаказы, НачальнаяЧасть = 0)

Функция СоздатьЗаказы_Пополнение(ДанныеРасчета, Организация, ПодразделениеНанесения = Неопределено, ЧастьЧисло= Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	//Валетов+ Добавил для правильного разбития автозаказов по готовым наборам
	//Разбитие заказов на части для готовых наборов должно быть 5
	ЕСли ЧастьЧисло = Неопределено Тогда 
		ЧастьЧисло = 10;
	КонецЕсли;	
	//Валетов-
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Результат.Ошибки.Добавить("Не указана организация !");
		Возврат Результат;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Части ИЗ &Части КАК Части
	|;	
	|ВЫБРАТЬ
	|	Номенклатура.ГТИН КАК ГТИН,
	|	*
	|ИЗ
	|	ВТ_Части
	|ИТОГИ ПО
	|	Часть
	|";
	
	//Валетов+ Добавил для правильного разбития автозаказов по готовым наборам
	//было
	//Запрос.УстановитьПараметр("Части", МаркировкаВС.РазбитьТЧнаЧасти(ДанныеРасчета, 10, 5000));
	//СТало
	Запрос.УстановитьПараметр("Части", МаркировкаВС.РазбитьТЧнаЧасти(ДанныеРасчета, ЧастьЧисло, 5000));
	//Валетов-
		
	рЗапроса 		= Запрос.Выполнить();	
	Выборка_Часть 	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Часть");	
		
	Если рЗапроса.Пустой() Тогда
		Результат.Ошибки.Добавить("Не найдено данных для обработки !");		
	КонецЕсли;
		
	Пока Выборка_Часть.Следующий() Цикл
		
		ДокОбъект = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
			
		ДокОбъект.Дата			= ТекущаяДата();
		ДокОбъект.Заполнить(Организация);		
		ДокОбъект.ПодразделениеНанесения = ПодразделениеНанесения;
		
		ДокОбъект.Комментарий	= "Пополнение запаса КМ.";
		
		ДокОбъект.Товары.Очистить();
		
		Выборка = Выборка_Часть.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ = ДокОбъект.Товары.Добавить();			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
		КонецЦикла; 
		
		ДокОбъект.ПометкаУдаления = Ложь;
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		Результат.Данные.Добавить(ДокОбъект.Ссылка);
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);	
	
	Возврат Результат;
	
КонецФункции //СоздатьЗаказы_Пополнение(ДанныеРасчета, Организация) Экспорт

Функция ОчиститьПодчиненныеЗаказы(ЗПС_Ссылка)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,
	|	Статус
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|ГДЕ
	|	ДокументОснование = &ЗПС_Ссылка
	|";
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ (Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе ИЛИ 
			Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке) Тогда
			
			ТекстОшибки = СтрШаблон("Недопустимый статус заказа на КМ: '%1', тек. статус: '%2', допустимые статусы: 'В работе' или 'К обработке'.", Выборка.Ссылка, Выборка.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли; 	
	КонецЦикла;
	
	СуществующиеЗаказы = Новый Соответствие;
	
	Сч = 1;
	Если Результат.Ошибки.Количество() = 0 Тогда
		Выборка.Сбросить();
		
		НачатьТранзакцию();
		
		Пока Выборка.Следующий() Цикл
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе;
			ДокОбъект.Товары.Очистить();
			ДокОбъект.Проведен			= Ложь;
			ДокОбъект.ПометкаУдаления 	= Истина;
		
			ДокОбъект.Записать();		
			
			СуществующиеЗаказы[Сч] = ДокОбъект.Ссылка;
			Сч	= Сч+1;
		КонецЦикла;		
		
		ЗафиксироватьТранзакцию();	
	Иначе
		Результат.Успешно = Ложь;
	КонецЕсли; 
	
	Результат.Вставить("СуществующиеЗаказы", СуществующиеЗаказы);

	Возврат Результат;
КонецФункции // ()
 
Функция ПроверитьДокументПередОтправкойВЧЗ(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка, "Проведен,Статус,СпособВводаВОборот,ДокументОснование");
	Если Реквизиты.Проведен Тогда
		Если Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе
			ИЛИ Реквизиты.Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке Тогда			
			
			Если Реквизиты.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда
				Если ЗначениеЗаполнено(Реквизиты.ДокументОснование) Тогда
					Результат.Успешно = Истина;
				Иначе
					ТекстОшибки = СтрШаблон("Не указан ЗПС док-та: %1.", ДокСсылка);					
					Результат.Ошибки.Добавить(ТекстОшибки);
				КонецЕсли; 			
			Иначе
				Результат.Успешно = Истина;			
			КонецЕсли; 			
		Иначе			
			ТекстОшибки = СтрШаблон("Не допустимый статус док-та: %1, статус: '%2', должен быть: 'В работе' или 'К обработке'.", ДокСсылка, Реквизиты.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли; 	
	Иначе
		Результат.Ошибки.Добавить("Документ не проведен.");
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПроверитьДокументПередОтправкойВЧЗ()
 
