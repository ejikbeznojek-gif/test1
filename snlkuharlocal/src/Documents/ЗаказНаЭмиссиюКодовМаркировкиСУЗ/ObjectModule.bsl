Функция СоздатьДокументПоТаблицеТоваров(ДокументОснование,ТаблицаТоваров,ВидНоменклатурыЧЗВДокументе)  Экспорт 

	    ЗаказНаЭмиссиюКодовМаркировкиСУЗ = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент(); 
		
		ЗаполнитьЗначенияСвойств(ЗаказНаЭмиссиюКодовМаркировкиСУЗ,ДокументОснование,,"Дата,Номер,КоличествоДокумента"); 
		
		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Дата = ТекущаяДатаСеанса(); 
		
		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары.Загрузить(ТаблицаТоваров); 
		
		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ВидНоменклатурыЧЗВДокументе = ВидНоменклатурыЧЗВДокументе;
		//++Данилова Е.В. 26.03.2025
		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект; 
		//--Данилова Е.В. 26.03.2025
		
		ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Записать(); 
		
		Возврат ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка; 		 
		
КонецФункции // ЗаполнитьДокументПоТаблицеТоваров()

// <Описание функции>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
Функция СоздатьНовыйДокументПоГотовымКомплектам(ДокОснование,ТаблицаТоваров) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.ГТИН КАК ГТИН,
	|	ВТТовары.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	&Товары КАК ВТТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.ГТИН КАК ГТИН,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Количество КАК Количество
	|ИЗ
	|	ВТТовары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
	|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура = НоменклатураСпр.Ссылка
	|			И (НоменклатураСпр.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))";
	
	
	Запрос.УстановитьПараметр("Товары",ТаблицаТоваров);
	
	Возврат СоздатьДокументПоТаблицеТоваров(ДокОснование,Запрос.Выполнить().Выгрузить(),Перечисления.ВидыНоменклатурыЧЗ.Набор); 


КонецФункции // СоздатьНовыйДокументПоГотовымКомплектам()

//++Данилова Е.В. 03.04.2025 ASU-2175
Процедура ПересчитатьКоличествоКомплектующихВТоварах() Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары",Товары.Выгрузить()); 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура,
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.ГТИН КАК ГТИН,
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	ВТТовары.ГТИН КАК ГТИН,
		|	МАКСИМУМ(ВТТовары.Количество) КАК Количество,
		|	СУММА(НоменклатураКоплектующие.Количество) * МАКСИМУМ(ВТТовары.Количество) КАК КоличествоКомплект
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|			ПО НоменклатураСпр.Ссылка = НоменклатураКоплектующие.Ссылка
		|				И (НЕ(НоменклатураКоплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
		|						ИЛИ НоменклатураКоплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)))
		|		ПО ВТТовары.Номенклатура = НоменклатураСпр.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТТовары.Номенклатура,
		|	ВТТовары.ГТИН";
	
	Товары.Загрузить(Запрос.Выполнить().Выгрузить()); 	

КонецПроцедуры

//Валетов + 23,04,2025 ПУСТАЯ ЗАДАЧА 
//Регистрация КМ к выгрузке для наборов. В ЕКАТ выгружается документ с Видом комплекта Готовый набор без Марок, по этой Эмиссии
Процедура ЗарегистрироватьКМГотовыхНаборов(УзелПолучателя)

	СписокУзлов=новый Массив;
	СписокУзлов.Добавить(УзелПолучателя);
	
	запрос=новый запрос;
	
	запрос.Текст = "ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.ЗаказКМ = &ДокЭмиссии";
	запрос.УстановитьПараметр("ДокЭмиссии",Ссылка);
	МассивКМ = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	запрос.Текст="ВЫБРАТЬ различные
	|	СтатусыКМ_ЧЗ.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрСведений.СтатусыКМ_ЧЗ КАК СтатусыКМ_ЧЗ
	|ГДЕ
	|	СтатусыКМ_ЧЗ.ШтрихКодУпаковки В(&ШтрихКодУпаковки)";
	запрос.УстановитьПараметр("ШтрихКодУпаковки",МассивКМ);
	Выборка=запрос.выполнить().выбрать();
	пока Выборка.Следующий() цикл
		НаборЗаписей = РегистрыСведений.СтатусыКМ_ЧЗ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);	
		ПланыОбмена.ЗарегистрироватьИзменения(СписокУзлов, НаборЗаписей);
	КонецЦикла;
	
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтатусыКМ_Факт.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт КАК СтатусыКМ_Факт
	|ГДЕ
	|	СтатусыКМ_Факт.ШтрихКодУпаковки В(&ШтрихКодУпаковки)";
	запрос.УстановитьПараметр("ШтрихКодУпаковки",МассивКМ);
	Выборка=запрос.выполнить().выбрать();
	пока Выборка.Следующий() цикл
		НаборЗаписей = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);	
		ПланыОбмена.ЗарегистрироватьИзменения(СписокУзлов, НаборЗаписей);
	КонецЦикла;
		
	для каждого СтрСписка из МассивКМ цикл	
		ПланыОбмена.ЗарегистрироватьИзменения(СписокУзлов, СтрСписка);		
	КонецЦикла;
КонецПроцедуры

