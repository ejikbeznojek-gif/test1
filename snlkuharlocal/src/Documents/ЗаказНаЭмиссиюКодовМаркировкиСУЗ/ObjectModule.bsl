	Если Маркировка_ПИ.ТипТекущегоУзла("ДанныеЧЗ") <> Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	//--Данилова Е.В. 26.06.2026 
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ
	|	Ссылка КАК ШтрихкодУпаковки,
	|	Ссылка.Владелец.Родитель.ВидКомплекта КАК ВидКомплекта,
	|	ТипКода
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ЗаказКМ = &Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	Владелец.Наименование
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка		= Запрос.Выполнить().Выбрать();
	
	СтатусКМ_ЧЗ			= Перечисления.СтатусыКодовМаркировкиИСМП.Эмитирован;		
	СтатусКМ_Факт		= Перечисления.СтатусыКодовМаркировкиФакт.Эмитирован;		
	
	Пока Выборка.Следующий() Цикл		
		Движение = Движения.СтатусыКМ_ЧЗ.Добавить();
		
		Движение.Период 			= Дата;
		Движение.ШтрихКодУпаковки	= Выборка.ШтрихкодУпаковки;				
		Движение.Статус				= СтатусКМ_ЧЗ;
		
		Если Выборка.ТипКода = Перечисления.ТипыКодовМаркировки.Набор   
			И Выборка.ВидКомплекта <> Перечисления.ВидыКомплектов.ГотовыйКомплект 
			//Валетов + https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3032
			И  НЕ (Выборка.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект И СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт) Тогда
			//Валетов -
			Движение = Движения.СтатусыКМ_Факт.Добавить();
		
			Движение.Период				= Дата + 1;
			Движение.ШтрихКодУпаковки	= Выборка.ШтрихкодУпаковки;
			Движение.Статус				= Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати;		
			Движение.Местонахождение	= ПодразделениеНанесения;
		КонецЕсли; 
	КонецЦикла;
	
	Если Движения.СтатусыКМ_Факт.Количество() = 0  Тогда
		Движения.СтатусыКМ_Факт.Очистить();	
	КонецЕсли;   
	СформироватьДвижения_ОстаткиКМ();	   
	
КонецПроцедуры

