Функция СформироватьДвижения_ОстаткиКМ()
	ПодразделениеОдн= Справочники.Подразделения.НайтиПоКоду("SSP-0211");
	
	Запрос			= Новый Запрос;
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	Номенклатура.Родитель.ВидКомплекта 	КАК ВидКомплекта,
	|	Номенклатура						КАК Номенклатура,
	|	Ссылка.Дата 						КАК Период,
	|	Ссылка.ПодразделениеНанесения 		КАК Местонахождение,
	|	Ссылка.СпособВводаВОборот 			КАК СпособВводаВОборот,
	|	Количество							КАК ЭмитированноКМ
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
	|ГДЕ
	|	Ссылка = &Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл	
		Запись = Движения.ОстаткиДоступныхКМ.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
		Если Выборка.ВидКомплекта = Перечисления.ВидыКомплектов.Товар Тогда
			Запись.ТипКода = Перечисления.ТипыКодовМаркировки.Товар;
		Иначе                                                       
			Запись.ТипКода = Перечисления.ТипыКодовМаркировки.Набор;			
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(Запись.Местонахождение) Тогда
			Запись.Местонахождение = ПодразделениеОдн;		
		КонецЕсли;		
	КонецЦикла;
КонецФункции //СформироватьДвижения_ОстаткиКМ()

Функция ЗаполнитьТоварыПо_Накладной(Док_Ссылка)
	Товары.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Номенклатура.ГТИН   КАК ГТИН,
	|	СУММА(Заявка)		КАК Количество	
	|ИЗ
	|	"+Док_Ссылка.Метаданные().ПолноеИмя()+".Товары
	|ГДЕ
	|	Ссылка = &Док_Ссылка
	|	И НЕ Номенклатура.СтатусКарточкиВЧЗ В (
	|		ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка),
	|		ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)
	|	)
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("Док_Ссылка", Док_Ссылка);	
	
	Товары.Очистить();
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Для Каждого СтрокаТ Из Товары Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТ.ГТИН) Тогда
			СтрокаТ.ГТИН = Справочники.Номенклатура.ПолучитьГТИН(СтрокаТ.Номенклатура);		
		КонецЕсли;
	КонецЦикла; 
КонецФункции // ()

Функция ПроверитьВидыКомплектовВДокументе()
	Результат = МаркировкаКС.СтруктураРезультата();

	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Родитель.ВидКомплекта КАК ВидКомплекта,
	|	Ссылка КАК Номенклатура,
	|	Код    КАК Номенклатура_Код
	|ИЗ
	|	Справочник.Номенклатура 
	|ГДЕ
	|	Ссылка В (&МассивНоменклатуры)
	|ИТОГИ ПО
	|	ВидКомплекта	
	|";
	
	Запрос.УстановитьПараметр("МассивНоменклатуры", Товары.ВыгрузитьКолонку("Номенклатура"));
	
	ВидовКомплектов = 0;
	
	Выборка_ВидКомплекта = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидКомплекта");
	Пока Выборка_ВидКомплекта.Следующий() Цикл
		ВидовКомплектов = ВидовКомплектов + 1;
		Если ЗначениеЗаполнено(Выборка_ВидКомплекта.ВидКомплекта) Тогда
			Результат.Данные = Выборка_ВидКомплекта.ВидКомплекта; 
		Иначе
			Выборка = Выборка_ВидКомплекта.Выбрать();
			Пока Выборка.Следующий() Цикл			
				ТекстОшибки = СтрШаблон("Не указан вид комплекта для номенклатуры: %1 (%2) !", Выборка.Номенклатура, Выборка.Номенклатура_Код);
				Результат.Ошибки.Добавить(ТекстОшибки);			
			КонецЦикла;
		КонецЕсли;	
	КонецЦикла; 
	
	Если ВидовКомплектов > 1 Тогда
		Результат.Ошибки.Добавить("В документе указана номенклатура с различными видами комплекта !");
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции // ПроверитьВидыКомплектовВДокументе()

