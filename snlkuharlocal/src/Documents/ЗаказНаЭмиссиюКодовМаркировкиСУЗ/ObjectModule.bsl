Функция ПроверитьГотовыеКомплектыВДокументе(ТаблицаТоваров)  Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыТЧ.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	&Товары КАК ТоварыТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВтТовары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура = НоменклатураСпр.Ссылка
		|			И (НоменклатураСпр.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВтТовары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура = НоменклатураСпр.Ссылка
		|			И (НоменклатураСпр.ВидКомплекта <> ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))";
	
	Запрос.УстановитьПараметр("Товары",ТаблицаТоваров);
	
	РезультатЗапросаПакеты = Запрос.ВыполнитьПакет();
	
	ГотовыеКомплекты =  НЕ РезультатЗапросаПакеты[1].Пустой();  
	
    НеГотовыеКомплекты = НЕ РезультатЗапросаПакеты[2].Пустой();
	
	Возврат Новый Структура("ГотовыеКомплекты, НеГотовыеКомплекты",ГотовыеКомплекты,НеГотовыеКомплекты); 
	
КонецФункции // ПроверитьГотовыеКомплектыВДокументе()

