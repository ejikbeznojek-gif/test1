Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)	
	ЗаполнитьШапкуДокумента(ЭтотОбъект, ПараметрыСеанса.Пользователь, ОбщегоНазначения_ПИ.ВалютаНац(), "Продажа");
	
	Статус		= Перечисления.СтатусыДокументовМаркировки.ВРаботе;	
	
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	//СпособВводаВОборот 		= Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков;
	СпособВводаВОборот 		= Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка;
	//Валетов -
	 
	ДокументОснование   	= ДанныеЗаполнения;
	ПодразделениеНанесения	= Справочники.Подразделения.ПустаяСсылка();
	
	ТипОснования = ТипЗнч(ДанныеЗаполнения);	
	Если ТипОснования = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
		СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.Импорт;
		
		Организация 		= ДанныеЗаполнения.Организация;		
		ЗаполнитьТоварыПо_Накладной(ДокументОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда		
		СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.Импорт;
		
		Организация 		= ДанныеЗаполнения.Организация;		
		ЗаполнитьТоварыПо_Накладной(ДокументОснование);					
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда		
		СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка;
		
		Организация 		= ДанныеЗаполнения.Организация;		
		ЗаполнитьТоварыПо_Накладной(ДокументОснование);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.РасходнаяНакладная") Тогда		
		Организация 		= ДанныеЗаполнения.Организация;
		ЗаполнитьТоварыПо_Накладной(ДокументОснование);							
	ИначеЕсли ТипОснования = Тип("СправочникСсылка.Организации") Тогда
		Организация 		= ДанныеЗаполнения;
		//++Данилова Е.В. 03.04.2025
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
		ПодразделениеНанесения 	= ДанныеЗаполнения.ПодразделениеНанесения;
		Организация 			= ДанныеЗаполнения.Организация;
		СпособВводаВОборот = ДанныеЗаполнения.СпособВводаВОборот; 
		//--Данилова Е.В. 03.04.2025
	КонецЕсли; 
КонецПроцедуры

