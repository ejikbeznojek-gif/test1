
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	рПроверки = ПроверитьДокументыКОбработке(ПараметрКоманды);
			
	Для Каждого ТекстОшибки Из рПроверки.ОшибкиДокументов Цикл
		Сообщить(ТекстОшибки, СтатусСообщения.Важное);	
	КонецЦикла; 
	
	Для Каждого ЗаказНаЭмиссию Из рПроверки.ДокументыКОбработке Цикл
		ВидОперацииИСМП = ВидОперацииИСМП(ЗаказНаЭмиссию);
		ДокСсылка 		= НайтиПодчиненныйВводВоборот(ЗаказНаЭмиссию, ВидОперацииИСМП);
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
			Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка, "Статус");			
			Если Реквизиты.Статус<>Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
				ТекстОшибки = СтрШаблон("Невозможно перезаполнить ввод в оборот: %1, недопустимый сатус: ''.", ДокСсылка, Реквизиты.Статус);
				Продолжить;							
			КонецЕсли; 
			ДокОбъект = ДокСсылка.ПолучитьОбъект();
		Иначе
			ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
		КонецЕсли; 
		
		ДокОбъект.Заполнить(ЗаказНаЭмиссию);
		
		//Валетов + 26,02,2026 
		//ДокОбъект.ВидОперации 		= Перечисления.ВидыОперацийМаркировки.ВводВОборот;  
		Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков Тогда
			ДокОбъект.ВидОперации 		= Перечисления.ВидыОперацийМаркировки.ВводВОборот;  
		Иначе           
			ДокОбъект.ВидОперации 		= Перечисления.ВидыОперацийМаркировки.Перемаркировка;
		КонецЕсли; 
		//Валетов -		
		ДокОбъект.ВидОперацииИСМП	= ВидОперацииИСМП;		
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);		
		
		ОповеститьОбИзменении(ЗаказНаЭмиссию);
		
		Сообщить("Оформлен документ ввода в оборот: " + ДокОбъект);
		
		//рОбработки = МаркировкаВС.ОтправитьНаОбработку_ОперМаркировки(ДокСсылка);		
		//
		//Если рОбработки.Успешно Тогда
		//	ОповеститьОбИзменении(ДокСсылка);
		//	Оповестить("ИзмененСтатус", , ДокСсылка);	
		//КонецЕсли;		
	КонецЦикла;	
КонецПроцедуры
 
&НаСервере
Функция ПроверитьДокументыКОбработке(мСсылки)
	Результат = Новый Структура("ОшибкиДокументов,ДокументыКОбработке", Новый Массив, Новый Массив);
	
	Для Каждого ДокСсылка Из мСсылки Цикл		
		рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередВводомВОборот(ДокСсылка);
		Если рПроверки.Успешно Тогда
			Результат.ДокументыКОбработке.Добавить(ДокСсылка);
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат.ОшибкиДокументов, рПроверки);				
		КонецЕсли;				
	КонецЦикла; 	
	
	Возврат Результат;
КонецФункции //ПроверитьДокументыКОбработке(мСсылки)

&НаСервере
Функция НайтиПодчиненныйВводВоборот(ЗаказНаЭмиссию, ВидОперацииИСМП)
	
	ПоляПоиска = Новый Структура("ДокументОснование,ВидОперацииИСМП", ЗаказНаЭмиссию, ВидОперацииИСМП);
	
	Возврат НайтиДокумент("МаркировкаТоваровИСМП", ПоляПоиска);
КонецФункции //НайтиПодчиненныйВводВоборот(ЗаказНаЭмиссию)
 
&НаСервере
Функция ВидОперацииИСМП(ЗаказНаЭмиссию)
	СпособВводаВоборот = ПолучитьРеквизитШапки(ЗаказНаЭмиссию, "СпособВводаВОборот");
	
	ВидОперацииИСМП = ?(СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт, 
		Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт,    
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522	
	//	Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков 
	Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно
	);
	
	Возврат ВидОперацииИСМП;
КонецФункции // ()
 