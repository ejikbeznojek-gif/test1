&НаКлиенте
Процедура ПослеОтветаОчиститьТовары(ОтветНаВопрос,ДопПараметры) Экспорт
	 
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		Объект.Товары.Очистить();
	ИначеЕсли  ОтветНаВопрос = КодВозвратаДиалога.Отмена 
		ИЛИ ОтветНаВопрос = Неопределено Тогда 
		
		Возврат; 
		
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура(); 
	
	ДиалогПомещения = Новый ПараметрыДиалогаПомещенияФайлов;
	ДиалогПомещения.МножественныйВыбор = Истина;
	
	ОповещениеЗавершения = Новый ОписаниеОповещения("ЗагрузитьФайлЗавершение",ЭтотОбъект,ДополнительныеПараметры);  
	
	НачатьПомещениеФайловНаСервер(ОповещениеЗавершения,,,,Новый УникальныйИдентификатор);

КонецПроцедуры // ПослеОтветаОчиститьТовары()

 &НаКлиенте
Процедура ЗагрузитьФайлЗавершение(ОписаниеФайлов,ДополнительныеПараметры) Экспорт
	
	Если ОписаниеФайлов = неопределено  Тогда
		
		Возврат; 
		
	КонецЕсли;   
	
	Для каждого Файл Из ОписаниеФайлов Цикл
		ЗагрузитьФайлЗавершениеНаСервере(Файл.Адрес,ДополнительныеПараметры);  	
	КонецЦикла;	
	
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьФайлЗавершениеНаСервере(АдресФайла,ДополнительныеПараметры)
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла);
	ИмяВремФайла = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ИмяВремФайла);
	
	ТабличныйДокумент = новый ТабличныйДокумент();
	ТабличныйДокумент.Прочитать(ИмяВремФайла,СпособЧтенияЗначенийТабличногоДокумента.Значение);
	
	ПостроительЗапроса = Новый ПостроительЗапроса;
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТабличныйДокумент.Область());
	ПостроительЗапроса.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
	ПостроительЗапроса.ЗаполнитьНастройки();
	ПостроительЗапроса.Выполнить();
	
	Если ПостроительЗапроса.Результат = неопределено Тогда
		
		Сообщить("Не получилось отработать построитель"); 
		
		Возврат; 
		
	КонецЕсли;
	
	ТаблицаЗначенийИзФайла = ПостроительЗапроса.Результат.Выгрузить();
		    	
	//первая колонка  - или код, или наименование, или штрихкод, вторая колонка - количество 
	НомерСтроки = 1; 
	Для каждого СтрокаТЧ  Из ТаблицаЗначенийИзФайла  Цикл
		НомерСтроки = НомерСтроки + 1; 
		Номенклатура = НайтиНоменклатуруПоЗначениюВКолонке(СтрокаТЧ[0]); 
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			
			Сообщить("По номеру строки №" + Строка(НомерСтроки) + " не найдена номенклатура" ); 	
			
		КонецЕсли;
		Попытка
			
			Количество = Число(СтрокаТЧ[1]); 
			
		Исключение
			Количество = СтрокаТЧ[1]; 
		КонецПопытки;
		
		
		НоваяСтрока = Объект.Товары.Добавить(); 
		НоваяСтрока.Номенклатура = Номенклатура; 
		НоваяСтрока.Количество = Количество; 
		
	КонецЦикла;	
	
	 
		
		
КонецПроцедуры

&НаСервере
Функция НайтиНоменклатуруПоЗначениюВКолонке(Знач ЗначениеДляПоиска)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Код = &ЗначениеДляПоиска
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Наименование ПОДОБНО &ЗначениеДляПоиска
		|	И НЕ Номенклатура.ЭтоГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ШтрихКоды КАК ШтрихКоды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
		|		ПО ШтрихКоды.Владелец = Номенклатура.Ссылка
		|ГДЕ
		|	НЕ ШтрихКоды.ПометкаУдаления
		|	И ШтрихКоды.Наименование ПОДОБНО &ЗначениеДляПоиска
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.ГТИН ПОДОБНО &ЗначениеДляПоиска
		|	И НЕ Номенклатура.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("ЗначениеДляПоиска", Строка(ЗначениеДляПоиска));
	
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	
	Если ПакетРезультатов[0].Пустой() Тогда
		
		Если ПакетРезультатов[1].Пустой() Тогда
			
			Если ПакетРезультатов[2].Пустой() Тогда
				
				Если ПакетРезультатов[3].Пустой() Тогда
					
					Возврат Справочники.Номенклатура.ПустаяСсылка();
					
				Иначе 
					Выборка =  ПакетРезультатов[3].Выбрать();
				КонецЕсли;
				
				
				
			Иначе 
				Выборка =  ПакетРезультатов[2].Выбрать(); 
			КонецЕсли;
			
		Иначе 
			
			Выборка =  ПакетРезультатов[1].Выбрать();
			
		КонецЕсли;
		
		
	Иначе 
		
		Выборка =  ПакетРезультатов[0].Выбрать(); 
		
	КонецЕсли;
	
	Выборка.Следующий(); 
	Возврат Выборка.Ссылка;

КонецФункции // НайтиНоменклатуруПоЗначениюВКолонке()
