&НаСервере
Процедура УправлениеВидимостью()
	Имена = СтрРазделить("Организация,ДокументОснование,СпособВводаВОборот,Товары", ",");	
	
	мТолькоПросмотр = ТолькоПросмотр ИЛИ (Объект.Статус <> Перечисления.СтатусыДокументовМаркировки.ВРаботе);
	Для Каждого ИмяЭУ Из Имена Цикл
		Элементы[ИмяЭУ].ТолькоПросмотр = мТолькоПросмотр;	
	КонецЦикла;
	
	Элементы.Статус.ТолькоПросмотр = ?(РольДоступна("Администратор"), ТолькоПросмотр, мТолькоПросмотр);
	//++Данилова Е.В. 03.04.2025 ASU-2175 
	Элементы.ТоварыКоличествоКомплект.Видимость = Объект.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект 
	ИЛИ Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.КомплектСпайка_Импорт(Объект.Ссылка)  
	//--Данилова Е.В. 03.04.2025  
	//++Данилова Е.В. 29.05.2026 
	ИЛИ Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.КомплектСпайка_ПоПеремаркировке(Объект.Ссылка); 
	//--Данилова Е.В. 29.05.2026 
КонецПроцедуры
 
