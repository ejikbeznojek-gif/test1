&НаКлиенте
Процедура ЗагрузитьНоменклатуруИзФайла(Команда)
	
	Если ЗначениеЗаполнено(Объект.Статус) 
		И Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыДокументовМаркировки.ВРаботе") Тогда
		
		ПоказатьПредупреждение(,"Добавление возможно только в статусе ""В работе"""); 
		
		Возврат; 
	
	КонецЕсли;
	
	Если Объект.Товары.Количество() > 0  Тогда
		
		ОповещениеВопрос = Новый ОписаниеОповещения("ПослеОтветаОчиститьТовары",ЭтаФорма); 
		ПоказатьВопрос(ОповещениеВопрос,"Очистить таблицу товаров?",РежимДиалогаВопрос.ДаНетОтмена); 
		
	Иначе
		
		ДополнительныеПараметры = Новый Структура(); 
		
		ДиалогПомещения = Новый ПараметрыДиалогаПомещенияФайлов;
		ДиалогПомещения.МножественныйВыбор = Истина;
		
		ОповещениеЗавершения = Новый ОписаниеОповещения("ЗагрузитьФайлЗавершение",ЭтотОбъект,ДополнительныеПараметры);  
		
		НачатьПомещениеФайловНаСервер(ОповещениеЗавершения,,,,Новый УникальныйИдентификатор);
	КонецЕсли;
КонецПроцедуры
