&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.Товары.Количество() > 10 Тогда
		ПоказатьПредупреждение(,"Превышено максимальное количество строк ! Допускается не более 10 позиций !");
		Отказ = Истина;
	КонецЕсли;
	//++Данилова Е.В. 24.01.2025
	Если НЕ Отказ
		И Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовМаркировки.ВРаботе")
		И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		СоздаватьДокументПоГотовымКомплектам = Ложь; 
		ПроверитьДокументНаНаличиеГотовыхКомплектовНаСервере(СоздаватьДокументПоГотовымКомплектам);
		
		Если СоздаватьДокументПоГотовымКомплектам Тогда
			
			Отказ = Истина; 
			
			ОповещениеВопросПоСозданиюДокумента = Новый ОписаниеОповещения("ОтветаНаВопросСоздатьДокументГотовыйКомплект",ЭтаФорма); 
			ПоказатьВопрос(ОповещениеВопросПоСозданиюДокумента,"Найдены готовые комплекты, выделить их в отдельный документ?",РежимДиалогаВопрос.ОКОтмена); 	
		
		КонецЕсли;
	
	КонецЕсли;
	//--Данилова Е.В. 24.01.2025  
	//Валетов + 21,04,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3669
	ОшибкаИНН = ПроверитьИмпортПередЗаписью(); 
	Если ОшибкаИНН Тогда
		СообщитьИзМодуля("Запрещено создание импортных заказов КМ по организации ЕЕЭ!");
		Отказ = ОшибкаИНН;
	 КонецЕсли;
	 
КонецПроцедуры 

