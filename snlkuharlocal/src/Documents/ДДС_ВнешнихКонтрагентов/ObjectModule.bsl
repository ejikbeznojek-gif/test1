Функция ПроведениеПоРегиструОстаткиДДС_ВК(ДокументСсылка,Движения,Загрузка=Ложь) Экспорт	
	
	результат = 1;
	ТекДок = Документссылка;
	
	ДатаДокумента=ТекДок.Дата;
	
	ДвиженияПоОстаткамДДС_ВК = СоздатьТаблицуДвижений("ДДС_ВнешнихКонтрагентов");
	
	Если ТекДок.КодОперации = Перечисления.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств 
		или  ТекДок.КодОперации = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств
		
	Тогда
		Запись = ДвиженияПоОстаткамДДС_ВК.Добавить();
		Запись.Активность = Истина;
		Запись.ВидДвижения = ВидДвиженияНакопления.Приход;
		Запись.Период = Дата;
		Запись.контрагент = контрагент;
		Запись.Сумма = ТекДок.сумма;
		Запись.КодОперации = ТекДок.кодОперации;
		Запись.договор = ТекДок.договор; 
		Запись.валюта = ТекДок.валюта; 
		Запись.комментарий = ТекДок.комментарий;
	Иначе
		Запись = ДвиженияПоОстаткамДДС_ВК.Добавить();
		Запись.Активность = Истина;
		Запись.ВидДвижения = ВидДвиженияНакопления.Расход;
		Запись.Период = Дата;
		Запись.контрагент = контрагент;
		Запись.Сумма = ТекДок.сумма;
		Запись.КодОперации = ТекДок.кодОперации; 
		Запись.договор = ТекДок.договор; 
		Запись.валюта = ТекДок.валюта; 
		Запись.комментарий = ТекДок.комментарий;

	КонецЕсли;
		
	
	Возврат Результат;
	
КонецФункции  

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь,Очищать=Истина)
	
	ИмяРегистра = "ДДС_ВнешнихКонтрагентов";
	ТаблицаДвижения = ДвиженияПоРегистрам; 
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Продолжить  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];
		Если Очищать Тогда
			НаборЗаписей.Очистить();
		КонецЕсли;
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	     
	
КонецПроцедуры 

