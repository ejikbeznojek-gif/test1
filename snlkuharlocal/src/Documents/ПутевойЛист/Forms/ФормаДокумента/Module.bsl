	ОткрытьФорму("Документ.СписаниеИзлишковГСМ.ФормаОбъекта",Новый Структура("Основание",Объект.Ссылка),ЭтаФорма);	
КонецПроцедуры

&НаКлиенте
Процедура ДетализацияРасходаГСМ(Команда)
	ТабДок=ДетализацияРасходаГСМНаСервере();
	ТабДок.показать();
КонецПроцедуры


&НаСервере
Функция ДетализацияРасходаГСМНаСервере()
	ТабДок		= Новый ТабличныйДокумент;
	
	ДокОбъект	= РеквизитФормыВЗначение("Объект");	
	Макет		= ДокОбъект.ПолучитьМакет("Детализация");  
	
	ОблШапка						= Макет.получитьобласть("Шапка");
	
	ОблШапка.Параметры.Автомобиль	= ДокОбъект.Автомобиль;
	ОблШапка.Параметры.Водитель		= ДокОбъект.Автомобиль.Водитель;
	
	ТабДок.Вывести(ОблШапка);
	
	Запрос=новый Запрос;
	Запрос.Текст= "
	|ВЫБРАТЬ
	|	Период,
	|	Регистратор,
	|	Автомобиль,
	|
	|	КоличествоНачальныйОстаток,	
	|	КоличествоПриход,
	|	КоличествоРасход,
	|	КоличествоКонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиГСМ.ОстаткиИОбороты(&Дата1,&Дата2,Регистратор,,Автомобиль = &Автомобиль)	
	|УПОРЯДОЧИТЬ ПО
	|	Период" ;
	
	Запрос.УстановитьПараметр("Дата1",		НачалоДня(ТекущаяДата()-3*30*24*60*60));
	Запрос.УстановитьПараметр("Дата2",		КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Автомобиль",	Объект.Автомобиль);
	
	Выборка=Запрос.Выполнить().выбрать();
	
	Пока Выборка.Следующий() цикл
		ОблСтрока	= Макет.ПолучитьОбласть("Строка");
		ОблСтрока.Параметры.Заполнить(Выборка);
		ТабДок.Вывести(ОблСтрока);		
	КонецЦикла;
	
	Возврат ТабДок;
КонецФункции


&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	если Объект.Номер="" тогда
		Объект.Номер="12345";
	КонецЕсли;
	если  Объект.ДеньВыездаФакт>Объект.ДеньВозвращениеФакт или ((объект.ВыездИзГаражаФактический>Объект.ВозвращениеВГаражФактическое) и  Объект.ДеньВыездаФакт=Объект.ДеньВозвращениеФакт)  тогда
		сообщить("Запрещено записывать документ с датой выезда более поздней, чем дата возвращения!");
		отказ=истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПерерасчитатьОстатки(Команда)
	ЗаполнитьНачальныеДанные();
	РассчитатьПробегиИРасход();
КонецПроцедуры

&НаКлиенте
Процедура СпидометрСкорректированВручнуюПриИзменении(Элемент)
	Если Объект.СпидометрСкорректированВручную Тогда
		ЭтаФорма.Элементы.НачальныйСпидометр.Доступность=Истина;
	Иначе
		ЭтаФорма.Элементы.НачальныйСпидометр.Доступность=Ложь;
		
		Объект.ПробегЗаПутевку		 	= Объект.КонечныйСпидометр - Объект.НачальныйСпидометр;
		Объект.Расход 					= Объект.ПробегЗаПутевку * РасходНаКМ /100 + Объект.Рейсов*РасходНа1Операцию;
		Объект.ОстатокТопливаВозврат	= Объект.ОстатокТопливаВыезд-Объект.Расход+Объект.ЗаправкаНаМаршруте;		
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоказанияНачальныхОстатков(Автомобиль,Дата)
	Возврат Документы.ПутевойЛист.ПоказанияНачальныхОстатков(Автомобиль,Дата);
КонецФункции // ()

