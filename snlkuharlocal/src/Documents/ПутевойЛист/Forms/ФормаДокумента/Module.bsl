&НаСервере
Процедура ЗаполнитьНачальныеДанные()
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	
	Если НЕ Объект.ЭтоВтораяХодка Тогда
		Объект.Дата=НачалоДня(Объект.Дата)+7*60*60;
	КонецЕсли;	 
	
	
	
	// Получаем показания спидометра
	Если НЕ Объект.СпидометрСкорректированВручную тогда
		Объект.НачальныйСпидометр  = Документы.ПутевойЛист.ПоказанияНачальногоСпидометра(Объект.Автомобиль, Объект.Дата);
	КонецЕсли;
	
	// Получаем остаток топлива перед выездом            
	Объект.ОстатокТопливаВыезд	= ПоказанияНачальныхОстатков(Объект.Автомобиль, Объект.Дата);
	
	Объект.Водитель				= Объект.Автомобиль.Водитель;
КонецПроцедуры	

&НаСервере
Процедура ЗаполнитьНормыРасхода()
	ДокОбъект			= РеквизитФормыВЗначение("Объект");
	
	РасходНаКМ 			= ДокОбъект.ПолучитьРасходНа100км();	 
	РасходНа1Операцию	= ДокОбъект.ПолучитьРасходНаОперацию();
КонецПроцедуры 

&НаКлиенте
Процедура Дата_ПриИзменении(Элемент)
	ЗаполнитьНачальныеДанные();
	Если Объект.ДеньВыездаФакт<Объект.Дата ИЛИ Объект.ДеньВозвращениеФакт<Объект.Дата Тогда
		Объект.ДеньВыездаФакт		=Объект.Дата;
		Объект.ДеньВозвращениеФакт	=Объект.Дата;
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура АвтомобильПриИзменении(Элемент)
	ЗаполнитьНачальныеДанные();	
КонецПроцедуры 

&НаКлиенте
Процедура КонечныйСпидометрПриИзменении(Элемент)
	РассчитатьПробегиИРасход();	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьПробегиИРасход()
	Объект.ПробегЗаПутевку			= Объект.КонечныйСпидометр - Объект.НачальныйСпидометр;	 
	Объект.Расход 					= Объект.ПробегЗаПутевку * РасходНаКМ/100 + Объект.Рейсов*РасходНа1Операцию;
	Объект.ОстатокТопливаВозврат 	= Объект.ОстатокТопливаВыезд-Объект.Расход+Объект.ЗаправкаНаМаршруте;
КонецПроцедуры
 

&НаКлиенте
Процедура РейсовПриИзменении(Элемент)
	РассчитатьПробегиИРасход();
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьОстатокВБаке(Команда)	 
	Объект.ОстатокТопливаВыезд = ПоказанияНачальныхОстатков(Объект.Автомобиль, Объект.Дата);	 
КонецПроцедуры

&НаКлиенте
Процедура ВодительПриИзменении(Элемент)	 
	Объект.ВыездИзГаража		= ПрочитатьРежимРаботыВодителей(Объект.Водитель,Объект.Автомобиль, Объект.Дата);
	Объект.ВозвращениеВГараж 	= ПрочитатьРежимРаботыВодителей1(Объект.Водитель,Объект.Автомобиль, Объект.Дата);
КонецПроцедуры


