&НаКлиенте
Процедура ПриОткрытии(Отказ)	
	//кухарь 29.03.15 начало
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ТипПутевого=ПредопределенноеЗначение("Перечисление.ТипПутевогоЛиста.ГрузовойАвтомобильФорма4_С");
		ЗаполнитьНачальныеДанные();
		Объект.КонечныйСпидометр=Объект.НачальныйСпидометр;		
	КонецЕсли;
	//кухарь 29.03.15 конец	
	
	//Кухарь 23.06.15 начало
	ТекОстатокТопливаВозврат = Объект.ОстатокТопливаВыезд-Объект.Расход+Объект.ЗаправкаНаМаршруте;
	Если ТекОстатокТопливаВозврат<>Объект.ОстатокТопливаВозврат тогда
		Объект.ОстатокТопливаВозврат=ТекОстатокТопливаВозврат;
	КонецЕсли;
	//Кухарь 23.06.15 конец	
	
	УстановитьВидимостьИДоступность(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗаправкуГСМ(Команда)
	Записать();	
	
	ОткрытьФормуМодально("Документ.ЗаправкаГСМ.ФормаОбъекта",Новый Структура("Основание",Объект.Ссылка),ЭтаФорма);	

	ЭтаФорма.Прочитать();	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьСписаниеГСМ(Команда)
