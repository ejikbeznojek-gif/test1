	ОборотнаяСторона = Макет.ПолучитьОбласть("Оборот");	
	Маршрут = Ссылка.ВидРаботы.АдресПогрузки + " " + Ссылка.ВидРаботы.АдресРазгрузки;
	ОборотнаяСторона.Параметры.Маршрут                       = Маршрут;
    Маршрут1 = Ссылка.ВидРаботы1.АдресПогрузки + " " + Ссылка.ВидРаботы1.АдресРазгрузки;
	ОборотнаяСторона.Параметры.Маршрут1                      = Маршрут1;
	ТабДок.Вывести(ОборотнаяСторона);
	
КонецПроцедуры

