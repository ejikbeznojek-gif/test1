	КонецЕсли; 

	Если Не Ссылка.ВозвращениеВГараж = Дата(1,1,1) Тогда	
		ЛицеваяСторона.Параметры.ВозвращениеЧисло = Формат(День(Ссылка.Дата),"ЧЦ=2; ЧН=; ЧВН=");
		ЛицеваяСторона.Параметры.ВозвращениеМесяц = Формат(Месяц(Ссылка.Дата),"ЧЦ=2; ЧН=; ЧВН=");
		ЛицеваяСторона.Параметры.ВозвращениеЧас   = Формат(Час(Ссылка.ВозвращениеВГараж),"ЧЦ=2; ЧН=; ЧВН=");
		ЛицеваяСторона.Параметры.ВозвращениеМин   = Формат(Минута(Ссылка.ВозвращениеВГараж),"ЧЦ=2; ЧН=; ЧВН=");
	КонецЕсли;
	
	ТабДок.Вывести(ЛицеваяСторона);

КонецПроцедуры

Процедура Печать_ГА_П_Оборотная(ТабДок, Ссылка) Экспорт	
	ТабДок.ОриентацияСтраницы   = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб          = Истина;
	ТабДок.ОтображатьСетку      = Ложь;
	ТабДок.ПолеСверху           = 5;
	ТабДок.ПолеСнизу            = 5;
	ТабДок.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ";
	
	Макет                       = ПолучитьМакет("ГрузовойАвтомобиль");	
	
	ОбластьОборот = Макет.ПолучитьОбласть("Оборот");
	
	ОбластьОборот.Параметры.Заказчик            = Ссылка.Заказчик;
	ОбластьОборот.Параметры.Заказчик1           = Ссылка.Заказчик1;
	ОбластьОборот.Параметры.Организация         = Ссылка.Организация;
	ОбластьОборот.Параметры.Автомобиль          = Ссылка.Автомобиль;
	ОбластьОборот.Параметры.АвтомобильГосНомер  = Ссылка.Автомобиль.ГосНомер;
	ОбластьОборот.Параметры.Прицеп              = Ссылка.Прицеп;
	ОбластьОборот.Параметры.ПрицепГосНомер      = Ссылка.Прицеп.ГосНомер;
	
	ТабДок.Вывести(ОбластьОборот);
КонецПроцедуры


Процедура ПечатьЛицевая(ТабДок, Ссылка) Экспорт	
	ТипПутевого=Ссылка.ТипПутевого;
	Если ТипПутевого=Перечисления.ТипПутевогоЛиста.ГрузовойАвтомобильФорма4_С Тогда
		Печать_ГА_С_Лицевая(ТабДок, Ссылка);					
	ИначеЕсли ТипПутевого=Перечисления.ТипПутевогоЛиста.ГрузовойАвтомобильФорма4_П Тогда
		Печать_ГА_П_Лицевая(ТабДок, Ссылка);		
	КонецЕсли;
КонецПроцедуры

Процедура ПечатьОборотная(ТабДок, Ссылка) Экспорт	
	ТипПутевого=Ссылка.ТипПутевого;
	Если ТипПутевого=Перечисления.ТипПутевогоЛиста.ГрузовойАвтомобильФорма4_С Тогда
		Печать_ГА_С_Оборотная(ТабДок, Ссылка);
	ИначеЕсли ТипПутевого=Перечисления.ТипПутевогоЛиста.ГрузовойАвтомобильФорма4_П Тогда
		Печать_ГА_П_Оборотная(ТабДок, Ссылка);		
	КонецЕсли;
КонецПроцедуры
  

Функция ПоказанияНачальногоСпидометра(Автомобиль,Дата) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|    МАКСИМУМ(КонечныйСпидометр)
	|ИЗ
	|    Документ.ПутевойЛист
	|ГДЕ
	|	Автомобиль=&Автомобиль
	|	И Дата<&Дата
	|";
	
	Запрос.УстановитьПараметр("Дата",		НачалоДня(Дата));
	Запрос.УстановитьПараметр("Автомобиль",	Автомобиль);
	
	Результат	= 0;
	Выборка		= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат=Выборка.КонечныйСпидометр;			
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции	

Функция ПоказанияНачальныхОстатков(Автомобиль,Дата) Экспорт	  
