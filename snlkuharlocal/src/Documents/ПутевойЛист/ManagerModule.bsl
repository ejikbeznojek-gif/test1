		ОбластьЗадание.Параметры.ТчРасстояние           = ДетальныеЗаписи.Расстояние;				
		ОбластьЗадание.Параметры.ТчПеревезтиТонн        = ДетальныеЗаписи.ПеревезтиТонн;
		ТабДок.Вывести(ОбластьЗадание);
	КонецЦикла;
	
	//Кухарь 12.04.15 начало
