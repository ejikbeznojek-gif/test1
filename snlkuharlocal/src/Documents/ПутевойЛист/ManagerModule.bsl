&НаСервере
Функция ПроверкаПроведенныхДокументов(Автомобиль,Период)Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст ="
	|ВЫБРАТЬ
	|  Ссылка
	|ИЗ
	|  Документ.ПутевойЛист
	|ГДЕ
	|  Проведен
	|  И Дата > &Дата
	|  И Автомобиль = &Ссылка
	|";
	
	Запрос.УстановитьПараметр("Дата", 		Период);
	Запрос.УстановитьПараметр("Ссылка", 	Автомобиль);
	
	Результат = Запрос.Выполнить();	
	Если НЕ Результат.Пустой() Тогда 		
		Выборка= Результат.Выбрать();
		Пока Выборка.Следующий()Цикл
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = Строка("Отменено проведение: "+Выборка.Ссылка);
			Сообщение.Сообщить();
			
			ОбъектПутевойЛист = Выборка.Ссылка.ПолучитьОбъект();			
			ОбъектПутевойЛист.Проведен = Ложь;
			ОбъектПутевойЛист.Записать();
		КонецЦикла;		
	КонецЕсли;
	
КонецФункции
