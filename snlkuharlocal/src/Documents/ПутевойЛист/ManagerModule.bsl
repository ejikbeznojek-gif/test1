Процедура Печать_СА_Лицевая(ТабДок, Ссылка) Экспорт
	
	ТабДок.ОриентацияСтраницы   = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб          = Истина;
	ТабДок.ОтображатьСетку      = Ложь;
	ТабДок.ПолеСверху           = 20;
	ТабДок.ПолеСнизу            = 10;
	ТабДок.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ";
	Макет                       = ПолучитьОбщийМакет("СпецАвтомобиль");     	
	
	ЛицеваяСторона                                          = Макет.ПолучитьОбласть("Лицо");	
	ЛицеваяСторона.Параметры.Номер                          = Ссылка.Номер;
	ЛицеваяСторона.Параметры.Дата                           = Формат(Ссылка.Дата,"ДЛФ=DD");
	Реквизиты = Ссылка.Организация.Наименование + " " + Ссылка.Организация.АдресОрганизации + " "
	+ Ссылка.Организация.ТелефонОрганизации;
	ЛицеваяСторона.Параметры.Реквизиты                      = Реквизиты;
	ЛицеваяСторона.Параметры.ОКПО 	                        = Ссылка.Организация.ОКПО;
	ЛицеваяСторона.Параметры.Автомобиль                     = Ссылка.Автомобиль;
	ЛицеваяСторона.Параметры.АвтомобильГосНомер             = Ссылка.Автомобиль.ГосНомер;
	ЛицеваяСторона.Параметры.Водитель                       = Ссылка.Водитель.Наименование;
	ЛицеваяСторона.Параметры.НачальныйСпидометр             = ПоказанияНачальногоСпидометра(Ссылка.Автомобиль, Ссылка.Дата);
	//ЛицеваяСторона.Параметры.КонечныйСпидометр              = Ссылка.КонечныйСпидометр;
	ЛицеваяСторона.Параметры.ТопливоВыезд                   = ПоказанияНачальныхОстатков(Ссылка.Автомобиль, Ссылка.Дата);
	//ЛицеваяСторона.Параметры.Горючее                        = Ссылка.Автомобиль.ОсновноеТопливо; 	
	//ЛицеваяСторона.Параметры.ОстатокТопливаВозврат          = Ссылка.ОстатокТопливаВозврат;
	ЛицеваяСторона.Параметры.ВыездИзГаража                  = Ссылка.ВыездИзГаража;
	ЛицеваяСторона.Параметры.ВозвращениеВГараж              = Ссылка.ВозвращениеВГараж;
	ЛицеваяСторона.Параметры.Прицеп                         = Ссылка.Прицеп;
	ЛицеваяСторона.Параметры.ПрицепГосНомер                 = Ссылка.Прицеп.ГосНомер;	
	ЛицеваяСторона.Параметры.МеханикПодпись                 = Ссылка.Механик.Подпись;
	ЛицеваяСторона.Параметры.ДиспетчерПодпись               = Ссылка.Диспетчер.Подпись;      	
	ЛицеваяСторона.Параметры.МедикПодпись                   = Ссылка.Медик.Подпись;
	ЛицеваяСторона.Параметры.ВодительПодпись                = Ссылка.Водитель.Подпись;
	ЛицеваяСторона.Параметры.Организация                    = Ссылка.Организация;	
	ЛицеваяСторона.Параметры.Заказчик                       = Ссылка.Заказчик;
	ЛицеваяСторона.Параметры.ЗаказчикПредставитель          = Ссылка.ЗаказчикПредставитель;
	ЛицеваяСторона.Параметры.ВидРаботы                      = Ссылка.ВидРаботы;
	ЛицеваяСторона.Параметры.Заказчик1                      = Ссылка.Заказчик1;	
	ЛицеваяСторона.Параметры.Заказчик1Представитель         = Ссылка.Заказчик1Представитель; 
	
	//Если ЗначениеЗаполнено(Ссылка.ЗаказчикПредставитель) = Неопределено Тогда
	//	   ЛицеваяСторона.Параметры.ЗаказчикПредставительПодпись		= Ссылка.ЗаказчикПредставитель;

	//Иначе  
	//	  ЛицеваяСторона.Параметры.ЗаказчикПредставительПодпись       = Ссылка.ЗаказчикПредставитель; 
	//	  Если Не ЗначениеЗаполнено(Ссылка.ЗаказчикПредставитель)   Тогда
	//		 ЛицеваяСторона.Параметры.ЗаказчикПредставительПодпись       = Ссылка.ЗаказчикПредставитель; 
	//КонецЕсли;
	//КонецЕсли;
	     	
 
	ЛицеваяСторона.Параметры.ВидРаботы1                     = Ссылка.ВидРаботы1;

	ТабДок.Вывести(ЛицеваяСторона);
КонецПроцедуры

Процедура Печать_СА_Оборотная(ТабДок, Ссылка) Экспорт
	
	ТабДок.ОриентацияСтраницы   = ОриентацияСтраницы.Ландшафт;
