Процедура РасчитатьПлановыеСтоимости()
	//крохин начало 13.01.2019
	//тарифы можно менять руками
	//Если ЗначениеЗаполнено(ПунктДоставки.ТарифДоставки) тогда
	//	ТекТариф=ПунктДоставки.ТарифДоставки;
	//ИначеЕсли ЗначениеЗаполнено(ПунктДоставки.Регион.ТарифДоставки) тогда
	//	ТекТариф=ПунктДоставки.Регион.ТарифДоставки;
	//иначе ТекТариф=Справочники.ТарифыДоставки.ПустаяСсылка();
	//КонецЕсли;
	ТекТариф = ТарифДоставки;
	//крохин конец 13.01.2019
	
	если ТекТариф=Справочники.ТарифыДоставки.ПустаяСсылка() тогда
		СтоимостьЗаПаллетыПлан=0;
		СтоимостьЗаОбъемПлан=0;
		СтоимостьЗаШтукиПлан=0;
		//крохин начало 24.02.2019
		СтоимостьЗаОбъемПланТариф = 0;
		СтоимостьЗаОбъемПланКилометраж = 0;
		СтоимостьЗаОбъемПланАвизация = 0;
		СтоимостьЗаОбъемПланЭкспедирование = 0;
		СтоимостьЗаОбъемПланПогрузка = 0;
		СтоимостьЗаОбъемПланДоставкаДоТК = 0;
		//крохин конец 24.02.2019
		Возврат;
	КонецЕсли;
	
	РасчитатьПоправкуЗаКилометраж(ТекТариф);
	//крохин начало 13.01.2019
	//новые реквизиты
	РассчитатьПоправкуЗаАвизацию(ТекТариф);
	РассчитатьПоправкуЗаЭкспедирование(ТекТариф);
	РассчитатьПоправкуЗаПогрузку(ТекТариф);
	//крохин конец 13.01.2019
	
	//крохин начало 03.02.2019
	РассчитатьПоправкуЗаДоставкуДоТК(ТекТариф);
	//крохин конец 03.02.2019
	
	
	СтоимШтук=0;
	НашлиСтрочку=ложь;
	ПредыдущееЗначение=0;
	если ТекТариф.ТарифНаШтуки.ПорогиСтоимости.Количество()>0 тогда
		для каждого СтрПорогов из ТекТариф.ТарифНаШтуки.ПорогиСтоимости цикл
			если КоличествоШтук>СтрПорогов.Значение тогда 
				ПредыдущееЗначение=СтрПорогов.стоимость;
				Продолжить;
			ИначеЕсли  КоличествоШтук=СтрПорогов.Значение тогда
				СтоимШтук=СтрПорогов.стоимость;
			иначе
				СтоимШтук=ПредыдущееЗначение;
				НашлиСтрочку=Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		
		если НашлиСтрочку=ложь тогда
			СтоимШтук=ТекТариф.ТарифНаШтуки.ПорогиСтоимости.Получить(ТекТариф.ТарифНаШтуки.ПорогиСтоимости.Количество()-1).Стоимость;
		КонецЕсли;	
	Иначе
		СтоимШтук=0;
	КонецЕсли;
	//крохин начало 13.01.2019
	//базовая стоимость не используется + новые реквизиты
	//ИтогоЗаШтуки=СтоимШтук*(ТекТариф.БазоваяСтоимость+СтоимостьКМзаШтуки);
	//крохин начало 03.02.2019
	//ИтогоЗаШтуки = СтоимШтук*КоличествоШтук + СтоимостьКМзаШтуки + СтоимостьАвизацииЗаШтуки + СтоимостьЭкспедированияЗаШтуки+СтоимостьПогрузкиЗаШтуки;
	ИтогоЗаШтуки = СтоимШтук*КоличествоШтук + СтоимостьКМзаШтуки + СтоимостьАвизацииЗаШтуки + СтоимостьЭкспедированияЗаШтуки+СтоимостьПогрузкиЗаШтуки+СтоимостьДоставкиДоТКЗаШтуки*КоличествоШтук;
	//крохин конец 03.02.2019
	//крохин конец 13.01.2019
	
	
	СтоимПаллет=0;
	НашлиСтрочку=ложь;
	ПредыдущееЗначение=0;
	
	если ТекТариф.ТарифНаПаллеты.ПорогиСтоимости.Количество()>0 тогда
		для каждого СтрПорогов из ТекТариф.ТарифНаПаллеты.ПорогиСтоимости цикл
			если КоличествоПаллет>СтрПорогов.Значение тогда 
				ПредыдущееЗначение=СтрПорогов.стоимость;
				Продолжить;
			ИначеЕсли  КоличествоПаллет=СтрПорогов.Значение тогда
				СтоимПаллет=СтрПорогов.стоимость;
				
			иначе
				СтоимПаллет=ПредыдущееЗначение;
				НашлиСтрочку=Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		
		если НашлиСтрочку=ложь тогда
			СтоимПаллет=ТекТариф.ТарифНаПаллеты.ПорогиСтоимости.Получить(ТекТариф.ТарифНаПаллеты.ПорогиСтоимости.Количество()-1).Стоимость;
		КонецЕсли;	
	Иначе
		СтоимПаллет=0;
	КонецЕсли;
	//крохин начало 13.01.2019
	//базовая стоимость не используется + новые реквизиты
	//ИтогоЗаПаллеты=СтоимПаллет*(ТекТариф.БазоваяСтоимость+СтоимостьКМЗаПаллеты);
	//крохин начало 03.02.2019
	//ИтогоЗаПаллеты=СтоимПаллет*КоличествоПаллет+СтоимостьКМЗаПаллеты+СтоимостьАвизацииЗаПаллеты+СтоимостьЭкспедированияЗаПаллеты+СтоимостьПогрузкиЗаПаллеты;
	ИтогоЗаПаллеты=СтоимПаллет*КоличествоПаллет+СтоимостьКМЗаПаллеты+СтоимостьАвизацииЗаПаллеты+СтоимостьЭкспедированияЗаПаллеты+СтоимостьПогрузкиЗаПаллеты+СтоимостьДоставкиДоТКЗаПаллеты*КоличествоПаллет;
	//крохин конец 13.01.2019
	
	
	
	СтоимОбъем=0;
	НашлиСтрочку=ложь;
	ПредыдущееЗначение=0;
	
	если ТекТариф.ТарифНаОбъем.ПорогиСтоимости.Количество()>0 тогда
		для каждого СтрПорогов из ТекТариф.ТарифНаОбъем.ПорогиСтоимости цикл
			если Объем>СтрПорогов.Значение тогда 
				ПредыдущееЗначение=СтрПорогов.стоимость;
				Продолжить;
