Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	//тариф
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланТариф,Справочники.ВидыУслуг.ПланТариф);
	//километраж
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланКилометраж,Справочники.ВидыУслуг.ПланКилометраж);
	//авизация
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланАвизация,Справочники.ВидыУслуг.ПланАвизация);
	//экспедирование
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланЭкспедирование,Справочники.ВидыУслуг.ПланЭкспедирование);
	//погрузка
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланПогрузка,Справочники.ВидыУслуг.ПланПогрузка);
	//доставка до ТК
	СформироватьПроводкиПлановойДоставки(СтоимостьЗаОбъемПланДоставкаДоТК,Справочники.ВидыУслуг.ПланДоставкаДоТК);
КонецПроцедуры

Процедура СформироватьПроводкиПлановойДоставки(РаспределяемаяСтоимость,ВидУслуги)
	//крохин начало 15.04.2019
	Если РаспределяемаяСтоимость = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	//крохин конец 15.04.2019
	ОсталосьРаспределить = РаспределяемаяСтоимость;	
	Для Каждого накл Из СписокНакладных Цикл
		Движение = Движения.ПлановаяСтоимостьДоставки.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения		= ВидДвиженияНакопления.Приход;
		Если  накл.ПунктДоставки.Пустая() Тогда
			Движение.ПунктДоставки = ПунктДоставки;
		Иначе
			Движение.ПунктДоставки = накл.ПунктДоставки;
		КонецЕсли;
		Движение.ВидУслуги = ВидУслуги;
		Движение.Накладная = накл.Документ;
		движение.ДатаОтгрузки=Накл.Документ.ДатаОтгрузки;
		если накл.Документ.метаданные().имя<>"Перемещение" и накл.Документ.метаданные().имя<>"ЗаявкаВТранспортныйОтдел" тогда
			движение.Контрагент=накл.Документ.Контрагент;
			движение.Подразделение=накл.Документ.Подразделение;
		ИначеЕсли накл.Документ.метаданные().имя="ЗаявкаВТранспортныйОтдел" тогда	
			если накл.Документ.отправитель.Метаданные().Имя="Контрагенты" тогда
				движение.Контрагент=накл.Документ.отправитель;
				движение.Подразделение=накл.Документ.Получатель.Подразделение;
			ИначеЕсли накл.Документ.получатель.Метаданные().Имя="Контрагенты" тогда
				движение.Контрагент=накл.Документ.получатель;
				движение.Подразделение=накл.Документ.Отправитель.Подразделение;
			иначе
				движение.Подразделение=накл.Документ.Получатель.Подразделение;				
			КонецЕсли;
			если накл.Документ.Подразделение<>справочники.Подразделения.ПустаяСсылка() тогда
				движение.Подразделение=накл.Документ.Подразделение;
			КонецЕсли;		
		иначе
			движение.Подразделение=накл.Документ.складполучатель.Подразделение;	
		КонецЕсли;
		если накл.Документ.метаданные().имя<>"ЗаявкаВТранспортныйОтдел" тогда 
			движение.СуммаНакладной=Накл.Документ.СуммаДокумента;
		иначе
			движение.СуммаНакладной=0;
		КонецЕсли;
		
		Движение.ПериодРасходов = Дата;
		
		Движение.ОбъемНаладной = накл.Объем;
		
		Движение.КоличествоКоробок = накл.Документ.КоличествоКоробок;
		Движение.КоличествоНакладной = накл.КоличествоШтук;
		Если Объем <> 0 Тогда
			//крохин начало 15.04.2019	
			// Движение.РаспределеннаяСумма = СтоимостьЗаОбъемПлан*((накл.Объем+0.15*Окр(накл.КоличествоПаллет,0))/Объем);
			Движение.РаспределеннаяСумма = РаспределяемаяСтоимость*((накл.Объем+0.15*Окр(накл.КоличествоПаллет,0))/Объем);
			//крохин конец 15.04.2019
		Иначе
			Движение.РаспределеннаяСумма = 0;
		КонецЕсли;
		ОсталосьРаспределить = ОсталосьРаспределить - Движение.РаспределеннаяСумма;
		
	КонецЦикла;
	Если ОсталосьРаспределить <> 0 Тогда
		Движение.РаспределеннаяСумма = Движение.РаспределеннаяСумма + ОсталосьРаспределить;
	КонецЕсли;
	
КонецПроцедуры

