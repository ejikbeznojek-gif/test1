			КонецЕсли;
			
		КонецЕсли;
		//крохин конец 14.02.2019
		
		//крохин начало 03.03.2019
		Если Автомобиль.Пустая() Тогда
			#Если Клиент Тогда
				Сообщить("Не указан автомобиль! Документ ""доставка"" не записан!"); 	
