			ЗапВРег=РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьНаборЗаписей();	
			ЗапВРег.Отбор.ИмяРеквизита.значение="ТарифДоставки";
			ЗапВРег.Отбор.Документ.значение=СписокНакладных[0].Документ;
			ЗапВРег.Отбор.ИмяРеквизита.использование=Истина;
			ЗапВРег.Отбор.Документ.использование=Истина;	
			ЗапВРег.Прочитать();
			для каждого СтрЗР из ЗапВРег цикл
				ТарифДоставки=СтрЗР.ЗначениеРеквизита;
			КонецЦикла;
			
		КонецЕсли;
		//крохин конец 13.09.2019
		
		//крохин начало 14.02.2019
		Если ТарифДоставки.Пустая() Тогда
			Если Объем >= ПунктДоставки.ОбъемДляСменыТарифаНаРегиональный Тогда
				ТарифДоставки = ПунктДоставки.Регион.ТарифДоставки;	
				Если ТарифДоставки.Пустая() Тогда 
					#Если Клиент  Тогда
						Сообщить("Не указан тариф для региона "+ПунктДоставки.Регион+"! Документ ""доставка"" не записан!"); 
						//крохин начало 03.03.2019
						Сообщить("Дата отгрузки "+Формат(ДатаОтгрузки));
						Сообщить("Накладная: " + СписокНакладных[0].Документ);
						//крохин конец 03.03.2019
					#КОНЕЦЕСЛИ
					Отказ = Истина;
				КонецЕсли;
			Иначе
				//крохин начало 29.05.2019
				//ТарифДоставки = ПунктДоставки.ТарифДоставки;
				ЗапВРег=РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьНаборЗаписей();	
				ЗапВРег.Отбор.ИмяРеквизита.значение="ТарифДоставки";
				ЗапВРег.Отбор.Документ.значение=СписокНакладных[0].Документ;
				ЗапВРег.Отбор.ИмяРеквизита.использование=Истина;
				ЗапВРег.Отбор.Документ.использование=Истина;	
				ЗапВРег.Прочитать();
				для каждого СтрЗР из ЗапВРег цикл
					ТарифДоставки=СтрЗР.ЗначениеРеквизита;
				КонецЦикла;
				Если ТарифДоставки.Пустая() Тогда
					ТарифДоставки = ПунктДоставки.ТарифДоставки;
				КонецЕсли;
				//крохин конец 29.05.2019
				Если ТарифДоставки.Пустая() Тогда
					#Если Клиент Тогда
						Сообщить("Не указан тариф для пункта доставки "+ПунктДоставки+"("+ПунктДоставки.Владелец+ ")! Документ ""доставка"" не записан!"); 
