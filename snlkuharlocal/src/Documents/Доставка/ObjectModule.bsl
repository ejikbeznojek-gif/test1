		Если Истина Тогда
			//крохин конец 25.01.2019	
			для каждого СтрТЧ из СписокНакладных цикл
				Накл=СтрТЧ.Документ;
				Если Накл.Метаданные().Имя = "РасходнаяНакладная" ИЛИ Накл.Метаданные().Имя = "Перемещение" Тогда
					ОбъемПаллет=Накл.ОбъемПаллет;
				Иначе
					ОбъемПаллет=0;
				КонецЕсли;;
				//крохин начало 25.01.2019
				//атавизм, плюс в этот момент для нового документа даты ещё нет
				//Если  Дата >= '20180301' и ОбъемПаллет>0 тогда				
				Если ОбъемПаллет > 0 Тогда
					//крохин конец 25.01.2019	
