			//		//	ТекТариф=ПунктДоставки.Регион.ТарифДоставки;
			//		//иначе ТекТариф=Справочники.ТарифыДоставки.ПустаяСсылка();
			//		//КонецЕсли;
			//		//крохин начало 14.02.2019
