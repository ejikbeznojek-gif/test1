Функция ПолучитьПочтовыйОтвет(ПочтовыйЯщик) Экспорт
	
	/// ПочтовыйЯщик - справочник УчетныеЗаписиЭлектроннойПочты
	///	Договорились забирать почту с отдельного ящика
	
	ФлагУспешно = Ложь;
	
	СтруктураВозврата = Новый Структура("КоличествоВложений, ФлагУспешно", 0, ФлагУспешно);
	
	Профиль = Справочники.УчетныеЗаписиЭлектроннойПочты.ПолучитьИнтернетПочтовыйПрофиль(ПочтовыйЯщик);
	
	УстановитьПривилегированныйРежим(Истина);
	
	МассивСообщений = Новый Массив;
	
	Попытка
		
		Почта = Новый ИнтернетПочта;
		Почта.Подключиться(Профиль, ПротоколИнтернетПочты.IMAP);
		
		// Получаем все сообщения из почтового ящика
		МассивСообщений = Почта.Выбрать(Истина,,Истина);
		
	Исключение
		
		// Ошибка при подключении к серверу или при приеме сообщения
		#Если Клиент Тогда
			Сообщить("Ошибка при подключении или приеме" + ОписаниеОшибки());
		#КонецЕсли
		ЗаписатьВЛог("Подключение к эл.почте","Ошибка при подключении или приеме" + ОписаниеОшибки(),"Ошибка");
		УстановитьПривилегированныйРежим(Ложь);
		Возврат СтруктураВозврата;
		
	КонецПопытки;
	
	Если МассивСообщений.Количество() = 0 Тогда
		// Сообщений в почтовом ящике нет
		Почта.Отключиться();
		УстановитьПривилегированныйРежим(Ложь);
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если МассивСообщений.Количество() > 0 Тогда 
		
		//Тимофеев Ю.А. 15.08.2023 Начало
		//если сообщения найдены - отправим их копии ОВЛ
		//Создадим профиль для отправки копии сообщения
		
		ПочтовыйПрофиль = Новый ИнтернетПочтовыйПрофиль;
		ПараметрыПочты  = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
		ЗаполнитьЗначенияСвойств(ПочтовыйПрофиль,ПараметрыПочты);
		ПочтаОтправка   = Новый ИнтернетПочта();
		
		//Тимофеев Ю.А. 15.08.2023 Конец

		
		
		Индекс = 0;
		Для Каждого Сообщение ИЗ МассивСообщений Цикл
			// Перебираем вложения письма
			Для Каждого Вложение Из Сообщение.Вложения Цикл
				Попытка
					Вложение.Данные.Записать(КаталогВременныхФайлов() + "ЗаявкаНаДоставку_" + Строка(Индекс) + ".xlsx");
					Индекс = Индекс + 1;
					ФлагУспешно = Истина;
				Исключение
					СообщитьИзМодуля(ОписаниеОшибки());
					ФлагУспешно = Ложь;
				КонецПопытки;
			КонецЦикла;
			
			
			//Тимофеев Ю.А. 15.08.2023 Начало  
			//переименуем тему соообщения добавим приставку - [АВТОБОТ-ПЕРЕСЫЛКА] 
			//заменим получателей на - ПочтовыйЯщик.АдресЭлектроннойПочты - /Учетная запись обмена с ТК  ovlexchangetk@collant.ru
			
			//Если Найти(Сообщение.Тема,"[ПЕРЕСЫЛКА-АВТОБОТ]") =0 Тогда   //Тимофеев Ю.А. 13.02.2024 /чтобы не циклились сообщения
			//	
			//	ПочтаОтправка.Подключиться(ПочтовыйПрофиль);
			//	Сообщение.Тема       ="[ПЕРЕСЫЛКА-АВТОБОТ] "+Сообщение.Тема; 
			//	
			//	Сообщение.Получатели.Очистить();
			//	//Сообщение.Получатели.Добавить(ПочтовыйЯщик.АдресЭлектроннойПочты);  //Учетная запись обмена с ТК  ovlexchangetk@collant.ru     
			//	Сообщение.Получатели.Добавить("ovlto@collant.ru");     //Тимофеев Ю.А. 13.02.2024
			//	 
			//	Попытка 
			//		ПочтаОтправка.Послать(Сообщение);			
			//	Исключение 
			//		Сообщить(ОписаниеОшибки()); 				 
			//	КонецПопытки; 	
			//	
			//КонецЕсли;
			
		КонецЦикла;
	

		
		//Тимофеев Ю.А. 15.08.2023 Конец

		
		
		
		Если ФлагУспешно Тогда
			Почта.УдалитьСообщения(МассивСообщений);
		КонецЕсли;
		
		Почта.Отключиться(); 
		
		//Тимофеев Ю.А. 15.08.2023 Начало
		ПочтаОтправка.Отключиться();
		//Тимофеев Ю.А. 15.08.2023 Начало

		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	СтруктураВозврата.Вставить("КоличествоВложений", Индекс);
	СтруктураВозврата.Вставить("ФлагУспешно", ФлагУспешно);
	
	Возврат СтруктураВозврата;

	
КонецФункции

Функция ОбработатьПочтовыйОтвет() Экспорт
	
	МассивФайловВложений = НайтиФайлы(КаталогВременныхФайлов(), "ЗаявкаНаДоставку_*.xlsx");
	МассивКУдалению = Новый Массив;
	
	Если МассивФайловВложений.Количество() > 0 Тогда
		
		Для Каждого Файл ИЗ МассивФайловВложений Цикл
			
			///////// ПРОЧИТАЕМ ФАЙЛЫ ЭКСЕЛЬ ////////////////////////////////////////////
			
			ТабДок = Новый ТабличныйДокумент;
			Попытка
				ТабДок.Прочитать(Файл.ПолноеИмя);
			Исключение
				СообщитьИзМодуля(ОписаниеОшибки());
				Продолжить;
			КонецПопытки;
	
			ОбластиТаб = ТабДок.Область(4, 1, 5, 7);
	
			Построитель = Новый ПостроительЗапроса;
			Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластиТаб);  
			Построитель.Выполнить();
	
			ТабДанные = Построитель.Результат.Выгрузить();			
			
			/////////////////////////////////////////////////////////////////////////////
			
			Если ТабДанные.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			НомерДокумента = СокрЛП(ТабДанные[0].НомерДокумента);
			КодПолучателя = СокрЛП(ТабДанные[0].КодПолучателя);
			
			СуммаИзЭксельСтрокой = СокрЛП(ТабДанные[0].Сумма);
			Попытка
				СуммаИзЭксель = Число(СуммаИзЭксельСтрокой);
			Исключение
				СуммаИзЭксель = 0;
			КонецПопытки;
			
			Если СокрЛП(НомерДокумента) = "" Тогда
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("НомерДокумента", НомерДокумента);
			Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ЗаявкаНаДоставку.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
			|ГДЕ
			|	ЗаявкаНаДоставку.Номер = &НомерДокумента
			|	И НЕ ЗаявкаНаДоставку.ПометкаУдаления
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗаявкаНаДоставку.Дата УБЫВ";
			
			УстановитьПривилегированныйРежим(Истина);
			Выборка = Запрос.Выполнить().Выбрать();
			УстановитьПривилегированныйРежим(Ложь);
			
			Если Выборка.Следующий() Тогда
				
				ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
				Если ДокОбъект <> Неопределено И КодПолучателя <> "" И СуммаИзЭксель <> 0 Тогда
					
					ФлагСохранять = Ложь;
					
					Запрос.УстановитьПараметр("КодПолучателя", КодПолучателя);
					Запрос.Текст =
					"ВЫБРАТЬ ПЕРВЫЕ 1
					|	ЕСТЬNULL(Контрагенты.Ссылка, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Получатель
					|ИЗ
					|	Справочник.Контрагенты КАК Контрагенты
					|ГДЕ
					|	Контрагенты.Код = &КодПолучателя
					|	И НЕ Контрагенты.ПометкаУдаления
					|	И НЕ Контрагенты.ЭтоГруппа";
					
					УстановитьПривилегированныйРежим(Истина);
					ВыборкаКонтрагент = Запрос.Выполнить().Выбрать();
					УстановитьПривилегированныйРежим(Ложь);
					
					Получатель = Справочники.Контрагенты.ПустаяСсылка();
					Если ВыборкаКонтрагент.Следующий() Тогда
						Получатель = ВыборкаКонтрагент.Получатель;
					КонецЕсли;
					
					НайденныеСтроки = ДокОбъект.ПолучателиПредложения.НайтиСтроки(Новый Структура("Получатель", Получатель));
					
					Если НайденныеСтроки.Количество() > 0 Тогда 
						Для Каждого НайденнаяСтрока ИЗ НайденныеСтроки Цикл
							НайденнаяСтрока.ПредложеннаяПолучателемСумма = СуммаИзЭксель;
							ФлагСохранять = Истина;
						КонецЦикла;
					Иначе
						НоваяСтрока = ДокОбъект.ПолучателиПредложения.Добавить();
						НоваяСтрока.Получатель = Получатель;
						НоваяСтрока.ПредложеннаяПолучателемСумма = СуммаИзЭксель;
						ФлагСохранять = Истина;
					КонецЕсли;
					
					Если ФлагСохранять Тогда
						Попытка
							ДокОбъект.Записать();
							МассивКУдалению.Добавить(Файл.Имя);
							СообщитьИзМодуля("Изменен документ " + Строка(ДокОбъект.Ссылка));
						Исключение
							СообщитьИзМодуля(ОписаниеОшибки());
						КонецПопытки;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивКУдалению;
	
КонецФункции

Функция УдалитьОбработанныеФайлы(МассивКУдалению) Экспорт
	
	//////// УДАЛИМ УСПЕШНО ОБРАБОТАННЫЕ /////////////////////////////////////
	
	Удалено = Ложь;
	Если МассивКУдалению.Количество() > 0 Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		Для Каждого ИмяФайла ИЗ МассивКУдалению Цикл
			Попытка
				УдалитьФайлы(КаталогВременныхФайлов(), ИмяФайла);
				Удалено = Истина;
			Исключение
				СообщитьИзМодуля("Не могу удалить " + ИмяФайла);
				Удалено = Ложь;
			КонецПопытки;
		КонецЦикла;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;
	
	Возврат Удалено;
	
КонецФункции

