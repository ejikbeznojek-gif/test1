// ПАРАМЕТРЫ: СохранятьВФайл = Ложь, Заголовок = ""
Функция ПечатьДокумента(ДокументСсылка, ПараметрыПечати = Неопределено) Экспорт
	
	СтруктураВозврата = Новый Структура("Успешно, ИмяФайла", Ложь, "");
	
	СхемаКомпоновкиДанных = ПолучитьМакет("Макет");
	Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	
	ЭлементПараметраДанных = Настройки.ПараметрыДанных.Элементы.Найти("Ссылка");
	
	Если ЭлементПараметраДанных = Неопределено Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ЭлементПараметраДанных.Значение = ДокументСсылка;
	ЭлементПараметраДанных.Использование = Истина;
	
	ЭлементПараметраДанных = Настройки.ПараметрыДанных.Элементы.Найти("НомерДокумента");
	Если ЭлементПараметраДанных <> Неопределено Тогда
		ЭлементПараметраДанных.Значение = ?(ПараметрыПечати = Неопределено, СокрЛП(ДокументСсылка.Номер), ПараметрыПечати.НомерДокумента);
		ЭлементПараметраДанных.Использование = Истина;
	КонецЕсли;
	
	ЭлементПараметраДанных = Настройки.ПараметрыДанных.Элементы.Найти("КодПолучателя");
	Если ЭлементПараметраДанных <> Неопределено Тогда
		ЭлементПараметраДанных.Значение = ?(ПараметрыПечати = Неопределено, "", ПараметрыПечати.КодПолучателя);
		ЭлементПараметраДанных.Использование = Истина;
	КонецЕсли;
	
	ЭлементПараметраДанных = Настройки.ПараметрыДанных.Элементы.Найти("АдресСклада");
	Если ЭлементПараметраДанных <> Неопределено Тогда
		ЭлементПараметраДанных.Значение = ?(ПараметрыПечати = Неопределено,
			СокрЛП(Константы.УзелТранспортногоОтдела.Получить().Подразделение.ОсновнойСклад.Адрес), ПараметрыПечати.АдресСклада);
		ЭлементПараметраДанных.Использование = Истина;
	КонецЕсли;
	
	Счетчик = ?(ПараметрыПечати = Неопределено, 0, ПараметрыПечати.Счетчик);
	
	ЗначениеПараметра = Настройки.ПараметрыВывода.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Title"));

	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("Заголовок") Тогда
		ЗначениеПараметра.Значение = ?(ПараметрыПечати.Заголовок = "", Строка(ДокументСсылка), ПараметрыПечати.Заголовок);
	Иначе
		ЗначениеПараметра.Значение = Строка(ДокументСсылка);
	КонецЕсли;
	ЗначениеПараметра.Использование = Истина;

	КомпоновщикМакета	= Новый КомпоновщикМакетаКомпоновкиДанных;
	ДанныеРасшифровки	= Новый ДанныеРасшифровкиКомпоновкиДанных;	
	МакетКомпоновки		= КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);
	
	ДокументРезультат = Новый ТабличныйДокумент;
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки, Истина);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	АдресРасшифровки = ПоместитьВоВременноеХранилище(ДанныеРасшифровки, Новый УникальныйИдентификатор);
	
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("СохранятьВФайл") Тогда
		ИмяФайла = КаталогВременныхФайлов() + "ЗаявкаНаДоставку_" + СокрЛП(ДокументСсылка.Номер) + "_" + Строка(Счетчик) + ".xlsx";
		ДокументРезультат.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLSX);
		СтруктураВозврата.Вставить("Успешно", Истина);
		СтруктураВозврата.Вставить("ИмяФайла", ИмяФайла);
	Иначе
	    ЗаполнениеДокументов.НапечататьТабличныйДокумент(ДокументРезультат,,,"Накладные", , ,АдресРасшифровки);
		СтруктураВозврата.Вставить("Успешно", Истина);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

//Функция ОтправитьПредложениеВТК(ДокументСсылка) Экспорт
//Тимофеев Ю.А. 10.08.23 ПредпросмотрПисмьма - вывод письма на экран

Функция ОтправитьПредложениеВТК(ДокументСсылка,ПредпросмотрПисмьма=Ложь) Экспорт
	
	ФлагОтправлено = Ложь;   
	
	///Тимофеев Ю.А. начало 03.08.2023
	СписокВКопию = "";    
	
	Если ДокументСсылка.КопияПредложения.Количество()>0 Тогда
		СписокВКопию = Новый СписокЗначений;
		Для Каждого Стр ИЗ ДокументСсылка.КопияПредложения Цикл			 
			Если ЗначениеЗаполнено(Стр.ЕмейлПолучателя) Тогда
				СписокВКопию.Добавить(Стр.ЕмейлПолучателя);
			КонецЕсли; 		 
		КонецЦикла;  	 
	КонецЕсли;
	///Тимофеев Ю.А. конец 03.08.2023
	
	
	
	Если ДокументСсылка.ПолучателиПредложения.Количество() Тогда
		
		ПараметрыПечати = Новый Структура("Заголовок, НомерДокумента, КодПолучателя, СохранятьВФайл", "", "", "", Истина);
		
		ТекстПисьма = "Прошу рассмотреть заявку во вложении, заполнить поле Сумма и выслать вложение обратной почтой";
		ТемаПисьма = "Прошу рассмотреть заявку " + СокрЛП(ДокументСсылка.Номер);
		Вложение = Неопределено;
		
		Счетчик = 0;
		
		УчПочтаОтправителя=Справочники.УчетныеЗаписиЭлектроннойПочты.УчетнаяЗаписьОбменаСТК;

		
		Для Каждого Стр ИЗ ДокументСсылка.ПолучателиПредложения Цикл
			
			Если ЗначениеЗаполнено(Стр.ЕмейлПолучателя) Тогда
				
				Заголовок = "Заявка на доставку " + СокрЛП(ДокументСсылка.Номер) + " для контрагента " + СокрЛП(Стр.Получатель);
				
				ПараметрыПечати.Вставить("Заголовок", Заголовок);
				ПараметрыПечати.Вставить("НомерДокумента", СокрЛП(ДокументСсылка.Номер));
				ПараметрыПечати.Вставить("КодПолучателя", ?(Стр.Получатель.Пустая(), "", СокрЛП(Стр.Получатель.Код)));
				ПараметрыПечати.Вставить("Счетчик", Счетчик);
				ПараметрыПечати.Вставить("АдресСклада", СокрЛП(Константы.УзелТранспортногоОтдела.Получить().Подразделение.ОсновнойСклад.Адрес));
				
				СтруктураВозврата = Документы.ЗаявкаНаДоставку.ПечатьДокумента(ДокументСсылка, ПараметрыПечати);
				Если СтруктураВозврата.ИмяФайла <> "" Тогда
					
					
					//Тимофеев Ю.А. 10.08.2023 Начало
					Если ПредпросмотрПисмьма Тогда 
						//выведим форму только на просмотр
						ТП=Новый ТабличныйДокумент;
						ТП.Прочитать(СтруктураВозврата.ИмяФайла);
						ТП.ОтображатьСетку=Ложь;
						ТП.ОтображатьЗаголовки=Ложь;
						ТП.Защита =Истина;
						ВысотаТаб=ТП.ВысотаТаблицы+2;
						ТП.Область(ВысотаТаб,2).Текст="ТОЛЬКО ПРОСМОТР. ЕСЛИ НУЖНО ВНЕСТИ ИЗМЕНЕНИЯ. ЗАКРЫВАЕМ ПЕЧАТНУЮ ФОРМУ и ПРАВИМ ДОКУМЕНТ!";
						ТП.Область(ВысотаТаб,2).ЦветТекста = Новый Цвет(255,0,0);
						ТП.Показать("Проверка письма перед отправкой.Правки вносим строго в документе !");						
						Возврат Ложь;
					КонецЕсли;  					
					//Тимофеев Ю.А. 10.08.2023 Конец 					
					
					
					///Тимофеев Ю.А. начало 03.08.2023
					//добавим еще один параметр
					//СформироватьВнутреннееУведомление(СокрЛП(Стр.ЕмейлПолучателя), ТекстПисьма, ТемаПисьма, ДокументСсылка,
					//	, СтруктураВозврата.ИмяФайла, Справочники.УчетныеЗаписиЭлектроннойПочты.УчетнаяЗаписьОбменаСТК); 
										
					СформироватьВнутреннееУведомление(СокрЛП(Стр.ЕмейлПолучателя), ТекстПисьма, ТемаПисьма, ДокументСсылка,
					, СтруктураВозврата.ИмяФайла, УчПочтаОтправителя,СписокВКопию,Счетчик); 
					
					///Тимофеев Ю.А. конец 17.08.2023  добавим счетчик для записи регистра
					
					///Тимофеев Ю.А. конец 03.08.2023
						
					ФлагОтправлено = Истина;
					Счетчик = Счетчик + 1;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Кухарь А.Ю.  05.06.2023 начало
	//
	Параметры=новый ТаблицаЗначений;
	Параметры.Колонки.Добавить("Имя");
	Параметры.Колонки.Добавить("Значение");
	СтрТЗ=Параметры.Добавить();
	СтрТЗ.Имя="Обработка";
	СтрТЗ.Значение="ОбработатьПисьмаНаОтправку";
	
	СтрТЗ=Параметры.Добавить();
	СтрТЗ.Имя="ОтборПоДокументу";
	СтрТЗ.Значение=ДокументСсылка;

	МассивПараметров=новый Массив;
	МассивПараметров.Добавить(Параметры);
	ФоновыеЗадания.Выполнить("Регламент.ВнешнееЗадание",МассивПараметров,новый УникальныйИдентификатор,"Отправка писем по  "+ДокументСсылка);
	// Кухарь А.Ю.  05.06.2023 конец
	
	
	Возврат ФлагОтправлено;
	
	
КонецФункции


///Тимофеев Ю.А. конец 09.08.2023
//При отработки документа - отправка результата тендера
//ФлагОтправки - булево - Истина - всем, Ложь - только Победителю

Процедура ОтправитьРезультатТендера(ДокументСсылка,ФлагОтправки) Экспорт
		
	СписокВКопию = "";    
	
	Если ДокументСсылка.КопияПредложения.Количество()>0 Тогда
		СписокВКопию = Новый СписокЗначений;
		Для Каждого Стр ИЗ ДокументСсылка.КопияПредложения Цикл			 
			Если ЗначениеЗаполнено(Стр.ЕмейлПолучателя) Тогда
				СписокВКопию.Добавить(Стр.ЕмейлПолучателя);
			КонецЕсли; 		 
		КонецЦикла;  	 
	КонецЕсли;
	
	Если ДокументСсылка.ПолучателиПредложения.Количество() Тогда
		
		//победитель тендера		
		ТекстПисьмаП = "Вы назначены перевозчиком по - Заявка на доставку " + СокрЛП(ДокументСсылка.Номер);
		ТемаПисьмаП  = "Тендер завершен. Вы назначены перевозчиком !";
		//участник  тендера
		ТекстПисьма = "Спасибо за участие в тендере "+ СокрЛП(ДокументСсылка.Номер);
		ТемаПисьма  = "Тендер завершен. Заявку выполняет другой перевозчик";

		УчПочтаОтправителя=Справочники.УчетныеЗаписиЭлектроннойПочты.УчетнаяЗаписьОбменаСТК;
		
		Счетчик=0;
		
		Для Каждого Стр ИЗ ДокументСсылка.ПолучателиПредложения Цикл
			
			Если ЗначениеЗаполнено(Стр.ЕмейлПолучателя) Тогда 			
				
				Если Стр.ПредложениеПринято Тогда //победитель тендера		
					
					СформироватьВнутреннееУведомление(СокрЛП(Стр.ЕмейлПолучателя), ТекстПисьмаП, ТемаПисьмаП, ДокументСсылка,
					, Неопределено,УчПочтаОтправителя,СписокВКопию,Счетчик); 
					
				Иначе
					
					Если ФлагОтправки Тогда   //участник  тендера
						
						СформироватьВнутреннееУведомление(СокрЛП(Стр.ЕмейлПолучателя), ТекстПисьма, ТемаПисьма, ДокументСсылка,
						,Неопределено, УчПочтаОтправителя,СписокВКопию,Счетчик);
						
					КонецЕсли;
					
				КонецЕсли;    				
				
			КонецЕсли;
			Счетчик=Счетчик+1;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Кухарь А.Ю.  05.06.2023 начало
	//
	Параметры=новый ТаблицаЗначений;
	Параметры.Колонки.Добавить("Имя");
	Параметры.Колонки.Добавить("Значение");
	СтрТЗ=Параметры.Добавить();
	СтрТЗ.Имя="Обработка";
	СтрТЗ.Значение="ОбработатьПисьмаНаОтправку";
	
	СтрТЗ=Параметры.Добавить();
	СтрТЗ.Имя="ОтборПоДокументу";
	СтрТЗ.Значение=ДокументСсылка;

	МассивПараметров=новый Массив;
	МассивПараметров.Добавить(Параметры);
		
	ФоновыеЗадания.Выполнить("Регламент.ВнешнееЗадание",МассивПараметров,новый УникальныйИдентификатор,"Отправка писем по  "+ДокументСсылка); //ТЮА
		
	// Кухарь А.Ю.  05.06.2023 конец
	          	
КонецПроцедуры

