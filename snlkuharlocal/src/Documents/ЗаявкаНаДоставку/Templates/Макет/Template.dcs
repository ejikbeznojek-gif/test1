		<group>ПунктДоставки</group>
	</totalField>
	<totalField>
		<dataPath>НомерСтроки</dataPath>
		<expression>Максимум(НомерСтроки)</expression>
	</totalField>
	<totalField>
		<dataPath>ВремяРазгрузки</dataPath>
		<expression>ВремяРазгрузки</expression>
	</totalField>
	<totalField>
		<dataPath>ВремяОтгрузки</dataPath>
		<expression>Максимум(ВремяОтгрузки)</expression>
	</totalField>
