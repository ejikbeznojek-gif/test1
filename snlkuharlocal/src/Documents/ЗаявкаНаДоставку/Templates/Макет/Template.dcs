				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Накладные.НомерСтроки КАК НомерСтроки,
	Накладные.Накладная КАК Накладная,
	Накладные.Получатель КАК Получатель,
	Накладные.ПунктДоставки КАК ПунктДоставки,
	Накладные.АдресПолучателя КАК АдресПолучателя,
	Накладные.ДатаПриемки КАК ДатаПриемки,
	Накладные.ВремяПриемки КАК ВремяПриемки,
	Накладные.КоличествоНакладной КАК КоличествоНакладной,
	Накладные.СуммаНакладной КАК СуммаНакладной,
	Накладные.ОбъёмНакладной КАК ОбъёмНакладной,
	Накладные.Ссылка КАК Ссылка,
	Накладные.Ссылка.ДатаОтгрузки КАК ДатаОтгрузки,
	Накладные.Ссылка.ВремяОтгрузки КАК ВремяОтгрузки,
	Накладные.ВремяРазгрузки КАК ВремяРазгрузки,
	Накладные.КоличествоПаллет КАК КоличествоПаллет,
	Накладные.КоличествоПаллетАвтомобиль КАК КоличествоПаллетАвтомобиль
ИЗ
	Документ.ЗаявкаНаДоставку.Накладные КАК Накладные
ГДЕ
	Накладные.Ссылка = &amp;Ссылка</query>
	</dataSet>
	<calculatedField>
		<dataPath>НомерВыгрузки</dataPath>
		<expression>"Выгрузка " + Строка(НомерСтроки)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Номер выгрузки</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:string</v8:Type>
			<v8:StringQualifiers>
				<v8:Length>0</v8:Length>
				<v8:AllowedLength>Variable</v8:AllowedLength>
			</v8:StringQualifiers>
		</valueType>
	</calculatedField>
	<totalField>
