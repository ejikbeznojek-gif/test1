<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>Запрос</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаНакладной</dataPath>
			<field>СуммаНакладной</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Накладная</dataPath>
			<field>Накладная</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВремяПриемки</dataPath>
			<field>ВремяПриемки</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Получатель</dataPath>
			<field>Получатель</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПунктДоставки</dataPath>
			<field>ПунктДоставки</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоНакладной</dataPath>
			<field>КоличествоНакладной</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъёмНакладной</dataPath>
			<field>ОбъёмНакладной</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаПриемки</dataPath>
			<field>ДатаПриемки</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>АдресПолучателя</dataPath>
			<field>АдресПолучателя</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерСтроки</dataPath>
			<field>НомерСтроки</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ссылка</dataPath>
			<field>Ссылка</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаОтгрузки</dataPath>
			<field>ДатаОтгрузки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата отгрузки</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоПаллет</dataPath>
			<field>КоличествоПаллет</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество паллет</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоПаллетАвтомобиль</dataPath>
			<field>КоличествоПаллетАвтомобиль</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество паллет автомобиль</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Накладные.НомерСтроки КАК НомерСтроки,
	Накладные.Накладная КАК Накладная,
	Накладные.Получатель КАК Получатель,
	Накладные.ПунктДоставки КАК ПунктДоставки,
	Накладные.АдресПолучателя КАК АдресПолучателя,
	Накладные.ДатаПриемки КАК ДатаПриемки,
	Накладные.ВремяПриемки КАК ВремяПриемки,
	Накладные.КоличествоНакладной КАК КоличествоНакладной,
	Накладные.СуммаНакладной КАК СуммаНакладной,
	Накладные.ОбъёмНакладной КАК ОбъёмНакладной,
	Накладные.Ссылка КАК Ссылка,
	Накладные.Ссылка.ДатаОтгрузки КАК ДатаОтгрузки,
	ЕСТЬNULL(Накладные.Накладная.КоличествоПаллет, 0) КАК КоличествоПаллет,
	ЕСТЬNULL(Накладные.Ссылка.Автомобиль.КоличествоПаллет,0) КАК КоличествоПаллетАвтомобиль
ИЗ
	Документ.ЗаявкаНаДоставку.Накладные КАК Накладные
ГДЕ
	Накладные.Ссылка = &amp;Ссылка</query>
	</dataSet>
	<calculatedField>
		<dataPath>НомерВыгрузки</dataPath>
		<expression>"Выгрузка " + Строка(НомерСтроки)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Номер выгрузки</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:string</v8:Type>
			<v8:StringQualifiers>
				<v8:Length>0</v8:Length>
				<v8:AllowedLength>Variable</v8:AllowedLength>
			</v8:StringQualifiers>
		</valueType>
	</calculatedField>
	<totalField>
		<dataPath>КоличествоНакладной</dataPath>
		<expression>Сумма(КоличествоНакладной)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаНакладной</dataPath>
		<expression>Сумма(СуммаНакладной)</expression>
	</totalField>
	<totalField>
		<dataPath>ОбъёмНакладной</dataPath>
		<expression>Сумма(ОбъёмНакладной)</expression>
	</totalField>
	<totalField>
		<dataPath>АдресПолучателя</dataPath>
		<expression>Максимум(АдресПолучателя)</expression>
		<group>НомерСтроки</group>
	</totalField>
	<totalField>
		<dataPath>ДатаПриемки</dataPath>
		<expression>Максимум(ДатаПриемки)</expression>
		<group>НомерСтроки</group>
	</totalField>
	<totalField>
		<dataPath>ВремяПриемки</dataPath>
		<expression>Максимум(ВремяПриемки)</expression>
		<group>НомерСтроки</group>
	</totalField>
	<totalField>
		<dataPath>ПунктДоставки</dataPath>
		<expression>Максимум(ПунктДоставки)</expression>
		<group>ПунктДоставки</group>
	</totalField>
	<totalField>
		<dataPath>НомерВыгрузки</dataPath>
		<expression>Максимум(НомерВыгрузки)</expression>
		<group>НомерСтроки</group>
	</totalField>
	<totalField>
		<dataPath>Получатель</dataPath>
		<expression>Максимум(Получатель)</expression>
		<group>НомерСтроки</group>
	</totalField>
	<totalField>
		<dataPath>ДатаОтгрузки</dataPath>
		<expression>Максимум(ДатаОтгрузки)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоПаллет</dataPath>
		<expression>Сумма(КоличествоПаллет)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоПаллетАвтомобиль</dataPath>
		<expression>Максимум(КоличествоПаллетАвтомобиль)</expression>
	</totalField>
	<parameter>
		<name>Ссылка</name>
		<title xsi:type="v8:LocalStringType">
