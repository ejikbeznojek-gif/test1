Функция СоздатьЗаданияНабораДляАвторазбивки()	
	ВидНакладной=Накладная.Метаданные().Имя;
	ЭтоКомплектация=(ВидНакладной="РасходнаяНакладная" И ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов","Документ")=Истина) или ВидНакладной="Комплектация"; 
	ИмяТЧНакладной=?(ЭтоКомплектация,"Комплектующие","Товары");
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ТЧ.Номенклатура, ТЧ.Единица, ТЧ.Коэффициент, СУММА(ТЧ.Количество) ПОМЕСТИТЬ ТЧ_Накладной ИЗ Документ."+ВидНакладной+"."+ИмяТЧНакладной+" как ТЧ ГДЕ Ссылка=&Накладная	
	|СГРУППИРОВАТЬ ПО
	|	ТЧ.Номенклатура,
	|ТЧ.Коэффициент,
	|	ТЧ.Единица
	|;
	|ВЫБРАТЬ 
	|	*
	|ПОМЕСТИТЬ ТЧ_ПН
	|ИЗ	
	|	Документ.ПланНабора.тБрэндов 
	|ГДЕ
	|	Ссылка=&Ссылка	
	|;	
	|ВЫБРАТЬ
	|	МИНИМУМ(НомерСтроки) КАК ИД_Строки,
	|	Наборщик,
	|	ЭтоКомплектующие,
	|	ЭтоБлочки
	|ПОМЕСТИТЬ Части_ПН	
	|ИЗ
	|	ТЧ_ПН
	|СГРУППИРОВАТЬ ПО
	|	Наборщик,
	|	ЭтоКомплектующие,
	|	ЭтоБлочки 	
	|;
	|ВЫБРАТЬ
	|	Части_ПН.ИД_Строки,
	|	Части_ПН.Наборщик,	
	|	Части_ПН.ЭтоКомплектующие,
	|	Части_ПН.ЭтоБлочки,
	|
	|	ТЧ_ПН.НомерСтроки 			КАК НомерСтрокиПН,
	|
	|	ТЧ_Накладной.Номенклатура 	КАК Номенклатура,	
	|	ТЧ_Накладной.Единица		КАК Единица,
	|	ВЫБОР 
	|		КОГДА ТЧ_ПН.Коллекция.ЭтоГруппа ТОГДА ТЧ_Накладной.Количество		
	|		ИНАЧЕ ТЧ_ПН.Количество
	|	КОНЕЦ КАК Количество,
	|	ТЧ_Накладной.Коэффициент	КАК Коэффициент
	|ИЗ 
	|	Части_ПН
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ТЧ_ПН  
	|ПО
	|	Части_ПН.Наборщик			= ТЧ_ПН.Наборщик
	|	И Части_ПН.ЭтоКомплектующие	= ТЧ_ПН.ЭтоКомплектующие
	|	И Части_ПН.ЭтоБлочки		= ТЧ_ПН.ЭтоБлочки
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ТЧ_Накладной
	|ПО
	|	ВЫБОР 
	|		КОГДА ТЧ_ПН.Коллекция.ЭтоГруппа ТОГДА ТЧ_Накладной.Номенклатура.Родитель.Родитель 
	|		ИНАЧЕ ТЧ_Накладной.Номенклатура
	|	КОНЕЦ = ТЧ_ПН.Коллекция
	|ГДЕ
	|	ТЧ_Накладной.Количество>0
	|УПОРЯДОЧИТЬ ПО 
	|	Части_ПН.ИД_Строки,
	|	ТЧ_ПН.НомерСтроки
	|ИТОГИ 
	|	МАКСИМУМ(Части_ПН.Наборщик),
	|	МАКСИМУМ(Части_ПН.ЭтоКомплектующие),
	|	МАКСИМУМ(Части_ПН.ЭтоБлочки) 
	|ПО 
	|	Части_ПН.ИД_Строки	
	|";
	
	Запрос.УстановитьПараметр("Ссылка",		Ссылка);
	Запрос.УстановитьПараметр("Накладная",	Накладная);
	
	Если ВидНакладной="Перемещение" Тогда
		Получатель=ПолучитьРеквизитШапки(Накладная,"СкладПолучатель","Документ");
	Иначе
		Получатель=ПолучитьРеквизитШапки(Накладная,"Контрагент","Документ");
	КонецЕсли;	
	
	Сч=0;
	ВыборкаПоЧастям=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ИД_Строки");
	Пока ВыборкаПоЧастям.Следующий() Цикл
		Сч=Сч+1;	
		Задание						= НайтиСоздатьЗаданиеИзМодуля(Сч);	
		Задание.Накладная			= Накладная;
		// Кухарь А.Ю. 29.07.2020 начало
		// Задание.СостояниеНакладной	= Перечисления.СостоянияНакладной.СформированыЗаданияНабора;	
		Задание.СостояниеНакладной	= Перечисления.СостоянияНакладной.ОжиданиеНабора;	 
		// Кухарь А.Ю. 29.07.2020 конец
		
		Задание.Дата				= ТекущаяДата();
		Задание.Склад				= Склад;
		Задание.Получатель			= Получатель;
		Задание.ПометкаУдаления		= Ложь;
		Задание.Автор				= ПараметрыСеанса.Пользователь;			
		Задание.ЭтоКомплектующие	= ВыборкаПоЧастям.ЭтоКомплектующие;
		Задание.ЭтоБлочки			= ВыборкаПоЧастям.ЭтоБлочки;		
		Задание.Товары.Очистить();	
		Выборка=ВыборкаПоЧастям.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ=Задание.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,Выборка);				
			тБрэндов[Выборка.НомерСтрокиПН-1].НомерЧасти=Сч;
		КонецЦикла;		
		
		Задание.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;	
	
КонецФункции // ()

Функция НайтиСоздатьЗаданиеИзМодуля(НомерЧасти)
	СтруктураПоиска	= Новый Структура("ДокументОснование,НомерЧасти",Ссылка,НомерЧасти);
	Задание			= НайтиДокумент("ЗаданиеНабора",СтруктураПоиска);
	Если Задание.Пустая() Тогда
		ДокОбъект=Документы.ЗаданиеНабора.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(ДокОбъект,СтруктураПоиска);
	Иначе
		ДокОбъект=Задание.ПолучитьОбъект();
	КонецЕсли;	
	
	Возврат ДокОбъект;
КонецФункции //НайтиСоздатьЗадание(НомерЧасти)

