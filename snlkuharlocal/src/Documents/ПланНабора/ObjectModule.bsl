			КоличествоВКоробках=Цел(СтрокаТБ.Количество/ШтукВКоробке)*ШтукВКоробке;
			
			// Кухарь А.Ю.  06.11.2024 начало
			КоличествоДляНаборовОбщее=СтрокаТБ.КоличествоДляНаборов;
