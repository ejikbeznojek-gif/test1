				//	КоробкиОбъемы=ПолучитьКоробкиОбъемыПоПереукладке();					
				//	
				//	РеквизитыОснования.Вставить("КоличествоКоробок",	КоробкиОбъемы.КоличествоКоробок);
				//	РеквизитыОснования.Вставить("ОбъемКоробов",			КоробкиОбъемы.ОбъемДокумента);
				//	//кухарь 08.09.14 начало
				//	//запись количества коробок и объёма коробок в регистр, чтобы уйти от реквизитов
				//	
				//	ЗаписатьКоличествоИОбъемКоробовВРегистр(ДокОснование,КоробкиОбъемы.КоличествоКоробок,КоробкиОбъемы.ОбъемКоробов);
				//	
				//	//кухарь 08.09.14 конец					
				//КонецЕсли;
				//Кухарь 16.12.19 конец
				
				// Кухарь А.Ю. 24.08.2020 начало
				// Товар не сканируют
				если не СозданоОбработкойПополнения тогда 
					// Кухарь А.Ю. 24.08.2020 конец
					
					РезультатПроверки=ЕстьОшибкиНабора();
					Если РезультатПроверки.ЕстьОшибки тогда
						//++Данилова Е.В. 05.03.2026 SNL-153
						ВидЛиста = ?(РезультатПроверки.ИспользоватьЛНТолькоДляНабора,"ЛП","ЛН"); 
						ТекстСообщения = СтрШаблон("Не совпадает количество из накладной и из %1. В накладной - %2,в %1 - %3",ВидЛиста,РезультатПроверки.КоличествоВНакладной,РезультатПроверки.КоличествоВЛН); 
						Сообщить (ТекстСообщения,СтатусСообщения.Важное);
						//Сообщить ("Не совпадает количество из накладной и из ЛН. В накладной - "+РезультатПроверки.КоличествоВНакладной+", в ЛН - "+РезультатПроверки.КоличествоВЛН,СтатусСообщения.Важное);
						//--Данилова Е.В. 05.03.2026 
						Возврат;
					КонецЕсли;	
					// Кухарь А.Ю. 24.08.2020 начало
					//
				КонецЕсли; 
				// Кухарь А.Ю. 24.08.2020 конец
				
			КонецЕсли;
			//кухарь 02.09.14 конец			
			
			//Кухарь 08.11.17 начало
			//заполнение плана набора ошибками набора
			ЗаполнитьОшибкамиНабора();	
			
			УстановитьРеквизитыОбъекта(ДокОснование,РеквизитыОснования,,Истина); 
			// Кухарь А.Ю. 03.05.2024 начало
			//
			// Кухарь А.Ю.  25.04.2024 начало
			//
			если ТипЗнч(ДокОснование)=Тип("ДокументСсылка.РасходнаяНакладная") и ДокОснование.ТребуетсяМаркировка и ВсеГотовы тогда
				// Кухарь А.Ю.  24.02.2025 начало
				//РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_РНК(ДокОснование);
				//если не РезультатРаботыСХКМ.Успешно тогда
				//	РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
				//	СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				//	отказ=Истина;	
				//КонецЕсли;
				ДокОснованиеОбъект=ДокОснование.ПолучитьОбъект();
				Результат=ДокОснованиеОбъект.СозданиеДокументовЧЗ();
				если не Результат тогда
					отказ=Истина;
				КонецЕсли;
				// Кухарь А.Ю.  24.02.2025 конец
				
			КонецЕсли;
			// Кухарь А.Ю.  25.04.2024 конец
			
			// Кухарь А.Ю. 03.05.2024 конец
			
		КонецЕсли;
		
		Если МоноСостояние=Перечисления.СостоянияНакладной.Отгружена И НЕ Отказ Тогда
			НомераЧастей=тБрэндов.Выгрузить(,"НомерЧасти");
			НомераЧастей.Свернуть("НомерЧасти");	
			
			Для Каждого СтрокаТЗ Из НомераЧастей Цикл
				ЗаданиеНабора=НайтиДокумент("ЗаданиеНабора",Новый Структура("ДокументОснование,НомерЧасти,Проведен",Ссылка,СтрокаТЗ.НомерЧасти,Истина));
				Если ЗначениеЗаполнено(ЗаданиеНабора) Тогда
					ЗаданиеНабора_Объект=ЗаданиеНабора.ПолучитьОбъект();				
					ЗаданиеНабора_Объект.СостояниеНакладной=МоноСостояние;
					ЗаданиеНабора_Объект.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;				
			КонецЦикла; 					
		КонецЕсли; 
	КонецЕсли;
	
	//крохин конец 11.12.2013
	//Кухарь 13.09.16 начало	
	Если НЕ Отказ Тогда
		Отбор=Новый Структура("Состояние",Перечисления.СостоянияНакладной.ОжиданиеНабора);
		ОсталосьНабратьСтрок=тБрэндов.НайтиСтроки(Отбор).Количество();
		
		Отбор.Состояние=Перечисления.СостоянияНакладной.ОжиданиеСканирования;
		ОсталосьОтсканироватьСтрок=тБрэндов.НайтиСтроки(Отбор).Количество();
		
		Отбор.Состояние=Перечисления.СостоянияНакладной.ОжиданиеДопОбработки;		
		ОсталосьДопОбработатьСтрок=тБрэндов.НайтиСтроки(Отбор).Количество();
	КонецЕсли;
	//Кухарь 13.09.16 конец	
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	
	Если НЕ ЗначениеЗаполнено(Основание) Тогда Возврат КонецЕсли;
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	
	ДокОснование	= Основание;
	Накладная 		= ДокОснование;
	
	ВидОснования	= ДокОснование.Метаданные().Имя;
	
	ИБ			 	= ДокОснование.ИБ;
	Склад			= ДокОснование.Склад;
	
	СобиратьНаТСД = Истина; // Кельманов А.В. - HELP-6542 - 2025.08.13
	
	// Кухарь А.Ю.  21.04.2025 начало
	ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);
	РаспределятьРасходныеМатериалы=ложь;
	если ДопПараметрыНакладной.НаборыЧЗбезОклейкиКомплектующих или ДопПараметрыНакладной.ОтгрузкаFBS тогда
		РаспределятьРасходныеМатериалы=Истина;
	КонецЕсли;
	ЗаполнитьТаблицуБрэндов(РаспределятьРасходныеМатериалы);	
	// Кухарь А.Ю.  21.04.2025 конец
	
	// Кельманов А.В. - HELP-6558 - 2025.08.19 {
	//// Шворобей ВЮ 05.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5266
	//ТЗ_Брэндов = Документы.ПланНабора.ЗаполнитьСлужебногоНаборщикаFBS(тБрэндов.Выгрузить());
	//тБрэндов.Загрузить(ТЗ_Брэндов);	
	//// Шворобей ВЮ 05.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5266
	ТЗ_Наборщики = Документы.ПланНабора.ЗаполнитьСлужебногоНаборщикаFBS(тБрэндов.Выгрузить());
	Для Каждого Стр ИЗ ТЗ_Наборщики Цикл
		НайденныеСтроки = тБрэндов.НайтиСтроки(Новый Структура("Брэнд, Коллекция", Стр.Брэнд, Стр.Коллекция));
		Для Каждого НСтр ИЗ НайденныеСтроки Цикл
			Если НЕ ЗначениеЗаполнено(НСтр.Наборщик) Тогда
				НСтр.Наборщик = Стр.СлужебныйНаборщик;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	// Кельманов А.В. - HELP-6558 - 2025.08.19 }
	
	Если ВидОснования = "Перемещение" Тогда
		Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			СкладПользователя=ПолучитьЗначениеПоУмолчанию("ОсновнойСклад");
			Если СкладПользователя<>Неопределено И НЕ СкладПользователя.Пустая() Тогда
				Если ДокОснование.Склад=СкладПользователя Тогда
					//оставляем как есть склад документа
				ИначеЕсли ДокОснование.СкладПолучатель=СкладПользователя Тогда
					Склад = ДокОснование.СкладПолучатель;
				КонецЕсли; 			
			Иначе				
				Если ДокОснование.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					//если для полдьзователя не задан склад то считаем что лист набора на отгрузку 
					//оставляем как есть склад документа
				ИначеЕсли ДокОснование.СкладПолучатель.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					Склад = ДокОснование.СкладПолучатель;									
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)	
КонецПроцедуры

Функция ВсеНаборщикиЗаполнены() Экспорт
	Для Каждого ТекСтрока из тБрэндов Цикл		
		Если ТекСтрока.Наборщик.Пустая() Тогда
			Возврат Ложь;
		КонецЕсли;		
	КонецЦикла;
	Возврат Истина;
КонецФункции // ()


//Кухарь 05.10.17 начало
//Заполнение количества коробок, блочков и штучек в плане набора
Процедура ЗаполнитьКоличестваПоТипамШК()  экспорт
	ЕстьРазбивка=(тБрэндов.Количество()>0 И НЕ тБрэндов[0].Коллекция.ЭтоГруппа);
	
	Для Каждого СтрТЧ Из тБрэндов Цикл
		СтрТЧ.КоличествоКоробок	= 0;
		СтрТЧ.КоличествоБлочков	= 0;
		СтрТЧ.КоличествоШтук	= 0;	
	КонецЦикла;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ТипШК,
	|	Номенклатура.Родитель.Родитель КАК Номенклатура,
	|	СУММА(ВЫБОР КОГДА ТипШК=ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка) 	ТОГДА Количество ИНАЧЕ 0 КОНЕЦ)		КАК КоличествоКоробок,
	|	СУММА(ВЫБОР КОГДА ТипШК=ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок) 	ТОГДА Количество ИНАЧЕ 0 КОНЕЦ) 	КАК КоличествоБлочков,
	|	СУММА(ВЫБОР КОГДА ТипШК=ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука) 	ТОГДА Количество ИНАЧЕ 0 КОНЕЦ) 	КАК КоличествоШтук,
	|	СУММА(Количество) КАК Количество	
	|ИЗ
	|	Документ.ЛистНабора.Товары
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокОснование	
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура.Родитель.Родитель,
	|	ТипШК";
	
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование);	
	
	Если ЕстьРазбивка Тогда
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"Номенклатура.Родитель.Родитель","Номенклатура");
	КонецЕсли;
	
	Результат=Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		Отбор		= Новый Структура("Коллекция",Результат.Номенклатура);
		МассСтрокТЧ	= тБрэндов.НайтиСтроки(Отбор);
		
		Если МассСтрокТЧ.Количество()=1 Тогда
			ТекСтрока=МассСтрокТЧ.Получить(0);
			
			ТекСтрока.КоличествоКоробок	=ТекСтрока.КоличествоКоробок+Результат.КоличествоКоробок;
			ТекСтрока.КоличествоБлочков	=ТекСтрока.КоличествоБлочков+Результат.КоличествоБлочков;
			ТекСтрока.КоличествоШтук	=ТекСтрока.КоличествоШтук	+Результат.КоличествоШтук;			
		Иначе			
			Для Каждого ТекСтрока из МассСтрокТЧ Цикл
				Если ТекСтрока.ЭтоБлочки Тогда
					Если Результат.ТипШК=Перечисления.ТипыШтрихКодов.Блочок Тогда
						ТекСтрока.КоличествоБлочков=ТекСтрока.КоличествоБлочков+Результат.Количество;
					ИначеЕсли Результат.ТипШК=Перечисления.ТипыШтрихКодов.Штука Тогда
						ТекСтрока.КоличествоШтук=ТекСтрока.КоличествоШтук+Результат.Количество;					
					КонецЕсли;
				Иначе
					Если Результат.ТипШК=Перечисления.ТипыШтрихКодов.Коробка Тогда
						ТекСтрока.КоличествоКоробок=ТекСтрока.КоличествоКоробок+Результат.Количество;
					КонецЕсли;					
				КонецЕсли;
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
//Кухарь 05.10.17 конец

//Кухарь 08.11.17 начало
//заполнение плана набора ошибками набора
Процедура ЗаполнитьОшибкамиНабора()	
	ЕстьРазбивка=(тБрэндов.Количество()>0 И тБрэндов[0].Коллекция.ЭтоГруппа);
	
	Запрос=новый запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	//Кухарь 16.12.19 начало
	//При замене текста запроса в  СтрЗаменить(Запрос.Текст,"Номенклатура","Номенклатура.Родитель.Родитель");
	//Меняется псевдоним поля и вываливается с конфигураторной ошибкой
	//|	Номенклатура,
	|	Номенклатура как НОменклатура,	
	//Кухарь 16.12.19 конец	
	|	СУММА(Количество) 				КАК КоличествоНеверноНабранногоТовара,
	|	Ссылка.Наборщик 				КАК Наборщик,
	|	//ЭтоБлочкиПоле			 
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) 	КАК КоличествоОшибок
	|ИЗ
	|	Документ.ЛистНабора.ОшибкиСотрудников
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокОснование
	|	И Ссылка.Проведен
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура,
	|	//ЭтоБлочкиГруппировка
	|	Ссылка.Наборщик";
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	
	Если ЕстьРазбивка тогда
		ТекстПоля	="(Ссылка.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))";
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"//ЭтоБлочкиПоле",		ТекстПоля+" КАК ЭтоБлочки,");		
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"//ЭтоБлочкиГруппировка",	ТекстПоля+",");		
	Иначе		
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"Номенклатура","Номенклатура.Родитель.Родитель");		
	КонецЕсли;
	
	Результат=Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() цикл
		Отбор=новый Структура("Коллекция,Наборщик",Результат.Номенклатура,Результат.Наборщик);
		Если ЕстьРазбивка Тогда
			Отбор.Вставить("ЭтоБлочки",Результат.ЭтоБлочки);			
		КонецЕсли; 
		МассСтрокТЧ=тБрэндов.НайтиСтроки(Отбор);
		Для Каждого СтрокаТЧ из МассСтрокТЧ цикл				
			СтрокаТЧ.КоличествоНеверноНабранногоТовара=Результат.КоличествоНеверноНабранногоТовара;
			СтрокаТЧ.КоличествоОшибок=Результат.КоличествоОшибок;				
		КонецЦикла;
	КонецЦикла;	
КонецПроцедуры
//Кухарь 08.11.17 конец

