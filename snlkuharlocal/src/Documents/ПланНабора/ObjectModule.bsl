					ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ,СтрокаТБ,,"НомерСтроки");
					//--Данилова Е.В. 14.03.2026 
					
					НоваяСтрокаТЧ.Количество 		= СтрокаТБ.Количество - КоличествоВКоробках;
					НоваяСтрокаТЧ.СекторХранения 	= СтрЗаменить(НоваяСтрокаТЧ.СекторХранения,"_блочки","") + "_блочки";
					НоваяСтрокаТЧ.ЭтоБлочки 		= Истина;				
					НоваяСтрокаТЧ.ОбъемКоробов		= РассчитатьОбъемКоробки(НоваяСтрокаТЧ.Количество,ОбъемКоробки,ШтукВКоробке);
					
					СтрокаТБ.Количество			 	= КоличествоВКоробках;
					СтрокаТБ.ОбъемКоробов			= РассчитатьОбъемКоробки(СтрокаТБ.Количество,ОбъемКоробки,ШтукВКоробке);
					
					// Кухарь А.Ю.  06.11.2024 начало
					СтрокаТБ.КоличествоДляНаборов   = КоличествоДляНаборовКороба;
					если СтрокаТБ.КоличествоДляНаборов>0 тогда
						СтрокаТБ.ТребуетсяФормированиеНабораЧЗ=Истина;
					иначе
						СтрокаТБ.ТребуетсяФормированиеНабораЧЗ=Ложь;
					КонецЕсли;			
					
					НоваяСтрокаТЧ.КоличествоДляНаборов   = КоличествоДляНаборовШтуки;
					если НоваяСтрокаТЧ.КоличествоДляНаборов>0 тогда
						НоваяСтрокаТЧ.ТребуетсяФормированиеНабораЧЗ=Истина;
					иначе
						НоваяСтрокаТЧ.ТребуетсяФормированиеНабораЧЗ=Ложь;
					КонецЕсли;									
					// Кухарь А.Ю.  06.11.2024 конец
