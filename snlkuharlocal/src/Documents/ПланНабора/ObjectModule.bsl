Процедура ОбновитьСостоянияЗаявокНабора(ОграничиватьПоСостоянию = Истина) Экспорт
// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 }
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ * ПОМЕСТИТЬ тБрэндов ИЗ &тБрэндов КАК тБрэндов
	|;
	|ВЫБРАТЬ 
	|	НомерЧасти,
	|	МАКСИМУМ(Состояние) КАК Состояние 
	|ИЗ 
	|	тБрэндов 
	|СГРУППИРОВАТЬ ПО 
	|	НомерЧасти 	
	|";	
	Запрос.УстановитьПараметр("тБрэндов",тБрэндов);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл	
		
		// Кухарь А.Ю. 29.01.2020 начало
		// 		Если ПолучитьНомерСостоянияНакладной(Выборка.Состояние)>400 Тогда //После Ожидания набора	
		
		// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 {
		//Если ПолучитьНомерСостоянияНакладной(Выборка.Состояние)>=400 Тогда //иногда ошибочно отдают в набор и хотят вернуть		 
		Если Не ОграничиватьПоСостоянию Или ПолучитьНомерСостоянияНакладной(Выборка.Состояние) >= 400 Тогда 		 
			// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 }
			
			// Кухарь А.Ю. 29.01.2020 конец
			
			//Кухарь 18.12.19 начало
			//Если хоть 1 строчка отгружена, значит отгружена вся накладная
			//Документы.ЗаданиеНабора.УстановитьСостояниеЗадания(Ссылка,Выборка.НомерЧасти,Выборка.Состояние);		
			если Выборка.Состояние=Перечисления.СостоянияНакладной.Отгружена тогда
				Документы.ЗаданиеНабора.УстановитьСостояниеЗадания(Ссылка,Неопределено,Выборка.Состояние);
				Прервать;
			иначе
				Документы.ЗаданиеНабора.УстановитьСостояниеЗадания(Ссылка,Выборка.НомерЧасти,Выборка.Состояние);		
			КонецЕсли;
			//Кухарь 18.12.19 конец
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Кухарь А.Ю. 15.01.2020 начало
// для обработки смены состояния путём сканирования ЗНБ
Процедура СменитьСостоянияСтрокПоЗНБ (НовоеСостояние,ЗНБ,ЭтоНачалоПаузы=Неопределено,ЭтоОкончаниеПаузы=Неопределено,ВидПаузы=Неопределено) Экспорт 
	
	если НачалоДня(дата)<>НачалоДня(Накладная.Дата) тогда
		дата=Накладная.Дата;
	КонецЕсли;
	
	Если ЗНБ=Неопределено тогда
		МассСтрок=тБрэндов;
	иначе
		МассСтрок=тБрэндов.НайтиСтроки(новый Структура("НомерЧасти",ЗНБ.НомерЧасти));
	КонецЕсли;
	
	если МассСтрок.Количество()=0 тогда
		Возврат;
	Иначе
		СтрокаПН=МассСтрок.Получить(0);
	КонецЕсли;
	
	НоваяДата=ТекущаяДата();
	СтароеСостояние=СтрокаПН.Состояние;
	
	если ВидПаузы=Неопределено тогда
	ИначеЕсли ВидПаузы=Перечисления.СостоянияНакладной.ВНаборе тогда
		ВидПаузы="Набора";
	ИначеЕсли ВидПаузы=Перечисления.СостоянияНакладной.Сканирование тогда
		ВидПаузы="Сканирования";
	ИначеЕсли ВидПаузы=Перечисления.СостоянияНакладной.ДопОбработка тогда
		ВидПаузы="ДопОбработки";	
	КонецЕсли;
	
	если ЭтоНачалоПаузы=Истина тогда      
		ИмяКолонкиНачалаПаузы="НачалоОстановки"+ВидПаузы;
		для каждого СтрТЧ из МассСтрок цикл
			если СтрТЧ[ИмяКолонкиНачалаПаузы]=ПустаяДата() тогда			
				СтрТЧ[ИмяКолонкиНачалаПаузы]=НоваяДата;
			иначе
				Сообщить("Пауза по выбранному виду работ уже была начата ранее.");
				Возврат;
			КонецЕсли;
		КонецЦикла;
		Сообщить("Работа приостановлена.");
		
	ИначеЕсли ЭтоОкончаниеПаузы тогда
		ИмяКолонкиНачалаПаузы="НачалоОстановки"+ВидПаузы;
		ИмяКолонкиОкончанияПаузы="Остановка"+ВидПаузы;
		для каждого СтрТЧ из МассСтрок цикл
			НачалоПаузы=СтрТЧ[ИмяКолонкиНачалаПаузы];
			ПродолжительностьПаузы=СтрТЧ[ИмяКолонкиОкончанияПаузы];			
			Если НачалоПаузы=ПустаяДата() тогда 
				Сообщить("Пауза по выбранному виду работ не была начата ранее, а значит завершать нечего.");
				Возврат;
			КонецЕсли;				
			СтрТЧ[ИмяКолонкиОкончанияПаузы]=НоваяДата-НачалоПаузы+ПродолжительностьПаузы;
			СтрТЧ[ИмяКолонкиНачалаПаузы]=ПустаяДата();
		КонецЦикла;	
		Сообщить("Работа возобновлена.");
		
	иначе
		ЭтоБельё=ложь;
		если СтароеСостояние=Перечисления.СостоянияНакладной.ДопОбработка  тогда
			СтрСканировка=ЗНБ.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.Сканирование);
			СтрДО=ЗНБ.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.ДопОбработка);
			если СтрДО<>Неопределено и СтрСканировка<>Неопределено тогда
				если ЗНБ.ПланируемыеСостояния.индекс(СтрСканировка)> ЗНБ.ПланируемыеСостояния.индекс(СтрДО) тогда
					ЭтоБельё=Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		если  ПолучитьНомерСостоянияНакладной(СтароеСостояние,ЭтоБельё)< ПолучитьНомерСостоянияНакладной(НовоеСостояние,ЭтоБельё)тогда	
			СтруктураИзменений=новый Структура;
			если СтароеСостояние=Перечисления.СостоянияНакладной.ВНаборе тогда		
				если ЗначениеЗаполнено(СтрокаПН.НачалоОстановкиНабора) тогда
					Сообщить("Сначала завершите паузу набора.");
					Возврат;
				КонецЕсли;			
				СтруктураИзменений.Вставить("НаборЗакончен",Истина);
				СтруктураИзменений.Вставить("ОкончаниеНабора",НоваяДата);
				Сообщение="Набор по сотруднику "+СтрокаПН.наборщик+" закончен.";
				УстановитьТекущиеЗаданияСотрудников(СтрокаПН.наборщик);
				
			иначеесли СтароеСостояние=Перечисления.СостоянияНакладной.ДопОбработка тогда				
				если ЗначениеЗаполнено(СтрокаПН.НачалоОстановкиДопОбработки) тогда
					Сообщить("Сначала завершите паузу доп. обработки");
					Возврат;
				КонецЕсли;				
				СтруктураИзменений.Вставить("ДопОбработкаЗакончена",Истина);
				СтруктураИзменений.Вставить("ОкончаниеДопОбработки",НоваяДата);
				Сообщение="ДО по сотруднику "+СтрокаПН.ДопОбработчик+" закончена.";	
				
			иначеесли СтароеСостояние=Перечисления.СостоянияНакладной.Термоусадка тогда
				СтруктураИзменений.Вставить("ТермоусадкаЗакончена",Истина);
				СтруктураИзменений.Вставить("ОкончаниеТермоусадки",НоваяДата);
				Сообщение="Термоусадка по сотруднику "+СтрокаПН.Термоусадчик+" закончена.";	
				УстановитьТекущиеЗаданияСотрудников(СтрокаПН.Термоусадчик);
				
			иначеесли СтароеСостояние=Перечисления.СостоянияНакладной.Переукладка тогда
				СтруктураИзменений.Вставить("ОкончаниеПереукладки",НоваяДата);
				Сообщение="Переукладка по сотруднику "+СтрокаПН.Переукладчик+" закончена.";		
			КонецЕсли;
			
			
			
			для каждого СтрТЧ из МассСтрок цикл			
				ЗаполнитьЗначенияСвойств(СтрТЧ,СтруктураИзменений);
				СтрТЧ.Состояние=НовоеСостояние;		
			КонецЦикла;
			
			СообщитьИзМодуля(Сообщение);
		КонецЕсли;	
	КонецЕсли;
	
	Записать(РежимЗаписиДокумента.Запись);	
КонецПроцедуры
