			Если Лев(СтрокаТЧ.СекторХранения,1)="2" и ЕстьБельёПоНакладной=Неопределено тогда	 
				// Кухарь А.Ю. 15.04.2022 конец	
				ТекСтрокаЭтоБельё	= Истина;
			Иначе
				ЕстьКолготки		= Истина;
				ТекСтрокаЭтоБельё	= Ложь;				
			КонецЕсли;
			
			
			
			НомерСостоянияСтроки = ПолучитьНомерСостоянияНакладной(СтрокаТЧ.Состояние,ТекСтрокаЭтоБельё);			
			//Кухарь 22.11.17 конец			
			
			// Кухарь А.Ю. 24.12.2021 начало
			////Изменение схемы состояний на "по последней строчке"
			//Если НомерСостоянияСтроки > ТекНомерСостояния Тогда
			Если НомерСостоянияСтроки < ТекНомерСостояния Тогда
				// Кухарь А.Ю. 24.12.2021 конец
				
				//Кухарь 09.10.16 конец			
				ТекНомерСостояния =  НомерСостоянияСтроки;
			КонецЕсли;
			
			
		КонецЦикла;		
		
		
		Если МоноСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда
			ВсеГотовы=Истина;
		КонецЕсли;		
		
		Если ВсеГотовы=Истина ИЛИ Накладная.СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке тогда
			ТекНомерСостояния=ПолучитьНомерСостоянияНакладной(Перечисления.СостоянияНакладной.ГотоваКОтгрузке);			
			// Кухарь А.Ю.  06.02.2023 начало
