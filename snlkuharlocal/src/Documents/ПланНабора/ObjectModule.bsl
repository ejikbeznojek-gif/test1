Функция УстановитьНаборщиков ()
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	РеквизитыСправочников.Справочник КАК Сотрудник,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК Сектор
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = ""СекторСотрудников""
	|	И РеквизитыСправочников.Справочник В иерархии(&Справочник)";
	
	запрос.УстановитьПараметр("Справочник",Справочники.ФизическиеЛица.НайтиПоКоду("SNL-02040"));
	ТЗСотрудников=запрос.Выполнить().Выгрузить();
	
	ТЗБрендовСверн=тБрэндов.Выгрузить(,"Брэнд,ЭтоБлочки");
	ТЗБрендовСверн.Свернуть("Брэнд,ЭтоБлочки");
	
	НаборщикиНайдены=Истина;
	Для каждого СтрТЧ из ТЗБрендовСверн цикл
		Сектор=СтрТЧ.Брэнд.СекторХраненияОдинцово4;
		если СтрДлина(Сектор)<3 тогда
			СообщитьИзМодуля("У номенклатуры "+СтрТЧ.Брэнд.Наименование+" не заполнен сектор");
			НаборщикиНайдены=Ложь;
			Продолжить;
		КонецЕсли;
		
		МассНаборщиков=ТЗСотрудников.НайтиСтроки(новый Структура("Сектор",Сектор));
		если МассНаборщиков.Количество()<2 тогда
			СообщитьИзМодуля("У сектора "+Сектор+" должно быть хотя бы 2 наборщика. ");
			НаборщикиНайдены=Ложь;
			Продолжить;		
		КонецЕсли;
		
		если СтрТЧ.этоблочки тогда
			Наборщик=МассНаборщиков[0].Сотрудник;
		иначе
			Наборщик=МассНаборщиков[1].Сотрудник;
		КонецЕсли;
		
		МассТЧ=тБрэндов.НайтиСтроки(Новый Структура("Брэнд,ЭтоБлочки",СтрТЧ.Брэнд,СтрТЧ.ЭтоБлочки));
		Для каждого СтрМасс из МассТЧ цикл
			СтрМасс.Наборщик=Наборщик;
		КонецЦикла;
		
	КонецЦикла;
	
	возврат НаборщикиНайдены;
	
	
КонецФункции
