Функция ПроверитьКорректностьНаборщиковСканировщиков(Отказ)
	
	СписокНаборщиков 		= тБрэндов.Выгрузить(,"Наборщик");
	СписокСканировщиков 	= тБрэндов.Выгрузить(,"Сканировщик");
	СписокДопОбработчиков 	= тБрэндов.Выгрузить(,"ДопОбработчик");
	
	СписокНаборщиков.Свернуть("Наборщик");
	СписокСканировщиков.Свернуть("Сканировщик");
	СписокДопОбработчиков.Свернуть("ДопОбработчик");
	
	Результат=Истина;
	
	Сторонние = Справочники.ФизическиеЛица.НайтиПоКоду("SNL-01032");
	Для Каждого СтрокаНаборщик Из СписокНаборщиков Цикл
		ТекНаборщик = СтрокаНаборщик.Наборщик;
		Если ТекНаборщик.Пустая() ИЛИ ТекНаборщик.Штатный ИЛИ ТекНаборщик.ПринадлежитЭлементу(Сторонние) Тогда
		Иначе	
			Сообщить("По "+Накладная + " выбран некорректный наборщик! "+ ТекНаборщик);
			Результат = Ложь;
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаСканировщик Из СписокСканировщиков Цикл
		ТекСканировщик = СтрокаСканировщик.Сканировщик;
		Если ТекСканировщик.Пустая() ИЛИ ТекСканировщик.Штатный ИЛИ ТекСканировщик.ПринадлежитЭлементу(Сторонние) Тогда
		Иначе	
			Сообщить("По "+Накладная + " выбран некорректный сканировщик! "+ ТекСканировщик);
			Результат = Ложь;
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаДопОбработчик Из СписокДопОбработчиков Цикл
		ТекДопОбработчик = СтрокаДопОбработчик.ДопОбработчик;
		Если ТекДопОбработчик.Пустая() ИЛИ ТекДопОбработчик.Штатный ИЛИ ТекДопОбработчик.ПринадлежитЭлементу(Сторонние) Тогда
		Иначе	
			Сообщить("По "+Накладная + " выбран некорректный допобработчик! "+ ТекДопОбработчик);
			Результат = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ Результат Тогда
		Отказ	= Истина;	
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //ПроверитьКорректностьНаборщиковСканировщиков()

Функция ПолучитьМоноСостояние() Экспорт
	Результат=Неопределено;
	
	ВремТаб=тБрэндов.Выгрузить(,"Состояние,Количество");
	ВремТаб.Свернуть("Состояние","Количество");
	Если ВремТаб.Количество()=1 Тогда
		Результат=ВремТаб[0].Состояние;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьМоноСостояние()

Функция ПроверкаДублейПланаНабора(Отказ)
	Результат=Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номер
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	Накладная = &Накладная
	|	И НЕ ПометкаУдаления	
	|";
	Запрос.УстановитьПараметр("Накладная",	Накладная);
	Выборка = Запрос.Выполнить().Выбрать();
