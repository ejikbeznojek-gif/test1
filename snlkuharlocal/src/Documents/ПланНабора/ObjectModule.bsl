		// Кухарь А.Ю.  19.11.2024 конец
		//|	Документ." + ВидНакладной + "." + ИмяТабЧасти + "
		
		Запрос.Текст 	= "ВЫБРАТЬ
		             	  |	ТаблицаСПризнакомАдресногоХранения.Номенклатура КАК Номенклатура,
		             	  |	ТаблицаСПризнакомАдресногоХранения.АдресноеХранение КАК АдресноеХранение
		             	  |ПОМЕСТИТЬ ВТАдресов
		             	  |ИЗ
		             	  |	&ТаблицаСПризнакомАдресногоХранения КАК ТаблицаСПризнакомАдресногоХранения
		             	  |;
		             	  |
		             	  |////////////////////////////////////////////////////////////////////////////////
		             	  |ВЫБРАТЬ
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.Родитель.Родитель КАК Брэнд,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура КАК Коллекция,
		             	  |	ВЫБОР
		             	  |		КОГДА РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> &ПустаяДата
		             	  |				И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <= &ДатаОтгрузки
		             	  |				И &ОтделятьМаркированныйТовар
		             	  |			ТОГДА ИСТИНА
		             	  |		КОГДА РасходнаяНакладнаяТовары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ
		             	  |			ТОГДА ИСТИНА
		             	  |		ИНАЧЕ ЛОЖЬ
		             	  |	КОНЕЦ КАК ТребуетсяМаркировка,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.ОбъемКоробки КАК ОбъемКоробки,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
