		             	  |	0 КАК КоличествоДляНаборов,
		             	  |	СУММА(РасходнаяНакладнаяТовары.Объем) КАК Объем,
		             	  |	МАКСИМУМ(ЕСТЬNULL(ВТАдресов.АдресноеХранение, ЛОЖЬ)) КАК АдресноеХранение
		             	  |ИЗ
		             	  |		Документ." + ВидНакладной + "." + ИмяТабЧасти + " КАК РасходнаяНакладнаяТовары
		             	  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТАдресов КАК ВТАдресов
		             	  |		ПО РасходнаяНакладнаяТовары.Номенклатура = ВТАдресов.Номенклатура
		             	  |ГДЕ
		             	  |	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
		             	  |	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Услуга)
		             	  |
		             	  |СГРУППИРОВАТЬ ПО
		             	  |	РасходнаяНакладнаяТовары.Номенклатура,
		             	  |	ВЫБОР
		             	  |		КОГДА РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <> &ПустаяДата
		             	  |				И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой <= &ДатаОтгрузки
		             	  |				И &ОтделятьМаркированныйТовар
		             	  |			ТОГДА ИСТИНА
		             	  |		КОГДА РасходнаяНакладнаяТовары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ
		             	  |			ТОГДА ИСТИНА
		             	  |		ИНАЧЕ ЛОЖЬ
		             	  |	КОНЕЦ,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.Родитель.Родитель,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.ОбъемКоробки,
		             	  |	РасходнаяНакладнаяТовары.Номенклатура.Родитель.ШтукВКоробке
		             	  |
		             	  |ИМЕЮЩИЕ
		             	  |	СУММА(РасходнаяНакладнаяТовары.Количество) > 0
		             	  |
		             	  |УПОРЯДОЧИТЬ ПО
		             	  |	Брэнд,
		             	  |	Коллекция";	
		
		// Кухарь А.Ю.  06.11.2024 начало
		//
		если ИмяТабЧасти="Комплектующие" тогда
			ПолеКоличествоДляНаборов="Сумма(ВЫБОР
			|КОГДА Номенклатура = Продукция
			|	ТОГДА 0
			|ИНАЧЕ Количество
			|КОНЕЦ) КАК КоличествоДляНаборов";
			
			Запрос.Текст=СтрЗаменить(Запрос.Текст,"0 как КоличествоДляНаборов",ПолеКоличествоДляНаборов);	
		КонецЕсли;
		// Кухарь А.Ю.  06.11.2024 конец
		
