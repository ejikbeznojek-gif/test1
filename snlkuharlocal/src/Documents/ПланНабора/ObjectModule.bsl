		#Если Клиент Тогда
			Сообщить("По "+Накладная + " уже существует план набора! Сохранение невозможно!");
		#КонецЕсли
		Результат=Ложь;			
	КонецЕсли;
	
	Если НЕ Результат Тогда
		Отказ = Истина;	
	КонецЕсли; 
	
	Возврат Результат;
