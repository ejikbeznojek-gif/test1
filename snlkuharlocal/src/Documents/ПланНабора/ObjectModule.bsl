		// СтрокаТЧ.Состояние=Перечисления.СостоянияНакладной.СформированыЗаданияНабора;
		СтрокаТЧ.Состояние=Перечисления.СостоянияНакладной.ОжиданиеНабора; 
		// Кухарь А.Ю. 29.07.2020 конец
		
		
	КонецЦикла; 	
	
	НаборщикиУстановлены=УстановитьНаборщиков();
	если не НаборщикиУстановлены тогда
		СообщитьИзМодуля("План набора не записан");
		возврат ложь;
	КонецЕсли;
	
	НачатьТранзакцию();
	Записать(РежимЗаписиДокумента.Проведение);
	СоздатьЗаданияНабораДляАвторазбивки();	
	// Кухарь А.Ю. 29.07.2020 начало
	//УстановитьРеквизитыОбъекта(Накладная,Новый Структура("СостояниеНакладной",Перечисления.СостоянияНакладной.СформированыЗаданияНабора));
	УстановитьРеквизитыОбъекта(Накладная,Новый Структура("СостояниеНакладной",Перечисления.СостоянияНакладной.ОжиданиеНабора)); 
	// Кухарь А.Ю. 29.07.2020 конец
	
	
	ЗафиксироватьТранзакцию();
	
