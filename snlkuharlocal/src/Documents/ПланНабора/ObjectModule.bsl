Функция ЕстьОшибкиНабора()
	Запрос=Новый запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(КоличествоВНакладной) КАК КоличествоВНакладной,
	|	СУММА(КоличествоВЛН) 		КАК КоличествоВЛН
	|ИЗ
	|(
	|ВЫБРАТЬ
	|	Номенклатура,
	|	0					КАК КоличествоВНакладной, 
	//++Данилова Е.В. 02.03.2026  SNL-153 
	//|	Количество			КАК КоличествоВЛН 
	|	%Количество%			КАК КоличествоВЛН
	//--Данилова Е.В. 02.03.2026 
	|ИЗ
	|	Документ.ЛистНабора.Товары
	|ГДЕ
	|	Ссылка.ДокОснование = &ДокОснование
	|	И Ссылка.Проведен
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Количество			КАК КоличествоВНакладной,
	|	0					КАК КоличествоВЛН
	|ИЗ
	|	Документ."+Накладная.Метаданные().Имя+"."+ИмяТчНакладной()+"
	|ГДЕ
	|	Ссылка=&ДокОснование
	|) КАК Сводный	
	|СГРУППИРОВАТЬ ПО 
	|	Номенклатура
	|ИТОГИ 
	|	СУММА(КоличествоВНакладной),СУММА(КоличествоВЛН)
	|ПО ОБЩИЕ
	|";
	
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование.Ссылка);
	//++Данилова Е.В. 02.03.2026 SNL-153 
	ИспользоватьЛНТолькоДляНабора = ИспользоватьЛНТолькоДляНабора(Накладная);
	Если ИспользоватьЛНТолькоДляНабора Тогда 	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ.ЛистПереукладки"); 	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Количество%","Отсканировано");
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Количество%","Количество");
	КонецЕсли;
	//--Данилова Е.В. 02.03.2026 
	Ошибки		=Новый Массив;
	Результат	=Новый Структура("ЕстьОшибки,КоличествоВНакладной,КоличествоВЛН",Ложь,0,0);
	
	Выборка=Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда
			ЗаполнитьЗначенияСвойств(Результат,Выборка);
			Если Выборка.КоличествоВНакладной<>Выборка.КоличествоВЛН Тогда
				Результат.ЕстьОшибки=Истина;								
			КонецЕсли; 
		Иначе
			Если Выборка.КоличествоВНакладной<>Выборка.КоличествоВЛН Тогда
				Ошибка=Новый Структура("Номенклатура,КоличествоВНакладной,КоличествоВЛН",Неопределено,0,0);			
				ЗаполнитьЗначенияСвойств(Ошибка,Выборка);
				Ошибки.Добавить(Ошибка);
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	
	Результат.Вставить("Ошибки",Ошибки);
	//++Данилова Е.В. 05.03.2026 SNL-153 
	Результат.Вставить("ИспользоватьЛНТолькоДляНабора",ИспользоватьЛНТолькоДляНабора);
	//--Данилова Е.В. 05.03.2026 
	Возврат Результат;	
КонецФункции //ЕстьОшибкиНабора()

Функция ЕстьЛистыПереукладки()
	ЛП=ПолучитьЛистыПереукладки(ДокОснование);
	Возврат (ЛП.Количество()>0);
КонецФункции //ЕстьЛистыПерукладки()

Функция ПолучитьКоробкиОбъемыПоПереукладке()
	Запрос=новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) 	КАК КоличествоКоробок,
	|	СУММА(ОбъемДокумента) 			КАК ОбъемДокумента
	|ИЗ
	|	Документ.ЛистПереукладки
	|ГДЕ
	|	ДокОснование = &ДокОснование
	|	И Проведен					
	|";
	
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	
	Результат=Новый Структура("КоличествоКоробок,ОбъемДокумента",0,0);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат,Выборка);				
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьКоробкиОбъекмыПоПереукладке()  

