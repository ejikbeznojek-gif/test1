	//// Кухарь А.Ю. 29.03.2021 начало
	//// перенёс выше
	//Если ЭтоНовый() Тогда
	//	ПроверкаДублейПланаНабора(Отказ);
	//КонецЕсли;	 
	//// Кухарь А.Ю. 29.03.2021 конец
	
	Если Отказ Тогда Возврат КонецЕсли;	
	
	КоличествоДокумента = тБрэндов.Итог("Количество");	
	ОбъемДокумента		= тБрэндов.Итог("Объемкоробов");	
	ДокОснование		= Накладная;
	//крохин начало 11.12.2013
	//перезаписываем состояние документа-основания в зависимости от состояний строк плана, для ODN
	//Кухарь 28.10.15 начало
	//Новый склад	
	//Если ПараметрыСеанса.ЭтотУзел.Код = "ODN" Тогда
	Если ПараметрыСеанса.ЭтотУзел.Код = "ODN" или ПараметрыСеанса.ЭтотУзел.Код = "OD7"  Тогда
		//Кухарь 28.10.15 конец
		
		//крохин начало 29.01.2014
		Если НачалоОбработки = '00010101' Тогда
			ДатаФормирования = ТекущаяДата();
			НачалоОбработки = ТекущаяДата();
		КонецЕсли;
		
		ВсеГотовы					= Ложь;		
		
		// Кухарь А.Ю. 24.12.2021 начало
		//Изменение схемы состояний на "по последней строчке"
		// ТекНомерСостояния = 0;
		ТекНомерСостояния = 999999;	
		// Кухарь А.Ю. 24.12.2021 конец
		
		//Кухарь 22.11.17 начало
		//У белья доп обработка до сканирования		
		ЕстьКолготки	= ложь;
		//Кухарь 22.11.17 конец	
		
		МоноСостояние=ПолучитьМоноСостояние();
		
		// Кухарь А.Ю. 15.04.2022 начало
		//Исключение из бельевой Схемы по ВБ
		ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);
		если ДопПараметрыНакладной<>Неопределено и ДопПараметрыНакладной.имя="WB_FBS" тогда
			ЕстьБельёПоНакладной=ложь;
		иначе
			ЕстьБельёПоНакладной=Неопределено;	
		КонецЕсли;	  
		// Кухарь А.Ю. 15.04.2022 конец
		
		
