						//++Данилова Е.В. 19.03.2026 без задачи
						//отбор = Новый Структура("Коллекция",НоваяСтрокаТЧ.Коллекция);
						отбор = Новый Структура("Коллекция,ЭтоБлочки",НоваяСтрокаТЧ.Коллекция,НоваяСтрокаТЧ.ЭтоБлочки);
