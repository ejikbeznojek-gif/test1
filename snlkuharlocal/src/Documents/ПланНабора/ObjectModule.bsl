							Иначе 
								ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ,СтрокиСохраненные[0],,"НомерСтроки");
								НоваяСтрокаТЧ.Состояние = Перечисления.СостоянияНакладной.СформированыЗаданияНабора;
								НоваяСтрокаТЧ.Разделенная = Истина;
								НоваяСтрокаТЧ.ВремяРаспределения 	= ТекущаяДата();
								НоваяСтрокаТЧ.ВремяТекущегоСостояния = ТекущаяДата();
							КонецЕсли;
							
						КонецЕсли;	
					КонецЕсли;
					//--Данилова Е.В. 13.03.2026
				Иначе
					СтрокаТБ.СекторХранения 		= СтрЗаменить(СтрокаТБ.СекторХранения,"_блочки","") + "_блочки";
					СтрокаТБ.ЭтоБлочки 				= Истина;
				КонецЕсли;
			КонецЕсли;		
		КонецЕсли;
		//++Данилова Е.В. 24.02.2026 HELP-8893 
		Если ДанныеДляРазделения <> неопределено Тогда  		
		
			//++Данилова Е.В. 19.03.2026 без задачи
			//отбор = Новый Структура("Коллекция",СтрокаТБ.Коллекция);
			отбор = Новый Структура("Коллекция,ЭтоБлочки",СтрокаТБ.Коллекция,СтрокаТБ.ЭтоБлочки);
			//--Данилова Е.В. 19.03.2026 
			СтрокиСохраненные = ТБрендовКопия.НайтиСтроки(отбор); 	
