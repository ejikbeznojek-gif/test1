			//	ЗаполнитьКоличестваПоТипамШК();
			//КонецЕсли;			 
			// Кухарь А.Ю.  06.02.2023 конец		
		КонецЕсли;
		
		
		// Кухарь А.Ю.  06.02.2023 начало
		Если ВсеГотовы=Истина 
			или МоноСостояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке
