			ТекНомерСостояния=ПолучитьНомерСостоянияНакладной(МоноСостояние);		
		КонецЕсли;		
		//Кухарь 27.12.17 конец		
		
		//Кухарь 22.11.17 начало
		//У белья доп обработка до сканирования
		//НомерСостоянияНакладной =  ПолучитьНомерСостоянияНакладной(ДокОснование.СостояниеНакладной);
		НомерСостоянияНакладной =  ПолучитьНомерСостоянияНакладной(ДокОснование.СостояниеНакладной, НЕ ЕстьКолготки);		
		//Кухарь 22.11.17 конец			
		
		Если ТекНомерСостояния > НомерСостоянияНакладной И ТекНомерСостояния <> 10000 Тогда
			ТекСостояние 		= ПолучитьСостояниеНакладнойПоНомеру(ТекНомерСостояния);		
			
			РеквизитыОснования	= Новый Структура("СостояниеНакладной",ТекСостояние);			
			
			//кухарь 02.09.14 начало
