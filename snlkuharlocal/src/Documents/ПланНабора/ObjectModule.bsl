		возврат ложь;
	КонецЕсли;
	//--Данилова Е.В. 12.03.2026 
	
	НужноПересоздатьЗНБ=ложь;
	//++Данилова Е.В. 24.02.2026  HELP-8893 
	если ЭтоНовый() 
		ИЛИ Модифицированность() тогда
		ЗаписатьБезОбработки(РежимЗаписиДокумента.Проведение);
		//иначе
		//	Если Модифицированность() Тогда 
		//		НужноПересоздатьЗНБ=Истина;
		//		Возврат Ложь; 
		//	КонецЕсли;
	КонецЕсли;
	ВидНакладной=ОбщегоНазначения_ПИ.ПолучитьИмяДокумента(Накладная);
	ЭтоКомплектация = (ВидНакладной="РасходнаяНакладная" И ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов","Документ")=Истина) или ВидНакладной="Комплектация";  
	
	//--Данилова Е.В. 24.02.2026 
	
	ИмяТЧНакладной=?(ЭтоКомплектация,"Комплектующие","Товары");	
	ОтделятьМаркированныйТовар=ОпределитьНеобходимостьМаркировкиПоНакладной(Накладная);
	
	// Кухарь А.Ю.  31.03.2024 начало
	если ВидНакладной="РасходнаяНакладная" или ВидНакладной="Перемещение" тогда
		ДатаОтгрузки=ПолучитьРеквизитШапки(Накладная,"ДатаОтгрузки","Документ");				
	иначе
		ДатаОтгрузки=ТекущаяДата();	
	КонецЕсли;
	
	если ДатаОтгрузки=ПустаяДата() тогда
		ДатаОтгрузки=ТекущаяДата();
	КонецЕсли;
	// Кухарь А.Ю.  31.03.2024 конец
	
	// Кельманов А.В. - ASU-2094 - 2025.03.13 {
	НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ = Ложь;
	//ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);
	
	Если ВидНакладной = "РасходнаяНакладная" 
		И Не Склад.ЭтоСкладМаркированногоТовара 
		// Кухарь А.Ю.  20.03.2025 начало
		и СобиратьНаТСД 
