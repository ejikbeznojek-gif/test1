Функция ПолучитьСекторХранения(Брэнд)
	Если ПараметрыСеанса.ЭтотУзел.Код = "ODM" Тогда		
		Возврат ПолучитьРеквизитРодителя(Брэнд, "СекторХраненияОдинцово4");
	Иначе
		Возврат ПолучитьРеквизитРодителя(Брэнд, "СекторХранения");
	КонецЕсли;
КонецФункции // ПолучитьСекторХранения(Брэнд)

Функция ПолучитьСекторНабора(Коллекция)
	Возврат ПолучитьРеквизитРодителя(Коллекция,"СекторХраненияОдинцово4")
КонецФункции // ПолучитьСекторНабора(Коллекция) 

Функция РассчитатьОбъемКоробки(Количество,ОбъемКоробки,ШтукВКоробке)
	Если ТипЗнч(ШтукВКоробке)=Тип("Число") И ШтукВКоробке>0 Тогда
		Возврат Количество*ОбъемКоробки/ШтукВКоробке;
	Иначе
		Возврат ОбъемКоробки;
	КонецЕсли;
КонецФункции //РассчитатьОбъектКоробки(Количество,ОбъемКоробки,ШтукВКоробке)

