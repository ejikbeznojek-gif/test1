Функция ПроверитьСектораНаборщиковПоНабору(ДопПараметрыНакладной)
	ТЗНаборщиков=тБрэндов.Выгрузить(,"Наборщик");
	ТЗНаборщиков.Свернуть("Наборщик");
	// Кухарь А.Ю. 24.11.2021 начало
	// Для озона
	ТЗНаборщиков.Колонки.Добавить("Сектор");
	// Кухарь А.Ю. 24.11.2021 конец
	
	МожноСоздавать=Истина;
	для каждого СтрТЗ из ТЗНаборщиков цикл
		если не ЗначениеЗаполнено(СтрТЗ.Наборщик.сектор) тогда
			МожноСоздавать=ложь;
			Сообщить("Заполните сектор у наборщика "+СтрТЗ.Наборщик);
			// Кухарь А.Ю. 24.11.2021 начало
			Продолжить;; 
			// Кухарь А.Ю. 24.11.2021 конец			
		КонецЕсли;
		
		// Кухарь А.Ю. 24.11.2021 начало
		// По озону сборные ЗНБ нельзя
		
		// Кухарь А.Ю. 11.01.2022 начало
		//+ Аллиэкспресс
		// 		если ДопПараметрыНакладной<>Неопределено и ДопПараметрыНакладной.имя="OZON_FBS" тогда
		если ДопПараметрыНакладной<>Неопределено и (ДопПараметрыНакладной.имя="OZON_FBS" 
			или ДопПараметрыНакладной.имя="AlIEXPRESS_FBS"
			// Кухарь А.Ю. 23.03.2022 начало
			или ДопПараметрыНакладной.имя="YANDEX_FBS"		 
			// Кухарь А.Ю. 23.03.2022 конец	
			// Ихсанов Д. А. Начало 02.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
			Или ДопПараметрыНакладной.Имя = "MAGNIT_FBS"
			// Ихсанов Д. А. Конец  02.06.2025
			
			// Кухарь А.Ю.  28.06.2022 начало
			// + сбер
			или ДопПараметрыНакладной.имя="SBRF_FBS"	 
			// Кухарь А.Ю.  28.06.2022 конец
			
			) тогда	 
			// Кухарь А.Ю. 11.01.2022 конец
			
			
			//Запреты:
			//Пустой сектор наборщика, сборный сектор наборщика, несколько наборщиков с 1 сектором.
			Сектор=СтрТЗ.Наборщик.сектор;
			СтрТЗ.Сектор=Сектор;
			
			если Сектор.Сборный тогда
				МожноСоздавать=ложь;
				Сообщить("У наборщика "+СтрТЗ.Наборщик+" сборный сектор. В данной накладной сборные сектора запрещены.");
				Продолжить;
			КонецЕсли;
			
			
			МассСтрок=ТЗНаборщиков.НайтиСтроки(новый Структура("Сектор",Сектор));
			если МассСтрок.Количество()>1 тогда
				Сотрудники="";
				Для каждого СтрМасс из МассСтрок цикл
					Сотрудники=Сотрудники+СтрМасс.Наборщик+"   ";			 
				КонецЦикла;
				
				Сообщить("Обнаружено несколько наборщиков по 1 сектору "+Сотрудники+" . В данной накладной это запрещено.");
				МожноСоздавать=ложь;
				Продолжить;
				
			КонецЕсли;
		КонецЕсли;		  
		// Кухарь А.Ю. 24.11.2021 конец
		
	КонецЦикла;
	
	
	
	возврат МожноСоздавать;
КонецФункции 

Процедура УдалитьПодчиненныеЗаданияНабора()
	мОтбор	= Новый Структура("ДокументОснование",Ссылка);
	Выборка	= Документы.ЗаданиеНабора.Выбрать(,,мОтбор);
	Пока Выборка.Следующий() Цикл
		Выборка.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);					
	КонецЦикла; 
КонецПроцедуры

Функция НайтиСоздатьЗаданиеНабора(НомерЧасти)
	СтруктураПоиска	= Новый Структура("ДокументОснование,НомерЧасти",Ссылка,НомерЧасти);
	Задание			= НайтиДокумент("ЗаданиеНабора",СтруктураПоиска);
	Если Задание.Пустая() Тогда
		ДокОбъект=Документы.ЗаданиеНабора.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(ДокОбъект,СтруктураПоиска);
	Иначе
		ДокОбъект=Задание.ПолучитьОбъект();
	КонецЕсли;	
	
	Возврат ДокОбъект;
КонецФункции 

