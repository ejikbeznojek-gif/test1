	|	ВТ_Общая.КоличествоТовараВСпайке КАК КоличествоТовараВСпайке,
	|	ВТ_Общая.КоличествоТовара КАК КоличествоТовара,
	|	ВТ_Общая.КоличествоРасходника / ВТ_СуммаТовара.КоличествоТовараОбщее КАК РасходниковНаШтукуТовара,
	|	ВТ_СуммаТовара.КоличествоТовараОбщее КАК КоличествоТовараОбщее
	|ИЗ
	|	ВТ_Общая КАК ВТ_Общая
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СуммаТовара КАК ВТ_СуммаТовара
	|		ПО ВТ_Общая.НормальныйТовар = ВТ_СуммаТовара.НормальныйТовар
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Общая.Номенклатура";
	// Кельманов А.В. - Проблема 0000000195 - 2026.07.08 }
	
	Запрос.УстановитьПараметр("Ссылка", Накладная);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПолучитьТаблицуРасходныхМатериаловСвернутуюНабора()
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	|ГДЕ
	|	РасходнаяНакладнаяКомплектующие.Ссылка = &Ссылка
	|	И РасходнаяНакладнаяКомплектующие.Номенклатура.ВидНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяКомплектующие.Номенклатура";
	запрос.УстановитьПараметр("Ссылка",Накладная);
	возврат запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура СоздатьЗНМ_И_ЛМ_ПоЗНБ_Набора()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНабора.Ссылка КАК ЗНБ
	               |ИЗ
	               |	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	               |ГДЕ
	               |	ЗаданиеНабора.ДокументОснование = &ДокументОснование
	               |	И ЗаданиеНабора.Проведен
	               |	И ЗаданиеНабора.ТребуетсяМаркировка
	               |	И ЗаданиеНабора.Дата >= &Дата
	               |	И ЗаданиеНабора.ЗНМ = ЗНАЧЕНИЕ(Документ.ЗаданиеНаМаркировку.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ДокументОснование", Ссылка);
	Запрос.УстановитьПараметр("Дата", Константы.ДатаЗапретаРедактирования.Получить());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Ошибки = Документы.ЗаданиеНабора.СоздатьЗНМ_И_ЛМ(Выборка.ЗНБ, Накладная);
		
		Если ЗначениеЗаполнено(Ошибки) Тогда
			
			Сообщить(Ошибки);
			
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры


