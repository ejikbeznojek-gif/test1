		СтрокаКурса			=Курсы.Добавить();		
		
		СтрокаКурса.Валюта	=Заказ.Валюта;				
		Если СтрокаКурса.Валюта<>Валюта Тогда			
			СтрокаКурса.Курс	=ПолучитьКурсВалюты(Заказ.Валюта,Дата).Курс;				
