Процедура ПровестиПоГТД(Записывать=Ложь) Экспорт
	Если ГТД.Пустая() Тогда
		Движения.ОстаткиГТД.Очистить();
	Иначе
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура.Родитель КАК Модель,
		|	СУММА(Количество) КАК Количество
		|ИЗ
		|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
		|ГДЕ
		|	Ссылка.ДокОснование.Машина = &Машина
		|	И Ссылка.Проведен
		|	И Ссылка.СостояниеНакладной = &СостояниеНакладной
		|СГРУППИРОВАТЬ ПО
		|	Номенклатура.Родитель";
		
		Запрос.УстановитьПараметр("Машина",Ссылка);
		Запрос.УстановитьПараметр("СостояниеНакладной",Перечисления.СостоянияНакладной.Принята);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.Количество<>0 Тогда
				Движение=Движения.ОстаткиГТД.Добавить();				
				
				Движение.Период			=НачалоДня(Дата);
				Движение.ВидДвижения	=ВидДвиженияНакопления.Приход;
				
				Движение.Номенклатура	=Выборка.Модель;
				Движение.ГТД			=ГТД;
				Движение.Количество		=Выборка.Количество;			
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли; 
	
	Если Записывать Тогда
		Движения.ОстаткиГТД.Записать();		
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////////////
	
	// Шворобей ВЮ 27.04.2022 +
	
	Запрос = Новый Запрос;
	//Запрос.Текст =
	//"ВЫБРАТЬ
	//|	МашинаНомераГТД.Модель КАК Модель,
	//|	СУММА(МашинаНомераГТД.Количество) КАК Количество,
	//|	МАКСИМУМ(МашинаНомераГТД.ГТД) КАК ГТД
	//|ИЗ
	//|	Документ.Машина.НомераГТД КАК МашинаНомераГТД
	//|ГДЕ
	//|	МашинаНомераГТД.Ссылка = &Ссылка
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	МашинаНомераГТД.Модель
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	Модель
	//|АВТОУПОРЯДОЧИВАНИЕ
	//|";
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МашинаНомераГТД.Модель, МашинаНомераГТД1.Модель) КАК Модель,
	|	ЕСТЬNULL(МашинаНомераГТД.Количество, МашинаНомераГТД1.Количество) КАК Количество,
	|	ЕСТЬNULL(МашинаНомераГТД.ГТД, МашинаНомераГТД1.ГТД) КАК ГТД
	|ПОМЕСТИТЬ ГТД
	|ИЗ
	|	Документ.Машина.НомераГТД КАК МашинаНомераГТД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Машина.НомераГТД КАК МашинаНомераГТД1
	|		ПО МашинаНомераГТД.Ссылка = МашинаНомераГТД1.Ссылка
	|			И МашинаНомераГТД.Модель = МашинаНомераГТД1.Модель
	|ГДЕ
	|	МашинаНомераГТД.Ссылка = &Ссылка
	|	И МашинаНомераГТД.Количество >= МашинаНомераГТД1.Количество
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТабГТД.Модель КАК Модель,
	|	СУММА(ТабГТД.Количество) КАК Количество,
	|	МАКСИМУМ(ТабГТД.ГТД) КАК ГТД
	|ИЗ
	|	ГТД КАК ТабГТД
	|ГДЕ
	|	ТабГТД.ГТД <> ЗНАЧЕНИЕ(Справочник.ГТД.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТабГТД.Модель
	|";
	
	Запрос.Параметры.Вставить("Ссылка", Ссылка); // <МАШ>[МАШ SSP-000019 от 14.01.2022 12:00:00]
	
	ТЗГТД = Запрос.Выполнить().Выгрузить();
	
	НЗ=РегистрыСведений.История.СоздатьНаборЗаписей();
	//крохин начало
	//ГТД записываем датой из ГТД, а не из документа 
	//НЗ.Отбор.Период.Установить(Дата,Истина);
	Год = "20"+Сред(ГТД.Наименование,14,2);
	Месяц =  Сред(ГТД.Наименование,12,2);
	День =  Сред(ГТД.Наименование,10,2);
	попытка
		ДатаНомераГТД = Дата(Год+месяц+день);
	исключение
		ДатаНомераГТД = Дата;
	Конецпопытки;
	НЗ.Отбор.Период.Установить(ДатаНомераГТД,Истина);
	
	//крохин конец
	НЗ.Отбор.Документ.Установить(Ссылка,Истина);
	
	Для Каждого СтрокаГТД Из ТЗГТД Цикл
		
		Если НЕ СтрокаГТД.ГТД.Пустая() И НЕ СтрокаГТД.Модель.Пустая() Тогда
			Запись=НЗ.Добавить();
			//крохин начало
			//ГТД записываем датой из ГТД, а не из документа 
			//	Запись.Период		=Дата;
			Запись.Период		=ДатаНомераГТД;
			//крохин конец
			Запись.Объект		=СтрокаГТД.Модель;
			Запись.Реквизит		="НомерГТД";
			Запись.Документ		=Ссылка;		
			
			Запись.Значение		=СтрокаГТД.ГТД;			
			
			Запись.Регистратор	=Ссылка;			
		КонецЕсли;	
	КонецЦикла;

	НЗ.Записать();
	
	// Шворобей ВЮ 27.04.2022 +
	
КонецПроцедуры


Функция ГруппыТоваровМашины(ДокОбъект,ИмяТЧ="Товары",ИмяКолонки="Номенклатура") Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР КОГДА Номенклатура.ЭтоГруппа ТОГДА Номенклатура.Родитель.Наименование ИНАЧЕ Номенклатура.Родитель.Родитель.Наименование КОНЕЦ КАК Наименование,
	|	ВЫБОР КОГДА Номенклатура.ЭтоГруппа ТОГДА Номенклатура.Родитель.Брэнд ИНАЧЕ Номенклатура.Родитель.Родитель.Брэнд КОНЕЦ КАК Брэнд
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В (
	|		ВЫБРАТЬ РАЗЛИЧНЫЕ
	|			Номенклатура
	|		ИЗ
	|			Документ.ЗаказПоставщику.Товары
	|		ГДЕ
	|			Ссылка В(&СписокЗаказов)
	|	)	
	|УПОРЯДОЧИТЬ ПО Наименование";	
	
	СписокЗаказов=Заказы.ВыгрузитьКолонку("Заказ");
	Запрос.УстановитьПараметр("СписокЗаказов",СписокЗаказов);
	
	ГруппыТоваров="";
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекБрэнд=?(ПустаяСтрока(Выборка.Брэнд),Выборка.Наименование,Выборка.Брэнд);
		ГруппыТоваров=ГруппыТоваров+ТекБрэнд+",";	
	КонецЦикла; 
	
	Если НЕ ПустаяСтрока(ГруппыТоваров) Тогда
		ГруппыТоваров=Лев(ГруппыТоваров,СтрДлина(ГруппыТоваров)-1)	
	КонецЕсли; 
	
	Возврат ГруппыТоваров;	
КонецФункции

Процедура ЗаполнитьСтрокуПоЗаказу(СтрокаТЧ) Экспорт
	Заказ=СтрокаТЧ.Заказ;
	
	СтрокаТЧ.Номерпоставщика= Заказ.НомерПоставщика;
	СтрокаТЧ.Количество		= Заказ.КоличествоДокумента;	
	СтрокаТЧ.Объем			= Заказ.ОбъемДокумента;
	СтрокаТЧ.Всего			= Заказ.СуммаДокумента;
	СтрокаТЧ.Валюта			= Заказ.Валюта;
	Если Заказ.Валюта=Валюта Тогда
		СтрокаТЧ.СуммаЗаказа=Заказ.СуммаДокумента;
	Иначе
		СтрокаТЧ.СуммаЗаказа=глПересчет(Заказ.СуммаДокумента,Заказ.Валюта,Заказ.Курс,Валюта,Курс)
	КонецЕсли; 
	
	СтрокаТЧ.ГруппыТоваров  = Заказ.ГруппыТоваров;
	//крохин начало
	СтрокаТЧ.КурсЗПС = Заказ.Курс;
	//крохин конец
КонецПроцедуры 

Процедура ОбновитьДанныеЗаказов(Принудительно=Ложь) Экспорт
	Для Каждого СтрокаЗП Из Заказы Цикл
		ЗаказОбъект=Неопределено;
		
		Если СтрокаЗП.Заказ.ДопРасходыПоМашине<>СтрокаЗП.ДопРасходы ИЛИ Принудительно Тогда
			ЗаказОбъект=СтрокаЗП.Заказ.ПолучитьОбъект();			
			ЗаказОбъект.ДопРасходыПоМашине=СтрокаЗП.ДопРасходы;
		КонецЕсли;	
		
		Если СтрокаЗП.Заказ.Машина<>Ссылка Тогда
			Если ЗаказОбъект=Неопределено Тогда
				ЗаказОбъект=СтрокаЗП.Заказ.ПолучитьОбъект();
			КонецЕсли;			
			ЗаказОбъект.Машина=Ссылка;
		КонецЕсли;	
		
		Если СтрокаЗП.Заказ.НомерМашины<>НомерМашины Тогда
			Если ЗаказОбъект=Неопределено Тогда
				ЗаказОбъект=СтрокаЗП.Заказ.ПолучитьОбъект();
			КонецЕсли;			
			ЗаказОбъект.НомерМашины=НомерМашины		
		КонецЕсли; 
		
		Если ЗаказОбъект<>Неопределено Тогда
			ЗаказОбъект.ОбновитьДанныеЗаказа();
			
			ЗаказОбъект.ПересчетДопРасходовПоИнвойсу();
			ЗаказОбъект.ПересчетДопРасходовПоМашине();
			
			ЗаказОбъект.ОбновитьДанныеЗаказа();
			
			ЗаказОбъект.РасчетРублевыхЦен();
			
			ЗаказОбъект.ОбновитьДанныеЗаказа();			
		КонецЕсли;		
	КонецЦикла; 	
КонецПроцедуры 

