#Область СобытияОбъекта

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс);
	КонецЕсли; 
	Префикс = Префикс+Маркировка_ПИ.ЭтотУзел_Код("Основной") + "-";
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)	
	Статус				= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
	Автор 				= ПараметрыСеанса.Пользователь;	
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	//СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков; 
	СпособВводаВОборот 	= Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка;
	//Валетов -
	Основание	= ДанныеЗаполнения;
	
	Если НЕ ЗначениеЗаполнено(Основание) Тогда Возврат КонецЕсли;
	ТипОснования 		= ТипЗнч(Основание);		
	
	СтрокаРеквизитов = "Дата,Организация,Комментарий";
	Если ТипОснования	= Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Организация		= ПолучитьРеквизитШапки(Основание, "Организация");	
	КонецЕсли;	
	
	Если ТипОснования = Тип("СправочникСсылка.Номенклатура") Тогда
		ЗаполнитьТоварыПоСправочнику(Основание);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда				
		ЗаполнитьТоварыПоНакладной(Основание);		
	КонецЕсли;
	
	Дата = ТекущаяДата();
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Статус = Перечисления.СтатусыДоков_Маркировка.ВРаботе;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ЗаписатьГТИНвНоменклатуру();	
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьТоварыПоСправочнику(Основание)
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура
	|ГДЕ
	|	Ссылка В ИЕРАРХИИ (&Основание)
	|	И НЕ ЭтоГруппа
	|	И ГТИН = """"
	|УПОРЯДОЧИТЬ ПО
	|	Родитель.Наименование,
	|	Наименование
	|";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	Товары.Очистить();
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры //ЗаполнитьТоварыПоСправочнику(Основание)

Процедура ЗаполнитьТоварыПоНакладной(Основание)	
	Запрос = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары
	|ГДЕ
	|	Ссылка = &Основание	
	|	И Номенклатура.ГТИН = """"
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Родитель.Наименование,
	|	Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	Товары.Очистить();
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры //ЗаполнитьТоварыПоСправочнику(Основание)

Процедура ЗаписатьГТИНвНоменклатуру()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	ГТИН
	|ИЗ
	|	Документ.ЗапросКодовМаркировки.Товары КАК ТЧ_Товары
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И Номенклатура.ГТИН <> ТЧ_Товары.ГТИН
	|";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СпрОбъект 		= Выборка.Номенклатура.ПолучитьОбъект();					
		СпрОбъект.ГТИН	= Выборка.ГТИН;
		
		СпрОбъект.Записать();		
		
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОповеститьОбИзменении(Выборка.Номенклатура);
		#КОНЕЦЕСЛИ
	КонецЦикла;
КонецПроцедуры
 