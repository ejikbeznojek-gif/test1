Функция НайтиСоздатьЗаданиеНаСборку(Накладная, ЛистНабора) Экспорт
	Ссылка = НайтиДокумент("ЗаданиеНаСборкуКомплектовЧЗ", Новый Структура("ДокОснование,ЛистНабора", Накладная, ЛистНабора));
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Результат = Ссылка;
	Иначе		
		ДокОбъект = Документы.ЗаданиеНаСборкуКомплектовЧЗ.СоздатьДокумент();	
		ДокОбъект.Заполнить(Накладная);
		ДокОбъект.ЛистНабора = ЛистНабора;
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		Результат = ДокОбъект.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьЛистСборки(ЗаданиеНаСборкуКомплектовЧЗ, ЛистНабора) Экспорт 
   
// Кельманов А.В. - HELP-4052 - 2025.05.14 {
//Функция ПолучитьЗабронироватьКМПакетно(Продукция, КоличествоПродукции, ЛистСборки) Экспорт
Функция ПолучитьЗабронироватьКМПакетно(Продукция, КоличествоПродукции, ЛистСборки, Знач ДопПараметры = Неопределено) Экспорт
// Кельманов А.В. - HELP-4052 - 2025.05.14 }

	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	ДатаФормированияКомплекта = ТекущаяДата();
	
	// Кельманов А.В. - HELP-4052 - 2025.05.14 {
	//пПолучения	= Новый Структура(
	//	"Период,Количество,Статус,НовыйСтатус,ТипКода,Добавлять", 
	//	ДатаФормированияКомплекта, КоличествоПродукции, Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати, 
	//	Перечисления.СтатусыКодовМаркировкиФакт.Нанесен, Перечисления.ТипыКодовМаркировки.Набор, Истина
	//);
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = Новый Структура;	
	КонецЕсли;
	
	Статус = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус", Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати);
	
	пПолучения	= Новый Структура(
		"Период,Количество,Статус,НовыйСтатус,ТипКода,Добавлять", 
		ДатаФормированияКомплекта, КоличествоПродукции, Статус, 
		Перечисления.СтатусыКодовМаркировкиФакт.Нанесен, Перечисления.ТипыКодовМаркировки.Набор, Истина
	);	

	Если ДопПараметры.Свойство("МассивДоступныхКодов") Тогда
		пПолучения.Вставить("МассивДоступныхКодов", ДопПараметры.МассивДоступныхКодов);	
	КонецЕсли;
	// Кельманов А.В. - HELP-4052 - 2025.05.14 }
	
	рПолучения 	= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Продукция, ЛистСборки, пПолучения);
		
	Если рПолучения.Успешно Тогда
		КодыПродукции = рПолучения.Данные[Продукция];
	Иначе	
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура							КАК Номенклатура,		
	|	Номенклатура.Родитель.ВидНоменклатуры 	КАК ВидНоменклатуры,
	|	СУММА(Количество) 						КАК Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие 
	|ГДЕ
	|	Ссылка = &Продукция	
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|";
	
	Запрос.УстановитьПараметр("Продукция", Продукция);	
	
	ВсеКодыКомплектующих = Новый Массив;
	
	ТР = Документы.ЛистСборкиКомплектовЧЗ.СоздатьДокумент().ШтрихкодыУпаковок.ВыгрузитьКолонки();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда			
			Количество	= Выборка.Количество*КоличествоПродукции;
			ДопПараметры = Новый Структура("Количество,Период,НовыйСтатус,Добавлять", Количество, ДатаФормированияКомплекта, Перечисления.СтатусыКодовМаркировкиФакт.Вложен, Истина);
			рПолучения	= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Выборка.Номенклатура, ЛистСборки, ДопПараметры);
			Если рПолучения.Успешно Тогда
				КодыКомплектующих = Новый Массив;
				Для Каждого КиЗ Из рПолучения.Данные Цикл
					Для каждого ШтрихкодУпаковки Из КиЗ.Значение Цикл
						ВсеКодыКомплектующих.Добавить(ШтрихкодУпаковки);
						КодыКомплектующих.Добавить(ШтрихкодУпаковки);
					КонецЦикла;					
				КонецЦикла;
				
				Для НомерКомплекта = 0 По КоличествоПродукции - 1 Цикл
					Для НомерПродукции = 0 По Выборка.Количество - 1 Цикл
						СтрокаТР = ТР.Добавить();
						
						СтрокаТР.ШтрихкодКомплекта			= КодыПродукции[НомерКомплекта];
						СтрокаТР.Комплектующее 				= Выборка.Номенклатура;						
						СтрокаТР.ШтрихкодУпаковки   		= КодыКомплектующих[НомерКомплекта*Выборка.Количество + НомерПродукции];
						СтрокаТР.КодКомплектующегоНеНанесен = Истина;
						СтрокаТР.ДатаФормированияКомплекта  = ДатаФормированияКомплекта;
					КонецЦикла;									
				КонецЦикла;
			Иначе
				МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
				Прервать;
			КонецЕсли;
		Иначе			
			Для НомерКомплекта = 0 По КоличествоПродукции - 1 Цикл
				Для НомерПродукции = 0 По Выборка.Количество - 1 Цикл
					СтрокаТР = ТР.Добавить();
					
					СтрокаТР.ШтрихкодКомплекта			= КодыПродукции[НомерКомплекта];
					СтрокаТР.Комплектующее 				= Выборка.Номенклатура;
					СтрокаТР.КодКомплектующегоНеНанесен = Истина;
					СтрокаТР.ДатаФормированияКомплекта  = ДатаФормированияКомплекта;
				КонецЦикла;									
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() = 0 Тогда
		РегистрыСведений.СтатусыКМ_Факт.УстановитьСтатусКМ(ВсеКодыКомплектующих, Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально,	ЛистСборки, Новый Структура("Добавлять,Период,ИспользоватьУправляемыеБлокировки", Истина, ДатаФормированияКомплекта - 1, Истина));
		
		Результат.Успешно	= Истина;
		Результат.Данные	= ТР;	
	КонецЕсли;
	
	ТекстСообщения = "Документ.ЛистСборкиКомплектовЧЗ.ПолучитьЗабронироватьКМПакетно";
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000);
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьКМПакетно(Набор)

Функция ПроверитьДублиКодовКомплектов(ЛСК_Тек) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка,
	|	ШтрихкодКомплекта
	|ПОМЕСТИТЬ ВТ_КомплектыТек
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок 
	|ГДЕ
	|	Ссылка = &ЛСК_Тек
	|	И ШтрихкодКомплекта<>ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодыУпаковок.Ссылка 						КАК ЛСК_Дубль,
	|	ВТ_КомплектыТек.ШтрихкодКомплекта				КАК ШтрихкодКомплекта,
	|	ВТ_КомплектыТек.ШтрихкодКомплекта.Владелец		КАК Номенклатура,
	|	ВТ_КомплектыТек.ШтрихкодКомплекта.Владелец.Код	КАК Номенклатура_Код
	|ИЗ
	|	ВТ_КомплектыТек	
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ШтрихкодыУпаковок
	|ПО
	|	ШтрихкодыУпаковок.ШтрихкодКомплекта = ВТ_КомплектыТек.ШтрихкодКомплекта
	|	И ШтрихкодыУпаковок.Ссылка <> ВТ_КомплектыТек.Ссылка
	|";	
	
	Запрос.УстановитьПараметр("ЛСК_Тек", ЛСК_Тек);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекстСообщения = СтрШаблон("Дублирован КМ комплекта: '%1' ! Номенклатура: '%2' (%3), документ дубль: %4 !!!", 
			Выборка.ШтрихкодКомплекта, Выборка.Номенклатура, Выборка.Номенклатура_Код, Выборка.ЛСК_Дубль);
		Результат.Ошибки.Добавить(ТекстСообщения); 			
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции // ПроверитьДублиКодовКомплектов(ЛСК_Тек) Экспорт

Функция ОчиститьДвижения(ДокСсылка) Экспорт
