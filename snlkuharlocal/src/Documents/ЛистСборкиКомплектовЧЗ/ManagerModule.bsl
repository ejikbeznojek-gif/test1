Функция ЗаписатьВЖурналИзмененийРеквизитовДокумента(Документ, ИмяРеквизита = "ОчисткаЛСК", СтароеЗначение = Неопределено,
		НовоеЗначение = Неопределено) Экспорт

	Запись = РегистрыСведений.ЖурналИзмененийРеквизитов.СоздатьМенеджерЗаписи();
	
       Запись.Дата = ТекущаяДатаСеанса();
	Запись.Документ = Документ;
	Запись.ИмяРеквизита = ИмяРеквизита;

	Если СтароеЗначение <> Неопределено Тогда
		Запись.СтароеЗначение = СтароеЗначение;
	КонецЕсли;
	Если НовоеЗначение <> Неопределено Тогда
		Запись.НовоеЗначение = НовоеЗначение;
	КонецЕсли;
	
	Запись.Пользователь = ПараметрыСеанса.Пользователь;
	Запись.ТипДокумента = Документ.Метаданные().Имя;
	
	Попытка
		Запись.Записать();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;

КонецФункции

