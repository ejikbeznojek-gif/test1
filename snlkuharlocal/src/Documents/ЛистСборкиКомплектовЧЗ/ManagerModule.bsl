//Добавляет комплект в РНК
//
//Параметры:
//	ЛистНабора		- Документ.ЛистНабора, Документ.ЛистПеремаркировки - Cсылка на лист набора или перемаркировки
//	Продукция		- Справочник.Номенклатура, Справочник.ШтрихКодыУпаковок - Cсылка на комплект (продукцию) или ссылка на код маркировки продукции
//	Комплектующие	- ТаблицаЗначений - Таблица комплектующих 
//	Колонки
//		Номенклатура	- Справочник.Номенклатура
//		ШтрихКод		- Справочник.ШтрихКоды,Справочник.ШтрихкодыУпаковокТоваров
//		Количество 		- Число (1 - для КМ, произвольное для обычного ШК)
// Возвращаемое значение:
//   СтруктураРезультата  - стандартная структура результата
Функция ДобавитьКомплектВНакладную(ЛистНабора, Продукция, Комплектующие) Экспорт
	Накладная		= ПолучитьРеквизитШапки(ЛистНабора, "ДокОснование");	
	ЗаданиеНаСборку = НайтиСоздатьЗаданиеНаСборку(Накладная, ЛистНабора);
	ЛистСборки		= НайтиСоздатьЛистСборки(ЗаданиеНаСборку, ЛистНабора);
	
	Возврат ДобавитьКомплектВЛистСборки(ЛистСборки, Продукция, Комплектующие);
КонецФункции //ДобавитьКомплектВНакладную(Накладная, ЛистНабора, Продукция, Комплектующие) Экспорт

//Добавляет комплект в лист сборки
//
//Параметры:
//	ЛистСборки		- Документ.ЛистСборкиКомплектовЧЗ - Cсылка на лист сборки
//	ПродукцияВход	- Справочник.Номенклатура, Справочник.ШтрихКодыУпаковок - Cсылка на комплект (продукцию) или ссылка на код маркировки продукции
//	Комплектующие	- ТаблицаЗначений - Таблица комплектующих 
//	Колонки
//		Номенклатура	- Справочник.Номенклатура
//		ШтрихКод		- Справочник.ШтрихКоды,Справочник.ШтрихкодыУпаковокТоваров
//		Количество 		- Число (1 - для КМ, произвольное для обычного ШК)
// Возвращаемое значение:
//   СтруктураРезультата  - стандартная структура результата
Функция ДобавитьКомплектВЛистСборки(ЛистСборки, ПродукцияВход, Комплектующие) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ТипЗнч(ПродукцияВход) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") Тогда
		Продукция = ПолучитьРеквизитШапки(ПродукцияВход, "Владелец");
	Иначе
		Продукция = ПродукцияВход;
	КонецЕсли; 
	
	КодыКомплектующих = Комплектующие.СкопироватьКолонки();
	
	рПроверки = ПроверитьДублиКодов(ЛистСборки, Комплектующие);
	Если рПроверки.Успешно Тогда
		Для Каждого СтрокаК Из Комплектующие Цикл
			Если ТипЗнч(СтрокаК.ШтрихКод) = Тип("СправочникСсылка.ШтрихКоды") Тогда
				рПолучения = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(СтрокаК.Номенклатура, ЛистСборки, Новый Структура("Количество", СтрокаК.Количество));
				Если рПолучения.Успешно Тогда
					Для Каждого ШтрихКодУпаковки Из рПолучения.Данные Цикл
						СтрокаР = КодыКомплектующих.Добавить();					
						
						СтрокаР.Номенклатура = СтрокаК.Номенклатура;
						СтрокаР.ШтрихКод	 = ШтрихКодУпаковки;
						СтрокаР.Количество	 = 1;
					КонецЦикла; 
				Иначе					
					МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);				
				КонецЕсли;
			Иначе
				СтрокаР = Результат.Данные.Добавить();					
				ЗаполнитьЗначенияСвойств(СтрокаР, СтрокаК);						
			КонецЕсли; 		
		КонецЦикла;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПроверки);
	КонецЕсли;
	
	Результат.Данные.Вставить("КодыКомплектующих", КодыКомплектующих);
	
	Если Результат.Ошибки.Количество() = 0 Тогда
		Результат.Данные = Новый Структура("КодыКомплектующих", КодыКомплектующих);
		
		Если ТипЗнч(ПродукцияВход) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") Тогда
			Результат.Данные.Вставить("ШтрихкодКомплекта", ПродукцияВход);
		Иначе
			рПолучения = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Продукция, ЛистСборки, Новый Структура("Количество", 1));
			Если рПолучения.Успешно Тогда
				Результат.Данные.Вставить("ШтрихкодКомплекта", рПолучения.Данные[0]);
			Иначе
				МаркировкаКС.ДобавитьОшибки(Результат, рПроверки);			
			КонецЕсли;			
		КонецЕсли;
			
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Если Результат.Успешно Тогда
		ДатаФормированияКомплекта = ТекущаяДата();		
		//ДобавитьСтатусыКДвижениям(ЛистСборки, Результат.Данные, ДатаФормированияКомплекта);		
		
		ЗаписатьКомплектВЛистСборки(ЛистСборки, Результат.Данные, ДатаФормированияКомплекта);	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ДобавитьКомплектВЛистСборки(ЛистСборки, ПродукцияВход, Комплектующие) Экспорт

Функция ДобавитьСтатусыКДвижениям(ЛистСборки, ДанныеКомплекта, ДатаФормированияКомплекта)
	Подразделение = ПолучитьРеквизитШапки(ЛистСборки, "Подразделение");
	
	Если ЗначениеЗаполнено(ЛистСборки) И ТипЗнч(ЛистСборки) = Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ") Тогда
		НЗ = РегистрыСведений.СтатусыКМ_Факт.СоздатьНаборЗаписей();
		НЗ.Отбор.Регистратор.Установить(ЛистСборки, Истина);
		
		Запись = НЗ.Добавить();
		
		Запись.Период 			= ДатаФормированияКомплекта;
		Запись.Регистратор		= ЛистСборки;
		Запись.ШтрихКодУпаковки = ДанныеКомплекта.ШтрихкодКомплекта;
		Запись.Местонахождение	= Подразделение;
		
		Для каждого СтрокаК Из ДанныеКомплекта.КодыКомплектующих Цикл
			Запись = НЗ.Добавить();
		
			Запись.Период 			= ДатаФормированияКомплекта;
			Запись.Регистратор		= ЛистСборки;
			Запись.ШтрихКодУпаковки = СтрокаК.ШтрихКод;
			Запись.Местонахождение	= Подразделение;		
		КонецЦикла; 
		
		НЗ.Записать(Ложь);	
	КонецЕсли;
КонецФункции //ДобавитьСтатусыКДвижениям(ЛистСборки, Результат.Данные)

Функция ЗаписатьКомплектВЛистСборки(ЛистСборки, ДанныеКомплекта, ДатаФормированияКомплекта)
	ДокОбъект = ЛистСборки.ПолучитьОбъект();
	
	ШтрихкодКомплекта = ДанныеКомплекта.ШтрихкодКомплекта;
	
	Для Каждого СтрокаК Из ДанныеКомплекта.КодыКомплектующих Цикл
		СтрокаК.Комплектующее 				= СтрокаК.Номенклатура;
		СтрокаК.ШтрихкодУпаковки			= СтрокаК.ШтрихКод;
		СтрокаК.ШтрихкодКомплекта   		= ШтрихкодКомплекта;	
		СтрокаК.ДатаФормированияКомплекта   = ДатаФормированияКомплекта;
	КонецЦикла; 
	
	ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
КонецФункции

Функция ПроверитьДублиКодов(ЛистСборки, Комплектующие)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Комплектующие ИЗ &Комплектующие КАК Комплектующие 
	|;
	|ВЫБРАТЬ
	|	ВТ_Комплектующие.ШтрихКод КАК ШтрихКод
	|ИЗ
	|	ВТ_Комплектующие
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ТЧ
	|ПО
	|	ТЧ.Ссылка = &ЛистСборки
	|	И ТЧ.ШтрихкодУпаковки = Комплектующие.ШтрихКод
	|";
	
	Запрос.УстановитьПараметр("ЛистСборки", 	ЛистСборки);
	Запрос.УстановитьПараметр("Комплектующие",	Комплектующие);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекстОшибки = СтрШаблон("Код комплектующего: %1 уже присутствует в листе сборки комплекта !", Выборка.ШтрихКод);
		Результат.Ошибки.Добавить(ТекстОшибки);		
	КонецЦикла; 
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПроверитьДублиКодов(ЛистСборки, Комплектующие)

Функция НайтиСоздатьЛистСборки(ЗаданиеНаСборкуКомплектов, ЛистНабора) Экспорт	
	Ссылка = НайтиДокумент("ЛистСборкиКомплектовЧЗ", Новый Структура("ДокОснование,ЛистНабора", ЗаданиеНаСборкуКомплектов, ЛистНабора));
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Результат = Ссылка;
	Иначе		
		ДокОбъект = Документы.ЛистСборкиКомплектовЧЗ.СоздатьДокумент();	
		ДокОбъект.Заполнить(ЗаданиеНаСборкуКомплектов);
		ДокОбъект.ЛистНабора = ЛистНабора;
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		Результат = ДокОбъект.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьЛистСборки(ЗаданиеНаСборкуКомплектовЧЗ, ЛистНабора) Экспорт

Функция ДобавитьСпайкуFBSВЛСК (ТаблицаКодов,КодНабора,ЗСБ) экспорт
	
	СтруктураОтвета=новый Структура("Успех,Ошибки",Истина,"");
	МассивОшибок=новый Массив;
	ЛСК=ПолучитьЛСКДляFBS(ЗСБ);
	ЛСКОбъект=ЛСК.ПолучитьОбъект();
	
	если ЛСКОбъект.ШтрихкодыУпаковок.Найти(КодНабора,"ШтрихкодКомплекта") <> Неопределено тогда
		 МассивОшибок.Добавить("Обнаружен дубль набора в ЛСК "+ЛСКОбъект.Номер+" по коду "+КодНабора);
	КонецЕсли;
	
	
	Для Каждого СтрокаТЗ из ТаблицаКодов цикл
		КодЧЗ=СтрокаТЗ.МаркаЧЗ;
		если не ЗначениеЗаполнено(КодЧЗ) тогда
			Продолжить;
		КонецЕсли;
		если ЛСКОбъект.ШтрихкодыУпаковок.Найти(КодЧЗ,"ШтрихкодУпаковки") <> Неопределено тогда
			МассивОшибок.Добавить("Обнаружен дубль комплектующей в ЛСК "+ЛСКОбъект.Номер+" по коду "+КодЧЗ);
			Продолжить;
		КонецЕсли;		
		СтрТЧ = ЛСКОбъект.ШтрихкодыУпаковок.Добавить();
		СтрТЧ.ДатаФормированияКомплекта=ТекущаяДата();
		СтрТЧ.Комплектующее=СтрокаТЗ.Номенклатура;
		СтрТЧ.ШтрихкодКомплекта=КодНабора;
		СтрТЧ.ШтрихкодУпаковки=КодЧЗ;	
		СтрТЧ.КодКомплектующегоНеНанесен=СтрокаТЗ.НанесенияНеБыло; 
	КонецЦикла;
	
	если МассивОшибок.Количество()=0 тогда
		попытка
			ЛСКОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			МассивОшибок.Добавить("Не удалось записать документ по причине "+ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли; 
	
	
	если МассивОшибок.Количество()>0 тогда
		СтруктураОтвета.успех=ложь;
		СтруктураОтвета.Ошибки=СтрСоединить(МассивОшибок,символы.ПС);
	КонецЕсли;
	
	возврат СтруктураОтвета;
КонецФункции

Функция ТекстЗапроса_ВсеКодыДокумента()
	Возврат "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки,ШтрихкодКомплекта,ШтрихкодКоробки
	|ПОМЕСТИТЬ ВТ_ШтрихкодыУпаковок
	|ИЗ
	|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ПОМЕСТИТЬ ВТ_ВсеКМДокумента
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодУпаковки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихкодКомплекта
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодКомплекта <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихкодКоробки
	|ИЗ
	|	ВТ_ШтрихкодыУпаковок
	|ГДЕ	
	|	ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|";
	
КонецФункции

Функция ПолучитьПорцииКМДляПроверки(ДокСсылка, РазмерПорции = 1000) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ВсеКодыДокумента() + "
	|;
	|ВЫБРАТЬ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.Наименование КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ВсеКМДокумента
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ИспользованныеКодыАгрегаций КАК ИспользованныеКА
	|ПО 	
	|	ИспользованныеКА.ШтрихКодУпаковки = ВТ_ВсеКМДокумента.ШтрихКодУпаковки
	|	И ИспользованныеКА.Регистратор ССЫЛКА Документ.МаркировкаТоваровИСМП
	|	И ИспользованныеКА.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
	|	И ИспользованныеКА.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|	И ИспользованныеКА.Регистратор.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная
	|ГДЕ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.Наименование КАК ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ВсеКМДокумента
	|ГДЕ 
	|	ВТ_ВсеКМДокумента.ШтрихкодУпаковки.ТипКода <> ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ВсегоСтрок 	= Выборка.Количество();
	Сч			= 0;
	
	Порции = Новый Массив;
	ТекПорция = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		Сч = Сч + 1;
		
		ТекПорция.Добавить(Выборка.ШтрихкодУпаковки);
		Если ТекПорция.Количество() >= РазмерПорции ИЛИ Сч >= ВсегоСтрок Тогда
			Порции.Добавить(ТекПорция);
			ТекПорция = Новый Массив;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Порции;
КонецФункции //ПолучитьКМДляПроверки(ДокСсылка) Экспорт

Функция ПолучитьТаблицуКМДокумента(ДокСсылка, ДопПараметры = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_ВсеКодыДокумента() + "
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ИЗ
	|	ВТ_ВсеКМДокумента	
	|";                                                                                
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //ПолучитьТаблицуКМДокумента(ДокСсылка, ДопПараметры = Неопределено) Экспорт

