Функция ЭтоМоноКомплектация()
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Владелец КАК Продукция
	|ИЗ 
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	Ссылка В (&МассивКодов)
	|	И НЕ Владелец.ВерсияДанных ЕСТЬ NULL
	|";
	
	МассивКодов = ШтрихкодыУпаковок.Выгрузить( , "ШтрихкодКомплекта");
	МассивКодов.Свернуть("ШтрихкодКомплекта");
	
	Запрос.УстановитьПараметр("МассивКодов", МассивКодов.ВыгрузитьКолонку("ШтрихкодКомплекта"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 1 Тогда
		Выборка.Следующий();
		
		Если ЗначениеЗаполнено(Выборка.Продукция) Тогда	
			Результат.Данные	= Выборка.Продукция;			
			Результат.Успешно	= Истина;
		КонецЕсли;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ЭтоМоноКомплектация() 

Функция ВсеНаборыСобраны()
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(КолСобрано) КАК КолСобрано,
	|	СУММА(КолЗадание) КАК КолЗадание
	|ИЗ
	|(
	|	ВЫБРАТЬ
	|		Номенклатура,
	|		Количество*Коэффициент	КАК КолСобрано,
	|		0						КАК КолЗадание
	|	ИЗ
	|		Документ.ЛистСборкиКомплектовЧЗ.Товары КАК ЛистСборкиКомплектовЧЗТовары
	|	ГДЕ
	|		Ссылка.ДокОснование = &ДокОснование
	|		И Ссылка.Проведен И Ссылка.Завершен	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	ВЫБРАТЬ
	|		Номенклатура,
	|		0						КАК КолСобрано,
	|		Количество*Коэффициент	КАК КолЗадание
	|	ИЗ
	|		Документ.ЗаданиеНаСборкуКомплектовЧЗ.Товары
	|	ГДЕ
	|		Ссылка = &ДокОснование
	|) КАК Сводный
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ИМЕЮЩИЕ
	|	СУММА(КолСобрано)<>СУММА(КолЗадание)
	|";	
			
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);			
	
	Возврат Запрос.Выполнить().Пустой();
КонецФункции //ВсеНаборыСобраны() 

Функция КоличествоКомплектов()
	ШККомплектов = Новый Соответствие;
	Для Каждого СтрокаТЧ Из ШтрихкодыУпаковок Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодКомплекта) Тогда
			ШККомплектов[СтрокаТЧ.ШтрихкодКомплекта] = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ШККомплектов.Количество();
КонецФункции //КоличествоКомплектов() 

