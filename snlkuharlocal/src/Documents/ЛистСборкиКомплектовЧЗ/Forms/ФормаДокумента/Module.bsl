	мТекКомплект = ХэшКомплектов[ПолучитьХэшКомплектаПоНом(Коды)];
	
	// Кельманов А.В. - HELP-9583 - 2026.04.28 {
	Если Объект.фРежим = 0 И ЗначениеЗаполнено(Объект.Продукция) И ЗначениеЗаполнено(мТекКомплект) И Объект.Продукция <> мТекКомплект Тогда
		
