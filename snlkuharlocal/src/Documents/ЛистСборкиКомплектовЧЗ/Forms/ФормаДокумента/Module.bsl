&НаКлиенте
Функция ДобавитьКМвДокумент_ОбычныйРежим(Номенклатура, КодМаркировки)
	
	Нашли = Ложь;
	
	// Кельманов А.В. - HELP-5254 - 2026.03.24 {
	//Если ДопустимыеКомплектующие.НайтиПоЗначению(Номенклатура) <> Неопределено Тогда
	Если ДопустимыеКомплектующие_Продукция.НайтиПоЗначению(Номенклатура) <> Неопределено Тогда
	// Кельманов А.В. - HELP-5254 - 2026.03.24 }
		
		Нашли = Истина;
		Строки = Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодУпаковки", КодМаркировки));
		Если Строки.Количество() = 0 Тогда				
			СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();
			СтрокаТЧ.Комплектующее		= Номенклатура;
			СтрокаТЧ.ШтрихкодУпаковки 	= КодМаркировки;
		    //++Данилова Е.В. 11.06.2026 №0000001219
			ИдентификаторСтроки = СтрокаТЧ.ПолучитьИдентификатор(); 
			Элементы.ШтрихкодыУпаковок.ТекущаяСтрока = ИдентификаторСтроки; 
			//--Данилова Е.В. 11.06.2026 
			НайтиКомплект();
		Иначе
			ТекстСообщения = СтрШаблон("Код маркировки : '%1' уже присутствует в документе !", КодМаркировки); 
			ПоказатьПредупреждение(, ТекстСообщения);				
			МаркировкаК.ВоспроизвестиЗвукОшибки();
		КонецЕсли;				
	КонецЕсли;
	
	Если ДопустимыеКомплекты.НайтиПоЗначению(Номенклатура) <> Неопределено Тогда
		Нашли	= Истина;				
		Строки	= Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодКомплекта", КодМаркировки));
		
		Ошибки = Новый Массив;
		
		Если Строки.Количество() = 0 Тогда
			Ошибки.Добавить("Не обнаружено строк комплектующих для комплекта ! " + Номенклатура);
		Иначе
			Для Каждого СтрокаТЧ Из Строки Цикл
				Если СтрокаТЧ.КодКомплектаПодтвержденСканированием Тогда
					Ошибки.Добавить("Код комплекта уже сканировался в документ ! Стр.: " + Объект.ШтрихкодыУпаковок.Индекс(СтрокаТЧ));
				КонецЕсли; 				
			КонецЦикла;			
		КонецЕсли;		
		
		Если Ошибки.Количество() = 0  Тогда
			Для Каждого СтрокаТЧ Из Строки Цикл
				СтрокаТЧ.КодКомплектаПодтвержденСканированием = Истина;					
			КонецЦикла;
			//++Данилова Е.В. 11.06.2026 №0000001219 
			Если Строки.Количество() > 0 Тогда 
				ИдентификаторСтроки = СтрокаТЧ.ПолучитьИдентификатор(); 
				Элементы.ШтрихкодыУпаковок.ТекущаяСтрока = ИдентификаторСтроки;
			КонецЕсли;
			ОбновитьКоличествоСобранныхКомплектов(); 
			//--Данилова Е.В. 11.06.2026
			Записать();
		Иначе
			ПоказатьПредупреждение(, СтрСоединить(Ошибки, Символы.ПС));
		КонецЕсли;				
	КонецЕсли;
	
	Если Не Нашли Тогда
				
		// Кельманов А.В. - HELP-5254 - 2026.03.24 {
		//ТекстСообщения = СтрШаблон("Номенклатура: '%1' ( %2 ) отсутствует в задании на сборку !", Номенклатура, ПолучитьРеквизитШапки(Номенклатура, "Код"));
		ТекстСообщения = СтрШаблон("Номенклатура: '%1' ( %2 ) отсутствует в комплекте: '%3' !", Номенклатура, ПолучитьРеквизитШапки(Номенклатура, "Код"), Объект.Продукция);
		// Кельманов А.В. - HELP-5254 - 2026.03.24 }
		
		ПоказатьПредупреждение(, ТекстСообщения);			
		МаркировкаК.ВоспроизвестиЗвукОшибки();
		
	КонецЕсли;
	
КонецФункции //ДобавитьКМвДокумент(Номенклатура, КодМаркировки)

&НаКлиенте
Функция ДобавитьКМвДокумент_УпрощенныйРежим(Номенклатура, КодМаркировки)
	Если ДопустимыеКомплекты.НайтиПоЗначению(Номенклатура) <> Неопределено Тогда
		Строки	= Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодКомплекта", ПредопределенноеЗначение("Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка")));
		Если Строки.Количество() = 0 Тогда
			рПолучения = ПолучитьЗабронироватьКодыКомплектующих(Номенклатура);			
			Если рПолучения.Успешно Тогда
				Данные = рПолучения.Данные;
				Для Каждого ШтрихкодУпаковки Из Данные.КодыКомплектующих Цикл
					СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();									
					
					СтрокаТЧ.ШтрихкодКомплекта	= КодМаркировки;
					СтрокаТЧ.ШтрихкодУпаковки	= ШтрихкодУпаковки;
					СтрокаТЧ.Комплектующее		= ПолучитьРеквизитШапки(ШтрихкодУпаковки, "Владелец");					
					СтрокаТЧ.ДатаФормированияКомплекта = Данные.ДатаФормированияКомплекта;
					//++Данилова Е.В. 11.06.2026 №0000001219
					ИдентификаторСтроки = СтрокаТЧ.ПолучитьИдентификатор(); 
					Элементы.ШтрихкодыУпаковок.ТекущаяСтрока = ИдентификаторСтроки; 
					//--Данилова Е.В. 11.06.2026
				КонецЦикла; 			
				
				Для каждого СтрокаНТК Из Данные.НеТоварныеКомплектующие Цикл
					Для Сч = 1 По СтрокаНТК.Количество  Цикл
						СтрокаТЧ.ШтрихкодКомплекта	= КодМаркировки;						
						СтрокаТЧ.Комплектующее		= СтрокаНТК.Комплектующее;					
						СтрокаТЧ.ДатаФормированияКомплекта = Данные.ДатаФормированияКомплекта;					
					КонецЦикла;
				КонецЦикла; 
				
				Записать();
			Иначе				
				ПоказатьПредупреждение(, СтрСоединить(рПолучения, Символы.ПС));
				МаркировкаК.ВоспроизвестиЗвукОшибки();
			КонецЕсли; 
		Иначе			
			ТекстСообщения = СтрШаблон("В документе найдены строки недозаполненного набора !");
			ПоказатьПредупреждение(, ТекстСообщения);			
			МаркировкаК.ВоспроизвестиЗвукОшибки();
		КонецЕсли;
	Иначе
		ТекстСообщения = СтрШаблон("Набор: '%1' ( %2 ) отсутствует в задании на сборку !", Номенклатура, ПолучитьРеквизитШапки(Номенклатура, "Код"));
		ПоказатьПредупреждение(, ТекстСообщения);			
		МаркировкаК.ВоспроизвестиЗвукОшибки();
	КонецЕсли;		
КонецФункции //ДобавитьКомлектВДокумент_УпрощенныйРежим() 

&НаСервере
Функция ПолучитьЗабронироватьКодыКомплектующих(Набор)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,	
	|	Количество,
	|	Номенклатура.Родитель.ВидНоменклатуры КАК ВидНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие 
	|ГДЕ
	|	Ссылка = &Набор	
	|";
	
	Запрос.УстановитьПараметр("Набор", Набор);	
	
	КодыКомплектующих 		= Новый Массив;
	НеТоварныеКомплектующие = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
			Для Сч = 0 По Выборка.Количество() Цикл
				рПолучения = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(Выборка.Номенклатура, Объект.Ссылка, Новый Структура("Количество", Выборка.Количество));
				Если рПолучения.Успешно Тогда
					Для Каждого ШтрихкодУпаковки Из рПолучения.Данные Цикл
						КодыКомплектующих.Добавить(ШтрихкодУпаковки);				
					КонецЦикла;
				Иначе
					МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);				
					Прервать;
				КонецЕсли; 
			КонецЦикла;			
		Иначе			
			НеТоварныеКомплектующие.Добавить(Новый Структура("Комплектующее,Количество", Выборка.Номенклатура, Выборка.Количество));
		КонецЕсли;
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() = 0 Тогда
		ДатаФормированияКомплекта = ТекущаяДата();
		РегистрыСведений.СтатусыКМ_Факт.УстановитьСтатусКМ(КодыКомплектующих, Перечисления.СтатусыКодовМаркировкиФакт.Вложен, Объект.Ссылка, Новый Структура("Добавлять,Период,ИспользоватьУправляемыеБлокировки", Истина, ДатаФормированияКомплекта, Истина));
		
		Результат.Данные = Новый Структура(
			"НеТоварныеКомплектующие,КодыКомплектующих,ДатаФормированияКомплекта",
			НеТоварныеКомплектующие,КодыКомплектующих,ДатаФормированияКомплекта
		);		
	Иначе
		Результат.Успешно = Ложь;		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьКодыКомплектующих(Набор)

