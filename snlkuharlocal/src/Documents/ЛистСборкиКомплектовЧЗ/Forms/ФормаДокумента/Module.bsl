Процедура РаспечататьКодыКомплектов(Команда)
	сКоды = Новый Соответствие;	
	мКоды = Новый Массив;
	Для каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок Цикл
		Если сКоды[СтрокаТЧ.ШтрихкодКомплекта] = Неопределено Тогда
			сКоды[СтрокаТЧ.ШтрихкодКомплекта] = Истина;	
			мКоды.Добавить(СтрокаТЧ.ШтрихкодКомплекта);
		КонецЕсли;		
	КонецЦикла; 
	
	рПечати = РаспечататьКодыКомплектов_НаСервере(мКоды);
	Если рПечати.Успешно Тогда
		Если фПечататьКодНабораСразуНаПринтер Тогда
			рПечати.Данные.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
		Иначе					
			рПечати.Данные.Показать("Этикетки по ЛСК: " + Объект.Ссылка);      
		КонецЕсли;        
		// Кухарь А.Ю. 06.05.2025 начало
