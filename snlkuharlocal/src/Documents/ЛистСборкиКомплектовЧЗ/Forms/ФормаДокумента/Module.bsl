&НаКлиенте
Процедура РазрешитьРедактированиеМарок(Команда)
	
	// Кухарь А.Ю.  04.06.2025 начало
	РезультатПроверки=ПроверитьВозможностьОчистки(объект.ДокОснование); 
	если не РезультатПроверки.Успех тогда
		Сообщить(СтрСоединить(РезультатПроверки.Ошибки,Символы.ПС));
		возврат;
	КонецЕсли;
	// Кухарь А.Ю.  04.06.2025 конец
		
	
	ПричинаОчисткиЛСК = "";
	Если НЕ ВвестиСтроку(ПричинаОчисткиЛСК, "Введите причину очистки ЛСК") Тогда
		Сообщить("Строка не введена. Редактирование запрещено!");
		Возврат;
	КонецЕсли;
	
	Если ПричинаОчисткиЛСК = "" Тогда
		ПричинаОчисткиЛСК = "Очистка ЛСК";
	КонецЕсли;
	
	Документы.ЛистСборкиКомплектовЧЗ.ЗаписатьВЖурналИзмененийРеквизитовДокумента(Объект.Ссылка, "ОчисткаЛСК",, ПричинаОчисткиЛСК);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		ДополнительныеРеквизиты.Вставить("ОчисткаЛСК", Истина);
	КонецЕсли;

	// Кухарь А.Ю.  04.06.2025 начало
	ТолькоПросмотр = ложь;
	// Кухарь А.Ю.  04.06.2025 конец
		
	
КонецПроцедуры

&НаКлиенте
Процедура ШтрихкодыУпаковокПередУдалением(Элемент, Отказ)
	
	ЗначениеСвойства = Неопределено;
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") И ДополнительныеРеквизиты.Свойство("ОчисткаЛСК") Тогда
		ЗначениеСвойства = ДополнительныеРеквизиты.ОчисткаЛСК;
	КонецЕсли;
	
	Если ЗначениеСвойства = Неопределено ИЛИ ЗначениеСвойства = Ложь Тогда
		Сообщить("Нет прав на удаление строки!!!");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры
 
&НаСервереБезКонтекста
Функция ПроверитьВозможностьОчистки(ЗСБ)
	СтруктураВозврата = новый Структура("Успех,Ошибки");
	МассивОшибок = новый Массив;
	Запрос=новый запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	МаркировкаТоваровИСМП.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	               |ГДЕ
	               |	МаркировкаТоваровИСМП.Статус <> &ВРаботе
	               |	И МаркировкаТоваровИСМП.Проведен
	               |	И МаркировкаТоваровИСМП.ВидОперацииИСМП = &ФормированиеНабора
	               |	И МаркировкаТоваровИСМП.ДокументОснование = &ЗСБ";
	запрос.УстановитьПараметр("ВРаботе",Перечисления.СтатусыДокументовМаркировки.ВРаботе);
	запрос.УстановитьПараметр("ЗСБ",ЗСБ);
	запрос.УстановитьПараметр("ФормированиеНабора",Перечисления.ВидыОперацийИСМП.ФормированиеНабора);
	выборка = запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		МассивОшибок.Добавить("Найден документ для отправки в ЧЗ, в статусе не в работе. Перед очисткой нужно этот документ вернуть в работу "+выборка.ссылка);
	КонецЦикла;
	если МассивОшибок.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь;
		СтруктураВозврата.Ошибки = МассивОшибок;
	иначе
		СтруктураВозврата.Успех = Истина;
	КонецЕсли;
	
	возврат СтруктураВозврата;
КонецФункции

#КонецОбласти
