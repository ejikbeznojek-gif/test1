&НаКлиенте
Процедура КоличествоПродукцииПриИзменении(Элемент)
	
	Если Объект.фРежим = 0 И ЗначениеЗаполнено(Объект.Продукция) И ЗначениеЗаполнено(Объект.КоличествоДокумента) Тогда
		
		Если Объект.Ссылка.Пустая() Тогда
			
			Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));	
			
		КонецЕсли;
		
		ТекстОшибки = ЗабронироватьКодыСпаек();
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			
			Сообщить(ТекстОшибки);
			
			Объект.КоличествоДокумента = 0;
			
			Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
			
			ПоказатьПредупреждение(, "Укажите плановое количество спаек!");
			
			Элементы.КоличествоПродукции.ТолькоПросмотр = Ложь;
			Элементы.КоличествоПродукции.ЦветФона = WebЦвета.Бирюзовый; 
			ЭтаФорма.ТекущийЭлемент = Элементы.КоличествоПродукции;
			
		Иначе
			
			Элементы.КоличествоПродукции.ЦветФона = WebЦвета.Белый; 

		КонецЕсли;
		
		УправлениеВидимостью();
		
	КонецЕсли;

КонецПроцедуры

