// Кельманов А.В. - HELP-5254 - 2026.03.30
&НаСервере
Функция ЗабронироватьКодыСпаек()
	
	ТекстОшибки = "";
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКМ_Факт.СрезПоследних(, Номенклатура = &Владелец) КАК СтатусыКМ_ФактСрезПоследних
	|		ПО ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки = СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки
	|ГДЕ
	|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЗСБЧЗ
	|	И СтатусыКМ_ФактСрезПоследних.Статус = &Статус";
	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыКодовМаркировкиФакт.Зарезервирован);
	Запрос.УстановитьПараметр("ЗСБЧЗ", Объект.ДокОснование);
	Запрос.УстановитьПараметр("Владелец", Объект.Продукция);
	
	МассивДоступныхКодовЗСБ = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	
	ТаблицаДляПолученияКодов = Новый ТаблицаЗначений;
	ТаблицаДляПолученияКодов.Колонки.Добавить("Номенклатура");
	ТаблицаДляПолученияКодов.Колонки.Добавить("Количество");
	
	НовСтрПолучениеКодов = ТаблицаДляПолученияКодов.Добавить();
	НовСтрПолучениеКодов.Номенклатура = Объект.Продукция;
	НовСтрПолучениеКодов.Количество = Объект.КоличествоДокумента;
	
	ДопПараметры = Новый Структура("Статус, МассивДоступныхКодов, ТипКода, Добавлять",
	Перечисления.СтатусыКодовМаркировкиФакт.Зарезервирован, МассивДоступныхКодовЗСБ, Перечисления.ТипыКодовМаркировки.Набор, Истина);
	
	РезультатПолученияКодов = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(ТаблицаДляПолученияКодов, Объект.Ссылка, ДопПараметры);		
	
	Если Не РезультатПолученияКодов.Успешно Тогда
		
		ТекстОшибки = СтрСоединить(РезультатПолученияКодов.Ошибки, Символы.ПС);
		
	Иначе
		
		Объект.ШтрихкодыУпаковок.Очистить();
		Объект.Товары.Очистить();
		
		Для Каждого СтрокаДанных Из РезультатПолученияКодов.Данные.Получить(Объект.Продукция) Цикл
			
			НовСтр = Объект.ШтрихкодыУпаковок.Добавить();
			
			НовСтр.ШтрихкодКомплекта = СтрокаДанных;
			
		КонецЦикла;
		
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
		
	КонецЕсли;
	
	Возврат ТекстОшибки;

КонецФункции

// Кельманов А.В. - HELP-4221 - 2025.07.17
&НаСервере
Процедура ОпределитьСкладМаркированногоТовара()
	
	ЭтоСкладМаркированногоТовара = Ложь;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(ЗаданиеНаСборкуКомплектовЧЗ.ДокОснование.Склад.ЭтоСкладМаркированногоТовара, ЛОЖЬ) КАК ЭтоСкладМаркированногоТовара
	               |ИЗ
	               |	Документ.ЗаданиеНаСборкуКомплектовЧЗ КАК ЗаданиеНаСборкуКомплектовЧЗ
	               |ГДЕ
	               |	ЗаданиеНаСборкуКомплектовЧЗ.Ссылка = &ЗСБ";
	
	Запрос.УстановитьПараметр("ЗСБ", Объект.ДокОснование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЭтоСкладМаркированногоТовара = Выборка.ЭтоСкладМаркированногоТовара;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостью()
	
	Если РольДоступна("Администратор") Тогда	
		Элементы.Завершен.ТолькоПросмотр				= ТолькоПросмотр;	
		
		Элементы.ШтрихкодыУпаковок.ТолькоПросмотр		= ТолькоПросмотр;	
		Элементы.ШтрихкодыУпаковок.ИзменятьСоставСтрок	= Истина;		
	КонецЕсли;
	
	Элементы.фРежим.Доступность = (Объект.ШтрихкодыУпаковок.Количество() = 0);
	
	Если Объект.Завершен Тогда
		Элементы.кнРаспечататьКодКомплекта.Доступность	= Ложь;
		Элементы.кнЗавершитьСборку.Доступность 			= Ложь;
		
		Элементы.ОчититьКодыКомплектующих.Доступность 	= Ложь;
		Элементы.ЗаполнитьКодыКомплектующих.Доступность = Ложь;		
		
		Если НЕ РольДоступна("Администратор") Тогда
			ТолькоПросмотр	= Истина;			
		КонецЕсли;
	Иначе
		УстановитьФильтрПоТекущемуКомплекту();				
	КонецЕсли;
	
	Элементы.гТекущйКомплект.Видимость = Ложь;
	Элементы.гПродукция.Видимость = Ложь;
	Элементы.кнРаспечататьКодКомплекта.Видимость = Ложь;
	Элементы.кнРаспечататьЛентуКомплектов.Видимость = Ложь;
	
	// Кельманов А.В. - HELP-4221 - 2025.07.17 {
	Если ЭтоСкладМаркированногоТовара И Не Объект.фРежим = 2 Тогда
		Элементы.фРежим.Видимость = Ложь;		
		Элементы.фРежим1.Видимость = Истина;		
	Иначе
		Элементы.фРежим.Видимость = Истина;		
		Элементы.фРежим1.Видимость = Ложь;		
	КонецЕсли;
	// Кельманов А.В. - HELP-4221 - 2025.07.17 }
	
	Если Объект.фРежим = 0 Тогда //Обычный
		// Кельманов А.В. - HELP-5254 - 2026.03.23 {
		Элементы.гПродукция.Видимость = Истина;	
		Элементы.ПродукцияШ.ТолькоПросмотр = Истина;
		Элементы.КоличествоПродукции.ТолькоПросмотр = Не ЗначениеЗаполнено(Объект.Продукция) Или ЗначениеЗаполнено(Объект.КоличествоДокумента);
		// Кельманов А.В. - HELP-5254 - 2026.03.23 }
		Элементы.гТекущйКомплект.Видимость 				= Истина;
		Элементы.кнРаспечататьКодКомплекта.Видимость	= Истина;
		Элементы.кнЗаполнитьПакет.Видимость				= Ложь;
	ИначеЕсли Объект.фРежим = 1 Тогда //Упрощенный
		Элементы.гТекущйКомплект.Видимость 				= Истина;
		Элементы.кнРаспечататьКодКомплекта.Видимость 	= Истина;
		Элементы.кнЗаполнитьПакет.Видимость				= Ложь;
	ИначеЕсли Объект.фРежим = 2 Тогда //Пакетный
		Элементы.гПродукция.Видимость = Истина;	
		Элементы.ПродукцияШ.ТолькоПросмотр = Ложь; // Кельманов А.В. - HELP-5254 - 2026.03.23	
		Элементы.кнРаспечататьЛентуКомплектов.Видимость = Истина;
		Элементы.кнЗаполнитьПакет.Видимость				= Истина;
	КонецЕсли; 
	
	
	Элементы.ФормаОчиститьДвижения.Доступность = НЕ Объект.Ссылка.Пустая() И ПолучитьПолномочиеПользователя(ПланыВидовХарактеристик.ПолномочияПользователей.ОчисткаЛСК);	
	// Кельманов А.В. - HELP-3850 - 2025.04.03 {
	Элементы.УзелТСД.Видимость = ЗначениеЗаполнено(Объект.УзелТСД);
	Элементы.СборщикКомплектаТСД.Видимость = ЗначениеЗаполнено(Объект.СборщикКомплектаТСД);     
	// Кельманов А.В. - HELP-3850 - 2025.04.03 }
	// Кухарь А.Ю. 06.05.2025 начало
	Элементы.ДатаНачалаСканирования.Видимость = ЗначениеЗаполнено(Объект.ДатаНачалаСканирования);
	Элементы.ДатаОкончанияСканирования.Видимость = ЗначениеЗаполнено(Объект.ДатаОкончанияСканирования);
	// Кухарь А.Ю. 06.05.2025 конец
	
	// Шворобей ВЮ 15.05.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4854
	Если ПолучитьПолномочиеПользователя("ОчисткаЛСК", ПараметрыСеанса.Пользователь) Тогда
		Элементы.кнРазрешитьРедактированиеМарок.Доступность = Истина;
	КонецЕсли;
	// Шворобей ВЮ 15.05.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4854
	
КонецПроцедуры

