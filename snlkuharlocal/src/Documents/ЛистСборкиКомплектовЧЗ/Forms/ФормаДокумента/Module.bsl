		СтрокаТЧ = Объект.ШтрихкодыУпаковок.НайтиПоИдентификатору(ИдСтроки);		
		Если сКоды[СтрокаТЧ.ШтрихкодКомплекта] = Неопределено Тогда		
			сКоды[СтрокаТЧ.ШтрихкодКомплекта]	= Истина;	
			КодыМаркировки.Добавить(СтрокаТЧ.ШтрихкодКомплекта);
		КонецЕсли;
	КонецЦикла;
	
	ТД = Неопределено;
	Для Каждого КодМаркировки Из КодыМаркировки Цикл

		// Кельманов А.В. - HELP-5659 - 2025.08.06 {
		//рПечати = НапечататьКодКомплекта_НаСервере(КодМаркировки);
		НомерШтуки = мВсеКоды.Найти(КодМаркировки) + 1;
		
	    рПечати = НапечататьКодКомплекта_НаСервере(КодМаркировки, , , НомерШтуки);
		// Кельманов А.В. - HELP-5659 - 2025.08.06 }

		Если рПечати.Успешно Тогда
			Если ТД = Неопределено Тогда
				ТД = рПечати.Данные;
			Иначе
				ТД.ВывестиГоризонтальныйРазделительСтраниц();
				// Смирнов М.Ю. 16.06.2025 HELP-4528 начало
				ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЛСК_КодКомплекта_Повт" + "Этикетка_25_25";
				// Смирнов М.Ю. 16.06.2025 HELP-4528 конец
				ТД.Вывести(рПечати.Данные);
			КонецЕсли;
		Иначе
			МаркировкаК.ВывестиОшибки(рПечати);			
		КонецЕсли;
	КонецЦикла; 
	
	ТД.ОтображатьСетку = Ложь;
	ТД.ОтображатьЗаголовки = Ложь;	
	
	Если фПечататьКодНабораСразуНаПринтер Тогда
		ТД.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
	Иначе					
		ТД.Показать("Коды комплектов по ЛСБ: " + Объект.Ссылка);
	КонецЕсли;
КонецФункции //ПовторнаяПечать_Комплекты()

&НаСервере
Функция ЗаменитьДублиКомплектующихНаСервере()
	МассивСообщений=новый Массив;
	Запрос=новый запрос;
	запрос.Текст=   "ВЫБРАТЬ
	                |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка КАК Ссылка,
	                |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	                |ПОМЕСТИТЬ ПолнаяТЗ
	                |ИЗ
	                |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	                |ГДЕ
	                |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
	                |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ДокОснование
	                |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки В(&ШтрихкодУпаковки)
	                |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки <> &ПустойШК
	                |;
	                |
	                |////////////////////////////////////////////////////////////////////////////////
	                |ВЫБРАТЬ
	                |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПолнаяТЗ.Ссылка) КАК Ссылка,
	                |	ПолнаяТЗ.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	                |	ПолнаяТЗ.ШтрихкодУпаковки.Владелец КАК ШтрихкодУпаковкиВладелец
	                |ПОМЕСТИТЬ Дубли
	                |ИЗ
	                |	ПолнаяТЗ КАК ПолнаяТЗ
	                |
	                |СГРУППИРОВАТЬ ПО
	                |	ПолнаяТЗ.ШтрихкодУпаковки,
	                |	ПолнаяТЗ.ШтрихкодУпаковки.Владелец
	                |
	                |ИМЕЮЩИЕ
	                |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПолнаяТЗ.Ссылка) > 1
	                |;
	                |
	                |////////////////////////////////////////////////////////////////////////////////
	                |ВЫБРАТЬ
	                |	Дубли.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	                |	Дубли.ШтрихкодУпаковкиВладелец КАК Номенклатура,
	                |	ПолнаяТЗ.Ссылка КАК Ссылка
	                |ИЗ
	                |	Дубли КАК Дубли
	                |		ЛЕВОЕ СОЕДИНЕНИЕ ПолнаяТЗ КАК ПолнаяТЗ
	                |		ПО Дубли.ШтрихкодУпаковки = ПолнаяТЗ.ШтрихкодУпаковки
	                |ГДЕ
	                |	ПолнаяТЗ.Ссылка = &Ссылка
	                |ИТОГИ ПО
	                |	Номенклатура";
	запрос.УстановитьПараметр("ШтрихкодУпаковки",Объект.ШтрихкодыУпаковок.Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки"));
	запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);
	запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());

	запрос.УстановитьПараметр("ДокОснование",объект.ДокОснование);
	
	ВыборкаНоменклатуры=запрос.Выполнить().выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");
	Пока ВыборкаНоменклатуры.Следующий() цикл
		Выборка=ВыборкаНоменклатуры.Выбрать();
		рПолучения = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСвободныеКодыШтук(ВыборкаНоменклатуры.Номенклатура, Выборка.Количество());
		Сч=0;
		
		Если рПолучения.Успешно Тогда
			Пока Выборка.Следующий() цикл 
				КодЗамены=рПолучения.Данные[сч];
				МассСтрок=Объект.ШтрихкодыУпаковок.НайтиСтроки(новый Структура("ШтрихкодУпаковки",Выборка.ШтрихкодУпаковки));
				Для каждого СтрМасс из МассСтрок цикл
					СтрМасс.ШтрихкодУпаковки=КодЗамены;
					МассивСообщений.Добавить(СтрШаблон("Замена с %1 на %2",Выборка.ШтрихкодУпаковки,КодЗамены));
				КонецЦикла;
				сч=сч+1;
			КонецЦикла;
		Иначе
			МассивСообщений.Добавить("не получилось...");			
			Прервать;
		КонецЕсли; 
	КонецЦикла;
	// Кухарь А.Ю.  24.04.2025 начало
	//Записать();
	Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение) );
	// Кухарь А.Ю.  24.04.2025 конец

	Возврат МассивСообщений;
	
КонецФункции

