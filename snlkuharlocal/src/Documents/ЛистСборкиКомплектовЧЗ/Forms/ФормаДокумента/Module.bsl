Процедура ЗаполнитьКодыКомплектующих_НаСервере()
	мНоменклатура = Новый Массив;
	Если МаркировкаК.ЗаписатьИзмененныйОбъектВУпрФорме(ЭтаФорма) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	Комплектующее
		|ИЗ
		|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок
		|ГДЕ
		|	ШтрихкодУпаковки = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
		|	И Комплектующее.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
		|	И Ссылка = &Ссылка
		|";              
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
		
		мНоменклатура	= Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Комплектующее");		
		рПолучения		= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(мНоменклатура, Объект.Ссылка, Новый Структура("Добавлять", Истина));
		Если рПолучения.Успешно Тогда						
			Для каждого КиЗ Из рПолучения.Данные Цикл
				Номенклатура	= КиЗ.Ключ;
				Коды			= КиЗ.Значение; 
				Сч = 0;
				Для Каждого СтрокаТЧ Из Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("Комплектующее,ШтрихкодУпаковки", Номенклатура, Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка())) Цикл
					СтрокаТЧ.ШтрихкодУпаковки = Коды[Сч];
					Сч = Сч + 1;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

