&НаСервере
Функция ПроверитьВсеКомплектыСобраны(Комплект)
	
	ВсеКомплектыСобраны = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНаСборкуКомплектовЧЗТовары.Номенклатура КАК Номенклатура,
	               |	СУММА(ЗаданиеНаСборкуКомплектовЧЗТовары.Количество) КАК КоличествоЗСБ
	               |ПОМЕСТИТЬ ВТ_ЗСБ
	               |ИЗ
	               |	Документ.ЗаданиеНаСборкуКомплектовЧЗ.Товары КАК ЗаданиеНаСборкуКомплектовЧЗТовары
	               |ГДЕ
	               |	ЗаданиеНаСборкуКомплектовЧЗТовары.Ссылка = &ЗСБ
	               |	И ЗаданиеНаСборкуКомплектовЧЗТовары.Номенклатура = &Номенклатура
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗаданиеНаСборкуКомплектовЧЗТовары.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.Владелец КАК Продукция,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта) КАК КоличествоЛСК
	               |ПОМЕСТИТЬ ВТ_ЛСК
	               |ИЗ
	               |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	               |ГДЕ
	               |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.Владелец = &Номенклатура
	               |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗСБ
	               |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
	               |	И НЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.ВерсияДанных ЕСТЬ NULL
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта.Владелец
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ЗСБ.КоличествоЗСБ КАК КоличествоЗСБ,
	               |	ЕСТЬNULL(ВТ_ЛСК.КоличествоЛСК, 0) КАК КоличествоЛСК
	               |ИЗ
	               |	ВТ_ЗСБ КАК ВТ_ЗСБ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЛСК КАК ВТ_ЛСК
	               |		ПО ВТ_ЗСБ.Номенклатура = ВТ_ЛСК.Продукция";
	
	Запрос.УстановитьПараметр("ЗСБ", Объект.ДокОснование);
	Запрос.УстановитьПараметр("Номенклатура", Комплект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ДоступноКомплектов = Выборка.КоличествоЗСБ - Выборка.КоличествоЛСК;
		
		Если ДоступноКомплектов = 0 Тогда
			
			ВсеКомплектыСобраны = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВсеКомплектыСобраны;
	
КонецФункции

