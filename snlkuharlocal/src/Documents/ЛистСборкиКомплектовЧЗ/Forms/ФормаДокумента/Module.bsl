Процедура УдалитьКомплектующее(Команда)
	
	МассивСтрок = Элементы.ШтрихкодыУпаковок.ВыделенныеСтроки;
	
	ЗначениеСвойства = Неопределено;
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") И ДополнительныеРеквизиты.Свойство("ОчисткаЛСК") Тогда
		ЗначениеСвойства = ДополнительныеРеквизиты.ОчисткаЛСК;
	КонецЕсли;
	
	Если МассивСтрок.Количество() > 0 И ЗначениеСвойства = Истина Тогда
		
   		Для Индекс = -МассивСтрок.ВГраница() По 0 Цикл
        
        		ИдентификаторСтроки = МассивСтрок[-Индекс];
        		НайденнаяСтрока = Объект.ШтрихкодыУпаковок.НайтиПоИдентификатору(ИдентификаторСтроки);
        
        		Объект.ШтрихкодыУпаковок.Удалить(НайденнаяСтрока);
        
		КонецЦикла;
		
	Иначе
		ПоказатьПредупреждение(, "Не выбраны строки комплектующих!");
	КонецЕсли;
	
КонецПроцедуры
