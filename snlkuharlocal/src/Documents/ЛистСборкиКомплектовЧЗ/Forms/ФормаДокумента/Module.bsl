&НаСервере
Функция ПолучитьКодыДляКоробки(ВыбНоменклатура)	
	Результат = Новый Структура("Успешно,Ошибки,ШтрихКодКоробки,ШтрихКодыУпаковок", Истина, Новый Массив, Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(), Новый Массив);			
	
	ШтукВКоробке = ПолучитьРеквизитШапки(ВыбНоменклатура, "Родитель.ШтукВКоробке");
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихКодУпаковки КАК ШтрихкодКоробки
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(,
	|		Номенклатура 	= ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)	
	|		И ТипШК			= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)    
	//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522 Добавил Перемаркировку
	|		И ШтрихКодУпаковки.СпособВводаВОборот В (ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Перемаркировка))
	|		И ШтрихКодУпаковки.ТипУпаковки	= ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МонотоварнаяУпаковка)	
	|	)
	|ГДЕ
	|	Местонахождение = &ПодразделениеНанесения	
	|	И НЕ ВПути
	|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ГотовКПечати)
	|ДЛЯ ИЗМЕНЕНИЯ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних
	|;
	|ВЫБРАТЬ ПЕРВЫЕ " + ШтукВКоробке + "
	|	ШтрихКодУпаковки КАК ШтрихКодУпаковки
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(,
	|		ШтрихКодУпаковки.Владелец 	= &Номенклатура
	|		И ТипШК						= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)     
	//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522  Добавил Перемаркировку
	|		И ШтрихКодУпаковки.СпособВводаВОборот 	В (ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Перемаркировка))
	|		И ШтрихКодУпаковки.ТипУпаковки 			= ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МаркированныйТовар)
	|		И ШтрихКодУпаковки.ТипКода В (ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор))
	|	)
	|ГДЕ
	|	Местонахождение = &ПодразделениеНанесения	
	|	И НЕ ВПути
	|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ГотовКПечати)
	|ДЛЯ ИЗМЕНЕНИЯ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних
	|";
	
	Запрос.УстановитьПараметр("ПодразделениеНанесения", Объект.Подразделение);
	Запрос.УстановитьПараметр("Номенклатура", 			ВыбНоменклатура);
	
	рЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = рЗапроса[0].Выбрать();	
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ШтрихКодКоробки) Тогда
			Результат.ШтрихкодКоробки = Выборка.ШтрихкодКоробки;					
		КонецЕсли;	
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(Результат.ШтрихкодКоробки) Тогда
		Результат.Ошибки.Добавить("Не найдено свободных кодов агрегации !");			
	КонецЕсли; 
	
	Выборка = рЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.ШтрихКодыУпаковок.Добавить(Выборка.ШтрихКодУпаковки);
	КонецЦикла;	
	
	ПолученоКМ = Результат.ШтрихКодыУпаковок.Количество();
	Если ПолученоКМ = ШтукВКоробке Тогда
	Иначе	
		ТекстОшибки = СтрШаблон("Найдено: %1 из необходимых: %2 кодов маркировки.", ПолученоКМ, ШтукВКоробке);
		
		Результат.Ошибки.Добавить(ТекстОшибки);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПолучитьКодыДляКоробки(ВыбНоменклатура)

&НаСервере
Функция СоздатьЛистМаркировки(Номенклатура)
	ЛН_Объект = Документы.ЛистМаркировкиОстатков.СоздатьДокумент();	
	ЗаполнитьШапкуДокумента(ЛН_Объект, ПараметрыСеанса.Пользователь); 	
	
	ЛН_Объект.Дата			= ТекущаяДата();
	ЛН_Объект.ДокОснование	= Объект.Ссылка;
	ЛН_Объект.Номенклатура	= Номенклатура;
	
	ЛН_Объект.Записать();
	Возврат ЛН_Объект.Ссылка;	
КонецФункции //СоздатьЛистНабора() 

