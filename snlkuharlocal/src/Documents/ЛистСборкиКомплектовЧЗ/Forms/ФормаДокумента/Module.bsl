Функция НайтиКомплект()
	рПоиска = НайтиКомплектПоКомплектующим();
	Если рПоиска.Успешно Тогда
		ТекущйКомплект = рПоиска.Данные.Комплект;
	Иначе
		ТекущйКомплект = Неопределено;		
	КонецЕсли;
	КоличествоКомплектующих = рПоиска.Данные.КоличествоКомплектующих;
	
	Если КоличествоКомплектующих > 0 Тогда
		Элементы.КоличествоКомплектующих.ЦветТекстаЗаголовка = WebЦвета.Красный;
		Элементы.КоличествоКомплектующих.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.КоличествоКомплектующих.ЦветТекстаЗаголовка = WebЦвета.Зеленый;
		Элементы.КоличествоКомплектующих.ЦветТекста = WebЦвета.Зеленый;
	КонецЕсли; 
	
	Возврат ЗначениеЗаполнено(ТекущйКомплект);
КонецФункции //НайтиКомплект()

