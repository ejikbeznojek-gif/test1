&НаСервере
Функция ПроверитьСтатусыКодовКомплектующих(КодыКомплектующих)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки,
	|	Статус
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(, ШтрихкодУпаковки В (&КодыКомплектующих))
	|";	
	
	Запрос.УстановитьПараметр("КодыКомплектующих", КодыКомплектующих);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Статус = Выборка.Статус;
		Если Статус = Перечисления.СтатусыКодовМаркировкиФакт.Нанесен Тогда
		ИначеЕсли Статус = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте Тогда
		Иначе     
			ТекстОшибки = СтрШаблон("Недопустимый статус кода комплектующего: '%1' - '&2' ! Ожидаемый статус 'Нанесен' или 'В обороте' !", Выборка.ШтрихкодУпаковки, Выборка.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли;
	КонецЦикла;
	
	Результат.Успешно = Результат.Ошибки.Количество() = 0;
	
	Возврат Результат;	
КонецФункции //ПроверитьСтатусыКодовКомплектующих(ШтрихкодКомплекта)


&НаСервереБезКонтекста
Функция ПолучитьПоляКМДляПечати(КМ)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Владелец							КАК Номенклатура,
	|	Владелец.Родитель.КодПроизводителя	КАК Артикул,
	|	Владелец.Цвет						КАК Цвет,
	|	Владелец.Размер						КАК Размер,
	|	Ссылка								КАК ШтрихкодУпаковки,	
	|	ЗначениеШтрихкода					КАК ЗначениеКМ
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	Ссылка = &КМ
	|";
	
	Запрос.УстановитьПараметр("КМ", КМ);
	рЗапроса = Запрос.Выполнить();
	
	Результат = Новый Структура;
	Для Каждого Кол Из рЗапроса.Колонки Цикл
		Результат.Вставить(Кол.Имя, Неопределено);	
	КонецЦикла; 
	Выборка = рЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьПоляКМДляПечати(КМ)

&НаСервереБезКонтекста
Функция НапечататьКодКомплекта_НаСервере(КМКомплекта, ИмяМакета	= "Этикетка_25_25", СразуНаПринтер = Ложь, НомерШтуки = 0)
	Результат		= МаркировкаКС.СтруктураРезультата(Ложь);	
	
	ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
	Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
	
	ТД = Новый ТабличныйДокумент;
	ТД.ОтображатьСетку		= Ложь;
	ТД.ОтображатьЗаголовки	= Ложь;
	// Смирнов М.Ю. 16.06.2025 HELP-4528 начало
	//ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЛСК_"+ИмяМакета;
	ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_ЛСК_КодКомплекта" + ИмяМакета;
	// Смирнов М.Ю. 16.06.2025 HELP-4528 конец
	
	РаспечатанныеКМ = Новый Соответствие;
	
	ДанныеДляПечати	= ПолучитьПоляКМДляПечати(КМКомплекта);		
 
	// Кухарь А.Ю.  19.11.2025 начало   
	//ДопПараметры = Новый Структура("НомерШтуки,НомерКоробки,ШтукВКоробке", 1, 1, 1); 

	// Кельманов А.В. - Вернул как было - 2025.11.20 {
	//НомерШтуки = 0;
	//ДопПараметры = Новый Структура("НомерШтуки,НомерКоробки,ШтукВКоробке", 0, 1, 1);
	ДопПараметры = Новый Структура("НомерШтуки,НомерКоробки,ШтукВКоробке", 1, 1, 1);
	// Кельманов А.В. - Вернул как было - 2025.11.20 }

	// Кухарь А.Ю.  19.11.2025 конец
	
	Если НомерШтуки <> 0 Тогда
		ДопПараметры.НомерШтуки = "№ " + НомерШтуки;			
	КонецЕсли;	
	Область 		= ОбработкаПечати.СформироватьЭтикету(Макет, ДанныеДляПечати, ДопПараметры);
	
	ТД.Вывести(Область);
	
	Результат.Данные 	= ТД;
	Результат.Успешно 	= Истина;
	
	Возврат Результат;
КонецФункции //НапечататьКодКомплекта_НаСервере(КМКомплекта, ИмяМакета	= "Этикетка_25_25", СразуНаПринтер = Ложь)

