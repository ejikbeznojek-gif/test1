	КонецЕсли;
	
	Если Объект.фРежим = 0 Тогда
		Результат = ДобавитьКМвДокумент_ОбычныйРежим(Номенклатура, КодМаркировки); 		
	ИначеЕсли Объект.фРежим = 1 Тогда
		Результат = ДобавитьКМвДокумент_УпрощенныйРежим(Номенклатура, КодМаркировки);		
	Иначе
		ПоказатьПредупреждение(, "В пакетом режиме сканирование в документ не допускается !");
		МаркировкаК.ВоспроизвестиЗвукОшибки(3);
	КонецЕсли;	
	
	Элементы.фРежим.ТолькоПросмотр = (Объект.ШтрихкодыУпаковок.Количество() > 0);
	
	Возврат Результат;
КонецФункции //ДобавитьКМвДокумент(Номенклатура, КодМаркировки)

&НаКлиенте
Функция МожноДобавлятьКодКомплектующего(КодМаркировки)
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	ТекСтатус	= МаркировкаС.ТекущийСтатусКодаФакт(КодМаркировки);
	Если ЕстьКМКомплектующегоВДокументе(КодМаркировки) Тогда
		Если ТекСтатус = Перечисления.СтатусыКодовМаркировкиФакт.Распечатан Тогда					
		Иначе			
			Результат.Ошибки.Добавить(СтрШаблон("Код маркировки: '%1' уже сканировался в этот документ !", КодМаркировки));
		КонецЕсли;
	Иначе		
		Если ТекСтатус = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте
			ИЛИ ТекСтатус = Перечисления.СтатусыКодовМаркировкиФакт.Нанесен Тогда
			Результат.Успешно = Истина;
		Иначе
			Результат.Ошибки.Добавить(СтрШаблон("Недопустимый статус КМ: '%1' !", КодМаркировки));
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //МожноДобавлятьКодКомплектующего(КодМаркировки)

