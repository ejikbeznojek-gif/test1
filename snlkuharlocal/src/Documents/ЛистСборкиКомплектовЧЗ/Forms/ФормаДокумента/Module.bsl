	Возврат СтрСоединить(Строки, ",");
КонецФункции //ПолучитьХэшКомплектаПоНом(МассивКМ)

&НаСервере
Функция ПолучитьХэшиКомплектовЗадания()
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура 					КАК Продукция,
	|	Null							КАК Номенклатура,
	|	""""							КАК Номенклатура_Код,
	|	0				 				КАК Количество,
	|	СУММА(Количество*Коэффициент) 	КАК КоличествоПродукции
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.Товары
	|ГДЕ
	|	Ссылка = &ДокОснование	
	|	И Количество*Коэффициент<>0
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Продукция,
	|	Номенклатура,
	|	Номенклатура.Код				КАК Номенклатура_Код,
	|	СУММА(Количество*Коэффициент)  	КАК Количество,
	|	0								КАК КоличествоПродукции
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.Комплектующие
	|ГДЕ
	|	Ссылка = &ДокОснование	
	|	И Количество*Коэффициент<>0
	|СГРУППИРОВАТЬ ПО
	|	Продукция,
	|	Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура_Код
	|ИТОГИ СУММА(КоличествоПродукции) ПО
	|	Продукция
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", Объект.ДокОснование);
	
	ДопустимыеКомплекты.Очистить();
	мДопустимыеКомплектующие = Новый Соответствие;
	
	Выборка_Продукция = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Продукция");
	
	Пока Выборка_Продукция.Следующий() Цикл
		
		// Кельманов А.В. - HELP-9640 - 2026.05.12 {
		Если Объект.фРежим = 0 И ЗначениеЗаполнено(Объект.Продукция) И Выборка_Продукция.Продукция <> Объект.Продукция Тогда
			
			Продолжить;
			
		КонецЕсли;
		// Кельманов А.В. - HELP-9640 - 2026.05.12 }
		
		ДопустимыеКомплекты.Добавить(Выборка_Продукция.Продукция);
		
		Строки = Новый Массив;
		Выборка = Выборка_Продукция.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.Количество>0 Тогда
				Строки.Добавить(Выборка.Номенклатура_Код+"___"+Выборка.Количество/Выборка_Продукция.КоличествоПродукции);
				мДопустимыеКомплектующие[Выборка.Номенклатура] = Истина;			
			КонецЕсли;
		КонецЦикла;
		
		Результат[СтрСоединить(Строки, ",")] = Выборка_Продукция.Продукция;
		
	КонецЦикла;
	
	Для Каждого КиЗ Из мДопустимыеКомплектующие Цикл
		ДопустимыеКомплектующие.Добавить(КиЗ.Ключ);	
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции //ПолучитьХэшиКомплектовЗадания()

&НаСервере
Процедура ЗаполнитьШаблонСпайки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Комплектующее КАК Номенклатура,
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.КодКомплектующегоНеНанесен КАК СканировалиЛинейнымШК
		|ИЗ
		|	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
		|ГДЕ
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Комплектующее,
		|	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.КодКомплектующегоНеНанесен";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	ШаблонСпайкиЗначение = РеквизитФормыВЗначение("ШаблонСпайки");
	ШаблонСпайкиЗначение = Запрос.Выполнить().Выгрузить();
	ЗначениеВРеквизитФормы(ШаблонСпайкиЗначение, "ШаблонСпайки");
		
КонецПроцедуры

&НаСервере
Функция ПроверитьДобавитьСтрокуВШаблонСканированияСпайки(Номенклатура, СканировалиЛинейнымШК = Ложь)
	
	СтруктураПоиска = Новый Структура("Номенклатура", Номенклатура);
	НайденныеСтроки = ШаблонСпайки.НайтиСтроки(СтруктураПоиска);
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		
		НовСтр = ШаблонСпайки.Добавить();
		НовСтр.Номенклатура = Номенклатура;
		НовСтр.СканировалиЛинейнымШК = СканировалиЛинейнымШК;
		
		Возврат Истина;
		
	Иначе
		
		СтрокаШаблон = НайденныеСтроки[0];
		
		Если СканировалиЛинейнымШК = СтрокаШаблон.СканировалиЛинейнымШК Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

