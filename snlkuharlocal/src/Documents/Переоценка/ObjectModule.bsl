Перем ПараметрыЗагрузки;

Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		НаборЗаписей.Очистить();
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры 

Функция ПолучитьОстаткиДляПереоценки()
	Запрос=Новый Запрос;
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	Номенклатура,
	|	Цена КАК Цена
	|ПОМЕСТИТЬ Данные
	|ИЗ
	|	&Данные КАК Данные";
	Запрос.УстановитьПараметр("Данные",Товары);
	Запрос.Выполнить();
	
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(1) КАК КоличествоЦен,	
	|	СУММА(Цена) КАК Цена
	|ПОМЕСТИТЬ 
	|	Цены	
	|ИЗ
	|	Данные
	|СГРУППИРОВАТЬ ПО Номенклатура";
	Запрос.Выполнить();
	
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Склад,
	|   Остатки.Номенклатура.Родитель КАК Модель,
	|	Остатки.Номенклатура	КАК Номенклатура,
	|	КоличествоОстаток 		КАК Остаток,
	|	СуммаОстаток 			КАК СтоимостьСтарая,
	|	IsNULL(КоличествоЦен,0) КАК КоличествоЦен,
	|	IsNULL(Цена,0) 			КАК Цена
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата1,"+?(Включать_Исключать_Склады="В"," ","НЕ ")+"Склад В (&Склады)"+?(ПереоценкаКДолларам,""," И Номенклатура В ИЕРАРХИИ (&Номенклатура)")+") КАК Остатки
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Цены
	|ПО 
	|	Остатки.Номенклатура.Родитель = Цены.Номенклатура
	|ГДЕ 
	|	КоличествоОстаток<>0";
	
	Запрос.УстановитьПараметр("Дата1",МоментВремени());
	Запрос.УстановитьПараметр("Склады",			Склады.ВыгрузитьКолонку("Склад"));
	Запрос.УстановитьПараметр("Номенклатура",	Товары.ВыгрузитьКолонку("Номенклатура"));
	
	ТО=Запрос.Выполнить().Выгрузить();
	ТО.Колонки.Добавить("СтоимостьНовая",ПолучитьОписаниеТиповЧисла(19,2));
	
	Возврат ТО;	
КонецФункции //

// Шворобей ВЮ 03.12.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1211
Процедура УстановитьБрэндТипТовара(СтрокаТЧ) Экспорт
	
	Номенклатура = СтрокаТЧ.Номенклатура;
	Если Номенклатура.Пустая() Тогда Возврат КонецЕсли; 
	
	Уровень = Номенклатура.Уровень();
	Если Уровень = 0 Тогда //ТипТовара
		СтрокаТЧ.ТипТовара	= Номенклатура;
		СтрокаТЧ.Брэнд	= Неопределено;
	ИначеЕсли Уровень = 1 Тогда //Брэнд
		СтрокаТЧ.ТипТовара	= Номенклатура.Родитель;
		СтрокаТЧ.Брэнд	= Номенклатура;
	ИначеЕсли Уровень = 2 Тогда //Модель		
		СтрокаТЧ.ТипТовара	= Номенклатура.Родитель.Родитель;
		СтрокаТЧ.Брэнд	= Номенклатура.Родитель;		
	ИначеЕсли Уровень = 3 Тогда //Позиция
		СтрокаТЧ.ТипТовара	= Номенклатура.Родитель.Родитель.Родитель;
		СтрокаТЧ.Брэнд	= Номенклатура.Родитель.Родитель;
	ИначеЕсли Уровень = 4 Тогда
		СтрокаТЧ.ТипТовара	= Номенклатура.Родитель.Родитель.Родитель.Родитель;
		СтрокаТЧ.Брэнд	= Номенклатура.Родитель.Родитель.Родитель;
	ИначеЕсли Уровень = 5 Тогда
		СтрокаТЧ.ТипТовара	= Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель;
		СтрокаТЧ.Брэнд	= Номенклатура.Родитель.Родитель.Родитель.Родитель;
	Иначе //ХЗ
		СтрокаТЧ.ТипТовара	= Неопределено;
		СтрокаТЧ.Брэнд	= Неопределено;
	КонецЕсли;
	
КонецПроцедуры
