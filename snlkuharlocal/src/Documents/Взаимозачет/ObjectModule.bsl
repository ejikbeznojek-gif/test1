Процедура ОбработкаЗаполнения(Основание)
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Основание) Тогда Возврат КонецЕсли; 
	
	ТипОснования=ТипЗнч(Основание);
	Если ТипОснования=Тип("ДокументСсылка.ЗаявкаНаОплату") Тогда		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", Основание);
		Запрос.Текст =" 
		|ВЫБРАТЬ	
		|	Сотрудник,
		|	МАКСИМУМ(Договоры.Ссылка) КАК Договор
		|ПОМЕСТИТЬ ДоговорыПодотчет
		|ИЗ
		|	Документ.ЗаявкаНаОплату.Подотчет КАК ЗаявкаНаОплатуПодотчет
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	Справочник.Договоры КАК Договоры
		|ПО
		|	ЗаявкаНаОплатуПодотчет.Сотрудник	=Договоры.Владелец 	
		|	И Договоры.ВидДоговора_Новый		=&ВидДоговораПодОтчет
		|	И НЕ Договоры.ПометкаУдаления
		|ГДЕ
		|	ЗаявкаНаОплатуПодотчет.Ссылка=&ЗНО
		|СГРУППИРОВАТЬ ПО 
		|	Сотрудник
		|;
		|ВЫБРАТЬ
		|	ЗаявкаНаОплатуПодотчет.Сотрудник 	КАК Контрагент_Кредитор,
		|	ДоговорыПодотчет.Договор			КАК Договор_Кредитор,
		|	ЗаявкаНаОплатуПодотчет.Сумма		КАК Сумма
		|ИЗ	
		|	Документ.ЗаявкаНаОплату.Подотчет КАК ЗаявкаНаОплатуПодотчет	
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	ДоговорыПодотчет
		|ПО
		|	ДоговорыПодотчет.Сотрудник=ЗаявкаНаОплатуПодотчет.Сотрудник			
		|ГДЕ
		|	ЗаявкаНаОплатуПодотчет.Ссылка		=&ЗНО";
		
		ВидДоговораПодОтчет	= Справочники.ВидыДоговоров.НайтиПоНаименованию("Под отчёт", Истина);	
		
		Запрос.УстановитьПараметр("ЗНО",Основание);
		Запрос.УстановитьПараметр("ВидДоговораПодОтчет",ВидДоговораПодОтчет);		
		
		Выборка = Запрос.Выполнить().Выбрать();
		// заполняем таб.часть Взаимозачеты
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = Взаимозачеты.Добавить();			
			
			НоваяСтрока.Контрагент_Дебитор	= Основание.Контрагент;
			НоваяСтрока.Договор_Дебитор		= Основание.Договор;
			
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);			
		КонецЦикла;		
	КонецЕсли; 
КонецПроцедуры
