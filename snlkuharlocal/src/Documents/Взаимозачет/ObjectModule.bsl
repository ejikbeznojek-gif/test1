Функция ПересчетМЮ(Сумма,Валюта1,Курс1,Валюта2,Курс2)	
	Если Валюта1=Рубли И Валюта2=Доллары Тогда		
		Возврат ?(Курс1=0,0,Сумма/Курс1);	
	ИначеЕсли Валюта1=Доллары И Валюта2=Рубли Тогда
		Возврат Сумма*Курс1;		
	Иначе
		Возврат глПересчет(Сумма,Валюта1,Курс1,Валюта2,Курс2);	
	КонецЕсли; 	
КонецФункции // ПересчетМЮ()

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	Доллары				=Справочники.Валюты.НайтиПоКоду("840");
	Рубли				=Справочники.Валюты.НайтиПоКоду("810");
	
	ВалютаУпр			=?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	Если Сумма <> 0 Тогда
		
		ВалютаРасчетов_Дебитор	=ПолучитьВалютуРасчетов(Договор_Дебитор);	
		ВалютаРасчетов_Кредитор	=ПолучитьВалютуРасчетов(Договор_Кредитор);	
		
		СуммаВАЛ_Дебитор	= глПересчет(Сумма,Валюта,Курс,ВалютаРасчетов_Дебитор,Дата);
		СуммаВАЛ_Кредитор	= глПересчет(Сумма,Валюта,Курс,ВалютаРасчетов_Кредитор,Дата);
		
		СуммаУпр			= глПересчет(Сумма,Валюта,Курс,ВалютаУпр,Дата);	
		
		Движение 					= Движения.Взаиморасчеты.Добавить();
		Движение.ВидДвижения		= ВидДвиженияНакопления.Расход;
		
		Движение.Период				= Дата;
		Движение.Контрагент			= Контрагент_Дебитор;
		Движение.Договор 			= Договор_Дебитор;			
		
		Движение.СуммаВал			= Модуль(СуммаВАЛ_Дебитор);
		Движение.СуммаУпр			= Модуль(СуммаУпр);
		
		Движение.СуммаДокумента		= Сумма;
		Движение.ВалютаДокумента	= Валюта;	
		
		Движение.КодОперации		= Перечисления.КодыОперацийОстатки.Взаимозачет;
		
		Движение 					= Движения.Взаиморасчеты.Добавить();
		Движение.ВидДвижения		= ВидДвиженияНакопления.Приход;
		
		Движение.Период				= Дата;
		Движение.Контрагент			= Контрагент_Кредитор;
		Движение.Договор 			= Договор_Кредитор;			
		
		Движение.СуммаВал			= Модуль(СуммаВАЛ_Кредитор);
		Движение.СуммаУпр			= Модуль(СуммаУпр);
		
		Движение.СуммаДокумента		= Сумма;
		Движение.ВалютаДокумента	= Валюта;	
		
		Движение.КодОперации		= Перечисления.КодыОперацийОстатки.Взаимозачет;
	КонецЕсли;
	//сформируем проводки по ТЧ
	Если Взаимозачеты.Количество() <> 0 Тогда
		Для Каждого СтрокаТЧ Из Взаимозачеты Цикл
			ВалютаРасчетов_Дебитор	=ПолучитьВалютуРасчетов(СтрокаТЧ.Договор_Дебитор);	
			ВалютаРасчетов_Кредитор	=ПолучитьВалютуРасчетов(СтрокаТЧ.Договор_Кредитор);	
			
			СуммаВАЛ_Дебитор	= глПересчет(СтрокаТЧ.Сумма,Валюта,Курс,ВалютаРасчетов_Дебитор,Дата);
			СуммаВАЛ_Кредитор	= глПересчет(СтрокаТЧ.Сумма,Валюта,Курс,ВалютаРасчетов_Кредитор,Дата);
			
			СуммаУпр			= глПересчет(СтрокаТЧ.Сумма,Валюта,Курс,ВалютаУпр,Дата);	
			
			Движение 					= Движения.Взаиморасчеты.Добавить();
			Движение.ВидДвижения		= ВидДвиженияНакопления.Расход;
			
			Движение.Период				= Дата;
			Движение.Контрагент			= СтрокаТЧ.Контрагент_Дебитор;
			Движение.Договор 			= СтрокаТЧ.Договор_Дебитор;			
			
			Движение.СуммаВал			= Модуль(СуммаВАЛ_Дебитор);
			Движение.СуммаУпр			= Модуль(СуммаУпр);
			
			Движение.СуммаДокумента		= СтрокаТЧ.Сумма;
			Движение.ВалютаДокумента	= Валюта;	
			
			Движение.КодОперации		= Перечисления.КодыОперацийОстатки.Взаимозачет;
			
			Движение 					= Движения.Взаиморасчеты.Добавить();
			Движение.ВидДвижения		= ВидДвиженияНакопления.Приход;
			
			Движение.Период				= Дата;
			Движение.Контрагент			= СтрокаТЧ.Контрагент_Кредитор;
			Движение.Договор 			= СтрокаТЧ.Договор_Кредитор;			
			
			Движение.СуммаВал			= Модуль(СуммаВАЛ_Кредитор);
			Движение.СуммаУпр			= Модуль(СуммаУпр);
			
			Движение.СуммаДокумента		= СтрокаТЧ.Сумма;
			Движение.ВалютаДокумента	= Валюта;	
			
			Движение.КодОперации		= Перечисления.КодыОперацийОстатки.Взаимозачет;
			
		КонецЦикла;	
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	Если ОбменДанными.Загрузка Тогда
		Движения.Взаиморасчеты.Записать();	
	КонецЕсли; 
КонецПроцедуры

