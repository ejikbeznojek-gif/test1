Функция ПарситСостав(ВхСтр, СимвПр = "%", СимволР = ",")
	Рез = Новый Массив;
	//л = 1
	ОстСтр = ВхСтр;
	ОстСтр = СтрЗаменить(ОстСтр, " ", СимволР);
	Поз = 1;
	РезОст = "";
	Пока Поз <= СтрДлина(ОстСтр) Цикл
		ТекС = Сред(ОстСтр, Поз, 1);
		Если НЕ ((ТекС = СимволР) И (Сред(ОстСтр, Поз - 1, 1) = СимвПр)) Тогда
			РезОст = РезОст + ТекС;
		КонецЕсли;	
		Поз = Поз + 1;
	КонецЦикла;	
	ОстСтр = РезОст;
	Пока НЕ ОстСтр = "" Цикл
		Поз1 = СтрНайти(ОстСтр, СимвПр);
		Если Поз1 >= 1 Тогда
			//ВхСтр1 = Сред(ВхСтр, Поз1 + СтрДлина(КлючП));
			//Поз2 = СтрНайти(ВхСтр1, ";");
			Проц = Число(СокрЛП(Лев(ОстСтр, Поз1 - СтрДлина(СимвПр))));
			Поз2 = СтрНайти(ОстСтр, СимволР);
			Если Поз2 >= 1 Тогда
				СтрМат =  СокрЛП(Сред(ОстСтр, Поз1 +  СтрДлина(СимвПр), Поз2 - Поз1 - СтрДлина(СимволР) +  СтрДлина(СимвПр) - 1));
				ОстСтр = СокрЛП(Сред(ОстСтр, Поз2 + СтрДлина(СимволР)));
			Иначе
				СтрМат = Сред(ОстСтр, Поз1 + СтрДлина(СимвПр));
				ОстСтр = "";
			КонецЕсли;
			Рез.Добавить(Новый Структура("Проц, Мат", Проц, СтрМат));
		Иначе
			ОстСтр = "";
		КонецЕсли;
	КонецЦикла;	
	
	
	Возврат Рез;
КонецФункции

