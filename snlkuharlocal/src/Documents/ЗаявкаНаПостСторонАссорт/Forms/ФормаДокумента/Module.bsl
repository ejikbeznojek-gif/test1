Функция СопоставитЦветРазмер(Цвет, ЦветР, Размер, ВхСтрНаим, СтрЦвет, СтрРазмер)
	Рез = Ложь;
	Если ((СтрНайти(ВхСтрНаим, СтрЦвет) > 0) ИЛИ (СтрНайти(Цвет, СтрЦвет) > 0) ИЛИ (СтрНайти(ЦветР, СтрЦвет) > 0)) И СтрНайти(Размер, СтрРазмер) > 0 Тогда
		Рез = Истина;
	Иначе
		Если СтрНайти(Размер, СтрРазмер) > 0 Тогда
			Рез = Истина;
		КонецЕсли;
	КонецЕсли;	
	Возврат Рез;
