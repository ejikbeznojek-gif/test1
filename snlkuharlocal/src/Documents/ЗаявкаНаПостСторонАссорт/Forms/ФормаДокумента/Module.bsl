Функция ПолучитьИмп(СтрИмп)
	Рез = Неопределено;
	//Импортёр:ООО "Миа";ИНН импортёра:7723416980;КПП импортёра:772301001
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ИНН = &ИНН
	|	И Контрагенты.КПП = &КПП
	|";
	Запрос.УстановитьПараметр("ИНН", СокрЛП(ВыделитьЧасть(СтрИмп, "ИНН импортёра:", ";")));
	Запрос.УстановитьПараметр("КПП", СокрЛП(ВыделитьЧасть(СтрИмп, "КПП импортёра:", ";")));
	Выб = Запрос.Выполнить().Выбрать();
	Если Выб.Следующий() Тогда
		Рез = Выб.Ссылка;
	КонецЕсли;	
	Возврат Рез;
КонецФункции	

&НаСервереБезКонтекста
Функция НайтиУстановитьДекларацию(НомерСертификата, ДатаДекларации, Номенклатура, Модель, Филиал, Изготовитель, Орган, Импортер, Страна, Агентский)
	Рез = Неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Декларация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Декларация КАК Декларация
	|ГДЕ
	|	Декларация.ПометкаУдаления = ЛОЖЬ
	|	И Декларация.Наименование = &Наименование
	|	И Декларация.Объект = &Объект";
	Запрос.УстановитьПараметр("Наименование",НомерСертификата);
	Запрос.УстановитьПараметр("Объект", Модель);
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Рез = Результат.Ссылка;
	Иначе	
		Декларация = Справочники.Декларация.СоздатьЭлемент();
		Декларация.ВидДокумента = Перечисления.ВидыДекларации.Сертификат;
		Декларация.Объект = Модель;
		Декларация.ДатаНачала = ДатаДекларации - 157680000; //~5 лет
		Декларация.ДатаОкончания = ДатаДекларации;
		Декларация.Наименование=НомерСертификата;
		Декларация.Организация = Импортер;	 
		Декларация.Изготовитель = Изготовитель;
		Декларация.СтранаПроисхождения = Страна;
		Декларация.Орган = Орган;
		Декларация.Сертификат = Перечисления.ОрганСертификации.ЕАС;
		Если Филиал <> "" Тогда
			Декларация.Филиал = Филиал;
		Иначе 
			Декларация.Филиал = Изготовитель;
		КонецЕсли;
		Декларация.Родитель = Справочники.Декларация.НайтиПоКоду("0009601");
		Декларация.Записать();
		Рез = Декларация.Ссылка;
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиУстановитьДекларацию_Рез(НомерСертификата, ДатаДекларации, Номенклатура, Модель, Филиал, Изготовитель, Орган, Импортер, Страна, Агентский)
	Рез = Неопределено;
	Запрос = Новый Запрос;
	//Если Агентский Тогда
	СоотНДИст = Новый Соответствие;	
	СоотНД = Новый Соответствие;
	Запрос.Текст="ВЫБРАТЬ 
	//|История.Период КАК Период,
	//|История.Объект КАК Объект,
	////|История.Реквизит КАК Реквизит,
	//|История.Документ КК Документ,
	| 1 КАК Парт,        
	|История.Значение КАК Декларация,
	|История.Значение.ДатаОкончания КАК ДатаОкончания,
	|История.Объект КАК Объект
	|	ИЗ
	|РегистрСведений.История.СрезПоследних() КАК История
	|ГДЕ
	|История.Реквизит = ""Декларация""
	|И ТипЗначения(История.Объект )= тип(Справочник.Номенклатура)
	|И ТипЗначения(История.Значение )= тип(Справочник.Декларация)
	| И (История.Объект = &Модель
	|	ИЛИ История.Объект = &Номенклатура)
	|	ОБЪЕДИНИТЬ ВЫБРАТЬ
	|	2,
	|	Декларация.Ссылка ,
	|	Декларация.ДатаОкончания,
	|	Декларация.Объект 
	|ИЗ
	|	Справочник.Декларация КАК Декларация
	|ГДЕ
	|	Декларация.ПометкаУдаления = ЛОЖЬ
	|	И ТИПЗНАЧЕНИЯ(Декларация.Объект) = ТИП(Справочник.Номенклатура)
	|	И (Декларация.Объект = &Номенклатура
	|	ИЛИ Декларация.Объект = &Модель)
	|";
	//Запрос.УстановитьПараметр("Наименование",НомерСертификата);
	Запрос.УстановитьПараметр("Модель",Модель);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Выб = Запрос.Выполнить().Выбрать(); 
	Пока Выб.Следующий() Цикл
		Если Выб.ДатаОкончания > ТекущаяДатаСеанса() Тогда
			Если Выб.Парт = 1 Тогда
				СоотНДИст.Вставить(Выб.Объект, Выб.Декларация);
			Иначе
				СоотНД.Вставить(Выб.Объект, Выб.Декларация);
