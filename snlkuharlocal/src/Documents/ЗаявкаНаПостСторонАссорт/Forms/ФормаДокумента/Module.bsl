Процедура ПровДеклЗапИстор(Декл, Товар)
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	История.Значение КАК значение
	|ИЗ
	|	РегистрСведений.История КАК История
	|ГДЕ
	//|	История.Значение В(&Значение)
	|	История.Значение = &Значение
	|	И История.Объект = &Объект";
	Запрос.УстановитьПараметр("Значение", Декл);
	Запрос.УстановитьПараметр("Объект", Товар);
	
	Результат = Запрос.Выполнить().Выбрать(); 
	Если результат.Количество()=0 тогда
		НоваяЗапись = РегистрыСведений.История.СоздатьМенеджерЗаписи();
		НоваяЗапись.Объект = Товар;			
		НоваяЗапись.Реквизит = "Декларация"; 
		НоваяЗапись.Значение = Декл;
