
&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	// Вставить содержимое обработчика.
	Если НЕ ЗначениеЗаполнено(Объект.Подразделение) Тогда
		ПоказатьПредупреждение(,"Сначала выберите подразделение");
		Возврат;
	КонецЕсли;	
	Объект.Комментарий = "";
	ДиалогФыбораФайла								=	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогФыбораФайла.Фильтр						=	"Файлы Excel (*.xls;*.xlsx)|*.xls;*.xlsx";
	ДиалогФыбораФайла.Заголовок						=	"Выберите файл";
	ДиалогФыбораФайла.ПредварительныйПросмотр		=	Ложь;
	ДиалогФыбораФайла.Расширение					=	"xlsx, xls";
	ДиалогФыбораФайла.ИндексФильтра					=	0;
	Прод=Ложь;
	Если ДиалогФыбораФайла.Выбрать() Тогда 
		
		Расшир = "";
		ИмяФайла = ДиалогФыбораФайла.ПолноеИмяФайла;
		ПослТочка = СтрНайти(ДиалогФыбораФайла.ПолноеИмяФайла, ".", НаправлениеПоиска.СКонца);
		Если ПослТочка > 0 Тогда
			Расшир = Сред(ДиалогФыбораФайла.ПолноеИмяФайла, ПослТочка + 1);
			ИмяФайла = Лев(ИмяФайла,  ПослТочка - 1);
			ПослСлэш = СтрНайти(ИмяФайла, "\", НаправлениеПоиска.СКонца);
			ИмяФайла = ?(ПослСлэш > 0, Сред(ИмяФайла, ПослСлэш + 1), ИмяФайла);  
		КонецЕсли;
		Объект.РасширениеИсходногоФайла = Расшир;
		Объект.ЗагруженВЦО = Истина;
		Объект.ИмяИсходногоФайла = ИмяФайла;
		ФайлС = Новый ДвоичныеДанные(ДиалогФыбораФайла.ПолноеИмяФайла);
    	АдресФ = ПоместитьВоВременноеХранилище(ФайлС, ЭтаФорма.УникальныйИдентификатор);
		ПрочитатьФайл(АдресФ, Расшир);  
		ОбработатьТД();
		//Попытка
		//	ТабличныйДокумент.Прочитать(ДиалогФыбораФайла.ПолноеИмяФайла);
		//Исключение
		//	Сообщить(ОписаниеОшибки());
		//	//Рез.Вставить("Ошибка","Ошибка при обработке икселя "+ОписаниеОшибки());
		//	//Возврат Рез;
		//КонецПопытки;
		
		//РезультатОбр=ПроверитьИкс(ДиалогФыбораФайла.ПолноеИмяФайла);
		Объект.Комментарий = Объект.Комментарий + "Загрузка файла " + Объект.ИмяИсходногоФайла + "." + Объект.РасширениеИсходногоФайла;
		МожноОбработать = ПровЗагружД(Объект.ИменаКолонок);	
		Если МожноОбработать Тогда
			ОбработатьНаСервере();
		Иначе
			Объект.Комментарий = Объект.Комментарий + " в загружаемом файле есть колонки без наименования - дальнейшая обработка невозможна";
		КонецЕсли;
		
		Элементы.ФормаОбработать.Доступность = МожноОбработать;
		Элементы.Группа5.ТекущаяСтраница = ?(МожноОбработать, Элементы.Группа8, Элементы.Группа6);
		Элементы.ФормаФормирДок.Доступность = МожноФормировать;
		Элементы.Статус.Картинка = ?(Объект.ИменаКолонок.Количество() = 0, БиблиотекаКартинок.ОформлениеКвадратыПустые, ?(МожноОбработать, БиблиотекаКартинок.ОформлениеКругЗелeный, БиблиотекаКартинок.ОформлениеКругКрасный));
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		ЭтаФорма.Записать();
		ЭтаФорма.ОбновитьОтображениеДанных();
	Иначе
		ПоказатьПредупреждение(,НСтр("ru='Файл не выбран'"));
		Возврат;
	КонецЕсли;
	Если Объект.Товары.Количество() Тогда
		Элементы.Группа10.Заголовок = "Товары (" + Формат(Объект.Товары.Итог("Количество"), "ЧДЦ=0; ЧГ=3,0") + ")";
	Иначе
		Элементы.Группа10.Заголовок = "Товары";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПрочитатьФайл(АдресФ, Расшир) 
	ИсхТаблица.Очистить();
	ИмяПромежуточногоФайла = ПолучитьИмяВременногоФайла(Расшир);

	ДанныеФайла = ПолучитьИзВременногоХранилища(АдресФ);
	Объект.ИсходныйФайлСтрока = Base64Строка(ДанныеФайла);
	//сообщить(" ДанныеФайла "+строка(ДанныеФайла));
	ДанныеФайла.Записать(ИмяПромежуточногоФайла);
	Объект.ЗагруженВЦО = Истина;
	
	Попытка
		ИсхТаблица.Прочитать(ИмяПромежуточногоФайла);
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
    Попытка
		УдалитьФайлы(ИмяПромежуточногоФайла);
	
	Исключение
	КонецПопытки;
КонецПроцедуры   

&НаСервере
Процедура ОбработатьТД()
	Объект.ИменаКолонок.Очистить();
	Объект.ЗначенияКолонок.Очистить();
	Объект.Товары.Очистить();
	Объект.Брэнды.Очистить();
	Объект.ВидыНоменклатуры.Очистить();
	Объект.Цвета.Очистить();
	Объект.Размеры.Очистить();
	Объект.Коллекции.Очистить();
	нс = Объект.НомСтрКол;
	ПК = 100;
	Пока ПК >0 Цикл
		Если  НЕ СокрЛП(ИсхТаблица.Область(нс, ПК).Текст) = "" ИЛИ НЕ СокрЛП(ИсхТаблица.Область(нс + 1, ПК).Текст) = "" ИЛИ НЕ СокрЛП(ИсхТаблица.Область(нс + 2, ПК).Текст) = ""
			ИЛИ НЕ СокрЛП(ИсхТаблица.Область(нс + 3, ПК).Текст) = "" ИЛИ НЕ СокрЛП(ИсхТаблица.Область(нс + 4, ПК).Текст) = "" Тогда
			Прервать;
		КонецЕсли;	
		ПК = ПК - 1;
	КонецЦикла;
	нк = 1;
	кк = 0;
	Пока нк <= ПК Цикл
		НовСтр = Объект.ИменаКолонок.Добавить();
		НовСтр.НомерКолонки = нк;
		НовСтр.ИмяКолонки = ?(СокрЛП(ИсхТаблица.Область(нс, нк).Текст) = "", "<>", СокрЛП(ИсхТаблица.Область(нс, нк).Текст));
		нк = нк + 1;
		кк = кк + 1;
	КонецЦикла;
	
	нс = Объект.НомСтрКол + 1;
	нк = 1;
	Пока НЕ ПустаяСтрока(ИсхТаблица.Область(нс, 1).Текст) ИЛИ НЕ ПустаяСтрока(ИсхТаблица.Область(нс, 2).Текст) ИЛИ НЕ ПустаяСтрока(ИсхТаблица.Область(нс, 3).Текст) ИЛИ НЕ ПустаяСтрока(ИсхТаблица.Область(нс, 4).Текст) Цикл
		нк = 1;
		Пока нк <= кк Цикл
			НовСтр = Объект.ЗначенияКолонок.Добавить();
			НовСтр.НомерКолонки = нк;
			НовСтр.НомерСтрокиТаб = нс;
			НовСтр.СтрокаЗначение = СокрЛП(ИсхТаблица.Область(нс, нк).Текст);
			нк = нк + 1;
		КонецЦикла;
		нс = нс + 1;
	КонецЦикла;
КонецПроцедуры


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//Вставить содержимое обработчика
	Если НЕ ЗначениеЗаполнено(Объект.Автор) Тогда
		Объект.Автор		= ПараметрыСеанса.Пользователь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ДатаПоставки) Тогда
		Объект.ДатаПоставки		= НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.НомСтрКол) Тогда
		Объект.НомСтрКол = 1;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.НомКолКодПроизв) Тогда
		Объект.НомКолКодПроизв = 2;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.НомКолШК) Тогда
		Объект.НомКолШК = 5;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.НомКолТНВЭД) Тогда
		Объект.НомКолТНВЭД = 27;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.НомКолБр) Тогда
		Объект.НомКолБр = 8;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.НомКолВН) Тогда
		Объект.НомКолВН = 10;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.НомКолНДС) Тогда
		Объект.НомКолНДС = 9;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.НомКолЦв) Тогда
		Объект.НомКолЦв = 3;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.НомКолРз) Тогда
		Объект.НомКолРз = 4;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.СкладПРМ) Тогда
		Объект.СкладПРМ		= Справочники.Склады.НайтиПоКоду("SSX-66");
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.КонтрагентПРМ) Тогда
		Объект.КонтрагентПРМ		= Справочники.Контрагенты.НайтиПоКоду("SSP-7012");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СкладПолучПРМ) И ЗначениеЗаполнено(Объект.Подразделение) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Склады.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Подразделение = &Подразделение";
		Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);
		Выб = Запрос.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Объект.СкладПолучПРМ = Выб.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	Элементы.РодПапка.СписокВыбора.Очистить();
	РодП1 = Справочники.Номенклатура.НайтиПоКоду("SNL-511970");
	РодП2 = Справочники.Номенклатура.НайтиПоКоду("SNL-309252");
	Если НЕ ЗначениеЗаполнено(Объект.РодПапка) Тогда
		Если Объект.Брэнды.Количество() Тогда
			СтрБр = Объект.Брэнды.Получить(0);
			Если СтрБр.Брэнд.ВидБренда = Перечисления.ВидБренда.Агентский Тогда
				Объект.РодПапка		= РодП1;
			Иначе
				Объект.РодПапка		= РодП2;
			КонецЕсли;
		Иначе
			Объект.РодПапка		= РодП1;	
		КонецЕсли;
	КонецЕсли;
	Элементы.РодПапка.СписокВыбора.Добавить(РодП1);
	Элементы.РодПапка.СписокВыбора.Добавить(РодП2);
	Если Объект.Товары.Количество() Тогда
		Элементы.Группа10.Заголовок = "Товары (" + Формат(Объект.Товары.Итог("Количество"), "ЧДЦ=0; ЧГ=3,0") + ")";
	Иначе
		Элементы.Группа10.Заголовок = "Товары";
	КонецЕсли;
	ПерезапСВ();	
КонецПроцедуры

&НаСервере
Процедура ПерезапСВ()
	Если ЗначениеЗаполнено(Объект.РодПапка) Тогда
		Элементы.ПапНовМод.СписокВыбора.Очистить();
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	Номенклатура.Ссылка КАК Ссылка
		               |ИЗ
		               |	Справочник.Номенклатура КАК Номенклатура
		               |ГДЕ
		               |	Номенклатура.Родитель = &Род";
		Запрос.УстановитьПараметр("Род", Объект.РодПапка);
		Выб = Запрос.Выполнить().Выбрать();
		Пока Выб.Следующий() Цикл
			Элементы.ПапНовМод.СписокВыбора.Добавить(Выб.Ссылка);
		КонецЦикла;	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	//Вставить содержимое обработчика
	
	Для Каждого ТСтр Из Объект.ИменаКолонок Цикл
		ИсхТаблица.Область(1, ТСтр.НомерКолонки).Текст = ТСтр.ИмяКолонки;
	КонецЦикла;
	
	Для Каждого ТСтр Из Объект.ЗначенияКолонок Цикл
		ИсхТаблица.Область(ТСтр.НомерСтрокиТаб, ТСтр.НомерКолонки).Текст = ТСтр.СтрокаЗначение;
	КонецЦикла;
	Если Объект.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияЗаявкиНаСторонПост.Отменена") Тогда
		МожноОбработать = Ложь;
		Элементы.ФормаЗагрузитьИзФайла.Доступность =  Ложь;
	Иначе
		МожноОбработать = ПровЗагружД(Объект.ИменаКолонок);	
	КонецЕсли;
	Если Объект.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияЗаявкиНаСторонПост.Выполнена") Тогда
		Элементы.Статус.Картинка = БиблиотекаКартинок.ВыполненоУспешно32;
		Элементы.ФормаОбработать.Доступность = Ложь;
		Элементы.ФормаФормирДок.Доступность =  Ложь;
		Элементы.ФормаЗагрузитьИзФайла.Доступность =  Ложь;
	Иначе
		Элементы.Статус.Картинка = ?(Объект.ИменаКолонок.Количество() = 0, БиблиотекаКартинок.ОформлениеКвадратыПустые, ?(МожноОбработать, БиблиотекаКартинок.ОформлениеКругЗелeный, БиблиотекаКартинок.ОформлениеКругКрасный));
		Элементы.ФормаОбработать.Доступность = ?(Объект.ИменаКолонок.Количество() = 0, Ложь, ?(МожноОбработать, Истина, Ложь));
		Элементы.ФормаФормирДок.Доступность = ?(Объект.ИменаКолонок.Количество() = 0, Ложь, ?(МожноФормировать, Истина, Ложь));
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Функция ПолучитьНомХар(МСШК, МСК, СтрЦвет, СтрРазмер, СтрНаим, тЦвет = Неопределено, тРазмер = Неопределено)
	
	//|ВЫБРАТЬ
	//|ВТТ.НК,
	//|ВТТ.НСТ,
	//|ВТТ.СтрЗн,
	//|	isnull(Штрихкоды.Владелец, """") КАК Ном,
	//|	isnull(ХН.Ссылка, """") КАК ХарНом
	Ном = Неопределено;
	ХарНом = Неопределено;
	Найдено = Ложь;
	нс = 0;
	Пока нс < МСШК.Количество() Цикл
		Если ЗначениеЗаполнено(МСШК[нс].Ном) Тогда
			Ном = МСШК[нс].Ном;
		КонецЕсли;
		Если ЗначениеЗаполнено(МСШК[нс].ХарНом) Тогда
			ХарНом = МСШК[нс].ХарНом;
			
		КонецЕсли;
		нс =нс + 1;
	КонецЦикла;
	Если Ном = Неопределено ИЛИ ХарНом = Неопределено Тогда
		Пока нс < МСК.Количество() Цикл
			Если ЗначениеЗаполнено(МСК[нс].НомАрт) Тогда
				Ном = МСК[нс].НомАрт;
			Иначе
				Если ЗначениеЗаполнено(МСК[нс].Ном) Тогда
					Ном = МСК[нс].Ном;
				КонецЕсли;
			КонецЕсли;
			Если ЗначениеЗаполнено(МСК[нс].ХарНом) Тогда		        
				ХарНом = МСК[нс].ХарНом;
				Если ЗначениеЗаполнено(тЦвет) И ЗначениеЗаполнено(тРазмер) Тогда
					Найдено = ?((ХарНом.Цвет = тЦвет И ХарНом.Размер = тРазмер), Истина, Ложь);
				Иначе	
					Найдено = СопоставитЦветРазмер(СокрЛП(ХарНом.Цвет.Наименование), СокрЛП(ХарНом.Цвет.РусскоеНаименование), СокрЛП(ХарНом.Размер.Наименование), СтрНаим, СтрЦвет, СтрРазмер);
				КонецЕсли;	
				//Если СокрЛП(ХарНом.Цвет.Наименование) = СтрЦвет И СокрЛП(ХарНом.Размер.Наименование) = СтрРазмер Тогда
				Если Найдено Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;
			нс =нс + 1;
		КонецЦикла;
	Иначе
		Найдено = Истина;
	КонецЕсли;	
	Рез = Новый Структура("Ном, ХарНом, Найдено", Ном, ХарНом, Найдено);
	Возврат Рез;
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПровЗагружД(ТЗКол)
	Рез = Истина;
	Для Каждого ТСтр Из ТЗКол Цикл
		Если ТСтр.ИмяКолонки = "<>" Тогда
			Если ТСтр.НомерКолонки < 6 ИЛИ ТСтр.НомерКолонки = 8 ИЛИ ТСтр.НомерКолонки = 10 Тогда
				Рез = Ложь;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;	
