Функция ПолучитьИзТЧ(ТЧ, ИмяРеквП, РеквП, ИмяРекв)
	Рез = Неопределено;
	Найды = Объект[ТЧ].НайтиСтроки(Новый Структура(ИмяРеквП, РеквП));
	Если Найды.Количество() Тогда
