		// НоваяЗапись.Документ=ДокС;
		НоваяЗапись.Записать();  
		
	КонецЕсли;
КонецПроцедуры



&НаСервере
Процедура ФормирДокНаСервере_1()
	// Вставить содержимое обработчика.
	ТЗПоискНом.Очистить();
	Если ЗначениеЗаполнено(Объект.ПНК) Тогда
		Сообщить("Документы уже сформированы");
		Возврат;
	КонецЕсли;
	МБренд = Новый Массив;
	МКП = Новый Массив;
	МНС = Новый Массив;
	Для Каждого ТСтр Из Объект.Брэнды Цикл
		МБренд.Добавить(ТСтр.Брэнд);
	КонецЦикла;	
	Для Каждого ТСтр Из Объект.Товары Цикл
		СтрНом = ТСтр.СтрНоменклатура;
		Если НЕ ТСтр.ТоварНайден И НЕ ТСтр.ТоварСоздан Тогда
			СтрКП = ВыделитьЧасть(СтрНом, "Код:", ";");
			Если НЕ ПустаяСтрока(СтрКП) Тогда
				МКП.Добавить(СтрКП);
				МНС.Добавить(ТСтр.НомерСтроки);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если МКП.Количество() Тогда
		Запрос = Новый Запрос;
		КП = МКП[0];
		НС = МНС[0];
		Б1 = Ложь;
		ДВ = "";
		Если МКП.Количество() > 1 Тогда
			 Б1 = Истина;
			 н = 1;
			 Пока н < МКП.Количество() Цикл
				ТКП = МКП.Получить(н);
				ТНС = МНС.Получить(н);
			 	Запрос.УстановитьПараметр("КП" + Формат(н, "ЧГ=0"), ТКП);
				Запрос.УстановитьПараметр("НС" + Формат(н, "ЧГ=0"), ТНС);
				ДВ = ДВ + " ОБЪЕДИНИТЬ ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ВЫБОР КОГДА 
				|	isnull(Номенклатура1.КодПроизводителя, """") = """" ТОГДА &КП" + Формат(н, "ЧГ=0") + "
				|	ИНАЧЕ Номенклатура1.КодПроизводителя КОНЕЦ,
				|	&НС" + Формат(н, "ЧГ=0") + ",
				|	isnull(Номенклатура1.Ссылка, Значение(Справочник.Номенклатура.ПустаяСсылка)),
				|	Номенклатура.Родитель.Ссылка,
				|	Номенклатура.Родитель.Родитель
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
				|	ПО Номенклатура.ФР_Бренд = Номенклатура1.ФР_Бренд
				|	И Номенклатура.Родитель = Номенклатура1.Родитель
				|	И Номенклатура.Родитель.Родитель = Номенклатура1.Родитель.Родитель
				|	И Номенклатура1.КодПроизводителя = &КП" + Формат(н, "ЧГ=0") + " 
				|ГДЕ
				|	Номенклатура.ФР_Бренд В(&Бренды)
				|	И Номенклатура1.ФР_Бренд В(&Бренды) 
				|	";
				н = н + 1;
			КонецЦикла;	
		КонецЕсли; 
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫБОР КОГДА 
		|	isnull(Номенклатура1.КодПроизводителя, """") = """" ТОГДА &КП
		|	ИНАЧЕ Номенклатура1.КодПроизводителя КОНЕЦ КАК КодПроизводителя,
		|	&НС КАК НомСтр,
		|	isnull(Номенклатура1.Ссылка, Значение(Справочник.Номенклатура.ПустаяСсылка)) КАК Папка,
		|	Номенклатура.Родитель.Ссылка КАК Род,
		|	Номенклатура.Родитель.Родитель КАК Род1
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
		|	ПО Номенклатура.ФР_Бренд = Номенклатура1.ФР_Бренд
		|	И Номенклатура.Родитель = Номенклатура1.Родитель
		|	И Номенклатура.Родитель.Родитель = Номенклатура1.Родитель.Родитель
		|	И Номенклатура1.КодПроизводителя = &КП
		|ГДЕ
		|	Номенклатура.ФР_Бренд В(&Бренды)
		|	И Номенклатура1.ФР_Бренд В(&Бренды)
		| " + ДВ + "
		|";
		Запрос.УстановитьПараметр("КП", КП);
		Запрос.УстановитьПараметр("НС", НС);
		Запрос.УстановитьПараметр("Бренды", МБренд);
		ТЗПоискНом.Загрузить(Запрос.Выполнить().Выгрузить());
		//Создание ном и групп
		Для Каждого ТекСтр Из ТЗПоискНом Цикл
			НайдыТ = Объект.Товары.НайтиСтроки(Новый Структура("НомерСтроки", ТекСтр.НомСтр));
			Если НайдыТ.Количество() Тогда
				НайдТ = НайдыТ[0];
				ОтвСтр = СоздатьНом(ТекСтр.Род, ПапНовМод, ТекСтр.Папка, НайдТ);//, Объект.Брэнды, Объект.ВидыНоменклатуры, Объект.Цвета, Объект.Размеры);
				НайдТ.ТоварСоздан = ОтвСтр.Создан;
				НайдТ.Номенклатура = ОтвСтр.Мод;
				НайдТ.ХарактеристикаНоменклатуры = ОтвСтр.Ном;
				//Если ЗначениеЗаполнено(ТекСтр.Родитель) Тогда
				//	Если ЗначениеЗаполнено(ТекСтр.Папка) Тогда
				//		//созд. только элем.
				//		
				//	Иначе
				//		//созд. мод. и элем.
				//	КонецЕсли;	
				//КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//SSP-7012 код контра
	//формирование док-тов
		
	ФормПРМ = Ложь;
	
	ПРМ = Документы.Перемещение.СоздатьДокумент();
	ПРМ.Склад = Объект.СкладПРМ;
	ПРМ.СкладПолучатель = Объект.СкладПолучПРМ;
	ПРМ.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
	ПРМ.Менеджер = ПараметрыСеанса.Пользователь.ФизЛицо;
	ПРМ.Автор = ПараметрыСеанса.Пользователь;
	ПРМ.Организация=Справочники.Организации.НайтиПоКоду("SS-001");
	ПРМ.Контрагент = Справочники.Контрагенты.НайтиПоКоду("SSP-7012");
	УстановитьПунктДоставкиД(ПРМ,"СкладПолучатель","ПунктДоставки");
	ПРМ.Комментарий="Создано обработкой. ПРМ Сторон. ассорт.";
	ПРМ.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	ПРМ.СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.ГотоваКПриемке;
	ПРМ.Отгружен = Перечисления.Отгружен.Отгружен;
	ПРМ.Дата = Объект.ДатаПоставки;
	ПРМ.ДатаПриемки = Объект.ДатаПоставки;
	ПРМ.Валюта=Справочники.Валюты.НайтиПоКоду("810");
	ПРМ.Курс=1;
		
	УстановитьНомерДокументаКлиентСервер(ПРМ);
	
	ОСум = 0;
	Для Каждого ТСтр Из Объект.Товары Цикл
		Если ТСтр.ТоварНайден ИЛИ ТСтр.ТоварСоздан Тогда
			Если ТСтр.Количество > 0 Тогда
				НовС = ПРМ.Товары.Добавить();
				НовС.Номенклатура = ТСтр.ХарактеристикаНоменклатуры;
				НовС.Единица = Справочники.Единицы.НайтиПоНаименованию("шт.", , , ТСтр.ХарактеристикаНоменклатуры);
				НовС.Заявка = ТСтр.Количество;
				НовС.ПодтвержденнаяЗаявка = ТСтр.Количество;
				НовС.Количество = ТСтр.Количество;
				НовС.Коэффициент = ТСтр.Коэффициент;
				НовС.Цена = ТСтр.Цена;
				НовС.СтавкаНДС = ТСтр.Номенклатура.СтавкаНДС;
				НовС.Себестоимость = ТСтр.ЦенаПоСебестоимости;
				НовС.Всего = НовС.Цена * НовС.Количество;
				ПроцНДС = ПроцентНДСпоСтавке(НовС.СтавкаНДС);
				НовС.НДС	=НовС.Всего * ПроцНДС/(1+ПроцНДС);			
				НовС.Сумма  =НовС.Всего - НовС.НДС;
				ОСум = ОСум + НовС.Всего;
			КонецЕсли;
			
		КонецЕсли;	
	КонецЦикла;
	ПРМ.СуммаДокумента = ОСум;
	Попытка
		ПРМ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ПРМ.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;
	ПрмСсыл = ПРМ.Ссылка;
	
	ПрайсРозн = Документы.ПрайсЛист.СоздатьДокумент();
	ПрайсРозн.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
	ПрайсРозн.Курс = 1;
	ПрайсРозн.Автор = ПараметрыСеанса.Пользователь;
	ПрайсРозн.Организация=Справочники.Организации.НайтиПоКоду("SS-001");
