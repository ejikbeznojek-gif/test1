		 ШКОбъект=Справочники.ШтрихКоды.СоздатьЭлемент();			
		 ШКОбъект.Владелец	=Номенклатура;
		 ШКОбъект.ТипШК		=ТипШК;
		 ШКОбъект.ВидШК		=Перечисления.ВидыШК.Основной;
	 ИначеЕсли СсылкаНаШК.Наименование="9999999999999" Тогда
		 ШКОбъект=СсылкаНаШК.ПолучитьОбъект();
	 Иначе
		 // по идее нормальный штрих код		
		 Возврат;
	 КонецЕсли; 	
	 
	 ШКОбъект.Наименование	=ШтрихКод;
	 ШКОбъект.ПометкаУдаления=Ложь;
	 если СтрДлина(ШтрихКод)=13 тогда
		 КС=КонтрольныйСимволEAN(Лев(ШКОбъект.Наименование,12),13);
		 Если Прав(ШКОбъект.Наименование,1)<> КС тогда
			 Сообщить("ШК - не записан. Некорректный контрольный символ  в ШК-"+ШКОбъект.Наименование+".В Номенклатуре "+Номенклатура.наименование+". Допустимый ШК - "+Лев(ШКОбъект.Наименование,12)+КС);
	 
			 НомерШК=ПолучитьМаксимальныйНомерШК()+1;
			 
			 ШКШтуки="20"+Формат(НомерШК,"ЧЦ=10; ЧРГ=; ЧВН=; ЧГ=0");
			 ШКШтуки=ШКШтуки+КонтрольныйСимволEAN(ШКШтуки,13);
			 
			 ШКБлочка="21"+Формат(НомерШК,"ЧЦ=10; ЧРГ=; ЧВН=; ЧГ=0");
			 ШКБлочка=ШКБлочка+КонтрольныйСимволEAN(ШКБлочка,13);
			 
			 ШККоробки="22"+Формат(НомерШК,"ЧЦ=10; ЧРГ=; ЧВН=; ЧГ=0");
			 ШККоробки=ШККоробки+КонтрольныйСимволEAN(ШККоробки,13);
			 
			 ПрописатьШтрихКодаТовара(Номенклатура,Перечисления.ТипыШтрихКодов.Штука,ШКШтуки);
			 ПрописатьШтрихКодаТовара(Номенклатура,Перечисления.ТипыШтрихКодов.Блочок,ШКБлочка);
			 ПрописатьШтрихКодаТовара(Номенклатура,Перечисления.ТипыШтрихКодов.Коробка,ШККоробки);
		 
		 иначе
			 попытка
				 ШКОбъект.Записать();	
			 Исключение
				 Сообщить(ОписаниеОшибки());
			 КонецПопытки;		 		 
		 КонецЕсли;
	 иначе
		 попытка
			 ШКОбъект.Записать();	
		 Исключение
			 Сообщить(ОписаниеОшибки());
		 КонецПопытки;
	 КонецЕсли;
	 
КонецПроцедуры//ПрописатьШтрихКодаТовара 

