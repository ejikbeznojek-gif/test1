Функция СоздатьНом(Род, РодП,  Мод, ТовСтр)
	//, ТЗБрэнды, ТЗВидыНоменклатуры, ТЗЦвета, ТЗРазмеры)
	Рез = Новый Структура("Ном, Мод, Создан", Неопределено, Мод, Ложь);
	Если НЕ ЗначениеЗаполнено(Род) И НЕ ЗначениеЗаполнено(РодП) Тогда
		Возврат Рез;
	КонецЕсли;
	тРод = ?(ЗначениеЗаполнено(Род), Род, РодП);
	
	//Наименование:Трусы-бразилиана SNAKE 63147-18;Код:63147-18;Бренд:COQUETTE REVUE;Тип товара:Бразилиана;Состав:80% ПОЛИАМИД, 20% ЭЛАСТАН
	//Штрихкод:9999999999999;Цвет:черный с нюдом;Размер:40
	СтрНаиМ = ВыделитьЧасть(ТовСтр.СтрНоменклатура, "Наименование:", ";");
	СтрКодП = ВыделитьЧасть(ТовСтр.СтрНоменклатура, "Код:", ";");
	СтрБренд = ВыделитьЧасть(ТовСтр.СтрНоменклатура, "Бренд:", ";");
	СтрТипТ = ВыделитьЧасть(ТовСтр.СтрНоменклатура, "Тип товара:", ";");
	СтрСост = ВыделитьЧасть(ТовСтр.СтрНоменклатура, "Состав:", ";");
	СтрукСост = ПарситСостав(СтрСост);
	СтрШК = ВыделитьЧасть(ТовСтр.СтрХарНом, "Штрихкод:", ";");
	СтрЦвет = ВыделитьЧасть(ТовСтр.СтрХарНом, "Цвет:", ";");
	СтрРазм = ВыделитьЧасть(ТовСтр.СтрХарНом, "Размер:", ";");
	//ФР_Бренд = ТЗБрэнды.Найти(СтрБренд, "Наименование").Брэнд;
	//ФР_ВидН = ТЗВидыНоменклатуры.Найти(СтрТипТ, "Наименование").ВидНоменклатуры;
	//
	//тЦвет = ТЗЦвета.Найти(СтрЦвет, "Наименование").Цвет;
	//тРазм = ТЗРазмеры.Найти(СтрРазм, "Наименование").Размер;
	//ФР_ВидН = ТЗВидыНоменклатуры.Найти(СтрТипТ, "Наименование").ВидНоменклатуры;
	ФР_Бренд = ПолучитьИзТЧ("Брэнды", "Наименование", СтрБренд, "Брэнд");
	ФР_ВидН = ПолучитьИзТЧ("ВидыНоменклатуры", "Наименование", СтрТипТ, "ВидНоменклатуры");
	//ТЗВидыНоменклатуры.Найти(СтрТипТ, "Наименование").ВидНоменклатуры;
	
	тЦвет = ПолучитьИзТЧ("Цвета", "Наименование", СтрЦвет, "Цвет");
	//ТЗЦвета.Найти(СтрЦвет, "Наименование").Цвет;
	тРазм = ПолучитьИзТЧ("Размеры", "Наименование", СтрРазм, "Размер"); 
	//ТЗРазмеры.Найти(СтрРазм, "Наименование").Размер;
	//ФР_ВидН = ПолучитьИзТЧ(ТЗВидыНоменклатуры, "Наименование", СтрБренд, "Брэнд");
	//ТЗВидыНоменклатуры.Найти(СтрТипТ, "Наименование").ВидНоменклатуры;

	ФР_Коллекция = Справочники.ФР_Коллекции.НайтиПоНаименованию(Род.Наименование);
	
	//сообщить(Строка(тЦвет) + " " + строка(ФР_Коллекция));
	Если НЕ ЗначениеЗаполнено(Мод) Тогда
		Возврат Рез;
	КонецЕсли;	
	НомО = Справочники.Номенклатура.СоздатьЭлемент();
	НомО.Родитель = Мод;
	НомО.ПервичнаяГруппа = Мод;
	НомО.БазоваяЕдиница = Справочники.ОКЕИ.НайтиПоКоду("796");
	НомО.Наименование = СтрНаиМ + " " + СтрЦвет + " " + СтрРазм;
	НомО.Цвет = тЦвет;
	НомО.Размер = тРазм;
	НомО.ЖизненныйЦиклНоменклатуры = Перечисления.ЖизненныйЦиклНоменклатуры.Активна;
	НомО.Записать();
	Ном= НомО.Ссылка;
	
	ЕдиницаОбъект = Справочники.Единицы.СоздатьЭлемент();
	ЕдиницаОбъект.Владелец     = Ном;
	ЕдиницаОбъект.Наименование = Ном.БазоваяЕдиница.Наименование;
	ЕдиницаОбъект.ОКЕИ			= Ном.БазоваяЕдиница;
	ЕдиницаОбъект.Коэффициент  = 1;		
	Попытка
		ЕдиницаОбъект.Записать();
		Прот = Прот + "Запись ед. хран. " + СокрЛП(ЕдиницаОбъект) + Символы.ПС;
	Исключение
		Сообщить("Не удалось записать единицу хранения остатков: " + ОписаниеОшибки(), СтатусСообщения.Важное);
		Прот = Прот + "Запись ед. хран., ошибка " + ОписаниеОшибки() + Символы.ПС;
	КонецПопытки;
	Если СтрШК = "9999999999999" Тогда
		НомерШК=ПолучитьМаксимальныйНомерШК()+1;
		ШКШтуки="60"+Формат(НомерШК,"ЧЦ=10; ЧРГ=; ЧВН=; ЧГ=0");
		ШКШтуки=ШКШтуки + КонтрольныйСимволEAN(ШКШтуки,13);		
		ПрописатьШтрихКодаТовара(Ном, Перечисления.ТипыШтрихКодов.Штука, ШКШтуки);
	Иначе
		ПрописатьШтрихКодаТовара(Ном, Перечисления.ТипыШтрихКодов.Штука, СтрШК);
	КонецЕсли;	
	Рез.Ном = Ном;
	Рез.Создан = Истина;
	Возврат Рез;
КонецФункции	


