Функция ПолучитьДатуИзСтр(СтрДата)
	
	Рез = Неопределено;
	Попытка
		СтрДата = СокрЛП(СтрДата);
		СтрРез = "";
		РаздТ = Найти(СтрДата,".");
		РаздТр = Найти(СтрДата,"-");
		РаздЗ = Найти(СтрДата,",");
		РаздСП = Найти(СтрДата,"/");
		РаздСО = Найти(СтрДата,"\");
		РаздДТ = Найти(СтрДата,":");
		Если (РаздТ>0) И (РаздТр>0) Тогда
			Если (РаздТ>РаздТр) Тогда
				РаздТ = 0;
			КонецЕсли;
		КонецЕсли;
		
		Если (РаздТ > 0) ИЛИ (РаздЗ > 0) Тогда
			//сообщить("РаздСП "+строка(РаздСП));
			//предположим германский с разными разделителями
			Если (Сред(СтрДата,3,1) = ".") Тогда
				Попытка
					Если (РаздДТ > 0) Тогда
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						СтрЧМ = СокрЛП(Сред(СтрДата,11));
						СтрЧМ = СтрЗаменить(СтрЧМ,":","");
						СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ) = 5 Тогда
							СтрЧМ = "0" + СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ = Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ = "000000") Тогда
							СтрРез = СтрРез + СтрЧМ;
						КонецЕсли;
						Рез = Дата(СтрРез);
					Иначе	
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						Рез = Дата(СтрРез);
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;
			
		ИначеЕсли РаздТр>0 Тогда
			
			Если Сред(СтрДата,3,1) = "-" Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						СтрЧМ = СокрЛП(Сред(СтрДата,11));
						
						СтрЧМ = СтрЗаменить(СтрЧМ,":","");
						СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ) = 5 Тогда
							СтрЧМ = "0" + СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ = Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ = "000000") Тогда
							СтрРез = СтрРез + СтрЧМ;
						КонецЕсли;
						Рез = Дата(СтрРез);
					Иначе	
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						Рез = Дата(СтрРез);
					КонецЕсли;
				Исключение
				КонецПопытки;
			Иначе
				СтрЧМ = СокрЛП(Сред(СтрДата,11));
				СтрРез = СтрЗаменить(СокрЛП(Лев(СтрДата,10)),"-","");
				СтрЧМ = СтрЗаменить(СтрЧМ,":","");
				СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
				Если СтрДлина(СтрЧМ) = 5 Тогда
					СтрЧМ = "0" + СтрЧМ;
				КонецЕсли;
				Если СтрДлина(СтрЧМ)>6 Тогда
					СтрЧМ = Лев(СтрЧМ,6);
				КонецЕсли;
				Если НЕ(СтрЧМ = "000000") Тогда
					СтрРез = СтрРез + СтрЧМ;
				КонецЕсли;
				Рез = Дата(СтрРез);
			КонецЕсли;
			
		ИначеЕсли РаздСП>0 Тогда
			ДлС = СтрДлина(СтрДата);
			сообщить(длс);
			СтрГод = "";
			СтрМес = "";
			СтрДень = "";
			Поз = 1;
			СчтСлаш = 0;
			Пока Поз<= ДлС Цикл
				Если Сред(СтрДата, Поз, 1) = "/" Тогда
					СчтСлаш = СчтСлаш + 1;
				Иначе
					Если СчтСлаш = 0 Тогда
						СтрМес = СтрМес + Сред(СтрДата, Поз, 1);
					ИначеЕсли СчтСлаш = 1 Тогда
						СтрДень = СтрДень + Сред(СтрДата, Поз, 1);
					Иначе
						СтрГод = СтрГод + Сред(СтрДата, Поз, 1);
					КонецЕсли;
				КонецЕсли;
				Поз  =  Поз  +  1;
			КонецЦикла;
			СтрГод = ?(СтрДлина(СтрГод)>4, Лев(СтрГод,4), СтрГод);
			Рез = Дата(Число(СтрГод),Число(СтрМес), Число(СтрДень));
		Иначе
			//анси формат
			Если СтрДлина(СтрДата)>= 8 Тогда
				Рез = Дата(Лев(СтрДата,8));
			КонецЕсли;
		КонецЕсли;
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	Возврат Рез;
	
КонецФункции

&НаСервере
Процедура ПодразделениеПриИзмененииНаСервере()
	// Вставить содержимое обработчика.
	Объект.СкладПолучПРМ = Объект.Подразделение.ОсновнойСклад;
	Если НЕ ЗначениеЗаполнено(Объект.СкладПолучПРМ) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Склады.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Подразделение = &Подразделение";
		Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);
		Выб = Запрос.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Объект.СкладПолучПРМ = Выб.Ссылка;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

