Процедура ФормирДокНаСервере()
	// Вставить содержимое обработчика.
	//формирование док-тов
	Прот = "";
	Сч = 0;
	Для Каждого ТСтр Из Объект.Товары Цикл
		Если ТСтр.ТоварНайден ИЛИ ТСтр.ТоварСоздан Тогда
			Сч = Сч + 1;
		КонецЕсли;	
	КонецЦикла;		
	Если НЕ Сч = Объект.Товары.Количество() Тогда
		//Сообщить("Не все товары найдены");
		Прот = Прот + "Не все товары найдены" + Символы.ПС;
		Сообщить("Не все товары найдены формирование документов отменено");
		Возврат;
	КонецЕсли;
	//ФормПРМ = Ложь;
	
	ПРМ = Документы.Перемещение.СоздатьДокумент();
	ПРМ.Склад = Объект.СкладПРМ;
	ПРМ.СкладПолучатель = Объект.СкладПолучПРМ;
	ПРМ.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
