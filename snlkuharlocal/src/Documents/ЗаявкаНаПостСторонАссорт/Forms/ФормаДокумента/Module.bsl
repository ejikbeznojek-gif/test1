Функция УбратьСлСимвПроб1(ВхСтр)
	Рез = "";
	Поз = 1;
	ДлС = СтрДлина(ВхСтр);
	Пока Поз <= ДлС Цикл
		Если КодСимвола(Сред(ВхСтр, Поз, 1)) > 32 И КодСимвола(Сред(ВхСтр, Поз, 1)) <> 160 Тогда
			Рез = Рез + Сред(ВхСтр, Поз, 1);
		КонецЕсли;
		Поз = Поз + 1;
	КонецЦикла;
	Возврат Рез;
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция КонвЧисло(ВхСтр)
	Рез = 0;
	ЕстьРазд = Ложь;
	//ВхСтр = СтрЗаменить(ВхСтр, " ", "");
	ВхСтр = УбратьСлСимвПроб1(ВхСтр);
	ПР = 0;
	П1 = СтрНайти(ВхСтр, ",");
	П2 = СтрНайти(ВхСтр, ".");
	П3 = СтрНайти(ВхСтр, "-");
	Если П1 > 1 Тогда
		ПР = П1;
	ИначеЕсли П2 > 1 Тогда
		ПР = П2;
	ИначеЕсли П3 > 1 Тогда
		ПР = П3;	
	КонецЕсли;
	Если ПР > 1 Тогда
		Рез = Число(Лев(ВхСтр, ПР - 1));
		СтрДЧ = Сред(ВхСтр, ПР + 1);
		
		Если СтрДлина(СтрДЧ) = 3 Тогда
			Пока Лев(СтрДЧ, 1) = "0" Цикл
				СтрДЧ = Сред(СтрДЧ, 2);
			КонецЦикла;
			Если СтрДлина(СтрДЧ) >= 1 Тогда
				Рез = Рез + Число(СтрДЧ) * 0.001;
			КонецЕсли;
		ИначеЕсли СтрДлина(СтрДЧ) = 2 Тогда
			Пока Лев(СтрДЧ, 1) = "0" Цикл
				СтрДЧ = Сред(СтрДЧ, 2);
			КонецЦикла;
			Если СтрДлина(СтрДЧ) >= 1 Тогда
				Рез = Рез + Число(СтрДЧ) * 0.01;
			КонецЕсли;
		ИначеЕсли СтрДлина(СтрДЧ) = 1 Тогда
			Рез = Рез + Число(СтрДЧ) * 0.1;
		КонецЕсли;	
		
	Иначе
		Рез = Число(ВхСтр);
	КонецЕсли;	
	
	Возврат Рез;
КонецФункции

