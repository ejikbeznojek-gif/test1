&НаСервереБезКонтекста
Процедура ПровГТДЗапИстор(ГТД, Страна, Импортер, Товар, ДокС)
	Запрос = Новый Запрос;
	Запрос.Текст= "ВЫБРАТЬ
	|	ГТД.Ссылка КАК ссылка
	|ИЗ
	|	Справочник.ГТД КАК ГТД
	|ГДЕ
	|	ГТД.Импортер = &Импортер
	|	И ГТД.ПометкаУдаления = ЛОЖЬ
	|	И ГТД.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Импортер", Импортер);
	Запрос.УстановитьПараметр("Наименование", ГТД);
	
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Количество() = 0 Тогда
		ГТД=Справочники.ГТД.СоздатьЭлемент();
		ГТД.Импортер = Импортер;
		ГТД.Владелец=Справочники.ИБ.НайтиПоКоду("SSP");
		ГТД.Родитель=Справочники.ГТД.НайтиПоКоду("TZ2-188");
		ГТД.СтранаПроисхождения = Страна;
		ГТД.Наименование=ГТД;
		Попытка
			ГТД.Записать();		 
		Исключение
			//сообщить(ОписаниеОшибки());
			//Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;    
	
	Запрос.Текст="ВЫБРАТЬ
	|	История.Значение КАК значение
	|ИЗ
	|	РегистрСведений.История КАК История
	|ГДЕ
	|	История.Значение = &Значение
	|	И История.Объект = &Объект";
	Запрос.УстановитьПараметр("Значение", ГТД);
	Запрос.УстановитьПараметр("Объект", Товар);
	
	Результат=запрос.Выполнить().Выбрать();
	Если результат.Количество()=0 тогда
		НоваяЗапись = РегистрыСведений.История.СоздатьМенеджерЗаписи();
		НоваяЗапись.Объект = Товар;			
		НоваяЗапись.Реквизит = "НомерГТД"; 
		НоваяЗапись.Значение = ГТД;
		НоваяЗапись.Период = НачалоДня(ТекущаяДата())-10;	
		НоваяЗапись.Документ = ДокС;
		НоваяЗапись.Записать(); 
		
	КонецЕсли;
	
	
КонецПроцедуры

