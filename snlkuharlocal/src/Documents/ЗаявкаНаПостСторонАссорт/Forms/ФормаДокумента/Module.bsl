	ПрайсРозн.ТипЦен = ПрмСсыл.СкладПолучатель.Подразделение.РозничныйТипЦен;
	ПрайсРозн.Дата = Объект.ДатаПоставки;
	ПрайсРозн.Дата2 = НачалоДня(КонецГода(КонецГода(ПрайсРозн.Дата) + 100));
	УстановитьНомерДокументаКлиентСервер(ПрайсРозн);
	ПрайсРозн.Записать();
	Для Каждого ТСтр Из Объект.Товары Цикл
		Если ТСтр.ТоварНайден ИЛИ ТСтр.ТоварСоздан Тогда
			МенЗап = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			МенЗап.Номенклатура = ТСтр.ХарактеристикаНоменклатуры;
			МенЗап.Период = Объект.ДатаПоставки;
			МенЗап.Прайс = ПрайсРозн.Ссылка;
			МенЗап.ТипЦен = ПрайсРозн.ТипЦен;
			МенЗап.Модель = ТСтр.Номенклатура;
			МенЗап.Цена = ТСтр.Цена;
			МенЗап.Записать();
			
		КонецЕсли;	
	КонецЦикла;
	
	
	//декларации, гтд
	
	Для Каждого ТСтр Из Объект.Товары Цикл
		Если ЗначениеЗаполнено(ТСтр.ХарактеристикаНоменклатуры) Тогда
			тНоменклатура = ТСтр.ХарактеристикаНоменклатуры;
			тМодель = ТСтр.Номенклатура;
			тСтранаПроисхождения = Справочники.КлассификаторСтранМира.НайтиПоНаименованию(ТСтр.СтранаПроисхождения);
			ТДанныеСертификата = ТСтр.ДанныеСертификата;
			тНомерСертификата = СокрЛП(СтрЗаменить(ВыделитьЧасть(ТДанныеСертификата, "Номер сертификата ЕАС:", ";"), "ЕАЭС", ""));
			тДатаДекларации = ПолучитьДатуИзСтр(СокрЛП(ВыделитьЧасть(ТДанныеСертификата, "Дата окончания сертификата ЕАС:", ";")));
			тОрган = СокрЛП(ВыделитьЧасть(ТДанныеСертификата, "Серцифицирующий орган:", ";"));
			тПроизводитель = ТСтр.Производитель;
			тИзготовитель = СокрЛП(ВыделитьЧасть(тПроизводитель, "Производитель:", ";")) + ", " + СокрЛП(ВыделитьЧасть(тПроизводитель, "Адрес производителя:", ";"));
			тОрган = СокрЛП(ВыделитьЧасть(ТДанныеСертификата, "Серцифицирующий орган:", ";"));
			тИмпортер = ПолучитьИмп(ТСтр.Импортер);
			тФилиал = СокрЛП(ВыделитьЧасть(ТДанныеСертификата, "Филиал:", ";"));
			//Номер сертификата ЕАС:RU C-IT.AB71.B.24669;Дата окончания сертификата ЕАС:31.12.25;Филиал:;Адрес Филиала:;Серцифицирующий орган:ООО "ОптимаТест"
			//
			//Номер сертификата ЕАС:ЕАЭС RU C-IT.BE02.B.01570/19;Дата окончания сертификата ЕАС:27.10.2025;Филиал:;Адрес Филиала:;Серцифицирующий орган:ООО "Глобальное Соответствие"
			//
			//Номер сертификата ЕАС:ЕАЭС RU C-IT.BE02.B.01570/19;Дата окончания сертификата ЕАС:27.10.2025;Филиал:;Адрес Филиала:;Серцифицирующий орган:ООО "Глобальное Соответствие"
			//Импортёр:ООО "Миа";ИНН импортёра:7723416980;КПП импортёра:772301001
			//
			//Производитель:I.T. ITAL TESSILE S.R.L.;Адрес производителя:Италия,Via Gordoni,31 Milano
			Попытка
				СтрБр = Объект.Брэнды.Получить(0);
				Если СтрБр.Брэнд.ВидБренда = Перечисления.ВидБренда.Агентский Тогда
					Агентский = Истина;
				Иначе
					Агентский = Ложь;
				КонецЕсли;
				тДекл = НайтиУстановитьДекларацию(тНомерСертификата, тДатаДекларации, тНоменклатура, тМодель, тФилиал, тИзготовитель, тОрган, тИмпортер, тСтранаПроисхождения, Агентский);
				//ПровГТДЗапИстор(ТСтр.НомерГТД, тСтранаПроисхождения, тИмпортер, тДекл, тНоменклатура, ПрмСсыл);
			Исключение
			КонецПопытки;
		КонецЕсли;	
	КонецЦикла;
	Объект.ПНК = ПрмСсыл;
	Объект.Прайс = ПрайсРозн.Ссылка;
	Объект.Состояние = Перечисления.СостоянияЗаявкиНаСторонПост.Выполнена;
КонецПроцедуры


