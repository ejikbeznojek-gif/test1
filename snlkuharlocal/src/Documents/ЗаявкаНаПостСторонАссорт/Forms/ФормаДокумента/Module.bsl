&НаКлиенте 
Процедура Отказ_Окончание(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	Если НЕ ЗначениеЗаполнено(РезультатЗакрытия) Тогда
		Объект.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияЗаявкиНаСторонПост.КСогласованию");
		// ничего не выбрали
		//ЭтаФорма.Элементы.ТоварыУстановитьПродавца.Пометка = Ложь;
		//Возврат;
		Элементы.ФормаОбработать.Доступность = МожноОбработать;
		Элементы.Группа5.ТекущаяСтраница = ?(МожноОбработать, Элементы.Группа8, Элементы.Группа6);
		Элементы.ФормаФормирДок.Доступность = МожноОбработать;
		Элементы.Статус.Картинка = ?(Объект.ИменаКолонок.Количество() = 0, БиблиотекаКартинок.ОформлениеКвадратыПустые, ?(МожноОбработать, БиблиотекаКартинок.ОформлениеКругЗелeный, БиблиотекаКартинок.ОформлениеКругКрасный));
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		ЭтаФорма.Записать();
		ЭтаФорма.ОбновитьОтображениеДанных();
	Иначе
		Объект.Комментарий = Объект.Комментарий + " отказ от согласования - " + РезультатЗакрытия + "  - дальнейшая обработка невозможна";
		МожноОбработать = Ложь;
		Элементы.ФормаЗагрузитьИзФайла.Доступность = МожноОбработать;
		Элементы.ФормаОбработать.Доступность = МожноОбработать;
		Элементы.Группа5.ТекущаяСтраница = ?(МожноОбработать, Элементы.Группа8, Элементы.Группа6);
		Элементы.ФормаФормирДок.Доступность = МожноОбработать;
		Элементы.Статус.Картинка = ?(Объект.ИменаКолонок.Количество() = 0, БиблиотекаКартинок.ОформлениеКвадратыПустые, ?(МожноОбработать, БиблиотекаКартинок.ОформлениеКругЗелeный, БиблиотекаКартинок.ОформлениеКругКрасный));
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		ЭтаФорма.Записать();
		ЭтаФорма.ОбновитьОтображениеДанных();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПровПарсСостНаСервере(СтрНом)
	// Вставить содержимое обработчика.
	СтрСост = ВыделитьЧасть(СтрНом, "Состав:", ";"); 
	сообщить(СтрСост);
	СтрукСост = ПарситСостав(СтрСост);
	Для Каждого ТЭл Из СтрукСост Цикл
		Попытка
			//НовС = МодО.СоставНоменклатуры.Добавить(); 
			Сообщить(ТЭл.Мат + " % " + строка(ТЭл.Проц));
			МатериалСостав = Справочники.МатериалыСостав.НайтиПоНаименованию(СокрЛП(ТЭл.Мат));
			Сообщить("МатериалСостав" + строка(МатериалСостав));
			Процент = ТЭл.Проц;
			Прот = Прот + "Добавление состава материал " + СокрЛП(МатериалСостав) + " % " + СокрЛП(Процент) + Символы.ПС;
		Исключение
			Прот = Прот + "Ошибка при добавлении состава материал " + ОписаниеОшибки() + Символы.ПС;
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

