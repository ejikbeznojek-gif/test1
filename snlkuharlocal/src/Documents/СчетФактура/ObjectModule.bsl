Процедура СообщитьКритическиеОшибки(массивОшибок, ТемаПисьма) Экспорт
	
	Если массивОшибок.количество()=0 ТОгда
		возврат;
	КонецЕсли;	
	
	
	
	Профиль= Новый ИнтернетПочтовыйПрофиль;

	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);		 
	// Кухарь А.Ю.  08.09.2022 конец

	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	
	//------------------------------------------------
	// сообщение о критических ошибках
	//------------------------------------------------
	сообщениеКрит=новый интернетПочтовоеСообщение;
	СообщениеКрит.Получатели.Добавить("nechaeva@collant.ru");
	СообщениеКрит.Получатели.Добавить("pro@collant.ru");

	сообщениеКрит.Отправитель="ecode@collant.ru";
	СообщениеКрит.Тема=""+ТемаПисьма+" Критические ошибки!";
	Строка="Добрый день!!!"+Символ(13);
	НомСтр=1;
	Если массивОшибок.Количество()>0 Тогда
		Для рр=0 по массивОшибок.Количество()-1 Цикл
			Строка=Строка+Символ(13)+НомСтр+". "+массивОшибок[рр];
			Строка=Строка+Символ(13);
			НомСтр=НомСтр+1;
		КонецЦикла;
	КонецЕсли;
	
	Строка=Строка+Символ(13)+"________________________________________________________________";
	//-----------------------------------------
	СообщениеКрит.Тексты.Добавить(Строка);
	
	Почта= Новый ИнтернетПочта;
	//попытка
		Почта.Подключиться(Профиль);
		почта.Послать(СообщениеКрит);
		Почта.Отключиться();
	//исключение
	//	ЗаписатьВЛог("екод","Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки(),"Информация");
	//	
	//конецПопытки;
	//
КонецПроцедуры

Функция ПроверкаОтправленныхСФкРНК(РНК,СФ)

	 Проверка = ложь;

	 	
		Запрос = Новый Запрос;
		запрос.Текст=	"ВЫБРАТЬ
		|	СчетФактураВыданный.Номер КАК Номер,
		|	СчетФактураВыданный.Дата КАК Дата,
		|	СчетФактураВыданный.Контрагент КАК Контрагент,
		|	СчетФактураВыданный.Ссылка КАК Документ,
		|	ЛОЖЬ КАК Пометка,
		|	СчетФактураНакладные.Накладная.Номер КАК НомерРНК
		|ИЗ
		|	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактура КАК СчетФактураВыданный
		|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|				ЗначенияСвойствОбъектов.Объект.Номер КАК ОбъектНомер,
		|				ЗначенияСвойствОбъектов.Свойство КАК Свойство,
		|				ЗначенияСвойствОбъектов.Значение КАК Значение,
		|				ЗначенияСвойствОбъектов.Объект КАК Объект
		|			ИЗ
		|				РегистрСведений.ЗначенияСвойствОбъектовУПД КАК ЗначенияСвойствОбъектов
		|			ГДЕ
		|				ЗначенияСвойствОбъектов.Свойство = &ТекСвойство) КАК ВложенныйЗапрос
		|			ПО СчетФактураВыданный.Ссылка = ВложенныйЗапрос.Объект
		|		ПО СчетФактураНакладные.Ссылка = СчетФактураВыданный.Ссылка
		|ГДЕ
		|	 НЕ ВложенныйЗапрос.Значение ЕСТЬ NULL
		|	И СчетФактураВыданный.Ссылка = (&Докумен)
		|	И СчетФактураНакладные.Накладная = (&РНК)";
			
	   
		Запрос.УстановитьПараметр("РНК",РНК);
		Запрос.УстановитьПараметр("Докумен",СФ);
		Запрос.УстановитьПараметр("ТекСвойство",планыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("EDIНомер").Ссылка);
		 
	 рез = запрос.Выполнить().Выбрать();
	 
	 Если Рез.следующий() >0 ТОгда
		//сообщить("По документу " +РНК+ " уже есть отправленная СФ "+Рез.Документ );
		//КритичОшибки.добавить("По документу " +РНК+ " уже есть отправленная СФ "+Рез.Документ );
		 Проверка = истина;
	 КонецЕсли;
	 
	
	
	 возврат Проверка;
	
КонецФункции
