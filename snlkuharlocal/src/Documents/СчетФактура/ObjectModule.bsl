Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	Если НЕ ОбменДанными.Загрузка Тогда
		Для Каждого СтрокаНакладной Из Накладные Цикл
			Накладная=СтрокаНакладной.Накладная;
			Если Накладная<>Неопределено И НЕ Накладная.Пустая() И Накладная.Метаданные().Имя="Чек" И ЗначениеЗаполнено(Накладная.Номер) Тогда
				Отказ=Не УстановитьПометкуЧека(Накладная,Истина);				
			КонецЕсли; 				
		КонецЦикла; 				
	КонецЕсли;	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НЕ ОбменДанными.Загрузка Тогда
		Для Каждого СтрокаНакладной Из Накладные Цикл
			Накладная=СтрокаНакладной.Накладная;
			Если Накладная<>Неопределено И НЕ Накладная.Пустая() И Накладная.Метаданные().Имя="Чек" Тогда
				Отказ=Не УстановитьПометкуЧека(Накладная,Ложь);
			КонецЕсли; 				
		КонецЦикла; 				
	КонецЕсли;
	//крохин начало
	Для Каждого СтрокаНакладной Из Накладные Цикл
		Накладная=СтрокаНакладной.Накладная;
		Если Накладная<>Неопределено И ЕстьРеквизитДокумента("СостояниеДокументов",Накладная.Метаданные()) Тогда
			НакладнаяОбъект = Накладная.ПолучитьОбъект();
			//крохин начало 15.04.2013
			//НакладнаяОбъект.СостояниеДокументов = Перечисления.СостояниеДокументов.НеВыписаны;
			//НакладнаяОбъект.Записать(РежимЗаписиДокумента.Запись);
			НакладнаяОбъект.УстановитьСостояниеДокументов(Перечисления.СостояниеДокументов.НеВыписаны,Неопределено,Истина);
			//крохин конец 15.04.2013
		КонецЕсли ;
	КонецЦикла; 	
	//крохин конец	
КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	
	ВидОснования = Основание.Метаданные().Имя;
	
	ИБ			 = Основание.ИБ; 
	
	Если ВидОснования = "РасходнаяНакладная" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;
	ИначеЕсли ВидОснования = "Чек" Тогда	

		Контрагент   = Основание.Контрагент;
			
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
	     //крохин начало
	     //проверка для чеков
		 Если Основание.ПометкаУдаления И НЕ РольДоступна("Администратор") Тогда
			 сообщить("СФ на основании помеченного на удаление чека ввести невозможно");
		 КонецЕсли;	 
	     //крохин конец

			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
			СтрокаТЧ.НомерЧека=Основание.Номер;	
		КонецЕсли;
	ИначеЕсли ВидОснования="Перемещение" Тогда	
		Контрагент   = ПолучитьКонтрагентаСклада(Основание.СкладПолучатель);
			
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;
	ИначеЕсли ВидОснования = "ПродажаИМ" Тогда				
		Контрагент   = Основание.Контрагент;
		Договор 	 = Основание.Договор;		
		
		Валюта		 = Основание.Валюта;	
		Курс		 = Основание.Курс;
		
		Организация	 = ?(Основание.Склад.Организация.Пустая(),Основание.Организация,Основание.Склад.Организация);		
		Склад		 = Основание.Склад;		
		
		СтрокаТЧ=Накладные.Найти(Основание,"Накладная");
		Если СтрокаТЧ=Неопределено Тогда
			СтрокаТЧ=Накладные.Добавить();
			СтрокаТЧ.Накладная=Основание;			
		КонецЕсли;
	
	КонецЕсли;	
	
	Если ВидОснования = "РасходнаяНакладная" И ЗначениеЗаполнено(Основание.ДатаОтгрузки) И НачалоДня(Основание.ДатаОтгрузки)>НачалоДня(Основание.Дата) Тогда
		Дата=Основание.ДатаОтгрузки;		
	Иначе
		СдвигДаты=ПолучитьЗначениеПоУмолчанию("СдвигатьДатуСФ");
		Если СдвигДаты<>Неопределено Тогда
			Дата=Основание.Дата+СдвигДаты*24*60*60;		
		КонецЕсли;
	КонецЕсли;	
	
	Для Каждого СтрокаТЧ Из Накладные Цикл
		РасчетСтроки(СтрокаТЧ);	
	КонецЦикла; 
КонецПроцедуры
