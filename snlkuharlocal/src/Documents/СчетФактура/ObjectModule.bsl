Функция ПолучитьКонтрагентаСклада(Склад)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	ЗначенияСвойствОбъектов.Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Объект
	|	И ЗначенияСвойствОбъектов.Свойство = &Свойство";
	
	Запрос.УстановитьПараметр("Объект",Склад);
	Запрос.УстановитьПараметр("Свойство",ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Контрагент получатель"));
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Значение;
	КонецЦикла; 
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
КонецФункции //ПолучитьКонтрагентаСклада(Склад)

Процедура РасчетСтроки(СтрокаТЧ) Экспорт
	СтрокаТЧ.СуммаБезНДС18		=0;
	СтрокаТЧ.НДС18				=0;
	СтрокаТЧ.СуммаБезНДС10		=0;
	СтрокаТЧ.НДС10				=0;
	СтрокаТЧ.СуммаСовсемБезНДС	=0;
    
	Если СтрокаТЧ.Накладная<>Неопределено И НЕ СтрокаТЧ.Накладная.Пустая() Тогда
		ТабСтавок=СтрокаТЧ.Накладная.Товары.Выгрузить();
		ТабСтавок.Свернуть("СтавкаНДС","Всего,НДС");	
		
		СтрокаТЧ.Всего=ТабСтавок.Итог("Всего");		
		
		Для Каждого СтрокаСтавок Из ТабСтавок Цикл
			//крохин начало 08.01.2019
			//Если СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС18 Тогда
			Если СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС18 ИЛИ СтрокаСтавок.СтавкаНДС	= Перечисления.СтавкиНДС.НДС20 Тогда
				//крохин конец 08.01.2019
				СтрокаТЧ.СуммаБезНДС18	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				СтрокаТЧ.НДС18			= СтрокаСтавок.НДС;			
			ИначеЕсли СтрокаСтавок.СтавкаНДС=Перечисления.СтавкиНДС.НДС10 Тогда
				СтрокаТЧ.СуммаБезНДС10	= СтрокаСтавок.Всего-СтрокаСтавок.НДС;								
				СтрокаТЧ.НДС10			= СтрокаСтавок.НДС;			
				//крохин начало 15.02.2019	
		//ИначеЕсли СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.БезНДС Тогда
		//для иностранцев
		ИначеЕсли СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.БезНДС ИЛИ СтрокаСтавок.СтавкаНДС= Перечисления.СтавкиНДС.НДС0 Тогда
		//крохин конец 15.02.2019
				СтрокаТЧ.СуммаСовсемБезНДС	= СтрокаСтавок.Всего;			
			КонецЕсли;			
		КонецЦикла; 
	КонецЕсли;
КонецПроцедуры

Функция КонтрольДублейСФ(СФОбъект,Отказ,Дубли=Неопределено) Экспорт	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка КАК СФ,
	|	Накладная
	|ИЗ
	|	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
	|ГДЕ
	|	Накладная В(&Накладные)
	|	И НЕ Ссылка.ПометкаУдаления
	|	И Ссылка <> &Ссылка
	|	И Ссылка.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Накладные",СФОбъект.Накладные.ВыгрузитьКолонку("Накладная"));
	Запрос.УстановитьПараметр("Ссылка",СФОбъект.Ссылка);
	Запрос.УстановитьПараметр("Организация",СФОбъект.Организация);
	
	ЕстьДубли=Ложь;	
	
	Дубли=Новый Массив;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Сообщить("На накладную: "+Выборка.Накладная+", по организации: """+СФОбъект.Организация+"""
		|	уже выписана СФ: "+Выборка.СФ,СтатусСообщения.Важное);		
		ЕстьДубли=Истина;	
		
		Дубли.Добавить(Выборка.СФ);
	КонецЦикла;
	
	Если НЕ Отказ И ЕстьДубли Тогда
		Отказ=Истина;
	КонецЕсли;	
	
	Возврат НЕ ЕстьДубли;
КонецФункции //КонтрольДублейСФ(СФОбъект,Отказ)

Функция УстановитьПометкуЧека(ЧекСсылка,Пометка)
	ЧекОбъект=ЧекСсылка.ПолучитьОбъект();
	ЧекОбъект.СДокументами=Пометка;
	
	Попытка	
		ЧекОбъект.Заблокировать();			
	Исключение		
		СообщитьОбОшибке("Не удалось заблокировать чек ! Возможно открыта форма чека !");
		ЧекОбъект=Неопределено;		
		Возврат Ложь;
	КонецПопытки;	
	
	ЧекОбъект.Записать(РежимЗаписиДокумента.Запись);
	
	Возврат Истина;
КонецФункции

//СОБЫТИЯ ОБЪЕКТА
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	// Шворобей ВЮ 12.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1395
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзНакладные", Накладные.Выгрузить());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	тзНакладные.Накладная КАК Накладная
	|ПОМЕСТИТЬ тзНакладные
	|ИЗ
	|	&тзНакладные КАК тзНакладные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзНакладные.Накладная КАК Документ.РасходнаяНакладная) КАК Накладная
	|ИЗ
	|	тзНакладные КАК тзНакладные
	|ГДЕ
	|	ВЫРАЗИТЬ(тзНакладные.Накладная КАК Документ.РасходнаяНакладная).КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Комиссия)";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Количество() > 0 Тогда
		Отказ = Истина;
	КонецЕсли;
	// Шворобей ВЮ 12.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1395
	
	ЕстьИзменения	= Модифицированность();
	НужноВыгружать = НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	
	Если НЕ ОбменДанными.Загрузка Тогда
		
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			Отказ=НЕ ПолучитьПолномочиеПользователя("ВыпискаСФвОфисе");
			
			// Кухарь А.Ю. 08.04.2022 начало
			// Чтобы не создавали СФ по накладным с реальных складов других подразделений
			если не Отказ и ЭтоНовый() тогда
				если ЗначениеЗаполнено(Склад.КодФизическогоУзла) и Склад.КодФизическогоУзла<>ПараметрыСеанса.ЭтотУзел.Код тогда
					Отказ=Истина;
				КонецЕсли;
			КонецЕсли;
			// Кухарь А.Ю. 08.04.2022 конец
			
			Если Отказ Тогда
				Сообщить("Недостаточно полномочий для оформления СФ в офисной базе !",СтатусСообщения.Важное);			
			КонецЕсли;		
		КонецЕсли;
		
		//крохин начало 16.02.2012
		//запретим редактировать филиальные СФ в офисе и офисные - в филиале
		Если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если Склад.ТипСклада = Перечисления.ТипСклада.Филиал ИЛИ Склад.ТипСклада = Перечисления.ТипСклада.ОптовыйТЦ Тогда
				#Если КЛИЕНТ Тогда
					сообщить("СФ по складу "+Склад + " редактируются только в соответствующем подразделении");
				#КОНЕЦЕСЛИ	
				Отказ = Истина;	
				
			КонецЕсли;
		ИначеЕсли ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			//крохин начало 11.04.2013
			//СФ можно редактировать только свои
			//Если Склад.ТипСклада <> Перечисления.ТипСклада.Филиал И Склад.ТипСклада <> Перечисления.ТипСклада.ОптовыйТЦ Тогда
			Если Склад.Подразделение <> ПараметрыСеанса.ЭтотУзел.Подразделение Тогда
				//крохин конец 11.04.2013
				#Если КЛИЕНТ Тогда
					сообщить("СФ по складу "+Склад + " редактируются только в офисе");
				#КОНЕЦЕСЛИ	
				Отказ = Истина;	
			КонецЕсли;
		КонецЕсли;
		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		КонтрольДублейСФ(ЭтотОбъект,Отказ);		
		
		Если Отказ Тогда Возврат КонецЕсли;
		
	КонецЕсли;
	
	// Нечаева, 04,02,26 ,  проблемы, с отправкой писем для ПРО, массовые, не можем отследить. посмотрим по логам.
	// 55140 Отправка Уведомлений об удалении СФ  ELP-8721
	Если ЭтотОбъект.ПометкаУдаления = истина   ТОгда    
		попытка
			ЗаписатьВЛог("ОтправкаПисемПРО","1. "+ЭтотОбъект.Ссылка+" помечен на удаление "+ПланыОбмена.Основной.ЭтотУзел()+ПараметрыСеанса.Пользователь,,,,);
		исключение
		КонецПопытки;
	КонецЕсли;	

	
	Если ЕстьИзменения Тогда		
		СуммаБезНДС18		=Накладные.Итог("СуммаБезНДС18");
		НДС18				=Накладные.Итог("НДС18");
		СуммаБезНДС10		=Накладные.Итог("СуммаБезНДС10");
		НДС10				=Накладные.Итог("НДС10");
		СуммаСовсемБезНДС	=Накладные.Итог("СуммаСовсемБезНДС");
		Всего				=СуммаБезНДС18+НДС18+СуммаБезНДС10+НДС10+СуммаСовсемБезНДС;
		
		Для Каждого СтрокаТЧ Из Накладные Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.Накладная.Номер) Тогда
				Если СтрокаТЧ.Накладная.Метаданные().Имя="Перемещение" Тогда
					Контрагент=ПолучитьКонтрагентаСклада(СтрокаТЧ.Накладная.СкладПолучатель);						
				Иначе
					Контрагент=СтрокаТЧ.Накладная.Контрагент;
				КонецЕсли;		
				
				Прервать;			
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;	
	
	//нечаева 29,05,23++
	
	//нечаева 27,06,24++
		
	// Нечаева, 04,02,26 ,  проблемы, с отправкой писем для ПРО, массовые, не можем отследить. посмотрим по логам.
	// 55140 Отправка Уведомлений об удалении СФ  ELP-8721
	//Если ЭтотОбъект.ПометкаУдаления = истина   ТОгда    
	//	попытка
	//		ЗаписатьВЛог("ОтправкаПисемПРО","2. "+ЭтотОбъект.Ссылка+" помечен на удаление "+ПланыОбмена.Основной.ЭтотУзел()+ПараметрыСеанса.Пользователь,,,,);
	//	исключение
	//	КонецПопытки;
	//КонецЕсли;	
	
	
	// Нечаева 02,03,26 +++ пока уберу проверку, не все письма приходят, возможно какой-то глюк 1с.
	// Отправка Уведомлений об удалении СФ  ELP-8721

	
	//СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	//ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом
	
	Если  (ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL")) 
		Тогда        
		//нечаева 27,06,24--
		
		Если ЭтотОбъект.ПометкаУдаления = истина   ТОгда
			
			КрОши= новый Массив;
			
			РНК = ЭтотОбъект.Накладные[0].накладная.ссылка;
			Проверка = ПроверкаОтправленныхСФкРНК(РНК,ЭтотОбъект.Ссылка);
		  // Нечаева 02,03,26 +++
		  //55140 Отправка Уведомлений об удалении СФ  ELP-8721

			ЗаписатьВЛог("ОтправкаПисемПРО","2. "+ЭтотОбъект.Ссылка+" помечен на удаление, есть отправленный УПД"+ПланыОбмена.Основной.ЭтотУзел()+ПараметрыСеанса.Пользователь+ проверка,,,,);

			Если Проверка ТОгда
				КрОши.Добавить("Помечена на удаление СФ, по которой уже есть отправленный УПД.  "+ЭтотОбъект+ " - "+РНК.Контрагент+ " - "+РНК);
				СообщитьКритическиеОшибки(КрОши,"Ошибка отправки УПД");   
				попытка
					ЗаписатьВЛог("ОтправкаПисемПРО","3. "+ЭтотОбъект.Ссылка+" помечен на удаление, есть отправленный УПД"+ПланыОбмена.Основной.ЭтотУзел()+ПараметрыСеанса.Пользователь,,,,);
				исключение
				КонецПопытки;
			конецЕсли;	
		КонецЕсли;		
	КонецЕсли;

	//нечаева 29,05,23--
	
	
КонецПроцедуры


