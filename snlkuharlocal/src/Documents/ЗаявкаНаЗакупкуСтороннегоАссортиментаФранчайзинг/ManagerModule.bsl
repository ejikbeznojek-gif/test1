Функция ПоискТиповАртикуловПоНоменклатуре(Номенклатура) Экспорт
	
	МассивТипов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.Родитель КАК Родитель
	|ПОМЕСТИТЬ Родители
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АртикулыКонтрагентов.Владелец КАК Владелец,
	|	АртикулыКонтрагентов.ТипАртикула КАК ТипАртикулаКонтрагента,
	|	АртикулыКонтрагентов.Наименование КАК КодПоставщика
	|ИЗ
	|	Справочник.АртикулыКонтрагентов КАК АртикулыКонтрагентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Родители КАК Родители
	|		ПО АртикулыКонтрагентов.Владелец = Родители.Родитель";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.ТипАртикулаКонтрагента) Тогда
			МассивТипов.Добавить(Выборка.ТипАртикулаКонтрагента);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивТипов;
	
КонецФункции

