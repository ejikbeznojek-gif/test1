КонецФункции

Функция СоздатьГруппуНоменклатуры(ДокОбъект, ТекущаяСтрока, ВПапкеФранчайзинга = Истина) Экспорт
	
	Модель = Справочники.Номенклатура.СоздатьГруппу();
	Модель.Наименование = ТекущаяСтрока.НаименованиеНоменклатуры;
	Модель.РусскоеНаименование = ТекущаяСтрока.НаименованиеНоменклатуры;
	Модель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар;
	
	///////////////////////////////////////////////////////////////////////////////////
	Если ВПапкеФранчайзинга Тогда
		РодительМодели = ПоискМоделиПоКодуПроизводителя_ТипуАртикулаКонтрагента(ДокОбъект, ТекущаяСтрока, "КорневаяПапка");
		Если РодительМодели = Неопределено Тогда
			ТекущаяСтрока.ЗамечанияКСтроке = "Не найдена Корневая папка";
			Возврат Неопределено;
		Иначе
			Модель.Родитель = РодительМодели;
		КонецЕсли;
	КонецЕсли;
	///////////////////////////////////////////////////////////////////////////////////
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.СтавкаНДС) Тогда
		Модель.СтавкаНДС = ТекущаяСтрока.СтавкаНДС;
	ИначеЕсли НЕ ЗначениеЗаполнено(ТекущаяСтрока.СтавкаНДС) И ЗначениеЗаполнено(ТекущаяСтрока.НаименованиеСтавкиНДС) Тогда
		Модель.СтавкаНДС = ПоискСтавкиНДСПоНаименованию(ТекущаяСтрока.НаименованиеСтавкиНДС);
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////////////////////////
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.ВидНоменклатуры) Тогда
		Модель.ФР_ВидНоменклатуры = ТекущаяСтрока.ВидНоменклатуры;
	ИначеЕсли НЕ ЗначениеЗаполнено(ТекущаяСтрока.ВидНоменклатуры) И ЗначениеЗаполнено(ТекущаяСтрока.НаименованиеВидаНоменклатуры) Тогда
		ВидНоменклатуры = ПоискВидаНоменклатуры(ТекущаяСтрока.НаименованиеВидаНоменклатуры);
		Если ВидНоменклатуры.Пустая() Тогда
			ВидНоменклатуры = СоздатьВидНоменклатуры(ТекущаяСтрока.НаименованиеВидаНоменклатуры);
		КонецЕсли;
		Если ВидНоменклатуры <> Неопределено Тогда
			Модель.ФР_ВидНоменклатуры = ВидНоменклатуры;
		КонецЕсли;
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////////////////////////
	
	Если ЗначениеЗаполнено(ДокОбъект.Бренд) Тогда
		Модель.ФР_Бренд = ДокОбъект.Бренд;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокОбъект.Линия) Тогда
		Модель.ФР_ЛинияНоменклатуры = ДокОбъект.Линия;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокОбъект.Коллекция) Тогда
		Модель.ФР_Коллекция = ДокОбъект.Коллекция;
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////////////////////////
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.СтранаПроизводитель) Тогда
		Модель.Страна = ТекущаяСтрока.СтранаПроизводитель;
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ТекущаяСтрока.Состав) Тогда
		МассивПодстрок = РазложитьСтрокуВМассивПодстрок(ТекущаяСтрока.Состав, " ");
		Для Каждого Элемент ИЗ МассивПодстрок Цикл
			// сумма % из состава не превышает 100
			Если Найти(Элемент, "%") > 0 Тогда
				СтруктураВозврата = ЗаполнениеДокументов.ЦифрыСимволыЧисла(Элемент);
				Попытка
					Процент = Число(СтруктураВозврата.НовоеЗначение);
				Исключение
					Процент = 0;
				КонецПопытки;
			Иначе
				// материалы из текста есть в справочнике материалов
				Материал = Справочники.МатериалыСостав.НайтиПоНаименованию(Элемент, Ложь);
			КонецЕсли;
		КонецЦикла;
		Если НЕ Материал.Пустая() И Процент <> 0 Тогда
			НоваяСтрока = Модель.СоставНоменклатуры.Добавить();
			НоваяСтрока.МатериалСостав = Материал;
			НоваяСтрока.Процент = Процент;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		Модель.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Модель.Ссылка;
	
КонецФункции

// нужно создать элемент справочника АртикулыКонтрагентов.
// Тип артикула из подразделения, Наименование = КодПроизводителя, владелец – только что созданная группа
Функция СоздатьАртикулКонтрагента(ДокОбъект, ТекущаяСтрока) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Модель) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	АртикулКонтрагента = Справочники.АртикулыКонтрагентов.СоздатьЭлемент();
	АртикулКонтрагента.Владелец = ТекущаяСтрока.Модель;
	АртикулКонтрагента.Наименование = СокрЛП(ТекущаяСтрока.КодПроизводителя);
	АртикулКонтрагента.ТипАртикула = ДокОбъект.СкладПолучатель.Подразделение.ТипАртикулаКонтрагента;
	
	Попытка
		АртикулКонтрагента.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат АртикулКонтрагента.Ссылка;
	
КонецФункции

Функция СоздатьВидНоменклатуры(Знач НаименованиеВидаНоменклатуры) Экспорт
	
	ВидНоменклатуры = Справочники.ФР_ВидыНоменклатуры.СоздатьЭлемент();
	ВидНоменклатуры.Наименование = СокрЛП(НаименованиеВидаНоменклатуры);
	ВидНоменклатуры.ТипНоменклатуры = Перечисления.ВидыНоменклаутры.Товар;
	Попытка
		ВидНоменклатуры.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ВидНоменклатуры.Ссылка;
	
КонецФункции

Функция СоздатьЭлементНоменклатуры(ТекущаяСтрока) Экспорт
	
	Номенклатура = Справочники.Номенклатура.СоздатьЭлемент();
	Номенклатура.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар;
	
	// Наименование = НаименованиеБрендаФР + « » +Наименование модели + « »+ наименование цвета + « »  наименование размера
	Номенклатура.Наименование = СокрЛП(ТекущаяСтрока.НаименованиеБрендаФР) + " " + СокрЛП(ТекущаяСтрока.НаименованиеНоменклатуры) + " " +
		СокрЛП(ТекущаяСтрока.НаименованиеЦвета) + " " + СокрЛП(ТекущаяСтрока.НаименованиеРазмера);
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Модель) Тогда
		Номенклатура.Родитель = ТекущаяСтрока.Модель;
		Номенклатура.ПервичнаяГруппа = ТекущаяСтрока.Модель;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Цвет) Тогда
		Номенклатура.Цвет = ТекущаяСтрока.Цвет;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Размер) Тогда
		Номенклатура.Размер = ТекущаяСтрока.Размер;	
	КонецЕсли;
	
	Попытка
		Номенклатура.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Номенклатура.Ссылка;
	
КонецФункции

Функция СоздатьЭлементШтрихкодов(ТекущаяСтрока) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Номенклатура) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ШтрихКод = Справочники.ШтрихКоды.СоздатьЭлемент();
	
	ШтрихКод.УстановитьНовыйКод(ПолучитьПрефиксНомеров(ШтрихКод));
	
	ШтрихКод.Владелец = ТекущаяСтрока.Номенклатура;
	ШтрихКод.ВидШК = Перечисления.ВидыШК.Основной;
	ШтрихКод.ТипШК = Перечисления.ТипыШтрихКодов.Штука;
	
	Если ТекущаяСтрока.ТребуетсяПереклейка Тогда // нужно сгенерировать по правилам
		// Получаем максимальный номер ШК на 60
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПОДСТРОКА(ШтрихКоды.Наименование, 3, 10) КАК НомерШК
		|ИЗ
		|	Справочник.ШтрихКоды КАК ШтрихКоды
		|ГДЕ
		|	ПОДСТРОКА(ШтрихКоды.Наименование, 1, 1) = ""6""
		|	И ПОДСТРОКА(ШтрихКоды.Наименование, 3, 4) = ""0000""
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПОДСТРОКА(ШтрихКоды.Наименование, 3, 10) УБЫВ";
		
		УстановитьПривилегированныйРежим(Истина);
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);
	
		Если Выборка.Следующий() Тогда
			ТекущийШК = "600"+Формат(СокрЛП(Выборка.НомерШК),"ЧЦ=10; ЧРГ=; ЧВН=; ЧГ=0");
			СтруктураВозврата = ЗаполнениеДокументов.ЦифрыСимволыЧисла(СокрЛП(ТекущийШК));
			// Прибавляем единичку и получаем ШК
			Попытка
				ТекущийШК_Число = Число(СтруктураВозврата.НовоеЗначение) + 1;
				ШтрихКод.Наименование = Строка(ТекущийШК_Число);
			Исключение
				ШтрихКод.Наименование = СокрЛП(ТекущаяСтрока.ШтрихкодИзФайла);
			КонецПопытки;
		КонецЕсли;
	Иначе  // если в строке нет признака переклейки ШК, то наименование – это ШК из файла
		ШтрихКод.Наименование = СокрЛП(ТекущаяСтрока.ШтрихкодИзФайла);
	КонецЕсли;
	
	Если СтрДлина(ШтрихКод.Наименование) = 13 Тогда
		ШтрихКод.ФорматШК = Перечисления.ФорматыШК.EAN13;
	Иначе
		ШтрихКод.ФорматШК = Перечисления.ФорматыШК.ITF14;
	КонецЕсли;	
	
	Попытка
		ШтрихКод.ОбменДанными.Загрузка = Истина;
		ШтрихКод.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ШтрихКод.Ссылка;
	
КонецФункции

Функция СоздатьИмпортера(ТекущаяСтрока) Экспорт
	
	Если ПустаяСтрока(ТекущаяСтрока.ИмпортерНаименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Импортер = Справочники.Контрагенты.СоздатьЭлемент();
	Импортер.Наименование = ТекущаяСтрока.ИмпортерНаименование;
	
	Если Найти(ВРЕГ(ТекущаяСтрока.АдресИмпортера), "БЕЛАРУС") > 0 Тогда
		Импортер.ИННИностранногоКонтрагента = ТекущаяСтрока.ИННИмпортера;
		Импортер.ИНН = "00";
	Иначе
		Импортер.ИНН = ТекущаяСтрока.ИННИмпортера;
	КонецЕсли;
	
	Импортер.КПП = ТекущаяСтрока.КППИмпортера;
    Импортер.ПолноеНаименование = ТекущаяСтрока.ИмпортерНаименование;
	
    Импортер.Владелец = Справочники.ИБ.НайтиПоКоду("SSP");
    Импортер.Родитель = Справочники.Контрагенты.НайтиПоКоду("SSR-4946");
	
    Импортер.ЮридическийАдрес = СокрЛП(ТекущаяСтрока.АдресИмпортера);
    Импортер.ПочтовыйАдрес = СокрЛП(ТекущаяСтрока.АдресИмпортера);
	
	Попытка
		Импортер.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Импортер.Ссылка;
	
КонецФункции

Функция СоздатьЭлементГТД(ТекущаяСтрока) Экспорт
	
	Если ПустаяСтрока(ТекущаяСтрока.НомерГТД) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ГТД = Справочники.ГТД.СоздатьЭлемент();
    ГТД.Наименование = ТекущаяСтрока.НомерГТД;
	
    ГТД.Владелец = Справочники.ИБ.НайтиПоКоду("SSP");
    ГТД.Родитель = Справочники.ГТД.НайтиПоКоду("TZ2-188");
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Импортер) Тогда
	    ГТД.Импортер = ТекущаяСтрока.Импортер;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.СтранаПроизводитель) Тогда
		ГТД.СтранаПроисхождения = ТекущаяСтрока.СтранаПроизводитель;
	КонецЕсли;
	
	Попытка
		ГТД.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ГТД.Ссылка;
	
КонецФункции

Функция СоздатьЭлементДекларация(ТекущаяСтрока) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Модель) ИЛИ ПустаяСтрока(ТекущаяСтрока.НомерСертификатаЕАС) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Декларация = Справочники.Декларация.СоздатьЭлемент();
	Декларация.Наименование = СокрЛП(ТекущаяСтрока.НомерСертификатаЕАС);
	Декларация.Родитель = Справочники.Декларация.НайтиПоКоду("0009601");
	Декларация.ВидДокумента = Перечисления.ВидыДекларации.Сертификат;
	
    Декларация.Объект = ТекущаяСтрока.Модель;
    Декларация.ДатаНачала = Дата(2014,02,04);
	Если ЗначениеЗаполнено(ТекущаяСтрока.ДатаОкончанияСертификата) Тогда
    	Декларация.ДатаОкончания = ТекущаяСтрока.ДатаОкончанияСертификата;
	КонецЕсли;
                                               
	Если ЗначениеЗаполнено(ТекущаяСтрока.Импортер) Тогда
		Декларация.Организация = ТекущаяСтрока.Импортер;
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекущаяСтрока.Производитель) Тогда
    	Декларация.Изготовитель = СокрЛП(ТекущаяСтрока.Производитель);
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекущаяСтрока.СертифицирующийОрган) Тогда
    	Декларация.Орган = СокрЛП(ТекущаяСтрока.СертифицирующийОрган);
	КонецЕсли;
    Декларация.Сертификат = Перечисления.ОрганСертификации.ЕАС;
	
    Если ЗначениеЗаполнено(ТекущаяСтрока.ФилиалПроизводителя) Тогда
	    Декларация.Филиал = СокрЛП(ТекущаяСтрока.ФилиалПроизводителя);
    Иначе 
        Декларация.Филиал = СокрЛП(ТекущаяСтрока.АдресПроизводителя);
    КонецЕсли;
                
	Попытка
		Декларация.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Декларация.Ссылка;
	
КонецФункции

/////////////////// ЗАПИСЬ В РЕГИСТР СВЕДЕНИЙ ИСТОРИЯ ///////////////////////////////////
/// ИмяРеквизита = "НомерГТД"; "Декларация";  РегОбъект = Номенклатура;
Функция ЗаписатьВРегистрСведенийИстория(ДокОбъект, РегОбъект, Значение, ИмяРеквизита = "", Период = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", РегОбъект);
	Запрос.УстановитьПараметр("Значение", Значение);
	запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	История.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.История КАК История
	|ГДЕ
	|	История.Значение В(&Значение)
	|	И История.Объект = &Объект";
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() = 0 тогда
		НоваяЗапись = РегистрыСведений.История.СоздатьМенеджерЗаписи();
		НоваяЗапись.Объект = РегОбъект;                                 
		НоваяЗапись.Реквизит = ИмяРеквизита; 
		НоваяЗапись.Значение = Значение;
		НоваяЗапись.Период = ?(Период = Неопределено, НачалоДня(ТекущаяДата())-10, Период);          
		НоваяЗапись.Документ = ДокОбъект.Ссылка;
		НоваяЗапись.Записать();                                          
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции


