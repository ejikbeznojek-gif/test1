Функция НайтиВидБренда(Номенклатура) Экспорт
	
	///// 1.Ищем по реквизитам ////////////////////////////////////////////////////////
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА Номенклатура.ФР_Бренд.ВидБренда <> ЗНАЧЕНИЕ(Перечисление.ВидБренда.ПустаяСсылка)
	|			ТОГДА Номенклатура.ФР_Бренд.ВидБренда
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Номенклатура.Родитель.ФР_Бренд.ВидБренда <> ЗНАЧЕНИЕ(Перечисление.ВидБренда.ПустаяСсылка)
	|					ТОГДА Номенклатура.Родитель.ФР_Бренд.ВидБренда
	|				ИНАЧЕ ВЫБОР
	|						КОГДА Номенклатура.Родитель.Родитель.ФР_Бренд.ВидБренда <> ЗНАЧЕНИЕ(Перечисление.ВидБренда.ПустаяСсылка)
	|							ТОГДА Номенклатура.Родитель.Родитель.ФР_Бренд.ВидБренда
	|						ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидБренда.ПустаяСсылка)
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ВидБренда
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Номенклатура
	|	И НЕ Номенклатура.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.ВидБренда) Тогда
			Возврат Выборка.ВидБренда;
		КонецЕсли;
	КонецЕсли;
	
	////// 2. Если вид бренда пустой, то определяем вид бренда из иерархии
	
	ГруппаСтороннийАссортимент = ПолучитьЗначениеРеквизитыСправочников(,"СтороннийАссортимент");
	
	Если ГруппаСтороннийАссортимент <> Неопределено Тогда
		Если Номенклатура.ПринадлежитЭлементу(ГруппаСтороннийАссортимент) Тогда
			Возврат Перечисления.ВидБренда.Агентский;
		КонецЕсли;
	КонецЕсли;
	
	ГруппаФранчайзинг = ПолучитьЗначениеРеквизитыСправочников(,"Франчайзинг");
	
	Если ГруппаФранчайзинг <> Неопределено Тогда
		Если Номенклатура.ПринадлежитЭлементу(ГруппаФранчайзинг) Тогда
			Возврат Перечисления.ВидБренда.Франчайзинг;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Перечисления.ВидБренда.ПустаяСсылка();
	
КонецФункции

Функция ПоискСтавкиНДСПоНаименованию(Знач НаименованиеСтавкиНДС) Экспорт
	
	СтруктураНДС = Новый Структура("СтавкаНДС, ТекстОшибки", Неопределено, "");
	
	СтрокаПоиска = СокрЛП(НаименованиеСтавкиНДС);
	
	Если Найти(ВРЕГ(СтрокаПоиска), "БЕЗ") > 0 Тогда
		СтруктураНДС.Вставить("СтавкаНДС", Перечисления.СтавкиНДС.БезНДС);
	ИначеЕсли Найти(СтрокаПоиска, "10") > 0 Тогда
		СтруктураНДС.Вставить("СтавкаНДС", Перечисления.СтавкиНДС.НДС10);
	ИначеЕсли Найти(СтрокаПоиска, "20") > 0 Тогда
		СтруктураНДС.Вставить("СтавкаНДС", Перечисления.СтавкиНДС.НДС20);
	Иначе
		СтруктураНДС.Вставить("ТекстОшибки", "Не найдена СтавкаНДС");
	КонецЕсли;
	
	Возврат СтруктураНДС;
	
КонецФункции

Функция ПоискВидаНоменклатуры(Знач НаименованиеВидаНоменклатуры) Экспорт
	
	ВидНоменклатуры = Справочники.ФР_ВидыНоменклатуры.НайтиПоНаименованию(СокрЛП(НаименованиеВидаНоменклатуры));
	Если НЕ ВидНоменклатуры.Пустая() Тогда
		Возврат ВидНоменклатуры;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидНоменклатуры", "%" + СокрЛП(НаименованиеВидаНоменклатуры) + "%");
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФР_ВидыНоменклатуры.Ссылка КАК ВидНоменклатуры
	|ИЗ
	|	Справочник.ФР_ВидыНоменклатуры КАК ФР_ВидыНоменклатуры
	|ГДЕ
	|	ФР_ВидыНоменклатуры.Наименование ПОДОБНО &ВидНоменклатуры
	|	И НЕ ФР_ВидыНоменклатуры.ПометкаУдаления
	|	И НЕ ФР_ВидыНоменклатуры.ЭтоГруппа";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ВидНоменклатуры;
	Иначе
		Возврат Справочники.ФР_ВидыНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция ПоискГТД(ТекущаяСтрока) Экспорт
	
	Если ПустаяСтрока(ТекущаяСтрока.НомерГТД) ИЛИ НЕ ЗначениеЗаполнено(ТекущаяСтрока.Модель) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НомерГТД", СокрЛП(ТекущаяСтрока.НомерГТД));
	Запрос.УстановитьПараметр("Модель", ТекущаяСтрока.Модель);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ГТД.Ссылка КАК НомерГТД
	|ИЗ
	|	Справочник.ГТД КАК ГТД
	|ГДЕ
	|	ГТД.Наименование = &НомерГТД
	|	И ГТД.Владелец = &Модель
	|	И НЕ ГТД.ПометкаУдаления
	|	И НЕ ГТД.ЭтоГруппа";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.НомерГТД;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПоискДекларации(ТекущаяСтрока) Экспорт
	
	Результат = Неопределено;
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Модель) ИЛИ ПустаяСтрока(ТекущаяСтрока.НомерСертификатаЕАС) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", ТекущаяСтрока.Модель);
	Запрос.УстановитьПараметр("Наименование", СокрЛП(ТекущаяСтрока.НомерСертификатаЕАС));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Декларация.Ссылка КАК Декларация
	|ИЗ
	|	Справочник.Декларация КАК Декларация
	|ГДЕ
	|	Декларация.Наименование = &Наименование
	|	И Декларация.Объект = &Объект
	|	И НЕ Декларация.ПометкаУдаления
	|	И НЕ Декларация.ЭтоГруппа";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Декларация;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПоискКонтрагентаПоИНН(ТекущаяСтрока) Экспорт
	
	ФлагИННИностранногоКонтрагента = Ложь;
	Если НЕ ПустаяСтрока(ТекущаяСтрока.АдресИмпортера) Тогда
		Если Найти(ВРЕГ(ТекущаяСтрока.АдресИмпортера), "БЕЛАРУС") > 0 Тогда
			ФлагИННИностранногоКонтрагента = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИНН", ТекущаяСтрока.ИННИмпортера);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Контрагент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты." + ?(ФлагИННИностранногоКонтрагента, "ИННИностранногоКонтрагента = &ИНН", "ИНН = &ИНН") + "
	|	И НЕ Контрагенты.ЭтоГруппа
	|	И НЕ Контрагенты.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Контрагент;
	КонецЕсли;
	
	Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(ТекущаяСтрока.ИмпортерНаименование);
	Если НЕ Контрагент.Пустая() Тогда
		Возврат Контрагент;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПоискМоделиПоКодуПроизводителя_ТипуАртикулаКонтрагента(ДокОбъект, ТекущаяСтрока, КодПроизводителяВручную = "") Экспорт
	
	Запрос = Новый Запрос;
	
	Если СокрЛП(КодПроизводителяВручную) <> "" Тогда
		Запрос.УстановитьПараметр("КодПроизводителя", СокрЛП(КодПроизводителяВручную));
	Иначе
		Запрос.УстановитьПараметр("КодПроизводителя", СокрЛП(ТекущаяСтрока.КодПроизводителя));
	КонецЕсли;
	Запрос.УстановитьПараметр("ТипАртикулаКонтрагента", ДокОбъект.СкладПолучатель.Подразделение.ТипАртикулаКонтрагента);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АртикулыКонтрагентов.Владелец КАК Модель
	|ИЗ
	|	Справочник.АртикулыКонтрагентов КАК АртикулыКонтрагентов
	|ГДЕ
	|	АртикулыКонтрагентов.ТипАртикула = &ТипАртикулаКонтрагента
	|	И АртикулыКонтрагентов.Наименование = &КодПроизводителя
	|	И АртикулыКонтрагентов.Владелец.ЭтоГруппа
	|	И НЕ АртикулыКонтрагентов.Владелец.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Модель;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПоискШтрихкодаПоНоменклатуре_Наименованию(ТекущаяСтрока) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ШтрихкодИзФайла", СокрЛП(ТекущаяСтрока.ШтрихкодИзФайла));
	Запрос.УстановитьПараметр("Номенклатура", ТекущаяСтрока.Номенклатура);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихКоды.Ссылка КАК ШтрихКод
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Наименование = &ШтрихкодИзФайла
	|	И ШтрихКоды.Владелец = &Номенклатура
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И НЕ ШтрихКоды.Владелец.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ШтрихКод;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПоискПоШК(Знач ШтрихКод) Экспорт
	
	СтруктураШК = Новый Структура("Штрихкод, Номенклатура", Справочники.ШтрихКоды.ПустаяСсылка(), Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ШтрихКод", СокрЛП(ШтрихКод));
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихКоды.Ссылка КАК ШтрихКод,
	|	ШтрихКоды.Владелец КАК Номенклатура
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Наименование = &ШтрихКод
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И НЕ ШтрихКоды.Владелец.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураШК, Выборка);
	КонецЕсли;
	
	Возврат СтруктураШК;
	
КонецФункции

Функция ПоискМоделиПоНаименованию(НаименованиеНоменклатуры, ОтборПоПапкеСтороннийАссортимент = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", СокрЛП(НаименованиеНоменклатуры));
	Если ОтборПоПапкеСтороннийАссортимент Тогда
		Запрос.УстановитьПараметр("ГруппаСтороннийАссортимент", ПолучитьЗначениеРеквизитыСправочников(,"СтороннийАссортимент"));
	КонецЕсли;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Номенклатура.Ссылка КАК Модель
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Наименование = &Наименование
	|	" + ?(ОтборПоПапкеСтороннийАссортимент = Истина, "И Номенклатура.Ссылка В(&ГруппаСтороннийАссортимент)", "") + """
	|	И Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Модель;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначениеРеквизитыСправочников(Ссылка = Неопределено, ИмяРеквизита = "") Экспорт
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	|	" + ?(Ссылка = Неопределено, "", "И РеквизитыСправочников.Справочник = &Ссылка") + "";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.ЗначениеРеквизита;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

////////////// ПОИСК НОМЕНКЛАТУРЫ ПО ЧЕТЫРЕМ ТОЧКАМ ///////////////////////////////////

Функция ПоискНоменклатурыПоКоду_ТипуАртикулаКонтрагента_Цвет_Размер(Код, ТипАртикулаКонтрагента, Цвет = Неопределено, Размер = Неопределено, НаходитсяВПапкеФранчайзинг = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Код", СокрЛП(Код));
	Запрос.УстановитьПараметр("ТипАртикулаКонтрагента", ТипАртикулаКонтрагента);
	Запрос.УстановитьПараметр("Цвет", Цвет);
	Запрос.УстановитьПараметр("Размер", Размер);
	
	Если НаходитсяВПапкеФранчайзинг Тогда
		Запрос.УстановитьПараметр("ПапкаФранчайзинг", ПолучитьЗначениеРеквизитыСправочников(,"Франчайзинг"));
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	АртикулыКонтрагентов.Владелец КАК Номенклатура
	|ПОМЕСТИТЬ ГруппыНоменклатуры
	|ИЗ
	|	Справочник.АртикулыКонтрагентов КАК АртикулыКонтрагентов
	|ГДЕ
	|	АртикулыКонтрагентов.ТипАртикула = &ТипАртикулаКонтрагента
	|	И АртикулыКонтрагентов.Наименование = &Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СпрНоменклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	ГруппыНоменклатуры КАК ГруппыНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО (ГруппыНоменклатуры.Номенклатура = СпрНоменклатура.Родитель
	|				ИЛИ ГруппыНоменклатуры.Номенклатура = СпрНоменклатура.Родитель.Родитель)
	|ГДЕ
	|	СпрНоменклатура.Цвет = &Цвет
	|	И СпрНоменклатура.Размер = &Размер
	|	И НЕ СпрНоменклатура.ПометкаУдаления
	|	И НЕ СпрНоменклатура.ЭтоГруппа
	|	" + ?(НаходитсяВПапкеФранчайзинг = Истина, "И СпрНоменклатура.Ссылка В ИЕРАРХИИ(&ПапкаФранчайзинг)", "") + "";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Номенклатура;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПоискНоменклатурыПоМодели_Цвет_Размер(Модель, Цвет = Неопределено, Размер = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Модель", Модель);
	Запрос.УстановитьПараметр("Цвет", Цвет);
	Запрос.УстановитьПараметр("Размер", Размер);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Номенклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В ИЕРАРХИИ(&Модель)
	|	И Номенклатура.Размер = &Размер
	|	И Номенклатура.Цвет = &Цвет
	|	И НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Номенклатура;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

