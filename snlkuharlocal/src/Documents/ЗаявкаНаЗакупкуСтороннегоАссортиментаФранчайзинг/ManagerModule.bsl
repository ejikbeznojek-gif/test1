Функция ОпределитьТипАртикулаНоменклатурыФранчайзинга (Номенклатура) экспорт
	Запрос=новый запрос;
	запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	             |	АртикулыКонтрагентов.ТипАртикула КАК ТипАртикула
	             |ИЗ
	             |	Справочник.АртикулыКонтрагентов КАК АртикулыКонтрагентов
	             |ГДЕ
	             |	АртикулыКонтрагентов.Владелец = &Номенклатура
	             |	И не АртикулыКонтрагентов.ПометкаУдаления";
	Результат = запрос.Выполнить().Выбрать();
	пока Результат.Следующий() цикл
		возврат Результат.ТипАртикула;
	КонецЦикла;
	
	возврат Справочники.ТипыАтрикуловКонтрагентов.ПустаяСсылка();
	

КонецФункции
