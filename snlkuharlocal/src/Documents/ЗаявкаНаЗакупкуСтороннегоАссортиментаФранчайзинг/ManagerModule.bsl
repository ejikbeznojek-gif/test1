Функция СоздатьЭлементСправочникаЦвета(ТекущаяСтрока, ТекРодитель = Неопределено) Экспорт
	
	НовыйЦвет = Справочники.Цвета.СоздатьЭлемент();
	НовыйЦвет.Родитель = ?(ТекРодитель = Неопределено, Справочники.Цвета.НайтиПоКоду("20791"), ТекРодитель);
	НовыйЦвет.Наименование = ТекущаяСтрока.НаименованиеЦвета;
	НовыйЦвет.РусскоеНаименование = ТекущаяСтрока.НаименованиеЦвета;
	
	Попытка
		НовыйЦвет.Записать();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат НовыйЦвет.Ссылка;
	
КонецФункции

Функция СоздатьЭлементСправочникаРазмеры(ТекущаяСтрока, ТекРодитель = Неопределено) Экспорт
	
	НовыйРазмер = Справочники.Размеры.СоздатьЭлемент();
