#Область ОбработчикиСобытийЭлементовШапкиФормы     

&НаКлиенте
Процедура ВидНачисленияПриИзменении(Элемент)   
	
	ВидНачисленияПриИзмененииНаСервере();  
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы 

&НаКлиенте
Процедура ЗаполнитьОплачиваемыйПроцент(Команда)  
	
	УказанноеЧисло = Неопределено;
	ВвестиЗначение(УказанноеЧисло, "Укажите макс. %", Тип("Число"));
	Если УказанноеЧисло <> Неопределено И УказанноеЧисло > 0 Тогда
		Для Каждого ТекущаяСтрока Из Элементы.Параметры.ВыделенныеСтроки Цикл

			ДанныеСтроки = Элементы.Параметры.ДанныеСтроки(ТекущаяСтрока);
			ДанныеСтроки.МаксимальноОплачиваемыйПроцентВыполнения = УказанноеЧисло;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПремию(Команда)

	УказанноеЧисло = Неопределено;
	ВвестиЗначение(УказанноеЧисло, "Укажите премию", Тип("Число"));
	Если УказанноеЧисло <> Неопределено И УказанноеЧисло > 0 Тогда
		Для Каждого ТекущаяСтрока Из Элементы.Параметры.ВыделенныеСтроки Цикл
			ДанныеСтроки = Элементы.Параметры.ДанныеСтроки(ТекущаяСтрока);
			ДанныеСтроки.ПремияПриВыполненииСтаПроцентовПлана = УказанноеЧисло;
		КонецЦикла;
	КонецЕсли; 

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции   

&НаСервере
Процедура ВидНачисленияПриИзмененииНаСервере()  
	
	Если ЗначениеЗаполнено(Объект.ВидНачисления) Тогда
		ЗаполнитьКритерииПоНаправлению();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКритерииПоНаправлению()  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	Спр.Номенклатура КАК КритерийНачисления
				   |ИЗ
				   |	Справочник.РаспределениеСотрудниковПоНаправлениямПродаж.Товары КАК Спр
				   |ГДЕ
				   |	Спр.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", объект.ВидНачисления);
	Объект.Параметры.Загрузить(Запрос.Выполнить().Выгрузить());   
	
КонецПроцедуры

#КонецОбласти


