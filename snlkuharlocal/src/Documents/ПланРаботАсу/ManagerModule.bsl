Процедура ДействияФормыЗаполнитьСтарыеЗадачи(ДокОбъект) экспорт
	если ложь тогда
		ДокОбъект=Документы.ПланРаботАсу.СоздатьДокумент();
	КонецЕсли;
	// Кухарь А.Ю.  20.06.2022 начало
	//Опечатка
	//	если ЗначениеЗаполнено(ДокОбъект.Ссылка) тогда 
	если не ЗначениеЗаполнено(ДокОбъект.Ссылка) тогда 
		// Кухарь А.Ю.  20.06.2022 конец
		ТекДок=Неопределено;
	иначе
		Текдок=ДокОбъект.Ссылка;
	КонецЕсли;
	
	ПодразделениеИсполнителя=ДокОбъект.ПодразделениеИсполнителя;
	
	
	
	если ЗначениеЗаполнено(ПодразделениеИсполнителя) тогда
		МассСтрок=ДокОбъект.Задачи.НайтиСтроки(новый Структура("ПеренесенаСПрошлогоПлана",Истина));
		Для каждого СтрМасс из МассСтрок цикл
			ДокОбъект.Задачи.Удалить(СтрМасс);
		КонецЦикла;
		
		ТЗСтарыхЗадач =  ДокОбъект.ПолучитьЗадачиПрошлогоПлана(ПодразделениеИсполнителя,ТекДок);
		Для каждого СтрТЗ из ТЗСтарыхЗадач цикл
			если ДокОбъект.Задачи.Найти(СтрТЗ.Задача)<> Неопределено тогда Продолжить; КонецЕсли;
			СтрТЧ=ДокОбъект.Задачи.Добавить();
			СтрТЧ.Задача=СтрТЗ.задача;
			СтрТЧ.Описание=СтрТЗ.задача.полноеОписаниеЗадачи;
			СтрТЧ.ПеренесенаСПрошлогоПлана=Истина;
			// Кухарь А.Ю.  23.08.2022 начало
			СтрТЧ.Исполнитель=СтрТЧ.Задача.РеальныйИсполнитель; 
			// Кухарь А.Ю.  23.08.2022 конец
			
			СообщитьИзМодуля("Добавлена задача "+СтрТЧ.Задача.Номер+" из предыдущего плана работ.");
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

