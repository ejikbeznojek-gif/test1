
Функция НайтиСоздатьПланРаботАСУ (Дата,Подразделение) экспорт
	Запрос=новый запрос;
	запрос.Текст=    "ВЫБРАТЬ первые 1
	                 |	ПланРаботАсу.Ссылка КАК Ссылка
	                 |ИЗ
	                 |	Документ.ПланРаботАсу КАК ПланРаботАсу
	                 |ГДЕ
	                 |	ПланРаботАсу.Проведен
	                 |	И ПланРаботАсу.Дата = &Дата
	                 |	И ПланРаботАсу.ПодразделениеИсполнителя = &Подразделение";
	запрос.УстановитьПараметр("Дата",НачалоНедели(Дата));
	запрос.УстановитьПараметр("Подразделение",Подразделение);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		возврат результат.ссылка;
	КонецЦикла;
	
	ПланРабот=Документы.ПланРаботАсу.СоздатьДокумент();
	ПланРабот.Дата=НачалоНедели(ТекущаяДата());
	ПланРабот.ПодразделениеИсполнителя=Подразделение;
	ПланРабот.ДатаОкончания=КонецНедели(ТекущаяДата());
	ПланРабот.Исполнитель=ПолучитьИсполнителяПоПодразделению(Подразделение);
	
	ПланРабот.Записать(РежимЗаписиДокумента.Проведение);
	СообщитьИзМодуля("Создан "+ПланРабот);
	
	
	возврат ПланРабот.Ссылка;
КонецФункции



Процедура ДобавитьМассивЗадачВПлан (Подразделение,МассивЗадач) экспорт
	
	ПланСсылка=НайтиСоздатьПланРаботАСУ(ТекущаяДата(),Подразделение);

	
	
	
	
		

	
	
	
	
	если ложь тогда ПланСсылка=документы.ПланРаботАсу.ПустаяСсылка();КонецЕсли;
	
	ПланРаботОбъект=ПланСсылка.ПолучитьОбъект();
	
	Если ПланРаботОбъект.Задачи.Количество()=0 тогда
		ПервичноеЗаполнение=Истина;
	Иначе
		ПервичноеЗаполнение=ложь;
	КонецЕсли;
	Внеплановая=не ПервичноеЗаполнение;
	
	
	

	// Кухарь А.Ю.  07.06.2022 начало
	если ПервичноеЗаполнение тогда
		ДействияФормыЗаполнитьСтарыеЗадачи(ПланРаботОбъект);
	КонецЕсли;
	// Кухарь А.Ю.  07.06.2022 конец
	
	
	
	
	
	
	НачатьТранзакцию();
	
	Для каждого ТекЗадача из МассивЗадач Цикл 
		
		// Андреев И.Д. 31.08.2022 начало
		// Проверка на задачи которые уже есть в плане
		Запрос = новый запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ПланРаботАсуЗадачи.НомерСтроки КАК НомерСтроки,
		               |	ПланРаботАсуЗадачи.Задача КАК Задача
		               |ИЗ
		               |	Документ.ПланРаботАсу.Задачи КАК ПланРаботАсуЗадачи
		               |ГДЕ
		               |	ПланРаботАсуЗадачи.Ссылка.Ссылка = &ПланСсылка
		               |	И НЕ ПланРаботАсуЗадачи.Ссылка.ПометкаУдаления
		               |	И ПланРаботАсуЗадачи.Задача = &ТекЗадача";
		
		Запрос.УстановитьПараметр("ПланССылка", ПланССылка);
		Запрос.УстановитьПараметр("ТекЗадача",ТекЗадача.задача);
		результат=Запрос.Выполнить().Выгрузить(); 
		
		Если Результат.Количество()=0 тогда;
			
		Иначе
			
			Для каждого СтрТч из результат цикл 
				Сообщить("Задача уже есть в плане, номер строки: "+СтрТч.номерстроки);	
				КонецЦикла;	
			
			    Продолжить;

		КонецЕсли;
		
		// Андреев И.Д. 31.08.2022 конец

		
		
		если ПланРаботОбъект.Задачи.Найти(ТекЗадача) <> Неопределено тогда
			СообщитьИзМодуля("Задача "+ТекЗадача+" не добавлена в план "+ПланСсылка+" т.к. уже там была.");
			Продолжить;
		КонецЕсли;
		если ТипЗнч(ТекЗадача)=Тип("СтрокаТаблицыЗначений") тогда
			ТекЗадача=ТекЗадача.Задача;
		КонецЕсли; 
		
		СтрТЧ=ПланРаботОбъект.Задачи.Добавить();
		СтрТЧ.Задача=ТекЗадача;
		
		// Кухарь А.Ю. 20.05.2022 начало
		СтрТЧ.Исполнитель=СтрТЧ.Задача.НастоящийИсполнитель; 
		// Кухарь А.Ю. 20.05.2022 конец
		
		// Андреев И.Д. 09.08.2022 начало
		Если  ПланРаботОбъект.ЗаполненПлан = ложь тогда
			Внеплановая = ложь;
		КонецЕсли;
		// Андреев И.Д. 09.08.2022 конец
		

		ОбработатьЗаполнениеЗадачиВСтроке(ПланРаботОбъект,СтрТЧ,Внеплановая,,Истина);
		СообщитьИзМодуля("Задача "+ТекЗадача.номер+" добавлена в план "+ПланРаботОбъект.Номер+". ")
		
	КонецЦикла;
	ПланРаботОбъект.Записать();
	ЗафиксироватьТранзакцию();
	
	#ЕСЛИ КЛИЕНТ ТОГДА
		ПланРаботОбъект.ПолучитьФорму("ФормаДокумента").Открыть();
	#КОНЕЦЕСЛИ

	
КонецПроцедуры

Функция ПолучитьИсполнителяПоПодразделению(Подразделение) экспорт
	Запрос=новый запрос;
	запрос.Текст=    "ВЫБРАТЬ ПЕРВЫЕ 1
	                 |	ПланРаботАсу.Исполнитель КАК Исполнитель,
	                 |	ПланРаботАсу.Дата КАК Дата
	                 |ИЗ
	                 |	Документ.ПланРаботАсу КАК ПланРаботАсу
	                 |ГДЕ
	                 |	 ПланРаботАсу.ПодразделениеИсполнителя = &Подразделение
	                 |	И ПланРаботАсу.Исполнитель <> &Исполнитель
	                 |
	                 |УПОРЯДОЧИТЬ ПО
	                 |	ПланРаботАсу.Дата УБЫВ";
	запрос.УстановитьПараметр("Подразделение",Подразделение);
	запрос.УстановитьПараметр("Исполнитель",Справочники.ФизическиеЛица.ПустаяСсылка());
	
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		возврат результат.Исполнитель;
	КонецЦикла;

	возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	

КонецФункции

Процедура ОбработатьЗаполнениеЗадачиВСтроке(ДокОбъект,СтрокаТЧ,Внеплановая=ложь,ПеренесенаСПрошлогоПлана=ложь,ОтправлятьУведомление=ложь) экспорт
	если не ЗначениеЗаполнено(СтрокаТЧ.Задача) тогда Возврат;КонецЕсли;
	СтрокаТЧ.Описание=СтрокаТЧ.Задача.ПолноеОписаниеЗадачи;
	СтрокаТЧ.Внеплановая=Внеплановая;
	СтрокаТЧ.ПеренесенаСПрошлогоПлана=ПеренесенаСПрошлогоПлана;
	
	
	если ложь тогда ДокОбъект=документы.ПланРаботАсу.СоздатьДокумент();КонецЕсли;
	если ОтправлятьУведомление  тогда
		ЕМэйл=ДокОбъект.Исполнитель.ЕМэйл;
		если не ЗначениеЗаполнено(ЕМэйл) тогда
			ЕМэйл=ПолучитьЕмейлПоКоду(ПараметрыСеанса.Пользователь.ФизЛицо);
		КонецЕсли;
		если ЗначениеЗаполнено(ЕМэйл) и ПараметрыСеанса.Пользователь.ФизЛицо<>ДокОбъект.Исполнитель тогда
			СписокПолучателей=новый СписокЗначений;
			СписокПолучателей.Добавить(ЕМэйл);
			ТекстПисьма="В план работ № "+ДокОбъект.Номер+" добавлена задача "+СтрокаТЧ.Задача.Номер+". "+СтрокаТЧ.Задача.ПолноеОписаниеЗадачи;
			ТемаПисьма="Уведомление о новой задаче";			
			СформироватьВнутреннееУведомление(СписокПолучателей,ТекстПисьма,ТемаПисьма);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЕмейлПоКоду (ФизЛицо)
	КодФЛ=ФизЛицо.код;
	если КодФЛ="SNL-00316" тогда
		возврат "zhuravlev@collant.ru";
	//ИначеЕсли КодФЛ="SNL-02326" тогда
	//	возврат "nikolaev@collant.ru";
	ИначеЕсли КодФЛ="SNL--00075" тогда
		возврат "krohin@collant.ru";	
	ИначеЕсли КодФЛ="SNL-07579" тогда
		возврат "orlov@collant.ru";
	иначе 
		возврат Неопределено;
	КонецЕсли;
КонецФункции


