
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Дата = ТекущаяДата();
	Сотрудник = Справочники.ФизическиеЛица.ПустаяСсылка();
	
	СоздатьИзмеренияПланировщика();	
	ОбновитьПериодОтображенияПланировщика();
	
	ЗаполнитьЖурналЗадач();
	
	
КонецПроцедуры


&НаСервере
Процедура СоздатьИзмеренияПланировщика()
	Планировщик.Измерения.Очистить();
	Измерение = Планировщик.Измерения.Добавить("Сотрудник");
	
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ФизическиеЛица.Ссылка КАК Ссылка,
	|	ФизическиеЛица.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	ФизическиеЛица.Родитель = &Родитель";
	запрос.УстановитьПараметр("Родитель",Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00760"));
	выборка=запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		если ЗначениеЗаполнено(Сотрудник) и выборка.ссылка<>Сотрудник тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеИзмерения = Измерение.Элементы.Добавить(Выборка.Ссылка);	
		ЗначениеИзмерения.Текст = Выборка.Наименование;
		ЗначениеИзмерения.ЦветРамки = WebЦвета.Синий;
		
	КонецЦикла;
	
КонецПроцедуры 



&НаСервере
Процедура ОбновитьПериодОтображенияПланировщика()
	
	Начало = НачалоМесяца(Дата);
	Конец = КонецМесяца(Дата);
	
	Планировщик.ТекущиеПериодыОтображения.Очистить();
	Планировщик.ТекущиеПериодыОтображения.Добавить(Начало, Конец);
	
КонецПроцедуры // ОбновитьПериодОтображенияПланировщика()



&НаСервере
Процедура ЗаполнитьЖурналЗадач()
	
	
	Планировщик.Элементы.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	|	ЗадачиАСУ.Ссылка КАК Задача,
	|	ЗадачиАСУ.ДатаПланируемогоНачала КАК ДатаНачала,
	|	ЗадачиАСУ.НастоящийИсполнитель КАК НастоящийИсполнитель,
	|	ЗадачиАСУ.НаименованиеЗадачи КАК НаименованиеЗадачи,
	|	ЗадачиАСУ.ДатаПланируемогоОкончания КАК ДатаОкончания,
	|	ЗадачиАСУ.СостояниеЗадачи КАК СостояниеЗадачи,
	|	ЗадачиАСУ.Распределена КАК Распределена
	|ИЗ
	|	Документ.ЗадачиАСУ КАК ЗадачиАСУ
	|ГДЕ
	|	ЗадачиАСУ.Проведен
	|	И ЗадачиАСУ.ДатаПланируемогоНачала МЕЖДУ &Дата1 И &Дата2
	|	И &СоставнойФильтр
	|	И ЗадачиАСУ.НастоящийИсполнитель В ИЕРАРХИИ(&НастоящийИсполнитель)";  
	запрос.УстановитьПараметр("НастоящийИсполнитель",Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00760"));
	
	Запрос.УстановитьПараметр("Дата1", НачалоМесяца(Дата));
	Запрос.УстановитьПараметр("Дата2", КонецМесяца(Дата));
	// Кухарь А.Ю.  27.04.2023 начало
	//
	СоставнойФильтр = "";
	если СкрытьЗавершённые тогда
		СоставнойФильтр=СоставнойФильтр+" "+" не СостояниеЗадачи в (&СписокЗавершенныхСостояний) ";
		СписокЗавершенныхСостояний=новый СписокЗначений;
		СписокЗавершенныхСостояний.Добавить(Справочники.СостояниеЗадачи.Выполнена);
		СписокЗавершенныхСостояний.Добавить(Справочники.СостояниеЗадачи.Отклонённые);
		запрос.УстановитьПараметр("СписокЗавершенныхСостояний",СписокЗавершенныхСостояний);
		
	КонецЕсли;
	
	если СоставнойФильтр<>"" тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"&СоставнойФильтр",СоставнойФильтр);
	иначе
		запрос.УстановитьПараметр("СоставнойФильтр",Истина);
	КонецЕсли;
	// Кухарь А.Ю.  27.04.2023 конец
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		если ЗначениеЗаполнено(Сотрудник) и выборка.НастоящийИсполнитель<>Сотрудник тогда
			Продолжить;
		КонецЕсли;
		
		ЗначенияИзмерений = Новый Соответствие;
		ЗначенияИзмерений.Вставить("Сотрудник", Выборка.НастоящийИсполнитель);
		
		ЖирныйШрифт = Новый Шрифт(,,Истина);		                                                                       
		//	
		ПредставлениеЗадачи = символы.ПС+Выборка.НаименованиеЗадачи+Символы.ПС+Строка(Выборка.СостояниеЗадачи);
		МассивСтрок = Новый Массив;
		МассивСтрок.Добавить(Новый ФорматированнаяСтрока(ПредставлениеЗадачи, ЖирныйШрифт));
		//	
		ЭлементПланировщика = Планировщик.Элементы.Добавить(НачалоДня(Выборка.ДатаНачала), Выборка.ДатаОкончания);
		ЭлементПланировщика.ЗначенияИзмерений = Новый ФиксированноеСоответствие(ЗначенияИзмерений);	
		ЭлементПланировщика.Значение = Выборка.Задача;
		ЭлементПланировщика.Текст = Новый ФорматированнаяСтрока(МассивСтрок);
		
		
		// Кухарь А.Ю.  27.04.2023 начало
		//
		
		Цвет = новый цвет (Выборка.СостояниеЗадачи.Цвет1,Выборка.СостояниеЗадачи.Цвет2,Выборка.СостояниеЗадачи.Цвет3);  
		Если Выборка.СостояниеЗадачи.цвет1=0 и Выборка.СостояниеЗадачи.цвет2=0 и Выборка.СостояниеЗадачи.цвет3=0 тогда 
			Цвет = Неопределено;
		КонецЕсли;
		
		// Кухарь А.Ю. 11.05.2022 начало
		Если Выборка.Распределена тогда
			Цвет = WebЦвета.ГолубойСоСтальнымОттенком;
		КонецЕсли;
		
		если цвет <>Неопределено тогда
			ЭлементПланировщика.ЦветФона = Цвет;
		КонецЕсли;
		// Кухарь А.Ю. 11.05.2022 конец
		
		// Кухарь А.Ю.  27.04.2023 конец
		
		
		//	Цвет = Выборка.Цвет.Получить();
		//	Если Цвет = Неопределено Тогда
		//		Цвет = WebЦвета.БледноЛиловый;
		//	КонецЕсли;
		//	
		//	ЭлементПланировщика.ЦветФона = Цвет;
		//	
	КонецЦикла;
	
КонецПроцедуры // ЗаполнитьЖурналЗаписей()



