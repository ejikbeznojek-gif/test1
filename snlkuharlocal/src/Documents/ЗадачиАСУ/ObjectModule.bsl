Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	если ЗначениеЗаполнено(Исполнитель) и ЗначениеЗаполнено(Исполнитель.Подразделение) тогда
		ПодразделениеИсполнителя=Исполнитель.Подразделение;
	КонецЕсли;
	
	если ЗначениеЗаполнено(ПродолжительностьДни) и ЗначениеЗаполнено(ДатаПланируемогоНачала) тогда
		Запрос=новый запрос;
		запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 100
		|	КалендарьДни.Дата КАК Дата
		|ПОМЕСТИТЬ ВремТЗ
		|ИЗ
		|	Справочник.Календарь.Дни КАК КалендарьДни
		|ГДЕ
		|	НЕ КалендарьДни.Ссылка.ПометкаУдаления
		|	И КалендарьДни.Дата > &Дата
		|	И КалендарьДни.Часы = 8
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВремТЗ.Дата КАК Дата
		|ИЗ
		|	ВремТЗ КАК ВремТЗ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
		запрос.УстановитьПараметр("Дата",ДатаПланируемогоНачала);
		запрос.Текст=СтрЗаменить(запрос.Текст," ПЕРВЫЕ 100", " ПЕРВЫЕ "+Строка(ПродолжительностьДни));
		результат=запрос.Выполнить().выбрать();
		пока результат.Следующий() цикл
			ДатаПланируемогоОкончания=результат.дата;
		КонецЦикла; 			
	КонецЕсли;
КонецПроцедуры
