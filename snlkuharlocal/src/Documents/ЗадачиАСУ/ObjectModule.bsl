
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	//{{__КОНСТРУКТОР_ВВОД_НА_ОСНОВАНИИ
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗадачиАСУ") Тогда
		// Заполнение шапки
		Заказчик = ДанныеЗаполнения.Заказчик;
		КатегорияЗадачи = ДанныеЗаполнения.КатегорияЗадачи;
		НаименованиеЗадачи = ДанныеЗаполнения.НаименованиеЗадачи;
		ПодразделениеЗаказчика = ДанныеЗаполнения.ПодразделениеЗаказчика;
		ПодразделениеИсполнителя = ДанныеЗаполнения.ПодразделениеИсполнителя;
		ОсновнаяЗадача = ДанныеЗаполнения.ссылка;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Совещание") Тогда
		// Заполнение шапки
		Совещание = ДанныеЗаполнения.Ссылка;
	КонецЕсли;
	//}}__КОНСТРУКТОР_ВВОД_НА_ОСНОВАНИИ
	
	
	
	// Кухарь А.Ю.  09.08.2022 начало
	//
	ДатаНачалаРаботыПоПоследнемуИзменению=ПустаяДата();
	ДатаФактическогоНачала=ПустаяДата();
	ДатаПланируемогоНачала=ПустаяДата();
	ДатаФактическогоНачала=ПустаяДата();
	ДатаПланируемогоОкончания=ПустаяДата();
	ДатаПостановки=ПустаяДата();
	ЗадачаИзСогласованногоПлана=Ложь;
	// Кухарь А.Ю.  09.08.2022 конец
	
КонецПроцедуры


Процедура ПриКопировании(ОбъектКопирования)
	    
ЭтотОбъект.Автор = параметрысеанса.Пользователь.ФизЛицо;

// Кухарь А.Ю.  09.08.2022 начало
