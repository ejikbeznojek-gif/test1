				Рез = Запрос.Выполнить().Выбрать();
				Если рез.Следующий() тогда
					Если рез.ссылка.пометкаУдаления = истина тогда
						продолжить;
					иначе
						шкОб = рез.Ссылка.получитьОбъект();
						ШкОб.пометкаудаления = истина;
