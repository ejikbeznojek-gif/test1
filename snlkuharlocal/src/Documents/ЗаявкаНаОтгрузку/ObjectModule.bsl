Процедура ОбновитьСостоянияНакладных() Экспорт
	//крохин начало 17.11.2013
	//получим номера СФ
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СчетФактураНакладные.Ссылка.Номер КАК НомерСФ,
	|	СчетФактураНакладные.Накладная.Номер КАК НомерРНК
	|ИЗ
	|	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
	|ГДЕ
	|	СчетФактураНакладные.Накладная В(&СписокНакладных)
	|	И СчетФактураНакладные.Ссылка.Проведен";
	Запрос.УстановитьПараметр("СписокНакладных",Накладные.ВыгрузитьКолонку("Накладная"));
	ТаблицаНомеровСФ = Запрос.Выполнить().Выгрузить();
	
	//крохин конец 17.11.2013
	Для Каждого СтрокаТЧ Из Накладные Цикл
		Если НЕ СтрокаТЧ.Накладная.Пустая() И НЕ ЗначениеНеЗаполнено(СтрокаТЧ.Накладная.Номер) Тогда
			ЗаполнитьСтрокуПоНакладной(СтрокаТЧ,СтрокаТЧ.Накладная);
			//крохин начало 17.11.2013
			Если ТаблицаНомеровСФ <> Неопределено И СтрокаТЧ.Накладная.Метаданные().имя = "РасходнаяНакладная" Тогда
				НайденнаяСтрока = ТаблицаНомеровСФ.Найти(СтрокаТЧ.НомерНакладной,"НомерРНК");
				Если НайденнаяСтрока = Неопределено Тогда
					СтрокаТЧ.НомерСФ = "";	
				Иначе
					СтрокаТЧ.НомерСФ = НайденнаяСтрока.НомерСФ;
				КонецЕсли;
			КонецЕсли;
			//крохин конец 17.11.2013
		КонецЕсли;
	КонецЦикла; 
КонецПроцедуры


Процедура  ОбновитьСостояниеПаллет() Экспорт
	
	 //Тимофеев Ю.А. 17.08.2023 Начало
	
	//получим все ПНК у который в табличной части 
	//1 строка с Паллетами на возрат от покупателя
	//и аналогично добавим в табличную часть ЗОГ
	//в верхнем ЗАПРОСЕ они не подадают 
	//так как имеют СостоянияНакладной = СостоянияНакладной.Принята
	
	//а можно было вот так сделать
	//////Тимомфеев Ю.А.
	//|И ВЫБОР
	//|КОГДА Накладная.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя)
	//|	ТОГДА ИСТИНА
	//|ИНАЧЕ НЕ Накладная.СостояниеНакладной В (&СписокНедопустимыхСостояний)
	//| КОНЕЦ";
	//////Тимомфеев Ю.А.
	
		
	ТоварПаллеты = Справочники.Номенклатура.НайтиПоКоду("ODB-000325"); 
	
	
	ЗапросП = Новый Запрос;
	ЗапросП.Текст = "ВЫБРАТЬ
	|	ПриходнаяНакладнаяТовары.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ПНСсПАЛЕТТАМИ
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	ПриходнаяНакладнаяТовары.Номенклатура = &Номенклатура
	|	И ПриходнаяНакладнаяТовары.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ПриходнаяНакладнаяТовары.Ссылка.Проведен
	|	И ПриходнаяНакладнаяТовары.Ссылка.Склад = &Склад
	|	И ПриходнаяНакладнаяТовары.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	|	И ПриходнаяНакладнаяТовары.Ссылка.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя)
	|	И ПриходнаяНакладнаяТовары.Ссылка.ПунктДоставки.ТребуетсяЗабиратьПалетты
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриходнаяНакладнаяТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(1) КАК СчетСтрок,
	|	ПриходнаяНакладнаяТовары.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ТолькоПаллеты
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	ПриходнаяНакладнаяТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ПНСсПАЛЕТТАМИ.Ссылка КАК Ссылка
	|			ИЗ
	|				ПНСсПАЛЕТТАМИ КАК ПНСсПАЛЕТТАМИ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриходнаяНакладнаяТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""ПНК"" КАК Вид,
	|	ТолькоПаллеты.Ссылка КАК Ссылка
	|ИЗ
	|	ТолькоПаллеты КАК ТолькоПаллеты
	|ГДЕ
	|	ТолькоПаллеты.СчетСтрок = 1";

	
	ЗапросП.УстановитьПараметр("Номенклатура", ТоварПаллеты);// Номенклатура
	ЗапросП.УстановитьПараметр("Дата1"       , КонецДня(Константы.ДатаЗапретаРедактирования.Получить()));
	ЗапросП.УстановитьПараметр("Дата2",		   КонецДня(Дата));
	ЗапросП.УстановитьПараметр("Склад",		   Склад);
	ЗапросП.УстановитьПараметр("ДатаОтгрузки", НачалоДня(Дата));
	
	
	ВыборкаП=ЗапросП.Выполнить().Выбрать();
	
	//сократим немного Тимофеев Ю.А.
	ОбъектПолученныйПоСсылке = Ссылка.ПолучитьОбъект();
	ПеречВспомогательная     = Перечисления.ВидыЗавокНаОтргузку.Вспомогательная;
	
	Пока ВыборкаП.Следующий() Цикл		
		СтрокаТЧ=Накладные.Найти(ВыборкаП.Ссылка,"Накладная");
		
		Если СтрокаТЧ=Неопределено Тогда
			
			СтрокаТЧ=Накладные.Добавить();
			
			//кухарь 15.03.15 начало
			//будем галку снимать если зог был или стал вспомогательным. Их могут формировать логисты заранее. 
		ИначеЕсли ссылка <> Документы.ЗаявкаНаОтгрузку.ПустаяСсылка() тогда
			//Кухарь 25.05.17 начало
			//Опечатка
			//если ДокОбъект.Ссылка.ПолучитьОбъект().ВидЗаявки<>Перечисления.ВидыЗавокНаОтргузку.Вспомогательная или  ДокОбъект.ВидЗаявки<>Перечисления.ВидыЗавокНаОтргузку.Вспомогательная тогда
			ТекущаяНакладная=СтрокаТЧ.Накладная; 
			
			//Тимофеев Ю.А. 21.08.2023 Начало
			СтрокаТЧ.НеОтгружать= ТекущаяНакладная.Проведен;			
			//Тимофеев Ю.А. 21.08.2023 Конец
			
			если ОбъектПолученныйПоСсылке.ВидЗаявки=ПеречВспомогательная или  ВидЗаявки=ПеречВспомогательная тогда
				//Кухарь 25.05.17 начало     				
								
				если  ТекущаяНакладная.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе и  ТекущаяНакладная.Проведен и  ТекущаяНакладная.ДатаОтгрузки=ДатаОтгрузки тогда
					СтрокаТЧ.НеОтгружать=Ложь;
				КонецЕсли;
				
			КонецЕсли;		
			//кухарь 15.03.15 конец
		КонецЕсли;
		
