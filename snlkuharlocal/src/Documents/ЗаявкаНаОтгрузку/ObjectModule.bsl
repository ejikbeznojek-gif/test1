	СостояниеНакладной	=Неопределено;
	Отгружен			=Неопределено;
	СостояниеДокументов	=Неопределено;
	ДатаОтгрузки		=Неопределено;
	
	Автор				=Неопределено;
КонецПроцедуры

Процедура ЗаполнитьАдрес(СтрокаТЧ,ВидАдреса="Получатель",Накладная,ПунктДоставки,ТранспортнаяКомпания,ПунктПерегруза)
	//Кухарь 04.05.18 начало
	//Тип доставки теперь есть в документе
	//	ТипДоставки						=ПунктДоставки.ТипДоставки;	
	попытка
		если ЗначениеЗаполнено(Накладная.ТипДоставки) тогда
			ТипДоставки=Накладная.ТипДоставки;
		иначе
			ТипДоставки=ПунктДоставки.ТипДоставки;
		КонецЕсли;
	Исключение
		ТипДоставки=ПунктДоставки.ТипДоставки;
	КонецПопытки;
	//Кухарь 04.05.18 конец	
	
	
	СтрокаТЧ.ТипДоставки			=ТипДоставки;
	
	Если 1=2 Тогда
		СтрокаТЧ=Накладные.Добавить();	
	КонецЕсли; 
	
	Если ТипДоставки		= Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда
		СтрокаТЧ["ПунктДоставки"		+ВидАдреса]	= ПунктДоставки;
		СтрокаТЧ["ПунктПерегруза"		+ВидАдреса]	= ПунктПерегруза;		
		СтрокаТЧ["ТранспортнаяКомпания"	+ВидАдреса]	= ТранспортнаяКомпания;		
		//Кухарь 06.02.18 начало
		//Новое тип доставки 
		//ИначеЕсли ТипДоставки	= Перечисления.ТипыДоставки.Доставка Тогда		
	ИначеЕсли ТипДоставки	= Перечисления.ТипыДоставки.Доставка 	или ТипДоставки=Перечисления.ТипыДоставки.Перегруз  Тогда				
		//Кухарь 06.02.18 конец				
		СтрокаТЧ["ПунктДоставки"		+ВидАдреса]	= ПунктДоставки;
		СтрокаТЧ["ПунктПерегруза"		+ВидАдреса]	= Неопределено;		
		СтрокаТЧ["ТранспортнаяКомпания"	+ВидАдреса]	= Неопределено;
	Иначе
		//СтрокаТЧ.СкладСамовывоза				= СтрокаТЧ.Отправитель;
		
		Если ПунктДоставки.СкладСамовывоза.Пустая() Тогда
			СтрокаТЧ.СкладСамовывоза				= СтрокаТЧ.Отправитель;
		Иначе
			СтрокаТЧ.СкладСамовывоза				= ПунктДоставки.СкладСамовывоза;
		КонецЕсли;
	КонецЕсли;
	
	
	СтрокаТЧ["РайонДоставки"+ВидАдреса]= ПунктДоставки.РайонДоставки;
	
	Адрес="";
	
	Если ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда			
		ПД=ПунктПерегруза;			
		
		Адрес="АД (ТК): "+СокрЛП(ТранспортнаяКомпания.Наименование)+
		", адрес: "+СокрЛП(ПД.Регион)+", "+СокрЛП(ПД.АдресПолучателя)+
		?(ПустаяСтрока(ПД.Телефоны),"",", тел.: "+ПД.Телефоны)+" "+СокрЛП(ПД.КонтактныеЛица)
		+" "+Символы.ПС;
		
		СтрокаТЧ["РайонДоставки"+ВидАдреса]	= ПД.РайонДоставки;
	ИначеЕсли ТипДоставки=Перечисления.ТипыДоставки.Доставка  Тогда		
		
		ПД=ПунктДоставки;
		
		Адрес= "АД: "+СокрЛП(СтрокаТЧ[ВидАдреса].Наименование)+
		", адрес: "+СокрЛП(ПД.Регион)+", "+СокрЛП(ПД.АдресПолучателя)+" "+Символы.ПС;
		
		СтрокаТЧ["РайонДоставки"+ВидАдреса]	= ПД.РайонДоставки;
		//Кухарь 06.02.18 начало
		//Новый тип доставки 	
	ИначеЕсли ТипДоставки=Перечисления.ТипыДоставки.Перегруз  Тогда	
		ПД=ПунктДоставки;
		
		//Кухарь 22.06.18 начало
		//Какая то ошибка иногда
		попытка
			Адрес= "АД: "+СтрокаТЧ.Накладная.АдресПерегруза+" "+Символы.ПС;
		Исключение
			Адрес= "АД: "+СокрЛП(СтрокаТЧ[ВидАдреса].Наименование)+
			", адрес: "+СокрЛП(ПД.Регион)+", "+СокрЛП(ПД.АдресПолучателя)+" "+Символы.ПС;
			
		КонецПопытки;
		//Кухарь 22.06.18  конец		
		СтрокаТЧ["РайонДоставки"+ВидАдреса]	= ПД.РайонДоставки;
		
		//Кухарь 06.02.18 конец	
		
		СтрокаТЧ["РайонДоставки"+ВидАдреса]	= ПД.РайонДоставки;
		
		//Кухарь 06.02.18 конец			
	Иначе
		ПД=ПунктДоставки;
		Адрес="АД: САМОВЫВОЗ. Склад вывоза: "+СтрокаТЧ.СкладСамовывоза+", адрес: "+СтрокаТЧ.СкладСамовывоза.Адрес+Символы.ПС;
		
	КонецЕсли;
	
	Если ТипДоставки<>Перечисления.ТипыДоставки.Самовывоз Тогда
		ПД=ПунктДоставки;		
		Адрес=Адрес+"АП: "+СокрЛП(ПД.Регион)+", "+СокрЛП(ПД.АдресПолучателя)+?(ПустаяСтрока(ПД.Телефоны),"",", тел.: "+ПД.Телефоны)+" "+СокрЛП(ПД.КонтактныеЛица);
	КонецЕсли;	
	СтрокаТЧ["Адрес"+ВидАдреса]=Адрес;
КонецПроцедуры


//Катаев+ 09/10/14 Для РМТ передаем в качестве параметра и РНК для заполнения части реквизитов оттуда
//Процедура ЗаполнитьСтрокуПоНакладной(СтрокаТЧ,Накладная) Экспорт	
Процедура ЗаполнитьСтрокуПоНакладной(СтрокаТЧ,Накладная, РНК = Неопределено) Экспорт	
	Если Накладная=Неопределено ИЛИ НЕ ЗначениеЗаполнено(Накладная.Номер) Тогда Возврат КонецЕсли; 
	
	СтрокаТЧ.Накладная			=Накладная;	
	//крохин начало
	//Катаев+ 08/10/14
	//СтрокаТЧ.Менеджер = Накладная.Менеджер;
	Если ТипЗнч(СтрокаТЧ.Накладная) <> Тип("ДокументСсылка.РасходМатериаловИТары") Тогда
		СтрокаТЧ.Менеджер = Накладная.Менеджер;
	Иначе
		СтрокаТЧ.Менеджер = Накладная.Контрагент.Менеджер;
	КонецЕсли;
	//Катаев- 08/10/14
	//крохин конец
	//кухарь 12.09.14 начало
	//теперь будет браться не из реквизитов документа, а из регистра "РеквизитыДокументов"	
	ОбИКол=ПолучитьКоличествоИОбъемКоробовИзРегистра(Накладная);
	//кухарь 12.09.14 конец	
	СтрокаТЧ.СостояниеНакладной	=Накладная.СостояниеНакладной;
	Если (ТипЗнч(СтрокаТЧ.Накладная)=Тип("ДокументСсылка.РасходнаяНакладная")) ИЛИ (ТипЗнч(СтрокаТЧ.Накладная)=Тип("ДокументСсылка.Перемещение")) Тогда
		//Кухарь 14.11.19 начало
		//Тоже будем писать в ЗОГе, чтобы при необходимости изменений объёма паллет в закрытом периоде менять в ЗОГе, а не в накладных.
		СтрокаТЧ.ОбъемПаллет=Накладная.ОбъемПаллет;
		//Кухарь 14.11.19 конец 	
		
		Если СтрокаТЧ.СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке
			//крохин начало 16.02.2012
			//новое состояние
			ИЛИ  СтрокаТЧ.СостояниеНакладной=Перечисления.СостоянияНакладной.ДопОбработка 
			//крохин конец 16.02.2012
			ИЛИ  СтрокаТЧ.СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКПриемке 
			ИЛИ  СтрокаТЧ.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена
			ИЛИ  СтрокаТЧ.СостояниеНакладной=Перечисления.СостоянияНакладной.Принята Тогда
			//кухарь 12.09.14 начало
			//теперь будет браться не из реквизитов документа, а из регистра "РеквизитыДокументов"
			//СтрокаТЧ.Объем				=Накладная.ОбъемКоробов;
			если ОбИКол<>Неопределено тогда
				СтрокаТЧ.Объем=ОбИКол.ОбъемКоробов;
			иначе
				СтрокаТЧ.Объем=999;
			КонецЕсли;
			//кухарь 12.09.14 конец
		КонецЕсли;	
	ИначеЕсли (ТипЗнч(СтрокаТЧ.Накладная)=Тип("ДокументСсылка.ЗаявкаВТранспортныйОтдел")) Тогда
		//кухарь 12.09.14 начало
		//теперь будет браться не из реквизитов документа, а из регистра "РеквизитыДокументов"
		//СтрокаТЧ.Объем				=Накладная.ОбъемКоробов;
		если ОбИКол<>Неопределено тогда
			СтрокаТЧ.Объем=ОбИКол.ОбъемКоробов;
		иначе
			СтрокаТЧ.Объем=999;
		КонецЕсли;
		//кухарь 12.09.14 конец		
	КонецЕсли;
	
	//ЕстьРеквизитДокумента(ИмяРеквизита, МетаданныеДокумента) Экспорт
	МетаданныеНакладной			=Накладная.Метаданные();
	
	Если СтрокаТЧ.Объем=0 И ЕстьРеквизитДокумента("ОбъемДокумента",Накладная.Метаданные()) Тогда			
		СтрокаТЧ.Объем=Накладная.ОбъемДокумента;	
	КонецЕсли; 
	
	//Катаев+ 08/10/14
	//СтрокаТЧ.Количество         =Накладная.КоличествоДокумента;
	Если ТипЗнч(СтрокаТЧ.Накладная) <> Тип("ДокументСсылка.РасходМатериаловИТары") Тогда
		СтрокаТЧ.Количество         =Накладная.КоличествоДокумента;
	Иначе
		СтрокаТЧ.Количество         =Накладная.Товары.Итог("Количество");
	КонецЕсли;
	//Катаев- 08/10/14
	
	//кухарь 12.09.14 начало
	//теперь будет браться не из реквизитов документа, а из регистра "РеквизитыДокументов"	
	//СтрокаТЧ.КоличествоКоробок	=Накладная.КоличествоКоробок;
	если ОбИКол<>Неопределено тогда
		СтрокаТЧ.КоличествоКоробок=ОбИКол.КоличествоКоробок;
	иначе
		СтрокаТЧ.КоличествоКоробок=99999;
	КонецЕсли;	
	//кухарь 12.09.14 конец	
	
	
	
	СтрокаТЧ.Комментарий		=Накладная.Комментарий;	
	Попытка
		СтрокаТЧ.СуммаДокумента     =Накладная.СуммаДокумента;
	Исключение КонецПопытки;
	Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ДатаРегистрации) Тогда
		СтрокаТЧ.ДатаРегистрации=ТекущаяДата();	
	КонецЕсли;
	
	СтрокаТЧ.НомерНакладной		=Накладная.Номер;
	СтрокаТЧ.ДатаНакладной		=Накладная.Дата;		
	
	ВидНакладной				=МетаданныеНакладной.Имя;
	ПредставлениеВида			=""+МетаданныеНакладной;
	СтрокаТЧ.ВидНакладной		=ПредставлениеВида;	
	
	Если ЕстьРеквизитДокумента("Организация",МетаданныеНакладной) Тогда
		СтрокаТЧ.Организация=Накладная.Организация;	
	КонецЕсли; 
	
	Если 1=2 Тогда
		СтрокаТЧ=Накладные.Добавить();	
	КонецЕсли; 
	
	Если НачалоДня(Накладная.ДатаОтгрузки)<>НачалоДня(Дата) Тогда
		СтрокаТЧ.НеОтгружать=Истина;		
	КонецЕсли; 
	
	Если ВидНакладной="РасходнаяНакладная" Тогда	
		Если 1=2 Тогда
			Накладная=Документы.РасходнаяНакладная.СоздатьДокумент();		
		КонецЕсли; 
		
		  // Кухарь А.Ю. 01.03.2022 начало
		  //
		  СтрокаТЧ.КоличествоКомплектующих=Накладная.КоличествоКомплектующих;
		  // Кухарь А.Ю. 01.03.2022 конец
		  
		
		СтрокаТЧ.Отправитель			=Накладная.Склад;	
		СтрокаТЧ.АдресОтправитель   	=Накладная.Склад.Адрес;
		
		СтрокаТЧ.Получатель				=Накладная.Контрагент;			
		
		СтрокаТЧ.ТранспортнаяКомпанияПолучатель	=Накладная.ТранспортнаяКомпания;
		
		
