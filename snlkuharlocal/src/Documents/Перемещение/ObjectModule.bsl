//Валетов + 04,03,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-3158
Функция ПолучитьСтатусЗаказовКМПоНакланой(Накладная)
	Запрос = новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.Маркивведенывоборот)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная = &Накладная";
	Запрос.УстановитьПараметр("Накладная", Накладная);
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда 
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции
//Валетов-

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	Если ОбщегоНазначения_ПИ.ЭтоУзел_Склад() И (Отгружен=Перечисления.Отгружен.Резерв ИЛИ Отгружен=Перечисления.Отгружен.РезервТранзит) Тогда
		Возврат;	
	КонецЕсли;
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	ДвиженияПоРегистрам=Неопределено;
	РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
	Результат=РезультатПроведения["Результат"];
	
	Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда		
		Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));		
		ВывестиТрассировку(РезультатПроведения["ТОшибок"],?(Отказ,-2,Результат));			
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
	КонецЕсли; 
	
	СформироватьДвиженияПоЗабалансовымРегистрам();
	
	Если СкладПолучатель.ТипСклада=перечисления.ТипСклада.ПалетноеХранение  и НЕ обменДанными.Загрузка И СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена и ДатаПриемки <> дата(1,1,1) тогда //Добавил проверку на дату приемки.
		Партия=справочники.Партии.НайтиПоРеквизиту("ПНК",ССылка);
		Если Партия.Пустая() тогда
			Партия=Справочники.Партии.СоздатьЭлемент();
			партия.ПНК=ссылка;
			партия.Наименование=номер+"-"+Формат(дата,"ДФ=гг");
			партия.Записать();
			партия=партия.Ссылка;
		Конецесли;	                 
		
		для каждого ТекСтрокаТовары из товары  цикл
			
			Если ТекСтрокаТовары.Количество<>0 тогда
				ЛН = ПолучитьЛН(ТекСтрокаТовары.Номенклатура, ЭтотОбъект.Ссылка);
				Для Каждого текЛН Из ЛН Цикл
					Движение = Движения.Партии.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Партия = Партия;
					Движение.Период =ДатаПриемки ;
					Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
					Движение.Склад = СкладПолучатель;
					Движение.ШтВКоробе=0;
					Попытка
						Движение.Количество = Число(текЛН.Количество);
						Движение.Сумма = ТекСтрокаТовары.Всего*Число(текЛН.Количество)/ТекСтрокаТовары.Количество;
					Исключение
						Движение.Количество = 0;
						Движение.Сумма = 0;
					КонецПопытки;
					Движение.ЛН = текЛН.НомерЛН;
				КонецЦикла;
			Конецесли;
			
		Конеццикла;	
		Если ОбменДанными.Загрузка Тогда
			Движения.Партии.Записать();             
		КонецЕсли;
	Конецесли;
	
	Если Склад.ТипСклада=перечисления.ТипСклада.ПалетноеХранение тогда
		для каждого ТекСтрокаТовары из товары  цикл
			
			Если ТекСтрокаТовары.Количество<>0 тогда 
				ЛН = ПолучитьЛН_Возврат(ТекСтрокаТовары.Номенклатура, ДокОснование);
				Для Каждого текЛН Из ЛН Цикл
					Движение = Движения.Партии.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
					Движение.Партия = текЛН.Партия;
					Движение.Период =Дата ;
					Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
					Движение.Склад = Склад;
					Движение.ШтВКоробе=0;
					Попытка
						Движение.Количество = Число(текЛН.Количество);
						Движение.Сумма = ТекСтрокаТовары.Всего*Число(текЛН.Количество)/ТекСтрокаТовары.Количество;
					Исключение
						Движение.Количество = 0;
						Движение.Сумма = 0;
					КонецПопытки;
					Движение.ЛН = текЛН.НомерЛН;
				КонецЦикла;
			Конецесли;
		Конеццикла;	
		Если ОбменДанными.Загрузка Тогда
			Движения.Партии.Записать();             
		КонецЕсли;
	Конецесли;
	если не УчетСертификатов.ПровестиДокументПоСертификатнымОстаткам(ЭтотОбъект) тогда
		отказ=Истина;
	КонецЕсли;
	если ОбменДанными.Загрузка тогда
		Движения.СертификатныеОстатки.Записать();
	КонецЕсли;
	если ЭтоНовый() Тогда 
		ЗаписатьКоличествоИОбъемКоробовВРегистр (ЭтотОбъект.Ссылка,КоличествоКоробок,ОбъемКоробов);   
		//запись объёма коробов и количество коробок в регистр	
	иначе
		//входящие ПРМ пишем всегда
		если Склад.КодФизическогоУзла<>ПараметрыСеанса.ЭтотУзел.Код тогда
			если ПараметрыСеанса.ЭтотУзел.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
				ЗаписатьКоличествоИОбъемКоробовВРегистр (ЭтотОбъект.Ссылка,КоличествоКоробок,ОбъемКоробов);
			КонецЕсли;	
		Иначе 
			ЧСостояние=ПолучитьНомерСостоянияНакладной(СостояниеНакладной);
			если  ЧСостояние < 400 и ЧСостояние<>0 тогда
				если ПараметрыСеанса.ЭтотУзел.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
					ЗаписатьКоличествоИОбъемКоробовВРегистр (ЭтотОбъект.Ссылка,КоличествоКоробок,ОбъемКоробов);
				КонецЕсли;		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	//Для контроля что запись накладной прошла успешно
	если СостояниеКоррекции=Перечисления.СостоянияКоррекции.Утверждена и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение и не ОбменДанными.Загрузка тогда
		ЗаписатьЗначениеВРеквизитыРНКПНКПРМ("ДатаПоследнегоИзменения",ТекущаяДата(),Ссылка);
	КонецЕсли;

	Если ЗначениеЗаполнено(ЗаявкаНаПерепаковку) 
		И Склад.ТипСклада = Перечисления.ТипСклада.Перепаковка
		И СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.Принята Тогда 
		
		Если Товары.Количество() > 0 Тогда
			
			СтруктураОстатков = Документы.Перемещение.КонтрольПоРегиструСпайкиВПути(Ссылка, ЗаявкаНаПерепаковку);
			
			Если ТипЗнч(СтруктураОстатков.ТаблицаНехватки) = Тип("ТаблицаЗначений")
				И СтруктураОстатков.ТаблицаНехватки.Количество() = 0 Тогда
				
				Движения.СпайкиВПути.Записывать = Истина;
				Движения.СпайкиВПути.Очистить();
				Для Каждого ТекСтрокаТовары Из Товары Цикл
					Движение = Движения.СпайкиВПути.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
					Движение.Период = Дата;
					Движение.Регистратор = Ссылка;
					Движение.Заявка = ДокОснование;
					Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
					Движение.Количество = ТекСтрокаТовары.Количество;
				КонецЦикла;
				Движения.СпайкиВПути.Записать(Истина);
				
			Иначе	
				 СообщитьИзМодуля("Остатков Спаек в пути не хватает!!!!");
				 Отказ = Истина;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

	Если РезервироватьТовар И Отгружен = Перечисления.Отгружен.Отгружен
		И ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если Товары.Количество() > 0 Тогда
			Движения.РезервыТМЦ.Записывать = Истина;
			Движения.РезервыТМЦ.Очистить();
			Для Каждого ТекСтрокаТовары Из Товары Цикл
				Если ТекСтрокаТовары.Количество > 0 Тогда
					Движение = Движения.РезервыТМЦ.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = Дата;
					Движение.Регистратор = Ссылка;
					// Кухарь А.Ю. 12.01.2026 начало
					// HELP-8448  
					//Движение.Заказ = ДокОснование;
					Движение.Заказ = Ссылка;				
					// Кухарь А.Ю. 12.01.2026 конец		
					Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
					Движение.Количество = ТекСтрокаТовары.Количество;
					Движение.Склад = СкладПолучатель;
					Движение.Получатель = СкладПолучатель;
				КонецЕсли;
			КонецЦикла;
			Движения.РезервыТМЦ.Записать(Истина);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры       

//Катаев+ 29/01/14
Функция ПолучитьЛН(Номенклатура, Объект)
	Запрос = Новый Запрос;
	///Катаев+ 07/02/14 Запрос изменен в соответствии с новым занесение данных в регистр
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.ЗначениеРеквизита КАК Количество,
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.ИмяРеквизита КАК НомерЛН
	|ИЗ
	|	РегистрСведений.РеквизитыТЧ_Товары_РНКПНКПРМ КАК РеквизитыТЧ_Товары_РНКПНКПРМ
	|ГДЕ
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.Документ = &Документ
	|	И ПОДСТРОКА(РеквизитыТЧ_Товары_РНКПНКПРМ.ИмяРеквизита, 1, 9) = &ИмяРеквизита
	|	И РеквизитыТЧ_Товары_РНКПНКПРМ.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("Документ", Объект);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ИмяРеквизита", "Номер ЛН");
	Выборка = Запрос.Выполнить().Выбрать();
	//Катаев+ 07/02/14 Палетов с одной номенклатурой может быть несколько
	//Выборка.Следующий();
	//НомерЛН = Выборка.НомерЛН;
	НомерЛН = Новый ТаблицаЗначений;
	НомерЛН.Колонки.Добавить("НомерЛН");
	НомерЛН.Колонки.Добавить("Количество");
	Пока Выборка.Следующий() Цикл
		стр = НомерЛН.Добавить();
		стр.НомерЛН = Выборка.НомерЛН;
		стр.Количество = Выборка.Количество;
	КонецЦикла;
	//Катаев- 07/02/14
	Возврат НомерЛН;
КонецФункции
//Катаев- 29/01/14

//Катаев+ 10/02/14
Функция ПолучитьЛН_Возврат(Номенклатура, ДокОснование)
	Если ДокОснование = Неопределено Тогда
		НомерЛН = ПолучитьЛН(Номенклатура, ЭтотОбъект.Ссылка);
		НомерЛН.Колонки.Добавить("Партия");
		Для Каждого стр из НомерЛН Цикл
			//Определяем документ основание для ЛН
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	РеквизитыТЧ_Товары_РНКПНКПРМ.Документ
			|ИЗ
			|	РегистрСведений.РеквизитыТЧ_Товары_РНКПНКПРМ КАК РеквизитыТЧ_Товары_РНКПНКПРМ
			|ГДЕ
			|	РеквизитыТЧ_Товары_РНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита
			|	И РеквизитыТЧ_Товары_РНКПНКПРМ.Документ.СкладПолучатель.ТипСклада = &ТипСклада";
			Запрос.УстановитьПараметр("ТипСклада", Перечисления.ТипСклада.ПалетноеХранение);
			Запрос.УстановитьПараметр("ИмяРеквизита", стр.НомерЛН);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				стр.Партия = справочники.Партии.НайтиПоРеквизиту("ПНК",Выборка.Документ);
			КонецЕсли;
		КонецЦикла;
	Иначе
		НомерЛН = ПолучитьЛН(Номенклатура, ДокОснование);
		НомерЛН.Колонки.Добавить("Партия");
		Для Каждого стр из НомерЛН Цикл
			стр.Партия = справочники.Партии.НайтиПоРеквизиту("ПНК",ДокОснование);
		КонецЦикла;
	КонецЕсли;
	Возврат НомерЛН;
КонецФункции
