Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;	
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	////////////////////////////////////////////////////////////////////////
	//Кухарь А.Ю.  27.10.2024 начало
	//Временно закомментировал. Этот код 3 месяца провисел в хранилище и никому не понадобился	
	//Если ВидОснования = "Заказ" Тогда
	//	#Если Клиент Тогда
	//	ВызватьИсключение "Документ ПРМ на основании Заказа создать не получится!";
	//	#КонецЕсли
	//КонецЕсли;
	//Кухарь А.Ю.  27.10.2024 конец

	////////////////////////////////////////////////////////////////////////
	
	ВариантЗаполнения=Неопределено;
	#ЕСЛИ КЛИЕНТ ТОГДА
		ВариантЗаполнения=ВыбратьВариантЗаполнения();
	#КОНЕЦЕСЛИ
	Если ВариантЗаполнения=Неопределено Тогда
		ВариантЗаполнения="Целиком";
	КонецЕсли;	
	
	ДокОснование	= Основание;
	
	// Шворобей ВЮ 21.09.2023 ++
	ШаблонРеквизитов = "ИБ,СкладПолучатель,Менеджер,Организация,Склад,ТипЦен,ТипСкидок,Скидка";
	СписокРеквизитов = ЗаполнениеДокументов.СформироватьСтрокуРеквизитовПоШаблону(Основание, ШаблонРеквизитов);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание, СписокРеквизитов);
	
	//ИБ				= Основание.ИБ; // Отключил за ненадобностью
	
	//СкладПолучатель	= ПолучитьРеквизитОбъекта(ДокОснование,"СкладПолучатель");	
	//Менеджер 		= ПолучитьРеквизитОбъекта(ДокОснование,"Менеджер");
	//
	//Организация		= ПолучитьРеквизитОбъекта(ДокОснование,"Организация");		
	//Склад			= ПолучитьРеквизитОбъекта(ДокОснование,"Склад");
	//крохин начало
	//Группы товаров пересчитаем заново
	//ГруппыТоваров	= ПолучитьРеквизитОбъекта(ДокОснование,"ГруппыТоваров");
	//крохин конец
	
	//ТипЦен			= ПолучитьРеквизитОбъекта(ДокОснование,"ТипЦен");
	//ТипСкидок		= ПолучитьРеквизитОбъекта(ДокОснование,"ТипСкидок");
	//Скидка			= ПолучитьРеквизитОбъекта(ДокОснование,"Скидка");
	// Шворобей ВЮ 21.09.2023 ++
	
	Комментарий		= ""+ДокОснование.Метаданные()+" № " + ДокОснование.Номер + " от " + Формат(ДокОснование.Дата,"ДФ=dd.MM.yy");		
	
	Если ВидОснования="ПриходнаяНакладная" И НЕ ПолучитьПолномочиеПользователя("ВидимостьПриходныхЦен") Тогда
		ОбнулитьЦены=Истина;	
	Иначе
		ОбнулитьЦены=Ложь;	
	КонецЕсли;
	Для Каждого исхСтрокаТЧ Из ДокОснование.Товары Цикл
		СтрокаТЧ = Товары.Добавить();
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,исхСтрокаТЧ);	
		Если ВариантЗаполнения="НехватающиеЗаявка" Тогда
			СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.Заявка-исхСтрокаТЧ.Количество;
			СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
			СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
		ИначеЕсли ВариантЗаполнения="НехватающиеПодтверждение" Тогда
			СтрокаТЧ.ПодтвержденнаяЗаявка	=исхСтрокаТЧ.ПодтвержденнаяЗаявка-исхСтрокаТЧ.Количество;
			СтрокаТЧ.Количество				=СтрокаТЧ.ПодтвержденнаяЗаявка;				
			СтрокаТЧ.Заявка					=СтрокаТЧ.ПодтвержденнаяЗаявка;
		Иначе
			Если СтрокаТЧ.Заявка=0 Тогда
				СтрокаТЧ.Заявка	= СтрокаТЧ.Количество;			
			КонецЕсли;
			//Кухарь 26.12.17 начало
			//Не верно заполнялось
			//Если СтрокаТЧ.ПодтвержденнаяЗаявка=0 Тогда
			//	СтрокаТЧ.ПодтвержденнаяЗаявка=СтрокаТЧ.Количество;
			//КонецЕсли;
			СтрокаТЧ.ПодтвержденнаяЗаявка=СтрокаТЧ.Количество;			
			//Кухарь 26.12.17 конец
			
		КонецЕсли;
		//крохин начало 25.10.2011
		//новый реквизит
		СтрокаТЧ.ПодтвержденнаяЗаявкаПеремещения = СтрокаТЧ.Заявка;
		//крохин конец 25.10.2011
		
		Если ОбнулитьЦены Тогда
			СтрокаТЧ.Цена=0;		
			СтрокаТЧ.ЦенаБезСкидки=0;
		КонецЕсли;
		
		//Кухарь 16.11.18 начало
		//Расчёт себестоимости
		если ДокОснование.метаданные().имя="РасходнаяНакладная" тогда
			//Кухарь 16.11.18 конец	
			если ДокОснование.подразделение.код= "SSP-0150" тогда //Франчайзинг
				//Кухарь 05.12.18 начало
				//	СтрокаТЧ.Себестоимость=СтрокаТЧ.Цена;
				//Кухарь 24.12.18 начало
				//У сертификатов нет себестоимости
				//СтрокаТЧ.Себестоимость=СтрокаТЧ.Цена*СтрокаТЧ.Количество;		
				если СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.ПодарочныйСертификат тогда
					СтрокаТЧ.Себестоимость=СтрокаТЧ.Цена*СтрокаТЧ.Количество;
				иначе
					СтрокаТЧ.Себестоимость=0;
				КонецЕсли;
				//Кухарь 24.12.18 конец
				
				//Кухарь 05.12.18 конец
				//крохин 03.12.2018
				//без даты цены не считаются
				ЭтотОбъект.Дата = ТекущаяДата();
				ЭтотОбъект.Валюта = ДокОснование.валюта;
				ЭтотОбъект.Курс = ДокОснование.курс;
				//крохин конец 03.12.2018
				//Кухарь 06.12.18 начало
				//По просьбе Поповой Е.М.
				//СтрокаТЧ.Цена=0;
				//СтрокаТЧ.ЦенаБезСкидки=0;				
				//ЗаполнитьЦенуНоменклатурыТабЧасти(СтрокаТЧ, ЭтотОбъект);
				СтрокаТЧ.Цена=1;
				//Кухарь 13.12.18 начало
				//Чтобы был таки рубль
				//СтрокаТЧ.ЦенаБезСкидки=1;		
				СтрокаТЧ.ЦенаБезСкидки=2;
				СтрокаТЧ.Скидка=50;
				//Кухарь 13.12.18 конец
				
				//Кухарь 06.12.18 конец
			КонецЕсли;
			//Кухарь 23.10.18 конец
			//Кухарь 16.11.18 начало
			//Расчёт себестоимости
		КонецЕсли;
		//Кухарь 16.11.18 конец	
		
		Если СтрокаТЧ.Количество=0 Тогда
			Товары.Удалить(СтрокаТЧ);	
		Иначе
			РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект);
		КонецЕсли; 
	КонецЦикла;
	//крохин начало
	ГруппыТоваров	=ГруппыТоваровДокумента(ЭтотОбъект);
	Если Дата >= '20101001' Тогда
		СекторХранения = СекторХраненияДокумента(ЭтотОбъект);
	КонецЕсли;
	//крохин конец
	
	//Мессерле Паллетное хранение
	Если ВидОснования = "Перемещение" тогда
		Если Основание.СкладПолучатель.ТипСклада=перечисления.ТипСклада.ПалетноеХранение тогда
			времсклад=Основание.складполучатель;
			складполучатель=Основание.склад;
			Склад=времсклад;
		Конецесли;
	ИначеЕсли ВидОснования = "Заказ" Тогда // Шворобей ВЮ 21.09.2023 ++
		ШаблонРеквизитов = "КодВторичногоКонтрагента,НаименованиеВторичногоКонтрагента,НомерЗаказаВторичногоКонтрагента";
		СписокРеквизитов = ЗаполнениеДокументов.СформироватьСтрокуРеквизитовПоШаблону(Основание, ШаблонРеквизитов);
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание, СписокРеквизитов);
	КонецЕсли;
	// Шворобей ВЮ 21.09.2023 ++
	
	//крохин начало 09.09.2015
	Упаковка.Очистить();
	РедактированиеУпаковки = Ложь;
	//крохин конец 09.09.2015
	
	//крохин начало 10.02.2017
	СостояниеКоррекции = Неопределено;
	//крохин конец 10.02.2017
	//Кухарь 18.10.17 начало
	ОбъемПаллет=0;
	КоличествоПаллет=0;
	//Кухарь 18.10.17 конец
	
	//Кухарь 16.01.19 начало
