//++Данилова Е.В. 21.05.2026 MARK-3718 
Процедура СоздатьХКМ_к_ПРМ_Призаписи()
	
	ТекущееПодразделение=ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла();
	РеквизитыНакладной = ПолучитьРеквизитыШапки(Ссылка, "Склад,СкладПолучатель,Склад.КодФизическогоУзла,СкладПолучатель.КодФизическогоУзла
						|,Склад.КарантинЧЗ,СкладПолучатель.КарантинЧЗ", "Документ"); 
	
	Если РеквизитыНакладной.Склад_КарантинЧЗ = Истина 
		ИЛИ  РеквизитыНакладной.СкладПолучатель_КарантинЧЗ = Истина тогда
		РаботаСКарантином = Истина;
	иначе
		РаботаСКарантином = ложь;
	КонецЕсли; 
	
	ТребуетсяМаркировкаСДаты = ТребуетсяМаркировка и Дата>='20250101'; 
	 
	ЕстьХКМ = Документы.ХранилищеКодовМаркировки.ПроверитьНаличиеХКМ(Ссылка,Перечисления.ПланФакт.Факт,ТекущееПодразделение);
	Если  ТребуетсяМаркировкаСДаты
		И ЭтоУзелОтправителя() тогда 
		
		СостояниеРНКРГ = СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке 
		или  СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена;
		
		//НачСостояниеНеРГ = НачСостНакладной <> Перечисления.СостоянияНакладной.ГотоваКОтгрузке
		//и НачСостНакладной <> Перечисления.СостоянияНакладной.Отгружена; 
		
		НачСостояниеРГ = НачСостНакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке
		ИЛИ НачСостНакладной = Перечисления.СостоянияНакладной.Отгружена;
		
		НеСовпадаетКодУзла = РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла <> РеквизитыНакладной.Склад_КодФизическогоУзла;
		
		ЕстьЛН = ОбщегоНазначения_ПИ.ЕстьЛН(Ссылка);
		ЕстьЛНСмарками = ОбщегоНазначения_ПИ.ЕстьЛНСМаркировкой(Ссылка); 
		ТипУзлаСклад = ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад;
		ТипУзлаОфис=  ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение; 
		
		ПРМСНепромаркирТоваром = (ТипУзлаОфис 
		ИЛИ ТипУзлаСклад)
		И ЕстьЛН 
		И НЕ  ЕстьЛНСмарками;
		
		НетЛНСМарками = (ТипУзлаОфис 
		ИЛИ ТипУзлаСклад)
		И НЕ ЕстьЛН 
		И НЕ ЕстьЛНСмарками; 
		
		
		Если  НЕ НачСостояниеРГ 
			ИЛИ НачПроведен = Ложь
			ИЛИ Не естьХКМ Тогда 
			
			Если СостояниеРНКРГ Тогда   			
				
				Если ПРМСНепромаркирТоваром Тогда
					
					СообщитьИзМодуля("Нет ЛН с отсканированным маркированным товаром. ХКМ Создан не будет!");
					
				ИначеЕсли НЕ НетЛНСМарками 
					И   (НеСовпадаетКодУзла
					ИЛИ РаботаСКарантином) Тогда 
					
					РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_РНК(Ссылка);	
					если не РезультатРаботыСХКМ.Успешно тогда
						РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
						СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
						отказ=Истина;	
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли; 
			
		ИначеЕсли НачСостояниеРГ 
			И НЕ СостояниеРНКРГ Тогда
			
			РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Отменить_ХКМ_к_НАК(Ссылка,Перечисления.ПланФакт.Факт);				 		
			если не РезультатРаботыСХКМ.Успешно тогда
				РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
				СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				отказ=Истина;
			КонецЕсли;
			
			
		КонецЕсли;
		
	ИначеЕсли ТребуетсяМаркировкаСДаты
		И ЭтоУзелПолучателя() Тогда  	
		
		Если РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла=""  тогда
			РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла="SNL";
		КонецЕсли;
		Если РеквизитыНакладной.Склад_КодФизическогоУзла=""  тогда
			РеквизитыНакладной.Склад_КодФизическогоУзла="SNL";
		КонецЕсли;
		ТипУзлаУправляющий = ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение;
		ЕстьЛНСМаркировкой = ОбщегоНазначения_ПИ.ЕстьЛНСМаркировкой(Ссылка);
		СостояниеПринята = СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.Принята; 
		КодПолучателяЭтогоУзла = РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла <> РеквизитыНакладной.Склад_КодФизическогоУзла 		
		И РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла = ПараметрыСеанса.ЭтотУзел.Код; 
		
		Если СостояниеПринята
			И ЕстьЛНСМаркировкой 
			И НЕ ЕстьХКМ 
			И НЕ ТипУзлаУправляющий
			И КодПолучателяЭтогоУзла Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
			|ГДЕ
			|	ХранилищеКодовМаркировки.ДокОснование = &ДокОснование
			|	И ХранилищеКодовМаркировки.ПланФакт = &ПланФакт
			|	И ХранилищеКодовМаркировки.КодУзлаСоздания <> &КодЭтогоУзла";	
			Запрос.УстановитьПараметр("ДокОснование",	Ссылка);
			Запрос.УстановитьПараметр("ПланФакт",		Перечисления.ПланФакт.Факт);
			Запрос.УстановитьПараметр("КодЭтогоУзла",	ПараметрыСеанса.ЭтотУзел.Код);
			
			Выборка = Запрос.Выполнить().Выбрать();	
			Пока Выборка.Следующий() Цикл
				ДокОбъектХКМ = Выборка.Ссылка.ПолучитьОбъект();
				ДокОбъектХКМ.ПланФакт = Перечисления.ПланФакт.План;
				ДокОбъектХКМ.ОбменДанными.Загрузка	= Истина;
				
				ДокОбъектХКМ.Записать();		
			КонецЦикла;
			
			РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ПНК_Факт(Ссылка);	
			если не РезультатРаботыСХКМ.Успешно тогда
				РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
				СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				отказ=Истина;	
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

