Функция ПроверитьТоварНаНаличиеГТИН() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст  = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЗ.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ТЗ
	|ИЗ
	|	&Товары КАК ТЗ
	|ГДЕ
	|	ТЗ.Количество > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗ.Номенклатура КАК Номенклатура
	|ИЗ
	|	ТЗ КАК ТЗ
	|ГДЕ
	|	ТЗ.Номенклатура.ГТИН = """" 
	|	И ТЗ.Номенклатура.Родитель.ВидНоменклатуры = значение (Перечисление.ВидыНоменклаутры.Товар)";    
	запрос.УстановитьПараметр("Товары",Товары); 

	МассивНоменклатуры=Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");	
	Если МассивНоменклатуры.Количество()> 0 Тогда
		
		//Список номенклатуры сказали не нужен	
		//сообщить("Есть товары без GTIN!"+символы.ПС+СтрСоединить(МассивНоменклатуры,Символы.ПС)); 		 
		сообщить("Есть товары без GTIN!"); 
		
		возврат 1;
	КонецЕсли;	
	
	возврат 0;
	
КонецФункции
