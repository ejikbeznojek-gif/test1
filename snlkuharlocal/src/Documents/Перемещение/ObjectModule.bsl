Процедура УстановитьСостояниеДокументов(НовоеСостояниеДокументов,КодУзла = Неопределено,НЕКонтрольСФ = Неопределено) Экспорт
	Если СостояниеДокументов <> НовоеСостояниеДокументов Тогда
		НеВыгружатьДокумент = Истина;
		НеКонтролироватьЗапись=Истина;
		СостояниеДокументов=НовоеСостояниеДокументов;
		Записать();
		Если КодУзла = Неопределено Тогда
			СписокПолучателей = Новый СписокЗначений;
			Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				Если НЕ ПустаяСтрока(Склад.КодФизическогоУзла) Тогда
					СписокПолучателей.Добавить(Склад.КодФизическогоУзла);
				КонецЕсли;	
				
			Иначе
				
				Если Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					СписокПолучателей.Добавить("SNL");					
				КонецЕсли;
			КонецЕсли;
			НЗ = РегистрыСведений.СостояниеДокументов.СоздатьНаборЗаписей();
			НЗ.Отбор.КодУзла.Установить(ПараметрыСеанса.ЭтотУзел.Код,Истина);
			НЗ.Отбор.Документ.Установить(Ссылка,Истина);
			Для Каждого УзелИзСписка Из СписокПолучателей Цикл
				Запись = НЗ.Добавить();
				Запись.Регистратор = Ссылка;
				Запись.Состояние = НовоеСостояниеДокументов;
				Запись.Автор = ПараметрыСеанса.Пользователь;
				Запись.КодУзлаПолучателя = УзелИзСписка;
				Запись.Документ = Ссылка;
				запись.КодУзла =  ПараметрыСеанса.ЭтотУзел.Код;
				Запись.Отработана = Ложь;
			КонецЦикла;
			НЗ.Записать();
		КонецЕсли;
		
		НеКонтролироватьЗапись=Ложь;
		НеВыгружатьДокумент = Ложь;
	КонецЕсли;
	
	Если КодУзла <> Неопределено Тогда
		НЗ = РегистрыСведений.СостояниеДокументов.СоздатьНаборЗаписей();
		НЗ.Отбор.КодУзла.Установить(КодУзла,Истина);
		НЗ.Отбор.КодУзлаПолучателя.Установить(ПараметрыСеанса.ЭтотУзел.Код,Истина);
		НЗ.Отбор.Документ.Установить(Ссылка,Истина);
		НЗ.Записать();
	КонецЕсли;		
КонецПроцедуры
