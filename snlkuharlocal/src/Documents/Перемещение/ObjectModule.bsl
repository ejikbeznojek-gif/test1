Процедура ВернутьИзОтгружено ()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ первые 1
	|	ПланНабора.Ссылка
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	
	|ГДЕ
	|	ПланНабора.ДокОснование = &ДокОснование
	|	И ПланНабора.Проведен";
	запрос.УстановитьПараметр("ДокОснование",Ссылка);			
	Выборка = запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Не Ссылка.Пустая() Тогда
		ПланНабора = Выборка.Ссылка.получитьобъект();
		если ложь тогда ПланНабора=документы.ПланНабора.ПустаяСсылка().ПолучитьОбъект();КонецЕсли;
		НужноЗаписывать=ложь;
		Для каждого СтрТЧ из ПланНабора.тБрэндов цикл
			если СтрТЧ.Состояние<>СостояниеНакладной тогда
				НужноЗаписывать=Истина;
				СтрТЧ.Состояние=СостояниеНакладной;
				
			КонецЕсли;
		КонецЦикла;
		если НужноЗаписывать тогда
			// Кухарь А.Ю.  29.08.2022 начало
			//			ПланНабора.Записать();
			ПланНабора.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);			 
			// Кухарь А.Ю.  29.08.2022 конец

		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Проведен
	|	И ЗаданиеНабора.Накладная = &Накладная
	|	И ЗаданиеНабора.Дата >= &Дата";
	запрос.УстановитьПараметр("Накладная",Ссылка);		
	запрос.УстановитьПараметр("Дата",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());		
	запрос.УстановитьПараметр("СостояниеНакладной",СостояниеНакладной);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		ЗНБ = результат.Ссылка.получитьобъект();
		// Кухарь А.Ю. 24.04.2020 начало
		// есть краткий момент времени когда у ЗНБ уже проводки по резервам вернулись, 
		//а у РНК проводки по остаткам ещё не убрались.Если дату ЗНБ сделать чуть меньше, то трассировки не будет
		ЗНБ.дата=Дата-1;	 
		// Кухарь А.Ю. 24.04.2020 конец    		
		ЗНБ.СостояниеНакладной=СостояниеНакладной;
		// Кухарь А.Ю. 03.06.2021 начало
		// ЗНБ.записать(РежимЗаписиДокумента.Проведение);
		ЗНБ.ЗаписатьЗНББезКонтроляСостояний(РежимЗаписиДокумента.Проведение);		 
		// Кухарь А.Ю. 03.06.2021 конец

	КонецЦикла;
	
