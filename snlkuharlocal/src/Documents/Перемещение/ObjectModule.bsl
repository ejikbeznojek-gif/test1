Процедура ПриЗаписи(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НачСостНакладной<>СостояниеНакладной Тогда
		ЗаписатьИзменениеСостоянияНакладной(Ссылка,СостояниеНакладной);
	КонецЕсли;
	//крохин начало 07.10.2021
	//в ПРМ по складу РС франчайзинг тоже надо заполнять, для агентской номенклатуры
	Если Отгружен = Перечисления.Отгружен.Отгружен И Склад = Справочники.Склады.НайтиПоКоду("SSX-66") Тогда
		ЗаполнитьПервичнуюГруппуНоменклатуры(Товары.ВыгрузитьКолонку("Номенклатура"));
	КонецЕсли;
	//крохин конец 07.10.2021
	
	//++Данилова Е.В. 21.05.2026 MARK-3718 
	Если Не ОбменДанными.Загрузка 
		И Не Отказ Тогда
	
		СоздатьХКМ_к_ПРМ_Призаписи(); 
	
	КонецЕсли;
	//--Данилова Е.В. 21.05.2026 
	//-----------------------------------------------------------------------------
	//Нечаева 19,09,23 ++
	// сделаем запись в регистр, что это по веб заказам. после выгрузки на сайт проставим, что отгружен
	ЗаказССайта = ложь;
	ПРМСсайта = ложь;
	
	попытка
		ЗаказССайта = ПроцедурыОбменаССайтом.ОпределитьПризнакЗаказаССайта(ДокОснование.Ссылка);
		ПРМССайта = ПроцедурыОбменаССайтом.ОпределитьПризнакПРМССайта(Ссылка);
	исключение
	
	конецПопытки;
	
	// проверим еще, по складу - только для ПРМ, в котором склад-ОТПРАВИТЕЛЬ совпадает со складом в заказе
	Если ЗаказССайта и Не ПРМССайта  и (СостояниеНакладной= перечисления.СостоянияНакладной.Отгружена) Тогда
		Если  докОснование.Склад = ЭтотОбъект.Склад Тогда
			Успешно = ПроцедурыОбменаССайтом.УстановитьКатегориюДокумента(ЭтотОбъект.Ссылка, Справочники.КатегорииОбъектов.ЗаказСWEBСайта, Истина);
		конецЕсли;
	КонецЕсли;
	//нечаева 19,09,23 --
КонецПроцедуры

