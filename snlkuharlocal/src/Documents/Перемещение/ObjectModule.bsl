Функция РасчитатьКоличествоПаллет ()
	если склад.ТипСклада=Перечисления.ТипСклада.ПалетноеХранение или СкладПолучатель.ТипСклада=Перечисления.ТипСклада.ПалетноеХранение тогда
		Запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		             |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Паллета.Ссылка) КАК КоличествоПаллет
		             |ИЗ
		             |	Документ.Паллета КАК Паллета
		             |ГДЕ
		             |	Паллета.Дата >= &Дата
		             |	И Паллета.ЛистыНабора.Документ = &Документ
		             |	И Паллета.Проведен";
		запрос.УстановитьПараметр("Дата",Дата-90*86400);
		запрос.УстановитьПараметр("Документ",ссылка);
		результат=запрос.Выполнить().Выбрать();
		пока результат.Следующий() цикл
			возврат Результат.КоличествоПаллет;
		КонецЦикла;
		
	иначе 
		возврат КоличествоПаллет;
	КонецЕсли;
	
	возврат 0;
