// Функция - ВидПеремещения
//
// Параметры:
//  ДокСсылка	 - 	 ДокументСсылка.Перемещение 
// 
// Возвращаемое значение:
//   Строка - "Входящее", "Исходящее", "Виртуальное", "Транзитное"
//
Функция ВидПеремещения(ДокСсылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ	
	//Кто-то дописал))  https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9331
	|	Ссылка,   
	//Валетов -
	|	IsNull(Склад.ФизическийСклад.Подразделение, Склад.Подразделение)						КАК Подразделение_Отправитель, 
	|	IsNull(СкладПолучатель.ФизическийСклад.Подразделение, СкладПолучатель.Подразделение)	КАК Подразделение_Получатель	
	|ИЗ
	|	Документ.Перемещение
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";	
	
	Результат = "Битое";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		ПодразделениеТекущегоУзла = ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла();
		Если Выборка.Подразделение_Отправитель = Выборка.Подразделение_Получатель Тогда
			Результат = "Виртуальное";
		ИначеЕсли Выборка.Подразделение_Отправитель = ПодразделениеТекущегоУзла Тогда
			Результат = "Исходящее";					
		ИначеЕсли Выборка.Подразделение_Получатель = ПодразделениеТекущегоУзла Тогда
			Результат = "Входящее";
		Иначе
			Результат = "Транзитное";
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ВидПеремещения(ДокСсылка) Экспорт