
Функция КонтрольПоРегиструСпайкиВПути(ДокСсылка, ЗаявкаНаПерепаковку) Экспорт
	
	ИмяДокумента = ДокСсылка.Метаданные().Имя;
	
	СтруктураОстатков = Новый Структура("ТаблицаОстатков, ТаблицаНехватки");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.УстановитьПараметр("Дата", Новый Граница(ДокСсылка.Дата, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Заявка", ЗаявкаНаПерепаковку);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СпайкиВПутиОстатки.Номенклатура, Товары.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(Товары.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(СпайкиВПутиОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпайкиВПутиОстатки.КоличествоОстаток, 0) < ЕСТЬNULL(Товары.Количество, 0)
	|			ТОГДА ЕСТЬNULL(Товары.Количество, 0) - ЕСТЬNULL(СпайкиВПутиОстатки.КоличествоОстаток, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Нехватка
	|ИЗ
	|	Документ." + ИмяДокумента + ".Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СпайкиВПути.Остатки(&Дата, Заявка = &Заявка) КАК СпайкиВПутиОстатки
	|		ПО Товары.Номенклатура = СпайкиВПутиОстатки.Номенклатура
	|ГДЕ
	|	Товары.Ссылка = &ДокСсылка";
	
	// 	" + ИмяДокумента + "
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаЗапроса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТаблицаНехватки = ТаблицаЗапроса.СкопироватьКолонки();
	Для Каждого Стр ИЗ ТаблицаЗапроса Цикл
		Если Стр.Нехватка > 0 Тогда
			ЗаполнитьЗначенияСвойств(ТаблицаНехватки.Добавить(), Стр);
		КонецЕсли;
	КонецЦикла;
	
	СтруктураОстатков.Вставить("ТаблицаОстатков", ТаблицаЗапроса);
	СтруктураОстатков.Вставить("ТаблицаНехватки", ТаблицаНехватки);
	
	Возврат СтруктураОстатков;
	
КонецФункции

