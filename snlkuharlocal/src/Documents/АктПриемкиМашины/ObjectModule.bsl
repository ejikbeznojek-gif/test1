Функция СписокГруппНоменклатуры() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА Номенклатура.Родитель.Родитель.Брэнд = """" ТОГДА Номенклатура.Родитель.Родитель.Наименование
	|		ИНАЧЕ Номенклатура.Родитель.Родитель.Брэнд
	|	КОНЕЦ КАК Брэнд,
	|	Номенклатура.Родитель КАК Модель,
	|	Номенклатура.Родитель.Наименование КАК Модель_Представление
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	ПриходнаяНакладнаяТовары.Ссылка В(&СписокПНК)
	|УПОРЯДОЧИТЬ ПО	
	|	Модель_Представление,
	|	Брэнд
	|";
	
	Запрос.УстановитьПараметр("СписокПНК",СписокПНК.ВыгрузитьКолонку("ПриходнаяНакладная"));
	
	Список=Новый СписокЗначений;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Список.Добавить(Выборка.Модель,""+Выборка.Модель+" ("+Выборка.Брэнд+")");	
	КонецЦикла; 
	
	Возврат Список;
КонецФункции
 
