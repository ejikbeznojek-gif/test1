#Область ПоискНезакрытыхКоллективныхРабот

Функция ПоискНезакрытыхКоллективныхРаботПоДокументуОснования(ДокОснование) Экспорт
	
	МассивКР = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	Запрос.УстановитьПараметр("ДатаЗапретаРедактирование", ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КоллективныеРаботы.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КоллективныеРаботы КАК КоллективныеРаботы
	|ГДЕ
	|	КоллективныеРаботы.ДокОснование = &ДокОснование
	|	И КоллективныеРаботы.Проведен
	|	И НЕ КоллективныеРаботы.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Отгружена), ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Принята))
	|	И КоллективныеРаботы.Дата > &ДатаЗапретаРедактирование
	|	И КоллективныеРаботы.ДатаОкончанияРабот = ДАТАВРЕМЯ(1, 1, 1)";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		МассивКР.Добавить(Выборка.Ссылка);	
	КонецЦикла;
	
	Возврат МассивКР;
	
КонецФункции

#КонецОбласти
