#Область ПоискФизлицПоШтрихКодуГруппы

Функция ПоискФизлицПоШтрихКодуГруппы(ШтрихКод, ЧислоСотрудников = 1) Экспорт
	
	ЧислоСотрудников = ?(ЧислоСотрудников = 0, 1, ЧислоСотрудников);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ШтрихКод", ШтрихКод);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ФизическиеЛица.Ссылка КАК Группа
	|ПОМЕСТИТЬ вр_Группа
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	ФизическиеЛица.ЭтоГруппа
	|	И НЕ ФизическиеЛица.ПометкаУдаления
	|	И ФизическиеЛица.ШтрихКод = &ШтрихКод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ " + Строка(Окр(ЧислоСотрудников,0)) + "
	|	ФизическиеЛица.Ссылка КАК ФизЛицо
	|ИЗ
	|	вр_Группа КАК вр_Группа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО вр_Группа.Группа = ФизическиеЛица.Родитель
	|ГДЕ
	|	НЕ ФизическиеЛица.ЭтоГруппа
	|	И НЕ ФизическиеЛица.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ФизЛицо
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивФизлиц = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ФизЛицо");
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат МассивФизлиц;

КонецФункции

#КонецОбласти
