#Область Интерфейс

Функция НайтиКоличествоКомплектующих(тзТовары) Экспорт
	
	Если тзТовары.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзТовары", тзТовары);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(тзТовары.Количество КАК ЧИСЛО(10, 0)) КАК Количество
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	&тзТовары КАК тзТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Товары.Номенклатура КАК Номенклатура,
	|	вр_Товары.Номенклатура КАК Комплектующее,
	|	ЕСТЬNULL(вр_Товары.Количество, 0) КАК Количество
	|ПОМЕСТИТЬ вр_Таблица
	|ИЗ
	|	вр_Товары КАК вр_Товары
	|ГДЕ
	|	вр_Товары.Номенклатура.ВидКомплекта В (ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Товар), ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект), ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ПустаяСсылка))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Комплектующие.Ссылка,
	|	Комплектующие.Номенклатура,
	|	ЕСТЬNULL(Комплектующие.Количество, 0) * ЕСТЬNULL(вр_Товары.Количество, 0)
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
	|		ПО Комплектующие.Ссылка = вр_Товары.Номенклатура
	|ГДЕ
	|	Комплектующие.Ссылка.ВидКомплекта В (ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект))
	|	И Комплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(вр_Таблица.Количество) КАК Количество
	|ИЗ
	|	вр_Таблица КАК вр_Таблица";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Функция ПреобразоватьШтрихкодыУпаковокВТовары(тзШтрихкодыУпаковок) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("тзШтрихкодыУпаковок", тзШтрихкодыУпаковок);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзШтрихкодыУпаковок.ШтрихкодУпаковки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК Штрихкод
	|ПОМЕСТИТЬ вр_Штрихкоды
	|ИЗ
	|	&тзШтрихкодыУпаковок КАК тзШтрихкодыУпаковок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Штрихкоды.Штрихкод.Владелец КАК Номенклатура,
	|	вр_Штрихкоды.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ т_Штрихкоды
	|ИЗ
	|	вр_Штрихкоды КАК вр_Штрихкоды
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т_Штрихкоды.Номенклатура КАК Номенклатура,
	|	КОЛИЧЕСТВО(т_Штрихкоды.Штрихкод) КАК Количество
	|ИЗ
	|	т_Штрихкоды КАК т_Штрихкоды
	|
	|СГРУППИРОВАТЬ ПО
	|	т_Штрихкоды.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	тзВыборка = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат тзВыборка;
	
КонецФункции

