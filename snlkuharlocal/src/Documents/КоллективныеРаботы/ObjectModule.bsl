			если ДокОснование.Метаданные().Имя="РасходнаяНакладная" тогда
				для каждого СтрТЧ из Накладные цикл
					// Шворобей ВЮ 31.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5975
					Если ЕстьРеквизитДокумента("КоличествоПаллет", СтрТЧ.Накладная.Метаданные()) Тогда
						СтрТЧ.КоличествоПаллет=СтрТЧ.Накладная.КоличествоПаллет;
					КонецЕсли;
					Если ЕстьРеквизитДокумента("КоличествоКоробок", СтрТЧ.Накладная.Метаданные()) Тогда
						СтрТЧ.КоличествоКоробок=СтрТЧ.Накладная.КоличествоКоробок;
					КонецЕсли;
					// Шворобей ВЮ 31.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5975
				КонецЦикла;
			КонецЕсли;
			
			
			//Кухарь 05.02.19 начало
			//Перезапишем трудозатраты
