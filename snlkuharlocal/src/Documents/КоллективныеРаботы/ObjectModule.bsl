Процедура ПроверитьЗанятостьСотрудников()
	
	//Феданченков М.С. 02.07.2026 начало
	//Проблема 0000000162
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|   СтатусРаботыСотрудникаСрезПоследних.Сотрудник КАК Сотрудник
	|ИЗ
	|   РегистрСведений.СтатусРаботыСотрудника.СрезПоследних(
	|       ,
	|       ДокументОснования = &ДокументОснования
	|           И ДатаОкончания = &ДатаОкончания) КАК СтатусРаботыСотрудникаСрезПоследних";
	Запрос.УстановитьПараметр("ДокументОснования", Ссылка);
	Запрос.УстановитьПараметр("ДатаОкончания", Дата(1,1,1));
	
	ТаблицаСуществующих = Запрос.Выполнить().Выгрузить();
	
	СуществующиеСотрудники = Новый Соответствие;
	ЕстьСуществующие = ТаблицаСуществующих.Количество() > 0;
	
	Если ЕстьСуществующие Тогда
		Для каждого СтрСущ из ТаблицаСуществующих Цикл
			СуществующиеСотрудники.Вставить(СтрСущ.Сотрудник, Истина);
		КонецЦикла;
	КонецЕсли;
	//Феданченков М.С. 02.07.2026 конец
	
	//https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-105
	
	Если ДатаОкончанияРабот<>Дата(1,1,1) Тогда
		
		Для каждого стрСотр из Данные Цикл  
			//ADRESS.ИзменитьСтатусСотрудника(стрСотр.Сотрудник, Ссылка);
			//Феданченков М.С. 02.07.2026 начало
			//Проблема 0000000162
			Если СуществующиеСотрудники.Получить(стрСотр.Сотрудник) = Неопределено Тогда //
				ADRESS.ИзменитьСтатусСотрудника(стрСотр.Сотрудник, Ссылка);
			КонецЕсли;
			
			ADRESS.ЛокальноСнятьЗанятостьСотрудника(стрСотр.Сотрудник, Ссылка, "Коллективные работы - документ закрыт");
			//Феданченков М.С. 02.07.2026 конец
		КонецЦикла	
		
	Иначе
		
		Для каждого стрСотр из Данные Цикл  
			Если СтрСотр.ОкончаниеВыполнения<>Дата(1,1,1) Тогда
				//Феданченков М.С. 02.07.2026 начало
				//Проблема 0000000162
				Если СуществующиеСотрудники.Получить(стрСотр.Сотрудник) = Неопределено Тогда
					ADRESS.ИзменитьСтатусСотрудника(стрСотр.Сотрудник, Ссылка);
				КонецЕсли;
				//Феданченков М.С. 02.07.2026 конец
				
				ADRESS.ЛокальноСнятьЗанятостьСотрудника(стрСотр.Сотрудник, Ссылка, "Коллективные работы - документ закрыт"); 
			Иначе
				ADRESS.ИзменитьСтатусСотрудника(стрСотр.Сотрудник, Ссылка);
			КонецЕсли;
		КонецЦикла	
		
	КонецЕсли; 
	
	//https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-105
	//Феданченков М.С. 02.07.2026 начало
	//Проблема 0000000162
	Если ЕстьСуществующие Тогда
		ТекущиеСотрудники = Новый Соответствие;
		Для каждого стрСотр из Данные Цикл
			Если ЗначениеЗаполнено(стрСотр.Сотрудник) Тогда
				ТекущиеСотрудники.Вставить(стрСотр.Сотрудник, Истина);
			КонецЕсли;
		КонецЦикла;
		
		Для каждого СтрСущ из ТаблицаСуществующих Цикл
			Если ТекущиеСотрудники.Получить(СтрСущ.Сотрудник) = Неопределено Тогда
				ADRESS.ЛокальноСнятьЗанятостьСотрудника(СтрСущ.Сотрудник, Ссылка, "Изменен состав бригады");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//Феданченков М.С. 02.07.2026 конец
	
КОнецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если НЕ Отказ Тогда 
		
		//Тимофеев Ю.А. https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-105
		ПроверитьЗанятостьСотрудников();
		//Тимофеев Ю.А. //https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-105     	
		
		Если Состояние = Перечисления.СостоянияНакладной.Отгружена И ПоследняяРабота Тогда
			Для Каждого Стр ИЗ Накладные Цикл
				НакладнаяОбъект = Стр.Накладная.ПолучитьОбъект();
				Если НакладнаяОбъект <> Неопределено Тогда
					ФлагИзменять = Ложь;
					Если ЕстьРеквизитДокумента("СостояниеНакладной", Стр.Накладная.Метаданные()) Тогда
						// Кельманов А.В. - 0000000796 - 2026.06.09 {
						//НакладнаяОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеПаллетирования;
						Если ДокОснование.Метаданные().Имя = "ПриходнаяНакладная" Тогда   
							//Феданченков М.С. 02.07.2026 начало
							//Проблема 0000000173
							Если ЕстьРеквизитДокумента("ОбработаноЧЗ", Стр.Накладная.Метаданные()) И Не НакладнаяОбъект.ОбработаноЧЗ Тогда
								НакладнаяОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ;
							Иначе
								НакладнаяОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКПриемке;
							КонецЕсли;
							//Феданченков М.С. 02.07.2026 конец
						Иначе
							НакладнаяОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеПаллетирования;
						КонецЕсли;
						// Кельманов А.В. - 0000000796 - 2026.06.09 }
						ФлагИзменять = Истина;
					КонецЕсли;
					Если ФлагИзменять Тогда
						Попытка
							НакладнаяОбъект.Записать();
						Исключение
						       Сообщить(ОписаниеОшибки());
						КонецПопытки;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
