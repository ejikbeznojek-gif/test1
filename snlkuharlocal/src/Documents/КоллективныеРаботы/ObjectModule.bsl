Процедура ЗаписатьПланНабора (Накладная,Сотрудник)
	если ложь тогда накладная=Документы.РасходнаяНакладная.ПустаяСсылка();КонецЕсли;
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ первые 1
	|	ПланНабора.Ссылка
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	ПланНабора.Проведен
	|	И ПланНабора.Дата >= &Дата
	|	И ПланНабора.Накладная = &Накладная";
	запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
	запрос.УстановитьПараметр("Накладная",Накладная);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		ПланНабораОбъект=результат.ссылка.получитьобъект();
		если ложь тогда ПланНабораОбъект=Документы.ПланНабора.ПустаяСсылка().ПолучитьОбъект();КонецЕсли;
		
		если Состояние=Перечисления.СостоянияНакладной.Отгружена  или  Состояние=Перечисления.СостоянияНакладной.Принята тогда
			Для каждого СтрТЧ из ПланНабораОбъект.тБрэндов цикл
				если СтрТЧ.Состояние<>Перечисления.СостоянияНакладной.ГотоваКОтгрузке тогда
					СтрТЧ.ТермоусадкаЗакончена=Истина;
					СтрТЧ.ОкончаниеТермоусадки=ДатаОкончанияРабот;
					СтрТЧ.Состояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
					если не ЗначениеЗаполнено(СтрТЧ.Термоусадчик) тогда
						СтрТЧ.Термоусадчик=Сотрудник;
					КонецЕсли;
				иначе 
					Прервать;
				КонецЕсли;
			КонецЦикла;
			ПланНабораОбъект.Записать(РежимЗаписиДокумента.Проведение);
		иначе
			Для каждого  СтрТЧ из ПланНабораОбъект.тБрэндов  цикл
				если  СтрТЧ.Состояние<>Перечисления.СостоянияНакладной.Термоусадка и СтрТЧ.Состояние<>Перечисления.СостоянияНакладной.ГотоваКОтгрузке тогда
					СтрТЧ.НачалоТермоусадки=ДатаНачалаРабот;
					СтрТЧ.Термоусадчик=Сотрудник;
					СтрТЧ.Состояние=Перечисления.СостоянияНакладной.Термоусадка;
				иначе 
					Прервать;
				КонецЕсли;
			КонецЦикла;	
			ПланНабораОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры
