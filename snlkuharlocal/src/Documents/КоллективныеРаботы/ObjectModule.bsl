// Шворобей ВЮ 22.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5976
#Область СтандартныеОбработчики

Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;	
	
	ДокОснование = Основание;
	Дата = ТекущаяДатаСеанса();
	Состояние = Перечисления.СостоянияНакладной.ВРаботе;
	
	//Кухарь 25.09.19 начало
	Если Основание = Неопределено тогда
		Основание = Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	//Кухарь 25.09.19 конец
	
	Если Накладные.Найти(Основание) = Неопределено Тогда
		
		СтрТЧ = Накладные.Добавить();
		СтрТЧ.Накладная = Основание;
		
		МетаданныеДокумента = СтрТЧ.Накладная.Метаданные();
		
		Если МетаданныеДокумента.Имя = "ПриходнаяНакладная" тогда				
			СтрТЧ.КоличествоКоробок=Основание.КоличествоКоробок;
			СтрТЧ.КоличествоШтук=Основание.КоличествоДокумента;
			СтрТЧ.КоличествоСтрок=основание.Товары.Количество();
			
		ИначеЕсли МетаданныеДокумента.Имя = "ЛистЗагрузки" тогда
			ТЗСтрок=Основание.Заявка.Выгрузить();
			ТЗСтрок.Свернуть("ПунктДоставки");
			КоличествоСтрокДокОснования=ТЗСтрок.Количество();
			
			
			СтрТЧ.КоличествоКоробок=Основание.Заявка.Итог("КоличествоКоробок");
			СтрТЧ.КоличествоШтук=0;
			СтрТЧ.КоличествоСтрок=КоличествоСтрокДокОснования;
		ИначеЕсли МетаданныеДокумента.Имя = "РасходнаяНакладная" тогда
			СтрТЧ.КоличествоКоробок=Основание.КоличествоКоробок;
			СтрТЧ.КоличествоШтук=Основание.КоличествоДокумента;
			СтрТЧ.КоличествоСтрок=основание.Товары.Количество();
			СтрТЧ.КоличествоПаллет=Основание.количествопаллет;
			
		КонецЕсли;
		
		Если ЕстьТабЧастьДокумента("Товары", МетаданныеДокумента) Тогда
			тзТовары = СтрТЧ.Накладная.Товары.Выгрузить();
		ИначеЕсли ЕстьТабЧастьДокумента("ШтрихкодыУпаковок", МетаданныеДокумента) Тогда
			тзШтрихкодыУпаковок = СтрТЧ.Накладная.ШтрихкодыУпаковок.Выгрузить();
			тзТовары = Документы.КоллективныеРаботы.ПреобразоватьШтрихкодыУпаковокВТовары(тзШтрихкодыУпаковок);
		КонецЕсли;
	
		СтрТЧ.КоличествоШтук = Документы.КоллективныеРаботы.НайтиКоличествоКомплектующих(тзТовары); 
		
	КонецЕсли;
	
	КоличествоШтук = Накладные.Итог("КоличествоШтук");
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	#Область ПроверкаОбязательныхРеквизитов
	
	Если ДополнительныеСвойства.Свойство("НеЗаполнятьВидРаботы") Тогда
		ОбязательныеРеквизитыШапки = Новый Структура("Состояние, ДатаНачалаРабот");
		ОбязательныеРеквизитыТЧ_Данные = Новый Структура("Сотрудник, НачалоВыполнения");
	Иначе
		ОбязательныеРеквизитыШапки = Новый Структура("Состояние, ВидРаботы, ДатаНачалаРабот");
		ОбязательныеРеквизитыТЧ_Данные = Новый Структура("ВидРаботы, Сотрудник, НачалоВыполнения");
	КонецЕсли;
	
	ПроверитьЗаполнениеШапкиДокумента(ЭтотОбъект, ОбязательныеРеквизитыШапки, Отказ, "Не заполнены реквизиты Шапки документа!!!");
	//Валетов + 28,08,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6777
	//Пока оставим проверку только на количество...
	
	//ОбязательныеРеквизитыТЧ_Накладные = Новый Структура("Накладная, КоличествоШтук");
	ОбязательныеРеквизитыТЧ_Накладные = Новый Структура("КоличествоШтук");   
	//Валетов-
	ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Накладные", ОбязательныеРеквизитыТЧ_Накладные, Отказ, "Не заполнены реквизиты ТЧ <Накладные>!");
	
	ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Данные", ОбязательныеРеквизитыТЧ_Данные, Отказ, "Не заполнены реквизиты ТЧ <Данные>!");
	
	// Кельманов А.В. - SNL-189 - 2026.04.29 {
	// Феданченков М.С.-HELP-9906 - 25.05.2026 начало  
	// Феданченков М.С.-HELP-9928 - 27.05.2026 начало
	//Если ДокОснование.Метаданные().Имя <> "ПриходнаяНакладная" И ЗначениеЗаполнено(ДатаОкончанияРабот) И Состояние <> Перечисления.СостоянияНакладной.Отгружена Тогда
	Если ЗначениеЗаполнено(ДокОснование) И ДокОснование.Метаданные().Имя <> "ПриходнаяНакладная" И ЗначениеЗаполнено(ДатаОкончанияРабот) И Состояние <> Перечисления.СостоянияНакладной.Отгружена Тогда
	// Феданченков М.С.-HELP-9928 - 27.05.2026 конец
	// Феданченков М.С. 25.05.2026 конец	
		Состояние = Перечисления.СостоянияНакладной.Отгружена;
	КонецЕсли;
	// Кельманов А.В. - SNL-189 - 2026.04.29 }
	
	Если Состояние = Перечисления.СостоянияНакладной.Отгружена Тогда
		//Валетов + 28,08,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6807
		//Если при сканировании кода окончания работ не заполнилась дата, поставим её текущей.
		Если Не ЗначениеЗаполнено(ДатаОкончанияРабот) Тогда
			ДатаОкончанияРабот = ТекущаяДата();
		КонецЕсли;
		//Валетов-
		
		// Кельманов А.В. - SNL-189 - 2026.04.24 {
		Для Каждого СтрДанных Из Данные Цикл
			
			Если Не ЗначениеЗаполнено(СтрДанных.ОкончаниеВыполнения) Тогда
				
				СтрДанных.ОкончаниеВыполнения = ДатаОкончанияРабот;
					
			КонецЕсли;
			
		КонецЦикла;
		// Кельманов А.В. - SNL-189 - 2026.04.24 }
		
		ОбязательныеРеквизитыШапки = Новый Структура("ДатаОкончанияРабот");
		ПроверитьЗаполнениеШапкиДокумента(ЭтотОбъект, ОбязательныеРеквизитыШапки, Отказ, "Не заполнены реквизиты Шапки документа!!!");
		
		ОбязательныеРеквизитыТЧ_Данные = Новый Структура("ОкончаниеВыполнения");
		ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Данные", ОбязательныеРеквизитыТЧ_Данные, Отказ, "Не заполнены реквизиты ТЧ <Данные>!");
		
	КонецЕсли;
	
	#КонецОбласти
	
	Если ВидРаботы<>Справочники.ВидыВыполняемыхРабот.ВыгрузкаИзАвтомобиля и Состояние<>Перечисления.СостоянияНакладной.Отгружена и Состояние<>Перечисления.СостоянияНакладной.Принята и Данные.Количество()>0  тогда
		МассСтрок=Данные.НайтиСтроки(новый Структура("ОкончаниеВыполнения",ПустаяДата()));
		если МассСтрок.Количество()=0 тогда
			
			
			//Кухарь 23.01.19 начало
			//Иногда одни доп обработчики могут начать и закончить раньше чем начнут другие
			если ВидРаботы=Справочники.ВидыВыполняемыхРабот.ДопОбработка  тогда
				запрос=новый запрос;
				запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
				|	ПланНаборатБрэндов.Наборщик
				|ИЗ
				|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
				|ГДЕ
				|	ПланНаборатБрэндов.Ссылка.Проведен
				|	И ПланНаборатБрэндов.Ссылка.Дата >= &Дата
				|	И (НЕ ПланНаборатБрэндов.ДопОбработкаЗакончена)
				|	И ПланНаборатБрэндов.Ссылка.Накладная = &Накладная";
				запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
				запрос.УстановитьПараметр("Накладная",ДокОснование);
				КолСтрок=запрос.Выполнить().Выгрузить().Количество();						
				//если Накладные.Получить(0).Накладная.СостояниеНакладной=Перечисления.СостоянияНакладной.ДопОбработка или Накладные.Получить(0).Накладная.СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеДопОбработки тогда
				если КолСтрок>0 тогда
					НельзяЗаканчивать=Истина
				КонецЕсли;
			КонецЕсли;
			если НельзяЗаканчивать<>Истина тогда
				//Кухарь 23.01.19 Конец
				
				ВсёЗакончили=Истина;
				Состояние=Перечисления.СостоянияНакладной.Отгружена;
				ДатаОкончанияРабот=ТекущаяДата();
				//Кухарь 23.01.19 начало
				//Иногда одни доп обработчики могут начать и закончить раньше чем начнут другие
			КонецЕсли;
			//Кухарь 23.01.19 Конец
			
		КонецЕсли;		
	КонецЕсли;
	
	// Кухарь А.Ю. 28.01.2020 начало
	//  чтобы не было неопределено
	для каждого СтрТЧ из Накладные цикл
		если СтрТЧ.Накладная =Неопределено тогда
			СтрТЧ.Накладная=документы.РасходнаяНакладная.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла; 
	// Кухарь А.Ю. 28.01.2020 конец
	
	
	
	
	//Кухарь 30.01.19 начало	
	//если ДокОснование=Неопределено и Накладные.Количество()>0 тогда
	если (ДокОснование=Неопределено или СокрЛП(ДокОснование.номер)="") и Накладные.Количество()>0 тогда
		//Кухарь 30.01.19 конец	
		//Кухарь 25.06.19 начало
		//Чтобы не было ошибок при проверке метаданных
		//ДокОснование=Накладные.Получить(0).Накладная;
		ДокОснование=?(Накладные.Получить(0).Накладная=Неопределено,Документы.РасходнаяНакладная.ПустаяСсылка(),Накладные.Получить(0).Накладная);
		//Кухарь 25.06.19 конец		
	КонецЕсли;
	
	если Накладные.Количество()=0 и ДокОснование<>Неопределено тогда
		СтрТЧ=Накладные.Добавить();
		СтрТЧ.Накладная=ДокОснование;
		Если ДокОснование.метаданные().имя="ПриходнаяНакладная" тогда				
			СтрТЧ.КоличествоКоробок=ДокОснование.КоличествоКоробок;
			СтрТЧ.КоличествоШтук=ДокОснование.КоличествоДокумента;
			СтрТЧ.КоличествоСтрок=ДокОснование.Товары.Количество();
		ИначеЕсли ДокОснование.метаданные().имя="ЛистЗагрузки" тогда
			ТЗСтрок=ДокОснование.Заявка.Выгрузить();
			ТЗСтрок.Свернуть("ПунктДоставки");
			КоличествоСтрокДокОснования=ТЗСтрок.Количество();
			
			
			СтрТЧ.КоличествоКоробок=ДокОснование.Заявка.Итог("КоличествоКоробок");
			СтрТЧ.КоличествоШтук=0;
			СтрТЧ.КоличествоСтрок=КоличествоСтрокДокОснования;
		ИначеЕсли ДокОснование.метаданные().имя="РасходнаяНакладная" тогда
			СтрТЧ.КоличествоКоробок=ДокОснование.КоличествоКоробок;
			СтрТЧ.КоличествоШтук=ДокОснование.КоличествоДокумента;
			СтрТЧ.КоличествоСтрок=ДокОснование.Товары.Количество();
			СтрТЧ.КоличествоПаллет=ДокОснование.количествопаллет;
			
			
		КонецЕсли;
		
	КонецЕсли;
	
	
	
	ПаузаВРаботе=?(ПриостановкаРабот=ПустаяДата(),0,ВозобновлениеРабот-ПриостановкаРабот);
	ВремяПростояДоВыгрузки=?(ДатаНачалаРабот=ПустаяДата(),0,ДатаНачалаРабот-ДатаПрибытия);
	ВремяРаботы=?(ДатаОкончанияРабот=ПустаяДата(),0,ДатаОкончанияРабот-ДатаНачалаРабот);
	ВремяРаботыЧистое=ВремяРаботы-ПаузаВРаботе;	
	ВремяПребыванияОбщее=?(ДатаУбытия=ПустаяДата(),0,ДатаУбытия-ДатаПрибытия);
	
	если ДатаУбытия<ДатаПрибытия и ДатаУбытия<>ПустаяДата() тогда
		Сообщить("Дата убытия не может быть раньше даты прибытия");
		отказ=Истина;
	КонецЕсли;
	если ДатаОкончанияРабот<ДатаНачалаРабот и ДатаОкончанияРабот<>ПустаяДата() тогда
		Сообщить("Дата окончания работ не может быть раньше даты начала работ");
		отказ=Истина;
	КонецЕсли;
	
	//Кухарь 08.08.18 начало
	//Чтобы исключить дурацкие ошибки
	если ВидРаботы=Справочники.ВидыВыполняемыхРабот.ВыгрузкаИзАвтомобиля тогда
		если не ЗначениеЗаполнено(ДатаПрибытия) тогда
			Сообщить("Заполните дату прибытия");
			отказ=Истина;
		ИначеЕсли  ДатаПрибытия>ДатаНачалаРабот и ЗначениеЗаполнено(ДатаНачалаРабот) тогда
			Сообщить("Дата прибытия не может быть позже даты начала работ");
			отказ=Истина;
		КонецЕсли;
	КонецЕсли;
	//Кухарь 08.08.18 конец
	
	если ЭтоНовый() и не ОбменДанными.Загрузка тогда
		дата=ТекущаяДата();
		Состояние=Перечисления.СостоянияНакладной.ВРаботе;
		если автор=Справочники.Пользователи.ПустаяСсылка() тогда
			Автор=ПараметрыСеанса.Пользователь;
		КонецЕсли;
	КонецЕсли;

	СтрокаОшибок = "";
	
	Если Состояние = Перечисления.СостоянияНакладной.Принята Или Состояние = Перечисления.СостоянияНакладной.Отгружена Тогда

		КоличествоСотрудников = Данные.Количество();

		//Кухарь 17.10.19 начало
		Если Не ЗначениеЗаполнено(ДатаОкончанияРабот) Тогда
			ДатаОкончанияРабот = ТекущаяДата();
		КонецЕсли;
		//Кухарь 17.10.19 конец		

		Для Каждого СтрДанных Из Данные Цикл
			
