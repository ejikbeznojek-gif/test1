Функция ОбновитьЦеныПоПравилам (СтруктураПараметров = Неопределено) Экспорт 

	ЦеныОбновлены = ложь;       
	СтруктураТиповЦен = Неопределено;     
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,Новый Массив);
	
	если ТипЗнч(СтруктураПараметров) = Тип("Структура") тогда 
		Если СтруктураПараметров.Свойство("РасчитатьПоПодразделению") и   СтруктураПараметров.РасчитатьПоПодразделению = Истина тогда 
			СтруктураТиповЦен = Документы.ПланПродаж.ПолучитьСтруктуруРекомендуемыхТиповЦенПоПодразделению(Подразделение);      
			если не СтруктураТиповЦен.Успех тогда   
				МаркировкаКС.ДобавитьОшибки(СтруктураВозврата.Ошибки,СтруктураТиповЦен.Ошибки);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	          
	
	
	если СтруктураВозврата.Ошибки.количество() = 0 тогда
		если СтруктураТиповЦен = Неопределено тогда
			СтруктураТиповЦен = ПолучитьСтруктуруРекомендуемыхТиповЦенПоТекущемуОбъекту();
		иначе 
			Скидка = СтруктураТиповЦен.Скидка;	
			ТипЦен = СтруктураТиповЦен.ТипЦен;	
		КонецЕсли; 
		

		
		если СтруктураТиповЦен.ИспользоватьМатрицуДляПлановПродаж тогда
			Результат = ОбновитьЦеныПоМатрицам(СтруктураТиповЦен);
		Иначе
			Результат = ОбновитьЦеныПоТипуЦен(СтруктураТиповЦен);
		КонецЕсли; 
		если не Результат.Успех тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата.Ошибки,Результат.Ошибки); 
		КонецЕсли;
	КонецЕсли; 
	
	если СтруктураВозврата.Ошибки.количество() > 0 тогда  
		СтруктураВозврата.Успех = ложь;
	КонецЕсли;

	возврат СтруктураВозврата;
	
КонецФункции

Функция ПолучитьСтруктуруРекомендуемыхТиповЦенПоТекущемуОбъекту () 

	СтруктураВозврата = Документы.ПланПродаж.СоздатьСтруктуруВозвратаРекомендуемыхТиповЦен();	
	ЗаполнитьЗначенияСвойств(СтруктураВозврата,ЭтотОбъект,"ТипЦен,Скидка");    
	если не ЗначениеЗаполнено(СтруктураВозврата.ТипЦен) тогда 
		СтруктураВозврата.ИспользоватьМатрицуДляПлановПродаж = Истина;
	КонецЕсли;
	Возврат СтруктураВозврата;
		
КонецФункции       

Функция ОбновитьЦеныПоМатрицам(СтруктураТиповЦен)
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина, новый Массив);		
	СтруктураОтключаемыхФильтров = новый Структура("ПунктДоставки,Договор,ПостояннаяАкция",Истина,Истина,Истина);      
	ДатаЦены = ?(ЗначениеЗаполнено(ДатаРасчетаЦенПоМатрице),ДатаРасчетаЦенПоМатрице,Дата);
	
	МассивНоменклатуры = ПолучитьМассивНоменклатурыПланаРазвернуто();
	СтруктураДокумента = новый Структура("Номенклатура,ПунктДоставки,Контрагент,Дата,Договор,ПостояннаяАкция",
	МассивНоменклатуры,Справочники.ПунктыДоставки.ПустаяСсылка(),Контрагент,ДатаЦены,Справочники.Договоры.ПустаяСсылка(),ложь);       
	
	
	если МатрицыДляРасчетаЦен.Количество() = 0 тогда
		ТаблицаМатриц = ПолучитьТаблицуМатрицСрезПоследних(СтруктураДокумента,Неопределено,МассивНоменклатуры,СтруктураОтключаемыхФильтров);    
	иначе 
		ТаблицаМатриц = ПолучитьТаблицуМатрицИзМатрицДляРасчётаЦен(МассивНоменклатуры);    
	КонецЕсли;

	Если Детальный тогда
		ИмяКолонкиПоиска = "Номенклатура";
	Иначе
		ИмяКолонкиПоиска = "Модель";   
		ТаблицаМатриц.Свернуть("Модель,Цена")
	КонецЕсли;
	
	
	Для каждого СтрокаТЧ из Состав цикл    
		СтрокаТЗ = ТаблицаМатриц.Найти(СтрокаТЧ.Номенклатура,ИмяКолонкиПоиска);
		если СтрокаТЗ = Неопределено тогда 
			СтруктураВозврата.Ошибки.Добавить("Не найдена цена в матрице по "+СтрокаТЧ.Номенклатура);     
			Продолжить;
		КонецЕсли; 
		
		СтрокаТЧ.ЦенаБезСкидки=СтрокаТЗ.Цена;
		СтрокаТЧ.Цена=Макс(СтрокаТЗ.Цена*(1-СтруктураТиповЦен.Скидка/100),0);
		РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);
		
	КонецЦикла;        
	
	если СтруктураВозврата.Ошибки.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь;
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции

Функция ОбновитьЦеныПоТипуЦен(СтруктураТиповЦен) 
	
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина, новый Массив);
	
	если не ЗначениеЗаполнено(СтруктураТиповЦен.ТипЦен) тогда    
		СтруктураВозврата.Ошибки.Добавить("Не заполнен тип цен");  
	иначе	
		Для каждого СтрокаТЧ из Состав цикл   
			ЦенаПоПрайсу=ПолучитьЦенуНоменклатуры(СтрокаТЧ.Модель,,СтруктураТиповЦен.ТипЦен,Валюта,Курс,Дата);
			если не ЗначениеЗаполнено(ЦенаПоПрайсу) тогда  
				СтруктураВозврата.Ошибки.Добавить("Не найдена цена в прайсах по "+СтрокаТЧ.Модель);  	
			КонецЕсли;	                                 
			СтрокаТЧ.ЦенаБезСкидки=ЦенаПоПрайсу;
			СтрокаТЧ.Цена=Макс(ЦенаПоПрайсу*(1-СтруктураТиповЦен.Скидка/100),0);
			
			РассчитатьСуммуТабЧасти(СтрокаТЧ,ЭтотОбъект);		
		КонецЦикла;
	КонецЕсли;
	
	если СтруктураВозврата.Ошибки.Количество()>0 тогда
		СтруктураВозврата.Успех = ложь;
	КонецЕсли;
	
	возврат СтруктураВозврата;    
	
	
КонецФункции

Функция ПолучитьМассивНоменклатурыПланаРазвернуто () 
	Запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В ИЕРАРХИИ(&МассивНоменклатуры)";
	запрос.УстановитьПараметр("МассивНоменклатуры",Состав.ВыгрузитьКолонку("Номенклатура"));      
	Возврат запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПолучитьТаблицуМатрицИзМатрицДляРасчётаЦен (МассивНоменклатуры)
	Запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.Номенклатура.Родитель КАК Модель,
	|	МатрицаТовары.Цена КАК Цена
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка В(&МассивМатриц)
	|	И МатрицаТовары.Номенклатура В ИЕРАРХИИ(&МассивНоменклатуры)";
	запрос.УстановитьПараметр("МассивМатриц",МатрицыДляРасчетаЦен.ВыгрузитьКолонку("Матрица"));   
	запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);   	 
	возврат запрос.Выполнить().Выгрузить();
КонецФункции
