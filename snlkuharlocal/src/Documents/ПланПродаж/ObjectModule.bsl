Процедура ДвиженияПоТЧДетальные(Знач ВсегоДней, Знач КоэффКурса, Знач РезультатПоДням, ИмяТЧ, ИмяРНакопления)  	

	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланПродажКомплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(ПланПродажКомплектующие.Количество) КАК Количество, 
	|	СУММА(ПланПродажКомплектующие.КоличествоОстаток) КАК КоличествоОстаток,
	|	ПланПродажКомплектующие.Коэффициент КАК Коэффициент,
	|	МАКСИМУМ(ПланПродажКомплектующие.Цена) КАК Цена,
	|	СУММА(ПланПродажКомплектующие.Сумма) КАК Сумма,
	|	ПланПродажКомплектующие.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ПланПродажКомплектующие.НДС) КАК НДС
	|ИЗ
	|	Документ.ПланПродаж.%ИмяТЧ% КАК ПланПродажКомплектующие
	|ГДЕ
	|	ПланПродажКомплектующие.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланПродажКомплектующие.Номенклатура,
	|	ПланПродажКомплектующие.СтавкаНДС,
	|	ПланПродажКомплектующие.Коэффициент"; 
	Запрос.УстановитьПараметр("ссылка",ссылка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяТЧ%",ИмяТЧ);
	СтрокаТЧ = Запрос.Выполнить().Выбрать(); 
	Пока СтрокаТЧ.Следующий() Цикл	
		ИтогоРасчКол=0;
		ИтогоФактКол=0;		
		
		ВыборкаПоДням=РезультатПоДням.Выбрать();			
		Пока ВыборкаПоДням.Следующий() Цикл  
			
			Если ВыборкаПоДням.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда Продолжить КонецЕсли;
			Движение=Движения[ИмяРНакопления].Добавить();
			Движение.НеУчитыватьПриРасчетеЗаказа = НеУчитыватьПриРасчетеЗаказа;
			Движение.ВидПланаПродаж = ВидПланаПродаж;

			Если НЕ Акция Тогда
				Движение.Период			=ВыборкаПоДням.Дата;
			Иначе
				Движение.Период			=Дата;
			КонецЕсли;
			Движение.Номенклатура	=СтрокаТЧ.Номенклатура;
			Движение.Склад			=Склад;
			Движение.Контрагент     =Контрагент;
			
			РасчКол					=СтрокаТЧ.Количество/ВсегоДней;			
			Движение.Количество		=РасчКол;
			
			ИтогоРасчКол			=ИтогоРасчКол+РасчКол;
			ИтогоФактКол			=ИтогоФактКол+Движение.Количество;
			
			Корректировка=Окр(ИтогоРасчКол-ИтогоФактКол,0,1);
			Если Корректировка<>0 Тогда
				Движение.Количество	=Движение.Количество+Корректировка;
				ИтогоФактКол		=ИтогоФактКол+Корректировка;					
			КонецЕсли;
			
			Если Движение.Количество=0 Тогда
				Движения[ИмяРНакопления].Удалить(Движение);				
			КонецЕсли; 
			
			Движение.Сумма			=Движение.Количество*СтрокаТЧ.Цена*КоэффКурса;
			
			Движение.Подразделение	=Подразделение;  
			
		КонецЦикла;		
	КонецЦикла;

