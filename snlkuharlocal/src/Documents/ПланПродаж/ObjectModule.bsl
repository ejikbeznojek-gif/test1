					Движение.Период			=ВыборкаПоДням.Дата;
				Иначе
					Движение.Период			=Дата;
				КонецЕсли;
				//крохин конец 11.09.2012
				Движение.Номенклатура	=ВыборкаПоТоварам.Номенклатура;
				Движение.Склад			=Склад;
				//крохин начало
				Движение.Контрагент     =Контрагент;
				//крохин конец
				
				РасчКол				=ВыборкаПоТоварам.План/ВсегоДней*КоэффициентКорректировки;			
				Движение.Количество	=РасчКол;
				
				ИтогоРасчКол		=ИтогоРасчКол+РасчКол;
				ИтогоФактКол		=ИтогоФактКол+Движение.Количество;
				
				Корректировка=Окр(ИтогоРасчКол-ИтогоФактКол,0,1);
				Если Корректировка<>0 Тогда
					Движение.Количество	=Движение.Количество+Корректировка;
					ИтогоФактКол		=ИтогоФактКол+Корректировка;					
				КонецЕсли;				
				
				Движение.Сумма			=Движение.Количество*Цена*КоэффКурса;
				
				Движение.Подразделение	=Подразделение;
				
				СтрокаТР=ТР.Добавить();
				СтрокаТР.ИтогоРасчКол	=ИтогоРасчКол;
				СтрокаТР.ИтогоФактКол	=ИтогоФактКол;
				СтрокаТР.Отклонение		=ИтогоРасчКол-ИтогоФактКол;
				
			КонецЦикла;			
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда  
			
		Валюта 	= Основание.Валюта;
		ИБ 		= Основание.ИБ;
		Склад 	= Основание.Склад;
		ТипЦен 	= Основание.ТипЦен;
		
		Для Каждого СтрокаИст Из Основание.Товары  Цикл
			Если СтрокаИст.Количество=0 Тогда Продолжить КонецЕсли;
			
			СтрокаТЧ=Состав.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаИст);
		КонецЦикла; 
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
КонецПроцедуры

#Область Комплектующие 
//++Данилова Е.В. 28.07.2025
Процедура ЗаполнитьТЧКомплектующие()
	
	//Если Комплектующие.Количество() = 0  Тогда
	
