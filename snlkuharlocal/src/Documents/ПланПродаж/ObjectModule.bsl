Функция ЗаполнениеОстаткаПлан () 
	
	СтруктураВозврата = Новый Структура ("Успешно, Ошибки", Истина, Новый Массив); 
	
	Запрос = Новый Запрос;   
	Запрос.УстановитьПараметр("Ссылка",Ссылка);      
	Запрос.УстановитьПараметр("Состав",Состав);
	Если Детальный Тогда
		ИмяКолонкиНоменклатуры = "Номенклатура";
	Иначе 
		ИмяКолонкиНоменклатуры = "Модель";
	КонецЕсли;
	
	Запрос.Текст = СтрШаблон("ВЫБРАТЬ
	|	ПланПродажСостав.%1 КАК Номенклатура,
	|	ПланПродажСостав.Количество КАК Количество
	|ПОМЕСТИТЬ ИсходнаяТЧ
	|ИЗ
	|	Документ.ПланПродаж.Состав КАК ПланПродажСостав
	|ГДЕ
	|	ПланПродажСостав.Ссылка = &Ссылка
	|
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланПродажСостав.%1 КАК Номенклатура,
	|	ПланПродажСостав.Количество КАК Количество,
	|	ПланПродажСостав.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ ТекущаяТЧ   
	|ИЗ
	|	&Состав КАК ПланПродажСостав
	
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТекущаяТЧ.Номенклатура, ИсходнаяТЧ.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТекущаяТЧ.Количество, 0) КАК ТекущееКоличество,
	|	ЕСТЬNULL(ИсходнаяТЧ.Количество, 0) КАК ИсходноеКоличество,
	|	ЕСТЬNULL(ТекущаяТЧ.КоличествоОстаток, ТекущаяТЧ.КоличествоОстаток) КАК ОстатокПлана,
	|	ЕСТЬNULL(ТекущаяТЧ.Количество, 0) - ЕСТЬNULL(ИсходнаяТЧ.Количество, 0) КАК ДельтаКоличества
	|ИЗ
	|	ТекущаяТЧ КАК ТекущаяТЧ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ИсходнаяТЧ КАК ИсходнаяТЧ
	|		ПО ТекущаяТЧ.Номенклатура = ИсходнаяТЧ.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(ТекущаяТЧ.Количество, 0) - ЕСТЬNULL(ИсходнаяТЧ.Количество, 0) <> 0", 
	ИмяКолонкиНоменклатуры);          
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл  
		Номенклатура = Выборка.Номенклатура;
		Если Выборка.ДельтаКоличества < 0 Тогда  
			УменьшениеПлана = -1 * Выборка.ДельтаКоличества;
			Если УменьшениеПлана > Выборка.ОстатокПлана Тогда 
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По номенклатуре %1 не хватает остатка плана 
				|- %2, для уменьшения количества на - %3 штук", 
				Номенклатура, Выборка.ОстатокПлана, УменьшениеПлана));    
			Иначе
				СтрокаТЧ = Состав.Найти(Номенклатура, ИмяКолонкиНоменклатуры);  
				Если СтрокаТЧ <> Неопределено Тогда
					СтрокаТЧ.КоличествоОстаток = СтрокаТЧ.КоличествоОстаток - УменьшениеПлана;	
				КонецЕсли;
			КонецЕсли;    
		Иначе
			УвеличениеПлана = Выборка.ДельтаКоличества; 
			СтрокаТЧ = Состав.Найти(Номенклатура, ИмяКолонкиНоменклатуры);  
			Если СтрокаТЧ <> Неопределено Тогда
				СтрокаТЧ.КоличествоОстаток = СтрокаТЧ.КоличествоОстаток + УвеличениеПлана;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;      
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда 
		СтруктураВозврата.Успешно = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции
// Кухарь А.Ю.  02.07.2026 конец

