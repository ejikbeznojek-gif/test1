Функция ПланРаспределялсяВНакладные () 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспределениеПлановПродажПоНакладным.Накладная КАК Накладная
	|ИЗ
	|	РегистрСведений.РаспределениеПлановПродажПоНакладным КАК РаспределениеПлановПродажПоНакладным
	|ГДЕ
	|	РаспределениеПлановПродажПоНакладным.ПланПродаж = &ПланПродаж";
	Запрос.УстановитьПараметр("ПланПродаж",Ссылка); 
	Выборка = Запрос.Выполнить();
	Если Выборка.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции
// Кухарь А.Ю.  15.07.2026 конец

#КонецОбласти

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)			
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.

	
	// Кухарь А.Ю.  15.07.2026 начало   
	// Изменение 0000000223   
	Если Не ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ОтключитьРасчетОстаткаПланов", Неопределено, Ложь) Тогда	
		РеквизитыШапкиНач = ПолучитьРеквизитыШапки(Ссылка, "НеУчитыватьПриРасчетеЗаказа", "Документ");
		Если НеУчитыватьПриРасчетеЗаказа = Истина И РеквизитыШапкиНач.НеУчитыватьПриРасчетеЗаказа = Ложь Тогда 
			Для Каждого СтрокаТЧ Из Состав Цикл
				СтрокаТЧ.КоличествоОстаток = 0;
			КонецЦикла         
		ИначеЕсли НеУчитыватьПриРасчетеЗаказа = Ложь И РеквизитыШапкиНач.НеУчитыватьПриРасчетеЗаказа = Истина Тогда
			Если Не ПланРаспределялсяВНакладные() Тогда
				Для Каждого СтрокаТЧ Из Состав Цикл
					СтрокаТЧ.КоличествоОстаток = СтрокаТЧ.Количество;
				КонецЦикла      
			КонецЕсли;
		КонецЕсли;             
	КонецЕсли;
	// Кухарь А.Ю.  15.07.2026 конец
   
	
	// Кухарь А.Ю.  18.12.2025 начало
	//HELP-8209
	если не ЦеныРассчитаны или Модифицированность() тогда  
		РезультатОбновленияЦен = ОбновитьЦеныПоПравилам(новый Структура("РасчитатьПоПодразделению",истина));
		если РезультатОбновленияЦен.Успех тогда
			ЦеныРассчитаны = Истина;
		иначе       
			ЦеныРассчитаны = ложь;  
			РезультатОбновленияЦен.Ошибки.Добавить("Не удалось расчитать цены по плану продаж № "+Номер);
	        СообщитьИзМодуля(СтрСоединить(РезультатОбновленияЦен.Ошибки,Символы.ПС));
		КонецЕсли; 
	КонецЕсли;
	// Кухарь А.Ю.  18.12.2025 конец
	
	ЕстьИзменения		=Модифицированность();
	НужноВыгружать		=Ложь;
	
	// Нечаева 21,01,26 +++ OUT-179
	Если Проведен Тогда  
		// запрет на распроведение и запрет, на пометку на удаление.
		Если режимзаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
			Отказ = истина;
			сообщить("Отмена проведения запрещена!");
		КонецЕсли;
		
		Если ЭтотОбъект.ПометкаУдаления = Истина ТОгда
	    	 Отказ = истина;
			сообщить("Пометка на удаление запрещена! Воспользуйтесь кнопкой - Обнулить!");
   		КонецЕсли;	
		
	КонецЕсли;
	// Нечаева 21,01,26 --- OUT-179


	
	Если НЕ ОбменДанными.Загрузка Тогда		
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
		
		// Кухарь А.Ю.  02.07.2026 начало
		// Изменение 0000000223
		Если ЕстьИзменения Тогда   
			Если Не ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ОтключитьРасчетОстаткаПланов", Неопределено, Ложь) Тогда
				РезультатЗаполненияОстатка = ЗаполнениеОстаткаПлан(); 
				Если Не РезультатЗаполненияОстатка.Успешно Тогда  
					ТекстОшибки = СтрСоединить(РезультатЗаполненияОстатка.Ошибки, ", ");
					ВызватьИсключение ТекстОшибки;
				КонецЕсли;    
			КонецЕсли;
		КонецЕсли;
		// Кухарь А.Ю.  02.07.2026 конец
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;		

	Если Отказ Тогда Возврат КонецЕсли;
		
	Если ЕстьИзменения Тогда 
		ТипТовара			= Брэнд.Родитель;		
		КоличествоДокумента = Состав.Итог("Количество");
		СуммаДокумента		= Состав.Итог("Всего");
		ГруппыТоваров		= ГруппыТоваровДокумента(ЭтотОбъект,"Состав",?(Детальный,"Номенклатура","Модель"));
		
		Состав.Сортировать("ТипТовара,Брэнд,Модель,Номенклатура");
		
		НужноВыгружать		= Истина;
	Иначе
		Если (НЕ Ссылка.Проведен И РежимЗаписи=РежимЗаписиДокумента.Проведение) ИЛИ Ссылка.ПометкаУдаления<>ПометкаУдаления Тогда
			НужноВыгружать=Истина;			
		КонецЕсли;		
	КонецЕсли;	
	
	Если НужноВыгружать Тогда
		//УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;
	//++Данилова Е.В. 28.07.2025  HELP-6187
	Если ЕстьИзменения
		И Дата >= Дата(2025,07,01) Тогда
	
		ЗаполнитьТЧКомплектующие(); 	
	    ПроверитьТЧКомплектующие(Отказ); 
		
	КонецЕсли;
	//--Данилова Е.В. 28.07.2025  
	
		
	//---------------------------------------------------------------------------------------------------------
	// нечаева 19,01,26 ++OUT-179
	
	
	
	
	
	
	
	
	// создадим документ коррекции, если есть изменения.
	Если ЭтотОбъект.Проведен и ЕстьИзменения Тогда 
		КоррекцияПлана=Документы.ЗаявкаНаКоррекциюПланаПродаж.СоздатьДокумент();
		ЗаполнитьШапкуДокумента(КоррекцияПлана,ПараметрыСеанса.Пользователь);
		КоррекцияПлана.ОбработкаЗаполнения(ЭтотОбъект);
		КоррекцияПлана.Дата=ТекущаяДата();
		КоррекцияПлана.ДатаПланаПродаж = дата;
		КоррекцияПлана.ДокОснование = ЭтотОбъект.Ссылка;
		
		
		// запись изменений, смотрим, что сейчас есть.
		для каждого СтрТЧПлана из ЭтотОбъект.Состав цикл
			
		
			
			если ЭтотОбъект.Детальный тогда
				СтрСостава=КоррекцияПлана.Состав.Найти(СтрТЧПлана.Номенклатура,"Номенклатура");
			иначе
				СтрСостава=КоррекцияПлана.Состав.Найти(СтрТЧПлана.Модель,"Модель");
			КонецЕсли;
			
			
			если СтрСостава=Неопределено тогда	
				СтрСостава=КоррекцияПлана.Состав.Добавить();
				ЗаполнитьЗначенияСвойств(СтрСостава,СтрТЧПлана);		
				СтрСостава.количествоИсх=0;		
			КонецЕсли;
			СтрСостава.КоличествоФакт=СтрТЧПлана.Количество; // новое количество 
			
			// найдем строку по ссылке
			если ЭтотОбъект.Детальный тогда
				СтрСоставаИсх=ссылка.Состав.Найти(СтрТЧПлана.Номенклатура,"Номенклатура");
			иначе
				СтрСоставаИсх=Ссылка.Состав.Найти(СтрТЧПлана.Модель,"Модель");
			КонецЕсли;
			
			//СтрСостава.КоличествоИсх = СтрСоставаИсх.Количество;
			//Нечаева 30,01,26 ++
			Если СтрСоставаИсх = неопределено Тогда
				СтрСостава.КоличествоИсх = 0;
			иначе	
				СтрСостава.КоличествоИсх = СтрСоставаИсх.Количество;
			КонецЕсли;
			//Нечаева 30,01,26 --

			СтрСостава.Количество= СтрСостава.КоличествоИсх-СтрСостава.КоличествоФакт;
						
			
		КонецЦикла;
		
		// для новых строк. или удаленных?	
		если КоррекцияПлана.Состав.Количество()<>ЭтотОбъект.Состав.Количество() тогда
			Для каждого СтрСостава из  КоррекцияПлана.Состав цикл
				если ЭтотОбъект.Детальный тогда
					СтрТЧПлана=ЭтотОбъект.Состав.Найти(СтрСостава.Номенклатура,"Номенклатура");
				иначе
					СтрТЧПлана=ЭтотОбъект.Состав.Найти(СтрСостава.Модель,"Модель");
				КонецЕсли;
				
				если СтрТЧПлана=Неопределено тогда	
					СтрСостава.КоличествоФакт=0;
					СтрСостава.Количество=СтрСостава.КоличествоИсх-СтрСостава.КоличествоФакт;	
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		// ---------------------------------------------------
		
		СтруктураДляПоиска = Новый Структура("Количество", 0); 
		ТабличнаяЧастьДок = КоррекцияПлана.Состав; 
		МассивПустыхСтрок = ТабличнаяЧастьДок.НайтиСтроки(СтруктураДляПоиска); 
		Для каждого Строка Из МассивПустыхСтрок Цикл 
			ТабличнаяЧастьДок.Удалить(Строка); 
		КонецЦикла; 
			
		КоррекцияПлана.ОтработалСотрудник=ПараметрыСеанса.Пользователь;
		КоррекцияПлана.ПричинаКоррекции=Справочники.ПричиныКоррекций.НайтиПоКоду("000000002");
		КоррекцияПлана.Утвержден=Истина;
		КоррекцияПлана.ДатаОтработки=ТекущаяДата(); 
		КоррекцияПлана.Записать(РежимЗаписиДокумента.Проведение);	
		
		//КоррекцияПлана.ПолучитьФорму("ФормаДокумента").Открыть();   
		
	КонецЕсли;
	// сразу корректируем
	
	//----------------------------------------------------------------------------------------------------------
	// нечаева 19,01,26 ++  
	
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	ЗапросПоДням=Новый Запрос;
	ЗапросПоДням.Текст="
	|ВЫБРАТЬ
	|	КалендарьДни.Дата КАК Дата
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	КалендарьДни.Ссылка.Период = &Период
	|	И КалендарьДни.Часы > 0
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Дата)
	|ПО ОБЩИЕ";
	
	ЗапросПоДням.УстановитьПараметр("Период",НачалоМесяца(Дата));
	РезультатПоДням	=ЗапросПоДням.Выполнить();
	
	ВсегоДней=0;
	
	ВыборкаПоДням	=РезультатПоДням.Выбрать();
	Пока ВыборкаПоДням.Следующий() Цикл
		Если ВыборкаПоДням.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда
			ВсегоДней=ВыборкаПоДням.Дата;			
		Иначе					
			Прервать;
		КонецЕсли;	
	КонецЦикла; 
	
	Если ВсегоДней=0 Тогда
		Сообщить("Не заполнен календарь на: " +ПредставлениеПериода(НачалоМесяца(Дата),КонецМесяца(Дата)),СтатусСообщения.Важное);					
		Отказ=Истина;
		Возврат;			
	КонецЕсли;
	
	КоэффКурса=глПересчет(1,Валюта,Курс,ПараметрыСеанса.ВалютаНац,Дата);
	
	ТР=Новый ТаблицаЗначений;
	ТР.Колонки.Добавить("ИтогоРасчКол");
	ТР.Колонки.Добавить("ИтогоФактКол");
	ТР.Колонки.Добавить("Отклонение");
	//++Данилова Е.В. 28.07.2025 HELP-6187 
	ИспользоватьСхемуСКомплектующими = Дата >= Дата(2025,07,01); 
	//--Данилова Е.В. 28.07.2025
	//++Данилова Е.В. 28.07.2025 HELP-6187 
	Если НЕ ИспользоватьСхемуСКомплектующими Тогда 
		
		Если НЕ Детальный Тогда
			
			ТекстЗапроса = "
			|ВЫБРАТЬ
			|	ПланПродажСостав.Модель КАК Модель,
			|	РаспределениеСрезПоследних.Номенклатура,
			|	ПланПродажСостав.Количество КАК Количество,
