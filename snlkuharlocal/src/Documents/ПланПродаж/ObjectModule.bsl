Функция ПолучитьТаблицуСоставИзРаспределения() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланПродажСостав.Модель КАК Модель,
	|	ПланПродажСостав.Количество КАК Количество
	|ПОМЕСТИТЬ ВТПланПродажСостав
	|ИЗ
	|	&Состав КАК ПланПродажСостав
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПланПродажСостав.Модель КАК Модель,
	|	РаспределениеСрезПоследних.Номенклатура КАК Номенклатура,
	|	ПланПродажСостав.Количество * РаспределениеСрезПоследних.Процент / 100 КАК Количество,
	|	ВЫБОР
	|		КОГДА РаспределениеСрезПоследних.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|			ТОГДА ВЫБОР
	|					КОГДА РаспределениеСрезПоследних.Номенклатура.Родитель.ШтукВКомплекте = 0
	|							ИЛИ РаспределениеСрезПоследних.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|						ТОГДА ПланПродажСостав.Количество * РаспределениеСрезПоследних.Процент / 100
	|					ИНАЧЕ ПланПродажСостав.Количество * РаспределениеСрезПоследних.Процент / 100 * РаспределениеСрезПоследних.Номенклатура.Родитель.ШтукВКомплекте
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоКомплектующих,
	|	1 КАК Коэффициент,
	|	0 КАК Цена
	|ИЗ
	|	ВТПланПродажСостав КАК ПланПродажСостав
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Распределение.СрезПоследних(&Дата2, Склад = &Склад) КАК РаспределениеСрезПоследних
	|		ПО ПланПродажСостав.Модель = РаспределениеСрезПоследних.Номенклатура.Родитель
	|ГДЕ
	|	НЕ РаспределениеСрезПоследних.Номенклатура ЕСТЬ NULL
	|	И РаспределениеСрезПоследних.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Дата2",КонецДня(Дата));
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Состав",Состав.Выгрузить());
	
	ТЧСостав = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЧСостав;

КонецФункции

Процедура ПроверитьТЧКомплектующие(Отказ)

	КоличествоДокумента 	= Состав.Итог("Количество");
	КоличествоКомплектующих = Комплектующие.Итог("Количество");
	
	КоличествоКомплектующихДляСверки = Состав.Итог("КоличествоКомплектующих");
	
	Если КоличествоКомплектующихДляСверки = 0 
		И Детальный Тогда
		Для каждого СтрокаТЧ из Состав цикл
			ЗаполнитьКоличествоКомплектующихПоСтроке(СтрокаТЧ);		
		КонецЦикла;			
	КонецЕсли;
	
	Если не ОбменДанными.Загрузка тогда
		
		Если Детальный
			И Состав.Итог("КоличествоКомплектующих") <> Комплектующие.Итог("Количество") тогда
			СообщитьИзМодуля("Не совпадает количество комплектующих в таблице состав и в таблице комплектующие");
			Отказ = Истина; 
		КонецЕсли;
		
		Если Детальный Тогда 
			
			//ТЧНоменклатура = Состав.Выгрузить(,"Номенклатура");
			//ТЧНоменклатура.Свернуть("Номенклатура"); 
			МассивНоменклатуры = ПолучитьМассивНоменклатуры("Состав","Номенклатура");//ТЧНоменклатура.ВыгрузитьКолонку("Номенклатура");
			
			//ТЧПродукции = Комплектующие.Выгрузить(,"Продукция"); 
			//ТЧПродукции.Свернуть("Продукция"); 	
			
			МассивПродукции = ПолучитьМассивНоменклатуры("Комплектующие","Продукция");//ТЧПродукции.ВыгрузитьКолонку("Продукция");
			
			Если МассивНоменклатуры.Количество() <>  МассивПродукции.Количество() Тогда
				
				Отказ = истина; 
				Сообщить("Не совпадает номенклатура на закладке Состав и Комплектующие");
			Иначе 
				Для каждого ЭлементТовара Из МассивНоменклатуры Цикл
					
					Если МассивПродукции.Найти(ЭлементТовара) = неопределено Тогда
						
						Отказ = Истина; 	
						
						Сообщить("Не совпадает номенклатура на закладке Состав:" +Строка(ЭлементТовара)  + " и Комплектующие: не найдено");
						
					КонецЕсли;	
					
				КонецЦикла; 
				
				Для каждого ЭлементТовара Из МассивПродукции Цикл
					
					Если МассивНоменклатуры.Найти(ЭлементТовара) = неопределено Тогда
						
						Отказ = Истина; 	
						
						Сообщить("Не совпадает номенклатура на закладке Комплектующие:" +Строка(ЭлементТовара)  + " и Состав: не найдено");
						
					КонецЕсли;	
					
				КонецЦикла;
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;                                
	

КонецПроцедуры

Функция ЗаполнитьТЧКомплектующиеПоРаспределению(ТЧРаспределения)  Экспорт
	
	
	ТаблицаКомплектующих = Новый ТаблицаЗначений;
	ТаблицаКомплектующих.Колонки.Добавить("Продукция");
	ТаблицаКомплектующих.Колонки.Добавить("Номенклатура");
	ТаблицаКомплектующих.Колонки.Добавить("Количество");
	
	СоответствиеМодельКоличествоКомплектующих = Новый Соответствие; 
	Для Каждого СтрокаТЧ Из ТЧРаспределения Цикл
		
		ВремТЗ = ПолучитьТаблицуКомплектующих(СтрокаТЧ.Номенклатура);
		Для Каждого СтрокаВремТЗ Из ВремТЗ Цикл
			
			Если СтрокаВремТЗ.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
				
				Продолжить;	
			КонецЕсли;
			
			НоваяСтрока = ТаблицаКомплектующих.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаВремТЗ);
			
		КонецЦикла;
		
		КоличествоКомплектующих = СоответствиеМодельКоличествоКомплектующих.Получить(СтрокаТЧ.Модель); 
		Если КоличествоКомплектующих = неопределено Тогда
			
			КоличествоКомплектующих = 0; 	
			
		КонецЕсли;
		СоответствиеМодельКоличествоКомплектующих.Вставить(СтрокаТЧ.Модель,КоличествоКомплектующих + Окр(СтрокаТЧ.КоличествоКомплектующих)); 
	КонецЦикла;
	
	ТР = Новый ТаблицаЗначений;	
	ТР.Колонки.Добавить("Продукция");
	ТР.Колонки.Добавить("Номенклатура");
	ТР.Колонки.Добавить("Количество");
	ТР.Колонки.Добавить("Всего");
	
	Для Каждого СтрокаТЧ Из ТЧРаспределения Цикл
		
		
		КолвоПродукции	= СтрокаТЧ.Количество * СтрокаТЧ.Коэффициент;
		
		СтрокиТаблицыКомплектующих = ТаблицаКомплектующих.НайтиСтроки(Новый Структура("Продукция", СтрокаТЧ.Номенклатура));
		
		Для Каждого СтрокаТаблицыКомплектующих Из СтрокиТаблицыКомплектующих Цикл			
			
			ТекНоменклатура		= СтрокаТаблицыКомплектующих.Номенклатура;
			ТребуемоеКоличество	= КолвоПродукции * СтрокаТаблицыКомплектующих.Количество;
			
			Если ТребуемоеКоличество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если ТекНоменклатура.Коплектующие.Количество() = 0 
				ИЛИ ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
				СтрокаТР = ТР.Добавить();
				СтрокаТР.Продукция		= СтрокаТЧ.Номенклатура;
				СтрокаТР.Номенклатура	= ТекНоменклатура;				
				СтрокаТР.Количество		= ТребуемоеКоличество;
				Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
					СтрокаТР.Всего = СтрокаТР.Количество * СтрокаТЧ.Цена;
				КонецЕсли;				
				
				
			ИначеЕсли (ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
				Или (НЕ ЗначениеЗаполнено(ТекНоменклатура.ВидКомплекта)) Тогда
				
				ТЗПропорций = Новый ТаблицаЗначений;
				ТЗПропорций.Колонки.Добавить("Номенклатура");
				ТЗПропорций.Колонки.Добавить("Количество");
				
				для каждого СтрТЧКМП из ТекНоменклатура.Коплектующие цикл
					СтрПроп=ТЗПропорций.Добавить();
					СтрПроп.Номенклатура=СтрТЧКМП.Номенклатура;
					СтрПроп.Количество=Окр(ТребуемоеКоличество*СтрТЧКМП.Количество/ТекНоменклатура.Коплектующие.Итог("Количество"),0);			
				КонецЦикла;
				если ТЗПропорций.Итог("Количество")<>ТребуемоеКоличество тогда
					СтрДоберём = ТЗПропорций.Получить(ТЗПропорций.Количество()-1);
					СтрДоберём.количество=СтрДоберём.количество+(ТребуемоеКоличество-ТЗПропорций.Итог("Количество"));
				КонецЕсли;
				
				
				ТЗПропорций.Свернуть("Номенклатура","Количество");
				Для каждого СтрТЗПроп из ТЗПропорций цикл
					СтрокаТР=ТР.Добавить();
					СтрокаТР.Продукция 		= СтрокаТЧ.Номенклатура;
					СтрокаТР.Номенклатура	= СтрТЗПроп.Номенклатура;				
					СтрокаТР.Количество		= + СтрТЗПроп.Количество;
					Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
						СтрокаТР.Всего = СтрТЗПроп.Количество * СтрокаТЧ.Цена;
					КонецЕсли;
				КонецЦикла;	
				
				
			Иначе
				СообщитьИзМодуля("ВНУТРЕННЯЯ ОШИБКА! Комплекты с Вид комплекта = " + ТекНоменклатура.ВидКомплекта + " не поддерживаются!");					
			КонецЕсли;							
		КонецЦикла;			
	КонецЦикла;	
	
	ТР.Свернуть("Номенклатура, Продукция","Количество, Всего");
	
	
	Комплектующие.Очистить(); 
	
	Для Каждого СтрокаТР Из ТР Цикл
		Если СтрокаТР.Количество = 0 тогда
			Продолжить;
		КонецЕсли;
		СтрокаТЧ = Комплектующие.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТР);
		
		ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ, ЭтотОбъект);
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ЭтотОбъект, "ОтВсего");			
	КонецЦикла;
	
	Для каждого СтрокаПоМодели Из Состав Цикл
		
		СтрокаПоМодели.КоличествоКомплектующих = СоответствиеМодельКоличествоКомплектующих.Получить(СтрокаПоМодели.Модель); 
		
	КонецЦикла;
	
	
КонецФункции

Функция ПолучитьТаблицуКомплектующих(Продукция, МассивПродукцииВерхнегоУровня = Неопределено)
	
	ТаблицаКомплектующих = Новый ТаблицаЗначений;
	ТаблицаКомплектующих.Колонки.Добавить("Продукция");
	ТаблицаКомплектующих.Колонки.Добавить("Номенклатура");
	ТаблицаКомплектующих.Колонки.Добавить("Количество");
	
	// чтобы отслеживать ситуацию зацикливания комплектов
	МассивПВУ = Новый Массив;
	Если МассивПродукцииВерхнегоУровня <> Неопределено Тогда
		Для Каждого Элемент Из МассивПродукцииВерхнегоУровня Цикл 
			МассивПВУ.Добавить(Элемент);
		КонецЦикла;
	КонецЕсли;
	МассивПВУ.Добавить(Продукция);
	
	ОбщКолКомп=Продукция.Коплектующие.Итог("Количество");
	
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураКоплектующие.Номенклатура КАК Запчасть,
	|	НоменклатураКоплектующие.Номенклатура.НоменклатураЗамены КАК ЗаменаЗапчасти,
	|	НоменклатураКоплектующие.Ссылка КАК Продукция
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка = &Продукция";
	запрос.УстановитьПараметр("Продукция",Продукция);
	ТаблицаЗамен=запрос.Выполнить().Выгрузить();
	
	Если (Продукция.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект)
		И (Продукция.Коплектующие.Количество() > 0) Тогда		
		Для Каждого СтрокаТЧ Из Продукция.Коплектующие Цикл
			Комплектующее = СтрокаТЧ.Номенклатура;
			
			СтрокаЗамены=ТаблицаЗамен.Найти(Комплектующее,"Запчасть");
			если СтрокаЗамены<>Неопределено и ЗначениеЗаполнено(СтрокаЗамены.ЗаменаЗапчасти) тогда
				Комплектующее	= СтрокаЗамены.ЗаменаЗапчасти;
			КонецЕсли;				
			Если МассивПВУ.Найти(Комплектующее) <> Неопределено Тогда
				СообщитьИзМодуля("ОШИБКА! Обнаружено зацикливание комплектующих у комплекта """ + МассивПВУ[0] + """!" + Символы.ПС
				+ " - зацикливание возникло на комплектующем """ + Комплектующее + """"
				+ " из вложенного комплекта """ + Продукция + """");
				Продолжить;
			КонецЕсли;
			
			КолвоКомплектующих	= СтрокаТЧ.Количество * СтрокаТЧ.Единица.Коэффициент;
			ВремТЗ				= ПолучитьТаблицуКомплектующих(Комплектующее, МассивПВУ);
			Для Каждого СтрокаВремТЗ Из ВремТЗ Цикл
				НоваяСтрока = ТаблицаКомплектующих.Добавить();
				НоваяСтрока.Продукция		= Продукция;
				НоваяСтрока.Номенклатура	= СтрокаВремТЗ.Номенклатура;			
				НоваяСтрока.Количество		= КолвоКомплектующих * СтрокаВремТЗ.Количество;				
			КонецЦикла;			
		КонецЦикла;				
	Иначе
		НоваяСтрока					= ТаблицаКомплектующих.Добавить();
		НоваяСтрока.Продукция		= Продукция; // МассивПВУ[0];
		НоваяСтрока.Номенклатура	= Продукция;
		НоваяСтрока.Количество		= 1;
	КонецЕсли;
	
	Возврат ТаблицаКомплектующих; 
	
КонецФункции

Функция ПолучитьМассивНоменклатуры(ИмяТЧ,ИмяКолонки)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПланПродажТовары.%ИмяКолонки% КАК Номенклатура,
		|	ПланПродажТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ПланПродажТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|ГДЕ
		|	ВТТовары.Количество > 0
		|	И ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)"; 	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяКолонки%",ИмяКолонки);
	
	Запрос.УстановитьПараметр("Товары",ЭтотОбъект[ИмяТЧ].Выгрузить()); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура"); 


КонецФункции  


