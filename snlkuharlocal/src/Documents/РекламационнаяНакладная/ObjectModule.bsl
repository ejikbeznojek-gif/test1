Процедура ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,Записывать=Ложь)
	Для Каждого НаборДвижений Из ДвиженияПоРегистрам Цикл
		ИмяРегистра		=НаборДвижений.Ключ;
		ТаблицаДвижения =НаборДвижений.Значение;
		
		Если Движения.Найти(ИмяРегистра)=Неопределено Тогда Возврат  КонецЕсли; 
		
		НаборЗаписей=Движения[ИмяРегистра];		
		НаборЗаписей.Очистить();
		
		Для Каждого Движение Из ТаблицаДвижения Цикл
			Запись=НаборЗаписей.Добавить();	
			ЗаполнитьЗначенияСвойств(Запись,Движение);	
			
			Запись.Регистратор=Ссылка;
		КонецЦикла;	
		
		Если Записывать Тогда
			НаборЗаписей.Записать();		
		КонецЕсли; 
	КонецЦикла;	
КонецПроцедуры 

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	ЕстьИзменения		= Модифицированность();
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ЗаявкаНаРекламацию") Тогда
		НужноВыгружать = Ложь;
	Иначе
		НужноВыгружать	= НужноВыгружатьДокумент(ЕстьИзменения,Ссылка,РежимЗаписи,ПометкаУдаления);
	КонецЕсли;
	
	Если НЕ ОбменДанными.Загрузка Тогда
		КонтрольДатыЗапрета(ЭтотОбъект,Отказ);
		МожноЗаписатьДокумент(ЭтотОбъект,Отказ,РежимЗаписи,Истина);
		МожноИзменятьДокумент(ЭтотОбъект,Отказ,Истина);		
			
		// Шворобей ВЮ 28.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1244
		Если ЭтоНовый() И ВидРекламации = Перечисления.ВидыРекламаций.Возврат 
			И Месяц(Дата) <> Месяц(ТекущаяДатаСеанса()) Тогда
			СообщитьОбОшибке("Месяц даты РКМ не совпадает с текущим!!!");
			Отказ = Истина;
		КонецЕсли;
		// Шворобей ВЮ 28.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1244
		
		Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение И ДокОснование.Метаданные().Имя="Перемещение" И ДокОснование.Склад.КодФизическогоУзла<>ПараметрыСеанса.ЭтотУзел.Код Тогда
			СообщитьОбОшибке("Рекламационные накладные на перемещения вводятся только на складе отправителе !!!");
			Отказ=Истина;
		КонецЕсли;
		
		 //крохин начало 05.02.2014
		 //иногда не отрабатывает "перед удалением"
		Если ПометкаУдаления И (Отработано или ПервичнаяПриемка) Тогда
			СообщитьОбОшибке("Невозможно удалить рекламацию в состоянии Предварительная обработка или Отработано.");
			Отказ=Истина;
		КонецЕсли;
		//крохин конец 05.02.2014
		
		Если Отказ Тогда Возврат КонецЕсли; 	
	КонецЕсли;
	
	Если ЕстьИзменения Тогда		
		СуммаДокумента		= Товары.Итог("Всего");
		ОбъемДокумента		= Товары.Итог("Объем");
		КоличествоДокумента = Товары.Итог("Количество");
		
		ГруппыТоваров   	= ГруппыТоваровДокумента(ЭтотОбъект);
	КонецЕсли; 
	
	Если НужноВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
		//Катаев+ 08/10/14
		Если Не ЭтотОбъект.Ссылка.Пустая() Тогда
			НужноВыгружать = Ложь;
		КонецЕсли;
		//Катаев- 08/10/14
	КонецЕсли;
	
	
	//нечаева 23,12,16 +++
	//меняем и дату КСФ
	Если НЕ ОбменДанными.Загрузка Тогда
		
		//нечаева 03,010,16++
		#если клиент	Тогда
			// нечаева 29,08,16+++
			
			КСФ=Неопределено;
			КСФ=КСчетФактураНакладной(ЭтотОбъект.Ссылка,Организация);
			
					
			если РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения  
				и ВидРекламации=Перечисления.ВидыРекламаций.Вычерк  Тогда
				
				// нечаева 23,08,16+++ 				
				Если НЕ КСФ.Пустая() Тогда
					// снимаем проведение
					КСФ_Объект=КСФ.ПолучитьОбъект();
					КСФ_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения,РежимПроведенияДокумента.Неоперативный);
					
				КонецЕсли;		
				
			КонецЕсли;
			// нечаева 29,08,16+++
			Если НЕ КСФ.Пустая() Тогда
				//крохин начало 06.05.2021
				//перед записью дата ещё старая
				//Если КСФ.дата<> ЭтотОбъект.Ссылка.Дата Тогда
				//	КСФ_Объект=КСФ.ПолучитьОбъект();
				//	КСФ_Объект.Дата = ЭтотОбъект.Дата;
				//	КСФ_Объект.записать();
				//КонецЕсли;
				Если КСФ.дата<> Дата Тогда
					КСФ_Объект=КСФ.ПолучитьОбъект();
					КСФ_Объект.Дата = Дата;
					КСФ_Объект.записать();
				КонецЕсли;

				//крохин конец 06.05.2021
			КонецЕсли;
			
		#конецЕсли
	КонецЕсли;
	//нечаева 23,12,16 ---
	
	
	////нечаева 14,07,14 +++
	//Если ЭтотОбъект.Модифицированность() = Истина и ВидРекламации = Перечисления.ВидыРекламаций.Вычерк  Тогда
	//	ДокОснование.получитьобъект().УстановитьСостояниеДокументов(Перечисления.СостояниеДокументов.НеВыписаны);
	//конецЕсли;
	////нечаева 14,07,14 *--
	//
	
	//крохин начало 22.01.2020
	Если НЕ ОбменДанными.Загрузка Тогда
		Если ДокОснование.Метаданные().Имя = "РасходнаяНакладная" Тогда
			Если ДокОснование.СуммаСкидкиДС <> 0 Тогда
				СуммаСкидкиДСДоИзменения = ДокОснование.СуммаСкидкиДС;
				Если ДокОснование.СуммаДокумента <> 0 Тогда
				ПроцентИзмененияСкидкиДС = СуммаДокумента/ДокОснование.СуммаДокумента;
			Иначе
				ПроцентИзмененияСкидкиДС = 0;
			КонецЕсли;
			СуммаСкидкиДС = ПроцентИзмененияСкидкиДС*СуммаСкидкиДСДоИзменения;
			ДоговорСкидкиДС = ДокОснование.ДоговорСкидкиДС;
			КонецЕсли;
        КонецЕсли;
	КонецЕсли;
    //крохин конец 22.01.2020
	
	//крохин начало 14.06.2020
	//требуется изменение статуса претензии
	Если Не ОбменДанными.Загрузка И РежимЗаписи=РежимЗаписиДокумента.Проведение И НЕ ПретензияПолучателя.Пустая() И ПретензияПолучателя.Проведен  И ПретензияПолучателя.СтатусПретензии <> Перечисления.СтатусыПретензииПокупателя.Завершена И ПретензияПолучателя.СтатусПретензии <> Перечисления.СтатусыПретензииПокупателя.ОформлениеДокументов Тогда
		КоличествоПретензияПолучателя = 0;
		ВсегоПретензияПолучателя = 0;
		Для Каждого СтрокаТЧ Из ПретензияПолучателя.Товары Цикл
			Если СтрокаТЧ.Решение = Перечисления.СостоянияКоррекции.Принята Тогда
				КоличествоПретензияПолучателя = КоличествоПретензияПолучателя + СтрокаТЧ.Количество;
				ВсегоПретензияПолучателя = ВсегоПретензияПолучателя + СтрокаТЧ.Всего;
			КонецЕсли;
		КонецЦикла;
		Если КоличествоДокумента = КоличествоПретензияПолучателя И СуммаДокумента = ВсегоПретензияПолучателя Тогда
			ДокПретензияПолучателя = ПретензияПолучателя.ПолучитьОбъект();
			Если ДокОснование.Метаданные().Имя = "Перемещение" Тогда
				
				ДокПретензияПолучателя.СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.Завершена;
				ДокПретензияПолучателя.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
			Если ДокОснование.Метаданные().Имя = "РасходнаяНакладная" Тогда
				ДокПретензияПолучателя.СтатусПретензии = Перечисления.СтатусыПретензииПокупателя.ОформлениеДокументов;
				ДокПретензияПолучателя.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	//крохин конец 14.06.2020
	
	// Шворобей ВЮ 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4275
	СтруктураВозврата = Документы.РекламационнаяНакладная.ПроверкаДублейЧЗ(ШтрихкодыУпаковок.Выгрузить());
	Если СтруктураВозврата.ЕстьДубли = Истина Тогда
		СообщитьОбОшибке("Есть дубли ШК упаковок");
		Отказ = Истина;
	КонецЕсли;
	// Шворобей ВЮ 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4275
	//Валетов + 02,06,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-237
	Если ЭтоНовый() И Подразделение.Закрыто Тогда 
		Подразделение = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(Справочники.Подразделения.ПустаяСсылка(),"ПодразделениеЗаменыВРКМ"); 
	КонецЕсли;
	//Валетов - 
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Отработано=Ложь;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	если ВидРекламации=Перечисления.ВидыРекламаций.Рекламация  тогда
		Сообщить("Запрещено проводить рекламацию с типом - рекламация.");
		отказ=Истина;
	КонецЕсли;
	Если НЕ ОбменДанными.Загрузка И НЕ ПараметрыСеанса.ЗапущенаОбработка Тогда
	#если клиент Тогда
		Если ПараметрыСеанса.ЭтотУзел.Код = "SNL" И НЕ ПустаяСтрока(Склад.КодФизическогоУзла) И ВидРекламации <> Перечисления.ВидыРекламаций.Возврат Тогда	
			сообщить("РКМ и КЦН проводятся только на складе!");
			если не РольДоступна("Администратор") тогда 
				отказ = истина;
				возврат;
			КонецЕсли; 
		КонецЕсли;	
	#КонецЕсли
	КонецЕсли;
	
	Если НЕ ПроводитьПоОстаткам Тогда 
		//+++Чирков 30.04.2026 СФ на АВ - промежуточные договора возвратов
		Если ВидРекламации = Перечисления.ВидыРекламаций.Возврат И 
			ИспользоватьВспомогательныеДоговораПриВозвратах(ЭтотОбъект.Дата) Тогда        
			
			ДвиженияПоВзаиморасчетам = Неопределено;
			рПроведения = ПроведениеПоРегистрамВзаиморасчетов(Ссылка, ДвиженияПоВзаиморасчетам);
			Если рПроведения.Результат = 1 Тогда			
				ВыполнитьДвиженияПоРегистрам(ДвиженияПоВзаиморасчетам, ОбменДанными.Загрузка);
			КонецЕсли;			
		КонецЕсли;
		//---Чирков 30.04.2026 СФ на АВ - промежуточные договора возвратов
		
		Возврат;  
	КонецЕсли;
	
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки

	ДвиженияПоРегистрам=Неопределено;	
	
	РезультатПроведения=ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоРегистрам,ОбменДанными.Загрузка);	
	
	Результат=РезультатПроведения["Результат"];
	//крохин начало 08.12.2011
	Если ВидРекламации = Перечисления.ВидыРекламаций.Вычерк Тогда
		ДвиженияПоВзаиморасчетам=Неопределено;
		РезультатПроведения=ПроведениеПоРегистрамВзаиморасчетов(Ссылка,ДвиженияПоВзаиморасчетам);
	КонецЕсли;
	//крохин конец 08.12.2011
	Если Результат<0 И НЕ ОбменДанными.Загрузка Тогда 			
		Отказ=Не(ПолучитьПолномочиеПользователя("СписыватьВМинус"));
	КонецЕсли;
	
	
	Если Не Отказ Тогда
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоРегистрам,ОбменДанными.Загрузка);		
	КонецЕсли;
	//крохин начало 08.12.2011
	Если ВидРекламации = Перечисления.ВидыРекламаций.Вычерк Тогда
		Если Не Отказ Тогда
			ВыполнитьДвиженияПоРегистрам(ДвиженияПоВзаиморасчетам,ОбменДанными.Загрузка);		
		КонецЕсли;
		
	КонецЕсли;
	//крохин конец 08.12.2011
	
	//крохин начало 05.05.2020
	//комиссионная торговля
	Если ДокОснование.Метаданные().Имя = "РасходнаяНакладная" И ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
		ДвиженияПоОстаткамТМЦКомиссия = Неопределено;
		РезультатПроведения = ПроведениеПоРегиструОстаткиТМЦКомиссия(Ссылка,ДвиженияПоОстаткамТМЦКомиссия);
		ВыполнитьДвиженияПоРегистрам(ДвиженияПоОстаткамТМЦКомиссия, ОбменДанными.Загрузка);
	КонецЕсли;
	//крохин конец 05.05.2020
    //+HELP-7109 20251112 Михайловский 
	Если ДокОснование.Метаданные().Имя = "ПриходнаяНакладная" И ПроводитьПоОстаткам Тогда
		//ДвиженияПоОстаткамТМЦ = Неопределено;
		//РезультатПроведения = ПроведениеПоРегистрамОстатков(Ссылка,ДвиженияПоОстаткамТМЦ);
		////ВыполнитьДвиженияПоРегистрам(ДвиженияПоОстаткамТМЦ, ОбменДанными.Загрузка);
		//ВыполнитьДвиженияПоРегистрам(ДвиженияПоОстаткамТМЦ, Истина); 
		// делаю фиксом, т. к. пред кусок не работает
		ФиксДвижОстТМЦ();
	КонецЕсли;
	//-HELP-7109 20251112 Михайловский
	
	//крохин начало 22.01.2020
	//при заполнении "суммы скидки" формируются доп. проводки
	ВалютаУпр=Константы.ВалютаУпрУчета_2009.Получить(); 
	Если СуммаСкидкиДС <> 0 Тогда
            Движение=Движения.Затраты.Добавить();
			
			Движение.Период			= Дата;
			
			Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;		
			
			//++Данилова Е.В. 03.10.2025 HELP-7050 
			Если Дата >= дата(2025,09,01) Тогда
				
				Движение.Подразделение		= ?(ЗначениеЗаполнено(Подразделение),Подразделение,ДокОснование.Подразделение);
			Иначе 
				Движение.Подразделение		= ДокОснование.Подразделение;
			КонецЕсли;
			//Движение.Подразделение		= ДокОснование.Подразделение;
			//--Данилова Е.В. 03.10.2025			
			Движение.СтатьяЗатрат	= Справочники.СтатьиЗатрат.НайтиПоКоду("320 570"); //Трейд-маркетинг
			
			Движение.СуммаУпр		= глПересчет(СуммаСкидкиДС, Валюта, Курс, ВалютаУпр, Дата);	
			
			Движение.СуммаДокумента	= СуммаДокумента;
			
			Движение.ВалютаДокумента= Валюта;
			
			Движение.Комментарий    = "скидка по ДС";

			
			Движение.ДатаЗаписи		= ТекущаяДата();
	КонецЕсли;		

	//крохин конец 22.01.2020
	
	// Катаев+ 18/03/13 Проверяем наличие акта. Если акт есть, то заносим данные в регистр и делаем проверку на соответсвие данных по акту и рекламации
	Если не Отказ Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	АктПриемки.Ссылка
		|ИЗ
		|	Документ.АктПриемки КАК АктПриемки
		|ГДЕ
		|	АктПриемки.РНК = &РНК
		|	И АктПриемки.Проведен";
		Запрос.УстановитьПараметр("РНК", ДокОснование);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Акт = Выборка.Ссылка.ПолучитьОбъект();
			//крохин начало 15.12.2018
			//ошибка - Действие не может выполняться в режиме загрузки данных
			//Акт.ОбменДанными.Загрузка = Истина;
			//крохин конец 15.12.2018
			Если Отработано Тогда
				Акт.СостояниеДокумента = Перечисления.СостоянияНакладной.Принята;
			Иначе
				Акт.СостояниеДокумента = Перечисления.СостоянияНакладной.ВРаботе;
			КонецЕсли;
			Акт.СостоянияРКМ = Перечисления.СостоянияРКМ.СовпадаетСАктом;
			Для Каждого ТекСтрокаТовары Из Товары Цикл
				// регистр РасхожденияПоАкту Приход
				Движение = Движения.РасхожденияПоАкту.Добавить();
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.Период = Дата;
				Движение.РНК = ДокОснование;
				Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
				Движение.Отправлено = ТекСтрокаТовары.КоличествоИсх;
				Движение.Принято = ТекСтрокаТовары.КоличествоФакт;
			КонецЦикла;
			// Получаем остатки по регистру
			Запрос.Текст =
			"ВЫБРАТЬ
			|	РасхожденияПоАктуОстатки.Номенклатура,
			|	РасхожденияПоАктуОстатки.ОтправленоОстаток,
			|	РасхожденияПоАктуОстатки.ПринятоОстаток
			|ИЗ
			|	РегистрНакопления.РасхожденияПоАкту.Остатки(, РНК = &РНК) КАК РасхожденияПоАктуОстатки";
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НайденнаяСтрока = товары.Найти(Выборка.Номенклатура,"Номенклатура");
				Если НайденнаяСтрока = Неопределено Тогда
					Акт.СостоянияРКМ = Перечисления.СостоянияРКМ.НеСовпадаетСАктом;
					Прервать;
				ИначеЕсли НайденнаяСтрока.КоличествоИсх <> Выборка.ОтправленоОстаток  или НайденнаяСтрока.КоличествоФакт <> Выборка.ПринятоОстаток Тогда
					Акт.СостоянияРКМ = Перечисления.СостоянияРКМ.НеСовпадаетСАктом;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			//катаев+ 20/05/13
			//Акт.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
			Попытка
				//крохин начало 28.05.2013
				//пока закомментировал
				Акт.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
				//крохин конец 28.05.2013
			Исключение
			КонецПопытки;
			//Катаев- 20/05/13
		КонецЕсли;
	КонецЕсли;
	//Валетов + 17,04,2025 Создание ХКМ для движения регистра Статусы КМ Факт
	//https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4172  
	Если НЕ Отказ 
		И ШтрихкодыУпаковок.Количество() > 0 
		//И НЕ ЭтоНовый() 
		И НЕ Документы.ХранилищеКодовМаркировки.ПроверитьНаличиеХКМ(Ссылка,Перечисления.ПланФакт.Факт) Тогда
		//Валеов+ 27,05,2025 Закоментировал проверку, иногда не создается ХКМ если РКМ СРАЗУ заполняют марками при создании
		//Если НЕ ШтрихкодыУпаковок.Количество() = Ссылка.ШтрихкодыУпаковок.Количество() Тогда
			//РезультатРаботыСХКМ=Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ПНК_Факт(Ссылка);
			//  Так не работает потому, что нет ЛН к РКМ с марками.Сделаем свой аналог. 
			РезультатРаботыСХКМ = Создать_ХКМ_к_РКМ(Ссылка);	
			Если не РезультатРаботыСХКМ.Успешно тогда
				РезультатРаботыСХКМ.Ошибки.Добавить("Не удалось создать хранилище кодов маркировки");
				СообщитьИзМодуля(СтрСоединить(РезультатРаботыСХКМ.Ошибки,","));
				отказ=Истина;	
			КонецЕсли;
			
		//КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

