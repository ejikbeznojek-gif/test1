Функция Создать_ХКМ_к_РКМ(СсылкаРКМ) 
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);		
		
	ПланФакт = Перечисления.ПланФакт.Факт;
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ
	|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
	|ГДЕ
	|	ХранилищеКодовМаркировки.ДокОснование = &ДокОснование
	|	И ХранилищеКодовМаркировки.ПланФакт = &ПланФакт";
	Запрос.УстановитьПараметр("ДокОснование",	СсылкаРКМ);
	Запрос.УстановитьПараметр("ПланФакт",		ПланФакт);
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
	Если РезультатЗапроса.Следующий() Тогда
		ДокОбъект = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		ДокОбъект.ШтрихкодыУпаковок.Очистить();
	Иначе				
		ДокОбъект = Документы.ХранилищеКодовМаркировки.СоздатьДокумент();
		
		ДокОбъект.Дата	= ТекущаяДата();
		ДокОбъект.Заполнить(Новый Структура("ДокОснование,ТолькоШапка", СсылкаРКМ, Истина));
	КонецЕсли;
	//Валетов + 22,02,2025
	//ПУСТАЯ ЗАДАЧА Добавление движения ХКМ для РКМ с пересортом. Одна КМ "+" на склад, вторая "-" покупателю.
	
	ДокОбъект.ПланФакт	= ПланФакт;
	//+HELP-7109 20251112 Михайловский 
	//ДокОбъект.Операция	= Перечисления.СкладскиеОперации.Приемка; 
	ДокОбъект.Операция	= ?(ТипЗнч(Ссылка.ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная"), Перечисления.СкладскиеОперации.Отгрузка, Перечисления.СкладскиеОперации.Приемка);
	//-HELP-7109 20251112 Михайловский
	ДокОбъект.Организация = Организация;
	ДокОбъект.ДокОснование = Ссылка;
	//+HELP-7109 20251112 Михайловский
	//ДокОбъект.Отправитель = Корреспондент;
	//ДокОбъект.Получатель = Склад.Подразделение; 
	ДокОбъект.Отправитель = ?(ДокОбъект.Операция = Перечисления.СкладскиеОперации.Отгрузка, Склад.Подразделение, Корреспондент);
	ДокОбъект.Получатель = ?(ДокОбъект.Операция = Перечисления.СкладскиеОперации.Отгрузка, Корреспондент,  Склад.Подразделение);
	//-HELP-7109 20251112 Михайловский
	
	//ДокОбъект.ШтрихкодыУпаковок.Загрузить(ШтрихкодыУпаковок.Выгрузить(,"ШтрихкодУпаковки"));
	Для Каждого ШтрихКодУпаковки Из ШтрихкодыУпаковок Цикл
		СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();		
		СтрокаТЧ.ШтрихкодУпаковки = ШтрихКодУпаковки.ШтрихкодУпаковки;
		
		Если ШтрихКодУпаковки.СтатусУКонтрагента = Перечисления.СтатусыМарокУКонтаргента.Излишек Тогда
			СтрокаТЧ.Операция = Перечисления.СкладскиеОперации.Отгрузка;
		Иначе 
			СтрокаТЧ.Операция = Перечисления.СкладскиеОперации.Приемка;
		КонецЕсли;
		
	КонецЦикла;
	//Валетов -
	ДокОбъект.ПометкаУдаления = Ложь; 
	
	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
	
	Результат.Успешно = Истина;	
	
	Возврат Результат;
	
КонецФункции
