Процедура ОбработкаЗаполнения(ДокументОснование)  Экспорт
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	
	ДокОснование		= ДокументОснование;
	
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда		
		ИБ 					= ДокОснование.ИБ;
		Организация 		= ДокОснование.Организация;
		Подразделение		= ДокОснование.Склад.Подразделение;
		
		Контрагент 			= ДокОснование.Контрагент;
		ПринятоОт			= ДокОснование.Контрагент;
		КонтрагентЦБ		= Контрагент.Ведущий;
		Договор 			= ДокОснование.Договор;		
		
		Сумма 				= ДокОснование.СуммаДокумента;
		Валюта 				= ДокОснование.Валюта;
		
		СтатьяДДС			= Справочники.СтатьиЗатрат.НайтиПоКоду("211 100"); //выручка
		
	КонецЕсли;
	
	Комментарий 		= "На основании: "+ДокОснование;		
	Основание			= ""+ДокОснование;
	ВидОперации			= Перечисления.ВидыОперацийПКО.ОплатаПокупателя;
	
	//крохин начало
	Если Дата > '20100601' И Контрагент <> Справочники.Контрагенты.ПустаяСсылка() И Контрагент.родитель <> Подразделение.ЧастноеЛицо.Родитель Тогда
		ДопПроводки = Истина;	
	Иначе
		ДопПроводки = Ложь;
	КонецЕсли;
	//крохин конец
	
	
КонецПроцедуры

