Функция РаспределитьЗатраты(Знач СуммаКРаспределению)	
	БР=Новый ТаблицаЗначений; //база распределения
	БР.Колонки.Добавить("СтатьяДДС");
	БР.Колонки.Добавить("Подразделение");
	БР.Колонки.Добавить("КапитальныеЗатраты");	
	БР.Колонки.Добавить("ПериодРасходов");	
	БР.Колонки.Добавить("Проект");	
	БР.Колонки.Добавить("СубЗатрата");
	БР.Колонки.Добавить("База",ПолучитьОписаниеТиповЧисла(19,2));
	БР.Колонки.Добавить("Сумма",ПолучитьОписаниеТиповЧисла(19,2));	
		
	Если РасшифровкиЗатрат.Количество()=0 Тогда
		СтрокаБР=БР.Добавить();
		
		СтрокаБР.СтатьяДДС			= СтатьяДДС;
		СтрокаБР.Подразделение		= Подразделение;
		СтрокаБР.КапитальныеЗатраты = КапитальныеЗатраты;
		СтрокаБР.ПериодРасходов		= НачалоМесяца(?(ЗначениеЗаполнено(ПериодРасходов),ПериодРасходов,Дата));
		СтрокаБР.Проект				= Проект;
		СтрокаБР.СубЗатрата			= СубЗатрата;		
		
		СтрокаБР.База				= СуммаКРаспределению;
		СтрокаБР.Сумма				= СуммаКРаспределению;
	Иначе
		Для Каждого СтрокаР Из РасшифровкиЗатрат Цикл
			СтрокаБР=БР.Добавить();		
			
			СтрокаБР.СтатьяДДС			= ?(ЗначениеЗаполнено(СтрокаР.СтатьяДДС)	,СтрокаР.СтатьяДДС		,СтатьяДДС);
			СтрокаБР.Подразделение		= ?(ЗначениеЗаполнено(СтрокаР.Подразделение),СтрокаР.Подразделение	,Подразделение);		
			СтрокаБР.КапитальныеЗатраты = ?(ЗначениеЗаполнено(СтрокаР.КапитальныеЗатраты),СтрокаР.КапитальныеЗатраты,КапитальныеЗатраты);
			СтрокаБР.Проект				=Проект;
			СтрокаБР.СубЗатрата			=СубЗатрата;		
			
			Если ЗначениеЗаполнено(СтрокаР.ПериодРасходов) Тогда
				СтрокаБР.ПериодРасходов		= НачалоМесяца(СтрокаР.ПериодРасходов);
			ИначеЕсли ЗначениеЗаполнено(ПериодРасходов) Тогда
				СтрокаБР.ПериодРасходов		= НачалоМесяца(ПериодРасходов);
			Иначе
				СтрокаБР.ПериодРасходов		= НачалоМесяца(Дата);
			КонецЕсли;
			
			СтрокаБР.База			= СтрокаР.Сумма;			
		КонецЦикла;
		
		МаксСтрокаБР	=Неопределено;
		МаксСумма		=-100000000000000000000000000;
		
		БазаВсего=БР.Итог("База");
		
		Если БазаВсего=0 Тогда
			СообщитьОбОшибке("Нулевая база распределения расходов !!!");
			
			БР.ЗаполнитьЗначения(1,"База");
			БазаВсего=БР.Итог("База");
		КонецЕсли; 
		
		Для Каждого СтрокаБР Из БР Цикл		
			СтрокаБР.Сумма=СуммаКРаспределению*СтрокаБР.База/БазаВсего;
			
			Если Модуль(СтрокаБР.Сумма)>МаксСумма Тогда
				МаксСумма	=Модуль(СтрокаБР.Сумма);
				МаксСтрокаБР=СтрокаБР;			
			КонецЕсли; 
		КонецЦикла; 
		
		Если БР.Итог("Сумма")<>СуммаКРаспределению И МаксСтрокаБР<>Неопределено Тогда
			МаксСтрокаБР.Сумма=МаксСтрокаБР.Сумма+(СуммаКРаспределению-БР.Итог("Сумма"));
		КонецЕсли; 
	КонецЕсли;	
	
	Возврат БР;
КонецФункции //ПолучитьЗатраты(СтрокаТЧ)


Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт	
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.

	Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда Возврат КонецЕсли; 
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
	
	ВалютаУпр		=ПараметрыСеанса.ВалютаУпр_2009;
	КурсУпр			=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	СуммаУпр		=глПересчет(Сумма,Валюта,Дата,ВалютаУпр,КурсУпр,Ложь);
	
	КурсВал			=ПолучитьКурсВалюты_ПоРусски(Валюта,Дата);
	
	Если Затраты Тогда //ЗАТРАТЫ		
		БР=РаспределитьЗатраты(Сумма);
		
		Для Каждого СтрокаБР Из БР Цикл
			СуммаДок 					= СтрокаБР.Сумма;			
			
			Если СуммаДок=0 Тогда Продолжить КонецЕсли; 
			
			Движение 					= Движения.Затраты.Добавить();
			
			Движение.ВидДвижения		= ВидДвиженияНакопления.Расход;	
			
			Движение.Период				= Дата;
			
			Движение.Подразделение		= СтрокаБР.Подразделение;
			Движение.СтатьяЗатрат		= СтрокаБР.СтатьяДДС;			
			Движение.СубЗатрата			= СтрокаБР.СубЗатрата;
			
			Движение.СуммаУпр			= Модуль(глПересчет(СуммаДок,Валюта,КурсВал,ВалютаУпр,КурсУпр));			
			
			Движение.Контрагент			= Контрагент;
			Движение.Договор			= Договор;
			
			Движение.СуммаДокумента		= СуммаДок;
			Движение.ВалютаДокумента	= Валюта;				
			
			Движение.КапитальныеЗатраты	= СтрокаБР.КапитальныеЗатраты;			
			Движение.Проект				= СтрокаБР.Проект;
			Движение.ПериодРасходов		= СтрокаБР.ПериодРасходов;
		//крохин начало
		Движение.Комментарий        = Комментарий;
		//крохин конец

			
			Движение.ДатаЗаписи			= ТекущаяДата();
		КонецЦикла;
	Иначе //ВЗАИМОРАСЧЕТЫ
		Если Контрагент.Пустая() Тогда			
			Сообщить("Не указан контрагент !",СтатусСообщения.Важное);
		КонецЕсли; 
		
		ВалютаРасчетов				= ПолучитьВалютуРасчетов(Договор);		
		
		Движение 					= Движения.Взаиморасчеты.Добавить();
		Движение.ВидДвижения		= ВидДвиженияНакопления.Расход;
		
		Движение.Период				= Дата;
		
		Движение.Контрагент			= ?(КонтрагентЦБ.Пустая(),Контрагент,КонтрагентЦБ);		
		Движение.Договор 			= Договор;			
		
		Движение.СуммаВал			= Модуль(глПересчет(Сумма,Валюта,Курс,ВалютаРасчетов,Дата));
		Движение.СуммаУпр			= Модуль(СуммаУпр);
		
		Движение.СуммаДокумента		= Сумма;
		Движение.ВалютаДокумента	= Валюта;	
		Движение.СтатьяДДС			= СтатьяДДС;			
		
		Если ДокОснование<>Неопределено И ЕстьРеквизитДокумента("КодОперации",ДокОснование.Метаданные()) Тогда
			Движение.КодОперации=ДокОснование.КодОперации;			
		КонецЕсли;		
	КонецЕсли;	
	
	//ДДС	
	БР=РаспределитьЗатраты(Сумма);
		
	Для Каждого СтрокаБР Из БР Цикл
		СуммаДок 					= СтрокаБР.Сумма;
		
		Движение					= Движения.ДенежныеСредства.Добавить();
		
		Движение.Период				= Дата;
		Движение.ВидДвижения		= ВидДвиженияНакопления.Приход;			
		Движение.БанковскийСчет		= Касса;			
		Движение.Валюта				= Валюта;
		
		Движение.Сумма				= СуммаДок;
		Если Дата>='20090101' Тогда
			Движение.СуммаУпр		= СуммаУпр;		
		КонецЕсли;		
		
		Движение.СуммаДокумента		= СуммаДок;
		Движение.ВалютаДокумента	= Валюта;
		
		Движение.СтатьяДДС			= СтатьяДДС;
		//крохин начало
		Движение.Комментарий        = Комментарий;
			Если Дата > '20100901' Тогда
				Движение.Субзатрата         = СтрокаБР.СубЗатрата;
			КонецЕсли;

		//крохин конец
		
		//крохин начало 14.08.2013
		//Движение.Отправитель		= КонтрагентЦБ;
		Если Дата >= '20130801' Тогда
		Движение.Отправитель		= ?(КонтрагентЦБ.Пустая(),Контрагент,КонтрагентЦБ);	
		Иначе
		Движение.Отправитель		= КонтрагентЦБ;	
		КонецЕсли;
		//крохин конец 14.08.2013
		Движение.Договор			= Договор;
		//+HELP-2684 20250204 Михайловский
		Если ЗначениеЗаполнено(Касса.ПодразделениеДляУчета) И (Дата>='20241201') И НЕ(Касса.ПодразделениеДляУчета	= Подразделение)  Тогда
			Движение.Подразделение	= Касса.ПодразделениеДляУчета;
		Иначе
			Движение.Подразделение		= Подразделение;
		КонецЕсли;
		//-HELP-2684 20250204 Михайловский
	КонецЦикла;
	
	Если ОбменДанными.Загрузка Тогда
		Движения.Взаиморасчеты.Записать();
		Движения.Затраты.Записать();
		Движения.ДенежныеСредства.Записать();	
	КонецЕсли;
КонецПроцедуры

