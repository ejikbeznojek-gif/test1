Функция ПолучитьТЗОтрабатываемыхСтрок ()  экспорт
	ТЗСтрок=Новый ТаблицаЗначений;
	ТЗСтрок.Колонки.Добавить("Подразделение");
	
	если не Согласования.найти(Справочники.Подразделения.НайтиПоКоду("SSP-0001")).Согласовано и ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаЦО") тогда
		СтрТЗ = ТЗСтрок.Добавить();
		СтрТЗ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SSP-0001");
	КонецЕсли;
	
	//Кухарь 15.08.19 начало
	//ОВЛ больше не нужны
	//если не Согласования.найти(Справочники.Подразделения.НайтиПоКоду("SMN-0434")).Согласовано  и ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаОВЛ") тогда
	//	СтрТЗ = ТЗСтрок.Добавить();
	//	СтрТЗ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0434");		
	//КонецЕсли;
	//Кухарь 15.08.19 конец	
	
	//Кухарь А.Ю.  25.05.2022 начало
	//Галки по складу ставим только на складе
	//если не Согласования.найти(Справочники.Подразделения.НайтиПоКоду("SMN-0436")).Согласовано  и ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаСК") тогда
	если не Согласования.найти(Справочники.Подразделения.НайтиПоКоду("SMN-0436")).Согласовано  и ПолучитьПолномочиеПользователя("ДокументКоррекцияОбработкаСК")
		и ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.Склад  тогда		
		//Кухарь А.Ю.  25.05.2022 конец
	

		СтрТЗ = ТЗСтрок.Добавить();
		СтрТЗ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0436");		
	КонецЕсли;
	
	
	Возврат ТЗСтрок;
КонецФункции

Функция ОтработатьКусокКоррекции () экспорт
	ТЗСтрок=ПолучитьТЗОтрабатываемыхСтрок();
	Для каждого СтрТЗ из ТЗСтрок цикл
		СтрТЧ=Согласования.Найти(СтрТЗ.Подразделение);
		СтрТЧ.Согласовано=Истина;
		СтрТЧ.АвторСогласования=ПараметрыСеанса.Пользователь.ФизЛицо;
		// Кухарь А.Ю. 25.08.2021 начало
		//По просьбе Лисицкого М.В.
		СтрТЧ.ДатаСогласования=ТекущаяДата(); 
		//Кухарь А.Ю.  25.08.2021 конец		
	КонецЦикла;	
	МассНеотработанных=Согласования.НайтиСтроки(новый Структура("Согласовано",Ложь));
	если МассНеотработанных.Количество()=0 тогда
		возврат ОтработатьКоррекциюПолностью();
	иначе	
		если не КоррекциюМожноЗаписывать() тогда
			НачатьТранзакцию();
			Записать(РежимЗаписиДокумента.Проведение);
			//Кухарь 15.10.19 начало
			//Убрать лишние перезаписи накладной
			//НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);				
			НакладнаяОбъект=ДокОснование.ПолучитьОбъект();			
			если СостояниеКоррекции<>НакладнаяОбъект.СостояниеКоррекции тогда
				НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);
			КонецЕсли;
			//Кухарь 15.10.19 конец	
			ЗафиксироватьТранзакцию();			
			Возврат Истина;			
		иначе
			возврат ложь;
		КонецЕсли;		
	КонецЕсли;
	
КонецФункции

Процедура ОтклонитьКоррекцию() экспорт
	СостояниеКоррекции=Перечисления.СостоянияКоррекции.Отклонена;
	Отработана=Истина;
	Отработал=ПараметрыСеанса.Пользователь.ФизЛицо;
	СформироватьУведомление("Уведомление об отклонении коррекции товаров");	
	НачатьТранзакцию();
	//Кухарь 15.10.19 начало
	//Убрать лишние перезаписи накладной
	//НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);		
	НакладнаяОбъект=ДокОснование.ПолучитьОбъект();	
	если СостояниеКоррекции<>НакладнаяОбъект.СостояниеКоррекции тогда
		НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);
	КонецЕсли;
	//Кухарь 15.10.19 конец		
	Записать();
	ЗафиксироватьТранзакцию();
КонецПроцедуры

