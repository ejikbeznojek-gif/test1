Функция ОтработатьКоррекциюПолностью_OLD()	
	//Кухарь 15.08.19 начало
	//В ЦО этого делать нельзя
	если ПараметрыСеанса.ЭтотУзел.ТипУзла<>Перечисления.ТипУзлаИБ.Склад тогда
		СообщитьИзМодуля("Коррекции по товарам отрабатываются на складе");
		Возврат ложь;			
	КонецЕсли;
	//Кухарь 15.08.19 конец
	МассИзменяемыхСтрок=Товары.НайтиСтроки(новый Структура ("СтрокаИзменена",Истина));
	если МассИзменяемыхСтрок.Количество()>0 тогда
		ДокОснованиеОбъект=ДокОснование.ПолучитьОбъект();
		Для каждого СтрМасс из МассИзменяемыхСтрок цикл
			МассТЧ=ДокОснованиеОбъект.Товары.НайтиСтроки(новый Структура("Номенклатура",СтрМасс.Номенклатура));
			Если МассТЧ.Количество()>1 тогда
				СообщитьИзМодуля("Количество строк с товаром "+СтрМасс.Номенклатура.Наименование+" больше 1");
				Возврат ложь;				
			КонецЕсли;		
			если МассТЧ.Количество()=1 тогда
				СтрокаТЧ=МассТЧ.Получить(0);
			иначе
				СтрокаТЧ=ДокОснованиеОбъект.Товары.Добавить();
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрМасс);	
		КонецЦикла;
		
		//Кухарь 15.08.19 начало
		//Чтобы грузилась подтверждённая заявка
		//если Товары.Количество()>ТоварыДоИзменения.Количество() тогда
		//	ДокОснованиеОбъект.ЗагружатьЦеныВЦО=Истина;
		//КонецЕсли;
		ДокОснованиеОбъект.ЗагружатьЦеныВЦО=Истина;		
		//Кухарь 15.08.19 конец
		
		
		Отработана=Истина;
		Отработал=ПараметрыСеанса.Пользователь.ФизЛицо;
		СостояниеКоррекции=Перечисления.СостоянияКоррекции.Принята;
		ДокОснованиеОбъект.СостояниеКоррекции=СостояниеКоррекции;
		
		// Кухарь А.Ю. 06.04.2020 начало
		// Заблокируем накладную
		если ПолучитьНомерСостоянияНакладной(ДокОснованиеОбъект.СостояниеНакладной)>= 325 тогда//Сформированы ЗНБ 
			БлокируемНакладную=Истина;
			запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			|	ЗаданиеНабора.Ссылка КАК ЗНБ,
			|	ЗаданиеНабора.ДокументОснование КАК ПН
			|ИЗ
			|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
			|ГДЕ
			|   ЗаданиеНабора.Дата >= &Дата
			|	И ЗаданиеНабора.Проведен
			|	И ЗаданиеНабора.Накладная = &Накладная" ;
		запрос.УстановитьПараметр("Дата",ТекущаяДата()-30*24*3600);
		запрос.УстановитьПараметр("Накладная",ДокОснование);
		ТЗЗНБ=запрос.Выполнить().Выгрузить();
		если ТЗЗНБ.Количество()=0 тогда
			БлокируемНакладную=Ложь;
		КонецЕсли;
		ПланНабора=ТЗЗНБ.Получить(0).ПН;		
		иначе
			БлокируемНакладную=ложь;
		КонецЕсли;
		// Кухарь А.Ю. 06.04.2020 конец
		
		
		
		НачатьТранзакцию();	
		//Кухарь 16.09.19 начало
		//Иначе строчки с новым товаром не добавляются.
		ПараметрыСеанса.ЗапущенаОбработка=Истина;
		//Кухарь 16.09.19 конец		
		
		// Кухарь А.Ю. 06.04.2020 начало
		// Сразу изменим состояние накладной, чтобы не перезаписывать потом
		если БлокируемНакладную тогда
			ДокОснованиеОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.ОжиданиеКорректировки;
		КонецЕсли;	 
		// Кухарь А.Ю. 06.04.2020 конец
		
		
		
		ДокОснованиеОбъект.Записать(РежимЗаписиДокумента.Проведение);  
		Записать(РежимЗаписиДокумента.Проведение);
		СформироватьУведомление("Уведомление об отработке коррекции товаров");	
		//Кухарь 16.09.19 начало
		//Иначе строчки с новым товаром не добавляются.
		ПараметрыСеанса.ЗапущенаОбработка=ложь;
		//Кухарь 16.09.19 конец		
		
		// Кухарь А.Ю. 06.04.2020 начало
		//Обработаем сначала ЗНБ, а потом ПН.
		если БлокируемНакладную тогда
			Для каждого СтрЗНБ из ТЗЗНБ цикл
				документы.ЗаданиеНабора.УстановитьСостояниеБлокировки(СтрЗНБ.ЗНБ,Перечисления.СостоянияНакладной.ОжиданиеКорректировки);
			КонецЦикла;
			ПланНабора=ПланНабора.получитьобъект();
			Для каждого СтрТЧ из ПланНабора.тБрэндов цикл
				СтрТЧ.Состояние = Перечисления.СостоянияНакладной.ОжиданиеКорректировки;
			КонецЦикла;
			ПланНабора.записать();
		КонецЕсли;	 
		// Кухарь А.Ю. 06.04.2020 конец
		
		
		
		ЗафиксироватьТранзакцию();
		
		СообщитьИзМодуля("Коррекция отработана");
		Возврат Истина
	КонецЕсли;	
КонецФункции
