Процедура ОбработкаПроведения(Отказ, РежимПроведения) экспорт
	Если РезервироватьТовар Тогда
	//++Ратманов управляемые блокировки
	Если НЕ ПроведениеС.БлокировкаПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	Если НЕ ПроведениеС.КонтрольПоОбъекту(Ссылка) Тогда  
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	//--Ратманов управляемые блокировки
		Если ПараметрыСеанса.ЭтотУзел=ПланыОбмена.Основной.НайтиПоКоду("SNL") И СостояниеКоррекции=Перечисления.СостоянияКоррекции.Принята Тогда
			
			//Если Ссылка.ДокОснование.ИБ=Справочники.ИБ.НайтиПоКоду("SSP") Тогда
			Движения.РезервыТМЦ.Записывать=Истина;
			Запрос=Новый Запрос;
			Запрос.Текст=
			"ВЫБРАТЬ
			|	КоррекцияТоваровТовары.Номенклатура КАК Номенклатура,
			|	КоррекцияТоваровТовары.Количество КАК Количество,
			|	КоррекцияТоваровТоварыДоИзменения.Количество КАК Количество1
			|ИЗ
			|	Документ.КоррекцияТоваров.Товары КАК КоррекцияТоваровТовары
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КоррекцияТоваров.ТоварыДоИзменения КАК КоррекцияТоваровТоварыДоИзменения
			|		ПО КоррекцияТоваровТовары.Номенклатура = КоррекцияТоваровТоварыДоИзменения.Номенклатура
			|			И КоррекцияТоваровТовары.Ссылка = КоррекцияТоваровТоварыДоИзменения.Ссылка
			|ГДЕ
			|	КоррекцияТоваровТовары.Ссылка = &Ссылка";
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			Выб=Запрос.Выполнить().Выбрать();
			Пока Выб.Следующий() Цикл
				Если (Выб.Количество1-Выб.Количество)>0 Тогда
					ТекДвиж=Движения.РезервыТМЦ.Добавить();
					ТекДвиж.ВидДвижения=ВидДвиженияНакопления.Приход;
					ТекДвиж.Активность=Истина;
					ТекДвиж.Номенклатура=Выб.Номенклатура;
					ТекДвиж.Регистратор=Ссылка;
					ТекДвиж.Период=Ссылка.Дата;
					ТекДвиж.Заказ=Ссылка.ДокОснование;
					ТекДвиж.Склад=Ссылка.ДокОснование.Склад;
					ТекДвиж.Получатель=Ссылка.ДокОснование.Контрагент;
					ТекДвиж.Количество=(Выб.Количество1-Выб.Количество);
				КонецЕсли;	
			КонецЦикла;	
			Движения.РезервыТМЦ.Записать();
			
		КонецЕсли;	
	КонецЕсли;	
КонецПроцедуры                                                                         

Процедура ОбработкаУдаленияПроведения(Отказ)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
