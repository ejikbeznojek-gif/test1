   
Процедура ОбработкаЗаполнения(Основание) 
	Если ТипЗнч(Основание)=Тип("Структура") Тогда Возврат КонецЕсли;
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	Если Основание.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе  Тогда
			СообщитьИзМодуля("Накладные в состоянии ""в работе"" корректируются без заявки!");	
		Возврат;
	КонецЕсли;
	// Шворобей ВЮ 24.05.2022 +
	//если Основание.Метаданные().имя="РасходнаяНакладная" и Основание.ОтгрузкаКомплектов тогда
	//	СообщитьИзМодуля("на РНК с внутренними комплектациями создание коррекции по товарам запрещено.");	
	//	Возврат;
	//КонецЕсли;
	// Шворобей ВЮ 24.05.2022 +
	
	Автор=ПараметрыСеанса.Пользователь;
	ДокОснование	= Основание;
	
	Префикс=ДокОснование.Номер+"/";
	УстановитьНовыйНомер(Префикс);	
	ТЗ=ДокОснование.товары.выгрузить();
	Товары.Загрузить(тз);
	ТоварыДоИзменения.Загрузить(тз);
	КоличествоДокумента=Товары.Итог("Количество");
	КоличествоДокументаДоИзменения=ТоварыДоИзменения.Итог("Количество");
	СуммаДокумента=Товары.Итог("Всего");
	СуммаДокументаДоИзменения=ТоварыДоИзменения.Итог("Всего");
	ОбъемДокумента=Товары.Итог("Объем");
	ОбъемДокументаДоИзменения=ТоварыДоИзменения.Итог("Объем");
	СостояниеКоррекции=Перечисления.СостоянияКоррекции.ВРаботе;	
	Дата=ТекущаяДата();
	
	СтрТЧ=Согласования.Добавить();
	СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SSP-0001");  //ЦО (Управление)
	//Кухарь 15.08.19 начало
	//ОВЛ больше не нужны	
	//СтрТЧ=Согласования.Добавить();	
	//СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0434");  //ОВЛ
	//Кухарь 15.08.19 конец		
	СтрТЧ=Согласования.Добавить();	
	СтрТЧ.Подразделение=Справочники.Подразделения.НайтиПоКоду("SMN-0436");  //Складской Комплекс Общие

	// Шворобей ВЮ 24.05.2022 +

	//Кухарь  26.05.2022 начало
	//	ЗаполнитьКомплектующие();
	Комплектующие.Загрузить(ДокОснование.Комплектующие.выгрузить());	 
	//Кухарь  26.05.2022 конец
	
	КомплектующиеДоИзменения.Загрузить(Комплектующие.Выгрузить());
	// Шворобей ВЮ 24.05.2022 +
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Возврат;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	если не ОбменДанными.Загрузка тогда
		КоличествоДокумента=Товары.Итог("Количество");
		КоличествоДокументаДоИзменения=ТоварыДоИзменения.Итог("Количество");
		СуммаДокумента=Товары.Итог("Всего");
		СуммаДокументаДоИзменения=ТоварыДоИзменения.Итог("Всего");
		ОбъемДокумента=Товары.Итог("Объем");
		ОбъемДокументаДоИзменения=ТоварыДоИзменения.Итог("Объем");
		

		Отказ=КоррекциюМожноЗаписывать(Отказ);
			
		СтароеСостояние=ссылка.СостояниеКоррекции;
		НовоеСостояние=СостояниеКоррекции;
		
		если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			//Кухарь 15.10.19 начало
			//Для отображения того, что коррекция уже есть
			если НовоеСостояние<>ДокОснование.СостояниеКоррекции тогда
				НакладнаяОбъект=ДокОснование.ПолучитьОбъект();
				НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);					
			КонецЕсли;
			//Кухарь 15.10.19 конец
			
			если (НовоеСостояние=Перечисления.СостоянияКоррекции.Утверждена и СтароеСостояние<>Перечисления.СостоянияКоррекции.Утверждена) или
				 (НовоеСостояние=Перечисления.СостоянияКоррекции.Утверждена и ЭтоНовый()) или
				(НовоеСостояние=Перечисления.СостоянияКоррекции.Отклонена и СтароеСостояние<>Перечисления.СостоянияКоррекции.Отклонена)  тогда
				НужноВыгружать=Истина;
			иначе
				НужноВыгружать=Ложь;
			КонецЕсли;
		иначе
			если (НовоеСостояние=Перечисления.СостоянияКоррекции.Принята и СтароеСостояние<>Перечисления.СостоянияКоррекции.Принята) или
				(НовоеСостояние=Перечисления.СостоянияКоррекции.Отклонена и СтароеСостояние<>Перечисления.СостоянияКоррекции.Отклонена)  тогда
				НужноВыгружать=Истина;
			иначе
				НужноВыгружать=Ложь;
			КонецЕсли;
		КонецЕсли;
		
	иначе
		//Кухарь 16.10.19 начало
		//Для отображения того, что коррекция уже есть
		если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда	
			если СостояниеКоррекции<>ДокОснование.СостояниеКоррекции тогда
				НакладнаяОбъект=ДокОснование.ПолучитьОбъект();
				НакладнаяОбъект.УстановитьСостояниеКоррекции(СостояниеКоррекции);					
			КонецЕсли;
		КонецЕсли;
		//Кухарь 16.10.19 конец			
		НужноВыгружать=ложь;
	КонецЕсли;
	
	если НужноВыгружать тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);	
	КонецЕсли;
	
КонецПроцедуры

