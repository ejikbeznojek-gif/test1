		если ВидУведомления="Уведомление об отработке коррекции товаров" тогда
		СписокПолучателей.Добавить("ovlto@collant.ru");
		КонецЕсли;
		//Кухарь 15.08.19 конец	
		
		
		ТекстПисьма="Коррекция "+Номер+" была "+?(ВидУведомления="Уведомление об отработке коррекции товаров"," отработана "," отклонена ")+" пользователем "+ПараметрыСеанса.Пользователь;
		//Кухарь 16.08.19 начало
		//выводе изменений в уведомления
		ТЗИзменений=новый ТаблицаЗначений;		
		ТЗИзменений.Колонки.Добавить("Реквизит");
		ТЗИзменений.Колонки.Добавить("ДоИзменения");
		ТЗИзменений.Колонки.Добавить("ПослеИзменения");
		если ОбъемДокумента<>ОбъемДокументаДоИзменения тогда
			СтрТЗ=ТЗИзменений.Добавить();
			СтрТЗ.Реквизит="Объём номенклатуры";
			СтрТЗ.ДоИзменения=ОбъемДокументаДоИзменения;
			СтрТЗ.ПослеИзменения=ОбъемДокумента;	
		КонецЕсли;
		если СуммаДокумента<>СуммаДокументаДоИзменения тогда
			СтрТЗ=ТЗИзменений.Добавить();
			СтрТЗ.Реквизит="Сумма документа";
			СтрТЗ.ДоИзменения=СуммаДокументаДоИзменения;
			СтрТЗ.ПослеИзменения=СуммаДокумента;	
		КонецЕсли;
		если КоличествоДокумента<>КоличествоДокументаДоИзменения тогда
			СтрТЗ=ТЗИзменений.Добавить();
			СтрТЗ.Реквизит="Количество";
			СтрТЗ.ДоИзменения=КоличествоДокументаДоИзменения;
			СтрТЗ.ПослеИзменения=КоличествоДокумента;	
		КонецЕсли;
		если ТЗИзменений.Количество()>0 Тогда
			ХТМЛТекст=ПреобразоватьТаблицуВHTMLText(ТЗИзменений,ТекстПисьма,ТЗИзменений);
			ТекстПисьма=ХТМЛТекст;
		КонецЕсли;
		//Кухарь 16.08.19 конец
		
		
	ИначеЕсли ВидУведомления="Уведомление об утверждении коррекции товаров"  тогда
		СписокПолномочий=новый СписокЗначений;
		
		//Михайловский С. 20220718 -коррекция по полномочиям+++
		ДопСписок1=СформСписокПолучат(Справочники.ТипыРассылок.НоменклатураБезСектора, Справочники.Подразделения.НайтиПоКоду("SSP-0145"));
		ДопСписок2=СформСписокПолучат(Справочники.ТипыРассылок.НоменклатураБезСектора, Справочники.Подразделения.НайтиПоКоду("SMN-0436"));
		если Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SSP-0145"))<>Неопределено тогда  //Претензионно-ревизионный отдел
		
			Если ДопСписок1.Количество() Тогда
				Для Каждого ТЭл ИЗ ДопСписок1 Цикл
					СписокПолучателей.Добавить(ТЭл.Значение);
				КонецЦикла;	
			Иначе
				СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработка);
			КонецЕсли;
			
		КонецЕсли;					

		//Кухарь 15.08.19 начало
		//ОВЛ больше не нужны
		//если Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0434"))<>Неопределено тогда   //ОВЛ
		//	СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработкаОВЛ);
		//КонецЕсли;		
		//Кухарь 15.08.19 конец			
		если Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0436"))<>Неопределено тогда  //Складской Комплекс Общие
			
			Если ДопСписок2.Количество() Тогда
				Для Каждого ТЭл ИЗ ДопСписок2 Цикл
					СписокПолучателей.Добавить(ТЭл.Значение);
				КонецЦикла;	
			Иначе
				СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработкаСК);
			КонецЕсли;
			
		КонецЕсли;	
		Если НЕ ДопСписок1.Количество() И НЕ ДопСписок2.Количество() Тогда
			Запрос=новый запрос;
			запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВЫРАЗИТЬ(ПолномочияПользователей.Пользователь.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК Почта,
			|	ПолномочияПользователей.Полномочие
			|ИЗ
			|	РегистрСведений.ПолномочияПользователей КАК ПолномочияПользователей
			|ГДЕ
			|	ПолномочияПользователей.Полномочие В(&СписокПолномочий)
			// Кухарь А.Ю.  17.06.2022 начало
			// По просьбе Никиты уволенных нужно убрать
			|	И ПолномочияПользователей.Пользователь.ФизЛицо.Штатный 
			// Кухарь А.Ю.  17.06.2022 конец			
			|	И ПолномочияПользователей.Значение = ИСТИНА";
			запрос.УстановитьПараметр("СписокПолномочий",СписокПолномочий);
			результат=запрос.Выполнить().Выбрать();
			пока результат.Следующий() цикл
				//Михайловский С. 20220712 -придется так+++
				//вместо
				//СписокПолучателей.Добавить(СокрЛП(результат.Почта));
				Если МИскл.Найти(СокрЛП(результат.Почта))=неопределено Тогда
					СписокПолучателей.Добавить(СокрЛП(результат.Почта));
				КонецЕсли;	
				//Михайловский С. 20220712 -придется так---
			КонецЦикла;
		КонецЕсли;
		//Михайловский С. 20220718 -коррекция по полномочиям---
		ТекстПисьма="Просьба отработать коррекцию по товарам "+Номер;
	КонецЕсли;
	
	//Михайловский С. 20220712 -дополнительно+++
	ДопСписок=СформСписокПолучат(Справочники.ТипыРассылок.НоменклатураБезСектора);
	Если ДопСписок.Количество() Тогда
		Для Каждого ТЭл ИЗ ДопСписок Цикл
			СписокПолучателей.Добавить(ТЭл.Значение);
		КонецЦикла;	
	КонецЕсли;	
	//Михайловский С. 20220712 -дополнительно---
	
	если СокрЛП(ТекстПисьма="") тогда
		ЗаписатьВЛог("Регламент","Пустой текст при формировании письма к коррекции № "+Номер,"Ошибка");		
	ИначеЕсли СписокПолучателей.Количество()=0 тогда
		ЗаписатьВЛог("Регламент","Пустой список адресатов при формировании письма к коррекции № "+Номер,"Ошибка");
	иначе
		ПодготовитьПисьмоКОтправке (СписокПолучателей,ТекстПисьма,ТемаПисьма);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодготовитьПисьмоКОтправке (СписокПолучателей,ТекстПисьма,ТемаПисьма)
	СписокАдресов="";
	для каждого Стр из СписокПолучателей цикл
		если Найти(СписокАдресов,Стр.Значение)=0 тогда
			СписокАдресов=СписокАдресов+Стр.Значение+"##";
		КонецЕсли;
	КонецЦикла;
	
	СписокАдресов=лев(СписокАдресов,СтрДлина(СписокАдресов)-2);
	
	
	ЗаписьВРег=РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
	ЗаписьВРег.Основание=Ссылка;	
	ЗаписьВРег.ДатаСозданияПисьма=ТекущаяДата();
	ЗаписьВРег.период=ЗаписьВРег.ДатаСозданияПисьма;
	
	ЗаписьВРег.ТекстПисьма=ТекстПисьма;
	ЗаписьВРег.ТемаПисьма=ТемаПисьма;
	ЗаписьВРег.СписокПолучателей=СписокАдресов;
	ЗаписьВРег.Записать();	
КонецПроцедуры
