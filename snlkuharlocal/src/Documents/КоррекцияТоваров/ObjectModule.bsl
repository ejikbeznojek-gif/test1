Процедура ЗаполнитьКоличествоПродукции() Экспорт
	
	// обнуление колонки КоличествоПродукции
	Для Каждого СтрокаТЧ Из Комплектующие Цикл 
		СтрокаТЧ.КоличествоПродукции = 0;
	КонецЦикла;
	
	ТПродукции = Товары.Выгрузить(, "Номенклатура, Количество, Коэффициент");
	Для Каждого СтрокаТЗ Из ТПродукции Цикл
		СтрокаТЗ.Количество = СтрокаТЗ.Количество * СтрокаТЗ.Коэффициент;		
	КонецЦикла;
	ТПродукции.Свернуть("Номенклатура", "Количество");
	
	Для Каждого СтрокаТЗ Из ТПродукции Цикл
		СтрокаКомплектующих = Комплектующие.Найти(СтрокаТЗ.Номенклатура, "Продукция");
		Если СтрокаКомплектующих <> Неопределено Тогда
			СтрокаКомплектующих.КоличествоПродукции = СтрокаТЗ.Количество;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
