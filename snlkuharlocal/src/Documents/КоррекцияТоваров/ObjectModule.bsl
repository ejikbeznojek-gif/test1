Функция ПреобразоватьТаблицуВHTMLText(ТЗ,ДопТекст,ТЗИзменений) 
	Ответ = "<HTML><HEAD><BODY>"+ДопТекст+"<TABLE border=1><TBODY>";	
	Ответ=Ответ+"<TR bgcolor=#FFFF99>";	
	Ответ=Ответ+"<TD><P><FONT size=3> Изменяемые реквизиты </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Старое значение </FONT></TD>";
	Ответ=Ответ+"<TD><P><FONT size=3> Новое значение </FONT></TD>";
	Ответ=Ответ+"</TR>";
	
	для каждого СтрокаТаблицы из ТЗ	цикл
		Ответ=Ответ+"<TR>";			
		Ответ=Ответ+"<TD><P><FONT size=3>"+СтрокаТаблицы.Реквизит+"</FONT></P></TD>";
		Ответ=Ответ+"<TD><P><FONT size=3>"+СтрокаТаблицы.ДоИзменения+"</FONT></P></TD>";
		Ответ=Ответ+"<TD><P><FONT size=3>"+СтрокаТаблицы.ПослеИзменения+"</FONT></P></TD>";		
		Ответ=Ответ+"</TR>";	
	КонецЦикла;			
	
	Ответ  =Ответ+"</TBODY></TABLE></BODY></HTML>";
	Возврат Ответ;
КонецФункции
