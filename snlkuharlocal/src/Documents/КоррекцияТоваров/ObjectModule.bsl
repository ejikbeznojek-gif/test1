Функция КоррекциюМожноЗаписывать (Отказ=ложь) 
	МассНулей=Товары.НайтиСтроки(новый Структура("Цена",0));
	Если МассНулей.Количество()>0 и МассНулей.Количество()<>Товары.Количество() тогда	
		// Кухарь А.Ю.  10.10.2022 начало
		ЕстьПозицииБезЦен=ложь; 
		// Кухарь А.Ю.  10.10.2022 конец
		
		Для каждого СтрМасс из МассНулей цикл
			// Кухарь А.Ю.  10.10.2022 начало
			//СообщитьИзМодуля("Нулевые цены в строке "+СтрМасс.НомерСтроки);			
			если СтрМасс.Количество>0 тогда
				СообщитьИзМодуля("Нулевые цены в строке "+СтрМасс.НомерСтроки);
				ЕстьПозицииБезЦен=Истина;
			КонецЕсли;
			// Кухарь А.Ю.  10.10.2022 конец					
		КонецЦикла;			
		
		// Кухарь А.Ю.  10.10.2022 начало
		если ЕстьПозицииБезЦен тогда
			СообщитьИзМодуля("Нельзя чтобы на часть позиций были цены, а на часть нет.");
			Отказ=Истина;
		КонецЕсли;
		// Кухарь А.Ю.  10.10.2022 конец
		
	КонецЕсли;		
	МассИзменений=Товары.НайтиСтроки(новый Структура("СтрокаИзменена",Истина));
	если МассИзменений.Количество()= 0 тогда
		СообщитьИзМодуля("Нет изменений в товарах, коррекция не записана.");
		отказ=Истина;
	КонецЕсли;
	
	МассПустыхПозиций=Товары.НайтиСтроки(новый Структура("Номенклатура",Справочники.Номенклатура.ПустаяСсылка()));
	если МассПустыхПозиций.Количество()> 0 тогда
		СообщитьИзМодуля("Нельзя записывать коррекции с пустой номенклатурой");
		отказ=Истина;
	КонецЕсли;
	возврат Отказ;	
КонецФункции

