Функция ПолучитьПД(Контра)
	Рез = Неопределено;
	Запр = Новый Запрос;
	Запр.Текст =
	"ВЫБРАТЬ
	|	ПунктыДоставки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПунктыДоставки КАК ПунктыДоставки
	|ГДЕ
	|	ПунктыДоставки.Владелец = &Контра";
	Запр.УстановитьПараметр("Контра", Контра);
	Выб = Запр.Выполнить().Выбрать();
	Если Выб.Следующий() Тогда
		Рез = Выб.Ссылка;
	КонецЕсли;	
	Возврат Рез;
КонецФункции	
