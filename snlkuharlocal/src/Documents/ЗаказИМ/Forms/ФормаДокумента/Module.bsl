&НаКлиенте
Процедура ОформитОтказКлиента(Команда)
	// Вставить содержимое обработчика.  
	Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ОтказКлиента"); 
	ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	ЭтаФорма.ОбновитьОтображениеДанных();
	ПоказатьКолво();
	УстВидим();
КонецПроцедуры

&НаКлиенте
Процедура ПеревестиВСканированиеКМ(Команда)
	// Вставить содержимое обработчика.
	Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПодготовкаКВыдаче");
	ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	ЭтаФорма.ОбновитьОтображениеДанных();
	ПоказатьКолво();
	УстВидим();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСкидкаПриИзменении(Элемент)
	// Вставить содержимое обработчика. 
	СтрокаТЧ = Элементы.Товары.ТекущиеДанные;
	Если НЕ СтрокаТЧ = Неопределено Тогда
		СтрокаТЧ.Цена	= СтрокаТЧ.ЦенаБезСкидки * (1 - Окр(СтрокаТЧ.Скидка/100, 2));
	КонецЕсли;	
КонецПроцедуры
