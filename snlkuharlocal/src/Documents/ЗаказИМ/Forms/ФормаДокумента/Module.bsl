&НаКлиенте
Процедура ПоказатьКолво()
	Объект.СуммаЗаказа = (Объект.Товары.Итог("Всего")); 
	Объект.СуммаЗаказаОбщая = (Объект.Товары.Итог("ВсегоЗаказ"));
	Элементы.СтраницаТовары.Заголовок = "Товары" + ?(Объект.Товары.Итог("Заказ")," (" + Формат(Объект.Товары.Итог("Заказ"), "ЧДЦ=0; ЧН=-; ЧГ=3,0") + ")", "");
	Элементы.СтраницаШК.Заголовок = "ШК упаковок" + ?(Объект.ШтрихкодыУпаковок.Количество(), " (" + Формат(Объект.ШтрихкодыУпаковок.Количество(), "ЧДЦ=0; ЧН=-; ЧГ=3,0") + ")", ""); 
	//ШК упаковок возврат СтраницаШКВозврат
	Элементы.СтраницаШКВозврат.Заголовок = "ШК упаковок вычерк" + ?(Объект.ШтрихкодыУпаковокВозврат.Количество(), " (" + Формат(Объект.ШтрихкодыУпаковокВозврат.Количество(), "ЧДЦ=0; ЧН=-; ЧГ=3,0") + ")", "");
	Элементы.СтраницаВозвраты.Заголовок = ЗаголовокВозвраты();
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.Формирование") Тогда
		СтатКоммент = "В этом статусе
		|формируется товары в заказе
		|заводятся данные по заказу
		|№ интернет заказа и т. п.";
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПодготовкаКВыдаче") Тогда
		СтатКоммент = "В этом статусе
		|сканируются КМ, производится подготовка
		|к передаче в доставку";
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ГотовоКВыдаче") Тогда
		СтатКоммент = "В этом статусе 
		|заказ готов к передаче в доставку";	
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПереданоВДоставку") Тогда
		СтатКоммент = "Это статус ожидания
		//|сканируются КМ
		//|производится подготовка к передаче в доставку
		|результатов доставки";	
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.Обработка") Тогда
		СтатКоммент = "В этом статусе
		|сканируются КМ вычерков
		|клиента";
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.СформированыДокументы") Тогда
		СтатКоммент = "В этом статусе 
		|можно только создавать возвраты";
		//|клиента";
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ОтказКлиента") Тогда
		СтатКоммент = "Этот статус присваивается при полном отказе 
		//|сканируются КМ
		//|производится подготовка к передаче в доставку
		|при полном отказе клиента от приобретения";
	Иначе
		СтатКоммент = "Этот статус  
		//|сканируются КМ
		//|производится подготовка к передаче в доставку
		|требует уточнения";	
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ЗаголовокВозвраты() 
	Рез =  "Возвраты " + ?(Объект.Возвраты.Количество(), " (док-тов: " + Формат(Объект.Возвраты.Количество(), "ЧДЦ=0; ЧН=-; ЧГ=3,0") + ")", "");
	Поз = 0;
	Для Каждого ТСтр Из Объект.Возвраты Цикл
		Поз = Поз + ТСтр.Возврат.ШтрихкодыУпаковок.Количество();
	КонецЦикла;
	Рез = Рез + ?(Поз, " (позиций: " + Формат(Поз, "ЧДЦ=0; ЧН=-; ЧГ=3,0") + ")", "");
	Возврат Рез;
КонецФункции

