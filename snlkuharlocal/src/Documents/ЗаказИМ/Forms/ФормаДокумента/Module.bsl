	ПоказатьКолво();
КонецПроцедуры 

&НаСервере
Процедура ТоварыПриИзмененииНаСервере(ТСтрока)
	// Вставить содержимое обработчика.
	ТСтрока = ?(ТСтрока = Неопределено, 0, ТСтрока);
	НайдТ = Объект.Товары.НайтиПоИдентификатору(ТСтрока);
	//СтрБр.УИД = "";
	//Если ЗначениеЗаполнено(СтрБр.Брэнд) Тогда
	//	СтрБр.УИД = СокрЛП(СтрБр.Брэнд.УникальныйИдентификатор());
	//КонецЕсли;
	НайдТ.ВсегоЗаказ = НайдТ.Цена * НайдТ.Заказ;
	НайдТ.Всего = НайдТ.Цена * НайдТ.ПодтвержденныйЗаказ;
	ПроцНДС = Перечисления.СтавкиНДС.ПроцентНДС(НайдТ.СтавкаНДС);
	Всего = НайдТ.Всего;
	НайдТ.НДС = Окр(ПроцНДС * Всего/(100 + ПроцНДС), 2);
	НайдТ.Сумма	= Всего - НайдТ.НДС;
КонецПроцедуры

&НаКлиенте
Процедура СформироватьВозврат(Команда)
	// Вставить содержимое обработчика. 
	//ПараметрыФормы.Вставить("ВозможностьОплатыСБП",	ПодключенСБП());  
	ОповещениеСозданВозврат = Новый ОписаниеОповещения("СозданВозврат", ЭтаФорма);
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗаказИМ",	Объект.Ссылка);
	ОткрытьФорму("Документ.ЗаказИМ.Форма.ФормаСозданияВозврата", ПараметрыФормы,,,,, ОповещениеСозданВозврат, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

