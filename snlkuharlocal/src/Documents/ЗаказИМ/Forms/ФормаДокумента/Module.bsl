	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПодготовкаКВыдаче") Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.Формирование"); 
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ГотовоКВыдаче") Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПодготовкаКВыдаче");	
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПереданоВДоставку") Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ГотовоКВыдаче");	
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.Обработка") Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.ПереданоВДоставку");
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусЗаказаИМ.СформированыДокументы") Тогда
