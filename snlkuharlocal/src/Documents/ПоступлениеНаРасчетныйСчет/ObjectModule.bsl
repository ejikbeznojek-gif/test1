#Область СобытияОбъекта

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс);
	КонецЕсли; 
	Префикс = Префикс+Маркировка_ПИ.ЭтотУзел_Код("Основной") + "-";
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Автор = ПараметрыСеанса.Пользователь;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	УИД_СтрокиПлатежа = Неопределено;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если НЕ ЭтоНовый() Тогда
		РеквизитыДоИзменения = ПолучитьРеквизитыШапки(Ссылка, "ПометкаУдаления,Проведен,Дата,СуммаДокумента,Контрагент,Договор");
		ДополнительныеСвойства.Вставить("РеквизитыДоИзменения", РеквизитыДоИзменения);	
	КонецЕсли;
КонецПроцедуры

Процедура ПриЗаписи(Отказ)                  
	Если ИзменилисьКлючевыеРеквизиты() Тогда
		РегистрыСведений.УведомленияОПоступившихПлатежах.УдалитьУведомление(Ссылка);			
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

Функция ИзменилисьКлючевыеРеквизиты()
	Результат = Ложь;
	
	РеквизитыДоИзменения = МаркировкаКС.ПолучитьЗначениеПараметра(ДополнительныеСвойства, "РеквизитыДоИзменения");	
	Если ТипЗнч(РеквизитыДоИзменения) = Тип("Структура") Тогда
		Для каждого КиЗ Из РеквизитыДоИзменения Цикл
			Если КиЗ.Значение <> ЭтотОбъект[КиЗ.Ключ] Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ИзменилисьКлючевыеРеквизиты()