 Процедура ОбработкаПроведения(Отказ, РежимПроведения) Экспорт
	 ТЗДокументов = ЛистыНабора.Выгрузить(,"Документ");
	 ТЗДокументов.Свернуть("Документ");
	 Если СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена Тогда
		 Для Каждого СтрокаТЗ ИЗ ТЗДокументов Цикл
			 ДокОбъект = СтрокаТЗ.Документ.ПолучитьОбъект();
			 Если ДокОбъект.Состояниенакладной <> Перечисления.СостоянияНакладной.Отгружена Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.Отгружена;
				 ДокОбъект.Отгружен = Перечисления.Отгружен.Отгружен;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
		 Для Каждого СтрокаТЗ Из Паллеты Цикл
			 ДокОбъект = строкаТЗ.Паллета.ПолучитьОбъект();
			 Если ДокОбъект.СостояниеНакладной <>  Перечисления.СостоянияНакладной.Отгружена Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.Отгружена;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
	 ИначеЕсли СостояниеНакладной = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
		 Для Каждого СтрокаТЗ ИЗ ТЗДокументов Цикл
			 ДокОбъект = СтрокаТЗ.Документ.ПолучитьОбъект();
			 Если ДокОбъект.Состояниенакладной <> Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад;
				 ДокОбъект.Отгружен = Перечисления.Отгружен.ОтгруженТранзит;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
		 Для Каждого СтрокаТЗ Из Паллеты Цикл
			 ДокОбъект = строкаТЗ.Паллета.ПолучитьОбъект();
			 Если ДокОбъект.СостояниеНакладной <>  Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
		 
		 
	 Иначе
		 Для Каждого СтрокаТЗ ИЗ ТЗДокументов Цикл
			 ДокОбъект = СтрокаТЗ.Документ.ПолучитьОбъект();
			 Если ДокОбъект.Состояниенакладной <> Перечисления.СостоянияНакладной.ВМашине Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ВМашине;
				 ДокОбъект.Отгружен = Перечисления.Отгружен.Резерв;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
		 Для Каждого СтрокаТЗ Из Паллеты Цикл
			 ДокОбъект = строкаТЗ.Паллета.ПолучитьОбъект();
			 Если ДокОбъект.СостояниеНакладной <>  Перечисления.СостоянияНакладной.ВМашине Тогда
				 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ВМашине;
				 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
			 КонецЕсли;
		 КонецЦикла;
		 
	 КонецЕсли;
 КонецПроцедуры
 
 Процедура ОбработкаУдаленияПроведения(Отказ)
	 ТЗДокументов = ЛистыНабора.Выгрузить(,"Документ");
	 ТЗДокументов.Свернуть("Документ");
	 Для Каждого СтрокаТЗ ИЗ ТЗДокументов Цикл
		 ДокОбъект = СтрокаТЗ.Документ.ПолучитьОбъект();
		 Если ДокОбъект.Состояниенакладной <> Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда
			 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
			 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
		 КонецЕсли;
	 КонецЦикла;
	 Для Каждого СтрокаТЗ Из Паллеты Цикл
		 ДокОбъект = строкаТЗ.Паллета.ПолучитьОбъект();
		 Если ДокОбъект.СостояниеНакладной <>  Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда
			 ДокОбъект.Состояниенакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
			 ДокОбъект.записать(РежимЗаписиДокумента.Проведение);
		 КонецЕсли;
	 КонецЦикла;
	 
	 
 КонецПроцедуры
 
 
 
 СписокДоступныхСостояний = Новый СписокЗначений;
 СписокДоступныхСостояний.Добавить(Перечисления.СостоянияНакладной.ГотоваКОтгрузке);
 СписокДоступныхСостояний.Добавить(Перечисления.СостоянияНакладной.ВМашине);
 СписокДоступныхСостояний.Добавить(Перечисления.СостоянияНакладной.Отгружена);
 СписокДоступныхСостояний.Добавить(Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад);
