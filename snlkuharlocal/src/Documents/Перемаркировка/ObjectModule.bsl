//				МаркировкаС.ЗапуститьВФонеСозданиеЗаказовКодовМаркировки(ссылка, ИдентификаторФЗ);
//			КонецЕсли;
			//--Данилова Е.В. 26.06.2026 
			//++Данилова Е.В. 11.06.2026 исправление MARK-3615 
			//СтатусдляВыгрузки = Статус = Перечисления.СтатусыПеремаркировки.ОбработаноЧЗ ; 
			//НужноВыгружать	= Документы.Перемаркировка.НужноВыгружатьДокПеремаркировка(СтатусдляВыгрузки, Ссылка,
			//РежимЗаписиДокумента, ПометкаУдаления);
			//++Данилова Е.В. 26.06.2026 Изм.№0000000222
			ИзмененСтатус = СостояниеДоПерезаписи <> Статус;
			
			НужноВыгружать	= Документы.Перемаркировка.НужноВыгружатьДокПеремаркировка(ИзмененСтатус, Ссылка,
			РежимЗаписиДокумента, ПометкаУдаления); 
			
