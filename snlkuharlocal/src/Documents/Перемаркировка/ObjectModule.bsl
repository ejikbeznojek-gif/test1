КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		//++Данилова Е.В. 26.06.2026 Изм.№0000000222
		УстановитьСтатусПолученоСкладом(); 
		//--Данилова Е.В. 26.06.2026 
		Возврат; 
	КонецЕсли;
	Если НЕ ЭтоНовый() Тогда
		СостояниеДоПерезаписи = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ссылка, "Статус");  
	Иначе
		 СостояниеДоПерезаписи = Перечисления.СтатусыПеремаркировки.ПустаяСсылка(); 
	 КонецЕсли;
	 
	 РежимЗаписиДокНового = РежимЗаписи; 
	
	ЕстьИзменения = Модифицированность(); 
	Если ЕстьИзменения И Не ПроверитьВведеннуюНоменклатуру() Тогда
		Отказ = Истина;
		Сообщить(
			"В документе могут быть указаны только спайки или только штуки (готовые комплекты). Разделите документ!");
	КонецЕсли
	; 
	Если ОтгрузкаКомплектов И Комплектующие.Количество() = 0 Тогда
		Отказ = Истина;
		Сообщить("Заполните комплектующие!");
		Возврат; 
	КонецЕсли;
	Если ОтгрузкаКомплектов Тогда
	
		КоличествоТоваров = Товары.Итог("Количество"); 	
	    КоличествоПродукции = Комплектующие.Итог("КоличествоПродукции");
		Если КоличествоТоваров <> КоличествоПродукции Тогда
			
			Отказ = Истина;
			Сообщить("Перезаполните комплектующие, несоответствие по количеству продукции!");	
			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ОбщегоНазначенияС.ЗаполнитьШапкуДокументаСервер(ЭтотОбъект,ОбщегоНазначенияС.ТекущийПользователь()); //
	Статус = ПредопределенноеЗначение("Перечисление.СтатусыПеремаркировки.ВРаботе");
	ТоварыУдаленные.Очистить();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыиФункции

Функция ПроверитьВведеннуюНоменклатуру() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТЧТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ТЧТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВЫБОР
		|		КОГДА НоменклатураСпр.родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
		|			ТОГДА НоменклатураСпр.родитель.ВидКомплекта
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Товар)
		|	КОНЕЦ) КАК ВидКомплекта
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ТЧТовары.Номенклатура = НоменклатураСпр.Ссылка
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВЫБОР
		|		КОГДА НоменклатураСпр.родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
		|			ТОГДА НоменклатураСпр.родитель.ВидКомплекта
		|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Товар)
		|	КОНЕЦ) > 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НоменклатураСпр.родитель.ВидКомплекта КАК ВидКомплекта
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ТЧТовары.Номенклатура = НоменклатураСпр.Ссылка";
	
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());
		
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	РезультатПроверка = ПакетЗапросов[1];
	ВыборкаВид =  ПакетЗапросов[2].Выбрать();
	ВидыКомплектов.Очистить();	
	Пока ВыборкаВид.Следующий() Цикл
		НСтрока = ВидыКомплектов.Добавить(); 
		НСтрока.ВидКомплекта = ВыборкаВид.ВидКомплекта; 
	КонецЦикла;
	
	Возврат РезультатПроверка.Пустой(); 
	
КонецФункции

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Если ЗначениеЗаполнено(Организация) Тогда
		Префикс = СокрЛП(Организация.Префикс)+"-";	
	КонецЕсли;
КонецПроцедуры

