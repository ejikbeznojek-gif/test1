//			РежимЗаписиДокумента, ПометкаУдаления); 
			//--Данилова Е.В. 11.06.2026 
			//--Данилова Е.В. 26.06.2026 
			ДополнительныеСвойства.Вставить("НужноВыгружать", НужноВыгружать);
			
			Если НужноВыгружать Тогда
				Документы.Перемаркировка.УстановитьПолучателейИзменений(ЭтотОбъект);
			КонецЕсли;
		КонецЕсли;
		
		Если Статус = Перечисления.СтатусыПеремаркировки.Обработано
			И СостояниеДоПерезаписи <> Статус Тогда
			ЗаданиеНаСборку = ОбщегоНазначенияС.НайтиДокументНаСервере("ЗаданиеНаСборкуКомплектовЧЗ",
