	Если Не Отказ 
		И (Проведен 
		ИЛИ РежимЗаписиДокНового = РежимЗаписиДокумента.Проведение) Тогда
		 
		Если Статус = Перечисления.СтатусыПеремаркировки.КОтработкеЧЗ 
			Или Статус = Перечисления.СтатусыПеремаркировки.ОбработаноЧЗ
			//++Данилова Е.В. 26.06.2026 Изм.№0000000222 
			ИЛИ Статус = Перечисления.СтатусыПеремаркировки.ПолученоСкладом Тогда
			//--Данилова Е.В. 26.06.2026 
			//	
			//++Данилова Е.В. 26.06.2026 Изм.№0000000222
			//перенесено создание в офис по регламенту 
//			Если Статус = Перечисления.СтатусыПеремаркировки.КОтработкеЧЗ 
//				И СостояниеДоПерезаписи <> Статус
