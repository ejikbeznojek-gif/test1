Процедура УстановитьСтатусПолученоСкладом()
	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад И Статус
		= Перечисления.СтатусыПеремаркировки.КОтправкеНаСклад Тогда
			
		Статус = Перечисления.СтатусыПеремаркировки.ПолученоСкладом; 
			
	КонецЕсли;
КонецПроцедуры

Процедура ЗарегистрироватьИзмененияПолученоСкладом()

	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад
		И Статус = Перечисления.СтатусыПеремаркировки.ПолученоСкладом Тогда
		//++Данилова Е.В. 01.07.2026 №Изм.0000000222
		ОбменДанными.Отправитель = неопределено;
		//--Данилова Е.В. 01.07.2026 
		Документы.Перемаркировка.УстановитьПолучателейИзменений(ЭтотОбъект);
		
	КонецЕсли;

КонецПроцедуры

