
#Область ОбработчикиСобытий
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	РезультатПроверки = ПроверитьДокументыКОбработке(ПараметрКоманды); 
	Если НЕ РезультатПроверки.Успешно Тогда
		МаркировкаКС.ВывестиОшибки(РезультатПроверки); 
		Возврат; 
	КонецЕсли;
	ТипДокумента = ОпределитьВидДокументаДляСканирования(ПараметрКоманды);
	//++Данилова Е.В. 25.06.2026  Проб.№0000000148 
	Если ЕстьСозданныеДокументы(ТипДокумента,ПараметрКоманды) Тогда 
		
		ДопПараметры = Новый Структура("Перемаркировка,ТипДокумента",ПараметрКоманды,ТипДокумента); 
		
		ОповещениеВопрос = Новый ОписаниеОповещения("ПослеПроверкиСозданныхДокументов",ЭтотОбъект,ДопПараметры);
		ПоказатьВопрос(ОповещениеВопрос,"Существуют ранее созданные документы, они будут перезаписаны, продолжить?",РежимДиалогаВопрос.ДаНет); 
		
	Иначе
		
		СоздатьДокументыСканированияНаКлиенте(ПараметрКоманды, ТипДокумента); 
		
	КонецЕсли;
	//--Данилова Е.В. 25.06.2026
КонецПроцедуры

//Данилова Е.В. 25.06.2026  Проб.№0000000148 вынесла в процедуру
&НаКлиенте
Процедура СоздатьДокументыСканированияНаКлиенте(Знач ПараметрКоманды, Знач ТипДокумента)
	 
	Если ТипДокумента = "ЗаданиеНаМаркировку" Тогда
		РезультатСоздания = СоздатьЗНМ_И_ЛМ_НаСервере(ПараметрКоманды);
		Если РезультатСоздания.Успешно И РезультатСоздания.Данные.Количество() > 0 Тогда
			Для Каждого ДокСозданный Из РезультатСоздания.Данные Цикл
				
				ОткрытьЗначение(ДокСозданный);
				
			КонецЦикла; 
		Иначе 
			МаркировкаКС.ВывестиОшибки(РезультатСоздания); 
		КонецЕсли;
	Иначе 
		РезультатСоздания = СоздатьЗСБ_И_ЛСК_НаСервере(ПараметрКоманды);
		Если РезультатСоздания.Успешно И РезультатСоздания.Данные.Количество() > 0 Тогда
			Для Каждого ДокСозданный Из РезультатСоздания.Данные Цикл
				
				ОткрытьЗначение(ДокСозданный);
				
			КонецЦикла;
		Иначе 
			МаркировкаКС.ВывестиОшибки(РезультатСоздания);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
#Область СлужебныеПроцедурыИФункции
&НаСервере
Функция СоздатьЗСБ_И_ЛСК_НаСервере(ДокПеремаркировки)
	Возврат Документы.Перемаркировка.СоздатьЗСБ_И_ЛСК(ДокПеремаркировки);
КонецФункции
&НаСервере
Функция СоздатьЗНМ_И_ЛМ_НаСервере(ДокПеремаркировки)
	Возврат Документы.Перемаркировка.СоздатьЗНМ_И_ЛМ(ДокПеремаркировки);
КонецФункции
&НаСервере
Функция ПроверитьДокументыКОбработке(ДокПеремаркировки)
	РезультатПроверки = МаркировкаКС.СтруктураРезультата(Ложь); 
	Если ДокПеремаркировки.Статус <> Перечисления.СтатусыПеремаркировки.Сканирование Тогда
		ТекстОшибки = СтрШаблон(
			"Документ перемаркировки %1 сканируется только в статусе ""Сканирование"", текущий статус %2",
			ДокПеремаркировки.ссылка, ДокПеремаркировки.Статус);
		РезультатПроверки.Ошибки.Добавить(ТекстОшибки);
		Возврат РезультатПроверки; 
	КонецЕсли;
	РезультатПроверки.Успешно = Истина; 
	Возврат РезультатПроверки; 
КонецФункции
&НаСервере
Функция ОпределитьВидДокументаДляСканирования(ДокПеремаркировки)
	Если ДокПеремаркировки.ВидыКомплектов.Количество() > 0 
		И ДокПеремаркировки.ВидыКомплектов[0].ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда
		ИмяДокумента = "ЗаданиеНаСборкуКомплектовЧЗ";
	Иначе 
		ИмяДокумента = "ЗаданиеНаМаркировку"; 	
	КонецЕсли;
	Возврат ИмяДокумента; 
КонецФункции

//++Данилова Е.В. 25.06.2026  Проб.№0000000148
&НаСервере
Функция ЕстьСозданныеДокументы(ТипДокумента,ДокПеремаркировки)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗаданиеНаСборкуКомплектовЧЗ.Ссылка КАК Ссылка
		
		|ИЗ
		|	Документ.%ТипДокумента% КАК ЗаданиеНаСборкуКомплектовЧЗ
		|ГДЕ
		|	ЗаданиеНаСборкуКомплектовЧЗ.Проведен
		|	И ЗаданиеНаСборкуКомплектовЧЗ.ДокОснование = &ДокОснование";
	
	
	Запрос.УстановитьПараметр("ДокОснование", ДокПеремаркировки); 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ТипДокумента%",ТипДокумента); 
	
	РезультатЗапроса = Запрос.Выполнить();	
	
	Возврат  НЕ РезультатЗапроса.Пустой(); 
КонецФункции // ПроверитьСозданныеДокументы()

&НаКлиенте
Процедура ПослеПроверкиСозданныхДокументов(ОтветНаВопрос,ДопПараметры) Экспорт
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		СоздатьДокументыСканированияНаКлиенте(ДопПараметры.Перемаркировка,ДопПараметры.ТипДокумента); 
		
	КонецЕсли; 
	
	
КонецПроцедуры

