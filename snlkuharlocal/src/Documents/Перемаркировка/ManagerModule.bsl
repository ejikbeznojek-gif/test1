Функция ПолучитьТаблицуКомплектующихПоЗаказуКМ(Знач ЗаказКМ, Знач ДокПеремаркировки)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Номенклатура КАК Номенклатура,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Количество КАК Количество
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Товары КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗТовары.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|ГДЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка = &ЗаказКМ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПеремаркировкаКомплектующие.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА СУММА(ПеремаркировкаКомплектующие.КоличествоПродукции) = 0
	|			ТОГДА МАКСИМУМ(ВТТовары.Количество)
	|		ИНАЧЕ СУММА(ПеремаркировкаКомплектующие.Количество) / СУММА(ПеремаркировкаКомплектующие.КоличествоПродукции) * МАКСИМУМ(ВТТовары.Количество)
	|	КОНЕЦ КАК Количество
	|ИЗ
	|	Документ.Перемаркировка.Комплектующие КАК ПеремаркировкаКомплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТовары КАК ВТТовары
	|		ПО ПеремаркировкаКомплектующие.Продукция = ВТТовары.Номенклатура
	|ГДЕ
	|	ПеремаркировкаКомплектующие.Ссылка = &Ссылка
	|	И ПеремаркировкаКомплектующие.Номенклатура.Родитель.ТНВЭД <> ЗНАЧЕНИЕ(Справочник.ТНВЭД.ПустаяСсылка)
	|	И ПеремаркировкаКомплектующие.Номенклатура.Родитель.ВидНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар), ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.ПустаяСсылка))
	|	И НЕ(ПеремаркировкаКомплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|				ИЛИ ПеремаркировкаКомплектующие.Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке))
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремаркировкаКомплектующие.Номенклатура";
	Запрос.УстановитьПараметр("Ссылка", ДокПеремаркировки);
	Запрос.УстановитьПараметр("ЗаказКМ", ЗаказКМ);

	ТаблицаКомплектующих = Запрос.Выполнить().Выгрузить();	

КонецФункции // ПолучитьТаблицуКомплектующихПоЗаказуКМ()
