Функция ТабличныйДокументЗаполнен(ТабДокумент) Экспорт
	Если ТабДокумент.Области.Количество()> 0  Тогда
		Возврат Истина;
	Иначе
		Сообщить("Табличный документ пустой");
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция СоздатьЗаявкиНаДоставку(СтруктураДокумента) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаОтгрузки", СтруктураДокумента.ДатаОтгрузки);
	
	СписокНедопустимыхСостояний = Новый СписокЗначений;
	СписокНедопустимыхСостояний.Добавить(Перечисления.СостоянияНакладной.Отменена);
	Запрос.УстановитьПараметр("СписокНедопустимыхСостояний",СписокНедопустимыхСостояний);
	
	Запрос.УстановитьПараметр("КодФизическогоУзла", ПараметрыСеанса.ЭтотУзел.Код);
	
	ТекстАвтомобиль = "";
	Если СтруктураДокумента.Свойство("Автомобиль") Тогда
		Если ТипЗнч(СтруктураДокумента.Автомобиль) = Тип("СправочникСсылка.Автомобили") И ЗначениеЗаполнено(СтруктураДокумента.Автомобиль) Тогда
			ТекстАвтомобиль = "И Накладные.Автомобиль = &Автомобиль";
			Запрос.УстановитьПараметр("Автомобиль", СтруктураДокумента.Автомобиль);
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Накладные.Автомобиль КАК Автомобиль,
	|	Накладные.НомерХодки КАК НомерХодки,
	|	Накладные.ПорядковыйНомерОтгрузки КАК ПорядковыйНомерОтгрузки,
	|	Накладные.Накладная КАК Накладная,
	|	Накладные.Получатель КАК Получатель,
	|	Накладные.ПунктДоставкиПолучатель КАК ПунктДоставки,
	|	ВЫБОР
	|		КОГДА Накладные.ВидНакладной = ""ПНК""
	|			ТОГДА Накладные.АдресОтправитель
	|		КОГДА Накладные.ВидНакладной = ""ЗТО""
	|				И (Накладные.Отправитель ССЫЛКА Справочник.Контрагенты
	|					ИЛИ Накладные.Отправитель.КодФизическогоУзла <> ""OD7"")
	|			ТОГДА Накладные.АдресОтправитель
	|		ИНАЧЕ Накладные.АдресПолучатель
	|	КОНЕЦ КАК АдресПолучателя,
	|	Накладные.ДатаПриемки КАК ДатаПриемки,
	|	Накладные.ВремяПриемки КАК ВремяПриемки,
	|	Накладные.Количество КАК КоличествоНакладной,
	|	Накладные.СуммаДокумента КАК СуммаНакладной,
	|	Накладные.Объем КАК ОбъёмНакладной,
	|	Накладные.ВидНакладной КАК ВидНакладной
	|ИЗ
	|	Документ.ЗаявкаНаОтгрузку.Накладные КАК Накладные
	|ГДЕ
	|	Накладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	|	" + ТекстАвтомобиль + "
	|	И Накладные.ВидНакладной <> ""ПНК""
	|	И (Накладные.ВидНакладной <> ""ЗТО""
	|			ИЛИ Накладные.ВидНакладной = ""ЗТО""
	|				И Накладные.Отправитель.КодФизическогоУзла = &КодФизическогоУзла)
	|	И НЕ Накладные.НеОтгружать
	|	И НЕ ЕСТЬNULL(Накладные.Накладная.СостояниеНакладной, Накладные.СостояниеНакладной) В (&СписокНедопустимыхСостояний)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Автомобиль,
	|	НомерХодки,
	|	ПорядковыйНомерОтгрузки
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗОГ = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если РезультатЗОГ.Количество() = 0 Тогда Возврат Ложь; КонецЕсли;
	
	МассивАвтомобилей = РезультатЗОГ.ВыгрузитьКолонку("Автомобиль");
	МассивАвтомобилей = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(МассивАвтомобилей);
	
	Для Каждого СтрАвтомобиль из МассивАвтомобилей Цикл
		
		МассивСтрокТЗ = РезультатЗОГ.НайтиСтроки(Новый Структура("Автомобиль", СтрАвтомобиль));
		
		МассивНомеровХодок = Новый Массив;
		Для Каждого СтрокаТЗ ИЗ МассивСтрокТЗ Цикл
			Индекс = МассивНомеровХодок.Найти(СтрокаТЗ.НомерХодки);
			Если Индекс = Неопределено Тогда
				МассивНомеровХодок.Добавить(СтрокаТЗ.НомерХодки);
			КонецЕсли;
		КонецЦикла;
		
		МассивНомеровХодок = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(МассивНомеровХодок);
		
		Для Каждого НомерХодки ИЗ МассивНомеровХодок Цикл
			
			ЗапросДок = Новый Запрос;
			ЗапросДок.УстановитьПараметр("Автомобиль", СтрАвтомобиль);
			ЗапросДок.УстановитьПараметр("НомерХодки", НомерХодки);
			ЗапросДок.УстановитьПараметр("НачалоПериода", НачалоДня(СтруктураДокумента.ДатаОтгрузки));
			ЗапросДок.УстановитьПараметр("КонецПериода", КонецДня(СтруктураДокумента.ДатаОтгрузки));

			ЗапросДок.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ЗаявкаНаДоставку.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
			|ГДЕ
			|	ЗаявкаНаДоставку.Проведен
			|	И ЗаявкаНаДоставку.ДатаОтгрузки МЕЖДУ &НачалоПериода И &КонецПериода
			|	И ЗаявкаНаДоставку.Автомобиль = &Автомобиль
			|	И ЗаявкаНаДоставку.НомерХодки = &НомерХодки";
			
			УстановитьПривилегированныйРежим(Истина);
			Результат = ЗапросДок.Выполнить().Выгрузить();
			УстановитьПривилегированныйРежим(Ложь);
			
			Если Результат.Количество() > 0 Тогда
				ЗаявкаНаДоставкуОбъект = Результат[0].Ссылка.ПолучитьОбъект();
			Иначе
				ЗаявкаНаДоставкуОбъект = Документы.ЗаявкаНаДоставку.СоздатьДокумент();
				ЗаявкаНаДоставкуОбъект.Дата = СтруктураДокумента.ДатаОтгрузки;
			КонецЕсли;
			
			Если ЗаявкаНаДоставкуОбъект <> Неопределено Тогда
				
				СтруктураДокумента.Вставить("Автомобиль", СтрАвтомобиль);
				СтруктураДокумента.Вставить("НомерХодки", НомерХодки);
				
				МассивСтрокХодки = РезультатЗОГ.НайтиСтроки(Новый Структура("Автомобиль, НомерХодки", СтрАвтомобиль, НомерХодки));  // Нужный набор строк по Автомобилю и Номеру ходки
				Если МассивСтрокХодки.Количество() > 0 Тогда
					СтруктураДокумента.Вставить("Накладные", МассивСтрокХодки);	
				КонецЕсли;
				
				ЗаявкаНаДоставкуОбъект.Заполнить(СтруктураДокумента);
				
				Попытка
					ЗаявкаНаДоставкуОбъект.Записать(РежимЗаписиДокумента.Проведение);
					СообщитьИзМодуля("Создан/изменен документ " + Строка(ЗаявкаНаДоставкуОбъект.Ссылка));
				Исключение
					СообщитьИзМодуля(ОписаниеОшибки());
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецФункции
