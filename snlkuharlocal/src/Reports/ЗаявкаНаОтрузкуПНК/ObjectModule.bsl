//меняем реквизит распределена из ТЧ накладные документа ЗОГ - тут
процедура ИзменитьРеквизитРаспределенаВЗОГ(Автомобиль,Значение,ДатаОтгрузки)   экспорт	
	//проверки на совсем уж кривой вызов функции начало
	если значение<>Истина и Значение<>ложь тогда
		Сообщить("Не корректное значение реквизита..обратитесь в тех поддержку.");
		Возврат;
	КонецЕсли;	
	если ТипЗнч(Автомобиль)<>Тип("СправочникСсылка.Автомобили")тогда
		Сообщить("Не корректный автомобиль..обратитесь в тех поддержку.");
		Возврат;
	КонецЕсли;
	//пока уберу чтобы тестить легче было
	//если НачалоМесяца(ТекущаяДата())>ДатаОтгрузки тогда
	//	Сообщить("Утверждать распределение маршрутов можно только в текущем месяце.");
	//	Возврат;
	//КонецЕсли;
	//проверки на совсем уж кривой вызов функции конец
	
	если Автомобиль=Справочники.Автомобили.ПустаяСсылка() тогда //тогда утверждаем маршрут для всех накладных с машинами
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
		|ГДЕ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен
		|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
		|	И ЗаявкаНаОтгрузкуНакладные.Автомобиль <> &Автомобиль
		|	И ЗаявкаНаОтгрузкуНакладные.ВидНакладной <> ""ПНК""
		|	И (ЗаявкаНаОтгрузкуНакладные.ВидНакладной <> ""ЗТО""
		|			ИЛИ ЗаявкаНаОтгрузкуНакладные.ВидНакладной = ""ЗТО""
		|				И ЗаявкаНаОтгрузкуНакладные.Отправитель.КодФизическогоУзла = &КодФизическогоУзла)
		//кухарь 23.03.15 начало
		|	И ЗаявкаНаОтгрузкуНакладные.Отправитель.КодФизическогоУзла = &КодФизическогоУзла";	
		//кухарь 23.03.15 конец
		запрос.УстановитьПараметр("КодФизическогоУзла",ПараметрыСеанса.ЭтотУзел.Код);	
		//кухарь 15.03.15 конец
		запрос.УстановитьПараметр("ДатаОтгрузки",НачалоДня(ДатаОтгрузки));
		запрос.УстановитьПараметр("Автомобиль",Автомобиль);
		результат=запрос.Выполнить().Выгрузить();
		для каждого СтрРез из результат цикл
			ЗОГобъект=СтрРез.ссылка.получитьобъект();
			//кухарь 22.04.15 начало
			//Для каждого Накладная из ЗОГобъект.Накладные цикл
			//	если Накладная.Автомобиль=Автомобиль тогда
			//		Накладная.Распределена=Значение;
			//	КонецЕсли;
			//КонецЦикла;	
			//ЗОГобъект.Записать();
			НадоЗаписать=ложь;
			Для каждого Накладная из ЗОГобъект.Накладные цикл
				если Накладная.Распределена<>Значение тогда
					НадоЗаписать=Истина;
				КонецЕсли;
				Накладная.Распределена=Значение;
			КонецЦикла;
			если НадоЗаписать тогда
				ЗОГобъект.Записать();
			КонецЕсли;
			//кухарь 22.04.15 конец
		КонецЦикла;	
	иначе //тогда утверждаем маршрут для текущей машины
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
		|ГДЕ
		|	ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен
		|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
		|	И ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль
		|	И ЗаявкаНаОтгрузкуНакладные.ВидНакладной <> ""ПНК""
		|	И (ЗаявкаНаОтгрузкуНакладные.ВидНакладной <> ""ЗТО""
		|			ИЛИ ЗаявкаНаОтгрузкуНакладные.ВидНакладной = ""ЗТО""
		|				И ЗаявкаНаОтгрузкуНакладные.Отправитель.КодФизическогоУзла = &КодФизическогоУзла)
		//кухарь 24.03.15 начало
		|	И ЗаявкаНаОтгрузкуНакладные.Отправитель.КодФизическогоУзла = &КодФизическогоУзла";
		//кухарь 24.03.15 конец
		запрос.УстановитьПараметр("КодФизическогоУзла",ПараметрыСеанса.ЭтотУзел.Код);
		//кухарь 15.03.15 конец
		
		запрос.УстановитьПараметр("ДатаОтгрузки",НачалоДня(ДатаОтгрузки));
		запрос.УстановитьПараметр("Автомобиль",Автомобиль);
		
		результат=запрос.Выполнить().Выгрузить();
		для каждого СтрРез из результат цикл
			ЗОГобъект=СтрРез.ссылка.получитьобъект();
			Для каждого Накладная из ЗОГобъект.Накладные цикл
				если Накладная.Автомобиль=Автомобиль тогда
					Накладная.Распределена=Значение;
				КонецЕсли;
			КонецЦикла;		
			ЗОГобъект.Записать();
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

// Кухарь А.Ю. 14.12.2021 начало
//Функция ПроверитьРаспределениеАвтомобиляВМаршрут (Автомобиль,ДатаОтгрузки) экспорт
Функция ПроверитьРаспределениеАвтомобиляВМаршрут (Автомобиль,ДатаОтгрузки,НомерХодки=Неопределено) экспорт
 
// Кухарь А.Ю. 14.12.2021 конец

	если ТипЗнч(Автомобиль)<>Тип("СправочникСсылка.Автомобили")тогда
		Сообщить("Не корректный автомобиль..обратитесь в тех поддержку.");
		Возврат ложь;
	КонецЕсли;
	
	//крохин начало 30.04.2015
	Если Автомобиль.пустая() Тогда
	Возврат Ложь;	
	КонецЕсли;
	
	//крохин конец 30.04.2015
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаявкаНаОтгрузкуНакладные.Ссылка
	|ИЗ
	|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
	|ГДЕ
	|	ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен
	|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.ДатаОтгрузки = &ДатаОтгрузки
	|	И ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль
	|	И ЗаявкаНаОтгрузкуНакладные.Распределена";
	запрос.УстановитьПараметр("ДатаОтгрузки",НачалоДня(ДатаОтгрузки));
	запрос.УстановитьПараметр("Автомобиль",Автомобиль);
	// Кухарь А.Ю. 14.12.2021 начало
	//
	если НомерХодки<>Неопределено тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"И ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль","И ЗаявкаНаОтгрузкуНакладные.Автомобиль = &Автомобиль и ЗаявкаНаОтгрузкуНакладные.НомерХодки = &НомерХодки ");
		запрос.УстановитьПараметр("НомерХодки",НомерХодки);
	КонецЕсли;
	// Кухарь А.Ю. 14.12.2021 конец
	
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда
		возврат Истина;
	иначе
		Возврат ложь;
	КонецЕсли;
	
КонецФункции

