Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = Новый Структура("", );
	
	Форма = ПолучитьФорму("Обработка.РегистрацияИзмененийДляОбмена.Форма.Форма", ПараметрыФормы);
	Форма.УзелОбмена = ПараметрКоманды; 
	Форма.Открыть();	
	
КонецПроцедуры
