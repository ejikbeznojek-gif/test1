Функция УстановитьСтатус(ДокСсылка, Статус) Экспорт
	МЗ = РегистрыСведений.СтатусыОтложеннойОбработкиДокументов.СоздатьМенеджерЗаписи();
	
	МЗ.Документ = ДокСсылка;
	МЗ.Статус	= Статус;
	
	Если ЗначениеЗаполнено(МЗ.Документ) Тогда	
		МЗ.Записать();			
	КонецЕсли;
КонецФункции //УстановитьСтатус(ДокСсылка, Статус) Экспорт
