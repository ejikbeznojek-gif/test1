&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	рРазбора = РегистрыСведений.ДанныеЛогов.РазобратьПакет(Запись.Данные);
	Если рРазбора.Успешно Тогда
		ЗаписиЗамера.Загрузить(рРазбора.Данные);
		
		Элементы.сТаблица.Заголовок = СтрШаблон("Записи (%1)", Формат(рРазбора.Данные.Количество(), "ЧРГ=; ЧГ=' '"));
	Иначе
		МаркировкаКС.ВывестиОшибки(рРазбора);	
	КонецЕсли;
КонецПроцедуры
