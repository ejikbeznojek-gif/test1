&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ХранитьФайлыНаВнешнемНосителе = Константы.ХранитьФайлыНаВнешнемНосителе.Получить();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если НЕ ПолучитьПолномочиеПользователя("ОткрытиеФормыСлужебногоРегистраСведений", ПараметрыСеанса.Пользователь) Тогда
		Сообщить("Это служебная форма Записи. Изменения возможны в справочнике Контрагенты");
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Попытка
		УдалитьФайлы(КаталогВременныхФайлов() + Запись.ИмяФайла);
	Исключение
		Сообщить("Не могу удалить временные файлы!");
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаОткрытие(Элемент, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Запись.ИмяФайла) Тогда
		Сообщить("Не заполнено Имя Файла!");
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если ХранитьФайлыНаВнешнемНосителе = Истина Тогда
		
		ИмяВременногоФайла = ПолучитьКаталогТЗнаДОКонтрагентов() + Запись.ИмяФайла;
		
		Попытка
			ЗапуститьПриложение(ИмяВременногоФайла);	
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Запись.Контрагент) Тогда
		Сообщить("Заполните Контрагента!");
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ДиалогВыбораФайла =	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбораФайла.Заголовок	= "Выберите файл";
	ДиалогВыбораФайла.ПредварительныйПросмотр	= Ложь;
	ДиалогВыбораФайла.ИндексФильтра = 0;
	
	Если ДиалогВыбораФайла.Выбрать() Тогда
		Файл = Новый Файл(ДиалогВыбораФайла.ПолноеИмяФайла);
		ИмяВременногоФайла = ПолучитьКодКонтрагента(Запись.Контрагент) + "_"
			+ ЗаменитьНедопустимыеСимволыВИмениФайла(Файл.ИмяБезРасширения, "_") + "_"
			+ Формат(ТекущаяДатаСеанса(), "ДФ=дд-ММ-гггг") + Файл.Расширение;
		Запись.ИмяФайла = ИмяВременногоФайла;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если Файл.Существует() Тогда
		Если ХранитьФайлыНаВнешнемНосителе = Истина Тогда
			Попытка
				КопироватьФайл(Файл.ПолноеИмя, ПолучитьКаталогТЗнаДОКонтрагентов() + ИмяВременногоФайла);
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////////////

&НаКлиенте
Процедура ПоказатьФайл(Команда)
	
	Если ХранитьФайлыНаВнешнемНосителе = Истина Тогда
		
		ИмяВременногоФайла = ПолучитьКаталогТЗнаДОКонтрагентов() + Запись.ИмяФайла;
		
		Попытка
			ЗапуститьПриложение(ИмяВременногоФайла);	
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКаталогТЗнаДОКонтрагентов()
	Возврат СокрЛП(Константы.КаталогХраненияТЗнаДО.Получить());	
КонецФункции

&НаСервере
Функция ПолучитьКодКонтрагента(Контрагент)
	Возврат СокрЛП(Контрагент.Код);	
КонецФункции
