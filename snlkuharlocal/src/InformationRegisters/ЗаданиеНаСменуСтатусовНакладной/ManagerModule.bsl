Функция СоздатьЗаданиеНаСменуСтатуса(Документ, СостоянияНакладной_Нов, ДопПараметры = Неопределено) Экспорт
	РеквизитыНовые	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры,		"РеквизитыНовые");
	Отгружен_Нов	= МаркировкаКС.ПолучитьЗначениеПараметра(РеквизитыНовые,	"Отгружен");
	
	МЗ = РегистрыСведений.ЗаданиеНаСменуСтатусовНакладной.СоздатьМенеджерЗаписи();
	
	МЗ.Документ 		= Документ;
	МЗ.АвторЗадания 	= ПараметрыСеанса.Пользователь;
	
	МЗ.СостоянияНакладной_Нов	= СостоянияНакладной_Нов;
	Если Отгружен_Нов <> Неопределено Тогда
		МЗ.Отгружен_Нов = Отгружен_Нов; 			
	КонецЕсли;	
	МЗ.ДатаЗаписи				= ТекущаяДата();
	
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		рШапки 			= ПолучитьРеквизитыШапки(Документ, "СостояниеНакладной,Отгружен,Контрагент");		
		МЗ.Получатель	= рШапки.Контрагент;		
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.Перемещение") Тогда
		рШапки			= ПолучитьРеквизитыШапки(Документ, "СостояниеНакладной,Отгружен,СкладПолучатель");		
		МЗ.Получатель	= рШапки.СкладПолучатель;		
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	МЗ.СостоянияНакладной_Тек 	= рШапки.СостояниеНакладной;
	МЗ.Отгружен_Тек			 	= рШапки.Отгружен;
	
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда
		МЗ.ДопПараметры = Новый ХранилищеЗначения(ДопПараметры);	
	КонецЕсли;
	
	МЗ.Записать();
	
	Возврат Истина;
КонецФункции //СоздатьЗаданиеНаСменуСтатуса(Документ, НовоеСостояние) Экспорт

