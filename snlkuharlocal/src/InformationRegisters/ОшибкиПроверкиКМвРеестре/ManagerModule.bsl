Функция ОчиститьОшибкиКМ(ДокСсылка, тОшибок) Экспорт
	НЗ = РегистрыСведений.ОшибкиПроверкиКМвЧЗ.СоздатьНаборЗаписей();
	НЗ.Отбор.ОшибочныйДокумент.Установить(ДокСсылка, Истина);	
	
	Если НЕ ЗначениеЗаполнено(НЗ.Отбор.ОшибочныйДокумент.Значение) Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	НЗ.Записать();
	
	Возврат Истина;
КонецФункции //ОчиститьОшибкиКМ(ДокСсылка, тОшибок) Экспорт
