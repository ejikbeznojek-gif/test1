Функция ОбновитьСтатусПакета(Пакет, Поля, Знач ИмяПланаОбмена = "") Экспорт
	Если ПустаяСтрока(ИмяПланаОбмена) И ЗначениеЗаполнено(Пакет) И МаркировкаС.ОбъектСуществует(Пакет) Тогда
		ИмяПланаОбмена = ПолучитьРеквизитШапки(Пакет, "ПланОбмена"); 			 
	КонецЕсли;
	
	Отбор = Новый Структура("Пакет,КодУзла", Пакет, Маркировка_ПИ.ЭтотУзел_Код(ИмяПланаОбмена));
	
	МЗ = РегистрыСведений.СостояниеПакетовОбмена.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МЗ, Отбор);
	
	МЗ.Прочитать();
	Если НЕ ЗначениеЗаполнено(МЗ.Пакет) Тогда
		ЗаполнитьЗначенияСвойств(МЗ, Отбор);
	КонецЕсли;                              
	
	ЗаполнитьЗначенияСвойств(МЗ, Поля);
	
	МЗ.ДатаРедактированияЗаписи = ТекущаяДата();
	
	МЗ.Записать();
КонецФункции //Функция ОбновитьСтатусПакета(Пакет, Поля, ИмяПланаОбмена = "ДанныеЧЗ") Экспорт

Функция ПолучитьЗаписьЗагрузки(Пакет, КодУзла) Экспорт
	Результат = Новый Структура("Период, ИД_ЗаданияЗагрузкиДанных");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1	
	|	ИД_ПакетаЗаданийЗагрузки,
	|	ИД_ЗаданияЗагрузкиДанных
	|ИЗ
	|	РегистрСведений.СостояниеПакетовОбмена	
	|ГДЕ
	|	 Пакет = &Пакет
	|	 И КодУзла = &КодУзла	
	|";
	
	Запрос.УстановитьПараметр("Пакет",		Пакет);
	Запрос.УстановитьПараметр("КодУзла",	КодУзла);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);			
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьЗаписьЗагрузки(Пакет, КодУзла) Экспорт

Функция ЗагрузитьДанные_Регистра(ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");	
	
	Записи 	= Неопределено;	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ,"Записи_") Тогда			
			Записи = КиЗ.Значение;
		КонецЕсли;		
	КонецЦикла;
	
	Если Записи = Неопределено Тогда
		Результат.Ошибки.Добавить("Не обнаружено таблицы с данными записей регистра !");
		Возврат Результат;	
	КонецЕсли;
	
	Для Каждого ДанныеИст Из Записи Цикл		       
		Пакет = ДанныеИст.Пакет;
		Если НЕ (ЗначениеЗаполнено(Пакет) И ТипЗнч(Пакет) = Тип("СправочникСсылка.ФР_ПакетыДанных")) Тогда 
			Продолжить;		
		КонецЕсли;
		
		Если МаркировкаС.ОбъектСуществует(Пакет) Тогда
			рПакета = ПолучитьРеквизитыШапки(ДанныеИст.Пакет, "ПланОбмена,Отправитель,Получатель");		
			
			ПланОбмена		= рПакета.ПланОбмена;
			КодТекущегоУзла = Маркировка_ПИ.ЭтотУзел_Код(ПланОбмена);
			
			Запись = РегистрыСведений.СостояниеПакетовОбмена.СоздатьМенеджерЗаписи();
			
			Запись.Пакет 	= Пакет;
			Запись.КодУзла  = КодТекущегоУзла;
			
			Запись.Прочитать();
			
			Если СокрЛП(рПакета.Отправитель) = КодТекущегоУзла Тогда				
				Поля = Новый Структура("ДатаПолучения,ДатаЗагрузки,Состояние");
				ЗаполнитьЗначенияСвойств(Поля, ДанныеИст);
				
				Если НЕ ЗначениеЗаполнено(Запись.Состояние) Тогда
					Состояние = Неопределено;
					Если ЗначениеЗаполнено(ДанныеИст.ДатаЗагрузки) Тогда
						Если ДанныеИст.ЕстьОшибкиЗагрузки Тогда
							Состояние = "Ошибка";
						Иначе
							Состояние = "Загружен";
						КонецЕсли;				
					Иначе				
						Состояние = "Получен";			
					КонецЕсли;					
					Поля.Вставить("Состояние", Состояние);
				КонецЕсли;				
			ИначеЕсли СокрЛП(рПакета.Получатель) = КодТекущегоУзла Тогда				
				Поля = Новый Структура("ДатаОтправки,ДатаСоздания");
				ЗаполнитьЗначенияСвойств(Поля, ДанныеИст);
			Иначе
				Поля = Новый Структура;				
			КонецЕсли;
			
			ОбновитьСтатусПакета(Пакет, Поля, рПакета.ПланОбмена);
		Иначе //Тут все проще - нет пакета - значит полностью новая запись			
			//Запись = РегистрыСведений.СостояниеПакетовОбмена.СоздатьМенеджерЗаписи();			
			//ЗаполнитьЗначенияСвойств(Запись, ДанныеИст);			
			//Запись.КодУзла 	= КодТекущегоУзла;			
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;	
КонецФункции //ЗагрузитьДанные_Регистра(ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт