Функция ОбновитьСтатусыЗадач() Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	АктивныеЗадачи = Новый Соответствие;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	ИмяОчереди,
	|	ИД_Задачи,
	|	СостояниеЗадания,
	|	ИсполняющееФЗ
	|ИЗ
	|	РегистрСведений.ОчередьЗадач
	|ГДЕ
	|	СостояниеЗадания = ЗНАЧЕНИЕ(Перечисление.СостоянияФЗ.Активно)	
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗапуска_Факт УБЫВ
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	
	ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	//+++Чирков 30.05.2026 без задачи
	//ЗаписатьВЛог("Отладка", "Очередь задач. Время получения активных задач: " + ВремяВыполнения, "Информация");
	//---Чирков 30.05.2026
	
	Пока Выборка.Следующий() Цикл
		ФЗ = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Выборка.ИсполняющееФЗ);
		Если ФЗ <> Неопределено Тогда
			Если ФЗ.Состояние = СостояниеФоновогоЗадания.Активно Тогда			
				Количество = АктивныеЗадачи[Выборка.ИмяОчереди];
				Если Количество = Неопределено Тогда
					Количество = 0;				
				КонецЕсли;
				АктивныеЗадачи[Выборка.ИмяОчереди] = Количество + 1;           
			//+++Чирков 03.07.2025 - временно до выяснения проблем с сзапись статусов задач	
			ИначеЕсли ФЗ.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
				ОбновитьСостояниеИсполняющегоФЗ(ФЗ, Результат);
				
				ТекстСообщения = СтрШаблон("Обновление статуса по завершенной задаче: %1, очередь: %2, ФЗ: %3.", 
					Выборка.ИД_Задачи, Выборка.ИмяОчереди, Выборка.ИсполняющееФЗ
				);
				ЗаписатьВЛог("Отладка.ОчередьЗадач", ТекстСообщения, "Информация");
			//---Чирков 03.07.2025
			ИначеЕсли ФЗ.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
				Результат = МаркировкаКС.СтруктураРезультата(Ложь);
				
				Инфо		= ФЗ.ИнформацияОбОшибке;
				ТекстОшибки = СтрШаблон("%1 %2 %3 %4", Инфо.Описание, Инфо.ИмяМодуля, Инфо.НомерСтроки, Инфо.ИсходнаяСтрока);
				Результат.Ошибки.Добавить(ТекстОшибки);
				
				ОбновитьСостояниеИсполняющегоФЗ(ФЗ, Результат);
			КонецЕсли;
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		КонецЕсли;		
	КонецЦикла;
	
	Результат.Сообщения.Добавить("Активных задач: " + Выборка.Количество());
	
	Результат.Данные = АктивныеЗадачи;
	
	Возврат Результат;
КонецФункции //ОбновитьСтатусыЗадач()

Функция ПерезапуститьУпавшиеЗадачи(пОбработки = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ИД_Задачи,
	|	НомерЧасти,
	|	ЗадачаОбработки.ИнтервалПовтораЗадач 	КАК ИнтервалПовтораЗадач,
	|	ЗадачаОбработки.ИнтервалМеждуЗадачами	КАК ИнтервалМеждуЗадачами
	|ИЗ
	|	РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
	|ГДЕ
	|	НЕ Успешно
	|	И ДатаЗавершения >= &ДатаЗавершения
	|	И ДатаЗавершения < ДОБАВИТЬКДАТЕ(&ТекущаяДата, СЕКУНДА, -ЗадачаОбработки.ИнтервалПовтораЗадач)
	|	И НомерПопытки < IsNull(ЗадачаОбработки.МаксЧислоПопыток, 0)
	|ИТОГИ ПО
	|	ЗадачаОбработки
	|";
	
	Запрос.УстановитьПараметр("ТекущаяДата", 	ТекущаяДата()); //За последние сутки	
	Запрос.УстановитьПараметр("ДатаЗавершения", ТекущаяДата() - 24*60*60); //За последние сутки	
	
	ОбработаноОбъектов = 0;
	
	Выборка_ЗадачаОбработки	= Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ЗадачаОбработки");
	Пока Выборка_ЗадачаОбработки.Следующий() Цикл
		ДатаЗапуска = ТекущаяДата();	
		ИнтервалМеждуЗадачами = Выборка_ЗадачаОбработки.ИнтервалМеждуЗадачами;
		
		Выборка 	= Выборка_ЗадачаОбработки.Выбрать();		
		Пока Выборка.Следующий() Цикл
			ДатаЗапуска = ДатаЗапуска + ИнтервалМеждуЗадачами;
			ПерезапуститьЗадачу(Выборка.ИД_Задачи, Выборка.НомерЧасти, ДатаЗапуска);		
			ОбработаноОбъектов = ОбработаноОбъектов + 1;
		КонецЦикла;		
	КонецЦикла;	
	
	Результат.ОбработаноОбъектов = ОбработаноОбъектов;
	
	Возврат Результат;
КонецФункции //ПерезапуститьУпавшиеЗадачи(пОбработки = Неопределено) Экспорт

Функция ПерезапуститьЗадачу(ИД_Задачи, НомерЧасти, ДатаЗапуска)
	Запись = РегистрыСведений.ОчередьЗадач.СоздатьМенеджерЗаписи();
	Запись.ИД_Задачи = ИД_Задачи; 
	Запись.НомерЧасти= НомерЧасти;
	
	Запись.Прочитать();		
	
	Запись.ДатаЗапуска_План = ДатаЗапуска;
	Запись.ДатаЗапуска_Факт	= Неопределено;
	Запись.ДатаЗавершения	= Неопределено;
	Запись.НомерПопытки		= Запись.НомерПопытки + 1;
	Запись.СостояниеЗадания = Неопределено;                                                
	Запись.Ошибки			= "";
	Запись.ВремяВыполнения	= 0;
	Запись.КоличествоОбъектов = 0;
	
	Запись.Записать();	
КонецФункции //ПерезапуститьЗадачу(ИД_Задачи, НомерЧасти, ИнтервалПовтораЗадач)

