Функция ЗарегистрироватьКодыПоДокументу(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();             
	
	Накладная = МаркировкаС.НакладнаяПоДокументуСканирования(ДокСсылка);	
	
	тКодыМаркировки = ПолучитьТаблицуКМДокумента(ДокСсылка);	
	
	НЗ = РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьНаборЗаписей();
	
	ВидДокумента    = ДокСсылка.Метаданные().Имя;
	Выборка 		= ПолучитьВыборкуВложенныхКодов(тКодыМаркировки);
	
	Автор 			= ПараметрыСеанса.Пользователь;
	ИмяКомпьютера   = ИмяКомпьютера();       
	ДатаЗаписи		= ТекущаяДата();
	
	Пока Выборка.Следующий() Цикл
		Запись = НЗ.Добавить();			
		
		Запись.ШтрихКодУпаковки = Выборка.ШтрихКодУпаковки;
		Запись.ВидДокумента 	= ВидДокумента;
		Запись.ДокОснование		= ДокСсылка;		
		Запись.Накладная		= Накладная;
	КонецЦикла;                                   
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_НовыеЗаписи ИЗ &НЗ КАК НЗ
	|;   
	|ВЫБРАТЬ	
	|	ВТ_НовыеЗаписи.ШтрихКодУпаковки КАК ШтрихКодУпаковки,
	|	ВТ_НовыеЗаписи.ВидДокумента		КАК ВидДокумента	
	|ИЗ
	|	ВТ_НовыеЗаписи
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки КАК СтарыеЗаписи
	|ПО
	|	ВТ_НовыеЗаписи.ШтрихКодУпаковки = СтарыеЗаписи.ШтрихКодУпаковки
	|	И ВТ_НовыеЗаписи.ВидДокумента = СтарыеЗаписи.ВидДокумента
	|ГДЕ
	|	ВТ_НовыеЗаписи.ШтрихКодУпаковки ЕСТЬ NULL
	|;
	|ВЫБРАТЬ	
	|	ВТ_НовыеЗаписи.ШтрихКодУпаковки КАК ШтрихКодУпаковки,
	|	ВТ_НовыеЗаписи.ВидДокумента		КАК ВидДокумента,
	|	ВТ_НовыеЗаписи.Накладная		КАК Накладная,
	|	ВТ_НовыеЗаписи.ДокОснование		КАК ДокОснование,	
	|	СтарыеЗаписи.ДокОснование 		КАК ПравильныйДокумент,
	|	СтарыеЗаписи.Накладная 			КАК ПравильнаяНакладная
	|ИЗ
	|	ВТ_НовыеЗаписи
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки КАК СтарыеЗаписи
	|ПО
	|	ВТ_НовыеЗаписи.ШтрихКодУпаковки = СтарыеЗаписи.ШтрихКодУпаковки
	|	И (
	|		ВТ_НовыеЗаписи.ВидДокумента = СтарыеЗаписи.ВидДокумента //Документ такого-же вида в той-же накладной
	|		ИЛИ ВТ_НовыеЗаписи.Накладная <> СтарыеЗаписи.Накладная	//Любой документ в другой накладной
	|	)
	|";
	
	Запрос.УстановитьПараметр("НЗ", НЗ.Выгрузить());
	
	рЗапроса = Запрос.ВыполнитьПакет();
	
	НЗ.Очистить();
	НЗ.РасширенныеРежимыЗамещения = Истина;
	
	//Удаление лишних записей
	Выборка = рЗапроса[рЗапроса.ВГраница() - 1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = НЗ.Добавить();	
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
	КонецЦикла;
	Если НЗ.Количество() > 0 Тогда		
		НЗ.Записать(РежимЗамещения.Удаление);
	КонецЕсли;
		
	НЗ.Очистить();
	
	НЗ_Ошибки = РегистрыСведений.ОшибкиПроверкиКМвРеестре.СоздатьНаборЗаписей();
	НЗ_Ошибки.РасширенныеРежимыЗамещения = Истина;
	НЗ_Ошибки.Отбор.ОшибочныйДокумент.Установить(ДокСсылка);	
	
	ОшибочныеКоды = Новый Соответствие;
	
	//Регистрация новых записей
	Выборка = рЗапроса[рЗапроса.ВГраница()].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ПравильнаяНакладная) И Выборка.ПравильнаяНакладная <> Выборка.Накладная Тогда			
			ТектОшибки = СтрШаблон("КМ: '%1' уже зарегистрирован к отгрузке по другой накладной: %2.", Выборка.ШтрихКодУпаковки, Выборка.ПравильнаяНакладная);
			
			Если ОшибочныеКоды[Выборка.ШтрихКодУпаковки] = Неопределено Тогда
				ОшибочныеКоды[Выборка.ШтрихКодУпаковки] = Истина;			
				
				ЗаписьОшибки = НЗ_Ошибки.Добавить();
				
				ЗаполнитьЗначенияСвойств(ЗаписьОшибки, Выборка);
				
				ЗаписьОшибки.ОшибочныйДокумент	= ДокСсылка;
				ЗаписьОшибки.ОшибочнаяНакладная = Накладная;
				
				ЗаписьОшибки.Ошибка				= ТектОшибки;
				ЗаписьОшибки.ДатаПроверки		= ДатаЗаписи;
				ЗаписьОшибки.Автор				= Автор;
				
				Результат.Ошибки.Добавить(ТектОшибки);
			КонецЕсли;
		ИначеЕсли ЗначениеЗаполнено(Выборка.ПравильныйДокумент) И Выборка.ПравильныйДокумент <> Выборка.ДокОснование Тогда			
			ТектОшибки = СтрШаблон("КМ: '%1' уже зарегистрирован к отгрузке по док-ту: %2.", Выборка.ШтрихКодУпаковки, Выборка.ПравильныйДокумент);
			
			ЗаписьОшибки = НЗ_Ошибки.Добавить();      
			
			ЗаполнитьЗначенияСвойств(ЗаписьОшибки, Выборка);			
			
			ЗаписьОшибки.ОшибочныйДокумент	= ДокСсылка;
			ЗаписьОшибки.ОшибочнаяНакладная = Накладная;			
			
			ЗаписьОшибки.Ошибка				= ТектОшибки;			
			ЗаписьОшибки.ДатаПроверки		= ДатаЗаписи;
			ЗаписьОшибки.Автор				= Автор;			
			
			Результат.Ошибки.Добавить(ТектОшибки);		
		Иначе
			Запись = НЗ.Добавить();
			
			ЗаполнитьЗначенияСвойств(Запись, Выборка);
			
			Запись.Автор			= Автор;
			Запись.ИмяКомпьютера	= ИмяКомпьютера;
			Запись.ДатаЗаписи		= ДатаЗаписи;
		КонецЕсли;
	КонецЦикла;
	
	Если НЗ.Количество() > 0 Тогда		
		НЗ.Записать(РежимЗамещения.Слияние);	
	КонецЕсли;
	
	НЗ_Ошибки.Записать(РежимЗамещения.Слияние);
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);	
	
	Возврат Результат;	
КонецФункции //ЗарегистрироватьКодыПоДокументу(ДокСсылка) Экспорт

Функция ОчиститьКодыПоДокументу(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();             
	
	Накладная = МаркировкаС.НакладнаяПоДокументуСканирования(ДокСсылка);	
	
	тКодыМаркировки = ПолучитьТаблицуКМДокумента(ДокСсылка);	
	
	ВидДокумента    = ДокСсылка.Метаданные().Имя;
	Выборка 		= ПолучитьВыборкуВложенныхКодов(тКодыМаркировки);
	
	Автор 			= ПараметрыСеанса.Пользователь;
	ИмяКомпьютера   = ИмяКомпьютера();       
	ДатаЗаписи		= ТекущаяДата();
	
	НЗ		= РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьНаборЗаписей();
	тКоды 	= НЗ.ВыгрузитьКолонки("ШтрихКодУпаковки");
	
	Пока Выборка.Следующий() Цикл
		Запись = тКоды.Добавить();
		Запись.ШтрихКодУпаковки = Выборка.ШтрихКодУпаковки;		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Коды ИЗ &тКоды КАК тКоды
	|;
	|ВЫБРАТЬ
	|	ВТ_Коды.ШтрихКодУпаковки,
	|	ОтгружаемыеКоды.ВидДокумента КАК ВидДокумента
	|ИЗ
	|	ВТ_Коды
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки КАК ОтгружаемыеКоды
	|ПО
	|	ВТ_Коды.ШтрихКодУпаковки = ОтгружаемыеКоды.ШтрихКодУпаковки
	|ГДЕ
	|	ОтгружаемыеКоды.ВидДокумента ЕСТЬ НЕ NULL
	|";
	
	//+++Чирков 29.04.2026 - на всякий случай фильт по исходной накладной при очистке 
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда //ХКМ к ПНК или ПРМ		
		Запрос.Текст = Запрос.Текст + "
		|	И ОтгружаемыеКоды.ДатаЗаписи <= &ДатаХКМ
		|";
		Запрос.УстановитьПараметр("ДатаХКМ", ПолучитьРеквизитШапки(ДокСсылка, "Дата"));
	Иначе //ЛН,ЛП,ЛСК
		Если ЗначениеЗаполнено(Накладная) Тогда		            
			Запрос.Текст = Запрос.Текст + "
			|	И ОтгружаемыеКоды.Накладная = &Накладная
			|";
			Запрос.УстановитьПараметр("Накладная", 	Накладная);			
		КонецЕсли;	
	КонецЕсли;	
	//---Чирков 29.04.2026
	
	Запрос.УстановитьПараметр("тКоды", тКоды);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись = НЗ.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
	КонецЦикла;	
	
	НЗ.РасширенныеРежимыЗамещения = Истина;	
	Если НЗ.Количество() > 0 Тогда		
		НЗ.Записать(РежимЗамещения.Удаление);	
	КонецЕсли;	
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);	
	
	Возврат Результат;	
КонецФункции //ОчиститьКодыПоДокументу(ДокСсылка) Экспорт

Функция ОчиститьКодыПоНакладной(Накладная) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();             
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихКодУпаковки,
	|	ВидДокумента
	|ИЗ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки
	|ГДЕ
	|	Накладная = &Накладная
	|";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	НЗ = РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьНаборЗаписей();	
	НЗ.Загрузить(Запрос.Выполнить().Выгрузить());		
	
	НЗ.РасширенныеРежимыЗамещения = Истина;	
	Если НЗ.Количество() > 0 Тогда		
		НЗ.Записать(РежимЗамещения.Удаление);	
	КонецЕсли;	
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);	
	
	Возврат Результат;	
КонецФункции //ОчиститьКодыПоНакладной(ДокСсылка) Экспорт

Функция ПолучитьТаблицуКМДокумента(ДокСсылка)
	Результат = Новый Массив;
	Попытка
	    тКодыМаркировки = Документы[ДокСсылка.Метаданные().Имя].ПолучитьТаблицуКМДокумента(ДокСсылка);		
	Исключение           
		тКодыМаркировки = Новый ТаблицаЗначений;	
		тКодыМаркировки.Колонки.Добавить("ШтрихкодУпаковки", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));		
	КонецПопытки;
	
	Возврат тКодыМаркировки;
КонецФункции //ПолучитьТаблицуКМДокумента(ДокСсылка)

Функция ПолучитьВыборкуВложенныхКодов(КодыМаркировки, ДопПараметры = Неопределено) Экспорт	
	ВключатьКодыКомплектующих = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ВключатьКодыКомплектующих", Истина);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = " 	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_КодыМаркировки ИЗ &КодыМаркировки КАК КодыМаркировки
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ       
	|	ШтрихкодУпаковки
	|ИЗ	
	|	ВТ_КодыМаркировки
	|ГДЕ	
	|	(
	|		ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка) 	
	|		ИЛИ (&ВключатьКодыКомплектующих И ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор))
	|	)
	|";
	
	Запрос.УстановитьПараметр("КодыМаркировки", КодыМаркировки);
	Запрос.УстановитьПараметр("ВключатьКодыКомплектующих", ВключатьКодыКомплектующих);
	
	ШтрихКодыСВложениями	= Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");	
	ВложенныеКоды 			= Документы.МаркировкаТоваровИСМП.ПолучитьВложенныеКоды(ШтрихКодыСВложениями);	
	
	Запрос.Текст = " 	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ВложенныеКоды ИЗ &ВложенныеКоды КАК ВложенныеКоды
	|;
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ИЗ	
	|	ВТ_КодыМаркировки
	|ОБЪЕДИНИТЬ          
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки
	|ИЗ	
	|	ВТ_ВложенныеКоды
	|";	
	
	Запрос.УстановитьПараметр("ВложенныеКоды", МаркировкаС.МассивВТаблицу(ВложенныеКоды, "ШтрихкодУпаковки", "СправочникСсылка.ШтрихкодыУпаковокТоваров"));
	
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции //ПолучитьВыборкуВложенныхКодов()

Функция ЗаписатьКМвОтгрузку(ДокОснование, ШтрихКоды, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ИмяКомпьютера = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ИмяКомпьютера", ИмяКомпьютера());
	
	Накладная = МаркировкаС.НакладнаяПоДокументуСканирования(ДокОснование);	
	
	ВложенныеКМ = Документы.МаркировкаТоваровИСМП.ПолучитьВложенныеКоды(ШтрихКоды);	
	
	тШК = Новый ТаблицаЗначений;
	тШК.Колонки.Добавить("ШтрихКодУпаковки", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));
	Для каждого ШтрихКодУпаковки Из ШтрихКоды Цикл
		СтрокаТ = тШК.Добавить();	
		СтрокаТ.ШтрихКодУпаковки = ШтрихКодУпаковки;
	КонецЦикла;
	Для каждого ШтрихКодУпаковки Из ВложенныеКМ Цикл
		СтрокаТ = тШК.Добавить();	
		СтрокаТ.ШтрихКодУпаковки = ШтрихКодУпаковки;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_КМ ИЗ &тШК КАК тШК
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_КМ.КМ 					КАК ШтрихКодУпаковки,
	|	МАКСИМУМ(Статусы.Статус) 	КАК Статус
	|ПОМЕСТИТЬ ВТ_КодыТекущейОтгрузки
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	РегистрСведений.СтатусыКМ_Факт КАК Статусы
	|ПО
	|	Статусы.ШтрихКодУпаковки = ВТ_КМ.ШтрихКодУпаковки
	|СГРУППИРОВАТЬ ПО
	|	ШтрихКодУпаковки
	|;
	|ВЫБРАТЬ
	|	ВТ_КодыТекущейОтгрузки.*,
	|	ПрочиеОтгрузки.ДокОснование КАК ДокОснование,
	|	ПрочиеОтгрузки.ДатаЗаписи	КАК ДатаЗаписи,
	|   ПрочиеОтгрузки.Автор		КАК Автор
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки КАК ПрочиеОтгрузки
	|ПО
	|	ВТ_КодыТекущейОтгрузки.ШтрихКодУпаковки = ПрочиеОтгрузки.ШтрихКодУпаковки
	|	И ПрочиеОтгрузки.ВидДокумента = &ВидДокумента
	|";                                              
	
	ВидДокумента = ДокОснование.Метаданные().Имя;
	
	Запрос.УстановитьПараметр("тШК", 			тШК);
	Запрос.УстановитьПараметр("ВидДокумента", 	ВидДокумента);
	
	НЗ = РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьНаборЗаписей();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ДокОснование) Тогда
			ТекстОшибки = СтрШаблон("Код маркировки: '%1' уже отгружается документом: %2 (%3)! К отгрузке зарегистрировал: %4, дата: %5.",
				Выборка.ШтрихКодУпаковки, Выборка.ДокОснование, Выборка.Накладная, Выборка.Автор, Выборка.ДатаЗаписи);
			
			Результат.Ошибки.Добавить();
		Иначе
			Запись = НЗ.Добавить();		
			
			Запись.ШтрихКодУпаковки = Выборка.ШтрихКодУпаковки;
			Запись.ВидДокумента		= ВидДокумента;
			
			Запись.ДокОснование 	= ДокОснование;			
			Запись.Автор			= ПараметрыСеанса.Пользователь;
			Запись.ДатаЗаписи		= ТекущаяДата();
			Запись.ИмяКомпьютера	= ИмяКомпьютера;
			
			Запись.Накладная		= Накладная;
		КонецЕсли;	
	КонецЦикла;
	
	НЗ.Записать(РежимЗамещения.Добавление);
	
	Результат.ОбработаноОбъектов = НЗ.Количество();
	Результат.Успешно = (Результат.Ошибки.Количество() > 0);
	
	Возврат Результат;	
КонецФункции //ЗаписатьКМвОтгрузку(ДокОснование, ШтрихКоды, ДопПараметры = Неопределено) Экспорт

Функция УдалитьЗаписиПоДокументу(ДокОснование) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихКодУпаковки,
	|	ВидДокумента
	|ИЗ
	|	РегистрСведений.ОтгружаемыеКодыМаркировки	
	|ГДЕ
	|	ДокОснование = &ДокОснование
	|";
	
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	
	НЗ = РегистрыСведений.ОтгружаемыеКодыМаркировки.СоздатьНаборЗаписей();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл                                         
		Запись = НЗ.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);	
	КонецЦикла;
	
	Если НЗ.Количество() > 0 Тогда
		НЗ.РасширенныеРежимыЗамещения = Истина;
		НЗ.Записать(РежимЗамещения.Удаление);
	КонецЕсли;
КонецФункции //УдалитьЗаписиПоДокументу(ДокОснование) Экспорт

