Функция ЗаблокироватьТаблицу(Знач мНоменклатура = Неопределено) Экспорт  
	Результат 				= МаркировкаКС.СтруктураРезультата();
	
	Блокировка				= Новый БлокировкаДанных;					
					
	ЭлементБлокировки 		= Блокировка.Добавить("РегистрСведений.СтатусыКМ_Факт_Штуки_Актуальные");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;					
	
	Если ЗначениеЗаполнено(мНоменклатура) Тогда
		тНоменклатура = Новый ТаблицаЗначений;
		тНоменклатура.Колонки.Добавить("Номенклатура",  Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		
		Если ТипЗнч(мНоменклатура) =  Тип("Массив") Тогда
			Для Каждого Номенклатура Из мНоменклатура Цикл
				СтрокаТЧ = тНоменклатура.Добавить();
				СтрокаТЧ.Номенклатура = Номенклатура;
			КонецЦикла;
		Иначе
			СтрокаТЧ = тНоменклатура.Добавить();
			СтрокаТЧ.Номенклатура = мНоменклатура;
		КонецЕсли;
		
		ЭлементБлокировки.ИсточникДанных = тНоменклатура; 
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	КонецЕсли;	
	
	Попытка
		Блокировка.Заблокировать();                         
	Исключение
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить("Ошибка установки блокировки ! " + ОписаниеОшибки());
	КонецПопытки;	
	
	Возврат Результат;
КонецФункции //ЗаблокироватьТаблицу() Экспорт

Функция СформироватьДвижения(Регистратор) Экспорт
	Если НЕ Метаданные.РегистрыСведений.СтатусыКМ_Факт_А.СтандартныеРеквизиты.Регистратор.Тип.СодержитТип(ТипЗнч(Регистратор)) Тогда
		Возврат Неопределено;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Период,
	|	Регистратор,
	|	ТипШК,
	|	ШтрихКодУпаковки,
	|	Статус,
	|	Местонахождение,
	|	ВПути,
	|	ШтрихКодУпаковки.СпособВводаВОборот КАК СпособВводаВОборот
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт КАК СтатусыКМ_Факт
	|ГДЕ
	|	Регистратор = &Регистратор
	|	И ТипШК <> ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|";
	
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	
	НЗ = РегистрыСведений.СтатусыКМ_Факт_А.СоздатьНаборЗаписей();
	НЗ.Отбор.Регистратор.Установить(Регистратор, Истина);
	
	НЗ.Загрузить(Запрос.Выполнить().Выгрузить());
	
	НЗ.Записать();	
КонецФункции //СформироватьДвижения(Регистратор) Экспорт