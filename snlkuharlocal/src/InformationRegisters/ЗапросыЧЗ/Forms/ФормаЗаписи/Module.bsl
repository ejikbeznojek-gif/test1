
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	Запрос = ТекущийОбъект.ДанныеЗапроса.Получить();
	
	ДанныеОтвета = ТекущийОбъект.ДанныеОтвета.Получить();
	Если ЗначениеЗаполнено(ДанныеОтвета) Тогда	
		Попытка
			Ответ	= МаркировкаКС.ПричесатьЖСОН(ДанныеОтвета);		
		Исключение
			Ответ	= ДанныеОтвета;
		КонецПопытки;		
	КонецЕсли;	
КонецПроцедуры
