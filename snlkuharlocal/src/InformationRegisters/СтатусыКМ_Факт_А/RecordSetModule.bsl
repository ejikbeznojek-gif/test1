Процедура ПередЗаписью(Отказ, Замещение)
	Если ОбменДанными.Загрузка Тогда Возврат КонецЕсли;
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	
	локУстановитьСписокПолучателей();	
КонецПроцедуры

Функция локУстановитьСписокПолучателей()
	Регистратор	= Отбор.Регистратор.Значение;
	
	ИмяПланаОбмена	= "ДанныеЧЗ";
	Получатели		= Новый Массив;
	
	ТипРегистратора = ТипЗнч(Регистратор);	
	
	Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если ТипРегистратора = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
			Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.Склад, ИмяПланаОбмена);
		ИначеЕсли ТипРегистратора = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда		
			Если ПолучитьРеквизитШапки(Регистратор, "КодУзлаСоздания") = Маркировка_ПИ.ЭтотУзел_Код() Тогда
				Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.Склад, ИмяПланаОбмена);
			КонецЕсли;
		КонецЕсли;	
	Иначе //Периферийная база - отправка в ЦО
		Если ТипРегистратора = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
			Если ПолучитьРеквизитШапки(Регистратор, "КодУзлаСоздания") = Маркировка_ПИ.ЭтотУзел_Код() Тогда
				Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.УправляющееПодразделение, ИмяПланаОбмена);
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;  
	
	ЭтотУзел = Маркировка_ПИ.ЭтотУзел(ИмяПланаОбмена);
	Для Каждого Получатель Из Получатели Цикл
		Если Получатель <> ЭтотУзел Тогда		
			ОбменДанными.Получатели.Добавить(Получатель);
		КонецЕсли;
	КонецЦикла;	
КонецФункции //локУстановитьСписокПолучателей()