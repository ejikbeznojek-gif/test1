Функция ПолучитьОтпечатокЭЦП(ТипТокена, Организация, Пользователь = Неопределено, Знач СУЗ = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	мПользователь = ?(ЗначениеЗаполнено(Пользователь), Пользователь, ПараметрыСеанса.Пользователь);
	
	Данные = Новый Структура("Токен,СУЗ,ОтпечатокЭЦП");
	
	Запись = РегистрыСведений.ТокеныАвторизацииИСМП.СоздатьМенеджерЗаписи();
	
	Запись.Организация 		= Организация;
	Запись.ТипТокена 		= ТипТокена;
	Запись.Пользователь 	= мПользователь;
	
	Если ТипТокена = "СУЗ" И НЕ ЗначениеЗаполнено(СУЗ) Тогда           
		рПолучения = Справочники.СтанцииУправленияЗаказамиИСМП.ПолучитьСузПользователя(Запись.Организация, Запись.Пользователь);
		Если рПолучения.Успешно Тогда
			СУЗ	= рПолучения.Данные;	
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
			Возврат Результат;
		КонецЕсли;		
	КонецЕсли;
	
	Запись.СУЗ = СУЗ;
	Запись.Прочитать();	
	
	Если ЗначениеЗаполнено(Запись.ОтпечатокЭЦП) Тогда
		Результат.Данные	= Запись.ОтпечатокЭЦП;
		Результат.Успешно	= Истина;		
	Иначе   
		ТекстОшибки = СтрШаблон("Не найден отпечаток ЭЦП для токена %1 ! Организация: '%2', пользователь: '%3', СУЗ: '%4'.", ТипТокена, Организация, СокрЛП(мПользователь), СУЗ);
		Результат.Ошибки.Добавить(ТекстОшибки);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьОтпечатокЭЦП(ТипТокена, Организация, Пользователь = Неопределено, Знач СУЗ = Неопределено) Экспорт

Функция ПолучитьТокенВЧЗ(ТипТокена, Организация, ОтпечатокЭЦП, СУЗ)
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Данные = Новый Структура("Токен,СУЗ,ОтпечатокЭЦП");	
	
	ТекстСообщения = СтрШаблон("Запрос токена: %1, организация: %2, пользователь: %3, СУЗ: %4, отпечаток ЭЦП: %5.", 
		ТипТокена, Организация, СокрЛП(""+ПараметрыСеанса.Пользователь), СУЗ, ОтпечатокЭЦП);
	ЗаписатьВЛог("Токены ЧЗ", ТекстСообщения, "Отладка");
	
	//TO DO - странная логика -надо разобраться что там намудрили спаролями ЭЦП
	Если СтрНачинаетсяС(ВРег(СокрЛП("" + ПараметрыСеанса.Пользователь)), "AUTO") 
		ИЛИ (ЗначениеЗаполнено(СУЗ) И СУЗ.СУЗДляОУКЭП) Тогда
		ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ПарольДоступаКЗакрытомуКлючу", "");		
		ЗаписатьВЛог("Токены ЧЗ", "Сохранен пустой пароль доступа к закрытому ключу", "Отладка");
	Иначе
		
	КонецЕсли;
	
	ОбработкаАПИ = Обработки.АпиЧЗ.Создать();
			
	Если ТипТокена = "СУЗ" Тогда			
		Токен = ОбработкаАПИ.ПолучитьТокен_СУЗ(СУЗ, ОтпечатокЭЦП);	
	Иначе
		Токен = ОбработкаАПИ.ПолучитьТокен_TrueApi(ОтпечатокЭЦП, Организация);			
	КонецЕсли;
	
	Если ПустаяСтрока(Токен) Тогда 
		ТекстОшибки = СтрШаблон("Не удалось получить токен: %1 для организации: %2 !", ТипТокена, Организация);
		Результат.Ошибки.Добавить(ТекстОшибки);
	Иначе			
		СохранитьТокен(Токен, ТипТокена, Организация, ОтпечатокЭЦП, СУЗ);
		
		Данные.Токен		= Токен;
		Данные.СУЗ 			= СУЗ;
		Данные.ОтпечатокЭЦП	= ОтпечатокЭЦП;
		
		Результат.Успешно	= Истина;
	КонецЕсли;
	
	Результат.Данные = Данные;
	
	Возврат Результат;
КонецФункции // ()
//++Данилова Е.В. 06.03.2026
Функция ОтработкаБлокировкиТокена(Запись)
	
	Результат = МаркировкаКС.СтруктураРезультата(Истина); 
	Если ЗначениеЗаполнено(Запись.ДатаБлокировки) 
		И ТекущаяДата() - Запись.ДатаБлокировки < 1800 Тогда
		Результат.Успешно = Ложь; 
		Результат.Ошибки.Добавить("Получение токена заблокировано"); 
		ЗаписатьВЛог("Токены ЧЗ", "Получение токена заблокировано", "Отладка");
		Возврат Результат; 
	Иначе
		Запись.ДатаБлокировки = ТекущаяДатаСеанса(); 
		Запись.Записать(); 
		Возврат Результат; 
	КонецЕсли;	

КонецФункции // ()

//--Данилова Е.В. 06.03.2026 
