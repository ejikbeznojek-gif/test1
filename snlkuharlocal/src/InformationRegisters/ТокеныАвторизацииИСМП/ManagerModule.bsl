Функция СохранитьТокен(Токен, ТипТокена, Организация, ОтпечатокЭЦП, СУЗ = Неопределено) Экспорт
	Если Не ЗначениеЗаполнено(Организация) Тогда 
		ЗаписатьВЛог("Получение токенов ЧЗ", "Не указана организация токена !", "Ошибка");
		Возврат Ложь; 
	КонецЕсли;
	
	Запись = РегистрыСведений.ТокеныАвторизацииИСМП.СоздатьМенеджерЗаписи();
	
	Запись.Организация 		= Организация;
	Запись.ТипТокена 		= ТипТокена;	
	Запись.Пользователь		= ПараметрыСеанса.Пользователь;
	Запись.СУЗ				= СУЗ;
	Запись.Токен 			= Новый ХранилищеЗначения(Токен);
	
	Запись.ДатаПолучения 	= ТекущаяДата();
	Запись.СрокДействия		= Запись.ДатаПолучения + СрокЖизниТокена(ТипТокена);
	
	Запись.РабочееМесто 	= ПараметрыСеанса.РабочееМестоКлиента;
	Запись.ОтпечатокЭЦП		= ОтпечатокЭЦП;
	
	Запись.Записать();
КонецФункции //СохранитьТокен(Токен, ТипТокена, Организация, ОтпечатокЭЦП, СУЗ = Неопределено) Экспорт

Функция СрокЖизниТокена(ТипТокена = "СУЗ")
	Возврат 5*60*60;
КонецФункции //СрокЖизниТокена(ТипТокена = "СУЗ")

Функция ПолучитьТокен(ТипТокена, Организация, Знач ОтпечатокЭЦП = Неопределено, Знач СУЗ = Неопределено, Пользователь = Неопределено) Экспорт
