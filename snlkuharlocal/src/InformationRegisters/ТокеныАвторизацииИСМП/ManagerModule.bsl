		//	РезультатОтработки = ОтработкаБлокировкиТокена(Запись);
		//	Если НЕ РезультатОтработки.Успешно Тогда
		//		
		//		МаркировкаКС.ДобавитьОшибки(Результат, РезультатОтработки);	
		//		
		//	Иначе
		//		//--Данилова Е.В. 06.03.2026
		//		рПолучения = ПолучитьТокенВЧЗ(ТипТокена, Организация, ОтпечатокЭЦП, СУЗ);
		//		
		//		Если рПолучения.Успешно Тогда
		//			Данные = рПолучения.Данные;
		//			Результат.Успешно = Истина;
		//		Иначе
		//			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);			
		//		КонецЕсли;
		//	КонецЕсли;
		//КонецЕсли;
