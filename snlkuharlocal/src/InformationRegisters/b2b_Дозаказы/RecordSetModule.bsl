
Процедура ПриЗаписи(Отказ, Замещение)
	ДатаЗаписи = ТекущаяДатаСеанса(); 
	Для каждого ЭлементЗаписи Из ЭтотОбъект Цикл
		
		МенеджерЗаписи = Регистрысведений.b2b_ДозаказыИстория.СоздатьМенеджерЗаписи(); 
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ЭлементЗаписи); 
		МенеджерЗаписи.Период = ДатаЗаписи; 
		МенеджерЗаписи.Записать(); 
		
	КонецЦикла;
КонецПроцедуры
