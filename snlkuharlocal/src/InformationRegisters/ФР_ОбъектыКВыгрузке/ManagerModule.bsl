	#КОНЕЦЕСЛИ
КонецПроцедуры

Функция НужноРегистрироватьХКМ_ДляФР(СсылкаНаОбъект)
	Результат	= Новый Структура(
		"ВариантВыгрузки,ВыгружаемаяСсылка,ПодразделениеПолучатель,Нужно,Ошибки",
		"", СсылкаНаОбъект, Неопределено, Ложь, Новый Массив);
	
	Если НЕ Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Возврат Результат;
	КонецЕсли;
	
	РеквизитыШ = ПолучитьРеквизитыШапки(СсылкаНаОбъект, "ДокОснование,КодУзлаСоздания");
	
	Если ТипЗнч(РеквизитыШ.ДокОснование) = Тип("ДокументСсылка.Перемещение") Тогда
		ДокОснование 	= РеквизитыШ.ДокОснование;
		
		текРезультат	= Это_ПРМ_ПРМ_На_ФР(ДокОснование);
		Если текРезультат.Результат Тогда			
			Результат.Нужно			  			= Истина;				
			
			Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
		Иначе
			//крохин начало 24.12.2024
			//СсылкаНаОбъект - ХКМ, при передаче его в функцию Это_ПРМ_ПРМ_С_ФР выходит ошибка "нет реквизита подразделение".
			//текРезультат	= Это_ПРМ_ПРМ_С_ФР(СсылкаНаОбъект);			
			//
			//Результат.Нужно	= Истина;				
			//
			//Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;							
			//крохин конец 24.12.2024
		КонецЕсли;
		ИначеЕсли ТипЗнч(РеквизитыШ.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		ДокОснование 	= РеквизитыШ.ДокОснование;
		
		текРезультат	= Это_РНК_На_ФР(ДокОснование);
		Если текРезультат.Результат Тогда			
			Результат.Нужно			  			= Истина;				
			
			Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
		КонецЕсли;
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //НужноРегистрироватьХКМ_ДляФР()

//+HELP-2306 20250220 Михайловский	
Функция НужноРегистрироватьПСАЗ(СсылкаНаОбъект)
	Результат	= Новый Структура(
		"ВариантВыгрузки,ВыгружаемаяСсылка,ПодразделениеПолучатель,Нужно,Ошибки",
		"", СсылкаНаОбъект, СсылкаНаОбъект.Подразделение, Ложь, Новый Массив);
	Если СсылкаНаОбъект.Состояние = Перечисления.СостоянияЗаявкиНаСторонПост.Отменена ИЛИ
	СсылкаНаОбъект.Состояние = Перечисления.СостоянияЗаявкиНаСторонПост.Выполнена ИЛИ
	СсылкаНаОбъект.Состояние = Перечисления.СостоянияЗаявкиНаСторонПост.Согласована Тогда
		Результат.Нужно = Истина;
	КонецЕсли;
	Возврат Результат;
КонецФункции //-HELP-2306 20250220 Михайловский
