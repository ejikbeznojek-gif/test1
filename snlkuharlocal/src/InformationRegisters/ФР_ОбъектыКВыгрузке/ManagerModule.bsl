КонецФункции //Это_ПНК_ВЗВ_На_ФР(СсылкаНаОбъект)

Функция ПолучитьСсылкуИзНЗ(НЗ,ТипОбъекта)
	
	СсылкаНаОбъект	= Неопределено;
	ПолеОтбора		= Неопределено;
	
	Если ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.ЦеныНоменклатуры") Тогда
		ПолеОтбора	= "Прайс";
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.ЗначенияСвойствОбъектов") Тогда		
		ПолеОтбора	= "Объект";		
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.История") Тогда
		ПолеОтбора	= "Объект";		
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.КоличествоПосетителей") Тогда
		ПолеОтбора	= "Подразделение";		
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.КурсыВалют") Тогда
		ПолеОтбора	= "Валюта";
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.РеквизитыСправочников") Тогда
		ПолеОтбора	= "Справочник";		
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.СкидкиНоменклатуры") Тогда
		ПолеОтбора	= "Документ";
	ИначеЕсли ТипОбъекта=Тип("РегистрСведенийНаборЗаписей.СкидкиКонтрагентов") Тогда
		ПолеОтбора	= "Контрагент";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолеОтбора) Тогда	
		СсылкаНаОбъект=НЗ.Отбор[ПолеОтбора].Значение;	
	КонецЕсли;	
	
	Возврат СсылкаНаОбъект;
	
КонецФункции //ПолучитьСсылкуИзНЗ(НЗ,ТипОбъекта)
 

Процедура ЗарегистрироватьОбъекты(ТабДокументов,ДопПараметры=Неопределено) Экспорт	
	ИД_Пакета				= Новый УникальныйИдентификатор();
	
	РегистрироватьДопОбъекты	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"РегистрироватьДопОбъекты",Ложь);
	
	МЗ	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьНаборЗаписей();			
	
	МЗ.ДополнительныеСвойства.Вставить("РегистрироватьДопОбъекты",РегистрироватьДопОбъекты);	
	
	МЗ.Отбор.ИД_Пакета.Установить(ИД_Пакета,Истина);
	
	Дубли		= Новый Соответствие;
	
	НачНомер	= ТекущаяУниверсальнаяДатаВМиллисекундах()*100000;
	
	Для Каждого СтрокаТД Из ТабДокументов Цикл
		Если СтрокаТД.ОбъектСсылка=Неопределено Тогда КонецЕсли; 
		ОбъектСсылка	= СтрокаТД.ОбъектСсылка;
		
		ТипСсылка	= ТипЗнч(ОбъектСсылка);
		ОбъектТип	= ФР_ОбщегоНазначения_ПИ.ИмяТипа(ЗначениеВСтрокуВнутр(ТипСсылка));
		Если ПустаяСтрока(ОбъектТип) Тогда Продолжить КонецЕсли; 
		
		ИД_Строки	= ОбъектТип+XMLСтрока(СтрокаТД.ОбъектСсылка)+СтрокаТД.ОтборРС_Хэш;
		Если Дубли.Получить(ИД_Строки)<>Неопределено Тогда Продолжить КонецЕсли; 
		Дубли.Вставить(ИД_Строки,Истина);
		
		Запись	= МЗ.Добавить();
		
		Запись.ОбъектТип		= ОбъектТип;
		Запись.ОбъектСсылкаУИД 	= ОбъектСсылка.УникальныйИдентификатор();
		Запись.ОтборРС_Хэш		= СтрокаТД.ОтборРС_Хэш;
		Запись.ИД_Пакета 		= ИД_Пакета;
		
		Запись.Получатель		= СтрокаТД.Получатель;
		Запись.ДокОснование		= СтрокаТД.ДокОснование;
		Запись.ОтборРС			= СтрокаТД.ОтборРС;
		
		Запись.ВариантВыгрузки	= ВариантВыгрузки(ОбъектСсылка,СтрокаТД.ВариантВыгрузки);
		Запись.Номер			= НачНомер;
		
		Запись.ДатаРегистрации	= ТекущаяДата();
		Запись.ПредставлениеОбъекта = ОбъектСсылка;
		
		НачНомер	= НачНомер+1;
	КонецЦикла;
	
	МЗ.Записать();
	
КонецПроцедуры

Функция ЭтоМодель_(Номенклатура)
	Результат	= Ложь;
	
	Запрос	= Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников
	|ГДЕ
	|	Справочник = &Справочник
	|	И ИмяРеквизита = ""ЭтоМодель""
	|";
	
	Запрос.УстановитьПараметр("Справочник",Номенклатура);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат	= Выборка.ЗначениеРеквизита;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции // ()

Функция ЭтоМодель(Номенклатура)
	Возврат (ПолучитьРеквизитШапки(Номенклатура, "ЭтоМодель", "Справочник") = Истина);	
КонецФункции // ()

Функция ЗаписатьРеквизитСправочника(СпрСсылка,Имя,Значение)
	МЗ	= РегистрыСведений.РеквизитыСправочников.СоздатьМенеджерЗаписи();	
	МЗ.Справочник			= СпрСсылка;
	МЗ.ИмяРеквизита			= Имя;
	МЗ.ЗначениеРеквизита    = Значение;
	
	МЗ.Записать();
КонецФункции //ЗаписатьРеквизитСправочника()
   

Функция ВариантВыгрузки(СсылкаНаОбъект,ВариантВыгрузки="") Экспорт	
	ТипОбъекта	= ТипЗнч(СсылкаНаОбъект);	
	
	Если ПустаяСтрока(ВариантВыгрузки) Тогда		
		ТипСтрВнутр	= ЗначениеВСтрокуВнутр(ТипОбъекта);
		ОТ			= ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ТипСтрВнутр);
		
		Если ОТ.КлассЕЧ="Документ" Тогда
			Если ОТ.Вид="РасходнаяНакладная" Тогда
				ЭтоРНК	= Это_РНК_На_ФР(СсылкаНаОбъект);
				Если ЭтоРНК.Результат Тогда
					ВариантВыгрузки="РНК_ПНК";
				КонецЕсли;
			ИначеЕсли ОТ.Вид="Перемещение" Тогда
				текРезультат	= Это_ПРМ_ПНК_На_ФР(СсылкаНаОбъект);
				Если текРезультат.Результат Тогда
					ВариантВыгрузки="ПРМ_ПНК";
				Иначе
					текРезультат	= Это_ПРМ_РНК_С_ФР(СсылкаНаОбъект);
					Если текРезультат.Результат Тогда
						ВариантВыгрузки="ПРМ_РНК";
					Иначе
						ВариантВыгрузки="ПРМ_ПРМ";						
					КонецЕсли;				
				КонецЕсли;			
			ИначеЕсли ОТ.Вид="ПриходнаяНакладная" Тогда
				текРезультат	= Это_ПНК_ВЗВ_На_ФР(СсылкаНаОбъект);
				Если текРезультат.Результат Тогда
					ВариантВыгрузки="ПНК_ВЗВ";														
				КонецЕсли; 				
			ИначеЕсли ОТ.Вид="ЭмиссияПодарочныхСертификатов" Тогда
				РеквизитыШ = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"КодОперации,Подразделение","Документ");
				Если 
					РеквизитыШ.КодОперации = Перечисления.КодыОперацийПС.Деактивация
					ИЛИ РеквизитыШ.КодОперации = Перечисления.КодыОперацийПС.Дарение Тогда
					
					ВариантВыгрузки			= "ЭПС_СПН";				
				КонецЕсли;
			КонецЕсли;			
		ИначеЕсли ОТ.КлассЕЧ="Справочник" Тогда			
			ВариантВыгрузки = "Элемент";
			Если ОТ.Вид	="Номенклатура" Тогда		
				Реквизиты = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"ЭтоГруппа,Родитель"); 
				
				Если Реквизиты.ЭтоГруппа=Null ИЛИ Реквизиты.ЭтоГруппа = Неопределено Тогда
					Возврат "";									
				КонецЕсли; 
				
				Если Реквизиты.ЭтоГруппа Тогда
					//а с группами вообще непонятно что.......	
					ВариантВыгрузки = ВариантВыгрузкиГруппаНоменклатуры(СсылкаНаОбъект);
				Иначе					
					Если ЭтоМодель(Реквизиты.Родитель) = Истина Тогда
						ЗарегистрироватьОбъект(Реквизиты.Родитель);											
					КонецЕсли; 					
					ВариантВыгрузки	= "Справочник.ХарактеристикиНоменклатуры";					
				КонецЕсли;
			Иначе				
				Если ОТ.ИмеетГруппы Тогда
					ЭтоГруппа	= ПолучитьРеквизитШапки(СсылкаНаОбъект,"ЭтоГруппа","Справочник");
					Если ЭтоГруппа Тогда
						ВариантВыгрузки = "Группа";					
					КонецЕсли;					
				КонецЕсли; 
			КонецЕсли;
		ИначеЕсли ОТ.КлассЕЧ="ПланВидовХарактеристик" Тогда
			Результат = "Элемент";
			Если ОТ.ИмеетГруппы Тогда				
				ЭтоГруппа	= ПолучитьРеквизитШапки(СсылкаНаОбъект,"ЭтоГруппа","ПланВидовХарактеристик");
				Если ЭтоГруппа Тогда
					ВариантВыгрузки = "Группа";					
				КонецЕсли; 				
			КонецЕсли;			
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВариантВыгрузки;

КонецФункции //ВариантРегистрации(СсылкаНаОбъект)

Функция ВариантВыгрузкиГруппаНоменклатуры(Номенклатура)	
	ВариантВыгрузки = -1;	
	ЭтоМодель 		= ЭтоМодель(Номенклатура);	
	
	Если ЭтоМодель Тогда
		ВариантВыгрузки = "Элемент";
	Иначе
		КолПодчОбъектов = ПодчиненыеОбъекты(Номенклатура);
		
		Если КолПодчОбъектов.Группы = 0 Тогда
			Если КолПодчОбъектов.Элементы > 0 Тогда //Модель			
				ВариантВыгрузки = "Элемент";
			Иначе
				//Пустая группа - ХЗ что это
			КонецЕсли; 
		Иначе
			Если КолПодчОбъектов.Элементы = 0 Тогда //Группа
				ВариантВыгрузки = "Группа";					
			Иначе							
				//Это каша
			КонецЕсли;				
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат ВариантВыгрузки;
КонецФункции //ВариантВыгрузкиГруппаНоменклатуры(Номенклатура)
 

Функция СделатьЗаписьРегистрации(ОбъектСсылка,ВариантВыгрузки="",ОтборРС="",ПодразделениеПолучатель=Неопределено) Экспорт
	Результат	= Новый Структура("Результат,Ошибки",Ложь,Новый Массив);
	
	ТекстОшибки	= "";
	Если ВариантВыгрузки =-1 Тогда 
		ТекстОшибки	= "Не определен вариант выгрузки.";		
	ИначеЕсли НЕ ЗначениеЗаполнено(ОбъектСсылка) Тогда
		ТекстОшибки	= "Пустой объект выгрузки.";		
	КонецЕсли;
	Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
		Результат.Ошибки.Добавить(ТекстОшибки);	
		Возврат Результат;		
	КонецЕсли; 
	
	Запись	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьМенеджерЗаписи();
	
	Если ЗначениеЗаполнено(ОтборРС) Тогда
		ОтборРС_Хэш	= ФР_ОбщегоНазначения_С.ХэшСтрока(ОтборРС);
	Иначе
		ОтборРС_Хэш	= "";		
	КонецЕсли; 
	
	ОбъектСсылкаУИД	= ОбъектСсылка.УникальныйИдентификатор();
	
	//Если НЕ ЗаписьСуществует(ОбъектСсылкаУИД,ОтборРС_Хэш,ВариантВыгрузки) Тогда		
		Запись.ОбъектТип		= ФР_ОбщегоНазначения_ПИ.ИмяТипа(ЗначениеВСтрокуВнутр(ТипЗнч(ОбъектСсылка)));
		Запись.ОбъектСсылкаУИД	= ОбъектСсылкаУИД;
		Запись.ОтборРС_Хэш		= ОтборРС_Хэш;
		Запись.ИД_Пакета		= Новый УникальныйИдентификатор();		
		
		Запись.Номер			= ТекущаяУниверсальнаяДатаВМиллисекундах()*100000;
		
		Запись.ВариантВыгрузки	= ВариантВыгрузки;		
		
		Если ЗначениеЗаполнено(ОтборРС) Тогда
			Запись.ОтборРС		= Новый ХранилищеЗначения(ОтборРС,Новый СжатиеДанных(1));
		КонецЕсли;		
		
		Запись.Получатель		= ПодразделениеПолучатель;		
		Запись.ДатаРегистрации	= ТекущаяДата();
		Запись.ПредставлениеОбъекта	= ОбъектСсылка;	
		
		Если Запись.ОбъектСсылкаУИД<>Неопределено Тогда
			Запись.Записать();
			Результат.Результат	= Истина;
		КонецЕсли;
	//КонецЕсли;
	
	Если (ТипЗнч(ОбъектСсылка)=Тип("ДокументСсылка.РасходнаяНакладная")	ИЛИ ТипЗнч(ОбъектСсылка)=Тип("ДокументСсылка.Перемещение"))
		И (ВариантВыгрузки="ПРМ_ПНК" ИЛИ  ВариантВыгрузки="РНК_ПНК") Тогда
		
		СостояниеНакладной = ПолучитьРеквизитШапки(ОбъектСсылка,"СостояниеНакладной","Документ");
		
		Если СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке ИЛИ СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена Тогда			
			Зарегистрировать_ШКиДекларацииПоПНК(ОбъектСсылка);			
		КонецЕсли;	    
	ИначеЕсли ТипЗнч(ОбъектСсылка)=Тип("ДокументСсылка.ПрайсЛист") Тогда
		Если ПустаяСтрока(ВариантВыгрузки) Тогда
			ЗарегистрироватьЦены(ОбъектСсылка);
		КонецЕсли;		
	ИначеЕсли ТипЗнч(ОбъектСсылка)=Тип("ДокументСсылка.УстановкаСкидок") Тогда
		Если ПустаяСтрока(ВариантВыгрузки) Тогда
			ЗарегистрироватьСкидки(ОбъектСсылка);		
		КонецЕсли;	
	ИначеЕсли ТипЗнч(ОбъектСсылка)=Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
		ЗарегистрироватьКМпоХКМ(ОбъектСсылка);				
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции

Функция ЗаписьСуществует(ОбъектСсылкаУИД,ОтборРС_Хэш,ВариантВыгрузки)
	Результат	= Ложь;
	
	Запрос	=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОбъектСсылкаУИД
	|ИЗ 
	|	РегистрСведений.ФР_ОбъектыКВыгрузке	
	|ГДЕ
	|	ОбъектСсылкаУИД	= &ОбъектСсылкаУИД
	|	И ОтборРС_Хэш	= &ОтборРС_Хэш 
	|	И ВариантВыгрузки = &ВариантВыгрузки
	|";
	
	Запрос.УстановитьПараметр("ОбъектСсылкаУИД",	ОбъектСсылкаУИД);
	Запрос.УстановитьПараметр("ОтборРС_Хэш",		ОтборРС_Хэш);
	Запрос.УстановитьПараметр("ВариантВыгрузки",	ВариантВыгрузки);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ОбъектСсылкаУИД) Тогда
		Результат=Истина;			
	КонецЕсли; 
	
	Возврат Результат;	 	
КонецФункции //ЗаписьСуществует(СсылкаНаОбъект,ОтборРС)
 

Функция ПодчиненыеОбъекты(Группа)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	СУММА(ВЫБОР КОГДА ЭтоГруппа ТОГДА 1 ИНАЧЕ 0 КОНЕЦ) КАК Группы,
	|	СУММА(ВЫБОР КОГДА ЭтоГруппа ТОГДА 0 ИНАЧЕ 1 КОНЕЦ) КАК Элементы
	|ИЗ
	|	Справочник.Номенклатура
	|ГДЕ
	|	Родитель=&Группа
	|";
	
	
	Результат = Новый Структура("Группы,Элементы",0,0);
	
	Запрос.УстановитьПараметр("Группа",	Группа);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.Группы<>Null Тогда
		ЗаполнитьЗначенияСвойств(Результат,Выборка);	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПодчиненыеОбъекты(Группа)

Процедура УдалитьРегистрацию(ОбъектТип,ОбъектСсылкаУИД,ОтборРС_Хэш,ВариантВыгрузки) Экспорт	
	НЗ	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьНаборЗаписей();	
	
	НЗ.Отбор.ОбъектТип.Установить(ОбъектТип,Истина);
	НЗ.Отбор.ОбъектСсылкаУИД.Установить(ОбъектСсылкаУИД,Истина);
	НЗ.Отбор.ОтборРС_Хэш.Установить(ОтборРС_Хэш,Истина);
	НЗ.Отбор.ВариантВыгрузки.Установить(ВариантВыгрузки,Истина);
	
	ИспользоватьУправляемыеБлокировки=Ложь;
	Если ИспользоватьУправляемыеБлокировки Тогда
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.ФР_ОбъектыКВыгрузке");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		
		ЭлементБлокировки.УстановитьЗначение("ОбъектТип", 		ОбъектТип);
		ЭлементБлокировки.УстановитьЗначение("ОбъектСсылкаУИД", ОбъектСсылкаУИД);
		ЭлементБлокировки.УстановитьЗначение("ОтборРС_Хэш", 	ОтборРС_Хэш);
		ЭлементБлокировки.УстановитьЗначение("ВариантВыгрузки", ВариантВыгрузки);
		
		БлокировкаДанных.Заблокировать();	
	КонецЕсли;	
	
	НЗ.Записать();	
КонецПроцедуры

Функция ИзмененияЗарегистрированы(СсылкаНаОбъект,ОтборРС) Экспорт
	Результат	= Ложь;
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СсылкаНаОбъект
	|ИЗ
	|	РегистрСведений.ФР_ОбъектыКВыгрузке	
	|ГДЕ	
	|	СсылкаНаОбъект=&СсылкаНаОбъект
	|	И (ОтборРС=&ОтборРС ИЛИ &БезОтбораПоРС)
	|";
	
	МаксНомер	= 0;
	
	Запрос.УстановитьПараметр("СсылкаНаОбъект",	СсылкаНаОбъект);
	Запрос.УстановитьПараметр("ОтборРС",		ОтборРС);
	Запрос.УстановитьПараметр("БезОтбораПоРС",	НЕ ЗначениеЗаполнено(ОтборРС));	
	
	Выборка		= Запрос.Выполнить().Выбрать();	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.СсылкаНаОбъект) Тогда
		Результат=Истина;
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ИзмененияЗарегистрированы(УзелПолучатель,Ссылка) Экспорт

Функция СоздатьТаблицуОбъектов() Экспорт
	ТД	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьНаборЗаписей().ВыгрузитьКолонки("ОбъектТип,ВариантВыгрузки,Получатель,ДокОснование,ОтборРС,ОтборРС_Хэш,ИмяТаблицы");
	ТД.Колонки.Добавить("ОбъектСсылка",ФР_ОбщегоНазначения_С.Тип_ВсеСсылки());
	
	Возврат ТД;
КонецФункции //СоздатьТаблицуОбъектовКРегистрации()

Функция ЗарегистрироватьКМпоХКМ(ДокСсылка, ДопПараметры = Неопределено)	
	Результат		= Новый Структура("Ошибки,Сообщения",Новый Массив,Новый Массив);
			
	Запрос			= Новый Запрос;	
	Запрос.Текст	= "	
	|ВЫБРАТЬ 	
	|	ШтрихкодУпаковки 			КАК КМ_Ссылка,
	|	ШтрихкодУпаковки.ТипКода    КАК ТипКода
	|ПОМЕСТИТЬ ВТ_ШК
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок	
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|;
	|ВЫБРАТЬ
	|	КМ_Ссылка КАК ОбъектСсылка	
	|ИЗ
	|	ВТ_ШК
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	ШтрихКод
	|ИЗ	
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды
	|ГДЕ
	|	Ссылка В (ВЫБРАТЬ РАЗЛИЧНЫЕ КМ_Ссылка ИЗ ВТ_ШК ГДЕ ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка))
	|";	
		
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	ТО			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();	
	
	Выборка		= Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл		
		СтрокаТО	= ТО.Добавить();
		
		СтрокаТО.ОбъектСсылка		= Выборка.ОбъектСсылка;		
		СтрокаТО.ВариантВыгрузки	= "Элемент";
	КонецЦикла; 
			
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО, ДопПараметры);	
	
	Результат.Сообщения.Добавить(СтрШаблон("Выгружено: %1 кодов маркировки.",	Выборка.Количество()));	
	
	Возврат Результат;
КонецФункции //ЗарегистрироватьКМпоХКМ(МассивСсылок, ДопПараметры = Неопределено) Экспорт

Функция ЗарегистрироватьЦены(ДокСсылка) Экспорт
	ДанныеРегистрации	= НужноРегистрироватьОбъект(ДокСсылка);
	Если ДанныеРегистрации.Нужно Тогда		
		ТипЦен	= ПолучитьРеквизитШапки(ДокСсылка,"ТипЦен");
		
		НЗ			= РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
		НЗ.Отбор.Прайс.Установить(ДокСсылка,Истина);
		НЗ.Отбор.ТипЦен.Установить(ТипЦен,Истина);		
		
		ЗарегистрироватьОбъект(НЗ);
	КонецЕсли;	
	Возврат ДанныеРегистрации;
КонецФункции //ЗарегистрироватьЦены()
 
Функция ЗарегистрироватьСкидки(ДокСсылка) Экспорт
	ДанныеРегистрации	= НужноРегистрироватьОбъект(ДокСсылка);
	Если ДанныеРегистрации.Нужно Тогда	
		ТипСкидок	= ПолучитьРеквизитШапки(ДокСсылка,"ТипСкидок");
		
		НЗ			= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();
		НЗ.Отбор.Документ.Установить(ДокСсылка,Истина);
		НЗ.Отбор.ТипСкидок.Установить(ТипСкидок,Истина);
		
		ЗарегистрироватьОбъект(НЗ);
	КонецЕсли;
КонецФункции //ЗарегистрироватьСкидки()

Функция ПолучитьЗапросПоПНК(ДокСсылка)
	ОТ	= ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ЗначениеВСтрокуВнутр(ТипЗнч(ДокСсылка)));
	
	Запрос			= Новый Запрос;	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст	= "	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Номенклатура,
	|	Номенклатура.Родитель	КАК Модель,
	|	Номенклатура.Цвет 		КАК Цвет,
	|	Номенклатура.Размер 	КАК Размер
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ 
	|	"+ОТ.ПолноеИмя+".Товары
	|ГДЕ 			
	|	Ссылка=&ДокСсылка
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка",ДокСсылка);
	Запрос.Выполнить();
	
	Возврат Запрос;	
КонецФункции // ()
 

Функция Зарегистрировать_ШКиДекларацииПоПНК(ДокСсылка) Экспорт
	Запрос = ПолучитьЗапросПоПНК(ДокСсылка);	
	Запрос.Текст	= "
	|ВЫБРАТЬ 	
	|	История.Объект			КАК Объект,
	|	История.Реквизит		КАК Реквизит,
	|	История.Значение		КАК Значение,
	|	История.Документ		КАК Документ,
	|	ПоследниеПериоды.Период	КАК Период	
	|ИЗ
	|	РегистрСведений.История	КАК История
	|ПРАВОЕ СОЕДИНЕНИЕ	
	|(
	|ВЫБРАТЬ
	|	Объект 				КАК Номенклатура,
	|	Реквизит			КАК Реквизит,
	|	МАКСИМУМ(Период)	КАК Период
	|ИЗ
	|	РегистрСведений.История
	|ГДЕ 	
	|	Объект ССЫЛКА Справочник.Номенклатура
	|	И Реквизит = ""Декларация""
	|	И НЕ ВЫРАЗИТЬ(Объект КАК Справочник.Номенклатура).ВерсияДанных ЕСТЬ NULL
	|	И Объект В (ВЫБРАТЬ РАЗЛИЧНЫЕ Модель ИЗ ВТ_Номенклатура)
	|СГРУППИРОВАТЬ ПО
	|	Объект,
	|	Реквизит
	|) КАК ПоследниеПериоды
	|ПО
	|	История.Период = ПоследниеПериоды.Период
	|	И История.Объект ССЫЛКА Справочник.Номенклатура
	|	И История.Объект	= ПоследниеПериоды.Номенклатура
	|	И История.Реквизит	= ПоследниеПериоды.Реквизит	
	|УПОРЯДОЧИТЬ ПО Объект
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка",ДокСсылка);
	
	ТО			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Результат	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл		
		НЗ	= РегистрыСведений.История.СоздатьНаборЗаписей();
		
		НЗ.Отбор.Период.Установить(Выборка.Период,Истина);	
		НЗ.Отбор.Объект.Установить(Выборка.Объект,Истина);
		НЗ.Отбор.Реквизит.Установить(Выборка.Реквизит,Истина);
		НЗ.Отбор.Документ.Установить(Выборка.Документ,Истина);
		
		СтрокаТО	= ТО.Добавить();
		
		СтрокаТО.ОбъектСсылка		= Выборка.Объект;		
		СтрокаТО.ВариантВыгрузки	= "РегистрСведений.История";
		СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
		СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);	
		
		СтрокаТО	= ТО.Добавить();		
		СтрокаТО.ОбъектСсылка		= Выборка.Значение;		
	КонецЦикла; 
	
	Результат	= Новый Структура("КоличествоДеклараций,КоличествоШК",0,0);
	
	ЗарегистрироватьОбъекты(ТО);	
	
	Результат.КоличествоДеклараций	= ТО.Количество();
	
	Запрос.Текст="	
	|ВЫБРАТЬ
	|	Ссылка
  	|ИЗ
	|	Справочник.ШтрихКоды	
	|ГДЕ
	|	НЕ Наименование ПОДОБНО ""99999%""		
	|	И Владелец В (ВЫБРАТЬ РАЗЛИЧНЫЕ Номенклатура ИЗ ВТ_Номенклатура)	
	|УПОРЯДОЧИТЬ ПО 	
	|	Наименование
	|";
	
	Результат.КоличествоШК	= ЗарегистрироватьВыборку(Запрос,"Справочник.ШтрихКоды","Элемент");	
	
	Возврат Результат;
КонецФункции

Функция Зарегистрировать_НоменклатуруПоПНК(ДокСсылка) Экспорт
	Результат	= Новый Структура("КоличествоМоделей,КоличествоХарактеристик,КоличествоЦветов,КоличествоРазмеров",0,0,0,0);
	
	Запрос = ПолучитьЗапросПоПНК(ДокСсылка);	
	Запрос.УстановитьПараметр("ДокСсылка",ДокСсылка);
	
	Запрос.Текст	= "ВЫБРАТЬ РАЗЛИЧНЫЕ Модель КАК Ссылка ИЗ ВТ_Номенклатура УПОРЯДОЧИТЬ ПО Модель.Наименование";
	Результат.КоличествоМоделей	= ЗарегистрироватьВыборку(Запрос,"Справочник.Номенклатура","Элемент");	
			
	Запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ Номенклатура КАК Ссылка ИЗ ВТ_Номенклатура	УПОРЯДОЧИТЬ ПО Номенклатура.Наименование";	
	Результат.КоличествоХарактеристик	= ЗарегистрироватьВыборку(Запрос,"Справочник.Номенклатура","Справочник.ХарактеристикиНоменклатуры");
	
	Запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ Цвет КАК Ссылка ИЗ ВТ_Номенклатура	УПОРЯДОЧИТЬ ПО Цвет.Наименование ";	
	Результат.КоличествоЦветов	= ЗарегистрироватьВыборку(Запрос,"Справочник.Цвета","Элемент");
	
	Запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ Размер КАК Ссылка ИЗ ВТ_Номенклатура	УПОРЯДОЧИТЬ ПО Цвет.Наименование ";	
	Результат.КоличествоРазмеров	= ЗарегистрироватьВыборку(Запрос,"Справочник.Размеры","Элемент");
	
	Возврат Результат;
КонецФункции //Зарегистрировать_НоменклатуруПоПНК(ДокСсылка)

Функция ЗарегистрироватьВыборку(Запрос,ИмяОбъекта,ВариантВыгрузки="",ДопПараметры=Неопределено) Экспорт	
	Если ДопПараметры<>Неопределено Тогда
		Для Каждого Элемент Из ДопПараметры Цикл
			Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);		
		КонецЦикла; 	
	КонецЕсли; 
	
	ТО			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Результат	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	
	//Сообщить_("К регистрации по типу "+ИмяОбъекта+" найдено: "+Выборка.Количество()+" объектов.");
	Пропущено=0;
	
	Пока Выборка.Следующий() Цикл
		ОбработкаПрерыванияПользователя_(); 	
		
		Результат	= РегистрыСведений.ФР_ОбъектыКВыгрузке.НужноРегистрироватьОбъект(Выборка.Ссылка);
		Если Результат.Нужно Тогда			
			СтрокаТО	= ТО.Добавить();
			
			СтрокаТО.ОбъектСсылка		= Результат.ВыгружаемаяСсылка;		
			СтрокаТО.ВариантВыгрузки	= ?(ПустаяСтрока(ВариантВыгрузки), Результат.ВариантВыгрузки, ВариантВыгрузки);
			СтрокаТО.Получатель			= Результат.ПодразделениеПолучатель;			
			
			Если ИмяОбъекта="Документ.ПрайсЛист" Тогда
				НЗ			= РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
				НЗ.Отбор.Прайс.Установить(Выборка.Ссылка,Истина);
				НЗ.Отбор.ТипЦен.Установить(Выборка.ТипЦен,Истина);
				
				СтрокаТО	= ТО.Добавить();
				
				СтрокаТО.ОбъектСсылка		= Выборка.Ссылка;		
				СтрокаТО.ВариантВыгрузки	= "РегистрСведений.ЦеныНоменклатуры";
				СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
				СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);
			ИначеЕсли ИмяОбъекта="Документ.УстановкаСкидок" Тогда			
				НЗ			= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();
				НЗ.Отбор.Документ.Установить(Выборка.Ссылка,Истина);
				НЗ.Отбор.ТипСкидок.Установить(Выборка.ТипСкидок,Истина);
				
				СтрокаТО	= ТО.Добавить();
				
				СтрокаТО.ОбъектСсылка		= Выборка.Ссылка;		
				СтрокаТО.ВариантВыгрузки	= "РегистрСведений.СкидкиНоменклатуры";
				СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
				СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);
			КонецЕсли; 
		Иначе
			Пропущено=Пропущено+1;
		КонецЕсли;
		
		Если ТО.Количество()>=1000 Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);
			ТО.Очистить();		
		КонецЕсли; 	
		
		Сч=Сч+1;
		Если Сч%100=0 Тогда
			Состояние_("Регистрация "+ИмяОбъекта+": "+(ВсегоСтрок-Сч));		
		КонецЕсли;		
	КонецЦикла; 
	
	Если ТО.Количество()>0 Тогда
		РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);
	КонецЕсли; 
	
	//Сообщить_("	зарегистрировано: "+ТО.Количество()+", пропущено: "+Пропущено);
	
	Состояние_("");

	Возврат ТО.Количество();
КонецФункции

Функция Зарегистрировать_СвойстваНоменклатуры(МассивСсылок) Экспорт	
	Запрос			= Новый Запрос;	
	Запрос.Текст	= "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Объект КАК Ссылка
	|ИЗ 
	|	РегистрСведений.ЗначенияСвойствОбъектов 
	|ГДЕ 
	|	Объект В (&МассивСсылок) 
	|	И Свойство В (&Свойсво_Бренд,&Свойсво_ВидНоменклатуры)
	|";
	
	Запрос.УстановитьПараметр("МассивСсылок",			МассивСсылок);
	Запрос.УстановитьПараметр("Свойсво_Бренд",			ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Бренд (ФР)"));
	Запрос.УстановитьПараметр("Свойсво_ВидНоменклатуры",ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("Вид номенклатуры (ФР)"));
	
	ТО	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбработкаПрерыванияПользователя_();
		
		НЗ	= РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьНаборЗаписей();
		НЗ.Отбор.Объект.Установить(Выборка.Ссылка,Истина);
		
		СтрокаТО 				= ТО.Добавить();
		
		СтрокаТО.ОбъектСсылка	= Выборка.Ссылка;		
		СтрокаТО.ВариантВыгрузки= "РегистрСведений.ЗначенияСвойствОбъектов"; 		
		
		СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
		СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);	
	КонецЦикла; 
	
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);	
	Возврат ТО.Количество();
КонецФункции

