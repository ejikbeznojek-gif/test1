Функция ДобавитьОшибки(Результат1,Результат2)
	Для Каждого ТекстОшибки Из Результат2.Ошибки Цикл
		Результат1.Ошибки.Добавить(ТекстОшибки);	
	КонецЦикла;
КонецФункции //ДобавитьОшибки(Результат1,Результат2)

Функция ЗарегистрироватьОбъект(Знач СсылкаНаОбъект,	Отправитель=Неопределено, ДопПараментры=Неопределено) Экспорт	
	Результат			= Новый Структура("Результат,Ошибки",Ложь,Новый Массив);
	
	ТипОбъекта			= ТипЗнч(СсылкаНаОбъект);
	ДанныеРегистрации	= НужноРегистрироватьОбъект(СсылкаНаОбъект,ТипОбъекта,Отправитель);
	
	Если ДанныеРегистрации.Нужно =  Ложь Тогда
		ДобавитьОшибки(Результат,ДанныеРегистрации);
		Возврат Результат;	
	КонецЕсли; 
	
	//Функция СделатьЗаписьРегистрации(ОбъектСсылка,ВариантВыгрузки="",ОтборРС="",ПодразделениеПолучатель=Неопределено)
	ОтборРС					= "";
	ПодразделениеПолучатель	= Неопределено;
	
	Если ФР_ОбщегоНазначения_ПИ.ЭтоНаборЗаписейРС(ЗначениеВСтрокуВнутр(ТипОбъекта)) Тогда
		ОтборРС		= ЗначениеВСтрокуВнутр(СсылкаНаОбъект.Отбор);
	ИначеЕсли ТипОбъекта	= Тип("СправочникСсылка.Номенклатура") Тогда
		//+HELP-8160 20251211 Михайловский
		Род1 = СсылкаНаОбъект.Родитель;
		Род2 = СсылкаНаОбъект.Родитель.Родитель;
		Если  ЗначениеЗаполнено(Род1) Тогда
			ДанныеРегистрации1	= НужноРегистрироватьОбъект(Род1, ТипОбъекта, Отправитель);
			Р1 = СделатьЗаписьРегистрации(Род1, ДанныеРегистрации1.ВариантВыгрузки, ОтборРС, ПодразделениеПолучатель);
		КонецЕсли;
		Если  ЗначениеЗаполнено(Род2) Тогда
			ДанныеРегистрации2	= НужноРегистрироватьОбъект(Род2, ТипОбъекта, Отправитель);
			Р2 = СделатьЗаписьРегистрации(Род2, ДанныеРегистрации2.ВариантВыгрузки, ОтборРС, ПодразделениеПолучатель);
		КонецЕсли;
		//-HELP-8160 20251211 Михайловский	
	Иначе
		ПодразделениеПолучатель	= ДанныеРегистрации.ПодразделениеПолучатель;
	КонецЕсли;
	
	РезультатРегистрации	= СделатьЗаписьРегистрации(ДанныеРегистрации.ВыгружаемаяСсылка,ДанныеРегистрации.ВариантВыгрузки,ОтборРС,ПодразделениеПолучатель);		
	Если РезультатРегистрации.Результат Тогда
		Результат.Результат	= Истина;
	Иначе				
		ДобавитьОшибки(Результат,РезультатРегистрации);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗарегистрироватьОбъект(Знач СсылкаНаОбъект) Экспорт

Функция ДанныеПодразделенияДокумента(ДокСсылка,ПолноеИмяТипа=Неопределено)
	Результат	= Новый Структура("Подразделение,ВидПодразделения,ДатаПереходаНаНовуюВерсию,ДатаДокумента",Справочники.Подразделения.ПустаяСсылка(),Перечисления.ВидыПодразделений.ПустаяСсылка());
	Если ФР_ОбщегоНазначения_ПИ.ЕстьРеквизитДокумента_("Подразделение",ПолноеИмяТипа) Тогда		
		Поля	= ПолучитьРеквизитыШапки(ДокСсылка,"Дата,Подразделение,Подразделение.ВидПодразделения","Документ");
		
		Результат.Подразделение		= Поля.Подразделение;	
		Результат.ВидПодразделения	= Поля.Подразделение_ВидПодразделения;
		Результат.ДатаДокумента		= Поля.Дата;
		
	ИначеЕсли ФР_ОбщегоНазначения_ПИ.ЕстьРеквизитДокумента_("Склад",ПолноеИмяТипа) Тогда
		Поля 	= ПолучитьРеквизитыШапки(ДокСсылка,"Дата,Склад.Подразделение,Склад.Подразделение.ВидПодразделения","Документ");				
		
		Результат.Подразделение		= Поля.Склад_Подразделение;	
		Результат.ВидПодразделения	= Поля.Склад_Подразделение_ВидПодразделения;
		Результат.ДатаДокумента		= Поля.Дата;
	Иначе
		Поля						= ПолучитьРеквизитыШапки(ДокСсылка,"Дата");
		Результат.ДатаДокумента		= Поля.Дата;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()
 

Функция НужноРегистрироватьОбъект(Знач СсылкаНаОбъект, ТипОбъекта = Неопределено, Отправитель = Неопределено) Экспорт
	Результат	= Новый Структура("ВариантВыгрузки,ВыгружаемаяСсылка,ПодразделениеПолучатель,Нужно,Ошибки",
		"",СсылкаНаОбъект,Неопределено,Ложь,Новый Массив);	
		
	Если СсылкаНаОбъект=Неопределено Тогда 
		Результат.Ошибки.Добавить("Неопределенный объект !");
		Возврат Результат; 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отправитель) И ТипЗнч(Отправитель)=ТипЗнч(ПланыОбмена.ФР_ОбменСФРК.ПустаяСсылка()) Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	Если ТипОбъекта=Неопределено Тогда
		ТипОбъекта=ТипЗнч(СсылкаНаОбъект);	
	КонецЕсли;	
	
	ОТ	= ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ЗначениеВСтрокуВнутр(ТипОбъекта));	
	
	Если ОТ.КлассЕЧ="РегистрСведений" И ЗначениеЗаполнено(СсылкаНаОбъект.Отбор)  Тогда
	ИначеЕсли НЕ ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		Возврат Результат;		
	КонецЕсли;	
	
	ИмяПланаОбмена			= "ФР_ОбменСФРК";	
	
	Если ОТ.КлассЕЧ="Документ" Тогда	
		Если ТипОбъекта=Тип("ДокументСсылка.Заказ") Тогда
			текРезультат		= Это_ЗПК_На_ФР(СсылкаНаОбъект);			
			Если текРезультат.Результат Тогда
				Результат.ВариантВыгрузки			= "ЗПК_ЗПС";		
				
				Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
				Результат.Нужно						= Истина;
			Иначе
				Результат.Ошибки.Добавить("Это не ЗПК на ФР.");
			КонецЕсли;			
		ИначеЕсли ТипОбъекта=Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			текРезультат		= Это_РНК_На_ФР(СсылкаНаОбъект);
			Если текРезультат.Результат Тогда
				Результат.ВариантВыгрузки			= "РНК_ПНК";		
				
				Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
				
				НакладнаяГОилиО	 = НакладнаяГотоваКОтгрузкеИлиОтгружена(СсылкаНаОбъект);
				
				Если НакладнаяГОилиО Тогда
					Результат.Нужно	= Истина;				
				КонецЕсли;				
			Иначе
				Результат.Ошибки.Добавить("Это не РНК на ФР.");
			КонецЕсли;			
		ИначеЕсли ТипОбъекта=Тип("ДокументСсылка.Перемещение") Тогда
			НакладнаяГОилиО	 = НакладнаяГотоваКОтгрузкеИлиОтгружена(СсылкаНаОбъект);
			
			//Грузим РНК
			Если НакладнаяГОилиО Тогда
				текРезультат	= Это_ПРМ_ПНК_На_ФР(СсылкаНаОбъект);
				Если текРезультат.Результат Тогда
					Результат.ВариантВыгрузки			= "ПРМ_ПНК";
					Результат.Нужно			  			= Истина;
					Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;	
				Иначе
					текРезультат	= Это_ПРМ_РНК_С_ФР(СсылкаНаОбъект);
					Если текРезультат.Результат Тогда
						Результат.ВариантВыгрузки			= "ПРМ_РНК";
						Результат.Нужно			  			= Истина;				
						Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
					Иначе
						текРезультат	= Это_ПРМ_ПРМ_На_ФР(СсылкаНаОбъект);
						Если текРезультат.Результат Тогда
							Результат.ВариантВыгрузки			= "ПРМ_ПРМ";
							Результат.Нужно			  			= Истина;				
							
							Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
						Иначе
							текРезультат	= Это_ПРМ_ПРМ_С_ФР(СсылкаНаОбъект);
							//+HELP-1380 20241015 Михайловский
							Если текРезультат.Результат Тогда
							//-HELP-1380 20241015 Михайловский
								Результат.ВариантВыгрузки			= "ПРМ_ПРМ";
								Результат.Нужно			  			= Истина;				
								Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
							//+HELP-1380 20241015 Михайловский
							КонецЕсли;
							//-HELP-1380 20241015 Михайловский							
						КонецЕсли;					
					КонецЕсли;				
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипОбъекта=Тип("ДокументСсылка.РекламационнаяНакладная") Тогда
			текРезультат		= Это_РКМ_На_ФР(СсылкаНаОбъект);
			Если текРезультат.Результат Тогда
				Если ЗначениеЗаполнено(текРезультат.ДокОснование) 
					И ТипЗнч(текРезультат.ДокОснование) = Тип("ДокументСсылка.Перемещение")
					И текРезультат.ВидРекламации = Перечисления.ВидыРекламаций.Рекламация Тогда
					//Это какой то трешовый мусор (но очень нужный для работы) - его типа выгружать не надо
					Результат.Нужно	= Ложь;
				Иначе
					Результат.ВариантВыгрузки			= "РКМ_КП";		
				
					Результат.ПодразделениеПолучатель	= текРезультат.ПодразделениеПолучатель;
				
					//Результат.Нужно	= текРезультат.Проведен;
					//Малахов 10.01.24 иначе не выгружается пометка удаления
					Результат.Нужно=Истина;
					//Малахов 10.01.24
				КонецЕсли;				
			Иначе
				Результат.Ошибки.Добавить("Это не РНК на ФР.");
			КонецЕсли;			
		ИначеЕсли ТипОбъекта=Тип("ДокументСсылка.ЭмиссияПодарочныхСертификатов") Тогда
			РеквизитыШ = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"КодОперации,Подразделение","Документ");
			Если 
				РеквизитыШ.КодОперации = Перечисления.КодыОперацийПС.Деактивация
				ИЛИ РеквизитыШ.КодОперации = Перечисления.КодыОперацийПС.Дарение Тогда
				
				Результат.ВариантВыгрузки			= "ЭПС_СПН";
				Результат.Нужно			  			= Истина;				
						
				Результат.ПодразделениеПолучатель	= РеквизитыШ.Подразделение;				
			КонецЕсли;			
		ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ЗаявкаНаРекламацию") Тогда
			РеквизитыШ = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"Отработано","Документ");
			Если РеквизитыШ.Отработано Тогда
				Результат.Нужно = Истина;
			КонецЕсли;
		ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
			Результат = НужноРегистрироватьХКМ_ДляФР(СсылкаНаОбъект);
		//+HELP-2306 20250220 Михайловский	
		ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ЗаявкаНаПостСторонАссорт") Тогда
			Результат = НужноРегистрироватьПСАЗ(СсылкаНаОбъект);	
		//-HELP-2306 20250220 Михайловский
		Иначе
			ДанныеПодразделения		= ДанныеПодразделенияДокумента(СсылкаНаОбъект,ОТ.ПолноеИмя);
			Результат.ПодразделениеПолучатель	= ДанныеПодразделения.Подразделение;			
			
			Если ДанныеПодразделения.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
				ИЛИ ДанныеПодразделения.ВидПодразделения=Перечисления.ВидыПодразделений.Торговое Тогда
				Если ФР_ОбщегоНазначения_ПИ.ОбъектХодитСверхуВниз(ИмяПланаОбмена,ОТ.ПолноеИмя) Тогда
					Результат.Нужно	= Истина;
				ИначеЕсли ФР_ОбщегоНазначения_ПИ.ОбъектХодитТудаСюда(ИмяПланаОбмена,ОТ.ПолноеИмя) Тогда
					Результат.Нужно	= НЕ ЗначениеЗаполнено(Отправитель);					
				ИначеЕсли ФР_ОбщегоНазначения_ПИ.ОбъектХодитСверхуВнизДляСтарыхУзлов(ИмяПланаОбмена,ОТ.ПолноеИмя) Тогда
					Результат.Нужно = Ложь; //Чирков 13.09.2024 - все - нет больше старых узлов
					//ДатаПерехода	= ПолучитьРеквизитСправочникаИзРегистра(Результат.ПодразделениеПолучатель,"ДатаПереходаНаНовуюВерсию");					
					//Если НЕ ЗначениеЗаполнено(ДатаПерехода) Тогда					
					//	Результат.Нужно	= Истина						
					//Иначе
					//	Результат.Нужно	= (ДанныеПодразделения.ДатаДокумента<НачалоДня(ДатаПерехода));
					//КонецЕсли;
					//Если НЕ Результат.Нужно Тогда
					//	Результат.Ошибки.Добавить("Объект не ходит сверху вниз после перехода на новую версию.");					
					//КонецЕсли;					
				КонецЕсли;
			ИначеЕсли НЕ ЗначениеЗаполнено(ДанныеПодразделения.Подразделение) Тогда
				Если ФР_ОбщегоНазначения_ПИ.ОбъектХодитСверхуВниз(ИмяПланаОбмена,ОТ.ПолноеИмя) Тогда
					Если ТипОбъекта = Тип("ДокументСсылка.ПрайсЛист") Тогда
						РеквизитыШ = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"ТипЦен.Закупочный_ФР,ТипЦен.Розничный","Документ");																		
						Если РеквизитыШ.ТипЦен_Закупочный_ФР = Истина 
							ИЛИ РеквизитыШ.ТипЦен_Розничный = Истина Тогда						
							Результат.Нужно	= Истина;						
						КонецЕсли; 
					Иначе
						Результат.Нужно	= Истина;
					КонецЕсли; 					
				Иначе
					Результат.Ошибки.Добавить("Объект не ходит сверху вниз.");					
				КонецЕсли;				
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ОТ.КлассЕЧ="Справочник" Тогда		
		Если ЗначениеЗаполнено(Отправитель) И ТипЗнч(Отправитель)=Тип("ПланОбменаСсылка.ФР_ОбменСФРК") Тогда
			Возврат Результат;
		КонецЕсли;
		
		Если ОТ.Вид	="Номенклатура" Тогда
			Реквизиты = ПолучитьРеквизитыШапки(СсылкаНаОбъект,"ЭтоГруппа,Родитель");
			
			Если Реквизиты.ЭтоГруппа = Null  ИЛИ Реквизиты.ЭтоГруппа = Неопределено Тогда
				Результат.Нужно	= Ложь;
				Возврат Результат;			
			КонецЕсли; 
			
			Если Реквизиты.ЭтоГруппа Тогда
				Результат.ВариантВыгрузки	= ВариантВыгрузкиГруппаНоменклатуры(СсылкаНаОбъект);
				Если Результат.ВариантВыгрузки<>-1 Тогда				
					Результат.Нужно				= Истина;
				КонецЕсли;				
			Иначе				
				Если НЕ ЭтоМодель(Реквизиты.Родитель) Тогда
					ЗарегистрироватьОбъект(Реквизиты.Родитель);
				КонецЕсли;
				Результат.ВариантВыгрузки	= "Справочник.ХарактеристикиНоменклатуры"; //Характеристика					
				Результат.Нужно				= Истина;				
			КонецЕсли;
		ИначеЕсли ОТ.Вид = "Пользователи" Тогда
			Подразделение	= ПодразделениеСправочника(СсылкаНаОбъект);			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				времРеквизиты	= ПолучитьРеквизитыШапки(Подразделение,"ЭтоГруппа,Код,ВидПодразделения","Справочник");
				Если НЕ ВремРеквизиты.ЭтоГруппа
					И (ВремРеквизиты.Код="SSP-0001" 
						ИЛИ времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
						ИЛИ времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Торговое
						) Тогда
					Результат.ВариантВыгрузки			= "Элемент";
					Результат.ПодразделениеПолучатель   = Подразделение;
					Результат.Нужно						= Истина;
				КонецЕсли;
			КонецЕсли; 
		ИначеЕсли ОТ.Вид = "Склады" Тогда
			Подразделение	= ПодразделениеСправочника(СсылкаНаОбъект);			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				времРеквизиты	= ПолучитьРеквизитыШапки(Подразделение,"ЭтоГруппа,Код,ВидПодразделения","Справочник");
				Если НЕ ВремРеквизиты.ЭтоГруппа				
					// Кухарь А.Ю.  18.10.2023 начало
					// И времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
					И (времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг 
					или времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Торговое) 
					Тогда					 
					// Кухарь А.Ю.  18.10.2023 конец
					
					Результат.ВариантВыгрузки			= "Элемент";
					Результат.ПодразделениеПолучатель   = Подразделение;
					Результат.Нужно						= Истина;
				КонецЕсли;
			КонецЕсли;	
		ИначеЕсли ОТ.Вид = "Договоры" Тогда
			Подразделение	= ПодразделениеСправочника(СсылкаНаОбъект);			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				времРеквизиты	= ПолучитьРеквизитыШапки(Подразделение,"ЭтоГруппа,Код,ВидПодразделения","Справочник");
				Если НЕ ВремРеквизиты.ЭтоГруппа И 
					(
						времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
						ИЛИ времРеквизиты.ВидПодразделения=Перечисления.ВидыПодразделений.Торговое
					)	
					Тогда
					Результат.ВариантВыгрузки			= "Элемент";
					Результат.ПодразделениеПолучатель   = Подразделение;
					Результат.Нужно						= Истина;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ОТ.Вид = "Контрагенты"  Тогда
			ЭтоГруппа	= ПолучитьРеквизитШапки(СсылкаНаОбъект,"ЭтоГруппа","Справочник");
			Если ЭтоГруппа Тогда
				Результат.Нужно = Ложь;
			Иначе
				Если ФранчПодразделенияКонтрагента(СсылкаНаОбъект).Количество()>0 Тогда
					Результат.Нужно = Истина;									
					Результат.ВариантВыгрузки = "Документ.ЦеныПоставщика";
				КонецЕсли; 
			КонецЕсли; 
		ИначеЕсли ОТ.Вид = "ФизическиеЛица"  Тогда			
			рПроверки = НужноВыгружатьФЛ(СсылкаНаОбъект);
			Если рПроверки.Нужно Тогда 				
				Результат.Нужно 					= Истина;
				Результат.ВариантВыгрузки 			= "Элемент";
				Результат.ПодразделениеПолучатель   = рПроверки.ПодразделениеПолучатель;
			КонецЕсли;
		ИначеЕсли ОТ.Вид = "Договоры"  Тогда			
			рШапки	= ПолучитьРеквизитыШапки(СсылкаНаОбъект, "Владелец", "Справочник");
			Если ТипЗнч(рШапки.Владелец) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
				рПроверки = НужноВыгружатьФЛ(рШапки.Владелец);
				Если рПроверки.Нужно Тогда
					Результат.Нужно 					= Истина;
					Результат.ВариантВыгрузки 			= "Элемент";
					Результат.ПодразделениеПолучатель   = рПроверки.Подразделение;				
				КонецЕсли;
			КонецЕсли;	
		Иначе				
			ЭтоГруппа	= Ложь;
			Если ОТ.ИмеетГруппы Тогда
				ЭтоГруппа	= ПолучитьРеквизитШапки(СсылкаНаОбъект,"ЭтоГруппа","Справочник");					
			КонецЕсли;
			
			Результат.Нужно 	= Истина;
			Если ОТ.Вид="ТипыЦен" ИЛИ ОТ.Вид="ТипыСкидок" Тогда				
				Если ОТ.Вид="ТипыЦен" Тогда
					Результат.Нужно = ПолучитьРеквизитШапки(СсылкаНаОбъект,"Закупочный_ФР","Справочник");
				Иначе
					Результат.Нужно = Ложь;					
				КонецЕсли;
			Иначе
				//Результат.Ошибки.Добавить("Тип цен или тип скидок не являются розничными.");
			КонецЕсли; 
			
			Если Результат.Нужно = Истина Тогда
				Результат.ВариантВыгрузки	= ?(ЭтоГруппа,"Группа","Элемент");			
			КонецЕсли;
		КонецЕсли;
		
		
	ИначеЕсли ОТ.КлассЕЧ="ПланВидовХарактеристик" Тогда
		//Вручную - там один мусор
		//Нужно 		= Ложь;		
		
		ИменаРеквизитов	= "Наименование";
		Если ОТ.ИмеетГруппы Тогда			
			ИменаРеквизитов	= ИменаРеквизитов	+",ЭтоГруппа";
		КонецЕсли;		
		Реквизиты	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,ИменаРеквизитов,"ПланВидовХарактеристик");
		ЭтоГруппа	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(Реквизиты,"ЭтоГруппа",Ложь);
		
		Результат.ВариантВыгрузки	= ?(ЭтоГруппа,"Группа","Элемент");
		Если СтрНайти(Реквизиты.Наименование,"(ФР)")>0 Тогда
			Результат.Нужно	= Истина;
		Иначе
			Результат.Ошибки.Добавить("С этим мусосром непонятно что делать, пока грузится.");		
		КонецЕсли;		
	ИначеЕсли ОТ.КлассЕЧ="РегистрСведений" Тогда
		Результат.ВыгружаемаяСсылка	= ПолучитьСсылкуИзНЗ(СсылкаНаОбъект,ТипОбъекта);		
		Результат.ВариантВыгрузки	= ОТ.ПолноеИмя;
		Если ТипЗнч(Результат.ВыгружаемаяСсылка)=Тип("ДокументСсылка.ПрайсЛист") Тогда
			Розничный		= ПолучитьРеквизитШапки(Результат.ВыгружаемаяСсылка,"ТипЦен.Розничный","Документ");
			Если Розничный=Истина Тогда
				Результат.Нужно = Истина;
			Иначе				
				Результат.Ошибки.Добавить("Тип цен не является розничными.");			
			КонецЕсли;			
		ИначеЕсли ТипЗнч(Результат.ВыгружаемаяСсылка)=Тип("ДокументСсылка.УстановкаСкидок") Тогда			
			Розничный	= ПолучитьРеквизитШапки(Результат.ВыгружаемаяСсылка,"ТипСкидок.Розничный","Документ");
			Если Розничный=Истина Тогда
				Результат.Нужно = Истина;
			Иначе				
				Результат.Ошибки.Добавить("Тип скидок не является розничными.");			
			КонецЕсли;			
		ИначеЕсли ТипЗнч(СсылкаНаОбъект)=Тип("РегистрСведенийНаборЗаписей.РеквизитыСправочников") Тогда
			ТипВыгрСсылки=ТипЗнч(Результат.ВыгружаемаяСсылка);
			Если 				
				ТипВыгрСсылки=Тип("СправочникСсылка.ВнешниеОтчеты")
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.Договоры")
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.Пользователи")
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.ПунктыДоставки")
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.Контрагенты")
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.Номенклатура") 
				//+Служеб. 20241122 Михайловский ветка непонятная пока оставлю с добав.
				//эти лезут напрасно
				ИЛИ ТипВыгрСсылки=Тип("СправочникСсылка.ИнетМагазины")
				//-Служеб. 20241122 Михайловский ветка непонятная пока оставлю с добав.
				Тогда
				//Это не выгружается
			Иначе
				Результат.Нужно=Истина;
			КонецЕсли;
		ИначеЕсли ТипЗнч(СсылкаНаОбъект)=Тип("РегистрСведенийНаборЗаписей.История") Тогда
			Если СсылкаНаОбъект.Отбор.Реквизит.Значение="Декларация" Тогда
				Результат.Нужно=Истина;							
			КонецЕсли; 						
		ИначеЕсли ТипЗнч(СсылкаНаОбъект)=Тип("РегистрСведенийНаборЗаписей.КоличествоПосетителей") Тогда			
			Результат.Нужно=Истина;
		ИначеЕсли ТипЗнч(СсылкаНаОбъект)=Тип("РегистрСведенийНаборЗаписей.ЗначенияСвойствОбъектов") Тогда
			Если ТипЗнч(СсылкаНаОбъект.Отбор.Объект.Значение)=Тип("СправочникСсылка.Номенклатура") Тогда				
				Результат.Нужно=Истина;							
			КонецЕсли;
		ИначеЕсли ТипЗнч(СсылкаНаОбъект)=Тип("РегистрСведенийНаборЗаписей.КурсыВалют") Тогда
			Результат.Нужно=Истина;
		Иначе			
			Результат.Ошибки.Добавить("Объект типа: "+ОТ.ПолноеИмя+"не выгружается.");			
		КонецЕсли; 
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НужноРегистрироватьОбъект(Знач СсылкаНаОбъект,ТипОбъекта=Неопределено) Экспорт

Функция НужноВыгружатьФЛ(ФЛ_Ссылка)
	Результат = Новый Структура("Нужно,ПодразделениеПолучатель", Ложь);
	рШапки	= ПолучитьРеквизитыШапки(ФЛ_Ссылка, 
		"ЭтоГруппа,Подразделение,Подразделение.КонтрагентФР,Подразделение.Закрыто,Подразделение.ВидПодразделения",
		"Справочник"
	);
	Если 
		рШапки.ЭтоГруппа = Ложь
		И рШапки.Подразделение_ВидПодразделения = Перечисления.ВидыПодразделений.Торговое
		И рШапки.Подразделение_Закрыто = Ложь
		И НЕ ЗначениеЗаполнено(рШапки.Подразделение_КонтрагентФР) Тогда
		
		Результат.Нужно 					= Истина;		
		Результат.ПодразделениеПолучатель   = рШапки.Подразделение;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()


Функция НакладнаяГотоваКОтгрузкеИлиОтгружена(НакладнаяСсылка)
	Результат = Ложь;
	РеквизитыШ	= ПолучитьРеквизитыШапки(НакладнаяСсылка,"СостояниеНакладной,Проведен");
	Если РеквизитыШ.Проведен И 
		(РеквизитыШ.СостояниеНакладной=Перечисления.СостоянияНакладной.ГотоваКОтгрузке ИЛИ РеквизитыШ.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена) Тогда
		Результат = Истина;				
	КонецЕсли;	
	Возврат Результат;
КонецФункции //НакладнаяГотоваКОтгрузкеИлиОтгружена(НакладнаяСсылка)

Функция ФранчПодразделенияКонтрагента(Контрагент)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка
	|ИЗ
	|	Справочник.Подразделения
	|ГДЕ
	|	ВидПодразделения = ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|	И КонтрагентФР = &Контрагент
	|	И НЕ ПометкаУдаления
	|";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции // ()
 

Функция ПолучитьРеквизитИзРегистра(Ссылка,ИмяРеквизита) Экспорт
	Запрос	= Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ ПЕРВЫЕ 1 РАЗРЕШЕННЫЕ
	|	ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников	
	|ГДЕ
	|	Справочник 		= &Ссылка
	|	И ИмяРеквизита	= """+ИмяРеквизита+"""	
	|";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ЗначениеРеквизита) Тогда
		Результат	= Выборка.ЗначениеРеквизита;
	Иначе
		Результат	= Неопределено;		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьРеквизитИзРегистра(Ссылка,ИмяРеквизита) 

Функция ПодразделениеСправочника(Ссылка)
	Если ЕстьРеквизитДокумента("Подразделение",Метаданные.НайтиПоТипу(ТипЗнч(Ссылка))) Тогда
		Результат	= ПолучитьРеквизитШапки(Ссылка,"Подразделение","Справочник");				
	Иначе
		Результат	= ПолучитьРеквизитИзРегистра(Ссылка,"Подразделение");				
	КонецЕсли;	
	
	ОТ	= Новый ОписаниеТипов("СправочникСсылка.Подразделения");
	
	Возврат ОТ.ПривестиЗначение(Результат);	
КонецФункции //ПодразделениеСправочника(Ссылка)

Функция Это_ЗПК_На_ФР(СсылкаНаОбъект)
	
	РеквизитыШ	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"Подразделение,Подразделение.ВидПодразделения","Документ");
	
	Результат	= (РеквизитыШ.Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг);
	
	Возврат Новый Структура("Результат,ПодразделениеПолучатель",Результат,РеквизитыШ.Подразделение);	
	
КонецФункции //Это_ЗПК_На_ФР(СсылкаНаОбъект)

Функция Это_РКМ_На_ФР(СсылкаНаОбъект)
	Результат  = Ложь;
	
	Запрос	= Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ		
	|	Истина КАК Результат,
	|	Ссылка,
	|	ВидРекламации,
	|	ДокОснование,
	|	Проведен,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ПодразделениеПолучатель
	|ИЗ
	|	Документ.РекламационнаяНакладная КАК Док_РКМ
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ПО
	|	Док_РКМ.ПунктДоставки	= РеквизитыСправочников.Справочник
	|	И РеквизитыСправочников.ИмяРеквизита=""ПодразделениеФранчайзинга""
	|ГДЕ
	|	Ссылка = &СсылкаНаОбъект
	|	И ВЫРАЗИТЬ(РеквизитыСправочников.ЗначениеРеквизита КАК Справочник.Подразделения).ВидПодразделения=ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|";
	
	
	
	ПодразделениеПолучатель	= Неопределено;
	
	Результат = Новый Структура("Результат,ПодразделениеПолучатель,ВидРекламации,ДокОснование,Проведен",Ложь);
	
	Запрос.УстановитьПараметр("СсылкаНаОбъект",СсылкаНаОбъект);
	Выборка	= Запрос.Выполнить().Выбрать();	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //Это_РКМ_На_ФР(СсылкаНаОбъект)

Функция Это_РНК_На_ФР(СсылкаНаОбъект)
	Результат  = Ложь;
	
	Запрос	= Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ		
	|	Ссылка,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ПодразделениеПолучатель
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Док_РНК
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ПО
	|	Док_РНК.ПунктДоставки	= РеквизитыСправочников.Справочник
	|	И РеквизитыСправочников.ИмяРеквизита=""ПодразделениеФранчайзинга""
	|ГДЕ
	|	Ссылка = &СсылкаНаОбъект
	|	И ВЫРАЗИТЬ(РеквизитыСправочников.ЗначениеРеквизита КАК Справочник.Подразделения).ВидПодразделения=ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|";
	
	ПодразделениеПолучатель	= Неопределено;
	
	Запрос.УстановитьПараметр("СсылкаНаОбъект",СсылкаНаОбъект);
	Выборка=Запрос.Выполнить().Выбрать();	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат  				= Истина;	
		ПодразделениеПолучатель = Выборка.ПодразделениеПолучатель;
	КонецЕсли;
	
	Возврат Новый Структура("Результат,ПодразделениеПолучатель",Результат,ПодразделениеПолучатель);
КонецФункции //Это_РНК_На_ФР(СсылкаНаОбъект)

Функция Это_ПРМ_ПНК_На_ФР(СсылкаНаОбъект) Экспорт
	Результат	= Новый Структура("Результат,ПодразделениеПолучатель",Ложь,Справочники.Подразделения.ПустаяСсылка());
	РеквизитыШапки	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"
		|ДокОснование,
		|СкладПолучатель.Организация,
		|СкладПолучатель.Подразделение,
		|СкладПолучатель.Подразделение.ВидПодразделения,
		|Склад.Организация,
		|Склад.Подразделение.ВидПодразделения","Документ");
	Если 
		РеквизитыШапки.СкладПолучатель_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
		И ТипЗнч(РеквизитыШапки.ДокОснование)<>Тип("ДокументСсылка.РасходнаяНакладная")
		И (
			РеквизитыШапки.Склад_Подразделение_ВидПодразделения<>Перечисления.ВидыПодразделений.Франчайзинг
			ИЛИ РеквизитыШапки.Склад_Организация<>РеквизитыШапки.СкладПолучатель_Организация 
		)	
		Тогда
		
		Результат.Результат					= Истина;			
		Результат.ПодразделениеПолучатель   = РеквизитыШапки.СкладПолучатель_Подразделение;
		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //Это_ПРМ_ПНК_На_ФР(СсылкаНаОбъект)

Функция Это_ПРМ_ПРМ_На_ФР(СсылкаНаОбъект) Экспорт
	Результат	= Новый Структура("Результат,ПодразделениеПолучатель",Ложь,Справочники.Подразделения.ПустаяСсылка());
	РеквизитыШапки	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"
		|ДокОснование,
		|СкладПолучатель.Организация,
		|СкладПолучатель.Подразделение,
		|СкладПолучатель.Подразделение.ВидПодразделения,
		|Склад.Организация,
		|Склад.Подразделение.ВидПодразделения","Документ");
	Если 
		РеквизитыШапки.Склад_Организация=РеквизитыШапки.СкладПолучатель_Организация 
		И (						
			РеквизитыШапки.СкладПолучатель_Подразделение_ВидПодразделения	= Перечисления.ВидыПодразделений.Торговое		 
			ИЛИ (
				РеквизитыШапки.Склад_Подразделение_ВидПодразделения				= Перечисления.ВидыПодразделений.Франчайзинг
				И РеквизитыШапки.СкладПолучатель_Подразделение_ВидПодразделения	= Перечисления.ВидыПодразделений.Франчайзинг
				И ТипЗнч(РеквизитыШапки.ДокОснование)<>Тип("ДокументСсылка.РасходнаяНакладная")
			)
		) Тогда
		
		Результат.Результат					= Истина;			
		Результат.ПодразделениеПолучатель   = РеквизитыШапки.СкладПолучатель_Подразделение;
		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //Это_ПРМ_ПРМ_На_ФР(СсылкаНаОбъект)

Функция Это_ПРМ_ПРМ_С_ФР(СсылкаНаОбъект) Экспорт
	Результат	= Новый Структура("Результат,ПодразделениеПолучатель",Ложь,Справочники.Подразделения.ПустаяСсылка());
	РеквизитыШапки	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"
		|ДокОснование,
		|СкладПолучатель.Организация,
		|СкладПолучатель.Подразделение,
		|СкладПолучатель.Подразделение.ВидПодразделения,
		|Склад.Организация,
		|Склад.Подразделение.ВидПодразделения","Документ");
	Если 
		РеквизитыШапки.Склад_Организация=РеквизитыШапки.СкладПолучатель_Организация 
		И (		
			РеквизитыШапки.Склад_Подразделение_ВидПодразделения	= Перечисления.ВидыПодразделений.Торговое
			ИЛИ (
				РеквизитыШапки.Склад_Подразделение_ВидПодразделения				= Перечисления.ВидыПодразделений.Франчайзинг
				И РеквизитыШапки.СкладПолучатель_Подразделение_ВидПодразделения	= Перечисления.ВидыПодразделений.ПустаяСсылка() //Возврат на склад
				И ТипЗнч(РеквизитыШапки.ДокОснование)<>Тип("ДокументСсылка.РасходнаяНакладная")
			)
		) Тогда
		
		Результат.Результат					= Истина;			
		Результат.ПодразделениеПолучатель   = РеквизитыШапки.СкладПолучатель_Подразделение;
		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //Это_ПРМ_ПРМ_С_ФР(СсылкаНаОбъект)


Функция Это_ПРМ_РНК_С_ФР(СсылкаНаОбъект) Экспорт
	Результат	= Новый Структура("Результат,ПодразделениеПолучатель",Ложь,Справочники.Подразделения.ПустаяСсылка());
	РеквизитыШ	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"
		|ДокОснование,
		|Склад.Подразделение,
		|Склад.Организация,
		|Склад.Подразделение.ВидПодразделения,
		|СкладПолучатель.Организация,
		|СкладПолучатель.Подразделение,
		|СкладПолучатель.Подразделение.ВидПодразделения","Документ");
	
	Если РеквизитыШ.Склад_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
		И РеквизитыШ.СкладПолучатель_Подразделение_ВидПодразделения<>Перечисления.ВидыПодразделений.Франчайзинг
		Тогда
		
		Результат.Результат					= Истина;			
		Результат.ПодразделениеПолучатель   = РеквизитыШ.Склад_Подразделение;
	ИначеЕсли РеквизитыШ.Склад_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг
		И РеквизитыШ.СкладПолучатель_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
		Если РеквизитыШ.Склад_Организация<>РеквизитыШ.СкладПолучатель_Организация Тогда
			Результат.Результат					= Истина;			
			Результат.ПодразделениеПолучатель   = РеквизитыШ.Склад_Подразделение;					
		КонецЕсли; 		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //Это_ПРМ_РНК_С_ФР(СсылкаНаОбъект)

Функция Это_ПНК_ВЗВ_На_ФР(СсылкаНаОбъект) Экспорт
	Результат	= Новый Структура("Результат,ПодразделениеПолучатель",Ложь,Справочники.Подразделения.ПустаяСсылка());
