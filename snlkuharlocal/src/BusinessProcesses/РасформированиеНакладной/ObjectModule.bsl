
Процедура СогласованоЦОПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗадачиПользователя.Согласовано КАК Согласовано
	|ИЗ
	|	Задача.ЗадачиПользователя КАК ЗадачиПользователя
	|ГДЕ
	|	ЗадачиПользователя.БизнесПроцесс = &БизнесПроцесс
	|	И ЗадачиПользователя.ТочкаМаршрута = &ТочкаМаршрута";
	
	Запрос.УстановитьПараметр("БизнесПроцесс", ЭтотОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТочкаМаршрута", БизнесПроцессы.РасформированиеНакладной.ТочкиМаршрута.СогласоватьЦО);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	Результат = ВыборкаДетальныеЗаписи.Согласовано;
	Если Результат Тогда
	   СформироватьУведомление("Уведомление о утверждении расформирования РНК в ЦО");
	Иначе	
		СформироватьУведомление("Уведомление о отклонении расформирования РНК");
		РНКОбъект = ОбъектСогласования.ПолучитьОбъект();
		РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Отклонена;
		РНКОбъект.Записать(РежимЗаписиДокумента.Проведение);

	КонецЕсли;
	
КонецПроцедуры

Процедура СогласоватьЦОПередСозданиемЗадач(ТочкаМаршрутаБизнесПроцесса, ФормируемыеЗадачи, СтандартнаяОбработка)
