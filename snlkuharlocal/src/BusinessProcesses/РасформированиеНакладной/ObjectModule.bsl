		УникальныеЛистыЗагрузки = тзЗаявкаНаОтгрузкуСтроки.Скопировать(,"ЗаявкаНаОтгрузку");
		УникальныеЛистыЗагрузки.Свернуть("ЗаявкаНаОтгрузку");
		Для каждого ЗаявкаНаОтгрузку Из УникальныеЛистыЗагрузки Цикл
			ЗаявкаНаОтгрузкуОбъект = ЗаявкаНаОтгрузку.ЗаявкаНаОтгрузку.ПолучитьОбъект();
			ЗаявкаНаОтгрузкуОбъект.Заблокировать();
			ПараметрыОтбора = Новый Структура("ЗаявкаНаОтгрузку",ЗаявкаНаОтгрузку.ЗаявкаНаОтгрузку);
			МассивИзменяемыхСтрок = Новый Массив;
			МассивСтрок = тзЗаявкаНаОтгрузкуСтроки.НайтиСтроки(ПараметрыОтбора);
			Для Каждого мСтрока Из МассивСтрок Цикл
				МассивИзменяемыхСтрок.Добавить(ЗаявкаНаОтгрузкуОбъект.Накладные.Получить(мСтрока.НомерСтроки - 1));
			КонецЦикла;
			Для каждого ИзменяемаяСтрока Из МассивИзменяемыхСтрок Цикл
				ИзменяемаяСтрока.НеОтгружать = Истина;
			КонецЦикла;
			ЗаявкаНаОтгрузкуОбъект.Записать();
		КонецЦикла;
		
		РНКОбъект = ОбъектСогласования.ПолучитьОбъект();
		РНКОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.Отменена;
		РНКОбъект.Отгружен = Перечисления.Отгружен.Отменен;
		РНКОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		// Заполнение шапки
		Дата= ТекущаяДата();
		ОбъектСогласования = ДанныеЗаполнения.Ссылка;     
		Инициатор = ПараметрыСеанса.Пользователь;
		СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.НаСогласовании;
		ДатаСтарта = Дата;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаявкаСогласованаПриЗавершении(ТочкаМаршрутаБизнесПроцесса, Отказ)
	ЭтотОбъект.СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.Согласован;
	ЭтотОбъект.ДатаЗавершения = ТекущаяДата();
	РНКОбъект = ОбъектСогласования.ПолучитьОбъект();
	РНКОбъект.Отгружен = Перечисления.Отгружен.Отменен;
	//РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Принята;
	РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Отработана;
	РНКОбъект.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры

Процедура ЗаявкаНеСогласованаПриЗавершении(ТочкаМаршрутаБизнесПроцесса, Отказ)
	ЭтотОбъект.СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.НеСогласован;
	ЭтотОбъект.ДатаЗавершения = ТекущаяДата();
КонецПроцедуры

Процедура РасформированиеСогласованоПроверкаУсловия(ТочкаМаршрутаБизнесПроцесса, Результат)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗадачиПользователя.Согласовано КАК Согласовано,
	|	ЗадачиПользователя.Ссылка КАК Ссылка,
	|	ЗадачиПользователя.ТочкаМаршрута КАК ТочкаМаршрута,
	|	ЗадачиПользователя.БизнесПроцесс КАК БизнесПроцесс,
	|	ЗадачиПользователя.Выполнена КАК Выполнена
	|ИЗ
	|	Задача.ЗадачиПользователя КАК ЗадачиПользователя
	|ГДЕ
	|	ЗадачиПользователя.БизнесПроцесс = &БизнесПроцесс
	|	И ЗадачиПользователя.ТочкаМаршрута = &ТочкаМаршрута";
	
	Запрос.УстановитьПараметр("БизнесПроцесс", ЭтотОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТочкаМаршрута", БизнесПроцессы.РасформированиеНакладной.ТочкиМаршрута.СогласоватьОВЛ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	ОВЛСогласовано = ВыборкаДетальныеЗаписи.Согласовано;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗадачиПользователя.Согласовано КАК Согласовано,
	|	ЗадачиПользователя.Ссылка КАК Ссылка,
	|	ЗадачиПользователя.ТочкаМаршрута КАК ТочкаМаршрута,
	|	ЗадачиПользователя.БизнесПроцесс КАК БизнесПроцесс,
	|	ЗадачиПользователя.Выполнена КАК Выполнена
	|ИЗ
	|	Задача.ЗадачиПользователя КАК ЗадачиПользователя
	|ГДЕ
	|	ЗадачиПользователя.БизнесПроцесс = &БизнесПроцесс
	|	И ЗадачиПользователя.ТочкаМаршрута = &ТочкаМаршрута";
	
	Запрос.УстановитьПараметр("БизнесПроцесс", ЭтотОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТочкаМаршрута", БизнесПроцессы.РасформированиеНакладной.ТочкиМаршрута.СогласоватьСК);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	СКСогласовано = ВыборкаДетальныеЗаписи.Согласовано;
	Результат = ОВЛСогласовано И СКСогласовано;
	БизнесПроцессОбъект = ВыборкаДетальныеЗаписи.БизнесПроцесс.ПолучитьОбъект();
	Если Результат Тогда
		БизнесПроцессОбъект.СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.Согласован;
		РНКОбъект = ОбъектСогласования.ПолучитьОбъект();
		//РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Утверждена;
		//РНКОбъект.Записать(РежимЗаписиДокумента.Проведение);
		РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Принята;
		РНКОбъект.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);
	Иначе
		БизнесПроцессОбъект.СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.НеСогласован;
		РНКОбъект = ОбъектСогласования.ПолучитьОбъект();
		РНКОбъект.СостояниеКоррекции = Перечисления.СостоянияКоррекции.Отклонена;
		//РНКОбъект.Записать(РежимЗаписиДокумента.Проведение);
		РНКОбъект.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);
	КонецЕсли;
	БизнесПроцессОбъект.Записать();
	Если БизнесПроцессОбъект.СостояниеСогласования = Перечисления.СостояниеОбъектаСогласования.Согласован Тогда
		СформироватьУведомление("Уведомление о утверждении расформирования РНК");
	Иначе	
		СформироватьУведомление("Уведомление о отклонении расформирования РНК");
	КонецЕсли;

КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	Если ОбменДанными.Загрузка  Тогда
		Возврат;
	КонецЕсли;
	УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
КонецПроцедуры

