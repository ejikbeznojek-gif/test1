Процедура СформироватьУведомление(ВидУведомления) экспорт
	
	СписокПолучателей=новый СписокЗначений;
	ТемаПисьма=ВидУведомления;
	
	ТекстПисьма="";
	Если ВидУведомления="Уведомление о расформировании РНК" Тогда	
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(ИсполнителиЗадач.Исполнитель.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК ИсполнительФизЛицоЕМэйл
		|ИЗ
		|	РегистрСведений.ИсполнителиЗадач КАК ИсполнителиЗадач
		|ГДЕ
		|	ИсполнителиЗадач.РольИсполнителя = ЗНАЧЕНИЕ(Справочник.РолиИсполнителей.Согласующий_ЦО)";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если Найти(ВыборкаДетальныеЗаписи.ИсполнительФизЛицоЕМэйл,"@")>0 тогда
				СписокПолучателей.Добавить(СокрЛП(ВыборкаДетальныеЗаписи.ИсполнительФизЛицоЕМэйл));
			КонецЕсли;
		КонецЦикла;
		
		ТекстПисьма="Утверждение расформирования "+ЭтотОбъект.ОбъектСогласования+" было инициировано пользователем "+ЭтотОбъект.Инициатор;
		
		
	ИначеЕсли ВидУведомления="Уведомление о утверждении расформирования РНК в ЦО"  тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(ИсполнителиЗадач.Исполнитель.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК ИсполнительФизЛицоЕМэйл
		|ИЗ
		|	РегистрСведений.ИсполнителиЗадач КАК ИсполнителиЗадач
		|ГДЕ
		|	(ИсполнителиЗадач.РольИсполнителя = ЗНАЧЕНИЕ(Справочник.РолиИсполнителей.Согласующий_СК)
		|			ИЛИ ИсполнителиЗадач.РольИсполнителя = ЗНАЧЕНИЕ(Справочник.РолиИсполнителей.Согласующий_ОВЛ))";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если Найти(ВыборкаДетальныеЗаписи.ИсполнительФизЛицоЕМэйл,"@")>0 тогда
				СписокПолучателей.Добавить(СокрЛП(ВыборкаДетальныеЗаписи.ИсполнительФизЛицоЕМэйл));
			КонецЕсли;
		КонецЦикла;
		
		ТекстПисьма="Расформирование "+ЭтотОбъект.ОбъектСогласования+" было инициировано пользователем "+ЭтотОбъект.Инициатор;
		
	ИначеЕсли ВидУведомления="Уведомление о утверждении расформирования РНК"  тогда
		
		СписокПолучателей.Добавить(СокрЛП(ЭтотОбъект.Инициатор.ФизЛицо.ЕМэйл));
		
		ТекстПисьма="Расформирование "+ЭтотОбъект.ОбъектСогласования+" было утверждено.";
		
	ИначеЕсли ВидУведомления="Уведомление о отклонении расформирования РНК"  тогда
		
		СписокПолучателей.Добавить(СокрЛП(ЭтотОбъект.Инициатор.ФизЛицо.ЕМэйл));
		
		ТекстПисьма="Расформирование "+ЭтотОбъект.ОбъектСогласования+" было отклонено.";
		
	КонецЕсли;
	
	
	Если СокрЛП(ТекстПисьма="") Тогда
		ЗаписатьВЛог("Регламент","Пустой текст при формировании письма к коррекции № "+Номер,"Ошибка");		
	ИначеЕсли СписокПолучателей.Количество()=0 Тогда
		ЗаписатьВЛог("Регламент","Пустой список адресатов при формировании письма к коррекции № "+Номер,"Ошибка");
	Иначе
		ПодготовитьПисьмоКОтправке (СписокПолучателей,ТекстПисьма,ТемаПисьма);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодготовитьПисьмоКОтправке (СписокПолучателей,ТекстПисьма,ТемаПисьма)
	СписокАдресов="";
	для каждого Стр из СписокПолучателей цикл
		если Найти(СписокАдресов,Стр.Значение)=0 тогда
			СписокАдресов=СписокАдресов+Стр.Значение+"##";
		КонецЕсли;
	КонецЦикла;
	
	СписокАдресов=лев(СписокАдресов,СтрДлина(СписокАдресов)-2);
	
	
	ЗаписьВРег=РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
	ЗаписьВРег.Основание=Ссылка;	
	ЗаписьВРег.ДатаСозданияПисьма=ТекущаяДата();
	ЗаписьВРег.период=ЗаписьВРег.ДатаСозданияПисьма;
	
	ЗаписьВРег.ТекстПисьма=ТекстПисьма;
	ЗаписьВРег.ТемаПисьма=ТемаПисьма;
	ЗаписьВРег.СписокПолучателей=СписокАдресов;
	ЗаписьВРег.Записать();	
КонецПроцедуры
