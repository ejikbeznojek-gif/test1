Функция СоздатьЗадачу(Знач ТочкаМаршрутаБизнесПроцесса)
	
	Задача = Задачи.ЗадачиПользователя.СоздатьЗадачу();
	
	Задача.Дата                          = ТекущаяДата();
	Задача.Инициатор                     = Инициатор;
	Задача.Наименование                  = ТочкаМаршрутаБизнесПроцесса.НаименованиеЗадачи;
	Задача.Объект                      	 = ОбъектСогласования;
	Если ТочкаМаршрутаБизнесПроцесса.РольИсполнителя.Пустая() Тогда
		Задача.Исполнитель = ЭтотОбъект.Инициатор;
	Иначе
		Задача.РольИсполнителя           = ТочкаМаршрутаБизнесПроцесса.РольИсполнителя;
	КонецЕсли;
	Задача.БизнесПроцесс                 = Ссылка;
	Задача.ТочкаМаршрута                 = ТочкаМаршрутаБизнесПроцесса;
	
	Возврат Задача;
	
КонецФункции

