Функция УстановитьДЗРпоДДСпоАвансам(Дата) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	БылаДата = Константы.ДатаЗапретаРедактированияДДСпоАвансовымДоговорам.Получить();
	Константы.ДатаЗапретаРедактированияДДСпоАвансовымДоговорам.Установить(Дата);
	
	ТекстЛога		= СтрШаблон("Изменена ДЗР по ДДС по авансам. Старая дата: %1, новая дата: %2.", Формат(БылаДата, "ДФ=dd.MM.yyyy"), Формат(Дата, "ДФ=dd.MM.yyyy"));
	ТипСообщения	= ТипСообщенияЖурнала(БылаДата, Дата);
	
	ЗаписатьВЛог("Авансы покупателей", ТекстЛога, ТипСообщения); 
КонецФункции //УстановитьДЗРпоДДСпоАвансам(Дата) Экспорт

Функция УстановитьДЗРпоРНКпоАвансам(Дата) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	БылаДата = Константы.ДатаЗапретаРедактированияРНКпоАвансовымДоговорам.Получить();
