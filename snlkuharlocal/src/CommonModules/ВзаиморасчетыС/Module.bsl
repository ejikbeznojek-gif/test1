КонецФункции //УстановитьДЗРпоРНКпоАвансам(Дата) Экспорт

Функция ТипСообщенияЖурнала(СтараяДата, НоваяДата)
	Возврат ?(НоваяДата < СтараяДата, "Предупреждение", "Информация");
КонецФункции //ТипСообщенияЖурнала(СтараяДата, НоваяДата)

Функция ПолучитьАвансовыеДоговора(ДоговораСсылки) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	Ссылка
	|ИЗ
	|	Справочник.Договоры
	|ГДЕ
	|	Ссылка В (&ДоговораСсылки)
	|	И УсловияОплаты = ЗНАЧЕНИЕ(Перечисление.УсловияОплаты.Предоплата)
	|	И ВидДоговора_Новый = ЗНАЧЕНИЕ(Справочник.ВидыДоговоров.Товары_Продажа)
	|";		
	
	Запрос.УстановитьПараметр("ДоговораСсылки", ДоговораСсылки);
	
	АвансовыеДоговора = Новый Соответствие;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		АвансовыеДоговора[Выборка.Ссылка] = Истина;
	КонецЦикла;
	
	Возврат АвансовыеДоговора;
КонецФункции //ПолучитьАвансовыеДоговора(мДоговора) Экспорт