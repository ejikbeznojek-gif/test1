	ДатаДокумента=ТекДок.Дата;
	
	#Если Клиент Тогда
		Состояние(""+ТекВид+" "+ТекДок.Номер+" "+ТекДок.Дата);
	#КонецЕсли
	
	//крохин начало 05.05.2020
	//комиссионная торговля
	//проводки по взаиморасчетам формирует только отчёт комиссионера
	Если ТекВид="РасходнаяНакладная" И ТекДок.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
		Движения=Новый Структура("Взаиморасчеты",ТДВ);		
		
		Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
	КонецЕсли;
	
	Если ТекВид = "РекламационнаяНакладная" И  ТекДок.ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
		Движения=Новый Структура("Взаиморасчеты",ТДВ);		
		
		Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
		
	КонецЕсли;
	Если ТекВид = "КорректировкаЦенВНакладной" И  ТекДок.ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
		Движения=Новый Структура("Взаиморасчеты",ТДВ);		
		
		Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
		
	КонецЕсли;
	
	Если Теквид = "ОтчетКомиссионера" Тогда
		
		ТекКонтрагент			=?(Документ.Контрагент.Ведущий.Пустая(),Документ.Контрагент,Документ.Контрагент.Ведущий);
		ВалютаРасчетов			=ПолучитьВалютуРасчетов(Документ.Договор);			
		ВалютаДокумента			=ПолучитьВалютуРасчетов(Документ.Договор);
		КурсДокумента			=1;
		// Кухарь А.Ю. 18.06.2020 начало
		// Аня попросила вместо 1й суммирующей проводки писать все + и все - проводки
		// Это проводка +
		//СуммаДокумента =  Документ.СуммаОплата;
		СуммаДокумента = Документ.СуммаДокумента;
		// Кухарь А.Ю. 18.06.2020 конец		
		
								//крохин начало 26.11.2021
		//оплата бонусами по отдельному договору
		СуммаОплатыБонусами = Документ.СуммаОплатыБонусами;
