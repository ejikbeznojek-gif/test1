Функция ЕстьСтрокиРекламацийвПНК(ПНК_Ссылка)            
	Запрос = Новый Запрос;
	Запрос.Текст = "    
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Рекламация
	|ИЗ
	|	Документ.ПриходнаяНакладная.Рекламации
	|ГДЕ
	|	Ссылка = &ПНК_Ссылка	
	|";
	
	Запрос.УстановитьПараметр("ПНК_Ссылка", ПНК_Ссылка);
	Выборка	= Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Рекламация));
КонецФункции //ЕстьСтрокиРекламацийвПНК(ПНК_Ссылка)

Функция ПроведениеПоРегистрамВзаиморасчетов(ДокументСсылка,Движения) Экспорт
	РезультатПроведения	=ПровестиПоВзаиморасчетам(ДокументСсылка,Движения);	
	Возврат РезультатПроведения;		
