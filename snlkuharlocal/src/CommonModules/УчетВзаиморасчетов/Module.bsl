Функция ПровестиПоВзаиморасчетамСезонныеБонусы(Документ, Движения) Экспорт 
	
	Если ПараметрыСеанса.Отладка Тогда
		Сообщить("Проведение: "+Документ);
	КонецЕсли;
	
	Доллары=Справочники.Валюты.НайтиПоКоду("840");
	Рубли=Справочники.Валюты.НайтиПоКоду("810");
	
	Результат	=1;
	ТОшибок		=Неопределено;	
	
	ВалютаУпр	= ПараметрыСеанса.ВалютаУпр_2009;
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Документ.Дата);
	
	ТДВ = СоздатьТаблицуДвижений("Взаиморасчеты");	
	
	ТекВид=Документ.Метаданные().Имя;	
	ТекДок=Документ;
	
	ДатаДокумента=ТекДок.Дата;
	
	#Если Клиент Тогда
		Состояние(""+ТекВид+" "+ТекДок.Номер+" "+ТекДок.Дата);
	#КонецЕсли
	
	СуммаБонуса = Документ.Товары.Итог("ВсегоБезБонуса") - Документ.СуммаДокумента;
	
	Если СуммаБонуса <> 0 Тогда
		
		ТекКонтрагент			=?(Документ.Контрагент.Ведущий.Пустая(),Документ.Контрагент,Документ.Контрагент.Ведущий);	
		ДоговорСезонногоБонуса	= ПолучитьДоговорСезонногоБонуса(Документ.Контрагент);		
		ВалютаДокумента			= Документ.Валюта; // валюта бонуса = валюта документа
		КурсДокумента			= Документ.Курс;
		СуммаДокумента			= СуммаБонуса;
		
		// Выполняем 1 или 2 движения (в зависимости о признака отгрузки):
		//	1-ое движение: по договору сезонного бонуса
		//	2-ое движение: по основному договору 	
		КолвоДвижений = ?(Документ.Отгружен = Перечисления.Отгружен.Отгружен, 2, 1);
		
		Для Сч = 1 По КолвоДвижений Цикл
			
			ТекДоговор		= ?(Сч = 1, ДоговорСезонногоБонуса, Документ.Договор);		
			ВалютаРасчетов	= ПолучитьВалютуРасчетов(ТекДоговор);
			
			Запись = ТДВ.Добавить();
			Запись.Период			= Документ.Дата;
			Запись.Активность		= Истина;		
			Запись.Контрагент		= ТекКонтрагент;		
			Запись.Договор			= ТекДоговор;
			Запись.СуммаДокумента	= СуммаДокумента;			
			Запись.ВалютаДокумента	= ВалютаДокумента;				
			Запись.ВидДвижения		= ?(Сч = 1, ВидДвиженияНакопления.Приход, ВидДвиженияНакопления.Расход);
			Запись.СуммаВал			= глПересчет(СуммаДокумента, ВалютаДокумента, КурсДокумента, ВалютаРасчетов, ДатаДокумента);
			Запись.СуммаУпр			= глПересчет(СуммаДокумента, ВалютаДокумента, ДатаДокумента, ВалютаУпр, КурсУпр);		
			Запись.КодОперации		= Перечисления.КодыОперацийОстатки.Бонус; // ?(Сч = 1, Перечисления.КодыОперацийОстатки.Бонус, Перечисления.КодыОперацийОстатки.Реализация);
			
			Если Запись.СуммаВал=0 И Запись.СуммаУпр=0 Тогда
				ТДВ.Удалить(Запись);		
			КонецЕсли; 
			
		КонецЦикла; // Для Сч = 1 По КолвоДвижений Цикл
		
	КонецЕсли; // Если СуммаБонуса <> 0 Тогда
	
	Движения=Новый Структура("Взаиморасчеты",ТДВ);		
	
	Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
КонецФункции
