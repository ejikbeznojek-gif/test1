Функция СуммаПСвРНК(ДокСсылка)
	//крохин начало 31.05.2019
	//может быть не только РНК
	МетаДок				= ДокСсылка.Метаданные();
	Если НЕ ЕстьТабЧастьДокумента("Товары",МетаДок) Тогда	
		Возврат 0;		
	КонецЕсли;
	ВидНакладной = МетаДок.Имя;
	//крохин конец 31.05.2019
	
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	СУММА(Всего) КАК СуммаПроданныхСертификатов
	|ИЗ
	//крохин начало 31.05.2019
	////может быть не только РНК
	//|	Документ.РасходнаяНакладная.Товары
	|	Документ."+ВидНакладной+".Товары
	//крохин конец 20.05.2019
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.ПодарочныйСертификат)
	|";
	
	Запрос.УстановитьПараметр("Ссылка",ДокСсылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.СуммаПроданныхСертификатов) Тогда
		Возврат Выборка.СуммаПроданныхСертификатов;
	Иначе
		Возврат 0;
	КонецЕсли; 
КонецФункции //СуммаПСвРНК(ДокСсылка)


Функция ПровестиПоВзаиморасчетам(Документ,Движения)
	Если ПараметрыСеанса.Отладка Тогда
		Сообщить("Проведение: "+Документ);
	КонецЕсли;
	
	
	Доллары=Справочники.Валюты.НайтиПоКоду("840");
	Рубли=Справочники.Валюты.НайтиПоКоду("810");
	
