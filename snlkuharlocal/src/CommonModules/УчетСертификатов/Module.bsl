						#КонецЕсли
						ПредварительныйРезультат= ложь;
					КонецЕсли;
					
				КонецЕсли;
				
				
			КонецЦикла;
			
			
		Иначеесли  документ.метаданные().имя<>"Инвентаризация"  тогда 
