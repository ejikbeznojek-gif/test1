функция СертификатныеОстаткиПоСкладу(склад,ДатаОстатков)  экспорт
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	СертификатныеОстаткиОстатки.Сертификат КАК Сертификат,
	|	СертификатныеОстаткиОстатки.КоличествоОстаток КАК Количество,
	|	СертификатныеОстаткиОстатки.СуммаОстаток КАК Всего
	|ИЗ
	|	РегистрНакопления.СертификатныеОстатки.Остатки(&Дата2, Склад = &склад) КАК СертификатныеОстаткиОстатки";
	запрос.УстановитьПараметр("Склад",склад);
	запрос.УстановитьПараметр("Дата2",ДатаОстатков);
	результат=запрос.Выполнить().Выгрузить();
	возврат результат
	
КонецФункции






