функция ОприходованиеСертификатныхОстатков (Документ,ХПС)
	
	
	если документ.метаданные().имя="Перемещение" и документ.СостояниеНакладнойУПолучателя<>Перечисления.СостоянияНакладной.Принята  тогда
		//кухарь 25.08.14 начало
		//закомментировал за ненадобностью
		//	Документ.НеСоответствуетЗаявке=ложь;
		//кухарь 25.08.14 конец
		Возврат Истина
	КонецЕсли;
	
	
	//кухарь 23.12.13 начало	
	//оптимизация контроля сертификатных остатков
	если документ.метаданные().имя="Перемещение" тогда
		склад=документ.складполучатель;
	иначе
		склад=документ.склад;
	КонецЕсли;	
	//кухарь 20.01.14 начало
	//СписокСерт=КонтрольКоличестваСертификатовСписком(хпс.Сертификаты.ВыгрузитьКолонки("Сертификат"),склад,ТекущаяДата());
	//крохин начало 02.10.2014
	//проверка остатков должна быть на дату документа
	//СписокСерт=КонтрольКоличестваСертификатовСписком(хпс.Сертификаты.ВыгрузитьКолонку("Сертификат"),склад,ТекущаяДата());
	СписокСерт=КонтрольКоличестваСертификатовСписком(хпс.Сертификаты.ВыгрузитьКолонку("Сертификат"),склад,новый граница(Документ.МоментВремени(),видграницы.Исключая));	
	//крохин конец 02.10.2014
	//кухарь 20.01.14 конец	
	//кухарь 09.01.14 начало
	если СписокСерт=Неопределено тогда 
		возврат Истина;
	КонецЕсли;
	//кухарь 09.01.14 конец
	
	
	для Каждого ТекСерт из СписокСерт Цикл 
					//крохин начало 25.01.2017
			//Для ПНК-возвратов день в день контроль не нужен
			Если Документ.метаданные().Имя = "ПриходнаяНакладная" и Документ.КодОперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя  И НачалоДня(Документ.Дата) = НачалоДня(Документ.ДокОснование.Дата) Тогда
				Продолжить;
			КонецЕсли;
            //крохин конец 25.01.2017
		//кухарь начало 12.02.14
		//Если ТекСерт.количество>=1 тогда
		//кухарь 03.03.14 начало
		//крохин начало 02.10.2014
		//ищем сертификат по элементу справочника, а не по коду
		//если хпс.сертификаты.найти(тексерт.сертификат) <> Неопределено тогда
		ТекСтрока = хпс.сертификаты.найти(тексерт.сертификатСсылка,"Сертификат");		
		если ТекСтрока <> Неопределено тогда
			//крохин конец 02.10.2014
			//кухарь 03.03.14  конец	
			//крохин начало 02.10.2014
			//ищем сертификат по элементу справочника, а не по коду
			//Если ТекСерт.количество>=1 и хпс.сертификаты.найти(тексерт.сертификат).количество>0 тогда
			Если ТекСерт.количество>=1 и ТекСтрока.количество>0 тогда
			//крохин конец 25.01.2017	
				//крохин конец 02.10.2014	
				//кухарь конец 12.02.14
				#ЕСЛИ КЛИЕНТ ТОГДА
					Сообщить("Сертификат с кодом "+ТекСерт.Сертификат+" уже оприходован на остатки данного склада");
				#КонецЕсли
				//возврат ложь;
			КонецЕсли;
			//кухарь 03.03.14 начало
		КонецЕсли;
		//кухарь 03.03.14 конец
	КонецЦикла;
	//кухарь 23.12.13 конец	
	
	
	Для каждого СтрокаСерт из ХПС.сертификаты цикл
		
		
		//для ПРМ
		если документ.метаданные().имя="Перемещение" тогда
			//кухарь начало 28.10.2013 
			если Документ.СкладПолучатель=Справочники.Склады.НайтиПоКоду("SSX-66") тогда Возврат Истина КонецЕсли;
			//кухарь конец 28.10.2013
			
			склад=документ.складполучатель;
			Подразделение=склад.подразделение;
			Количество=СтрокаСерт.принято;	
			Документ.НеСоответствуетЗаявке=ложь;
		иначе
			Количество=СтрокаСерт.Количество;
			склад=документ.склад;
			попытка
				Подразделение=документ.подразделение;
			Исключение
				подразделение=документ.склад.подразделение;
			КонецПопытки;
		КонецЕсли;
		
		
		// для инвентаризаций
		если Количество<=0 Тогда Продолжить КонецЕсли;;
		// для инвентаризаций
		
		
		
		
		Движение = документ.Движения.СертификатныеОстатки.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = документ.Дата;	
		Движение.Сертификат = СтрокаСерт.Сертификат;
		Движение.Сумма = СтрокаСерт.Номинал*Количество;
		Движение.Регистратор=документ.Ссылка;
		Движение.Подразделение=Подразделение;
		Движение.Склад =склад;
		Движение.Количество = Количество;
		
		
		если документ.метаданные().имя="Инвентаризация" или Документ.метаданные().имя="ОприходованиеТМЦ"  тогда
			движение.КодОперации=Перечисления.КодыОперацийОстатки.Оприходование;
		ИначеЕсли 
			документ.метаданные().имя="Перемещение" тогда
			движение.КодОперации=Перечисления.КодыОперацийОстатки.Перемещение;
		ИначеЕсли 
			документ.метаданные().имя="ПриходнаяНакладная" тогда
			движение.КодОперации=Перечисления.КодыОперацийОстатки.Закупка;
			
		КонецЕсли;
		
	КонецЦикла;
	
	
	
	
	возврат истина	
КонецФункции


Функция КонтрольКоличестваСертификатов(Сертификат,склад,ДатаОстатков) экспорт
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	естьnull(СертификатныеОстаткиОстатки.КоличествоОстаток,0) КАК количество
	|ИЗ
	|	РегистрНакопления.СертификатныеОстатки.Остатки(
	|			&Дата2,
	|			Сертификат = &Сертификат
	|			И склад = &Склад) КАК СертификатныеОстаткиОстатки";
	//|ГДЕ
	//|	СертификатныеОстаткиОстатки.Склад = &Склад
	//|	И СертификатныеОстаткиОстатки.Сертификат = &Сертификат";
	запрос.УстановитьПараметр("Дата2",ДатаОстатков);
	запрос.УстановитьПараметр("Склад",склад);
	запрос.УстановитьПараметр("Сертификат",Сертификат);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 Тогда
		
		Возврат результат.получить(0).количество;
	иначе возврат 0
	КонецЕсли;
	
	
КонецФункции





функция получитьХПС(документ,форма) экспорт
	//Кухарь 09.01.18 начало
	//Чтобы не цепляло ХПС с пустыми основаниями
	попытка
		если документ.ссылка.склад=Справочники.Склады.ПустаяСсылка() тогда
			Возврат Неопределено;
		КонецЕсли;
	Исключение
	КонецПопытки;
	//Кухарь 09.01.18 конец
	
	
	запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ХранилищеПодарочныхСертификатов.Ссылка КАК ссылка
	|ИЗ
	|	Документ.ХранилищеПодарочныхСертификатов КАК ХранилищеПодарочныхСертификатов
	|ГДЕ
	|	ХранилищеПодарочныхСертификатов.ДокОбъект = &ДокОбъект
	|	И ХранилищеПодарочныхСертификатов.ПометкаУдаления = ЛОЖЬ" ;
	запрос.УстановитьПараметр("ДокОбъект",документ.ссылка);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда
		ХПС=результат.Получить(0).ссылка.получитьобъект();
		возврат ХПС;
	ИначеЕсли форма<>Неопределено тогда
		ХПС=документы.ХранилищеПодарочныхСертификатов.СоздатьДокумент();
		хпс.Сертификаты.Загрузить(форма.сертификаты);
		хпс.ДокОбъект=документ.ссылка;
		хпс.Дата=документ.дата;
		если хпс.сертификаты.количество()>0 тогда
			хпс.Записать();
		КонецЕсли;
		возврат ХПС;
	иначе Возврат Неопределено;
	КонецЕсли;
	
КонецФункции



