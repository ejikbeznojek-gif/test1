				если СтрТов.Количество<>НомСерт.Количество тогда
					#ЕСЛИ КЛИЕНТ ТОГДА
						Сообщить("Не совпадает количество сертификатов "+СтрТов.Номенклатура.Наименование+ "во вкладках Товары и Сертификаты");
					#КонецЕсли
					
					ПредварительныйРезультат= ложь;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		//запрет проведением с не совпадением количества серт в разных вкладках
		//документ=документы.Инвентаризация.НайтиПоНомеру();
		//кухарь 25.08.14 начало
		//закомментировал за ненадобностью
		//Документ.Товары.Сортировать("Номенклатура");
		//кухарь 25.08.14 конец
		//кухарь 25.08.14 начало 		
	КонецЕсли;
	//кухарь 25.08.14 конец 	
	//списание с остатков
	если ДелаемПроводкиСписания и (Документ.метаданные().имя="Инвентаризация" или документ.метаданные().имя="СписаниеТМЦ" 
		или документ.метаданные().имя="Перемещение" или документ.метаданные().имя="РасходнаяНакладная" или документ.метаданные().имя="ОтчетКассовойСмены") тогда
		
		РезультатСписания=СписаниеСертификатныхОстатков(Документ,ХПС);
		
	иначе РезультатСписания=Истина	
	КонецЕсли;
	
	//оприходования на остатки
	если ДелаемПроводкиОприходования и (Документ.метаданные().имя="Инвентаризация" или Документ.метаданные().имя="ОприходованиеТМЦ" 
		или документ.метаданные().имя="Перемещение"  или документ.метаданные().имя="ПриходнаяНакладная") тогда
		
		РезультатОприходования=ОприходованиеСертификатныхОстатков(Документ,ХПС);
	иначе РезультатОприходования=Истина	
	КонецЕсли;
	
	
	
	
	если РезультатСписания и РезультатОприходования Тогда 
		возврат Истина;
	иначе
		ПредварительныйРезультат= ложь;
	КонецЕсли;
	
	
	если ПредварительныйРезультат=Истина Тогда 
		Возврат Истина;
	Иначе
		если ПараметрыСеанса.ЭтотУзел.Код="SNL" тогда
			Возврат Истина;
		КонецЕсли;
		#ЕСЛИ Сервер ТОГДА
			Возврат Истина;
		#КонецЕсли
		
		Возврат ложь;
	КонецЕсли;
	
КонецФункции

//крохин начало 28.01.2017
//установка флага "подарок"
//функция СоздатьСертификатВДокументе(СтрокаТЧ)  экспорт
функция СоздатьСертификатВДокументе(СтрокаТЧ, Подарок = Ложь)  экспорт
//крохин конец 28.01.2017	
	//завести сертификат
	//если СтрокаТЧ.Сертификат<>Справочники.ПодарочныеСертификаты.ПустаяСсылка() тогда Продолжить;
	//КонецЕсли;
	ИщемСерт=Справочники.ПодарочныеСертификаты.НайтиПоКоду(СтрокаТЧ.КодСертификата);
	если ИщемСерт<>Неопределено и ИщемСерт<>Справочники.ПодарочныеСертификаты.ПустаяСсылка() Тогда 
		Возврат ИщемСерт
	КонецЕсли;
	
	
	СертификатОбъект=Справочники.ПодарочныеСертификаты.СоздатьЭлемент();		
	СертификатОбъект.Владелец				=СтрокаТЧ.Номенклатура;				
	СертификатОбъект.Код					=СтрокаТЧ.КодСертификата;
	СертификатОбъект.Номинал                =СтрокаТЧ.Номинал; 
	СертификатОбъект.СрокДействия			=360;
	СертификатОбъект.ПодразделениеПолучатель=ПараметрыСеанса.ЭтотУзел.Подразделение;				
	СертификатОбъект.КодСертификата     =СтрокаТЧ.КодСертификата;
	//
	//   			Если КодОперации=Перечисления.КодыОперацийПС.Дарение Тогда
	//   				СертификатОбъект.Подарок 		= Истина;
	//   				СертификатОбъект.ДатаВыдачи 	= Дата;	
	//   			КонецЕсли;				
	//СертификатОбъект.Документ			=документ.Ссылка;			
	СертификатОбъект.ВидСертификата		=Справочники.ВидыПодарочныхСертификатов.ЕЕ;	
	
	// нечаева 15,10,14 ++ для подарочных карт
	Если СтрокаТЧ.Номенклатура = Справочники.Номенклатура.НайтиПоКоду("SNL-357490") или 
		СтрокаТЧ.Номенклатура = Справочники.Номенклатура.НайтиПоКоду("SNL-357492") или
	//крохин начало 28.01.2017
	//сертификаты-подарки 500 рублей
	СтрокаТЧ.Номенклатура = Справочники.Номенклатура.НайтиПоКоду("SNL-353054") или	
	//крохин конец 28.01.2017
		СтрокаТЧ.Номенклатура = Справочники.Номенклатура.НайтиПоКоду("SNL-357494")
		Тогда	
		
		СертификатОбъект.Подарок = истина;
		
	КонецЕсли;
	// нечаева 15,10,14 --
	
	//крохин начало 28.01.2017
	//установка флага "подарок"
	Если Подарок Тогда
		СертификатОбъект.Подарок = истина;
	КонецЕсли;
	//крохин конец 28.01.2017
	
	СертификатОбъект.Записать();
	ИщемСерт=Справочники.ПодарочныеСертификаты.НайтиПоКоду(СтрокаТЧ.КодСертификата);
	
	Возврат ИщемСерт;
	
	
КонецФункции


//Кухарь 25.05.15 начало
//Добавил передачу формы, для выделения текущей строки при сканировании
//процедура СканированиеСертификатов(Сертификаты,данные,Документ) экспорт
процедура СканированиеСертификатов(Сертификаты,данные,Документ,форма=Неопределено) экспорт
//Кухарь 25.05.15 конец	
	Данные=СокрЛП(Данные);
	Если Лев(Данные,2)="00" И СтрДлина(Данные)=12 Тогда //странный глюк сканера
		Данные="0"+Данные;					
	КонецЕсли;
	
	ТекСертификат=Справочники.ПодарочныеСертификаты.НайтиПоКоду(Данные);
	если ТекСертификат <> Неопределено и ТекСертификат<>Справочники.ПодарочныеСертификаты.ПустаяСсылка() тогда
		//крохин начало 20.01.2017
		//возможен возврат через ПНК
		//Если ЗначениеЗаполнено(ТекСертификат.ДатаВыдачи) Тогда
		Если ЗначениеЗаполнено(ТекСертификат.ДатаВыдачи) И НЕ (документ.метаданные().имя = "ПриходнаяНакладная" И Документ.кодоперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя) Тогда
		//крохин конец 20.01.2017	
			Сообщить("Сертификат: "+ТекСертификат.Код+" уже выдавался !");
			Возврат
		ИначеЕсли ЗначениеЗаполнено(ТекСертификат.ДатаПогашения) Тогда
			Сообщить("Сертификат: "+ТекСертификат.Код+" погашен !");	
			Возврат
		ИначеЕсли ТекСертификат.Комментарий<>"" тогда
			Сообщить(ТекСертификат.Комментарий);
			Возврат
		КонецЕсли;
	КонецЕсли;
	
	ЭтоПриемщик=ложь;
	ВидДокумента=документ.метаданные().имя;
	
	СтарСерт=сертификаты.Найти(данные);
	//СтарСерт=найти(сертификаты,данные);
	
	//для получателей в ПРМ
	если ВидДокумента="Перемещение" тогда
		КодПолучателя=документ.складполучатель.кодфизическогоузла ;
		если  ПараметрыСеанса.ЭтотУзел.Код=КодПолучателя  или (документ.складполучатель=Справочники.Склады.НайтиПоКоду("SSP-56") и ПараметрыСеанса.ЭтотУзел.Код="SNL") Тогда 
			ЭтоПриемщик=Истина;
		КонецЕсли;
		
	иначе
		КодПолучателя="";
	КонецЕсли;	
	//для получателей в ПРМ
	
	//контроль наличия при сканировании
	если ТекСертификат<>Неопределено и ТекСертификат<>Справочники.ПодарочныеСертификаты.ПустаяСсылка() и (ВидДокумента="СписаниеТМЦ" или ВидДокумента="РасходнаяНакладная" или (ВидДокумента="Перемещение" и ПараметрыСеанса.ЭтотУзел.Код<>КодПолучателя))  тогда
		
		// Кухарь А.Ю. 19.08.2021 начало
		//если Документ.склад.родитель<>Справочники.Склады.НайтиПоКоду("SSP-64") тогда
		если Документ.склад.родитель<>Справочники.Склады.НайтиПоКоду("SSP-64") и Документ.склад.код<>"SSX-66" тогда		 
			// Кухарь А.Ю. 19.08.2021 конец	
			КолЭтогоСерт=КонтрольКоличестваСертификатов(ТекСертификат,Документ.склад,Документ.дата);
			Если КолЭтогоСерт<=0 тогда
				Сообщить("Сертификата нет на остатках выбранного склада");
				возврат;
			КонецЕсли;	
		КонецЕсли;
	иначеесли ТекСертификат<>Неопределено и ТекСертификат<>Справочники.ПодарочныеСертификаты.ПустаяСсылка() и  Документ.метаданные().имя="ОприходованиеТМЦ" или документ.метаданные().имя="ПриходнаяНакладная" или (ВидДокумента="Перемещение" и ПараметрыСеанса.ЭтотУзел.Код=КодПолучателя) тогда
		если ВидДокумента<>"Перемещение" тогда
			КолЭтогоСерт=КонтрольКоличестваСертификатов(ТекСертификат,Документ.склад,ТекущаяДата());
		иначе
			КолЭтогоСерт=КонтрольКоличестваСертификатов(ТекСертификат,Документ.складполучатель,ТекущаяДата());
			
		КонецЕсли;
				//крохин начало 25.01.2017
		//для возвратов день в день  контроль не нужен
		Если документ.метаданные().имя="ПриходнаяНакладная" И Документ.КодОперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя  Тогда
			Если НачалоДня(ТекСертификат.ДатаВыдачи) = НачалоДня(ТекущаяДата()) Тогда
			КолЭтогоСерт = 0;
		    КонецЕсли;
			Если ПустаяСтрока(ТекСертификат.НомерЧекаВыдачи) Тогда
				Сообщить("сертификат не выдавался, возврат невозможен!");
				Возврат;
			КонецЕсли;
			Если НЕ ПустаяСтрока(ТекСертификат.НомерЧекаПогашения) ИЛИ ТекСертификат.Использован Тогда
				Сообщить("сертификат уже был использован, возврат невозможен!");
			КонецЕсли;
		КонецЕсли;
		
			//крохин конец 25.01.2017
		если КолЭтогоСерт>=1 тогда
			Сообщить("Этот сертификат уже оприходовался на остатки");
			Возврат ;
		КонецЕсли;
	КонецЕсли;
	
	//контроль наличия при сканировании
	
	//сертификаты заводи только в ОПР и ИНВ	
		если (ТекСертификат=Неопределено или ТекСертификат=Справочники.ПодарочныеСертификаты.ПустаяСсылка()) и (ВидДокумента<>"Инвентаризация" и ВидДокумента<>"ОприходованиеТМЦ" и ВидДокумента<>"Перемещение" и ВидДокумента<>"ПриходнаяНакладная") тогда

		Сообщить("сертификат не найден");	
		Возврат	
	КонецЕсли;
	//сертификаты заводи только в ОПР и ИНВ	
	
	//крохин начало 26.01.2017
	//в ТЦ нельзя делать ПНК на сертификаты, кроме возвратов
	если (ТекСертификат=Неопределено или ТекСертификат=Справочники.ПодарочныеСертификаты.ПустаяСсылка()) И (ВидДокумента="ПриходнаяНакладная" И ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение) Тогда
		Сообщить("сертификат не найден");	
		Возврат	
	КонецЕсли;
    //крохин конец 26.01.2017	
	
	если СтарСерт=Неопределено тогда
		ТекСертификат=Справочники.ПодарочныеСертификаты.НайтиПоКоду(Данные);
		СвойстваДобСерт=УчетСертификатов.ОпределитьСвойстваСертификата(Данные);
		если СвойстваДобСерт=Неопределено тогда Возврат  КонецЕсли;	
		ДобСерт=Сертификаты.Добавить();
		если ТекСертификат=Справочники.ПодарочныеСертификаты.ПустаяСсылка() тогда
			ДобСерт.КодСертификата=Данные;	
			ДобСерт.Номинал=СвойстваДобСерт.получить(0).номинал;
		Иначе 
			ДобСерт.Сертификат=ТекСертификат;
			ДобСерт.КодСертификата=ТекСертификат.Код;
			ДобСерт.Номинал=ТекСертификат.Номинал;
		КонецЕсли;
		ДобСерт.Номенклатура=СвойстваДобСерт.получить(0).Номенклатура;
		
		
		
		если ВидДокумента="Инвентаризация" тогда
			ДобСерт.КоличествоФакт=1;	
			ДобСерт.Количество=ДобСерт.КоличествоФакт-ДобСерт.КоличествоРасч;
			
			
		ИначеЕсли ЭтоПриемщик Тогда 
			ДобСерт.Принято=1;
		Иначе 	
			добСерт.Количество=1;
		КонецЕсли;
		ДобСерт.Всего=ДобСерт.Количество*ДобСерт.Номинал;
		//Кухарь 25.05.15 начало
		//крохин начало 06.12.2017
		//теперь для всех документов
		//если ВидДокумента="Инвентаризация" тогда
		Если форма <> Неопределено Тогда
		//крохин конец 06.12.2017	
			Форма.элементыформы.сертификаты.текущаястрока=ДобСерт;
		КонецЕсли;
		//Кухарь 25.05.15 конец
	иначе
		если ВидДокумента="Инвентаризация" тогда
			//Кухарь 25.05.15 начало
			//Чтобы искать дубли сертификатов было легче
			//если старсерт.Количество<=0 или СтарСерт.КоличествоФакт<=0 тогда
			если СтарСерт.КоличествоФакт=1 тогда
				Сообщить("Сертификат "+СтарСерт.КодСертификата+" отсканирован повторно");
			КонецЕсли;
			Форма.элементыформы.сертификаты.текущаястрока=СтарСерт;
			//Кухарь 25.05.15 конец
			
			СтарСерт.КоличествоФакт=СтарСерт.КоличествоФакт+1;
			СтарСерт.Количество=СтарСерт.КоличествоФакт-СтарСерт.КоличествоРасч;
			СтарСерт.Всего=СтарСерт.Номинал*(СтарСерт.КоличествоФакт-СтарСерт.КоличествоРасч);
			//Кухарь 25.05.15 начало
			//Чтобы искать дубли сертификатов было легче
			//иначе
			//сообщить(СтарСерт.КодСертификата+ " уже присутствует в этом документе");
			//КонецЕсли;
			//Кухарь 25.05.15 конец
		ИначеЕсли ЭтоПриемщик Тогда 
			СтарСерт.Принято=1;
			
		иначе
			если старсерт.Количество<=0 тогда
				
				СтарСерт.Количество=СтарСерт.Количество+1;
				СтарСерт.Всего=СтарСерт.Номинал*СтарСерт.Количество;
			иначе
				сообщить(СтарСерт.КодСертификата+ " уже присутствует в этом документе");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	//крохин начало 25.01.2017
	//для возвратных ПНК попробуем найти чек и заполнить реквизиты ПНК по нему
	Если ВидДокумента = "ПриходнаяНакладная" И Документ.кодоперации = Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда
		если СтарСерт<>Неопределено тогда
			ТекСертификат = СтарСерт;
		КонецЕсли;
		Если ТекСертификат.ПодразделениеВыдачи = Документ.Подразделение Тогда
			ЧекВыдачи = Документы.Чек.НайтиПоНомеру(ТекСертификат.НомерЧекаВыдачи,ТекСертификат.ДатаВыдачи);
			Если НЕ ЧекВыдачи.Пустая() Тогда
				Документ.ДокОснование = ЧекВыдачи;
				Если ЧекВыдачи.ВидОплаты = Перечисления.ВидыОплаты.БН Тогда
					Документ.ВозвратПК = Истина;
				Иначе
					Документ.ВозвратПК = Ложь;
				КонецЕсли;	
			Иначе
				Сообщить("Чек продажи сертификата не обнаружен! Установите вид оплаты в соответствии с бумажным чеком!");		
			КонецЕсли;
		Иначе
			Сообщить("Сертификат был продан в: " + ТекСертификат.ПодразделениеВыдачи + ". Установите вид оплаты в соответствии с бумажным чеком!");	
		КонецЕсли;
	КонецЕсли;
		//крохин конец 25.01.2017
КонецПроцедуры



процедура УдалениеКомментариевСписанныхСертификатов(документ) экспорт
	ХПС=получитьХПС(Документ,Неопределено);
	если ХПС<>Неопределено тогда
		СписокСписанныхСертификатов=новый СписокЗначений;
		Для каждого СтрокаСерт из ХПС.сертификаты цикл
			// для инвентаризаций
			если документ.метаданные().имя<>"Инвентаризация" тогда
				количество=СтрокаСерт.количество;
			иначе
				количество=-СтрокаСерт.количество;
			КонецЕсли;
			если количество<=0 Тогда Продолжить КонецЕсли;
			
			СписокСписанныхСертификатов.Добавить(СтрокаСерт.Сертификат);
			
			
		КонецЦикла;
		для каждого ССС из СписокСписанныхСертификатов цикл
			ССерт=ссс.Значение.получитьобъект();
			ССерт.комментарий="";
			ССерт.записать();
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры



функция СписаниеСертификатныхОстатков(документ,ХПС)
