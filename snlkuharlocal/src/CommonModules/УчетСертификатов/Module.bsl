функция ПровестиДокументПоСертификатнымОстаткам(Документ) экспорт
	ПредварительныйРезультат=истина;
	ХПС=получитьХПС(Документ,Неопределено);
	если хпс=Неопределено тогда Возврат Истина КонецЕсли;
	
	РазныеСертификаты=новый ТаблицаЗначений;
	РазныеСертификаты.Колонки.Добавить("Номенклатура");
	РазныеСертификаты.Колонки.Добавить("Количество");
	для каждого СтрокаТовара из Документ.товары цикл
		если СтрокаТовара.номенклатура.родитель.родитель.код="SNL-095760" тогда
			стрТаб=РазныеСертификаты.Добавить();
			стрТаб.номенклатура=СтрокаТовара.номенклатура;
			стрТаб.количество=СтрокаТовара.количество;
		КонецЕсли;	
	КонецЦикла;
	
	если ХПС.сертификаты.количество() = 0 и РазныеСертификаты.Количество() = 0 тогда
		Возврат Истина;	
	КонецЕсли;
	//определение необходимости проводок по складу
	если документ.метаданные().имя<>"Перемещение" тогда
		если документ.склад.кодфизическогоузла=ПараметрыСеанса.ЭтотУзел.Код тогда
			ДелаемПроводкиСписания=истина;
			ДелаемПроводкиОприходования=Истина;
		иначе 
			ДелаемПроводкиСписания=ложь;
			ДелаемПроводкиОприходования=ложь;
		КонецЕсли;
	иначе
		если документ.склад.кодфизическогоузла=ПараметрыСеанса.ЭтотУзел.Код тогда
			ДелаемПроводкиСписания=истина;
		Иначе 
			ДелаемПроводкиСписания=ложь;
		КонецЕсли;
		
		если документ.складполучатель.кодфизическогоузла=ПараметрыСеанса.ЭтотУзел.Код тогда
			ДелаемПроводкиОприходования=истина;
		Иначе 
			ДелаемПроводкиОприходования=ложь;
		КонецЕсли;		
	КонецЕсли;
	
	если ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
		ДелаемПроводкиСписания=Истина;
		ДелаемПроводкиОприходования=Истина;
	КонецЕсли;
	//определение необходимости проводок по складу
	
	//кухарь 25.08.14 начало 
	если документ.метаданные().имя<>"ОтчетКассовойСмены" тогда
		для каждого СтрТовары из документ.товары цикл
			ТекТов=хпс.сертификаты.найти(СтрТовары.номенклатура);
			Если ТекТов= Неопределено тогда
				#ЕСЛИ КЛИЕНТ ТОГДА
					Сообщить(СтрТовары.Номенклатура.Наименование+" отсутствует во вкладке сертификаты");
				#КонецЕсли
				ПредварительныйРезультат= Ложь;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	если ПредварительныйРезультат тогда
		//кухарь 25.08.14 конец		
		
		
		
		//запрет проведением с не совпадением количества серт в разных вкладках
		если документ.метаданные().имя="Перемещение" тогда	
			таб=ХПС.Сертификаты.выгрузить();
			таб.Свернуть("Номенклатура","Принято,Количество");
			//для каждого НомСерт из таб цикл
			//	серт=документ.Товары.найти(НомСерт.номенклатура);
			//	если серт=Неопределено тогда
			//		серт=документ.товары.добавить();
			//	КонецЕсли;
			//	серт.Номенклатура=НомСерт.номенклатура;
			//	серт.Заявка=НомСерт.количество;
			//	серт.ПодтвержденнаяЗаявка=НомСерт.количество;
			//	серт.ПодтвержденнаяЗаявкаПеремещения=НомСерт.количество;
			//	если Документ.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена тогда
			//		серт.Количество=НомСерт.принято;
			//	иначе 
			//		серт.Количество=НомСерт.количество;
			//	КонецЕсли;
			//	серт.СтавкаНДС=Перечисления.СтавкиНДС.НДС18;
			//КонецЦикла;
			РазныеСертификаты=новый ТаблицаЗначений;
			РазныеСертификаты.Колонки.Добавить("Номенклатура");
			РазныеСертификаты.Колонки.Добавить("Количество");
			для каждого СтрокаТовара из Документ.товары цикл
				если СтрокаТовара.номенклатура.родитель.родитель.код="SNL-095760" тогда
					стрТаб=РазныеСертификаты.Добавить();
					стрТаб.номенклатура=СтрокаТовара.номенклатура;
					стрТаб.количество=СтрокаТовара.количество;
				КонецЕсли;	
			КонецЦикла;
			
			
			
			
			для каждого НомСерт из РазныеСертификаты цикл
				
				СтрТов=таб.Найти(НомСерт.номенклатура);
				если СтрТов=Неопределено тогда
					#ЕСЛИ КЛИЕНТ ТОГДА
						Сообщить(НомСерт.Номенклатура.Наименование+" отсутствует во вкладке сертификаты");
					#КонецЕсли
					ПредварительныйРезультат= Ложь;
				КонецЕсли;
				если Документ.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.Принята тогда
					если СтрТов.принято<>НомСерт.Количество тогда
						#ЕСЛИ КЛИЕНТ ТОГДА
							Сообщить("Не совпадает количество сертификатов "+СтрТов.Номенклатура.Наименование+ "во вкладках Товары и Сертификаты");
