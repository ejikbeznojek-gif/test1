				для каждого НомСерт из РазныеСертификаты цикл
					СтрТов=таб.Найти(НомСерт.номенклатура);
					если СтрТов=Неопределено тогда
						#ЕСЛИ КЛИЕНТ ТОГДА
							Сообщить(НомСерт.Номенклатура.Наименование+" отсутствует во вкладке сертификаты");
						#КонецЕсли
