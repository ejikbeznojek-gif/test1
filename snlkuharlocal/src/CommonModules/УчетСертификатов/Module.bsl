Функция ПогаситьСертификатыПриВозврате(Документ) Экспорт 
	ХПС = УчетСертификатов.получитьХПС(Документ,Неопределено);
	Для Каждого СтрокаТЧ ИЗ ХПС.Сертификаты Цикл
	СертификатОбъект = СтрокаТЧ.Сертификат.ПолучитьОбъект();
	СертификатОбъект.ДатаПогашения = Документ.дата;
	СертификатОбъект.Использован = Истина;
	СертификатОбъект.НомерЧекаПогашения = Документ.номер;
	СертификатОбъект.ПодразделениеПредъявления = Документ.подразделение;
	СертификатОбъект.Код = "R"+Прав(СертификатОбъект.Код,12);
	СертификатОбъект.Комментарий = "Сертификат был возвращен";
	СертификатОбъект.Записать();
	КонецЦикла;
КонецФункции
