#Область СлужебныеПроцедурыИФункции
//test
Функция ПолучитьСтруктуруПодключения() Экспорт
	
	ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
	
	// получить настройки из РС b2b_НастройкиОбменаДанными
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.Сервер КАК Сервер,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.Порт КАК Порт,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.КлючАвторизации КАК КлючАвторизации,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.ХранитьПодробностиЛогирования КАК ХранитьПодробностиЛогирования,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.Узел КАК Узел,
		|	ИСТИНА КАК ЗащищенноеСоединение,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.МетодAPIВыгрузитьКонтрагентов КАК МетодAPIВыгрузитьКонтрагентов,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.МетодAPIВыгрузитьАкции КАК МетодAPIВыгрузитьАкции,
		|	b2b_НастройкиОбменаДаннымиСрезПоследних.МетодAPIПроверкаСтатуса КАК МетодAPIПроверкаСтатуса,
		|	"""" КАК Логин,
		|	"""" КАК Пароль
		|ИЗ
		|	РегистрСведений.b2b_НастройкиОбменаДанными.СрезПоследних КАК b2b_НастройкиОбменаДаннымиСрезПоследних";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаНастройки = РезультатЗапроса.Выбрать();
	ВыборкаНастройки.Следующий();
	СтруктураПодключения = b2b_ОбменДаннымиПоAPI.ПолучитьСтруктуруИзВыборки(ВыборкаНастройки);
	СтруктураПодключения.Вставить("ИдентификаторЗапроса", ИдентификаторЗапроса); 
	
	Возврат СтруктураПодключения;
	
КонецФункции

Функция ПолучитьСтруктуруИзВыборки(Выборка) Экспорт
	
	Результат = Новый Структура;
	Для каждого Колонка Из Выборка.Владелец().Колонки Цикл
		Результат.Вставить(Колонка.Имя);
	КонецЦикла;
	ЗаполнитьЗначенияСвойств(Результат, Выборка);
	
	Возврат Результат;
	
КонецФункции

Функция HTTPСоединениеДляОбменаДаннымиAPI(СтруктураПодключения) Экспорт
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	Прокси = Новый ИнтернетПрокси(Ложь); 

	Если СтруктураПодключения.Порт = 80 Тогда 		
		СтруктураПодключения.ЗащищенноеСоединение = Ложь; 
	КонецЕсли;
	
	Попытка
		Если СтруктураПодключения.ЗащищенноеСоединение Тогда
			СоединениеHTTP = Новый HTTPСоединение(
				СтруктураПодключения.Сервер, 
				СтруктураПодключения.Порт, 
				СтруктураПодключения.Логин, 
				СтруктураПодключения.Пароль,
				Прокси,
				,
				ЗащищенноеСоединение
			);
		Иначе 
			СоединениеHTTP = Новый HTTPСоединение(
				СтруктураПодключения.Сервер, 
				СтруктураПодключения.Порт, 
				СтруктураПодключения.Логин, 
				СтруктураПодключения.Пароль,
				Прокси
			);
		КонецЕсли;
		
		Возврат СоединениеHTTP; 
		
	Исключение
		ЗаписатьОшибкуОбменДаннымиПоAPI(СтруктураПодключения.ИдентификаторЗапроса, , ОписаниеОшибки()); 
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Процедура ЗаписатьОшибкуОбменДаннымиПоAPI(
	ИдентификаторЗапроса, 
	ИдентификаторКлиента, 
	ИнформацияОбОшибке,
	Результат = Неопределено
	) Экспорт
	
	НоваяЗапись = РегистрыСведений.b2b_ЖурналОшибок.СоздатьМенеджерЗаписи();
	НоваяЗапись.Период = ТекущаяДата();
	НоваяЗапись.ИдентификаторЗапроса = ИдентификаторЗапроса;
	НоваяЗапись.ИдентификаторКлиента = ИдентификаторКлиента;
	НоваяЗапись.ИнформацияОбОшибке = ИнформацияОбОшибке;
	Если Результат <> Неопределено Тогда
		НоваяЗапись.Результат = Новый ХранилищеЗначения(Результат, Новый СжатиеДанных(9));
	КонецЕсли;
	
	Попытка
		НоваяЗапись.Записать();
	Исключение
		ЗаписьЖурналаРегистрации(
			"ОшибкаЗаписиВЖурналОшибок",
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.РегистрыСведений.b2b_ЖурналОшибок,
			,
			,
		); 
	КонецПопытки; 
	
КонецПроцедуры

Функция СериализоватьВСтрокуJSON(Значение) Экспорт

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON( , Символы.Таб)); 
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

Процедура ПолучитьРезультатОбработкиОчередиНаПортале(СтруктураПодключения) Экспорт
	
	Если Не СтруктураПодключения.Свойство("ТипЗапроса") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ТипЗнч(СтруктураПодключения.ТипЗапроса) = Тип("Строка") 
		Или Не ЗначениеЗаполнено(СтруктураПодключения.ТипЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторЗапроса КАК ИдентификаторЗапроса,
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторКлиента КАК ИдентификаторКлиента,
		|	b2b_ЗапросыНаОбновлениеВОчереди.МассивДанных КАК МассивДанных
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновлениеВОчереди КАК b2b_ЗапросыНаОбновлениеВОчереди
		|ГДЕ
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторКлиента <> """"
		|	И НЕ b2b_ЗапросыНаОбновлениеВОчереди.Отработано
		|	И (ВЫРАЗИТЬ(b2b_ЗапросыНаОбновлениеВОчереди.ТекстОшибки КАК СТРОКА(500))) = """"
		|	И b2b_ЗапросыНаОбновлениеВОчереди.ТипЗапроса = &ТипЗапроса
		|
		|УПОРЯДОЧИТЬ ПО
		|	b2b_ЗапросыНаОбновлениеВОчереди.Период";
	
	Запрос.УстановитьПараметр("ТипЗапроса", СтруктураПодключения.ТипЗапроса);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	РезультатОтправки = Ложь; 
	
	МассивОшибок = Новый массив; 
	
	Пока Выборка.Следующий() Цикл
		ПараметрыДляОтправкиЗапроса = Новый Структура; 
		ПараметрыДляОтправкиЗапроса.Вставить("ИдентификаторКлиента", Выборка.ИдентификаторКлиента);
		ПараметрыДляОтправкиЗапроса.Вставить("ИдентификаторЗапроса", Выборка.ИдентификаторЗапроса);
		ПараметрыДляОтправкиЗапроса.Вставить("ТипЗапроса", "ОтработкаОчереди" + СтруктураПодключения.ТипЗапроса);
		МассивДанныхИзЗапроса = Выборка.МассивДанных.Получить();
		Если МассивДанныхИзЗапроса <> Неопределено Тогда
			МассивКонтрагентов = ЗначениеИзСтрокиВнутр(МассивДанныхИзЗапроса);
		КонецЕсли;
		ПараметрыДляОтправкиЗапроса.Вставить("МассивДанных", МассивКонтрагентов);
		ОтработкаОтправленныхДанныхПоКонтрагентам(
			СтруктураПодключения, 
			ПараметрыДляОтправкиЗапроса, 
			РезультатОтправки, 
			МассивОшибок
		); 
	КонецЦикла;
	
	Если МассивОшибок.Количество() > 0 Тогда
		ТемаПисьма = СтрШаблон("Ошибка отработки очереди  по %1", СтруктураПодключения.ТипЗапроса); 
		ТекстПисьма = МассивОшибок[0] + Символы.ПС + ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы())); 
		Комментарий = СтрШаблон("Ошибка отправки данных с типом %1", СтруктураПодключения.ТипЗапроса);
		b2b_ОбменЗаявками.СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма, ТемаПисьма, Комментарий);	
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтработкаОтправленныхДанныхПоКонтрагентам(СтруктураПодключения, ВходныеПараметры, РезультатОтправки, МассивОшибок) Экспорт
	
	СтруктураДанных = b2b_ОбменЗаявками.ЗаполнитьСтруктуруДляПолученияДанныхОчереди(ВходныеПараметры);
	
	СоединениеHTTP = HTTPСоединениеДляОбменаДаннымиAPI(СтруктураПодключения); 
	
	HTTPзапрос = Новый HTTPзапрос();
	
	ЗаголовокHTTP = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Content-Type", "application/json");
	ЗаголовокHTTP.Вставить("Authorization", СтруктураПодключения.КлючАвторизации);
	
	HTTPЗапрос.Заголовки = ЗаголовокHTTP;
	HTTPзапрос.АдресРесурса = СтруктураПодключения.МетодAPIПроверкаСтатуса;
	
	ТекстЗапроса = b2b_ОбменДаннымиПоAPI.СериализоватьВСтрокуJSON(СтруктураДанных);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	// отправка данных на портал и записываем в журнал: b2b_ЗапросыНаОбновлениеИстория
	Попытка
		Ответ_АПИ = СоединениеHTTP.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		// записываем ошибку в лог РС b2b_ЖурналОшибок
        b2b_ОбменДаннымиПоAPI.ЗаписатьОшибкуОбменДаннымиПоAPI(СтруктураПодключения.ИдентификаторЗапроса, , ОписаниеОшибки());
		Возврат;
	КонецПопытки;	
	
	РезультатЧтенияJSON = b2b_ОбменЗаявками.СтруктураJSONЗапроса(Ответ_АПИ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;
	
	СтрокаJSONОтвета = Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
				
		ИдентификаторКлиента = Структура_JSON_Ответ.requestId;
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди", , "");
		РезультатДанные.РезультатJson = Структура_JSON_Ответ;
		РезультатДанные.ИдентификаторОчереди =  ВходныеПараметры.ИдентификаторКлиента; 
		
		b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(
			Строка(СтруктураПодключения.ИдентификаторЗапроса),
			ИдентификаторКлиента, 
			ТекстЗапроса,
			ВходныеПараметры,
			СтруктураПодключения.ХранитьПодробностиЛогирования
		);

		Если Структура_JSON_Ответ.Свойство("data") Тогда 
			
			b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
				Строка(СтруктураПодключения.ИдентификаторЗапроса),
				ИдентификаторКлиента,
				РезультатДанные,
				"",
				,
				,
				СтруктураПодключения.ХранитьПодробностиЛогирования
			);
			
			 Если Структура_JSON_Ответ.data.result = "queued" Тогда     //пока не отработано  
				 
				 РезультатДанныеОчереди = Неопределено;  //не перезаписываем
				 b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
				 	ВходныеПараметры.ИдентификаторЗапроса,
					ВходныеПараметры.ИдентификаторКлиента,
					РезультатДанныеОчереди,
					"В обработке"
					,
					,
					,
					СтруктураПодключения.ХранитьПодробностиЛогирования
				 ); 
				 
			 ИначеЕсли 	Структура_JSON_Ответ.data.result = "success" 
				 Или Структура_JSON_Ответ.data.result = "warning" Тогда			 			
				 
				 ОбъектыКСнятиюСРегистрации = ВходныеПараметры.МассивДанных;
				 
				 ТекстОшибокИзСтруктурыОтвета = "";
				  
				 Если Структура_JSON_Ответ.data.result = "warning" Тогда
					 
					 Если Структура_JSON_Ответ.data.Свойство("data") И ТипЗнч(Структура_JSON_Ответ.data.data) = Тип("Массив") Тогда 
						 
						 МассивКодовПриВыгрузкеСОшибкой = Новый Массив;
						 
						 Для Каждого ЭлементМассиваData Из Структура_JSON_Ответ.data.data Цикл
							 Если ЭлементМассиваData.Свойство("errors") И ТипЗнч(ЭлементМассиваData.errors) = Тип("Массив") Тогда 
								 Для Каждого ЭлементМассиваОшибок Из ЭлементМассиваData.errors Цикл
									 // для контрагентов
									 Если ЭлементМассиваОшибок.Свойство("login") Тогда
										 МассивКодовПриВыгрузкеСОшибкой.Добавить(ЭлементМассиваОшибок.login);
										 ТекстОшибокИзСтруктурыОтвета = ТекстОшибокИзСтруктурыОтвета + 
										 СтрШаблон("%1: %2;", ЭлементМассиваОшибок.login, ЭлементМассиваОшибок.error); 
									 КонецЕсли;
									 // для акций
									 Если ЭлементМассиваОшибок.Свойство("code") Тогда
										 МассивКодовПриВыгрузкеСОшибкой.Добавить(ЭлементМассиваОшибок.code);
										 ТекстОшибокИзСтруктурыОтвета = ТекстОшибокИзСтруктурыОтвета + 
										 СтрШаблон("%1: %2;", ЭлементМассиваОшибок.code, ЭлементМассиваОшибок.error); 
									 КонецЕсли;
								 КонецЦикла;
							 КонецЕсли; 
						 КонецЦикла;
						 
						 ОбъектыКСнятиюСРегистрации = Неопределено;
						 
						 Если МассивКодовПриВыгрузкеСОшибкой.Количество() > 0 Тогда 
							 
							 Если ВходныеПараметры.МассивДанных <> Неопределено Тогда
								 
								 Если СтруктураПодключения.ТипЗапроса = "ВыгрузкаКонтрагентов" Тогда
									 
									 Запрос = Новый Запрос;
									 Запрос.Текст = 
									 "ВЫБРАТЬ
									 |	Контрагенты.Ссылка КАК Ссылка
									 |ИЗ
									 |	Справочник.Контрагенты КАК Контрагенты
									 |ГДЕ
									 |	Контрагенты.Ссылка В(&Контрагенты)
									 |	И НЕ Контрагенты.Код В (&ОбъектыВыгруженныеСОшикой)";
									 
									 Запрос.УстановитьПараметр("Контрагенты", ВходныеПараметры.МассивДанных);
									 Запрос.УстановитьПараметр("ОбъектыВыгруженныеСОшикой", МассивКодовПриВыгрузкеСОшибкой);
									 
									 ОбъектыКСнятиюСРегистрации = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
									 
								 КонецЕсли;  
								 
								 Если СтруктураПодключения.ТипЗапроса = "ВыгрузкаАкций" Тогда
									 
									 Запрос = Новый Запрос;
									 Запрос.Текст = 
									 "ВЫБРАТЬ
									 |	УстановкаСкидокПоКонтрагентам.Ссылка КАК Ссылка
									 |ИЗ
									 |	Документ.УстановкаСкидокПоКонтрагентам КАК УстановкаСкидокПоКонтрагентам
									 |ГДЕ
									 |	УстановкаСкидокПоКонтрагентам.Ссылка В(&Документы)
									 |	И НЕ УстановкаСкидокПоКонтрагентам.Номер В (&ОбъектыВыгруженныеСОшикой)";
									 
									 Запрос.УстановитьПараметр("Документы", ВходныеПараметры.МассивДанных);
									 Запрос.УстановитьПараметр("ОбъектыВыгруженныеСОшикой", МассивКодовПриВыгрузкеСОшибкой);
									 
									 ОбъектыКСнятиюСРегистрации = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
									 
								 КонецЕсли;
								 
							 КонецЕсли;
							 
						 КонецЕсли;
						 
					 КонецЕсли;
					 
				 КонецЕсли;
	
				РезультатДанныеОчереди = Неопределено; 
				b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
					ВходныеПараметры.ИдентификаторЗапроса,
					ВходныеПараметры.ИдентификаторКлиента,
					РезультатДанныеОчереди,
					"",
					Ложь,
					Истина,
					СтруктураПодключения.ХранитьПодробностиЛогирования
				);
				
				Если ОбъектыКСнятиюСРегистрации <> Неопределено И ОбъектыКСнятиюСРегистрации.Количество() > 0 Тогда
					// снимаем с регистрации контрагентов, выгруженных без ошибки
					ПланыОбмена.УдалитьРегистрациюИзменений(СтруктураПодключения.Узел, ОбъектыКСнятиюСРегистрации);
					// запись в журнал контрагентов, при выгрузке которых произошла ошибка
					Если ТекстОшибокИзСтруктурыОтвета <> "" Тогда
						ТекстОшибкиЗагрузки =  СтрШаблон("%1 %2", Структура_JSON_Ответ.data.message, ТекстОшибокИзСтруктурыОтвета);
						b2b_ОбменЗаявками.ЗаписатьОшибкуВЖурнал(
							Строка(СтруктураПодключения.ИдентификаторЗапроса),
							"Есть ошибки при отработки очереди. " + ТекстОшибкиЗагрузки,
							Структура_JSON_Ответ.requestId
						);
					КонецЕсли;
				
				КонецЕсли;
				
			 ИначеЕсли Структура_JSON_Ответ.data.result = "error" Тогда
				 
				 ТекстОшибокИзСтруктурыОтвета = "";
				 
				 Если Структура_JSON_Ответ.data.Свойство("data") Тогда
					 
					 Если ТипЗнч(Структура_JSON_Ответ.data.data) = Тип("Структура") 
						 И Структура_JSON_Ответ.data.data.Свойство("errors") Тогда 
						 
						 Если ТипЗнч(Структура_JSON_Ответ.data.data.errors) = Тип("Массив") Тогда
							 
							 МассивКодовПриВыгрузкеСОшибкой = Новый Массив;
							 
							 Для Каждого ЭлементМассиваОшибок Из Структура_JSON_Ответ.data.data.errors Цикл 
								 // для контрагентов
								 Если ЭлементМассиваОшибок.Свойство("login") Тогда
									 МассивКодовПриВыгрузкеСОшибкой.Добавить(ЭлементМассиваОшибок.login);
									 ТекстОшибокИзСтруктурыОтвета = ТекстОшибокИзСтруктурыОтвета + 
									 	СтрШаблон("%1: %2;", ЭлементМассиваОшибок.login, ЭлементМассиваОшибок.error);
								 КонецЕсли;
								 // для акций
								 Если ЭлементМассиваОшибок.Свойство("code") Тогда
									 МассивКодовПриВыгрузкеСОшибкой.Добавить(ЭлементМассиваОшибок.code);
									 ТекстОшибокИзСтруктурыОтвета = ТекстОшибокИзСтруктурыОтвета + 
									 	СтрШаблон("%1: %2;", ЭлементМассиваОшибок.code, ЭлементМассиваОшибок.error);	 
								 КонецЕсли;
							 КонецЦикла;
							 
							 Если МассивКодовПриВыгрузкеСОшибкой.Количество() > 0 Тогда
								 
								 Если СтруктураПодключения.ТипЗапроса = "ВыгрузкаКонтрагентов" Тогда
									 
									 Запрос = Новый Запрос;
									 Запрос.Текст = 
									 "ВЫБРАТЬ
									 |	Контрагенты.Ссылка КАК Ссылка
									 |ИЗ
									 |	Справочник.Контрагенты КАК Контрагенты
									 |ГДЕ
									 |	Контрагенты.Ссылка В(&Контрагенты)
									 |	И НЕ Контрагенты.Код В (&ОбъектыВыгруженныеСОшикой)";
									 
									 Запрос.УстановитьПараметр("Контрагенты", ВходныеПараметры.МассивДанных);
									 Запрос.УстановитьПараметр("ОбъектыВыгруженныеСОшикой", МассивКодовПриВыгрузкеСОшибкой);
									 
									 ОбъектыКСнятиюСРегистрации = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
								 
								 КонецЕсли;
								 
								 Если СтруктураПодключения.ТипЗапроса = "ВыгрузкаАкций" Тогда
									 
									 Запрос = Новый Запрос;
									 Запрос.Текст = 
									 "ВЫБРАТЬ
									 |	УстановкаСкидокПоКонтрагентам.Ссылка КАК Ссылка
									 |ИЗ
									 |	Документ.УстановкаСкидокПоКонтрагентам КАК УстановкаСкидокПоКонтрагентам
									 |ГДЕ
									 |	УстановкаСкидокПоКонтрагентам.Ссылка В(&Документы)
									 |	И НЕ УстановкаСкидокПоКонтрагентам.Номер В (&ОбъектыВыгруженныеСОшикой)";
									 
									 Запрос.УстановитьПараметр("Документы", ВходныеПараметры.МассивДанных);
									 Запрос.УстановитьПараметр("ОбъектыВыгруженныеСОшикой", МассивКодовПриВыгрузкеСОшибкой);
									 
									 ОбъектыКСнятиюСРегистрации = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
									 
								 КонецЕсли;
								 
								 Если ОбъектыКСнятиюСРегистрации.Количество() > 0 Тогда
									 ПланыОбмена.УдалитьРегистрациюИзменений(СтруктураПодключения.Узел, ОбъектыКСнятиюСРегистрации);
								 КонецЕсли;
							 КонецЕсли; 
							 
						 КонецЕсли;
						 
					 КонецЕсли;
					 
				 КонецЕсли;
				 
				 ТекстОшибкиЗагрузки =  СтрШаблон("%1 %2", Структура_JSON_Ответ.data.message, ТекстОшибокИзСтруктурыОтвета);
				 РезультатДанныеОчереди = Неопределено; 
				 b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
				 	ВходныеПараметры.ИдентификаторЗапроса,
					ВходныеПараметры.ИдентификаторКлиента,
					РезультатДанныеОчереди,
					"Ошибка отработки очереди. " + ТекстОшибкиЗагрузки,
					Истина,
					,
					СтруктураПодключения.ХранитьПодробностиЛогирования
				 );
				 b2b_ОбменЗаявками.ЗаписатьОшибкуВЖурнал(
				 	Строка(СтруктураПодключения.ИдентификаторЗапроса),
					"Ошибка отработки очереди. " + ТекстОшибкиЗагрузки,
					Структура_JSON_Ответ.requestId
				 );
			 Иначе 
				 РезультатДанныеОчереди = Неопределено; 
				 b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
				 	ВходныеПараметры.ИдентификаторЗапроса,
					ВходныеПараметры.ИдентификаторКлиента,
					РезультатДанныеОчереди,
					"Нераспознанный результат",
					Истина,
					,
					СтруктураПодключения.ХранитьПодробностиЛогирования
				 );
				 b2b_ОбменЗаявками.ЗаписатьОшибкуВЖурнал(
				 	Строка(СтруктураПодключения.ИдентификаторЗапроса),
					"Ошибка отработки очереди",
					Структура_JSON_Ответ.requestId);
			 КонецЕсли;
			
		Иначе 
						
			РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди", , ""); 			
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
				Строка(СтруктураПодключения.ИдентификаторЗапроса),
				ИдентификаторКлиента,
				РезультатДанные,
				"Ответ по структуре не соответствует ожидаемой",
				Истина,
				,
				СтруктураПодключения.ХранитьПодробностиЛогирования
			);

		КонецЕсли;
		
		РезультатОтправки = Истина;
	Иначе 
		//запись в журнал
		b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(
			Строка(СтруктураПодключения.ИдентификаторЗапроса),
			"", 
			ТекстЗапроса, 
			ВходныеПараметры,
			СтруктураПодключения.ХранитьПодробностиЛогирования
		);
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400
			ИЛИ КодОшибки = 403 Тогда   		
			
			ИнформацияОбОшибке = СтрокаJSONОтвета;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = СтрШаблон("%1:%2", Строка(КодОшибки), ИнформацияОбОшибке); 
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 
		РезультатДанные.РезультатJson = СтрокаJSONОтвета; 
		
		b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
			Строка(СтруктураПодключения.ИдентификаторЗапроса),
			"",
			РезультатДанные,
			Комментарий,
			Истина,
			,
			СтруктураПодключения.ХранитьПодробностиЛогирования
		);
		
		ТекстОшибки = "Не удалось отправить запрос на отработку очереди по остаткам ЦО из SNL." + ИнформацияОбОшибке;
		МассивОшибок.Добавить(ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры // ОтправкаПодтвержденияДоЗаказа()

