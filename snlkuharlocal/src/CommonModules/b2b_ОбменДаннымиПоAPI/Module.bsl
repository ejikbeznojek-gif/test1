Процедура ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиПоAPI(
		ИдентификаторЗапроса,
		ИдентификаторКлиента,
		Запрос,
		ВходныеПараметры,
		ХранитьПодробностиЛогирования = Ложь
	) Экспорт

	МенеджерЗаписи = РегистрыСведений.b2b_ЗапросыНаОбновлениеВОчереди.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДатаСеанса(); 
	МенеджерЗаписи.ИдентификаторЗапроса = ИдентификаторЗапроса; 
	МенеджерЗаписи.ИдентификаторКлиента = ИдентификаторКлиента;
	Если ХранитьПодробностиЛогирования Тогда
	
		МенеджерЗаписи.Запрос = Новый ХранилищеЗначения(Запрос, Новый СжатиеДанных(9));	
	
	КонецЕсли;
	
	//Если ВходныеПараметры.Свойство("СписокКонтрагентов") Тогда
	//	
	//	МенеджерЗаписи.МассивДанных = ВходныеПараметры.СписокКонтрагентов;
	//	
	//КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ИдентификаторОчереди") Тогда
	
		МенеджерЗаписи.ИдентификаторОчереди = ВходныеПараметры.ИдентификаторОчереди; 	
	
	КонецЕсли;       
		
	Если ВходныеПараметры.Свойство("ТипЗапроса") Тогда
	
		МенеджерЗаписи.ТипЗапроса = ВходныеПараметры.ТипЗапроса; 	
	
	КонецЕсли;
	
	b2b_ОбменЗаявками.ПопыткаЗаписиВЖурнал( МенеджерЗаписи, "b2b_ЗапросыНаОбновлениеИстория", ИдентификаторЗапроса); 

КонецПроцедуры //  

Функция ПолучитьВсеИзмененияИзПланаОбмена(УзелПланаОбмена, ИмяОбъектаМетаданных = "") Экспорт
	
	Если ИмяОбъектаМетаданных = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура("Данные, НомерСообщения", Новый Массив());
	
	Если НЕ ЗначениеЗаполнено(УзелПланаОбмена) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не (УзелПланаОбмена.Код = "B2B" Или УзелПланаОбмена.Код = "KNT") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЗаписьXML = Новый ЗаписьXML();
	ЗаписьXML.УстановитьСтроку();
	
	ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();
	ЗаписьСообщения.НачатьЗапись(ЗаписьXML, УзелПланаОбмена);
	
	СтруктураВозврата.НомерСообщения = ЗаписьСообщения.НомерСообщения;
	
	Выборка = ПланыОбмена.ВыбратьИзменения(ЗаписьСообщения.Получатель, ЗаписьСообщения.НомерСообщения); 
	
	Пока Выборка.Следующий() Цикл
		
		Данные = Выборка.Получить();

		Если ИмяОбъектаМетаданных = "Контрагенты" И ТипЗнч(Данные) = Тип("СправочникОбъект.Контрагенты") Тогда
			
			СтруктураВозврата.Данные.Добавить(Данные.Ссылка);	
			
		КонецЕсли;
		
		Если ИмяОбъектаМетаданных = "УстановкаСкидокПоКонтрагентам" 
			И ТипЗнч(Данные) = Тип("ДокументОбъект.УстановкаСкидокПоКонтрагентам") Тогда
			
			СтруктураВозврата.Данные.Добавить(Данные.Ссылка);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтруктураВозврата; 
	
КонецФункции

