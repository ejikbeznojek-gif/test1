	ДокЗаписан = Ложь; 
	ПроверкаВерсииДокументаПриЗаписи(ВерсияСтарая,Документрегистрации,ДокЗаписан);
	
	Если ДокЗаписан Тогда
		
		ЗаписатьДанныеПоАкцииВРегистрДляПередачи(ДокументРегистрации); 
		
