Процедура ОтправитьДанныеПоАкциямПоИзмененнымДанным()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ПереданныеАкцииКонтрагентов.ДокументРегистрации КАК ДокументРегистрации
		|ИЗ
		|	РегистрСведений.b2b_ПереданныеАкцииКонтрагентов КАК b2b_ПереданныеАкцииКонтрагентов
		|ГДЕ
		|	b2b_ПереданныеАкцииКонтрагентов.Изменен";
	
	МассивДляВыгрузки =  Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументРегистрации"); 
	
	Если МассивДляВыгрузки.Количество() > 0 Тогда 
		
		ОбработкаОб = Обработки.b2b_ОбменДанныхПоAPI.Создать();
		
		ТипЗапроса = "ВыгрузкаАкций";
		СтруктураПодключения = b2b_ОбменДаннымиПоAPI.ПолучитьСтруктуруПодключения();
		СтруктураПодключения.Вставить("ТипЗапроса", ТипЗапроса);
		СтруктураПодключения.Вставить("ПолнаяВыгрузка", ложь);
		СтруктураПодключения.Вставить("Данные", МассивДляВыгрузки);
		
		СтруктураДляВыгрузкиАкций = ОбработкаОб.ПолучитьСтруктуруДляВыгрузкиАкций(СтруктураПодключения);
		
		РезультатОтправки = Ложь;  	
	    ОбработкаОб.ОтправитьВыгружаемыеДанныеНаПорталПоAPI(СтруктураПодключения,СтруктураДляВыгрузкиАкций,РезультатОтправки); 
		Если РезультатОтправки = Истина Тогда
			
			Для каждого ДокОтправки  Из МассивДляВыгрузки Цикл
				
				МенеджерЗаписи = РегистрыСведений.b2b_ПереданныеАкцииКонтрагентов.СоздатьМенеджерЗаписи();  
				МенеджерЗаписи.ДокументРегистрации = ДокОтправки;  
				МенеджерЗаписи.Прочитать();
				
				МенеджерЗаписи.ПереданныеДанные = МенеджерЗаписи.ДанныеБазы; 
				МенеджерЗаписи.Изменен = Ложь;
				МенеджерЗаписи.ДатаОтправки = ТекущаяДатаСеанса(); 
				МенеджерЗаписи.Записать(); 
				
			КонецЦикла;	
			
			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры



Процедура ПроверкаВерсииДокументаПриЗаписи(Знач ВерсияСтарая,Знач ДокументРегистрации,ДокЗаписан,СекундПауза = 0) Экспорт 
	
	Если СекундПауза >= 300 Тогда 
		
		ДокЗаписан = Ложь;	
		
	ИначеЕсли ВерсияСтарая = ДокументРегистрации.ссылка.ВерсияДанных Тогда 
		
		Пауза(10);
		
		СекундПауза = СекундПауза + 10; 
		
		ПроверкаВерсииДокументаПриЗаписи(ВерсияСтарая,ДокументРегистрации,ДокЗаписан,СекундПауза); 
	Иначе 
		ДокЗаписан = истина;  
	КонецЕсли;

КонецПроцедуры


Процедура ЗаписатьДанныеПоАкцииВРегистрДляПередачи(Знач ДокументРегистрации) Экспорт 
	
	//прежде чем записывать, необходимо, что
	
	НаборЗаписей = РегистрыСведений.b2b_ПереданныеАкцииКонтрагентов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ДокументРегистрации.Установить(ДокументРегистрации.ссылка); 
	НаборЗаписей.Прочитать();
	
	
	ДанныеАкции = ЗаполнитьСтруктуруДанныхПоАкции(ДокументРегистрации); 
	
	Если НаборЗаписей.Количество() > 0  Тогда
		МенеджерЗаписи = НаборЗаписей[0];
		
		ПереданныеДанные = МенеджерЗаписи.ПереданныеДанные.Получить(); 
		РезультатСравнения = РезультатСравненияСпереданнымиАкциямиНаПортал(ДанныеАкции,ПереданныеДанные);
		
		СтруктураИзменений = Новый Структура; 
		СтруктураИзменений.Вставить("ИзмененаШапка",РезультатСравнения.ИзмененаШапка); 
		СтруктураИзменений.Вставить("ИзмененыТовары",РезультатСравнения.ИзмененыТовары);
		СтруктураИзменений.Вставить("ИзмененыКонтрагенты",РезультатСравнения.ИзмененыКонтрагенты);
		СтруктураИзменений.Вставить("КонтрагентыИзмененные",РезультатСравнения.МассивИзмКонтрагентов);
		
		МенеджерЗаписи.ДанныеБазы = Новый ХранилищеЗначения(ДанныеАкции,Новый СжатиеДанных(9));
		
		Если НЕ РезультатСравнения.ИзмененаШапка
			И НЕ РезультатСравнения.ИзмененыТовары
			И НЕ РезультатСравнения.ИзмененыКонтрагенты Тогда
			
			НаборЗаписей.Записать();
			
			Возврат; 	
		Иначе 						 
			
			МенеджерЗаписи.Изменения = Новый ХранилищеЗначения(СтруктураИзменений,Новый СжатиеДанных(9)); 
			МенеджерЗаписи.Изменен = Истина; 
			МенеджерЗаписи.ДатаИзменения = ТекущаяДатаСеанса(); 
			НаборЗаписей.Записать(); 
		КонецЕсли;
		
		 
		
	Иначе 
		
		
		СтруктураИзменений = Новый Структура; 
		СтруктураИзменений.Вставить("ИзмененаШапка",истина); 
		СтруктураИзменений.Вставить("ИзмененыТовары",истина);
		СтруктураИзменений.Вставить("ИзмененыКонтрагенты",истина);
		СтруктураИзменений.Вставить("КонтрагентыИзмененные","Все");
		
		МенеджерЗаписи = РегистрыСведений.b2b_ПереданныеАкцииКонтрагентов.СоздатьМенеджерЗаписи(); 
		МенеджерЗаписи.ДокументРегистрации = ДокументРегистрации.ссылка; 
		МенеджерЗаписи.ДанныеБазы = Новый ХранилищеЗначения(ДанныеАкции,Новый СжатиеДанных(9));  
		МенеджерЗаписи.Изменен = Истина;
		МенеджерЗаписи.Изменения = Новый ХранилищеЗначения(СтруктураИзменений,Новый СжатиеДанных(9));
		МенеджерЗаписи.ДатаИзменения = ТекущаяДатаСеанса();
		МенеджерЗаписи.Записать(); 
		
	КонецЕсли;
	
КонецПроцедуры

Функция РезультатСравненияСпереданнымиАкциямиНаПортал(ДанныеБазы,ПереданныеДанные)

	 //перебором, чтобы получить, что изменилось 
	 // 
	 ИзмененаШапка = Ложь; 
	 ИзмененыТовары = Ложь;
	 ИзмененыКонтрагенты = Ложь; 
	 
	 ИзмененныеКонтрагенты = Новый Массив; 
	 
	 Если  ТипЗнч(ПереданныеДанные) = Тип("Структура") Тогда 	 
		 
		 //еще сравнить массивы по контрагентам точечно  
		 
		 Для каждого ЭлементСтруктуры Из ДанныеБазы Цикл
			 
			 Если типЗнч(ЭлементСтруктуры.Значение) = Тип("Массив") Тогда
				 
				 
				 МассивПереданныхДанных = ПереданныеДанные[ЭлементСтруктуры.Ключ];
				 МассивДанныхБазы = ЭлементСтруктуры.Значение; 
				 
				 СтрокаПереданные = ЗначениеВСтрокуВнутр(МассивПереданныхДанных);  
				 СтрокаДанныеБазы = ЗначениеВСтрокуВнутр(МассивДанныхБазы);
					
				 Если ЭлементСтруктуры.Ключ = "products" Тогда 					
					
					Если СтрокаПереданные <> СтрокаДанныеБазы Тогда
					
						ИзмененыТовары = Истина; 	
					
					КонецЕсли;
					
				КонецЕсли;
				
				Если ЭлементСтруктуры.Ключ = "distributors" Тогда
					
					Если СтрокаПереданные <> СтрокаДанныеБазы Тогда
					
						ИзмененыКонтрагенты = Истина; 
						
						//поточечно
						
						СоответствиеКонтрагентыБазы = Новый Соответствие; 
						СоответствиеКонтрагентыПереданные = Новый Соответствие; 
						
						Для каждого ЭлементМассива Из МассивПереданныхДанных Цикл
							
							СоответствиеКонтрагентыПереданные.Вставить(ЭлементМассива.distr,ЭлементМассива.active); 
							
						КонецЦикла;
						
						Для каждого ЭлементМассива Из МассивДанныхБазы Цикл
							
							СоответствиеКонтрагентыБазы.Вставить(ЭлементМассива.distr,ЭлементМассива.active); 
							
						КонецЦикла; 
						
						Для каждого ЭлементСоотКонтр Из СоответствиеКонтрагентыБазы Цикл
							
							Если СоответствиеКонтрагентыПереданные.Получить(ЭлементСоотКонтр.Ключ) = неопределено
								ИЛИ СоответствиеКонтрагентыПереданные.Получить(ЭлементСоотКонтр.Ключ) <> ЭлементСоотКонтр.Значение Тогда
								
								ИзмененныеКонтрагенты.Добавить(ЭлементСоотКонтр.Ключ); 	
								
							КонецЕсли;
							
						КонецЦикла; 
						
						
						Для каждого ЭлементСоотКонтр Из СоответствиеКонтрагентыПереданные Цикл
							
							Если СоответствиеКонтрагентыБазы.Получить(ЭлементСоотКонтр.Ключ) = неопределено
								ИЛИ СоответствиеКонтрагентыБазы.Получить(ЭлементСоотКонтр.Ключ) <> ЭлементСоотКонтр.Значение Тогда
								
								Если ИзмененныеКонтрагенты.Найти(ЭлементСоотКонтр.Ключ) = неопределено Тогда
									
									ИзмененныеКонтрагенты.Добавить(ЭлементСоотКонтр.Ключ);	
									
								КонецЕсли;
								
								
							КонецЕсли;
							
						КонецЦикла;

					
					КонецЕсли;
					
				КонецЕсли;
				
				 				 
			 Иначе 
				 Если НЕ ПереданныеДанные.Свойство(ЭлементСтруктуры.Ключ) 
					 ИЛИ ПереданныеДанные[ЭлементСтруктуры.Ключ] <> ЭлементСтруктуры.Значение Тогда
					 
					 ИзмененаШапка = Истина; 
					 
				 КонецЕсли;
			 КонецЕсли;
			 
		 КонецЦикла;
	 Иначе
		 
		 ИзмененаШапка = истина; 
		 ИзмененыТовары = истина;
		 ИзмененыКонтрагенты = Истина; 
		  
	 КонецЕсли;
	 
	 Возврат Новый Структура("ИзмененаШапка,ИзмененыТовары,ИзмененыКонтрагенты,МассивИзмКонтрагентов",ИзмененаШапка,ИзмененыТовары,ИзмененыКонтрагенты,ИзмененныеКонтрагенты); 
КонецФункции // СравнитьСпереданнымиАкциямиНаПортал()


Функция ЗаполнитьСтруктуруДанныхПоАкции(Знач ДокументРегистрации)

	Запрос = Новый Запрос; 	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УстановкаСкидокПоКонтрагентам.Ссылка КАК Ссылка,
		|	УстановкаСкидокПоКонтрагентам.Номер КАК Номер,
		|	УстановкаСкидокПоКонтрагентамСкидки.Номенклатура КАК Номенклатура,
		|	УстановкаСкидокПоКонтрагентамСкидки.Скидка КАК Скидка,
		|	УстановкаСкидокПоКонтрагентамСкидки.СкидкаКонечныйПокупатель КАК СкидкаКонечныйПокупатель,
		|	ВЫРАЗИТЬ(УстановкаСкидокПоКонтрагентам.Комментарий КАК СТРОКА(100)) КАК Наименование,
		|	УстановкаСкидокПоКонтрагентам.Дата КАК ДатаНачала,
		|	УстановкаСкидокПоКонтрагентам.Дата2 КАК ДатаОкончания
		|ПОМЕСТИТЬ втДанные
		|ИЗ
		|	Документ.УстановкаСкидокПоКонтрагентам КАК УстановкаСкидокПоКонтрагентам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.УстановкаСкидокПоКонтрагентам.Скидки КАК УстановкаСкидокПоКонтрагентамСкидки
		|		ПО УстановкаСкидокПоКонтрагентам.Ссылка = УстановкаСкидокПоКонтрагентамСкидки.Ссылка
		|ГДЕ
		|	УстановкаСкидокПоКонтрагентам.Проведен
		|	И УстановкаСкидокПоКонтрагентам.Ссылка = &ДокументРегистрации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НоменклатураГруппа.Код КАК КодМодели,
		|	втДанные.Скидка КАК Скидка,
		|	втДанные.СкидкаКонечныйПокупатель КАК СкидкаКонечныйПокупатель,
		|	втДанные.Номер КАК Номер,
		|	втДанные.Наименование КАК Наименование,
		|	НАЧАЛОПЕРИОДА(втДанные.ДатаНачала, ДЕНЬ) КАК ДатаНачала,
		|	КОНЕЦПЕРИОДА(втДанные.ДатаОкончания, ДЕНЬ) КАК ДатаОкончания
		|ИЗ
		|	Справочник.Номенклатура КАК СпрНоменлатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураГруппа
		|		ПО СпрНоменлатура.Родитель = НоменклатураГруппа.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДанные КАК втДанные
		|		ПО (СпрНоменлатура.Ссылка В ИЕРАРХИИ
		|				(ВЫБРАТЬ
		|					втДанные.Номенклатура КАК Номенклатура
		|				ИЗ
		|					втДанные КАК втДанные))
		|ГДЕ
		|	СпрНоменлатура.ПометкаУдаления = ЛОЖЬ
		|	И СпрНоменлатура.ЭтоГруппа = ЛОЖЬ
		|	И ВЫБОР
		|			КОГДА СпрНоменлатура.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|				ТОГДА ""Да""
		|			КОГДА СпрНоменлатура.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
		|				ТОГДА ""Нет""
		|			ИНАЧЕ ВЫБОР
		|					КОГДА СпрНоменлатура.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|						ТОГДА ""Да""
		|					КОГДА СпрНоменлатура.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
		|						ТОГДА ""Нет""
		|					ИНАЧЕ ВЫБОР
		|							КОГДА СпрНоменлатура.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|								ТОГДА ""Да""
		|							КОГДА СпрНоменлатура.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
		|								ТОГДА ""Нет""
		|							ИНАЧЕ ВЫБОР
		|									КОГДА СпрНоменлатура.Родитель.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|										ТОГДА ""Да""
		|									КОГДА СпрНоменлатура.Родитель.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
		|										ТОГДА ""Нет""
		|									ИНАЧЕ ""Нет""
		|								КОНЕЦ
		|						КОНЕЦ
		|				КОНЕЦ
		|		КОНЕЦ = ""Да""
		|ИТОГИ
		|	МАКСИМУМ(Наименование),
		|	МАКСИМУМ(ДатаНачала),
		|	МАКСИМУМ(ДатаОкончания)
		|ПО
		|	Номер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Ведущие.Код КАК КодКонтрагента,
		|	УстановкаСкидокПоКонтрагентамКонтрагенты.Согласован КАК УчавствуетВАкции,
		|	втДанные.Номер КАК Номер
		|ИЗ
		|	втДанные КАК втДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.УстановкаСкидокПоКонтрагентам.Контрагенты КАК УстановкаСкидокПоКонтрагентамКонтрагенты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Ведущие
		|				ПО Контрагенты.Ведущий = Ведущие.Ссылка
		|			ПО УстановкаСкидокПоКонтрагентамКонтрагенты.Контрагент = Контрагенты.Ссылка
		|		ПО втДанные.Ссылка = УстановкаСкидокПоКонтрагентамКонтрагенты.Ссылка
		|ГДЕ
		|	Ведущие.ВыгружатьВИнтернетМагазин = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)"; 
	
	Запрос.УстановитьПараметр("ДокументРегистрации",ДокументРегистрации.ссылка); 
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаАкции = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКонтрагенты = РезультатЗапроса[2].Выбрать(); 
	
	ДанныеШапки = СтруктураДанныхПоАкции();
	
	Если ВыборкаАкции.Следующий() Тогда  		 
		
		ДанныеШапки.code = ВыборкаАкции.Номер;
		ДанныеШапки.name =  ВыборкаАкции.Наименование;
		ДанныеШапки.startDate = ВыборкаАкции.ДатаНачала;
		ДанныеШапки.endDate = ВыборкаАкции.ДатаОкончания;
		
		ВыборкаСкидки = ВыборкаАкции.Выбрать();
		
		МассивНоменклатуры = Новый Массив;
		
		Пока ВыборкаСкидки.Следующий() Цикл
			
			Если ЗначениеЗаполнено(ВыборкаСкидки.КодМодели) Тогда
				
				СтруктураТоваров = СтруктураДанныхПоТоварамАкции(); 
				СтруктураТоваров.code = ВыборкаСкидки.КодМодели;
				СтруктураТоваров.discountDistr = ВыборкаСкидки.Скидка;
				СтруктураТоваров.discountClient = ВыборкаСкидки.СкидкаКонечныйПокупатель; 
				
				МассивНоменклатуры.Добавить(СтруктураТоваров);
			КонецЕсли;
			
		КонецЦикла;
		
		ДанныеШапки.products = МассивНоменклатуры; //всегда добавляем, для сравнения 
		
		МассивКонтрагентов = Новый Массив;
		
		Пока ВыборкаКонтрагенты.Следующий() Цикл
			
			Если ВыборкаКонтрагенты.Номер = ВыборкаАкции.Номер Тогда
				
				Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодКонтрагента) Тогда
					СтруктураКонтрагента = СтруктураДанныхПоКонтрагентамАкции();
					СтруктураКонтрагента.distr = ВыборкаКонтрагенты.КодКонтрагента; 
					СтруктураКонтрагента.active = ВыборкаКонтрагенты.УчавствуетВАкции;
					МассивКонтрагентов.Добавить(СтруктураКонтрагента);	
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ДанныеШапки.distributors = МассивКонтрагентов;
			
	КонецЕсли;
	
    Возврат ДанныеШапки; 
	
КонецФункции // ЗаполнитьСтруктуруДанныхПоАкции()


Функция СтруктураДанныхПоАкции() 
	
	ДанныеШапки = Новый Структура; 
	ДанныеШапки.Вставить("code","");
	ДанныеШапки.Вставить("name","");
	ДанныеШапки.Вставить("startDate",Дата(1,1,1));
	ДанныеШапки.Вставить("endDate",Дата(1,1,1));
	ДанныеШапки.Вставить("products",Новый Массив);  
	ДанныеШапки.Вставить("distributors",Новый Массив); 
	
	Возврат ДанныеШапки; 

КонецФункции // СтруктураДанныхПоАкциям()

Функция СтруктураДанныхПоТоварамАкции()
	
	ДанныеПоТовару = Новый Структура; 
	ДанныеПоТовару.Вставить("code");
	ДанныеПоТовару.Вставить("discountDistr");
	ДанныеПоТовару.Вставить("discountClient");
	
	Возврат ДанныеПоТовару; 
	
КонецФункции // СтруктураДанныхПоТоварамАкции() 


Функция СтруктураДанныхПоКонтрагентамАкции()
	
	ДанныеПоТовару = Новый Структура; 
	ДанныеПоТовару.Вставить("distr");
	ДанныеПоТовару.Вставить("active"); 
	
	Возврат ДанныеПоТовару; 
	
КонецФункции



	
