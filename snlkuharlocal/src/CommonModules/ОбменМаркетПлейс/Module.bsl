	|ПОМЕСТИТЬ ВТ_ОстаткиМаркиИтог
	|ИЗ
	|	ВТ_ОстаткиМарки КАК ВТ_ОстаткиМарки
	|ГДЕ
	|	ВТ_ОстаткиМарки.КолКонФакт > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НомДок.Комплектующие КАК Комплектующие,
	|	НомДок.Количество - ЕСТЬNULL(ВТ_ОстаткиМаркиИтог.КолКонФакт, 0) КАК КолКонФакт,
	|	НомДок.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НЕХВАТАЕТМАРКИ
	|ИЗ
	|	ВТ_НомДок КАК НомДок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиМаркиИтог КАК ВТ_ОстаткиМаркиИтог
	|		ПО НомДок.Комплектующие = ВТ_ОстаткиМаркиИтог.Номенклатура
	|ГДЕ
	|	НомДок.Количество > ЕСТЬNULL(ВТ_ОстаткиМаркиИтог.КолКонФакт, 0)";
	
	
	//Параметры запроса
	Запрос.УстановитьПараметр("Заказано",   Заказано);// Не определено
	Запрос.УстановитьПараметр("СкладМарки", МаркетПлейс.СкладМаркировки);// Не определено
	Запрос.УстановитьПараметр("СкладФБС",   МаркетПлейс.Склад);// Не определено 
	
	//////////////////////////////////////////////////////////////
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(МаркетПлейс.Склад);
	
	Если ЗначениеЗаполнено(МаркетПлейс.СкладМаркировки) Тогда
		МассивСкладов.Добавить(МаркетПлейс.СкладМаркировки);
	КонецЕсли;
	//////////////////////////////////////////////////////////////
	
	Запрос.УстановитьПараметр("Склады",     МассивСкладов);// Не определено
	Запрос.УстановитьПараметр("Спайка",     Спайка);// Не определено
	
	ИтоговыйЗапрос = Запрос.ВыполнитьПакетСПромежуточнымиДанными(); //8 пакетовр
	
	ТЗНетНаличии    = ИтоговыйЗапрос[2].Выгрузить();
	ТЗСкладФБС      = ИтоговыйЗапрос[5].Выгрузить();
	ТЗСкладМаркаФБС = ИтоговыйЗапрос[8].Выгрузить();
	
	СтруктураСпайки = Новый Структура;
	СтруктураСпайки.Вставить("НетВналичии",ТЗНетНаличии);
	СтруктураСпайки.Вставить("СкладФБС",   ТЗСкладФБС);
	СтруктураСпайки.Вставить("СкладМарка", ТЗСкладМаркаФБС);
	
	Возврат СтруктураСпайки;
	
КонецФункции 

