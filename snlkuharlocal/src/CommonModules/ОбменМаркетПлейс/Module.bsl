			Файл= новый файл (ПутькПДФ);
			РазмерФайла = Файл.Размер();
			Если РазмерФайла>1000 тогда
				КопироватьФайл(ПутькПДФ,ЭтикФ);
			конецЕсли;
		КонецЕсли;
	исключение
