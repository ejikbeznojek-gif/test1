// Ихсанов Д. А. Начало 26.05.2026 Наряд 0000000171 от 20.05.2026 11:18:21: e1cib/data/Документ.Наряд?ref=89690050568f680711f1542474905136
// Формирование план факта по каналам выполнить на сервере.
// 
// Параметры: ФормированиеПланФактаПоКаналамПериод - Дата - Формирование план факта по каналам период
//  Параметры - Соответствие Из Строка- Параметры
// 
// Возвращаемое значение:
//  Строка - Данные JSON
Функция ФормированиеПланФактаПоКаналамВыполнитьНаСервере(Параметры)
	
	// Предварительная инициализация запросов данных с именами ключевых полей
	МассивДанныхЗапросКлючевоеПоле = Новый Массив;
	МассивДанныхЗапросКлючевоеПоле.Добавить(Новый Структура("ИмяКлючевыхДанных, ТекстЗапроса",
		"ActualQuantityCurrPeriod", ТекстЗапросаКоличествоФактТекущийПериод()));
	МассивДанныхЗапросКлючевоеПоле.Добавить(Новый Структура("ИмяКлючевыхДанных, ТекстЗапроса",
		"ActualAmountCurrPeriod", ТекстЗапросаСуммаФактТекущийПериод()));
	МассивДанныхЗапросКлючевоеПоле.Добавить(Новый Структура("ИмяКлючевыхДанных, ТекстЗапроса",
		"PlannedQuantityCurrPeriod", ТекстЗапросаКоличествоПланТекущийПериод()));
	МассивДанныхЗапросКлючевоеПоле.Добавить(Новый Структура("ИмяКлючевыхДанных, ТекстЗапроса",
		"PlannedAmountCurrPeriod", ТекстЗапросаСуммаПланТекущийПериод()));
	
	// Инициализация запроса
	Запрос = Новый Запрос;
	#Область ТекстЗапроса
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстЗапросаПрародители("Номенклатура"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	ТаблицаДанных.Потомок КАК Номенклатура,
	|	ТаблицаДанных.Предок КАК ГруппаТоваров
	|ПОМЕСТИТЬ вт_ДанныеПрародителиНоменклатуры
	|ИЗ
	|	ТаблицаДанных КАК ТаблицаДанных"); // Преобразуем итоги транзитивного замыкания в понимаемую таблицу данных
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	ДанныеКаналаСбыта.Родитель КАК КаналПродажи
	|ПОМЕСТИТЬ вт_ДанныеКонтрагентаИКаналаСбыта
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КаналСбыта КАК ДанныеКаналаСбыта
	|		ПО Контрагенты.КаналСбыта1 = ДанныеКаналаСбыта.Ссылка
	|ГДЕ
	|	ДанныеКаналаСбыта.Родитель <> ЗНАЧЕНИЕ(Справочник.КаналСбыта.ПустаяСсылка)"); // Заранее получим каналы сбыта
	
	// Сформируем блок запроса по ключевым данным
	ТекстЗапросаОбъединение = "";
	Для каждого ДанныеЗапросКлючевоеПоле Из МассивДанныхЗапросКлючевоеПоле Цикл
		ТекущийНомерКолонки = МассивДанныхЗапросКлючевоеПоле.Найти(ДанныеЗапросКлючевоеПоле) + 1;
		
		// Дополним тексты запросов данными по получению ключевого поля
		ТекстыЗапросов.Добавить(ДанныеЗапросКлючевоеПоле.ТекстЗапроса);
		
		// Добавим запрос в объединение данных по ключевым значениям
		ТекущийТекстОбъединенияПролог = "ВЫБРАТЬ SalesChannel, Counterparty, ProductGroup,";
		ТекущийТекстОбъединенияЭпилог = СтрШаблон("%1ИЗ %2 КАК Т",
			?(ПустаяСтрока(ТекстЗапросаОбъединение), "ПОМЕСТИТЬ вт_ПланФактПоКаналам ", ""),
			ДанныеЗапросКлючевоеПоле.ИмяКлючевыхДанных);
		
		СтрокиКолонок = Новый Массив;
		Для НомерКолонки = 1 По МассивДанныхЗапросКлючевоеПоле.Количество() Цикл
			СтрокиКолонок.Добавить(СтрШаблон("%1 КАК {%2}",
				?(НомерКолонки = ТекущийНомерКолонки, "ЗначениеКлючевогоПоля", "0"), НомерКолонки));
		КонецЦикла;
		
		ТекущиеТекстыОбъединения = Новый Массив;
		ТекущиеТекстыОбъединения.Добавить(ТекущийТекстОбъединенияПролог);
		ТекущиеТекстыОбъединения.Добавить(СтрСоединить(СтрокиКолонок, ","));
		ТекущиеТекстыОбъединения.Добавить(ТекущийТекстОбъединенияЭпилог);
		
		ТекстЗапросаОбъединение = СтрШаблон("%1%2%3",
			ТекстЗапросаОбъединение, ?(ПустаяСтрока(ТекстЗапросаОбъединение), "", " ОБЪЕДИНИТЬ "),
				СтрСоединить(ТекущиеТекстыОбъединения, " "));
	КонецЦикла;
	
	ТекстыЗапросаКолонкиРезультирующий = Новый Массив;
	Для каждого ДанныеЗапросКлючевоеПоле Из МассивДанныхЗапросКлючевоеПоле Цикл
		// Заполним колонки результирующего пакета запроса
		ТекстыЗапросаКолонкиРезультирующий.Добавить(СтрШаблон("СУММА(%1)", ДанныеЗапросКлючевоеПоле.ИмяКлючевыхДанных));
		
		// Установим имена полей для пакета объединения
		ТекстЗапросаОбъединение = СтрЗаменить(ТекстЗапросаОбъединение,
			СтрШаблон("{%1}", МассивДанныхЗапросКлючевоеПоле.Найти(ДанныеЗапросКлючевоеПоле) + 1),
			ДанныеЗапросКлючевоеПоле.ИмяКлючевыхДанных);
	КонецЦикла;
	
	ТекстыРезультирующийПакет = Новый Массив;
	ТекстыРезультирующийПакет.Добавить("ВЫБРАТЬ SalesChannel, Counterparty, ProductGroup,");
	ТекстыРезультирующийПакет.Добавить(СтрСоединить(ТекстыЗапросаКолонкиРезультирующий, ","));
	ТекстыРезультирующийПакет.Добавить("ИЗ вт_ПланФактПоКаналам
		|СГРУППИРОВАТЬ ПО SalesChannel,Counterparty,ProductGroup");
	
	ТекстыЗапросов.Добавить(ТекстЗапросаОбъединение); // Получение данных по всем ключевым полям
	ТекстыЗапросов.Добавить(СтрСоединить(ТекстыРезультирующийПакет, " ")); // Результирующий пакет
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, ";");
	#КонецОбласти
	Запрос.УстановитьПараметр("ДатаНачала", Параметры["start_date"]);
	Запрос.УстановитьПараметр("ДатаОкончания", Параметры["end_date"]);
	Запрос.УстановитьПараметр("Подразделение", Справочники.Подразделения.НайтиПоКоду("SSP-0069 "));
	
	МассивДанных = Новый Массив;
	РезультатЗапроса = Запрос.Выполнить(); 
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтруктураДанных = Новый Структура;
		Для каждого Колонка из РезультатЗапроса.Колонки Цикл
			СтруктураДанных.Вставить(Колонка.Имя, Выборка[Колонка.Имя]);
		КонецЦикла;
		СтруктураДанных.Вставить("StartDate", Формат(Параметры["start_date"], "ДФ=yyyy-MM-dd"));
		СтруктураДанных.Вставить("EndDate", Формат(Параметры["end_date"], "ДФ=yyyy-MM-dd"));
		
		МассивДанных.Добавить(СтруктураДанных);
	КонецЦикла;
	
	Возврат МассивДанных;
	
КонецФункции // ФормированиеПланФактаПоКаналамВыполнитьНаСервере()

// Текст запроса количество факт текущий период.
// 
// Возвращаемое значение:
//  Строка - Текст запроса отгрузка комлпектующих товар без КМПЛ
Функция ТекстЗапросаКоличествоФактТекущийПериод()
	
	Возврат "ВЫБРАТЬ
	|	Спр.Ссылка КАК ПростоНоменклатура
	|ПОМЕСТИТЬ НоменклатураБезКМП
	|ИЗ
	|	Справочник.Номенклатура КАК Спр
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|		ПО НоменклатураКоплектующие.Ссылка = Спр.Ссылка
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка ЕСТЬ NULL
	|	И НЕ Спр.ЭтоГруппа
	|	И НЕ Спр.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|	И (Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|	ИЛИ Номенклатура.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|	ИЛИ Номенклатура.Родитель.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|	ИЛИ Номенклатура.Родитель.Родитель.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПростоНоменклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура_Коплектующие.Номенклатура КАК Комплектующее,
	|	СУММА(Номенклатура_Коплектующие.Количество) КАК Количество,
	|	Номенклатура_Коплектующие.Ссылка КАК НоменклатураКомпл
	|ПОМЕСТИТЬ ВТ_ТабКомплектующих
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК Номенклатура_Коплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура_Шапка
	|		ПО Номенклатура_Шапка.Ссылка = Номенклатура_Коплектующие.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураРодитель
	|		ПО НоменклатураРодитель.Ссылка = Номенклатура_Шапка.Родитель
	|		И НЕ НоменклатураРодитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура_Компл
	|		ПО Номенклатура_Компл.Ссылка = Номенклатура_Коплектующие.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура_КомплРодитель
	|		ПО Номенклатура_КомплРодитель.Ссылка = Номенклатура_Компл.Родитель
	|		И Номенклатура_КомплРодитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура_Коплектующие.Номенклатура,
	|	Номенклатура_Коплектующие.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НоменклатураКомпл,
	|	Комплектующее
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	уу.Отправитель КАК Counterparty,
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи КАК SalesChannel,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров КАК ProductGroup,
	|	СУММА(уу.КолРасх * уу.КоэфКомплКоличество - уу.КолПрих * уу.КоэфКомплКоличество) КАК ЗначениеКлючевогоПоля
	|ПОМЕСТИТЬ ActualQuantityCurrPeriod
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(ТаблицаПродажНачальная.КолРасх) КАК КолРасх,
	|		СУММА(ТаблицаПродажНачальная.КолПрих) КАК КолПрих,
	|		ТаблицаПродажНачальная.Отправитель КАК Отправитель,
	|		Комплектующие.Комплектующее КАК Комплектующее,
	|		ВЫБОР
	|			КОГДА ТаблицаПродажНачальная.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(перечисление.ВидыКомплектов.Комплект)
	|				ТОГДА Комплектующие.Количество
	|			ИНАЧЕ Комплектующие.Количество / Комплектующие.ВсегоКомпл
	|		КОНЕЦ КАК КоэфКомплКоличество
	|	ИЗ
	|		(ВЫБРАТЬ
	|			СУММА(ВЫБОР
	|				КОГДА Остатки.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|					ТОГДА Остатки.Количество
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК КолРасх,
	|			СУММА(ВЫБОР
	|				КОГДА Остатки.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|					ТОГДА Остатки.Количество
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК КолПрих,
	|			Остатки.Отправитель КАК Отправитель,
	|			Остатки.Номенклатура КАК Номенклатура
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ КАК Остатки
	|		ГДЕ
	|			Остатки.Период МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|			И Остатки.КодОперации В (ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя),
	|				ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Реализация),
	|				ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратПоставщику), ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Комиссия))
	|			И Остатки.Подразделение В ИЕРАРХИИ (&Подразделение)
	|		СГРУППИРОВАТЬ ПО
	|			Остатки.Отправитель,
	|			Остатки.Номенклатура
	|
	|		ОБЪЕДИНИТЬ ВСЕ
	|
	|		ВЫБРАТЬ
	|			ДвижениеТовараВнешнегоКонтрагентаТовары.КОтгрузке,
	|			0,
	|			NULL,
	|			ДвижениеТовараВнешнегоКонтрагентаТовары.Номенклатура
	|		ИЗ
	|			Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК ДвижениеТовараВнешнегоКонтрагентаТовары) КАК
	|			ТаблицаПродажНачальная
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				ии.Комплектующее КАК Комплектующее,
	|				ии.Количество КАК Количество,
	|				ии.НоменклатураКомпл КАК НоменклатураКомпл,
	|				аа.Количество КАК ВсегоКомпл
	|			ИЗ
	|				(ВЫБРАТЬ
	|					ВТ_ТабКомплектующих.Комплектующее КАК Комплектующее,
	|					ВТ_ТабКомплектующих.Количество КАК Количество,
	|					ВТ_ТабКомплектующих.НоменклатураКомпл КАК НоменклатураКомпл
	|				ИЗ
	|					ВТ_ТабКомплектующих КАК ВТ_ТабКомплектующих) КАК ии
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|						СУММА(ВТ_ТабКомплектующих.Количество) КАК Количество,
	|						ВТ_ТабКомплектующих.НоменклатураКомпл КАК НоменклатураКомпл
	|					ИЗ
	|						ВТ_ТабКомплектующих КАК ВТ_ТабКомплектующих
	|					СГРУППИРОВАТЬ ПО
	|						ВТ_ТабКомплектующих.НоменклатураКомпл) КАК аа
	|					ПО аа.НоменклатураКомпл = ии.НоменклатураКомпл
	|
	|			ОБЪЕДИНИТЬ ВСЕ
	|
	|			ВЫБРАТЬ
	|				НоменклатураБезКМП.ПростоНоменклатура,
	|				1,
	|				НоменклатураБезКМП.ПростоНоменклатура,
	|				1
	|			ИЗ
	|				НоменклатураБезКМП КАК НоменклатураБезКМП) КАК Комплектующие
	|			ПО ТаблицаПродажНачальная.Номенклатура = Комплектующие.НоменклатураКомпл
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаПродажНачальная.Отправитель,
	|		ТаблицаПродажНачальная.Номенклатура,
	|		Комплектующие.Комплектующее,
	|		Комплектующие.Количество,
	|		Комплектующие.ВсегоКомпл,
	|		ВЫБОР
	|			КОГДА ТаблицаПродажНачальная.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|				ТОГДА Комплектующие.Количество
	|			ИНАЧЕ Комплектующие.Количество / Комплектующие.ВсегоКомпл
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА ТаблицаПродажНачальная.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|				ТОГДА Комплектующие.Количество * Комплектующие.ВсегоКомпл
	|			ИНАЧЕ Комплектующие.Количество / Комплектующие.ВсегоКомпл
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА ТаблицаПродажНачальная.Номенклатура.ВидКомплекта = ЗНАЧЕНИЕ(перечисление.ВидыКомплектов.Комплект)
	|				ТОГДА Комплектующие.Количество
	|			ИНАЧЕ Комплектующие.Количество / Комплектующие.ВсегоКомпл
	|		КОНЕЦ) КАК уу
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеКонтрагентаИКаналаСбыта КАК вт_ДанныеКонтрагентаИКаналаСбыта
	|		ПО уу.Отправитель = вт_ДанныеКонтрагентаИКаналаСбыта.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПрародителиНоменклатуры КАК вт_ДанныеПрародителиНоменклатуры
	|		ПО уу.Комплектующее = вт_ДанныеПрародителиНоменклатуры.Номенклатура
	|ГДЕ
	|	НЕ вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров ЕСТЬ NULL
	|	И НЕ вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи ЕСТЬ NULL
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи,
	|	уу.Отправитель,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров";
	
КонецФункции // ТекстЗапросаОтгрузкаКомлпектующихТоварБезКМПЛ()

// Текст запроса сумма факт текущий период.
// 
// Возвращаемое значение:
//  Строка - Текст запроса сумма факт текущий период
Функция ТекстЗапросаСуммаФактТекущийПериод()
	
	Возврат "ВЫБРАТЬ
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи КАК SalesChannel,
	|	Остатки.Отправитель КАК Counterparty,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров КАК ProductGroup,
	|	СУММА(Остатки.Оборот) КАК ЗначениеКлючевогоПоля
	|ПОМЕСТИТЬ ActualAmountCurrPeriod
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеКонтрагентаИКаналаСбыта КАК вт_ДанныеКонтрагентаИКаналаСбыта
	|		ПО Остатки.Отправитель = вт_ДанныеКонтрагентаИКаналаСбыта.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПрародителиНоменклатуры КАК вт_ДанныеПрародителиНоменклатуры
	|		ПО Остатки.Номенклатура = вт_ДанныеПрародителиНоменклатуры.Номенклатура
	|ГДЕ
	|	Остатки.Период МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|	И Остатки.КодОперации В (ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя),
	|		ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Реализация))
	|	И НЕ вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров ЕСТЬ NULL
	|	И НЕ вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи ЕСТЬ NULL
	|	И Остатки.Подразделение В ИЕРАРХИИ (&Подразделение)
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи,
	|	Остатки.Отправитель,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров";
	
КонецФункции // ТекстЗапросаСуммаФактТекущийПериод()

// Текст запроса количество план текущий период.
// 
// Возвращаемое значение:
//  Строка - Текст запроса количество план текущий период
Функция ТекстЗапросаКоличествоПланТекущийПериод()
	
	Возврат "ВЫБРАТЬ
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи КАК SalesChannel,
	|	ПланПродаж.Контрагент КАК Counterparty,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров КАК ProductGroup,
	|	СУММА(ПланПродаж.Количество) КАК ЗначениеКлючевогоПоля
	|ПОМЕСТИТЬ PlannedQuantityCurrPeriod
	|ИЗ
	|	РегистрНакопления.ПланПродажШтуки КАК ПланПродаж
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеКонтрагентаИКаналаСбыта КАК вт_ДанныеКонтрагентаИКаналаСбыта
	|		ПО ПланПродаж.Контрагент = вт_ДанныеКонтрагентаИКаналаСбыта.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПрародителиНоменклатуры КАК вт_ДанныеПрародителиНоменклатуры
	|		ПО ПланПродаж.Номенклатура = вт_ДанныеПрародителиНоменклатуры.Номенклатура
	|ГДЕ
	|	ПланПродаж.Период МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|	И НЕ вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров ЕСТЬ NULL
	|	И НЕ вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи ЕСТЬ NULL
	|	И ПланПродаж.Подразделение В ИЕРАРХИИ (&Подразделение)
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи,
	|	ПланПродаж.Контрагент,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров";
	
КонецФункции // ТекстЗапросаКоличествоПланТекущийПериод()

// Текст запроса сумма план текущий период.
// 
// Возвращаемое значение:
//  Строка - Текст запроса сумма план текущий период
Функция ТекстЗапросаСуммаПланТекущийПериод()
	
	Возврат "ВЫБРАТЬ
	|	ПланПродаж.Номенклатура КАК Номенклатура,
	|	ПланПродаж.Контрагент КАК Контрагент,
	|	СУММА(ПланПродаж.Сумма) КАК Сумма
	|ПОМЕСТИТЬ вт_ИтоговыеДанныеПланПродаж
	|ИЗ
	|	РегистрНакопления.ПланПродаж КАК ПланПродаж
	|ГДЕ
	|	ПланПродаж.Период МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|	И ПланПродаж.Подразделение В ИЕРАРХИИ (&Подразделение)
	|СГРУППИРОВАТЬ ПО
	|	ПланПродаж.Номенклатура,
	|	ПланПродаж.Контрагент,
	|	ПланПродаж.Сумма
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПланПродаж.Номенклатура,
	|	ПланПродаж.Контрагент,
	|	СУММА(ПланПродаж.Сумма)
	|ИЗ
	|	РегистрНакопления.ПланПродаж2 КАК ПланПродаж
	|ГДЕ
	|	ПланПродаж.Период МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|СГРУППИРОВАТЬ ПО
	|	ПланПродаж.Номенклатура,
	|	ПланПродаж.Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи КАК SalesChannel,
	|	вт_ИтоговыеДанныеПланПродаж.Контрагент КАК Counterparty,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров КАК ProductGroup,
	|	СУММА(вт_ИтоговыеДанныеПланПродаж.Сумма) КАК ЗначениеКлючевогоПоля
	|ПОМЕСТИТЬ PlannedAmountCurrPeriod
	|ИЗ
	|	вт_ИтоговыеДанныеПланПродаж КАК вт_ИтоговыеДанныеПланПродаж
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеКонтрагентаИКаналаСбыта КАК вт_ДанныеКонтрагентаИКаналаСбыта
	|		ПО вт_ИтоговыеДанныеПланПродаж.Контрагент = вт_ДанныеКонтрагентаИКаналаСбыта.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПрародителиНоменклатуры КАК вт_ДанныеПрародителиНоменклатуры
	|		ПО вт_ИтоговыеДанныеПланПродаж.Номенклатура = вт_ДанныеПрародителиНоменклатуры.Номенклатура
	|ГДЕ
	|	НЕ вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров ЕСТЬ NULL
	|	И НЕ вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи ЕСТЬ NULL
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеКонтрагентаИКаналаСбыта.КаналПродажи,
	|	вт_ИтоговыеДанныеПланПродаж.Контрагент,
	|	вт_ДанныеПрародителиНоменклатуры.ГруппаТоваров";
	
КонецФункции // ТекстЗапросаСуммаПланТекущийПериод()

// Текст запроса прародители.
// 
// Параметры:
//  ИмяСправочника - Строка - Имя справочника
//  МаксимальнаяДлинаПути - Число - Максимальная длина пути
// 
// Возвращаемое значение:
//  Строка - Прародители
Функция ТекстЗапросаПрародители(ИмяСправочника, МаксимальнаяДлинаПути = 10)

	Пролог = "ВЫБРАТЬ Родитель НачалоДуги, Ссылка КонецДуги ПОМЕСТИТЬ ЗамыканияДлины1 ИЗ Справочник.Номенклатура
            | ГДЕ Родитель <> Значение(Справочник.Номенклатура.ПустаяСсылка)
            | ОБЪЕДИНИТЬ ВЫБРАТЬ Ссылка, Ссылка ИЗ Справочник.Номенклатура;";
    Рефрен = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПерваяДуга.НачалоДуги, ВтораяДуга.КонецДуги ПОМЕСТИТЬ ЗамыканияДлины#2 ИЗ ЗамыканияДлины#1 КАК ПерваяДуга
            | СОЕДИНЕНИЕ ЗамыканияДлины#1 КАК ВтораяДуга ПО ПерваяДуга.КонецДуги = ВтораяДуга.НачалоДуги;
            | УНИЧТОЖИТЬ ЗамыканияДлины#1;";
    Эпилог = "ВЫБРАТЬ НачалоДуги Предок, КонецДуги Потомок ПОМЕСТИТЬ ТаблицаДанных ИЗ ЗамыканияДлины#2
            | ГДЕ НачалоДуги <> КонецДуги И НачалоДуги.Родитель = Значение(Справочник.Номенклатура.ПустаяСсылка)";

    ТекстЗапроса = СтрЗаменить(Пролог, "Номенклатура", ИмяСправочника);

    МаксимальнаяДлинаЗамыканий = 1;
    Пока МаксимальнаяДлинаЗамыканий < МаксимальнаяДлинаПути Цикл
        ТекстЗапроса = ТекстЗапроса + СтрЗаменить(СтрЗаменить(Рефрен, "#1", Формат(МаксимальнаяДлинаЗамыканий, "ЧГ=0")), "#2", Формат(2 * МаксимальнаяДлинаЗамыканий, "ЧГ=0"));
        МаксимальнаяДлинаЗамыканий = 2 * МаксимальнаяДлинаЗамыканий;
    КонецЦикла;

    ТекстЗапроса = ТекстЗапроса + СтрЗаменить(СтрЗаменить(Эпилог, "Номенклатура", ИмяСправочника), "#2", Формат(МаксимальнаяДлинаЗамыканий, "ЧГ=0"));

    Возврат ТекстЗапроса;

КонецФункции // ТекстЗапросаПрародители()

// Преобразование данные для JSON.
// 
// Параметры:
//  Свойство - Строка - Имя свойство
//  Значение - Строка, Число, Булево, Дата, ЛюбаяСсылка - Значение свойства
//  ДополнительныеПараметры - Структура - Дополнительные параметры
//  Отказ - Булево - Отказ
// 
// Возвращаемое значение:
//  Строка, Число, Булево, Дата, ЛюбаяСсылка - Обработанные данные преобразования
Функция ПреобразованиеДанныеДляJSON(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт
	
	Если ТипЗнч(Значение) <> Тип("Число")
		Или ТипЗнч(Значение) <> Тип("Строка")
		Или ТипЗнч(Значение) <> Тип("Дата")
		Или ТипЗнч(Значение) <> Тип("Булево") Тогда
		Возврат Строка(Значение);
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции // ПреобразованиеДанныеДляJSON()
// Ихсанов Д. А. Конец 26.05.2026

#КонецОбласти

#Область Маркетплейсы_ОбщиеМетоды

// Создать документы предварительных заказов клиента.
// 
// Параметры:
//  ТаблицаДанных - ТаблицаЗначений, ДеревоЗначений - Таблица данных
//  ПараметрыОбработки - Структура - Параметры обработки
//  ОпределяемаяДатаОтгрузки - Неопределено, Дата - Определяемая дата отгрузки
//  ПолеГруппировкиЗаказа - Строка, Неопределено - Поле группировки по номеру заказа
Процедура СоздатьДокументыПредварительныхЗаказовКлиента(ТаблицаДанных, // ПараметрыОбработки...)
	ПараметрыОбработки, ОпределяемаяДатаОтгрузки = Неопределено, //)
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	ПолеГруппировкиЗаказа = Неопределено)
	
	Если ПолеГруппировкиЗаказа = Неопределено Тогда
		ПолеГруппировкиЗаказа = "РИД";
	КонецЕсли;
	// Ихсанов Д. А. Конец 18.06.2026
	
	ТЗЛимитпоСекторам = Новый ТаблицаЗначений;
	ТЗЛимитпоСекторам.Колонки.Добавить("СекторХранения");
	ТЗЛимитпоСекторам.Колонки.Добавить("Факт");
	
	ВременныеИнтервалыПолнойЗагрузки = Новый Массив;
	ЛимитПозиций = Ложь;
	ЛимитПоСекторам = Ложь;
	ПереносОтгрузки = 1;
	ПорогПростояНаСайте = 0;
	Для каждого Элемент из ПараметрыОбработки.ПараметрыЗадания Цикл
		Если Элемент.Ключ = "ЛимитПозиций" Тогда
			ЛимитПозиций = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ЛимитПоСекторам" Тогда
			ЛимитПоСекторам = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ПереносОтгрузки" Тогда
			ПереносОтгрузки = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ПорогПростояНаСайте" Тогда
			ПорогПростояНаСайте = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ВременныеИнтервалыПолнойЗагрузки" Тогда
			ВременныеИнтервалыПолнойЗагрузки = СтрРазделить(СтрЗаменить(Элемент.Значение, " ", ""), ",")
		КонецЕсли;
	КонецЦикла;
	
	// Выборка всех полей (*) из временной таблицы
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	// Доработка запроса под параметризуемое поле группировки заказов
	Запрос = Новый Запрос(СтрШаблон("ВЫБРАТЬ *
	|ПОМЕСТИТЬ вт_ДанныеПоЗаказам
	|ИЗ &ДанныеПоЗаказам КАК ДанныеПоЗаказам;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК СекторХранения
	|ИЗ
	|	вт_ДанныеПоЗаказам КАК вт_ДанныеПоЗаказам
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|		ПО вт_ДанныеПоЗаказам.Номенклатура.Родитель.Родитель.Родитель = РеквизитыСправочников.Справочник
	|			И (РеквизитыСправочников.ИмяРеквизита = ""СекторНоменклатуры"")
	|
	|УПОРЯДОЧИТЬ ПО
	|	СекторХранения
	|ИТОГИ ПО
	|	%1", ПолеГруппировкиЗаказа));
	// Ихсанов Д. А. Конец 18.06.2026
	Запрос.УстановитьПараметр("ДанныеПоЗаказам", ТаблицаДанных);
	
	ТаблицаСводная = ТаблицаДанных.СкопироватьКолонки();
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	// Доработка свертки таблицы под параметризуемое поле группировки заказов
	ТаблицаСводная.Свернуть(СтрШаблон("РИД,%1 Номенклатура",
		?(ПолеГруппировкиЗаказа = "РИД", "", СтрШаблон("%1,", ПолеГруппировкиЗаказа))), "Количество, СуммаЗак");
	// Ихсанов Д. А. Конец 18.06.2026
	ТаблицаСводная.Колонки.Добавить("СекторХранения", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(258)));
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		СписокСекторовНаЗаказ = Новый Массив;
		
		// Собираем данные по группе секторов от всей номенклатуры в заказе
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если СписокСекторовНаЗаказ.Найти(ВыборкаДетальныеЗаписи.СекторХранения) = Неопределено Тогда
				СписокСекторовНаЗаказ.Добавить(ВыборкаДетальныеЗаписи.СекторХранения);
			КонецЕсли;
		КонецЦикла;
		
		// Агрегируем данные в сводную таблицу
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрока = ТаблицаСводная.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи,, "СекторХранения");
			НоваяСтрока.СекторХранения = СтрСоединить(СписокСекторовНаЗаказ, " | ");
		КонецЦикла;
	КонецЦикла;
	
	ТаблицаСектора = ТаблицаСводная.Скопировать(,"СекторХранения");
	ТаблицаСектора.Свернуть("СекторХранения");
	Для каждого ДанныеСектора из ТаблицаСектора Цикл
		ТаблицаСводная_Доп = ТаблицаСводная.СкопироватьКолонки();
		ТоварПоСекторам = ТаблицаСводная.НайтиСтроки(Новый Структура("СекторХранения", ДанныеСектора.СекторХранения));
		Для Каждого ДанныеПоТовару из ТоварПоСекторам Цикл
			ЗаполнитьЗначенияСвойств(ТаблицаСводная_Доп.Добавить(), ДанныеПоТовару);
		КонецЦикла;
		
		// Выборка всех полей (*) из временной таблицы
		Запрос.Текст = "ВЫБРАТЬ *
		|ПОМЕСТИТЬ ДанныеПоЗаказам
		|ИЗ &ДанныеПоЗаказам КАК ДанныеПоЗаказам;
		|ВЫБРАТЬ
		|	ДанныеПоЗаказам.РИД КАК НомерЗаказа,
		|	ДанныеПоЗаказам.Номенклатура КАК Номенклатура,
		|	ДанныеПоЗаказам.Количество КАК Количество,
		|	ДанныеПоЗаказам.СуммаЗак КАК СуммаЗак,
		|	ДанныеНоменклатура.Родитель.Родитель.Родитель КАК Бренд
		|ПОМЕСТИТЬ вт_ДанныеПоЗаказам_Предварительная
		|ИЗ
		|	ДанныеПоЗаказам КАК ДанныеПоЗаказам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ДанныеНоменклатура
		|		ПО ДанныеПоЗаказам.Номенклатура = ДанныеНоменклатура.Ссылка
		|ГДЕ
		|	ДанныеПоЗаказам.СекторХранения = &СекторХранения
		|;
		|ВЫБРАТЬ
		|	вт_ДанныеПоЗаказам_Предварительная.НомерЗаказа КАК НомерЗаказа,
		|	вт_ДанныеПоЗаказам_Предварительная.Номенклатура КАК Номенклатура,
		|	вт_ДанныеПоЗаказам_Предварительная.Количество КАК Количество,
		|	вт_ДанныеПоЗаказам_Предварительная.СуммаЗак КАК СуммаЗак,
		|	вт_ДанныеПоЗаказам_Предварительная.Бренд КАК Бренд,
		|	РеквизитыСправочников.ЗначениеРеквизита КАК СекторХранения
		|ПОМЕСТИТЬ вт_ДанныеПоЗаказам
		|ИЗ
		|	вт_ДанныеПоЗаказам_Предварительная КАК вт_ДанныеПоЗаказам_Предварительная
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
		|		ПО вт_ДанныеПоЗаказам_Предварительная.Бренд = РеквизитыСправочников.Справочник
		|			И (РеквизитыСправочников.ИмяРеквизита = ""СекторНоменклатуры"")
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_ДанныеПоЗаказам.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(НоменклатураКоплектующие.Номенклатура, вт_ДанныеПоЗаказам.Номенклатура) КАК Комплектующее,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(НоменклатураКоплектующие.Количество, 0) = 0
		|			ТОГДА вт_ДанныеПоЗаказам.Количество
		|		ИНАЧЕ НоменклатураКоплектующие.Количество * вт_ДанныеПоЗаказам.Количество
		|	КОНЕЦ КАК Количество
		|ПОМЕСТИТЬ вт_Комплектующие
		|ИЗ
		|	вт_ДанныеПоЗаказам КАК вт_ДанныеПоЗаказам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|		ПО вт_ДанныеПоЗаказам.Номенклатура = НоменклатураКоплектующие.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОстаткиТМЦОстатки.Склад КАК Склад,
		|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
		|	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ПОМЕСТИТЬ вт_ОстаткиНаСкладах
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В (&Склад, &СкладМаркировки)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						вт_Комплектующие.Комплектующее
		|					ИЗ
		|						вт_Комплектующие)) КАК ОстаткиТМЦОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад В (&Склад, &СкладМаркировки)
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							вт_Комплектующие.Комплектующее
		|						ИЗ
		|							вт_Комплектующие)) КАК РезервыТМЦОстатки
		|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
		|			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
