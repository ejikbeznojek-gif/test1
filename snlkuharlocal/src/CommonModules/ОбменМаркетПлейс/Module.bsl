// Ихсанов Д. А. Начало 23.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
Процедура ЯндексМаркет_ОбработатьСозданиеДокументовПоЗаказамПЗК(МаркетПлейс, ТЗЗак1, ПараметрыЗадания,
	ДанныеМассивовЗаказов, ОпределяемаяДатаОтгрузки, ТекстОповещения) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	*,
	|	0 КАК КолНеТовар,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП1,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП2,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП3,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП4
	|ПОМЕСТИТЬ вт_ТЗЗак1
	|ИЗ
	|	&ТЗЗак1 КАК ТЗНомЗак
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ТЗЗак1.*
	|ИЗ
	|	вт_ТЗЗак1 КАК вт_ТЗЗак1
	|ГДЕ
	|	вт_ТЗЗак1.ДатаОтгрузки = &ДатаОтгрузки");
	Запрос.УстановитьПараметр("ТЗЗак1", ТЗЗак1);
	Запрос.УстановитьПараметр("ДатаОтгрузки", ОпределяемаяДатаОтгрузки);
	
	ТаблицаДанныхПоЗаказам = Запрос.Выполнить().Выгрузить();
	ТаблицаДанныхПоЗаказам = ОбменМаркетПлейс.МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТаблицаДанныхПоЗаказам);
	
	// НЕОПТИМАЛЬНОЕ ЛЕГАСИ
	Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ вт_ТаблицаДанных
	|ИЗ &ТаблицаДанных КАК ТаблицаДанных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА вт_ТаблицаДанных.КоличествоЭкземпляров > 1
	|			ТОГДА ИСТИНА
	|		КОГДА вт_ТаблицаДанных.Комплект И вт_ТаблицаДанных.КоличествоОстаток > 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ вт_ТаблицаДанных.Комплект
	|	КОНЕЦ КАК КомплектнаяПринадлежность,
	|	*
	|ПОМЕСТИТЬ вт_ТаблицаДанных_Комплекты
	|ИЗ вт_ТаблицаДанных КАК вт_ТаблицаДанных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ *
	|ИЗ вт_ТаблицаДанных_Комплекты КАК вт_ТаблицаДанных_Комплекты
	|ГДЕ вт_ТаблицаДанных_Комплекты.КомплектнаяПринадлежность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ *
	|ИЗ вт_ТаблицаДанных_Комплекты КАК вт_ТаблицаДанных_Комплекты
	|ГДЕ НЕ вт_ТаблицаДанных_Комплекты.КомплектнаяПринадлежность";
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанныхПоЗаказам);
	
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	МассивРезультатовЗапроса = Запрос.ВыполнитьПакет();
	Для Индекс = МассивРезультатовЗапроса.ВГраница() - 1 По МассивРезультатовЗапроса.ВГраница() Цикл
		РезультатЗапроса = МассивРезультатовЗапроса[Индекс];
		
		ТаблицаДанныхПоЗаказам = РезультатЗапроса.Выгрузить();
		МП_Яндекс_СоздатьДокументыПЗКНаСпайку(ТаблицаДанныхПоЗаказам,
			МаркетПлейс, ПараметрыЗадания, ТекстОповещения, ОпределяемаяДатаОтгрузки);
	КонецЦикла;
	// Ихсанов Д. А. Конец  17.03.2026
	
	Если МаркетПлейс.Тест Тогда
		Сообщить(ТекстОповещения);
		ЗаписатьВЛог("МП_ЯндексМаркет", НСтр("ru='Окончание выполнения. Задача: Загрузка заказов Яндекс!'"), "Информация")
	КонецЕсли;
	
КонецПроцедуры // ЯндексМаркет_ОбработатьСозданиеДокументовПоЗаказам()

Функция МП_Яндекс_СоздатьДокументыПЗКНаСпайку(ТаблицаДанных, МаркетПлейс, СтруктураПараметров, ТекстОповещения, ОпределяемаяДатаОтгрузки = Неопределено) Экспорт
	
	ТЗЛимитпоСекторам = Новый ТаблицаЗначений;
	ТЗЛимитпоСекторам.Колонки.Добавить("СекторХранения");
	ТЗЛимитпоСекторам.Колонки.Добавить("Факт");
	
	ВременныеИнтервалыПолнойЗагрузки = Новый Массив;
	ЛимитПозиций = Ложь; ЛимитПоСекторам = Ложь; ИнтеграторЧаса = Ложь;
	ОграничительЧаса = 0; ЧасНагрузки = 0; ПереносОтгрузки = 1; ПорогПростояНаСайте = 0;
	Для каждого Элемент из СтруктураПараметров Цикл
		Если Элемент.Ключ = "ЛимитПозиций" Тогда
			ЛимитПозиций = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ЛимитПоСекторам" Тогда
			ЛимитПоСекторам = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ОграничительЧаса" Тогда
			ОграничительЧаса = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ЧасНагрузки" Тогда
			ЧасНагрузки = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ИнтеграторЧаса" Тогда
			ИнтеграторЧаса = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ПереносОтгрузки" Тогда
			ПереносОтгрузки = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ПорогПростояНаСайте" Тогда
			ПорогПростояНаСайте = Элемент.Значение
		ИначеЕсли Элемент.Ключ = "ВременныеИнтервалыПолнойЗагрузки" Тогда
			ВременныеИнтервалыПолнойЗагрузки = СтрРазделить(СтрЗаменить(Элемент.Значение, " ", ""), ",")
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос("ВЫБРАТЬ *
	|ПОМЕСТИТЬ вт_ДанныеПоЗаказам
	|ИЗ &ДанныеПоЗаказам КАК ДанныеПоЗаказам;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК СекторХранения
	|ИЗ
	|	вт_ДанныеПоЗаказам КАК вт_ДанныеПоЗаказам
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|		ПО вт_ДанныеПоЗаказам.Номенклатура.Родитель.Родитель.Родитель = РеквизитыСправочников.Справочник
	|			И (РеквизитыСправочников.ИмяРеквизита = ""СекторНоменклатуры"")
	|
	|УПОРЯДОЧИТЬ ПО
	|	СекторХранения
	|ИТОГИ ПО
	|	РИД");
	Запрос.УстановитьПараметр("ДанныеПоЗаказам", ТаблицаДанных);
	
	ТаблицаСводная = ТаблицаДанных.СкопироватьКолонки();
	ТаблицаСводная.Свернуть("РИД, Номенклатура", "Количество, СуммаЗак");
	ТаблицаСводная.Колонки.Добавить("СекторХранения", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(258)));
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		СписокСекторовНаЗаказ = Новый Массив;
		
		// Собираем данные по группе секторов от всей номенклатуры в заказе
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если СписокСекторовНаЗаказ.Найти(ВыборкаДетальныеЗаписи.СекторХранения) = Неопределено Тогда
				СписокСекторовНаЗаказ.Добавить(ВыборкаДетальныеЗаписи.СекторХранения);
			КонецЕсли;
		КонецЦикла;
		
		// Агрегируем данные в сводную таблицу
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрока = ТаблицаСводная.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи,, "СекторХранения");
			НоваяСтрока.СекторХранения = СтрСоединить(СписокСекторовНаЗаказ, " | ");
		КонецЦикла;
	КонецЦикла;
	
	ТаблицаСектора = ТаблицаСводная.Скопировать(,"СекторХранения");
	ТаблицаСектора.Свернуть("СекторХранения");
	Для каждого ДанныеСектора из ТаблицаСектора Цикл
		ТаблицаСводная_Доп = ТаблицаСводная.СкопироватьКолонки();
		ТоварПоСекторам = ТаблицаСводная.НайтиСтроки(Новый Структура("СекторХранения", ДанныеСектора.СекторХранения));
		Для Каждого ДанныеПоТовару из ТоварПоСекторам Цикл
			ЗаполнитьЗначенияСвойств(ТаблицаСводная_Доп.Добавить(), ДанныеПоТовару);
		КонецЦикла;
		
		Запрос.Текст = "ВЫБРАТЬ *
		|ПОМЕСТИТЬ ДанныеПоЗаказам
		|ИЗ &ДанныеПоЗаказам КАК ДанныеПоЗаказам;
		|ВЫБРАТЬ
		|	ДанныеПоЗаказам.РИД КАК НомерЗаказа,
		|	ДанныеПоЗаказам.Номенклатура КАК Номенклатура,
		// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
		|	ДанныеПоЗаказам.Количество КАК Количество,
		// Ихсанов Д. А. Конец  17.03.2025
		|	ДанныеПоЗаказам.СуммаЗак КАК СуммаЗак,
		|	ДанныеНоменклатура.Родитель.Родитель.Родитель КАК Бренд
		|ПОМЕСТИТЬ вт_ДанныеПоЗаказам_Предварительная
		|ИЗ
		|	ДанныеПоЗаказам КАК ДанныеПоЗаказам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ДанныеНоменклатура
		|		ПО ДанныеПоЗаказам.Номенклатура = ДанныеНоменклатура.Ссылка
		|ГДЕ
		|	ДанныеПоЗаказам.СекторХранения = &СекторХранения
		|;
		|ВЫБРАТЬ
		|	вт_ДанныеПоЗаказам_Предварительная.НомерЗаказа КАК НомерЗаказа,
		|	вт_ДанныеПоЗаказам_Предварительная.Номенклатура КАК Номенклатура,
		|	вт_ДанныеПоЗаказам_Предварительная.Количество КАК Количество,
		|	вт_ДанныеПоЗаказам_Предварительная.СуммаЗак КАК СуммаЗак,
		|	вт_ДанныеПоЗаказам_Предварительная.Бренд КАК Бренд,
		|	РеквизитыСправочников.ЗначениеРеквизита КАК СекторХранения
		|ПОМЕСТИТЬ вт_ДанныеПоЗаказам
		|ИЗ
		|	вт_ДанныеПоЗаказам_Предварительная КАК вт_ДанныеПоЗаказам_Предварительная
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
		|		ПО вт_ДанныеПоЗаказам_Предварительная.Бренд = РеквизитыСправочников.Справочник
		|			И (РеквизитыСправочников.ИмяРеквизита = ""СекторНоменклатуры"")
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_ДанныеПоЗаказам.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(НоменклатураКоплектующие.Номенклатура, вт_ДанныеПоЗаказам.Номенклатура) КАК Комплектующее,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(НоменклатураКоплектующие.Количество, 0) = 0
		|			ТОГДА вт_ДанныеПоЗаказам.Количество
		|		ИНАЧЕ НоменклатураКоплектующие.Количество * вт_ДанныеПоЗаказам.Количество
		|	КОНЕЦ КАК Количество
		|ПОМЕСТИТЬ вт_Комплектующие
		|ИЗ
		|	вт_ДанныеПоЗаказам КАК вт_ДанныеПоЗаказам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		|		ПО вт_ДанныеПоЗаказам.Номенклатура = НоменклатураКоплектующие.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОстаткиТМЦОстатки.Склад КАК Склад,
		|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
		|	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ПОМЕСТИТЬ вт_ОстаткиНаСкладах
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В (&Склад, &СкладМаркировки)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						вт_Комплектующие.Комплектующее
		|					ИЗ
		|						вт_Комплектующие)) КАК ОстаткиТМЦОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад В (&Склад, &СкладМаркировки)
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							вт_Комплектующие.Комплектующее
		|						ИЗ
		|							вт_Комплектующие)) КАК РезервыТМЦОстатки
		|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
		|			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_Комплектующие.Номенклатура КАК Номенклатура,
		|	СУММА(вт_Комплектующие.Количество) КАК Количество,
		|	СУММА(ЕСТЬNULL(вт_ОстаткиНаСкладах.КоличествоОстаток, 0)) КАК КоличествоОстаток
		|ИЗ
		|	вт_Комплектующие КАК вт_Комплектующие
		|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ОстаткиНаСкладах КАК вт_ОстаткиНаСкладах
		|		ПО вт_Комплектующие.Комплектующее = вт_ОстаткиНаСкладах.Номенклатура
		|			И вт_ОстаткиНаСкладах.Склад = &Склад
		|ГДЕ
		|	вт_Комплектующие.Количество > ЕСТЬNULL(вт_ОстаткиНаСкладах.КоличествоОстаток, 0)
		|
		|СГРУППИРОВАТЬ ПО
		|	вт_Комплектующие.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_Комплектующие.Номенклатура КАК Номенклатура,
		|	СУММА(вт_Комплектующие.Количество) КАК Количество,
		|	СУММА(ЕСТЬNULL(вт_ОстаткиНаСкладах.КоличествоОстаток, 0)) КАК КоличествоОстаток
		|ИЗ
		|	вт_Комплектующие КАК вт_Комплектующие
		|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ОстаткиНаСкладах КАК вт_ОстаткиНаСкладах
		|		ПО вт_Комплектующие.Комплектующее = вт_ОстаткиНаСкладах.Номенклатура
		|			И вт_ОстаткиНаСкладах.Склад = &СкладМаркировки
		|ГДЕ
		|	вт_Комплектующие.Количество > ЕСТЬNULL(вт_ОстаткиНаСкладах.КоличествоОстаток, 0)
		|
		|СГРУППИРОВАТЬ ПО
		|	вт_Комплектующие.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_ДанныеПоЗаказам.Номенклатура КАК Номенклатура,
		// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
		|	вт_ДанныеПоЗаказам.НомерЗаказа КАК НомерЗаказа,
		// Ихсанов Д. А. Конец  17.03.2025
		|	вт_ДанныеПоЗаказам.Количество КАК КолКонФакт
		|ИЗ
		|	вт_ДанныеПоЗаказам КАК вт_ДанныеПоЗаказам";
		// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
		Запрос.УстановитьПараметр("ДанныеПоЗаказам", ТаблицаСводная_Доп);
		// Ихсанов Д. А. Конец  17.03.2025
		Запрос.УстановитьПараметр("Склад",			 МаркетПлейс.Склад);
		Запрос.УстановитьПараметр("СкладМаркировки", МаркетПлейс.СкладМаркировки);
		Запрос.УстановитьПараметр("СекторХранения",  ДанныеСектора.СекторХранения);
		
		СкладДляРНК = МаркетПлейс.СкладМаркировки;
		РезультатыЗапроса = Запрос.ВыполнитьПакет();                                                                                                                                                   
		
		ЛимитПозиций = 0;
		Если МаркетПлейс.РазбиватьПоЛимитуКоличество Тогда
			ЛимитПозиций = МаркетПлейс.ЛимитПоКоличеству;
		КонецЕсли;
		
		СостояниеВРаботе = Перечисления.СостоянияНакладной.ВРаботе;
		СостояниеНаСклад = Перечисления.СостоянияНакладной.КОтправкеНаСклад;
		
		Если ПорогПростояНаСайте > 0 И ПорогПростояНаСайте < ТаблицаДанных.Количество()
			И ВременныеИнтервалыПолнойЗагрузки.Количество() > 0
			И ВременныеИнтервалыПолнойЗагрузки.Найти(Час(ТекущаяДатаСеанса())) = Неопределено Тогда
			Продолжить
		КонецЕсли;
		
		ТаблицаКомплектующие = РезультатыЗапроса[РезультатыЗапроса.ВГраница()].Выгрузить();
		// Ихсанов Д. А. Начало 02.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
		ПолученныйЗаказ = СформироватьПредварительныйЗаказКлиента(МаркетПлейс, СкладДляРНК,
			МаркетПлейс.СкладРезерваМаркировки, ТаблицаДанных, ТаблицаКомплектующие, Истина, ЛимитПозиций,
			// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
				СостояниеНаСклад, ДанныеСектора.СекторХранения, ПереносОтгрузки, Истина, ТекстОповещения, ОпределяемаяДатаОтгрузки);
			// Ихсанов Д. А. Конец  17.03.2025
		// Ихсанов Д. А. Конец 02.09.2025
		
		Если ЛимитПоСекторам Тогда      
			КоличествоПоСектору = ТаблицаКомплектующие.Итог("КолКонФакт"); 
			Если КоличествоПоСектору > 0 Тогда
				НовЛимитСектора = ТЗлимитпоСекторам.Добавить();
				НовЛимитСектора.СекторХранения = ДанныеСектора.СекторХранения;
				НовЛимитСектора.Факт           = КоличествоПоСектору;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ЛимитПоСекторам Тогда  
		Если ТЗлимитпоСекторам.Количество() Тогда
			ДобавитьКоличествоПоСектору(МаркетПлейс, ТЗлимитпоСекторам);
		КонецЕсли;
	КонецЕсли;
	
	Если ТаблицаДанных.Количество() > 0 Тогда
		ЗаписатьВЛог("МП_ЯндексМаркет", "Проверить таблица СПАЙКА не обнулена !" + Строка(ТаблицаДанных.Количество()), "Ошибка");
	КонецЕсли; 
	
	Возврат 0;
	
КонецФункции
