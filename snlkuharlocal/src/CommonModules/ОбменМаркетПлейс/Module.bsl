			Найды=ТЗЗак.НайтиСтроки(Новый Структура("Номенклатура",ТНом));
			Для Каждого Найд Из Найды Цикл
				НСЗ=ТекЗак.Товары.Добавить();
				НСЗ.АртикулКонтрагента=Найд.АртКонтра;
				НСЗ.Количество=Найд.КолвоЗак;
				НСЗ.Заявка=Найд.КолвоЗак;
				НСЗ.Номенклатура=ТНом;
				НСЗ.Цена=Найд.СуммаЗак;
				НСЗ.НомерЗаказа=Найд.ИДЗаказа;
				НСЗ.ДатаЗаказа=Найд.ДатаСоздания;
				НСЗ.РИД=Найд.РИД;
			КонецЦикла;	
			ТекЗак.Дата=ТекущаяДатаСеанса();
			ТекЗак.Контрагент=МкПл.Контрагент;
			
			ТекЗак.УстановитьНовыйНомер();
			Если ТекДок.ПометкаУдаления Тогда
				ТекЗак.Записать(РежимЗаписиДокумента.Запись);
			Иначе
				ТекЗак.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			Если МасЗак.Найти(ТекЗак.Ссылка)=неопределено Тогда
				МасЗак.Добавить(ТекЗак.Ссылка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат МасЗак;
КонецФункции	

