Функция МП_ОЗОН_ВернутьСтруктуруДляUnfulfilled(Маркетплейс,Смещение=0,НужныйСтатус="awaiting_packaging") Экспорт
	
	// /v3/posting/fbs/unfulfilled/list
	
	//{
	//"dir": "ASC",
	//"filter": {
	//           "cutoff_from": "2025-03-20T14:15:22Z",
	//           "cutoff_to": "2025-03-31T14:15:22Z",
	//           "is_quantum": false,
	//           "status": "awaiting_packaging",
	//           "warehouse_id": [19791964666000]
	//},
	//"limit": 100,
	//"offset": 0,
	//"with": {
	//         "analytics_data": false,
	//         "barcodes": false,
	//         "financial_data": false,
	//         "translit": false
	//         }
	//}
	ДатаС = ТекущаяДата()- 5*86400;
	
	СтруктураТелаЗапроса   = Новый Структура;
	
	СтруктураТелаЗапроса.Вставить("dir","ASC");
	
	filter = Новый Структура;
	filter.Вставить("cutoff_from", Формат(ДатаС,        "ДФ=yyyy-MM-ddT00:00:00.000Z"));
	filter.Вставить("cutoff_to",   Формат(ТекущаяДата(),"ДФ=yyyy-MM-ddT23:59:59.000Z"));
	filter.Вставить("is_quantum",  False);
	filter.Вставить("status",      НужныйСтатус);
	
	warehouse_id          = Новый Массив;
	warehouse_id.Добавить(Маркетплейс.WarehouseId);
	filter.Вставить("warehouse_id", warehouse_id);
	
	СтруктураТелаЗапроса.Вставить("filter",  filter);
	СтруктураТелаЗапроса.Вставить("limit",   900);
	СтруктураТелаЗапроса.Вставить("offset",  Формат(Смещение,"ЧДЦ=0; ЧН=0; ЧГ=0"));
	
	Стрwith = Новый Структура;
	Стрwith.Вставить("analytics_data" , False);
	Стрwith.Вставить("barcodes" ,       False);
	Стрwith.Вставить("financial_data" , False);
	Стрwith.Вставить("translit" ,       False);
	
	СтруктураТелаЗапроса.Вставить("with", Стрwith);
	
	ТелоЗапроса="";
	
	ТелоЗапроса          =  МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Авто,ЭкранированиеСимволовJSON.Нет);
	
	Возврат ТелоЗапроса;
	
КонецФункции

Функция МП_ОЗОН_КонтрольКоличестваЗаказов(МаркетПлейс) Экспорт 
	
	КоличествоНовыхЗаказов=0;
	
	Команда      ="/v3/posting/fbs/unfulfilled/list";
	НужныйСтатус ="awaiting_packaging";
	
	ТЗЗаказыССайта = Новый ТаблицаЗначений;  
	
	КвалификаторыСтроки = Новый КвалификаторыСтроки(30);
	ОписаниеСтроки = Новый ОписаниеТипов("Строка", ,КвалификаторыСтроки);
	
	ТЗЗаказыССайта.Колонки.Добавить("posting_number",  ОписаниеСтроки );
	ТЗЗаказыССайта.Колонки.Добавить("in_process_at",   ОписаниеСтроки );	
	
	Смещение =0;      
	КолвоЗаказов = 0;
	Пока истина Цикл
		
		СтруктураЗапроса = МП_ОЗОН_ВернутьСтруктуруДляUnfulfilled(Маркетплейс,Смещение,НужныйСтатус);	
		Смещение=Смещение+900;
		
		Результат = POSTЗапросИз1С_ДжС(МаркетПлейс,Команда,СтруктураЗапроса);
		
		Если Результат=неопределено Тогда
			КолвоЗаказов = 0;
			Возврат 0;
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;	
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
		
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); 		
		
		Если Данные.Свойство("result") Тогда   		
			
			Если Данные.result.Свойство("count") Тогда
				КолвоЗаказов=Данные.result.count;
				КоличествоНовыхЗаказов=КоличествоНовыхЗаказов+КолвоЗаказов; 	
				
			Иначе
				КолвоЗаказов=0; 
				Возврат 0;
			КонецЕсли;				
			
			РезультатЗапроса = Данные.result; 
			
			Если РезультатЗапроса.Свойство("postings") Тогда
				
				МассивЗаказов = РезультатЗапроса.postings;			
				
				ТаблицаПоставок= ПреобразованиеМассивВТаблицуЗначений(МассивЗаказов);
				
				Если ТаблицаПоставок.КОличество()>0 Тогда
					
					Для каждого стрТЗ из ТаблицаПоставок Цикл
						НовСтр = ТЗЗаказыССайта.Добавить();
						ЗаполнитьЗначенияСвойств(НовСтр,СТрТЗ);				 
					КонецЦикла;    			
					
				КонецЕсли; 			
				
			КонецЕсли; 
			
		КонецЕсли;  		
		
		Если КолвоЗаказов<=Смещение Тогда
			Прервать;
		КОнецЕсли;    	
		
	КонецЦикла;
	
	Если ТЗЗаказыССайта.Количество()>0 Тогда   
		
		НачДата = ПрочитатьДатуJSON(ТЗЗаказыССайта[0].in_process_at,ФорматДатыJSON.ISO); 
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(ЗаказКлиентаFBSТовары.НомерЗаказа КАК СТРОКА(30)) КАК НомерЗаказа
		|ПОМЕСТИТЬ ВТ_В_БАЗЕ
		|ИЗ
		|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
		|ГДЕ
		|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
		|	И ЗаказКлиентаFBSТовары.Ссылка.Проведен
		|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МассивССайта.posting_number КАК posting_number
		|ПОМЕСТИТЬ ВТ_С_САЙТА
		|ИЗ
		|	&ТЗЗаказыССайта КАК МассивССайта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_С_САЙТА.posting_number КАК posting_number
		|ИЗ
		|	ВТ_С_САЙТА КАК ВТ_С_САЙТА
		|ГДЕ
		|	НЕ ВТ_С_САЙТА.posting_number В
		|				(ВЫБРАТЬ
		|					ВТ_В_БАЗЕ.НомерЗаказа КАК НомерЗаказа
		|				ИЗ
		|					ВТ_В_БАЗЕ КАК ВТ_В_БАЗЕ)
		|";
		
		Запрос.УстановитьПараметр("Контрагент",    Маркетплейс.Контрагент);// Не определено
		Запрос.УстановитьПараметр("НачДата",       НачДата);// Не определено
		Запрос.УстановитьПараметр("КонДата",       ТекущаяДата());// Не определено
		Запрос.УстановитьПараметр("ТЗЗаказыССайта",ТЗЗаказыССайта);// Не определено
		
		Результат = Запрос.Выполнить().Выгрузить();
		
		Возврат Результат.Количество();
		
	КонецЕсли;  	             	
	
	Возврат КоличествоНовыхЗаказов;
	
КонецФункции  

#КонецОбласти

#Область МП_ОЗОН_ПОВТОРНО_ТИМОФЕЕВ

Функция МП_ОЗОН_ПОВТОРНО_statusНажатие(МаркПл,НомерОтправления,ИзОбработки=Ложь) Экспорт    	
	
	ЕстьЭтикетка = Ложь;	
	//Команда = "/v4/fbs/posting/product/exemplar/status";
	
	Команда = "/v5/fbs/posting/product/exemplar/status";
	
	СтруктураТелаЗапроса = Новый Структура("posting_number",СокрЛП(НомерОтправления));		
	
	ТелоЗапроса           = МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Нет,ЭкранированиеСимволовJSON.Нет);
	Ответ                 = POSTЗапросИз1С_ДжС(МаркПл,Команда,ТелоЗапроса); 
	ПолученныйОтвет       = Ответ.ПолучитьТелоКакСтроку();
	
	Если Ответ.КодСостояния<400 Тогда    		
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ПолученныйОтвет);
		
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); 
		
		Если данные.свойство("status") Тогда
			//Статус проверки всех экземпляров и доступности сборки:	
			//ship_available — сборка доступна,
			//ship_not_available — сборка недоступна,
			//validation_in_process — экземпляры на проверке.
			
			Если Данные.status="ship_available" или Данные.status="update_available" или Данные.status="ship_not_available" Тогда
				
				//сборка доступна 
				//1.получим ТЗ и create-or-get
				ТЗЭКЗЕМЛЯРОВ = МП_ОЗОН_ПОВТОРНО_createorget(МаркПл,НомерОтправления,ИзОбработки);
				
				Если ТЗЭКЗЕМЛЯРОВ<>Неопределено Тогда
					//2.Привязка марок
					Если МП_ОЗОН_ПОВТОРНО_exemplar_set(МаркПл,НомерОтправления,ТЗЭКЗЕМЛЯРОВ,ИзОбработки) Тогда
						//3 Собрать заказа
						Если МП_ОЗОН_ПОВТОРНО_ship(МаркПл,НомерОтправления,ТЗЭКЗЕМЛЯРОВ,ИзОбработки) Тогда
							//4 печататаем этикетку
							ЕстьЭтикетка= МП_ОЗОН_ПОВТОРНО_ПолучитьЭтикетку(МаркПл,НомерОтправления,ИзОбработки);
							
						КонецЕсли;		
						
					КонецЕсли;	
				КонецЕсли;
				
			ИначеЕсли Данные.status="validation_in_process" Тогда	
				
				ЗаписатьВЛог("МП_ОЗОН","Статус задания на проверке! : "+Строка(НомерОтправления),"Информация");
				Сообщить("Статус задания на проверке! : "+Строка(НомерОтправления));
			КонецЕсли;	
		Иначе
			
			Если Данные.message="Posting must have 'awaiting_packaging' status" Тогда
				//уже закрыт можно печатать
				ЕстьЭтикетка=МП_ОЗОН_ПОВТОРНО_ПолучитьЭтикетку(МаркПл,НомерОтправления,ИзОбработки);
				
			Иначе		     		
				Сообщить("Ошибка "+Данные.message); 		
			КонецЕсли;
			
		КонецЕсли; 
	Иначе
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ПолученныйОтвет);		
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь);    		
		ЗаписатьВЛог("МП_ОЗОН","Заказ нельзя собирать ПОВТОРНО: "+Строка(НомерОтправления)+" "+"ОТВЕТ "+Строка(Ответ.КодСостояния)+"Ошибка :" +Данные.message ,"Ошибка");
	КонецЕсли; 
	
	Возврат ЕстьЭтикетка
	
КонецФункции

