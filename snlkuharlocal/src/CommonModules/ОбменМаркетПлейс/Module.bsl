Функция МП_ОЗОН_ПолучитьЭкземлярыДляМаркировки(Маркетплейс, НомерОтправления) Экспорт
	
	// Ихсанов Д. А. Начало 11.12.2025 Без номера задачи
	// 6-я версия метода
	СообщениеОбОшибке = "";
	
	НовТЗМарки = Новый ТаблицаЗначений;
	НовТЗМарки.Колонки.Добавить("product_id");
	НовТЗМарки.Колонки.Добавить("exemplars_id");
	НовТЗМарки.Колонки.Добавить("quantity");
	НовТЗМарки.Колонки.Добавить("marka");
	НовТЗМарки.Колонки.Добавить("МаркаНеНужна");
	
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("posting_number", НомерОтправления);
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON);
	ПараметрыОбработки.ДанныеЗапроса.Метод = "POST";
	ПараметрыОбработки.ИменаСвойствОшибок = "code";
	ПараметрыОбработки.ЗначенияСвойствОшибок = "0";
	
	ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
		ОбменМаркетПлейс.МП_Озон_ВернутьСоединение(Маркетплейс),
		ОбменМаркетПлейс.ПолучитьЗаголовкиОзон(Маркетплейс),
		"/v6/fbs/posting/product/exemplar/create-or-get",
		ПараметрыОбработки, Ложь, Ложь);
	Если Не ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки)
		Или Не ДанныеОтвета.Свойство("products") Тогда
		Возврат НовТЗМарки
	КонецЕсли;
	
	Для каждого ДанныеТовара из ДанныеОтвета.products Цикл
		Для каждого ДанныеЭкземпляра из ДанныеТовара.exemplars Цикл
			НоваяСтрока = НовТЗМарки.Добавить();
			НоваяСтрока.product_id	 = ДанныеТовара.product_id;
			НоваяСтрока.exemplars_id = ДанныеЭкземпляра.exemplar_id;
			НоваяСтрока.marka		 = "";
			НоваяСтрока.quantity	 = 1;
			НоваяСтрока.МаркаНеНужна = ДанныеТовара.is_mandatory_mark_needed
		КонецЦикла
	КонецЦикла;
	
	Возврат НовТЗМарки
	// Ихсанов Д. А. Конец 11.12.2025
	
КонецФункции

Функция МП_ОЗОН_привязать_Маркировку(Маркетплейс, НомерОтправления, ТЗДАННЫХ, КодМаркировки = Неопределено) Экспорт
	
	// Ихсанов Д. А. Начало 05.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7714
	// 6-я версия прикрепления маркировки к заказу
	// Предыдущая версия функционала была упразднена
	СообщениеОбОшибке = "";
	
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("multi_box_qty", 1);
	ДанныеДляJSON.Вставить("posting_number", НомерОтправления);
	ДанныеДляJSON.Вставить("products", Новый Массив);
	Для каждого СтрокаТаблицыДанных из ТЗДАННЫХ Цикл
		СтруктураТовара = Новый Структура;
		СтруктураТовара.Вставить("exemplars", Новый Массив);
		СтруктураТовара.Вставить("product_id", СтрокаТаблицыДанных.product_id);
		
		СтруктураЭкземпляра = Новый Структура;
		СтруктураЭкземпляра.Вставить("exemplar_id", СтрокаТаблицыДанных.exemplars_id);
		СтруктураЭкземпляра.Вставить("gtd", "");
		СтруктураЭкземпляра.Вставить("is_gtd_absent", Истина);
		СтруктураЭкземпляра.Вставить("is_rnpt_absent", Истина);
		СтруктураЭкземпляра.Вставить("marks", Новый Массив);
		СтруктураЭкземпляра.Вставить("rnpt", "");
		СтруктураЭкземпляра.Вставить("weight", 0);
		
		Если КодМаркировки <> Неопределено Тогда
			СтруктураКодовМаркировки = Новый Структура;
			СтруктураКодовМаркировки.Вставить("mark", КодМаркировки);
			СтруктураКодовМаркировки.Вставить("mark_type", "mandatory_mark");
			
			СтруктураЭкземпляра.marks.Добавить(СтруктураКодовМаркировки);
		КонецЕсли;
		
		СтруктураТовара.exemplars.Добавить(СтруктураЭкземпляра);
		ДанныеДляJSON.products.Добавить(СтруктураТовара);
	КонецЦикла;
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод = "POST";
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON);
	ПараметрыОбработки.ИменаСвойствОшибок = "code";
	ПараметрыОбработки.ЗначенияСвойствОшибок = "0";
	
	ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
		ОбменМаркетПлейс.МП_Озон_ВернутьСоединение(Маркетплейс),
		ОбменМаркетПлейс.ПолучитьЗаголовкиОзон(Маркетплейс),
		"/v6/fbs/posting/product/exemplar/set",
		ПараметрыОбработки, Ложь, Ложь);
	Если ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки) Тогда
		СообщитьИзМодуля(СтрШаблон("Привязка марки к заказу: %1. Марка привязана.", НомерОтправления));
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН", СтрШаблон("Привязка марки к заказу: %1. Марка привязана.", НомерОтправления), "Информация")
		КонецЕсли;
		Возврат Истина
	Иначе
		СообщитьИзМодуля(СтрШаблон("Привязка марки к заказу: %1. %2",
			НомерОтправления, СообщениеОбОшибке));
		ЗаписатьВЛог("МП_ОЗОН", СтрШаблон("Привязка марки к заказу: %1. %2",
			НомерОтправления, СообщениеОбОшибке), "Ошибка");
		Возврат Ложь
	КонецЕсли;
	
КонецФункции

