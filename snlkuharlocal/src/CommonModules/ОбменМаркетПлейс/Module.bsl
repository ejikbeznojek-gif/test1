	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBS
	|ГДЕ
	|	ЗаказКлиентаFBS.Ссылка.Проведен = ИСТИНА
	|	И ЗаказКлиентаFBS.Ссылка.Контрагент = &Вайлдб
	|	И ЗаказКлиентаFBS.Ссылка.ДокОснование.ДатаОтгрузки < &датаотгрузки
	|	И ЗаказКлиентаFBS.Ссылка.Дата >= &ДатаДок
	|	И ЗаказКлиентаFBS.СостояниеУКлиента <> &Статус";
	запрос.УстановитьПараметр("Датадок",ТекущаяДата() - 7*ДеньВСекундах);
	запрос.УстановитьПараметр("Вайлдб", МаркПл.Контрагент);
	запрос.УстановитьПараметр("датаотгрузки",НачалоДня(ТекущаяДата()));
	запрос.УстановитьПараметр("Статус",Статус);
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока рез.Следующий() цикл
		
		РНК = Рез.ссылка.ДокОснование;
		СостояниеНакладной = РНК.состояниеНакладной;
		# если клиент тогда
			сообщить(рез.ссылка);
		# конецЕсли
		
		Если (СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена  или СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке) 
			//или СостояниеНакладной = Перечисления.СостоянияНакладной.Паллетирование или СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеПаллетирования)
			//и НЕ РНК.ПереданПокупателюВЭлВиде         //    тогда
			тогда	
			
			//СобратьЗаказы(РНК,2);
			РезП=ВыгрузитьСтатусыМкПл(Рез.Ссылка,МаркПл,"2",Тест);
			Если РезП=2 Тогда
				Если НЕ Тест Тогда
					ДокОб=Рез.Ссылка.ПолучитьОбъект();
					Для Каждого ТСтр Из ДокОб.Товары Цикл
						ТСтр.СостояниеУКлиента=Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(Статус);
					КонецЦикла;	
					ДокОб.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;
	
	
	
КонецПроцедуры

