// Функция - Яндекс маркет получить данные этикетки с сайта
//
// Параметры:
//  МаркетПлейс			 - СправочникСсылка.ИнетМагазины - Данные с реквизитами справочника Интернет Магазины
//  НомерЗаказа			 - Строка						 - Номер заказа в модели сервиса
//  НомерОтгрузки		 - Строка						 - Номер отгрузки в модели сервиса
//  НомерПосылки		 - Строка						 - Номер посылки в модели сервиса
// 
// Возвращаемое значение:
//  ДвоичныеДанные - Файл PDF в формате двоичных данных
//
Функция  ЯндексМаркет_ПолучитьДанныеЭтикеткиССайта(МаркетПлейс, НомерЗаказа, НомерОтгрузки, НомерПосылки) Экспорт
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод = "GET";
	ПараметрыОбработки.Вставить("ПараметрыЗапроса", Новый Структура);
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("format", "A7");
	
	ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
		МП_Яндекс_ВернутьСоединение(МаркетПлейс),
		МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс),
		СтрШаблон("v2/campaigns/%1/orders/%2/delivery/shipments/%3/boxes/%4/label",
			МаркетПлейс.ИДКомпании, НомерЗаказа, НомерОтгрузки, НомерПосылки),
		ПараметрыОбработки,
		Истина);
	
	Если ТипЗнч(ДанныеОтвета) = Тип("Структура")
		И (ДанныеОтвета.Свойство("error")
		Или ДанныеОтвета.Свойство("errors")) Тогда
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("ЗаписьЛога_ОШИБКА", СтрШаблон("ЯндексМаркет. Возникла ошибка при работе с сервисом!%1%2", Символы.ПС,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "ИСКЛЮЧЕНИЕ_ОШИБКА");
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДанныеОтвета;
	
КонецФункции // ЯндексМаркет_ВыполнитьЗапросКЭтикетке()
