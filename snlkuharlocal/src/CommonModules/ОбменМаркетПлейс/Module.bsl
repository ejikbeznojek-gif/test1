	|	ВТ_Искл.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТ_Искл КАК ВТ_Искл
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомОст КАК ТЗНом
	|		ПО (ТЗНом.Номенклатура = ВТ_Искл.Номенклатура)
	|ГДЕ
	|	(ЕСТЬNULL(ТЗНом.КолКонФакт, 0) - ВТ_Искл.Лимит >= 0
	|				И ВТ_Искл.Лимит > 0
	|			ИЛИ ВТ_Искл.Лимит = 1)";
	
	
	Запрос.УстановитьПараметр("ТЗНомМатр",ТЗОст);
	Запрос.УстановитьПараметр("ТЗИскл",   ТЗИскл);
	
	РезультатЗапроса            =Запрос.Выполнить();
	ВыборкаРезультатаЗапроса    =РезультатЗапроса.Выбрать();
	
	
	Пока ВыборкаРезультатаЗапроса.Следующий() Цикл 
		
		Отбор = Новый Структура();
		Отбор.Вставить("Номенклатура",ВыборкаРезультатаЗапроса.Номенклатура);
		
		ПоискСтрокНом = ТЗКомпл.НайтиСтроки(Отбор);
		
		Если ПоискСтрокНом.Количество() > 0 Тогда
			
			Для каждого НайдСтрока Из ПоискСтрокНом Цикл
				
				ТЗКомпл.Удалить(НайдСтрока);
				
			КонецЦикла;   					
		КонецЕсли;
		
	КонецЦикла;       	
	
КонецПроцедуры         

Функция МП_Вайлберриз_СформироватьТЗКомплектацию(ТЗОст) Экспорт
	
	//ТИМОФЕЕВ Ю.А. 16.01.24
	//замена СформироватьТЗКомпл(ТЗОстаткиМатрица);
	//ТИМОФЕЕВ Ю.А. 16.01.24
	
	//надо дособрать
	ТЗКомпл=неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ТЗНомМатр.КолКонФакт КАК КолКонФакт,
	|	ТЗНомМатр.Комплект КАК Комплект,
	|	ТЗНомМатр.Номенклатура КАК Номенклатура,
	|	ТЗНомМатр.МатрКоличество КАК МатрКоличество
	|ПОМЕСТИТЬ ВТ_НомОст
	|ИЗ
	|	&ТЗНомМатр КАК ТЗНомМатр
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНомМатр.КолКонФакт КАК ОстПрод,
	|	ЕСТЬNULL(ТЗНом.КолКонФакт, 0) КАК ОстНом,
	|	ТЗНомМатр.Номенклатура КАК Продукция,
	|	Коплектующие.Номенклатура КАК Номенклатура,
	|	(ТЗНомМатр.МатрКоличество - ТЗНомМатр.КолКонФакт) * Коплектующие.Количество КАК НомКолво,
	|	ТЗНомМатр.МатрКоличество КАК КолМатрПрод,
	|	ЕСТЬNULL(ТЗНом.МатрКоличество, 0) КАК КолМатрНом,
	|	Коплектующие.Количество КАК КолвоКомпл,
	|	0 КАК НомКолвоНашли,
	|	0 КАК Коэффиц,
	|	ТЗНомМатр.МатрКоличество - ТЗНомМатр.КолКонФакт КАК ПродКолво
	|ИЗ
	|	ВТ_НомОст КАК ТЗНомМатр
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК Коплектующие
	|		ПО ТЗНомМатр.Номенклатура = Коплектующие.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомОст КАК ТЗНом
	|		ПО (ТЗНом.Номенклатура = Коплектующие.Номенклатура)
	|ГДЕ
	|	ТЗНомМатр.Комплект
	|	И ТЗНомМатр.МатрКоличество - ТЗНомМатр.КолКонФакт > 1";
	
	Запрос.УстановитьПараметр("ТЗНомМатр",ТЗОст);
	
	ТЗКомпл=Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗКомпл;
	
КонецФункции

Функция МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТЗОстаток) Экспорт
	
	//получаем таблицу значений - результат запроса
	//нужные колонки Номенклатура и добавляем Комплект (булево)
	//Если есть комплектующие у выбранной Номенклатуры комплект = Истина иначе ложь
	
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ *
	//|ПОМЕСТИТЬ НужныйТовар
	//|ИЗ
	//|	&ТЗОстаток КАК ТЗОстаток
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	МАКСИМУМ(ВЫБОР
	//|			КОГДА НоменклатураКоплектующие.НомерСтроки > 0
	//|				ТОГДА ИСТИНА
	//|			ИНАЧЕ ЛОЖЬ
	//|		КОНЕЦ) КАК МаксНомерСтроки,
	//|	НоменклатураКоплектующие.Ссылка КАК МаксНоменклатура
	//|ПОМЕСТИТЬ ИмеетКомпект
	//|ИЗ
	//|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	//|ГДЕ
	//|	НоменклатураКоплектующие.Ссылка В
	//|			(ВЫБРАТЬ
	//|				НужныйТовар.Номенклатура КАК Номенклатура
	//|			ИЗ
	//|				НужныйТовар КАК НужныйТовар)
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	НоменклатураКоплектующие.Ссылка
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	*,
	//|	ЕстьNull(ИмеетКомпект.МаксНомерСтроки,Ложь) КАК Комплект
	//|ИЗ
	//|	НужныйТовар КАК НужныйТовар
	//|		Левое СОЕДИНЕНИЕ ИмеетКомпект КАК ИмеетКомпект
	//|		ПО НужныйТовар.Номенклатура = ИмеетКомпект.МаксНоменклатура";
	//
	
	
	//ТИМОФЕЕВ Ю.А. 08.02.2025 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ *
	|ПОМЕСТИТЬ НужныйТовар
	|ИЗ
	|	&ТЗОстаток КАК ТЗОстаток
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА НоменклатураКоплектующие.НомерСтроки > 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК МаксНомерСтроки,
	|	НоменклатураКоплектующие.Ссылка КАК МаксНоменклатура
	|ПОМЕСТИТЬ ИмеетКомпект
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка В
	|			(ВЫБРАТЬ
	|				НужныйТовар.Номенклатура КАК Номенклатура
	|			ИЗ
	|				НужныйТовар КАК НужныйТовар)
	|
	|СГРУППИРОВАТЬ ПО
	|	НоменклатураКоплектующие.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ВЫБОР
	|		КОГДА НужныйТовар.Номенклатура.ВидКомплекта <> &ГотовыйКомплект
	// Ихсанов Д. А. Начало 02.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2612
	// Если по комплекту будет остаток, то он упадет в документ без отгрузки комплекта
	|				И НужныйТовар.КоличествоОстаток <= 0
	// Ихсанов Д. А. Конец  02.12.2025
	|			ТОГДА ЕСТЬNULL(ИмеетКомпект.МаксНомерСтроки, ЛОЖЬ)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Комплект
	|ИЗ
	|	НужныйТовар КАК НужныйТовар
	|		Левое СОЕДИНЕНИЕ ИмеетКомпект КАК ИмеетКомпект
	|		ПО НужныйТовар.Номенклатура = ИмеетКомпект.МаксНоменклатура";
	
	
	//ТИМОФЕЕВ Ю.А. 08.02.2025
	//|ВЫБОР
	//|	КОГДА НужныйТовар.Номенклатура.ВидКомплекта <> &ГотовыйКомплект
	//|		ТОГДА ЕСТЬNULL(ИмеетКомпект.МаксНомерСтроки, ЛОЖЬ)
	//|	ИНАЧЕ ЛОЖЬ
	//|КОНЕЦ КАК Комплект
	
	//ТИМОФЕЕВ Ю.А. 08.02.2025
	
	Запрос.УстановитьПараметр("ТЗОстаток",ТЗОстаток);
	Запрос.УстановитьПараметр("ГотовыйКомплект",Перечисления.ВидыКомплектов.ГотовыйКомплект);
	
	Результат = Запрос.Выполнить().Выгрузить();  
	
	Попытка
		//удаляем лишние колонки отставшиется от соединения
		//суслика видишь ? Нет ! А он есть ! (с) ДМБ
		Результат.Колонки.Удалить("МаксНоменклатура");	
		Результат.Колонки.Удалить("МаксНомерСтроки");
		Результат.Колонки.Удалить("Комплект1");
	Исключение
		
	КонецПопытки;   	
	
	Возврат Результат;
	
КонецФункции 

Функция МП_Вайлберриз_СформироватьТЗОстаткиМатрица(Контрагент, Договор, Склад, ПунктДоставки, ВыгрузкаПоМатрице=Ложь,ТЗФильтр=Неопределено) Экспорт
	
	//ТИМОФЕЕВ Ю.А. 16.01.2024
	// замена СформироватьТЗОст(Контрагент, Договор, Склад, ПунктДоставки, ВыгрузкаПоМатрице=Ложь,ТЗФильтр=Неопределено)
	// оптизация, увеличение скорости в разы, добавлен ФИЛЬТР по номенклатуре
	//ТИМОФЕЕВ Ю.А. 16.01.2024
	
	//ТЗОстаткиМатрица - свод по остаткам и матрицам
	
	//1. получаем все остатки по указанным складам
	
	ТЗОст=неопределено;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(Остатки.СуммаОстаток) КАК СебестоимостьБух,
	|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
	|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
	|	Ложь КАК Комплект,
	|	Остатки.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(КОНЕЦПЕРИОДА(&дата1, ДЕНЬ), Склад В ИЕРАРХИИ (&Склады)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(КОНЕЦПЕРИОДА(&дата1, ДЕНЬ), Склад В ИЕРАРХИИ (&Склады)) КАК Резервы
	|		ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			И Остатки.Склад = Резервы.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура";
	
	
	
	Запрос.УстановитьПараметр("Склады",склад);    //массив складов
	Запрос.УстановитьПараметр("Дата1", ТекущаяДатаСеанса());
	ТЗНомСкл=Запрос.Выполнить().Выгрузить();
	
	//2. получаем все остатки по матрицами
	
	Запрос1=Новый Запрос;
	
	Запрос1.Текст="ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(МатрицаТовары.ШККонтрагента КАК СТРОКА(150)) КАК ШККонтра,
	|	ВЫРАЗИТЬ(МатрицаТовары.ШККонтрагентаДополнительный КАК СТРОКА(150)) КАК ШККонтра1,
	|	ВЫРАЗИТЬ(МатрицаТовары.КодПроизводителяКонтрагента КАК СТРОКА(50)) КАК КодКонтра,
	|	МатрицаТовары.Цена КАК ЦенаМатрица,
	|	МатрицаТовары.Ссылка КАК Матрица,
	|	МатрицаТовары.Ссылка.Дата КАК МатрицаДата,
	|	МатрицаТовары.Выгружать0Ост КАК ВыгрОст0,
	|	ВЫБОР
	|		КОГДА МатрицаТовары.МинимальноеКоличество < МатрицаТовары.МинимальныйОстатокКоличество
	|			ТОГДА МатрицаТовары.МинимальныйОстатокКоличество
	|		ИНАЧЕ МатрицаТовары.МинимальноеКоличество
	|	КОНЕЦ КАК МатрКоличество
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.ШККонтрагента <> """"
	|	И МатрицаТовары.Ссылка.Дата < &Дата1
	|	И (МатрицаТовары.Ссылка.ДатаОкончания > &Дата1
	|			ИЛИ МатрицаТовары.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))";
	
	Запрос1.УстановитьПараметр("Контрагент",Контрагент);
	Запрос1.УстановитьПараметр("Договор",Договор);
	Запрос1.УстановитьПараметр("Дата1",ТекущаяДатаСеанса());
	ТЗНомМатр=Запрос1.Выполнить().Выгрузить();
	
	
	//3.объединяем ОСТАТКИ по СКЛАДАМ и ДАННЫЕ по МАТРИЦАМ
	
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ТЗНомМатр.Номенклатура КАК Номенклатура,
	|	ТЗНомМатр.ШККонтра КАК ШККонтра,
	|	ТЗНомМатр.ШККонтра1 КАК ШККонтра1,
	|	ТЗНомМатр.КодКонтра КАК КодКонтра,
	|	ТЗНомМатр.ЦенаМатрица КАК ЦенаМатрица,
	|	ТЗНомМатр.Матрица КАК Матрица,
	|	ТЗНомМатр.МатрицаДата КАК МатрицаДата,
	|	ТЗНомМатр.ВыгрОст0 КАК ВыгрОст0,
	|	ТЗНомМатр.МатрКоличество КАК МатрКоличество
	|ПОМЕСТИТЬ ВТ_НомМатр
	|ИЗ
	|	&ТЗНомМатр КАК ТЗНомМатр
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНомСкл.СебестоимостьБух КАК СебестоимостьБух,
	|	ТЗНомСкл.КолКонФакт КАК КолКонФакт,
	|	ТЗНомСкл.Резерв КАК Резерв,
	|	ТЗНомСкл.Комплект КАК Комплект,
	|	ТЗНомСкл.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомСкл
	|ИЗ
	|	&ТЗНомСкл КАК ТЗНомСкл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаПунктыДоставки.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Матр
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ГДЕ
	|	МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Ном.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ВТ_Ном.МатрицаДата) КАК МатрицаДатаМ
	|ПОМЕСТИТЬ ВТ_НомОтбор
	|ИЗ
	|	ВТ_НомМатр КАК ВТ_Ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Матр КАК ВТ_Матр
	|		ПО ВТ_Ном.Матрица = ВТ_Матр.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Ном.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НомОтбор.Номенклатура КАК Номенклатура,
	|	ТЗНомМатр.ШККонтра КАК ШККонтра,
	|	ТЗНомМатр.ШККонтра1 КАК ШККонтра1,
	|	ТЗНомМатр.КодКонтра КАК КодКонтра,
	|	ТЗНомМатр.ЦенаМатрица КАК ЦенаМатрица,
	|	ТЗНомМатр.Матрица КАК Матрица,
	|	ТЗНомМатр.МатрицаДата КАК МатрицаДата,
	|	ТЗНомМатр.ВыгрОст0 КАК ВыгрОст0,
	|	ТЗНомМатр.МатрКоличество КАК МатрКоличество
	|ПОМЕСТИТЬ ВТ_НомОтбор1
	|ИЗ
	|	ВТ_НомОтбор КАК ВТ_НомОтбор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_НомМатр КАК ТЗНомМатр
	|		ПО (ТЗНомМатр.МатрицаДата = ВТ_НомОтбор.МатрицаДатаМ)
	|			И ВТ_НомОтбор.Номенклатура = ТЗНомМатр.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТЗНомСкл.СебестоимостьБух, 0) КАК СебестоимостьБух,
	|	ЕСТЬNULL(ТЗНомСкл.КолКонФакт, 0) КАК КолКонФакт,
	|	ЕСТЬNULL(ТЗНомСкл.Комплект, ЛОЖЬ) КАК Комплект,
	|	ЕСТЬNULL(ТЗНомСкл.Резерв, 0) КАК Резерв,
	|	0 КАК РезервКомпл,
	|	ВЫБОР
	|		КОГДА ТЗНомСкл.Номенклатура ЕСТЬ NULL
	|			ТОГДА ТЗНомМатр.Номенклатура
	|		ИНАЧЕ ТЗНомСкл.Номенклатура
	|	КОНЕЦ КАК Номенклатура,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ТЗНомМатр.ШККонтра, """") КАК СТРОКА(50)) КАК ШККонтра,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ТЗНомМатр.ШККонтра1, """") КАК СТРОКА(50)) КАК ШККонтра1,
	|	ЕСТЬNULL(ТЗНомМатр.КодКонтра, """") КАК КодКонтра,
	|	ЕСТЬNULL(ТЗНомМатр.ЦенаМатрица, 0) КАК ЦенаМатрица,
	|	ЕСТЬNULL(ТЗНомМатр.Матрица, """") КАК Матрица,
	|	ЕСТЬNULL(ТЗНомМатр.МатрицаДата, ДАТАВРЕМЯ(2000, 1, 1)) КАК МатрицаДата,
	|	ЕСТЬNULL(ТЗНомМатр.ВыгрОст0, ЛОЖЬ) КАК ВыгрОст0,
	|	ЕСТЬNULL(ТЗНомМатр.МатрКоличество, 0) КАК МатрКоличество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТЗНомМатр.ШККонтра, """") = """"
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА &ВыгрузкаПоМатрице
	|					ТОГДА ВЫБОР
	|							КОГДА ЕСТЬNULL(ТЗНомМатр.МатрКоличество, 0) < ЕСТЬNULL(ТЗНомСкл.КолКонФакт, 0)
	|								ТОГДА ЕСТЬNULL(ТЗНомМатр.МатрКоличество, 0)
	|							ИНАЧЕ ЕСТЬNULL(ТЗНомСкл.КолКонФакт, 0)
	|						КОНЕЦ
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ЕСТЬNULL(ТЗНомМатр.МатрКоличество, 0) > 0
	|							ТОГДА ЕСТЬNULL(ТЗНомСкл.КолКонФакт, 0)
	|						ИНАЧЕ 0
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК КВыгрузке
	|ИЗ
	|	ВТ_НомСкл КАК ТЗНомСкл
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_НомОтбор1 КАК ТЗНомМатр
	|		ПО (ТЗНомМатр.Номенклатура = ТЗНомСкл.Номенклатура)";
	Запрос.УстановитьПараметр("ТЗНомМатр",        ТЗНомМатр);
	Запрос.УстановитьПараметр("ТЗНомСкл",         ТЗНомСкл);
	Запрос.УстановитьПараметр("ПунктДоставки",    ПунктДоставки);
	Запрос.УстановитьПараметр("ВыгрузкаПоМатрице",ВыгрузкаПоМатрице);
	
	ТЗОст=Запрос.Выполнить().Выгрузить();
	
	//итоговая таблица
	
	//4. если нужно добавляем фильтр
	//извините за такой вариант запроса , но он универасальный
	//сохраняя все колонки на входе и выходе
	
	Если ТЗФильтр<>Неопределено Тогда   	
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ *
		|ПОМЕСТИТЬ НужныйТовар
		|ИЗ
		|	&ТЗОстаток КАК ТЗОстаток
		|;
		|ВЫБРАТЬ *
		|ПОМЕСТИТЬ ФильтрТовар
		|ИЗ
		|	&ТЗФильтр КАК ТЗФильтр
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	НужныйТовар КАК НужныйТовар
		|ГДЕ
		|	Номенклатура.Ссылка В
		|			(ВЫБРАТЬ
		|				ФильтрТовар.Номенклатура КАК Номенклатура
		|			ИЗ
		|				ФильтрТовар КАК ФильтрТовар)";    		
		
		Запрос.УстановитьПараметр("ТЗОстаток",ТЗОст);
		Запрос.УстановитьПараметр("ТЗФильтр", ТЗФильтр); 		
		ТЗОст=Запрос.Выполнить().Выгрузить();			
		
	КОнецЕсли;
	
	//5. 
	
	//раньше было так при обработки 33000 строк уходило  17 минут 49 секунд
	
	//Для Каждого ТСтр Из ТЗОст Цикл
	//	Если ТСтр.Номенклатура.Ссылка.Коплектующие.Количество() Тогда
	//		ТСтр.Комплект=Истина;
	//	КонецЕсли;
	//	Если ТСтр.КВыгрузке<0 Тогда
	//		ТСтр.КВыгрузке=0;
	//	КонецЕсли;
	//КонецЦикла;
	
	//оптимизация бработки 33000 строк - 9 секунд 
	
	ТЗОст=МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТЗОст);	
	
	Для Каждого ТСтр Из ТЗОст Цикл
		Если ТСтр.КВыгрузке<0 Тогда
			ТСтр.КВыгрузке=0;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТЗОст;
	
КонецФункции	

Процедура МП_Вайлберриз_ВыгрузкаОстатков(ТаблицаПараметров=Неопределено)  Экспорт
	
	
	//Тимофеев Ю.А. 16012024
	//замена ВыгрузкаОстатковВайлберриз(ТаблицаПараметров=Неопределено) 
	//скорость выгрузки увеличена в 25 раз 
	//Тимофеев Ю.А. 16012024
	
	
	СтрокаСоединенияСразрешеннымОбменом	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения					=ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом Тогда	
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Выгрузка остатков. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");		
		Возврат;
	КонецЕсли;
	ЗаписатьВЛог("МП_Вайлберриз","Начало выполнения. Задача: Загрузка остатков ВБ.!","Информация");
	
	
	МаркетПлейс   = Справочники.ИнетМагазины.НайтиПоКоду("00001");
	Контрагент    = МаркетПлейс.Контрагент;
	ДоговорМП     = МаркетПлейс.Договор;
	Склад         = МаркетПлейс.Склад; 
	ПунктДоставки = МаркетПлейс.ПунктДоставки;
	ВыгрМатр      = МаркетПлейс.ВыгрузкаОстатковПоМатрице;
	
	
	МассивСкладовМП = Новый Массив;
	
	МассивСкладовМП.Добавить(Склад);
	
	Для Каждого ТекСтр Из МаркетПлейс.Склады Цикл
		
		МассивСкладовМП.Добавить(ТекСтр.Склад);
		
	КонецЦикла;	
	
	
	//ТЗОстаткиМатрица - свод по остаткам и матрицам
	
	ТЗОстаткиМатрица  = МП_Вайлберриз_СформироватьТЗОстаткиМатрица(Контрагент,ДоговорМП, МассивСкладовМП,ПунктДоставки, ВыгрМатр,ТаблицаПараметров);
	
	ТЗКомпл           = МП_Вайлберриз_СформироватьТЗКомплектацию(ТЗОстаткиМатрица);  	
	
	//Тимофеев Ю.А. 16.01.2024
	//Таблицы большие 18000 и 50000 добавим ИНДЕКСЫ
	//прирост скорости - 10 минут
	//Тимофеев Ю.А. 16.01.2024
	
	ТЗОстаткиМатрица.Индексы.Добавить("Номенклатура");
	
	ТЗКомпл.Индексы.Добавить("Номенклатура");
	
	
	Попытка
		
		ТЗИскл=МаркетПлейс.ИсключенияРасчетаОстатков.Выгрузить();
		
		Если ТЗИскл.Количество()>0 Тогда
			
			МП_Вайлберриз_ОбработатьИсключенияИзРасчета(ТЗИскл,ТЗОстаткиМатрица,ТЗКомпл);
			
		КонецЕсли;	
		
	Исключение
		
	КонецПопытки;
	
	ТЗКопияКомпл=ТЗКомпл.Скопировать();	
	
	ТЗКопияКомпл.Свернуть("Продукция,ПродКолво");
	
	ТЗКопияКомпл.Индексы.Добавить("Продукция");
	
	//ТЗКопияКомпл - Таблица значений копия таблицы с комплектующими
	//ТекСтрТЗКК   - текущая строка копии таблицы с комплеткующими
	
	ЕстьКомпл  = Ложь;
	МНомДопОбр = Новый Массив;
	
	Для Каждого ТекСтрТЗКК Из ТЗКопияКомпл Цикл
		
		Прод      =ТекСтрТЗКК.Продукция;
		ПродКолво =ТекСтрТЗКК.ПродКолво;
		
		//НСПВК        - НайденныеСтрокиПродукцииВКомплектации	
		//ТекСтрНСПВК  - текущая строка из  НайденнаяСтрокаПродукцииВКомплектации
		
		НСПВК = ТЗКомпл.НайтиСтроки(Новый Структура("Продукция",Прод));     //ищем все комплектущие
		
		Если НСПВК.Количество()>0 Тогда
			
			Для Каждого ТекСтрНСПВК Из НСПВК Цикл
				
				Надо  = ТекСтрНСПВК.НомКолво;
				Найды2= ТЗОстаткиМатрица.НайтиСтроки(Новый Структура("Номенклатура",ТекСтрНСПВК.Номенклатура));
				
				Найдено=0;
				Если Найды2.Количество()>0 Тогда
					
					Найд2=Найды2.Получить(0);
					
					Найдено=(Найд2.КолКонФакт-Найд2.МатрКоличество-Найд2.РезервКомпл);
					
				КонецЕсли;	
				
				Если Найдено<=0 Тогда
					Найдено =0;
				КонецЕсли;
				
				ТекСтрНСПВК.НомКолвоНашли=Найдено; 		
				
			КонецЦикла;	
			
			
			МК=Новый Массив;
			
			Для Каждого ТекСтрНСПВК Из НСПВК Цикл
				
				Если ТекСтрНСПВК.НомКолвоНашли<ТекСтрНСПВК.НомКолво Тогда
					
					Коэф=Окр(ТекСтрНСПВК.НомКолвоНашли/ТекСтрНСПВК.НомКолво,3);
					
					Если (Коэф>=0) И (Коэф<1) И (ТекСтрНСПВК.КолМатрПрод>0) Тогда
						
						Если МНомДопОбр.Найти(ТекСтрНСПВК.Номенклатура)=неопределено Тогда
							
							МНомДопОбр.Добавить(ТекСтрНСПВК.Номенклатура);
							
						КонецЕсли;	
						
					КонецЕсли;	
					
				Иначе
					
					Коэф=1;	
					
				КонецЕсли;
				
				ТекСтрНСПВК.Коэффиц=Коэф;
				МК.Добавить(Коэф);
				
			КонецЦикла;
			
			НужныйКоэф=1;
			Для Каждого СпКоэф из МК Цикл
				НужныйКоэф=Мин(НужныйКоэф,СпКоэф);
			КонецЦикла;
			
			ПродКолво=Цел(ПродКолво*НужныйКоэф);
			
			Если ПродКолво>0 Тогда
				
				Найды3=ТЗОстаткиМатрица.НайтиСтроки(Новый Структура("Номенклатура",Прод));
				
				Если Найды3.Количество()>0 Тогда
					
					Найд3=Найды3.Получить(0);
					ЕстьКомпл=Истина;
					
					Найд3.КВыгрузке=Найд3.КВыгрузке+ПродКолво;
					
				КонецЕсли;					
				
				Для Каждого ТекСтрНСПВК Из НСПВК Цикл
					
					Количество1		= Цел(ТекСтрНСПВК.КолвоКомпл*ПродКолво);
					
					Если Найды2.Количество()>0 Тогда
						
						Найд2=Найды2.Получить(0);
						Найд2.РезервКомпл=Найд2.РезервКомпл+Количество1;
						
						//резервируем на комплектацию
						
						Если Найд2.КВыгрузке>0 Тогда
							
							Если (Найд2.КолКонФакт-Найд2.РезервКомпл)<Найд2.КВыгрузке Тогда
								Найд2.КВыгрузке=Найд2.КолКонФакт-Найд2.РезервКомпл;
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла; 				
				
			КонецЕсли;	    			
			
		КонецЕсли;
		
	КонецЦикла;	
	
	Для Каждого ТЭм Из МНомДопОбр Цикл  		
		
		Найды4=ТЗКомпл.НайтиСтроки(Новый Структура("Номенклатура",ТЭм));
		
		Найды6=ТЗОстаткиМатрица.НайтиСтроки(Новый Структура("Номенклатура",ТЭм));
		
		Доб=0;
		Если Найды6.Количество()>0 Тогда
			
			Найд6=Найды6.Получить(0);
			
			Если Найд6.МатрКоличество>0 Тогда
				Доб=1;
			КонецЕсли;	
			
		КонецЕсли;     		
		
		Колво   = Найды4.Количество()+Доб;
		ТотКол  = 0;
		ОстНом  = Найды4[0].ОстНом;
		ОстНом2 = 0;
		
		Для Каждого Найд4 Из Найды4 Цикл
			
			Делать=Истина;
			
			Найды71=ТЗКомпл.НайтиСтроки(Новый Структура("Продукция",Найд4.Продукция));
			
			ПерваяНайды71=Найды71.Получить(0);
			
			К11=ПерваяНайды71.ОстНом/(ПерваяНайды71.ПродКолво*ПерваяНайды71.КолвоКомпл);
			
			Для Каждого Найд71 Из Найды71 Цикл
				
				Если Найд71.ОстНом<=0 Тогда
					
					Делать=Ложь;
					
				КонецЕсли;	
				
				НовыйРезультат = Найд71.ОстНом/(Найд71.ПродКолво*Найд71.КолвоКомпл);
				
				Если К11>НовыйРезультат Тогда
					
					К11=НовыйРезультат;
					
				КонецЕсли;	
				
			КонецЦикла;	
			
			Если Делать Тогда
				
				Если К11<1 Тогда
					Если Цел(Найд4.ПродКолво*К11)>=1 Тогда
						
						ТотКол=ТотКол+(Найд4.КолвоКомпл);
						
					КонецЕсли;
				Иначе
					
					ТотКол=ТотКол+Найд4.КолвоКомпл;
					
				КонецЕсли;	
				
			КонецЕсли;
			
		КонецЦикла;	
		
		ТотКол=ТотКол+Доб;
		
		Если ТотКол Тогда
			
			ТКол=Цел((ОстНом-ОстНом2)/ТотКол);
			
		Иначе
			
			ТКол=0;
			
		КонецЕсли;	
		
		ОстНом1=0;
		
		Для Каждого Найд4 Из Найды4 Цикл
			
			Делать=Истина;
			
			Найды5=ТЗОстаткиМатрица.НайтиСтроки(Новый Структура("Номенклатура",Найд4.Продукция));
			
			Найды7=ТЗКомпл.НайтиСтроки(Новый Структура("Продукция",Найд4.Продукция));
			
			ПерваяНайды7=Найды7.Получить(0);
			
			К1=ПерваяНайды7.ОстНом/(ПерваяНайды7.ПродКолво*ПерваяНайды7.КолвоКомпл);
			
			Для Каждого Найд7 Из Найды7 Цикл
				
				Если Найд7.ОстНом<=0 Тогда
					
					Делать=Ложь;
					
				КонецЕсли;	
				
				НовыйРезультат7 = Найд7.ОстНом/(Найд7.ПродКолво*Найд7.КолвоКомпл);
				
				Если К1>НовыйРезультат7 Тогда
					
					К1=НовыйРезультат7;
					
				КонецЕсли;	
				
			КонецЦикла;
			
			Если Делать Тогда
				
				Если К1<1 Тогда
					Если Цел(Найд4.ПродКолво*К1)>=1 Тогда
						
						ОстНом1=ОстНом1+Цел(Найд4.ПродКолво*К1*Найд4.КолвоКомпл);
						
					КонецЕсли;
				Иначе	
					
					ОстНом1=ОстНом1+Цел(ТКол*Найд4.КолвоКомпл);
					
				КонецЕсли;  				
				
				Если Найды5.Количество()>0 Тогда
					
					Найд5=Найды5.Получить(0);
					
					Если Найд5.МатрКоличество>0 Тогда
						
						Если К1<1 Тогда
							
							Если Цел(Найд4.ПродКолво*К1)>=1 Тогда
								
								Найд5.КВыгрузке=Цел(Найд4.ПродКолво*К1);
								
							КонецЕсли;
						Иначе	
							
							Найд5.КВыгрузке=ТКол;
							
						КонецЕсли;
						
					КонецЕсли;	
				КонецЕсли;
				
			Иначе
				
				Если Найды5.Количество()>0 Тогда
					
					Найд5=Найды5.Получить(0);
					Найд5.КВыгрузке=0;
					
				КонецЕсли;	
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Найды6.Количество() Тогда
			
			Найд6=Найды6.Получить(0);
			ТОст=ОстНом-ОстНом1;
			
			Если Найд6.МатрКоличество>0 И ТОст>0 Тогда
				
				Найд6.КВыгрузке=ТОст;
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;	  
	
	
	ИндексТЗ = ТЗОстаткиМатрица.Количество()-1;
	
	Пока ИндексТЗ>=0 Цикл
		
		ТекСтрТЗКК=ТЗОстаткиМатрица.Получить(ИндексТЗ);
		
		Если (НЕ ЗначениеЗаполнено(ТекСтрТЗКК.Матрица) ИЛИ (НЕ ЗначениеЗаполнено(ТекСтрТЗКК.ШККонтра) И НЕ ЗначениеЗаполнено(ТекСтрТЗКК.ШККонтра1)))  Тогда
			
			ТЗОстаткиМатрица.Удалить(ИндексТЗ);
			
		КонецЕсли;	
		
		ИндексТЗ=ИндексТЗ-1;
		
	КонецЦикла;
	
	ТЗОстатковФинальная=МП_Вайлберриз_СформироватьТЗОстатковФинальная(ТЗОстаткиМатрица);
	
	
	//вот только сюда получилось вставить фильтр
	
	//ТЗФИЛЬТР - таблица с Номенклатурой для фильтра
	
	ТЗФИЛЬТР = Неопределено;
	
	
	Если ТаблицаПараметров<>Неопределено  Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "ТЗ" Тогда			
				
				ТЗФИЛЬТР = СтрокаТП.Значение;
				
			КонецЕсли;	
			
		КонецЦикла;   	
		
		//извините за такой вариант запроса , но он универасальный
		//сохраняя все колонки на входе и выходе
		
		Если ТЗФильтр<>Неопределено Тогда   	
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ *
			|ПОМЕСТИТЬ НужныйТовар
			|ИЗ
			|	&ТЗОстаток КАК ТЗОстаток
			|;
			|ВЫБРАТЬ *
			|ПОМЕСТИТЬ ФильтрТовар
			|ИЗ
			|	&ТЗФильтр КАК ТЗФильтр
			|;
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	*
			|ИЗ
			|	НужныйТовар КАК НужныйТовар
			|ГДЕ
			|	Номенклатура.Ссылка В
			|			(ВЫБРАТЬ
			|				ФильтрТовар.Номенклатура КАК Номенклатура
			|			ИЗ
			|				ФильтрТовар КАК ФильтрТовар)";    		
			
			Запрос.УстановитьПараметр("ТЗОстаток",ТЗОстатковФинальная);
			Запрос.УстановитьПараметр("ТЗФильтр", ТЗФильтр); 		
			ТЗОстатковФинальная=Запрос.Выполнить().Выгрузить();			
			
		КОнецЕсли;
		
	КонецЕсли;
	
	
	
	//////////////////////////////////////////////
	
	ТЗШККВыгрузке      = МП_Вайлберриз_Вернуть_ШК_и_ОстаткиДляВыгрузки(ТЗОстатковФинальная);
	
	МП_Вайлберриз_ВыгрузитьОстаткиНаПортал(МаркетПлейс,ТЗШККВыгрузке,"");
	
	
	Если МаркетПлейс.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз"," Окончание выполнения. Задача: Загрузка остатков ВБ.!","Информация"); 
	КонецЕсли;
	
КонецПроцедуры

Функция МП_Вайлберриз_Вернуть_ШК_и_ОстаткиДляВыгрузки(ТЗОстатковФинальная)
	
	ТЗШККВыгрузке = ТЗОстатковФинальная.СкопироватьКолонки("Номенклатура,ШККонтра,КВыгрузке");
	
	для каждого стрШК из ТЗОстатковФинальная Цикл
		
		Если НЕ ПустаяСтрока(стрШК.ШККонтра) Тогда
			
			НовСтр = ТЗШККВыгрузке.Добавить();
			НовСТр.Номенклатура=СтрШК.Номенклатура;
			НовСТр.ШККонтра    =стрШК.ШККонтра;
			НовСТр.КВыгрузке   =СТрШК.КВыгрузке;
			
		КонецЕсли;    		
		
		Если НЕ ПустаяСтрока(стрШК.ШККонтра1) Тогда
			
			НовСтр = ТЗШККВыгрузке.Добавить();
			НовСТр.Номенклатура=СтрШК.Номенклатура;
			НовСТр.ШККонтра    =стрШК.ШККонтра1;
			НовСТр.КВыгрузке   =СТрШК.КВыгрузке;
			
		КонецЕсли;  		
		
	КонецЦикла;     
	
	Возврат ТЗШККВыгрузке;
	
КонецФункции

Функция МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркетПлейс, РеквизитыМаркетплейса = Неопределено) Экспорт
	
	// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
	ЗаголовокHTTP = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Content-Type", МаркетПлейс.ContentType);
	ЗаголовокHTTP.Вставить("Accept", МаркетПлейс.Accept);
	ЗаголовокHTTP.Вставить("Accept-Language", МаркетПлейс.AcceptLanguage);
	ЗаголовокHTTP.Вставить("Accept-Charset", МаркетПлейс.AcceptCharset);
	ЗаголовокHTTP.Вставить("Content-Language", МаркетПлейс.ContentLanguage);
	ЗаголовокHTTP.Вставить("Content-Charset", МаркетПлейс.ContentCharset);
	ЗаголовокHTTP.Вставить("Host", МаркетПлейс.Host);
	Если ЗначениеЗаполнено(МаркетПлейс.Token2) Тогда
		ЗаголовокHTTP.Вставить("Authorization", МаркетПлейс.Token2);
	Иначе
		ЗаголовокHTTP.Вставить("Authorization", МаркетПлейс.Token);
	КонецЕсли;
	
	Возврат ЗаголовокHTTP;
	// Ихсанов Д. А. Конец 02.07.2026
	
КонецФункции

Функция МП_Вайлберриз_ВернутьСоединение(МаркетПлейс) Экспорт
	
	Соединение=Неопределено;
	
	Попытка
		АдресТ = МаркетПлейс.АдресРесурса;
		
		Если МаркетПлейс.Порт="443" Тогда
			
			Соединение = Новый HTTPСоединение(АдресТ,443,,,,,Новый ЗащищенноеСоединениеOpenSSL);  
			
		Иначе
			
			Соединение = Новый HTTPСоединение(АдресТ);
			
		КонецЕсли;
