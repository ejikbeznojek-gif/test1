Функция СоздатьДокиНеКомпл(ТЗЗак,МкПл, МенятьДоговор=Истина)
	
	// Кухарь А.Ю. 07.07.2023 начало
	ЧасПриемки=Час(ТекущаяДата());
	ДеньЗагрузки=ДеньНедели(ТекущаяДата());
	СекундВДне=24*3600;
	ВремяВосемь=Справочники.ВремяПриемки.НайтиПоКоду("000000065");
	ВремяТринадцать=Справочники.ВремяПриемки.НайтиПоКоду("000000060");	
	// Кухарь А.Ю. 07.07.2023 конец
	
	
	МасЗак=Новый Массив;
	Если НЕ ТЗЗак.Количество() Тогда
		Возврат МасЗак;
	КонецЕсли;
	ТЗСвод=ТЗЗак.Скопировать();
	ТЗСвод.Свернуть("Номенклатура, ОстСклад, ОстОбщий","КолвоЗак");
	ТЗСвод.Колонки.Добавить("ОстОК",новый ОписаниеТипов("Булево"));
	ТЗСвод.Колонки.Добавить("НомДок",Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10, 0)));
	ТотКол=ТЗСвод.Итог("КолвоЗак");
	
	МасНеДост=Новый Массив;
	МасПодпит=Новый Массив;
	МасНеДостКол=Новый Массив;
	МасКорр=Новый Массив;
	МасКоррКол=Новый Массив;
	МасНеДостФин=Новый Массив;
	Для Каждого ТекСтр Из ТЗСвод Цикл
		Если (ТекСтр.КолвоЗак>ТекСтр.ОстСклад) Тогда
			
			#Если Клиент Тогда
				Сообщить("Не хват. "+строка(ТекСтр.Номенклатура));
			#КонецЕсли
			МасНеДост.Добавить(ТекСтр.Номенклатура);
			МасНеДостКол.Добавить(ТекСтр.КолвоЗак-ТекСтр.ОстСклад);
			Если (ТекСтр.КолвоЗак>ТекСтр.ОстСклад) И (ТекСтр.ОстОбщий>ТекСтр.ОстСклад) И (ТекСтр.ОстОбщий>=ТекСтр.КолвоЗак) Тогда
				МасПодпит.Добавить(ТекСтр.Номенклатура);
			КонецЕсли;	
		Иначе
			ТекСтр.ОстОК=Истина;
		КонецЕсли;	
	КонецЦикла;	
	ЕстьДопСкл=МкПл.Склады.Количество();
	ПССозд=Ложь;
	Если ЕстьДопСкл И МасНеДост.Количество() Тогда
		
		
		Запрос=Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|ТЗНом.Номенклатура КАК Номенклатура,
		|ТЗНом.КолвоЗак КАК Количество
		|ПОМЕСТИТЬ ВТ_НомДок
		|ИЗ
		|	&ТЗНом КАК ТЗНом
		|;
		|ВЫБРАТЬ
		|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
		|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
		|	Ложь КАК Комплект,
		|	Остатки.Номенклатура КАК Номенклатура
		|	ПОМЕСТИТЬ ВТ_ОстСкл
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В ИЕРАРХИИ (&Склады)
		|				И Номенклатура В (&Ном)) КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад В ИЕРАРХИИ (&Склады)
		|					И Номенклатура В (&Ном)) КАК Резервы
		|		ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			И Остатки.Склад = Резервы.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура
		|;
		|ВЫБРАТЬ 
		| НомДок.Номенклатура КАК Номенклатура,
		| isnull(КолКонФакт,0) КАК Доступно,
		| (НомДок.Количество-isnull(КолКонФакт,0)) КАК НеХват,
		| 0 КАК Добавка,
		| 0 КАК Добавка1
		| ИЗ ВТ_НомДок КАК НомДок
		| ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстСкл КАК ОстСкл
