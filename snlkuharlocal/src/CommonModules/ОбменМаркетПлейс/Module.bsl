	|	&ТЗНомОст КАК ТЗНомСкл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЗОстСт.ИДПрод КАК СТРОКА(50)) КАК ИДПрод,
	|	ВЫРАЗИТЬ(ТЗОстСт.НаимК КАК СТРОКА(150)) КАК НаимК,
	|	ТЗОстСт.Кол КАК Кол
	|ПОМЕСТИТЬ ВТ_НомСт1
	|ИЗ
	|	&ТЗОстСт КАК ТЗОстСт
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НомСт1.ИДПрод КАК ИДПрод,
	|	ВТ_НомСт1.НаимК КАК НаимК,
	|	МИНИМУМ(ВТ_НомСт1.Кол) КАК Кол
	|ПОМЕСТИТЬ ВТ_НомСт
	|ИЗ
	|	ВТ_НомСт1 КАК ВТ_НомСт1
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_НомСт1.ИДПрод,
	|	ВТ_НомСт1.НаимК
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНомСкл.СебестоимостьБух КАК СебестоимостьБух,
	|	ТЗНомСкл.КолКонФакт КАК КолКонФакт,
	|	ТЗНомСкл.Комплект КАК Комплект,
	|	ТЗНомСкл.Резерв КАК Резерв,
	|	ТЗНомСкл.РезервКомпл КАК РезервКомпл,
	|	ТЗНомСкл.Номенклатура КАК Номенклатура,
	|	ТЗНомСкл.ШККонтра КАК ШККонтра,
	|	ТЗНомСкл.КодКонтра КАК КодКонтра,
	|	ТЗНомСкл.ЦенаМатрица КАК ЦенаМатрица,
	|	ТЗНомСкл.Матрица КАК Матрица,
	|	ТЗНомСкл.МатрицаДата КАК МатрицаДата,
	|	ТЗНомСкл.МатрКоличество КАК МатрКоличество,
	|	ТЗНомСкл.КВыгрузке КАК КВыгрузке,
	|	ЕСТЬNULL(ТЗНом.Кол, 0) КАК ОстСайт,
	|	ЕСТЬNULL(ТЗНом.НаимК, """") КАК НаимК,
	|	ЕСТЬNULL(ТЗНом.ИДПрод, """") КАК ИДПрод
	|ИЗ
	|	ВТ_НомОст КАК ТЗНомСкл
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомСт КАК ТЗНом
	|		ПО (ВЫБОР
	|				КОГДА ТЗНомСкл.НомНаим = ТЗНомСкл.НаимКонтра
	|					ТОГДА ТЗНом.НаимК = ТЗНомСкл.НомНаим
	|				ИНАЧЕ ТЗНом.НаимК = ТЗНомСкл.НомНаим
	|						ИЛИ ТЗНом.НаимК = ТЗНомСкл.НаимКонтра
	|			КОНЕЦ)
	|ГДЕ
	|	НЕ ТЗНомСкл.КВыгрузке = ЕСТЬNULL(ТЗНом.Кол, 0)
	|	И ТЗНомСкл.КВыгрузке >= 0
	|	И НЕ ЕСТЬNULL(ТЗНом.ИДПрод, """") = """"";
	Запрос.УстановитьПараметр("ТЗНомОст",ТЗОст);
	Запрос.УстановитьПараметр("ТЗОстСт",ТЗОстСт);
	ТЗОстФин=Запрос.Выполнить().Выгрузить();
	Возврат ТЗОстФин;
КонецФункции

