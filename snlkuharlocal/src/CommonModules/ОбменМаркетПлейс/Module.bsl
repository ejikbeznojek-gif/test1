// Функция - Текст запроса данные для подтверждения документов
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// 
// Возвращаемое значение:
//  Строка - Текст запроса для получения данных для подтверждения документов заказов
//
Функция ТекстЗапросаДанныеДляПодтвержденияДокументов() Экспорт
	
	Возврат "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказFBS,
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование КАК РасходнаяНакладная,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	СУММА(ЗаказКлиентаFBSТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ вт_ДанныеДокументовНаПодтверждение
	|ИЗ
	|	вт_СериализированныеДанныеЗаказов КАК вт_СериализированныеДанныеЗаказов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_СериализированныеДанныеЗаказов.Документ = ЗаказКлиентаFBSТовары.Ссылка
	|			И вт_СериализированныеДанныеЗаказов.ШККонтрагента = ЗаказКлиентаFBSТовары.ШтрихКод
	|			И вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ЗаказКлиентаFBSТовары.НомерЗаказа
	|ГДЕ
	|	вт_СериализированныеДанныеЗаказов.ДополнительныйСтатус = &ДополнительныйСтатус
	|	И вт_СериализированныеДанныеЗаказов.ДатаОтгрузки < НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, 2), ДЕНЬ)
	|	И НЕ ЗаказКлиентаFBSТовары.Ссылка.ПометкаУдаления
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.Ссылка,
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод";
	
КонецФункции // ТекстЗапросаДанныеДляПодтвержденияДокументов()

// Процедура - Получить данные заказов в модели сервиса
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
//
// Параметры:
//  ТекстыЗапросов		 - Строка	 - Строка запроса
//  ПараметрыОбработки	 - Структура - Данные параметров к обработке
//  РеквизитыМаркетПлейс - Структура - Структура с данными для составления адреса запроса
//
Процедура ПолучитьДанныеЗаказовВМоделиСервиса(ТекстыЗапросов, ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт
	
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";"));
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Контрагент",      РеквизитыМаркетПлейс.Контрагент);
	Запрос.УстановитьПараметр("Договор", 	     РеквизитыМаркетПлейс.Договор);
	Запрос.УстановитьПараметр("ПунктДоставки",   РеквизитыМаркетПлейс.ПунктДоставки);
	Запрос.УстановитьПараметр("Склад", 		   	 РеквизитыМаркетПлейс.Склад);
	// Ихсанов Д. А. Начало 02.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2612
	Запрос.УстановитьПараметр("СкладМаркировки", РеквизитыМаркетПлейс.СкладМаркировки);
	// Ихсанов Д. А. Конец  02.12.2025
