	|ИЗ
	|	вт_ДокументыЗаказКлиента КАК вт_ДокументыЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_ДокументыЗаказКлиента.ЗаказКлиентаFBS = ЗаказКлиентаFBSТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_ДанныеПоДокументамЗаказКлиента_Предварительный.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(вт_СериализированныеДанныеЗаказов.ШтрихКод, """") КАК ШтрихКод,
	|	ЕСТЬNULL(вт_СериализированныеДанныеЗаказов.НомерПосылки, """") КАК СуффиксЗаказа,
	|	ЕСТЬNULL(вт_СериализированныеДанныеЗаказов.НомерОтгрузки, """") КАК ПрефиксЗаказа,
