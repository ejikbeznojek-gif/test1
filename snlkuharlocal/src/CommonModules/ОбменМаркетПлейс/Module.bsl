Функция МП_Вайлдберриз_ЗаписатьМаркуНаЗаказ(МаркПл,НомЗак,ДатаМатрикс) Экспорт
	
	// Ихсанов Д. А. Начало 03.07.2026 Изменение 0000000239 от 03.07.2026 16:54:45: e1cib/data/Документ.Изменение?ref=896d0050568f680711f176e6bbb78b04
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00001");
	РеквизитыМаркетПлйс = ЗначенияРеквизитовОбъекта(Маркетплейс, 
		ОбменМаркетПлейс.КлючевыеИменаРеквизитовМаркетплейса());
	
	ДополнительныеПараметры = КоннекторHTTP.НовыеПараметры();
	ДополнительныеПараметры.Заголовки = ОбменМаркетПлейс.МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркетПлейс);
	ДополнительныеПараметры.ПараметрыПреобразованияJSON.ПрочитатьВСоответствие = Ложь;
	
	ДополнительныеПараметры.Json = Новый Структура;
	ДополнительныеПараметры.Json.Вставить("sgtins", Новый Массив);
	ДополнительныеПараметры.Json.sgtins.Добавить(ДатаМатрикс);
	
	СтруктураДанныхОтвета = КоннекторHTTP.Put(СтрШаблон("https://%1%2",
		РеквизитыМаркетПлйс.host, СтрШаблон("/api/v3/orders/%1/meta/sgtin", НомЗак)),,
		ДополнительныеПараметры);
	Если СтруктураДанныхОтвета.КодСостояния > 400 Тогда
		Если СтруктураДанныхОтвета.КодСостояния = 429 Тогда
			ОбменМаркетПлейс.НужнаПауза(Число(СтруктураДанныхОтвета.Заголовки["X-Ratelimit-Retry"]) + 2);
		КонецЕсли;
		
		СтруктураДанныхОтвета = КоннекторHTTP.Put(СтрШаблон("https://%1%2",
			РеквизитыМаркетПлйс.host, СтрШаблон("/api/v3/orders/%1/meta/sgtin", НомЗак)),,
			ДополнительныеПараметры);
		Если СтруктураДанныхОтвета.КодСостояния > 400 Тогда
			Сообщить("Ошибка записи марки для заказа");
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	// Ихсанов Д. А. Конец  03.07.2026
	
КонецФункции

