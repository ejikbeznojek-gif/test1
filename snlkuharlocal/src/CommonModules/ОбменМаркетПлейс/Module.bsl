Процедура МП_Вайлбериз_ПроверитьИПоделить(Зак, Лим, МенятьДоговор=Истина,МаркПл) Экспорт //не обработанный
	//взамен ПроверитьИПоделить(ТЗак, ЛимПоз, МенятьДоговор)
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	Попытка
		РНКСсыл=Зак.ДокОснование;
	Исключение
		ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Нет основания у документа "+Строка(Зак),"Ошибка");
		Возврат;
	КонецПопытки;
	
	КолК=РНКСсыл.Комплектующие.Итог("Количество");
	
	КолТ=РНКСсыл.Товары.Итог("Количество");
	
	Если Окр(КолК/Лим)<2 Тогда
		Возврат;
	КонецЕсли;
	
	КолСтрТов=РНКСсыл.Товары.Количество();
	
	ПослСтр=РНКСсыл.Товары.Получить(КолСтрТов-1);
	
	НомУбир=ПослСтр.Номенклатура;
	
	
	КолНовДок=Окр(КолК/Лим)-1;
	ПК=1-(Окр(КолК/Лим)-Цел(КолК/Лим));
	
	ПН=Зак.Товары.Количество()-1;
	
	Если КолНовДок Тогда
		
		Если МаркПл.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"Начало выполнения. Задача: Разделение документов по кол-ву. !","Информация");
		КонецЕсли;
		
		НачатьТранзакцию();
		// Кухарь А.Ю. 07.04.2025 начало 
		//Временно
		ЗаписатьВЛог("Отладка","Начало транзакции маркетплейсы №10","Информация"); 
		// Кухарь А.Ю. 07.04.2025 конец
		Попытка
			
			ЗакИсх=Зак.ПолучитьОбъект();
			РНКИсх=РНКСсыл.ПолучитьОбъект();
			
			РЗ1=РежимЗаписиДокумента.Запись;
			РЗ2=РежимЗаписиДокумента.Запись;
			Коэф=Цел(КолК/КолТ);
			
			Если ЗакИсх.Проведен Тогда
				РЗ1=РежимЗаписиДокумента.Проведение;  				
				ЗакИсх.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;
			
			Если РНКИсх.Проведен Тогда
				РЗ2   =РежимЗаписиДокумента.Проведение;				
				РНКИсх.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;	
			НомДок=0;
			КолИзм=0;
			к=ЗакИсх.Товары.Количество()-1;
			Пока (НомДок<КолНовДок) Цикл
				Если ПН<=1 Тогда
					Прервать;
				КонецЕсли;	
				ТекЗак=Документы.ЗаказКлиентаFBS.СоздатьДокумент();
				ТекДок=Документы.РасходнаяНакладная.СоздатьДокумент();
				
				ТекДок.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад;
				
				
				ЗаполнитьЗначенияСвойств(ТекЗак,ЗакИсх,,"Номер,Дата,ДокОснование");
				ТекЗак.Дата=ТекущаяДата();
				ТекЗак.УстановитьНовыйНомер();
				ЗаполнитьЗначенияСвойств(ТекДок,РНКИсх,,"Номер,Дата");
				КолДок=0;
				
				Пока (к>=0) И ((КолДок*Коэф)<(Лим)) Цикл
					тс=ЗакИсх.Товары.Получить(к);
					//Если НЕ тс.Отменен И тс.Номенклатура=НомУбир Тогда
					Если Не тс.Отменен И НЕ тс.ВычеркОфис и Не тс.ВычеркСклад И тс.Номенклатура=НомУбир Тогда
						нс=ТекЗак.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(нс,тс,,"НомерСтроки");
						ЗакИсх.Товары.Удалить(к);
						КолИзм=КолИзм+1;
						КолДок=КолДок+1;
					КонецЕсли;	
					к=к-1;
				КонецЦикла;	
				ПН=к;
				
				
				//ТекДок.ОтгрузкаКомплектов =истина;
				Если КолДок>0 Тогда
					нст=ТекДок.Товары.Добавить();
					тст=РНКИсх.Товары.Получить(КолСтрТов-1);
					
					ЗаполнитьЗначенияСвойств(нст,тст,,"НомерСтроки");
					нст.Заявка=КолДок;
					нст.ПодтвержденнаяЗаявка=КолДок;
					нст.Количество=КолДок;
					
					тст.Заявка=тст.Заявка-КолДок;
					тст.ПодтвержденнаяЗаявка=тст.ПодтвержденнаяЗаявка-КолДок;
					тст.Количество=тст.Количество-КолДок;
					ТекДок.Дата=ТекущаяДата();
					УстановитьНомерДокументаКлиентСервер(ТекДок);
					
					ЗаполнитьКомплектующие(ТекДок);
					
					
					ПунктДоставки_ПриИзменении(ТекДок, МенятьДоговор);
					ТекДок.Записать(РЗ2);
					ТекЗак.ДокОснование=ТекДок.Ссылка;
					ТекЗак.Записать(РЗ1);
					
					Если МаркПл.Тест Тогда
						ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"Процесс выполнения. Задача: Разделение документов по кол-ву. Записан нов. документ "+Строка(ТекДок.Ссылка),"Информация");
					КонецЕсли;
					
				КонецЕсли;
				НомДок=НомДок+1;
			КонецЦикла;
			
			ЗакИсх.Записать(РЗ1);
			РНКИсх.Комплектующие.Очистить();
			ЗаполнитьКомплектующие(РНКИсх);
			
			
			
			РНКИсх.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад;
			РНКИсх.Записать(РЗ2);
			
			Если МаркПл.Тест Тогда
				ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"Процесс выполнения. Задача: Разделение документов по кол-ву. Записан исх. документ "+Строка(РНКИсх.Ссылка),"Информация");
			КонецЕсли;
			
			Если ТранзакцияАктивна() Тогда
				ЗафиксироватьТранзакцию();
			КонецЕсли;
			
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			Если МаркПл.Тест Тогда
				ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"Фин выполнения. Задача: Разделение документов по кол-ву. Возникла ошибка! "+ОписаниеОшибки(),"Информация");
			КонецЕсли; 
			
		КонецПопытки;
		
		Если МаркПл.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"Фин выполнения. Задача: Разделение документов по кол-ву. Успешно!","Информация");
		КонецЕсли;  	
		
	КонецЕсли;
	
КонецПроцедуры	

Процедура МП_Вайлбериз_ДозагрузитьЗагрузитьШК(МаркПл,Тест=Ложь) Экспорт   //не обработана
	
	//ДозагрузитьЗагрузитьШК1(МаркПл,Тест=Ложь)
	
	ДатаОтгрузки = Началодня(ТекущаяДата());
	
	ДеньВСекундах=24*60*60;
	
	//Стало Тимофеев Ю.А. 28.02.2024
	//отбор по равенству договоров
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказКлиентаFBS.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBS
	|ГДЕ
	|	ЗаказКлиентаFBS.Ссылка.Проведен
	|	И ЗаказКлиентаFBS.Ссылка.Контрагент = &Вайлдб
	|	И ЗаказКлиентаFBS.ШтрихКод = &Пусто
	|	И ЗаказКлиентаFBS.Ссылка.Дата >= &ДатаДок
	|	И ЗаказКлиентаFBS.Ссылка.ДокОснование.Договор = &Договор";
	//Параметры запроса
	Запрос.УстановитьПараметр("Вайлдб", МаркПл.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("ДатаДок",ТекущаяДата()   - 5*ДеньВСекундах);// Дата
	Запрос.УстановитьПараметр("Договор",МаркПл.Договор);// Договоры
	Запрос.УстановитьПараметр("Пусто","");
	
	//Конец Тимофеев Ю.А. 28.02.2024
	
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Статус="1";
	
	СостояниеУКлиента=Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(Статус);
	
	Пока рез.Следующий() Цикл
		
		док=рез.ссылка;
		
		Р=МП_ВыгрузитьСтатусыНаПортал(Док,МаркПл);
		
		
		Если Р>0 Тогда
			
			ДокОб=док.ПолучитьОбъект();
			
			НужноЗаписывать = Ложь;
			
			Для Каждого ТСтр Из ДокОб.Товары Цикл
				
				Если ТСтр.СостояниеУКлиента<>СостояниеУКлиента Тогда
					
					ТСтр.СостояниеУКлиента=СостояниеУКлиента;
					НужноЗаписывать = Истина;
					
				КонецЕсли;
				
			КонецЦикла;	
			
			Если НужноЗаписывать Тогда
				
				ДокОб.Записать(РежимЗаписиДокумента.Проведение); 			
				
			КонецЕсли;
			
			МП_Вайлбериз_ЗапросПоСтикерам(Док,МаркПл,Тест);
			
			
		КонецЕсли;    		
		
	конецЦикла;
	
КонецПроцедуры

