// Функция - МП Магнит вернуть соединение
//
// Параметры:
//  МаркетПлейс	 - Справочник.ИнетМагазины	 - Ссылка на сущность маркетплейса
// 
// Возвращаемое значение:
//  HTTPСоединение - Данные соединения с сервисом
//
Функция МП_Магнит_ВернутьСоединение(МаркетПлейс)  Экспорт
	
	Соединение = Неопределено;
	
	Попытка
		АдресТ = МаркетПлейс.АдресРесурса;
		
		Если МаркетПлейс.Порт="443" Тогда
			Соединение = Новый HTTPСоединение(АдресТ,443,,,,,Новый ЗащищенноеСоединениеOpenSSL);  
		Иначе
			Соединение = Новый HTTPСоединение(АдресТ);
		КонецЕсли;
	Исключение  		
		#Если клиент Тогда
			Сообщить("Ошибка при попытке соединения "+ОписаниеОшибки()); 			
		#КонецЕсли 		
	КонецПопытки;
	
	Возврат Соединение;
	
КонецФункции // МП_Магнит_ВернутьСоединение()

