Функция МП_Вайлберриз_СформироватьТЗОстатковФинальная(ТЗОст) Экспорт
	
	//ТИМОФЕЕВ Ю.А. 16.01.24
	//замена СформироватьТЗОстФин11(ТЗОстаткиМатрица)
	//ТИМОФЕЕВ Ю.А. 16.01.24
	
	
	ТЗОстФин=неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ТЗНомСкл.СебестоимостьБух КАК СебестоимостьБух,
	|	ТЗНомСкл.КолКонФакт КАК КолКонФакт,
	|	ТЗНомСкл.Комплект КАК Комплект,
	|	ТЗНомСкл.Резерв КАК Резерв,
	|	ТЗНомСкл.РезервКомпл КАК РезервКомпл,
	|	ТЗНомСкл.Номенклатура КАК Номенклатура,
	|	ТЗНомСкл.ШККонтра КАК ШККонтра,
	|	ТЗНомСкл.ШККонтра1 КАК ШККонтра1,
	|	ТЗНомСкл.КодКонтра КАК КодКонтра,
	|	ТЗНомСкл.ЦенаМатрица КАК ЦенаМатрица,
	|	ТЗНомСкл.Матрица КАК Матрица,
	|	ТЗНомСкл.МатрицаДата КАК МатрицаДата,
	|	ТЗНомСкл.ВыгрОст0 КАК ВыгрОст0,
	|	ТЗНомСкл.МатрКоличество КАК МатрКоличество,
	|	ВЫБОР
	|		КОГДА ТЗНомСкл.ВыгрОст0
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ТЗНомСкл.МатрКоличество < ТЗНомСкл.КВыгрузке
	|					ТОГДА ТЗНомСкл.МатрКоличество
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ТЗНомСкл.КВыгрузке > 0
	|							ТОГДА ТЗНомСкл.КВыгрузке
	|						ИНАЧЕ 0
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК КВыгрузке
	|ПОМЕСТИТЬ ВТ_НомОст
	|ИЗ
	|	&ТЗНомОст КАК ТЗНомСкл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНомСкл.СебестоимостьБух КАК СебестоимостьБух,
	|	ТЗНомСкл.КолКонФакт КАК КолКонФакт,
	|	ТЗНомСкл.Комплект КАК Комплект,
	|	ТЗНомСкл.Резерв КАК Резерв,
	|	ТЗНомСкл.РезервКомпл КАК РезервКомпл,
	|	ТЗНомСкл.Номенклатура КАК Номенклатура,
	|	ТЗНомСкл.ШККонтра КАК ШККонтра,
	|	ТЗНомСкл.ШККонтра1 КАК ШККонтра1,
	|	ТЗНомСкл.КодКонтра КАК КодКонтра,
	|	ТЗНомСкл.ЦенаМатрица КАК ЦенаМатрица,
	|	ТЗНомСкл.Матрица КАК Матрица,
	|	ТЗНомСкл.МатрицаДата КАК МатрицаДата,
	|	ТЗНомСкл.МатрКоличество КАК МатрКоличество,
	|	ТЗНомСкл.КВыгрузке КАК КВыгрузке
	|ИЗ
	|	ВТ_НомОст КАК ТЗНомСкл";
	
	Запрос.УстановитьПараметр("ТЗНомОст",ТЗОст);
	
	ТЗОстФин=Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗОстФин;
	
