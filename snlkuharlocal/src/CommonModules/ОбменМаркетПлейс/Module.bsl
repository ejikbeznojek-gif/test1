		ЗначениеВФайл(ИмяФайлаЛога, ДанныеКВыгрузке);
	Исключение
		ЗаписатьВЛог("ЗаписьЛога_ОШИБКА", СтрШаблон("%1. Имя файла %2 - %3", ПрефиксМаркетПлейса, ИмяФайлаЛога, 
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "ИСКЛЮЧЕНИЕ_ОШИБКА");
	КонецПопытки;
	
	// Ихсанов Д. А. Начало 15.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2188
	Если МаркетПлейс.Тест Тогда
		ВсегоСтрок 		 = Строка(ДанныеКВыгрузке.Количество());
		КоличествоТовара = Строка(ДанныеКВыгрузке.Итог("КВыгрузке"));
		ЗаписатьВЛог("МП_Магнит", СтрШаблон("Окончание выгрзки остатков Магнит! Строк: %1, общее количество %2.",
		ВсегоСтрок, КоличествоТовара), "Информация");
	КонецЕсли;
	// Ихсанов Д. А. Конец  15.04.2025
	
КонецПроцедуры // МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков_МагнитМаркет()

// Универсальные блоки кода, соответствующие работе с документами от функционала ОЗОН и ВБ
// РЕФАКТОРИНГ - Легаси
Функция МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ_для_МАГНИТ(МаркетПлейс, НужныйСклад, СкладВычерка = Неопределено) Экспорт
	
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Если СкладВычерка = Неопределено Тогда
		СкладВычерка = Справочники.Склады.ПустаяСсылка()
	КонецЕсли;
	// Ихсанов Д. А. Конец  20.08.2025
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	СУММА(ВложенныйЗапрос.Остаток) КАК Остаток,
	|	СУММА(ВложенныйЗапрос.Резерв) КАК Резерв,
	|	СУММА(ВложенныйЗапрос.КолКонФакт) КАК КолКонФакт
	|ПОМЕСТИТЬ ВТ_ОстаткиМинус
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|		ОстаткиТМЦОстатки.КоличествоОстаток КАК КолКонФакт,
	|		ОстаткиТМЦОстатки.КоличествоОстаток КАК Остаток,
	|		0 КАК Резерв
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад = &Склад) КАК ОстаткиТМЦОстатки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыТМЦОстатки.Номенклатура,
	|		-РезервыТМЦОстатки.КоличествоОстаток,
	|		0,
	|		РезервыТМЦОстатки.КоличествоОстаток
	|	ИЗ
	|		РегистрНакопления.РезервыТМЦ.Остатки(, Склад = &Склад) КАК РезервыТМЦОстатки) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОстаткиМинус.Номенклатура КАК Номенклатура,
	|	ВТ_ОстаткиМинус.Остаток КАК Остаток,
	|	ВТ_ОстаткиМинус.Резерв КАК Резерв,
	|	ВЫБОР
	|		КОГДА ВТ_ОстаткиМинус.КолКонФакт < 0
	|			ТОГДА 0
	|		ИНАЧЕ ВТ_ОстаткиМинус.КолКонФакт
	|	КОНЕЦ КАК КолКонФакт
	|ПОМЕСТИТЬ ВТ_ОСТАТКИ
	|ИЗ
	|	ВТ_ОстаткиМинус КАК ВТ_ОстаткиМинус
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаПунктыДоставки.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Матрицы
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ГДЕ
	|	ИСТИНА
	|	И МатрицаПунктыДоставки.Ссылка.Проведен
	|	И МатрицаПунктыДоставки.Ссылка.Контрагент = &Контрагент
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаПунктыДоставки.Ссылка.Договор = &Договор
	|	И (ЛОЖЬ
	|			ИЛИ МатрицаПунктыДоставки.Ссылка.ДатаОкончания > &ДатаОкончания
	|			ИЛИ МатрицаПунктыДоставки.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаПунктыДоставки.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.ШК КАК ШК,
	|	ВложенныйЗапрос.МатрицаДата КАК МатрицаДата,
	|	ВложенныйЗапрос.МатрицаКоличество КАК МатрицаКоличество,
	|	ВложенныйЗапрос.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВложенныйЗапрос.Матрица КАК Матрица,
	|	ВложенныйЗапрос.offer_id КАК offer_id,
	|	ВложенныйЗапрос.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВложенныйЗапрос.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_НомМатрицы
	|ИЗ
	|	(ВЫБРАТЬ
	|		МатрицаТовары.Номенклатура КАК Номенклатура,
	|		ВЫРАЗИТЬ(МатрицаТовары.ШККонтрагента КАК СТРОКА(150)) КАК ШК,
	|		ВЫРАЗИТЬ(МатрицаТовары.НаименованиеКонтрагента КАК СТРОКА(100)) КАК offer_id,
	|		ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(100)) КАК АртикулКонтрагента,
	|		ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(50)) КАК Product_ID,
	|		МатрицаТовары.Ссылка.Дата КАК МатрицаДата,
	|		МатрицаТовары.Выгружать0Ост КАК ВыгружатьОст0,
	|		ВЫБОР
	|			КОГДА МатрицаТовары.Выгружать0Ост
	|				ТОГДА 0
	|			ИНАЧЕ МатрицаТовары.МинимальноеКоличество
	|		КОНЕЦ КАК МатрицаКоличество,
	|		МатрицаТовары.Ссылка КАК Матрица
	|	ИЗ
	|		Документ.Матрица.Товары КАК МатрицаТовары
	|	ГДЕ
	|		МатрицаТовары.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТ_Матрицы.Ссылка КАК Ссылка
	|				ИЗ
	|					ВТ_Матрицы КАК ВТ_Матрицы)
	|		И МатрицаТовары.ШККонтрагента <> """") КАК ВложенныйЗапрос
	|ГДЕ
	|	(ВложенныйЗапрос.ВыгружатьОст0
	|			ИЛИ ВложенныйЗапрос.МатрицаКоличество > 0)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НомМатрицы.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ВТ_НомМатрицы.МатрицаДата) КАК ДатаМакс
	|ПОМЕСТИТЬ ВТ_НомОтбор
	|ИЗ
	|	ВТ_НомМатрицы КАК ВТ_НомМатрицы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Матрицы КАК ВТ_Матрицы
	|		ПО ВТ_НомМатрицы.Матрица = ВТ_Матрицы.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_НомМатрицы.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НомОтбор.Номенклатура КАК Номенклатура,
	|	ВТ_НомМатрицы.ШК КАК ШК,
	|	ВТ_НомМатрицы.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_НомМатрицы.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_НомМатрицы.offer_id КАК offer_id,
	|	ВТ_НомМатрицы.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТ_НомМатрицы.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_Продукция
	|ИЗ
	|	ВТ_НомОтбор КАК ВТ_НомОтбор
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомМатрицы КАК ВТ_НомМатрицы
	|		ПО ВТ_НомОтбор.ДатаМакс = ВТ_НомМатрицы.МатрицаДата
	|			И (ВТ_НомМатрицы.Номенклатура = ВТ_НомОтбор.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Продукция.Номенклатура КАК Номенклатура,
	|	ВТ_Продукция.ШК КАК ШК,
	|	МАКСИМУМ(ВТ_Продукция.МатрицаКоличество) КАК МатрицаКоличество,
	|	МАКСИМУМ(ЕСТЬNULL(ВТ_Остатки.КолКонФакт, 0)) КАК Остаток,
	|	ВТ_Продукция.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_Продукция.offer_id КАК offer_id,
	|	ВТ_Продукция.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТ_Продукция.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_СВОД
	|ИЗ
	|	ВТ_Продукция КАК ВТ_Продукция
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОСТАТКИ КАК ВТ_Остатки
	|		ПО ВТ_Продукция.Номенклатура = ВТ_Остатки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Продукция.Номенклатура,
	|	ВТ_Продукция.ШК,
	|	ВТ_Продукция.ВыгружатьОст0,
	|	ВТ_Продукция.offer_id,
	|	ВТ_Продукция.АртикулКонтрагента,
	|	ВТ_Продукция.Product_ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СВОД.Номенклатура КАК Номенклатура,
	|	ВТ_СВОД.ШК КАК ШК,
	|	ВТ_СВОД.Остаток КАК Остаток,
	|	ВТ_СВОД.МатрицаКоличество КАК МатрицаКоличество,
	|	ВЫБОР
	|		КОГДА &ВыгрузкаПоМатрице
	|			ТОГДА ВЫБОР
	|					КОГДА ВТ_СВОД.Остаток = 0
	|						ТОГДА 0
	|					ИНАЧЕ ВЫБОР
	|							КОГДА ВТ_СВОД.Остаток >= ВТ_СВОД.МатрицаКоличество
	|								ТОГДА ВТ_СВОД.МатрицаКоличество
	|							ИНАЧЕ ВТ_СВОД.Остаток
	|						КОНЕЦ
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТ_СВОД.МатрицаКоличество > 0
	|					ТОГДА ВТ_СВОД.Остаток
	|				ИНАЧЕ 0
	|			КОНЕЦ
	|	КОНЕЦ КАК КВыгрузке,
	|	ВТ_СВОД.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_СВОД.offer_id КАК offer_id,
	|	ВТ_СВОД.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТ_СВОД.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_СВОДИтог
	|ИЗ
	|	ВТ_СВОД КАК ВТ_СВОД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	СУММА(ВложенныйЗапрос.ЗапретОстаток) КАК ЗапретОстаток
	|ПОМЕСТИТЬ ВТ_Запрет
	|ИЗ
	|	(ВЫБРАТЬ
	|		ИнетМагазиныИсключенияРасчетаОстатков.Номенклатура КАК Номенклатура,
	|		0 КАК ЗапретОстаток
	|	ИЗ
	|		Справочник.ИнетМагазины.ИсключенияРасчетаОстатков КАК ИнетМагазиныИсключенияРасчетаОстатков
	|	ГДЕ
	|		ИнетМагазиныИсключенияРасчетаОстатков.Ссылка = &МаркетПлейс
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЗапретОтгрузкиСоСкладов.Номенклатура,
	|		0
	|	ИЗ
	|		РегистрСведений.ЗапретОтгрузкиСоСкладов КАК ЗапретОтгрузкиСоСкладов
	|	ГДЕ
	|		ИСТИНА
	|		И ЗапретОтгрузкиСоСкладов.МаркетПлейс = &МаркетПлейс
	|		И ЗапретОтгрузкиСоСкладов.Склад = &Склад) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СВОДИтог.Номенклатура КАК Номенклатура,
	|	ВТ_СВОДИтог.ШК КАК ШК,
	|	ВТ_СВОДИтог.Остаток КАК Остаток,
	|	ЕСТЬNULL(ВТ_Запрет.ЗапретОстаток, ВТ_СВОДИтог.МатрицаКоличество) КАК МатрицаКоличество,
	|	ЕСТЬNULL(ВТ_Запрет.ЗапретОстаток, ВТ_СВОДИтог.КВыгрузке) КАК КВыгрузке,
	|	ВТ_СВОДИтог.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_СВОДИтог.offer_id КАК offer_id,
	|	ВТ_СВОДИтог.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТ_СВОДИтог.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_НужныйТовар
	|ИЗ
	|	ВТ_СВОДИтог КАК ВТ_СВОДИтог
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Запрет КАК ВТ_Запрет
	|		ПО ВТ_СВОДИтог.Номенклатура = ВТ_Запрет.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА НоменклатураКоплектующие.НомерСтроки > 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК МаксНомерСтроки,
	|	НоменклатураКоплектующие.Ссылка КАК МаксНоменклатура
	|ПОМЕСТИТЬ ИмеетКомпект
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТ_НужныйТовар.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ВТ_НужныйТовар КАК ВТ_НужныйТовар)
	|
	|СГРУППИРОВАТЬ ПО
	|	НоменклатураКоплектующие.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НужныйТовар.Номенклатура КАК Номенклатура,
	|	ВТ_НужныйТовар.ШК КАК ШК,
	|	ВТ_НужныйТовар.Остаток КАК Остаток,
	|	ВТ_НужныйТовар.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_НужныйТовар.КВыгрузке КАК КВыгрузке,
	|	ВЫБОР
	|		КОГДА ВТ_НужныйТовар.Номенклатура.ВидКомплекта <> &ГотовыйКомплект
	|			ТОГДА ЕСТЬNULL(ИмеетКомпект.МаксНомерСтроки, ЛОЖЬ)
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Комплект,
	|	ВТ_НужныйТовар.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_НужныйТовар.offer_id КАК offer_id,
	|	ВТ_НужныйТовар.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТ_НужныйТовар.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_НомОстОбщийВсе
	|ИЗ
	|	ВТ_НужныйТовар КАК ВТ_НужныйТовар
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИмеетКомпект КАК ИмеетКомпект
	|		ПО ВТ_НужныйТовар.Номенклатура = ИмеетКомпект.МаксНоменклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НомОстОбщийВсе.Номенклатура КАК Номенклатура,
	|	ВТ_НомОстОбщийВсе.ШК КАК ШК,
	|	ВЫБОР
	|		КОГДА ВТ_НомОстОбщийВсе.Комплект
	|			ТОГДА 0
	|		ИНАЧЕ ВТ_НомОстОбщийВсе.Остаток
	|	КОНЕЦ КАК Остаток,
	|	ВТ_НомОстОбщийВсе.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_НомОстОбщийВсе.КВыгрузке КАК КВыгрузке,
	|	ВТ_НомОстОбщийВсе.Комплект КАК Комплект,
	|	ВТ_НомОстОбщийВсе.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_НомОстОбщийВсе.offer_id КАК offer_id,
	|	ВТ_НомОстОбщийВсе.АртикулКонтрагента КАК АртикулКонтрагента,
