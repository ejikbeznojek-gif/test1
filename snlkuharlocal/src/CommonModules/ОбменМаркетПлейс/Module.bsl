Процедура ЗапроситьФормированиеЭтикетки(ИДЗак,МкПл1,Замещать=Ложь) Экспорт
	
	МкПл=Справочники.ИнетМагазины.НайтиПоКоду("00006");
	
	ПутьЭтикетки=МкПл.КаталогДляЭтикеток;
	ПутЭт=?(ЗначениеЗаполнено(ПутьЭтикетки),ПутьЭтикетки,"\\srvfiles\1C_Logs_MarketPlace\");
	Если НЕ Прав(ПутЭт,1)="\" Тогда
		ПутЭт=ПутЭт+"\";
	КонецЕсли;
	АдресТ =МкПл.АдресРесурса; 
	снт=0;
	Если НЕ Замещать Тогда
		Файл = Новый Файл(ПутЭт+ИДЗак+".pdf");
		Если Файл.Существует() Тогда
			РазмерФайла = Файл.Размер();
			Если РазмерФайла>1000 Тогда
				// уже есть этикетка
				#Если Клиент Тогда
					Сообщить(НСтр("ru='Уже есть '")+ПутЭт+ИДЗак+".pdf");
				#КонецЕсли
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Час(ТекущаяДатаСеанса())>17 Тогда
		ПредДата=ТекущаяДатаСеанса();
