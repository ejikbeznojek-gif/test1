Функция ПолучитьДжНеимМасИзТЗВБ1(Табл)
	Стрдж="[";
	КолКол=Табл.Колонки.Количество();
	Кол=Табл.Количество();
	счт=0;
	Пока счт<Кол Цикл
		текстр=Табл.Получить(счт);
		Стрдж=Стрдж+"{";
		к=0;
		Пока к<КолКол Цикл
			Если к=0 Тогда
				Стрдж=Стрдж+""""+Табл.Колонки[к].Имя+""":"""+текстр[к]+"""";
			Иначе	
				Стрдж=Стрдж+""""+Табл.Колонки[к].Имя+""":"+текстр[к];
			КонецЕсли;	
			Если НЕ (к=КолКол-1) Тогда
				Стрдж=Стрдж+",";
			КонецЕсли;
			к=к+1;
		КонецЦикла;
		Стрдж=Стрдж+"}";
		Если НЕ (счт=Кол-1) Тогда
			Стрдж=Стрдж+",";
		КонецЕсли;	
		счт=счт+1;
	КонецЦикла;	
	Стрдж=Стрдж+"]";
	Возврат Стрдж;
КонецФункции

