	|	МАКСИМУМ(&СостояниеУКлиента) КАК СостояниеУКлиента,
	// Ихсанов Д. А. Начало 02.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2612
	|	МАКСИМУМ(ЕСТЬNULL(вт_ФактическийОстатокТовара.Количество, 0)) КАК КоличествоОстаток,
	// Ихсанов Д. А. Конец  02.12.2025
	// Ихсанов Д. А. Начало 10.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2752
	|	МАКСИМУМ(ТЗНомЗак.ЗаказПоЮрЛицу) КАК ЗаказПоЮрЛицу
	// Ихсанов Д. А. Конец 10.04.2026
	|ИЗ
	|	ВТ_Итог КАК ТЗНомЗак
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Ост КАК ТЗОст
	|		ПО ТЗНомЗак.Номенклатура = ТЗОст.Номенклатура
	|			И (ТЗОст.Склад В ИЕРАРХИИ (&Склад))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстСвод КАК ТЗОстСвод
	|		ПО ТЗНомЗак.Номенклатура = ТЗОстСвод.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО (РасходнаяНакладная.Ссылка.Контрагент = &Контрагент)
	|			И (РасходнаяНакладная.Ссылка.НомерЗаказа = ТЗНомЗак.ИДЗаказа)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ПО (РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка)
	|			И (РасходнаяНакладнаяТовары.Номенклатура = ТЗНомЗак.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО (ЗаказКлиентаFBSТовары.НомерЗаказа = ТЗНомЗак.ИДЗаказа)
	|			И (ЗаказКлиентаFBSТовары.Номенклатура = ТЗНомЗак.Номенклатура)
	|			И (ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО (ПредварительныйЗаказКлиентаТовары.НомерЗаказа = ТЗНомЗак.ИДЗаказа)
	|			И (ПредварительныйЗаказКлиентаТовары.Номенклатура = ТЗНомЗак.Номенклатура)
	|			И (ПредварительныйЗаказКлиентаТовары.Ссылка.Контрагент = &Контрагент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТоварыСвод
	|		ПО (ЗаказКлиентаFBSТовары.Ссылка.ДокОснование = РасходнаяНакладнаяТоварыСвод.Ссылка)
	|			И (ЗаказКлиентаFBSТовары.Номенклатура = РасходнаяНакладнаяТоварыСвод.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗагрЗак КАК ЗагрЗак
	|		ПО (ЗагрЗак.НомерЗаказа = ТЗНомЗак.ИДЗаказа)
	// Ихсанов Д. А. Начало 02.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2612
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ФактическийОстатокТовара КАК вт_ФактическийОстатокТовара
	|		ПО (ТЗНомЗак.Номенклатура = вт_ФактическийОстатокТовара.Номенклатура)
	// Ихсанов Д. А. Конец  02.12.2025
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗНомЗак.ИДЗаказа";
	
	Запрос.УстановитьПараметр("ТЗНомМатр",    ТЗНомМатр);
	Запрос.УстановитьПараметр("ТЗНомЗак",     ТЗНомЗак);
	Запрос.УстановитьПараметр("Контрагент",   МаркПл.Контрагент);
	Запрос.УстановитьПараметр("Склад",        МаркПл.Склад);
	// Ихсанов Д. А. Начало 02.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2612
	Запрос.УстановитьПараметр("СкладМаркировки", МаркПл.СкладМаркировки);
	// Ихсанов Д. А. Конец  02.12.2025
	Запрос.УстановитьПараметр("ПунктДоставки",МаркПл.ПунктДоставки);
	
	Запрос.УстановитьПараметр("Договор",      МаркПл.Договор);
	Запрос.УстановитьПараметр("Дата1",        ТекущаяДатаСеанса());
	
	// Ихсанов Д. А. Начало 06.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7648
	Запрос.УстановитьПараметр("СостояниеУКлиента",
		Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("1", Истина));
	// Ихсанов Д. А. Конец  06.11.2025
	
	ТЗЗаказы=Запрос.Выполнить().Выгрузить();
	
	ТЗЗаказы=МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТЗЗаказы);
	
	Возврат ТЗЗаказы;
	
КонецФункции

Функция МП_Вайлдберриз_ПолучитьЗаказыССайта(МаркПл,ДатаНач,СтруктураПараметров=Неопределено) Экспорт //Новый
	
	//взамен ПолучитьТЗЗакСайт1(МаркПл,ДатаНач)
	
	ТЗЗ = Новый ТаблицаЗначений;	  		
	ТЗЗ.Колонки.Добавить("ИДЗаказа",    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	ТЗЗ.Колонки.Добавить("ШК",          Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	ТЗЗ.Колонки.Добавить("ШК1",         Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	ТЗЗ.Колонки.Добавить("Статус",      Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(5)));
	ТЗЗ.Колонки.Добавить("Создан",      Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(30)));
	ТЗЗ.Колонки.Добавить("ДатаСоздания",Новый ОписаниеТипов("Дата"));
	ТЗЗ.Колонки.Добавить("Артикул",     Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	ТЗЗ.Колонки.Добавить("Кол",         Новый ОписаниеТипов("Число",    Новый КвалификаторыЧисла(15, 2)));
	ТЗЗ.Колонки.Добавить("Сумма",       Новый ОписаниеТипов("Число",    Новый КвалификаторыЧисла(15, 2)));
	ТЗЗ.Колонки.Добавить("РИД",         Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	ТЗЗ.Колонки.Добавить("ПИД",         Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	// Ихсанов Д. А. Начало 10.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2752
	ТЗЗ.Колонки.Добавить("ЗаказПоЮрЛицу", Новый ОписаниеТипов("Булево"));
	// Ихсанов Д. А. Конец 10.04.2026
	
	МаксЗаказов=0;
	Если СтруктураПараметров<>Неопределено Тогда
		Если СтруктураПараметров.Свойство("МаксЗаказов") Тогда
			МаксЗаказов=СтруктураПараметров.МаксЗаказов;
		КонецЕсли;
	КонецЕсли;
	
	НетЦенаВВалюте = 0;
	
	
	Если ЗначениеЗаполнено(МаркПл.Token2) Тогда
		НашКлючАдмин =МаркПл.Token2;
	Иначе
		НашКлючАдмин =МаркПл.Token;
	КонецЕсли;
	
	HTTP_запрос = Новый HTTPзапрос();   	
	АдресТ      = МаркПл.АдресРесурса; 	
	
	//для фильта по складу получателя
	ИндетификаторСклада = Число(МаркПл.warehouseId);
	
	Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	ЗаголовокHTTP  = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Authorization", НашКлючАдмин); 	
	HTTP_запрос.Заголовки    = ЗаголовокHTTP;    
	HTTP_запрос.АдресРесурса = "/api/v3/orders/new";  
	
	Попытка
		
		ОтветЗапроса = Соединение.Получить(HTTP_запрос); 
		
		Если ОтветЗапроса.КодСостояния < 400 Тогда
			
			ВозвСтр0 = ОтветЗапроса.ПолучитьТелоКакСтроку();
			
			ЧтениеJSON0       = Новый ЧтениеJSON;
			ЧтениеJSON0.УстановитьСтроку(ВозвСтр0);
			СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);
			
			МассивЗаказов = СтруктураИзСтроки["orders"];    		
			
			Для каждого СтрМассива из МассивЗаказов Цикл	 				
				
				Попытка
					
					//фильтр по складу получателю
					
					Если СтрМассива.warehouseId<>ИндетификаторСклада Тогда
						Продолжить;
					КонецЕсли;				
					
					СозданЗ       = СокрЛП(СтрМассива.createdAt);
					ДатаСозданияЗ = ПолучитьДатуИзСтр(СозданЗ); 		
					
					Если (ДатаСозданияЗ>=ДатаНач) Тогда
						
						//цена возвращается в разных валютах продажах
						//если рубль - 643 берем PRICE иначе convertedPrice
						Если СтрМассива.convertedCurrencyCode=СтрМассива.currencyCode=643 Тогда
							ЦенаСНулями = СтрМассива.Price;
						Иначе
							ЦенаСнулями = СтрМассива.convertedPrice;
						КонецЕсли;	
						
						//Тимофеев Ю.А. 17.10.24 может не быть цены перерасчета
						
						Если Число(ЦенаСНулями)>0  Тогда
							
							НовСтр             = ТЗЗ.Добавить();
							НовСтр.ИДЗаказа    = Строка(СтрМассива.Id);    //число
							НовСтр.ШК          = СокрЛП(СтрМассива.skus[0]);
							Если СтрМассива.skus.Количество()>1 Тогда 
								НовСтр.ШК1     = СокрЛП(СтрМассива.skus[1]);
							КонецЕсли;	
							НовСтр.Артикул     = Строка(СтрМассива.chrtId); //число;
							НовСтр.Кол         = 1;
							НовСтр.Создан      = СозданЗ;
							НовСтр.ДатаСоздания= ДатаСозданияЗ;
							НовСтр.Статус      = "0";
							// Ихсанов Д. А. Начало 10.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2752
							Новстр.ЗаказПоЮрЛицу = СтрМассива.options.isB2B;
							// Ихсанов Д. А. Конец 10.04.2026
							
							//Тимофеев Ю.А. 17.10.24 может не быть цены перерасчета
							
							НовСтр.Сумма       = Число(ЦенаСнулями)/100;
							//Тимофеев Ю.А. 27.06.2024
							НовСтр.РИД         = СокрЛП(СтрМассива.rid);	
							
						Иначе
							//иначе НОВЫЙ ЗАКАЗ пропускаем и не загружаем !!!
							
							НетЦенаВВалюте = НетЦенаВВалюте+1; 
							
						КонецЕсли;
						
					КонецЕсли;
					
				Исключение
					
					#Если Клиент Тогда
						Сообщить(ОписаниеОшибки());
					#КонецЕсли
					
				КонецПопытки;	
				
				Если МаксЗаказов= 0 Тогда
					
				ИначеЕСли ТЗЗ.Количество()>МаксЗаказов Тогда
					Прервать;
				КонецЕсли;
				
				
				Если НетЦенаВВалюте > 0 Тогда
					
					ЗаписатьВЛог("МП_Вайлберриз","Нет цены в валюте "+Строка(НетЦенаВВалюте),"Ошибка");
					
					
					Попытка
						
						Сооб="МП_Вайлберриз - Нет цены в валюте "+Строка(НетЦенаВВалюте) +" заказ. Заказы не загружены !" ;
						
						СписокПолучателей=новый СписокЗначений;
						
						СписокПолучателей.Добавить("timofeev@collant.ru");   //пока на время теста только мне						
						СписокПолучателей.Добавить("smirnyagina@collant.ru"); 
						ТекстОповещения="Привет!"+Символы.ПС+Сооб;
						ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,"МП_Вайлберриз - Нет цен перерасчета из валюты",ТекстОповещения);   
					Исключение
						
					КонецПопытки;	
					
				КонецЕсли;
				
			КонецЦикла;	   			
		КонецЕсли;
		
	Исключение  		
		#Если клиент Тогда
			Сообщить(ОписаниеОшибки());
		#КонецЕсли   		
	КонецПопытки;    	
	
	Возврат ТЗЗ;
	
КонецФункции	

Функция МП_Вайлбериз_ПроверитьСтатусы(Док,МаркПл) Экспорт  
	
	//получить статусы заказов из документа ЗАКАЗ FBS
	
	// ПроверитьСтатусыМкПл1(Док,МаркПл);
	
	Рез=Новый Соответствие;
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз","Начало выполнения. Задача: Получение статусов ВБ"+ПрефиксМаркета+" !","Информация");
	КонецЕсли;
	
	Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	HTTP_запрос = новый HTTPзапрос();
	
	
	HTTP_запрос.АдресРесурса="/api/v3/orders/status"; //Тимофеев Ю.А. 12.03 убрал лишний слеш
	
	ЗаголовокHTTP = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);	
	
	МасЗак=Новый Массив;
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.РИД КАК РИД,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка = &текдок";
	//   |	И ЗаказКлиентаFBSТовары.ШтрихКод = &Пусто";
	
	
	Запрос.УстановитьПараметр("ТекДок",Док.ссылка);
	
	
	Выб =Запрос.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		МасЗак.Добавить(Выб.НомерЗаказа);
	КонецЦикла;	
	
	
	Если НЕ МасЗак.Количество() Тогда
		Возврат Рез;
	КонецЕсли;	   
	
	Тот=0;
	КолТот=МасЗак.Количество();
	ТотСтр="";
	МасИД=Новый Массив;
	
	Пока Истина Цикл
		
		ФормСтр="";
		//ТЗ.Очистить();
		Счт=0;
		Если Тот>(КолТот-1) Тогда
			Прервать;
		КонецЕсли;
		//порциями не более 100
		МасИД.Очистить();
		Пока (Тот<КолТот) И (Счт<100) Цикл
			ТекСтр=МасЗак.Получить(Тот);
			МасИД.Добавить(Число(ТекСтр));     //Тимофеев Ю.А. 12.03 число
			Тот=Тот+1;
			Счт=Счт+1;
		КонецЦикла;
		
		Если НЕ МасИД.Количество() Тогда
			Прервать;
		КонецЕсли;	
		
		ПолСтр=МП_ВернутьСписокОрдеровВайлберизJSON(МасИД);
		
		#Если Клиент Тогда
			Сообщить(ПолСтр);
		#КонецЕсли
		
		
		
		РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
		
		
		ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
		//ФайлРезультата = ПолучитьИмяВременногоФайла();
		HTTP_запрос.Заголовки = ЗаголовокHTTP;
		//HTTP_запрос.УстановитьИмяФайлаТела(ФайлЗапроса);
		HTTP_запрос.УстановитьТелоИзСтроки(ПолСтр);
		
		ОСтр=HTTP_запрос.ПолучитьТелоКакСтроку();
		//Сообщить(ОСтр);
		//Отправляем для обрааботки на наш сервер
		Ответ = Соединение.ОтправитьДляОбработки(HTTP_запрос); //,ИмяВыходногоФайла);// Соединение.Получить(HTTP_запрос);  // ИмяВыходногоФайла
		//Сообщить("КодСостояния "+Строка(Ответ.КодСостояния));
		ВС=Ответ.ПолучитьТелоКакСтроку();
		
		
		#Если Клиент Тогда
			Сообщить(Строка(Ответ.КодСостояния)+" ответ "+ВС);
		#КонецЕсли
		
		Если Ответ.КодСостояния<400 Тогда	
			ЧтениеJSON1 = Новый ЧтениеJSON;
			ЧтениеJSON1.УстановитьСтроку(ВС);
			Сода = ПрочитатьJSON(ЧтениеJSON1); 
			
			
			МасЗак = Сода["orders"];
			
			//сообщить(сода);
			//{"orders":[{"supplierStatus":"complete","wbStatus":"sorted","id":633008733},
			
			Если МасЗак.Количество() Тогда
				
				н=0;
				Пока н<МасЗак.Количество() Цикл
					ТекСтру=МасЗак[н];
					Рез.Вставить(СокрЛП(ТекСтру["id"]),СокрЛП(ТекСтру["supplierStatus"]));
					н=н+1;
				КонецЦикла;	
				
			КонецЕсли;     			
		Иначе
			Сообщить("Ошибка, код "+Строка(Ответ.КодСостояния));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат РЕЗ;
	
КонецФункции

Функция МП_Вайлбериз_ПолучитьМатрицуПоНоменклатуре(МаркПл,Номенклатура) Экспорт
	
	//единичный случай, когда по Ном не найдена матрица
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.Ссылка КАК Матрица
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Проведен
	|   И МатрицаТовары.ШККонтрагента <> """"
	|	И (МатрицаТовары.Ссылка.ДатаОкончания > &Дата1
	|			ИЛИ МатрицаТовары.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
	|	И МатрицаТовары.Номенклатура = &Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Матрица УБЫВ";
	//Параметры запроса
	Запрос.УстановитьПараметр("Дата1",       ТекущаяДатаСеанса());// Дата
	Запрос.УстановитьПараметр("Договор",     МаркПл.Договор);// Договоры
	Запрос.УстановитьПараметр("Контрагент"  ,МаркПл.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);// Номенклатура
	
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		
		Возврат Результат.Матрица;
		
	Иначе
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции 

