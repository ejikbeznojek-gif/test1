// МП Загрузить заказы с сайта.
// 
// Параметры:
//  ПараметрыОбработки - Структура - Параметры обработки
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркет плейс
// 
// Возвращаемое значение:
//  Булево - Загрузить заказы с сайта
Функция МП_ЗагрузитьЗаказыССайта(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт
	
	// Забираем данные по имеющимся записям заказов. Записи обозначают факт загрузки заказов с сервиса в рамках обмена.
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстЗапросаСтатусыТоваровЗаказаКлиента());
	ТекстыЗапросов.Добавить(ТекстЗапросаДанныеЗаказовМоделиСервиса("МП_ДанныеЗаказовСервиса",
		"МП_ДанныеНоменклатурыЗаказовСервиса"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ * ПОМЕСТИТЬ вт_ИтоговыеДанныеЗаказовДоОбработки
	|ИЗ вт_ДанныеЗаказовМоделиСервисаДоОбработки");
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	вт_ИтоговыеДанныеЗаказовДоОбработки.*,
	|	ISNULL(ЗаказКлиентаFBSТовары.Отменен, ЛОЖЬ) КАК Отменен
	|ИЗ вт_ИтоговыеДанныеЗаказовДоОбработки КАК вт_ИтоговыеДанныеЗаказовДоОбработки
	|ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|	ПО вт_ИтоговыеДанныеЗаказовДоОбработки.НомерЗаказа = ЗаказКлиентаFBSТовары.НомерЗаказа
	|
	|УПОРЯДОЧИТЬ ПО ВнешнийИдентификатор, Идентификатор
	|ИТОГИ МАКСИМУМ(МаркетПлейс), МАКСИМУМ(Документ), МАКСИМУМ(ДатаСоздания),
	|	МАКСИМУМ(вт_ИтоговыеДанныеЗаказовДоОбработки.Сумма),
	|	МАКСИМУМ(Статус), МАКСИМУМ(ДатаОтгрузки), МАКСИМУМ(Интервал)
	|ПО ВнешнийИдентификатор, Идентификатор");
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ вт_ЗаписиДанныеЗаказовНеОбрабатываемые
	|ИЗ
	|	РегистрСведений.МП_ДанныеЗаказовСервиса КАК МП_ДанныеЗаказовСервиса
	|ГДЕ
	|	НЕ(МП_ДанныеЗаказовСервиса.ДатаСоздания МЕЖДУ &ДатаНачала И &ДатаОкончания)
	|	И МП_ДанныеЗаказовСервиса.МаркетПлейс = &МаркетПлейс
	|	
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	РегистрСведений.МП_ДанныеЗаказовСервиса КАК МП_ДанныеЗаказовСервиса
	|ГДЕ
	|	МП_ДанныеЗаказовСервиса.ДатаСоздания МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И НЕ МП_ДанныеЗаказовСервиса.ВнешнийИдентификатор В
	|			(ВЫБРАТЬ
	|				вт_ИтоговыеДанныеЗаказовДоОбработки.ВнешнийИдентификатор
	|			ИЗ
	|				вт_ИтоговыеДанныеЗаказовДоОбработки)
	|	И МП_ДанныеЗаказовСервиса.МаркетПлейс = &МаркетПлейс
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ * ИЗ вт_ЗаписиДанныеЗаказовНеОбрабатываемые КАК вт_ЗаписиДанныеЗаказовНеОбрабатываемые;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	РегистрСведений.МП_ДанныеНоменклатурыЗаказовСервиса КАК МП_ДанныеНоменклатурыЗаказовСервиса
	|ГДЕ
	|	МП_ДанныеНоменклатурыЗаказовСервиса.ВнешнийИдентификатор В
	|			(ВЫБРАТЬ
	|				вт_ЗаписиДанныеЗаказовНеОбрабатываемые.ВнешнийИдентификатор
	|			ИЗ
	|				вт_ЗаписиДанныеЗаказовНеОбрабатываемые)");
	
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";"));
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачала",		 ПараметрыОбработки.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания",	 ПараметрыОбработки.ДатаОкончания);
	Запрос.УстановитьПараметр("МаркетПлейс",	 ПараметрыОбработки.МаркетПлейс);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	// Будем хранить карту соответствия предсатвления и ссылок статусов
	СмещениеПакетаЗапроса_Статусы = 2;
	ВыборкаСтатусы = РезультатыЗапроса[СмещениеПакетаЗапроса_Статусы - 1].Выбрать();
	Пока ВыборкаСтатусы.Следующий() Цикл
		ПараметрыОбработки.ХешТаблицаСтатусов.Вставить(ВыборкаСтатусы.Наименование, ВыборкаСтатусы.Ссылка);
	КонецЦикла;
	
	ПараметрыОбработки.МенеджерОбъекта.МП_ОбработатьЗагрузкуЗаказовПорционно(ПараметрыОбработки, РезультатыЗапроса,
		РеквизитыМаркетПлейс);
	
	Возврат Истина;
	
КонецФункции // МП_ЗагрузитьЗаказыССайта()

// Процедура - Получить данные о заказах по программе в модели сервиса
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Яндекс Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ПолучитьДанныеОЗаказахПоПрограммеВМоделиСервиса(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстЗапросаДанныеЗаказовМоделиСервиса("МП_ДанныеЗаказовСервиса",
		"МП_ДанныеНоменклатурыЗаказовСервиса"));
	ТекстыЗапросов.Добавить(ТекстЗапросаДанныеОЗаказахПоПрограммеВМоделиСервиса(
	// Ихсанов Д. А. Начало 25.06.2026 Изменение 0000000221 от 25.06.2026 13:13:13: e1cib/data/Документ.Изменение?ref=89690050568f680711f1707e79109a75
		ПараметрыОбработки.ПолеСоответствияКодаТовара));
	// Ихсанов Д. А. Конец 25.06.2026
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ вт_СериализированныеДанныеЗаказов
	|ИЗ
	|	вт_ИтоговыеДанные КАК вт_ИтоговыеДанные");
	
	ПолучитьДанныеЗаказовВМоделиСервиса(ТекстыЗапросов, ПараметрыОбработки, РеквизитыМаркетПлейс);
	
КонецПроцедуры // ПолучитьДанныеОЗаказахПоПрограммеВМоделиСервиса()

