// МП Обмен данными маркет плейс
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// 
// Параметры:
//  МаркетПлейс - Неопределено, СправочникСсылка.ИнетМагазины - Маркет плейс
//  ПараметрыРегламентногоЗадания - Неопределено, Структура - Параметры регламентного задания
Процедура МП_ОбменДаннымиМаркетПлейс(МаркетПлейс, ПараметрыРегламентногоЗадания = Неопределено) Экспорт
	
	// Получаем менеджер обработки, необходимой для обмена с конкретным МаркетПлейсом
	МенеджерОбмена = Справочники.ИнетМагазины.МП_ПолучитьОбработчикДляОбменаСМаркетПлейсом(МаркетПлейс);
	
	// Получаем параметры для выполнения обмена с маркет плейсом
	ПараметрыОбработки = МенеджерОбмена.МП_ПараметрыОбработки();
	ПараметрыОбработки.МаркетПлейс 	   = МаркетПлейс;
	ПараметрыОбработки.МенеджерОбъекта = МенеджерОбмена;
	
	МенеджерОбмена.МП_ЗаполнитьПараметрыОбработки(ПараметрыОбработки);
	
	// Прокидываем параметры регламентного задания
	ПараметрыОбработки.Вставить("ПараметрыЗадания", ПараметрыРегламентногоЗадания);
	
	// Реквизиты справочника маркет плейсов запрашиваем единожды в этом месте
	РеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, КлючевыеИменаРеквизитовМаркетплейса());
	
	// Определение интервала загрузки заказов
	Сутки = 86400; // Кол во секунд в сутках для расчетов с датами.
	ПараметрыОбработки.ДатаНачала = НачалоДня(ПараметрыОбработки.ДатаЗапроса - Сутки * РеквизитыМаркетПлейс.ПериодСут);
	ПараметрыОбработки.ДатаОкончания = КонецДня(ПараметрыОбработки.ДатаЗапроса);
	
	// Выполняем запрос и записываем данные в БД.
	МП_ЗагрузитьЗаказыССайта(ПараметрыОбработки, РеквизитыМаркетПлейс);
	
	// Сохраняем в менеджер временных таблиц данные о заказах в программе и модели сервиса
	ПолучитьДанныеОЗаказахПоПрограммеВМоделиСервиса(ПараметрыОбработки, РеквизитыМаркетПлейс);
	
	// Обработка изменения документов заказов клиентов
	Если ПараметрыРегламентногоЗадания.Свойство("ОтменятьЗаказы")
		И ТипЗнч(ПараметрыРегламентногоЗадания.ОтменятьЗаказы) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.ОтменятьЗаказы Тогда
		МенеджерОбмена.ОбработатьОтменуЗаказов(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Обработка создания новых документов
	Если ПараметрыРегламентногоЗадания.Свойство("СоздаватьДокументы")
		И ТипЗнч(ПараметрыРегламентногоЗадания.СоздаватьДокументы) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.СоздаватьДокументы Тогда
		МенеджерОбмена.СоздатьДокументыЗаказовИНакладных(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Обработка создания новых документов
	Если ПараметрыРегламентногоЗадания.Свойство("ЗаполнитьДокументы")
		И ТипЗнч(ПараметрыРегламентногоЗадания.ЗаполнитьДокументы) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.ЗаполнитьДокументы Тогда
		МенеджерОбмена.ЗаполнитьДокументыДаннымиСервиса(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Привязка документов к заказам в модели сервиса
	Если ПараметрыРегламентногоЗадания.Свойство("КонтрольПривязкиДокументов")
		И ТипЗнч(ПараметрыРегламентногоЗадания.КонтрольПривязкиДокументов) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.КонтрольПривязкиДокументов Тогда
		МенеджерОбмена.ПривязатьДокументыКЗаказам(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Обработка первичного распределения
	Если ПараметрыРегламентногоЗадания.Свойство("РаспределятьТоварыПоПосылкам")
		И ТипЗнч(ПараметрыРегламентногоЗадания.РаспределятьТоварыПоПосылкам) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.РаспределятьТоварыПоПосылкам Тогда
		МенеджерОбмена.ВыполнитьРаспределениеТоваров(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Формирование этикеток для посылок
	Если ПараметрыРегламентногоЗадания.Свойство("ФормироватьЭтикетки")
		И ТипЗнч(ПараметрыРегламентногоЗадания.ФормироватьЭтикетки) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.ФормироватьЭтикетки Тогда
		МенеджерОбмена.СформироватьЭтикеткиДляПосылок(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Подтверждение заказов
	Если ПараметрыРегламентногоЗадания.Свойство("ПодтверждатьЗаказы")
		И ТипЗнч(ПараметрыРегламентногоЗадания.ПодтверждатьЗаказы) = Тип("Булево")
		И ПараметрыРегламентногоЗадания.ПодтверждатьЗаказы Тогда
		МенеджерОбмена.ОбработатьПодтверждениеЗаказов(ПараметрыОбработки, РеквизитыМаркетПлейс);
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 16.06.2026 Изменение 0000000019 от 21.05.2026 13:00:05: e1cib/data/Документ.Изменение?ref=89690050568f680711f154fbd6fa2dc8
	// Перемещенено в генерацию РНК
//	// Постобработка по РНК без Заказа клиента
//	Если ПараметрыРегламентногоЗадания.Свойство("ОбрабатыватьРНКБезЗаказа")
//		И ТипЗнч(ПараметрыРегламентногоЗадания.ОбрабатыватьРНКБезЗаказа) = Тип("Булево")
//		И ПараметрыРегламентногоЗадания.ОбрабатыватьРНКБезЗаказа Тогда
//		ПометитьНаУдалениеРасходныеНакладныеБезЗаказаКлиента(МаркетПлейс);
//	КонецЕсли;
	// Ихсанов Д. А. Конец 16.06.2026
	
КонецПроцедуры // МП_ОбменДаннымиМаркетПлейс()

// Текст запроса данные заказов модели сервиса.
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// 
// Параметры:
//  ИмяТаблицыЗаказов - Строка - Имя таблицы заказов
//  ИмяТаблицыТоваров - Строка - Имя таблицы товаров
// 
// Возвращаемое значение:
//  Строка - Текст запроса данные заказов модели сервиса
Функция ТекстЗапросаДанныеЗаказовМоделиСервиса(ИмяТаблицыЗаказов, ИмяТаблицыТоваров) Экспорт 
	
	Возврат СтрШаблон("ВЫБРАТЬ
	|	Т.%1,
	|	Т2.%2
	|ПОМЕСТИТЬ вт_ДанныеЗаказовМоделиСервисаДоОбработки
	|ИЗ
	|	РегистрСведений.%3 КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.%4 КАК Т2
	|		ПО Т.ВнешнийИдентификатор = Т2.ВнешнийИдентификатор
	|ГДЕ
	|	Т.ДатаСоздания МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И Т.МаркетПлейс = &МаркетПлейс",
		СтрСоединить(ПолучитьПоляРегистраСведений(ИмяТаблицыЗаказов), ", Т."),
		СтрСоединить(ПолучитьПоляРегистраСведений(ИмяТаблицыТоваров), ", Т2."),
		ИмяТаблицыЗаказов, ИмяТаблицыТоваров);
	
КонецФункции // ТекстЗапросаДанныеЗаказовМоделиСервиса()

