Процедура ВыгрузкаОстатковВайлберриз(ТаблицаПараметров=Неопределено) Экспорт
	
	СтрокаСоединенияСразрешеннымОбменом	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения					=ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю.  31.03.2026 начало
	//Рефакторинг. Приведение к 1й функции
	//Если ТекСтрокаСоединения <> СтрокаСоединенияСразрешеннымОбменом Тогда
	если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда	
		//Кухарь А.Ю.  31.03.2026 конец
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Выгрузка остатков. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");		
		Возврат;
	КонецЕсли;
	
	
	//Тимофеев Ю.А. Начало   14-02-2025
	// переход на альтернативную выгрузку остатков
	// HELP-1987 	
	
	Если ТаблицаПараметров=Неопределено Тогда
		//если вывоз из не регламентного задания то АЛЬТЕРНАТИВА
		МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков();
		
	Иначе
		
		АЛЬТЕРНАТИВА=Ложь;
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "ТЕСТ" Тогда			
				
				АЛЬТЕРНАТИВА = СтрокаТП.Значение;
				
			КонецЕсли;	
			
		КонецЦикла;  
		
		Если АЛЬТЕРНАТИВА Тогда 
			
			МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00001");			
			МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков(ТаблицаПараметров,МаркетПлейс);
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;         
	
	ЗаписатьВЛог("МП_Вайлбериз","запуск выгрузки без параметров WB.!","Ошибка");
	
	//Тимофеев Ю.А. Конец    14-02-2025
	
КонецПроцедуры

