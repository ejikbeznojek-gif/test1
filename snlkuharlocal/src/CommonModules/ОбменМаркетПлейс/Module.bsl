// Функция - Состояния документа для подтверждения
// 
// Возвращаемое значение:
//  Соответствие - Перечень состояний документа РНК в которых можно печатать этикетку и собирать заказ
//
Функция СостоянияДокументаДляПодтверждения() Экспорт
	
	СостоянияНакладной = Новый Соответствие;
	СостоянияНакладной.Вставить(Перечисления.СостоянияНакладной.ГотоваКОтгрузке,		Истина);
	СостоянияНакладной.Вставить(Перечисления.СостоянияНакладной.Отгружена,				Истина);
	
	Возврат СостоянияНакладной
	
