//Михайловский 20220719 ряд методов нужно переписать в связи со блокировкой ряда методов апи, см. выше ---

Функция POSTЗапросИз1С(ДанныеМаркетПлейса,Команда,ТелоДж,Расширение,ИмяВыходногоФайлаВложения=Неопределено)	Экспорт
	ИмяВыходногоФайла = ПолучитьИмяВременногоФайла("."+Расширение);
	
	попытка                          
		Соединение = Новый HTTPСоединение(ДанныеМаркетПлейса.АдресРесурса,Число(ДанныеМаркетПлейса.Порт),,,,,Новый ЗащищенноеСоединениеOpenSSL);  
	исключение
		Сообщение= "Ошибка соединения при создании http соединения "+ ОписаниеОшибки();
		ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация"); 
		СообщитьИзМодуля(Сообщение);
		Возврат Неопределено;
	конецПопытки;
	
	HTTP_запрос = новый HTTPзапрос();
	
	HTTP_запрос.АдресРесурса = Команда;
	
	
	ЗаголовокHTTP = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Content-Type", ДанныеМаркетПлейса.ContentType);
	ЗаголовокHTTP.Вставить("Accept", ДанныеМаркетПлейса.Accept);
	ЗаголовокHTTP.Вставить("Accept-Language", ДанныеМаркетПлейса.AcceptLanguage);
	ЗаголовокHTTP.Вставить("Accept-Charset", ДанныеМаркетПлейса.AcceptCharset);
	ЗаголовокHTTP.Вставить("Content-Language", ДанныеМаркетПлейса.ContentLanguage);
	ЗаголовокHTTP.Вставить("Content-Charset", ДанныеМаркетПлейса.ContentCharset);
	// потмо изменить
	ЗаголовокHTTP.Вставить("Host", ДанныеМаркетПлейса.Host); //"https://seller-api.sc.prod.s.o3.ru/v1/categories/tree?language=DEFAULT");
	ЗаголовокHTTP.Вставить("Client-Id", ДанныеМаркетПлейса.XAuthToken);
	ЗаголовокHTTP.Вставить("Api-Key", ДанныеМаркетПлейса.Token );	
	//Host: api-seller.ozon.ru
	
	
	HTTP_запрос.Заголовки = ЗаголовокHTTP;
	//	ТелоДЖ="C:\Users\nechaeva\AppData\Local\Temp\8\123.json";  - так работает , на работчем столе лежит
	
	HTTP_запрос.УстановитьИмяФайлаТела(ТелоДЖ);
	
	
	Попытка
		Ответ = Соединение.ОтправитьДляОбработки(HTTP_запрос);  // ИмяВыходногоФайла		
	Исключение
		СообщитьИзМодуля(ОписаниеОшибки());
	КонецПопытки;
	
	Соединение.ОтправитьДляОбработки(HTTP_запрос,ИмяВыходногоФайла);
	если ИмяВыходногоФайлаВложения<>Неопределено тогда
		ИмяВыходногоФайлаВложения=ИмяВыходногоФайла;
	КонецЕсли;
	возврат Ответ;
	
КонецФункции

