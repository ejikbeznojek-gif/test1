Процедура МП_Вайлбериз_ЗапросПоСтикерам(Док,МаркПл,Тест=Ложь) Экспорт     
	//взамен ЗапросПоСтикерам1(МТ,МаркПл,Тест1)
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	ТЗС = Новый ТаблицаЗначений;	
	
	ТЗС.Колонки.Добавить("ИДЗак",Новый ОписаниеТипов("Строка", ,   Новый КвалификаторыСтроки(50)));
	ТЗС.Колонки.Добавить("ШК",   Новый ОписаниеТипов("Строка", ,   Новый КвалификаторыСтроки(50)));
	ТЗС.Колонки.Добавить("ШК1",  Новый ОписаниеТипов("Строка", ,   Новый КвалификаторыСтроки(50)));
	ТЗС.Колонки.Добавить("ШК2",  Новый ОписаниеТипов("Строка", ,   Новый КвалификаторыСтроки(50)));
	
	
	Если НЕ Тест Тогда
		
		Если МаркПл.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз","Начало выполнения. Задача: Загрузка статусов ВБ."+ПрефиксМаркета+" !" +Строка(Док),"Информация");
		КонецЕсли;		
		
		
		Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);
		
		
		HTTP_запрос = новый HTTPзапрос();
		//
		
		
		HTTP_запрос.АдресРесурса="/api/v3/orders/stickers?type=png&width=58&height=40";
		
		ЗаголовокHTTP = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);	
		
	КонецЕсли;	
	//[
	//{
	//"orderId": "string",
	//"status": 2
	//}
	//]
	МасЗак=Новый Массив;
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.РИД КАК РИД,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка = &текдок";
	//   |	И ЗаказКлиентаFBSТовары.ШтрихКод = &Пусто";
	
	
	Запрос.УстановитьПараметр("ТекДок",Док.ссылка);
	
	
	Выб =Запрос.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(Выб.ШтрихКод) Тогда
			МасЗак.Добавить(Выб.НомерЗаказа);
		КонецЕсли;	
	КонецЦикла;	
	Если НЕ МасЗак.Количество() Тогда
		Возврат;
	КонецЕсли;	
	
	//Тз.Колонки.Добавить("warehouseId");
	
	Тот=0;
	КолТот=МасЗак.Количество();
	ТотСтр="";
	МасИД=Новый Массив;
	
	Пока Истина Цикл
		ФормСтр="";
		//ТЗ.Очистить();
		Счт=0;
		Если Тот>(КолТот-1) Тогда
			Прервать;
		КонецЕсли;
		//порциями не более 100
		МасИД.Очистить();
		Пока (Тот<КолТот) И (Счт<100) Цикл
			ТекСтр=МасЗак.Получить(Тот);
			//Тимофеев Ю.А. Начало   08-02-2025
			//
			//
			
			Попытка
				МасИД.Добавить(Число(ТекСтр));       //Тимофеев Ю.А.
			исключение
				ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"ОШИБКА ТекСтр _"+ТекСтр,"ОШИБКА");
				
			КонецПопытки;
			
			
			//Тимофеев Ю.А. Конец    08-02-2025
			
			Тот=Тот+1;
			Счт=Счт+1;
		КонецЦикла;
		
		Если НЕ МасИД.Количество() Тогда
			Прервать;
		КонецЕсли;	
		
		ПолСтр=МП_ВернутьСписокОрдеровВайлберизJSON(МасИД);
		
		#Если Клиент Тогда
			Сообщить(ПолСтр);
		#КонецЕсли
		
		Попытка
			
			РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
			
			Если Тест Тогда
				сообщить(РазмерФайлаНаОтправку);
				ТотСтр=ТотСтр+"Должен быть выгружен блок "+Символы.ПС+ПолСтр;
				
			Иначе	
				ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
				//ФайлРезультата = ПолучитьИмяВременногоФайла();
