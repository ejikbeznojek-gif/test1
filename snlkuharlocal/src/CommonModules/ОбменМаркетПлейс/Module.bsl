// Процедура - Выполнить задание интеграции с маркет плейсом
// Ихсанов Д. А. 25.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2336
// 
// Параметры: ПараметрыВыполнения	 - Любой
//  ТаблицаПараметров - Неопределено, ТаблицаЗначений - Таблица параметров
Процедура ВыполнитьЗаданияИнтеграцииСМаркетПлейсом(ТаблицаПараметров = Неопределено) Экспорт
	
	РезультатВыполнения = Новый Структура;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	КратностьНастроекДанных = 2; // 0 - Имя Регламентного задания, 1 - Интервал выполнения
	ИтераторСмещения = 1; КратностьМинуты = 60;
	
	МенеджерНастроек = РегистрыСведений.НастройкиОбъектов;
	
	ПараметрыРегламентногоЗадания = Новый Структура;
	ПараметрыРегламентногоЗадания.Вставить("Пользователь",		Справочники.Пользователи.НайтиПоНаименованию("Automat Маркетплейсы"));
	ПараметрыРегламентногоЗадания.Вставить("ТипОбъекта",		"РегламентноеЗадание");
	ПараметрыРегламентногоЗадания.Вставить("ИмяОбъекта",		"ИнтеграцияСМаркетПлейсом");
	ПараметрыРегламентногоЗадания.Вставить("ИмяНастройки",		"ПараметрыВыполнения");
	ПараметрыРегламентногоЗадания.Вставить("ЗначениеНастройки", Неопределено);
	
	ДанныеРегламентныхЗаданий = Новый Массив;
	Для каждого Элемент из ТаблицаПараметров Цикл
		Если Элемент.Имя = "ДанныеРегламентныхЗаданий" Тогда
			Для каждого ЗначениеНастройкиЗадания из СтрРазделить(СтрЗаменить(Элемент.Значение, " ", ""), ",") Цикл
				ДанныеРегламентныхЗаданий.Добавить(ЗначениеНастройкиЗадания)
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Если МенеджерНастроек.ПолучитьНастройку(ПараметрыРегламентногоЗадания) Тогда
		РезультатВыполнения = ПараметрыРегламентногоЗадания.ЗначениеНастройки.Получить();
	Иначе
		ПараметрыРегламентногоЗадания.ЗначениеНастройки = Новый ХранилищеЗначения(РезультатВыполнения);
		
		МенеджерНастроек.СохранитьСтандартнуюНастройку(ПараметрыРегламентногоЗадания);
	КонецЕсли;
	
	КоллекцияНастроекЗаданий = Новый Массив;
	Для лИндекс = 0 по ДанныеРегламентныхЗаданий.Количество() - ИтераторСмещения Цикл
		Если Не Булево(лИндекс % КратностьНастроекДанных) Тогда
			СтруктураДанныхНастроек = Новый Структура;
			СтруктураДанныхНастроек.Вставить("ИмяЗадания", ДанныеРегламентныхЗаданий[лИндекс]);
			СтруктураДанныхНастроек.Вставить("Интервал",   Неопределено);
		Иначе
			СтруктураДанныхНастроек.Интервал = ДанныеРегламентныхЗаданий[лИндекс];
			
			КоллекцияНастроекЗаданий.Добавить(СтруктураДанныхНастроек);
		КонецЕсли;
	КонецЦикла;
	
	// Определим наибольший приоритет выполнения
	ПриоритетныйИндекс = Неопределено; НаименьшееВремяИсполнения = Неопределено;
	Для каждого ДанныеРегламентногоЗадания из КоллекцияНастроекЗаданий Цикл
		Если Не РезультатВыполнения.Свойство(ДанныеРегламентногоЗадания.ИмяЗадания) Тогда
			ПриоритетныйИндекс = КоллекцияНастроекЗаданий.Найти(ДанныеРегламентногоЗадания);
			
			РезультатВыполнения.Вставить(ДанныеРегламентногоЗадания.ИмяЗадания, Неопределено);
			
			Прервать
		КонецЕсли;
		
		ТекущееВремяИсполнения = РезультатВыполнения[ДанныеРегламентногоЗадания.ИмяЗадания] 
			+ Число(ДанныеРегламентногоЗадания.Интервал) * КратностьМинуты;
		Если ТекущееВремяИсполнения <= ТекущаяДата Тогда
			Если НаименьшееВремяИсполнения = Неопределено Тогда
				НаименьшееВремяИсполнения = ТекущееВремяИсполнения;
				ПриоритетныйИндекс = КоллекцияНастроекЗаданий.Найти(ДанныеРегламентногоЗадания);
				
				Продолжить;
			КонецЕсли;
			
			Если ТекущееВремяИсполнения < НаименьшееВремяИсполнения Тогда
				НаименьшееВремяИсполнения = ТекущееВремяИсполнения;
				ПриоритетныйИндекс = КоллекцияНастроекЗаданий.Найти(ДанныеРегламентногоЗадания);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Запустим приоритетное регламентное задание
	Если ПриоритетныйИндекс <> Неопределено Тогда
		ДанныеРегламентногоЗадания = КоллекцияНастроекЗаданий[ПриоритетныйИндекс];
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Ключ", ДанныеРегламентногоЗадания.ИмяЗадания);
		
		СписокЗаданий = РегламентныеЗадания.ПолучитьРегламентныеЗадания(ПараметрыОтбора);
		Для каждого РегламентноеЗаданиеОбъект из СписокЗаданий Цикл
			ФоновыеЗадания.Выполнить(РегламентноеЗаданиеОбъект.Метаданные.ИмяМетода, РегламентноеЗаданиеОбъект.Параметры,
				РегламентноеЗаданиеОбъект.Ключ, РегламентноеЗаданиеОбъект.Наименование);
			
			Прервать;
		КонецЦикла;
		
		РезультатВыполнения[ДанныеРегламентногоЗадания.ИмяЗадания] = ТекущаяДата;
	КонецЕсли;
	
	ПараметрыРегламентногоЗадания.ЗначениеНастройки = Новый ХранилищеЗначения(РезультатВыполнения);
	
	МенеджерНастроек.СохранитьСтандартнуюНастройку(ПараметрыРегламентногоЗадания);
	
КонецПроцедуры // ВыполнитьЗаданиеИнтеграцииСМаркетПлейсом()

// Процедура - МП Выполнить обмен данными маркетплейсы
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// 
// Параметры: ПараметрыВыполнения	 - Любой
//  ТаблицаПараметров - Неопределено, ТаблицаЗначений - Таблица параметров
Процедура МП_ВыполнитьОбменДаннымиМаркетплейсы(ТаблицаПараметров = Неопределено) Экспорт 
	
	ПараметрыРегламентногоЗадания = Новый Структура;
	Для каждого ПараметрЗадания из ТаблицаПараметров Цикл
		ПараметрыРегламентногоЗадания.Вставить(ПараметрЗадания.Имя, ПараметрЗадания.Значение);
	КонецЦикла;
	
	ДанныеМаркетПлейсов = ПараметрыРегламентногоЗадания["МаркетПлейсы"];
	СписокМаркетПлейсов = СтрРазделить(СтрЗаменить(ДанныеМаркетПлейсов, " ", ""), ",");
	Для каждого НомерМаркетПлейса из СписокМаркетПлейсов Цикл
		МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду(НомерМаркетПлейса);
		
		Если МаркетПлейс = Справочники.ИнетМагазины.ПустаяСсылка() Тогда
			ЗаписатьВЛог("МП_МаркетПлейсы", НСтр(СтрШаблон("ru='Неверно указан номер маркетплейса в параметрах задания.
			|Обмен не был выполнен.'"), 
			"ru"), "Ошибка", Истина);
			
			Продолжить;
		КонецЕсли;
		
		МП_ОбменДаннымиМаркетПлейс(МаркетПлейс, ПараметрыРегламентногоЗадания);
		
		// Ихсанов Д. А. Начало 30.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2762
		ВыполнитьРебалансировкуПредварительныхЗаказовКлиента(НомерМаркетПлейса, ТаблицаПараметров);
		МаркетПлейсы_ПроведениеНепроведенныхПЗК(НомерМаркетПлейса);
		// Ихсанов Д. А. Конец  30.03.2025
	КонецЦикла;
	
КонецПроцедуры // ВыполнитьОбменДаннымиМаркетплейсы()

#КонецОбласти

#Область Маркетплейсы_БазовыйФункционал // ЛЕГАСИ - На замену HTTP коннектор!!!

// Функция - Выполнить и обработать запрос в модели сервиса
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Параметры:
//  HTTPСоединение - Неопределено, HTTPСоединение - HTTPСоединение
//  HTTPЗаголовки - Соответствие - HTTPЗаголовки
//  ПолныйПутьURL - Строка - Путь к URL вместе с параметрами запроса.
//  ПараметрыОбработки - Структура - * ПараметрыЗапроса - Структура - Параметры строки запроса к сервису
//  ОбработатьТелоКакФайл - Булево - Обработать тело как файл
//  ВыполнятьКонтрольУзла - Булево - Выполнять контроль узла
// 
// Возвращаемое значение:
//  Структура, Массив, Неопределено - Обработанные данные ответа на запрос.
//@skip-check doc-comment-collection-item-type
Функция ВыполнитьИОбработатьЗапросВМоделиСервиса(HTTPСоединение, HTTPЗаголовки, //ПолныйПутьURL...) Экспорт
	ПолныйПутьURL, ПараметрыОбработки, ОбработатьТелоКакФайл = Ложь, ВыполнятьКонтрольУзла = Ложь) Экспорт
	
	// Выполняем контроль ограничения на запросы к сервису
	АдресВыполненияКонтроля = HTTPСоединение.Сервер;
	Если ВыполнятьКонтрольУзла Тогда
		АдресВыполненияКонтроля = СтрШаблон("%1/%2", HTTPСоединение.Сервер, ПолныйПутьURL);
	КонецЕсли;
	
	РегистрыСведений.МП_ЯМ_КонтрольОграниченийПоРаботеССервисами.ВыполнитьКонтрольЗапроса(АдресВыполненияКонтроля);
	
	// Конкатенация параметров запроса с основным адресом запроса
	ТекстыПараметровЗапроса = Новый Массив;
	Для каждого ДанныеПараметраЗапроса из ПараметрыОбработки.ПараметрыЗапроса Цикл
		ТекстыПараметровЗапроса.Добавить(СтрШаблон("%1=%2", ДанныеПараметраЗапроса.Ключ,
			ДанныеПараметраЗапроса.Значение));
	КонецЦикла;
	
	ПолныйПутьURLСПараметрами = СтрШаблон("%1?%2", ПолныйПутьURL, СтрСоединить(ТекстыПараметровЗапроса, "&"));
	
	// Преобразуем данные тела запроса в строку
	ТелоЗапроса = ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса;
	Если ТипЗнч(ТелоЗапроса) = Тип("Массив")
		ИЛИ ТипЗнч(ТелоЗапроса) = Тип("Структура") Тогда
		ТелоЗапроса = СформироватьСтрокуJSON(ТелоЗапроса, ПараметрыОбработки);
	КонецЕсли;
	
	// Исполняем запрос и получаем необработанный результат.
	Результат = ВыполнитьHTTPЗапрос(ПолныйПутьURLСПараметрами, HTTPСоединение, HTTPЗаголовки, 
		ПараметрыОбработки.ДанныеЗапроса.Метод, ТелоЗапроса);
	
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Получаем удобную для работы структуру из строки.
	Попытка
		Если ПустаяСтрока(Результат.ПолучитьТелоКакСтроку()) 
			И Результат.КодСостояния = 200 Тогда
			ДанныеОтвета = Новый Структура;
		Иначе
			Если ОбработатьТелоКакФайл Тогда
				Если Результат.КодСостояния = 200 Тогда
					ДанныеОтвета = Результат.ПолучитьТелоКакДвоичныеДанные()
				Иначе
					ДанныеОтвета = ОбработатьСтрокуJSON(Результат.ПолучитьТелоКакСтроку(), ПараметрыОбработки.ИменаПолейСДатами,
						ПараметрыОбработки.ИменаПолейДляВосстановления, ПараметрыОбработки)
				КонецЕсли;
			Иначе
				ДанныеОтвета = ОбработатьСтрокуJSON(Результат.ПолучитьТелоКакСтроку(), ПараметрыОбработки.ИменаПолейСДатами,
					ПараметрыОбработки.ИменаПолейДляВосстановления, ПараметрыОбработки);
			КонецЕсли;
		КонецЕсли;
	Исключение
		Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При выполнении запроса на стороне программы возникла ошибка!
			|Невозможно обработать данные полученные от сервиса:
			|%2
			|%3'", "ru");
		//@skip-check bsl-legacy-check-static-feature-access
		СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ВыполнениеЗапросаКоВнешнемуСервису",
			Результат.ПолучитьТелоКакСтроку(), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписатьВЛог("МП_РаботаСВнешнимиСервисами", СообщениеОбОшибке, "Ошибка");
		
		ДанныеОтвета = Новый Структура("error", Результат.ПолучитьТелоКакСтроку());
	КонецПопытки;
	
	//@skip-check constructor-function-return-section
	Возврат ДанныеОтвета;
	
КонецФункции // ВыполнитьИОбработатьЗапросВМоделиСервиса()

// Функция - Запрос к сервису прошел успешно
// Проверяет ответ сервиса на наличие ошибок
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Параметры:
//  ДанныеОтвета - Структура - Ответ от сервиса после выполнения запроса
//  СообщениеОбОшибке - Строка - Пустое поле, которое заполнится данными ответа в строковом формате
//  ПараметрыОбработки - Структура - 
// 
// Возвращаемое значение:
//  Булево - При отсутствии ошибок возвращается Истина, иначе Ложь
Функция ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, //ДополнительныеПараметры...) Экспорт
	ПараметрыОбработки) Экспорт
	
	// Проверим есть ли данные в ответе
	Если ДанныеОтвета = Неопределено Тогда
		СообщениеОбОшибке = "В ответе сервиса отсутствуют данные!";
		
		Возврат Ложь;
	КонецЕсли;
	
	// Инициализируем коллекцию имен полей с признаком ошибки
	МассивИменКлючевыхПолей = СтрРазделить(ПараметрыОбработки.ИменаСвойствОшибок, ",", Ложь);
	
	// Инициализируем коллекцию значений ошибок
	МассивЗначенийОшибок = СтрРазделить(ПараметрыОбработки.ЗначенияСвойствОшибок, ",", Ложь);
	
	// Обработаем наличие признака ошибки в ответе сервиса на запрос
	// // Обойдем имена полей, по которым будем искать свойство с признаком ошибки
	Для каждого ИмяПоля из МассивИменКлючевыхПолей Цикл
		Если Не ДанныеОтвета.Свойство(ИмяПоля) Тогда
			Продолжить
		КонецЕсли;
		
		// // Проверим значение свойства с признаком ошибки
		Для каждого ЗначениеКлючевогоПоля из МассивЗначенийОшибок Цикл
			Если ЗначениеЗаполнено(ЗначениеКлючевогоПоля)
				И ДанныеОтвета[ИмяПоля] <> ЗначениеКлючевогоПоля Тогда
				Продолжить
			КонецЕсли;
			
			СообщениеОбОшибке = СформироватьСтрокуJSON(ДанныеОтвета, ПараметрыОбработки);
			
			Возврат Ложь;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции // ЗапросКСервисуПрошелУспешно()

// Функция - Получить общие параметры обработки
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Возвращаемое значение:
//  Структура - Получить общие параметры обработки:
// * ИменаПолейСДатами - Неопределено - 
// * ИменаПолейДляВосстановления - Неопределено - 
// * ПараметрыЗапроса - Структура - 
// * ДанныеЗапроса - Структура - 
// * ИменаСвойствОшибок - Строка - 
// * ЗначенияСвойствОшибок - Строка - 
Функция ПолучитьОбщиеПараметрыОбработки() Экспорт
	
	ПараметрыОбработки = Новый Структура;
	ПараметрыОбработки.Вставить("ИменаПолейСДатами",		   Неопределено);
	ПараметрыОбработки.Вставить("ИменаПолейДляВосстановления", Неопределено);
	ПараметрыОбработки.Вставить("ПараметрыЗапроса",			   Новый Структура);
	ПараметрыОбработки.Вставить("ДанныеЗапроса",			   Новый Структура);
	ПараметрыОбработки.Вставить("ИменаСвойствОшибок",		   "");
	ПараметрыОбработки.Вставить("ЗначенияСвойствОшибок",	   "");
	ПараметрыОбработки.ДанныеЗапроса.Вставить("ТелоЗапроса", "");
	ПараметрыОбработки.ДанныеЗапроса.Вставить("Метод",		 "GET");
	
	Возврат ПараметрыОбработки;
	
КонецФункции // ПолучитьОбщиеПараметрыОбработки()

#КонецОбласти

#Область МаркетПлейсы_РаботаСПредварительнымЗаказомКлиента

// Процедура - Маркет плейсы преобразовать данные предварительных заказов клиента в расходную накладную
// Ихсанов Д. А. 03.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// 
// Параметры:
//  ТаблицаПараметров - ТаблицаЗначений - Таблица с параметрами исполнения функционала при запуске регламентным заданием
Процедура МаркетПлейсы_ПреобразоватьДанныеПредварительныхЗаказовКлиентаВРасходнуюНакладную(ТаблицаПараметров = Неопределено) Экспорт
	
	// 14л	 - 95% - 95% - 60%
	// 52.5л - 95% - 95% - 74%
	// 72л	 - 95% - 95% - ? %
	КодМаркетПлейса							  = "";
	МинимальныйОбъемКоробки					  = 0.014;
	НаполняемостьКоробкиДляШтук				  = 80; // %
	НаполняемостьКоробкиДляПакетов			  = 80; // %
	НаполняемостьКоробкиДляКоробов			  = 80; // %
	НаполняемостьКоробкиДляСмешанныхУпаковок  = 80; // %
	ЧасОтсечкиПолнойЗагрузки				  = 21;
	ЕжедневныйЛимитПредварительныхЗаказов	  = 0;
	БлокировкаВыдачиВНабор_БлокироватьОстатки = Ложь;
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	РежимСмешанныхНакладных_Комплекты		  = Ложь;
	ВозможныЗаказыСНесколькимиТоварами		  = Ложь;
	ФиксированнаяДатаОтгрузки				  = Ложь;
	СмещениеПоДатеОтгрузки					  = Неопределено;
	// Ихсанов Д. А. Конец  17.03.2026
	// Ихсанов Д. А. Начало 30.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9292
	ПредопределенныйНенулевойОбъемШтуки		  = 0.002; // Если не заполнены ВГХ по товару, то мы устанавливаем объем
	// Ихсанов Д. А. Конец 30.04.2026
	// Ситуативный контроль итогов для переключения режима преобразования документов
	УровниОтборовПоЗаказам = "ЗаказПоЮрЛицу, ОтгрузкаКомплектов, Склад, Комментарий, Упаковка, ПриоритетныйОбъемТары, Родитель";
	Если ТаблицаПараметров <> Неопределено Тогда
		Для каждого Параметр из ТаблицаПараметров Цикл
			Если Параметр.Имя = "КодМаркетПлейса" Тогда
				КодМаркетПлейса = Параметр.Значение
			ИначеЕсли Параметр.Имя = "МинимальныйОбъемКоробки" Тогда
				МинимальныйОбъемКоробки = Параметр.Значение / 1000 // Указывается значение в литрах
			ИначеЕсли Параметр.Имя = "НаполняемостьКоробкиДляШтук" Тогда
				НаполняемостьКоробкиДляШтук = Параметр.Значение
			ИначеЕсли Параметр.Имя = "НаполняемостьКоробкиДляПакетов" Тогда
				НаполняемостьКоробкиДляПакетов = Параметр.Значение
			ИначеЕсли Параметр.Имя = "НаполняемостьКоробкиДляКоробов" Тогда
				НаполняемостьКоробкиДляКоробов = Параметр.Значение
			ИначеЕсли Параметр.Имя = "НаполняемостьКоробкиДляСмешанныхУпаковок" Тогда
				НаполняемостьКоробкиДляСмешанныхУпаковок = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ЧасОтсечкиПолнойЗагрузки" Тогда
				ЧасОтсечкиПолнойЗагрузки = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ЕжедневныйЛимитПредварительныхЗаказов" Тогда
				ЕжедневныйЛимитПредварительныхЗаказов = Параметр.Значение
			ИначеЕсли Параметр.Имя = "БлокировкаВыдачиВНабор_БлокироватьОстатки" Тогда
				БлокировкаВыдачиВНабор_БлокироватьОстатки = Параметр.Значение
			ИначеЕсли Параметр.Имя = "РежимСмешанныхНакладных_Комплекты" Тогда
				РежимСмешанныхНакладных_Комплекты = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ВозможныЗаказыСНесколькимиТоварами" Тогда
				ВозможныЗаказыСНесколькимиТоварами = Параметр.Значение
			ИначеЕсли Параметр.Имя = "УровниОтборовПоЗаказам" Тогда
				УровниОтборовПоЗаказам = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ФиксированнаяДатаОтгрузки" Тогда
				ФиксированнаяДатаОтгрузки = Параметр.Значение
			ИначеЕсли Параметр.Имя = "СмещениеПоДатеОтгрузки" Тогда
				СмещениеПоДатеОтгрузки = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ПредопределенныйНенулевойОбъемШтуки" Тогда
				ПредопределенныйНенулевойОбъемШтуки = Параметр.Значение
			КонецЕсли
		КонецЦикла;
	КонецЕсли;
	
	Если ПустаяСтрока(КодМаркетПлейса) Тогда
		ВызватьИсключение "Не указан код маркет плейса"
	КонецЕсли;
	
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду(КодМаркетПлейса);
	РеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, "Наименование, Договор, Контрагент, ПунктДоставки");
	
	// Инициализация
	ТекущаяДата = ТекущаяДатаСеанса();
	СекундВОдномДне = 86400;
	ИнтервалСмещения = 2;
	ДатаОтсечки = Дата(Год(ТекущаяДата), Месяц(ТекущаяДата), День(ТекущаяДата), ЧасОтсечкиПолнойЗагрузки, 0, 0);
	ДатаЗапретаРедактирования = Константы.ДатаЗапретаРедактирования.Получить();
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ТекстыСообщений = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ДатаНачала",	   НачалоДня(ДатаЗапретаРедактирования) - СекундВОдномДне * ИнтервалСмещения);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОтсечки);
	Запрос.УстановитьПараметр("Договор",	   РеквизитыМаркетПлейс.Договор);
	Запрос.УстановитьПараметр("Контрагент",	   РеквизитыМаркетПлейс.Контрагент);
	Запрос.УстановитьПараметр("ПунктДоставки", РеквизитыМаркетПлейс.ПунктДоставки);
	Запрос.УстановитьПараметр("ОбъемТары",	   МинимальныйОбъемКоробки);
	Запрос.УстановитьПараметр("ТекущаяДата",   ТекущаяДата);
	// Для выведения из ПЗК товара с заблокированным ассортиментом
	Запрос.УстановитьПараметр("БлокировкаВыдачиВНабор_БлокироватьОстатки", БлокировкаВыдачиВНабор_БлокироватьОстатки);
	// Контроль работы маркетплейсов со смешанными накладными
	Запрос.УстановитьПараметр("РежимСмешанныхНакладных_Комплекты",  РежимСмешанныхНакладных_Комплекты);
	Запрос.УстановитьПараметр("ВозможныЗаказыСНесколькимиТоварами", ВозможныЗаказыСНесколькимиТоварами);
	Запрос.УстановитьПараметр("СмещениеПоДатеОтгрузки", СмещениеПоДатеОтгрузки);
	// Ихсанов Д. А. Начало 30.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9292
	// Контроль исключений в выборке
	Запрос.УстановитьПараметр("ПредопределенныйНенулевойОбъемШтуки", ПредопределенныйНенулевойОбъемШтуки);
	// Ихсанов Д. А. Конец 30.04.2026
	
	// Ихсанов Д. А. Начало 30.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7560
	Если ЕжедневныйЛимитПредварительныхЗаказов > 0 Тогда
		Запрос.Текст = ТекстЗапросаДляПолученияКоличестваЗаказовПоПЗК();
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если Выборка.КоличествоЗаказов < ЕжедневныйЛимитПредварительныхЗаказов Тогда
				Возврат
			КонецЕсли
		КонецЕсли;
	КонецЕсли;
	// Ихсанов Д. А. Конец  30.10.2025
	
	// Выполним перемещение всего товара, который был зарезервирован документами ПЗК
	// Необходимо освободить резерв и вернуть товар на склад FBS для формирования документов РНК и Заказа клиента
	Запрос.Текст = ТекстЗапросаДляСнятияРезерваСПЗК();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	НачатьТранзакцию();
	Попытка
		ВыборкаПЗК_К_Сбросу = Запрос.Выполнить().Выбрать();
		Пока ВыборкаПЗК_К_Сбросу.Следующий() Цикл
			НаборЗаписей = РегистрыНакопления.РезервыТМЦ.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаПЗК_К_Сбросу.Ссылка);
			НаборЗаписей.Прочитать();
			
			Если НаборЗаписей.Количество() = 0 Тогда
				Продолжить
			КонецЕсли;
			
			НаборЗаписей.Очистить();
			НаборЗаписей.Записать()
		КонецЦикла;
		
		ВыборкаПЗК_К_Сбросу.Сбросить();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ТекстыСообщений.Добавить(СтрШаблон("Не удалось очистить движения по документам ПЗК за период: %1 - %2;",
			НачалоДня(ТекущаяДата) - СекундВОдномДне * ИнтервалСмещения, ДатаОтсечки));
	КонецПопытки;
	
	// Запросим данные по предварительным заказам клиента в удобном формате для формирования РНК
	Запрос.Текст = ТекстЗапросаПреобразованиеДанныхПредварительногоЗаказаКлиента(УровниОтборовПоЗаказам);
	Запрос.МенеджерВременныхТаблиц = Неопределено;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Сформируем таблицу для хранения данных по товару
	ТаблицаДанных = РезультатЗапроса.Выгрузить();
	ТаблицаДанных.Очистить();
	
	// Сформируем таблицу для хранения хвостов по товару, который не попал в кратность коробки
	ИзлишкиТовара = ТаблицаДанных.Скопировать();
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	ОбходДанныхПоВыборкеСФормированиемПЗК(МаркетПлейс, Выборка, СтрРазделить(УровниОтборовПоЗаказам, ",", Ложь).ВГраница() - 2, ТаблицаДанных,
		ИзлишкиТовара, НаполняемостьКоробкиДляШтук, НаполняемостьКоробкиДляПакетов, НаполняемостьКоробкиДляКоробов,
		НаполняемостьКоробкиДляСмешанныхУпаковок, ФиксированнаяДатаОтгрузки, ТекстыСообщений, СмещениеПоДатеОтгрузки);
	// Ихсанов Д. А. Конец  17.03.2026
	
	Если БлокировкаВыдачиВНабор_БлокироватьОстатки Тогда
		НачатьТранзакцию();
		Попытка
			// Необходимо освободить резерв и вернуть товар на склад FBS для формирования документов РНК и Заказа клиента
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	вт_МоделиВБлокировке.Ссылка КАК Ссылка
			|ИЗ
			|	вт_МоделиВБлокировке КАК вт_МоделиВБлокировке";
			Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				ДокументОбъектБлокировкаВыдачиВНабор = Выборка.Ссылка.ПолучитьОбъект();
				ДокументОбъектБлокировкаВыдачиВНабор.ОстаткиFBSОбнулены = Истина;
				ДокументОбъектБлокировкаВыдачиВНабор.Записать(РежимЗаписиДокумента.Проведение);
			КонецЦикла;
			
			Пока ВыборкаПЗК_К_Сбросу.Следующий() Цикл
				ДокументОбъектПредварительныйЗаказКлиента = ВыборкаПЗК_К_Сбросу.Ссылка.ПолучитьОбъект();
				ДокументОбъектПредварительныйЗаказКлиента.Записать(РежимЗаписиДокумента.Проведение);
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ТекстыСообщений.Добавить(СтрШаблон("Не удалось повторно записать документы ПЗК с
			|заблокированным остатком за период: %1 - %2;",
				НачалоДня(ТекущаяДата) - СекундВОдномДне * ИнтервалСмещения, ДатаОтсечки));
			
			ОтменитьТранзакцию();
		КонецПопытки;
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 16.06.2026 Изменение 0000000019 от 21.05.2026 13:00:05: e1cib/data/Документ.Изменение?ref=89690050568f680711f154fbd6fa2dc8
	ПометитьНаУдалениеРасходныеНакладныеБезЗаказаКлиента(МаркетПлейс);
	// Ихсанов Д. А. Конец 16.06.2026
	
	Если ТекстыСообщений.Количество() > 0 Тогда
		ТекстыСообщений.Вставить(0, "При формировании РНК возникли следующие проблемы:");
		ТекстСообщения = СтрСоединить(ТекстыСообщений, Символы.ПС);
		
		СписокПолучателей = Новый СписокЗначений;
		СписокПолучателей.Добавить("ikhsanov@collant.ru");
		
		ТемаПисьма = СтрШаблон("Предварительный заказ клиента %1. Формирование РНК. Исключения.", РеквизитыМаркетПлейс.Наименование);
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей, ТемаПисьма, ТекстСообщения);
		
		ЗаписатьВЛог("МаркетПлейсы_ПреобразованиеПЗК", ТекстСообщения, "Ошибка");
	КонецЕсли;
	
КонецПроцедуры // МаркетПлейсы_ПреобразоватьДанныеПредварительныхЗаказовКлиентаВРасходнуюНакладную()

#КонецОбласти

#Область API_V1

// Ихсанов Д. А. Начало 26.05.2026 Наряд 0000000171 от 20.05.2026 11:18:21: e1cib/data/Документ.Наряд?ref=89690050568f680711f1542474905136
// Обработка запроса GET Api v1.
// 
// Параметры:
//  Запрос - HTTPЗапрос
// 
// Возвращаемое значение:
//  HTTPСервисОтвет - Обработка запроса GET Api v1
Функция ОбработкаЗапросаGETApiV1(Запрос) Экспорт
	
	ИменаЗаголовковНаПроверку = Новый Массив;
	ИменаЗаголовковНаПроверку.Добавить("Content-Type");
	
	ЗаголовкиЗапроса = Новый Соответствие(Запрос.Заголовки);
	Для каждого ИмяЗаголовка Из ИменаЗаголовковНаПроверку Цикл
		Если ЗаголовкиЗапроса[ИмяЗаголовка] = Неопределено Тогда
			ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Ложь,
				СтрШаблон("Не заполнен обязательный заголовок %1.", ИмяЗаголовка)));
			
			Возврат ОтветСервисаНедействительныйСинтаксисПоAPI(ДанныеJSON);
		КонецЕсли;
	КонецЦикла;
	
	ОперацияПоМетоду = ДействующиеМетодыApiV1()[Запрос.ОтносительныйURL];
	Если ОперацияПоМетоду = Неопределено Тогда
		Возврат ОтветСервисаНеНайденоПоAPI();
	КонецЕсли;
	
	ПараметрыЗапроса = Новый Соответствие;
	Если ЗаголовкиЗапроса["Content-Type"] = "application/x-www-form-urlencoded" Тогда
		Для каждого ПараметрЗапроса Из СтрРазделить(Запрос.ПолучитьТелоКакСтроку(), "&") Цикл
			ПараметрыЗапроса.Вставить(СтрРазделить(ПараметрЗапроса, "=")[0], СтрРазделить(ПараметрЗапроса, "=")[1]);
		КонецЦикла;
	КонецЕсли;
	
	СтруктураВалидации = ВыполнитьВалидациюПоМетодуAPIV1(ОперацияПоМетоду);
	Для каждого ИмяОбязательногоПараметра из СтруктураВалидации.ИменаОбязательныхПараметров Цикл
		Если ПараметрыЗапроса[ИмяОбязательногоПараметра] = Неопределено Тогда
			ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Ложь,
				СтрШаблон("Не заполнен обязательный параметр %1.", ИмяОбязательногоПараметра)));
			
			Возврат ОтветСервисаНедействительныйСинтаксисПоAPI(ДанныеJSON);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ФорматВалидацииПараметра из СтруктураВалидации.ФорматПараметров Цикл
		Попытка
			ЗначениеПараметра = Дата(СтрСоединить(СтрРазделить(ПараметрыЗапроса[ФорматВалидацииПараметра.Ключ], "-"), ""));
			Если Формат(ЗначениеПараметра, ФорматВалидацииПараметра.Значение) <> ПараметрыЗапроса[ФорматВалидацииПараметра.Ключ] Тогда
				ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Ложь,
					СтрШаблон("Параметр %1 не соответствует формату %2.", ФорматВалидацииПараметра.Ключ,
						ФорматВалидацииПараметра.Значение)));
				
				Возврат ОтветСервисаНедействительныйСинтаксисПоAPI(ДанныеJSON);
			КонецЕсли;
		Исключение
			ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Ложь,
				СтрШаблон("Параметр %1 не соответствует формату %2.", ФорматВалидацииПараметра.Ключ,
					ФорматВалидацииПараметра.Значение)));
			
			Возврат ОтветСервисаНедействительныйСинтаксисПоAPI(ДанныеJSON);
		КонецПопытки;
		
		ПараметрыЗапроса[ФорматВалидацииПараметра.Ключ] = ЗначениеПараметра;
	КонецЦикла;
	
	Для каждого УсловиеДляВалидации из СтруктураВалидации.УсловияВалидацииПараметров Цикл
		Результат = Неопределено;
		
		УстановитьБезопасныйРежим(Истина);
		Выполнить (УсловиеДляВалидации.Значение);
		УстановитьБезопасныйРежим(Ложь);
		
		Если Не Результат Тогда
			ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Ложь, УсловиеДляВалидации.Ключ));
			
			Возврат ОтветСервисаНедействительныйСинтаксисПоAPI(ДанныеJSON);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыПреобразованияJSON = Новый Структура;
	ПараметрыПреобразованияJSON.Вставить("ПрочитатьВСоответствие", Ложь);
	ПараметрыПреобразованияJSON.Вставить("ФорматДатыJSON", ФорматДатыJSON.ISO);
	ПараметрыПреобразованияJSON.Вставить("ВариантЗаписиДатыJSON", ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением);
	ПараметрыПреобразованияJSON.Вставить("ИмяФункцииПреобразования", "ПреобразованиеДанныеДляJSON");
	ПараметрыПреобразованияJSON.Вставить("МодульФункцииПреобразования", ОбменМаркетПлейс);
	
	ПараметрыЗаписиJSON = КоннекторHTTP.ПараметрыЗаписиJSONПоУмолчанию();
	ПараметрыЗаписиJSON.Вставить("ПереносСтрок", ПереносСтрокJSON.Нет);
	ПараметрыЗаписиJSON.Вставить("СимволыОтступа", "");
	
	ДанныеJSON = КоннекторHTTP.ОбъектВJson(ОснасткаРезультатаОтвета(Истина, 
			ВыполнитьОперациюПоМетодуApiV1(ОперацияПоМетоду, ПараметрыЗапроса)),
			ПараметрыПреобразованияJSON, ПараметрыЗаписиJSON);
	
	Возврат ОтветСервисаУспешноПоAPI(ДанныеJSON);
	
КонецФункции // ОбработкаЗапросаGETApiV1()

// Обработка запроса HEAD Api v1.
// 
// Параметры:
//  Запрос - HTTPЗапрос
// 
// Возвращаемое значение:
//  HTTPСервисОтвет - Обработка запроса HEADApi v1
Функция ОбработкаЗапросаHEADApiV1(Запрос) Экспорт
	
	// Не нужна дополнительная обработка
	// Вся обработка происходит в методе GET
	Ответ = ОбработкаЗапросаGETApiV1(Запрос);
	Ответ.УстановитьТелоИзСтроки("");
	
	Возврат Ответ;
	
КонецФункции // ОбработкаЗапросаHEADApiV1()

// Обработка прочих запросов api v1.
// 
// Параметры:
//  Запрос - HTTPЗапрос
// 
// Возвращаемое значение:
//  HTTPСервисОтвет - Обработка прочих запросов api v1
Функция ОбработкаПрочихЗапросовApiV1(Запрос) Экспорт
	
	// Метод HEAD отсутствует в перечне стандартных методов 1С
	// Поэтому обработаем его вручную
	Если Запрос.HTTPМетод = "HEAD" Тогда
		Ответ = ОбработкаЗапросаHEADApiV1(Запрос);
		
		Возврат Ответ;
	КонецЕсли;
	
	// Если обработка касается прочих методов, то будет выполнен отдельный контроль
	ОперацияПоМетоду = ДействующиеМетодыApiV1()[Запрос.ОтносительныйURL];
	Если ОперацияПоМетоду = Неопределено Тогда
		Возврат ОтветСервисаНеНайденоПоAPI();
	КонецЕсли;
	
	Возврат ОтветСервисаМетодНеРазрешенПоAPI(Метаданные.HTTPСервисы.HTTPDataService.ШаблоныURL.ShareDataEndpointV1);
	
КонецФункции // ОбработкаПрочихЗапросовApiV1()
