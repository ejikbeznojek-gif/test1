#Область HMAC

// Хеш.
// 
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные - Двоичные данные
//  Тип - ХешФункция - Тип
// 
// Возвращаемое значение:
//  ДвоичныеДанные, Число - Хеш
Функция Хеш(ДвоичныеДанные, Тип)
	
	Хеширование = Новый ХешированиеДанных(Тип);
	Хеширование.Добавить(ДвоичныеДанные);
	
	Возврат Хеширование.ХешСумма;
		
КонецФункции // Хеш()

// HMAC.
// 
// Параметры:
//  Ключ - Строка - Ключ
//  Данные - Строка - Данные
//  Тип - ХешФункция - Тип
//  РазмерБлока - Число - Размер блока
// 
// Возвращаемое значение:
//  ДвоичныеДанные, Число - HMAC
Функция HMAC(Знач Ключ, Знач Данные, Тип, РазмерБлока)
	
	Если Ключ.Размер() > РазмерБлока Тогда
		Ключ = Хеш(Ключ, Тип);
	КонецЕсли;
	
	Если Ключ.Размер() < РазмерБлока Тогда
		Ключ = ПолучитьHexСтрокуИзДвоичныхДанных(Ключ);
		Ключ = Лев(Ключ + ПовторитьСтроку("00", РазмерБлока), РазмерБлока * 2);
	КонецЕсли;
	
	Ключ = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(ПолучитьДвоичныеДанныеИзHexСтроки(Ключ));
	
	БуферБлока0х36 = ПолучитьБуферДвоичныхДанныхИзHexСтроки(ПовторитьСтроку("36", РазмерБлока));
	БуферБлока0х5с = ПолучитьБуферДвоичныхДанныхИзHexСтроки(ПовторитьСтроку("5c", РазмерБлока));
	
	БуферБлока0х36.ЗаписатьПобитовоеИсключительноеИли(0, Ключ);
	ДанныеКлючаИсключающее0х36 = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(БуферБлока0х36);
	
	БуферБлока0х5с.ЗаписатьПобитовоеИсключительноеИли(0, Ключ);
	ДанныеКлючаИсключающее0х5с = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(БуферБлока0х5с);
	
	Возврат Хеш(СклеитьДвоичныеДанные(ДанныеКлючаИсключающее0х5с,
		Хеш(СклеитьДвоичныеДанные(ДанныеКлючаИсключающее0х36, Данные), Тип)), Тип);
	
КонецФункции // HMAC()

// Склеить двоичные данные.
// 
// Параметры:
//  ДвоичныеДанныеПерваяЧасть - ДвоичныеДанные - Двоичные данные первая часть
//  ДвоичныеДанныеВтораяЧасть - ДвоичныеДанные, Число, Строка - Двоичные данные вторая часть
// 
// Возвращаемое значение:
//  ДвоичныеДанные - Склеить двоичные данные
Функция СклеитьДвоичныеДанные(ДвоичныеДанныеПерваяЧасть, ДвоичныеДанныеВтораяЧасть)
	
	МассивДвоичныхДанных = Новый Массив;
	МассивДвоичныхДанных.Добавить(ДвоичныеДанныеПерваяЧасть);
	МассивДвоичныхДанных.Добавить(ДвоичныеДанныеВтораяЧасть);
	
	Возврат СоединитьДвоичныеДанные(МассивДвоичныхДанных);
	
КонецФункции // СклеитьДвоичныеДанные()

// Повторить строку.
// 
// Параметры:
//  ДанныеСтроки - Строка - Данные строки для повторения
//  Количество - Число - Количество
// 
// Возвращаемое значение:
//  Строка - Повторить строку
Функция ПовторитьСтроку(ДанныеСтроки, Количество)
	
	Части = Новый Массив(Количество);
	Для к = 1 По Количество Цикл
		Части.Добавить(ДанныеСтроки);
	КонецЦикла;
	
	Возврат СтрСоединить(Части, "");
	
КонецФункции // ПовторитьСтроку()

