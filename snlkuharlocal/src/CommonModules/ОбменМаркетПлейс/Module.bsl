Процедура СоздатьЛогистЗаказы(МкПл,ТЗЗЛ,ТЗЗак,ФормОп=Ложь)
	// Вставить содержимое обработчика.
	
	Если Не ТЗЗЛ.Количество() Тогда
		//ПоказатьПредупреждение(,НСтр("ru='Не выбран заказ'"));
		Возврат;
	КонецЕсли;
	Посыл=Ложь;
	Если  ФормОп Тогда
		
		СписокПолучателей=новый СписокЗначений;
		Для Каждого ТекСтр Из МкПл.ПолучателиУведомлений Цикл
			Мыло=СокрЛП(ТекСтр.Сотрудник.ЕМэйл);
			Если ЗначениеЗаполнено(Мыло) И (ТекСтр.СкладИОфис) Тогда
				СписокПолучателей.Добавить(Мыло);
			КонецЕсли;	
		КонецЦикла;
		
		ТекстОповещения="Здравствуйте!"+Символы.ПС+"Формирование логистических заказов АлиЭкспресс:"+Символы.ПС;
		
		
	КонецЕсли;
	ТекстОп="";
	АдресТ =МкПл.АдресРесурса; 
	//Контрагент=МкПл.Контрагент;
	//Договор=МкПл.Договор;
	//ПунктДоставки=МкПл.ПунктДоставки;
