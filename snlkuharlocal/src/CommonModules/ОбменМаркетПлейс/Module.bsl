	//НовСтр.mandatory_mark ="0108000000982650215!H<mQFICtYGC";
	//НовСтр.product_id     ="1381312657";
	//НовСтр.exemplar_id    =1;
	
	
	
	//Колонки в таблице
	//posting_number
	//mandatory_mark
	//Номенклатура
	//product_id
	//exemplar_id
	
	СтруктураТелаЗапроса               = Новый Структура;
	СтруктураТелаЗапроса.Вставить("multi_box_qty",     0);
	СтруктураТелаЗапроса.Вставить("posting_number",    СокрЛП(НомерОтправления));
	
	ТЗпродукты = ТЗДанных.Скопировать();
	
	ТЗПродукты.Свернуть("product_id");   	
	
	products = Новый Массив;
	
	Для Каждого Продукт из ТЗпродукты Цикл  		
		
		Структураproducts                                   = Новый Структура;
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("product_id", Продукт.product_id);
		
		exemplars = Новый Массив;      
		
		НайтиВсеЭкземпляры = ТЗДанных.НайтиСтроки(ПараметрыОтбора);
		quantity =0;
		
		Для каждого НайдЭкземпляр из НайтиВсеЭкземпляры Цикл
			
			Структураexemplars                                  = Новый Структура;
