Процедура МП_Вайлберриз_ВыгрузитьОстаткиНаПортал(МаркПл,ТЗШККВыгрузке,ПрефиксМаркета="") Экспорт
	//Тимофеев Ю.А. Начало   14-02-2025
	//
	//Полностью переписан модуль HELP-1987
	
	Если НЕ ТЗШККВыгрузке.Количество() Тогда  		
		#Если Клиент Тогда
			Сообщить(НСтр("ru = 'Нет данных к выгрузке - выгрузка невозможна!'"));
		#КонецЕсли
		Возврат;
	КонецЕсли;	
	
	ИДСклада=СокрЛП(МаркПл.WarehouseId);
	
	HTTP_запрос = новый HTTPзапрос();  		
	
	Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	HTTP_запрос.АдресРесурса="/api/v3/stocks/"+ИДСклада;
	
	ЗаголовокHTTP = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);	
	
	// Ихсанов Д. А. 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-146
	//Добавлено поле АртикулКонтрагента
	ТЗШККВыгрузкеПакет = ТЗШККВыгрузке.СкопироватьКолонки("ШК,КВыгрузке,Остаток,МинимумСпайка,Комплект,ВыгружатьОст0,АртикулКонтрагента");
	
	ТЗНекондиция       = ТЗШККВыгрузкеПакет.Скопировать();
	
	МассивЗаданий            =Новый ТаблицаЗначений; 
	МассивЗаданий.Колонки.Добавить("ТЗ");
	МассивЗаданийИсправленных=Новый ТаблицаЗначений; 
	МассивЗаданийИсправленных.Колонки.Добавить("ТЗ");
	СчетчикСтрок=0;
	
	Для каждого стрШК из ТЗШККВыгрузке Цикл
		
		Если СчетчикСтрок<500 Тогда
			СчетчикСтрок=СчетчикСтрок+1; 						
		Иначе
			НовСТР=МассивЗаданий.Добавить();
			НовСТр.ТЗ=ТЗШККВыгрузкеПакет.Скопировать();
			СчетчикСтрок=1;
			ТЗШККВыгрузкеПакет.Очистить();
		КонецЕсли;
		
		НоваяСтрокаВПакет = ТЗШККВыгрузкеПакет.Добавить();
		
		НоваяСтрокаВПакет.ШК	     =		СтрШК.ШК;
		// Ихсанов Д. А. Начало 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-146
		НоваяСтрокаВПакет.АртикулКонтрагента = СтрШК.АртикулКонтрагента;
		// Ихсанов Д. А. Конец  17.02.2026
		НоваяСтрокаВПакет.КВыгрузке  =      СтрШК.КВыгрузке; 	
		
	КонецЦикла;
	
	Если ТЗШККВыгрузкеПакет.Количество()>0 Тогда
		НовСТР=МассивЗаданий.Добавить();
		НовСТр.ТЗ=ТЗШККВыгрузкеПакет.Скопировать();
		
		ТЗШККВыгрузкеПакет.Очистить();
	КонецЕсли;
	
	Для каждого текПакет из МассивЗаданий Цикл
		
		ТЗНаОбрабоку = текПакет.ТЗ;
		
		ПолСтр =  МП_ВАЙЛБЕРИЗ_ПолучитьSKUОстатки(ТЗНаОбрабоку);  		
		
		РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
		
		ЕстьОш=Ложь;
		
		ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
		
		HTTP_запрос.Заголовки = ЗаголовокHTTP;
		
		HTTP_запрос.УстановитьТелоИзСтроки(ПолСтр);  				
		
		Ответ = Соединение.Записать(HTTP_запрос); 
		
		Если Ответ.КодСостояния < 400 Тогда   			
			
			#Если Клиент  тогда
				Сообщить("Остатки выгружены.");
			#КонецЕсли
			
		Иначе
			
			ЕстьОш=Истина;
			
			//МИскл=ПолучитьМНеКорЗ(ВС);      //ТЮА понять 	
			
			Попытка
				
				былострок = Строка(ТЗНаОбрабоку);	
				
				СтруктураСтрокой=Ответ.ПолучитьТелоКакСтроку();   			
				
				ЧтениеJSON0       = Новый ЧтениеJSON;
				ЧтениеJSON0.УстановитьСтроку(СтруктураСтрокой);
				СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);  	
				
				
				#Если Клиент  тогда
					ОписаниеОшибки= СтруктураИзСтроки[0].message;
					Сообщить("Остатки не выгружены." +ОписаниеОшибки);
				#КонецЕсли       			
				
				Если СтруктураИзСтроки[0].Свойство("data") Тогда
					
					Для каждого СтрМассива из СтруктураИзСтроки[0].data Цикл
						
						БракШК = СтрМассива.sku;
						
						НовБрак    = ТЗНекондиция.добавить();
						НовБрак.ШК = БракШК;     			
						
						ПоискШК =ТЗНаОбрабоку.Найти(БракШК,"ШК");
						
						Если ПоискШК <> Неопределено Тогда
							ТЗНаОбрабоку.Удалить(ПоискШК);
						КОнецЕсли;   					
						
					КонецЦикла;
					
				КонецЕсли;
				
				///сюда на воптор
				
			Исключение
				ЗаписатьВЛог("МП_Вайлберриз","При первой обработки "+ПрефиксМаркета+" "+ТЗНаОбрабоку+" "+СтруктураСтрокой,"Ошибка");
				
			КонецПопытки;
			
			НовСТР=МассивЗаданийИсправленных.Добавить();
			НовСТр.ТЗ=ТЗНаОбрабоку.Скопировать();
			
		КонецЕсли;
		
		НужнаПауза(3);
		
	КонецЦикла;
	
	ОшибочныхШК = МассивЗаданийИсправленных.Количество();
	
	Если ОшибочныхШК>0 Тогда
		
		ЗаписатьВЛог("МП_Вайлберриз","Есть ошибочные ШК "+ПрефиксМаркета+" "+Строка(ОшибочныхШК),"Ошибка");  
		
		Для каждого текПакет из МассивЗаданийИсправленных Цикл
			
			ТЗНаОбрабоку = текПакет.ТЗ;
			
			ПолСтр =  МП_ВАЙЛБЕРИЗ_ПолучитьSKUОстатки(ТЗНаОбрабоку);  		
			
			РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
			
			ЕстьОш=Ложь;
			
			ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
			
			HTTP_запрос.Заголовки = ЗаголовокHTTP;
			
			HTTP_запрос.УстановитьТелоИзСтроки(ПолСтр);  				
			
			Ответ = Соединение.Записать(HTTP_запрос);    			
			
			Если Ответ.КодСостояния < 400 Тогда   			
				
				#Если Клиент  тогда
					Сообщить("Остатки повторно выгружены.");
				#КонецЕсли
				
			Иначе
				
				Попытка 
					
					былострок = Строка(ТЗНаОбрабоку);
					
					СтруктураСтрокой=Ответ.ПолучитьТелоКакСтроку();   			
					
					ЧтениеJSON0       = Новый ЧтениеJSON;
					ЧтениеJSON0.УстановитьСтроку(СтруктураСтрокой);
					СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);  
					
					
					#Если Клиент  тогда
						ОписаниеОшибки= СтруктураИзСтроки[0].message;
						Сообщить("Остатки ОПЯТЬ не выгружены." +ОписаниеОшибки);
					#КонецЕсли       			
					
					Если СтруктураИзСтроки[0].Свойство("data") Тогда
						
						Для каждого СтрМассива из СтруктураИзСтроки[0].data Цикл
							
							БракШК = СтрМассива.sku;
							
							НовБрак           = ТЗНекондиция.добавить();
							НовБрак.ШК        = БракШК;     			
							НовБрак.КВыгрузке = 1;
							
						КонецЦикла;
						
					КонецЕсли;
					
				Исключение
					ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" При повторе обработки "+ТЗНаОбрабоку+" "+СтруктураСтрокой,"Ошибка");
					
				КонецПопытки;
				
			КонецЕсли;
			
			НужнаПауза(3);			
			
		КонецЦикла;    		
		
	КонецЕсли;   	
	
	Попытка
		
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
		
		ИмяФайла=ПутьЛог+"ПлохиеШК_WB_"+ПрефиксМаркета+"_"+ВремяЗаписи+".txt";
		
		ЗначениеВФайл(ИмяФайла, ТЗНекондиция);
		
	Исключение
		
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Имя файла "+ИмяФайла+" "+ОписаниеОшибки(),"ИСКЛЮЧЕНИЕ_ОШИБКА");
		
	КонецПопытки;  	
	
	//Тимофеев Ю.А. Конец    14-02-2025	
	
КонецПроцедуры


Процедура НужнаПауза(Время) Экспорт
	
	ВремяЗавершения = ТекущаяДата() + Время;
	Пока ТекущаяДата() < ВремяЗавершения Цикл
	КонецЦикла;
	
КонецПроцедуры


#КонецОбласти


#Область МП_Вайлберриз_ЗагрузкаЗаказов_ТИМОФЕЕВ

