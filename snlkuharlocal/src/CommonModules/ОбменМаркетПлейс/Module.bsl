//из массива в таблицу значений
Функция ПреобразованиеМассивВТаблицуЗначений(Массив) Экспорт
	
	ТЗ = Новый ТаблицаЗначений;
	
	Для Каждого СтрокаМассива Из Массив Цикл
		
		Если ТЗ.Колонки.Количество() = 0 Тогда
			Для Каждого ЭлементМассива Из СтрокаМассива Цикл
				ТЗ.Колонки.Добавить(ЭлементМассива.Ключ);
			КонецЦикла;
		КонецЕсли;
		
		НоваяСтрока = ТЗ.Добавить();
		Для Каждого ЭлементМассива Из СтрокаМассива Цикл
			НоваяСтрока[ЭлементМассива.Ключ] = ЭлементМассива.Значение;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТЗ;
	
КонецФункции

// Ихсанов Д. А. Начало 01.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// Функция - Заполнить данные маркет плейса по контрагенту
//
// Параметры:
//  Контрагент		 - СправочникСсылка.Контрагенты	 - Контрагент, участвующий в интернет продажах
//  ПунктДоставки	 - СправочникСсылка.ПунктДоставки	 - Пункт доставки по контрагенту
// 
// Возвращаемое значение:
//  Структура - Данные полей по элементу справочника Интернет магазина
//
Функция ЗаполнитьДанныеМаркетПлейсаПоКонтрагенту(Контрагент, ПунктДоставки) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ИнетМагазины.Ссылка КАК Ссылка,
	|	ИнетМагазины.Склад КАК Склад,
	|	ИнетМагазины.СкладМаркировки КАК СкладМаркировки,
	|	ИнетМагазины.СкладРезерва КАК СкладРезерва,
	|	ИнетМагазины.СкладРезерваМаркировки КАК СкладРезерваМаркировки
	|ИЗ
	|	Справочник.ИнетМагазины КАК ИнетМагазины
	|ГДЕ
	|	ИнетМагазины.Контрагент = &Контрагент
	|	И ИнетМагазины.ПунктДоставки = &ПунктДоставки");
	Запрос.УстановитьПараметр("Контрагент",	   Контрагент);
	Запрос.УстановитьПараметр("ПунктДоставки", ПунктДоставки);
	
	ДанныеМаркетПлейса = Новый Структура;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДанныеМаркетПлейса.Вставить("Ссылка",				  Выборка.Ссылка);
		ДанныеМаркетПлейса.Вставить("Склад",				  Выборка.Склад);
		ДанныеМаркетПлейса.Вставить("СкладМаркировки",		  Выборка.СкладМаркировки);
		ДанныеМаркетПлейса.Вставить("СкладРезерва",			  Выборка.СкладРезерва);
		ДанныеМаркетПлейса.Вставить("СкладРезерваМаркировки", Выборка.СкладРезерваМаркировки);
	КонецЕсли;
	
	Возврат ДанныеМаркетПлейса
	
