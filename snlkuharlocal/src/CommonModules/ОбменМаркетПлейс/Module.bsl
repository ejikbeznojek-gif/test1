Функция МП_ОЗОН_ПОВТОРНО_exemplar_set(МаркПл,НомерОтправления,ТЗЭКЗЕМЛЯРОВ,ИзОбработки=Ложь)
	
	Команда = "v4/fbs/posting/product/exemplar/set";
	
	Если ТЗЭКЗЕМЛЯРОВ.Количество()>0 Тогда
		СтрЗапроса = МП_ОЗОН_ВернутьСтруктуруДляПодачиМарки(НомерОтправления, ТЗЭКЗЕМЛЯРОВ) ;
	иначе
		Сообщить("Пустая таблица");
		Возврат Ложь;
	КонецЕсли;    
	
	Ответ                 = POSTЗапросИз1С_ДжС(МаркПл,Команда,СтрЗапроса); 
	
	ПолученныйОтвет = Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON           = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ПолученныйОтвет); 	
	
	Если Ответ.КодСостояния<400 Тогда
		
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь);   	
		
		Если данные.свойство("result") Тогда
			
			Если ИзОбработки Тогда 
				
				Сообщить("Все призязалось");
				
			КонецЕсли;
			
			Возврат Истина;
		Иначе
			Сообщить("ОШИБКА");
			Возврат Ложь;
			
		КонецЕсли; 
	Иначе
		ЗаписатьВЛог("МП_ОЗОН","Повторная привязка марок : "+Строка(НомерОтправления)+" "+ПолученныйОтвет+ " "+Ответ.КодСостояния ,"Ошибка");
	КонецЕсли; 
	
КонецФункции

Функция МП_ОЗОН_ПОВТОРНО_ship(МаркПл,НомерОтправления,ТЗЭКЗЕМЛЯРОВ,ИзОбработки=Ложь)
	
	Команда = "/v4/posting/fbs/ship";
	
	СтрЗапроса = МП_ОЗОН_ВернутьСтруктуруДляSHIP(НомерОтправления, ТЗЭКЗЕМЛЯРОВ);
	
	Ответ                 = POSTЗапросИз1С_ДжС(МаркПл,Команда,СтрЗапроса); 
	ПолученныйОтвет       = Ответ.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON           = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ПолученныйОтвет); 	
	
	Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); 
	
	Если Ответ.КодСостояния<=400 Тогда
		
		Если данные.свойство("result") Тогда
			
			Если ИзОбработки Тогда 
				
				Сообщить("Марки привязались");
				
			КонецЕсли;
			
			ЗаписатьВЛог("МП_ОЗОН","Повторная СБОРКА заказа : "+Строка(НомерОтправления)+" все марки привязаны!" ,"Информация");
			Возврат Истина;
		Иначе
			Сообщить("Что то пошло не так...Сайт ОЗОН не готов предоставить этикетку.Повторите через 5 минут. Спасибо");	
			ЗаписатьВЛог("МП_ОЗОН","ОШИБКА с марками : "+Строка(НомерОтправления)+" "+ПолученныйОтвет+ " "+Ответ.КодСостояния ,"Ошибка");
		КонецЕсли; 
		
	Иначе
		
		ЗаписатьВЛог("МП_ОЗОН","Повторная СБОРКА заказа : "+Строка(НомерОтправления)+" "+ПолученныйОтвет+ " "+Ответ.КодСостояния ,"Ошибка");
	КонецЕсли; 
	
	Возврат Ложь;
	
