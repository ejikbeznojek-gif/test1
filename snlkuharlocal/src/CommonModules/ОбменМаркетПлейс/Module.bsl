Функция МП_ОЗОН_ПОВТОРНО_ПолучитьЭтикетку(МаркПл,НомерОтправления,ИзОбработки=Ложь) 	
	
	Команда = "/v2/posting/fbs/package-label";  // получает файл маркировки отправления.
	
	ТелоДЖ = "";
	
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".json");
	
	Запись = Новый ЗаписьJSON;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
	Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата; //ЛокальнаяДата;      "2020-10-31T21:00:00Z",
	
	НомераЗаказов = Новый Массив;
	Если НомерОтправления<>"" Тогда
		НомераЗаказов.Добавить(НомерОтправления);
	КонецЕсли;
	Данные = Новый Структура;
	Данные.Вставить("posting_number",НомераЗаказов);
	
	Попытка
		ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
		Запись.Закрыть(); 		
		Сообщить("json ЗАПИСАЛИ"); 
	Исключение
		
	КонецПопытки;  
	
	ПутькПДФ="";
	
	Результат = POSTЗапросИз1С(МаркПл,Команда,ИмяВыходногоФайлаДЖ,"PDF",ПутькПДФ) ; 
	
	если результат=Неопределено тогда
		Возврат Ложь;
	КонецЕсли;
	
	попытка
		Распечатали  = 0;
		ПутьЭтик = "\\srvfile-sk\FBS";
		ЭтикФ = ПутьЭтик +"\"+НомерОтправления+".pdf";
		Если результат<>"" Тогда
			// проверим на размер, а потом уже скопируем
			//Файл = Новый Файл(результат);
			Файл= новый файл (ПутькПДФ);
			РазмерФайла = Файл.Размер();
			Если РазмерФайла>1000 тогда 			
				
				КопироватьФайл(ПутькПДФ,ЭтикФ);
				
				Если ИзОбработки Тогда
					
					Сообщить("Этикетка скопирована - можно печатать"); 	
					ЗапуститьПриложение(ЭтикФ);
					
				КонецЕсли;
				
				Возврат Истина;
			иНАЧЕ
				Сообщить("Этикетка НЕ получена "+СТРОКА(РазмерФайла));
				
			конецЕсли;
		КонецЕсли;
	исключение
		Сообщение=" Этикетка не записана "+ ОписаниеОшибки()+"   номер заказа - "+ НомерОтправления;
		//ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация"); 
		СообщитьИзМодуля(Сообщение);
	конецпопытки;   	
	
	Возврат Ложь;
	
КонецФункции

