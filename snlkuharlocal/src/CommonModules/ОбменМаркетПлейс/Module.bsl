	|			Склад В
	|					(ВЫБРАТЬ
	|						вт_ДанныеПредварительныйЗаказКлиента.Склад
	|					ИЗ
	|						вт_ДанныеПредварительныйЗаказКлиента)
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_ДанныеПредварительныйЗаказКлиента.Номенклатура
	|					ИЗ
	|						вт_ДанныеПредварительныйЗаказКлиента)) КАК ОстаткиТМЦОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РезервыТМЦОстатки.Склад КАК Склад,
	|	РезервыТМЦОстатки.Номенклатура КАК Номенклатура,
	|	РезервыТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_Резервы
	|ИЗ
	|	РегистрНакопления.РезервыТМЦ.Остатки(
	|			,
	|			Склад В
	|					(ВЫБРАТЬ
	|						вт_ДанныеПредварительныйЗаказКлиента.Склад
	|					ИЗ
	|						вт_ДанныеПредварительныйЗаказКлиента)
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_ДанныеПредварительныйЗаказКлиента.Номенклатура
	|					ИЗ
	|						вт_ДанныеПредварительныйЗаказКлиента)) КАК РезервыТМЦОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Остатки.Склад КАК Склад,
	|	вт_Остатки.Номенклатура КАК Номенклатура,
	|	вт_Остатки.КоличествоОстаток - ЕСТЬNULL(вт_Резервы.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоСкладамРезервов
	|ИЗ
	|	вт_Остатки КАК вт_Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_Резервы КАК вт_Резервы
	|		ПО вт_Остатки.Склад = вт_Резервы.Склад
	|			И вт_Остатки.Номенклатура = вт_Резервы.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПредварительныйЗаказКлиента.Склад КАК Склад,
	|	вт_ДанныеПредварительныйЗаказКлиента.Номенклатура КАК Номенклатура,
	|	СУММА(вт_ДанныеПредварительныйЗаказКлиента.Количество) КАК Количество,
	|	ЕСТЬNULL(вт_ДанныеПоСкладамРезервов.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоНехваткеТоваров
	|ИЗ
	|	вт_ДанныеПредварительныйЗаказКлиента КАК вт_ДанныеПредварительныйЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоСкладамРезервов КАК вт_ДанныеПоСкладамРезервов
	|		ПО вт_ДанныеПредварительныйЗаказКлиента.Склад = вт_ДанныеПоСкладамРезервов.Склад
	|			И вт_ДанныеПредварительныйЗаказКлиента.Номенклатура = вт_ДанныеПоСкладамРезервов.Номенклатура
	|ГДЕ
	|	вт_ДанныеПредварительныйЗаказКлиента.Количество > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеПредварительныйЗаказКлиента.Склад,
	|	вт_ДанныеПоСкладамРезервов.Склад,
	|	вт_ДанныеПредварительныйЗаказКлиента.Номенклатура,
	|	вт_ДанныеПоСкладамРезервов.Номенклатура,
	|	вт_ДанныеПоСкладамРезервов.КоличествоОстаток
	|
	|ИМЕЮЩИЕ
	|	ЕСТЬNULL(вт_ДанныеПоСкладамРезервов.КоличествоОстаток, 0) - СУММА(вт_ДанныеПредварительныйЗаказКлиента.Количество) < 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_ДанныеПредварительныйЗаказКлиента.НомерЗаказа КАК НомерЗаказа,
	|	вт_ДанныеПредварительныйЗаказКлиента.Ссылка КАК ЗаказКлиентаFBS,
	|	вт_ДанныеПредварительныйЗаказКлиента.Продукция КАК Номенклатура,
	|	вт_ДанныеПредварительныйЗаказКлиента.КоличествоПродукции КАК Количество,
	|	ВЫБОР
	|		КОГДА вт_ДанныеПредварительныйЗаказКлиента.ОтгрузкаКомплектов
	|			ТОГДА 0
	|		ИНАЧЕ вт_ДанныеПоНехваткеТоваров.КоличествоОстаток
	|	КОНЕЦ КАК Остаток,
	|	вт_ДанныеПредварительныйЗаказКлиента.ОтгрузкаКомплектов КАК Комплект
	|ИЗ
	|	вт_ДанныеПоНехваткеТоваров КАК вт_ДанныеПоНехваткеТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПредварительныйЗаказКлиента КАК вт_ДанныеПредварительныйЗаказКлиента
	|		ПО вт_ДанныеПоНехваткеТоваров.Склад = вт_ДанныеПредварительныйЗаказКлиента.Склад
	|			И вт_ДанныеПоНехваткеТоваров.Номенклатура = вт_ДанныеПредварительныйЗаказКлиента.Номенклатура
	|ИТОГИ ПО
	|	ЗаказКлиентаFBS";
	#КонецОбласти // Запрос
	Запрос.УстановитьПараметр("Контрагент", РеквизитыМаркетПлейса.Контрагент);
	Запрос.УстановитьПараметр("Договор", РеквизитыМаркетПлейса.Договор);
	Запрос.УстановитьПараметр("ПунктДоставки", РеквизитыМаркетПлейса.ПунктДоставки);
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДата - 64800*8));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ТекущаяДата));
	Запрос.УстановитьПараметр("ВозможныЗаказыСНесколькимиТоварами", ВозможныЗаказыСНесколькимиТоварами);
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		ДокументОбъектПредварительныйЗаказКлиента_НаРазделение = Выборка.ЗаказКлиентаFBS.ПолучитьОбъект();
		
		НачатьТранзакцию();
		Попытка
			ВыборкаДетальныеЗаписи = Выборка.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ПараметрыОтбора = Новый Структура;
				Если ВозможныЗаказыСНесколькимиТоварами Тогда
					ПараметрыОтбора.Вставить("РИД", ВыборкаДетальныеЗаписи.НомерЗаказа);
				Иначе
					ПараметрыОтбора.Вставить("НомерЗаказа", ВыборкаДетальныеЗаписи.НомерЗаказа);
				КонецЕсли;
				
				НайденныеСтроки = ДокументОбъектПредварительныйЗаказКлиента_НаРазделение.Товары.НайтиСтроки(ПараметрыОтбора);
				Если ДокументОбъектПредварительныйЗаказКлиента_НаРазделение.Товары.Количество() = НайденныеСтроки.Количество() Тогда
					РезультатПроведенияПЗК = МаркетПлейсы_ПровестиПредварительныйЗаказКлиентаПоАльтернативномуСкладу(
						ДокументОбъектПредварительныйЗаказКлиента_НаРазделение, РеквизитыМаркетПлейса);
					
					СообщитьИзМодуля(РезультатПроведенияПЗК.ТекстСообщения);
					
					Продолжить;
				КонецЕсли;
				
				РезультатВыделенияЗаказа = МаркетПлейсы_ВынестиЗаказОтдельныйПредварительныйЗаказКлиента(
					ДокументОбъектПредварительныйЗаказКлиента_НаРазделение,
					РеквизитыМаркетПлейса, ВыборкаДетальныеЗаписи.НомерЗаказа,
					ВозможныЗаказыСНесколькимиТоварами);
				
				СообщитьИзМодуля(РезультатВыделенияЗаказа.ТекстСообщения);
			КонецЦикла;
			
			ДокументОбъектПредварительныйЗаказКлиента_НаРазделение.Записать(РежимЗаписиДокумента.Проведение);
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			
			//@skip-check bsl-legacy-check-static-feature-access
			ТекстСообщения = СтрШаблон("Не удалось перенести заказы из документа %1. %3",
				ДокументОбъектПредварительныйЗаказКлиента_НаРазделение,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			СообщитьИзМодуля(ТекстСообщения);
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры // ВыполнитьРебалансировкуПредварительныхЗаказовКлиента()

// Процедура - Маркет плейсы проведение непроведенных ПЗК
// Ихсанов Д. А. 09.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7802
//
// Параметры:
//  КодМаркетПлейса	 - Строка	 - Номер интернет магазина
//
Процедура МаркетПлейсы_ПроведениеНепроведенныхПЗК(КодМаркетПлейса) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду(КодМаркетПлейса);
	РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс,
		"Контрагент, Договор, ПунктДоставки");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПредварительныйЗаказКлиента.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента КАК ПредварительныйЗаказКлиента
	|ГДЕ
	|	ПредварительныйЗаказКлиента.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиента.Договор = &Договор
	|	И ПредварительныйЗаказКлиента.ПунктДоставки = &ПунктДоставки
	|	И НЕ ПредварительныйЗаказКлиента.Проведен");
	Запрос.УстановитьПараметр("Контрагент", РеквизитыМаркетПлейса.Контрагент);
	Запрос.УстановитьПараметр("Договор", РеквизитыМаркетПлейса.Договор);
	Запрос.УстановитьПараметр("ПунктДоставки", РеквизитыМаркетПлейса.ПунктДоставки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументОбъектПредварительныйЗаказКлиента = Выборка.Ссылка.ПолучитьОбъект();
		ДокументОбъектПредварительныйЗаказКлиента.Дата = ТекущаяДата;
		
		Попытка
			ДокументОбъектПредварительныйЗаказКлиента.Записать(РежимЗаписиДокумента.Проведение);
			
			СообщитьИзМодуля(СтрШаблон("Выполнено простое проведение документа %1!", Выборка.Ссылка));
		Исключение
			СообщитьИзМодуля(СтрШаблон("Не удалось выполнить простое проведение документа %1!", Выборка.Ссылка));
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры // МаркетПлейсы_ПроведениеНепроведенныхПЗК()

