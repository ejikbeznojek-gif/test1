Функция МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс, НужныйСклад, // СкладВычерка, КлючевоеПолеТовара...) Экспорт
	СкладВычерка = Неопределено, КлючевоеПолеТовара = Неопределено) Экспорт
	
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Если СкладВычерка = Неопределено Тогда
		СкладВычерка = Справочники.Склады.ПустаяСсылка()
	КонецЕсли;
	// Ихсанов Д. А. Конец  20.08.2025
	
	// Ихсанов Д. А. Начало 03.02.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117
	Если КлючевоеПолеТовара = Неопределено Тогда
		КлючевоеПолеТовара = "ШККонтрагента"
	КонецЕсли;
	// Ихсанов Д. А. Конец  03.02.2025
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон("ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	СУММА(ВложенныйЗапрос.Остаток) КАК Остаток,
	|	СУММА(ВложенныйЗапрос.Резерв) КАК Резерв,
	|	СУММА(ВложенныйЗапрос.КолКонФакт) КАК КолКонФакт
	|ПОМЕСТИТЬ ВТ_ОстаткиМинус
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|		ОстаткиТМЦОстатки.КоличествоОстаток КАК КолКонФакт,
	|		ОстаткиТМЦОстатки.КоличествоОстаток КАК Остаток,
	|		0 КАК Резерв
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад = &Склад) КАК ОстаткиТМЦОстатки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыТМЦОстатки.Номенклатура,
	|		-РезервыТМЦОстатки.КоличествоОстаток,
	|		0,
	|		РезервыТМЦОстатки.КоличествоОстаток
	|	ИЗ
	|		РегистрНакопления.РезервыТМЦ.Остатки(, Склад = &Склад) КАК РезервыТМЦОстатки) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОстаткиМинус.Номенклатура КАК Номенклатура,
	|	ВТ_ОстаткиМинус.Остаток КАК Остаток,
	|	ВТ_ОстаткиМинус.Резерв КАК Резерв,
	|	ВЫБОР
	|		КОГДА ВТ_ОстаткиМинус.КолКонФакт < 0
	|			ТОГДА 0
	|		ИНАЧЕ ВТ_ОстаткиМинус.КолКонФакт
	|	КОНЕЦ КАК КолКонФакт
	|ПОМЕСТИТЬ ВТ_ОСТАТКИ
	|ИЗ
	|	ВТ_ОстаткиМинус КАК ВТ_ОстаткиМинус
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаПунктыДоставки.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Матрицы
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ГДЕ
	|	ИСТИНА
	|	И МатрицаПунктыДоставки.Ссылка.Проведен
	|	И МатрицаПунктыДоставки.Ссылка.Контрагент = &Контрагент
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаПунктыДоставки.Ссылка.Договор = &Договор
	|	И (ЛОЖЬ
	|			ИЛИ МатрицаПунктыДоставки.Ссылка.ДатаОкончания > &ДатаОкончания
	|			ИЛИ МатрицаПунктыДоставки.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаПунктыДоставки.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.ШК КАК ШК,
	|	ВложенныйЗапрос.МатрицаДата КАК МатрицаДата,
	|	ВложенныйЗапрос.МатрицаКоличество КАК МатрицаКоличество,
	|	ВложенныйЗапрос.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВложенныйЗапрос.Матрица КАК Матрица,
	|	ВложенныйЗапрос.offer_id КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|	ВложенныйЗапрос.АртикулКонтрагента КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|	ВложенныйЗапрос.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_НомМатрицы
	|ИЗ
	|	(ВЫБРАТЬ
	|		МатрицаТовары.Номенклатура КАК Номенклатура,
	|		ВЫРАЗИТЬ(МатрицаТовары.ШККонтрагента КАК СТРОКА(150)) КАК ШК,
	|		ВЫРАЗИТЬ(МатрицаТовары.НаименованиеКонтрагента КАК СТРОКА(100)) КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|		ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(100)) КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|		ВЫРАЗИТЬ(МатрицаТовары.КодПроизводителяКонтрагента КАК СТРОКА(50)) КАК Product_ID,
	// Тимофеев Ю.А. был АртикулКонтрагента 25.06.2025 
