	//Михайловский 20220721 +++
	ТаблицаВозврата.Колонки.Добавить("ПрефиксЗаказа",новый ОписаниеТипов("Строка"));
	//Михайловский 20220721 ---
	ТаблицаВозврата.Колонки.Добавить("ВерхнийШК",новый ОписаниеТипов("Строка"));
	ТаблицаВозврата.Колонки.Добавить("НижнийШК",новый ОписаниеТипов("Строка"));
	ТаблицаВозврата.Колонки.Добавить("Состояние",новый ОписаниеТипов("Строка"));
	ТаблицаВозврата.Колонки.Добавить("АртикулКонтрагента",новый ОписаниеТипов("Строка"));
	// Кухарь А.Ю. 24.11.2021 начало
	ТаблицаВозврата.Колонки.Добавить("СекторХраненияРазвернутый",новый ОписаниеТипов("Строка"));	
	// Кухарь А.Ю. 24.11.2021 конец
	
	// Кухарь А.Ю. 11.11.2021 начало
	ТаблицаВозврата.Колонки.Добавить("СекторХранения",новый ОписаниеТипов("СправочникСсылка.СектораХранения"));	
	если МассивНоменклатурыБезСектора=Неопределено тогда
		МассивНоменклатурыБезСектора=новый Массив;
	КонецЕсли;
	МассивСекторов=новый Массив;	
	СборныйСектор=Справочники.СектораХранения.НайтиПоКоду("000000013");
	// Кухарь А.Ю. 11.11.2021 конец
	
	
	//
	//// Кухарь А.Ю. 24.11.2021 начало
	//// Грузим только заказы на завтра
	//
	Если  ДатаОтгрузки>НачалоДня(ТекущаяДата()+24*60*60) тогда
		//возврат ТаблицаВозврата;
	КонецЕсли;		
	//// Кухарь А.Ю. 24.11.2021 конец
	
	
	Статус=СтруктураЗаказа.status;
	
	Если  СтруктураЗаказа.barcodes <> Неопределено тогда
		ВерхнийШК=СтруктураЗаказа.barcodes.upper_barcode;			
		НижнийШК=СтруктураЗаказа.barcodes.lower_barcode;
	иначе
