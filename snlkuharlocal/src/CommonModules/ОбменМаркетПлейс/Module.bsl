	|	ВТ_ПОЛНАЯ.Номенклатура КАК Номенклатура,
	|	ВТ_ПОЛНАЯ.ШК КАК SKU,
	|	ВТ_ПОЛНАЯ.Остаток КАК Остаток,
	|	ВТ_ПОЛНАЯ.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_ПОЛНАЯ.МинимумСпайка КАК МинимумСпайка,
	|	ВТ_ПОЛНАЯ.Комплект КАК Комплект,
	|	ВТ_ПОЛНАЯ.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_ПОЛНАЯ.КВыгрузке КАК КВыгрузке,
	|	0 КАК СержантскийЗапас,
	|	ВТ_ПОЛНАЯ.offer_id КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|	ВТ_ПОЛНАЯ.АртикулКонтрагента КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|	ВТ_ПОЛНАЯ.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ вт_Результат
	|ИЗ
	|	ВТ_ПОЛНАЯ КАК ВТ_ПОЛНАЯ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоВычеркамКомплектующих
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &СкладВычерка
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ВТ_ИТОГ.Номенклатура
	|					ИЗ
	|						ВТ_ИТОГ)) КАК ОстаткиТМЦОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоОстаткам
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &СкладВычерка
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_Результат.Номенклатура
	|					ИЗ
	|						вт_Результат)) КАК ОстаткиТМЦОстатки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВТ_ИТОГ.Продукция,
	|	вт_ДанныеПоВычеркамКомплектующих.КоличествоОстаток
	|ИЗ
	|	ВТ_ИТОГ КАК ВТ_ИТОГ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоВычеркамКомплектующих КАК вт_ДанныеПоВычеркамКомплектующих
	|		ПО ВТ_ИТОГ.Номенклатура = вт_ДанныеПоВычеркамКомплектующих.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(вт_ДанныеПоВычеркамКомплектующих.КоличествоОстаток, 0) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Результат.Номенклатура КАК Номенклатура,
	|	вт_Результат.SKU КАК SKU,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) > 0
	|			ТОГДА 0
	|		ИНАЧЕ вт_Результат.Остаток
	|	КОНЕЦ КАК Остаток,
	|	вт_Результат.МатрицаКоличество КАК МатрицаКоличество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) > 0
	|			ТОГДА 0
	|		ИНАЧЕ вт_Результат.МинимумСпайка
	|	КОНЕЦ КАК МинимумСпайка,
	|	вт_Результат.Комплект КАК Комплект,
	|	вт_Результат.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	вт_Результат.КВыгрузке КАК КВыгрузке,
	|	вт_Результат.СержантскийЗапас КАК СержантскийЗапас,
	|	ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) КАК ТоварыНаСкладахВычерках,
	|	вт_Результат.offer_id КАК offer_id,
	|	вт_Результат.АртикулКонтрагента КАК АртикулКонтрагента,
	|	вт_Результат.Product_ID КАК Product_ID,
	// Ихсанов Д. А. Начало 29.01.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117
	|	НЕ вт_ТоварыВБлокировке.Номенклатура ЕСТЬ NULL КАК ТоварВБлокировке
	// Ихсанов Д. А. Конец 29.01.2026
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоОстаткам КАК вт_ДанныеПоОстаткам
	|		ПО вт_Результат.Номенклатура = вт_ДанныеПоОстаткам.Номенклатура
	// Ихсанов Д. А. Начало 29.01.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ТоварыВБлокировке КАК вт_ТоварыВБлокировке
	|		ПО вт_Результат.Номенклатура = вт_ТоварыВБлокировке.Номенклатура";
	// Ихсанов Д. А. Конец 29.01.2026
	//Параметры запроса
	Запрос.УстановитьПараметр("ВыгрузкаПоМатрице",МаркетПлейс.ВыгрузкаОстатковПоМатрице);// Булево
	Запрос.УстановитьПараметр("ГотовыйКомплект",  Перечисления.ВидыКомплектов.ГотовыйКомплект);// Виды комплектов
	Запрос.УстановитьПараметр("ДатаОкончания",    КонецДня(ТекущаяДатаСеанса()));// Дата
	Запрос.УстановитьПараметр("Договор",          МаркетПлейс.Договор);// Договоры
	Запрос.УстановитьПараметр("Контрагент",       МаркетПлейс.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("МаркетПлейс",      МаркетПлейс);// Интернет магазины(marketplaces)
	Запрос.УстановитьПараметр("ПунктДоставки",    МаркетПлейс.ПунктДоставки);// Фактические адреса
	Запрос.УстановитьПараметр("Склад",            НужныйСклад);// Склады
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Запрос.УстановитьПараметр("СкладВычерка",     СкладВычерка);// Склады
	// Ихсанов Д. А. Конец  20.08.2025
	// Ихсанов Д. А. Начало 29.01.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	// Ихсанов Д. А. Конец 29.01.2026
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции 

Процедура МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков(ТаблицаПараметров=Неопределено,МаркетПлейс=Неопределено)  Экспорт
	
	//новый проект 14.02.2025
	//пока только Вайлбериз
	
	Если МаркетПлейс=Неопределено Тогда
		
		Сообщить("Обратитесь в ИТ отдел. Метод больше не работает");
		ЗаписатьВЛог("МП_Вайлберриз","Обратитесь в ИТ отдел. Метод больше не работает","Доступ");
		Возврат;
		
	КонецЕсли;          
	
	ПрефиксМаркета=ПрефМаркет(МаркетПлейс);
	
	Если МаркетПлейс.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз","Начало выгрузки остатков WB "+ПрефиксМаркета,"Информация");
	КонецЕсли;
	
	//////////иногда нужно ыгрузить выборочно//////////////////////////
	
	//вот только сюда получилось вставить фильтр
	
	//ТЗФИЛЬТР - таблица с Номенклатурой для фильтра
	
	ТЗФИЛЬТР             = Неопределено;
	ВыгружатьНаПортал    = Истина;
	СержантскийЗапас     = Ложь;
	ЛимитПоСекторам      = Ложь;
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	ОбнулятьТоварыПоВычеркамНаСкладах = Ложь;
	СоответствиеСкладовВычерка		  = Новый Соответствие;
	// Ихсанов Д. А. Конец  20.08.2025
	
	Если ТаблицаПараметров<>Неопределено  Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "ТЗ" Тогда			
				
				ТЗФИЛЬТР = СтрокаТП.Значение;
				
			КонецЕсли;	
			
			Если СтрокаТП.Имя = "ВыгружатьНаПортал" Тогда			
				
				ВыгружатьНаПортал = СтрокаТП.Значение;
				
			КонецЕсли;
			
			Если СтрокаТП.Имя = "СержантскийЗапас" Тогда			
				
				СержантскийЗапас = СтрокаТП.Значение;
				
			КонецЕсли; 	
			
			
			Если СтрокаТП.Имя = "ЛимитПоСекторам" Тогда			
				
				ЛимитПоСекторам = СтрокаТП.Значение;
				
			КонецЕсли;
			
			// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
			Если СтрокаТП.Имя = "ОбнулятьТоварыПоВычеркамНаСкладах" Тогда
				ОбнулятьТоварыПоВычеркамНаСкладах = СтрокаТП.Значение
			КонецЕсли;
			
			Если СтрокаТП.Имя = "СоответствиеСкладовВычерка" Тогда
				Попытка
					СоответствиеСкладовВычерка = ОбменМаркетПлейс.ОбработатьСтрокуJSON(СтрокаТП.Значение,,,, Истина);
				Исключение
					Если МаркетПлейс.Тест Тогда
						ЗаписатьВЛог("МП_Вайлберриз", "Невозможно валидировать параметр СоответствиеСкладовВычерка", "Предупреждение")
					КонецЕсли
				КонецПопытки
			КонецЕсли;
			// Ихсанов Д. А. Конец  20.08.2025
			
		КонецЦикла;   
		
	КонецЕсли;
	
	////////////остатки по разным складм/////////////////////////
	
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Склад = МаркетПлейс.СкладМаркировки;
	КодСкладаВычерка = СоответствиеСкладовВычерка[Склад.Код];
	СкладВычерка = Неопределено;
	Если ЗначениеЗаполнено(КодСкладаВычерка) И ОбнулятьТоварыПоВычеркамНаСкладах Тогда
		СкладВычерка = Справочники.Склады.НайтиПоКоду(КодСкладаВычерка)
	КонецЕсли;
	// Ихсанов Д. А. Конец  20.08.2025
	ТЗОСТАТОКФБС= МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс, Склад, СкладВычерка);
	
	////убрал склад маркировки из доп.складов
	//СкладМаркировки = МаркетПлейс.СкладМаркировки;
	//Если ЗначениеЗаполнено(СкладМаркировки) Тогда		
	//	
	//	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	//	КодСкладаВычеркаМаркировки = СоответствиеСкладовВычерка[СкладМаркировки.Код];
	//	СкладВычеркаМаркировки = Неопределено;
	//	Если ЗначениеЗаполнено(КодСкладаВычеркаМаркировки) И ОбнулятьТоварыПоВычеркамНаСкладах Тогда
	//		СкладВычеркаМаркировки = Справочники.Склады.НайтиПоКоду(КодСкладаВычеркаМаркировки)
	//	КонецЕсли;
	//	// Ихсанов Д. А. Конец  20.08.2025
	//	ТЗОСТАТОКМАРКИ = МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс,СкладМаркировки, СкладВычеркаМаркировки);
	//	
	//	Для Каждого СтрПол из ТЗОСТАТОКМАРКИ Цикл
	//		НовСтр=ТЗОСТАТОКФБС.Добавить();
	//		ЗаполнитьЗначенияСвойств(НовСтр,СтрПол);			
	//	КонецЦикла                                  
	//	
	//КонецЕсли;
	
	
	Для Каждого ДопСклад Из МаркетПлейс.Склады Цикл
		
		ТЗОСТАТОКДОП = МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс,ДопСклад.Склад);
		
		Для Каждого СтрПолДоп из ТЗОСТАТОКДОП Цикл
			НовСтр=ТЗОСТАТОКФБС.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр,СтрПолДоп);			
		КонецЦикла;  
		
		ТЗОСТАТОКДОП.Очистить();
		
	КонецЦикла;	 
	
	// Ихсанов Д. А. 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-146
	// Добавлено поле АртикулКонтрагента
	ТЗОСТАТОКФБС.Свернуть("Номенклатура,ШК,Комплект,ВыгружатьОст0,МатрицаКоличество,ТоварВБлокировке,АртикулКонтрагента",
		"Остаток,МинимумСпайка,КВыгрузке,СержантскийЗапас,ТоварыНаСкладахВычерках,КомплектующиеНаСкладахВычерках");
	//добавим ВЫЧЕРКИ
	
	// Ихсанов Д. А. Начало 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8904
	// Прогружаем в данные к выгрузке информацию о вычерках
	ТЗШККВыгрузке = СобратьДанныеОВычерках(ТЗОСТАТОКФБС, МаркетПлейс);
	// Ихсанов Д. А. Конец  17.02.2026
	
	//извините за такой вариант запроса , но он универасальный
	//сохраняя все колонки на входе и выходе
	
	Если ТЗФильтр<>Неопределено Тогда   	
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ *
		|ПОМЕСТИТЬ НужныйТовар
		|ИЗ
		|	&ТЗОстаток КАК ТЗОстаток
		|;
		|ВЫБРАТЬ *
		|ПОМЕСТИТЬ ФильтрТовар
		|ИЗ
		|	&ТЗФильтр КАК ТЗФильтр
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	НужныйТовар КАК НужныйТовар
		|ГДЕ
		|	Номенклатура.Ссылка В
		|			(ВЫБРАТЬ
		|				ФильтрТовар.Номенклатура КАК Номенклатура
		|			ИЗ
		|				ФильтрТовар КАК ФильтрТовар)";    		
		
		Запрос.УстановитьПараметр("ТЗОстаток",ТЗШККВыгрузке);
		Запрос.УстановитьПараметр("ТЗФильтр", ТЗФильтр); 		
		ТЗОстатковФинальная=Запрос.Выполнить().Выгрузить();			
		
	КОнецЕсли;
	
	
	
	//////////////////////////////////////////////
	
	
	//ОбНУЛЕНИЕ ВИТРИНЫ
	//Тимофеев Ю.А.  03.06.24
	
	Если МаркетПлейс.МаксКоличествоЗаказов>0 Тогда 
		
		//если Максимальное количество заказов больше нуля
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка КАК СтопВыгрузка
		|ИЗ
		|	РегистрСведений.СтатусФоновогоЗадания.СрезПоследних КАК СтатусФоновогоЗаданияСрезПоследних
		|ГДЕ
		|	СтатусФоновогоЗаданияСрезПоследних.КОД = &КОД";
		
		Запрос.УстановитьПараметр("КОД", МаркетПлейс.КОД);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();  		
		
		Если РезультатЗапроса.Следующий() Тогда
			
			Если РезультатЗапроса.СтопВыгрузка Тогда
				//стоит флаг СТОПВЫГРУЗКА 
				//обнулим колонку КВЫГРУЗКЕ - все уйдет по 0
				ТЗШККВыгрузке.ЗаполнитьЗначения(0,"КВыгрузке");
				//чтобы по секторам уже не разделяло 
				ЛимитПоСекторам = ложь;   
				СержантскийЗапас = ложь;
				
			КонецЕсли;
			
		КОнецЕсли;	
		
	КонецЕсли;
	
	//Тимофеев Ю.А.  03.06.24
	//ОбНУЛЕНИЕ ВИТРИНЫ
	
	//НЗ - неприкосновенный запас
	//Тимофеев Ю.А.  26.03.25
	
	Если СержантскийЗапас Тогда
		
		Если   ПараметрыСеанса.ТипУзла= Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			///ЕКАТ	
			ТЗШККВыгрузке=ОтложимСержантскийЗапасЕкат(ТЗШККВыгрузке);
			
		Иначе
			//ОФИС
			ТЗШККВыгрузке=ОтложимСержантскийЗапасОФИС(ТЗШККВыгрузке);
			
		КонецЕсли;
		
	КонецЕсли;
	
	//НЗ - неприкосновенный запас
	//Тимофеев Ю.А.  26.03.25
	
	//ЛимитПоСекторам - лимит по секторам
	//Тимофеев Ю.А.  07.05.25
	
	Если ЛимитПоСекторам Тогда   
		
		ПутьИмяФайла = МаркетПлейс.КаталогДляЭтикеток+"SektorXan.txt"; 
		
		ФайлТЗ = Новый Файл(ПутьИмяФайла);
		
		Если ФайлТЗ.Существует() Тогда
			
			ТЗПоСекторам = ЗначениеИзФайла(ПутьИмяФайла); 
			
			Если ТипЗнч(ТЗПоСекторам) = Тип("ТаблицаЗначений") Тогда
				
				ОбнулитьСектора = ТЗПоСекторам.Скопировать();
				ОбнулитьСектора.Очистить();
				ДатаПроверки = ТекущаяДатаСеанса();
				
				Для каждого СтрСектор из ТЗПоСекторам Цикл
					
					Если  ДатаПроверки>= СтрСектор.ДатаПроверки Тогда
						
						//если факт больше или равно плана
						Если СтрСектор.Факт>=СтрСектор.План Тогда
							
							НовСтр = ОбнулитьСектора.Добавить();
							ЗаполнитьЗначенияСвойств(НовСтр,СтрСектор);
							
						КонецЕсли; 
						
					КонецЕсли;  
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;	
		
		//если есть таблице значения - тогда обнуляем
		Если ОбнулитьСектора.Количество()>0 Тогда 			
			
			//добавим колонки
			
			ТЗШККВыгрузке.Колонки.Добавить("Бренд");
			ТЗШККВыгрузке.Колонки.Добавить("СекторХранения");
			
			//заполним сектора
			Для Каждого СтрН из ТЗШККВыгрузке Цикл
				
				Ном        = СТрН.Номенклатура; 	
				Бренд      = ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);	
				СтрН.Бренд =  Бренд;
				СтрН.СекторХранения=ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд); 
				
			КонецЦикла;     
			
			//обнулим сектора
			Для Каждого ОбнулСектор из ОбнулитьСектора Цикл
				
				Отбор = Новый Структура();
				Отбор.Вставить("СекторХранения",ОбнулСектор.СекторХранения);
				СтрокинужногоСектора = ТЗШККВыгрузке.НайтиСтроки(Отбор);	
				
				Для Каждого СтрСектор из СтрокинужногоСектора Цикл
					СтрСектор.КВыгрузке=0;	
				КонецЦикла;                   				
				
			КонецЦикла;                       		
			
		КонецЕсли;
		
	КонецЕсли;   	
	
	//ЛимитПоСекторам - лимит по секторам
	//Тимофеев Ю.А.  07.05.25
		
	Если ВыгружатьНаПортал Тогда  
		
		//Тимофеев Ю.А. 09.07.2025
		//уберем все отрицательные случайные остатки
		ТЗШККВыгрузке.Колонки.Добавить("Минус");
		
		Для каждого стрТовар из ТЗШККВыгрузке Цикл
			
			Если СтрТовар.КВыгрузке<0 Тогда
				СтрТовар.КВыгрузке=0; 
				СтрТовар.Минус=Истина;
			КонецЕсли;    
			
		КонецЦикла;
		//уберем все отрицательные случайные остатки
		//Тимофеев Ю.А. 09.07.2025         
		
		// Ихсанов Д. А. Начало 17.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьКЛогу = ?(ЗначениеЗаполнено(ПутьКонстантыЛогов), ПутьКонстантыЛогов, "\\srvfiles\1C_Logs_MarketPlace\");
		
		КешДанныеКВыгрузке = Неопределено;
		НайденныеФайлы = НайтиФайлы(ПутьКЛогу, СтрШаблон("ВыгрузкаОстатковWB_%1_%2*", ПрефиксМаркета,
			Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_")), Ложь);
		Если НайденныеФайлы.Количество() > 0 Тогда
			ФайлЛога = НайденныеФайлы[НайденныеФайлы.ВГраница()];
			КешДанныеКВыгрузке = ЗначениеИзФайла(ФайлЛога.ПолноеИмя);
		КонецЕсли;
		
		ТаблицаДляОтправкиНаСайт = ТЗШККВыгрузке;
		Если КешДанныеКВыгрузке <> Неопределено Тогда
			ТаблицаДляОтправкиНаСайт = ОбменМаркетПлейс.СравнитьДвеТаблицыЗначенийИвернутьТолькоИзменныеСтроки(КешДанныеКВыгрузке,
				ТЗШККВыгрузке, "Номенклатура", Истина);
		КонецЕсли;
		// Ихсанов Д. А. Конец 17.09.2025
		
		МП_Вайлберриз_ВыгрузитьОстаткиНаПортал(МаркетПлейс,ТаблицаДляОтправкиНаСайт,ПрефиксМаркета); 
		
	КонецЕсли;
		
	//////НОВЫЙ КОНТРОЛЬ ЗАПИСИ ТЗ ВЫГРУЗКИ ОСТАТКОВ///////
		
	Попытка
		
		// Ихсанов Д. А. Начало 23.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2506
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьКЛогу = ?(ЗначениеЗаполнено(ПутьКонстантыЛогов), ПутьКонстантыЛогов, "\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy_MM_dd_ЧЧ_мм_сс");
		ИмяФайла = СтрШаблон("%1ВыгрузкаОстатковWB_%2_%3_Польз_%4_%5_%6.txt", ПутьКЛогу, ПрефиксМаркета, ВремяЗаписи,
			СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".",""),
			НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref"), НСтр(СтрокаСоединенияИнформационнойБазы(), "Srvr"));
		
		//ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		//ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		//ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_ЧЧ_мм_сс");
		//
		////Если БТК Тогда
		//ИмяФайла=ПутьЛог+"ВыгрузкаОстатковWB_"+ПрефиксМаркета+"_"+ВремяЗаписи+"_Польз_"+СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".","")+".txt";
		////Иначе
		////	ИмяФайла=ПутьЛог+"ВыгрузкаОстатковWB_БТК_"+ВремяЗаписи+"_Польз_"+СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".","")+".txt";
		////КонецЕсли;	
		// Ихсанов Д. А. Конец  23.09.2025
		
		ЗначениеВФайл(ИмяФайла, ТЗШККВыгрузке);
		
	Исключение
		
		ЗаписатьВЛог("ЗаписьЛога_ОШИБКА",ПрефиксМаркета+" Имя файла "+ИмяФайла+" "+ОписаниеОшибки(),"ИСКЛЮЧЕНИЕ_ОШИБКА");
		
	КонецПопытки;
		
	//////НОВЫЙ КОНТРОЛЬ ЗАПИСИ ТЗ ВЫГРУЗКИ ОСТАТКОВ///////
		
	ВсегоСтрок = Строка(ТЗШККВыгрузке.Количество());
	КолТовара  = Строка(ТЗШККВыгрузке.Итог("КВыгрузке"));
	
	//Тимофеев Ю.А. Конец    13-02-2025
	
	ЗаписатьВЛог("МП_Вайлберриз","Окончание выгрзки остатков WB - ЕЕЭ! Строк :"+ВсегоСтрок+" количество "+КолТовара,"Информация");
		
КонецПроцедуры


Процедура МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков_ОЗОН(ТаблицаПараметров=Неопределено,МаркетПлейс=Неопределено)  Экспорт
	
	//новый проект 14.02.2025
	//пока только Вайлбериз
	
	Если МаркетПлейс=Неопределено Тогда
		
		Сообщить("Обратитесь в ИТ отдел. Метод больше не работает");
		ЗаписатьВЛог("МП_Вайлберриз","Обратитесь в ИТ отдел. Метод больше не работает","Доступ");
		Возврат;
		
	КонецЕсли;          
	
	ПрефиксМаркета="ОЗОН";
		
	Если МаркетПлейс.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз","Начало выгрузки остатков WB "+ПрефиксМаркета,"Информация");
	КонецЕсли;
	
	//////////иногда нужно ыгрузить выборочно//////////////////////////
	
	//вот только сюда получилось вставить фильтр
	
	//ТЗФИЛЬТР - таблица с Номенклатурой для фильтра
	
	ТЗФИЛЬТР             = Неопределено;
	ВыгружатьНаПортал    = Истина;
	СержантскийЗапас     = Ложь;
	ЛимитПоСекторам      = Ложь;
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	ОбнулятьТоварыПоВычеркамНаСкладах = Ложь;
	СоответствиеСкладовВычерка		  = Новый Соответствие;
	// Ихсанов Д. А. Конец  20.08.2025
	
	Если ТаблицаПараметров<>Неопределено  Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "ТЗ" Тогда			
				
				ТЗФИЛЬТР = СтрокаТП.Значение;
				
			КонецЕсли;	
			
			Если СтрокаТП.Имя = "ВыгружатьНаПортал" Тогда			
				
				ВыгружатьНаПортал = СтрокаТП.Значение;
				
			КонецЕсли;
			
			Если СтрокаТП.Имя = "СержантскийЗапас" Тогда			
				
				СержантскийЗапас = СтрокаТП.Значение;
				
			КонецЕсли; 	
			
			
			Если СтрокаТП.Имя = "ЛимитПоСекторам" Тогда			
				
				ЛимитПоСекторам = СтрокаТП.Значение;
				
			КонецЕсли;
			
			// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
			Если СтрокаТП.Имя = "ОбнулятьТоварыПоВычеркамНаСкладах" Тогда
				ОбнулятьТоварыПоВычеркамНаСкладах = СтрокаТП.Значение
			КонецЕсли;
			
			Если СтрокаТП.Имя = "СоответствиеСкладовВычерка" Тогда
				Попытка
					СоответствиеСкладовВычерка = ОбменМаркетПлейс.ОбработатьСтрокуJSON(СтрокаТП.Значение,,,, Истина);
				Исключение
					Если МаркетПлейс.Тест Тогда
						ЗаписатьВЛог("МП_Вайлберриз", "Невозможно валидировать параметр СоответствиеСкладовВычерка", "Предупреждение")
					КонецЕсли
				КонецПопытки
			КонецЕсли;
			// Ихсанов Д. А. Конец  20.08.2025
			
		КонецЦикла;   
		
	КонецЕсли;
	
	////////////остатки по разным складм/////////////////////////
	
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Склад = МаркетПлейс.СкладМаркировки;
	КодСкладаВычерка = СоответствиеСкладовВычерка[Склад.Код];
	СкладВычерка = Неопределено;
	Если ЗначениеЗаполнено(КодСкладаВычерка) И ОбнулятьТоварыПоВычеркамНаСкладах Тогда
		СкладВычерка = Справочники.Склады.НайтиПоКоду(КодСкладаВычерка)
	КонецЕсли;
	// Ихсанов Д. А. Конец  20.08.2025
	
	// Ихсанов Д. А. 03.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117 // Рефакторинг функционала. Универсализация.
	ТЗОСТАТОКФБС = МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс, Склад, СкладВычерка);
	
	////убрал склад маркировки из доп.складов
	//СкладМаркировки = МаркетПлейс.СкладМаркировки;
	//Если ЗначениеЗаполнено(СкладМаркировки) Тогда		
	//	
	//	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	//	КодСкладаВычеркаМаркировки = СоответствиеСкладовВычерка[СкладМаркировки.Код];
	//	СкладВычеркаМаркировки = Неопределено;
	//	Если ЗначениеЗаполнено(КодСкладаВычеркаМаркировки) И ОбнулятьТоварыПоВычеркамНаСкладах Тогда
	//		СкладВычеркаМаркировки = Справочники.Склады.НайтиПоКоду(КодСкладаВычеркаМаркировки)
	//	КонецЕсли;
	//	// Ихсанов Д. А. Конец  20.08.2025
	//	ТЗОСТАТОКМАРКИ = МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс,СкладМаркировки, СкладВычеркаМаркировки);
	//	
	//	Для Каждого СтрПол из ТЗОСТАТОКМАРКИ Цикл
	//		НовСтр=ТЗОСТАТОКФБС.Добавить();
	//		ЗаполнитьЗначенияСвойств(НовСтр,СтрПол);			
	//	КонецЦикла                                  
	//	
	//КонецЕсли;
	
	
	Для Каждого ДопСклад Из МаркетПлейс.Склады Цикл
		
		ТЗОСТАТОКДОП = МП_УНИВЕР_ОСТАТКИ_ПО_СКЛАДУ(МаркетПлейс,ДопСклад.Склад);
		
		Для Каждого СтрПолДоп из ТЗОСТАТОКДОП Цикл
			НовСтр=ТЗОСТАТОКФБС.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр,СтрПолДоп);			
		КонецЦикла;  
		
		ТЗОСТАТОКДОП.Очистить();
		
	КонецЦикла;	 
	
	ТЗОСТАТОКФБС.Свернуть("Номенклатура,offer_id,Product_ID,SKU,Комплект,ВыгружатьОст0,МатрицаКоличество,ТоварВБлокировке",
		"Остаток,МинимумСпайка,КВыгрузке,СержантскийЗапас,ТоварыНаСкладахВычерках,КомплектующиеНаСкладахВычерках");
	
	//добавим ВЫЧЕРКИ
	
	// Ихсанов Д. А. Начало 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8904
	// Прогружаем в данные к выгрузке информацию о вычерках
	ТЗШККВыгрузке = СобратьДанныеОВычерках(ТЗОСТАТОКФБС, МаркетПлейс);
	// Ихсанов Д. А. Конец  17.02.2026
	
	//извините за такой вариант запроса , но он универасальный
	//сохраняя все колонки на входе и выходе
	
	Если ТЗФильтр<>Неопределено Тогда   	
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ *
		|ПОМЕСТИТЬ НужныйТовар
		|ИЗ
		|	&ТЗОстаток КАК ТЗОстаток
		|;
		|ВЫБРАТЬ *
		|ПОМЕСТИТЬ ФильтрТовар
		|ИЗ
		|	&ТЗФильтр КАК ТЗФильтр
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	НужныйТовар КАК НужныйТовар
		|ГДЕ
		|	Номенклатура.Ссылка В
		|			(ВЫБРАТЬ
		|				ФильтрТовар.Номенклатура КАК Номенклатура
		|			ИЗ
		|				ФильтрТовар КАК ФильтрТовар)";    		
		
		Запрос.УстановитьПараметр("ТЗОстаток",ТЗШККВыгрузке);
		Запрос.УстановитьПараметр("ТЗФильтр", ТЗФильтр); 		
		ТЗОстатковФинальная=Запрос.Выполнить().Выгрузить();			
		
	КОнецЕсли;   
	
	//////////////////////////////////////////////
		
	//ОбНУЛЕНИЕ ВИТРИНЫ
	//Тимофеев Ю.А.  03.06.24
	
	Если МаркетПлейс.МаксКоличествоЗаказов>0 Тогда 
		
		//если Максимальное количество заказов больше нуля
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка КАК СтопВыгрузка
		|ИЗ
		|	РегистрСведений.СтатусФоновогоЗадания.СрезПоследних КАК СтатусФоновогоЗаданияСрезПоследних
		|ГДЕ
		|	СтатусФоновогоЗаданияСрезПоследних.КОД = &КОД";
		
		Запрос.УстановитьПараметр("КОД", МаркетПлейс.КОД);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();  		
		
		Если РезультатЗапроса.Следующий() Тогда
			
			Если РезультатЗапроса.СтопВыгрузка Тогда
				//стоит флаг СТОПВЫГРУЗКА 
				//обнулим колонку КВЫГРУЗКЕ - все уйдет по 0
				ТЗШККВыгрузке.ЗаполнитьЗначения(0,"КВыгрузке");
				
				//чтобы по секторам уже не разделяло 
				ЛимитПоСекторам = ложь;  
				СержантскийЗапас = ложь;  
				
			КонецЕсли;
			
		КОнецЕсли;	
		
	КонецЕсли;
	
	//Тимофеев Ю.А.  03.06.24
	//ОбНУЛЕНИЕ ВИТРИНЫ
	
	//НЗ - неприкосновенный запас
	//Тимофеев Ю.А.  26.03.25
	
	Если СержантскийЗапас Тогда
		
		Если   ПараметрыСеанса.ТипУзла= Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			///ЕКАТ	
			ТЗШККВыгрузке=ОтложимСержантскийЗапасЕкат(ТЗШККВыгрузке);
			
		Иначе
			//ОФИС
			ТЗШККВыгрузке=ОтложимСержантскийЗапасОФИС(ТЗШККВыгрузке);
			
		КонецЕсли;
		
	КонецЕсли;
	
	//НЗ - неприкосновенный запас
	//Тимофеев Ю.А.  26.03.25
	
	//ЛимитПоСекторам - лимит по секторам
	//Тимофеев Ю.А.  07.05.25
	
	Если ЛимитПоСекторам Тогда   
		
		ПутьИмяФайла = МаркетПлейс.КаталогДляЭтикеток+"SektorXan.txt"; 
		
		ФайлТЗ = Новый Файл(ПутьИмяФайла);
		
		Если ФайлТЗ.Существует() Тогда
			
			ТЗПоСекторам = ЗначениеИзФайла(ПутьИмяФайла); 
			
			Если ТипЗнч(ТЗПоСекторам) = Тип("ТаблицаЗначений") Тогда
				
				ОбнулитьСектора = ТЗПоСекторам.Скопировать();
				ОбнулитьСектора.Очистить();
				ДатаПроверки = ТекущаяДатаСеанса();
				
				Для каждого СтрСектор из ТЗПоСекторам Цикл
					
					Если  ДатаПроверки>= СтрСектор.ДатаПроверки Тогда
						
						//если факт больше или равно плана
						Если СтрСектор.Факт>=СтрСектор.План Тогда
							
							НовСтр = ОбнулитьСектора.Добавить();
							ЗаполнитьЗначенияСвойств(НовСтр,СтрСектор);
							
						КонецЕсли; 
						
					КонецЕсли;  
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;	
		
		//если есть таблице значения - тогда обнуляем
		Если ОбнулитьСектора.Количество()>0 Тогда 			
			
			//добавим колонки
			
			ТЗШККВыгрузке.Колонки.Добавить("Бренд");
			ТЗШККВыгрузке.Колонки.Добавить("СекторХранения");
			
			//заполним сектора
			Для Каждого СтрН из ТЗШККВыгрузке Цикл
				
				Ном        = СТрН.Номенклатура; 	
				Бренд      = ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);	
				СтрН.Бренд =  Бренд;
				СтрН.СекторХранения=ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд); 
				
			КонецЦикла;     
			
			//обнулим сектора
			Для Каждого ОбнулСектор из ОбнулитьСектора Цикл
				
				Отбор = Новый Структура();
				Отбор.Вставить("СекторХранения",ОбнулСектор.СекторХранения);
				СтрокинужногоСектора = ТЗШККВыгрузке.НайтиСтроки(Отбор);	
				
				Для Каждого СтрСектор из СтрокинужногоСектора Цикл
					СтрСектор.КВыгрузке=0;	
				КонецЦикла;                   				
				
			КонецЦикла;                       		
			
		КонецЕсли;
		
	КонецЕсли;   	
	
	//ЛимитПоСекторам - лимит по секторам
	//Тимофеев Ю.А.  07.05.25
	
	Если ВыгружатьНаПортал Тогда  
		
		//Тимофеев Ю.А. 09.07.2025
		//уберем все отрицательные случайные остатки
		ТЗШККВыгрузке.Колонки.Добавить("Минус");
		
		Для каждого стрТовар из ТЗШККВыгрузке Цикл
			
			Если СтрТовар.КВыгрузке<0 Тогда
				СтрТовар.КВыгрузке=0; 
				СтрТовар.Минус=Истина;
			КонецЕсли;    
			
		КонецЦикла;
		//уберем все отрицательные случайные остатки
		//Тимофеев Ю.А. 09.07.2025
		
		// Ихсанов Д. А. Начало 17.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьКЛогу = ?(ЗначениеЗаполнено(ПутьКонстантыЛогов), ПутьКонстантыЛогов, "\\srvfiles\1C_Logs_MarketPlace\");
		
		КешДанныеКВыгрузке = Неопределено;
		НайденныеФайлы = НайтиФайлы(ПутьКЛогу, СтрШаблон("ВыгрузкаОстатковОЗОН__%1*",
			Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_")), Ложь);
		Если НайденныеФайлы.Количество() > 0 Тогда
			ФайлЛога = НайденныеФайлы[НайденныеФайлы.ВГраница()];
			КешДанныеКВыгрузке = ЗначениеИзФайла(ФайлЛога.ПолноеИмя);
		КонецЕсли;
		
		ТаблицаДляОтправкиНаСайт = ТЗШККВыгрузке;
		Если КешДанныеКВыгрузке <> Неопределено Тогда
			ТаблицаДляОтправкиНаСайт = ОбменМаркетПлейс.СравнитьДвеТаблицыЗначенийИвернутьТолькоИзменныеСтроки(КешДанныеКВыгрузке,
				ТЗШККВыгрузке, "Номенклатура", Истина);
		КонецЕсли;
		// Ихсанов Д. А. Конец 17.09.2025
		
		МП_ОЗОН_ВыгрузитьОстаткиОзон(МаркетПлейс,ТаблицаДляОтправкиНаСайт); 
		
	КонецЕсли;
		
	//////НОВЫЙ КОНТРОЛЬ ЗАПИСИ ТЗ ВЫГРУЗКИ ОСТАТКОВ///////
		
	Попытка
		
		// Ихсанов Д. А. Начало 23.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2507
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьКЛогу = ?(ЗначениеЗаполнено(ПутьКонстантыЛогов), ПутьКонстантыЛогов, "\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy_MM_dd_ЧЧ_мм_сс");
		ИмяФайла = СтрШаблон("%1ВыгрузкаОстатковОЗОН__%2_Польз_%3_%4_%5.txt", ПутьКЛогу, ВремяЗаписи,
			СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".",""),
			НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref"), НСтр(СтрокаСоединенияИнформационнойБазы(), "Srvr"));
		
		//ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		//ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		//ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
		//
		////Если БТК Тогда
		//ИмяФайла=ПутьЛог+"ВыгрузкаОстатковОЗОН__"+ВремяЗаписи+"_Польз_"+СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".","")+".txt";
		////Иначе
		////	ИмяФайла=ПутьЛог+"ВыгрузкаОстатковWB_БТК_"+ВремяЗаписи+"_Польз_"+СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".","")+".txt";
		////КонецЕсли;	
		// Ихсанов Д. А. Конец  23.09.2025
		
		ЗначениеВФайл(ИмяФайла, ТЗШККВыгрузке);
		
	Исключение
		
		ЗаписатьВЛог("ЗаписьЛога_ОШИБКА",ПрефиксМаркета+" Имя файла "+ИмяФайла+" "+ОписаниеОшибки(),"ИСКЛЮЧЕНИЕ_ОШИБКА");
		
	КонецПопытки;
	
	//////НОВЫЙ КОНТРОЛЬ ЗАПИСИ ТЗ ВЫГРУЗКИ ОСТАТКОВ///////
	
	ВсегоСтрок = Строка(ТЗШККВыгрузке.Количество());
	КолТовара  = Строка(ТЗШККВыгрузке.Итог("КВыгрузке"));
	
	//Тимофеев Ю.А. Конец    13-02-2025
	
	ЗаписатьВЛог("МП_ОЗОН","Окончание выгрзки остатков ОЗОН! Строк :"+ВсегоСтрок+" количество "+КолТовара,"Информация");
		
КонецПроцедуры

Функция ОтложимСержантскийЗапасОФИС(ТЗдляОбработки) Экспорт
	       
	///ШК,КВыгрузке,Остаток,МинимумСпайка,Комплект
	
	Для Каждого СтрокаОбработки из  ТЗдляОбработки Цикл
		
		Если СтрокаОбработки.КВыгрузке = 0 Тогда
			Продолжить;
		КонецЕсли;  	
		
		Если СтрокаОбработки.Комплект //Тогда  
			// Ихсанов Д. А. Начало 18.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8924
			И СтрокаОбработки.Остаток < 2 Тогда
			// Ихсанов Д. А. Конец  18.02.2026
			
			НужноеКоличество = СтрокаОбработки.МинимумСпайка;
			
			ВходящееКоличество =  СтрокаОбработки.КВыгрузке;
			
			Если ВходящееКоличество<=2 Тогда
				
				Если НужноеКоличество<=2 Тогда				
					
					СтрокаОбработки.КВыгрузке        = 0;
					СтрокаОбработки.СержантскийЗапас = НужноеКоличество;		
					
				КонецЕсли;
				
			ИначеЕсли ВходящееКоличество<=5 Тогда 			
				
				Если НужноеКоличество<=5 Тогда				
					
					СтрокаОбработки.КВыгрузке        = НужноеКоличество-2;
					СтрокаОбработки.СержантскийЗапас = 2;  
					
				КонецЕсли;    		        
				
			ИначеЕсли ВходящееКоличество<=10 Тогда
				
				Если НужноеКоличество<=10 Тогда			
					
					СтрокаОбработки.КВыгрузке        = НужноеКоличество-4;
					СтрокаОбработки.СержантскийЗапас = 4;  
					
				КонецЕсли;
				
			КонецЕсли; 
			
		иначе
			НужноеКоличество = СтрокаОбработки.Остаток; 
			
			
			ВходящееКоличество =  СтрокаОбработки.КВыгрузке;
			
			Если ВходящееКоличество=1 Тогда
				
				
				
				СтрокаОбработки.КВыгрузке        = 0;
				СтрокаОбработки.СержантскийЗапас = ВходящееКоличество;		
				
			ИначеЕсли ВходящееКоличество=2 Тогда 			
				
				
				
				СтрокаОбработки.КВыгрузке        = 1;
				СтрокаОбработки.СержантскийЗапас = 1;  
				
				
				
			ИначеЕсли ВходящееКоличество=3 Тогда 			
				
				
				
				СтрокаОбработки.КВыгрузке        = 2;
				СтрокаОбработки.СержантскийЗапас = 1;  
				
				
				
			ИначеЕсли ВходящееКоличество=4 Тогда
				
				
				
				СтрокаОбработки.КВыгрузке        = 3;
				СтрокаОбработки.СержантскийЗапас = 1;   
				
			ИначеЕсли ВходящееКоличество=5 Тогда    						
				
				СтрокаОбработки.КВыгрузке        = 4;
				СтрокаОбработки.СержантскийЗапас = 1; 					
				
			КонецЕсли;  
			
		КонецЕсли;

		
	КонецЦикла;  
	
	Возврат ТЗдляОбработки;
	
КонецФункции


Функция ОтложимСержантскийЗапасЕкат(ТЗдляОбработки) Экспорт
	
	///ШК,КВыгрузке,Остаток,МинимумСпайка,Комплект 	
	
	Для Каждого СтрокаОбработки из  ТЗдляОбработки Цикл
		
		Если СтрокаОбработки.КВыгрузке = 0 Тогда
			Продолжить;
		КонецЕсли;      	
		
		Если СтрокаОбработки.Комплект Тогда
			НужноеКоличество = СтрокаОбработки.МинимумСпайка;
		иначе
			НужноеКоличество = СтрокаОбработки.Остаток;  
		КонецЕсли;
		
		ВходящееКоличество =  СтрокаОбработки.КВыгрузке;
		
		Если ВходящееКоличество<=3 Тогда
			
			Если НужноеКоличество<=3 Тогда	
				
				СтрокаОбработки.КВыгрузке        = 0;
				СтрокаОбработки.СержантскийЗапас = НужноеКоличество;
				
			КонецЕсли;
			
		ИначеЕсли ВходящееКоличество<=5 Тогда
			
			Если НужноеКоличество<=5 Тогда			
				
				СтрокаОбработки.КВыгрузке        = НужноеКоличество-2;
				СтрокаОбработки.СержантскийЗапас = 2;  
				
			КонецЕсли;    		        
			
		ИначеЕсли ВходящееКоличество<=10 Тогда
			
			Если НужноеКоличество<=10 Тогда			
				
				СтрокаОбработки.КВыгрузке        = НужноеКоличество-4;
				СтрокаОбработки.СержантскийЗапас = 4;  
				
			КонецЕсли;
			
		ИначеЕсли ВходящееКоличество<=20 Тогда
			
			Если НужноеКоличество<=20 Тогда			
				
				СтрокаОбработки.КВыгрузке        = НужноеКоличество-6;
				СтрокаОбработки.СержантскийЗапас = 6;  
				
			КонецЕсли;  		
			
		КонецЕсли;
		
	КонецЦикла;  
	
	Возврат ТЗдляОбработки;
	
	
КонецФункции   


// Ихсанов Д. А. Начало 18.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ID-17697
// Процедура - М п УНИВЕРСАЛЬНАЯ выгрузка остатков Яндекс маркет
//
Процедура МП_УНИВЕРСАЛЬНАЯ_ВыгрузкаОстатков_ЯндексМаркет(ТаблицаПараметров = Неопределено, //МаркетПлейс) Экспорт
	МаркетПлейс = Неопределено) Экспорт
	
	// Фиксируем разово дату для текущего блока кода
	ТекущаяДата = ТекущаяДатаСеанса();
	
	// Ихсанов Д. А. Начало 03.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2065
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00004");
	// Ихсанов Д. А. Конец  03.06.2025
	
	// По некоторым маркетплейсам интернет магазинов может быть больше одного
	// В дополнение тут избегается лишний вызов к бд
	Если МаркетПлейс = Неопределено Тогда
		Сообщить("Обратитесь в ИТ отдел. Метод больше не работает");
		ЗаписатьВЛог("МП_Яндекс", "Обратитесь в ИТ отдел. Метод больше не работает", "Доступ");
		
		Возврат;
	КонецЕсли;
	
	// Заранее получаем все необходимые данные по реквизитам и прокидываем их в весь функционал
	РеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, "ВыгрузкаОстатковПоМатрице, Договор,
		|Контрагент, ПунктДоставки, Код, МаксКоличествоЗаказов, ИДКомпании, Тест, КаталогДляЭтикеток");
	
	// Фиксируем префикс для наименования лога по выгрузке остатков
	ПрефиксМаркетПлейса = "";
	Если ПустаяСтрока(ПрефиксМаркетПлейса) Тогда
		ПрефиксМаркетПлейса = "Яндекс";
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 15.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2188
	Если МаркетПлейс.Тест Тогда
		ЗаписатьВЛог("МП_Яндекс", СтрШаблон("Начало выгрузки остатков %1%2.", 
		?(ЗначениеЗаполнено(ПрефиксМаркетПлейса), " ", ""), ПрефиксМаркетПлейса), "Информация");
	КонецЕсли;
	// Ихсанов Д. А. Конец  15.04.2025
	
	// Инициализируем параметры выполнения
	ТЗ_Фильтр						  = Неопределено;       // Таблица для отбора товара при выгрузке
	ВыгружатьНаПортал				  = Истина;             // Тумблер для отключения выгрузки остатков на маркетплейс
	СержантскийЗапас				  = Ложь;               // Числовая погрешность для избежания ухода остатка в минус
	ЕмкостьПорции					  = 2000;               // Количество строк, отправляемых на сайт за один раз
	ЛимитПоСекторам					  = Ложь;               // Ограничение продаж по секторам продукции
	ОбнулятьТоварыПоВычеркамНаСкладах = Ложь;               // Обнулять товары, если часть остатков есть на складах вычерка
	СоответствиеСкладовВычерка		  = Новый Соответствие; // Список складов для проверки на наличие вычерка
	Если ТаблицаПараметров <> Неопределено Тогда
		Для каждого Параметр из ТаблицаПараметров Цикл
			Если Параметр.Имя = "ТЗ" Тогда
				ТЗ_Фильтр = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ВыгружатьНаПортал" Тогда
				ВыгружатьНаПортал = Параметр.Значение
			ИначеЕсли Параметр.Имя = "СержантскийЗапас" Тогда
				СержантскийЗапас = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ЕмкостьПорции" Тогда
				ЕмкостьПорции = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ЛимитПоСекторам" Тогда
				ЛимитПоСекторам = Параметр.Значение
			ИначеЕсли Параметр.Имя = "ОбнулятьТоварыПоВычеркамНаСкладах" Тогда
				ОбнулятьТоварыПоВычеркамНаСкладах = Параметр.Значение
			ИначеЕсли Параметр.Имя = "СоответствиеСкладовВычерка" Тогда
				Попытка
					СоответствиеСкладовВычерка = ОбменМаркетПлейс.ОбработатьСтрокуJSON(Параметр.Значение,,,, Истина)
				Исключение
					Если МаркетПлейс.Тест Тогда
						ЗаписатьВЛог("МП_Вайлберриз", "Невозможно валидировать параметр СоответствиеСкладовВычерка", "Предупреждение")
					КонецЕсли
				КонецПопытки
			КонецЕсли
		КонецЦикла
	КонецЕсли;
	
	// Получим данные по складам
	вт_ОстаткиПоСкладу = Неопределено;
	ДанныеКВыгрузке    = Неопределено;
	//МассивСкладов = ДанныеПоВсемСкладамМаркетплейса(МаркетПлейс);
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(МаркетПлейс.СкладМаркировки);
	Для каждого ДанныеСклада из МассивСкладов Цикл
