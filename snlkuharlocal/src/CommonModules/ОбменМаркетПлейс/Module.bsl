// Ихсанов Д. А. Начало 28.01.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-820
// Функция - МП Яндекс маркет отправить данные по статусу документа
// Отправляет состав товаров и маркировку по нему на сервис Яндекс.Маркет.
//
// Параметры:
//  МаркетПлейс			 	- СправочникСсылка.ИнетМагазины - Ссылка на МаркетПлейс.
//  ВнешнийИдентификатор 	- Строка - Идентификатор заказа на стороне Яндекс.Маркет.
//  ДанныеДляJSON		 	- Структура - См. // РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ.
//  ДополнительныеПараметры - Структура - ИДКомпании и Наименование.
// 
// Возвращаемое значение:
//  Истина - Истина если данные по заказу были отправлены успешно, иначе Ложь.
//
Функция МП_ЯндексМаркет_ОтправитьДанныеПоСтатусуДокумента(МаркетПлейс, ВнешнийИдентификатор, //ДанныеДляJSON...) Экспорт
	ДанныеДляJSON, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(ДополнительныеПараметры.ИДКомпании) Тогда
		// Если не заполнено поле ИДКомпании, то сразу фиксируем ошибку и возвращаемся.
		Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При проверке заказа %2 на стороне сервиса возникла ошибка!
			|Не заполнен реквизит ""ИДКомпании"" у МаркетПлейса %3'", "ru");
		СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ОтправитьДанныеПоСтатусуДокумента",
		ВнешнийИдентификатор, ДополнительныеПараметры.Наименование);
		ЗаписатьВЛог("МП_ЯндексМаркет", СообщениеОбОшибке, "Ошибка");
		
		Возврат Ложь;
	КонецЕсли;
	
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - НАЧАЛО!!!! (СформироватьСтрокуJSON)
	// Ограничиваем отступы в рамках сформированной строки
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "");
	
	// Формируем строку из данных структуры или массива
	ЗаписьJSON = Новый ЗаписьJSON();
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
	ЗаписьJSON.ПроверятьСтруктуру = Истина;
	ЗаписатьJSON(ЗаписьJSON, ДанныеДляJSON);
	СтрокаJSON = ЗаписьJSON.Закрыть();
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - КОНЕЦ!!!!
	
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - НАЧАЛО!!!! (МП_АдресЗапроса_ПодготовкаЗаказа)
	// Получаем данные адреса запроса к сервису по информации об одном заказе
	АдресЗапроса = СтрШаблон("/v2/campaigns/%1/orders/%2/status.json", ДополнительныеПараметры.ИДКомпании, 
	ВнешнийИдентификатор);
	
	Метод = "PUT";
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - КОНЕЦ!!!!
	
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - НАЧАЛО!!!! (ВыполнитьИОбработатьЗапросВМоделиСервиса)
	HTTPЗапрос = Новый HTTPЗапрос(АдресЗапроса);
	HTTPЗапрос.Заголовки = МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс);
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);
	
	лHTTPСоединение = МП_Яндекс_ВернутьСоединение(МаркетПлейс);
	Попытка
		Результат = лHTTPСоединение.ВызватьHTTPМетод(Метод, HTTPЗапрос);
	Исключение
		// Исключение здесь говорит о том, что запрос не дошел до HTTP-Сервера
		Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При проверке заказа %2 на стороне сервиса возникла ошибка!
			|Возникла ошибка при получении данных от сервиса по заказу:
			|%3'", "ru");
		СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ОтправитьДанныеПоСтатусуДокумента",
		ВнешнийИдентификатор, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписатьВЛог("МП_ЯндексМаркет", СообщениеОбОшибке, "Ошибка");
		
		Возврат Ложь;
	КонецПопытки;
	
	// Обрабатываем ошибки и перенаправление
	Если Результат.КодСостояния >= 300 и Результат.КодСостояния < 500  Тогда
		Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При проверке заказа %2 на стороне сервиса возникла ошибка!
		|Сервис МаркетПлейса вернул ошибку на запрос:
		|%3'", "ru");
		СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ОтправитьДанныеПоСтатусуДокумента",
		ВнешнийИдентификатор, Результат.ПолучитьТелоКакСтроку());
		ЗаписатьВЛог("МП_ЯндексМаркет", СообщениеОбОшибке, "Ошибка");
		
		Возврат Ложь;
	КонецЕсли;
	
	// Статусы 1XX и 2XX считаем хорошими
	Если Результат.КодСостояния < 300 Тогда
		// Валидируем информацию о заказе
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
		ДанныеJSON = ПрочитатьJSON(ЧтениеJSON, Ложь,, ФорматДатыJSON.ISO);
		ЧтениеJSON.Закрыть();
		
		// Получаем и обрабатываем информацию о статусе заказа
		Если ДанныеJSON.Свойство("order") Тогда
			Возврат Истина
		КонецЕсли;
	КонецЕсли;
	// РЕФАКТОРИНГ - УНИФИЦИРОВАТЬ - КОНЕЦ!!!!
	
	Возврат Ложь;
	
КонецФункции // МП_ЯндексМаркет_ОтправитьДанныеПоСтатусуДокумента()
// Ихсанов Д. А. Конец  28.01.2025

// Ихсанов Д. А. Начало 01.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2125
//
// Параметры:
//  МаркетПлейс	 - Справочник.ИнетМагазины	 - Ссылка на сущность маркетплейса
// 
// Возвращаемое значение:
//  Число - Количество новых заказов на стороне сервиса Яндекс Маркет.
//
Функция МП_ЯндексМаркет_КонтрольКоличестваЗаказов(МаркетПлейс) Экспорт
	
	КвалификаторСтроки = Новый КвалификаторыСтроки();
	Массив = Новый Массив;	Массив.Добавить(Тип("Строка"));
	ОписаниеТипаСтрока = Новый ОписаниеТипов(Массив,, КвалификаторСтроки);
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	ИменаРеквизитов = "ИдКомпании, Контрагент, ПериодСут, Тест";
	РевизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
	СостояниеУКлиента	 = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("PROCESSING;STARTED");
	ДвоичныеДанныеСтроки = ПолучитьДвоичныеДанныеИзСтроки(Формат(ТекущаяДата, "ДФ=ddMMyyyy"));
	
	ДатаНачала 	  = НачалоДня(ТекущаяДата);
	ДатаОкончания = КонецДня(ТекущаяДата) + 1;
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказКлиентаFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBS.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBSТовары.СостояниеУКлиента = &СостояниеУКлиента");
	Запрос.УстановитьПараметр("ДатаНачала",        ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", 	   КонецДня(ДатаОкончания) + 1);
	Запрос.УстановитьПараметр("Контрагент",    	   РевизитыМаркетПлейса.Контрагент);
	Запрос.УстановитьПараметр("СостояниеУКлиента", СостояниеУКлиента);
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Ихсанов Д. А. 18.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8924
	// Произведен рефакторинг забора данных по количеству новых заказов
	ПараметрыОбработки = ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод = "GET";
	ПараметрыОбработки.ПараметрыЗапроса = Новый Структура();
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("status", 	  "PROCESSING");
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("substatus",  "STARTED");
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("fromDate",   Формат(ДатаНачала, "ДФ=dd-MM-yyyy"));
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("toDate",     Формат(ДатаОкончания, "ДФ=dd-MM-yyyy"));
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("limit", 	  "100");
	ПараметрыОбработки.ПараметрыЗапроса.Вставить("page_token", "");
	
	КоличествоНовыхЗаказов = 0;
	ЗапросАктуален		   = Истина;
	Пока ЗапросАктуален Цикл
		ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
			МП_Яндекс_ВернутьСоединение(МаркетПлейс),
			МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс),
			СтрШаблон("/v2/campaigns/%1/orders.json", РевизитыМаркетПлейса.ИдКомпании),
			ПараметрыОбработки);
		
		Если ДанныеОтвета.Свойство("error")
			Или ДанныеОтвета.Свойство("errors")
			Или ДанныеОтвета.Свойство("code") Тогда
			Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При получении данных о заказах на стороне сервиса возникла ошибка!'", "ru");
			СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ОтправитьДанныеПоСтатусуДокумента");
			Если РевизитыМаркетПлейса.Тест Тогда
				ЗаписатьВЛог("МП_ЯндексМаркет", СообщениеОбОшибке, "Ошибка");
			КонецЕсли;
			
			ВызватьИсключение СообщениеОбОшибке;
		КонецЕсли;
		
		Для каждого ДанныеЗаказа из ДанныеОтвета.orders Цикл
			Если Не Выборка.НайтиСледующий(Новый Структура("НомерЗаказа", 
				ОписаниеТипаСтрока.ПривестиЗначение(ДанныеЗаказа.id))) Тогда
				КоличествоНовыхЗаказов = КоличествоНовыхЗаказов + 1;
			КонецЕсли;
			
			Выборка.Сбросить();
		КонецЦикла;
		
		ЗапросАктуален = ДанныеОтвета.paging.Свойство("nextPageToken");
		Если ЗапросАктуален Тогда
			ПараметрыОбработки.ПараметрыЗапроса.page_token = ДанныеОтвета.paging.nextPageToken;
		КонецЕсли;
	КонецЦикла;
	
	Возврат КоличествоНовыхЗаказов;
	
КонецФункции // МП_ЯндексМаркет_КонтрольКоличестваЗаказов()
