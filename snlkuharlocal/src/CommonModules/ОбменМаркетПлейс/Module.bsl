#Область HMAC

// HMACSHA256.
// 
// Параметры:
//  Ключ - Строка - Ключ
//  Данные - Строка - Данные
// 
// Возвращаемое значение:
//  ДвоичныеДанные, Число - HMACSHA256
Функция HMACSHA256(Знач Ключ, Знач Данные) Экспорт
	
	Возврат HMAC(Ключ, Данные, ХешФункция.SHA256, 64);
	
КонецФункции // HMACSHA256()

// Получить хеш строки.
// 
// Параметры:
//  Значение - Строка - Значение
// 
// Возвращаемое значение:
//  Строка - Получить хеш строки
Функция ПолучитьХешСтроки(Значение) Экспорт
	
	ДвоичныеДанные = Хеш(ПолучитьДвоичныеДанныеИзСтроки(Значение), ХешФункция.SHA256);
	
	Возврат нрег(ПолучитьHexСтрокуИзДвоичныхДанных(ДвоичныеДанные));
	
КонецФункции // ПолучитьХешСтроки()

#КонецОбласти

#Область S3

// Создать ссылку s3.
// 
// Параметры:
//  ДанныеАвторизации - Структура - Данные авторизации
//  Путь - Строка - Путь
//  Метод - Строка - Метод
//  ВремяЖизни - Строка - Время жизни
// 
// Возвращаемое значение:
//  Строка
Функция СоздатьСсылкуS3(ДанныеАвторизации, Путь, Метод="GET", ВремяЖизни = 300) Экспорт 
	
	// Стандартизация пути и обработка системных символов
	ПутьКРесурсу = СтрШаблон("/%1%2", ДанныеАвторизации.Корзина,
		СтрЗаменить(КодироватьСтроку(Путь, СпособКодированияСтроки.КодировкаURL, "UTF-8"), "%2F", "/"));
	
	// Форматируем время инициализации запроса
	Время = ТекущаяУниверсальнаяДата();
	ДатаСтрокой = Формат(Время ,"ДФ=yyyyMMddTHHmmssZ");
	ОтметкаДаты = Формат(Время, "ДФ=yyyyMMdd");
	
	// Заполним массив канонических заголовков
	МассивКаноническихЗаголовков = Новый Массив;
	МассивКаноническихЗаголовков.Добавить(СтрШаблон("host:%1", ДанныеАвторизации.Хост));
	
	// Заполним массив имен заголовков для подписи
	МассивПодписанныхЗаголовков = Новый Массив;
	МассивПодписанныхЗаголовков.Добавить("host");
	
	// Соединим канонические заголовки
	КаноническиеЗаголовки = СтрСоединить(СортироватьМассив(МассивКаноническихЗаголовков), Символы.ПС)+Символы.ПС;
	
	// Соединим заголовки для подписи запроса
	ПодписанныеЗаголовки = СтрСоединить(СортироватьМассив(МассивПодписанныхЗаголовков), ";");
	
	// Соберем контекст удостоверения запроса
	КонтекстУдостоверения = СтрШаблон("%1/%2/%3/aws4_request", ОтметкаДаты, ДанныеАвторизации.Регион,
		ДанныеАвторизации.Сервис);
	
	// Соберем поля параметров запроса
	Поля = Новый Массив;
	Поля.Добавить(СтрШаблон("X-Amz-Algorithm=%1", ДанныеАвторизации.Алгоритм));
	Поля.Добавить(СтрШаблон("X-Amz-Credential=%1", КодировкаURI(СтрШаблон("%1/%2", ДанныеАвторизации.КлючДоступа,
		КонтекстУдостоверения))));
	Поля.Добавить(СтрШаблон("X-Amz-Date=%1", ДатаСтрокой));
	Поля.Добавить(СтрШаблон("X-Amz-Expires=%1", ВремяЖизни));
	Поля.Добавить(СтрШаблон("X-Amz-SignedHeaders=%1", КодировкаURI(ПодписанныеЗаголовки))); 
	
	ПараметрыЗапроса = СтрСоединить(Поля, "&");
	
	// Соберем данные канонического запроса
	КаноническийЗапрос = СтрШаблон("%1
	|%2
	|%3
	|%4
	|%5
	|UNSIGNED-PAYLOAD", Метод, ПутьКРесурсу, ПараметрыЗапроса, КаноническиеЗаголовки, ПодписанныеЗаголовки);
	
	// Соберем цифровую подпись запроса
	СтрокаДляПодписи = СтрШаблон("%1
	|%2
	|%3
	|%4", ДанныеАвторизации.Алгоритм, ДатаСтрокой, КонтекстУдостоверения, ПолучитьХешСтроки(КаноническийЗапрос));
	
	// Получим сигнатуру подписи
	КлючДляПодписи = ПолучитьСигнатуру(ДанныеАвторизации.СекретныйКлюч, ОтметкаДаты, ДанныеАвторизации.Регион,
		ДанныеАвторизации.Сервис);
	
	Сигнатура = HMACSHA256(КлючДляПодписи, ПолучитьДвоичныеДанныеИзСтроки(СтрокаДляПодписи)); 
	
	// Добавим сигнатуру в заголовки
	Поля.Добавить(СтрШаблон("X-Amz-Signature=%1", Нрег(ПолучитьHexСтрокуИзДвоичныхДанных(Сигнатура))));
	
	// Вернем полный адрес запроса
	Возврат СтрШаблон("http://%1%2?%3", ДанныеАвторизации.Хост, ПутьКРесурсу, СтрСоединить(Поля, "&"));
	
КонецФункции // СоздатьСсылку()

#КонецОбласти

#Область API

// Размер данных на отправку по API.
// 
// Параметры:
//  ДанныеJSON - Строка - Данные JSON
// 
// Возвращаемое значение:
//  Строка - Размер данных на отправку по API
Функция РазмерДанныхНаОтправкуПоAPI(ДанныеJSON) Экспорт
	
	ИмяФайлаДанныеJSON = ПолучитьИмяВременногоФайла();
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(ДанныеJSON);
	ТекстовыйДокумент.Записать(ИмяФайлаДанныеJSON, КодировкаТекста.ANSI);
	
	ФайлДанныеJSON = Новый Файл(ИмяФайлаДанныеJSON);
	РазмерФайлаДанныеJSONДляОтправки = XMLСтрока(ФайлДанныеJSON.Размер());
	
	Попытка
		УдалитьФайлы(ИмяФайлаДанныеJSON);
	Исключение
		ЗаписатьВЛог("ОшибкаУдаленияВременногоФайла", СтрШаблон("Не удалось удалить файл %1", ИмяФайлаДанныеJSON),
			"Ошибка");
	КонецПопытки;
	
	Возврат РазмерФайлаДанныеJSONДляОтправки;
	
Конецфункции // РазмерДанныхНаОтправкуПоAPI()
