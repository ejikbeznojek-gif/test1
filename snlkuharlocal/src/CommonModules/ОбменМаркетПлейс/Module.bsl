//Тимофеев Ю.А. 25.04.2024
Процедура МП_Вайлбериз_ДозагрузитьЗагрузитьШКНеЗависимая(МаркПл) Экспорт
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Начало выполнения. Задача: Заказы без ШК в НОВУЮ поставку !","Информация");
	КонецЕсли;	
	ИмяПост="Поставка доп "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование КАК ДокОснование,
	|	СУММА(1) КАК Количество,
	|	ЗаказКлиентаFBSТовары.Ссылка.Номер КАК Номер
	|ПОМЕСТИТЬ ПОДИТОГ
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Проведен
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.ШтрихКод = &ШтрихКод
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &Дата И &ДатаМеньше
	// Ихсанов Д. А. Начало 13.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7833
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен
	// Ихсанов Д. А. Конец 13.11.2025
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.Ссылка,
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование,
	|	ЗаказКлиентаFBSТовары.Ссылка.Номер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПОДИТОГ.Ссылка КАК Док
	|ИЗ
	|	ПОДИТОГ КАК ПОДИТОГ
	|ГДЕ
	|	ПОДИТОГ.Количество >= 1
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПОДИТОГ.Количество УБЫВ";
	//Параметры запроса
	
	Запрос.УстановитьПараметр("Дата",        ТекущаяДата()-86400);
	Запрос.УстановитьПараметр("ДатаМеньше",  ТекущаяДата()); //все что раньше 20 минут время на выполнение рег.задания
	Запрос.УстановитьПараметр("Контрагент",  МаркПл.Контрагент);
	Запрос.УстановитьПараметр("ШтрихКод","");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Результат = РезультатЗапроса.Выбрать();
		
		ИДПОСТАВКИ= МП_Вайлбериз_СоздатьПоставку(МаркПл,ИмяПост);
		
		Пока Результат.Следующий() Цикл 
			
			МП_Вайлбериз_ПривязатьКПоставке(Результат.Док,МаркПл,СокрЛП(ИДПОСТАВКИ));
			МП_Вайлбериз_ЗапросПоСтикерам(Результат.Док,МаркПл); 		
			
		КонецЦикла;  	
		
		Если МаркПл.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Конец выполнения. Задача: Заказы без ШК в НОВУЮ поставку !","Информация");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
//Тимофеев Ю.А. 25.04.2024

Функция ПрефМаркет(МаркПл) Экспорт
	
	ПрефМаркет="";
	
	Если     МаркПл.Код ="00001" Тогда
		ПрефМаркет="_ЕЕЭ_";
	ИначеЕсли МаркПл.Код="00009" Тогда
		ПрефМаркет="_БТК_";
	ИначеЕсли МаркПл.Код="00002" Тогда
		ПрефМаркет="_OZON_";
	ИначеЕсли МаркПл.Код="00004" Тогда
		ПрефМаркет="_YND_";
	ИначеЕсли МаркПл.Код="00014" Тогда
		ПрефМаркет="_MAG_";	
	ИначеЕсли МаркПл.Код="00014" Тогда
		ПрефМаркет="_MP_SYTLE_";	
	КонецЕсли;
	
	Возврат ПрефМаркет;
	
КонецФункции

Процедура МП_Вайлберриз_ПолучитьОбработатьЗаказыССайта(Стат1="0", Тест=Ложь, Тест1=Ложь, СтруктураПараметров=Неопределено) Экспорт 
	//на замену ПолучитьОбработатьЗаказыССайтаВБ1(Стат1="0",Тест=Ложь,Тест1=Ложь)
	
	КодМаркетплейса=СтруктураПараметров.КодМаркетплейса;
	
	МаркПл =Справочники.ИнетМагазины.НайтиПоКоду(КодМаркетплейса);
	
	//Проверим отмены ПЕРВОГО ЧАСА
	МП_Вайлдберриз_ПроверкаОтменНаПортале(МаркПл);
	//Проверим отмены ПЕРВОГО ЧАСА
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Начало выполнения. Задача: Загрузка заказов ВБ. !","Информация"); 	
	КонецЕсли;
	
	ДатаОкончания = НачалоДня(ТекущаяДатаСеанса());
	
	//Тимофеев Ю.А. 25.04.2024 перенос в конец процедуры с заменой вызываемой процедуры изменен алгоритм проверки
	
	Если Час(ТекущаяДатаСеанса())>17 Тогда
		ПредДата=ТекущаяДатаСеанса();
	Иначе
		ПредДата=НачалоДня(ТекущаяДатаСеанса())-100;
	КонецЕсли;	
	
	//Тимофеев Ю.А. 20.08.24
	//Отложенная отгрузка проверка поставок
	Если Час(ТекущаяДата())=10 Тогда
		МП_Вайлбериз_На_Повторную_Отгрузку(МаркПл);
	КонецЕсли;
	//Тимофеев Ю.А. 20.08.24
	
	ДатаНачала=НачалоДня(ПредДата);
	
	АдресТ      = МаркПл.АдресРесурса;
	
	ПериодНазад = МаркПл.ПериодСут;
	
	Если ЗначениеЗаполнено(ПериодНазад) Тогда
		ДатаНачала=НачалоДня(ТекущаяДатаСеанса()-(ПериодНазад*3600*24));
	КонецЕсли;	
	
	Если СтруктураПараметров<>Неопределено Тогда
		
		
		Если СтруктураПараметров.Свойство("МаркировкаВсе") Тогда			
			МаркировкаВсе = СтруктураПараметров.МаркировкаВсе; 
		КонецЕсли;
		
		
		
		Если СтруктураПараметров.Свойство("ДваСклада") Тогда			
			ДваСклада = СтруктураПараметров.ДваСклада; 
		КонецЕсли;
		
		Если СтруктураПараметров.Свойство("КонтрольЗаписи") Тогда			
			КонтрольЗаписи = СтруктураПараметров.КонтрольЗаписи; 
		КонецЕсли;
		
		
		Если СтруктураПараметров.Свойство("ТабДемо") Тогда
			ТЗЗак      = СтруктураПараметров.ТабДемо;
			
			Если ТЗЗак = Неопределено или ТЗЗак.Количество()=0  Тогда
				Возврат;
			КонецЕсли;  		
			
		Иначе           			
			//загрузит ШК для заказов которые без ПОСТАВКИ Тимофеев Ю.А.
			МП_Вайлбериз_ДозагрузитьЗагрузитьШКНеЗависимая(МаркПл);
			//загрузит ШК для заказов которые без ПОСТАВКИ Тимофеев Ю.А.
			
			ТЗЗак      = МП_Вайлдберриз_ПолучитьЗаказыССайта(МаркПл,ДатаНачала,СтруктураПараметров);
			
			
			
			///
			///
		КонецЕсли;
		
		
		//////////////////////////////////////////////////////////////////
		Если КонтрольЗаписи Тогда 	
			//Тимофеев Ю.А. 28.02.2025
			//запишем блок заказов с портала
			
			ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
			ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
			ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
			
			ИмяФайла=ПутьЛог+"Блок_Заказов_"+ПрефиксМаркета+ВремяЗаписи+".txt";
			
			ЗначениеВФайл(ИмяФайла,ТЗЗак);
			//Тимофеев Ю.А. 28.02.2025  
		КонецЕсли;
		
		/////////////////////////////////////////////////////////////////
		
		ТЗЗакНом   =МП_Вайлбериз_ОбработатьПолученныеЗаказы(ТЗЗак,МаркПл);
		Сооб = "";	
		Для Каждого ТекСтр Из ТЗЗакНом Цикл
			
			Если НЕ ЗначениеЗаполнено(ТекСтр.Матрица) Тогда
				//крайний шанс поиск не найденной матрицы - бывают единичные случаи				
				
				//Тимофеев Ю.А. 07.11.2024
				Если Не ЗначениеЗаполнено(ТекСтр.Номенклатура) Тогда
					
					Если ЗначениеЗаполнено(ТекСтр.ШК1) Тогда
						Запрос = Новый Запрос;
						Запрос.Текст = "ВЫБРАТЬ
						|	ШтрихКоды.Владелец КАК Товар,
						|	ШтрихКоды.Наименование КАК Наименование
						|ИЗ
						|	Справочник.ШтрихКоды КАК ШтрихКоды
						|ГДЕ
						|	ШтрихКоды.Наименование = &Наименование";
						//Параметры запроса
						Запрос.УстановитьПараметр("Наименование",ТекСтр.ШК1);// Строка
						Результат = Запрос.Выполнить().Выбрать();
						
						Если Результат.Следующий() тогда
							ТекСтр.Номенклатура=Результат.Товар;  				
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				//Тимофеев Ю.А. 07.11.2024
				
				ПоискМатрицы = МП_Вайлбериз_ПолучитьМатрицуПоНоменклатуре(МаркПл,ТекСтр.Номенклатура);
				
				Если ПоискМатрицы=Неопределено Тогда				 				
					Сооб=Сооб+"Не найдено в матрице для заказа "+Строка(ТекСтр.ИДЗаказа)+" товар "+Строка(ТекСтр.ШК)+Символы.ПС; 			
				Иначе
					ТекСтр.Матрица = ПоискМатрицы;  				
					Если МаркПл.Тест Тогда
						ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Поиск матрицы. Задача: Подстановка матрицы :"+Строка(ТекСтр.Номенклатура)+" !","Информация");
					КонецЕсли;				
				КонецЕсли;				
				
			КонецЕсли;	
			
		КонецЦикла;
		
		Если Сооб<>"" Тогда
			Сообщить(Сооб);
		КонецЕсли;   	
		
		Если НЕ ПустаяСтрока(Сооб) И НЕ Тест Тогда
			СписокПолучателей=новый СписокЗначений;
			
			Для Каждого ТекСтр Из МаркПл.ПолучателиУведомлений Цикл
				Мыло=ТекСтр.Сотрудник.ЕМэйл;
				Если ЗначениеЗаполнено(Мыло) И ТекСтр.СкладИОфис Тогда
					СписокПолучателей.Добавить(Мыло);
				КонецЕсли;	
			КонецЦикла;
			
			Если СписокПолучателей.Количество() Тогда
				ТекстОповещения="Здравствуйте!"+Символы.ПС+"!!!Ошибки при загрузке заказов Вайлдберриз"+ПрефиксМаркета+":"+Символы.ПС+Сооб;
				ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,НСтр("ru='Загрузка заказов Вайлдберриз"+ПрефиксМаркета+" ошибки!!! '")+Формат(ТекущаяДатаСеанса(),"ДФ='dd.MM.yyyy чч:мм'"),ТекстОповещения);
			КонецЕсли;	
			
		КонецЕсли;	
		
		н=ТЗЗакНом.Количество()-1;
		
		Пока н>=0 Цикл
			ТСтр=ТЗЗакНом.Получить(н);
			Если НЕ ЗначениеЗаполнено(ТСтр.Матрица) ИЛИ НЕ ЗначениеЗаполнено(ТСтр.Номенклатура) ИЛИ ЗначениеЗаполнено(ТСтр.РНК) 
				ИЛИ ЗначениеЗаполнено(ТСтр.ЗаказКлиентаFBS) ИЛИ ЗначениеЗаполнено(ТСтр.ЗаказЗагр) Тогда
				ТЗЗакНом.Удалить(н);
			КонецЕсли;	
			н=н-1;
		КонецЦикла;   
		
	КонецЕсли;
	
	
	
	
	Если НЕ МаркировкаВсе Тогда
		
		ТЗЗакНом = МаркаИлиНет(МаркПл,ТЗЗакНом); 	 
		
		//Тимофеев Ю.А. Конец    06-02-2025
		
		
		ТЗЗакНомОбщаяДляРазделения = ТЗЗакНом.Скопировать();
		
		ТЗЗакНом.Очистить();
		
		ТЗЗакНомСМаркировкой      =  ТЗЗакНом.Скопировать();
		
		//Статус КАРТОЧКА СОЗДНА
		
		// НужнаМаркировка           =  Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована;   //Тимофеев Ю.А.
		// СтрТаб.Номенклатура.СтатусКарточкиВЧЗ=НужнаМаркировка;
		//Ждем определение правильности маркированного товара
		
		Для каждого стрТаб из ТЗЗакНомОбщаяДляРазделения Цикл
			
			Если стрТаб.НужнаМаркировка=1 Тогда
				НовЗапМарка=ТЗЗакНомСМаркировкой.Добавить();
				ЗаполнитьЗначенияСвойств(НовЗапМарка,СтрТаб);
			Иначе
				НовЗап=ТЗЗакНом.Добавить();
				ЗаполнитьЗначенияСвойств(НовЗап,СтрТаб);
			КонецЕсли;  
			
		КонецЦикла; 
		
	Иначе
		//будем считать что все маркированное
		ТЗЗакНомСМаркировкой      =  ТЗЗакНом.Скопировать();
		ТЗЗакНом.Очистить();
	КонецЕсли;
	
	Если ТЗЗакНом.Количество()>0 Тогда
		
		Если Не ДваСклада  Тогда
			МП_Вайлбериз_ПостОбработкаЗаказа(МаркПл,ТЗЗакНом,Стат1,Тест,Ложь,СтруктураПараметров);
		Иначе  		
			МП_Вайлберриз_ОбраткаПолученныхЗаказов(МаркПл,ТЗЗакНом,Стат1,Тест,СтруктураПараметров); 
		КонецЕсли;
		
	КонецЕсли;     
	
	КолвоТоваровСМаркировкой = ТЗЗакНомСМаркировкой.Количество();
	
	Если ТЗЗакНомСМаркировкой.Количество()>0 Тогда
		//все заказы с маркировка и накладные в одном месте
		//и запись в регистра
		Если МаркПл.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз"+ПрефиксМаркета,"Найдены заказы с маркировкой ! "+Строка(КолвоТоваровСМаркировкой),"Информация");
		КонецЕсли;
		
		Если Не ДваСклада  Тогда
