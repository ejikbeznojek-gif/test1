Функция ФормСписПолуч(МкПл,УведСклад=Ложь) Экспорт
	СписокПолучат=новый СписокЗначений;
	Для Каждого ТекСтр Из МкПл.ПолучателиУведомлений Цикл
		Мыло=СокрЛП(ТекСтр.Сотрудник.ЕМэйл);
		Если ЗначениеЗаполнено(Мыло) И (ТекСтр.СкладИОфис ИЛИ УведСклад) Тогда
			СписокПолучат.Добавить(Мыло);
		КонецЕсли;	
	КонецЦикла;	
	Возврат СписокПолучат;
КонецФункции	

Функция ПолучитьДатуИзСтр(СтрДата) Экспорт
	Рез=неопределено;
	
	Попытка
		СтрДата=СокрЛП(СтрДата);
		СтрРез="";
		РаздТ=Найти(СтрДата,".");
		РаздТр=Найти(СтрДата,"-");
		РаздЗ=Найти(СтрДата,",");
		РаздСП=Найти(СтрДата,"/");
		РаздСО=Найти(СтрДата,"\");
		РаздДТ=Найти(СтрДата,":");
		Если (РаздТ>0) И (РаздТр>0) Тогда
			Если (РаздТ>РаздТр) Тогда
				РаздТ=0;
			КонецЕсли;	
		КонецЕсли;	
		
		Если РаздТ>0 ИЛИ РаздЗ>0  ИЛИ РаздСП>0 ИЛИ РаздСО>0 Тогда
			//Если РаздСО>0 Тогда
			//ИначеЕсли РаздСП>0 Тогда
			//ИначеЕсли РаздСЗ>0 Тогда
			//Иначе
			//предположим германский с разными разделителями
			Если Сред(СтрДата,3,1)="." Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						СтрЧМ=СокрЛП(Сред(СтрДата,11));
						СтрЧМ=СтрЗаменить(СтрЧМ,":","");
						СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ)=5 Тогда
							СтрЧМ="0"+СтрЧМ;
						КонецЕсли;	
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ=Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ="000000") Тогда
							СтрРез=СтрРез+СтрЧМ;
						КонецЕсли;
						Рез=Дата(СтрРез);
					Иначе	
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						Рез=Дата(СтрРез);
					КонецЕсли;	
				Исключение
				КонецПопытки;	
			КонецЕсли;	
			//КонецЕсли;	
		ИначеЕсли РаздТр>0 Тогда
			
			Если Сред(СтрДата,3,1)="-" Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						СтрЧМ=СокрЛП(Сред(СтрДата,11));
						
						СтрЧМ=СтрЗаменить(СтрЧМ,":","");
						СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ)=5 Тогда
							СтрЧМ="0"+СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ=Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ="000000") Тогда
							СтрРез=СтрРез+СтрЧМ;
						КонецЕсли;
						Рез=Дата(СтрРез);
					Иначе	
						СтрРез=Сред(СтрДата,7,4)+Сред(СтрДата,4,2)+Лев(СтрДата,2);
						Рез=Дата(СтрРез);
					КонецЕсли;	
				Исключение
				КонецПопытки;	
			Иначе
				
				СтрЧМ=СокрЛП(Сред(СтрДата,11));
				СтрРез=СтрЗаменить(СокрЛП(Лев(СтрДата,10)),"-","");
				СтрЧМ=СтрЗаменить(СтрЧМ,":","");
				СтрЧМ=СтрЗаменить(СтрЧМ,"T","");
				Если СтрДлина(СтрЧМ)=5 Тогда
					СтрЧМ="0"+СтрЧМ;
				КонецЕсли;	
				Если СтрДлина(СтрЧМ)>6 Тогда
					СтрЧМ=Лев(СтрЧМ,6);
				КонецЕсли;
				Если НЕ(СтрЧМ="000000") Тогда
					СтрРез=СтрРез+СтрЧМ;
				КонецЕсли;
				Рез=Дата(СтрРез);
			КонецЕсли;
			
			
			
		Иначе
			//анси формат
			Если СтрДлина(СтрДата)>=8 Тогда
				Рез=Дата(Лев(СтрДата,8));
			КонецЕсли;	
		КонецЕсли;	
	Исключение
	КонецПопытки;
	Возврат Рез;
КонецФункции

// Ихсанов Д. А. Начало 14.01.2026
// Процедура - Заполнение табличной части документа по файлу структурной разметки
//
// Параметры:
//  ПолноеИмяФайла		 - Строка		 - Путь к файлу и его имя
//  Объект				 - Любой объект	 - Любой объект ТЧ которого необходимо заполнить
//  ИмяТабличнойЧасти	 - Строка		 - Наименование ТЧ в объекте
//
Процедура ЗаполнениеТабличнойЧастиДокументаПоФайлуСтруктурнойРазметки(ПолноеИмяФайла, Объект, ИмяТабличнойЧасти) Экспорт
	
	// Инициализированные переменные
	МассивПримитивныхТипов = Новый Массив;
	МассивПримитивныхТипов.Добавить(Тип("Число"));
	МассивПримитивныхТипов.Добавить(Тип("Строка"));
	МассивПримитивныхТипов.Добавить(Тип("Булево"));
	МассивПримитивныхТипов.Добавить(Тип("Дата"));
	
	// Вывод данных из документа в читаемый программой формат
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.Прочитать(ПолноеИмяФайла, СпособЧтенияЗначенийТабличногоДокумента.Текст);
	
	ПостроительЗапроса = Новый ПостроительЗапроса;
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТабличныйДокумент.Область());
	ПостроительЗапроса.ЗаполнитьНастройки();
	ПостроительЗапроса.Выполнить();
	
	ТаблицаЗначений_Предварительная = ПостроительЗапроса.Результат.Выгрузить();
	КолонкиТабличнойЧастиДокумента = Объект[ИмяТабличнойЧасти].Выгрузить().Колонки;
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	
	// Определение типа каждого отдельного поля полученной таблицы
	КартаСсылочныхИменСправочник = Новый Соответствие;
	КартаСсылочныхИменПеречисление = Новый Соответствие;
	Для каждого КолонкаПредварительнойТаблицы из ТаблицаЗначений_Предварительная.Колонки Цикл
		КолонкаТабличнойЧасти = КолонкиТабличнойЧастиДокумента.Найти(КолонкаПредварительнойТаблицы.Имя);
		Если КолонкаТабличнойЧасти = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПроверяемыйТип = КолонкаТабличнойЧасти.ТипЗначения.Типы()[0];
		ПолноеИмяМетаданныхТипа = "";
		ТекстыПолногоИмениМетаданныхТипа = Новый Массив;
		Если МассивПримитивныхТипов.Найти(ПроверяемыйТип) = Неопределено
			И (КартаСсылочныхИменСправочник[КолонкаПредварительнойТаблицы.Имя] = Неопределено
				Или КартаСсылочныхИменПеречисление[КолонкаПредварительнойТаблицы.Имя] = Неопределено )Тогда
			ПолноеИмяМетаданныхТипа = Метаданные.НайтиПоТипу(ПроверяемыйТип).ПолноеИмя();
			ТекстыПолногоИмениМетаданныхТипа = СтрРазделить(ПолноеИмяМетаданныхТипа, ".");
		КонецЕсли;
		
		Если ТекстыПолногоИмениМетаданныхТипа.Количество() > 0 И ТекстыПолногоИмениМетаданныхТипа[0] = "Справочник" Тогда
			КартаСсылочныхИменСправочник.Вставить(КолонкаПредварительнойТаблицы.Имя, ПолноеИмяМетаданныхТипа);
		ИначеЕсли ТекстыПолногоИмениМетаданныхТипа.Количество() > 0 И ТекстыПолногоИмениМетаданныхТипа[0] = "Перечисление" Тогда
			КартаСсылочныхИменПеречисление.Вставить(КолонкаПредварительнойТаблицы.Имя, ПолноеИмяМетаданныхТипа);
		КонецЕсли;
		
		ТаблицаЗначений.Колонки.Добавить(КолонкаПредварительнойТаблицы.Имя, КолонкаТабличнойЧасти.ТипЗначения);
	КонецЦикла;
	
	// Сбор данных ссылочного типа в одну коллекцию значений
	Запрос = Новый Запрос;
	
	МассивТекстовЗапроса = Новый Массив; Индекс = 0;
	Для каждого ПолноеИмяСсылочногоИмени из КартаСсылочныхИменСправочник Цикл
		МассивТекстовЗапроса.Добавить(СтрШаблон("ВЫБРАТЬ Т.Ссылка, Т.Наименование, ""%1"" КАК ТипДанных
		|ИЗ
		|	%2 КАК Т
		|ГДЕ
		|	Т.Наименование В (&Наименование%3)", ПолноеИмяСсылочногоИмени.Ключ, ПолноеИмяСсылочногоИмени.Значение, Индекс));
		Запрос.УстановитьПараметр(СтрШаблон("Наименование%1", Индекс),
			ТаблицаЗначений_Предварительная.ВыгрузитьКолонку(ПолноеИмяСсылочногоИмени.Ключ));
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
	Для каждого ПолноеИмяСсылочногоИмени из КартаСсылочныхИменПеречисление Цикл
		МассивТекстовЗапроса.Добавить(СтрШаблон("ВЫБРАТЬ Т.Ссылка, ПРЕДСТАВЛЕНИЕССЫЛКИ(Т.Ссылка), ""%1""
		|ИЗ
		|	%2 КАК Т", ПолноеИмяСсылочногоИмени.Ключ, ПолноеИмяСсылочногоИмени.Значение));
	КонецЦикла;
	
	Запрос.Текст = СтрСоединить(МассивТекстовЗапроса, " ОБЪЕДИНИТЬ ВСЕ ");
	
	Выборка = Запрос.Выполнить().Выбрать();
	ХэшКартаСсылокИПредставлений = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		Если ХэшКартаСсылокИПредставлений[Выборка.Наименование] = Неопределено Тогда
			ХэшКартаСсылокИПредставлений.Вставить(Выборка.Наименование, Выборка.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	// Заполнение итоговой таблоцы даннми из файла с приведенными типами
	Для каждого СтрокаПредопределеннойТаблицы из ТаблицаЗначений_Предварительная Цикл
		НоваяСтрока = ТаблицаЗначений.Добавить();
		
		Для каждого КолонкаТаблицыЗначений из ТаблицаЗначений.Колонки Цикл
			ОписаниеТиповКолонки = КолонкаТаблицыЗначений.ТипЗначения;
			
			БазовоеЗначение = СтрокаПредопределеннойТаблицы[КолонкаТаблицыЗначений.Имя];
			
			Если ОписаниеТиповКолонки.Типы()[0] = Тип("Дата") И ЗначениеЗаполнено(БазовоеЗначение) Тогда
				Значение = Дата(СтрРазделить(БазовоеЗначение, ".")[2], СтрРазделить(БазовоеЗначение, ".")[1], СтрРазделить(БазовоеЗначение, ".")[0]);
			Иначе
				Значение = ОписаниеТиповКолонки.ПривестиЗначение(БазовоеЗначение);
			КонецЕсли;
			
			Если МассивПримитивныхТипов.Найти(ТипЗнч(Значение)) <> Неопределено Тогда
				НоваяСтрока[КолонкаТаблицыЗначений.Имя] = Значение;
				
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока[КолонкаТаблицыЗначений.Имя] = ХэшКартаСсылокИПредставлений[БазовоеЗначение];
		КонецЦикла;
	КонецЦикла;
	
	Объект[ИмяТабличнойЧасти].Загрузить(ТаблицаЗначений);
	
КонецПроцедуры // ЗаполнениеТабличнойЧастиДокументаПоФайлуСтруктурнойРазметки()

#КонецОбласти


