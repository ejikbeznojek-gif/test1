				СтрокаТЧ.Номенклатура	= ?(ЗначениеЗаполнено(СтрокаКомплекта.Номенклатура.НоменклатураЗамены),СтрокаКомплекта.Номенклатура.НоменклатураЗамены,СтрокаКомплекта.Номенклатура);
