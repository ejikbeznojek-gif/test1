			для каждого стрПост из ТолькоПоставки Цикл
				Сооб=Сооб+СтрПост.supplyID+Символы.ПС;
			КонецЦикла;		
			
			СписокПолучателей=новый СписокЗначений;
			
			//СписокПолучателей.Добавить("timofeev@collant.ru");   						
