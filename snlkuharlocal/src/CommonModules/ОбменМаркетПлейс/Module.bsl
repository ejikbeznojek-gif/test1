// РЕФАКТОРИНГ - Функционал новый, но он основан на ранее заложенной кодовой базе
Функция МП_ЯндексМаркет_РазбитьЗаказНаЧасти(МаркетПлейс, ДанныеПоТовару, ИдентификаторЗаказа) Экспорт
	
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("boxes", Новый Массив);
	
	Для каждого СтрокаТовара из ДанныеПоТовару Цикл
		Если СтрокаТовара.КолвоЗак = 0 Тогда
			Продолжить
		КонецЕсли;
		
		СтруктураТовары = Новый Структура;
		СтруктураТовары.Вставить("items", Новый Массив);
		
		СтруктураЭкземпляра = Новый Структура;
		СтруктураЭкземпляра.Вставить("id",		  СтрокаТовара.ИДТовара);
		СтруктураЭкземпляра.Вставить("fullCount", СтрокаТовара.КолвоЗак);
		
		СтруктураТовары.items.Добавить(СтруктураЭкземпляра);
		ДанныеДляJSON.boxes.Добавить(СтруктураТовары);
	КонецЦикла;
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод		 = "PUT";
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = СформироватьСтрокуJSON(ДанныеДляJSON,
		ПараметрыОбработки);
	ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
		МП_Яндекс_ВернутьСоединение(МаркетПлейс),
		МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс),
		СтрШаблон("/v2/campaigns/%1/orders/%2/boxes.json", МаркетПлейс.ИДКомпании, ИдентификаторЗаказа),
		ПараметрыОбработки);
	
	Если ДанныеОтвета.Свойство("error")
		Или ДанныеОтвета.Свойство("errors") Тогда
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("ЗаписьЛога_ОШИБКА", СтрШаблон("%1. Возникла ошибка при работе с сервисом! %2", "МП_ЯндексМаркет", 
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "ИСКЛЮЧЕНИЕ_ОШИБКА");
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДанныеОтвета;
	
КонецФункции // ЯндексМаркет_РазбитьЗаказНаЧасти()
