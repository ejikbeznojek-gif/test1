// Процедура - Перезаполнить РНКна основании заказ
// Перенесена в рамках задачи https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9008
// 
// Параметры: ТекущийЗаказ - ДокументСсылка.ЗаказКлиентаFBS		 - Ссылка на заказ клиента, по данным которого будет заполнена РНК
// ТекущаяРНК	 - ДокументОбъект.РасходнаяНакладная	 - Документ, который будет перезаполнен на основании Заказа клиента
//  ТекущийЗаказКлиентаFBS - ДокументОбъект.ЗаказКлиентаFBS - Текущий заказ клиента FBS
//  ТекущаяРасходнаяНакладная - Неопределено, ДокументОбъект.РасходнаяНакладная - Текущая расходная накладная
//  Лог - Булево - Флаг необходимости ведения логов по изменениям
Процедура ПерезаполнитьРНКнаОснованииЗаказа(ТекущийЗаказКлиентаFBS, ТекущаяРасходнаяНакладная = Неопределено, Лог = Ложь) Экспорт
	
	// Ихсанов Д. А. Начало 03.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9008
	Если ТекущаяРасходнаяНакладная = Неопределено Тогда

		// Кельманов А.В. - Исправление ошибки - 2026.06.30 {
		//ДокументСсылкаРасходнаяНакладная = ЗначенияРеквизитовОбъекта(ТекущийЗаказКлиентаFBS, "ДокументОснование");
		ДокументСсылкаРасходнаяНакладная = ПолучитьРеквизитШапки(ТекущийЗаказКлиентаFBS, "ДокОснование", "Документ");
		// Кельманов А.В. - Исправление ошибки - 2026.06.30 }
		
		ТекущаяРасходнаяНакладная = ДокументСсылкаРасходнаяНакладная.ПолучитьОбъект();
		
	КонецЕсли;
	
	КоличествоВРНКСтарое = ТекущаяРасходнаяНакладная.Товары.Итог("Количество");
	
	Запрос = Новый Запрос();
	#Область ТекстЗапросаДанныеЗаказаКлиента
	Запрос.Текст = "ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Ссылка КАК Ссылка,
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	РасходнаяНакладнаяТовары.Количество КАК Количество,
	|	РасходнаяНакладнаяТовары.Заявка КАК Заявка,
	|	РасходнаяНакладнаяТовары.Цена КАК Цена
	|ПОМЕСТИТЬ вт_РасходнаяНакладнаяТовары
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка = &РасходнаяНакладная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказКлиентаFBSТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ вт_ЗаказКлиентаFBSТовары
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО ЗаказКлиентаFBSТовары.Ссылка = ЗаказКлиентаFBS.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.ДокОснование = &РасходнаяНакладная
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	вт_ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	вт_ЗаказКлиентаFBSТовары.Количество КАК ПодтвержденнаяЗаявка,
	|	вт_РасходнаяНакладнаяТовары.Заявка КАК Заявка,
	|	вт_РасходнаяНакладнаяТовары.Цена КАК Цена
	|ИЗ
	|	вт_РасходнаяНакладнаяТовары КАК вт_РасходнаяНакладнаяТовары
	|		ПОЛНОЕ СОЕДИНЕНИЕ вт_ЗаказКлиентаFBSТовары КАК вт_ЗаказКлиентаFBSТовары
	|		ПО вт_РасходнаяНакладнаяТовары.Номенклатура = вт_ЗаказКлиентаFBSТовары.Номенклатура";
	#КонецОбласти
	Запрос.УстановитьПараметр("РасходнаяНакладная", ТекущаяРасходнаяНакладная.Ссылка);
	
	ТекущаяРасходнаяНакладная.Товары.Очистить();
	ВыборкаДанныеЗаполненияРНК = Запрос.Выполнить().Выбрать();
	Пока ВыборкаДанныеЗаполненияРНК.Следующий() Цикл
		НоваяСтрока = ТекущаяРасходнаяНакладная.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДанныеЗаполненияРНК);
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ТекущаяРасходнаяНакладная,, ВыборкаДанныеЗаполненияРНК.Цена);
		РассчитатьСуммуТабЧасти(НоваяСтрока, ТекущаяРасходнаяНакладная);
	КонецЦикла;
	
	Если ТекущаяРасходнаяНакладная.ОтгрузкаКомплектов Тогда
		ЗаполнитьКомплектующие(ТекущаяРасходнаяНакладная);
	КонецЕсли;
	
	Попытка
		ТекущаяРасходнаяНакладная.Записать();
		
		ТекстСообщения = СтрШаблон("Изменения по документу %1: Было - %2; Заказано - %3; Стало - %4.",
			ТекущаяРасходнаяНакладная.Ссылка, КоличествоВРНКСтарое, ТекущийЗаказКлиентаFBS.Товары.Количество(),
			ТекущаяРасходнаяНакладная.Товары.Итог("Количество"));
		
		Если Лог Тогда
			ЗаписатьВЛог("МП_ФБС", ТекстСообщения,, Истина);
		Иначе
			СообщитьИзМодуля(ТекстСообщения);
		КонецЕсли;
	Исключение
		ВызватьИсключение;
	КонецПопытки;
	
	Если Не ОбщегоНазначения_ПИ.ЭтоУзел_Склад() Тогда
		Возврат;
	КонецЕсли;
	
	#Область ТекстЗапросаЗаполнениеЗаданиеНабора
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК Ссылка,
	|	ЗаданиеНабора.Накладная КАК РасходнаяНакладная,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ вт_ДанныеЗаданийНаборов
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ПО ЗаданиеНабора.Ссылка = ЗаданиеНабораТовары.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.Накладная = &РасходнаяНакладная
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	НоменклатураМодель.ВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ вт_ДанныеПоНоменклатуре
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураМодель
	|		ПО Номенклатура.Родитель = НоменклатураМодель.Ссылка
	|ГДЕ
	|	Номенклатура.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеЗаданийНаборов.Номенклатура
	|			ИЗ
	|				вт_ДанныеЗаданийНаборов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество,
	|	1 КАК Коэффициент,
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА вт_ДанныеПоНоменклатуре.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|			ТОГДА РасходнаяНакладная.ТребуетсяМаркировка
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ТребуетсяМаркировка
	|ПОМЕСТИТЬ вт_ДанныеПоТоварамРасходнойНакладной
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_ДанныеПоНоменклатуре КАК вт_ДанныеПоНоменклатуре
	|		ПО РасходнаяНакладнаяТовары.Номенклатура = вт_ДанныеПоНоменклатуре.Ссылка
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка = &РасходнаяНакладная
	|	И НЕ РасходнаяНакладная.ОтгрузкаКомплектов
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладная.Ссылка,
	|	ВЫБОР
	|		КОГДА вт_ДанныеПоНоменклатуре.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|			ТОГДА РасходнаяНакладная.ТребуетсяМаркировка
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	РасходнаяНакладнаяТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка,
	|	СУММА(РасходнаяНакладнаяКомплектующие.Количество),
	|	1,
	|	РасходнаяНакладнаяКомплектующие.Номенклатура,
	|	ВЫБОР
	|		КОГДА вт_ДанныеПоНоменклатуре.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|			ТОГДА РасходнаяНакладная.ТребуетсяМаркировка
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяКомплектующие.Ссылка = РасходнаяНакладная.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_ДанныеПоНоменклатуре КАК вт_ДанныеПоНоменклатуре
	|		ПО РасходнаяНакладнаяКомплектующие.Номенклатура = вт_ДанныеПоНоменклатуре.Ссылка
	|ГДЕ
	|	РасходнаяНакладнаяКомплектующие.Ссылка = &РасходнаяНакладная
	|	И РасходнаяНакладная.ОтгрузкаКомплектов
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА вт_ДанныеПоНоменклатуре.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|			ТОГДА РасходнаяНакладная.ТребуетсяМаркировка
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	РасходнаяНакладная.Ссылка,
	|	РасходнаяНакладнаяКомплектующие.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеЗаданийНаборов.Ссылка КАК ЗаданиеНабора,
	|	ЕСТЬNULL(вт_ДанныеПоТоварамРасходнойНакладной.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(вт_ДанныеПоТоварамРасходнойНакладной.Коэффициент, 0) КАК Коэффициент,
	|	вт_ДанныеЗаданийНаборов.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(вт_ДанныеПоТоварамРасходнойНакладной.ТребуетсяМаркировка, вт_ДанныеЗаданийНаборов.РасходнаяНакладная.ТребуетсяМаркировка
	|			И вт_ДанныеПоНоменклатуре.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)) КАК ТребуетсяМаркировка
	|ИЗ
	|	вт_ДанныеЗаданийНаборов КАК вт_ДанныеЗаданийНаборов
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоТоварамРасходнойНакладной КАК вт_ДанныеПоТоварамРасходнойНакладной
	|		ПО вт_ДанныеЗаданийНаборов.РасходнаяНакладная = вт_ДанныеПоТоварамРасходнойНакладной.Ссылка
	|			И вт_ДанныеЗаданийНаборов.Номенклатура = вт_ДанныеПоТоварамРасходнойНакладной.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоНоменклатуре КАК вт_ДанныеПоНоменклатуре
	|		ПО вт_ДанныеЗаданийНаборов.Номенклатура = вт_ДанныеПоНоменклатуре.Ссылка
	|ИТОГИ ПО
	|	ЗаданиеНабора";
	#КонецОбласти
	
	ВыборкаЗаполнениеЗНБ = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаЗаполнениеЗНБ.Следующий() Цикл
		ДокументОбъектЗаданиеНабора = ВыборкаЗаполнениеЗНБ.ЗаданиеНабора.ПолучитьОбъект();
		
		ВыборкаДетальныеЗаписи = ВыборкаЗаполнениеЗНБ.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", ВыборкаДетальныеЗаписи.Номенклатура);
			
			НайденыеСтроки = ДокументОбъектЗаданиеНабора.Товары.НайтиСтроки(ПараметрыОтбора);
			Для каждого СтрокаТабличнойЧасти из НайденыеСтроки Цикл
				ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, ВыборкаДетальныеЗаписи)
			КонецЦикла;
		КонецЦикла;
		
		Попытка
			ДокументОбъектЗаданиеНабора.Записать(РежимЗаписиДокумента.Проведение);
			
			СообщитьИзМодуля(СтрШаблон("Успешно перезаполнен ЗНБ %1.", ВыборкаЗаполнениеЗНБ.ЗаданиеНабора));
		Исключение
			//@skip-check bsl-legacy-check-static-feature-access
			СообщитьИзМодуля(СтрШаблон("Не удалось перезаполнить ЗНБ %1:
				|%2", ВыборкаЗаполнениеЗНБ.ЗаданиеНабора, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		КонецПопытки;
	КонецЦикла;
	// Ихсанов Д. А. Конец 03.03.2026
	
КонецПроцедуры // ПерезаполнитьРНКнаОснованииЗаказа()

// Ихсанов Д. А. Начало 22.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2259
// Процедура - Пометить на удаление расходные накладные без заказа клиента
//
// Проверка на наличие заказа для РНК стоит и в модуле объекта документа расходной накладной,
// однако менеджеры все равно имеют возможность проводить такие документы в статусе К отправке на склад.
// Это механизм пост обработки получения данных сайта, который будет помечать такие документы
// на удаление во избежания проведения проблемных позиций менеджером
//
// Параметры:
//  МаркетПлейс	 - СправочникСсылка.ИнетМагазины - Ссылка на маркетплейс
//
Процедура ПометитьНаУдалениеРасходныеНакладныеБезЗаказаКлиента(МаркетПлейс) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	СписокРеквизитов = "Контрагент, ПунктДоставки, Тест, Склад, СкладМаркировки";
	РеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, СписокРеквизитов);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК РасходнаяНакладная,
	|	РасходнаяНакладная.Номер КАК Номер,
	|	РасходнаяНакладная.Дата КАК Дата
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО РасходнаяНакладная.Ссылка = ЗаказКлиентаFBS.ДокОснование
	|			И (ЗаказКлиентаFBS.Проведен)
	|ГДЕ
	|	РасходнаяНакладная.Контрагент = &Контрагент
	|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
	|	И РасходнаяНакладная.Склад = &Склад
	|	И РасходнаяНакладная.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И НЕ РасходнаяНакладная.ПометкаУдаления
	|	И ЗаказКлиентаFBS.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка,
	|	РасходнаяНакладная.Номер,
	|	РасходнаяНакладная.Дата
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО РасходнаяНакладная.Ссылка = ЗаказКлиентаFBS.ДокОснование
	|			И (ЗаказКлиентаFBS.Проведен)
	|ГДЕ
	|	РасходнаяНакладная.Контрагент = &Контрагент
	|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
	|	И РасходнаяНакладная.Склад = &СкладМаркировки
	|	И РасходнаяНакладная.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И НЕ РасходнаяНакладная.ПометкаУдаления
	|	И ЗаказКлиентаFBS.Ссылка ЕСТЬ NULL");
	Запрос.УстановитьПараметр("Контрагент",		 РеквизитыМаркетПлейс.Контрагент);
	Запрос.УстановитьПараметр("ПунктДоставки",	 РеквизитыМаркетПлейс.ПунктДоставки);
	Запрос.УстановитьПараметр("Склад",			 РеквизитыМаркетПлейс.Склад);
	Запрос.УстановитьПараметр("СкладМаркировки", РеквизитыМаркетПлейс.СкладМаркировки);
	Запрос.УстановитьПараметр("ДатаНачала",		 НачалоДня(ТекущаяДата));
	Запрос.УстановитьПараметр("ДатаОкончания",	 КонецДня(ТекущаяДата));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументРНК = Выборка.РасходнаяНакладная;
		ДокументОбъектРНК = ДокументРНК.ПолучитьОбъект();
		
		Попытка
			ДокументОбъектРНК.УстановитьПометкуУдаления(Истина);
			СообщитьИзМодуля(СтрШаблон("РНК №%1 от %2. Документ обработан успешно.", Выборка.Номер, Выборка.Дата));
		Исключение
			ТекстСообщения = СтрШаблон("РНК №%1 от %2. У документа нет заказа клиента FBS. Не удалось установить пометку удаления.",
			Выборка.Номер, Выборка.Дата);
			Если РеквизитыМаркетПлейс.Тест Тогда
				ЗаписатьВЛог("РНК_Без_ЗК", ТекстСообщения, "Ошибка");
			Иначе
				СообщитьИзМодуля(ТекстСообщения);
			КонецЕсли;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры // ПометитьНаУдалениеРасходныеНакладныеБезЗаказаКлиента()
// Ихсанов Д. А. Конец  22.05.2025

#КонецОбласти

#Область МаркетПлейсы_РаботаСПредварительнымЗаказомКлиента

// Процедура - Маркет плейсы сформировать документы РНК ЗК
// Ихсанов Д. А. 09.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// 
// Параметры:
//  МаркетПлейс - СправочникСсылка.ИнетМагазины - Ссылка на сущность маркет плейса
//  Склад - СправочникСсылка.Склады - Склад на который будет выполнено перемещение
//  ДанныеШапкиДокумента - Структура - Данные для шапки документа
//  ТаблицаДанных - ТаблицаЗначений - Данные товара для выполнения перемещения
//  ФиксированнаяДатаОтгрузки - Булево - Фиксированная дата отгрузки
//  ЗаказыОтЮрЛица - Булево - Заказы от юр лица
//  ТекстыСообщений - Массив - Массив текстов сообщений об ошибках
//  СмещениеПоДатеОтгрузки - Неопределено - Смещение по дате отгрузки
//@skip-check doc-comment-collection-item-type
Процедура МаркетПлейсы_СформироватьДокументыРНК_ЗК(МаркетПлейс, Склад, ДанныеШапкиДокумента, //ТаблицаДанных...) Экспорт
	ТаблицаДанных, ФиксированнаяДатаОтгрузки, ЗаказыОтЮрЛица = Ложь, ТекстыСообщений = Неопределено, СмещениеПоДатеОтгрузки = Неопределено) Экспорт
	
	// Инициализация
	ТекущаяДата = ТекущаяДатаСеанса();
	СекундВОдномДне = 86400;
	ПрефиксМаркета = ПрефМаркет(МаркетПлейс);
	
	КоличествоЧасовСмещенияНаПриемку = 12;
	КоличествоМинутСекунд = 60;
	
	////////////////////////////////////////////////////////////////
	// Инициировать создание документов РНК и ЗК
	// Очистить таблицу данных
	МассивНомеровЗаказов = ТаблицаДанных.ВыгрузитьКолонку("НомерЗаказа");
	
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	Если СмещениеПоДатеОтгрузки = Неопределено Тогда
		СмещениеПоДатеОтгрузки = 2;
	КонецЕсли;
	
	Если ФиксированнаяДатаОтгрузки Тогда
		ДатаОтгрузки = ДанныеШапкиДокумента.ДатаОтгрузки;
	Иначе
		ДатаОтгрузки = ТекущаяДата + СекундВОдномДне * СмещениеПоДатеОтгрузки;
	КонецЕсли;
	
	ОтгрузкаКомплектов = Ложь;
	КомлектыСОстатком = Новый Массив;
	// Ихсанов Д. А. Конец  17.03.2026
	
	// Ихсанов Д. А. Начало 30.04.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9622
//	ДокументОбъектРасходнаяНакладная = СоздатьИЗаполнитьШапкуНакладной11(МаркетПлейс,
//		СтрШаблон("%1. %2.", ДанныеШапкиДокумента.Комментарий, СтрСоединить(МассивНомеровЗаказов, ";")), Ложь);
	ДокументОбъектРасходнаяНакладная = СоздатьИЗаполнитьШапкуНакладной11(МаркетПлейс,
		СтрШаблон("%1.%2 %3.", ДанныеШапкиДокумента.Комментарий,
			?(ДанныеШапкиДокумента.ПоТоваруЗаполненыВГХ, "", " По некоторым товарам в накладной не заполнены ВГХ!"),
			СтрСоединить(МассивНомеровЗаказов, ";")), Ложь);
	// Ихсанов Д. А. Конец 30.04.2026
	ДокументОбъектРасходнаяНакладная.Склад					 = Склад;
	ДокументОбъектРасходнаяНакладная.Дата					 = ТекущаяДата;
	ДокументОбъектРасходнаяНакладная.ДистанционнаяПродажа	 = Истина;
	ДокументОбъектРасходнаяНакладная.ДатаОтгрузки			 = ДатаОтгрузки;
	ДокументОбъектРасходнаяНакладная.ОтгрузкаЗаказовПоЮрЛицу = ЗаказыОтЮрЛица;
	
	СвернутаяТаблицаДанных = ТаблицаДанных.Скопировать();
	СвернутаяТаблицаДанных.Свернуть("Номенклатура, Комплект, КомплектИзСебя", "Количество, Цена");
	Для каждого СтрокаСвернутойТаблицыДанных из СвернутаяТаблицаДанных Цикл
		Если СтрокаСвернутойТаблицыДанных.Комплект
			И СтрокаСвернутойТаблицыДанных.КомплектИзСебя
			И ДанныеШапкиДокумента.ОтгрузкаКомплектов Тогда
			КомлектыСОстатком.Добавить(СтрокаСвернутойТаблицыДанных.Номенклатура)
		ИначеЕсли СтрокаСвернутойТаблицыДанных.Комплект
			И ДанныеШапкиДокумента.ОтгрузкаКомплектов Тогда
			ОтгрузкаКомплектов = Истина
		КонецЕсли;
		
		НоваяСтрокаРНК = ДокументОбъектРасходнаяНакладная.Товары.Добавить();
		НоваяСтрокаРНК.Номенклатура			= СтрокаСвернутойТаблицыДанных.Номенклатура;
		НоваяСтрокаРНК.Количество			= СтрокаСвернутойТаблицыДанных.Количество;
		НоваяСтрокаРНК.Заявка				= СтрокаСвернутойТаблицыДанных.Количество;
		НоваяСтрокаРНК.ПодтвержденнаяЗаявка = СтрокаСвернутойТаблицыДанных.Количество;
		
		ЦенаССайта = СтрокаСвернутойТаблицыДанных.Цена / СтрокаСвернутойТаблицыДанных.Количество;
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрокаРНК, ДокументОбъектРасходнаяНакладная,, ЦенаССайта);
	КонецЦикла;
	
	ПунктДоставки_ПриИзменении(ДокументОбъектРасходнаяНакладная, Истина);
	
	ДокументОбъектРасходнаяНакладная.ОтгрузкаКомплектов = ОтгрузкаКомплектов;
	Если ОтгрузкаКомплектов Тогда
		ЗаполнитьКомплектующие(ДокументОбъектРасходнаяНакладная, КомлектыСОстатком);
	КонецЕсли;
	
	ДокументОбъектРасходнаяНакладная.Товары.Сортировать("Номенклатура");
	ДокументОбъектРасходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
	
	Попытка
		ЗаписьВРег=РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
		ЗаписьВРег.Документ			 = ДокументОбъектРасходнаяНакладная.Ссылка;
		ЗаписьВРег.ИмяРеквизита		 = "ИнтернетЗаказ";
		ЗаписьВРег.ЗначениеРеквизита = "Да";
		ЗаписьВРег.Записать();
	Исключение
		СообщитьИзМодуля(СтрШаблон("Не удалось зафиксировать признак интернет заказа в регистр Реквизиты справочников!
			|Документ: %1.", ДокументОбъектРасходнаяНакладная.Ссылка));
	КонецПопытки;
	
	ДокументОбъектЗаказКлиентаFBS = Документы.ЗаказКлиентаFBS.СоздатьДокумент();
	ДокументОбъектЗаказКлиентаFBS.ДокОснование = ДокументОбъектРасходнаяНакладная.Ссылка;
	ДокументОбъектЗаказКлиентаFBS.Дата = ТекущаяДата;
	ДокументОбъектЗаказКлиентаFBS.Контрагент = МаркетПлейс.Контрагент;
	ДокументОбъектЗаказКлиентаFBS.НомерПоставки = СтрШаблон("%1 %2", ДанныеШапкиДокумента.Комментарий,
		ПрефиксМаркета);
	
	МинимальнаяДатаЗаказаПоДокументу = ДатаОтгрузки;
	Для каждого СтрокаТаблицыДанных из ТаблицаДанных Цикл
		НоваяСтрокаFBS = ДокументОбъектЗаказКлиентаFBS.Товары.Добавить();
		НоваяСтрокаFBS.АртикулКонтрагента = СтрокаТаблицыДанных.АртикулКонтрагента;
		НоваяСтрокаFBS.Количество		  = СтрокаТаблицыДанных.Количество;
		НоваяСтрокаFBS.Заявка			  = СтрокаТаблицыДанных.Количество;
		НоваяСтрокаFBS.Номенклатура		  = СтрокаТаблицыДанных.Номенклатура;
		НоваяСтрокаFBS.Цена				  = СтрокаТаблицыДанных.Цена;
		НоваяСтрокаFBS.Всего			  = СтрокаТаблицыДанных.Всего;
		НоваяСтрокаFBS.НомерЗаказа		  = СтрокаТаблицыДанных.НомерЗаказа;
		НоваяСтрокаFBS.ДатаЗаказа		  = СтрокаТаблицыДанных.ДатаЗаказа;
		НоваяСтрокаFBS.РИД				  = СтрокаТаблицыДанных.РИД;
		НоваяСтрокаFBS.ШтрихКод			  = СтрокаТаблицыДанных.ШтрихКод;
		НоваяСтрокаFBS.СостояниеУКлиента  = СтрокаТаблицыДанных.СостояниеУКлиента;
		
		Если НоваяСтрокаFBS.ДатаЗаказа < МинимальнаяДатаЗаказаПоДокументу Тогда
			МинимальнаяДатаЗаказаПоДокументу = НоваяСтрокаFBS.ДатаЗаказа;
		КонецЕсли;
	КонецЦикла;
	
	ДатаПриемки = МинимальнаяДатаЗаказаПоДокументу + КоличествоЧасовСмещенияНаПриемку * КоличествоМинутСекунд
		* КоличествоМинутСекунд;
	ВремяПриемкиПоНакладной = ПолучитьВремяПриемкиИзДатыЗагрузки(ДеньНедели(ДатаПриемки),
		Час(ДатаПриемки), ДатаПриемки);
	Попытка
		ЗаписатьВремяПриемкиДляЗОГ(ДокументОбъектРасходнаяНакладная, ВремяПриемкиПоНакладной);
	Исключение
		СообщитьИзМодуля(СтрШаблон("Не удалось зафиксировать время приемки ЗОГ! Документ: %1.",
			ДокументОбъектРасходнаяНакладная.Ссылка));
	КонецПопытки;
	
	Попытка
		ОбновитьНумерациюОбъектов(Метаданные.Документы.ЗаказКлиентаFBS);
	Исключение
		СообщитьИзМодуля("Ошибка обновления нумерации объектов. (Не критичная)");
	Конецпопытки;
	
	ДокументОбъектЗаказКлиентаFBS.Записать(РежимЗаписиДокумента.Проведение);
	
	Попытка
		ДокументОбъектРасходнаяНакладная.СостояниеНакладной	  = Перечисления.СостоянияНакладной.КОтправкеНаСклад;
		ДокументОбъектРасходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ДокументОбъектРасходнаяНакладная.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе;
		ДокументОбъектРасходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
		
		Если ТекстыСообщений <> Неопределено Тогда
			ТекстыСообщений.Добавить(СтрШаблон("Не удалось записать %1;", ДокументОбъектРасходнаяНакладная.Ссылка))
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры // МаркетПлейсы_СформироватьДокументыРНК_ЗК()

