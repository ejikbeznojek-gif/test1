// Ихсанов Д. А. Начало 09.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7999
// Процедура - Маркет плейсы выполнить оповещение по РНКЗависших на заказе КМ
//
// Параметры:
//  ТаблицаПараметров - ТаблицаЗначений - Таблица с данными параметров регламентного задания
//
Процедура МаркетПлейсы_ВыполнитьОповещениеПоРНКЗависшихНаЗаказеКМ(ТаблицаПараметров = Неопределено) Экспорт
	
	МодификаторМинутыЧаса = 60;
	СмещениеПоИндексу = 1;
	
	КодМаркетПлейса = "";
	СмещениеИнтервалаПоЧасам = 2;
	Если ТаблицаПараметров <> Неопределено Тогда
		Для каждого Параметр из ТаблицаПараметров Цикл
			Если Параметр.Имя = "КодМаркетПлейса" Тогда
				КодМаркетПлейса = Параметр.Значение
			ИначеЕсли Параметр.Имя = "СмещениеИнтервалаПоЧасам" Тогда
				СмещениеИнтервалаПоЧасам = Параметр.Значение
			КонецЕсли
		КонецЦикла
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	СмещениеИнтервала = СмещениеИнтервалаПоЧасам * МодификаторМинутыЧаса * МодификаторМинутыЧаса;
	
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду(КодМаркетПлейса);
	РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс,
		"Контрагент, Наименование");
	
	ТекстыСообщения = Новый Массив;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|			ТОГДА ""Склад не указан""
	|		ИНАЧЕ РасходнаяНакладная.Склад.Представление
	|	КОНЕЦ КАК Склад
	|ПОМЕСТИТЬ вт_ДанныеРНК
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И РасходнаяНакладная.Контрагент = &Контрагент
	|	И РасходнаяНакладная.СостояниеНакладной = &СостояниеНакладной
	|	И РасходнаяНакладная.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеРНК.Ссылка КАК Ссылка,
	|	ТаймингиСостоянийСрезПоследних.Период КАК Дата,
	|	вт_ДанныеРНК.Склад КАК Склад
	|ИЗ
	|	вт_ДанныеРНК КАК вт_ДанныеРНК
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ТаймингиСостояний.СрезПоследних КАК ТаймингиСостоянийСрезПоследних
	|		ПО вт_ДанныеРНК.Ссылка = ТаймингиСостоянийСрезПоследних.Объект
	|ГДЕ
	|	ТаймингиСостоянийСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ЗаказКМЧЗ)
	|	И ТаймингиСостоянийСрезПоследних.Период < &ДатаОкончания");
	Запрос.УстановитьПараметр("СостояниеНакладной", Перечисления.СостоянияНакладной.ЗаказКМЧЗ);
	Запрос.УстановитьПараметр("Контрагент",			РеквизитыМаркетПлейса.Контрагент);
	Запрос.УстановитьПараметр("ДатаНачала",			ДобавитьМесяц(ТекущаяДата, - СмещениеПоИндексу));
	Запрос.УстановитьПараметр("ДатаОкончания",		ТекущаяДата - СмещениеИнтервала);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекстыСообщения.Добавить(СтрШаблон("Документ %1 (%2) завис в статусе заказа кодов маркировки на %3",
			Выборка.Ссылка, Выборка.Склад, ПолучитьСклоненияСтрокиПоЧислу("Час",
				// Ихсанов Д. А. 10.06.2026 Наряд 0000001061 от 09.06.2026 12:17:34: e1cib/data/Документ.Наряд?ref=89690050568f680711f163e408501409
				// Добавим пол часа к вычисляемой дате, что бы избежать уведомления с временем на час раньше в пограничных ситуациях
				ОКР((ТекущаяДата - Выборка.Дата) / МодификаторМинутыЧаса / МодификаторМинутыЧаса + 0.5, 0, РежимОкругления.Окр15как20))[0]));
	КонецЦикла;
	
	ПолучателиУведомленийЗависшиеРНКЗаказКМЧЗ = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(
		МаркетПлейс, "ПолучателиУведомленийЗависшиеРНКЗаказКМЧЗ");
	
	МассивПолучателейУведомлений = СтрРазделить(СтрЗаменить(ПолучателиУведомленийЗависшиеРНКЗаказКМЧЗ, " ", ""), ",");
	Если МассивПолучателейУведомлений.Количество() = 0 Тогда
		Возврат
	КонецЕсли;
	
	СписокПолучателейУведомлений = Новый СписокЗначений;
	СписокПолучателейУведомлений.ЗагрузитьЗначения(МассивПолучателейУведомлений);
	
	ТемаУведомления = СтрШаблон("%1. Зависшие накладные на этапе заказа кодов маркировки.", РеквизитыМаркетПлейса.Наименование);
	СообщениеУведомления = СтрШаблон("%1.", (СтрСоединить(ТекстыСообщения, СтрШаблон(";%1", Символы.ПС))));
	ОбменМаркетПлейс.ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателейУведомлений,
		ТемаУведомления, СообщениеУведомления);
	
КонецПроцедуры // МаркетПлейсы_ВыполнитьОповещениеПоРНКЗависшихНаЗаказеКМ()
// Ихсанов Д. А. Конец 09.12.2025

// Ихсанов Д. А. Начало 16.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7928;
// https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8007
// Процедура - Маркет плейсы контроль полей отмены документа заказа
//
// Параметры:
//  ДокументОбъект	 - ДокументОбъект.ЗаказКлиентаFBS, ДокументОбъект.ПредварительныйЗаказКлиента - Объект документа с заказами
//  ИменаРеквизитов	 - Строка, Массив Из Строка - Список реквизитов, в случае строки элементы должны разделяться запятой
//
Процедура МаркетПлейсы_КонтрольПолейОтменыДокументаЗаказа(ДокументОбъект, Знач ИменаРеквизитов) Экспорт
	
	Если ТипЗнч(ДокументОбъект) <> Тип("ДокументОбъект.ЗаказКлиентаFBS")
		И ТипЗнч(ДокументОбъект) <> Тип("ДокументОбъект.ПредварительныйЗаказКлиента") Тогда
		ВызватьИсключение "Передан недопустимый тип документа!"
	КонецЕсли;
	
	Если ТипЗнч(ИменаРеквизитов) <> Тип("Массив") Тогда
		ИменаРеквизитов = СтрРазделить(СтрЗаменить(ИменаРеквизитов, " ", ""), ",", Ложь);
	КонецЕсли;
	
	Для каждого ИмяРеквизита из ИменаРеквизитов Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить(ИмяРеквизита, Истина);
		
		НайденныеСтроки = ДокументОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для каждого СтрокаТабличнойЧасти из НайденныеСтроки Цикл
				Если Не СтрокаТабличнойЧасти.Отменен Тогда
					СтрокаТабличнойЧасти.Отменен = Истина
				КонецЕсли;
				
				Если СтрокаТабличнойЧасти.Количество > 0 Тогда
					СтрокаТабличнойЧасти.Количество = 0
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // МаркетПлейсы_КонтрольПолейОтменыДокументаЗаказа()
