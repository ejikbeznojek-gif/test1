// Ихсанов Д. А. Начало 04.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9056 ЛЕГАСИ!!!
Процедура ЯндексМаркет_ОтправитьДанныеОбОтменахНаСайт(МаркетПлейс) Экспорт
	
	// Инициализация
	ТекущаяДата = ТекущаяДатаСеанса();
	ИнтервалСмещения = 5;
	СекундВОднихСутках = 86400;
	
	ДополнительныеПараметры = КоннекторHTTP.НовыеПараметры();
	ДополнительныеПараметры.Заголовки = ОбменМаркетПлейс.МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс);
	ДополнительныеПараметры.ПараметрыПреобразованияJSON.ПрочитатьВСоответствие = Ложь;
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.РИД КАК РИД
	|ПОМЕСТИТЬ вт_ДанныеНомераЗаказов
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.Отменен
	|	И НЕ ЗаказКлиентаFBSТовары.ПереданоНаСайт
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	вт_ДанныеНомераЗаказов.РИД КАК НомерЗаказа,
	|	СУММА(ЗаказКлиентаFBSТовары.Количество) = 0 КАК ПолнаяОтмена
	|ПОМЕСТИТЬ вт_ЗаказыДанныеПолнойОтмены
	|ИЗ
	|	вт_ДанныеНомераЗаказов КАК вт_ДанныеНомераЗаказов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_ДанныеНомераЗаказов.РИД = ЗаказКлиентаFBSТовары.РИД
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеНомераЗаказов.РИД,
	|	ЗаказКлиентаFBSТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказFBS,
	|	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование КАК РасходнаяНакладная,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.РИД КАК НомерЗаказаВМоделиСервиса,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.СостояниеУКлиента КАК СостояниеУКлиента
	|ПОМЕСТИТЬ вт_Заказы
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.РИД В
	|			(ВЫБРАТЬ
	|				вт_ЗаказыДанныеПолнойОтмены.НомерЗаказа
	|			ИЗ
	|				вт_ЗаказыДанныеПолнойОтмены
	|			ГДЕ
	|				НЕ вт_ЗаказыДанныеПолнойОтмены.ПолнаяОтмена)
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен");
	ТекстыЗапросов.Добавить(Обработки.ЗаполнениеЗаказовФБСМаркиовкой.МП_ЯндексМаркет_ТекстЗапросаДанныеМаркировкиЗаказов("вт_Заказы"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ * ИЗ вт_Результат ИТОГИ ПО ЗаказFBS, НомерЗаказа, Идентификатор;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ Ссылка, НомерЗаказа ИЗ вт_ЗаказыДанныеПолнойОтмены ГДЕ ПолнаяОтмена ИТОГИ ПО Ссылка");
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";" + Символы.ПС));
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДата - ИнтервалСмещения * СекундВОднихСутках));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ТекущаяДата));
	Запрос.УстановитьПараметр("Контрагент", МаркетПлейс.Контрагент);
	
	МассивРезультатовЗапроса = Запрос.ВыполнитьПакет();
	
	// Инициализируем массив отборов для пометки отправки данных на сайт
	ВыборкаЗаказFBS = МассивРезультатовЗапроса[МассивРезультатовЗапроса.ВГраница() - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаЗаказFBS.Следующий() Цикл
		ДокументОбъектЗаказКлиентаFBS = ВыборкаЗаказFBS.ЗаказFBS.ПолучитьОбъект();
		
		// Формируем данные по коробкам для отправки
		ВыборкаНомерЗаказа = ВыборкаЗаказFBS.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНомерЗаказа.Следующий() Цикл
			// Получаем структуру, для перевода ее в формат JSON
			ДополнительныеПараметры.Json = Обработки.ЗаполнениеЗаказовФБСМаркиовкой.МП_ЯндексМаркет_СформироватьСтруктуруДанныхПоВыборке(ВыборкаНомерЗаказа,, Истина);
			СтруктураДанныхОтвета = КоннекторHTTP.Put(СтрШаблон("https://%1%2", Маркетплейс.Host,
				СтрШаблон("/v2/campaigns/%1/orders/%2/boxes.json", Маркетплейс.ИДКомпании, ВыборкаНомерЗаказа.НомерЗаказа)),, ДополнительныеПараметры);
			ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета, ДополнительныеПараметры.ПараметрыПреобразованияJSON);
			// Обработка ошибок со стороны сервиса
			Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
				Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
				СообщитьИзМодуля(СтрШаблон("Не удалось выполнить частичную отмену товара по заказу %1!", ВыборкаНомерЗаказа.НомерЗаказа))
			КонецЕсли;
			
			ДанныеМаркировкиОтправлены = ДанныеОтвета.Свойство("status") И ДанныеОтвета.status = "OK";
			Если ДанныеМаркировкиОтправлены Тогда
				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("РИД", ВыборкаНомерЗаказа.НомерЗаказа);
				ПараметрыОтбора.Вставить("Отменен", Истина);
				ПараметрыОтбора.Вставить("ПереданоНаСайт", Ложь);
				
				НайденныеСтроки = ДокументОбъектЗаказКлиентаFBS.Товары.НайтиСтроки(ПараметрыОтбора);
				Для каждого СтрокаТабличнойЧасти из НайденныеСтроки Цикл
					СтрокаТабличнойЧасти.ПереданоНаСайт = Истина;
				КонецЦикла;
				
				СообщитьИзМодуля(СтрШаблон("По заказу %1 успешно выполнена частичная отмена товаров.", ВыборкаНомерЗаказа.НомерЗаказа));
			Иначе
				СообщитьИзМодуля(СтрШаблон("Не удалось выполнить частичную отмену товара по заказу %1!", ВыборкаНомерЗаказа.НомерЗаказа));
			КонецЕсли;
		КонецЦикла;
		
		Если ДокументОбъектЗаказКлиентаFBS.Модифицированность() Тогда
			ДокументОбъектЗаказКлиентаFBS.Записать();
		КонецЕсли;
	КонецЦикла;
	
	ВыборкаПолнаяОтмена = МассивРезультатовЗапроса[МассивРезультатовЗапроса.ВГраница()].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПолнаяОтмена.Следующий() Цикл
		ДокументОбъектЗаказКлиентаFBS = ВыборкаПолнаяОтмена.Ссылка.ПолучитьОбъект();
		
		ВыборкаДетальныеЗаписи = ВыборкаПолнаяОтмена.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДополнительныеПараметры.Json = Новый Структура;
			ДополнительныеПараметры.Json.Вставить("order", Новый Структура);
			ДополнительныеПараметры.Json.order.Вставить("status", "CANCELLED");
			ДополнительныеПараметры.Json.order.Вставить("substatus", "SHOP_FAILED");
			
			СтруктураДанныхОтвета = КоннекторHTTP.Put(СтрШаблон("https://%1%2", Маркетплейс.Host,
				СтрШаблон("/v2/campaigns/%1/orders/%2/status.json", Маркетплейс.ИДКомпании, ВыборкаДетальныеЗаписи.НомерЗаказа)),, ДополнительныеПараметры);
			ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета, ДополнительныеПараметры.ПараметрыПреобразованияJSON);
			// Обработка ошибок со стороны сервиса
			Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
				Или СтруктураДанныхОтвета.КодСостояния > 400
				И ДанныеОтвета.Свойство("errors") Тогда
				СообщитьИзМодуля(СтрШаблон("Не удалось выполнить полную отмену заказа %1!", ВыборкаДетальныеЗаписи.НомерЗаказа));
				
				Продолжить;
			КонецЕсли;
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("РИД", ВыборкаДетальныеЗаписи.НомерЗаказа);
			ПараметрыОтбора.Вставить("Отменен", Истина);
			ПараметрыОтбора.Вставить("ПереданоНаСайт", Ложь);
			
			НайденныеСтроки = ДокументОбъектЗаказКлиентаFBS.Товары.НайтиСтроки(ПараметрыОтбора);
			Для каждого СтрокаТабличнойЧасти из НайденныеСтроки Цикл
				СтрокаТабличнойЧасти.ПереданоНаСайт = Истина;
			КонецЦикла;
			
			СообщитьИзМодуля(СтрШаблон("По заказу %1 успешно выполнена полная отмена товаров.", ВыборкаДетальныеЗаписи.НомерЗаказа));
		КонецЦикла;
		
		Если ДокументОбъектЗаказКлиентаFBS.Модифицированность() Тогда
			ДокументОбъектЗаказКлиентаFBS.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ЯндексМаркет_ОтправитьДанныеОбОтменахНаСайт()
