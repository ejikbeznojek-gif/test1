// Ихсанов Д. А. Начало 29.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-2538
// Процедура - Вывод кодов маркировки по интернет продажам
//
// Параметры:
//  ТаблицаПараметров	 - ТаблицаЗначений	 - Таблица с параметрами с колонками Имя и Значение.
//
Процедура ВыводКодовМаркировкиПоИнтернетПродажам(ТаблицаПараметров) Экспорт
	
	// Инициализация параметров исполнения
	СписокПолучателей = Новый СписокЗначений;
	ИнтервалСмещенияПоДням = 0; // Смещение в прошлое даты окончания
	ИнтервалПоДнямПериода = 0; // Интервал между датой начала и датой окончания
	МаркетПлейс = Справочники.ИнетМагазины.ПустаяСсылка();
	УведомлятьПолучателейОРазличияхВТоварах = Ложь;
	СоздаватьДокумент = Ложь;
	ЕмкостьПорции = 1000;
	Для каждого ПараметрИсполнения из ТаблицаПараметров Цикл
		Если ПараметрИсполнения.Имя = "ИнтервалСмещенияПоДням" Тогда
			ИнтервалСмещенияПоДням = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "ИнтервалПоДнямПериода" Тогда
			ИнтервалПоДнямПериода = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "МаркетПлейс" Тогда
			МаркетПлейс = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "ЕмкостьПорции" Тогда
			ЕмкостьПорции = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "УведомлятьПолучателейОРазличияхВТоварах" Тогда
			УведомлятьПолучателейОРазличияхВТоварах = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "СоздаватьДокумент" Тогда
			СоздаватьДокумент = ПараметрИсполнения.Значение;
		ИначеЕсли ПараметрИсполнения.Имя = "Получатель" Тогда
			СписокПолучателей.Добавить(ПараметрИсполнения.Значение);
		КонецЕсли;
	КонецЦикла;
	
	// Инициализация общих параметров исполнения
	СекундВОдномДне = 86400;
	
	ИменаРеквизитов = "АдресРесурса, Порт, ContentType, Accept, AcceptLanguage, AcceptCharset, ContentLanguage, ContentCharset, Host, Код,
		|XAuthToken, Token, Контрагент, Склад, СкладМаркировки, WarehouseId, Тест, ИДКомпании, Договор, ПунктДоставки, Организация, Наименование, Ссылка";
	РевизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
	
	// Сформируем интервалы сбора данных по листам набора
	ТекущаяДата	  = ТекущаяДатаСеанса();
	КонецПериода  = КонецДня(ТекущаяДата) - (ИнтервалСмещенияПоДням * СекундВОдномДне);
	НачалоПериода = НачалоДня(КонецПериода) - (ИнтервалПоДнямПериода * СекундВОдномДне);
	
	СтатусыПродано = Новый Соответствие;
	СтатусыПродано.Вставить("sold",	   Истина);
	СтатусыПродано.Вставить("Продано", Истина);
	
	Результат = ВыполнитьОбработкуПоСозданиюДокументаВыводаКодовМаркировки(НачалоПериода, КонецПериода, РевизитыМаркетПлейса,
		СоздаватьДокумент, ЕмкостьПорции, СтатусыПродано);
	
	// Уведомим получаетелей о том, что был произведен вывод марок из оборота в автоматическом режиме
	Если УведомлятьПолучателейОРазличияхВТоварах Тогда
		ОбменМаркетПлейс.ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,
			СтрШаблон(Нстр("ru='%1. Выполнен вывод кодов маркировки из оборота.'", "ru"), РевизитыМаркетПлейса.Наименование),
			Результат.ТекстУведомления);
	КонецЕсли;
	
КонецПроцедуры // ВыводКодовМаркировкиПоИнтернетПродажам()

Функция ВыполнитьОбработкуПоСозданиюДокументаВыводаКодовМаркировки(НачалоПериода, КонецПериода, //РевизитыМаркетПлейса...) Экспорт
	РевизитыМаркетПлейса, СоздаватьДокумент, ЕмкостьПорции, СтатусыПродано, СсылкаНаДокумент = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ТекстУведомления", "");
	Результат.Вставить("Документ", Документы.МаркировкаТоваровИСМП.ПустаяСсылка());
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	СоответствиеЗаказаКСтатусу = Новый Соответствие;
	
	ТекстыУведомления = Новый Массив;
	
	// Ихсанов Д. А. Начало 10.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3236
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(РевизитыМаркетПлейса.Склад);
	МассивСкладов.Добавить(РевизитыМаркетПлейса.СкладМаркировки);
	// Ихсанов Д. А. Конец  10.12.2025
	
	// Инициализируем запрос на получения данных о проданных марках
	ТекстыЗапроса = Новый Массив;
	ТекстыЗапроса.Добавить(ТекстЗапросаДанныеПоКодамМаркировки());
	ТекстыЗапроса.Добавить("ВЫБРАТЬ 
	|	вт_Результат.Id КАК НомерЗаказа,
	|	АВТОНОМЕРЗАПИСИ() КАК НомерСтроки
	|ПОМЕСТИТЬ вт_ДанныеДляПорционнойВыгрузки
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|ГДЕ
	|	вт_Результат.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю)
	|	И вт_Результат.Id <> """"
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_Результат.Id
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеДляПорционнойВыгрузки.НомерЗаказа КАК НомерЗаказа,
	|	ВЫРАЗИТЬ((вт_ДанныеДляПорционнойВыгрузки.НомерСтроки - 1) / &ЕмкостьПорции + 0.5 КАК ЧИСЛО(10, 0)) КАК НомерПорции
	|ИЗ
	|	вт_ДанныеДляПорционнойВыгрузки КАК вт_ДанныеДляПорционнойВыгрузки
	|ИТОГИ ПО
	|	НомерПорции");
	
	// Получим данные по кодам маркировки, которые имеются в базе по накладным
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапроса, ";"));
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачала",	   НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания", КонецПериода);
	Запрос.УстановитьПараметр("Контрагент",	   РевизитыМаркетПлейса.Контрагент);
	// Ихсанов Д. А. Начало 10.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3236
	Запрос.УстановитьПараметр("Склады",		   МассивСкладов);
	// Ихсанов Д. А. Конец  10.12.2025
	Запрос.УстановитьПараметр("ЕмкостьПорции", ЕмкостьПорции);
	
	// Сбор данных по проданным товарам в заказах
	КоличествоВсего = 0;
	МассивЗаказов = Новый Массив;
	// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
	КартаНомераЗаказаКНомеруЭкземпляра = Новый Соответствие;
	// Ихсанов Д. А. Конец 02.07.2026
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		МассивЗаказов.Очистить();
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НомерЗаказа = ВыборкаДетальныеЗаписи.НомерЗаказа;
				Если РевизитыМаркетПлейса.Код = "00001"
					Или РевизитыМаркетПлейса.Код = "00009" Тогда
					НомерЗаказа = Число(НомерЗаказа)
				// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
				ИначеЕсли РевизитыМаркетПлейса.Код = "00002" Тогда
					НомерЗаказа = СтрШаблон("%1-%2", СтрРазделить(НомерЗаказа, "-")[0], СтрРазделить(НомерЗаказа, "-")[1])
				ИначеЕсли РевизитыМаркетПлейса.Код = "00004" Тогда
					НомерЗаказа = Число(СтрРазделить(НомерЗаказа, "-")[0])
				ИначеЕсли РевизитыМаркетПлейса.Код = "00014" Тогда
					НомерЗаказа = СтрРазделить(НомерЗаказа, "-")[0]
				// Ихсанов Д. А. Конец 02.07.2026
				КонецЕсли;
				
				// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
				КартаНомераЗаказаКНомеруЭкземпляра.Вставить(ВыборкаДетальныеЗаписи.НомерЗаказа, НомерЗаказа);
				// Ихсанов Д. А. Конец 02.07.2026
				
				МассивЗаказов.Добавить(НомерЗаказа)
		КонецЦикла;
		
		// Выявим статусы заказов в модели сервиса
		КоличествоВсего = КоличествоВсего + МассивЗаказов.Количество();
		ПолучитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов, РевизитыМаркетПлейса, СтатусыПродано);
	КонецЦикла;
	
	// Подготовим тексты уведомления о количестве заказов с маркировкой и о проданных марках
	ТекстыУведомления.Добавить(СтрШаблон("Всего сборочных заданий с маркировкой %1", КоличествоВсего));
	ТекстыУведомления.Добавить(СтрШаблон("Сборочных заданий статус <ПРОДАНО> %1", СоответствиеЗаказаКСтатусу.Количество()));
	
	Если СоответствиеЗаказаКСтатусу.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 10.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3236
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_РасходныеНакладные.Номер КАК Номер
	|ИЗ
	|	вт_РасходныеНакладные КАК вт_РасходныеНакладные";
	
	МассивНомеровРНК = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номер");
	// Ихсанов Д. А. Конец  10.12.2025
	
	// Создадим документ вывода марок из оборота и заполним шапку документа
	ДокументОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
	Если СоздаватьДокумент Тогда
		Если ЗначениеЗаполнено(СсылкаНаДокумент) Тогда
			ДокументОбъект = СсылкаНаДокумент.ПолучитьОбъект();
		Иначе
			ДокументОбъект.Дата					  = ТекущаяДата;
			ДокументОбъект.ВидОперации			  = Перечисления.ВидыОперацийМаркировки.ВыводИзОборота;
			ДокументОбъект.ВидОперацииИСМП		  = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа;
			ДокументОбъект.Комментарий			  = СтрШаблон("Автоматически загруженные данные за - %1. %2.", Формат(ТекущаяДата, "ДФ=yyyy-MM-dd"),
				СтрСоединить(МассивНомеровРНК, ","));
			ДокументОбъект.Организация			  = РевизитыМаркетПлейса.Организация;
			ДокументОбъект.Статус				  = Перечисления.СтатусыДокументовМаркировки.ВРаботе; 
			ДокументОбъект.КодУзлаСоздания		  = "SNL";
			ДокументОбъект.ТипДокумента			  = Перечисления.ТипыДокументовИСМП.УПД;
			ДокументОбъект.ТипУпаковки			  = Перечисления.ТипыУпаковок.МаркированныйТовар;
			ДокументОбъект.ПодразделениеНанесения = РевизитыМаркетПлейса.Склад;
			ДокументОбъект.ДокументОснование	  = Документы.РасходнаяНакладная.НайтиПоНомеру("SSP-012028", ТекущаяДатаСеанса())
		КонецЕсли;
	КонецЕсли;
	
	ДокументОбъект.ШтрихкодыУпаковок.Очистить();
	ДокументОбъект.Товары.Очистить();
	
	// Ихсанов Д. А. Начало 10.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3236
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Результат.DataMatrix.Наименование КАК DataMatrix
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|ГДЕ
	|	вт_Результат.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю)
	|	И вт_Результат.Id <> """"";
	
	МассивКодовМаркировки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("DataMatrix");
	
	ОбработкаАПи = Обработки.АпиЧЗ.Создать(); 
	РезультатОтработки  = ОбработкаАПи.ПолучитьДанныеИзЧЗПоКодамКМ(МассивКодовМаркировки);
	
	МассивКодовМаркировкиВОбороте = Новый Массив;
	Для каждого ПорцияРезультатаОбработки из РезультатОтработки.Данные Цикл
		Для каждого ДанныеПоКодамМаркировки из ПорцияРезультатаОбработки.Данные Цикл
			МассивДанныеПоКодамМаркировки = ОбменМаркетПлейс.ОбработатьСтрокуJSON(ДанныеПоКодамМаркировки);
			Для каждого ЭлементКодаМаркировкиЧЗ из МассивДанныеПоКодамМаркировки Цикл
				Если ЭлементКодаМаркировкиЧЗ.cisInfo.status = "INTRODUCED" Тогда
					МассивКодовМаркировкиВОбороте.Добавить(ЭлементКодаМаркировкиЧЗ.cisInfo.cis)
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	// Ихсанов Д. А. Конец  10.12.2025
	
	// Из ранее сохраненных временных таблиц получим данные о номенклатуре и марках для заполнения ТЧ документа
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	*
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|ГДЕ
	|	вт_Результат.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю)
	|	И вт_Результат.Id <> """"
	|	И вт_Результат.DataMatrix.Наименование В(&МассивКодовМаркировкиВОбороте)
	|ИТОГИ ПО
	|	Id";
	Запрос.УстановитьПараметр("МассивКодовМаркировкиВОбороте", МассивКодовМаркировкиВОбороте);
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
		//Если СоответствиеЗаказаКСтатусу[Выборка.Id] = Неопределено Тогда
		Если СоответствиеЗаказаКСтатусу[КартаНомераЗаказаКНомеруЭкземпляра[Выборка.Id]] = Неопределено Тогда
		// Ихсанов Д. А. Конец 02.07.2026
			Продолжить
		КонецЕсли;
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрокаШК = ДокументОбъект.ШтрихкодыУпаковок.Добавить();
			НоваяСтрокаШК.ШтрихкодУпаковки = ВыборкаДетальныеЗаписи.DataMatrix;
			
			НоваяСтрокаТовары = ДокументОбъект.Товары.Добавить();
			НоваяСтрокаТовары.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
			НоваяСтрокаТовары.Количество   = 1;
			НоваяСтрокаТовары.Цена		   = ВыборкаДетальныеЗаписи.Цена;
		КонецЦикла;
	КонецЦикла;
	
	Если ДокументОбъект.ШтрихкодыУпаковок.Количество() > 0 И СоздаватьДокумент Тогда
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
	
	// Соберем данные о марках, которые не удалось обработать
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Результат.Id КАК НомерЗаказа,
	|	вт_Результат.DataMatrix КАК DataMatrix
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|ГДЕ
	|	вт_Результат.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю)
	|	И вт_Результат.Id = """"";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 Тогда
		ТекстыУведомления.Добавить("Следующие марки не были обработаны автоматически:");
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		ТекстыУведомления.Добавить(Выборка.DataMatrix);
	КонецЦикла;
	
	Если Выборка.Количество() > 0 Тогда
		ТекстыУведомления.Добавить("Их нужно обработать вручную!");
	КонецЕсли;
	
	Результат.ТекстУведомления = СтрСоединить(ТекстыУведомления, Символы.ПС);
	Если СоздаватьДокумент Тогда
		Результат.Документ = ДокументОбъект.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ВыполнитьТестовуюОбработкуКодовМаркировки()

// Функция - Текст запроса данные по кодам маркировки
// Возвращает текст запроса на получение данных о кодах маркировки от Листов Наборов
// 
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаДанныеПоКодамМаркировки()
	
	// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
	Возврат "ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	РасходнаяНакладная.Номер КАК Номер
	|ПОМЕСТИТЬ вт_РасходныеНакладные
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Контрагент = &Контрагент
	|	И РасходнаяНакладная.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И РасходнаяНакладная.Склад В(&Склады)
	|	И РасходнаяНакладная.Проведен
	|	И РасходнаяНакладная.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Отгружена)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(РасходнаяНакладнаяТовары.Цена) КАК Цена
	|ПОМЕСТИТЬ вт_ДанныеПоТоварамРНК
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_РасходныеНакладные.Ссылка
	|			ИЗ
	|				вт_РасходныеНакладные)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка КАК Ссылка,
	|	ЛистПереукладки.ДокОснование КАК ДокОснование
	|ПОМЕСТИТЬ вт_ЛистыПереукладки
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.ДокОснование В
	|			(ВЫБРАТЬ
	|				вт_РасходныеНакладные.Ссылка
	|			ИЗ
	|				вт_РасходныеНакладные)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЛистНабора.Ссылка КАК Ссылка,
