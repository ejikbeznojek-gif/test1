Процедура ВыполнитьПроверкуНаличияЗаказовЯндекс(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка, //РазмерПорции...)
	РазмерПорции, ДатаНачала, ДатаОкончания)
	
	СмещениеПоЗапросу = Base64Значение(РазмерПорции);
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	
	Пока Истина Цикл
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("fromDate",   Формат(ДатаНачала, "ДФ=dd-MM-yyyy"));
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("toDate",	   Формат(ДатаОкончания, "ДФ=dd-MM-yyyy"));
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("limit",	   РазмерПорции);
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("page_token", СмещениеПоЗапросу);
		
		// Инициализируем параметры подключения к программному интерфейсу сервиса
		ПараметрыОбработки.ДанныеЗапроса.Метод		 = "GET";
		ПараметрыОбработки.ИменаСвойствОшибок		 = "errors, error";
		
		// Выполняем запрос к сервису
		ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
			ОбменМаркетПлейс.МП_Яндекс_ВернутьСоединение(РеквизитыМаркетПлейса),
			ОбменМаркетПлейс.МП_Яндекс_ВернутьЗаголовкиHTTP(РеквизитыМаркетПлейса.Ссылка),
			СтрШаблон("/v2/campaigns/%1/orders.json", РеквизитыМаркетПлейса.ИДКомпании),
			ПараметрыОбработки);
		// Проверим успешно ли выполнился запрос
		СообщениеОбОшибке = "";
		Если Не ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки) Тогда
			ВызватьИсключение СтрШаблон("Яндекс. Не удаловсь выполнить соединение: %1", СообщениеОбОшибке)
		КонецЕсли;
		
		Для каждого ДанныеЗаказа из ДанныеОтвета.orders Цикл
			ДанныеПоНомеруЗаказа = Новый Структура;
			ДанныеПоНомеруЗаказа.Вставить("НомерЗаказа", ДанныеЗаказа.id);
			ДанныеПоНомеруЗаказа.Вставить("МаркетПлейс", РеквизитыМаркетПлейса.Наименование);
			
			МассивНомеровЗаказов.Добавить(ДанныеПоНомеруЗаказа)
		КонецЦикла;
		
		Если Не ДанныеОтвета.paging.Свойство("nextPageToken") Тогда
			Прервать
		КонецЕсли;
		
		СмещениеПоЗапросу = ДанныеОтвета.paging.nextPageToken
	КонецЦикла
	
КонецПроцедуры // ВыполнитьПроверкуНаличияЗаказовЯндекс()

