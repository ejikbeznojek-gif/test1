		//ЧтениеJSON           = Новый ЧтениеJSON;
		//ЧтениеJSON.УстановитьСтроку(ОтветСсайта.ПолучитьТелоКакСтроку()); 		
		//Данные = ПрочитатьJSON(ЧтениеJSON, Ложь);      		
		//ЗаписатьВЛог("МП_ОЗОН","Заказ "+НомерЗаказа+" успешно разбит на части","Информация");
		
		//Тимофеев Ю.А. Конец    13-02-2025
		
		
	Иначе                                                                                     		
		ЗаписатьВЛог("МП_ОЗОН","Ошибка разбивки заказа "+ОтветСсайта.ПолучитьТелоКакСтроку(),"Ошибка "+Строка(ОтветСсайта.КодСостояния)); 		
