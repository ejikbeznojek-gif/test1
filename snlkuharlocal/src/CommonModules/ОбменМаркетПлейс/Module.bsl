// Выполнить валидацию по методу APIV1.
// 
// Параметры:
//  Операция - Строка - Операция
// 
// Возвращаемое значение:
//  Строка - Выполнить валидацию по методу APIV1
Функция ВыполнитьВалидациюПоМетодуAPIV1(Операция)
	
	СтруктураВалидации = Новый Структура;
	СтруктураВалидации.Вставить("ИменаОбязательныхПараметров", Новый Массив);
	СтруктураВалидации.Вставить("ФорматПараметров", Новый Структура);
	СтруктураВалидации.Вставить("УсловияВалидацииПараметров", Новый Соответствие);
	
	Если Операция = "СформироватьПланФактПоКаналам" Тогда
		// Заполним имена обязательных параметров
		СтруктураВалидации.ИменаОбязательныхПараметров.Добавить("start_date");
		СтруктураВалидации.ИменаОбязательныхПараметров.Добавить("end_date");
		
		// Заполним формат параметров
		Для каждого ИмяПараметра из СтруктураВалидации.ИменаОбязательныхПараметров Цикл
			СтруктураВалидации.ФорматПараметров.Вставить(ИмяПараметра, "ДФ=yyyy-MM-dd");
		КонецЦикла;
		
		// Заполним вычисление условий валидации параметров
		Для каждого ИмяПараметра из СтруктураВалидации.ИменаОбязательныхПараметров Цикл
			СтруктураВалидации.УсловияВалидацииПараметров.Вставить("Параметр start_date не может быть больше end_date.",
				"Результат = ПараметрыЗапроса[""start_date""] <= ПараметрыЗапроса[""end_date""]");
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтруктураВалидации;
	
КонецФункции // ВыполнитьВалидациюПоМетодуAPIV1()

// Оснастка результата ответа.
// 
// Параметры:
//  УспешныйОтвет - Булево - Успешный ответ
//  Данные - Строка, Произвольный - Данные
// 
// Возвращаемое значение:
//  Структура - Оснастка результата ответа:
// * status - Строка - 
Функция ОснасткаРезультатаОтвета(УспешныйОтвет, Данные = "")
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("status", ?(УспешныйОтвет, "ok", "error"));
	СтруктураОтвета.Вставить(?(УспешныйОтвет, "data", "message"), Данные);
	
	Возврат СтруктураОтвета;
	
КонецФункции // ОснасткаРезультатаОтвета()
