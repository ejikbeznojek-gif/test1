	|		ИНАЧЕ ВТ_НомОстОбщий.КВыгрузке
	|	КОНЕЦ КАК МинимумСпайка,
	|	ВТ_НомОстОбщий.Комплект КАК Комплект,
	|	ВТ_НомОстОбщий.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_НомОстОбщий.КВыгрузке КАК КВыгрузке,
	|	ВТ_НомОстОбщий.offer_id КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|	ВТ_НомОстОбщий.АртикулКонтрагента КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|	ВТ_НомОстОбщий.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_ФИНАЛ
	|ИЗ
	|	ВТ_НомОстОбщий КАК ВТ_НомОстОбщий
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МинКТИтог КАК ВТ_МинКТИтог
	|		ПО ВТ_НомОстОбщий.Номенклатура = ВТ_МинКТИтог.Продукция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ФИНАЛ.Номенклатура КАК Номенклатура,
	|	ВТ_ФИНАЛ.ШК КАК ШК,
	|	ВТ_ФИНАЛ.Остаток КАК Остаток,
	|	ВТ_ФИНАЛ.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_ФИНАЛ.МинимумСпайка КАК МинимумСпайка,
	|	ВТ_ФИНАЛ.Комплект КАК Комплект,
	|	ВТ_ФИНАЛ.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВЫБОР
	|		КОГДА ВТ_ФИНАЛ.КВыгрузке = 0
	|			ТОГДА ВЫБОР
	|					КОГДА ВТ_ФИНАЛ.МинимумСпайка < ВТ_ФИНАЛ.МатрицаКоличество
	|						ТОГДА ВТ_ФИНАЛ.МинимумСпайка
	|					ИНАЧЕ ВТ_ФИНАЛ.МатрицаКоличество
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТ_ФИНАЛ.МинимумСпайка >= ВТ_ФИНАЛ.КВыгрузке
	|					ТОГДА ВТ_ФИНАЛ.МинимумСпайка
	|				ИНАЧЕ ВТ_ФИНАЛ.КВыгрузке
	|			КОНЕЦ
	|	КОНЕЦ КАК КВыгрузке,
	|	ВТ_ФИНАЛ.offer_id КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|	ВТ_ФИНАЛ.АртикулКонтрагента КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|	ВТ_ФИНАЛ.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ ВТ_ПОЛНАЯ
	|ИЗ
	|	ВТ_ФИНАЛ КАК ВТ_ФИНАЛ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПОЛНАЯ.Номенклатура КАК Номенклатура,
	|	ВТ_ПОЛНАЯ.ШК КАК SKU,
	|	ВТ_ПОЛНАЯ.Остаток КАК Остаток,
	|	ВТ_ПОЛНАЯ.МатрицаКоличество КАК МатрицаКоличество,
	|	ВТ_ПОЛНАЯ.МинимумСпайка КАК МинимумСпайка,
	|	ВТ_ПОЛНАЯ.Комплект КАК Комплект,
	|	ВТ_ПОЛНАЯ.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	ВТ_ПОЛНАЯ.КВыгрузке КАК КВыгрузке,
	|	0 КАК СержантскийЗапас,
	|	ВТ_ПОЛНАЯ.offer_id КАК offer_id,
	// Ихсанов Д. А. Начало 13.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2242
	|	ВТ_ПОЛНАЯ.АртикулКонтрагента КАК АртикулКонтрагента,
	// Ихсанов Д. А. Конец  15.04.2025
	|	ВТ_ПОЛНАЯ.Product_ID КАК Product_ID
	|ПОМЕСТИТЬ вт_Результат
	|ИЗ
	|	ВТ_ПОЛНАЯ КАК ВТ_ПОЛНАЯ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоВычеркамКомплектующих
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &СкладВычерка
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ВТ_ИТОГ.Номенклатура
	|					ИЗ
	|						ВТ_ИТОГ)) КАК ОстаткиТМЦОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ПОМЕСТИТЬ вт_ДанныеПоОстаткам
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад = &СкладВычерка
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_Результат.Номенклатура
	|					ИЗ
	|						вт_Результат)) КАК ОстаткиТМЦОстатки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВТ_ИТОГ.Продукция,
	|	вт_ДанныеПоВычеркамКомплектующих.КоличествоОстаток
	|ИЗ
	|	ВТ_ИТОГ КАК ВТ_ИТОГ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоВычеркамКомплектующих КАК вт_ДанныеПоВычеркамКомплектующих
	|		ПО ВТ_ИТОГ.Номенклатура = вт_ДанныеПоВычеркамКомплектующих.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(вт_ДанныеПоВычеркамКомплектующих.КоличествоОстаток, 0) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Результат.Номенклатура КАК Номенклатура,
	|	вт_Результат.SKU КАК SKU,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) > 0
	|			ТОГДА 0
	|		ИНАЧЕ вт_Результат.Остаток
	|	КОНЕЦ КАК Остаток,
	|	вт_Результат.МатрицаКоличество КАК МатрицаКоличество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) > 0
	|			ТОГДА 0
	|		ИНАЧЕ вт_Результат.МинимумСпайка
	|	КОНЕЦ КАК МинимумСпайка,
	|	вт_Результат.Комплект КАК Комплект,
	|	вт_Результат.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	вт_Результат.КВыгрузке КАК КВыгрузке,
	|	вт_Результат.СержантскийЗапас КАК СержантскийЗапас,
	|	ЕСТЬNULL(вт_ДанныеПоОстаткам.КоличествоОстаток, 0) КАК ТоварыНаСкладахВычерках,
	|	вт_Результат.offer_id КАК offer_id,
	|	вт_Результат.АртикулКонтрагента КАК АртикулКонтрагента,
	|	вт_Результат.Product_ID КАК Product_ID
	|ИЗ
	|	вт_Результат КАК вт_Результат
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеПоОстаткам КАК вт_ДанныеПоОстаткам
	|		ПО вт_Результат.Номенклатура = вт_ДанныеПоОстаткам.Номенклатура";
	//Параметры запроса
	
	Запрос.УстановитьПараметр("ВыгрузкаПоМатрице",МаркетПлейс.ВыгрузкаОстатковПоМатрице);// Булево
	Запрос.УстановитьПараметр("ГотовыйКомплект",  Перечисления.ВидыКомплектов.ГотовыйКомплект);// Виды комплектов
	Запрос.УстановитьПараметр("ДатаОкончания",    КонецДня(ТекущаяДатаСеанса()));// Дата
	Запрос.УстановитьПараметр("Договор",          МаркетПлейс.Договор);// Договоры
	Запрос.УстановитьПараметр("Контрагент",       МаркетПлейс.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("МаркетПлейс",      МаркетПлейс);// Интернет магазины(marketplaces)
	Запрос.УстановитьПараметр("ПунктДоставки",    МаркетПлейс.ПунктДоставки);// Фактические адреса
	Запрос.УстановитьПараметр("Склад",            НужныйСклад);// Склады
	// Ихсанов Д. А. Начало 20.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6670
	Запрос.УстановитьПараметр("СкладВычерка",     СкладВычерка);// Склады
	// Ихсанов Д. А. Конец  20.08.2025
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции 

// Функция - Магнит маркет получить данные по номенклатуре в модели сервиса
//
// Параметры:
//  МаркетПлейс			 - СправочникСсылка.ИнетМагазины	 - Ссылка на маркетплейс
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица значений с одной колонкой Номенклатура
//
Функция МагнитМаркет_ПолучитьДанныеПоНоменклатуреВМоделиСервиса(МаркетПлейс) Экспорт
	
	РазмерСтраницы = 1000;
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("pagination", Новый Структура);
	ДанныеДляJSON.pagination.Вставить("dir", "DESC");
	ДанныеДляJSON.pagination.Вставить("page", 0);
	ДанныеДляJSON.pagination.Вставить("page_size", РазмерСтраницы);
	
	ПараметрыОбработки = ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод		 = "POST";
	
	МассивШтрихкодов = Новый Массив;
	ЗапросАктуален = Истина; Страница = 1;
	Пока ЗапросАктуален Цикл
		ДанныеДляJSON.pagination.page = Страница;
		
		ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = СформироватьСтрокуJSON(ДанныеДляJSON,
		ПараметрыОбработки);
		ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
		МП_Магнит_ВернутьСоединение(МаркетПлейс),
		МП_Магнит_ВернутьЗаголовкиHTTP(МаркетПлейс),
		"api/seller/v1/products/sku/list",
		ПараметрыОбработки);
		
		Для каждого Элемент из ДанныеОтвета.result Цикл
			Если Элемент.seller_sku_id = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			МассивШтрихкодов.Добавить(Элемент.seller_sku_id);
		КонецЦикла;
		
		ТекущийРазмерСтраницы = ДанныеОтвета.result.Количество();
		Если РазмерСтраницы > ТекущийРазмерСтраницы Тогда
			ЗапросАктуален = Ложь;
		КонецЕсли;
		
		Страница = Страница + 1;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	МатрицаПунктыДоставки.Ссылка КАК Ссылка,
	|	МатрицаПунктыДоставки.Ссылка.ДатаОкончания КАК ДатаОкончания
	|ПОМЕСТИТЬ ВТ_Матрицы_Предварительная
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ГДЕ
	|	МатрицаПунктыДоставки.Ссылка.Проведен
	|	И МатрицаПунктыДоставки.Ссылка.Контрагент = &Контрагент
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И МатрицаПунктыДоставки.Ссылка.Договор = &Договор
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаПунктыДоставки.Ссылка,
	|	МатрицаПунктыДоставки.Ссылка.ДатаОкончания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Матрицы_Предварительная.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Матрицы
	|ИЗ
	|	ВТ_Матрицы_Предварительная КАК ВТ_Матрицы_Предварительная
	|ГДЕ
	|	ВТ_Матрицы_Предварительная.ДатаОкончания > &ДатаОкончания
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Матрицы_Предварительная.Ссылка
	|ИЗ
	|	ВТ_Матрицы_Предварительная КАК ВТ_Матрицы_Предварительная
	|ГДЕ
	|	ВТ_Матрицы_Предварительная.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(МатрицаТовары.ШККонтрагента КАК СТРОКА(150)) КАК ШК,
	|	МатрицаТовары.Выгружать0Ост КАК ВыгружатьОст0,
	|	ВЫБОР
	|		КОГДА МатрицаТовары.Выгружать0Ост
	|			ТОГДА 0
	|		ИНАЧЕ МатрицаТовары.МинимальноеКоличество
	|	КОНЕЦ КАК МатрицаКоличество
	|ПОМЕСТИТЬ вт_Номенклатура
	|ИЗ
	|	ВТ_Матрицы КАК ВТ_Матрицы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.Товары КАК МатрицаТовары
	|		ПО ВТ_Матрицы.Ссылка = МатрицаТовары.Ссылка
	|ГДЕ
	|	МатрицаТовары.ШККонтрагента В(&МассивШтрихкодов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_Номенклатура.Номенклатура КАК Номенклатура,
	|	вт_Номенклатура.ВыгружатьОст0 КАК ВыгружатьОст0,
	|	вт_Номенклатура.МатрицаКоличество КАК МатрицаКоличество
	|ИЗ
	|	вт_Номенклатура КАК вт_Номенклатура
	|ГДЕ
	|	вт_Номенклатура.ВыгружатьОст0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вт_Номенклатура.Номенклатура,
	|	вт_Номенклатура.ВыгружатьОст0,
	|	вт_Номенклатура.МатрицаКоличество
	|ИЗ
	|	вт_Номенклатура КАК вт_Номенклатура
	|ГДЕ
	|	вт_Номенклатура.МатрицаКоличество > 0";
	Запрос.УстановитьПараметр("ВыгрузкаПоМатрице",МаркетПлейс.ВыгрузкаОстатковПоМатрице);// Булево
	Запрос.УстановитьПараметр("ГотовыйКомплект",  Перечисления.ВидыКомплектов.ГотовыйКомплект);// Виды комплектов
	Запрос.УстановитьПараметр("ДатаОкончания",    КонецДня(ТекущаяДатаСеанса()));// Дата
	Запрос.УстановитьПараметр("Договор",          МаркетПлейс.Договор);// Договоры
	Запрос.УстановитьПараметр("Контрагент",       МаркетПлейс.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("МаркетПлейс",      МаркетПлейс);// Интернет магазины(marketplaces)
	Запрос.УстановитьПараметр("ПунктДоставки",    МаркетПлейс.ПунктДоставки);// Фактические адреса
	Запрос.УстановитьПараметр("МассивШтрихкодов", МассивШтрихкодов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // МагнитМаркет_ПолучитьДанныеПоНоменклатуреВМоделиСервиса()

// Процедура - Яндекс маркет выгрузить остатки на портал
//
// Параметры:
//  ДанныеКВыгрузке		 - ТаблицаЗначений					 - Подготовленные данные к выгрузке
//  МаркетПлейс			 - СправочникСсылка.ИнетМагазины	 - Ссылка на маркетплейс
//
Процедура ЯндексМаркет_ВыгрузитьОстаткиНаПортал(ДанныеКВыгрузке, МаркетПлейс, // РеквизитыМаркетПлейс...) 
	РеквизитыМаркетПлейс, ПрефиксМаркетПлейса, ЕмкостьПорции)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Запрос = Новый Запрос(ТекстЗапросаПорционнаяВыгрузка(Ложь));
	Запрос.УстановитьПараметр("ТаблицаЗначений", ДанныеКВыгрузке);
	Запрос.УстановитьПараметр("ЕмкостьПорции", 	 ЕмкостьПорции);
	
	// Контролируем выгрузку данных на портал
	ПараметрыОбработки = ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод		 = "PUT";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		ДанныеДляJSON = Новый Структура;
		ДанныеДляJSON.Вставить("skus", Новый Массив);
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДанныеПоТовару = Новый Структура;
			ДанныеПоТовару.Вставить("sku", 	 ВыборкаДетальныеЗаписи.SKU);
			ДанныеПоТовару.Вставить("items", Новый Массив);
			
			ДанныеПоКоличеству = Новый Структура;
			ДанныеПоКоличеству.Вставить("count", 	 ВыборкаДетальныеЗаписи.КВыгрузке);
			ДанныеПоКоличеству.Вставить("updatedAt", ЗаписатьДатуJSON(ТекущаяДата, ФорматДатыJSON.ISO,
			ВариантЗаписиДатыJSON.УниверсальнаяДата));
			
			ДанныеПоТовару.items.Добавить(ДанныеПоКоличеству);
			ДанныеДляJSON.skus.Добавить(ДанныеПоТовару);
		КонецЦикла;
		
		ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = СформироватьСтрокуJSON(ДанныеДляJSON,
		ПараметрыОбработки);
		ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
		МП_Яндекс_ВернутьСоединение(МаркетПлейс),
		МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс),
		СтрШаблон("/v2/campaigns/%1/offers/stocks.json", РеквизитыМаркетПлейс.ИДКомпании),
		ПараметрыОбработки);
		
		Если ДанныеОтвета.Свойство("error")
			Или ДанныеОтвета.Свойство("errors") Тогда
			Если РеквизитыМаркетПлейс.Тест Тогда
				ЗаписатьВЛог("ЗаписьЛога_ОШИБКА", СтрШаблон("%1. Возникла ошибка при работе с сервисом! %2", ПрефиксМаркетПлейса, 
					ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "ИСКЛЮЧЕНИЕ_ОШИБКА");
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ЯндексМаркет_ВыгрузитьОстаткиНаПортал()

// Процедура - Магнит маркет выгрузить остатки на портал
//
// Параметры:
//  ДанныеКВыгрузке		 - ТаблицаЗначений					 - Подготовленные данные к выгрузке
//  МаркетПлейс			 - СправочникСсылка.ИнетМагазины	 - Ссылка на маркетплейс
//
Процедура МагнитМаркет_ВыгрузитьОстаткиНаПортал(ДанныеКВыгрузке, МаркетПлейс, // РеквизитыМаркетПлейс...) 
	РеквизитыМаркетПлейс, ПрефиксМаркетПлейса, ЕмкостьПорции)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Запрос = Новый Запрос(ТекстЗапросаПорционнаяВыгрузка());
	Запрос.УстановитьПараметр("ТаблицаЗначений", ДанныеКВыгрузке);
	Запрос.УстановитьПараметр("ЕмкостьПорции", 	 ЕмкостьПорции);
	
	// Контролируем выгрузку данных на портал
	ПараметрыОбработки = ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод		 = "POST";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		ДанныеДляJSON = Новый Структура;
		ДанныеДляJSON.Вставить("stocks", Новый Массив);
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДанныеПоТовару = Новый Структура;
			//ДанныеПоТовару.Вставить("seller_sku_id", ВыборкаДетальныеЗаписи.SKU);
			ДанныеПоТовару.Вставить("sku_id", ВыборкаДетальныеЗаписи.АртикулКонтрагента);
			ДанныеПоТовару.Вставить("stock", 		 ВыборкаДетальныеЗаписи.КВыгрузке);
			ДанныеПоТовару.Вставить("warehouse_id",  РеквизитыМаркетПлейс.WarehouseId);
			
			ДанныеДляJSON.stocks.Добавить(ДанныеПоТовару);
		КонецЦикла;
		
		ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = СформироватьСтрокуJSON(ДанныеДляJSON,
			ПараметрыОбработки);
		ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
			МП_Магнит_ВернутьСоединение(МаркетПлейс),
			МП_Магнит_ВернутьЗаголовкиHTTP(МаркетПлейс),
			"api/seller/v1/products/sku/stocks",
			ПараметрыОбработки);
		
		Если ДанныеОтвета.Свойство("error")
			Или ДанныеОтвета.Свойство("errors") Тогда
			Если РеквизитыМаркетПлейс.Тест Тогда
				ЗаписатьВЛог("ЗаписьЛога_ОШИБКА", СтрШаблон("%1. Возникла ошибка при работе с сервисом! %2", ПрефиксМаркетПлейса, 
					ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "ИСКЛЮЧЕНИЕ_ОШИБКА");
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ЯндексМаркет_ВыгрузитьОстаткиНаПортал()

// Функция - Данные по всем складам маркетплейса
//
// Параметры:
//  МаркетПлейс	 - СправочникСсылка.ИнетМагазины	 - Ссылка на маркетплейс
// 
// Возвращаемое значение:
//  Массив - Данные по всем складам маркетплейса, структура с наименованием и ссылкой
//
Функция ДанныеПоВсемСкладамМаркетплейса(МаркетПлейс)
	
	// Получаем данные по всем указанным в МаркетПлейсе складам
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИнетМагазины.Ссылка КАК Ссылка,
	|	ИнетМагазины.Склад КАК Склад,
	|	ИнетМагазины.СкладМаркировки КАК СкладМаркировки
	|ПОМЕСТИТЬ вт_ДанныеМаркетПлейса
	|ИЗ
	|	Справочник.ИнетМагазины КАК ИнетМагазины
	|ГДЕ
	|	ИнетМагазины.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеМаркетПлейса.СкладМаркировки КАК Склад
	|ПОМЕСТИТЬ вт_ДанныеПоСкладам
	|ИЗ
	|	вт_ДанныеМаркетПлейса КАК вт_ДанныеМаркетПлейса
	|ГДЕ
	|	вт_ДанныеМаркетПлейса.СкладМаркировки <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Склады.Ссылка КАК Ссылка,
	|	Склады.Код КАК Код,
	|	Склады.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПоСкладам.Склад
	|			ИЗ
	|				вт_ДанныеПоСкладам)");
	Запрос.УстановитьПараметр("Ссылка", МаркетПлейс);
	
	МассивСкладов = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтруктураСклада = Новый Структура;
		СтруктураСклада.Вставить("Ссылка",		 Выборка.Ссылка);
		СтруктураСклада.Вставить("Наименование", Выборка.Наименование);
		СтруктураСклада.Вставить("Код",			 Выборка.Код);
		
		МассивСкладов.Добавить(СтруктураСклада);
	КонецЦикла;
	
	Возврат МассивСкладов;
	
КонецФункции // ДанныеПоВсемСкладамМаркетплейса()

// Функция - Текст запроса порционная выгрузка
// 
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаПорционнаяВыгрузка(ПроверкаПоАртикулу = Истина)
	
	ТекстЗапроса = "ВЫБРАТь
	|	*,
	|	АВТОНОМЕРЗАПИСИ() КАК НомерСтроки
	|ПОМЕСТИТЬ вт_ТаблицаЗначений
	|ИЗ
	|	&ТаблицаЗначений КАК ТаблицаЗначений
	|%1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ВЫРАЗИТЬ((НомерСтроки - 1) / &ЕмкостьПорции + 0.5 КАК ЧИСЛО(10, 0)) КАК НомерПорции
	|ИЗ
	|	вт_ТаблицаЗначений ИТОГИ ПО НомерПорции";
	
	ПодстрокаЗамены = "";
	Если ПроверкаПоАртикулу Тогда
		ПодстрокаЗамены = "ГДЕ
		|	(ВЫРАЗИТЬ(ТаблицаЗначений.АртикулКонтрагента КАК СТРОКА(32))) <> """"";
	КонецЕсли;
	
	Возврат СтрШаблон(ТекстЗапроса, ПодстрокаЗамены);
	
КонецФункции // ТекстЗапросаПорционнаяВыгрузка()

// Функция - Собрать данные о вычерках
//
// Параметры:
//  ТаблицаДанных		 - ТаблицаЗначений	 - Подготовленные данные к выгрузке
//  РеквизитыМаркетПлейс - Структура		 - Данные о реквизитах маркетплейса
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Готовые данные к выгрузке
//
Функция СобратьДанныеОВычерках(ТаблицаДанных, РеквизитыМаркетПлейс)
	
	лСутки = 86400;
	ДатаОкончания = ТекущаяДатаСеанса();
	ДатаНачала	  = НачалоДня(ДатаОкончания) - лСутки;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	СУММА(1) КАК Вычерк
	|ПОМЕСТИТЬ ВТ_ВРЕМ
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	(ЗаказКлиентаFBSТовары.ВычеркОфис
	|			ИЛИ ЗаказКлиентаFBSТовары.ВычеркСклад)
	|	И ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.ПунктДоставки = &ПунктДоставки
	|	И ЗаказКлиентаFBSТовары.Ссылка.Проведен
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &НачВычерка И &КонВычерка
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура,
	|	1
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка.ПунктДоставки = &ПунктДоставки
	|	И РасходнаяНакладнаяТовары.Ссылка.Дата МЕЖДУ &НачВычерка И &КонВычерка
	|	И РасходнаяНакладнаяТовары.Ссылка.Контрагент = &Контрагент
	|	И (НЕ РасходнаяНакладнаяТовары.Ссылка.Проведен
	|			ИЛИ РасходнаяНакладнаяТовары.Ссылка.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВРЕМ.Номенклатура КАК Номенклатура,
	|	СУММА(ВТ_ВРЕМ.Вычерк) КАК Вычерк
	|ПОМЕСТИТЬ ВТ_Вычерки
	|ИЗ
	|	ВТ_ВРЕМ КАК ВТ_ВРЕМ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ВРЕМ.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ ВТ_ОСТАТКИ
	|ИЗ
	|	&ТЗОСТАТКИ КАК ТЗОСТАТКИ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_Вычерки.Вычерк, 0) КАК Вычерк,
	|	ВТ_ОСТАТКИ.*
	|ПОМЕСТИТЬ ВТ_СВЕРКА
	|ИЗ
	|	ВТ_ОСТАТКИ КАК ВТ_ОСТАТКИ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Вычерки КАК ВТ_Вычерки
	|		ПО ВТ_ОСТАТКИ.Номенклатура = ВТ_Вычерки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СВЕРКА.ТоварыНаСкладахВычерках > 0 КАК ТоварыНаСкладахВычерках,
	// Ихсанов Д. А. Начало 24.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8932
	|	ВТ_СВЕРКА.КомплектующиеНаСкладахВычерках > 0 КАК КомплектующиеНаСкладахВычерках,
	// Ихсанов Д. А. Конец  24.02.2026
	|	ВЫБОР
	|		КОГДА ВТ_СВЕРКА.ВыгружатьОст0
	// Ихсанов Д. А. Начало 03.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-117
	|				ИЛИ ВТ_СВЕРКА.ТоварВБлокировке
	// Ихсанов Д. А. Конец 03.02.2026
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТ_СВЕРКА.Комплект
	|						И ВТ_СВЕРКА.МинимумСпайка > 0
	// Ихсанов Д. А. Начало 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8904
	|						И ВТ_СВЕРКА.Остаток - ВТ_СВЕРКА.Вычерк < 2
	// Ихсанов Д. А. Конец  17.02.2026
	|					ТОГДА ВЫБОР
	|							КОГДА ВТ_СВЕРКА.МатрицаКоличество > ВТ_СВЕРКА.МинимумСпайка
	|								ТОГДА ВЫБОР
	|										КОГДА ВТ_СВЕРКА.МинимумСпайка - ВТ_СВЕРКА.Вычерк > 0
	|											ТОГДА ВТ_СВЕРКА.МинимумСпайка - ВТ_СВЕРКА.Вычерк
	|										ИНАЧЕ 0
	|									КОНЕЦ
	|							ИНАЧЕ ВЫБОР
	|									КОГДА ВТ_СВЕРКА.МатрицаКоличество - ВТ_СВЕРКА.Вычерк > 0
	|										ТОГДА ВТ_СВЕРКА.МатрицаКоличество - ВТ_СВЕРКА.Вычерк
	|									ИНАЧЕ 0
	|								КОНЕЦ
	|						КОНЕЦ
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ВТ_СВЕРКА.Остаток - ВТ_СВЕРКА.Вычерк >= 2
	|							ТОГДА ВЫБОР
	|									КОГДА ВТ_СВЕРКА.МатрицаКоличество > ВТ_СВЕРКА.Остаток
	|										ТОГДА ВЫБОР
	|												КОГДА ВТ_СВЕРКА.Остаток - ВТ_СВЕРКА.Вычерк > 0
	|													ТОГДА ВТ_СВЕРКА.Остаток - ВТ_СВЕРКА.Вычерк
	|												ИНАЧЕ 0
	|											КОНЕЦ
	|									ИНАЧЕ ВЫБОР
	|											КОГДА ВТ_СВЕРКА.МатрицаКоличество - ВТ_СВЕРКА.Вычерк > 0
	|												ТОГДА ВТ_СВЕРКА.МатрицаКоличество - ВТ_СВЕРКА.Вычерк
	|											ИНАЧЕ 0
	|										КОНЕЦ
	|								КОНЕЦ
	|						ИНАЧЕ 0
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК КВыгрузке,
	|	ВТ_СВЕРКА.*
	|ИЗ
	|	ВТ_СВЕРКА КАК ВТ_СВЕРКА");
	Запрос.УстановитьПараметр("НачВычерка",    ДатаНачала);
	Запрос.УстановитьПараметр("КонВычерка",    ДатаОкончания);
	Запрос.УстановитьПараметр("Контрагент",    РеквизитыМаркетПлейс.Контрагент);
	Запрос.УстановитьПараметр("ПунктДоставки", РеквизитыМаркетПлейс.ПунктДоставки);
	Запрос.УстановитьПараметр("ТЗОСТАТКИ",     ТаблицаДанных);
	
	ТаблицаОбработанныхДанных = Запрос.Выполнить().Выгрузить();
	ТаблицаОбработанныхДанных.Колонки.Удалить("КВыгрузке1");
	ТаблицаОбработанныхДанных.Колонки.Удалить("ТоварыНаСкладахВычерках1");
	// Ихсанов Д. А. Начало 24.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8932
	ТаблицаОбработанныхДанных.Колонки.Удалить("КомплектующиеНаСкладахВычерках1");
	// Ихсанов Д. А. Конец  24.02.2026
	
	Возврат ТаблицаОбработанныхДанных;
	
КонецФункции // СобратьДанныеОВычерках()

// Функция - Выполнить отбор по фильтру
//
// Параметры:
//  ТаблицаДанных		 - ТаблицаЗначений	 - Подготовленные данные к выгрузке
//  ТЗ_Фильтр			 - ТаблицаЗначений	 - Данные отбора по товару
//  РеквизитыМаркетПлейс - Структура		 - Данные о реквизитах маркетплейса
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Готовые данные к выгрузке
//
Функция ВыполнитьОтборПоФильтру(ТаблицаДанных, ТЗ_Фильтр, РеквизитыМаркетПлейс)
	
	Запрос = Новый Запрос("ВЫБРАТЬ *
	|ПОМЕСТИТЬ НужныйТовар
	|ИЗ
	|	&ТЗОстаток КАК ТЗОстаток
	|;
	|ВЫБРАТЬ *
	|ПОМЕСТИТЬ ФильтрТовар
	|ИЗ
	|	&ТЗФильтр КАК ТЗФильтр
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	НужныйТовар КАК НужныйТовар
	|ГДЕ
	|	Номенклатура.Ссылка В
	|			(ВЫБРАТЬ
	|				ФильтрТовар.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ФильтрТовар КАК ФильтрТовар)");
	Запрос.УстановитьПараметр("ТЗОстаток", ТаблицаДанных);
	Запрос.УстановитьПараметр("ТЗФильтр",  ТЗ_Фильтр);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // ВыполнитьОтборПоФильтру()

// Функция - Необходимо выполнить обнуление витрины
//
// Параметры:
//  МаркетПлейс	 - СправочникСсылка.ИнетМагазины	 - Ссылка на маркетплейс
// 
// Возвращаемое значение:
//  Булево - Истина, если нужно обнулить витрину, Ложь если нет
//
Функция НеобходимоВыполнитьОбнулениеВитрины(МаркетПлейс)
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка КАК СтопВыгрузка
	|ИЗ
	|	Справочник.ИнетМагазины КАК ИнетМагазины
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФоновогоЗадания.СрезПоследних КАК СтатусФоновогоЗаданияСрезПоследних
	|		ПО ИнетМагазины.Код = СтатусФоновогоЗаданияСрезПоследних.КОД
	|ГДЕ
	|	ИнетМагазины.Ссылка = &Ссылка
	|	И СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка");
	Запрос.УстановитьПараметр("Ссылка", МаркетПлейс);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции // НеобходимоВыполнитьОбнулениеВитрины()

// Процедура - Выполнить контроль ограничения лимита по секторам
//
// Параметры:
//  ТаблицаДанных		 - ТаблицаЗначений	 - Подготовленные данные к выгрузке
//  РеквизитыМаркетПлейс - Структура		 - Данные о реквизитах маркетплейса
//
Процедура ВыполнитьКонтрольОграниченияЛимитаПоСекторам(ТаблицаДанных, РеквизитыМаркетПлейс) Экспорт
	
	ПутьИмяФайла = РеквизитыМаркетПлейс.КаталогДляЭтикеток + "SektorXan.txt"; 
	
	ФайлТЗ = Новый Файл(ПутьИмяФайла);
	Если ФайлТЗ.Существует() Тогда
		ТЗПоСекторам = ЗначениеИзФайла(ПутьИмяФайла); 
		Если ТипЗнч(ТЗПоСекторам) = Тип("ТаблицаЗначений") Тогда
			ОбнулитьСектора = ТЗПоСекторам.Скопировать();
			ОбнулитьСектора.Очистить();
			ДатаПроверки = ТекущаяДатаСеанса();
			
			Для каждого СтрСектор из ТЗПоСекторам Цикл
				Если  ДатаПроверки >= СтрСектор.ДатаПроверки Тогда
					// Если факт больше или равно плану
					Если СтрСектор.Факт >= СтрСектор.План Тогда
						НовСтр = ОбнулитьСектора.Добавить();
						ЗаполнитьЗначенияСвойств(НовСтр,СтрСектор);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	// Если есть таблице значения - тогда обнуляем
	Если ОбнулитьСектора.Количество() > 0 Тогда 			
		// Добавим колонки
		ТаблицаДанных.Колонки.Добавить("Бренд");
		ТаблицаДанных.Колонки.Добавить("СекторХранения");
		
		// Заполним сектора
		Для Каждого СтрН из ТаблицаДанных Цикл
			Ном					= СТрН.Номенклатура;
			Бренд				= ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);
			СтрН.Бренд			= Бренд;
			СтрН.СекторХранения = ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд);
		КонецЦикла;     
		
		// Обнулим сектора
		Для Каждого ОбнулСектор из ОбнулитьСектора Цикл
			Отбор = Новый Структура();
			Отбор.Вставить("СекторХранения",ОбнулСектор.СекторХранения);
			
			СтрокинужногоСектора = ТаблицаДанных.НайтиСтроки(Отбор);
			Для Каждого СтрСектор из СтрокинужногоСектора Цикл
				СтрСектор.КВыгрузке = 0;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры // ВыполнитьКонтрольОграниченияЛимитаПоСекторам()
// Ихсанов Д. А. Конец  18.03.2025

// Ихсанов Д. А. Начало 20.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2253
// Процедура - Внештатное обнуление остатков по маркетплейсам
//
Процедура ВнештатноеОбнулениеОстатковПоМаркетплейсам() Экспорт
	
	// Фиксируем константы для соотношения имеющихся данных к полученным
	ПрефиксыМаркетПлейсов = Новый Структура;
	ПрефиксыМаркетПлейсов.Вставить("ПрефиксЯндекс", "Яндекс");
	ПрефиксыМаркетПлейсов.Вставить("ПрефиксМагнит", "Магнит");
	ПрефиксыМаркетПлейсов.Вставить("ПрефиксОзон",	"ОЗОН");
	ПрефиксыМаркетПлейсов.Вставить("ПрефиксРВБ",	"_ЕЕЭ_");
	ПрефиксыМаркетПлейсов.Вставить("ПрефиксБТК",	"_БТК_");
	
	// Инициализируем таблицу с данными МП для работы с запросом
	ТаблицаДанныхМаркетплейсов = ПолучитьТаблицуДанныхМаркетплейсов();
	ЗаполнитьТаблицуДанныхМаркетплейсов(ТаблицаДанныхМаркетплейсов, ПрефиксыМаркетПлейсов);
	
	// Получаем данные по статусам регламентных заданий
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ТаблицаЗначений.Префикс КАК Префикс,
	|	ТаблицаЗначений.МаркетПлейс КАК МаркетПлейс,
	|	ТаблицаЗначений.ШаблонПоиска КАК ШаблонПоиска
	|ПОМЕСТИТЬ вт_ТаблицаЗначений
	|ИЗ
	|	&ТаблицаЗначений КАК ТаблицаЗначений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ТаблицаЗначений.Префикс КАК Префикс,
	|	вт_ТаблицаЗначений.МаркетПлейс КАК МаркетПлейс,
	|	ИнетМагазины.Код КАК Код,
	|	вт_ТаблицаЗначений.ШаблонПоиска КАК ШаблонПоиска
	|ПОМЕСТИТЬ вт_ДанныеМаркетПлейсов
	|ИЗ
	|	вт_ТаблицаЗначений КАК вт_ТаблицаЗначений
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИнетМагазины КАК ИнетМагазины
	|		ПО вт_ТаблицаЗначений.МаркетПлейс = ИнетМагазины.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусФоновогоЗаданияСрезПоследних.Период КАК Период,
	|	вт_ДанныеМаркетПлейсов.Префикс КАК Префикс,
	|	вт_ДанныеМаркетПлейсов.МаркетПлейс КАК МаркетПлейс,
	|	вт_ДанныеМаркетПлейсов.Код КАК Код,
	|	вт_ДанныеМаркетПлейсов.ШаблонПоиска КАК ШаблонПоиска,
	|	СтатусФоновогоЗаданияСрезПоследних.ИмяПроцедуры КАК ИмяПроцедуры
	|ИЗ
	|	вт_ДанныеМаркетПлейсов КАК вт_ДанныеМаркетПлейсов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФоновогоЗадания.СрезПоследних КАК СтатусФоновогоЗаданияСрезПоследних
	|		ПО вт_ДанныеМаркетПлейсов.Код = СтатусФоновогоЗаданияСрезПоследних.КОД
	|ГДЕ
	|	НЕ СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка");
	Запрос.УстановитьПараметр("ТаблицаЗначений", ТаблицаДанныхМаркетплейсов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ИменаРеквизитов = "ИДКомпании, WarehouseId";
		пРеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(Выборка.МаркетПлейс, ИменаРеквизитов);
		
		// Вытаскиваем кэшированный файл с последней выгрузкой остатков
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьКЛогу = ?(ЗначениеЗаполнено(ПутьКонстантыЛогов), ПутьКонстантыЛогов, "\\srvfiles\1C_Logs_MarketPlace\");
		
		СписокФайлов = НайтиФайлы(ПутьКЛогу, Выборка.ШаблонПоиска, Ложь);
		Если СписокФайлов.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Файл = СписокФайлов[СписокФайлов.Количество() - 1];
		
		ТаблицаДанных = ЗначениеИзФайла(Файл.ПолноеИмя);
		ТаблицаДанных.ЗаполнитьЗначения(0, "КВыгрузке");
		
		// Выгружаем нулевые остатки по маркетплейсам
		Если Выборка.Префикс = ПрефиксыМаркетПлейсов.ПрефиксЯндекс Тогда
			ЯндексМаркет_ВыгрузитьОстаткиНаПортал(ТаблицаДанных, Выборка.МаркетПлейс, пРеквизитыМаркетПлейс,
				ПрефиксыМаркетПлейсов.ПрефиксЯндекс, 1000);
		ИначеЕсли Выборка.Префикс = ПрефиксыМаркетПлейсов.ПрефиксМагнит Тогда
			МагнитМаркет_ВыгрузитьОстаткиНаПортал(ТаблицаДанных, Выборка.МаркетПлейс, пРеквизитыМаркетПлейс,
				ПрефиксыМаркетПлейсов.ПрефиксМагнит, 1000);
		ИначеЕсли Выборка.Префикс = ПрефиксыМаркетПлейсов.ПрефиксОзон Тогда
			МП_ОЗОН_ВыгрузитьОстаткиОзон(Выборка.МаркетПлейс, ТаблицаДанных);
		ИначеЕсли Выборка.Префикс = ПрефиксыМаркетПлейсов.ПрефиксРВБ Тогда
			МП_Вайлберриз_ВыгрузитьОстаткиНаПортал(Выборка.МаркетПлейс, ТаблицаДанных, ПрефиксыМаркетПлейсов.ПрефиксРВБ);
		ИначеЕсли Выборка.Префикс = ПрефиксыМаркетПлейсов.ПрефиксБТК Тогда
			МП_Вайлберриз_ВыгрузитьОстаткиНаПортал(Выборка.МаркетПлейс, ТаблицаДанных, ПрефиксыМаркетПлейсов.ПрефиксБТК);
		КонецЕсли;
		
		// Фиксируем стоп дату для избежания многократной выгрузки нулевых остатков
		МенеджерЗаписи = РегистрыСведений.СтатусФоновогоЗадания.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Период		= Выборка.Период;
		МенеджерЗаписи.КОД			= Выборка.Код;
		МенеджерЗаписи.ИмяПроцедуры = Выборка.ИмяПроцедуры;
		МенеджерЗаписи.Прочитать();
		Если МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.СтопВыгрузка = Истина;
			МенеджерЗаписи.СтопДата		= НачалоДня(ТекущаяДатаСеанса()) - 1;
			МенеджерЗаписи.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ВнештатноеОбнулениеОстатковПоМаркетплейсам()

// Функция - Получить таблицу данных маркетплейсов
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Пустая таблица значений для заполнения данными маркетплейса
//
Функция ПолучитьТаблицуДанныхМаркетплейсов()
	
	КвалификаторыСтроки = Новый КвалификаторыСтроки();
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("Строка"));
	ОписаниеТиповСтрока = Новый ОписаниеТипов(МассивТипов, , КвалификаторыСтроки);
	МассивТипов.Очистить();
	МассивТипов.Добавить(Тип("СправочникСсылка.ИнетМагазины"));
	ОписаниеТиповМаркетПлейс = Новый ОписаниеТипов(МассивТипов);
	
	ТаблицаДанныхМаркетплейсов = Новый ТаблицаЗначений;
	ТаблицаДанныхМаркетплейсов.Колонки.Добавить("Префикс",		ОписаниеТиповСтрока);
	ТаблицаДанныхМаркетплейсов.Колонки.Добавить("МаркетПлейс",	ОписаниеТиповМаркетПлейс);
	ТаблицаДанныхМаркетплейсов.Колонки.Добавить("ШаблонПоиска", ОписаниеТиповСтрока);
	
	Возврат ТаблицаДанныхМаркетплейсов;
	
КонецФункции // ПолучитьТаблицуДанныхМаркетплейсов()

// Процедура - Заполнить таблицу данных маркетплейсов
//
// Параметры:
//  ТаблицаДанныхМаркетплейсов	 - ТаблицаЗначений	 - Таблица значений для заполнения данными маркетплейса
//  ПрефиксыМаркетПлейсов		 - Структура	- Данные с именами префиксов для логов
//
Процедура ЗаполнитьТаблицуДанныхМаркетплейсов(ТаблицаДанныхМаркетплейсов, ПрефиксыМаркетПлейсов)
	
	НоваяСтрока = ТаблицаДанныхМаркетплейсов.Добавить();
	НоваяСтрока.Префикс		 = ПрефиксыМаркетПлейсов.ПрефиксЯндекс;
	НоваяСтрока.МаркетПлейс	 = Справочники.ИнетМагазины.НайтиПоКоду("00004");
	НоваяСтрока.ШаблонПоиска = "ВыгрузкаОстатков_Яндекс_*";
	
	НоваяСтрока = ТаблицаДанныхМаркетплейсов.Добавить();
	НоваяСтрока.Префикс		 = ПрефиксыМаркетПлейсов.ПрефиксМагнит;
	НоваяСтрока.МаркетПлейс	 = Справочники.ИнетМагазины.НайтиПоКоду("00014");
	НоваяСтрока.ШаблонПоиска = "ВыгрузкаОстатков_Магнит_*";
	
	НоваяСтрока = ТаблицаДанныхМаркетплейсов.Добавить();
	НоваяСтрока.Префикс		 = ПрефиксыМаркетПлейсов.ПрефиксОзон;
	НоваяСтрока.МаркетПлейс	 = Справочники.ИнетМагазины.НайтиПоКоду("00002");
	НоваяСтрока.ШаблонПоиска = "ВыгрузкаОстатковОЗОН__*";
	
	НоваяСтрока = ТаблицаДанныхМаркетплейсов.Добавить();
	НоваяСтрока.Префикс		 = ПрефиксыМаркетПлейсов.ПрефиксРВБ;
	НоваяСтрока.МаркетПлейс	 = Справочники.ИнетМагазины.НайтиПоКоду("00001");
	НоваяСтрока.ШаблонПоиска = "ВыгрузкаОстатковWB_*";
	
	НоваяСтрока = ТаблицаДанныхМаркетплейсов.Добавить();
	НоваяСтрока.Префикс		 = ПрефиксыМаркетПлейсов.ПрефиксБТК;
	НоваяСтрока.МаркетПлейс	 = Справочники.ИнетМагазины.НайтиПоКоду("00009");
	НоваяСтрока.ШаблонПоиска = "ВыгрузкаОстатковWB_*";
	
КонецПроцедуры // ЗаполнитьТаблицуДанныхМаркетплейсов()
