Функция МП_СберМаркет_Записать_JSON(Структура,
	ПереносСтрок  = Неопределено, 
	Экранирование = Неопределено) Экспорт 
	
	Если ПереносСтрок = Неопределено Тогда	
		ПереносСтрок = ПереносСтрокJSON.Авто;
	КонецЕсли;
	
	Если Экранирование = Неопределено Тогда
		Экранирование = ЭкранированиеСимволовJSON.СимволыВнеASCII;
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрок , Символы.Таб,,Экранирование);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписьJSON.ПроверятьСтруктуру = Ложь;
	ЗаписатьJSON(ЗаписьJSON, Структура);
	
	Попытка 
		ВозвращаемоеЗначение = ЗаписьJSON.Закрыть();
	Исключение
		ВозвращаемоеЗначение = Неопределено;
	КонецПопытки;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

