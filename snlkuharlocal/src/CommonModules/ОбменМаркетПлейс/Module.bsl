// Ответ сервиса метод не разрешен по API.
// 
// Параметры:
//  МенеджерСервиса - ОбъектМетаданныхШаблонURLHTTPСервиса - Менеджер сервиса
// 
// Возвращаемое значение:
//  HTTPСервисОтвет - Ответ сервиса метод не разрешен по API
Функция ОтветСервисаМетодНеРазрешенПоAPI(МенеджерСервиса)
	
	МассивРазрешенныхМетодов = Новый Массив;
	МассивРазрешенныхМетодов.Добавить("HEAD");
	
	Для каждого Метод из МенеджерСервиса.Методы Цикл
		Если Строка(Метод.HTTPМетод) <> "Любой" Тогда
			МассивРазрешенныхМетодов.Добавить(Строка(Метод.HTTPМетод));
		КонецЕсли;
	КонецЦикла;
	
	ЗаголовкиHTTP = Новый Соответствие;
	ЗаголовкиHTTP.Вставить("Content-Length", 0);
	ЗаголовкиHTTP.Вставить("Date", ВремяПоГринвичуПоAPI());
	ЗаголовкиHTTP.Вставить("Allow", СтрСоединить(МассивРазрешенныхМетодов, ","));
	
	Ответ = Новый HTTPСервисОтвет(405);
	Ответ.Заголовки = ЗаголовкиHTTP;
	
	Возврат Ответ;
	
КонецФункции // ОтветСервисаМетодНеРазрешенПоAPI()

