// Обход данных по выборке с формированием ПЗК.
// Ихсанов Д. А. Начало 10.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// 
// Параметры:
//  МаркетПлейс - Неопределено, СправочникСсылка.ИнетМагазины - Маркет плейс
//  Выборка - ВыборкаИзРезультатаЗапроса - Выборка
//  УровеньОбработкиДанных - Число - Уровень обработки данных
//  ТаблицаДанных - ТаблицаЗначений - Таблица данных
//  ИзлишкиТовара - ТаблицаЗначений - Излишки товара
//  НаполняемостьКоробкиДляШтук - Число - Наполняемость коробки для штук
//  НаполняемостьКоробкиДляПакетов - Число - Наполняемость коробки для пакетов
//  НаполняемостьКоробкиДляКоробов - Число - Наполняемость коробки для коробов
//  НаполняемостьКоробкиДляСмешанныхУпаковок - Число - Наполняемость коробки для смешанных упаковок
//  ФиксированнаяДатаОтгрузки - Булево - Фиксированная дата отгрузки
//  ТекстыСообщений - Массив Из Строка - Тексты сообщений
//  СмещениеПоДатеОтгрузки - Неопределено - Смещение по дате отгрузки
//@skip-check method-too-many-params
Процедура ОбходДанныхПоВыборкеСФормированиемПЗК(МаркетПлейс, Выборка, УровеньОбработкиДанных, ТаблицаДанных, ИзлишкиТовара,
		НаполняемостьКоробкиДляШтук, НаполняемостьКоробкиДляПакетов, НаполняемостьКоробкиДляКоробов, НаполняемостьКоробкиДляСмешанныхУпаковок,
		ФиксированнаяДатаОтгрузки, ТекстыСообщений, СмещениеПоДатеОтгрузки = Неопределено)
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.Уровень() < УровеньОбработкиДанных Тогда
			ОбходДанныхПоВыборкеСФормированиемПЗК(МаркетПлейс, Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам),
				УровеньОбработкиДанных, ТаблицаДанных, ИзлишкиТовара, НаполняемостьКоробкиДляШтук, НаполняемостьКоробкиДляПакетов,
				НаполняемостьКоробкиДляКоробов, НаполняемостьКоробкиДляСмешанныхУпаковок,
				ФиксированнаяДатаОтгрузки, ТекстыСообщений, СмещениеПоДатеОтгрузки);
			
			Продолжить
		КонецЕсли;
		
		ВыборкаРезультирующийУровеньГруппировки = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаРезультирующийУровеньГруппировки.Следующий() Цикл
			// Подготовим таблицу данных к новой порции
			ТаблицаДанных.Очистить();
			ИзлишкиТовара.Очистить();
			ОбщийОбъемКоробки = 0;
			
			// Рассчитаем конечный максимальный объем коробки от наполняемости рнк
			РасчетныйМинимальныйОбъемКоробки = Неопределено;
			Если ВыборкаРезультирующийУровеньГруппировки.Упаковка = "Штука" Тогда
				ПриоритетныйОбъемТары = ВыборкаРезультирующийУровеньГруппировки.ПриоритетныйОбъемТары * НаполняемостьКоробкиДляШтук;
				РасчетныйМинимальныйОбъемКоробки = Окр(ПриоритетныйОбъемТары / 100, 3);
			ИначеЕсли ВыборкаРезультирующийУровеньГруппировки.Упаковка = "Пакет" Тогда
				ПриоритетныйОбъемТары = ВыборкаРезультирующийУровеньГруппировки.ПриоритетныйОбъемТары * НаполняемостьКоробкиДляПакетов;
				РасчетныйМинимальныйОбъемКоробки = Окр(ПриоритетныйОбъемТары / 100, 3);
			ИначеЕсли ВыборкаРезультирующийУровеньГруппировки.Упаковка = "КрафтКороб" Тогда
				ПриоритетныйОбъемТары = ВыборкаРезультирующийУровеньГруппировки.ПриоритетныйОбъемТары * НаполняемостьКоробкиДляКоробов;
				РасчетныйМинимальныйОбъемКоробки = Окр(ПриоритетныйОбъемТары / 100, 3);
			ИначеЕсли ВыборкаРезультирующийУровеньГруппировки.Упаковка = "Смешанный" Тогда
				ПриоритетныйОбъемТары = ВыборкаРезультирующийУровеньГруппировки.ПриоритетныйОбъемТары * НаполняемостьКоробкиДляСмешанныхУпаковок;
				РасчетныйМинимальныйОбъемКоробки = Окр(ПриоритетныйОбъемТары / 100, 3);
			КонецЕсли;
			
			// Если не удалось установить вид упаковки, подходящей под функционал, то не учитываем позицию
			Если РасчетныйМинимальныйОбъемКоробки = Неопределено Тогда
				Продолжить
			КонецЕсли;
			
			// Выполним обход по родителю товара - формируем РНК по минимальному объему
			ВыборкаПоРодителю = ВыборкаРезультирующийУровеньГруппировки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоРодителю.Следующий() Цикл
				// Получим детальные записи по товару
				ВыборкаДетальныеЗаписи = ВыборкаПоРодителю.Выбрать();
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					ЗаполнитьЗначенияСвойств(ТаблицаДанных.Добавить(), ВыборкаДетальныеЗаписи);
					
					КоличествоЭкзепляровПоЗаказу = ТаблицаДанных.НайтиСтроки(Новый Структура("РИД", ВыборкаДетальныеЗаписи.РИД)).Количество();
					ОбщийОбъемКоробки = ОбщийОбъемКоробки + ВыборкаДетальныеЗаписи.ОбъемШтуки;
					Если ОбщийОбъемКоробки < РасчетныйМинимальныйОбъемКоробки
						Или ВыборкаДетальныеЗаписи.КоличествоЭкзепляровТоваров > КоличествоЭкзепляровПоЗаказу Тогда
						Продолжить
					КонецЕсли;
					
					МаркетПлейсы_СформироватьДокументыРНК_ЗК(МаркетПлейс, ВыборкаПоРодителю.Склад,
						ВыборкаПоРодителю, ТаблицаДанных, ФиксированнаяДатаОтгрузки,
						ВыборкаРезультирующийУровеньГруппировки.ЗаказПоЮрЛицу, ТекстыСообщений, СмещениеПоДатеОтгрузки);
					
					// Подготовим таблицу данных к новой порции
					ТаблицаДанных.Очистить();
					ОбщийОбъемКоробки = 0
				КонецЦикла;
				
				Если ТаблицаДанных.Количество() = 0 Тогда
					Продолжить
				КонецЕсли;
				
				// Все оставшиеся вне кратности короба товары отправляются в отдельную накладную
				Для каждого СтрокаТаблицыДанных из ТаблицаДанных Цикл
					ЗаполнитьЗначенияСвойств(ИзлишкиТовара.Добавить(), СтрокаТаблицыДанных)
				КонецЦикла;
				
				// Подготовим таблицу данных к новой порции
				ТаблицаДанных.Очистить();
				ОбщийОбъемКоробки = 0
			КонецЦикла;
			
			Если ИзлишкиТовара.Количество() = 0 Тогда
				Продолжить
			КонецЕсли;
			
			Для каждого СтрокаИзлишковТовара из ИзлишкиТовара Цикл
				ЗаполнитьЗначенияСвойств(ТаблицаДанных.Добавить(), СтрокаИзлишковТовара);
				
				КоличествоЭкзепляровПоЗаказу = ТаблицаДанных.НайтиСтроки(Новый Структура("РИД", СтрокаИзлишковТовара.РИД)).Количество();
				ОбщийОбъемКоробки = ОбщийОбъемКоробки + СтрокаИзлишковТовара.ОбъемШтуки;
				Если ОбщийОбъемКоробки < РасчетныйМинимальныйОбъемКоробки
					Или СтрокаИзлишковТовара.КоличествоЭкзепляровТоваров > КоличествоЭкзепляровПоЗаказу Тогда
					Продолжить
				КонецЕсли;
				
				МаркетПлейсы_СформироватьДокументыРНК_ЗК(МаркетПлейс, ВыборкаРезультирующийУровеньГруппировки.Склад,
					ВыборкаРезультирующийУровеньГруппировки, ТаблицаДанных, ФиксированнаяДатаОтгрузки,
					ВыборкаРезультирующийУровеньГруппировки.ЗаказПоЮрЛицу, ТекстыСообщений, СмещениеПоДатеОтгрузки);
				
				// Подготовим таблицу данных к новой порции
				ТаблицаДанных.Очистить();
				ОбщийОбъемКоробки = 0
			КонецЦикла;
			
			Если ТаблицаДанных.Количество() = 0 Тогда
				Продолжить
			КонецЕсли;
			
			МаркетПлейсы_СформироватьДокументыРНК_ЗК(МаркетПлейс, ВыборкаРезультирующийУровеньГруппировки.Склад,
				ВыборкаРезультирующийУровеньГруппировки, ТаблицаДанных, ФиксированнаяДатаОтгрузки,
				ВыборкаРезультирующийУровеньГруппировки.ЗаказПоЮрЛицу, ТекстыСообщений, СмещениеПоДатеОтгрузки);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры // ОбходДанныхПоВыборкеСФормированиемПЗК()
