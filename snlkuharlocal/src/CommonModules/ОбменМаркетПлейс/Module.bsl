Процедура МП_Вайлбериз_ОтменаЗаказовПоВычеркамОфисаИСкладаПоПЗК(Маркетплейс,ВыгрузкаНаСайт=Истина,КоличествоДней=7,ПрефиксМаркета="") Экспорт
	//ID-16465
	//выбираем все заказы ВАЙЛБЕРИЗ за крайние 7 дней
	//проведенные и у которых есть ВЫЧЕРКИ , но не переданы на сайт
	
	КонДата = ТекущаяДата();
	НачДата = КонДата - 86400*КоличествоДней;   //за крайниее 7 дней проверяем
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПредварительныйЗаказКлиентаТовары.Ссылка КАК ДокЗаказ,
	|	ПредварительныйЗаказКлиентаТовары.ВычеркОфис КАК ВычеркОфис,
	|	ПредварительныйЗаказКлиентаТовары.ВычеркСклад КАК ВычеркСклад,
	|	ПредварительныйЗаказКлиентаТовары.ПереданоНаСайт КАК ПереданоНаСайт,
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЛОЖЬ КАК ОтменаНаСайте
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|ГДЕ
	|	ПредварительныйЗаказКлиентаТовары.Ссылка.Проведен
	|	И ПредварительныйЗаказКлиентаТовары.Ссылка.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиентаТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
	|	И (ПредварительныйЗаказКлиентаТовары.ВычеркСклад
	|			ИЛИ ПредварительныйЗаказКлиентаТовары.ВычеркОфис
	|			ИЛИ ПредварительныйЗаказКлиентаТовары.Отменен)
	|	И НЕ ПредварительныйЗаказКлиентаТовары.ПереданоНаСайт";
	
	Запрос.УстановитьПараметр("НачДата",НачДата);// Дата
	Запрос.УстановитьПараметр("КонДата",КонДата);// Дата
	Запрос.УстановитьПараметр("Контрагент",Маркетплейс.Контрагент);// Контрагенты
	
	ТЗЗаказов = Запрос.Выполнить().Выгрузить();
	ВсегоЗаказов = ТЗЗаказов.Количество();
	Если ВсегоЗаказов>0 Тогда
		
		Если Маркетплейс.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Отмена заказов (вычерки) "+Строка(ВсегоЗаказов),"Информация");
		КонецЕсли;
		
		СпрСостояниеУКлиента = Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(24);      //WБ отклонено
		
		//отменим заказы на сайте
		
		
		
		Если ВыгрузкаНаСайт Тогда
			
			МП_Вайлбериз_ОтменаЗаказов(Маркетплейс,ТЗЗаказов,ПрефиксМаркета);
			
		иначе
			
			ТЗЗаказов.ЗаполнитьЗначения(Истина,"ОтменаНаСайте");
			
		КонецЕсли;
		
		ТЗДОКЗАК = ТЗЗаказов.Скопировать(,"ДокЗаказ");
		ТЗДОКЗАК.Свернуть("ДокЗаказ");
		
		//обработаем документ Заказ ФБС
		//передано на сайт и статус Состояние у клиента изменим
		
		Для каждого Док из ТЗДОКЗАК Цикл
			
			Отбор = Новый Структура();
			Отбор.Вставить("ДокЗаказ",Док.ДокЗаказ);
			Отбор.Вставить("ОтменаНаСайте",Истина); 		
			
			СтрокиЗаказов  = ТЗЗаказов.НайтиСтроки(Отбор);
			Если СтрокиЗаказов.Количество() > 0 Тогда
				
				ОбЗаказ = Док.ДокЗаказ.ПолучитьОбъект();
				
				для каждого НайдЗаказ из СтрокиЗаказов Цикл
					
					ОтборЗак = Новый Структура();
					ОтборЗак.Вставить("НомерЗаказа",НайдЗаказ.НомерЗаказа);
					СтЗаказов  = ОбЗаказ.Товары.НайтиСтроки(ОтборЗак);
					
					Если СтЗаказов.Количество() > 0 Тогда
						
						Для Каждого СтрЗак из СтЗаказов Цикл
							СтрЗак.ПереданоНаСайт    = Истина;
							СтрЗак.СостояниеУКлиента = СпрСостояниеУКлиента;
							СтрЗак.Количество        = 0; //обнуляем
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			
			Если ОбЗаказ<>Неопределено и ОбЗаказ.Модифицированность() Тогда
				
				Попытка
					ОбЗаказ.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					ОбЗаказ.Записать(РежимЗаписиДокумента.Запись);
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Маркетплейс.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Конец отмены заказов (вычерки) ","Информация");
		КонецЕсли;		
	КонецЕсли;   	
	
КонецПроцедуры
// Ихсанов Д. А. Конец 03.09.2025

// Ихсанов Д. А. Начало 01.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482 ЛЕГАСИ ЗАГОЛОВОК ++ УБРАТЬ
// Сформировать предварительный заказ клиента.
// 
// Параметры:
//  МаркетПлейс - СправочникОбъект.ИнетМагазины, Неопределено, СправочникСсылка.ИнетМагазины - Маркет плейс
//  СкладОтгрузки - СправочникСсылка.Склады - Склад отгрузки
//  СкладРезерва - СправочникСсылка.Склады - Склад резерва
//  ТЗССАЙТА - ДеревоЗначений, ТаблицаЗначений - ТЗССАЙТА
//  ТЗДляДок - ТаблицаЗначений, ДеревоЗначений - ТЗДля док:
// * Номенклатура - СправочникСсылка.Номенклатура
// * КолКонФакт - Число
//  НужнаМаркировка - Булево - Нужна маркировка
//  ЛимитПозиций - Число - Лимит позиций
//  СостояниеНакладной - ПеречислениеСсылка.СостоянияНакладной - Состояние накладной
//  Сектор - Строка
//  ПереносОтгрузки - Произвольный, Число - Перенос отгрузки
//  ОтгрузкаКомплектов - Булево - Отгрузка комплектов
//  МоеОповещение - Строка - Мое оповещение
//  ДатаОтгрузки - Неопределено - Дата отгрузки
// 
// Возвращаемое значение:
//  Неопределено, ДокументСсылка.ПредварительныйЗаказКлиента - Сформировать предварительный заказ клиента
//@skip-check method-too-many-params
//@skip-check method-optional-parameter-before-required
Функция СформироватьПредварительныйЗаказКлиента(МаркетПлейс, СкладОтгрузки, СкладРезерва, ТЗССАЙТА, ТЗДляДок, НужнаМаркировка,
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	ЛимитПозиций = 0, СостояниеНакладной, Сектор, ПереносОтгрузки, ОтгрузкаКомплектов, МоеОповещение, ДатаОтгрузки = Неопределено) Экспорт
	// Ихсанов Д. А. Конец  17.03.2025
	
	Попытка
		Если ТЗДляДок.Количество() = 0 Или ТЗДляДок.Итог("КолКонФакт") = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
	Исключение
		ЗаписатьВЛог("МП_Вайлберриз", "Пустая таблица проверить кэш", "Ошибка");
	КонецПопытки;
	
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	ОтборПоНомеруЗаказа = Ложь;
	Если ТЗДляДок.Колонки.Найти("НомерЗаказа") <> Неопределено Тогда
		ОтборПоНомеруЗаказа = Истина;
	КонецЕсли;
	// Ихсанов Д. А. Конец  17.03.2025
	
	ОтгрузкаКомплектов = Ложь;
	ТекущаяДата = ТекущаяДатаСеанса();
	СекундВДне = 86400;
	
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	КомлектыСОстатком = Новый Массив;
	// Ихсанов Д. А. Конец  17.03.2025
	
	// Ихсанов Д. А. Начало 19.05.2026 Наряд 0000000149 от 19.05.2026 12:15:38: e1cib/data/Документ.Наряд?ref=89690050568f680711f153634c38036e
	Если ДатаОтгрузки = Неопределено Тогда
		ДатаОтгрузки = НачалоДня(ТекущаяДата) + СекундВДне * ПереносОтгрузки;
	КонецЕсли;
	// Ихсанов Д. А. Конец 19.05.2026
	
	РеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, "Контрагент, Договор, ПунктДоставки, Тест");
	
	ДокументОбъектПЗК = Документы.ПредварительныйЗаказКлиента.СоздатьДокумент();
	ДокументОбъектПЗК.Дата				  = ТекущаяДата;
	ДокументОбъектПЗК.Склад				  = СкладОтгрузки;
	ДокументОбъектПЗК.СкладПолучатель	  = СкладРезерва;
	ДокументОбъектПЗК.Контрагент		  = РеквизитыМаркетПлейс.Контрагент;
	ДокументОбъектПЗК.ДатаОтгрузки		  = ДатаОтгрузки;
	ДокументОбъектПЗК.Комментарий		  = Сектор;
	ДокументОбъектПЗК.Договор			  = РеквизитыМаркетПлейс.Договор;
	ДокументОбъектПЗК.ПунктДоставки		  = РеквизитыМаркетПлейс.ПунктДоставки;
	ДокументОбъектПЗК.ТребуетсяМаркировка = НужнаМаркировка;
	
	Для каждого ДанныеСтрокиДляДокумента из ТЗДляДок Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Номенклатура", ДанныеСтрокиДляДокумента.Номенклатура);
		// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
		Если ОтборПоНомеруЗаказа Тогда
			ПараметрыОтбора.Вставить("РИД", ДанныеСтрокиДляДокумента.НомерЗаказа);
		КонецЕсли;
		// Ихсанов Д. А. Конец  17.03.2025
		
		НайденныеСтроки = ТЗССАЙТА.НайтиСтроки(ПараметрыОтбора);
		Для каждого СтрокаЗаказаССайта из НайденныеСтроки Цикл
			Если СтрокаЗаказаССайта.Комплект
				И СтрокаЗаказаССайта.КоличествоОстаток > 0 Тогда
				КомлектыСОстатком.Добавить(СтрокаЗаказаССайта.Номенклатура)
			ИначеЕсли СтрокаЗаказаССайта.Комплект Тогда
				ОтгрузкаКомплектов = Истина
			КонецЕсли;
			
			НоваяСтрока = ДокументОбъектПЗК.Товары.Добавить();
			НоваяСтрока.Номенклатура		 = СтрокаЗаказаССайта.Номенклатура;
			НоваяСтрока.Количество			 = СтрокаЗаказаССайта.Количество;
			НоваяСтрока.Цена				 = СтрокаЗаказаССайта.СуммаЗак;
			НоваяСтрока.Всего				 = СтрокаЗаказаССайта.СуммаЗак;
			НоваяСтрока.ПодтвержденнаяЗаявка = СтрокаЗаказаССайта.Количество;
			НоваяСтрока.Заявка				 = СтрокаЗаказаССайта.Количество;
			НоваяСтрока.ТребуетсяМаркировка	 = НужнаМаркировка;
			НоваяСтрока.НомерЗаказа			 = СтрокаЗаказаССайта.ИДЗаказа;
			НоваяСтрока.РИД					 = СтрокаЗаказаССайта.РИД;
			НоваяСтрока.ШтрихКод			 = СтрокаЗаказаССайта.ШтрихКод; // Ихсанов Д. А. 28.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7646
			НоваяСтрока.СостояниеУКлиента	 = СтрокаЗаказаССайта.СостояниеУКлиента; // Ихсанов Д. А. 06.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7648
			НоваяСтрока.ЗаказПоЮрЛицу		 = СтрокаЗаказаССайта.ЗаказПоЮрЛицу; // Ихсанов Д. А. 07.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7714
			НоваяСтрока.ДатаЗаказа			 = СтрокаЗаказаССайта.ДатаСоздания;
			// Ихсанов Д. А. Начало 12.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8604
			НоваяСтрока.СтавкаНДС			 = ПолучитьРеквизитРодителя(СтрокаЗаказаССайта.Номенклатура, "СтавкаНДС");
			// Ихсанов Д. А. Конец 12.02.2026
			НоваяСтрока.Сумма				 = СтрокаЗаказаССайта.СуммаЗак;
			НоваяСтрока.АртикулКонтрагента	 = СтрокаЗаказаССайта.АртКонтра;
			
			ТЗССАЙТА.Удалить(СтрокаЗаказаССайта);
		КонецЦикла;
	КонецЦикла;
	
	ДокументОбъектПЗК.ОтгрузкаКомплектов = ОтгрузкаКомплектов;
	Если ОтгрузкаКомплектов Тогда
		ЗаполнитьКомплектующие(ДокументОбъектПЗК, КомлектыСОстатком);
	КонецЕсли;
	
	Попытка
		ДокументОбъектПЗК.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Если РеквизитыМаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз", СтрШаблон("Не удалось провести документ %1", ДокументОбъектПЗК), "Ошибка")
		КонецЕсли;
		
		ДокументОбъектПЗК.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;
	
	Возврат ДокументОбъектПЗК.Ссылка;
	
КонецФункции // СформироватьПредварительныйЗаказКлиента()
// Ихсанов Д. А. Конец 01.09.2025

#КонецОбласти // МП_РВБ_НовыйФункционал

Процедура КонтрольЗагрузкиВБрз(ТаблицаПараметров=Неопределено) Экспорт
	
	//Тимофеев Ю.А. 19.09.2023
	
	СтруктураМагазина=Новый Структура;
	СтруктураМагазина.Вставить("Код","00001");                                      //Код Валбериз
	СтруктураМагазина.Вставить("ИмяПроцедуры","КонтрольЗагрузкиВБрз");   	        //Название процедуры
	Ответ=ПроверкаРазрешенияНаЗапускРегламентногоЗадания(СтруктураМагазина);
	
	Если Не Ответ Тогда
		ЗаписатьВЛог("МП_Вайлберриз","Отмена выполнения. Задача: Загрузка заказов Вайлдбериз. В фоне работает другая задача !","Информация");		
		Возврат;   
	КонецЕсли;     	
	
	//Тимофеев Ю.А. 19.09.2023 
	
	
	СтрокаСоединенияСразрешеннымОбменом	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения					=ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом Тогда	
		ЗаписатьВЛог("МП_Вайлберриз","Отмена выполнения. Задача: Загрузка заказов Вайлдбериз. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");		
		Возврат;
	КонецЕсли;
	
	
	//Тимофеев Ю.А. 05.03.2024
	//подмена запуска штатного способа
	
	ШтатныйСпособ=Истина;
	ЕстьСтатус   = "";
	
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("КодМаркетплейса","00001");  //Код Валбериз
	СтруктураПараметров.Вставить("ОграничительЧаса",0);       //если больше 0, то РНК с меньшим количеством номенклатуры будет пропущена до следующей загрузки.
	СтруктураПараметров.Вставить("ЧасНагрузки",18);           //снятие всех ограничений по количеству загрузки
	СтруктураПараметров.Вставить("ИнтеграторЧаса",1);         //если 1 то каждый час, 2 каждый второй час, 3 каждый третией час будет выполняться условие
	СтруктураПараметров.Вставить("МаксЗаказов",1500);         //если 0 то все , есби >0 то указананое количество
	
	СтруктураПараметров.Вставить("МаркировкаВсе",Ложь);       //если ИСТИНА , считаем что весь товар подлежит МАРКИРОВКЕ
	СтруктураПараметров.Вставить("ДваСклада",    Ложь);       //если ИСТИНА , распределяем по склада ФБС и МАРКИРОВКА
	СтруктураПараметров.Вставить("КонтрольЗаписи",Ложь);      //если ИСТИНА , запишем кэш заказов (на время тестирования
	СтруктураПараметров.Вставить("ЛимитПоСекторам",Ложь);     //есои Истина , то записываем лимиты по секторам
	
	
	//Тимофеев Ю.А. Начало   25-12-2024  ASU-1891
	//
	//Перенос ДАТЫ ОТГРУЗКИ на указанное количество ДНЕЙ - параметр вовзращает количество ДНЕЙ
	СтруктураПараметров.Вставить("ПереносОтгрузки",1);         //если 0 то все , есби >0 то указананое количество
	//Тимофеев Ю.А. Конец    25-12-2024 ASU-1891
	
	
	Если ТаблицаПараметров<>Неопределено Тогда
		//так иногда бывает
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "МаркировкаВсе" Тогда			
				СтруктураПараметров.Вставить("МаркировкаВсе",СтрокаТП.Значение); 
			КонецЕсли;
			
			Если СтрокаТП.Имя = "ДваСклада" Тогда			
				СтруктураПараметров.Вставить("ДваСклада",СтрокаТП.Значение); 
			КонецЕсли;
			
			Если СтрокаТП.Имя = "КонтрольЗаписи" Тогда			
				СтруктураПараметров.Вставить("КонтрольЗаписи",СтрокаТП.Значение);
			КонецЕсли;
			
			
			Если СтрокаТП.Имя = "ОграничительЧаса" Тогда			
				СтруктураПараметров.Вставить("ОграничительЧаса",СтрокаТП.Значение); 
			КонецЕсли;
			
			Если СтрокаТП.Имя = "ЧасНагрузки" Тогда			
				СтруктураПараметров.Вставить("ЧасНагрузки",СтрокаТП.Значение); 
			КонецЕсли;
			
			
			Если СтрокаТП.Имя = "ИнтеграторЧаса" Тогда			
				СтруктураПараметров.Вставить("ИнтеграторЧаса",СтрокаТП.Значение); 
			КонецЕсли;
			
			Если СтрокаТП.Имя = "МаксЗаказов" Тогда			
				СтруктураПараметров.Вставить("МаксЗаказов",СтрокаТП.Значение); 
			КонецЕсли;          
			
			Если СтрокаТП.Имя = "ЛимитПоСекторам" Тогда			
				СтруктураПараметров.Вставить("ЛимитПоСекторам",СтрокаТП.Значение); 
			КонецЕсли;
			
			// Ихсанов Д. А. Начало 19.05.2026 Наряд 0000000149 от 19.05.2026 12:15:38: e1cib/data/Документ.Наряд?ref=89690050568f680711f153634c38036e
			////Тимофеев Ю.А. Начало   25-12-2024  ASU-1891
			////
			////Перенос ДАТЫ ОТГРУЗКИ на указанное количество ДНЕЙ - параметр вовзращает количество ДНЕЙ
			////в поле         Имя            Значение     Комментарий
			////          ПереносОтгрузки  |  31.12.24   |  3   
			//
			//Если СтрокаТП.Имя = "ПереносОтгрузки" и НачалоДня(ТекущаяДатаСеанса())=СтрокаТП.Значение Тогда
			//	
			//	Попытка
			//		СколькоДней = Число(СтрокаТП.Комментарий);
			//	Исключение
			//		СколькоДней =1;
			//	КонецПопытки;     		
			//	
			//	СтруктураПараметров.Вставить("ПереносОтгрузки",СколькоДней); 
			//	
			//КонецЕсли;
			//
			////Тимофеев Ю.А. Конец    25-12-2024  ASU-1891
			Если СтрокаТП.Имя = "ПереносОтгрузки" Тогда
				// Ихсанов Д. А. Начало 22.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
				//СтруктураПараметров.Вставить("ПереносОтгрузки", СтрокаТП.Значение);
				СтруктураПараметров.Вставить("ПереносОтгрузки", ?(Час(ТекущаяДатаСеанса()) <= 13, СтрокаТП.Значение - 1, СтрокаТП.Значение));
				// Ихсанов Д. А. Конец 22.06.2026
			КонецЕсли;
			// Ихсанов Д. А. Конец 19.05.2026
			
			//Если СтрокаТП.Имя = "ТабДемо" Тогда			
			//	СтруктураПараметров.Вставить("ТабДемо",СтрокаТП.Значение); 
			//КонецЕсли;
			
			// Ихсанов Д. А. Начало 02.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2508
			Если СтрокаТП.Имя = "ПредварительныйЗаказКлиента" Тогда
				СтруктураПараметров.Вставить("ПредварительныйЗаказКлиента", СтрокаТП.Значение)
			КонецЕсли;
			// Ихсанов Д. А. Конец 02.09.2025
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 22.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2508
	Если СтруктураПараметров.Свойство("ПредварительныйЗаказКлиента")
		И СтруктураПараметров.ПредварительныйЗаказКлиента Тогда
		МП_Вайлберриз_ПолучитьОбработатьЗаказыССайтаЧерезПЗК(,,,СтруктураПараметров);
		
		// Ихсанов Д. А. Начало 09.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7802
		ВыполнитьРебалансировкуПредварительныхЗаказовКлиента("00001", ТаблицаПараметров);
		МаркетПлейсы_ПроведениеНепроведенныхПЗК("00001");
		// Ихсанов Д. А. Конец 09.12.2025
	Иначе
		МП_Вайлберриз_ПолучитьОбработатьЗаказыССайта(,,,СтруктураПараметров)
	КонецЕсли;
	// Ихсанов Д. А. Конец 22.09.2025
	
КонецПроцедуры

