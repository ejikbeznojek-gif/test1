Процедура ДобавитьКоличествоПоСектору(МаркетПлейс,ТЗлимитпоСекторам)Экспорт
	
	ПутьИмяФайла = МаркетПлейс.КаталогДляЭтикеток+"SektorXan.txt"; 
	
	ФайлТЗ = Новый Файл(ПутьИмяФайла); 
	
	ПрефиксМаркета=ПрефМаркет(МаркетПлейс);
	
	Если ФайлТЗ.Существует() Тогда
		
		ТЗПоСекторам = ЗначениеИзФайла(ПутьИмяФайла); 
		ДатаПроверки = НачалоДня(ТекущаяДатаСеанса());	 
		
		Если ТипЗнч(ТЗПоСекторам) = Тип("ТаблицаЗначений") Тогда 			
			
			//нужно обнулить, иначе не будет выгрузки
			Для каждого СтрСектор из ТЗПоСекторам Цикл
				
				Если ДатаПроверки> НачалоДня(СтрСектор.ДатаПроверки) Тогда 
					СтрСектор.Факт         = 0; 
					СтрСектор.ДатаПроверки = ДатаПроверки;  
				КонецЕсли;
				
			КонецЦикла;  		
			
			Для каждого СтрСектор из ТЗлимитпоСекторам Цикл
				
				ПоискСектора =ТЗПоСекторам.Найти(СтрСектор.СекторХранения,"СекторХранения");				
				
				Если ПоискСектора=Неопределено Тогда
					НовСТр = ТЗПоСекторам.Добавить();
					НовСтр.СекторХранения =СтрСектор.СекторХранения;
					НовСтр.Факт =  СтрСектор.Факт; 
					НовСтр.ДатаПроверки = ТекущаяДатаСеанса();
				Иначе	 
					Если ДатаПроверки> ПоискСектора.ДатаПроверки Тогда 
						ПоискСектора.Факт         = СтрСектор.Факт; 
						ПоискСектора.ДатаПроверки = ТекущаяДатаСеанса();  
					Иначе  
						ПоискСектора.Факт         = ПоискСектора.Факт+ СтрСектор.Факт; 
						ПоискСектора.ДатаПроверки = ТекущаяДатаСеанса();
					КонецЕсли;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли; 
		
		ЗначениеВФайл(ПутьИмяФайла, ТЗПоСекторам);
		
		ЗаписатьВЛог("МП_Сектора",ПрефиксМаркета+" Сектора хранений сохранены "+Строка(ТЗПоСекторам.Итог("Факт")),"Информация");
		
	КонецЕсли;		
	
КонецПроцедуры

Функция МП_Вайлберриз_Связка_ЗАКАЗ_РНК(МаркетПлейс,СкладОтгрузки,ТЗССАЙТА,ТЗДляДок,НужнаМаркировка,ЛимитПозиций=0,СостояниеНакладной,Сектор,ПереносОтгрузки,ОтгрузкаКомплектов,МоеОповещение) Экспорт
	
