	HTTP_запрос.Заголовки    = ЗаголовокHTTP;  
	
	HTTP_запрос.АдресРесурса = "api/v3/orders/"+НомЗак+"/meta";  
	
	
	ОтветЗапроса = Соединение.Получить(HTTP_запрос); 
	
	Если ОтветЗапроса.КодСостояния < 400 Тогда
		
		ВозвСтр0 = ОтветЗапроса.ПолучитьТелоКакСтроку();
		
		ЧтениеJSON0       = Новый ЧтениеJSON;
		ЧтениеJSON0.УстановитьСтроку(ВозвСтр0);
		СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);  
		
		Попытка
			
			Мета = СтруктураИзСтроки.meta;
			
			Если Мета.Свойство("sgtin") Тогда 
				
				Джейтин = Мета.sgtin;
				
				Если Джейтин.Свойство("value") Тогда
					
					Сообщить(НомЗак);
					
					Если Джейтин.value=Неопределено Тогда
						
						Возврат Ложь;
					Иначе
						//маркирока есть 
						
						#Если Клиент Тогда
							Сообщить("Заказ "+Строка(НомЗак)+" датаматрикс :"+Джейтин.value[0]);
						#КонецЕсли   
						
						Возврат Истина;
						
					КонецЕсли;      
					
				КонецЕсли;	        				     				
			Иначе 				
				Возврат Ложь;
			КонецЕсли;		
			
		Исключение
			#Если Клиент Тогда
				Сообщить("Ошибка при попытке соединения "+ОписаниеОшибки());
			#КонецЕсли   
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

