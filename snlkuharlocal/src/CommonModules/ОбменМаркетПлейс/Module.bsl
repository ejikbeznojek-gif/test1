Процедура МП_ОЗОН_переводЗаказаВДругойСтатус(Маркетплейс,НомерОтправления,ТЗДАННЫХ,СкачатьЭтикетку=Истина,ДляТеста=ЛОжь) Экспорт
	
	//переводит его в статус awaiting_deliver и если нужно качает этикетку
	
	Команда = "/v4/posting/fbs/ship";
	
	СтрЗапроса = МП_ОЗОН_ВернутьСтруктуруДляSHIP(НомерОтправления, ТЗДАННЫХ);
	
	Ответ           = POSTЗапросИз1С_ДжС(Маркетплейс,Команда,СтрЗапроса); 
	ЧтениеJSON      = Новый ЧтениеJSON;
	ОтветСтрокой    = Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON.УстановитьСтроку(ОтветСтрокой); 	
	
	Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); 
	
	Если Ответ.КодСостояния<=400 Тогда
		
		Если данные.свойство("result") Тогда
			
			
			Если МаркетПлейс.Тест Тогда
				ЗаписатьВЛог("МП_ОЗОН","Заказ "+Строка(НомерОтправления)+" переведен в статус awaiting_deliver" ,"Информация");  
			КонецЕсли;
			
			МП_ОЗОН_СМЕНА_статусаЗаказа(Маркетплейс,НомерОтправления);
			Если СкачатьЭтикетку Тогда
				//загрузим этикетку  в фоновом задании
				//из листа набора по запросу
				СформироватьЭтикеткуОзонПоНомеруЗаказа(Маркетплейс.Контрагент,Маркетплейс,НомерОтправления); 
				
			КонецЕсли;
		Иначе
			
			Если МаркетПлейс.Тест Тогда
				Если ДляТеста Тогда
					
					ЗаписатьВЛог("МП_ОЗОН","Заказ "+Строка(НомерОтправления)+" ОТПРАВЛЕН в статус awaiting_deliver" + ОтветСтрокой ,"Информация");		
				Иначе
					
					ЗаписатьВЛог("МП_ОЗОН","Заказ сборка "+Строка(НомерОтправления)+" " + ОтветСтрокой +" "+Строка(Ответ.КодСостояния),"Информация");
					
				КонецЕсли;				
			КонецЕсли;
			
			
						
			МП_ОЗОН_СМЕНА_статусаЗаказа(Маркетплейс,НомерОтправления);
			
			Если СкачатьЭтикетку Тогда
				//загрузим этикетку  в фоновом задании
				//из листа набора по запросу
				СформироватьЭтикеткуОзонПоНомеруЗаказа(Маркетплейс.Контрагент,Маркетплейс,НомерОтправления); 
				
			КонецЕсли;
			
		КонецЕсли;
		
		
	Иначе   
		
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН","Заказ "+Строка(НомерОтправления)+" не переведен " +ОтветСтрокой+" "+Строка(Ответ.КодСостояния),"Информация");	
		КонецЕсли;
    		
	КонецЕсли; 
	
КонецПроцедуры

Процедура МП_ОЗОН_СМЕНА_статусаЗаказа(Маркетплейс,НомерОтправления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказFBS
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа = &НомерЗаказа
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата >= &ДатаПоиска
	|	И ЗаказКлиентаFBSТовары.Ссылка.Проведен";
	//Параметры запроса
	Запрос.УстановитьПараметр("НомерЗаказа",НомерОтправления);
	Запрос.УстановитьПараметр("Контрагент",Маркетплейс.Контрагент);
	Запрос.УстановитьПараметр("ДатаПоиска",НачалоГода(ТекущаяДата()));
	
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		
		ОжиданиеДоставки = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("awaiting_deliver");	
		
		ЗаказFBSОбъект = Результат.ЗаказFBS.ПолучитьОбъект();
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("НомерЗаказа", НомерОтправления);
		НайденныеСтроки = ЗаказFBSОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
		
		для каждого СтрТЧ из НайденныеСтроки цикл
			СтрТЧ.СостояниеУКлиента=ОжиданиеДоставки;
		КонецЦикла;
		ЗаказFBSОбъект.Записать();  
		
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН","Смена статуса заказа "+Строка(НомерОтправления),"Информация");  
		КонецЕсли;

		
	КонецЕсли;
	
КонецПроцедуры

Функция МП_ОЗОН_ПроверкаСтатусаЗаказаСМаркировкой(МаркетПлейс, НомерОтправления) Экспорт
	
	// Актуализация функционала получения статуса по заказам
	// Ихсанов Д. А. Начало 11.12.2025 Без номера задачи
	// 5-я версия метода
	СообщениеОбОшибке = "";
	
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("posting_number", НомерОтправления);
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON);
	ПараметрыОбработки.ДанныеЗапроса.Метод = "POST";
	ПараметрыОбработки.ИменаСвойствОшибок = "code";
	ПараметрыОбработки.ЗначенияСвойствОшибок = "0";
	
	ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
		ОбменМаркетПлейс.МП_Озон_ВернутьСоединение(МаркетПлейс),
		ОбменМаркетПлейс.ПолучитьЗаголовкиОзон(МаркетПлейс),
		"/v5/fbs/posting/product/exemplar/status",
		ПараметрыОбработки, Ложь, Ложь);
	Если Не ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки) Тогда
		СообщениеДляПользователя = СтрШаблон("Невозможно получить данные по заказу %1. По причине: %2.",
			НомерОтправления, СообщениеОбОшибке);
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН", СообщениеДляПользователя, "Информация"); 
		КонецЕсли;
		СообщитьИзМодуля(СообщениеДляПользователя);
		
		Возврат Ложь
	КонецЕсли;
	
	Если Не ДанныеОтвета.Свойство("status") Тогда
		Возврат Ложь
	КонецЕсли;
	
	Если ДанныеОтвета.status = "ship_available" Или ДанныеОтвета.status = "update_available" Тогда
		СообщениеДляПользователя = СтрШаблон("Заказ %1 готов к сборке.", НомерОтправления);
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН", СообщениеДляПользователя, "Информация"); 
		КонецЕсли;
		СообщитьИзМодуля(СообщениеДляПользователя);
		
		Возврат Истина
	ИначеЕсли ДанныеОтвета.status = "validation_in_process" Тогда
		СообщениеДляПользователя = СтрШаблон("Заказ %1 ожидает привязки марок. Повторите запрос позднее.", НомерОтправления);
		Если МаркетПлейс.Тест Тогда
			ЗаписатьВЛог("МП_ОЗОН", СообщениеДляПользователя, "Информация"); 
		КонецЕсли;
		СообщитьИзМодуля(СообщениеДляПользователя);
		
		Возврат Ложь
	КонецЕсли;
	
	СообщениеДляПользователя = СтрШаблон("Заказ %1 не готов к сборке. Повторите запрос позднее.", НомерОтправления);
	Если МаркетПлейс.Тест Тогда
		ЗаписатьВЛог("МП_ОЗОН", СообщениеДляПользователя, "Информация"); 
	КонецЕсли;
	СообщитьИзМодуля(СообщениеДляПользователя);
	
	Возврат Ложь
	// Ихсанов Д. А. Конец 11.12.2025
	
КонецФункции

Процедура МП_Озон_РазбитьЗаказНаЧасти(ДанныеМаркетПлейса, СтрокаМассива) Экспорт	
	
