// Процедура - Получить данные по статусам заказов
// Получает даннные о текущем статусе заказа в модели сервиса.
// Нужно для более точного определения текущей ситуации по заказу.
// Данные по статусам складываются в параметр СоответствиеЗаказаКСтатусу
//
// Параметры:
//  СоответствиеЗаказаКСтатусу	 - Соответствие	 - Дополняемое соответствие заказов и статусов
//  МассивЗаказов				 - Массив		 - Список номеров заказов
//
Процедура ПолучитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов, //РевизитыМаркетПлейса, ...)
	РевизитыМаркетПлейса, СтатусыПродано)
	
	Если РевизитыМаркетПлейса.Код = "00001"
		Или РевизитыМаркетПлейса.Код = "00009" Тогда
		Вайлдберриес_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов,
			РевизитыМаркетПлейса, СтатусыПродано);
	// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
	ИначеЕсли РевизитыМаркетПлейса.Код = "00002" Тогда
		Озон_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов,
			РевизитыМаркетПлейса, СтатусыПродано);
	ИначеЕсли РевизитыМаркетПлейса.Код = "00004" Тогда
		ЯндексМаркет_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов,
			РевизитыМаркетПлейса, СтатусыПродано);
	ИначеЕсли РевизитыМаркетПлейса.Код = "00014" Тогда
		МагнитМаркет_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов,
			РевизитыМаркетПлейса, СтатусыПродано);
	// Ихсанов Д. А. Конец 02.07.2026
	Иначе
		МаркетПлейсы_ЗаглушкаПроверкиДанныхПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов);
	КонецЕсли;
	
КонецПроцедуры // ПолучитьДанныеПоСтатусамЗаказов()

// Процедура - Вайлдберриес загрузить данные по статусам заказов
//
// Параметры:
//  СоответствиеЗаказаКСтатусу	 - Соответствие	 - Дополняемое соответствие заказов и статусов
//  МассивЗаказов				 - Массив		 - Список номеров заказов
//
Процедура Вайлдберриес_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов, // РевизитыМаркетПлейса, ...)
	РевизитыМаркетПлейса, СтатусыПродано)
	
	ДополнительныеПараметры = КоннекторHTTP.НовыеПараметры();
	ДополнительныеПараметры.Заголовки = МП_Вайлберриз_ВернутьЗаголовкиHTTP(РевизитыМаркетПлейса);
	ДополнительныеПараметры.ПараметрыПреобразованияJSON.ПрочитатьВСоответствие = Ложь;
	
	ДополнительныеПараметры.Json = Новый Структура;
	ДополнительныеПараметры.Json.Вставить("orders", МассивЗаказов);
	
	СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1%2", РевизитыМаркетПлейса.Host,
			"/api/v3/orders/status"),, ДополнительныеПараметры);
	ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета, ДополнительныеПараметры.ПараметрыПреобразованияJSON);
	// Обработка ошибок со стороны сервиса
	Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
		Или СтруктураДанныхОтвета.КодСостояния >= 400 Тогда
		Если СтруктураДанныхОтвета.КодСостояния = 429 Тогда
			ОбменМаркетПлейс.НужнаПауза(Число(СтруктураДанныхОтвета.Заголовки["X-Ratelimit-Retry"]) + 2);
		КонецЕсли;
		
		СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1%2", РевизитыМаркетПлейса.Host,
				"/api/v3/orders/status"),, ДополнительныеПараметры);
		ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета, ДополнительныеПараметры.ПараметрыПреобразованияJSON);
		
		ВызватьИсключение "Ошибка получения данных по заказам";
	КонецЕсли;
	
	Для каждого ДанныеПоЗаказу из ДанныеОтвета.orders Цикл
		Если СтатусыПродано[ДанныеПоЗаказу.wbStatus] <> Истина Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствиеЗаказаКСтатусу.Вставить(ДанныеПоЗаказу.id, ДанныеПоЗаказу.wbStatus);
	КонецЦикла;
	
КонецПроцедуры // Вайлдберриес_ЗагрузитьДанныеПоСтатусамЗаказов()

// Ихсанов Д. А. Начало 02.07.2026 Изменение 0000000188 от 16.06.2026 12:31:15: e1cib/data/Документ.Изменение?ref=89690050568f680711f169661e865f83
Процедура ЯндексМаркет_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов, // РевизитыМаркетПлейса, ...)
	РевизитыМаркетПлейса, СтатусыПродано)
	
	ДополнительныеПараметры = КоннекторHTTP.НовыеПараметры();
	ДополнительныеПараметры.Заголовки = МП_Яндекс_ВернутьЗаголовкиHTTP(РевизитыМаркетПлейса);
	ДополнительныеПараметры.ПараметрыПреобразованияJSON.ПрочитатьВСоответствие = Ложь;
	
	ДополнительныеПараметры.ПараметрыЗапроса = Новый Структура;
	ДополнительныеПараметры.ПараметрыЗапроса.Вставить("limit", МассивЗаказов.Количество());
	ДополнительныеПараметры.ПараметрыЗапроса.Вставить("page_token", "");
	
	ДополнительныеПараметры.Json = Новый Структура;
	ДополнительныеПараметры.Json.Вставить("programTypes", Новый Массив);
	ДополнительныеПараметры.Json.programTypes.Добавить("FBS");
	ДополнительныеПараметры.Json.Вставить("campaignIds", Новый Массив);
	ДополнительныеПараметры.Json.campaignIds.Добавить(РевизитыМаркетПлейса.ИДКомпании);
	ДополнительныеПараметры.Json.Вставить("orderIds", МассивЗаказов);
	ДополнительныеПараметры.Json.Вставить("fake", Ложь);
	
	СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1%2", РевизитыМаркетПлейса.Host,
			Обработки.МП_ММ_ЯндексМаркет.МП_АдресЗапроса_СписокЗаказов(РевизитыМаркетПлейса.WarehouseId)),,
				ДополнительныеПараметры);
	ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета, ДополнительныеПараметры.ПараметрыПреобразованияJSON);
	// Обработка ошибок со стороны сервиса
	Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
		Или СтруктураДанныхОтвета.КодСостояния >= 400 Тогда
		ВызватьИсключение "Ошибка получения данных по заказам";
	КонецЕсли;
	
	Для каждого ДанныеПоЗаказу из ДанныеОтвета.orders Цикл
		Если СтатусыПродано[ДанныеПоЗаказу.status] <> Истина Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствиеЗаказаКСтатусу.Вставить(ДанныеПоЗаказу.orderId, ДанныеПоЗаказу.status);
	КонецЦикла;
	
КонецПроцедуры // ЯндексМаркет_ЗагрузитьДанныеПоСтатусамЗаказов()

Процедура Озон_ЗагрузитьДанныеПоСтатусамЗаказов(СоответствиеЗаказаКСтатусу, МассивЗаказов, // РевизитыМаркетПлейса, ...)
	РевизитыМаркетПлейса, СтатусыПродано)
	
