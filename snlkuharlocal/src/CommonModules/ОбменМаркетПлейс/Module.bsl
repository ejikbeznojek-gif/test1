//  Контрагент		 - СправочникСсылка.Контрагенты		 - Ссылка на контрагента по документу
//
Процедура ОткатитьЭкземплярТовараКПредварительномуЗаказуКлиента(НомераЗаказов, ЗаказКлиентаFBS, Контрагент) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	СмещениеПоИндексу = 1;
	
	МаркетПлейс = Справочники.ИнетМагазины.НайтиПоРеквизиту("Контрагент", Контрагент);
	
	// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
	//РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс,
	//	"Договор, ПунктДоставки, Склад, СкладМаркировки");
	РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, КлючевыеИменаРеквизитовМаркетплейса());
	
	ИмяПоляСНомеромЗаказа = "НомерЗаказа";
	Если РеквизитыМаркетПлейса.ВозможныМногоместныеЗаказы Тогда
		ИмяПоляСНомеромЗаказа = "РИД";
	КонецЕсли;
	// Ихсанов Д. А. Конец 07.07.2026
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ПредварительныйЗаказКлиента.Ссылка КАК Ссылка,
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента КАК ПредварительныйЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО ПредварительныйЗаказКлиента.Ссылка = ПредварительныйЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	ПредварительныйЗаказКлиента.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиента.Договор = &Договор
	|	И ПредварительныйЗаказКлиента.ПунктДоставки = &ПунктДоставки
	|	И ПредварительныйЗаказКлиентаТовары.НомерЗаказа В(&НомераЗаказов)
	|ИТОГИ ПО
	|	Ссылка");
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Договор", РеквизитыМаркетПлейса.Договор);
	Запрос.УстановитьПараметр("ПунктДоставки", РеквизитыМаркетПлейса.ПунктДоставки);
	Запрос.УстановитьПараметр("НомераЗаказов", НомераЗаказов);
	
	ДокументОбъектПредварительныйЗаказКлиента_Новый = Документы.ПредварительныйЗаказКлиента.ПустаяСсылка();
	
	НачатьТранзакцию();
	Попытка
		// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
		НомераЗаказовНаВозврат = Новый Массив;
		// Ихсанов Д. А. Конец 07.07.2026
		
		Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборка.Следующий() Цикл
			ДокументОбъектПредварительныйЗаказКлиента_НаРазделение = Выборка.Ссылка.ПолучитьОбъект();
			
			ВыборкаДетальныеЗаписи = Выборка.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
				НомераЗаказовНаВозврат.Добавить(ВыборкаДетальныеЗаписи.НомерЗаказа);
				// Ихсанов Д. А. Конец 07.07.2026
				
				Если ДокументОбъектПредварительныйЗаказКлиента_НаРазделение.Товары.Количество() = 1 Тогда
					РезультатПроведенияПЗК = МаркетПлейсы_ПровестиПредварительныйЗаказКлиентаПоАльтернативномуСкладу(
						ДокументОбъектПредварительныйЗаказКлиента_НаРазделение, РеквизитыМаркетПлейса);
					
					СообщитьИзМодуля(РезультатПроведенияПЗК.ТекстСообщения);
					
					Продолжить;
				КонецЕсли;
				
				РезультатВыделенияЗаказа = МаркетПлейсы_ВынестиЗаказОтдельныйПредварительныйЗаказКлиента(
					ДокументОбъектПредварительныйЗаказКлиента_НаРазделение, РеквизитыМаркетПлейса, ВыборкаДетальныеЗаписи.НомерЗаказа,
					// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
					РеквизитыМаркетПлейса.ВозможныМногоместныеЗаказы);
					// Ихсанов Д. А. Конец 07.07.2026
				
				СообщитьИзМодуля(РезультатВыделенияЗаказа.ТекстСообщения);
			КонецЦикла;
			
			ДокументОбъектПредварительныйЗаказКлиента_НаРазделение.Записать(РежимЗаписиДокумента.Проведение);
		КонецЦикла;
		
		ДокументОбъектЗаказКлиентаFBS = ЗаказКлиентаFBS.ПолучитьОбъект();
		Если Ложь Тогда ДокументОбъектЗаказКлиентаFBS = Документы.ЗаказКлиентаFBS.СоздатьДокумент() КонецЕсли;
		// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
		//Для каждого НомерЗаказа из НомераЗаказов Цикл
		Для каждого НомерЗаказа из НомераЗаказовНаВозврат Цикл
		// Ихсанов Д. А. Конец 07.07.2026
			лИндекс = ДокументОбъектЗаказКлиентаFBS.Товары.Количество() - 1;
			Пока лИндекс > 0 Цикл
				СтрокаТабличнойЧасти_ЗаказКлиентаFBS = ДокументОбъектЗаказКлиентаFBS.Товары[лИндекс];
				// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
				//Если СтрокаТабличнойЧасти_ЗаказКлиентаFBS.НомерЗаказа = НомерЗаказа Тогда
				Если СтрокаТабличнойЧасти_ЗаказКлиентаFBS[ИмяПоляСНомеромЗаказа] = НомерЗаказа Тогда
				// Ихсанов Д. А. Конец 07.07.2026
					ДокументОбъектЗаказКлиентаFBS.Товары.Удалить(лИндекс)
				КонецЕсли;
				
				лИндекс = лИндекс - 1;
			КонецЦикла;
		КонецЦикла;
		ДокументОбъектЗаказКлиентаFBS.Записать();
		
		ТекстСообщения = СтрШаблон("Из документа %1 удалены заказы %2.",
			ДокументОбъектЗаказКлиентаFBS,
			// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000233 от 30.06.2026 15:28:56: e1cib/data/Документ.Изменение?ref=89690050568f680711f1747f3daa877f
			//СтрСоединить(НомераЗаказов, ","));
			СтрСоединить(НомераЗаказовНаВозврат, ","));
			// Ихсанов Д. А. Конец 07.07.2026
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ТекстСообщения = СтрШаблон("Не удалось перенести заказы из документа. %1",
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	СообщитьИзМодуля(ТекстСообщения);
	
КонецПроцедуры

// Процедура - Маркет плейсы провести предварительный заказ клиента по альтернативному складу
//
// Параметры:
//  ДокументОбъектПредварительныйЗаказКлиента	 - ДокументОбъект.ПредварительныйЗаказКлиента	 - Объект целевого документа
//  РеквизитыМаркетПлейса						 - Структура									 - Данные реквизитов складов интернет магазина
//  НомерЗаказа									 - Строка										 - Номер заказа для выноса в отдельный документ
// 
// Возвращаемое значение:
//  Структура - :
//  * Выполнено		 – Булево
//  * ТекстСообщения	 – Текст
//
Функция МаркетПлейсы_ВынестиЗаказОтдельныйПредварительныйЗаказКлиента(ДокументОбъектПредварительныйЗаказКлиента, //РеквизитыМаркетПлейса...) Экспорт
	РеквизитыМаркетПлейса, НомерЗаказа, ВозможныЗаказыСНесколькимиТоварами = Ложь) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	СмещениеПоИндексу = 1;
	
	Результат = Новый Структура;
	Результат.Вставить("Выполнено");
	Результат.Вставить("ТекстСообщения");
	
	ПараметрыОтбора = Новый Структура;
	Если ВозможныЗаказыСНесколькимиТоварами Тогда
		ПараметрыОтбора.Вставить("РИД", НомерЗаказа);
	Иначе
		ПараметрыОтбора.Вставить("НомерЗаказа", НомерЗаказа);
	КонецЕсли;
	
	НайденныеСтроки = ДокументОбъектПредварительныйЗаказКлиента.Товары.НайтиСтроки(ПараметрыОтбора);
	Если НайденныеСтроки.Количество() > 0 Тогда
		ДокументОбъектПредварительныйЗаказКлиента_Новый = Документы.ПредварительныйЗаказКлиента.СоздатьДокумент();
		ДокументОбъектПредварительныйЗаказКлиента_Новый.Дата = ТекущаяДата;
		
		РеквизитыДокумента = "СкладПолучатель, Контрагент, ДатаОтгрузки, Комментарий, Договор, ПунктДоставки,
			|ТребуетсяМаркировка, ОтгрузкаКомплектов";
		ЗаполнитьЗначенияСвойств(ДокументОбъектПредварительныйЗаказКлиента_Новый,
			ДокументОбъектПредварительныйЗаказКлиента, РеквизитыДокумента);
		
		// Перекинем на другой склад
		Если ДокументОбъектПредварительныйЗаказКлиента.Склад = РеквизитыМаркетПлейса.Склад Тогда
			ДокументОбъектПредварительныйЗаказКлиента_Новый.Склад = РеквизитыМаркетПлейса.СкладМаркировки
		Иначе
			ДокументОбъектПредварительныйЗаказКлиента_Новый.Склад = РеквизитыМаркетПлейса.Склад
		КонецЕсли;
		
		Для каждого СтрокаТабличнойЧастиТовары_НаРазделение из НайденныеСтроки Цикл
			ЗаполнитьЗначенияСвойств(ДокументОбъектПредварительныйЗаказКлиента_Новый.Товары.Добавить(),
				СтрокаТабличнойЧастиТовары_НаРазделение);
		КонецЦикла;
		
		Если ДокументОбъектПредварительныйЗаказКлиента.ОтгрузкаКомплектов Тогда
			ЗаполнитьКомплектующие(ДокументОбъектПредварительныйЗаказКлиента_Новый);
		КонецЕсли;
		
		лИндекс = ДокументОбъектПредварительныйЗаказКлиента.Товары.Количество() - 1;
		Пока лИндекс >= 0 Цикл
			СтрокаТоваровТабличнойЧасти_НаРазделение = ДокументОбъектПредварительныйЗаказКлиента.Товары[лИндекс];
			Если СтрокаТоваровТабличнойЧасти_НаРазделение.НомерЗаказа = НомерЗаказа
				Или СтрокаТоваровТабличнойЧасти_НаРазделение.РИД = НомерЗаказа Тогда
				ДокументОбъектПредварительныйЗаказКлиента.Товары.Удалить(лИндекс)
			КонецЕсли;
			
			лИндекс = лИндекс - СмещениеПоИндексу;
		КонецЦикла;
		
		Если ДокументОбъектПредварительныйЗаказКлиента.ОтгрузкаКомплектов ТОгда
			лИндекс = ДокументОбъектПредварительныйЗаказКлиента.Комплектующие.Количество() - 1;
			Пока лИндекс >= 0 Цикл
				СтрокаТоваровТабличнойЧасти_НаРазделение = ДокументОбъектПредварительныйЗаказКлиента.Комплектующие[лИндекс];
				Если СтрокаТоваровТабличнойЧасти_НаРазделение.НомерЗаказа = НомерЗаказа
					Или СтрокаТоваровТабличнойЧасти_НаРазделение.РИД = НомерЗаказа Тогда
					ДокументОбъектПредварительныйЗаказКлиента.Комплектующие.Удалить(лИндекс)
				КонецЕсли;
				
				лИндекс = лИндекс - СмещениеПоИндексу;
			КонецЦикла;
		КонецЕсли;
		
		Попытка
			ДокументОбъектПредварительныйЗаказКлиента_Новый.Записать(РежимЗаписиДокумента.Запись);
			
			Результат.Выполнено = Истина;
			Результат.ТекстСообщения = СтрШаблон("Заказ %1 был успешно перенесен из документа %2 в документ %3.",
				НомерЗаказа,
				ДокументОбъектПредварительныйЗаказКлиента,
				ДокументОбъектПредварительныйЗаказКлиента_Новый);
		Исключение
			Результат.Выполнено = Ложь;
			Результат.ТекстСообщения = СтрШаблон("Заказ %1 не удалось перенести из документа %2!",
				НомерЗаказа,
				ДокументОбъектПредварительныйЗаказКлиента);
		КонецПопытки;
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции // МаркетПлейсы_ВынестиЗаказОтдельныйПредварительныйЗаказКлиента()

// Процедура - Маркет плейсы провести предварительный заказ клиента по альтернативному складу
//
// Параметры:
//  ДокументОбъектПредварительныйЗаказКлиента	 - ДокументОбъект.ПредварительныйЗаказКлиента	 - Объект целевого документа
//  РеквизитыМаркетПлейса						 - Структура									 - Данные реквизитов складов интернет магазина
// 
// Возвращаемое значение:
//  Структура - :
//  * Выполнено		 – Булево
//  * ТекстСообщения	 – Текст
//
Функция МаркетПлейсы_ПровестиПредварительныйЗаказКлиентаПоАльтернативномуСкладу(ДокументОбъектПредварительныйЗаказКлиента, РеквизитыМаркетПлейса) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Результат = Новый Структура;
	Результат.Вставить("Выполнено");
	Результат.Вставить("ТекстСообщения");
	
	ДокументОбъектПредварительныйЗаказКлиента.Дата = ТекущаяДата;
	Если ДокументОбъектПредварительныйЗаказКлиента.Склад = РеквизитыМаркетПлейса.Склад Тогда
		ДокументОбъектПредварительныйЗаказКлиента.Склад = РеквизитыМаркетПлейса.СкладМаркировки
	Иначе
		ДокументОбъектПредварительныйЗаказКлиента.Склад = РеквизитыМаркетПлейса.Склад
	КонецЕсли;

	Попытка
		ДокументОбъектПредварительныйЗаказКлиента.Записать(РежимЗаписиДокумента.Проведение);
		
		Результат.Выполнено = Истина;
		Результат.ТекстСообщения = СтрШаблон("Документ %1 был проведен по складу %2 успешно!",
			ДокументОбъектПредварительныйЗаказКлиента,
			ДокументОбъектПредварительныйЗаказКлиента.Склад);
	Исключение
		ДокументОбъектПредварительныйЗаказКлиента.Записать(РежимЗаписиДокумента.Запись);
		
		Результат.Выполнено = Ложь;
		Результат.ТекстСообщения = СтрШаблон("Возникли ошибки при проведении документа %1 по складу %2!. %3",
			ДокументОбъектПредварительныйЗаказКлиента,
			ДокументОбъектПредварительныйЗаказКлиента.Склад,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат Результат
	
КонецФункции // МаркетПлейсы_ПровестиПредварительныйЗаказКлиентаПоАльтернативномуСкладу()
// Ихсанов Д. А. Конец 12.11.2025

// Ихсанов Д. А. Начало 18.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7714
// Процедура - Создать операцию маркировки с формированием наборов
//
// Параметры:
//  РасходнаяНакладная	 - ДокументСсылка.РасходнаяНакладная	 - Ссылка на накладную
//
Процедура СоздатьОперациюМаркировкиСФормированиемНаборов(РасходнаяНакладная) Экспорт
	
	// Ихсанов Д. А. Начало 09.07.2026 Изменение 0000000249 от 08.07.2026 12:32:58: e1cib/data/Документ.Изменение?ref=896d0050568f680711f17aaffb047fc5
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЗаданиеНаСборкуКомплектовЧЗ.Ссылка КАК ЗаданиеНаСборкуКомплектов
	|ИЗ
	|	Документ.ЗаданиеНаСборкуКомплектовЧЗ КАК ЗаданиеНаСборкуКомплектовЧЗ
	|ГДЕ
	|	ЗаданиеНаСборкуКомплектовЧЗ.ДокОснование = &РасходнаяНакладная
	|	И ЗаданиеНаСборкуКомплектовЧЗ.Проведен
	|	И ЗаданиеНаСборкуКомплектовЧЗ.СостояниеНакладной <> ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ГотоваКОтгрузке)");
	Запрос.УстановитьПараметр("РасходнаяНакладная", РасходнаяНакладная);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		// Завершим все ЛСК и ЗНБ для того, что бы они не участвовали в следующей итерации
		МаркировкаКС.ЗавершитьВсеЛСК(Выборка.ЗаданиеНаСборкуКомплектов, Истина);
		Документы.ЗаданиеНаСборкуКомплектовЧЗ.ЗавершитьЗадание(Выборка.ЗаданиеНаСборкуКомплектов);
		
		// Разберем готовые комплекты на составляющие
		Документы.ЗаданиеНаСборкуКомплектовЧЗ.СоздатьРазагрегациюГотовыхНаборов(Выборка.ЗаданиеНаСборкуКомплектов);
		
		// Соберем наборы из правильных составляющих комплекта
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Статус", Перечисления.СтатусыДокументовМаркировки.КОбработке);
		
		Документы.ЗаданиеНаСборкуКомплектовЧЗ.Создать_Агрегации(Выборка.ЗаданиеНаСборкуКомплектов, ДополнительныеПараметры);
		
		СообщитьИзМодуля(СтрШаблон("Были созданы ОМ (Формирование набора) по документу %1", Выборка.ЗаданиеНаСборкуКомплектов));
	КонецЦикла;
	// Ихсанов Д. А. Конец 09.07.2026
	
КонецПроцедуры // СоздатьОперациюМаркировкиСФормированиемНаборов()
