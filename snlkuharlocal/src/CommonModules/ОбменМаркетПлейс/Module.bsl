	Рез = Запрос.Выполнить().Выбрать();
	
	Пока рез.Следующий() Цикл
		
		док=рез.ссылка;
		//ДокОб = док.ПолучитьОбъект();
		// проверим на пустые ШК
		ЗапросПоСтикерам(Док.ссылка,МаркПл,Тест);
		
	конецЦикла;
	
