		ТекстОповещения     =СформироватьТекстОповещенияЕкод(Неопределено,МассивНоменклатурыБезСектора,ВидСообщения);
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);
		МассивНоменклатурыБезСектора.очистить(); 			
		
	КонецЕсли;	
	// Кухарь А.Ю. 11.11.2021 конец
	
	
КонецПроцедуры

Функция МП_ОЗОН_МаркировкаВЗадании(МаркПл, НомерОтправления) Экспорт
	
	// Ихсанов Д. А. Начало 11.12.2025 Без номера задачи
	// 6-я версия метода
	СообщениеОбОшибке = "";
	
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("posting_number", НомерОтправления);
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON);
	ПараметрыОбработки.ДанныеЗапроса.Метод = "POST";
	ПараметрыОбработки.ИменаСвойствОшибок = "code";
	ПараметрыОбработки.ЗначенияСвойствОшибок = "0";
	
	ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
		ОбменМаркетПлейс.МП_Озон_ВернутьСоединение(МаркПл),
		ОбменМаркетПлейс.ПолучитьЗаголовкиОзон(МаркПл),
		"/v6/fbs/posting/product/exemplar/create-or-get",
		ПараметрыОбработки, Ложь, Ложь);
	Если Не ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки)
		Или Не ДанныеОтвета.Свойство("products") Тогда
		Возврат Ложь
	КонецЕсли;
	
	Для каждого ДанныеТовара из ДанныеОтвета.products Цикл
		Для каждого ДанныеЭкземпляра из ДанныеТовара.exemplars Цикл
			Возврат ДанныеТовара.is_mandatory_mark_needed
		КонецЦикла
	КонецЦикла;
	
	Возврат Ложь
	// Ихсанов Д. А. Конец 11.12.2025
	
КонецФункции

Функция МП_ОЗОН_ВернутьСтруктуру_Для_GET(Отправления,ФлагСообщить=Ложь)  Экспорт
	
	///v3/posting/fbs/get
	
	// {
	//    "posting_number": "11046397-0264-1",
	//    "with": {
	//        "analytics_data": false,
	//        "barcodes": false,
	//        "financial_data": false,
	//        "product_exemplars": true,
	//        "translit": false
	//    }
	// }
	
	
	СтруктураТелаЗапроса   = Новый Структура;
	
	СтруктураТелаЗапроса.Вставить("posting_number", СокрЛП(Отправления));
	
	Структураwith = Новый Структура;
	Структураwith.Вставить("additional_data"  ,Ложь);
	Структураwith.Вставить("barcodes"         ,Ложь);
	Структураwith.Вставить("financial_data"   ,Ложь);
	Структураwith.Вставить("product_exemplars",Истина);
	Структураwith.Вставить("translit"         ,Ложь); 	
	
	СтруктураТелаЗапроса.Вставить("with",          Структураwith);    	
	
	ТелоЗапроса="";
	
	ТелоЗапроса          =  МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Авто,ЭкранированиеСимволовJSON.Нет);
	
	Если ФлагСообщить Тогда
		Сообщить(ТелоЗапроса);
	КонецЕсли;
	
	Возврат ТелоЗапроса;
	
КонецФункции

Процедура МП_ЗаполнитьНакладнуюОзон(ДанныеМаркетПлейса,Выборка,Контрагент,ЭтоТест,НужнаМаркировка=Ложь) Экспорт 
	
	Если ложь тогда ДокОбъект=документы.РасходнаяНакладная.СоздатьДокумент();   КонецЕсли;  
	Если ложь тогда ДанныеМаркетПлейса=Справочники.ИнетМагазины.ПустаяСсылка(); КонецЕсли; 
	
	КритическиеОшибкиОзон = новый Массив;
	НеКритическиеОшибкиОзон = новый Массив;
	
	ОжиданиеУпаковки     = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("awaiting_packaging",Истина);		
	ВыборкаПоНомерамЗаказа=Выборка.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЗаказа");
	
	// Кухарь А.Ю. 29.11.2021 начало
	КоличествоНомеровЗаказа=ВыборкаПоНомерамЗаказа.количество();
	СчНакладных=0; 
	СчВыборки  =0;
	МаксЗаказовВНакладной=40;
	// Кухарь А.Ю. 29.11.2021 конец
	
	//Тимофеев Ю.А. Начало   13-11-2024
	//время до которого отгрузка на завтра, после на послезавтра
	//
	ВремяПереносаОтгрузки=Час(ДанныеМаркетПлейса.Склад.ВремяЗапретаОтправкиНаСклад);		
	
	Если ЗначениеНеЗаполнено(ВремяПереносаОтгрузки) Тогда
		ВремяПереносаОтгрузки=14;
	КонецЕсли;
	
	//Тимофеев Ю.А. Конец    13-11-2024
	
	
	пока ВыборкаПоНомерамЗаказа.следующий() цикл
		// Кухарь А.Ю. 29.11.2021 начало
		//
		СчВыборки=СчВыборки+1;
		если СчНакладных>=МаксЗаказовВНакладной тогда
			СчНакладных=1;
		Иначе
			СчНакладных=СчНакладных+1;
		КонецЕсли;
		
		Если СчНакладных=1 тогда
			
			ПроводитьFBS       = Истина;
			ПомечатьНаУдаление = ложь;
			ДокОбъект          = СоздатьИЗаполнитьШапкуНакладной(Контрагент,ДанныеМаркетПлейса,Выборка);
			ДокОбъектСсылка    = ДокОбъект.ссылка;
			
			//Тимофеев Ю.А. 01.07.24
			//добавим признак маркировки
			ДОкОбъект.ДистанционнаяПродажа = НужнаМаркировка;
			ДОкОбъект.ТребуетсяМаркировка  = НужнаМаркировка;
			//Тимофеев Ю.А. 01.07.24
			
			ЗаказКлиентаFBS              =Документы.ЗаказКлиентаFBS.СоздатьДокумент();
			ЗаказКлиентаFBS.Контрагент   =Контрагент;
			ЗаказКлиентаFBS.Дата         =ТекущаяДата();
			ЗаказКлиентаFBS.ДокОснование =ДокОбъектСсылка;
			
			
			//добавим комментарий визульаный - при отгрузки затрется оригинальным номером поставки
			Если НужнаМаркировка Тогда
				
				ЗаказКлиентаFBS.НомерПоставки="ОЗОН_МАРКИРОВКА";
				
			КонецЕсли;
			
		КонецЕсли;
		
		ВыборкаПоТоварам=ВыборкаПоНомерамЗаказа.выбрать();
		
		пока ВыборкаПоТоварам.следующий() цикл
			
			СтрТЧ                    =ЗаказКлиентаFBS.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЧ,ВыборкаПоТоварам);
			СтрТЧ.НомерЗаказа        =СокрЛП(ВыборкаПоТоварам.НомерЗаказа);
			СтрТЧ.АртикулКонтрагента =СокрЛП(ВыборкаПоТоварам.АртикулКонтрагента);
			СтрТЧ.ШтрихКод           =ВыборкаПоТоварам.НижнийШК;
			СтрТЧ.РИД                =ВыборкаПоТоварам.ВерхнийШК;
			СтрТЧ.СостояниеУКлиента  =ОжиданиеУпаковки;
			СтрТЧ.Заявка             =СтрТЧ.Количество;
			
		КонецЦикла;
		
		Если СчНакладных<МаксЗаказовВНакладной и СчВыборки<КоличествоНомеровЗаказа тогда
			Продолжить;
		КонецЕсли;
		
		ЗаказКлиентаFBS.Записать();
		ТЗТовары=ЗаказКлиентаFBS.Товары.Выгрузить(,"Номенклатура,Количество");
		ТЗТовары.Свернуть("Номенклатура","Количество");		
		
		Для каждого СтрТЗ из ТЗТовары цикл
			
			СтрТЧ                     =ДокОбъект.товары.добавить();
			ЗаполнитьЗначенияСвойств(СтрТЧ,СтрТЗ);
			СтрТЧ.Заявка              =СтрТЧ.Количество;
			СтрТЧ.ПодтвержденнаяЗаявка=СтрТЧ.Количество;
			ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокОбъект);
			РассчитатьСуммуТабЧасти(СтрТЧ, ДокОбъект);
		КонецЦикла;
		
		Если Контрагент.ИспользоватьНоменклатурнуюМатрицу  Тогда
			
			ПересчетТЧМатрицы(ДокОбъект,"Товары",ПараметрыСеанса.ВалютаНац,ПараметрыСеанса.ВалютаНац,1,1);	
		Иначе
			
			ПересчетТЧ(ДокОбъект,"Товары",ПараметрыСеанса.ВалютаНац,ПараметрыСеанса.ВалютаНац,1,1,Истина);
			
		Конецесли;		
		
		ЗаполнитьКМПТовара(ДокОбъект);
		
		ПунктДоставки_ПриИзменении(ДокОбъект);
		
		Если НЕ ДокОбъект.ОтгрузкаКомплектов =истина Тогда
			
			ДокОбъект.Комплектующие.Очистить();
			ИмяТЧ="Товары";
			
		Иначе
			
			ИмяТЧ="Комплектующие";
			
		КонецЕсли;			
		
		Попытка
			
			ЗаписьВРег=РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
			ЗаписьВРег.Документ=ДокОбъект.Ссылка;
			ЗаписьВРег.ИмяРеквизита="ИнтернетЗаказ";
			ЗаписьВРег.ЗначениеРеквизита="Да";
			ЗаписьВРег.Записать();
			
		Исключение
			
			КритическиеОшибкиОзон.Добавить("Заказ "+ДокОбъект.Ссылка+"не записаны ШК! "+ОписаниеОшибки());
			
		КонецПопытки;
		
		ТабОстатков = ПолучитьСвободныйОстатокНаКонецДня(ДокОбъект[ИмяТЧ].Выгрузитьколонку("Номенклатура"),ДокОбъект.склад,ТекущаяДата());
		хватает = 1;
		
		ТЧТоваровНакладной=ДокОбъект[ИмяТЧ].выгрузить();
		ТЧТоваровНакладной.свернуть("Номенклатура","Количество");
		
		Для  каждого ТекСтрока из  ТЧТоваровНакладной цикл		
			колОст = 0;
			НайденнаяСтрока = ТабОстатков.Найти(ТекСтрока.Номенклатура,"Номенклатура");
			
			Если НайденнаяСтрока <> Неопределено ТОгда
				КолОст=НайденнаяСтрока.СвободныйОстаток; 
			Иначе
				колОст = 0;
			КонецЕсли;	
			
			Если КолОст - Текстрока.Количество<0 ТОгда
				хватает =0;
				прервать;
			КонецЕсли;	
			
		конецЦикла;
		
		
		Если Не Хватает Тогда
			
			КритическиеОшибкиОзон.Добавить("Для "+ДокОбъект+" Не хватает номенклатуры на остатках. Документ не проведен и не сброшен на склад!");
			
		КонецЕсли;	
		
		ЕстьНулевыеЦены=ложь;
		
		Если ДокОбъект.товары.НайтиСтроки(новый Структура("Всего",0)).Количество()>0 тогда
			
			ЕстьНулевыеЦены=Истина;
			КритическиеОшибкиОзон.Добавить("В "+ДокОбъект+" есть нулевые цены. Нужно заполнить цены и вручную провести накладную.");
			
		КонецЕсли;
		
		Если не хватает или ЕстьНулевыеЦены тогда
			//Кухарь А.Ю.   28.12.2021 конец  			
			попытка
				
				ДокОбъект.записать();
				
			Исключение
				
				КритическиеОшибкиОзон.Добавить("Накладную не удалось провести. Заказы будут загружены при следующей попытки (С накладной ничего делать не нужно). Описание ошибки:" + ОписаниеОшибки());	
				ПроводитьFBS=ложь;	
				
			КонецПопытки;	
			
		конецЕсли;
		
		Если ЗначениеНеЗаполнено(ДокОбъект.ДатаВыгрузки) Тогда
			
			ДокОбъект.ДатаВыгрузки=ТекущаяДата();	
			
		КонецЕсли; 
		
		ДокОбъект.дата=ТекущаяДата();
		
		//ПризнакВерногоВремени=истина;
		
		ТекущееВремя =  час(ТекущаяДата());
		
		//
		//Если ТекущееВремя>=14 И ДокОбъект.ДатаОтгрузки<=НачалоДня(ТекущаяДата()+24*60*60) тогда
		//	
		//	ПризнакВерногоВремени = ложь;
		//	
		//КонецЕсли;	  		
		//
		СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад; 		
		РежимЗаписи=РежимЗаписиДокумента.Проведение;
		
		//если не ПризнакВерногоВремени тогда
		//	
		//	//Тимофеев Ю.А. 12.11.2024
		//	Если ДокОбъект.ДатаОтгрузки=ДокОбъект.ДатаОтгрузки Тогда
		//		ДокОбъект.ДатаОтгрузки=ДокОбъект.ДатаОтгрузки+2*86400;
		//	Иначе    				
		//		ДокОбъект.ДатаОтгрузки=ДокОбъект.ДатаОтгрузки+86400;
		//	КонецЕсли;
		//	//Тимофеев Ю.А. 12.11.2024
		
		//	НеКритическиеОшибкиОзон.Добавить("Накладная с датой отгрузки на завтра загружена после 14. Накладная перенесена на послезавтра.");
		//	
		//КонецЕсли;
		//
		//Если НачалоДня(ДокОбъект.ДатаОтгрузки)=НачалоДня(ТекущаяДата()) тогда
		//	
		//	ДокОбъект.ДатаОтгрузки=ДокОбъект.ДатаОтгрузки+(24*60*60);
		//	НеКритическиеОшибкиОзон.Добавить("Загружена накладная с датой отгрузки на сегодня. Накладная перенесена на завтра.");
		//	
		//КонецЕсли;
		
		
		
		
		если КритическиеОшибкиОзон.Количество()=0 тогда    //Если всё хорошо, то проводим РНК
			
			ДокОбъект.СостояниеНакладной=СостояниеНакладной;
			
			НачатьТранзакцию();
			// Кухарь А.Ю. 07.04.2025 начало 
			//Временно
			ЗаписатьВЛог("Отладка","Начало транзакции маркетплейсы №2","Информация"); 
			// Кухарь А.Ю. 07.04.2025 конец
			попытка
				
				ДокОбъект.пометкаудаления=ложь;
				ДокОбъект.Записать(РежимЗаписи);
				
			исключение
				
				КритическиеОшибкиОзон.Добавить("Накладную не удалось провести. Заказы будут загружены при следующей попытки (С накладной ничего делать не нужно). Описание ошибки:" + ОписаниеОшибки());	
				ПроводитьFBS=ложь;
				ПомечатьНаУдаление=Истина;
				ОтменитьТранзакцию();
				
			конецпопытки;
			
			если ПомечатьНаУдаление тогда
				
				попытка
					ДокОбъект.пометкаудаления=Истина;
					ДокОбъект.состояниенакладной=Перечисления.СостоянияНакладной.ВРаботе;
					ДокОбъект.записать();
				Исключение
				КонецПопытки;
				
			КонецЕсли;
			
			если  ПроводитьFBS тогда
				
				попытка
					ЗаказКлиентаFBS.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					если ТранзакцияАктивна() тогда
						ОтменитьТранзакцию();
					КонецЕсли;
				КонецПопытки;	
				
			КонецЕсли; 			
			
			если ТранзакцияАктивна() тогда
				
				ЗафиксироватьТранзакцию();
				
			КонецЕсли;
			
			Если  НЕ ДокОбъект.Проведен Тогда
				
				КритическиеОшибкиОзон.Добавить("РНК № "+ДокОбъект.Номер+" не проведена и не сброшена на склад.");
				Сообщение="РНК № "+ДокОбъект.Номер+" не проведена и не сброшена на склад.";
				ЗаписатьВЛог("МП_ОЗОН",Сообщение,"Ошибка");
				СообщитьИзМодуля(Сообщение);
				
			конецЕсли;    			
			
		иначе  
			если ПроводитьFBS тогда
				
				ЗаказКлиентаFBS.Записать(РежимЗаписиДокумента.Проведение);
				
			КонецЕсли;
			
		КонецЕсли;    		
		
		Если  КритическиеОшибкиОзон.количество()>0 Тогда 
			
			ВидСообщения          ="СообщитьМенеджеруОзон";
			СписокПолучателей     =СформироватьСписокПолучателейЕкод(ВидСообщения,ЭтоТест);
			ТемаОповещения        =СформироватьТемуОповещенияЕкод (ДокОбъект,ВидСообщения);
			ТекстОповещения       =СформироватьТекстОповещенияЕкод(ДокОбъект,КритическиеОшибкиОзон,ВидСообщения);
			ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);
			КритическиеОшибкиОзон.очистить(); 
			Продолжить;	
			
		КонецЕсли; 
		
		Если  НеКритическиеОшибкиОзон.количество()>0 Тогда 
			
			ВидСообщения          ="СообщитьМенеджеруОзон";
			СписокПолучателей     =СформироватьСписокПолучателейЕкод(ВидСообщения,ЭтоТест);
			ТемаОповещения        =СформироватьТемуОповещенияЕкод (ДокОбъект,ВидСообщения);
			ТекстОповещения       =СформироватьТекстОповещенияЕкод(ДокОбъект,НеКритическиеОшибкиОзон,ВидСообщения);
			ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);
			НеКритическиеОшибкиОзон.очистить(); 
			
		КонецЕсли; 
		
		//подтвердим в ОЗОН только НЕ МАРКИРОВАННЫЙ товар
		
		//Если Не НужнаМаркировка Тогда      //Тимофеев Ю.А.  07.06.25
			//о всех товарах
			ОтправитьВОзонПодтверждениеОЗагрузкеЗаказовНакладной(ДанныеМаркетПлейса,ДокОбъектСсылка,ЗаказКлиентаFBS.Ссылка,ЭтоТест);
			
		//КонецЕсли; 	                        //Тимофеев Ю.А. 07.06.25
		
	КонецЦикла; 	
	
КонецПроцедуры   

Процедура МП_ОЗОН_ЗапросЭтикеткиВЛистНабора(НужнаяРНК,СкачатьЭтикетку=Истина) Экспорт
	
	Маркетплейс=Справочники.ИнетМагазины.НайтиПоКоду("00002");
	
	//для добавления марок в заказ ОЗОН , сборка и получение этикетки
	//вызывается из документ ЛИСТ набора
	
	ЗаписатьВЛог("МП_ОЗОН","Лист набора.Запрос марки "+Строка(НужнаяРНК),"Информация");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ЛистНабораШтрихкодыУпаковок.НомерЗаказа КАК НомерЗаказа,
	|	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец КАК Номенклатура
	|ПОМЕСТИТЬ ЛИСТНАБОРА
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|ГДЕ
	|   ЛистНабораШтрихкодыУпаковок.Ссылка = &НужнаяРНК
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(20)) КАК АртикулКонтрагента,
	|	МатрицаТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ АРТ
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ЛИСТНАБОРА.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ЛИСТНАБОРА КАК ЛИСТНАБОРА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЛИСТНАБОРА.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ЛИСТНАБОРА.НомерЗаказа КАК НомерЗаказа,
	|	ЛИСТНАБОРА.Номенклатура КАК Номенклатура,
	|	АРТ.АртикулКонтрагента КАК product_id
	|ИЗ
	|	ЛИСТНАБОРА КАК ЛИСТНАБОРА
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АРТ КАК АРТ
	|		ПО ЛИСТНАБОРА.Номенклатура = АРТ.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛИСТНАБОРА.ШтрихкодУпаковки,
	|	ЛИСТНАБОРА.НомерЗаказа,
	|	АРТ.АртикулКонтрагента,
	|	ЛИСТНАБОРА.Номенклатура";
	
	//Параметры запроса
	Запрос.УстановитьПараметр("Контрагент",НужнаяРНК.ДокОснование.Контрагент);// Контрагенты
	Запрос.УстановитьПараметр("НужнаяРНК",НужнаяРНК);
	
	РезультатМарок = Запрос.Выполнить().Выгрузить();  	
	
	ТЗЗаказы = РезультатМарок.Скопировать();
	ТЗЗаказы.Свернуть("НомерЗаказа");
	
	ВсеМаркиПодгружены = Истина;
	
	
	Для Каждого СтрЗак из ТЗЗаказы Цикл 	
		
		ТекНомерЗаказа = СтрЗак.НомерЗаказа;
		
		НовТЗМарки = МП_ОЗОН_ПолучитьЭкземлярыДляМаркировки(Маркетплейс,ТекНомерЗаказа);
		
		Если НовТЗМарки<>Неопределено Тогда
			
			Для Каждого СтрЭкз из НовТЗМарки Цикл
				
				//НовТЗМарки.Колонки.Добавить("product_id");
				//НовТЗМарки.Колонки.Добавить("exemplars_id");
				//НовТЗМарки.Колонки.Добавить("quantity");
				//НовТЗМарки.Колонки.Добавить("marka");
				//НовТЗМарки.Колонки.Добавить("МаркаНеНужна");
				
				Если СтрЭкз.МаркаНеНужна Тогда //нужно добавить марку
					
					ПоискМарки=РезультатМарок.Найти(Строка(СтрЭкз.product_id),"product_id");
					
					Если ПоискМарки<>Неопределено Тогда
						СтрЭкз.marka = ПоискМарки.ШтрихкодУпаковки;
						
						РезультатМарок.Удалить(ПоискМарки);
					Иначе
						ЗаписатьВЛог("МП_ОЗОН","Лист набора. Не найдена марке для "+Строка(СтрЭкз.product_id),"Ошибка");
						
						ВсеМаркиПодгружены = Ложь;
						Прервать;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;  				
			
			Если ВсеМаркиПодгружены Тогда  				
				
				Если МП_ОЗОН_привязать_Маркировку(Маркетплейс,ТекНомерЗаказа,НовТЗМарки) Тогда
					
					//проверим статус если есть возможность перевода, переводим	
					//Если  МП_ОЗОН_ПроверкаСтатусаЗаказаСМаркировкой(МаркетПлейс,Выборка.НомерЗаказа) Тогда
					
					ДляТеста = МП_ОЗОН_ПроверкаСтатусаЗаказаСМаркировкой(МаркетПлейс,ТекНомерЗаказа); 
					//переводим заказ
					МП_ОЗОН_переводЗаказаВДругойСтатус(Маркетплейс,ТекНомерЗаказа,НовТЗМарки,СкачатьЭтикетку);
					ЗаписатьВЛог("МП_ОЗОН","Лист набора.Добавлена марка "+Строка(НужнаяРНК)+" "+Строка(ТекНомерЗаказа),"Информация");
					
				Иначе
					
					
					
					ЗаписатьВЛог("МП_ОЗОН","Лист набора.Статус не позволяет добавить марку "+Строка(НужнаяРНК)+" "+Строка(ТекНомерЗаказа),"Ошибка");
					
				КонецЕсли;   			
				
			КонецЕсли;
			
		Иначе
			
			СформироватьЭтикеткуОзонПоНомеруЗаказа(Маркетплейс.Контрагент,Маркетплейс,ТекНомерЗаказа);
			ЗаписатьВЛог("МП_ОЗОН","Лист набора.Нет данных ЭКСЗЕМЛЯРОВ "+Строка(НужнаяРНК)+" "+Строка(ТекНомерЗаказа),"Ошибка");
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура МП_ОЗОН_ОтменаЗаказовПоВычеркамОфисаИСклада(Маркетплейс) Экспорт
	//ASU-1952
	//выбираем все заказы ОЗОН за крайние 7 дней
	//проведенные и у которых есть ВЫЧЕРКИ , но не переданы на сайт
	
	КонДата = ТекущаяДата();
	НачДата = КонДата - 86400*7;   //за крайниее 7 дней проверяем
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ДокЗаказ,
	|	ЗаказКлиентаFBSТовары.ВычеркОфис КАК ВычеркОфис,
	|	ЗаказКлиентаFBSТовары.ВычеркСклад КАК ВычеркСклад,
	|	ЗаказКлиентаFBSТовары.ПереданоНаСайт КАК ПереданоНаСайт,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	Ложь Как ОтменаНаСайте
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Проведен                        	
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
	|	И (ЗаказКлиентаFBSТовары.ВычеркСклад
	|			ИЛИ ЗаказКлиентаFBSТовары.ВычеркОфис)
	|	И НЕ ЗаказКлиентаFBSТовары.ПереданоНаСайт
	|	";
	
	Запрос.УстановитьПараметр("НачДата",НачДата);// Дата
	Запрос.УстановитьПараметр("КонДата",КонДата);// Дата
	Запрос.УстановитьПараметр("Контрагент",Маркетплейс.Контрагент);// Контрагенты
	
	ТЗЗаказов = Запрос.Выполнить().Выгрузить();
	ВсегоЗаказов = ТЗЗаказов.Количество();
	Если ВсегоЗаказов>0 Тогда
		
		ЗаписатьВЛог("МП_ОЗОН","Отмена заказов (вычерки) "+Строка(ВсегоЗаказов),"Информация");
		
		СпрСостояниеУКлиента = Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(9);
		
		//отменим заказы на сайте
		Для Каждого СтрЗак из ТЗЗаказов Цикл
			НомерЗаказа   = СтрЗак.НомерЗаказа;
			СтрЗак.ОтменаНаСайте = МП_ОЗОН_ОТМЕНИТЬ_ЗаданиеНаПортале(МаркетПлейс,НомерЗаказа);
		КонецЦикла;
		
		ТЗДОКЗАК = ТЗЗаказов.Скопировать(,"ДокЗаказ");
		ТЗДОКЗАК.Свернуть("ДокЗаказ");
		
		//обработаем документ Заказ ФБС
		//передано на сайт и статус Состояние у клиента изменим
		
		Для каждого Док из ТЗДОКЗАК Цикл
			
			Отбор = Новый Структура();
			Отбор.Вставить("ДокЗаказ",Док.ДокЗаказ);
			Отбор.Вставить("ОтменаНаСайте",Истина); 		
			
			СтрокиЗаказов  = ТЗЗаказов.НайтиСтроки(Отбор);
			Если СтрокиЗаказов.Количество() > 0 Тогда
				
				ОбЗаказ = Док.ДокЗаказ.ПолучитьОбъект();
				
				Если ложь Тогда 
					ОбЗаказ = Документы.ЗаказКлиентаFBS.СоздатьДокумент();
				КонецЕсли;
				
				для каждого НайдЗаказ из СтрокиЗаказов Цикл
					
					ОтборЗак = Новый Структура();
					ОтборЗак.Вставить("НомерЗаказа",НайдЗаказ.НомерЗаказа);
					СтЗаказов  = ОбЗаказ.Товары.НайтиСтроки(ОтборЗак);
					
					Если СтЗаказов.Количество() > 0 Тогда
						
						Для Каждого СтрЗак из СтЗаказов Цикл
							СтрЗак.ПереданоНаСайт    = Истина;
							СтрЗак.СостояниеУКлиента =СпрСостояниеУКлиента;
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			Если ОбЗаказ<>Неопределено и ОбЗаказ.Модифицированность() Тогда
				
				Попытка
					ОбЗаказ.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ЗаписатьВЛог("МП_ОЗОН","Конец отмены заказов (вычерки) ","Информация");
		
	КонецЕсли;   	
	
КонецПроцедуры

Функция МП_ОЗОН_ОТМЕНИТЬ_ЗаданиеНаПортале(МаркетПлейс,НомерСборочногоЗадания) Экспорт
	//ASU-1952
	//вернет Истина если Сборочное задание ОТМЕНЕНО или было уже ОТМЕНЕНО
	
	ОтветФункции = Ложь;
	
	Команда     = "/v2/posting/fbs/cancel";
	
	СтруктураТелаЗапроса = Новый Структура();
	СтруктураТелаЗапроса.Вставить("cancel_reason_id"     ,352);
	СтруктураТелаЗапроса.Вставить("cancel_reason_message","Product is out of stock");
	СтруктураТелаЗапроса.Вставить("posting_number"       ,НомерСборочногоЗадания);
	
	//пример :
	//"{""cancel_reason_id"": 352,""cancel_reason_message"": ""Product is out of stock"",""posting_number"": """+отз+"""}";
	
	ТелоЗапроса          =  МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Нет,ЭкранированиеСимволовJSON.Нет);
	
	Ответ                =  POSTЗапросИз1С_ДжС(Маркетплейс,Команда,ТелоЗапроса); 
	
	ОтветСтрокой = Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ОтветСтрокой);
	ОтветСтруктура = ПрочитатьJSON(ЧтениеJSON);
	
	Если Ответ.КодСостояния<400 Тогда
		
		Если ОтветСтруктура.Свойство("result") Тогда
			
			Если ОтветСтруктура.result Тогда
				//ужем отменен
				ОтветФункции = Истина;
			Иначе
				Сообщить("Что то пошло не так...");
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		Если ОтветСтруктура.Свойство("message") Тогда
			
			Если ОтветСтруктура.message="POSTING_ALREADY_CANCELLED" Тогда
				//ужем отменен
				Сообщить("Уже был отменен");
				ОтветФункции = Истина;
			Иначе
				ЗаписатьВЛог("МП_ОЗОН","Ошибка отмены "+НомерСборочногоЗадания+" " +ОтветСтруктура.message ,"Ошибка");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ОтветФункции;  	
	
КонецФункции

Процедура МП_ОЗОН_ВыгрузитьОстаткиОзон(МаркетПлейс,ТЗОст) Экспорт
	// Вставить содержимое обработчика.
	Если НЕ ТЗОст.Количество() Тогда
		Сообщить(НСтр("ru = 'Нет данных к выгрузке выгрузка невозможна!'"));
		Возврат;
	КонецЕсли;	
	
	СтрЗагр= МаркетПлейс.API.Получить(3);
	
	Если НЕ СтрЗагр.ТипЗапроса=Перечисления.ТипHTTPЗапроса.POST Тогда
		Сообщить(НСтр("ru = 'Нет данных по api к выгрузке выгрузка невозможна!'"));
		Возврат;
	КонецЕсли;
	
	ЗаписатьВЛог("МП_Озон","Начало выполнения. Выгрузка остатков Озон. !","Информация");
	
	Если ЗначениеЗаполнено(МаркетПлейс.Token2) Тогда
		НашКлючАдмин =МаркетПлейс.Token2;
	Иначе
		НашКлючАдмин =МаркетПлейс.Token;
	КонецЕсли;	
	
	HTTP_запрос = новый HTTPзапрос();
	
	АдресТ =МаркетПлейс.АдресРесурса; 
	
	Попытка
		Если МаркетПлейс.Порт="443" Тогда
			Соединение = Новый HTTPСоединение(АдресТ,443,,,,,Новый ЗащищенноеСоединениеOpenSSL);  
		Иначе
			Соединение = Новый HTTPСоединение(АдресТ);
		КонецЕсли;
	Исключение
		Сообщить("Ошибка при попытке соединения "+ОписаниеОшибки());
	КонецПопытки;
	
	HTTP_запрос = новый HTTPзапрос();
	
	HTTP_запрос.АдресРесурса=СтрЗагр.Ресурс; 
	
	РеквизитыМаркетплейса = МаркетПлейс.Метаданные().Реквизиты;
	
	ЗаголовокHTTP =Новый Соответствие();
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentType.Синоним,     МаркетПлейс.ContentType);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.Accept.Синоним,          МаркетПлейс.Accept);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.AcceptLanguage.Синоним,  МаркетПлейс.AcceptLanguage);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.AcceptCharset.Синоним,   МаркетПлейс.AcceptCharset);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentLanguage.Синоним, МаркетПлейс.ContentLanguage);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentCharset.Синоним,  МаркетПлейс.ContentCharset);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.Host.Синоним,            МаркетПлейс.Host);
	
	Если МаркетПлейс.XAuthToken1 Тогда
		ХТок="Client-Id";
	Иначе
		ХТок="X-Auth-Token";
	КонецЕсли;	
	ЗаголовокHTTP.Вставить(ХТок, МаркетПлейс.XAuthToken);
	Если МаркетПлейс.Token1 Тогда
		ХТок="Api-Key";
	Иначе
		ХТок="Token"
	КонецЕсли;
	ЗаголовокHTTP.Вставить(ХТок, МаркетПлейс.Token);
	Если НЕ ПустаяСтрока(СокрЛП(МаркетПлейс.Authorization)) Тогда
		ЗаголовокHTTP.Вставить("Authorization", НашКлючАдмин );
	КонецЕсли;
	
	warehouse_id = МаркетПлейс.WarehouseId;
	
	ТЗ = Новый ТаблицаЗначений;
	//Тз.Колонки.Добавить("offer_id");
	Тз.Колонки.Добавить("product_id");
	Тз.Колонки.Добавить("stock");
	
	
	ТЗЗаданий = Новый ТаблицаЗначений;
	ТЗЗаданий.Колонки.Добавить("ТЗЗаказов");
	
	Для каждого стрТЗ из ТЗОст Цикл 				
		
		НовСтр = ТЗ.Добавить();
		//НовСтр.offer_id    = СокрЛП(стрТЗ.offer_id);
		НовСтр.product_id  = СокрЛП(стрТЗ.product_id);  //Интегер
		НовСтр.stock  = стрТЗ.КВыгрузке; 
		
		Если ТЗ.Количество()=100 Тогда
			НовСтрЗаказ = ТЗЗаданий.Добавить();
			НовСтрЗаказ.ТЗЗаказов=ТЗ.Скопировать();
			ТЗ.Очистить();
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТЗ.Количество()>0 Тогда
		НовСтрЗаказ = ТЗЗаданий.Добавить();
		НовСтрЗаказ.ТЗЗаказов=ТЗ.Скопировать();
	КонецЕсли;
	
	ПлохойРезультат ="";
    СекундыПаузы = 1;
	
	Для Каждого стрЗаказ из ТЗЗаданий Цикл   			
		
		ТелоЗапроса = МП_ОЗОН_ВернутьСтруктуруДляStocks(стрЗаказ.ТЗЗаказов,warehouse_id);
		
		Попытка
			
			РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ТелоЗапроса));
			
			HTTP_запрос.Заголовки = ЗаголовокHTTP;
			
			HTTP_запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
			
			//Отправляем для обрааботки на наш сервер
			ОтветССайта = Соединение.ОтправитьДляОбработки(HTTP_запрос);  				
			
			Если ОтветССайта.КодСостояния = 200 Тогда 					
				#Если Клиент  тогда
					Сообщить("Остатки выгружены.");
				#КонецЕсли
				
				//					{
				//"result": [
				//{
				//"warehouse_id": 22142605386000,
				//"product_id": 118597312,
				//"quant_size": 1,
				//"offer_id": "PH11042",
				//"updated": true,
				//"errors": [ ]
				//}
				//]
				//}
				
				ОтветСтрокой =ОтветССайта.ПолучитьТелоКакСтроку();		
				
				ЧтениеJSON0 = Новый ЧтениеJSON;
				ЧтениеJSON0.УстановитьСтроку(ОтветСтрокой);
				
				ОтветСтруктура = ПрочитатьJSON(ЧтениеJSON0);  	
				
				Если ОтветСтруктура.Свойство("result") Тогда
					
					ОтветМассива =ОтветСтруктура.result[0];
					
					Если не ОтветМассива.updated Тогда
						
						ОписаниеОшибки= "";
						
						Если ОтветМассива.errors.Количество()>0 Тогда
							ОписаниеОшибки= "/"+ОтветМассива.errors[0].message	
						КонецЕсли;
						
						ПлохойРезультат = ПлохойРезультат + ОтветМассива.product_id+"/"+ ОтветМассива.offer_id+ОписаниеОшибки+Символы.ПС
						
					КонецЕсли;
					
				КонецЕсли;
				
			НужнаПауза(СекундыПаузы);
				
			ИначеЕсли ОтветССайта.КодСостояния = 429 Тогда
				
				СекундыПаузы=СекундыПаузы+2;
				НужнаПауза(СекундыПаузы);				
				ЗаписатьВЛог("МП_ОЗОН","Выгрузка остатков...Превышено время "+Строка(СекундыПаузы),"Ошибка");
				
			Иначе
				
				ЗаписатьВЛог("МП_ОЗОН","Выгрузка остатков..."+Строка(ОтветССайта.КодСостояния),"Ошибка");
           				
			КонецЕсли;
			
		Исключение
			#Если клиент Тогда
				Сообщить(ОписаниеОшибки());
			#КонецЕсли   
		КонецПопытки;  
		
		
	КонецЦикла;   		
	
	Если СтрДлина(ПлохойРезультат) >0 Тогда
		
		Попытка
			
			Сооб="ОЗОН - не все остатки обновлены";
			
			СписокПолучателей=новый СписокЗначений;
			
			СписокПолучателей.Добавить("timofeev@collant.ru");   //пока на время теста только мне						
			
			ТекстОповещения="Здравствуйте!"+Символы.ПС+ПлохойРезультат+Символы.ПС+"Не найдены на портале - нужно проверить";
			ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,"ОЗОН-обновление остатков "+Формат(ТекущаяДатаСеанса(),"ДФ='dd.MM.yyyy чч:мм'"),ТекстОповещения);   
		Исключение
			
		КонецПопытки;	
		
	КонецЕсли;
	
КонецПроцедуры

Функция МП_ОЗОН_ВернутьСтруктуруДляStocks(ТЗДАННЫХ,warehouse_id) Экспорт
	
	//Вместо ПолСтр=ПолучитьДжНеимМасИзТЗ2(ТЗ); Тимофеев Ю.А. 17.02.2025
	//Тимофеев Ю.А. 29052025
	//{
	//"stocks": [
	//{
	//"offer_id": "PH11042",
	//"product_id": 313455276,
	//"quant_size": 1,
	//"stock": 100,
	//"warehouse_id": 22142605386000
	//}
	//]
	//}	
	СтруктураТелаЗапроса   = Новый Структура;
	
	mproducts              = Новый Массив;
	
	Для Каждого стрТз из ТЗДАННЫХ Цикл
		
		products = Новый Структура;
		Попытка
			products.Вставить("product_id",  Число(стрТз.product_id));
		исключение
			products.Вставить("product_id", 0);
		КонецПопытки;     
	//products.Вставить("quant_size",   1);
	//	products.Вставить("offer_id",    стрТз.offer_id);
		products.Вставить("stock",       Число(стрТз.stock));
		products.Вставить("warehouse_id",warehouse_id);
		
		mproducts.Добавить(products); 	
		
	КОнецЦикла;
	
	СтруктураТелаЗапроса.Вставить("stocks", mproducts);
	
	ТелоЗапроса="";
	
	ТелоЗапроса          =  МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Авто,ЭкранированиеСимволовJSON.Нет);
	
	Возврат ТелоЗапроса;
	
КонецФункции

Функция МП_ОЗОН_ПолучитьОстаткиОЗОН(МаркетПлейс) Экспорт
	
	//ЗАмена ПолучитьТЗОстСайт1(МаркПл) Тимофеев Ю.А. 17.02.2025
	
	
	ТЗОС = Новый ТаблицаЗначений;	
	ТЗОС.Колонки.Добавить("ИДПрод", Новый ОписаниеТипов("Строка"));
	ТЗОС.Колонки.Добавить("АртОзон",Новый ОписаниеТипов("Строка"));  //Интегер
	ТЗОС.Колонки.Добавить("Кол",  Новый ОписаниеТипов("Число"));
	ТЗОС.Колонки.Добавить("НаимК",  Новый ОписаниеТипов("Строка"));
	//
	HTTP_запрос   = новый HTTPзапрос();	
	АдресТ        = МаркетПлейс.АдресРесурса; 	
	Соединение    = МП_Вайлберриз_ВернутьСоединение(МаркетПлейс);
	//ЗаголовокHTTP = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркетПлейс);
	
	HTTP_запрос.АдресРесурса = "/v4/product/info/stocks";
	
	
	РеквизитыМаркетплейса = МаркетПлейс.Метаданные().Реквизиты;
	
	ЗаголовокHTTP =Новый Соответствие();
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentType.Синоним,     МаркетПлейс.ContentType);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.Accept.Синоним,          МаркетПлейс.Accept);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.AcceptLanguage.Синоним,  МаркетПлейс.AcceptLanguage);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.AcceptCharset.Синоним,   МаркетПлейс.AcceptCharset);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentLanguage.Синоним, МаркетПлейс.ContentLanguage);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.ContentCharset.Синоним,  МаркетПлейс.ContentCharset);
	ЗаголовокHTTP.Вставить(РеквизитыМаркетплейса.Host.Синоним,            МаркетПлейс.Host);
	
	Если МаркетПлейс.XAuthToken1 Тогда
		ХТок="Client-Id";
	Иначе
		ХТок="X-Auth-Token";
	КонецЕсли;	
	
	ЗаголовокHTTP.Вставить(ХТок, МаркетПлейс.XAuthToken);
	Если МаркетПлейс.Token1 Тогда
		ХТок="Api-Key";
	Иначе
		ХТок="Token"
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МаркетПлейс.Token2) Тогда
		НашКлючАдмин =МаркетПлейс.Token2;
	Иначе
		НашКлючАдмин =МаркетПлейс.Token;
	КонецЕсли;
	
	
	ЗаголовокHTTP.Вставить(ХТок, МаркетПлейс.Token);
	Если НЕ ПустаяСтрока(СокрЛП(МаркетПлейс.Authorization)) Тогда
		ЗаголовокHTTP.Вставить("Authorization", НашКлючАдмин );
	КонецЕсли;	       
	
	//////////////////////////////////////////////////////////
	
	КУРСОР="";
	ВсегоНоменклатуры=0;    	
	
	КоличествоЦиклов=0;
	
	Пока Истина Цикл
		
		//////////////////////////
		
		ЗапросНаСайт= Новый Структура;
		ЗапросНаСайт.Вставить("cursor",КУРСОР);
		ЗапросНаСайт.Вставить("filter",Новый Структура);
		ЗапросНаСайт.Вставить("limit", 900);
		
		ТелоЗапроса   = МП_СберМаркет_Записать_JSON(ЗапросНаСайт,ПереносСтрокJSON.Нет,ЭкранированиеСимволовJSON.Нет);
		
		//////////////////////////////////
		
		РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ТелоЗапроса));
		ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
		
		HTTP_запрос.Заголовки = ЗаголовокHTTP;
		
		HTTP_запрос.УстановитьТелоИзСтроки(ТелоЗапроса);   	
		
		ОтветССайта = Соединение.ОтправитьДляОбработки(HTTP_запрос); 
		
		Если ОтветССайта.КодСостояния<400 Тогда
			
			ОтветСтрокой =ОтветССайта.ПолучитьТелоКакСтроку();		
			
			ЧтениеJSON0 = Новый ЧтениеJSON;
			ЧтениеJSON0.УстановитьСтроку(ОтветСтрокой);
			
			ОтветСтруктура = ПрочитатьJSON(ЧтениеJSON0);  	
			
			Если ВсегоНоменклатуры=0 Тогда
				
				ВсегоНоменклатуры = ОтветСтруктура["total"];
				
			КонецЕсли;
			
			КУРСОР = ОтветСтруктура["cursor"]; 		
			
			МассивТовара = ОтветСтруктура["items"];
			
			Если МассивТовара.Количество()>0  Тогда 				
				
				Для каждого стрЗак из МассивТовара цикл
					
					НовСтр=ТЗОС.Добавить();
					НовСтр.ИДПрод = стрЗак.product_id;
					НовСтр.НаимК  = стрЗак.offer_id;
					
					ОстаткиТовара=стрЗак.stocks;
					Если ОстаткиТовара.Количество()>0 Тогда
						Для Каждого ТЭл Из ОстаткиТовара Цикл
							Если ТЭл.type="fbs" Тогда
								НовСтр.Кол     =ТЭл.present;
								НовСтр.АртОзон =ТЭЛ.SKU
							КонецЕсли;	
						КонецЦикла;	
					КонецЕсли;					
				КонецЦикла;
				
			КонецЕсли;		
		Иначе
			ЗаписатьВЛог("МП_ОЗОН","Ошибка загрузки остатков ОЗОН "+ОтветССайта.ПолучитьТелоКакСтроку(),"Ошибка");
			Продолжить;
		КонецЕсли;				
		
		//////////////////////////////////   	 
		
		
		Если ТЗОС.Количество()>=ВсегоНоменклатуры Тогда
			Прервать;
		КонецЕсли;
		
		//на случай чтобы в рекурсию не ушло
		Если КоличествоЦиклов>50 Тогда
			Прервать;
		Иначе
			КоличествоЦиклов=КоличествоЦиклов+1;
		КОнецЕсли;  		
		
	КонецЦикла;    	
	
	Возврат ТЗОС;
	
КонецФункции	
//Тимофеев Ю.А. 17.07.2024

//Тимофеев Ю.А. 19.03.2025 новый вариант обработки заказов
Процедура МП_ОЗОН_ПолучитьОбработатьЗаказыССайта(Стат1="0", Тест=Ложь, Тест1=Ложь, СтруктураПараметров=Неопределено) Экспорт
	
	Попытка
		
		КодМаркетплейса=СтруктураПараметров.КодМаркетплейса;     //00002 - ОЗОН
		
		Маркетплейс =Справочники.ИнетМагазины.НайтиПоКоду(КодМаркетплейса);
	Исключение
		
		Маркетплейс =Справочники.ИнетМагазины.НайтиПоКоду("00002");
		ЗаписатьВЛог("МП_ОЗОН","Вызов метода без параметров","Ошибка");
		
	КонецПопытки;
	
	
	ПрефиксМаркета="";
	
	ЗаписатьВЛог("МП_ОЗОН","Начало выполнения. Задача: Загрузка заказов ОЗОН !","Информация");
	
	//ТЮА
	////Тимофеев Ю.А. 20.08.24
	////Отложенная отгрузка проверка поставок
	//Если Час(ТекущаяДата())=10 Тогда
	//	МП_Вайлбериз_На_Повторную_Отгрузку(Маркетплейс);
	//КонецЕсли;
	////Тимофеев Ю.А. 20.08.24
	
	ПериодНазад =3;   //по умолчанию за три дня назад проверяем все заказы
	
	Если ЗначениеЗаполнено(ПериодНазад) Тогда
		ПериодНазад = Маркетплейс.ПериодСут;
	КонецЕсли;
	
	ДатаНачала=НачалоДня(ТекущаяДатаСеанса()-(ПериодНазад*3600*24));
	
	Если СтруктураПараметров<>Неопределено Тогда 
		
		КритическиеОшибки	=новый Массив;
		
		СтруктураПараметров.Вставить("КритическиеОшибкиОзон", КритическиеОшибки); 
		
		Если СтруктураПараметров.Свойство("МаркировкаВсе") Тогда			
			МаркировкаВсе = СтруктураПараметров.МаркировкаВсе; 
		КонецЕсли;                               		
		
		Если СтруктураПараметров.Свойство("ДваСклада") Тогда			
			ДваСклада = СтруктураПараметров.ДваСклада; 
		КонецЕсли;   	
		
	Иначе 
		ЗаписатьВЛог("МП_ОЗОН","Не заполнена ТАБЛИЦА ПАРАМЕТРОВ","Ошибка"); 
		Возврат;
		
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ТабДемо") Тогда		
		ТЗЗак      = СтруктураПараметров.ТабДемо;  		
	Иначе   
		
		//ТЮА
		////загрузит ШК для заказов которые без ПОСТАВКИ Тимофеев Ю.А.
		//МП_Вайлбериз_ДозагрузитьЗагрузитьШКНеЗависимая(Маркетплейс);
		////загрузит ШК для заказов которые без ПОСТАВКИ Тимофеев Ю.А.
		
		ТЗЗак      = МП_ОЗОН_ПолучитьЗаказыССайта(Маркетплейс,ДатаНачала,СтруктураПараметров);
		
	КонецЕсли;
	
	Если ТЗЗак = Неопределено или ТЗЗак.Количество()=0  Тогда
		Возврат;
	КонецЕсли;  
	
	
	/////////////1.1 запишем кеш загрузки с сайта////////////////////////
	КонтрольЗаписи = Ложь;
	
	Если СтруктураПараметров.Свойство("КонтрольЗаписи") Тогда
		
		КонтрольЗаписи = СтруктураПараметров.КонтрольЗаписи; 
		
	КонецЕсли;
	
	Если КонтрольЗаписи Тогда 	
		//запишем блок заказов (МАССИВ) с портала
		
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
		
		ИмяФайла=ПутьЛог+"Массив_Заказов_ОЗОН_"+ВремяЗаписи+".txt";
		
		ЗначениеВФайл(ИмяФайла,ТЗЗак);
		
	КонецЕсли;     
	
	ТЗЗакНом = МП_ОЗОН_ОбработатьПолученныеЗаказы(ТЗЗак,Маркетплейс,СтруктураПараметров);
	
	
	Если НЕ МаркировкаВсе Тогда
		
		ТЗЗакНом = МаркаИлиНет(Маркетплейс,ТЗЗакНом); 	 
		
		//Тимофеев Ю.А. Конец    06-02-2025
		
		
		ТЗЗакНомОбщаяДляРазделения = ТЗЗакНом.Скопировать();
		
		ТЗЗакНом.Очистить();
		
		ТЗЗакНомСМаркировкой      =  ТЗЗакНом.Скопировать();
		
		//Статус КАРТОЧКА СОЗДНА
		
		// НужнаМаркировка           =  Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована;   //Тимофеев Ю.А.
		// СтрТаб.Номенклатура.СтатусКарточкиВЧЗ=НужнаМаркировка;
		//Ждем определение правильности маркированного товара
		
		Для каждого стрТаб из ТЗЗакНомОбщаяДляРазделения Цикл
			
			Если стрТаб.НужнаМаркировка=1 Тогда
				НовЗапМарка=ТЗЗакНомСМаркировкой.Добавить();
				ЗаполнитьЗначенияСвойств(НовЗапМарка,СтрТаб);
			Иначе
				НовЗап=ТЗЗакНом.Добавить();
				ЗаполнитьЗначенияСвойств(НовЗап,СтрТаб);
			КонецЕсли;  
			
		КонецЦикла; 
		
	Иначе
		//будем считать что все маркированное
		ТЗЗакНомСМаркировкой      =  ТЗЗакНом.Скопировать();
		ТЗЗакНом.Очистить();
	КонецЕсли;
	
	Если ТЗЗакНом.Количество()>0 Тогда
		
		МП_ОЗОН_ОбраткаПолученныхЗаказов(Маркетплейс,ТЗЗакНом,Стат1,Тест,СтруктураПараметров); 
		
	КонецЕсли;     
	
	КолвоТоваровСМаркировкой = ТЗЗакНомСМаркировкой.Количество();
	
	Если ТЗЗакНомСМаркировкой.Количество()>0 Тогда
		//все заказы с маркировка и накладные в одном месте
		//и запись в регистра
		ЗаписатьВЛог("МП_ОЗОН"+ПрефиксМаркета,"Найдены заказы с маркировкой ! "+Строка(КолвоТоваровСМаркировкой),"Информация");
		
		МП_ОЗОН_ОбраткаПолученныхЗаказов(Маркетплейс,ТЗЗакНомСМаркировкой,Стат1,Тест,СтруктураПараметров); 
		
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 22.05.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2259
	// Постобработка механизма получения данных о заказах
	// Иногда в информационной базе появляются документы РНК без Заказа клиента FBS, такие документы мы
	// помечаем на удаление
	//ПометитьНаУдалениеРасходныеНакладныеБезЗаказаКлиента(Маркетплейс);
	// Ихсанов Д. А. Конец  22.05.2025
	
КонецПроцедуры

Процедура МП_ОЗОН_ОбраткаПолученныхЗаказов(Маркетплейс,ТЗЗакНом,Стат1="0",ЭтоТест=Ложь,СтруктураПараметров)
	
	ПрефиксМаркета="";
	
	///////////////4.Обработываем полученную таблицу///////////////////////////////////////////////////////////////
	
	ЛимитПозиций   =   Маркетплейс.ЛимитПоКоличеству;	
	
	СтруктураПараметров.Вставить("ЛимитПозиций"       ,ЛимитПозиций);
	
	
	МассивМассивовЗаказов=Новый Массив;
	
	///////////////4.1 разделим таблицу на СПАЙКИ (КОМПЛЕКТ) и ШТУКИ
	
	ТЗКомплект= ТЗЗакНом.Скопировать();
	ТЗКомплект.очистить();
	ТЗШтука   = ТЗКомплект.Скопировать();
	
	Для Каждого стрТаб из ТЗЗакНом Цикл
		
		Если СтрТаб.Комплект Тогда
			НовСтрокаК=ТЗКомплект.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрокаК,СтрТаб);
		Иначе
			НовСтрокаШ=ТЗШтука.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрокаШ,СтрТаб);
		КонецЕсли;
		
	КонецЦикла;	
	
	ЗаписатьВЛог("МП_ОЗОН",ПрефиксМаркета+" Начало обработки заказов - штучный товар","Информация");
	
	ТекстОповещения="Начало обработки заказов ОЗОН - штучный товар"+Символы.ПС;
	
	
	///////////////4.2 обработаем ШТУЧНЫЕ ЗАКАЗЫ /////////////////////////////////////////////////////////// 
	
	Если ТЗШтука.Количество()>0 Тогда 		
		МассивЗаказовШтучно = МП_ОЗОН_СоздатьДокументыНаШтучныйТовар(ТЗШтука,Маркетплейс,СтруктураПараметров,ТекстОповещения);	
		МассивМассивовЗаказов.Добавить(МассивЗаказовШтучно);
	КонецЕсли;  	
	
	///////////////4.3 получим таблицу спаек  с УПАКОВКОЙ и без ///////////////////////////////////////////////
	
	ЗаписатьВЛог("МП_ОЗОН",ПрефиксМаркета+" Начало обработки заказов - СПАЙКИ","Информация");
	
	ТекстОповещения=ТекстОповещения+"Начало обработки заказов - СПАЙКИ"+Символы.ПС;
	
	КНеТовар=МП_ПровкаНеТовар(ТЗКомплект);
	
	ТЗСпайкаСУпаковкой=ТЗКомплект.Скопировать();
	ТЗСпайкаСУпаковкой.Очистить();
	
	ТЗСпайкаСБезУпаковки = ТЗСпайкаСУпаковкой.Скопировать();  
	
	Если КНеТовар.МассивНеТовар.Количество()>0 Тогда    	 
		
		ТЗСпайкаСБезУпаковки = ТЗСпайкаСУпаковкой.Скопировать();
		
		Для Каждого ТСтр из ТЗКомплект Цикл
			
			Если ТСтр.КолНеТовар Тогда
				НовСтрокаУ=ТЗСпайкаСУпаковкой.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаУ,ТСтр);
			Иначе
				НовСтрокаБез= ТЗСпайкаСБезУпаковки.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаБез,ТСтр);
			КонецЕсли;
			
		КонецЦикла;	
		
	Иначе
		
		ТЗСпайкаСБезУпаковки = ТЗКомплект.Скопировать();
		
	КонецЕсли;
	
	Если ТЗСпайкаСБезУпаковки.Количество()>0 Тогда 
		
		МассивСпайкаБезУпаковки=МП_ОЗОН_СоздатьДокументыНаСпайку(ТЗСпайкаСБезУпаковки,Маркетплейс,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.
		МассивМассивовЗаказов.Добавить(МассивСпайкаБезУпаковки);
		
	КонецЕсли;  
	
	///////////////4.4 Спайки по одинаковым упаковочкам  ////////////////////////////////////////////////////////
	
	МассивНеТовар=КНеТовар.МассивНеТовар;
	
	Для каждого НеТовар из МассивНеТовар Цикл
		
		ТЗСпайкаПоУпаковке=ТЗСпайкаСУпаковкой.Скопировать();
		ТЗСпайкаПоУпаковке.Очистить();
		
		ИндексТЗ=ТЗСпайкаСУпаковкой.Количество()-1;
		
		Пока ИндексТЗ>=0 Цикл
			
			ТСтр=ТЗСпайкаСУпаковкой.Получить(ИндексТЗ);
			
			Если ТСтр.НомРП1=НеТовар Тогда
				НовС=ТЗСпайкаПоУпаковке.Добавить();
				ЗаполнитьЗначенияСвойств(НовС,ТСтр);
				ТЗСпайкаСУпаковкой.Удалить(ИндексТЗ);
			КонецЕсли;
			
			ИндексТЗ=ИндексТЗ-1;
			
		КонецЦикла;
		
		МассивСпайкаПоУпаковке=МП_ОЗОН_СоздатьДокументыНаСпайку(ТЗСпайкаПоУпаковке,Маркетплейс,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.
		
		МассивМассивовЗаказов.Добавить(МассивСпайкаПоУпаковке);	 
		
	КонецЦикла;
	
	//спайка по одинаковым упаковочкам
	
	Если ТЗСпайкаСУпаковкой.Количество() Тогда  
		//а вдруг не все удалили  	 
		МассивСпайкаСУпаковкой=МП_ОЗОН_СоздатьДокументыНаСпайку(ТЗСпайкаСУпаковкой,Маркетплейс,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.  	 
		МассивМассивовЗаказов.Добавить(МассивСпайкаСУпаковкой); 	 
		
	КонецЕсли;	
	
	Если Маркетплейс.Тест Тогда
		Сообщить(ТекстОповещения);
	КонецЕсли;
	
	ЗаписатьВЛог("МП_ОЗОН",ПрефиксМаркета+" Окончание выполнения. Задача: Загрузка заказов ВБ. !","Информация"); 
	
	
	КритическиеОшибкиОзон=СтруктураПараметров.КритическиеОшибкиОзон;
	
	Если  КритическиеОшибкиОзон.количество()>0 Тогда
		
		ВидСообщения       ="СообщитьМенеджеруОзон";
		СписокПолучателей  =СформироватьСписокПолучателейЕкод(ВидСообщения,Маркетплейс.Тест);
		ТемаОповещения     =СформироватьТемуОповещенияЕкод (Неопределено,ВидСообщения);
		ТекстОповещения    =СформироватьТекстОповещенияЕкод(Неопределено,КритическиеОшибкиОзон,ВидСообщения);
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);
		КритическиеОшибкиОзон.очистить(); 	
		
	КонецЕсли;  	
	
	
	
КонецПроцедуры

Функция МП_ОЗОН_ПолучитьЗаказыССайта(Маркетплейс,ДатаНачала,СтруктураПараметров) Экспорт
	
	
	КритическиеОшибкиОзон=СтруктураПараметров.КритическиеОшибкиОзон;
	////////////////////////1. Получим данные о заказах с сайта//////////////////////////
	
	КоличествоЗаказов=1000;
	
	Статус="awaiting_packaging";
	
	Команда="/v3/posting/fbs/list";
	
	offset=0;
	
	МассивПоставок= Новый Массив;
	
	Пока Истина Цикл
		
		ПолСтр="{
		|""dir"": ""ASC"",
		|""filter"": {
		|""since"": """+Формат(ДатаНачала,"ДФ=yyyy-MM-ddT00:00:00.000Z")+""",
		|""status"": """+СокрЛП(Статус)+""",
		|""to"": """+Формат(ТекущаяДата(),"ДФ=yyyy-MM-ddT23:59:59.999Z")+"""
		|},
		|""limit"": "+Формат(КоличествоЗаказов,"ЧДЦ=0; ЧГ=0")+",
		|""offset"": "+Формат(offset,"ЧДЦ=0; ЧН=0; ЧГ=0")+",
		|""translit"": false,
		|""with"": {
		|""analytics_data"": true,
		|""financial_data"": true,
		|""barcodes"": true
		|}
		|}";
		
		
		Результат = POSTЗапросИз1С_ДжС(Маркетплейс,Команда,ПолСтр);
		
		Если Результат=неопределено Тогда 		
			Прервать;                      		
		КонецЕсли;  		
		
		ЧтениеJSON = Новый ЧтениеJSON;  	
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
		
		СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON, Ложь); 
		
		Если  не СтруктураОтвета.свойство("result") тогда
			
			Сообщение= "http запрос получения заказов, вернул некорректные данные";
			ЗаписатьВЛог("МП_ОЗОН",Сообщение,"Ошибка");
			СообщитьИзМодуля(Сообщение);
			
			Прервать;
			
		КонецЕсли;  
		
		МассивЗаказов=СтруктураОтвета["result"]["postings"];
		
		для каждого ДанныеЗаказа из МассивЗаказов Цикл
			МассивПоставок.Добавить(ДанныеЗаказа);		
		КонецЦикла; 
		
		Если СтруктураОтвета.result.has_next Тогда		
			offset=offset+1000;                		
		Иначе       		
			Прервать;		
		КонецЕсли;
		
		Если offset>40000 Тогда		
			Прервать;       		
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивПоставок.количество()= 0 Тогда
		Возврат Неопределено;
	Иначе 	
		Возврат МассивПоставок;
	КонецЕсли;	
	
КонецФункции


Функция  МП_ОЗОН_ОбработатьПолученныеЗаказы(МассивЗаказов,Маркетплейс,СтруктураПараметров) Экспорт
	
	КритическиеОшибкиОзон=СтруктураПараметров.КритическиеОшибкиОзон;	
	
	// Ихсанов Д. А. Начало 14.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2446
	ТоварыОтсутствуютВМатрицах = Новый ТаблицаЗначений;
	ТоварыОтсутствуютВМатрицах.Колонки.Добавить("ИмяТовара");
	ТоварыОтсутствуютВМатрицах.Колонки.Добавить("НомерЗаказа");
	ТоварыОтсутствуютВМатрицах.Колонки.Добавить("СКУ");
	ТоварыОтсутствуютВМатрицах.Колонки.Добавить("offer_id");
	// Ихсанов Д. А. Конец  14.08.2025
	
	////////////////////////2. ОБРАБОТАЕМ ПОЛУЧЕННЫЕ ДАННЫЕ //////////////////////////
	
	//массив в таблицу значений
	
	ТаблицаПоставок= ПреобразованиеМассивВТаблицуЗначений(МассивЗаказов) ;
	/////////////////////////////////////////////////////
	
	//2.1 проверяем наличие текущих заказов в нашей базе
	
	КонДата        = КонецДня(ТекущаяДатаСеанса());
	НачДата        = КонДата- 30 * 86400;
	
	КолонкаЗаказов = ТаблицаПоставок.ВыгрузитьКолонку("posting_number");
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	// Ихсанов Д. А. Начало 24.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2509
	|ПОМЕСТИТЬ вт_НомераЗаказов
	// Ихсанов Д. А. Конец 23.09.2025
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Проведен
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа В(&МассивЗаказов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.НомерЗаказа
	// Ихсанов Д. А. Начало 24.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2509
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|ГДЕ
	|	ПредварительныйЗаказКлиентаТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
	|	И ПредварительныйЗаказКлиентаТовары.Ссылка.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиентаТовары.НомерЗаказа В(&МассивЗаказов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_НомераЗаказов.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	вт_НомераЗаказов КАК вт_НомераЗаказов
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_НомераЗаказов.НомерЗаказа";
	// Ихсанов Д. А. Конец 23.09.2025
	//Параметры запроса
	Запрос.УстановитьПараметр("НачДата",      НачДата);// Дата
	Запрос.УстановитьПараметр("КонДата",      КонДата);// Дата
	Запрос.УстановитьПараметр("Контрагент",   Маркетплейс.Контрагент );// Контрагенты
	Запрос.УстановитьПараметр("МассивЗаказов",КолонкаЗаказов);// Список значений
	
	ЗаказыЕстьВБазе = Запрос.Выполнить().Выгрузить();
	
	
	//2.2   получим все матрицы по ОЗОН
	
	Запрос = Новый Запрос;
	// Ихсанов Д. А. Начало 19.05.2026 Наряд 0000000149 от 19.05.2026 12:15:38: e1cib/data/Документ.Наряд?ref=89690050568f680711f153634c38036e
	//Запрос.Текст = "ВЫБРАТЬ
	//|	МатрицаТовары.Номенклатура КАК Номенклатура,
	//|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(16)) КАК SKU,
	//|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеКонтрагента КАК СТРОКА(50)) КАК offer_id
	//|ИЗ
	//|	Документ.Матрица.Товары КАК МатрицаТовары
	//|ГДЕ
	//|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
	//|	И МатрицаТовары.Ссылка.Договор = &Договор
	//|	И МатрицаТовары.Ссылка.Проведен
	//|    И (МатрицаТовары.Ссылка.ДатаОкончания > &ДатаОкончания
	//|			ИЛИ МатрицаТовары.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
	//|	И НЕ МатрицаТовары.Номенклатура.ПометкаУдаления";
	Запрос.Текст = "ВЫБРАТЬ
	|	МатрицаПунктыДоставки.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ вт_МатрицыПоПунктуДоставки
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|ГДЕ
	|	МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(16)) КАК SKU,
	|	ВЫРАЗИТЬ(МатрицаТовары.НаименованиеКонтрагента КАК СТРОКА(50)) КАК offer_id,
	|	МатрицаТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.Проведен
	|	И (МатрицаТовары.Ссылка.ДатаОкончания > &ДатаОкончания
	|			ИЛИ МатрицаТовары.Ссылка.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
	|	И НЕ МатрицаТовары.Номенклатура.ПометкаУдаления
	|	И МатрицаТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_МатрицыПоПунктуДоставки.Ссылка
	|			ИЗ
	|				вт_МатрицыПоПунктуДоставки)";
	// Ихсанов Д. А. Конец 19.05.2026
	//Параметры запроса
	Запрос.УстановитьПараметр("ДатаОкончания",КонецДня(ТекущаяДатаСеанса()));// Не определено
	Запрос.УстановитьПараметр("Договор",      Маркетплейс.Договор);// Не определено
	Запрос.УстановитьПараметр("Контрагент",   Маркетплейс.Контрагент);// Не определено
	// Ихсанов Д. А. Начало 19.05.2026 Наряд 0000000149 от 19.05.2026 12:15:38: e1cib/data/Документ.Наряд?ref=89690050568f680711f153634c38036e
	Запрос.УстановитьПараметр("ПунктДоставки", Маркетплейс.ПунктДоставки);
	// Ихсанов Д. А. Конец 19.05.2026
	ТаблицаМатриц = Запрос.Выполнить().Выгрузить();
	
	
	//////2.3 Создаем и заполняем таблицу для обработки///////////////////////////////////////////
	
	
	ТЗЗаказов=новый ТаблицаЗначений;
	
	ТЗЗаказов.Колонки.Добавить("ДатаСоздания",                 Новый ОписаниеТипов("Дата"));
	
	ТЗЗаказов.Колонки.Добавить("ИДЗаказа",                 Новый ОписаниеТипов("Строка"));
	ТЗЗаказов.Колонки.Добавить("АртКонтра",                Новый ОписаниеТипов("Строка"));
	ТЗЗаказов.Колонки.Добавить("Номенклатура",             Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗЗаказов.Колонки.Добавить("ШтрихКод",                 Новый ОписаниеТипов("Строка"));   ///ВерхнийШК
	ТЗЗаказов.Колонки.Добавить("РИД",                      Новый ОписаниеТипов("Строка"));   ///НижнийШК
	ТЗЗаказов.Колонки.Добавить("КолвоЗак",                 Новый ОписаниеТипов("Число"));
	ТЗЗаказов.Колонки.Добавить("СуммаЗак",                 Новый ОписаниеТипов("Число"));
