			ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,НСтр("ru=' ПОСТАВКИ WB - ОЖИДАЮТ ПОВТОРНОЙ ОТГРУЗКИ - '")+Формат(ТекущаяДатаСеанса(),"ДФ='dd.MM.yyyy чч:мм'"),ТекстОповещения);   
		Исключение
			ЗаписатьВЛог("МП_Вайлберриз","ПОСТАВКИ WB - ОЖИДАЮТ ПОВТОРНОЙ ОТГРУЗКИ " +ОписаниеОшибки(),"Ошибка");			
