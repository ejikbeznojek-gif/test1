		//	МоеОповещение=МоеОповещение+"Ожидаем проведения ПРМ "+Строка(Подсортировка)+Символы.ПС;
		//	
		//КонецЕсли;	  	
		
		Если СкладОтгрузки = МаркетПлейс.Склад Тогда
			//есои НЕ маркированный товар , переведем в статус ГОТОВ к отгрузке
			ОтправитьВОзонПодтверждениеОЗагрузкеЗаказовНакладной(МаркетПлейс,НоваяРНК,НовыйЗаказФБС.Ссылка,МаркетПлейс.Тест);	
		КонецЕсли;	             
		/////////////////////////////////////////////////    	
		МП_КонтрольКоличестваРНКиЗАКАЗА(НовыйЗаказФБС.Ссылка,"Создание");
		
	Иначе
		//Тимофеев Ю.А. 26.03.2025
		//только для теста РНК заполнена, а заказ пустой не часто , но пролетает
		НоваяРНК.УстановитьПометкуУдаления(Истина);
		
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Нет строк в заказе - удалена "+Строка(НоваяРНК),"Ошибка");
		
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
		
		ИмяФайла=ПутьЛог+"Блок_с_Сайта_"+ПрефиксМаркета+ВремяЗаписи+".txt";
		ЗначениеВФайл(ИмяФайла,ТЗССАЙТА);
		
		ИмяФайла=ПутьЛог+"Блок_для_Документа"+ПрефиксМаркета+ВремяЗаписи+".txt";
		ЗначениеВФайл(ИмяФайла,ТЗДляДок);
		
		Возврат Неопределено;
		//Тимофеев Ю.А. 26.03.2025
		
	КонецЕсли; 
	
	Возврат НовыйЗаказФБС.Ссылка;
	
КонецФункции	


Функция МП_ОЗОН_СоздатьДокументыНаСпайку(ТЗЗаказыСпайки,МаркетПлейс,СтруктураПараметров,ТекстОповещения) Экспорт ////СоздатьДокиНеКомпл
	//Замена СоздатьДокиНеКомпл(ТЗЗакНом,Маркетплейс);
	
	Если Ложь Тогда
		МаркетПлейс=Справочники.ИнетМагазины.СоздатьЭлемент();
	КонецЕсли;    	
	
	МассивНовыхЗаказов=Новый Массив;
	
	Если НЕ ТЗЗаказыСпайки.Количество() Тогда
		Возврат МассивНовыхЗаказов;
	КонецЕсли;  	
	
	//Тимофеев Ю.А. 10.07.24
	//получаем переменные из таблицы параметров  	
	
	Если СтруктураПараметров.Свойство("ЛимитПозиций") Тогда
		ЛимитПозиций=СтруктураПараметров.ЛимитПозиций;
	Иначе
		ЛимитПозиций=Ложь;
	КонецЕсли;
		
	Если СтруктураПараметров.Свойство("ЛимитПоСекторам") Тогда
		ЛимитПоСекторам=СтруктураПараметров.ЛимитПоСекторам;    
		
		ТЗлимитпоСекторам = Новый ТаблицаЗначений;
		ТЗлимитпоСекторам.Колонки.Добавить("СекторХранения");
		ТЗлимитпоСекторам.Колонки.Добавить("Факт");
		
	Иначе
		ЛимитПоСекторам=Ложь;
	КонецЕсли; 
	
	Если СтруктураПараметров.Свойство("ОграничительЧаса") Тогда
		ОграничительЧаса=СтруктураПараметров.ОграничительЧаса;
	Иначе
		ОграничительЧаса=0;     //проверить ТИМ   
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ЧасНагрузки") Тогда
		ЧасНагрузки=СтруктураПараметров.ЧасНагрузки;
	Иначе
		ЧасНагрузки=0;         //проверить ТИМ
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ИнтеграторЧаса") Тогда
		ИнтеграторЧаса=СтруктураПараметров.ИнтеграторЧаса;
	Иначе
		ИнтеграторЧаса=Ложь;
	КонецЕсли;
	
	//Получаем параметр ПереносОТГРУЗКИ
	
	Если СтруктураПараметров.Свойство("ПереносОтгрузки") Тогда
		ПереносОтгрузки=СтруктураПараметров.ПереносОтгрузки;
	Иначе
		ПереносОтгрузки=1;
	КонецЕсли; 	
	
	//Получаем параметр ПереносОТГРУЗКИ
	
	ТЗСвод=ТЗЗаказыСпайки.Скопировать();
	ТЗСвод.Свернуть("Номенклатура","КолвоЗак,СуммаЗак");          //входящую таблицу переделать ТЮА 26.02.25
	
	//тут перемещения если есть доп.склады ТИМОФЕЕВ Ю.А. вернуть
	
	//Разделение на сектора Хранений
	ТЗСвод.Колонки.Добавить("СекторХранения",новый ОписаниеТипов("СправочникСсылка.СектораХранения")) ;
		
	Для Каждого СтрН из ТЗСвод Цикл
		
		Ном = СТрН.Номенклатура; 			
		Бренд              =ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);
		СтрН.СекторХранения=ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд); 
		
	КонецЦикла; 
	
	ТЗСектора = ТЗСвод.Скопировать(,"СекторХранения");
	ТЗСектора.Свернуть("СекторХранения");
	
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(МаркетПлейс.Склад);
	
	Если ЗначениеЗаполнено(МаркетПлейс.СкладМаркировки) Тогда
		МассивСкладов.Добавить(МаркетПлейс.СкладМаркировки);
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	//создаем документы по секторам
	
	Для каждого тСектор из ТЗСектора Цикл
		
		ТоварПоСекторам=ТЗСвод.НайтиСтроки(Новый Структура("СекторХранения",тСектор.СекторХранения));
		
		ТЗСводНовый = ТЗСвод.СкопироватьКолонки();
		
		Для Каждого НайдТовар из ТоварПоСекторам Цикл
			НовСтрТЗ = ТЗСводНовый.Добавить();
			ЗаполнитьЗначенияСвойств(НовСТрТЗ,НайдТовар);
		КонецЦикла;
		
		
		//Тимофеев Ю.А.
		//контроль по количеству товара в заказе
		ТекЧас = Час(ТекущаяДата());
		
		Если ТекЧас>7 и ТекЧас < ЧасНагрузки Тогда
			
			//больше 8 чтобы дать утренним загрузкам большим в 5 утра и 6 утра без ограничений
			//час нагрузки по умолчанию 18
			
			Если Цел(ТекЧас/ИнтеграторЧаса) = ТекЧас/ИнтеграторЧаса Тогда
				//если условие 1 каждый час , 2 каждый второй час, 3 каждый третий час				
				Если ТЗСводНовый.Количество()< ОграничительЧаса Тогда
					продолжить;
				КонецЕсли; 		
			КонецЕсли;   
			
		КонецЕсли;
		//контроль по количеству товара в заказе
		//Тимофеев Ю.А.	
			
		//тут три пакета
		//нет в наличии
		//со склада ФБС
		//со склада маркировки  		
		
		МассивСкладов = Новый Массив;
		МассивСкладов.Добавить(МаркетПлейс.Склад);
		
		Если ЗначениеЗаполнено(МаркетПлейс.СкладМаркировки) Тогда
			МассивСкладов.Добавить(МаркетПлейс.СкладМаркировки);
		КонецЕсли;
		
		//таблицы 4 варианта  		
		
		//1.нет на обоих складах
		//Заказ ФСБ, НЕ РНК в работе , соощить все - что товара нет
		
		ТЗСкладыНЕТ      = Новый ТаблицаЗначений;
		ТЗСкладыНЕТ.Колонки.Добавить("Номенклатура");
		ТЗСкладыНЕТ.Колонки.Добавить("КолКонФакт");  
		
		//2.Есть на складе ФБС
		//Заказ ФСБ,ДА РНК на склад ,Склад ФБС
		
		ТЗСкладФБС      = Новый ТаблицаЗначений;
		ТЗСкладФБС.Колонки.Добавить("Номенклатура");
		ТЗСкладФБС.Колонки.Добавить("КолКонФакт");
		
		//3.Есть на складе Маркировка
		//Заказ ФСБ,ДА РНК на склад, Склад Маркировка  
		
		ТЗСкладМаркаФБС      = Новый ТаблицаЗначений;
		ТЗСкладМаркаФБС.Колонки.Добавить("Номенклатура");
		ТЗСкладМаркаФБС.Колонки.Добавить("КолКонФакт");
		
		//4.НЕТ НА ФБС, но Есть на складе Маркировка
		//Заказ ФСБ,НЕТ РНК в работе, Склад ФБС, Ждем проведения перемещения с маркировки на склад ФБС  
		
		ТЗСкладФБСНет      = Новый ТаблицаЗначений;
		ТЗСкладФБСНет.Колонки.Добавить("Номенклатура");
		ТЗСкладФБСНет.Колонки.Добавить("КолКонФакт");
		
		//4+ создаем перемещение
		ТЗНетНаличии      = Новый ТаблицаЗначений;
		ТЗНетНаличии.Колонки.Добавить("Номенклатура"); 
		ТЗНетНаличии.Колонки.Добавить("Комплектующие");
		ТЗНетНаличии.Колонки.Добавить("КолКонФакт");
		
		Для каждого тСпайка из  ТЗСводНовый Цикл 			
			
			ОтветнаяСтрукутура= МП_ОбработкаСпайкиПолучимОстаткиПоСкладам(МаркетПлейс,тСпайка.Номенклатура,тСпайка.КолвоЗак);
			
			//СтруктураСпайки.Вставить("НетВналичии",ТЗНетНаличии);
			//--нет на обоих складах
			//СтруктураСпайки.Вставить("СкладФБС",   ТЗСкладФБС);
			//--нет на складе ФБС
			//СтруктураСпайки.Вставить("СкладМарка", ТЗСкладМаркаФБС);
			//--нет на складе Маркировки
			
			Если ОтветнаяСтрукутура.НетВналичии.Количество()>0 тогда
				
				//1. не хватает товара на обоих склада и склад ФБС и склад маркировки
							
				НовНетНаСкладах = ТЗСкладыНЕТ.Добавить();
				НовНетНаСкладах.Номенклатура = тСпайка.Номенклатура;
				НовНетНаСкладах.КолКонФакт   = тСпайка.КолвоЗак;					
				
			Иначе
				
				Если ОтветнаяСтрукутура.СкладФБС.Количество()=0 Тогда
					//2. значит ,что все есть на складе ФБС 	
					
					НовФБС = ТЗСкладФБС.Добавить();
					НовФБС.Номенклатура = тСпайка.Номенклатура;
					НовФБС.КолКонФакт   = тСпайка.КолвоЗак;
					
				Иначе	
					
					Если ОтветнаяСтрукутура.СкладМарка.Количество()=0 Тогда
						//3. начит ,что все есть на складе Марка 					
						
						НовМарка = ТЗСкладМаркаФБС.Добавить();  						
						НовМарка.Номенклатура = тСпайка.Номенклатура;
						НовМарка.КолКонФакт   = тСпайка.КолвоЗак;
						
					Иначе	
						
						//4. ФБС но не хватает , ждем перемещения
						НовФБС = ТЗСкладФБСНет.Добавить();
						НовФБС.Номенклатура = тСпайка.Номенклатура;
						НовФБС.КолКонФакт   = тСпайка.КолвоЗак;
						
						//для перемещения
						Для Каждого стрФБСНет из ОтветнаяСтрукутура.СкладФБС Цикл							
							ПеремФБС= ТЗНетНаличии.Добавить();                   							
							ЗаполнитьЗначенияСвойств(ПеремФБС,стрФБСНет);        							
						КонецЦикла;
						
					КонецЕсли;  				
					
				КонецЕсли;      		
				
			КонецЕсли;					
			
		КонецЦикла;      		
		
		//////////////разделение по лимиту позиций
		ЕстьРаздел=МаркетПлейс.РазбиватьПоЛимитуКоличество;
		
		ЛимитПозиций = 0;
		
		Если ЕстьРаздел Тогда
			
			ЛимитПозиций = МаркетПлейс.ЛимитПоКоличеству;
			
		КонецЕсли;	
		//////////////разделение по лимиту позиций
		
		СостояниеВРаботе = Перечисления.СостоянияНакладной.ВРаботе;
		
		СостояниеНаСклад = Перечисления.СостоянияНакладной.КОтправкеНаСклад;
		
		//со склада просто ФБС 
		
		/////////////////////////////////////////////////////// 
		//Тимофеев Ю.А. 22.05.25
		ПростойНаСайте = МаркетПлейс.ИДКомпании;
		
		Попытка 
			ПростойНаСайте = Число(МаркетПлейс.ИДКомпании);	
		Исключение
			ПростойНаСайте =0;	
		КонецПопытки;
		//Тимофеев Ю.А. 22.05.25
		///////////////////////////////////////////////////////

		
		КолВоСкладФБС =   ТЗСкладФБС.Количество(); 
		НужноЗагружать = Истина;
		ТекущийЧас  = Час(ТекущаяДатаСеанса());
		
		//максимальное время простоя на сайте 11 часов 
		Если (ТекущийЧас>=11 и ТекущийЧас<=12) или (ТекущийЧас>=22 и ТекущийЧас<=23) Тогда
			
			НужноЗагружать = Истина;    
			
		Иначе
				
			Если  КолВоСкладФБС < ПростойНаСайте Тогда	
				
				НужноЗагружать = ЛОжь;	
				
			КонецЕсли;			 
			
		КонецЕсли;   
		
		Если КолВоСкладФБС >0 и НужноЗагружать Тогда   
			
			ВсегоТовараПоТЗ = ТЗСкладФБС.Итог("КолконФакт");
			
			//Тимофеев Ю.А. ID-21012   
			//для СПАЕЙ 100  
			
			Если ВсегоТовараПоТЗ>100 Тогда
				
				ЗаписатьВЛог("МП_Озон","Спайки в наличии Больше 100 !"+Строка(ВсегоТовараПоТЗ),"Информация");
				
				ТЗСкладФБС.Сортировать("КолконФакт Убыв"); 
				//копию
				РаздТЗСкладФБС = ТЗСкладФБС.Скопировать();
				//очистим
				РаздТЗСкладФБС.Очистить();
				ОбработаноСтрок=0;
				
				Для Каждого Стр из ТЗСкладФБС Цикл
					
					НовСтрРазТЗ = РаздТЗСкладФБС.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрРазТЗ,Стр);
					ОбработаноСтрок=ОбработаноСтрок+Стр.КолКонФакт;
					
					Если ОбработаноСтрок>=100 Тогда
					//	ПолученныйЗаказ =  МП_ОЗОН_Связка_ЗАКАЗ_РНК(МаркетПлейс,МаркетПлейс.Склад,ТЗЗаказыСпайки,ТЗСкладФБС ,ЛимитПозиций,СостояниеНаСклад,тСектор.СекторХранения,ПереносОтгрузки,Истина,ТекстОповещения); 
						ПолученныйЗаказ =  МП_ОЗОН_Связка_ЗАКАЗ_РНК(МаркетПлейс,МаркетПлейс.Склад,ТЗЗаказыСпайки,РаздТЗСкладФБС,ЛимитПозиций,СостояниеНаСклад,тСектор.СекторХранения,ПереносОтгрузки,Истина,ТекстОповещения); 
						
						Если ПолученныйЗаказ<>Неопределено и МассивНовыхЗаказов.Найти(ПолученныйЗаказ)=неопределено Тогда
							МассивНовыхЗаказов.Добавить(ПолученныйЗаказ);
						КонецЕсли; 
						//обнилим тз и счетчик	
						РаздТЗСкладФБС.Очистить(); 
						ОбработаноСтрок=0;
					КонецЕсли;				
					
				КОнецЦикла;   
				
				//если что то осталось - создадим еще один комплект
				
				Если РаздТЗСкладФБС.Количество()>0 Тогда
				   //	ПолученныйЗаказ =  МП_ОЗОН_Связка_ЗАКАЗ_РНК(МаркетПлейс,МаркетПлейс.Склад,ТЗЗаказыСпайки,ТЗСкладФБС ,ЛимитПозиций,СостояниеНаСклад,тСектор.СекторХранения,ПереносОтгрузки,Истина,ТекстОповещения); 
						ПолученныйЗаказ =  МП_ОЗОН_Связка_ЗАКАЗ_РНК(МаркетПлейс,МаркетПлейс.Склад,ТЗЗаказыСпайки,РаздТЗСкладФБС,ЛимитПозиций,СостояниеНаСклад,тСектор.СекторХранения,ПереносОтгрузки,Истина,ТекстОповещения); 
						
					Если ПолученныйЗаказ<>Неопределено и МассивНовыхЗаказов.Найти(ПолученныйЗаказ)=неопределено Тогда
						МассивНовыхЗаказов.Добавить(ПолученныйЗаказ);
					КонецЕсли; 
					
					РаздТЗСкладФБС.Очистить();				 
				КонецЕсли; 	 
				
			Иначе
				//Тимофеев Ю.А. ID-21012 			
				
				ПолученныйЗаказ =  МП_ОЗОН_Связка_ЗАКАЗ_РНК(МаркетПлейс,МаркетПлейс.Склад,ТЗЗаказыСпайки,ТЗСкладФБС,ЛимитПозиций,СостояниеНаСклад,тСектор.СекторХранения,ПереносОтгрузки,Истина,ТекстОповещения); 
				
				Если ПолученныйЗаказ<>Неопределено и МассивНовыхЗаказов.Найти(ПолученныйЗаказ)=неопределено Тогда
					
					МассивНовыхЗаказов.Добавить(ПолученныйЗаказ);
				КонецЕсли; 
				
			КонецЕсли;
		Иначе
			ТЗСкладФБС.Очистить();
		КонецЕсли;  		
		
		//со склада маркировки 
		КолвоСкладМаркаФБС =ТЗСкладМаркаФБС.Количество();
		НужноЗагружать = Истина;
		ТекущийЧас  = Час(ТекущаяДатаСеанса());
		
		//максимальное время простоя на сайте 11 часов 
		Если (ТекущийЧас>=11 и ТекущийЧас<=12) или (ТекущийЧас>=22 и ТекущийЧас<=23) Тогда
			
