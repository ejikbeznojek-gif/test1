		нн=0;
		счтот=0;
		счтзак=0;
		Пока нн<ТЗВыб.Количество() Цикл
			Выб=ТЗВыб.Получить(нн);
			МКол.Добавить(Выб.Колво);
			Если Выб.Закрыта Тогда
				счтзак=счтзак+1;
			Иначе
				счтот=счтот+1;
				ИДП=Выб.НомерОтгрузки;	
			КонецЕсли;	
			Счт=Счт+1;
			ТотКол=ТотКол+Выб.Колво;
			нн=нн+1;
		КонецЦикла;	
		
		//Пока Выб1.Следующий() Цикл
		//	ЗакрПост1=ПровПоставку(МкПл,Выб1.НомерОтгрузки);
