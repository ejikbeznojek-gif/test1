			Соединение = Новый HTTPСоединение(АдресТ,443,,,,,Новый ЗащищенноеСоединениеOpenSSL);  
		Иначе
			Соединение = Новый HTTPСоединение(АдресТ);
		КонецЕсли;
	Исключение
		#Если Клиент Тогда
			Сообщить("Ошибка при попытке соединения "+ОписаниеОшибки());
		#КонецЕсли
		
	КонецПопытки;
	sender_seller_addr="";
	refund_seller_addr="";
	pickup_seller_addr="";
	КолСтр=1;
	// /router/rest
	HTTP_запрос = новый HTTPзапрос();
	АдресРесурса="/router/rest";
	HTTP_запрос.АдресРесурса=АдресРесурса+"?"+ПолучитьДопАдр6(МкПл,"sender");
	Ответ = Соединение.Получить(HTTP_запрос);
	// ИмяВыходногоФайла
	
	Если Ответ.КодСостояния<=400 Тогда
		ВозвСтр =Ответ.ПолучитьТелоКакСтроку();
		ЧтениеJSON1 = Новый ЧтениеJSON;
		ЧтениеJSON1.УстановитьСтроку(ВозвСтр);
		Soda = ПрочитатьJSON(ЧтениеJSON1);
