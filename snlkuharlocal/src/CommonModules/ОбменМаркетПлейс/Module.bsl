Функция УстранПроблКлюч(ВхСтр)
	Рез="";
	н=1;
	ДлС=СтрДлина(ВхСтр);
	е1=Ложь;
	е2=Ложь;
	Пока н<=ДлС Цикл
		ТП=Сред(ВхСтр,н,1);
		
		//е3=Ложь;
		Если (ТП="{") ИЛИ ТП="," Тогда
			е1=Истина;
		КонецЕсли;
		
		Если ТП="""" Тогда
			
			Если е1 И НЕ е2 Тогда
				
				е2=Истина;
			Иначе
				
				е1=Ложь;
				е2=Ложь;
				
			КонецЕсли;
			
			
		КонецЕсли;
		
		
		
		Если е1 И е2 И ((ТП=" ") ИЛИ (ТП="-") ИЛИ (ТП="/") ИЛИ (ТП="\") ИЛИ (ТП=":") ИЛИ (ТП="(") ИЛИ (ТП=")") ИЛИ (ТП="&") ИЛИ (кодСимвола(ТП)=10) ИЛИ (кодСимвола(ТП)=9) ИЛИ (кодСимвола(ТП)=31) ИЛИ (кодСимвола(ТП)=32)) Тогда
			//сообщить(рез);
			//Рез=Рез+"_";
		Иначе
			//Если е1 И е2 И (кодСимвола(ТП)>32) Тогда
			Рез=Рез+ТП;
		КонецЕсли;	
		Если ТП=":" И е1 И е2 Тогда
			е1=Ложь;
			е2=Ложь;
		КонецЕсли;
		н=н+1;
	КонецЦикла;	
	Возврат Рез;
