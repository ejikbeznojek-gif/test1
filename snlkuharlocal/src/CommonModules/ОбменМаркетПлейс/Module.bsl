Процедура ПроверитьИПоделить(Зак, Лим, МенятьДоговор=Истина) Экспорт
	
	
	РНКСсыл=Зак.ДокОснование;
	КолК=РНКСсыл.Комплектующие.Итог("Количество");
	
	КолТ=РНКСсыл.Товары.Итог("Количество");
	Если Окр(КолК/Лим)<2 Тогда
		Возврат;
	КонецЕсли;
	КолСтрТов=РНКСсыл.Товары.Количество();
	ПослСтр=РНКСсыл.Товары.Получить(КолСтрТов-1);
	НомУбир=ПослСтр.Номенклатура;
	//1 ном будем убирать
	//Если РНКСсыл.Товары.Количество()>1 Тогда
	//	Возврат;
	//КонецЕсли;
	
	//Если НЕ (Зак.Товары.Количество()=Цел(КолК)) Тогда
	//	Возврат;
	//КонецЕсли;
	КолНовДок=Окр(КолК/Лим)-1;
	ПК=1-(Окр(КолК/Лим)-Цел(КолК/Лим));
	ПН=Зак.Товары.Количество()-1;
	Если КолНовДок Тогда
		ЗаписатьВЛог("ВБРЗ","Начало выполнения. Задача: Разделение документов по кол-ву. !","Информация");
		НачатьТранзакцию();
		// Кухарь А.Ю. 07.04.2025 начало 
		//Временно
		ЗаписатьВЛог("Отладка","Начало транзакции маркетплейсы №6","Информация"); 
		// Кухарь А.Ю. 07.04.2025 конец
		Попытка
			ЗакИсх=Зак.ПолучитьОбъект();
			РНКИсх=РНКСсыл.ПолучитьОбъект();
			РЗ1=РежимЗаписиДокумента.Запись;
			РЗ2=РежимЗаписиДокумента.Запись;
			Коэф=Цел(КолК/КолТ);
			
			Если ЗакИсх.Проведен Тогда
				РЗ1=РежимЗаписиДокумента.Проведение;
				ЗакИсх.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;
			
			Если РНКИсх.Проведен Тогда
				РЗ2=РежимЗаписиДокумента.Проведение;
				РНКИсх.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;	
			НомДок=0;
			КолИзм=0;
			к=ЗакИсх.Товары.Количество()-1;
			Пока (НомДок<КолНовДок) Цикл
				Если ПН<=1 Тогда
					Прервать;
				КонецЕсли;	
				ТекЗак=Документы.ЗаказКлиентаFBS.СоздатьДокумент();
				ТекДок=Документы.РасходнаяНакладная.СоздатьДокумент();
				ЗаполнитьЗначенияСвойств(ТекЗак,ЗакИсх,,"Номер,Дата,ДокОснование");
				ТекЗак.Дата=ТекущаяДата();
				ТекЗак.УстановитьНовыйНомер();
				ЗаполнитьЗначенияСвойств(ТекДок,РНКИсх,,"Номер,Дата");
				КолДок=0;
				
				Пока (к>=0) И ((КолДок*Коэф)<(Лим)) Цикл
					тс=ЗакИсх.Товары.Получить(к);
					//Если НЕ тс.Отменен И тс.Номенклатура=НомУбир Тогда
					
					Если  НЕ тс.Отменен или НЕ тс.ВычеркОфис или Не тс.ВычеркСклад Тогда //Тимофеев Ю.А.
						нс=ТекЗак.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(нс,тс,,"НомерСтроки");
						ЗакИсх.Товары.Удалить(к);
						КолИзм=КолИзм+1;
						КолДок=КолДок+1;
					КонецЕсли;	
					к=к-1;
				КонецЦикла;	
				ПН=к;
				
				
				//ТекДок.ОтгрузкаКомплектов =истина;
				Если КолДок>0 Тогда
					нст=ТекДок.Товары.Добавить();
					тст=РНКИсх.Товары.Получить(КолСтрТов-1);
					
					ЗаполнитьЗначенияСвойств(нст,тст,,"НомерСтроки");
					нст.Заявка=КолДок;
					нст.ПодтвержденнаяЗаявка=КолДок;
					нст.Количество=КолДок;
					
					тст.Заявка=тст.Заявка-КолДок;
					тст.ПодтвержденнаяЗаявка=тст.ПодтвержденнаяЗаявка-КолДок;
					тст.Количество=тст.Количество-КолДок;
					ТекДок.Дата=ТекущаяДата();
					УстановитьНомерДокументаКлиентСервер(ТекДок);
					
					ЗаполнитьКомплектующие(ТекДок);
					
					
					ПунктДоставки_ПриИзменении(ТекДок, МенятьДоговор);
					ТекДок.Записать(РЗ2);
					ТекЗак.ДокОснование=ТекДок.Ссылка;
					ТекЗак.Записать(РЗ1);
					ЗаписатьВЛог("ВБРЗ","Процесс выполнения. Задача: Разделение документов по кол-ву. Записан нов. документ "+Строка(ТекДок.Ссылка),"Информация");
				КонецЕсли;
				НомДок=НомДок+1;
			КонецЦикла;
			ЗакИсх.Записать(РЗ1);
			РНКИсх.Комплектующие.Очистить();
			ЗаполнитьКомплектующие(РНКИсх);
			РНКИсх.Записать(РЗ2);
			ЗаписатьВЛог("ВБРЗ","Процесс выполнения. Задача: Разделение документов по кол-ву. Записан исх. документ "+Строка(РНКИсх.Ссылка),"Информация");
			Если ТранзакцияАктивна() Тогда
				ЗафиксироватьТранзакцию();
			КонецЕсли;
		Исключение
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			ЗаписатьВЛог("ВБРЗ","Фин выполнения. Задача: Разделение документов по кол-ву. Возникла ошибка! "+ОписаниеОшибки(),"Информация");
		КонецПопытки;
		ЗаписатьВЛог("ВБРЗ","Фин выполнения. Задача: Разделение документов по кол-ву. Успешно!","Информация");
	КонецЕсли;
	
КонецПроцедуры	

