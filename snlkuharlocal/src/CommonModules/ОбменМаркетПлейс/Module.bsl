Процедура ПроверкаЗаказовФБСНаДублизаказов(МаркетПлейс)   Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	СУММА(1) КАК Количество
	|ПОМЕСТИТЬ ВсеЗаказы
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &ДатаС И &ДатаПо
	|	И НЕ ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.ПометкаУдаления
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа <> """"
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.НомерЗаказа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеЗаказы.НомерЗаказа КАК НомерЗаказа,
	|	ВсеЗаказы.Количество КАК Количество
	|ИЗ
	|	ВсеЗаказы КАК ВсеЗаказы
	|ГДЕ
	|	ВсеЗаказы.Количество > 1";   
	
	Запрос.УстановитьПараметр("Контрагент",МаркетПлейс.Контрагент);// Дата
	Запрос.УстановитьПараметр("ДатаС",НачалоДня(ТекущаяДатаСеанса())-2*86400);// Дата
	Запрос.УстановитьПараметр("ДатаПо",ТекущаяДатаСеанса());// Дата
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Сооб="";
	
	Если Результат.Количество()>0 Тогда        
		
		Для каждого СтрДубль из Результат Цикл
			Сооб=Сооб+СтрДубль.НомерЗаказа;
		КонецЦикла;	
		Сооб=Сооб+Символы.ПС+" наити и исправить";	
		
		СписокПолучателей=новый СписокЗначений;
		
		СписокПолучателей.Добавить("timofeev@collant.ru");   //пока на время теста только мне						
		СписокПолучателей.Добавить("ikhsanov@collant.ru"); 
		ТекстОповещения="Проблема дубли заказов ФБС! "+Строка(МаркетПлейс)+Символы.ПС+Сооб;
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,"Дубли заказов ФБС "+Строка(МаркетПлейс),ТекстОповещения);
		
	КонецЕсли;
	
	
КонецПроцедуры

//Будем считать , если у группы товара (родителя) 
