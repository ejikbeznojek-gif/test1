Процедура СохранимВЕКСЕЛЬ(ТЗ, ИмяФайла,ПутькПапке) Экспорт
	
	Если ПутькПапке="" Тогда
		
	Иначе 		
		
		Сообщить("Начало "+ИмяФайла+Строка(ТекущаяДата()));
		
		ИсточникДанных   = Новый ОписаниеИсточникаДанных(ТЗ);
		
		ПостроительОтчета = Новый ПостроительОтчета;
		ПостроительОтчета.ИсточникДанных = ИсточникДанных;
		
		ПостроительОтчета.Выполнить();
		
		ТП=Новый ТабличныйДокумент;
		ПостроительОтчета.Вывести(ТП);   	
