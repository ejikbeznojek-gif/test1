Функция МП_Вайлдберриз_ПроверитьСтатусЗаказа(МаркПл,НомЗак) Экспорт
	
	ПолСтр = МП_Вайлдберриз_ВернутьСтруктуру_orders(НомЗак);
	
	Соединение     = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	ЗаголовокHTTP  = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);
	
	HTTP_запрос = новый HTTPзапрос();
	HTTP_запрос.АдресРесурса="api/v3/orders/status"; 
	
	РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
	ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
	
	HTTP_запрос.Заголовки = ЗаголовокHTTP;
	HTTP_запрос.УстановитьТелоИзСтроки(ПолСтр);   	
	
	Ответ = Соединение.ОтправитьДляОбработки(HTTP_запрос);  // ИмяВыходногоФайла		
	
	Если Ответ.КодСостояния<=400 Тогда
		
		ВозвСтр =Ответ.ПолучитьТелоКакСтроку();
		
		Попытка
			
			ЧтениеJSON0       = Новый ЧтениеJSON;
			ЧтениеJSON0.УстановитьСтроку(ВозвСтр);
			СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);
			
			ПерваяСтрока   = СтруктураИзСтроки.orders[0];
			
			supplierStatus = ПерваяСтрока.supplierStatus;
			wbStatus       = ПерваяСтрока.wbStatus;
			
			СтатусЗаказа = "";
			
			Если supplierStatus="new" Тогда
				
				СтатусЗаказа = "Новый (new)";
			ИначеЕсли supplierStatus="confirm" Тогда
				
				СтатусЗаказа = "На сборке (confirm)";
			ИначеЕсли supplierStatus="complete" Тогда
				
				СтатусЗаказа = "В доставке (complete)";
			ИначеЕсли supplierStatus="cancel" Тогда
				
				СтатусЗаказа = "Отменено продавцом (cancel)";
			КонецЕсли;
			
			ПодСтатус ="";
			
			Если wbStatus="waiting" Тогда
				
				ПодСтатус = "Cборочное задание в работе (waiting)";
				
			ИначеЕсли wbStatus="sorted" Тогда
				
				ПодСтатус = "Cборочное задание отсортировано (sorted)";
				
			ИначеЕсли wbStatus="sold" Тогда
				
				ПодСтатус = "Cборочное задание получено покупателем (sold)";
				
			ИначеЕсли wbStatus="canceled" Тогда
				
				ПодСтатус = "Отмена сборочного задания (canceled)";
				
			ИначеЕсли wbStatus="canceled_by_client" Тогда
				
				ПодСтатус = "Покупатель отменил заказ при получении (canceled_by_client)";
				
			ИначеЕсли wbStatus="declined_by_client" Тогда
				
				ПодСтатус = "Покупатель отменил заказ в первый чаc (declined_by_client)";
				
			ИначеЕсли wbStatus="defect" Тогда
				
				ПодСтатус = "Отмена сборочного задания по причине брака (defect)";
				
			ИначеЕсли wbStatus="ready_for_pickup" Тогда
				
				ПодСтатус = "Сборочное задание прибыло на ПВЗ (ready_for_pickup)";
				
				
			КонецЕсли;
			
			Возврат Строка(НомЗак)+" статус :" +СтатусЗаказа +" - " +ПодСтатус;
			
		Исключение
			
			Возврат Строка(НомЗак)+ВозвСтр;
			
		КонецПопытки;
	Иначе
		
		Возврат "ошибка запроса ";
		
	КонецЕсли;	
	
	
	Возврат "";
	
КонецФункции        

Функция МП_Вайлдберриз_КонтрольКоличестваЗаказов(МаркПл) Экспорт //Тимофеев 21.05.24	
	
	//для Вайлбдериз
	
	Если ЗначениеЗаполнено(МаркПл.Token2) Тогда
		НашКлючАдмин =МаркПл.Token2;
	Иначе
		НашКлючАдмин =МаркПл.Token;
	КонецЕсли;
	
	HTTP_запрос = Новый HTTPзапрос();   	
	АдресТ      = МаркПл.АдресРесурса; 	
	
	//для фильта по складу получателя
	ИндетификаторСклада = Число(МаркПл.warehouseId);
	
	Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);			
	HTTP_запрос.Заголовки    = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);
	
	HTTP_запрос.АдресРесурса = "/api/v3/orders/new";  
	КоличествоНовыхЗаказов = 0;
	
	Попытка
		
		ОтветЗапроса = Соединение.Получить(HTTP_запрос); 
		
		Если ОтветЗапроса.КодСостояния < 400 Тогда
			
			ВозвСтр0 = ОтветЗапроса.ПолучитьТелоКакСтроку();
			
			ЧтениеJSON0       = Новый ЧтениеJSON;
			ЧтениеJSON0.УстановитьСтроку(ВозвСтр0);
			СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);
			
			МассивЗаказов = СтруктураИзСтроки["orders"];    			
			
			Для каждого СтрМассива из МассивЗаказов Цикл	 				
				
				Попытка
					
					//фильтр по складу получателю
					
					Если СтрМассива.warehouseId<>ИндетификаторСклада Тогда
						Продолжить;
					КонецЕсли;			
					
				Исключение
					
				КонецПопытки;	
				КоличествоНовыхЗаказов =КоличествоНовыхЗаказов +1;
			КонецЦикла;		
			
		КонецЕсли;	
		
		
	Исключение
		
	КонецПопытки;		
	
	Возврат КоличествоНовыхЗаказов;
	
КонецФункции  

Процедура МП_Вайлбериз_ОтменаЗаказовПоВычеркамОфисаИСклада(Маркетплейс,ВыгрузкаНаСайт=Истина,КоличествоДней=7,ПрефиксМаркета="") Экспорт
	//ID-16465
	//выбираем все заказы ВАЙЛБЕРИЗ за крайние 7 дней
	//проведенные и у которых есть ВЫЧЕРКИ , но не переданы на сайт
	
	КонДата = ТекущаяДата();
	НачДата = КонДата - 86400*КоличествоДней;   //за крайниее 7 дней проверяем
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ДокЗаказ,
	|	ЗаказКлиентаFBSТовары.ВычеркОфис КАК ВычеркОфис,
	|	ЗаказКлиентаFBSТовары.ВычеркСклад КАК ВычеркСклад,
	|	ЗаказКлиентаFBSТовары.ПереданоНаСайт КАК ПереданоНаСайт,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЛОЖЬ КАК ОтменаНаСайте
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Проведен
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &НачДата И &КонДата
	|	И (ЗаказКлиентаFBSТовары.ВычеркСклад
	|			ИЛИ ЗаказКлиентаFBSТовары.ВычеркОфис
	|			ИЛИ ЗаказКлиентаFBSТовары.Отменен)
	|	И НЕ ЗаказКлиентаFBSТовары.ПереданоНаСайт";
	
	Запрос.УстановитьПараметр("НачДата",НачДата);// Дата
	Запрос.УстановитьПараметр("КонДата",КонДата);// Дата
	Запрос.УстановитьПараметр("Контрагент",Маркетплейс.Контрагент);// Контрагенты
	
	ТЗЗаказов = Запрос.Выполнить().Выгрузить();
	ВсегоЗаказов = ТЗЗаказов.Количество();
	Если ВсегоЗаказов>0 Тогда
		
		Если Маркетплейс.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Отмена заказов (вычерки) "+Строка(ВсегоЗаказов),"Информация");
		КонецЕсли;
		
		СпрСостояниеУКлиента = Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(24);      //WБ отклонено
		
		//отменим заказы на сайте
		
		
		
		Если ВыгрузкаНаСайт Тогда
			
			МП_Вайлбериз_ОтменаЗаказов(Маркетплейс,ТЗЗаказов,ПрефиксМаркета);
			
		иначе
			
			ТЗЗаказов.ЗаполнитьЗначения(Истина,"ОтменаНаСайте");
			
		КонецЕсли;
		
		ТЗДОКЗАК = ТЗЗаказов.Скопировать(,"ДокЗаказ");
		ТЗДОКЗАК.Свернуть("ДокЗаказ");
		
		//обработаем документ Заказ ФБС
		//передано на сайт и статус Состояние у клиента изменим
		
		Для каждого Док из ТЗДОКЗАК Цикл
			
			Отбор = Новый Структура();
			Отбор.Вставить("ДокЗаказ",Док.ДокЗаказ);
			Отбор.Вставить("ОтменаНаСайте",Истина); 		
			
			СтрокиЗаказов  = ТЗЗаказов.НайтиСтроки(Отбор);
			Если СтрокиЗаказов.Количество() > 0 Тогда
				
				ОбЗаказ = Док.ДокЗаказ.ПолучитьОбъект();
				
				Если ложь Тогда 
					ОбЗаказ = Документы.ЗаказКлиентаFBS.СоздатьДокумент();
				КонецЕсли;
				
				для каждого НайдЗаказ из СтрокиЗаказов Цикл
					
					ОтборЗак = Новый Структура();
					ОтборЗак.Вставить("НомерЗаказа",НайдЗаказ.НомерЗаказа);
					СтЗаказов  = ОбЗаказ.Товары.НайтиСтроки(ОтборЗак);
					
					Если СтЗаказов.Количество() > 0 Тогда
						
						Для Каждого СтрЗак из СтЗаказов Цикл
							СтрЗак.ПереданоНаСайт    = Истина;
							СтрЗак.СостояниеУКлиента = СпрСостояниеУКлиента;
							СтрЗак.Количество        = 0; //обнуляем
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			
			Если ОбЗаказ<>Неопределено и ОбЗаказ.Модифицированность() Тогда
				
				Попытка
					ОбЗаказ.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					ОбЗаказ.Записать(РежимЗаписиДокумента.Запись);
				КонецПопытки;
				
				МП_КонтрольКоличестваРНКиЗАКАЗА(ОбЗаказ.Ссылка,"Отмена");
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Маркетплейс.Тест Тогда
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Конец отмены заказов (вычерки) ","Информация");
		КонецЕсли;		
	КонецЕсли;   	
	
КонецПроцедуры

Процедура МП_Вайлбериз_ОтменаЗаказов(МаркПл,ТЗЗаказов,ПрефиксМаркета="") Экспорт
	
	//https://suppliers-api.wildberries.ru/api/v3/orders/{order}/cancel
	
	Если ТЗЗаказов.Количество()=0 Тогда
		
		#Если Клиент Тогда
			Сообщить("Нет данных к выгрузке на маркетпллейс.Отмена!");
		#КонецЕсли
		
		Возврат;
		
	КонецЕсли;
	
	
	//Тимофеев Ю.А. Начало   17-02-2025
	//
	//
	
	//если ТЗ получим Массив
	Если ТипЗнч(ТЗЗаказов)=Тип("ТаблицаЗначений") Тогда
		
		МассивЗаказов= ТЗЗаказов.ВыгрузитьКолонку("НомерЗаказа");
		
	Иначе
		
		МассивЗаказов =ТЗЗаказов;
		
	КОнецЕсли; 	
	//Тимофеев Ю.А. Конец    17-02-2025
	
	
	
	ТотСтр="";
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Начало выполнения. Задача: Отмена заказов ВБ. !","Информация");
	КонецЕсли;
	
	HTTP_запрос = новый HTTPзапрос();
	
	АдресТ     = МаркПл.АдресРесурса; 
	
	Соединение = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	HTTP_запрос = Новый HTTPзапрос();
	
	ЗаголовокHTTP = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);			
	
	Для Каждого ТЗак Из МассивЗаказов Цикл
		
		Попытка
			
			HTTP_запрос.АдресРесурса="/api/v3/orders/"+СокрЛП(ТЗак)+"/cancel";
			
			HTTP_запрос.Заголовки = ЗаголовокHTTP;  				
			Ответ = Соединение.Изменить(HTTP_запрос); 
			
			ВС=Ответ.ПолучитьТелоКакСтроку();
			
			#Если Клиент  тогда
				Сообщить(Строка(Ответ.КодСостояния)+" ответ "+ВС);  					
			#КонецЕсли
			
			Если Ответ.КодСостояния < 400 Тогда  
				
				ТотСтр=ТотСтр+"Успешно выгружен блок отмены заказов "+ТЗак+Символы.ПС;	
				
				#Если Клиент  тогда
					Сообщить("Успешно выгружен блок отмены заказов "+ТЗак);  					
				#КонецЕсли
				
				Если ТипЗнч(ТЗЗаказов)=Тип("ТаблицаЗначений") Тогда
					НайтиВТЗ=ТЗЗаказов.Найти(ТЗак,"НомерЗаказа");
					
					Если НайтиВТЗ<> Неопределено Тогда
						НайтиВТЗ.ОтменаНаСайте=Истина;
					КонецЕсли;
				КонецЕсли;
				
			Иначе
				ТотСтр=ТотСтр+"Ошибка при выгрузке блока отмены "+ТЗак+" - "+Строка(Ответ.КодСостояния)+Символы.ПС;
				
				#Если Клиент  тогда
					Сообщить("Ошибка при выгрузке блока отмены "+ТЗак+" - "+Строка(Ответ.КодСостояния),СтатусСообщения.ОченьВажное);  					
				#КонецЕсли
				
			КонецЕсли;       			
			
		Исключение    			
			#Если клиент Тогда
				Сообщить(ОписаниеОшибки());
			#КонецЕсли			
			ТотСтр=ТотСтр+ ОписаниеОшибки();
		КонецПопытки; 		
		
	КонецЦикла;
	
	
	//если интернет есть значит все прогнали и считаем что передали на сайт
	
	Если ТипЗнч(ТЗЗаказов)=Тип("ТаблицаЗначений") Тогда
		ТЗЗаказов.ЗаполнитьЗначения(Истина,"ОтменаНаСайте");
	КОнецЕсли; 	
	
	
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Окончание выполнения. Задача: Отмена заказов ВБ.!","Информация");
	КонецЕсли;
	
	Попытка
		ПутьКонстанты = Константы.ПутьКЛогамМкПл.Получить();
		
		ПутьЛог  = ?(ЗначениеЗаполнено(ПутьКонстанты),ПутьКонстанты,"\\srvfiles\1C_Logs_MarketPlace\");
		ИмяФайла = ПутьЛог+"Отмена_Заказов_"+ПрефиксМаркета+Формат(ТекущаяДатаСеанса(),"ДФ=yyyyMMdd_ЧЧ_мм")+"_Польз_"+СтрЗаменить(СтрЗаменить(СокрЛП(ПараметрыСеанса.Пользователь)," ",""),".","")+".txt";
		ТекстДок = Новый ТекстовыйДокумент;
		ТекстДок.УстановитьТекст(ТотСтр);
		ТекстДок.Записать(ИмяФайла,КодировкаТекста.UTF8);
		
	Исключение
		#Если клиент Тогда
			Сообщить(ОписаниеОшибки());
		#КонецЕсли   
	КонецПопытки;
	
	
КонецПроцедуры

