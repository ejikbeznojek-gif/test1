//
//Для запрета ТОЛЬКО МАРКИРОВАННОГО ТОВАРА в филиале ЕКАТЕРИНБУРГ
//возвращает таблицу товара подлежащего маркировке из любой таблицы

Функция ТолькоМаркаДляЗапрета(МаркетПлейс,ВхТаблицаЗначений) Экспорт
	
	
	СтруктураДанныхНакладной=новый Структура("Номенклатура,ПунктДоставки,Договор,Дата,Контрагент,ПостояннаяАкция"); 
	СтруктураДанныхНакладной.Вставить("Номенклатура",   ВхТаблицаЗначений.ВыгрузитьКолонку("Номенклатура"));
	СтруктураДанныхНакладной.Вставить("ПунктДоставки",  МаркетПлейс.ПунктДоставки);
	СтруктураДанныхНакладной.Вставить("Контрагент",     МаркетПлейс.Контрагент);
	СтруктураДанныхНакладной.Вставить("Договор",        МаркетПлейс.Договор);
	СтруктураДанныхНакладной.Вставить("Дата",           ТекущаяДата());
	СтруктураДанныхНакладной.Вставить("ПостояннаяАкция", Ложь);
	СтруктураДанныхНакладной.Вставить("Товары",         ВхТаблицаЗначений);
	
	ТЗДАТЫМАРКИ =МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(СтруктураДанныхНакладной,"Товары");
	
	//вернет туже таблицу + одну колонку НужнаМаркировка
	//сделал колонку тип Число - для получения ИТОГА
	
	
	////!!!!ВНИМАНИЕ ТЕКСТ ЗАПРОСА РЕДАКТИРОВАТЬ СТРОГО В РУЧНУЮ
	////КОНСТРУКТОР убивает * (звездочку и КАРЕТА превращается в ТЫКВУ
	//	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ НужныйТовар
	|ИЗ
	|	&ТЗОстаток КАК ТЗОстаток
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗДАТЫМАРКИ.Номенклатура КАК Номенклатура,
	|	ТЗДАТЫМАРКИ.ДатаНачалаРаботыСМаркировкой КАК ДатаМарки
	|ПОМЕСТИТЬ ДанныеМарки
	|ИЗ
	|	&ТЗДАТЫМАРКИ КАК ТЗДАТЫМАРКИ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ЕСТЬNULL(ДанныеМарки.ДатаМарки, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаМарки
	|ПОМЕСТИТЬ НаВывод
	|ИЗ
	|	НужныйТовар КАК НужныйТовар
	|		ПОЛНОЕ СОЕДИНЕНИЕ ДанныеМарки КАК ДанныеМарки
	|		ПО НужныйТовар.Номенклатура = ДанныеМарки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ВЫБОР
	|		КОГДА НаВывод.ДатаМарки < &ДатаОтгрузки
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НужнаМаркировка
	|ПОМЕСТИТЬ НаВыводВТЗ
	|ИЗ
	|	НаВывод КАК НаВывод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|   *,
	|	НаВыводВТЗ.НужнаМаркировка КАК НужнаМаркировка
	|ИЗ
	|	НаВыводВТЗ КАК НаВыводВТЗ
	|ГДЕ
	|	НаВыводВТЗ.НужнаМаркировка";
	
	////!!!!ВНИМАНИЕ ТЕКСТ ЗАПРОСА РЕДАКТИРОВАТЬ СТРОГО В РУЧНУЮ
	////КОНСТРУКТОР убивает * (звездочку и КАРЕТА прерващается в ТЫКВУ
	//
	
	
	Запрос.УстановитьПараметр("ТЗОстаток",      ВхТаблицаЗначений);
	Запрос.УстановитьПараметр("ТЗДАТЫМАРКИ",    ТЗДАТЫМАРКИ);
	Запрос.УстановитьПараметр("ПустаяДата",     Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОтгрузки",   ТекущаяДата());
	
	Результат = Запрос.Выполнить().Выгрузить(); 
	
	Возврат Результат;   	
	
КонецФункции

