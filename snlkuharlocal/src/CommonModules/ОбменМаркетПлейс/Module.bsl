Функция ОбработатьОтветЭтикВБ(ИДЗ,ВС,МкПл)
	ВР="";
	ЧтениеJSON1 = Новый ЧтениеJSON;
	ЧтениеJSON1.УстановитьСтроку(ВС);
	Soda = ПрочитатьJSON(ЧтениеJSON1);
	resp = Soda["data"];
	Стр1=СокрЛП(resp["file"]);
	ПутьЭтикетки=МкПл.КаталогДляЭтикеток;
	ПутЭт=?(ЗначениеЗаполнено(ПутьЭтикетки),ПутьЭтикетки,"\\srvfiles\1C_Logs_MarketPlace\");
	//#Если Клиент Тогда
	//	ПутЭт="\\srvfiles\1C_Logs_MarketPlace\";
	//#КонецЕсли	
	ДвД=Base64Значение(Стр1);
	////СтрЗаменить(result," ",""));
	Если НЕ Прав(ПутЭт,1)="\" Тогда
		ПутЭт=ПутЭт+"\";
	КонецЕсли;	
	ДвД.Записать(ПутЭт+ИДЗ+".pdf"); 
	ВР="Сохранен pdf "+ПутЭт+ИДЗ+".pdf";
	Возврат ВР;
КонецФункции

