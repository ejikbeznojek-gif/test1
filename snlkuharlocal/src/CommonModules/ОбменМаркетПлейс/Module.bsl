Функция ПроверкаРазрешенияНаЗапускРегламентногоЗадания(СтруктураМагазина, //) Экспорт
	// Ихсанов Д. А. Начало 30.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2235
	ПоСтопДате = Ложь) Экспорт
	// Ихсанов Д. А. Конец 30.04.2025
	
	//получаем значение из регистра по заданной структуре
	//код - код справочника Интернет магазина
	//ИмяПроцедуры - строка уникальная (<имя процедуры>)
	
	ВыполнениеРазрешено = Ложь;  //по умолчанию и при условии что ФЗ активно
	
	//для контроля загрузки заказов
	
	СтопВыгрузка        = Ложь;
	Загружено           = 0;
	СтопДата            = Дата(1,1,1);
	
	
	//МаркПл =Справочники.ИнетМагазины.НайтиПоКоду(СтруктураМагазина.Код);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СтатусФоновогоЗаданияСрезПоследних.Период       КАК Период,
	|	СтатусФоновогоЗаданияСрезПоследних.КОД          КАК КОД,
	|	СтатусФоновогоЗаданияСрезПоследних.ИмяПроцедуры КАК ИмяПроцедуры,
	|	СтатусФоновогоЗаданияСрезПоследних.Занято       КАК Занято,
	|	СтатусФоновогоЗаданияСрезПоследних.СтопВыгрузка КАК СтопВыгрузка,
	|	СтатусФоновогоЗаданияСрезПоследних.Загружено    КАК Загружено,
	|	СтатусФоновогоЗаданияСрезПоследних.СтопДата     КАК СтопДата
	|ИЗ
	|	РегистрСведений.СтатусФоновогоЗадания.СрезПоследних КАК СтатусФоновогоЗаданияСрезПоследних
	|ГДЕ
	|	СтатусФоновогоЗаданияСрезПоследних.КОД = &КОД
	// Ихсанов Д. А. Начало 30.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2235
	|	%1";
	Если СтруктураМагазина.Свойство("ИмяПроцедуры") Тогда
		Запрос.Текст = СтрШаблон(Запрос.Текст,
		"И СтатусФоновогоЗаданияСрезПоследних.ИмяПроцедуры = &ИмяПроцедуры");
		Запрос.УстановитьПараметр("ИмяПроцедуры", СтруктураМагазина.ИмяПроцедуры);
	Иначе
		Запрос.Текст = СтрШаблон(Запрос.Текст, "");
	КонецЕсли;
	// Ихсанов Д. А. Конец 30.04.2025
	//Параметры запроса
	Запрос.УстановитьПараметр("КОД", СтруктураМагазина.Код);// Строка
	Результат = Запрос.Выполнить().Выбрать();
	
	
	//если есть запись
	Если Результат.Следующий() Тогда
		
		Если Результат.Занято +60*1 < ТекущаяДатаСеанса() // Тогда
			// Ихсанов Д. А. Начало 30.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2235
			Или (ПоСтопДате И ТекущаяДатаСеанса() > Результат.СтопДата) Тогда
			// Ихсанов Д. А. Конец 30.04.2025
			
			//удалим полностью запись
			
			НаборЗаписей = РегистрыСведений.СтатусФоновогоЗадания.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.КОД.Установить(СтруктураМагазина.Код);
			НаборЗаписей.Отбор.ИмяПроцедуры.Установить(СтруктураМагазина.ИмяПроцедуры);  
			НаборЗаписей.Записать();    		
			
			ВыполнениеРазрешено=Истина;  				
		КонецЕсли;
		
		СтопВыгрузка = Результат.СтопВыгрузка;
		Загружено    = Результат.Загружено;
		СтопДата     = Результат.СтопДата;
		
	Иначе			
		ВыполнениеРазрешено=Истина; 
	КонецЕсли;
	
	// Ихсанов Д. А. Начало 30.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2235
	Если СтруктураМагазина.Свойство("СтопДата") Тогда
		СтопДата = СтруктураМагазина.СтопДата;
	КонецЕсли;
	// Ихсанов Д. А. Конец 30.04.2025
	
	Если ВыполнениеРазрешено Тогда
		//создадим новую запись
		НовЗап=РегистрыСведений.СтатусФоновогоЗадания.СоздатьМенеджерЗаписи();
		НовЗап.Период       = ТекущаяДатаСеанса();
		НовЗап.КОД          = СтруктураМагазина.Код;
		НовЗап.ИмяПроцедуры = СтруктураМагазина.ИмяПроцедуры;
		НовЗап.Занято       = ТекущаяДатаСеанса(); 
		НовЗап.СтопВыгрузка = СтопВыгрузка;
		НовЗап.Загружено    = Загружено;
		НовЗап.СтопДата     = СтопДата;  		
		НовЗап.Записать();
		
	КонецЕсли;      	
	
	Возврат ВыполнениеРазрешено;  	
	
КонецФункции

//Тимофеев Ю.А. 05.06.2024

