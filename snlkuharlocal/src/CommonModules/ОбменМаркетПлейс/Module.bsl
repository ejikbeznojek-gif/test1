Процедура МП_Вайлдберриз_ПроверкаОтменНаПортале(МаркПл) Экспорт
	
	ОтправитьСообщение=ЛОжь;
	
	ТЗЗаказов     = Новый ТаблицаЗначений;
	ТЗЗаказов.Колонки.Добавить("НомерЗаказа");
	
	ТЗМассивов     =Новый ТаблицаЗначений;
	ТЗМассивов.Колонки.Добавить("МассивЗаказов");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказФБС
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка.Дата МЕЖДУ &ДатаНач И &ДатаКон
	|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.Договор = &Договор
	|	И ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.ПунктДоставки = &ПунктДоставки
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа <> """"
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаFBSТовары.НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.Ссылка";
	
	
	Запрос.УстановитьПараметр("ДатаНач",          НачалоДня(ТекущаяДата())-86400);// Дата
	Запрос.УстановитьПараметр("ДатаКон",          ТекущаяДата());// Дата
	Запрос.УстановитьПараметр("Договор",          МаркПл.Договор);// Договоры
	Запрос.УстановитьПараметр("ПунктДоставки",    МаркПл.ПунктДоставки);// Договоры 
	Запрос.УстановитьПараметр("Контрагент",       МаркПл.Контрагент);// Контрагенты
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для каждого стрЗак из Результат Цикл
		
		НовЗак=ТЗЗаказов.Добавить();      
		
		Попытка
			НовЗак.НомерЗаказа        = Число(стрЗак.НомерЗаказа); 
		исключение
			продолжить;
		КонецПопытки; 		
		
		Если ТЗЗаказов.Количество()=999 Тогда
			
			НовСТр = ТЗМассивов.Добавить();
			НовСтр.МассивЗаказов= ТЗЗаказов.Скопировать();  			
			ТЗЗаказов.Очистить();
		КонецЕсли;
		
	КонецЦикла;   
	
	
	ОТМЕНАПЕРВОГОЧАСА = Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(56); //отмена в первый час
	ОТКЛОНЕНО         = Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(24); //canceled
	
	НужноСообщение="";
	
	Для каждого МасЗаказов из ТЗМассивов Цикл
		
		БлокЗаков=МасЗаказов.МассивЗаказов.ВыгрузитьКолонку("НомерЗаказа");
		
		ТЗОтмен = МП_Вайлдберриз_ПроверитьСтатусЗаказаОтменыПервогоЧаса(МаркПл,БлокЗаков);
		
		ОтправитьСообщение=ЛОжь;
		
		Если ТЗОтмен.Количество()>0 Тогда
			
			ОтправитьСообщение=Истина; 			
			
			для каждого стрНом из ТЗОтмен Цикл         			
				СтрокаПоиска    = Результат.Найти(Строка(СтрНом.НомерЗаказа),"НомерЗаказа");
				СтрНом.ЗаказФБС = СтрокаПоиска.ЗаказФБС;		
			КонецЦикла;                                
			
			ВрТЗЗаказов = ТЗОтмен.Скопировать();
			ВРТЗЗаказов.Свернуть("ЗаказФБС");
			
			Для каждого текЗак из ВрТЗЗаказов Цикл
				
				Отбор = Новый Структура();
				Отбор.Вставить("ЗаказФБС",ТекЗак.ЗаказФБС);
				НайденныеСтроки = ТЗОтмен.НайтиСтроки(Отбор);
				
				Если НайденныеСтроки.Количество()>0 Тогда
					ОбДок = ТекЗак.ЗаказФБС.ПолучитьОбъект();
					
					для Каждого стрН из НайденныеСтроки Цикл   				
						
						НужнаяСтрока= обДок.Товары.Найти(Строка(стрН.НомерЗаказа),"НомерЗаказа");
						
						Если НужнаяСтрока.Количество=0 или НужнаяСтрока.ВычеркОфис или НужнаяСтрока.ВычеркСклад  Тогда
							
							//значит уже был вычерк и повторять не будем
							Продолжить;
							
						Иначе
							
							Если Стрн.wbStatus="canceled" Тогда
								НужнаяСтрока.СостояниеУКлиента = ОТКЛОНЕНО;
								НужноСообщение=НужноСообщение+"Отмен заказ "+ (стрН.НомерЗаказа)+"/"+Строка(ТекЗак.ЗаказФБС)+"/"+Строка(ТекЗак.ЗаказФБС.ДокОснование)+" ОТМЕНЁН"+Символы.ПС;
							Иначе   						
								НужнаяСтрока.СостояниеУКлиента = ОТМЕНАПЕРВОГОЧАСА;
								НужноСообщение=НужноСообщение+"Отмен заказ "+ (стрН.НомерЗаказа)+"/"+Строка(ТекЗак.ЗаказФБС)+"/"+Строка(ТекЗак.ЗаказФБС.ДокОснование)+" ОТМЕНА ПОКУПАТЕЛЕМ в 1-й ЧАС"+Символы.ПС;
							КонецЕсли;
							
							// Ихсанов Д. А. Начало 13.11.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7833
							НужнаяСтрока.Количество = 0;
							// Ихсанов Д. А. Конец 13.11.2025
							НужнаяСтрока.Отменен           = Истина;
							НужнаяСтрока.ПереданоНаСайт    = Истина; 
							
						КонецЕсли;
					КонецЦикла;
					
					Если ОбДок.Модифицированность() Тогда
						
						ОбДок.Записать(РежимЗаписиДокумента.Проведение);
						ОтправитьСообщение=Истина;
					КонецЕсли;
					
				КонецЕсли;			
				
			КонецЦикла;
			
		КонецЕсли;   
		
	КонецЦикла;
	
	Если ОтправитьСообщение и СтрДлина(НужноСообщение)>0 Тогда
		
		Попытка
			
			Тема="ОТМЕНА СБОРОЧНЫХ Заданий "+Строка(МаркПл);
			
			СписокПолучателей=новый СписокЗначений;
			СписокПолучателей.Добавить("operatorschastsy@collant.ru"); 
			Для Каждого Пользователь из МаркПл.ПолучателиУведомлений  Цикл
				
				СписокПолучателей.Добавить(Пользователь.Сотрудник.ЕМэйл);   //пока на время теста только мне						
				
			КонецЦикла;
			
			ТекстОповещения="Доброго времени суток!"+Символы.ПС+НужноСообщение;
			ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,Тема,ТекстОповещения);   
		Исключение
			
		КонецПопытки;		
		
	КонецЕсли;   	
	
КонецПроцедуры


Функция МП_Вайлдберриз_ПроверитьСтатусЗаказаОтменыПервогоЧаса(МаркПл,НомЗак) Экспорт 	
	
	ПолСтр         = МП_Вайлдберриз_ВернутьСтруктуру_orders(НомЗак);
	
	Соединение     = МП_Вайлберриз_ВернутьСоединение(МаркПл);
	
	ЗаголовокHTTP  = МП_Вайлберриз_ВернутьЗаголовкиHTTP(МаркПл);
	
	HTTP_запрос = новый HTTPзапрос();
	HTTP_запрос.АдресРесурса="api/v3/orders/status"; 
	
	РазмерФайлаНаОтправку = XMLСтрока(СтрДлина(ПолСтр));
	ЗаголовокHTTP.Вставить("Content-Length", РазмерФайлаНаОтправку);
	
	HTTP_запрос.Заголовки = ЗаголовокHTTP;
	HTTP_запрос.УстановитьТелоИзСтроки(ПолСтр);   	
	
	Ответ = Соединение.ОтправитьДляОбработки(HTTP_запрос);  // ИмяВыходногоФайла
	
	НоваяТЗОтмен = Новый ТаблицаЗначений;
	НоваяТЗОтмен.Колонки.Добавить("НомерЗаказа");
	НоваяТЗОтмен.Колонки.Добавить("wbStatus");
	НоваяТЗОтмен.Колонки.Добавить("ЗаказФБС");
	
	
	Если Ответ.КодСостояния<=400 Тогда
		
		ВозвСтр =Ответ.ПолучитьТелоКакСтроку();		
		
		ЧтениеJSON0       = Новый ЧтениеJSON;
		ЧтениеJSON0.УстановитьСтроку(ВозвСтр);
		СтруктураИзСтроки = ПрочитатьJSON(ЧтениеJSON0);
		
		Для каждого Орд из СтруктураИзСтроки.orders Цикл
			
			supplierStatus = Орд.supplierStatus;
			wbStatus       = Орд.wbStatus; 			
			
			Если wbStatus="declined_by_client" Тогда
				
				ПодСтатус = "Покупатель отменил заказ в первый чаc (declined_by_client)";
				
				НовСтр = НоваяТЗОтмен.Добавить();
				НовСтр.НомерЗаказа = Орд.id;
				НовСТр.wbStatus    = Орд.wbStatus;				
				
			ИначеЕсли wbStatus="canceled" Тогда
				
				ПодСтатус = "Отмена сборочного задания (canceled)";
				
				НовСтр = НоваяТЗОтмен.Добавить();
				НовСтр.НомерЗаказа = Орд.id;
				НовСТр.wbStatus    = Орд.wbStatus; 
				
			КонецЕсли;	
			
		КонецЦикла;
		
	КонецЕсли;	
	
	Возврат НоваяТЗОтмен;
	
КонецФункции  


