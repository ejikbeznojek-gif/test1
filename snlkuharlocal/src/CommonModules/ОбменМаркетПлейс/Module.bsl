// Функция - Текст запроса для получения количества заказов по ПЗК
// Ихсанов Д. А. 30.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7560
// 
// Возвращаемое значение:
//  Строка - Текст запроса для получения количество заказов по Предварительным заказа клиента
//
Функция ТекстЗапросаДляПолученияКоличестваЗаказовПоПЗК()
	
	Возврат "ВЫБРАТЬ
	|	ПредварительныйЗаказКлиента.Ссылка КАК Ссылка,
	|	ПредварительныйЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ПредварительныйЗаказКлиентаТовары.Количество КАК Количество,
	|	ВЫРАЗИТЬ(ПредварительныйЗаказКлиента.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	|	ПредварительныйЗаказКлиента.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
	|	ПредварительныйЗаказКлиента.Склад КАК Склад,
	|	ПредварительныйЗаказКлиента.СкладПолучатель КАК СкладРезервов,
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеПредварительногоЗаказаКлиента
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента КАК ПредварительныйЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО ПредварительныйЗаказКлиента.Ссылка = ПредварительныйЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	ПредварительныйЗаказКлиента.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиента.Договор = &Договор
	|	И ПредварительныйЗаказКлиента.ПунктДоставки = &ПунктДоставки
	|	И ПредварительныйЗаказКлиента.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ПредварительныйЗаказКлиента.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеСформированныхЗаказовКлиента
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказКлиентаFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа) КАК КоличествоЗаказов
	|ИЗ
	|	вт_ДанныеПредварительногоЗаказаКлиента КАК вт_ДанныеПредварительногоЗаказаКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеСформированныхЗаказовКлиента КАК вт_ДанныеСформированныхЗаказовКлиента
	|		ПО вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа = вт_ДанныеСформированныхЗаказовКлиента.НомерЗаказа
	|ГДЕ
	|	вт_ДанныеСформированныхЗаказовКлиента.Ссылка ЕСТЬ NULL
	|	И НЕ вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура ЕСТЬ NULL";
	
КонецФункции // ТекстЗапросаДляПолученияКоличестваЗаказовПоПЗК()

// Функция - Текст запроса для снятия резерва с ПЗК
// Ихсанов Д. А. 09.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// 
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаДляСнятияРезерваСПЗК()
	
	Возврат СтрШаблон("ВЫБРАТЬ
	|	ПредварительныйЗаказКлиента.Ссылка КАК Ссылка,
	|	ПредварительныйЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ПредварительныйЗаказКлиентаТовары.Количество КАК Количество,
	|	ВЫРАЗИТЬ(ПредварительныйЗаказКлиента.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	|	ПредварительныйЗаказКлиента.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
	|	ПредварительныйЗаказКлиента.Склад КАК Склад,
	|	ПредварительныйЗаказКлиента.СкладПолучатель КАК СкладРезервов,
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеПредварительногоЗаказаКлиента_ДанныеДоОтбораПоБлокировке
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента КАК ПредварительныйЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО ПредварительныйЗаказКлиента.Ссылка = ПредварительныйЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	ПредварительныйЗаказКлиента.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиента.Договор = &Договор
	|	И ПредварительныйЗаказКлиента.ПунктДоставки = &ПунктДоставки
	|	И ПредварительныйЗаказКлиента.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ПредварительныйЗаказКлиента.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|%1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПредварительногоЗаказаКлиента.Ссылка КАК Ссылка,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура КАК Номенклатура,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Количество КАК Количество,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Комментарий КАК Комментарий,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Склад КАК Склад,
	|	вт_ДанныеПредварительногоЗаказаКлиента.СкладРезервов КАК СкладРезервов,
	|	вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеПредварительногоЗаказаКлиента
	|ИЗ
	|	вт_ДанныеПредварительногоЗаказаКлиента_ДанныеДоОтбораПоБлокировке КАК вт_ДанныеПредварительногоЗаказаКлиента
	|ГДЕ
	|	(вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_ТоварыВБлокировке.Номенклатура
	|					ИЗ
	|						вт_ТоварыВБлокировке)
	|				И &БлокировкаВыдачиВНабор_БлокироватьОстатки
	|			ИЛИ ИСТИНА
	|				И НЕ &БлокировкаВыдачиВНабор_БлокироватьОстатки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеСформированныхЗаказовКлиента
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказКлиентаFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПредварительногоЗаказаКлиента.Ссылка КАК Ссылка
	|ИЗ
	|	вт_ДанныеПредварительногоЗаказаКлиента КАК вт_ДанныеПредварительногоЗаказаКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ДанныеСформированныхЗаказовКлиента КАК вт_ДанныеСформированныхЗаказовКлиента
	|		ПО вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа = вт_ДанныеСформированныхЗаказовКлиента.НомерЗаказа
	|ГДЕ
	|	вт_ДанныеСформированныхЗаказовКлиента.Ссылка ЕСТЬ NULL
	|	И НЕ вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеПредварительногоЗаказаКлиента.Ссылка",
		ТекстЗапросаМоделиПоАссортиментуВБлокировке("вт_ДанныеПредварительногоЗаказаКлиента_ДанныеДоОтбораПоБлокировке"));
	
КонецФункции // ТекстЗапросаДляСнятияРезерваСПЗК()

// Функция - Текст запроса преобразование данных предварительного заказа клиента
// Ихсанов Д. А. 09.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
// 
// Возвращаемое значение:
//  Строка - Текст запроса
//
Функция ТекстЗапросаПреобразованиеДанныхПредварительногоЗаказаКлиента(УровниОтборовПоЗаказам)
	
	// Ихсанов Д. А. Начало 17.03.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
	Возврат СтрШаблон("ВЫБРАТЬ
	|	ПредварительныйЗаказКлиента.Ссылка КАК Ссылка,
	|	ПредварительныйЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ПредварительныйЗаказКлиентаТовары.Количество КАК Количество,
	|	ВЫРАЗИТЬ(ПредварительныйЗаказКлиента.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	|	ПредварительныйЗаказКлиента.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
	|	ПредварительныйЗаказКлиента.Склад КАК Склад,
	|	ПредварительныйЗаказКлиента.СкладПолучатель КАК СкладРезервов,
	|	ПредварительныйЗаказКлиентаТовары.Номенклатура.Родитель КАК Родитель,
	|	ПредварительныйЗаказКлиентаТовары.НомерЗаказа КАК НомерЗаказа,
	|	ПредварительныйЗаказКлиентаТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ПредварительныйЗаказКлиентаТовары.ДатаЗаказа КАК ДатаЗаказа,
	|	ПредварительныйЗаказКлиентаТовары.РИД КАК РИД,
	|	ПредварительныйЗаказКлиентаТовары.Цена КАК Цена,
	|	ПредварительныйЗаказКлиентаТовары.Всего КАК Всего,
	|	ПредварительныйЗаказКлиентаТовары.ШтрихКод КАК ШтрихКод,
	|	ПредварительныйЗаказКлиентаТовары.СостояниеУКлиента КАК СостояниеУКлиента,
	|	ПредварительныйЗаказКлиентаТовары.ЗаказПоЮрЛицу КАК ЗаказПоЮрЛицу,
	|	ПредварительныйЗаказКлиента.ДатаОтгрузки КАК ДатаОтгрузки
	|ПОМЕСТИТЬ вт_ДанныеПредварительногоЗаказаКлиента_ДанныеДоОтбораПоБлокировке
	|ИЗ
	|	Документ.ПредварительныйЗаказКлиента КАК ПредварительныйЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО ПредварительныйЗаказКлиента.Ссылка = ПредварительныйЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	ПредварительныйЗаказКлиента.Контрагент = &Контрагент
	|	И ПредварительныйЗаказКлиента.Договор = &Договор
	|	И ПредварительныйЗаказКлиента.ПунктДоставки = &ПунктДоставки
	|	И ПредварительныйЗаказКлиента.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|		И НАЧАЛОПЕРИОДА(ПредварительныйЗаказКлиента.ДатаОтгрузки, ДЕНЬ) <= НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, &СмещениеПоДатеОтгрузки), ДЕНЬ)
	|	И ПредварительныйЗаказКлиента.Проведен
	|	И НЕ ПредварительныйЗаказКлиентаТовары.Отменен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|%1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПредварительногоЗаказаКлиента.Ссылка КАК Ссылка,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура КАК Номенклатура,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Количество КАК Количество,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Комментарий КАК Комментарий,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Склад КАК Склад,
	|	вт_ДанныеПредварительногоЗаказаКлиента.СкладРезервов КАК СкладРезервов,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Родитель КАК Родитель,
	|	вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа КАК НомерЗаказа,
	|	вт_ДанныеПредварительногоЗаказаКлиента.АртикулКонтрагента КАК АртикулКонтрагента,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ДатаЗаказа КАК ДатаЗаказа,
	|	вт_ДанныеПредварительногоЗаказаКлиента.РИД КАК РИД,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Цена КАК Цена,
	|	вт_ДанныеПредварительногоЗаказаКлиента.Всего КАК Всего,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ШтрихКод КАК ШтрихКод,
	|	вт_ДанныеПредварительногоЗаказаКлиента.СостояниеУКлиента КАК СостояниеУКлиента,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ЗаказПоЮрЛицу КАК ЗаказПоЮрЛицу,
	|	ЕСТЬNULL(вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура = ПредварительныйЗаказКлиентаКомплектующие.Номенклатура, ЛОЖЬ) КАК КомплектИзСебя,
	|	вт_ДанныеПредварительногоЗаказаКлиента.ДатаОтгрузки КАК ДатаОтгрузки
	|ПОМЕСТИТЬ вт_ДанныеПредварительногоЗаказаКлиента
	|ИЗ
	|	вт_ДанныеПредварительногоЗаказаКлиента_ДанныеДоОтбораПоБлокировке КАК вт_ДанныеПредварительногоЗаказаКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Комплектующие КАК ПредварительныйЗаказКлиентаКомплектующие
	|		ПО вт_ДанныеПредварительногоЗаказаКлиента.Ссылка = ПредварительныйЗаказКлиентаКомплектующие.Ссылка
	|			И вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура = ПредварительныйЗаказКлиентаКомплектующие.Номенклатура
	|			И вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа = ПредварительныйЗаказКлиентаКомплектующие.НомерЗаказа
	|ГДЕ
	|	(вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура В
	|					(ВЫБРАТЬ
	|						вт_ТоварыВБлокировке.Номенклатура
	|					ИЗ
	|						вт_ТоварыВБлокировке)
	|				И &БлокировкаВыдачиВНабор_БлокироватьОстатки
	|			ИЛИ ИСТИНА
	|				И НЕ &БлокировкаВыдачиВНабор_БлокироватьОстатки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПредварительногоЗаказаКлиента.РИД КАК РИД,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа) КАК КоличествоЭкзепляровТоваров
	|ПОМЕСТИТЬ вт_КоличествоЭкземпляровНаЗаказ
	|ИЗ
	|	вт_ДанныеПредварительногоЗаказаКлиента КАК вт_ДанныеПредварительногоЗаказаКлиента
	|ГДЕ
	|	&ВозможныЗаказыСНесколькимиТоварами
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеПредварительногоЗаказаКлиента.РИД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ПОМЕСТИТЬ вт_ДанныеСформированныхЗаказовКлиента
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказКлиентаFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBSТовары.НомерЗаказа В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.НомерЗаказа
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураДанные.Ссылка КАК Номенклатура,
	|	НоменклатураКоплектующие.Номенклатура КАК НоменклатураУпаковка,
	|	ВЫБОР
	|		КОГДА &ВозможныЗаказыСНесколькимиТоварами
	|				И &РежимСмешанныхНакладных_Комплекты
	|			ТОГДА ""Смешанный""
	|		ИНАЧЕ ВЫРАЗИТЬ(""Штука"" КАК СТРОКА(10))
	|	КОНЕЦ КАК Упаковка,
	|	NULL КАК ФиксированныйОбъем,
	|	&ОбъемТары КАК ПриоритетныйОбъемТары
	|ПОМЕСТИТЬ вт_ДанныеУпаковок_Предварительный
	|ИЗ
	|	Справочник.Номенклатура КАК НоменклатураДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|		ПО НоменклатураДанные.Ссылка = НоменклатураКоплектующие.Ссылка
	|ГДЕ
	|	НоменклатураДанные.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|	И НоменклатураКоплектующие.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураКоплектующие.Ссылка,
	|	НоменклатураКоплектующие.Номенклатура,
	|	ВЫБОР
	|		КОГДА &ВозможныЗаказыСНесколькимиТоварами
	|				И &РежимСмешанныхНакладных_Комплекты
	|			ТОГДА ""Смешанный""
	|		ИНАЧЕ ЕСТЬNULL(РеквизитыСправочниковУпаковка.ЗначениеРеквизита, ВЫРАЗИТЬ(""Пакет"" КАК СТРОКА(10)))
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА РеквизитыСправочниковФиксированныйОбъем.ЗначениеРеквизита ЕСТЬ NULL
	|			ТОГДА NULL
	|		ИНАЧЕ ОКР((ВЫРАЗИТЬ(РеквизитыСправочниковФиксированныйОбъем.ЗначениеРеквизита КАК ЧИСЛО(15, 0))) / 1000000000, 4)
	|	КОНЕЦ,
	|	ЕСТЬNULL(ОКР((ВЫРАЗИТЬ(РеквизитыСправочниковПриоритетныйОбъемТары.ЗначениеРеквизита КАК ЧИСЛО(15, 0))) / 1000000000, 4), &ОбъемТары)
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураДанные
	|		ПО НоменклатураКоплектующие.Номенклатура = НоменклатураДанные.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочниковУпаковка
	|		ПО НоменклатураКоплектующие.Номенклатура = РеквизитыСправочниковУпаковка.Справочник
	|			И (РеквизитыСправочниковУпаковка.ИмяРеквизита = ""ТипУпаковки"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочниковФиксированныйОбъем
	|		ПО НоменклатураКоплектующие.Номенклатура = РеквизитыСправочниковФиксированныйОбъем.Справочник
	|			И (РеквизитыСправочниковФиксированныйОбъем.ИмяРеквизита = ""ФиксированныйОбъемУпаковки"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочниковПриоритетныйОбъемТары
	|		ПО НоменклатураКоплектующие.Номенклатура = РеквизитыСправочниковПриоритетныйОбъемТары.Справочник
	|			И (РеквизитыСправочниковПриоритетныйОбъемТары.ИмяРеквизита = ""ПриоритетныйОбъемТары"")
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|	И НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеУпаковок_Предварительный.Номенклатура КАК Номенклатура,
	|	вт_ДанныеУпаковок_Предварительный.Упаковка КАК Упаковка,
	|	вт_ДанныеУпаковок_Предварительный.ФиксированныйОбъем КАК ФиксированныйОбъем,
	|	вт_ДанныеУпаковок_Предварительный.ПриоритетныйОбъемТары КАК ПриоритетныйОбъемТары
	|ПОМЕСТИТЬ вт_ДанныеУпаковок
	|ИЗ
	|	вт_ДанныеУпаковок_Предварительный КАК вт_ДанныеУпаковок_Предварительный
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ДанныеУпаковок_Предварительный.Номенклатура,
	|	вт_ДанныеУпаковок_Предварительный.Упаковка,
	|	вт_ДанныеУпаковок_Предварительный.ФиксированныйОбъем,
	|	вт_ДанныеУпаковок_Предварительный.ПриоритетныйОбъемТары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураДанные.Ссылка КАК Номенклатура,
	|	НоменклатураДанные.Ссылка КАК Ссылка,
	|	НоменклатураДанные.Родитель КАК Родитель,
	|	НЕ НоменклатураКоплектующие.Ссылка ЕСТЬ NULL КАК Комплект,
	|	1 КАК Коэффициент
	|ПОМЕСТИТЬ вт_ДанныеНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК НоменклатураДанные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|		ПО НоменклатураДанные.Ссылка = НоменклатураКоплектующие.Ссылка
	|ГДЕ
	|	НоменклатураДанные.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НоменклатураКоплектующие.Ссылка,
	|	НоменклатураДанные.Ссылка,
	|	НоменклатураДанные.Родитель,
	|	НЕ НоменклатураКоплектующие.Ссылка ЕСТЬ NULL,
	|	НоменклатураКоплектующие.Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураДанные
	|		ПО НоменклатураКоплектующие.Номенклатура = НоменклатураДанные.Ссылка
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеПредварительногоЗаказаКлиента.Номенклатура
	|			ИЗ
	|				вт_ДанныеПредварительногоЗаказаКлиента)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.ДлинаКоробки КАК ДлинаКоробки,
	|	Номенклатура.ВысотаКоробки КАК ВысотаКоробки,
	|	Номенклатура.ШиринаКоробки КАК ШиринаКоробки,
	|	Номенклатура.ДлинаКоробки * Номенклатура.ВысотаКоробки * Номенклатура.ШиринаКоробки / 1000000 КАК ОбъемКоробкиМ3,
	|	Номенклатура.ШтукВКоробке КАК ШтукВКоробке,
	|	ОКР(Номенклатура.ДлинаКоробки * Номенклатура.ВысотаКоробки * Номенклатура.ШиринаКоробки / 1000000 / ВЫБОР
	|			КОГДА Номенклатура.ШтукВКоробке = 0
	|				ТОГДА 1
	|			ИНАЧЕ Номенклатура.ШтукВКоробке
	|		КОНЕЦ, 4) КАК ОбъемШтукиМ3,
	|	Номенклатура.ОбъемШтуки КАК ОбъемШтуки
	|ПОМЕСТИТЬ вт_ВесогабаритныеХарактеристики
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В
	|			(ВЫБРАТЬ
	|				вт_ДанныеНоменклатуры.Родитель
	|			ИЗ
	|				вт_ДанныеНоменклатуры)
	|	И Номенклатура.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеНоменклатуры.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(вт_ВесогабаритныеХарактеристики.ОбъемШтукиМ3, 0) * вт_ДанныеНоменклатуры.Коэффициент) КАК ОбъемШтукиТовара,
