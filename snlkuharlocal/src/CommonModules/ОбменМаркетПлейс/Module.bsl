Функция МП_ПолучитьИДПоставкиПоПЗК(Док,МаркПл,КолЧаст=2)Экспорт
	//вместо ПолучитьИДПост1(Док,МаркПл,КолЧаст=2) 
	
	ИДП="";
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	Попытка
		КолЗак=Док.Товары.Количество();
	Исключение
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+Строка(Док)+ " нет табличной части","Ошибка");
		Возврат "";
	КонецПопытки;
	
	// Ихсанов Д. А. Начало 01.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
	Если ТипЗнч(Док) = Тип("ДокументСсылка.ПредварительныйЗаказКлиента") Тогда
		ДатаОт = Док.ДатаОтгрузки;
	Иначе
	// Ихсанов Д. А. Конец 03.09.2025
		ДатаОт=Док.ДокОснование.ДатаОтгрузки;
	// Ихсанов Д. А. Начало 01.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2482
	КонецЕсли;
	// Ихсанов Д. А. Конец 03.09.2025
	
	
	НомДН=ДеньНедели(ДатаОт);
	Дата1=НачалоДня(ДатаОт);
	Дата2=КонецДня(ДатаОт);
	
	ДатаЗак=Док.Дата;
	
	Счт=0;
	ТотКол=0;
	
	Запрос=Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(*) КАК Колво,
	|	МИНИМУМ(ЛогОтгрузкиЗаказовФБС.ДатаПривязки) КАК ДатаПривязки,
	|	ЛогОтгрузкиЗаказовФБС.НомерОтгрузки КАК НомерОтгрузки,
	|	ЛОЖЬ КАК Закрыта
	|ИЗ
	|	РегистрСведений.ЛогОтгрузкиЗаказовФБС КАК ЛогОтгрузкиЗаказовФБС
	|ГДЕ
	|	ЛогОтгрузкиЗаказовФБС.МаркетПлейс = &МаркПл
	|	И ЛогОтгрузкиЗаказовФБС.ДатаОтгрузки МЕЖДУ &Дата1 И &Дата2
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛогОтгрузкиЗаказовФБС.НомерОтгрузки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаПривязки";
	
	Запрос.УстановитьПараметр("МаркПл",МаркПл);
	Запрос.УстановитьПараметр("Дата1", Дата1);
	Запрос.УстановитьПараметр("Дата2", Дата2);
	
	ТЗВыб=Запрос.Выполнить().Выгрузить();     
	
	
	Если ТЗВыб.Количество()=0 Тогда
		ИДП=МП_Вайлбериз_СоздатьПоставку(МаркПл,"Поставка "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd"));
	Иначе
		
		Для Каждого Выб Из ТЗВыб Цикл
			Выб.Закрыта=МП_Вайлбериз_ПроверитьСтатусПоставки(МаркПл,Выб.НомерОтгрузки);
		КонецЦикла;	
		
		счтот=0;
		счтзак=0;
		
		Для каждого Выб из ТЗВыб Цикл
			
			Если Выб.Закрыта Тогда
				счтзак=счтзак+1;
			Иначе
				счтот=счтот+1;
				ИДП =Выб.НомерОтгрузки;	
			КонецЕсли;	
			Счт=Счт+1;
			ТотКол=ТотКол+Выб.Колво;
			
		КонецЦикла;	
		
		Счт=ТЗВыб.Количество()+1;
		
		Если счтот=1 И (КолЧаст>1) И (НомДН<7)  И (НомДН>1) Тогда
			Если (Дата2-ДатаЗак)<(3600*32) И (Дата2-ДатаЗак)>(3600*30) И (ТотКол>1000) Тогда
				ИДП=МП_Вайлбериз_СоздатьПоставку(МаркПл,"Поставка "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd"));
			КонецЕсли;	
		КонецЕсли;
		
		Если ПустаяСтрока(ИДП) Тогда
			ИДП=МП_Вайлбериз_СоздатьПоставку(МаркПл,"Поставка "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd"));
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ИДП;
	
КонецФункции

