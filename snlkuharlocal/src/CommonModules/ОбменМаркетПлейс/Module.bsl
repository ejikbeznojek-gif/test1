					МаркетПлейс.СкладРезерваМаркировки, ТЗЗакНомНеКомплект, ТЗСкладМаркаФБС, НужнаМаркировка, ЛимитПозиций,
					СостояниеНаСклад, тСектор.СекторХранения, ПереносОтгрузки, Ложь, ТекстОповещения);
				// Ихсанов Д. А. Конец 02.09.2025
				
				Если ПолученныйЗаказ<>Неопределено и МассивНовыхЗаказов.Найти(ПолученныйЗаказ)=неопределено Тогда
					МассивНовыхЗаказов.Добавить(ПолученныйЗаказ);
				КонецЕсли;
				
			КонецЕсли;
		Иначе
			ТЗСкладМаркаФБС.Очистить();
	
		КонецЕсли;	  
		
		
		Если ЛимитПоСекторам Тогда      
			
			КоличествоПоСектору =ТЗСкладФБС.Итог("КолКонФакт")+ТЗСкладМаркаФБС.Итог("КолКонФакт"); 
			
			Если КоличествоПоСектору >0 Тогда  			
				
				//ТЗлимитпоСекторам = Новый ТаблицаЗначений;
				//ТЗлимитпоСекторам.Колонки.Добавить("СекторХранения");
				//ТЗлимитпоСекторам.Колонки.Добавить("Факт");
				
				НовЛимитСектора = ТЗлимитпоСекторам.Добавить();
				НовЛимитСектора.СекторХранения = тСектор.СекторХранения;
				НовЛимитСектора.Факт           = КоличествоПоСектору;  			
				
			КонецЕсли;  
			
		КонецЕсли;
		

		
		//нет в наличии
		
		Если ТЗНетНаличии.Количество()>0 Тогда
			
			ВсегоТовараПоТЗ = ТЗНетНаличии.Итог("КолконФакт");
			
			//Тимофеев Ю.А. ID-21012   
