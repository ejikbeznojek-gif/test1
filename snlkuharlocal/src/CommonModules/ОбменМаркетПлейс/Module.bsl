	|ТОГДА ТЗНомМатр.Номенклатура
	|ИНАЧЕ ТЗНомСкл.Номенклатура КОНЕЦ КАК Номенклатура,
	|ВЫРАЗИТЬ(isnull(ТЗНомМатр.ШККонтра,"""") КАК Строка(50)) КАК ШККонтра,
	|isnull(ТЗНомМатр.КодКонтра,"""") КАК КодКонтра,
	|isnull(ТЗНомМатр.НаимКонтра,"""") КАК НаимКонтра,
	|isnull(ТЗНомМатр.ЦенаМатрица,0) КАК ЦенаМатрица,
	|isnull(ТЗНомМатр.Матрица,"""") КАК Матрица,
	|ТЗНомМатр.МатрицаДата КАК МатрицаДата,
	|isnull(ТЗНомМатр.МатрКоличество,0) КАК МатрКоличество,
	|ВЫБОР КОГДА isnull(ТЗНомМатр.ШККонтра,"""")=""""
	|ТОГДА 0 ИНАЧЕ 
	|	ВЫБОР КОГДА &ВыгрузкаПоМатрице ТОГДА
	|ВЫБОР КОГДА isnull(ТЗНомМатр.МатрКоличество,0)<isnull(ТЗНомСкл.КолКонФакт,0)
	| ТОГДА isnull(ТЗНомМатр.МатрКоличество,0)
	| ИНАЧЕ isnull(ТЗНомСкл.КолКонФакт,0)
	|КОНЕЦ
	|ИНАЧЕ 
	|ВЫБОР КОГДА isnull(ТЗНомМатр.МатрКоличество,0)>0
	| ТОГДА isnull(ТЗНомСкл.КолКонФакт,0)
	| ИНАЧЕ 0
	|КОНЕЦ
	|КОНЕЦ
	|КОНЕЦ КАК КВыгрузке
	|ИЗ
	|	ВТ_НомСкл КАК ТЗНомСкл
	|ПОЛНОЕ СОЕДИНЕНИЕ ВТ_НомОтбор1 КАК ТЗНомМатр
	|ПО ТЗНомМатр.Номенклатура=ТЗНомСкл.Номенклатура
	
	
	
	//|СОЕДИНЕНИЕ ВТ_Ном КАК ТЗНом
	//
	//|ПО ТЗНом.КодКонтра=ВТ_Отб.КодКонтра
	//|И ТЗНом.МатрицаДата=ВТ_Отб.МатрицаДатаМ
	
	//|СОЕДИНЕНИЕ ВТ_Инет КАК ВТ_Инет
	//|ПО ТЗНом.КодКонтра=ВТ_Инет.ИД
	
	
	|	";
	Запрос.УстановитьПараметр("ТЗНомМатр",ТЗНомМатр);
	Запрос.УстановитьПараметр("ТЗНомСкл",ТЗНомСкл);
	Запрос.УстановитьПараметр("ПунктДоставки",ПунктДоставки);
	Запрос.УстановитьПараметр("ВыгрузкаПоМатрице",ВыгрузкаПоМатрице1);
	ТЗОст=Запрос.Выполнить().Выгрузить();
	
	//Для Каждого ТСтр Из ТЗОст Цикл
	//	Если ТСтр.Номенклатура.Ссылка.Коплектующие.Количество() Тогда
	//		ТСтр.Комплект=Истина;
	//	КонецЕсли;
	//	Если ТСтр.КВыгрузке<0 Тогда
	//		ТСтр.КВыгрузке=0;
	//	КонецЕсли;
	//КонецЦикла;
	
	//Стало Тимофеев Ю.А. 20.03.24
	
	ТЗОст=МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТЗОст);	
	
	Для Каждого ТСтр Из ТЗОст Цикл 
		Если ТСтр.КВыгрузке<0 Тогда
			ТСтр.КВыгрузке=0;
		КонецЕсли;
	КонецЦикла;
	//Конец Тимофеев Ю.А. 20.03.24
	
	
	
	Возврат ТЗОст;
КонецФункции	

