		НижнийШК="";
	КонецЕсли;	
	
	ЕстьВсеТовары=истина;
	Для каждого ТекСтр из СтруктураЗаказа.products Цикл
		
		Ном = Справочники.Номенклатура.ПустаяСсылка();
		
		Артикул = ТекСтр.sku;   // или offer_id??? 
		ШК = "";
		Наименование = ТекСтр.name;
		//Михайловский 20220721 +++
		//Ном = ОбщегоНазначения_ПИ.НайтиНоменклатуруВМатрицеПоШКилиАртикулу(ШК,Артикул,Контрагент,ДанныеМаркетПлейса.Договор,ДанныеМаркетПлейса.ПунктДоставки);
		ВС=НайтиНоменклатуруВМатрицеПоШКилиАртикулуПИД(ШК,Артикул,Контрагент,ДанныеМаркетПлейса.Договор,ДанныеМаркетПлейса.ПунктДоставки,ДанныеМаркетПлейса);
		Ном=ВС.Ном;
		//Михайловский 20220721 ---
		Кол = ТекСтр.quantity;
		
		Если Ном = Справочники.Номенклатура.ПустаяСсылка() ТОгда
			КритическиеОшибкиОзон.Добавить("Для заказа "+номерзаказа+" Не найдена номенклатура "+Наименование+", артикул -" + артикул+ " количество - "+кол);
			естьвсеТовары=ЛОжь;
			продолжить;
		КонецЕсли;	
		
		Если кол >0 Тогда
			Нов = ТаблицаВозврата.Добавить();
			Нов.Номенклатура = Ном;
			Нов.Количество = кол;
			Нов.ДатаЗаказа=ДатаЗаказа;
			нов.ДатаОтгрузки=ДатаОтгрузки;
			Нов.НомерЗаказа=НомерЗаказа;
			//Михайловский 20220721 +++
			Нов.ПрефиксЗаказа=ВС.ИДПрод;
			//Михайловский 20220721 +++
			Нов.ВерхнийШК=ВерхнийШК;
			нов.НижнийШК=НижнийШК;
			нов.Состояние=статус;
			Нов.АртикулКонтрагента=ТекСтр.sku;
			// Кухарь А.Ю. 11.11.2021 начало
			//Ищем сначала бренд как номенклатура.родитель.родитель.родитель
			//потом по нему получаем сектор из РС реквизиты справочников
			Бренд=ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);
			Нов.СекторХранения=ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд); 
			если не ЗначениеЗаполнено(нов.СекторХранения) тогда
				если МассивНоменклатурыБезСектора.Найти(Бренд)=Неопределено тогда
					МассивНоменклатурыБезСектора.Добавить(Бренд);
				КонецЕсли;
				нов.СекторХранения=СборныйСектор; 
				
			КонецЕсли;
			
			если МассивСекторов.Найти(Нов.СекторХранения) = Неопределено тогда 
				МассивСекторов.Добавить(Нов.СекторХранения);
			КонецЕсли;
			// Кухарь А.Ю. 11.11.2021 конец
			
			нов.СекторХраненияРазвернутый=Строка(Нов.СекторХранения);
		КонецЕсли;	
	КонецЦикла;
	
	если не ЕстьВсеТовары тогда
		ТаблицаВозврата.Очистить();
	КонецЕсли;
	
	// Кухарь А.Ю. 24.11.2021 начало
	ТаблицаВозврата.Сортировать("СекторХранения");
	// Кухарь А.Ю. 24.11.2021 конец
	
	
	
	// Кухарь А.Ю. 11.11.2021 начало
	Если МассивСекторов.Количество()>1 тогда
		
		// Кухарь А.Ю. 24.11.2021 начало
		СвернутыйСектор="";
		для каждого СтрМасс из МассивСекторов цикл
			СвернутыйСектор=СвернутыйСектор+СтрМасс+", ";
		КонецЦикла;
		СвернутыйСектор=Лев(СвернутыйСектор,СтрДлина(СвернутыйСектор)-2);		 
		// Кухарь А.Ю. 24.11.2021 конец
		
		
		Для каждого СтрТЗ из ТаблицаВозврата цикл
			СтрТЗ.СекторХранения=СборныйСектор; 
			// Кухарь А.Ю. 24.11.2021 начало
			СтрТЗ.СекторХраненияРазвернутый=СвернутыйСектор; 
			// Кухарь А.Ю. 24.11.2021 конец
			
		КонецЦикла;
	КонецЕсли;
	// Кухарь А.Ю. 11.11.2021 конец
	
	
	возврат ТаблицаВозврата;
	
КонецФункции

Функция НайтиНоменклатуруВМатрицеПоШКилиАртикулуПИД(ШК,Артикул,Контрагент,Договор,ПунктДоставки,МкПл) Экспорт
	ВозврСтр=Новый Структура("Ном,ИДПрод",Справочники.Номенклатура.ПустаяСсылка(),"");
	//НайденнаяНоменклатура=Справочники.Номенклатура.ПустаяСсылка();
	//---------------------------------------------------------------------------
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Матрица.Ссылка КАК Ссылка1
	|ИЗ
	|	Документ.Матрица.ПунктыДоставки КАК Матрица
	|ГДЕ
	|	Матрица.Ссылка.Контрагент = &Контрагент
	|	И Матрица.Ссылка.Дата <= &Дата1
	|	И Матрица.Ссылка.ДатаОкончания >= &Дата2
	|	И Матрица.Ссылка.Договор = &Договор
	|	И Матрица.Ссылка.Проведен = ИСТИНА
	|	И Матрица.ПунктДоставки = &ПДИМ
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	
	Запрос.УстановитьПараметр("Дата2",НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Дата1",КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	Запрос.УстановитьПараметр("Договор",Договор);
	Запрос.УстановитьПараметр("ПДИМ",ПунктДоставки);  // фбс озон
	
	ТЗЕстьМатрицаПоДоговору = Запрос.Выполнить().Выгрузить();
	
	
	Если Артикул <> Неопределено Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	МатрицаТовары.Номенклатура КАК Номенклатура,
		|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
		|	МатрицаТовары.АртикулКонтрагента КАК АртикулКонтрагента,
		|	МатрицаТовары.Цена КАК Цена,
		|	isnull(СоответствиеПоИДИнетМаг.ИД,"""") КАК ИД
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоответствиеПоИДИнетМаг КАК СоответствиеПоИДИнетМаг
		|		ПО МатрицаТовары.Номенклатура = СоответствиеПоИДИнетМаг.Объект
		|		И СоответствиеПоИДИнетМаг.ИнетМагазин = &МкПл
		|ГДЕ
		|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
		|	И МатрицаТовары.Ссылка.ДатаОкончания >= &ТекДата
		|	И МатрицаТовары.Ссылка.Проведен = ИСТИНА
		|	И МатрицаТовары.АртикулКонтрагента ПОДОБНО &ТекАрт
		|	И МатрицаТовары.Ссылка В ИЕРАРХИИ(&спМатриц)";
		
		Запрос.УстановитьПараметр("Контрагент",Контрагент);
		Запрос.УстановитьПараметр("МкПл",МкПл);
		Запрос.УстановитьПараметр("ТекАрт","%"+Строка(Артикул)+"%");
		Запрос.УстановитьПараметр("ТекДата",ТекущаяДата());
		Запрос.УстановитьПараметр("спМатриц",ТЗЕстьМатрицаПоДоговору);
		
		Рез=Запрос.Выполнить().Выбрать();
		Если Рез.Следующий() Тогда
			ВозврСтр.Вставить("Ном",Рез.Номенклатура);
			ВозврСтр.Вставить("ИДПрод",Рез.ИД);
		КонецЕсли;
	КонецЕсли;
	
	возврат ВозврСтр;
	//----------------------------------------------------------------------------
КонецФункции

Процедура ЗаполнитьНакладнуюОзон(ДанныеМаркетПлейса,Выборка,Контрагент,ЭтоТест) Экспорт 
	
	если ложь тогда ДокОбъект=документы.РасходнаяНакладная.СоздатьДокумент();КонецЕсли;  
	если ложь тогда ДанныеМаркетПлейса=Справочники.ИнетМагазины.ПустаяСсылка(); КонецЕсли; 
	
	КритическиеОшибкиОзон = новый Массив;
	НеКритическиеОшибкиОзон = новый Массив;
	
	ОжиданиеУпаковки = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("awaiting_packaging",Истина);		
	ВыборкаПоНомерамЗаказа=Выборка.выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЗаказа");
	
	// Кухарь А.Ю. 29.11.2021 начало
	КоличествоНомеровЗаказа=ВыборкаПоНомерамЗаказа.количество();
	СчНакладных=0; 
	СчВыборки=0;
	МаксЗаказовВНакладной=40;
	// Кухарь А.Ю. 29.11.2021 конец
	
	//Тимофеев Ю.А. Начало   13-11-2024
	//время до которого отгрузка на завтра, после на послезавтра
	//
	ВремяПереносаОтгрузки=Час(ДанныеМаркетПлейса.Склад.ВремяЗапретаОтправкиНаСклад);		
	
	Если ЗначениеНеЗаполнено(ВремяПереносаОтгрузки) Тогда
		ВремяПереносаОтгрузки=14;
	КонецЕсли;
	
	//Тимофеев Ю.А. Конец    13-11-2024
	
	пока ВыборкаПоНомерамЗаказа.следующий() цикл
		// Кухарь А.Ю. 29.11.2021 начало
		//
		СчВыборки=СчВыборки+1;
		если СчНакладных>=МаксЗаказовВНакладной тогда
			СчНакладных=1;
		Иначе
			СчНакладных=СчНакладных+1;
		КонецЕсли;
		
		если СчНакладных=1 тогда
			ПроводитьFBS=Истина;
			ПомечатьНаУдаление=ложь;
			ДокОбъект = СоздатьИЗаполнитьШапкуНакладной(Контрагент,ДанныеМаркетПлейса,Выборка);
			ДокОбъектСсылка=ДокОбъект.ссылка;
			
			ЗаказКлиентаFBS=Документы.ЗаказКлиентаFBS.СоздатьДокумент();
			ЗаказКлиентаFBS.Контрагент=Контрагент;
			ЗаказКлиентаFBS.Дата=ТекущаяДата();
			ЗаказКлиентаFBS.ДокОснование=ДокОбъектСсылка;
		КонецЕсли;
		// Кухарь А.Ю. 29.11.2021 конец
		
		//НомерЗаказа= ВыборкаПоНомерамЗаказа.НомерЗаказа;
		ВыборкаПоТоварам=ВыборкаПоНомерамЗаказа.выбрать();
		пока ВыборкаПоТоварам.следующий() цикл
			СтрТЧ=ЗаказКлиентаFBS.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТЧ,ВыборкаПоТоварам);
			СтрТЧ.НомерЗаказа=СокрЛП(ВыборкаПоТоварам.НомерЗаказа);
			СтрТЧ.АртикулКонтрагента=СокрЛП(ВыборкаПоТоварам.АртикулКонтрагента);
			СтрТЧ.ШтрихКод=ВыборкаПоТоварам.НижнийШК;
			СтрТЧ.РИД=ВыборкаПоТоварам.ВерхнийШК;
			СтрТЧ.СостояниеУКлиента=ОжиданиеУпаковки;
			СтрТЧ.Заявка=СтрТЧ.Количество;
		КонецЦикла;
		
		//Записываем документы либо после того как набралось макс. заказов в 1й  РНК
		//Или по последней строке выборки
		если СчНакладных<МаксЗаказовВНакладной и СчВыборки<КоличествоНомеровЗаказа тогда
			Продолжить;
		КонецЕсли;
		
		ЗаказКлиентаFBS.Записать();
		ТЗТовары=ЗаказКлиентаFBS.Товары.Выгрузить(,"Номенклатура,Количество");
		ТЗТовары.Свернуть("Номенклатура","Количество");		
		
		Для каждого СтрТЗ из ТЗТовары цикл
			СтрТЧ=ДокОбъект.товары.добавить();
			ЗаполнитьЗначенияСвойств(СтрТЧ,СтрТЗ);
			СтрТЧ.Заявка=СтрТЧ.Количество;
			СтрТЧ.ПодтвержденнаяЗаявка=СтрТЧ.Количество;
			ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокОбъект);
			РассчитатьСуммуТабЧасти(СтрТЧ, ДокОбъект);
		КонецЦикла;
		
		Если Контрагент.ИспользоватьНоменклатурнуюМатрицу  Тогда
			ПересчетТЧМатрицы(ДокОбъект,"Товары",ПараметрыСеанса.ВалютаНац,ПараметрыСеанса.ВалютаНац,1,1);	
		Иначе
			ПересчетТЧ(ДокОбъект,"Товары",ПараметрыСеанса.ВалютаНац,ПараметрыСеанса.ВалютаНац,1,1,Истина);	
		Конецесли;		
		
		ЗаполнитьКМПТовара(ДокОбъект);
		ПунктДоставки_ПриИзменении(ДокОбъект);
		Если НЕ ДокОбъект.ОтгрузкаКомплектов =истина Тогда
			ДокОбъект.Комплектующие.Очистить();
			ИмяТЧ="Товары";
		Иначе
			ИмяТЧ="Комплектующие";
		КонецЕсли;	
		
		
		Попытка
			ЗаписьВРег=РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
			ЗаписьВРег.Документ=ДокОбъект.Ссылка;
			ЗаписьВРег.ИмяРеквизита="ИнтернетЗаказ";
			ЗаписьВРег.ЗначениеРеквизита="Да";
			ЗаписьВРег.Записать();
		Исключение
			КритическиеОшибкиОзон.Добавить("Заказ "+ДокОбъект.Ссылка+"не записаны ШК! "+ОписаниеОшибки()); 
		КонецПопытки;
		
		
		ТабОстатков = ПолучитьСвободныйОстатокНаКонецДня(ДокОбъект[ИмяТЧ].Выгрузитьколонку("Номенклатура"),ДокОбъект.склад,ТекущаяДата());
		хватает = 1;
		ТЧТоваровНакладной=ДокОбъект[ИмяТЧ].выгрузить();
		ТЧТоваровНакладной.свернуть("Номенклатура","Количество");
		ДЛя  каждого ТекСтрока из  ТЧТоваровНакладной цикл		
			колОст = 0;
			НайденнаяСтрока = ТабОстатков.Найти(ТекСтрока.Номенклатура,"Номенклатура");
			Если НайденнаяСтрока <> Неопределено ТОгда
