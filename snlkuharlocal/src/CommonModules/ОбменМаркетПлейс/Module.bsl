	//|ВТ_Ном. КАК ШККонтра,
	//|ВТ_Ном.КодКонтра КАК КодКонтра,
	//|ТЗНом.Матрица КАК Матрица,
	|max(ВТ_Ном.МатрицаДата) КАК МатрицаДатаМ
	//|max(ВТ_Ном.ЦенаМатрица) КАК ЦенаМатрица,
	//|min(ВТ_Ном.ЦенаМатрица) КАК ЦенаМатрица1,
	//|max(ВТ_Ном.Матрица) КАК Матрица
	|ПОМЕСТИТЬ ВТ_НомОтбор
	|ИЗ
	|	ВТ_НомМатр КАК ВТ_Ном
	|СОЕДИНЕНИЕ ВТ_Матр КАК ВТ_Матр
	| ПО ВТ_Ном.Матрица=ВТ_Матр.ССылка
	|	СГРУППИРОВАТЬ ПО
	|ВТ_Ном.Номенклатура
	//|ВТ_Ном.КодКонтра
	|;
	
