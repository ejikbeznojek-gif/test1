	Шапка.Вставить("Валюта",Справочники.Валюты.НайтиПоКоду("810"));
	Шапка.Вставить("ДатаОформления",Шапка.дата);
	Шапка.Вставить("СкидкаКонтрагента",ПолучитьРеквизитРодителя(Шапка.Контрагент,"Скидка"));	
	Шапка.Вставить("ДатаОтгрузки",Выборка.ДатаОтгрузки);	
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,Шапка);
	ЗаполнитьШапкуДокумента(ДокОбъект, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,Шапка);
	
	ДокОбъект.ДопОбработки.Очистить();
	Если ДокОбъект.ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
		Для Каждого СтрокаТЧ Из ДокОбъект.Контрагент.ВидыДопОбработок Цикл
			СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
