			Структураexemplars.Вставить("rnpt"                  , "");
			Структураexemplars.Вставить("jw_uin"                , "");
			
			exemplars.Добавить(Структураexemplars);
			quantity = quantity+1;
			
		КонецЦикла;
		
		Структураproducts.Вставить("exemplars",               exemplars); 
		Структураproducts.Вставить("is_gtd_needed",           Ложь);
		Структураproducts.Вставить("is_mandatory_mark_needed",Истина);
		Структураproducts.Вставить("is_rnpt_needed",          Ложь);
		Структураproducts.Вставить("product_id",              Продукт.product_id);                    //продукт ID
		Структураproducts.Вставить("quantity",                quantity);
		
		products.Добавить(Структураproducts);
		
	КонецЦикла;      	
	
	СтруктураТелаЗапроса.Вставить("products",products);	
	
	ТелоЗапроса="";
	ТелоЗапроса          =  МП_СберМаркет_Записать_JSON(СтруктураТелаЗапроса,ПереносСтрокJSON.Авто,ЭкранированиеСимволовJSON.Нет);
	
	Возврат ТелоЗапроса;
	
КонецФункции

Функция МП_ОЗОН_ВернутьСтруктуруДляSHIP(НомерОтправления,ТЗДАННЫХ) Экспорт
	
	///v4/posting/fbs/ship
	
