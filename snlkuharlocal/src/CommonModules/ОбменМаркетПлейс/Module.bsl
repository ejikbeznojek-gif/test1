//функция
//на вход две таблицы
//на выходе различные строки
//Тимофеев Ю.А. 29.05.2025

Функция СравнитьДвеТаблицыЗначенийИвернутьТолькоИзменныеСтроки(ТаблицаИсточник, ТаблицаИзменений, ПоляСортивки="" ,ТолькоИзмененные=Ложь) Экспорт
    
    ИменаВсехКолонок = "";   
	
    Для Каждого Колонка Из ТаблицаИсточник.Колонки Цикл 
        ИменаВсехКолонок = ИменаВсехКолонок + ", " + Колонка.Имя
	КонецЦикла;   
	
    ИменаВсехКолонок = Сред(ИменаВсехКолонок, 2);
    
    Таблица = ТаблицаИзменений.Скопировать();    
    
    Таблица.Колонки.Добавить("БылиИзменения", Новый ОписаниеТипов("Число"));
    
    Таблица.ЗаполнитьЗначения(1, "БылиИзменения");
    
    Для МойСчетчик = 1 По ТаблицаИсточник.Количество() Цикл Таблица.Вставить(0) КонецЦикла;
    
    Для МойСчетчик = 0 По ТаблицаИсточник.Колонки.Количество() - 1 Цикл Таблица.ЗагрузитьКолонку(ТаблицаИсточник.ВыгрузитьКолонку(МойСчетчик), МойСчетчик) КонецЦикла;
    
    Таблица.Колонки.Добавить("Счетчик");
    Таблица.ЗаполнитьЗначения(1, "Счетчик");
    
    Таблица.Свернуть(ИменаВсехКолонок, "БылиИзменения, Счетчик");
    
    Ответ = Таблица.Скопировать(Новый Структура("Счетчик", 1), ИменаВсехКолонок + ", БылиИзменения");    
	
	Если ПоляСортивки<>"" Тогда
		
		Ответ.Сортировать(ПоляСортивки); 
		
	КонецЕсли;
	
	Если ТолькоИзмененные Тогда
		
		ВрТЗ = Ответ.Скопировать();
		ВРТЗ.Очистить();   
		
		Отбор = Новый Структура();
		Отбор.Вставить("БылиИзменения",1);
		СтрокиБылиИзменения = Ответ.НайтиСтроки(Отбор);
		
		Для каждого СтрокаизТЗ из СтрокиБылиИзменения Цикл
			
			НовСтр=ВрТЗ.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтр,СтрокаизТЗ);		
			
		КонецЦикла;  
		
		ВрТЗ.Колонки.Удалить("БылиИзменения");
		Возврат   ВрТЗ;
		
	КонецЕсли;   	
    
    Возврат Ответ
    
КонецФункции
// Ихсанов Д. А. Конец  25.06.2025

// Ихсанов Д. А. Начало 29.07.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2388
// Процедура - Проверка наличия заказов в программе по данным сервиса
//
// Параметры:
//  ТаблицаПараметров	 - ТаблицаЗначений	 - Таблица с параметрами с колонками Имя и Значение.
//
Процедура ПроверкаНаличияЗаказовВПрограммеПоДаннымСервиса(ТаблицаПараметров = Неопределено) Экспорт
	
	// Инициализация параметров исполнения
	ВыполнятьПроверкуПоОзон = Ложь; ВыполнятьПроверкуПоВайлдберрис = Ложь;
	ВыполнятьПроверкуПоЯндекс = Ложь; ВыполнятьПроверкуПоМагнит = Ложь;
	УведомлятьПолучателейОРазличияхВТоварах = Ложь;
	ИнтервалСмещенияОтТекущейДаты = 0; РазмерПорции = 1000;
	СписокПолучателей = Новый СписокЗначений;
	Для каждого ПараметрИсполнения из ТаблицаПараметров Цикл
		Если ПараметрИсполнения.Имя = "ИнтервалСмещенияОтТекущейДаты" Тогда
			ИнтервалСмещенияОтТекущейДаты = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "ВыполнятьПроверкуПоОзон" Тогда
			ВыполнятьПроверкуПоОзон = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "ВыполнятьПроверкуПоВайлдберрис" Тогда
			ВыполнятьПроверкуПоВайлдберрис = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "ВыполнятьПроверкуПоЯндекс" Тогда
			ВыполнятьПроверкуПоЯндекс = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "ВыполнятьПроверкуПоМагнит" Тогда
			ВыполнятьПроверкуПоМагнит = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "РазмерПорции" Тогда
			РазмерПорции = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "УведомлятьПолучателейОРазличияхВТоварах" Тогда
			УведомлятьПолучателейОРазличияхВТоварах = ПараметрИсполнения.Значение
		ИначеЕсли ПараметрИсполнения.Имя = "Получатель" Тогда
			СписокПолучателей.Добавить(ПараметрИсполнения.Значение)
		КонецЕсли
	КонецЦикла;
	
	// Инициализируем параметры
	СекундВОдномДне = 86400;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаОкончания = КонецДня(ТекущаяДата);
	ДатаНачала = НачалоДня(ДатаОкончания) - (ИнтервалСмещенияОтТекущейДаты * СекундВОдномДне);
	
	Сортировка = "ASC";
	СообщениеОбОшибке = "";
	ИменаРеквизитов = "АдресРесурса, Порт, ContentType, Accept, AcceptLanguage, AcceptCharset, ContentLanguage, ContentCharset, Host, Код,
		|XAuthToken, Token, Контрагент, Склад, СкладМаркировки, WarehouseId, Тест, ИДКомпании, Договор, ПунктДоставки, Организация, Наименование, Ссылка";
	
	// Получим данные о списке заказов по интересующим нас интернет магазинам
	МассивНомеровЗаказов = Новый Массив;
	КонтрагентыДляПоиска = Новый Массив;
	КонтрагентыИсключения = Новый Массив;
	
	// Озон
	Если ВыполнятьПроверкуПоОзон Тогда
		МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00002");
		РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
		
		КонтрагентыДляПоиска.Добавить(РеквизитыМаркетПлейса.Контрагент);
		
		ВыполнитьПроверкуНаличияЗаказовОзон(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка,
			РазмерПорции, ДатаНачала, ДатаОкончания)
	КонецЕсли;
	
	// РВБ
	Если ВыполнятьПроверкуПоВайлдберрис Тогда
		МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00009");
		РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
		
		КонтрагентыДляПоиска.Добавить(РеквизитыМаркетПлейса.Контрагент);
		
		ВыполнитьПроверкуНаличияЗаказовРВБ(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка,
			РазмерПорции, ДатаНачала, ДатаОкончания)
	КонецЕсли;
	
	// Яндекс
	Если ВыполнятьПроверкуПоЯндекс Тогда
		МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00004");
		РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
		
		КонтрагентыДляПоиска.Добавить(РеквизитыМаркетПлейса.Контрагент);
		КонтрагентыИсключения.Добавить(РеквизитыМаркетПлейса.Контрагент);
		
		ВыполнитьПроверкуНаличияЗаказовЯндекс(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка,
			РазмерПорции, ДатаНачала, ДатаОкончания)
	КонецЕсли;
	
	// Магнит
	Если ВыполнятьПроверкуПоМагнит Тогда
		МаркетПлейс = Справочники.ИнетМагазины.НайтиПоКоду("00014");
		РеквизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
		
		КонтрагентыДляПоиска.Добавить(РеквизитыМаркетПлейса.Контрагент);
		КонтрагентыИсключения.Добавить(РеквизитыМаркетПлейса.Контрагент);
		
		ВыполнитьПроверкуНаличияЗаказовМагнит(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка,
			РазмерПорции, ДатаНачала, ДатаОкончания)
	КонецЕсли;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЗаказКлиентаFBS.Ссылка КАК Ссылка,
	|	ЗаказКлиентаFBS.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ вт_ЗаказыКлиентовFBS
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|ГДЕ
	|	ЗаказКлиентаFBS.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBS.Контрагент В(&СписокКонтрагентов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ЗаказыКлиентовFBS.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА вт_ЗаказыКлиентовFBS.Контрагент В (&КонтрагентыИсключения)
	|			ТОГДА ЗаказКлиентаFBSТовары.РИД
	|		ИНАЧЕ ЗаказКлиентаFBSТовары.НомерЗаказа
	|	КОНЕЦ КАК НомерЗаказа
	|ИЗ
	|	вт_ЗаказыКлиентовFBS КАК вт_ЗаказыКлиентовFBS
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_ЗаказыКлиентовFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка");
	Запрос.УстановитьПараметр("ДатаНачала",			   ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания",		   ДатаОкончания);
	Запрос.УстановитьПараметр("СписокКонтрагентов",	   КонтрагентыДляПоиска);
	Запрос.УстановитьПараметр("КонтрагентыИсключения", КонтрагентыИсключения);
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("НомерЗаказа");
	
	ТекстыУведомления = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Для каждого ДанныеПоНомеруЗаказа из МассивНомеровЗаказов Цикл
		ПараметрыОтбора.НомерЗаказа = ДанныеПоНомеруЗаказа.НомерЗаказа;
		
		Если Не Выборка.НайтиСледующий(ПараметрыОтбора) Тогда
			ТекстыУведомления.Добавить(СтрШаблон("В программе отсутствует заказ №%1, по контрагенту %2!",
				ДанныеПоНомеруЗаказа.НомерЗаказа, ДанныеПоНомеруЗаказа.МаркетПлейс))
		КонецЕсли
	КонецЦикла;
	
	// Уведомим получаетелей о том, что был произведен вывод марок из оборота в автоматическом режиме
	Если УведомлятьПолучателейОРазличияхВТоварах
		И ТекстыУведомления.Количество() > 1 Тогда
		Сообщить(СтрСоединить(ТекстыУведомления, Символы.ПС));
		ОбменМаркетПлейс.ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,
			"Маркет плейсы. Расхождение по товарам на сайте и в матрицах.",
			СтрСоединить(ТекстыУведомления, Символы.ПС))
	КонецЕсли
	
КонецПроцедуры // ПроверкаНаличияЗаказовВПрограммеПоДаннымСервиса()

// Процедура - Выполнить проверку наличия заказов озон
//
// Параметры:
//  МассивНомеровЗаказов	 - Массив	 - Список номеров заказов, который будет пополняться этой процедурой
//  РеквизитыМаркетПлейса	 - Структура - Данные реквизитов справочника Интернет Магазины
//  Сортировка				 - Строка	 - Направление сортировки получаемых данных
//  РазмерПорции			 - Число	 - Количество получаемых строк в ответе на запрос
//  ДатаНачала				 - Дата		 - Начало интервала получаемых данных
//  ДатаОкончания			 - Дата		 - Конец интервала получаемых данных
//
Процедура ВыполнитьПроверкуНаличияЗаказовОзон(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка, //РазмерПорции...)
	РазмерПорции, ДатаНачала, ДатаОкончания)
	
	СмещениеПоЗапросу = 0;
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	
	Пока Истина Цикл
		ДанныеДляJSON = Новый Структура;
		ДанныеДляJSON.Вставить("dir",		   Сортировка);
		ДанныеДляJSON.Вставить("filter",	   Новый Структура);
