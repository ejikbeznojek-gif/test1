			//Михайловский 20221124 сюда+++
			РНК.ОтгрузкаКомплектов =истина;
			//Михайловский 20221124 сюда---
		Иначе			
			// обычный товар
			СтрокаТЧ = РНК.Комплектующие.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТоваров);
			СтрокаТЧ.Продукция = Номенклатура;
			//Михайловский 20221124 +++
			КолКомпл=СтрокаТоваров.Количество;
			//Михайловский 20221124 ---
			// Ихсанов Д. А. Начало 26.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2511
			Если КолонкиТаблицыКомлпектующих.Найти("НомерЗаказа") <> Неопределено Тогда
				СтрокаТЧ.НомерЗаказа = СтрокаТоваров.НомерЗаказа
			КонецЕсли;
	 		// Ихсанов Д. А. Конец 26.02.2026
		КонецЕсли;
		//Михайловский 20221124 +++
		СтрокаТоваров.КоличествоКомплектующих=КолКомпл;
		//Михайловский 20221124 ---
	КонецЦикла;	
	
	//нечаева 02,02,21
	Если НЕ РНК.ОтгрузкаКомплектов =истина Тогда
