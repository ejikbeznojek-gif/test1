Функция СформироватьТекстОповещенияЕкод(ДокОбъект,МассивОшибок,ВидСообщения,НомерЗаказа="")
	если ВидСообщения="СообщитьМенеджеру" тогда
		
		// Кухарь А.Ю. 29.11.2021 начало
		//
		если ДокОбъект<>Неопределено тогда
			// Кухарь А.Ю. 29.11.2021 конец
			
			СтрокаНомеровЗаказа=СформироватьСтрокуНомеровЗаказаFBS(ДокОбъект.ссылка);
			Строка=Символ(13)+Символ(13)+"       Добрый день!"+Символ(13)+Символ(13)+Строка("Новые заказы ИМ Озон № "+СтрокаНомеровЗаказа+".")+
			+Символы.ПС+"Сформировано новое РНК № "+ДокОбъект.номер+" "+ДокОбъект.Дата+"."+Символ(13)+Символ(13);	
			// Кухарь А.Ю. 29.11.2021 начало
			//
		КонецЕсли;
		// Кухарь А.Ю. 29.11.2021 конец
		
		НомСтр=1;
		Строка=Строка+Символы.ПС;
		Если МассивОшибок.количество()>1 Тогда
			Строка=Строка+Символы.ПС+"Сообщения по загрузке данных:";
		КонецЕсли;	
		Если НЕ МассивОшибок=Неопределено и МассивОшибок.Количество()>0 Тогда
			Для рр=0 по МассивОшибок.Количество()-1 Цикл
				Строка=Строка+Символы.ПС+НомСтр+". "+МассивОшибок[рр];
				Строка=Строка+Символы.ПС;
				НомСтр=НомСтр+1;
			КонецЦикла;
		конецЕсли;
		Строка=Строка+Символы.ПС+"________________________________________________________________";
	ИначеЕсли ВидСообщения="СообщитьМенеджеруОзон" тогда
		Строка=Символ(13)+Символ(13)+"       Добрый день!"; 
		НомСтр=1;
		Строка=Строка+Символы.ПС;
		Если МассивОшибок.количество()>1 Тогда
			Строка=Строка+Символы.ПС+"Сообщения по загрузке данных:";
		КонецЕсли;	
		Если НЕ МассивОшибок=Неопределено и МассивОшибок.Количество()>0 Тогда
			Для рр=0 по МассивОшибок.Количество()-1 Цикл
				Строка=Строка+Символы.ПС+НомСтр+". "+МассивОшибок[рр];
				Строка=Строка+Символы.ПС;
				НомСтр=НомСтр+1;
			КонецЦикла;
		конецЕсли;
		Строка=Строка+Символы.ПС+"________________________________________________________________";	
	ИначеЕсли ВидСообщения="СообщитьОбОтменеЗаказа" тогда	
		
		Строка=Символ(13)+Символ(13)+"       Добрый день!"+Символ(13)+Символ(13)+Строка("Отмена заказа ИМ Озон № "+номерЗаказа+".")+
		+Символы.ПС+" РНК № "+ДокОбъект.номер+" "+ДокОбъект.Дата+"."+Символ(13)+Символ(13)+"Заказ отменен. Просьба удалить товар из РНК!!!";
		Строка=Строка+Символы.ПС+"________________________________________________________________";
		
		// Кухарь А.Ю. 11.11.2021 начало
	ИначеЕсли ВидСообщения="СообщитьОНоменклатуреБезСектора" тогда
		СписокПозиций="";
		Для рр=0 по МассивОшибок.Количество()-1 Цикл
			СписокПозиций=СписокПозиций+Символы.ПС+МассивОшибок[рр].Наименование+"("+МассивОшибок[рр].Код+")"+Символ(13);
		КонецЦикла;
		Строка="При загрузке накладной с сайта озон, у ряда брендов обнаружен пустой сектор. " +Символ(13)
		+"Эти товары загружены в сборную накладную. " +Символ(13)
		+"Для того чтобы при следующей загрузке этот товар попал в накладную по сектору, установите бренд для следующих позиций: "+Символ(13)
		+СписокПозиций;
		// Кухарь А.Ю. 11.11.2021 конец
		
	КонецЕсли;
	возврат Строка;
	
КонецФункции

Функция СформироватьТемуОповещенияЕкод(ДокОбъект,ВидСообщения,НомерЗаказа="")
	// Кухарь А.Ю. 29.11.2021 начало
	//
	если ДокОбъект<>Неопределено тогда
		Номер=" № "+ДокОбъект.Номер;
	иначе
		Номер="";
	КонецЕсли;
	// Кухарь А.Ю. 29.11.2021 конец
	
	если ВидСообщения="СообщитьМенеджеру" тогда
		Тема=" Новый заказ из ИМ Озон № "+Номер;		
	ИначеЕсли ВидСообщения="СообщитьМенеджеруОзон" тогда
		Тема=" Ошибки Озон"+Номер;	
	ИначеЕсли ВидСообщения="СообщитьОбОтменеЗаказа" тогда	
		Тема=" Отмена заказа Озон."+Номер+" . № заказа "+НомерЗаказа;	
	ИначеЕсли ВидСообщения="СообщитьОНоменклатуреБезСектора" тогда	
		Тема="ОЗОН. Номенклатура без сектора.";
	КонецЕсли;
	
	
	возврат Тема;
КонецФункции

Функция СформироватьМассивНомеровЗаказовFBSПоНакладной (Накладная) Экспорт
	
	ЗаказFBS=ОбщегоНазначения_ПИ.ПолучитьЗаказКлиентаFBSПоНакладной(накладная);
	если не ЗначениеЗаполнено(ЗаказFBS) тогда
		возврат новый Массив;
	КонецЕсли;
	ТЗЗаказов=ЗаказFBS.товары.выгрузить("НомерЗаказа");
	ТЗЗаказов.свернуть("НомерЗаказа");
	МассивЗаказов=ТЗЗаказов.выгрузитьколонку("НомерЗаказа");
	Возврат МассивЗаказов;
КонецФункции

Функция СформироватьСтрокуНомеровЗаказаFBS (Накладная)
	СтрокаНомеровЗаказа="";
	МассивНомеровЗаказа=СформироватьМассивНомеровЗаказовFBSПоНакладной(Накладная);
	Для каждого СтрМасс из МассивНомеровЗаказа цикл
		СтрокаНомеровЗаказа=СтрокаНомеровЗаказа+", "+СтрМасс;
	КонецЦикла;
	СтрокаНомеровЗаказа=Лев(СтрокаНомеровЗаказа,СтрДлина(СтрокаНомеровЗаказа)-2);
	возврат СтрокаНомеровЗаказа;
КонецФункции 



// переводим на сборку заказы
//Михайловский 20220719 ряд методов нужно переписать в связи со блокировкой ряда методов апи, см. выше +++
Процедура ОтправитьВОзонПодтверждениеОЗагрузкеЗаказовНакладной_ПредВер(ДанныеМаркетПлейса,ДокОбъектСсылка,ЗаказFBS,ЭтоТест=ложь)  экспорт
	КритическиеОшибкиОзон=новый Массив;	
	Команда = "/v2/posting/fbs/ship";  // Меняет состояние на сайте с awaiting_packaging на awaiting_deliver
	ТелоДЖ = "";
	
	Контрагент=ДанныеМаркетПлейса.Контрагент;
	ЗаказFBSОбъект=ЗаказFBS.получитьобъект();
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента
	|ИЗ
	|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.Ссылка = &ЗаказFBS
	|	И НЕ ЗаказКлиентаFBSТовары.Отменен
	|	И ЗаказКлиентаFBSТовары.Ссылка.Проведен
	|	И ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.Проведен
	|	И НЕ ЗаказКлиентаFBSТовары.ВычеркОфис
	|	И НЕ ЗаказКлиентаFBSТовары.ВычеркСклад
	|ИТОГИ ПО
	|	НомерЗаказа";
	запрос.УстановитьПараметр("ЗаказFBS",ЗаказFBS);
	ВыборкаНомераЗаказов=запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЗаказа");
	пока ВыборкаНомераЗаказов.Следующий() цикл
		ОтправитьВОзонПодтверждениеНачалаСборкиВыборкиСтрок_ПредВер(ВыборкаНомераЗаказов, ДанныеМаркетПлейса, Команда, КритическиеОшибкиОзон,ЭтоТест);
	КонецЦикла;
	
	Если  КритическиеОшибкиОзон.количество()>0 Тогда
		ВидСообщения="СообщитьМенеджеруОзон";
		СписокПолучателей=СформироватьСписокПолучателейЕкод(ВидСообщения,ЭтоТест);
		ТемаОповещения=СформироватьТемуОповещенияЕкод (ДокОбъектСсылка,ВидСообщения);
		ТекстОповещения=СформироватьТекстОповещенияЕкод(ДокОбъектСсылка,КритическиеОшибкиОзон,ВидСообщения);
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);
		КритическиеОшибкиОзон.очистить(); 	
	КонецЕсли; 		
	
	ОжиданиеДоставки = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("awaiting_deliver");	
	для каждого СтрТЧ из ЗаказFBSОбъект.Товары цикл
		СтрТЧ.СостояниеУКлиента=ОжиданиеДоставки;
	КонецЦикла;
	ЗаказFBSОбъект.Записать();
КонецПроцедуры

