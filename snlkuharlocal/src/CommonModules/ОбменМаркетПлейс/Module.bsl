Функция МП_ВАЙЛБЕРИЗ_ПолучитьSKUОстатки(ТаблицаСтрок=Неопределено,МассивСтрок=Неопределено) Экспорт
	
	//Тимофеев Ю.А. 16.01.2024
	//если передали таблицу ШККОНТРА и КВЫГРЗКЕ - преобразуем в массив
	//Иначе сразу готовый массив в JSON	
	
	
	Если МассивСтрок=Неопределено Тогда
		
		//таблицу строк в массив
		
		МассивСтрок = Новый Массив;
		
		Для Каждого ТекСтр из ТаблицаСтрок Цикл		
			//МассивСтрок.Добавить("sku:"+ТекСтр.ШККонтра+", amount:"+Формат(ТекСтр.КВыгрузке,"ЧН=0; ЧГ=0"));	
			
			Структура_data = Новый Структура;
			Структура_data.Вставить("sku",	    ТекСтр.ШК);
			// Ихсанов Д. А. Начало 17.02.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-146
			Структура_data.Вставить("chrtId", Число(ТекСтр.АртикулКонтрагента));
			// Ихсанов Д. А. Конец  17.02.2026
			Структура_data.Вставить("amount",	Число(Формат(ТекСтр.КВыгрузке,"ЧН=0; ЧГ=0")));
			
			МассивСтрок.Добавить(Структура_data);
			
		КонецЦикла;     
		
	КонецЕсли;   	
	
	//массив в структрур
	Структура_data = Новый Структура;
	Структура_data.Вставить("stocks",	МассивСтрок);
	
	ТелоЗапроса          = МП_СберМаркет_Записать_JSON(Структура_data,ПереносСтрокJSON.Нет,ЭкранированиеСимволовJSON.Нет);
	
	Возврат ТелоЗапроса;
	
	//пример  - "{""stocks"": [{""sku"":""8000000924759"",""amount"":10}]}";
	
КонецФункции     

