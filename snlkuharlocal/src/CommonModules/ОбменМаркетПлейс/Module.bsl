Процедура МП_Вайлберриз_ОбраткаПолученныхЗаказов(МаркПл,ТЗЗакНом,Стат1="0",ЭтоТест=Ложь,СтруктураПараметров) Экспорт
	
	ЛимитПозиций   =   МаркПл.ЛимитПоКоличеству;
	
	
	СтруктураПараметров.Вставить("ЛимитПозиций"       ,ЛимитПозиций);
	
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);    //???
	МассивМассивовЗаказов=Новый Массив;
	
	//разделим таблицу на СПАЙКИ (КОМПЛЕКТ) и ШТУКИ
	
	ТЗКомплект= ТЗЗакНом.Скопировать();
	ТЗКомплект.очистить();
	ТЗШтука   = ТЗКомплект.Скопировать();
	
	Для Каждого стрТаб из ТЗЗакНом Цикл
		
		Если СтрТаб.Комплект Тогда
			НовСтрокаК=ТЗКомплект.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрокаК,СтрТаб);
		Иначе
			НовСтрокаШ=ТЗШтука.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрокаШ,СтрТаб);
		КонецЕсли;
		
	КонецЦикла;	
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Начало обработки заказов WB - штучный товар","Информация");
	КонецЕсли;
	
	//ТекстОповещения="Начало обработки заказов WB - штучный товар"+Символы.ПС;
	ТекстОповещения=""; // 25.11.25 Тимофеев Ю.А.
	//разделим таблицу на СПАЙКИ (КОМПЛЕКТ) и ШТУКИ
	
	//обработаем ШТУЧНЫЕ ЗАКАЗЫ  
	
	Если ТЗШтука.Количество()>0 Тогда 		
		МассивЗаказовШтучно = МП_Вайлберриз_СоздатьДокументыНаШтучныйТовар(ТЗШтука,МаркПл,СтруктураПараметров,ТекстОповещения);	
		МассивМассивовЗаказов.Добавить(МассивЗаказовШтучно);
	КонецЕсли;   
	
	
	
	//получим таблицу спаек  с УПАКОВКОЙ и без 
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Начало обработки заказов WB - СПАЙКИ","Информация");
	КонецЕсли;
	
	//ТекстОповещения="Начало обработки заказов WB - штучный товар"+Символы.ПС;
	ТекстОповещения=""; // 25.11.25 Тимофеев Ю.А.
	
	
	КНеТовар=МП_ПровкаНеТовар(ТЗКомплект);
	
	
	ТЗСпайкаСУпаковкой=ТЗКомплект.Скопировать();
	ТЗСпайкаСУпаковкой.Очистить();
	
	ТЗСпайкаСБезУпаковки = ТЗСпайкаСУпаковкой.Скопировать();  
	
	Если КНеТовар.МассивНеТовар.Количество()>0 Тогда    	 
		
		ТЗСпайкаСБезУпаковки = ТЗСпайкаСУпаковкой.Скопировать();
		
		Для Каждого ТСтр из ТЗКомплект Цикл
			
			Если ТСтр.КолНеТовар Тогда
				НовСтрокаУ=ТЗСпайкаСУпаковкой.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаУ,ТСтр);
			Иначе
				НовСтрокаБез= ТЗСпайкаСБезУпаковки.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаБез,ТСтр);
			КонецЕсли;
			
		КонецЦикла;	
		
	Иначе
		ТЗСпайкаСБезУпаковки = ТЗКомплект.Скопировать();
	КонецЕсли;
	
	Если ТЗСпайкаСБезУпаковки.Количество()>0 Тогда 
		МассивСпайкаБезУпаковки=МП_Вайлберриз_СоздатьДокументыНаСпайку(ТЗСпайкаСБезУпаковки,МаркПл,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.
		МассивМассивовЗаказов.Добавить(МассивСпайкаБезУпаковки);
	КонецЕсли;  
	
	//спайка по одинаковым упаковочкам
	
	МассивНеТовар=КНеТовар.МассивНеТовар;
	
	Для каждого НеТовар из МассивНеТовар Цикл
		
		ТЗСпайкаПоУпаковке=ТЗСпайкаСУпаковкой.Скопировать();
		ТЗСпайкаПоУпаковке.Очистить();
		
		рр=ТЗСпайкаСУпаковкой.Количество()-1;
		
		Пока рр>=0 Цикл
			
			ТСтр=ТЗСпайкаСУпаковкой.Получить(рр);
			
			Если ТСтр.НомРП1=НеТовар Тогда
				НовС=ТЗСпайкаПоУпаковке.Добавить();
				ЗаполнитьЗначенияСвойств(НовС,ТСтр);
				ТЗСпайкаСУпаковкой.Удалить(рр);
			КонецЕсли;
			
			рр=рр-1;
			
		КонецЦикла;
		
		МассивСпайкаПоУпаковке=МП_Вайлберриз_СоздатьДокументыНаСпайку(ТЗСпайкаПоУпаковке,МаркПл,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.
		
		МассивМассивовЗаказов.Добавить(МассивСпайкаПоУпаковке);
		
		
	КонецЦикла;
	
	//спайка по одинаковым упаковочкам
	
	Если ТЗСпайкаСУпаковкой.Количество() Тогда  
		//а вдруг не все удалили
		
		МассивСпайкаСУпаковкой=МП_Вайлберриз_СоздатьДокументыНаСпайку(ТЗСпайкаСУпаковкой,МаркПл,СтруктураПараметров,ТекстОповещения);  //Тимофеев Ю.А.  	 
		МассивМассивовЗаказов.Добавить(МассивСпайкаСУпаковкой); 	 
		
	КонецЕсли;	
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета +" Смена статусов у заказов","Информация");  
	КонецЕсли;	
	
	СостояниеУКлиента=Справочники.СостояниеНакладнойУКлиента.НайтиПоКоду(11);  //НА СБОРКЕ
	
	Для Каждого текМассивЗаказов Из МассивМассивовЗаказов Цикл  			
		
		Для Каждого текущийМассив Из текМассивЗаказов Цикл
			
			Если ТипЗнч(текущийМассив)<>Тип("ДокументСсылка.ЗаказКлиентаFBS") Тогда
				ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета +" текущийМассив "+Строка(текущийМассив),"Ошибка");
				продолжить;
			КонецЕсли;
			
			Если НЕ текущийМассив.ПометкаУдаления Тогда
				
				//ТЮА - тут нужно подумать - не подтвержать сразу того чего нет !
				
				//Если ЗначениеЗаполнено(текущийМассив.ДокОснование) и  Не текущийМассив.ДокОснование.Проведен Тогда
				//    //если накладная РНК не провелась -есть проблемы- нет товара или ждем перемещения
				//    //не будем подтвержадать в первый час!
				//    Продолжить;					 
				//КонецЕсли;                    				 
				
				
				Если Не ЭтоТест Тогда
					//получение номера поставки и привязка в нее на портале 					
					ПривязкаПоставки=МП_ВыгрузитьСтатусыНаПортал(текущийМассив,МаркПл);					 
				Иначе
					ПривязкаПоставки=1;
				КонецЕсли;
				//???
				Если ПривязкаПоставки>0 Тогда
					
					ДокОб=текущийМассив.ПолучитьОбъект();
					
					НужноЗаписывать = Ложь;
					
					Для Каждого ТСтр Из ДокОб.Товары Цикл
						
						Если ТСтр.СостояниеУКлиента<>СостояниеУКлиента Тогда
							
							ТСтр.СостояниеУКлиента=СостояниеУКлиента;
							НужноЗаписывать = Истина;
							
						КонецЕсли;
						
					КонецЦикла;	
					
					Если НужноЗаписывать Тогда
						
						Если ДокОб.ПометкаУдаления Тогда
							ДокОб.Записать(РежимЗаписиДокумента.Запись);
						Иначе  							
							ДокОб.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;  					  
						
					КонецЕсли;  					
					
				КонецЕсли;      			  
				
				////////////////////////////
				
				Если Не ЭтоТест Тогда
					МП_Вайлбериз_ЗапросПоСтикерам(текущийМассив,МаркПл,ЭтоТест);  //????
				КонецЕсли; 
				
				
				Попытка
					РегЗаказМарка = РегистрыСведений.ЗаказыFBSМаркировка.СоздатьМенеджерЗаписи();
					РегЗаказМарка.ЗаказFBS = текущийМассив;
					РегЗаказМарка.Записать();
				Исключение
					
				КонецПопытки;    
				
			КонецЕсли;
			
			Если Не ЭтоТест Тогда
				
				МП_Вайлбериз_КонтрольКоличествоКМПЛ(текМассивЗаказов,МаркПл,Истина,ЛимитПозиций);
				
			КонецЕсли;
			
		КонецЦикла; 	  
		
	КонецЦикла;  
	
	
	Если ЭтоТест Тогда
		Сообщить(ТекстОповещения);
	Иначе
		
		СписокПолучателей=новый СписокЗначений;
		
		СписокПолучателей.Добавить("timofeev@collant.ru");   //пока на время теста только мне						
		
		ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,"Результат обработки загрузки WB",ТекстОповещения);   
		
		МП_Вайлбериз_ДозагрузитьЗагрузитьШКНеЗависимая(МаркПл);
		
	КонецЕсли;
	
	Если МаркПл.Тест Тогда
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Окончание выполнения. Задача: Загрузка заказов ВБ. !","Информация");
	КонецЕсли;  		
	
КонецПроцедуры  

Функция МП_ПровкаНеТовар(ТЗЗ)Экспорт
	
	//замена на ПровНеТовар(ТЗЗ)
	
	Рез=0;
	
	МассивНеТовар=Новый Массив;     //МассивНеТовар
	
	РезВС=Новый Структура;
	РезВС.Вставить("МаксКолво",Рез);
	РезВС.Вставить("МассивНеТовар",МассивНеТовар);
	
	ТЗСвод=ТЗЗ.Скопировать();
	ТЗСвод.Свернуть("Номенклатура");
	
	Запрос=Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	НоменклатураКоплектующие.Номенклатура КАК НеТовар,
	|	НоменклатураКоплектующие.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НЕ НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = &Товар
	|	И НоменклатураКоплектующие.Ссылка В(&МасНом)";
	Запрос.УстановитьПараметр("МасНом",ТЗСвод.ВыгрузитьКолонку("Номенклатура"));
	Запрос.УстановитьПараметр("Товар", Перечисления.ВидыНоменклаутры.Товар);
	
	ТЗКолНТ = Запрос.Выполнить().Выгрузить(); 		
	
	Если НЕ ТЗКолНТ.Количество() Тогда
		Возврат РезВС;
	КонецЕсли;                                	
	
	Для Каждого ТС Из ТЗЗ Цикл
		
		Найды=ТЗКолНТ.НайтиСтроки(Новый Структура("Ссылка",ТС.Номенклатура));
		
		Если Найды.Количество()=1 Тогда
			
			ТекН=Найды[0].НеТовар;
			
			Если МассивНеТовар.Найти(ТекН)=неопределено Тогда
				
				МассивНеТовар.Добавить(ТекН);
				
			КонецЕсли;	
			
		КонецЕсли;
		
		Счт=1;
		Для Каждого Найд Из Найды Цикл
			ТС.КолНеТовар=ТС.КолНеТовар+1;
			Если Счт=1 Тогда
				ТС.НомРП1=Найд.НеТовар;
			ИначеЕсли Счт=2 Тогда
				ТС.НомРП2=Найд.НеТовар;	
			ИначеЕсли Счт=3 Тогда
				ТС.НомРП3=Найд.НеТовар;	
			Иначе
				ТС.НомРП4=Найд.НеТовар;	
			КонецЕсли;	
			Счт=Счт+1;	
		КонецЦикла;	
		
		Если ТС.КолНеТовар>Рез Тогда
			Рез=ТС.КолНеТовар;
		КонецЕсли;
		
	КонецЦикла;	
	
	РезВС.Вставить("МаксКолво",    Рез);
	РезВС.Вставить("МассивНеТовар",МассивНеТовар);
	
	Возврат РезВС;
	
КонецФункции	

Функция МП_Вайлберриз_СоздатьДокументыНаШтучныйТовар(ТЗЗакНомНеКомплект,МаркетПлейс,СтруктураПараметров,ТекстОповещения) Экспорт ////СоздатьДокиНеКомпл
	//Замена СоздатьДокиНеКомпл(ТЗЗакНом,МаркПл);
	
	Если Ложь Тогда
		МаркетПлейс=Справочники.ИнетМагазины.СоздатьЭлемент();
	КонецЕсли;    	
	
	МассивНовыхЗаказов=Новый Массив;
	
	Если НЕ ТЗЗакНомНеКомплект.Количество() Тогда
		Возврат МассивНовыхЗаказов;
	КонецЕсли;  	
	
	//Тимофеев Ю.А. 10.07.24
	//получаем переменные из таблицы параметров
	
	Если СтруктураПараметров.Свойство("ЛимитПозиций") Тогда
		ЛимитПозиций=СтруктураПараметров.ЛимитПозиций;
	Иначе
		ЛимитПозиций=Ложь;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ЛимитПоСекторам") Тогда
		ЛимитПоСекторам=СтруктураПараметров.ЛимитПоСекторам;    
		
		ТЗлимитпоСекторам = Новый ТаблицаЗначений;
		ТЗлимитпоСекторам.Колонки.Добавить("СекторХранения");
		ТЗлимитпоСекторам.Колонки.Добавить("Факт");
		
	Иначе
		ЛимитПоСекторам=Ложь;
	КонецЕсли; 
	
	Если СтруктураПараметров.Свойство("ОграничительЧаса") Тогда
		ОграничительЧаса=СтруктураПараметров.ОграничительЧаса;
	Иначе
		ОграничительЧаса=0;     //проверить ТИМ
		
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ЧасНагрузки") Тогда
		ЧасНагрузки=СтруктураПараметров.ЧасНагрузки;
	Иначе
		ЧасНагрузки=0;         //проверить ТИМ
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ИнтеграторЧаса") Тогда
		ИнтеграторЧаса=СтруктураПараметров.ИнтеграторЧаса;
	Иначе
		ИнтеграторЧаса=Ложь;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("МаркировкаВсе") Тогда			
		НужнаМаркировка = СтруктураПараметров.МаркировкаВсе; 
	Иначе
		НужнаМаркировка =Ложь;
	КонецЕсли;
	
	
	//Получаем параметр ПереносОТГРУЗКИ
	
	Если СтруктураПараметров.Свойство("ПереносОтгрузки") Тогда
		ПереносОтгрузки=СтруктураПараметров.ПереносОтгрузки;
	Иначе
		ПереносОтгрузки=1;
	КонецЕсли; 	
	
	//Получаем параметр ПереносОТГРУЗКИ
	
	ТЗСвод=ТЗЗакНомНеКомплект.Скопировать();
	ТЗСвод.Свернуть("Номенклатура","КолвоЗак,СуммаЗак");   //входящую таблицу переделать ТИМ 26.02.25
	
	//тут перемещения если есть доп.склады ТИМОФЕЕВ Ю.А. вернуть
	
	//Разделение на сектора Хранений
	ТЗСвод.Колонки.Добавить("СекторХранения",новый ОписаниеТипов("СправочникСсылка.СектораХранения")) ;
	
	Если (МаркетПлейс.warehouseId = "1877" или МаркетПлейс.warehouseId = "729108")  Тогда 
		
		//если наш центральный склад
		
		Для Каждого СтрН из ТЗСвод Цикл
			
			Ном = СТрН.Номенклатура; 	
			
			Бренд              =ОбщегоНазначения_ПИ.ПолучитьБрендПоЭлементуНоменклатуры(Ном);
			СтрН.СекторХранения=ОбщегоНазначения_ПИ.ПолучитьСекторХраненияПоБренду(Бренд); 
			
		КонецЦикла;
		
	Иначе
		
		ТЗСвод.ЗаполнитьЗначения(Справочники.СектораХранения.ПустаяСсылка(),"СекторХранения");
		
	КонецЕсли;  
	
	ТЗСектора = ТЗСвод.Скопировать(,"СекторХранения");
	ТЗСектора.Свернуть("СекторХранения");
	
	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(МаркетПлейс.Склад);
	
	Если ЗначениеЗаполнено(МаркетПлейс.СкладМаркировки) Тогда
		МассивСкладов.Добавить(МаркетПлейс.СкладМаркировки);
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	//создаем документы по секторам
	
	Для каждого тСектор из ТЗСектора Цикл
		
		ТоварПоСекторам=ТЗСвод.НайтиСтроки(Новый Структура("СекторХранения",тСектор.СекторХранения));
		
		ТЗСводНовый = ТЗСвод.СкопироватьКолонки();
		
		Для Каждого НайдТовар из ТоварПоСекторам Цикл
			НовСтрТЗ = ТЗСводНовый.Добавить();
			ЗаполнитьЗначенияСвойств(НовСТрТЗ,НайдТовар);
		КонецЦикла;
		
		
		//Тимофеев Ю.А.
		//контроль по количеству товара в заказе
		ТекЧас = Час(ТекущаяДата());
		
		Если ТекЧас>7 и ТекЧас < ЧасНагрузки Тогда
			
			//больше 8 чтобы дать утренним загрузкам большим в 5 утра и 6 утра без ограничений
			//час нагрузки по умолчанию 18
			
			Если Цел(ТекЧас/ИнтеграторЧаса) = ТекЧас/ИнтеграторЧаса Тогда
				//если условие 1 каждый час , 2 каждый второй час, 3 каждый третий час				
				Если ТЗСводНовый.Количество()< ОграничительЧаса Тогда
					продолжить;
				КонецЕсли; 		
			КонецЕсли;   
			
		КонецЕсли;
		//контроль по количеству товара в заказе
		//Тимофеев Ю.А.	
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = "      ВЫБРАТЬ
		|	ТЗНом.Номенклатура КАК Номенклатура,
		|	ТЗНом.КолвоЗак КАК Количество
		|ПОМЕСТИТЬ ВТ_НомДок
		|ИЗ
		|	&ТЗНом КАК ТЗНом
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
		|	Остатки.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ОстаткиДвухСкладов
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В (&Склады)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТ_НомДок.Номенклатура КАК Номенклатура
		|					ИЗ
		|						ВТ_НомДок КАК ВТ_НомДок)) КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад В (&Склады)
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТ_НомДок.Номенклатура КАК Номенклатура
		|						ИЗ
		|							ВТ_НомДок КАК ВТ_НомДок)) КАК Резервы
		|		ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			И Остатки.Склад = Резервы.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура,
		|	Остатки.КоличествоОстаток
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
		|	Остатки.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ОстаткиФБС
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад = &СкладФБС
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТ_НомДок.Номенклатура КАК Номенклатура
		|					ИЗ
		|						ВТ_НомДок КАК ВТ_НомДок)) КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад = &СкладФБС
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТ_НомДок.Номенклатура КАК Номенклатура
		|						ИЗ
		|							ВТ_НомДок КАК ВТ_НомДок)) КАК Резервы
		|		ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			И Остатки.Склад = Резервы.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура,
		|	Остатки.КоличествоОстаток
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_НомДок.Номенклатура КАК Номенклатура,
		|	ВТ_НомДок.Количество КАК Количество
		|ПОМЕСТИТЬ ВТ_ДОКМ
		|ИЗ
		|	ВТ_НомДок КАК ВТ_НомДок
		|ГДЕ
		|	НЕ ВТ_НомДок.Номенклатура В
		|				(ВЫБРАТЬ
		|					ВТ_ОстаткиФБС.Номенклатура КАК Номенклатура
		|				ИЗ
		|					ВТ_ОстаткиФБС КАК ВТ_ОстаткиФБС
		|				ГДЕ
		|					ВТ_ОстаткиФБС.КолКонФакт > 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК КолКонФакт,
		|	Остатки.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_ОстаткиМаркиФБС
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад = &СкладМаркаФБС
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТ_НомДок.Номенклатура КАК Номенклатура
		|					ИЗ
		|						ВТ_НомДок КАК ВТ_НомДок)) КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
		|				,
		|				Склад = &СкладМаркаФБС
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТ_НомДок.Номенклатура КАК Номенклатура
		|						ИЗ
		|							ВТ_НомДок КАК ВТ_НомДок)) КАК Резервы
		|		ПО Остатки.Номенклатура = Резервы.Номенклатура
		|			И Остатки.Склад = Резервы.Склад
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура,
		|	Остатки.КоличествоОстаток
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
