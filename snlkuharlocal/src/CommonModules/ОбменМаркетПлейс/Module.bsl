//
// Параметры:
//  МаркетПлейс	 - Справочник.ИнетМагазины	 - Ссылка на сущность маркетплейса
// 
// Возвращаемое значение:
//  Число - Количество новых заказов на стороне сервиса Магнит Маркет.
//
Функция МП_МагнитМаркет_КонтрольКоличестваЗаказов(МаркетПлейс) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	ИменаРеквизитов = "ИдКомпании, Контрагент, ПериодСут, Тест";
	РевизитыМаркетПлейса = ЗначенияРеквизитовОбъекта(МаркетПлейс, ИменаРеквизитов);
	СостояниеУКлиента	 = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("NEW;CUSTOM");
	
	ДатаНачала 	  = НачалоДня(ТекущаяДата);
	ДатаОкончания = КонецДня(ТекущаяДата) + 1;
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказКлиентаFBS.Ссылка = ЗаказКлиентаFBSТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаFBS.Контрагент = &Контрагент
	|	И ЗаказКлиентаFBS.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЗаказКлиентаFBSТовары.СостояниеУКлиента = &СостояниеУКлиента");
	Запрос.УстановитьПараметр("ДатаНачала",        ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", 	   КонецДня(ДатаОкончания) + 1);
	Запрос.УстановитьПараметр("Контрагент",    	   РевизитыМаркетПлейса.Контрагент);
	Запрос.УстановитьПараметр("СостояниеУКлиента", СостояниеУКлиента);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ДанныеДляJSON = Новый Структура();
	ДанныеДляJSON.Вставить("page_size",  1000);
	ДанныеДляJSON.Вставить("status",  	 "NEW");
	ДанныеДляJSON.Вставить("created_at", Новый Структура);
	ДанныеДляJSON.created_at.Вставить("from", ЗаписатьДатуJSON(ДатаНачала, 
	ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.УниверсальнаяДата));
	ДанныеДляJSON.created_at.Вставить("to",   ЗаписатьДатуJSON(ДатаОкончания, 
	ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.УниверсальнаяДата));
	
	ПараметрыОбработки = ПолучитьОбщиеПараметрыОбработки();
	ПараметрыОбработки.ДанныеЗапроса.Метод	     = "POST";
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = СформироватьСтрокуJSON(ДанныеДляJSON,
		ПараметрыОбработки);
	
	КоличествоНовыхЗаказов = 0;
	ЗапросАктуален		   = Истина;
	Пока ЗапросАктуален Цикл
		ДанныеОтвета = ВыполнитьИОбработатьЗапросВМоделиСервиса(
			МП_Магнит_ВернутьСоединение(МаркетПлейс),
			МП_Магнит_ВернутьЗаголовкиHTTP(МаркетПлейс),
			"/api/seller/v1/orders/list", 
			ПараметрыОбработки);
		
		Если ДанныеОтвета.Свойство("error")
			Или ДанныеОтвета.Свойство("errors")
			Или ДанныеОтвета.Свойство("code") Тогда
			Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При получении данных о заказах на стороне сервиса возникла ошибка!'", "ru");
			СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ОтправитьДанныеПоСтатусуДокумента");
			Если РевизитыМаркетПлейса.Тест Тогда
				ЗаписатьВЛог("МП_МагнитМаркет", СообщениеОбОшибке, "Ошибка");
			КонецЕсли;
			
			ВызватьИсключение СообщениеОбОшибке;
		КонецЕсли;
		
		Для каждого ДанныеЗаказа из ДанныеОтвета.orders Цикл
			Если Не Выборка.НайтиСледующий(Новый Структура("НомерЗаказа", ДанныеЗаказа.order_id)) Тогда
				КоличествоНовыхЗаказов = КоличествоНовыхЗаказов + 1;
			КонецЕсли;
			
			Выборка.Сбросить();
		КонецЦикла;
		
		ЗапросАктуален = ДанныеОтвета.Свойство("next_page_token");
		Если ЗапросАктуален Тогда
			Если Не ДанныеДляJSON.Свойство("next_page_token") Тогда
				ДанныеДляJSON.Вставить("page_token");
			КонецЕсли;
			
			ДанныеДляJSON.page_token = ДанныеДляJSON.next_page_token;
		КонецЕсли;
	КонецЦикла;
	
	Возврат КоличествоНовыхЗаказов;
	
КонецФункции // МП_ЯндексМаркет_КонтрольКоличестваЗаказов()
