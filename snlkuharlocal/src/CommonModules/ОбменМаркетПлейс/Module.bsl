	Данные = Новый Структура;
	Данные.Вставить("posting_number",НомераЗаказов);
	
	Попытка
		ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
		Запись.Закрыть();
	Исключение
	КонецПопытки;;  
	
	ПутькПДФ="";
