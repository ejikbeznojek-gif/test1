	НоваяРНК.ТребуетсяМаркировка  = НужнаМаркировка;
	//признак наличия маркировки в документе     				
	//изанчально РНК в работе
	НоваяРНК.СостояниеНакладной= Перечисления.СостоянияНакладной.ВРаботе; 	
	//механизм дата отгрузки
	
	// Кухарь А.Ю. 07.07.2023 начало
	ЧасПриемки     =Час(ТекущаяДата());
	ДеньЗагрузки   =ДеньНедели(ТекущаяДата());
	СекундВДне     =24*3600;
	// Кухарь А.Ю. 07.07.2023 конец  
	
	ПрефиксМаркета=ПрефМаркет(МаркетПлейс);//???
	
	Если  ПереносОтгрузки=1 Тогда
		
		если ЧасПриемки<19 тогда
			НоваяРНК.ДатаОтгрузки=НачалоДня(ТекущаяДата())+СекундВДне;
		иначе
			НоваяРНК.ДатаОтгрузки=НачалоДня(ТекущаяДата())+2*СекундВДне;
		КонецЕсли;
		
	Иначе
		//например : указано 30.12.24 и 3 дня 
		//все заказы от 30.12.24 будут отружены 
		НоваяРНК.ДатаОтгрузки=НачалоДня(ТекущаяДатаСеанса())+ПереносОтгрузки*СекундВДне;
		
	КонецЕсли;  	                     
	//механизм дата отгрузки      
	
	ТЗДляДок.Свернуть("Номенклатура","КолКонФакт");
	
	Для каждого ВыбСтрока из ТЗдляДок Цикл
		
		КолвоЗаказано=ВыбСтрока.КолКонФакт;
		Если Ложь Тогда НоваяРНК= Документы.РасходнаяНакладная.СоздатьДокумент() КОнецЕсли;
		
		Если КолвоЗаказано >0 Тогда 
			
			ПоискЦены=ТЗССАЙТА.Найти(ВыбСтрока.Номенклатура,"Номенклатура");
			
			Если ПоискЦены=Неопределено Тогда
				ЦенаССайта=0; 
				ЗаписатьВЛог("МП_Вайлберриз",Строка(НоваяРНК)+" нет "+СТрока(ВыбСтрока.Номенклатура),"Ошибка");
				Продолжить;
			Иначе  			   
				ЦенаССайта= ПоискЦены.СуммаЗак/ПоискЦены.КолвоЗак; 			   
			КонецЕсли;
			
			НовСтр=НоваяРНК.Товары.Добавить();
			НовСтр.Номенклатура         = ВыбСтрока.Номенклатура;
			НовСтр.Количество           = КолвоЗаказано;
			НовСтр.Заявка               = КолвоЗаказано;
			НовСтр.ПодтвержденнаяЗаявка = КолвоЗаказано;
			
			Попытка
				ПриИзмененииНоменклатурыТабЧасти(НовСтр, НоваяРНК,,ЦенаССайта);
			исключение
				ЗаписатьВЛог("МП_Вайлберриз","Ошибка пересчета строки тз","Ошибка");
			КонецПопытки;
			
			Если НовСтр.Цена=0 Тогда
				НовСтр.Цена=НовСтр.ЦенаБезСкидки;				
				
				ЗаписатьВЛог("МП_Вайлберриз",Строка(НоваяРНК)+" нет цен "+СТрока(ВыбСтрока.Номенклатура),"Ошибка");
				
			КонецЕсли;
			
			
		КонецЕсли;
	КонецЦикла;
	
	Если НоваяРНК.Товары.Количество()=0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	
	
	
	ПунктДоставки_ПриИзменении(НоваяРНК,Истина);
	Если ОтгрузкаКомплектов ТОгда
		НоваяРНК.ОтгрузкаКомплектов =ОтгрузкаКомплектов;
		ЗаполнитьКомплектующие(НоваяРНК);
	КонецЕсли;
	
	Попытка     
		//Тимофеев Ю.А. ID-21187
		НоваяРНК.Товары.Сортировать("Номенклатура");
		//Тимофеев Ю.А. ID-21187
		НоваяРНК.Записать(РежимЗаписиДокумента.Запись);
	Исключение		
		Возврат Неопределено;
	КонецПопытки; 	
	
	Попытка
		
		ЗаписьВРег=РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
		ЗаписьВРег.Документ         = НоваяРНК.Ссылка;
		ЗаписьВРег.ИмяРеквизита     = "ИнтернетЗаказ";
		ЗаписьВРег.ЗначениеРеквизита= "Да";
		ЗаписьВРег.Записать();
		
	Исключение
		
	КонецПопытки;     											
	
	ТекВремяПриемки =ПолучитьВремяПриемкиИзДатыЗагрузки(ДеньЗагрузки, ЧасПриемки);
	
	попытка
		ЗаписатьВремяПриемкиДляЗОГ(НоваяРНК.Ссылка,ТекВремяПриемки);
	Исключение
		
	КонецПопытки;    
	
	/////////////Создаем ЗАКАЗ ФБС ////////////////
	
	врТЗССАЙТА = ТЗССАЙТА.СкопироватьКолонки();
	
	
	
	НовыйЗаказФБС=Документы.ЗаказКлиентаFBS.СоздатьДокумент(); 
	
	НовыйЗаказФБС.ДокОснование=НоваяРНК.Ссылка;
	
	Для Каждого стрНом Из НоваяРНК.Товары Цикл
		
		врТЗССАЙТА.очистить();
		
		ПоискВТЗ=ТЗССАЙТА.НайтиСтроки(Новый Структура("Номенклатура",стрНом.Номенклатура));
		
		Для Каждого СтрНайдена Из ПоискВТЗ Цикл
			
			ВремСтрока                    = врТЗССАЙТА.Добавить();
			ЗаполнитьЗначенияСвойств(ВремСтрока, СтрНайдена);
			
		КонецЦикла;	
		
		врТЗССАЙТА.Сортировать("ДатаСоздания");
		
		МожноСписать = стрНом.Количество;
		
		сч =1;
		
		для каждого стрЗак из врТЗССАЙТА Цикл    
			
			НоваяСтрокаЗаказа                    = НовыйЗаказФБС.Товары.Добавить();
			
			НоваяСтрокаЗаказа.АртикулКонтрагента = стрЗак.АртКонтра;
			НоваяСтрокаЗаказа.Количество         = стрЗак.КолвоЗак;
			НоваяСтрокаЗаказа.Заявка             = стрЗак.КолвоЗак;
			НоваяСтрокаЗаказа.Номенклатура       = стрЗак.Номенклатура;
			НоваяСтрокаЗаказа.Цена               = стрЗак.СуммаЗак;
			НоваяСтрокаЗаказа.НомерЗаказа        = стрЗак.ИДЗаказа;
			НоваяСтрокаЗаказа.ДатаЗаказа         = стрЗак.ДатаСоздания;
			НоваяСтрокаЗаказа.РИД                = стрЗак.РИД;
			
			ПоискЗаказа = ТЗССАЙТА.Найти(стрЗак.ИДЗаказа,"ИДЗаказа");
			
			Если ПоискЗаказа<>Неопределено Тогда
				ТЗССАЙТА.удалить(ПоискЗаказа); 
			Иначе    			   
				ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Проверить = нет заказа "+Строка(ПоискЗаказа),"Ошибка");
			КонецЕсли;
			
			Если МожноСписать=Сч Тогда
				прервать;
			Иначе
				Сч=Сч+1;
			КонецЕсли;                       
			
		КонецЦикла; 
		
	КонецЦикла;	 	
	
	НовыйЗаказФБС.Дата=ТекущаяДатаСеанса();
	НовыйЗаказФБС.Контрагент=МаркетПлейс.Контрагент;
	
	НовыйЗаказФБС.НомерПоставки = СокрЛП(Строка(Сектор)+" "+Строка(ПрефиксМаркета));
	ОбновитьНумерациюОбъектов(Метаданные.Документы.ЗаказКлиентаFBS);
	
	
	Если НовыйЗаказФБС.Товары.Количество()>0 Тогда
		
		НовыйЗаказФБС.Записать(РежимЗаписиДокумента.Проведение); 
		
		НоваяРНК.СостояниеНакладной=СостояниеНакладной; 
		
		Если СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда
			
			Попытка   			
				НоваяРНК.Записать(РежимЗаписиДокумента.Проведение);
			Исключение				
				НоваяРНК.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе; 		
				НоваяРНК.Записать(РежимЗаписиДокумента.Запись); 
				МоеОповещение=МоеОповещение+"Не удалось провести "+Строка(НоваяРНК)+Символы.ПС;
			КонецПопытки;
			
		ИначеЕсли СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе Тогда
			
			НоваяРНК.Записать(РежимЗаписиДокумента.Запись);
			МоеОповещение=МоеОповещение+"Не хватает товара , не проведена "+Строка(НоваяРНК)+Символы.ПС;
			
		КонецЕсли;
		
		//на всякий случай
		Если НоваяРНК<> Неопределено И (Не НоваяРНК.Проведен и СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад) Тогда
			НоваяРНК.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе; 	   
			НоваяРНК.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		
		МП_КонтрольКоличестваРНКиЗАКАЗА(НовыйЗаказФБС.Ссылка,"Создание");
		
		/////////////////////////////////////////////////    	
	Иначе
		//Тимофеев Ю.А. 26.03.2025
		//только для теста РНК заполнена, а заказ пустой не часто , но пролетает
		
		Попытка
			Если  НоваяРНК.Проведен Тогда
				НоваяРНК.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Иначе
				НоваяРНК.Записать(РежимЗаписиДокумента.Запись);				
			КонецЕсли;
			
			НоваяРНК.УстановитьПометкуУдаления(Истина);
			
		исключение
			ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+"1. Нет строк в заказе - пометка удаления "+Строка(НоваяРНК)+ОписаниеОшибки(),"Ошибка");
		КОнецПопытки;
		
		ЗаписатьВЛог("МП_Вайлберриз",ПрефиксМаркета+" Нет строк в заказе - удалена "+Строка(НоваяРНК),"Ошибка");
		
		ПутьКонстантыЛогов = Константы.ПутьКЛогамМкПл.Получить();
		ПутьЛог=?(ЗначениеЗаполнено(ПутьКонстантыЛогов),ПутьКонстантыЛогов,"\\srvfiles\1C_Logs_MarketPlace\");
		ВремяЗаписи =Формат(ТекущаяДатаСеанса(),"ДФ=yyyy_MM_dd_чч_мм_сс");
		
		ИмяФайла=ПутьЛог+"Блок_с_Сайта_"+ПрефиксМаркета+ВремяЗаписи+".txt";
		ЗначениеВФайл(ИмяФайла,ТЗССАЙТА);
		
		ИмяФайла=ПутьЛог+"Блок_для_Документа"+ПрефиксМаркета+ВремяЗаписи+".txt";
		ЗначениеВФайл(ИмяФайла,ТЗДляДок);
		
		Возврат Неопределено;
		//Тимофеев Ю.А. 26.03.2025
		
	КонецЕсли;
	
	Возврат НовыйЗаказФБС.Ссылка;
	
КонецФункции	


