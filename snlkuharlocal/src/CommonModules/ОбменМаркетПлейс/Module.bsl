					//	СтрокаМассива.ВычеркОфис=Истина; //Тимофеев Ю.А. 21.01.25
				КонецЦикла;
				ВидСообщения="СообщитьОбОтменеЗаказа";
				СписокПолучателей=СформироватьСписокПолучателейЕкод(ВидСообщения,ЭтоТест);
				ТемаОповещения=СформироватьТемуОповещенияЕкод (ДокОбъектСсылка,ВидСообщения,НомерЗаказа);
				ТекстОповещения=СформироватьТекстОповещенияЕкод(ДокОбъектСсылка,новый Массив,ВидСообщения,НомерЗаказа);
				ОтправитьПочтовоеСообщениеИзЕкода(СписокПолучателей,ТемаОповещения,ТекстОповещения);					
			КонецЦикла;
			ЗаказFBSОбъект.Записать();  		
			
		КонецЦикла;       
		
		
	КонецЕсли;
КонецПроцедуры

Процедура ПолучитьОтмененные_ПредВер(Контрагент,ДанныеМаркетПлейса=Неопределено,ЭтоТест=ложь) экспорт
	если ДанныеМаркетПлейса=Неопределено тогда
		ДанныеМаркетПлейса=ОбменМаркетПлейсПИ.ПолучитьИнтернетМагазин(Контрагент);		
	КонецЕсли;	
	
	если не ЗначениеЗаполнено(ДанныеМаркетПлейса) тогда 
		Сообщение="Не найден подходящий справочник интернет магазины по контрагенту";
		ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация");
		СообщитьИзМодуля(Сообщение);		
		Возврат;
	КонецЕсли;
	
	Команда = "/v2/posting/fbs/list";  // считывает заказы с сайта
	ТелоДЖ = "";	
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".json");
	Запись = Новый ЗаписьJSON;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
	Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата; //ЛокальнаяДата;      "2020-10-31T21:00:00Z",
	СтрПРо= Новый Структура;
	
	Дата1 = ДобавитьДату(текущаяДата(),-60*60*24*3);  // 3 дня назад. по текущую
	СтрПро.Вставить("since",Дата1);    //ТекДата1);
	СтрПро.Вставить("status","cancelled");  // ожидает упаковки
	СтрПро.Вставить("to",ТекущаяДата());
	
	ШК = Новый Структура;
	ШК.Вставить("barcodes",true);
	
	Данные = Новый Структура;
	Данные.Вставить("dir","asc");
	
	Данные.Вставить("filter",СтрПро);
	
	// Кухарь А.Ю. 26.11.2021 начало
	// Данные.Вставить("limit",50); // количество заказов  макс 50 за раз
	Данные.Вставить("limit",1000); // количество заказов  макс 1000 за раз	 
	// Кухарь А.Ю. 26.11.2021 конец
	
	Данные.Вставить("offset",1);
	Данные.Вставить("with",ШК);
	
	
	ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
	Запись.Закрыть();
	
	Результат = POSTЗапросИз1С(ДанныеМаркетПлейса,Команда,ИмяВыходногоФайлаДЖ,"json") ;    // ИмяВыходногоФайла?
	если результат=Неопределено тогда
		Возврат;
	КонецЕсли;
	
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
	
	Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
	если типзнч(данные)<>тип("Структура") или   не данные.свойство("result") тогда
		Сообщение="http запрос по получению отменённых заказов вернул некорректные данные";
		ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация");
		СообщитьИзМодуля(Сообщение);	
		Возврат;
	КонецЕсли;
	
	СписокНомеровЗаказов=новый СписокЗначений;
	Для каждого ТекСтрока из Данные.result цикл
		СписокНомеровЗаказов.Добавить(Текстрока.posting_number);	
	КонецЦикла;			
	
	
	если СписокНомеровЗаказов.Количество()>0 тогда	
		СостояниеОтменен=Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("cancelled");
		Запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
		|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
		|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
		|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказFBS
		|ИЗ
		|	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
		|ГДЕ
		|	ЗаказКлиентаFBSТовары.НомерЗаказа В(&СписокНомеровЗаказов)
		|	И НЕ ЗаказКлиентаFBSТовары.Отменен
		|	И ЗаказКлиентаFBSТовары.Ссылка.Дата >= &Дата
		|	И ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
		|	И ЗаказКлиентаFBSТовары.СостояниеУКлиента <> &Отменен
		|	И ЗаказКлиентаFBSТовары.Ссылка.Проведен
		|	И ЗаказКлиентаFBSТовары.Ссылка.ДокОснование.Проведен
		|	И НЕ ЗаказКлиентаFBSТовары.ВычеркОфис
		|	И НЕ ЗаказКлиентаFBSТовары.ВычеркСклад
		|ИТОГИ ПО
		|	ЗаказFBS,
		|	НомерЗаказа";
		запрос.УстановитьПараметр("СписокНомеровЗаказов",СписокНомеровЗаказов);
		Запрос.УстановитьПараметр("Дата",ТекущаяДата()-86400*7);
		Запрос.УстановитьПараметр("Контрагент",Контрагент);
		Запрос.УстановитьПараметр("Отменен",СостояниеОтменен);
		
		
		ВыборкаЗаказ=запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ЗаказFBS");
		пока ВыборкаЗаказ.Следующий() цикл
			ЗаказFBSОбъект=ВыборкаЗаказ.ЗаказFBS.ПолучитьОбъект();
			если ложь тогда ЗаказFBSОбъект=Документы.ЗаказКлиентаFBS.СоздатьДокумент();КонецЕсли;
			ДокОбъектСсылка=ЗаказFBSОбъект.ДокОснование;
			
			ВыборкаНомераЗаказов=ВыборкаЗаказ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЗаказа");
			пока ВыборкаНомераЗаказов.следующий() цикл
				НомерЗаказа=СокрЛП(ВыборкаНомераЗаказов.НомерЗаказа);
				МассивСтрок=ЗаказFBSОбъект.Товары.НайтиСтроки(Новый Структура("НомерЗаказа",НомерЗаказа));
				Для каждого СтрокаМассива из МассивСтрок цикл					
					СтрокаМассива.СостояниеУКлиента=СостояниеОтменен;
					СтрокаМассива.Отменен   =Истина;
					//	СтрокаМассива.ВычеркОфис=Истина; //Тимофеев Ю.А. 21.01.25
				КонецЦикла;
				ВидСообщения="СообщитьОбОтменеЗаказа";
