Функция ПолучитьИДПост1_пред(Док,МаркПл,КолЧаст=2)
	ИДП="";
	МКол=Новый Массив;
	МИДПост=Новый Массив;
	КолЗак=Док.Товары.Количество();
	ДатаОт=Док.ДокОснование.ДатаОтгрузки;
	НомДН=ДеньНедели(ДатаОт);
	Дата1=НачалоДня(ДатаОт);
	Дата2=КонецДня(ДатаОт);
	ДатаЗак=Док.Дата;
	Счт=0;
	ТотКол=0;
	Запрос=Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	Количество(*) КАК Колво,
	|  МИНИМУМ(ЛогОтгрузкиЗаказовФБС.ДатаПривязки) КАК ДатаПривязки,
	|	ЛогОтгрузкиЗаказовФБС.НомерОтгрузки КАК НомерОтгрузки
	|ИЗ
	|	РегистрСведений.ЛогОтгрузкиЗаказовФБС КАК ЛогОтгрузкиЗаказовФБС
	|ГДЕ
	|	ЛогОтгрузкиЗаказовФБС.МаркетПлейс = &МаркПл
	|	И ЛогОтгрузкиЗаказовФБС.ДатаОтгрузки МЕЖДУ &Дата1 И &Дата2
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛогОтгрузкиЗаказовФБС.НомерОтгрузки
	|	УПОРЯДОЧИТЬ ПО 2";
	Запрос.УстановитьПараметр("МаркПл",МаркПл);
	Запрос.УстановитьПараметр("Дата1",Дата1);
	Запрос.УстановитьПараметр("Дата2",Дата2);
	Выб=Запрос.Выполнить().Выбрать();
	Если Выб.Количество()=0 Тогда
		ИДП=СоздатьПоставку1(МаркПл,"Поставка "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd"));
	Иначе
		
		Пока Выб.Следующий() Цикл
			МКол.Добавить(Выб.Колво);
			ИДП=Выб.НомерОтгрузки;	
			Счт=Счт+1;
			ТотКол=ТотКол+Выб.Колво;
		КонецЦикла;	
		Если Счт=1 И (КолЧаст>1) И (НомДН<6) Тогда
			Если (Дата2-ДатаЗак)<(3600*32) И (Дата2-ДатаЗак)>(3600*30) Тогда
				ИДП=СоздатьПоставку1(МаркПл,"Поставка 2 "+Формат(ТекущаяДатаСеанса(),"ДФ=yyyy-MM-dd"));
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	Возврат ИДП;
КонецФункции	

