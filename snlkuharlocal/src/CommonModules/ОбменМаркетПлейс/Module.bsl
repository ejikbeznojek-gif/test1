//Михайловский 20220719 ряд методов нужно переписать в связи со блокировкой ряда методов апи, см. выше ---

Процедура ОтправитьВОзонПодтверждениеНачалаСборкиВыборкиСтрок_ПредВер( ВыборкаНомераЗаказов,  ДанныеМаркетПлейса,  Команда,  КритическиеОшибкиОзон, ЭтоТест=ложь) экспорт
	
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".json");		
	Запись = Новый ЗаписьJSON;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
	Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата; 		
	Товары = Новый Массив;
	ВыборкаПоТоварам=ВыборкаНомераЗаказов.Выбрать();
	Пока ВыборкаПоТоварам.Следующий() цикл		
		Если ВыборкаПоТоварам.Количество>0 Тогда
			АртикулКонтрагента = СокрЛП(ВыборкаПоТоварам.АртикулКонтрагента);		
			СтрПРо= Новый Структура;
			СтрПро.Вставить("quantity",ВыборкаПоТоварам.Количество);    //ТекДата1);
			СтрПро.Вставить("sku",АртикулКонтрагента);  // ожидает отгрузки	
			Товары.Добавить(СтрПРо);
		КонецЕсли;		
	КонецЦикла;
	
	Итемс = Новый Структура;
	Итемс.Вставить("items",Товары);
	
	СпТ = Новый Массив;
	СпТ.Добавить(Итемс); 
	НомерЗаказа=СокрЛП(ВыборкаНомераЗаказов.НомерЗаказа);
	Данные = Новый Структура;
	Данные.Вставить("packages",СпТ);    //ТекДата1);
	Данные.Вставить("posting_number",НомерЗаказа);  // ожидает отгрузки
	
	Попытка
		ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
		Запись.Закрыть();
	Исключение
		КритическиеОшибкиОзон.Добавить(" "+ ОписаниеОшибки());
	КонецПопытки;;  
	
	если ЭтоТест тогда Возврат; КонецЕсли; //Заглушка для тестов
	// Кухарь А.Ю. 28.12.2021 начало
	//Каким-то образом из копии ушли заказы.
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю.  31.03.2026 начало
	//Рефакторинг. Приведение к 1й функции
	//Если ТекСтрокаСоединения <> СтрокаСоединенияСразрешеннымОбменом Тогда
	если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда	
		//Кухарь А.Ю.  31.03.2026 конец
		возврат;
	КонецЕсли;
	// Кухарь А.Ю. 28.12.2021 конец
	
	
	
	Результат = POSTЗапросИз1С(ДанныеМаркетПлейса,Команда,ИмяВыходногоФайлаДЖ,"json") ;   
	если результат=Неопределено тогда
		Возврат;
	КонецЕсли;
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
	
	
	
	// сообщить(Данные);
	Попытка 
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
		
		Если данные.свойство("error") и Данные.error<>неопределено тогда
			Если  Данные.error.message<> "POSTING_ALREADY_SHIPPED" Тогда
				КритическиеОшибкиОзон.Добавить(" "+Данные.error.message+". Обратитесь в ИТ отдел. Ошибка перевода заказа ИМ на сборку."+НомерЗаказа);
			Иначе
				сообщить("Заказ уже передан на сборку");
			КонецЕсли;
			
			Если  Данные.error.message = "HAS_INCORRECT_PRODUCT_QUANTITY" Тогда
				КритическиеОшибкиОзон.Добавить("Ошибка в артикуле или количестве по заказу. Просьба проверить матрицу! Заказ не передан на сборку "+НомерЗаказа);
			КонецЕсли;	
		КонецЕсли;	 		
	исключение	
		КритическиеОшибкиОзон.Добавить(НомерЗаказа + " не передан "+ОписаниеОшибки());
		
	конецПопытки;
	
КонецПроцедуры

Процедура ОтправитьВОзонПодтверждениеНачалаСборкиВыборкиСтрок( ВыборкаНомераЗаказов,  ДанныеМаркетПлейса,  Команда,  КритическиеОшибкиОзон, ЭтоТест=ложь) экспорт
	СтрИДПрод="";
	ВыборкаПоТоварам=ВыборкаНомераЗаказов.Выбрать();
	Пока ВыборкаПоТоварам.Следующий() цикл		
		Если ВыборкаПоТоварам.Количество>0 Тогда
			АртикулКонтрагента = СокрЛП(ВыборкаПоТоварам.АртикулКонтрагента);
			СтрИДПрод=СтрИДПрод+"{""product_id"": "+АртикулКонтрагента+",""quantity"": "+Формат(ВыборкаПоТоварам.Количество,"ЧН=0; ЧГ=0")+" }"+",";
			
		КонецЕсли;		
	КонецЦикла;
	
	НомерЗаказа=СокрЛП(ВыборкаНомераЗаказов.НомерЗаказа);
	
	
	если ЭтоТест тогда Возврат; КонецЕсли; //Заглушка для тестов
	// Кухарь А.Ю. 28.12.2021 начало
	//Каким-то образом из копии ушли заказы.
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю.  31.03.2026 начало
	//Рефакторинг. Приведение к 1й функции
	//Если ТекСтрокаСоединения <> СтрокаСоединенияСразрешеннымОбменом Тогда
	если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда	
		//Кухарь А.Ю.  31.03.2026 конец    
		возврат;
	КонецЕсли;
	// Кухарь А.Ю. 28.12.2021 конец
	
	СтрИДПрод=Лев(СтрИДПрод,СтрДлина(СтрИДПрод)-1);
	ПередСтр="{""packages"": [{""products"": ["+СтрИДПрод+"]}],""posting_number"": """+НомерЗаказа+""",""with"": {""additional_data"": false }}";
	//ЗаписатьВЛог("Озон","На сборку_"+ПередСтр,"Информация");
	Результат = POSTЗапросИз1С_ДжС(ДанныеМаркетПлейса,Команда,ПередСтр);
	
	если результат=Неопределено тогда
		//ЗаписатьВЛог("Озон","Ошибка","Информация");
		Возврат;
	КонецЕсли;
	ВС=Результат.ПолучитьТелоКакСтроку();
	//ЗаписатьВЛог("Озон","На сборку ответ_"+ВС,"Информация");
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ВС);
	
	
	
	// сообщить(Данные);
	Попытка 
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
		
		Если данные.свойство("error") и Данные.error<>неопределено тогда
			Если  Данные.error.message<> "POSTING_ALREADY_SHIPPED" Тогда
				КритическиеОшибкиОзон.Добавить(" "+Данные.error.message+". Обратитесь в ИТ отдел. Ошибка перевода заказа ИМ на сборку."+НомерЗаказа);
			Иначе
				сообщить("Заказ уже передан на сборку");
			КонецЕсли;
			
			Если  Данные.error.message = "HAS_INCORRECT_PRODUCT_QUANTITY" Тогда
				КритическиеОшибкиОзон.Добавить("Ошибка в артикуле или количестве по заказу. Просьба проверить матрицу! Заказ не передан на сборку "+НомерЗаказа);
			КонецЕсли;	
		КонецЕсли;	 		
	исключение	
		КритическиеОшибкиОзон.Добавить(НомерЗаказа + " не передан "+ОписаниеОшибки());
		
	конецПопытки;
	
КонецПроцедуры

Функция ПолучитьСостояниеНакладнойПоНомеруЗаказа_ПредВер(Контрагент,НомерЗаказа, ДанныеМаркетПлейса=Неопределено) экспорт
	если ДанныеМаркетПлейса=Неопределено тогда
		ДанныеМаркетПлейса=ОбменМаркетПлейсПИ.ПолучитьИнтернетМагазин(Контрагент);		
	КонецЕсли;
	если не ЗначениеЗаполнено(ДанныеМаркетПлейса) тогда 
		Возврат "";
	КонецЕсли;
	
	Команда = "/v2/posting/fbs/get";  // считывает заказы с сайта
	ТелоДЖ = "";
	
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".json");
	
	Запись = Новый ЗаписьJSON;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
	Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата;		
	Данные = Новый Структура;
	Данные.Вставить("posting_number",НомерЗаказа);				
	ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
	Запись.Закрыть();
	
	Результат = POSTЗапросИз1С(ДанныеМаркетПлейса,Команда,ИмяВыходногоФайлаДЖ,".json") ; 
	если результат=Неопределено тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
	
	Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
	если типзнч(данные)<>тип("Структура") или   не данные.свойство("result") тогда
		Сообщение="http запрос получения состояний накладных вернул некорректные данные";
		ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация");
		СообщитьИзМодуля(Сообщение);
		Возврат Неопределено;
	КонецЕсли;
	
	
	Если Данные.result<>неопределено тогда
		возврат Данные.result.status;	
	КонецЕсли;	
КонецФункции

Функция ПолучитьСостояниеНакладнойПоНомеруЗаказа(Контрагент,НомерЗаказа, ДанныеМаркетПлейса=Неопределено) экспорт
	если ДанныеМаркетПлейса=Неопределено тогда
		ДанныеМаркетПлейса=ОбменМаркетПлейсПИ.ПолучитьИнтернетМагазин(Контрагент);		
	КонецЕсли;
	если не ЗначениеЗаполнено(ДанныеМаркетПлейса) тогда 
		Возврат "";
	КонецЕсли;
	
	Команда = "/v3/posting/fbs/get";  // считывает заказы с сайта
	ВхСтр="{""posting_number"": """+НомерЗаказа+""",""with"": {""analytics_data"": false,""barcodes"": false,""financial_data"": false,""product_exemplars"": false, ""translit"": false}}";
	Результат =POSTЗапросИз1С_ДжС(ДанныеМаркетПлейса,Команда,ВхСтр);
	
	если результат=Неопределено тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
	
	Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
	если типзнч(данные)<>тип("Структура") или   не данные.свойство("result") тогда
		Сообщение="http запрос получения состояний накладных вернул некорректные данные";
		ЗаписатьВЛог("ОшибкиЕкод",Сообщение,"Информация");
		СообщитьИзМодуля(Сообщение);
		Возврат Неопределено;
	КонецЕсли;
	
	
	Если Данные.result<>неопределено тогда
		возврат Данные.result.status;	
	КонецЕсли;	
КонецФункции

