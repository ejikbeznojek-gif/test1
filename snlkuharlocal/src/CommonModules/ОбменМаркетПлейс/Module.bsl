// Функция - Получить заголовки озон
//
// Параметры:
//  РеквизитыМаркетПлейс - Структура, Ссылка - Коллекция значений с необходимыми полями
// 
// Возвращаемое значение:
//  Соответствие - Заголовки для http запроса
//
Функция ПолучитьЗаголовкиОзон(РеквизитыМаркетПлейс) Экспорт
	
	ЗаголовкиHTTP = Новый Соответствие();
	ЗаголовкиHTTP.Вставить("Content-Type", 	   РеквизитыМаркетПлейс.ContentType);
	ЗаголовкиHTTP.Вставить("Accept", 		   РеквизитыМаркетПлейс.Accept);
	ЗаголовкиHTTP.Вставить("Accept-Language",  РеквизитыМаркетПлейс.AcceptLanguage);
	ЗаголовкиHTTP.Вставить("Accept-Charset",   РеквизитыМаркетПлейс.AcceptCharset);
	ЗаголовкиHTTP.Вставить("Content-Language", РеквизитыМаркетПлейс.ContentLanguage);
	ЗаголовкиHTTP.Вставить("Content-Charset",  РеквизитыМаркетПлейс.ContentCharset);
	ЗаголовкиHTTP.Вставить("Host", 			   РеквизитыМаркетПлейс.Host);
	ЗаголовкиHTTP.Вставить("Client-Id", 	   РеквизитыМаркетПлейс.XAuthToken);
	ЗаголовкиHTTP.Вставить("Api-Key", 		   РеквизитыМаркетПлейс.Token);
	
	Возврат ЗаголовкиHTTP;
	
КонецФункции // ПолучитьОбщиеПараметрыОбработки()

