// Процедура - Выполнить проверку наличия заказов РВБ
//
// Параметры:
//  МассивНомеровЗаказов	 - Массив	 - Список номеров заказов, который будет пополняться этой процедурой
//  РеквизитыМаркетПлейса	 - Структура - Данные реквизитов справочника Интернет Магазины
//  Сортировка				 - Строка	 - Направление сортировки получаемых данных
//  РазмерПорции			 - Число	 - Количество получаемых строк в ответе на запрос
//  ДатаНачала				 - Дата		 - Начало интервала получаемых данных
//  ДатаОкончания			 - Дата		 - Конец интервала получаемых данных
//
Процедура ВыполнитьПроверкуНаличияЗаказовРВБ(МассивНомеровЗаказов, РеквизитыМаркетПлейса, Сортировка, //РазмерПорции...)
	РазмерПорции, ДатаНачала, ДатаОкончания)
	
	СмещениеПоЗапросу = 0;
	
	ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
	
	ДатаВыполненияЗапросаВМиллисекундах = 0; ИнтервалИсполненияЗапросов = 200;
	Пока Истина Цикл
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("limit",	 РазмерПорции);
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("next",	 СмещениеПоЗапросу);
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("dateFrom", ОбменМаркетПлейс.СформироватьДатуTimeStamp(ДатаНачала));
		ПараметрыОбработки.ПараметрыЗапроса.Вставить("dateTo",	 ОбменМаркетПлейс.СформироватьДатуTimeStamp(ДатаОкончания));
		
		// Инициализируем параметры подключения к программному интерфейсу сервиса
		ПараметрыОбработки.ДанныеЗапроса.Метод		 = "GET";
		ПараметрыОбработки.ИменаСвойствОшибок		 = "code, error";
		
		Если ТекущаяУниверсальнаяДатаВМиллисекундах() < ДатаВыполненияЗапросаВМиллисекундах + ИнтервалИсполненияЗапросов Тогда
			Сообщить("Выполнена пауза");
			ОбменМаркетПлейс.ВыполнитьПаузуВМиллисекундах(ДатаВыполненияЗапросаВМиллисекундах
				+ ИнтервалИсполненияЗапросов - ТекущаяУниверсальнаяДатаВМиллисекундах());
		КонецЕсли;
		
		// Выполняем запрос к сервису
		ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
			ОбменМаркетПлейс.МП_Вайлберриз_ВернутьСоединение(РеквизитыМаркетПлейса),
			ОбменМаркетПлейс.МП_Вайлберриз_ВернутьЗаголовкиHTTP(РеквизитыМаркетПлейса.Ссылка),
			"/api/v3/orders", ПараметрыОбработки);
		ДатаВыполненияЗапросаВМиллисекундах = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		// Проверим успешно ли выполнился запрос
		СообщениеОбОшибке = "";
		Если Не ОбменМаркетПлейс.ЗапросКСервисуПрошелУспешно(ДанныеОтвета, СообщениеОбОшибке, ПараметрыОбработки) Тогда
			ВызватьИсключение СтрШаблон("РВБ. Не удаловсь выполнить соединение: %1", СообщениеОбОшибке)
		КонецЕсли;
		
		Для каждого ДанныеЗаказа из ДанныеОтвета.orders Цикл
			ДанныеПоНомеруЗаказа = Новый Структура;
			ДанныеПоНомеруЗаказа.Вставить("НомерЗаказа", ДанныеЗаказа.id);
			ДанныеПоНомеруЗаказа.Вставить("МаркетПлейс", РеквизитыМаркетПлейса.Наименование);
			
			МассивНомеровЗаказов.Добавить(ДанныеПоНомеруЗаказа)
		КонецЦикла;
		
		Если Не ЗначениеЗаполнено(ДанныеОтвета.next) Тогда
			Прервать
		КонецЕсли;
		
		СмещениеПоЗапросу = ДанныеОтвета.next
	КонецЦикла
	
КонецПроцедуры // ВыполнитьПроверкуНаличияЗаказовРВБ()

// Процедура - Выполнить проверку наличия заказов Яндекс
