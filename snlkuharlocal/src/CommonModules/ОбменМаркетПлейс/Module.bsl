	Запрос.УстановитьПараметр("ДатаОкончания",   ПараметрыОбработки.ДатаОкончания);
	Запрос.УстановитьПараметр("ГотовыйКомплект", Перечисления.ВидыКомплектов.ГотовыйКомплект);
	Запрос.УстановитьПараметр("МаркетПлейс", 	 ПараметрыОбработки.МаркетПлейс);
	Запрос.Выполнить();
	
КонецПроцедуры // ПолучитьДанныеЗаказовВМоделиСервиса()

// Функция - Получить параметр задания
// Ихсанов Д. А. 16.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// 
// Параметры:
//  ИмяПараметра - Строка - Имя параметра регламентного задания
//  ПараметрыОбработки - Структура - Данные параметров к обработке
// 
// Возвращаемое значение:
//  Строка, Число, Булево - Значение параметра регламентного задания, если значение не найдется, то вернется Неопределено
Функция ПолучитьПараметрЗадания(ИмяПараметра, ПараметрыОбработки) Экспорт
	
	ЗначениеПараметра = Неопределено;
	Если ПараметрыОбработки.Свойство("ПараметрыЗадания")
		И ПараметрыОбработки.ПараметрыЗадания <> Неопределено
		И ПараметрыОбработки.ПараметрыЗадания[ИмяПараметра] <> Неопределено Тогда
		ЗначениеПараметра = ПараметрыОбработки.ПараметрыЗадания[ИмяПараметра];
	КонецЕсли;
	
	Возврат ЗначениеПараметра;
	
КонецФункции // ПолучитьПараметрЗадания()

// Заполнить поля коллекции по вложенности.
// 
// Параметры:
//  ИменаПолей - Массив из Строка - Имена полей
//  Источник - Структура - Источник данных
//  Приемник - Произвольный - Коллекция значений приемника данных
Процедура ЗаполнитьПоляКоллекцииПоВложенности(ИменаПолей, Источник, Приемник) Экспорт

	Для Каждого ПараИменТовара Из ИменаПолей Цикл
		МассиВложенностиАтрибута = СтрРазделить(ПараИменТовара.Значение, ".");

		ЗначениеАтрибута = Источник;
		Для Каждого УровеньВложенности Из МассиВложенностиАтрибута Цикл
			Если ЗначениеАтрибута.Свойство(УровеньВложенности)
				И ЗначениеАтрибута[УровеньВложенности] <> Неопределено Тогда
				ЗначениеАтрибута = ЗначениеАтрибута[УровеньВложенности];
			КонецЕсли;
		КонецЦикла;

		Если ЗначениеАтрибута <> Источник Тогда
			Приемник[ПараИменТовара.Ключ] = ЗначениеАтрибута;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры // ЗаполнитьПоляКоллекцииПоВложенности()

// Обработать создание документов по предварительным заказам клиента.
// 
// Параметры:
//  ПараметрыОбработки - Структура - Параметры обработки
//  ТаблицаДанныхПоЗаказам - ТаблицаЗначений - Таблица данных по заказам
//  ДеньДатыОтгрузки - Дата - Дата отгрузки
//  ПолеГруппировкиЗаказа - Строка, Неопределено - Поле группировки заказа
Процедура ОбработатьСозданиеДокументовПоПредварительнымЗаказамКлиента(ПараметрыОбработки, // ...) Экспорт
	ТаблицаДанныхПоЗаказам, ДеньДатыОтгрузки, //) Экспорт
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	ПолеГруппировкиЗаказа = Неопределено) Экспорт
	
	Если ПолеГруппировкиЗаказа = Неопределено Тогда
		ПолеГруппировкиЗаказа = "РИД";
	КонецЕсли;
	// Ихсанов Д. А. Конец 18.06.2026
	
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	// Функционал подстроен под вызов с константой часа перехода даты отгрузки
	ТаблицаДанныхЗаказы = МП_ПолучитьСостояниеКомплектацииуНоменклатура(ТаблицаДанныхПоЗаказам);
	
	// НЕОПТИМАЛЬНОЕ ЛЕГАСИ
	Запрос = Новый Запрос("ВЫБРАТЬ * ПОМЕСТИТЬ вт_ТаблицаДанных
	|ИЗ &ТаблицаДанных КАК ТаблицаДанных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА вт_ТаблицаДанных.КоличествоЭкземпляров > 1
	|			ТОГДА ИСТИНА
	|		КОГДА вт_ТаблицаДанных.Комплект И вт_ТаблицаДанных.КоличествоОстаток > 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ вт_ТаблицаДанных.Комплект
	|	КОНЕЦ КАК КомплектнаяПринадлежность,
	|	*
	|ПОМЕСТИТЬ вт_ТаблицаДанных_Комплекты
	|ИЗ вт_ТаблицаДанных КАК вт_ТаблицаДанных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ *
	|ИЗ вт_ТаблицаДанных_Комплекты КАК вт_ТаблицаДанных_Комплекты
	|ГДЕ вт_ТаблицаДанных_Комплекты.КомплектнаяПринадлежность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ *
	|ИЗ вт_ТаблицаДанных_Комплекты КАК вт_ТаблицаДанных_Комплекты
	|ГДЕ НЕ вт_ТаблицаДанных_Комплекты.КомплектнаяПринадлежность");
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанныхЗаказы);
	
	МассивРезультатовЗапроса = Запрос.ВыполнитьПакет();
	Для Индекс = МассивРезультатовЗапроса.ВГраница() - 1 По МассивРезультатовЗапроса.ВГраница() Цикл
		СоздатьДокументыПредварительныхЗаказовКлиента(МассивРезультатовЗапроса[Индекс].Выгрузить(),
			ПараметрыОбработки, ДеньДатыОтгрузки, ПолеГруппировкиЗаказа);
	КонецЦикла;
	// Ихсанов Д. А. Конец 18.06.2026
	
КонецПроцедуры // ОбработатьСозданиеДокументовПоПредварительнымЗаказамКлиента()

// Получить данные набора регистра сведений по данным маркетплейса.
// 
// Параметры:
//  Маркетплейс - СправочникСсылка.ИнетМагазины - Маркетплейс
//  ИмяРегистра - Строка - Имя регистра
//  РезультатЗапроса - РезультатЗапроса - Результат запроса
// 
// Возвращаемое значение:
//  РегистрСведенийНаборЗаписейИмяРегистраСведений - Получить данные набора регистра сведений по данным маркетплейса
Функция ПолучитьДанныеНабораРегистраСведенийПоДаннымМаркетплейса(Маркетплейс, ИмяРегистра, РезультатЗапроса) Экспорт
	
	НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.МаркетПлейс.Установить(МаркетПлейс);
	НаборЗаписей.Загрузить(РезультатЗапроса.Выгрузить());
	
	Возврат НаборЗаписей;
	
КонецФункции // ПолучитьДанныеНабораРегистраСведенийПоДаннымМаркетплейса()

// Выполнить группировку записей по набору.
// 
// Параметры:
//  НаборДанных - РегистрСведенийНаборЗаписей - Набор данных
//  ПоляСуммирования - Строка - Поля суммирования
Процедура ВыполнитьГруппировкуЗаписейПоНабору(НаборДанных, ПоляСуммирования) Экспорт
	
	МетаданныеРегистра = НаборДанных.Метаданные();
	
	МассивПолейСуммирования = СтрРазделить(СтрЗаменить(ПоляСуммирования, " ", ""), ",");
	
	ПоляГруппировки = Новый Массив;
	Для каждого ДанныеИзмерения из МетаданныеРегистра.Измерения Цикл
		Если МассивПолейСуммирования.Найти(ДанныеИзмерения.Имя) <> Неопределено Тогда
			Продолжить
		КонецЕсли;
		
		ПоляГруппировки.Добавить(ДанныеИзмерения.Имя);
	КонецЦикла;
	
	Для каждого ДанныеРесурсы из МетаданныеРегистра.Ресурсы Цикл
		Если МассивПолейСуммирования.Найти(ДанныеРесурсы.Имя) <> Неопределено Тогда
			Продолжить
		КонецЕсли;
		
		ПоляГруппировки.Добавить(ДанныеРесурсы.Имя);
	КонецЦикла;
	
	Для каждого ДанныеРеквизиты из МетаданныеРегистра.Реквизиты Цикл
		Если МассивПолейСуммирования.Найти(ДанныеРеквизиты.Имя) <> Неопределено Тогда
			Продолжить
		КонецЕсли;
		
		ПоляГруппировки.Добавить(ДанныеРеквизиты.Имя);
	КонецЦикла;
	
	ТаблицаДанных = НаборДанных.Выгрузить();
	ТаблицаДанных.Свернуть(СтрСоединить(ПоляГруппировки, ","), ПоляСуммирования);
	НаборДанных.Загрузить(ТаблицаДанных);
	
КонецПроцедуры // ВыполнитьГруппировкуЗаписейПоНабору()

#КонецОбласти

#Область Маркетплейсы_БазовыйФункционал // ЛЕГАСИ - На замену HTTP коннектор!!!

// Функция - Выполнить HTTPЗапрос
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Параметры:
//  ПолныйПутьURL - Строка - Путь к URL вместе с параметрами запроса.
//  HTTPСоединение - HTTPСоединение - Объект HTTPСоединение с заполненными данными авторизации.
//  HTTPЗаголовки - Соответствие - Данные заголовков в формате Ключ - Значение
//  Метод - Неопределено - Метод
//  ТелоЗапроса - Неопределено, Структура, Массив, Строка - Тело запроса
// 
// Возвращаемое значение:
//  HTTPОтвет - Необработанные данные ответа сервиса.
//@skip-check doc-comment-collection-item-type
Функция ВыполнитьHTTPЗапрос(ПолныйПутьURL, HTTPСоединение, HTTPЗаголовки, Метод = Неопределено, //ТелоЗапроса...) Экспорт
	ТелоЗапроса = Неопределено) Экспорт
	
	Если Метод = Неопределено Тогда
		Метод = "GET";
	КонецЕсли;
	Если ТелоЗапроса = Неопределено Тогда
		ТелоЗапроса = "";
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(ПолныйПутьURL);
	HTTPЗапрос.Заголовки = HTTPЗаголовки;
	
	Если ЗначениеЗаполнено(ТелоЗапроса) Тогда
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	КонецЕсли;
	
	Попытка
		Если Метод = "GET" Тогда
			Результат = HTTPСоединение.Получить(HTTPЗапрос);
		ИначеЕсли Метод = "POST" Тогда
			Результат = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		ИначеЕсли Метод = "PUT" Тогда
			Результат = HTTPСоединение.Записать(HTTPЗапрос);
		ИначеЕсли Метод = "PATCH" Тогда
			Результат = HTTPСоединение.Изменить(HTTPЗапрос);
		ИначеЕсли Метод = "HEAD" Тогда
			Результат = HTTPСоединение.ПолучитьЗаголовки(HTTPЗапрос);
		ИначеЕсли Метод = "DELETE" Тогда
			Результат = HTTPСоединение.Удалить(HTTPЗапрос);
		Иначе
			Результат = HTTPСоединение.ВызватьHTTPМетод(Метод, HTTPЗапрос);
		КонецЕсли;
	Исключение
		// Исключение здесь говорит о том, что запрос не дошел до HTTP-Сервера
		Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При выполнении запроса на стороне программы возникла ошибка!
			|Возникла ошибка при попытке получить данные от сервиса:
			|%2'", "ru");
		//@skip-check bsl-legacy-check-static-feature-access
		СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ВыполнениеЗапросаКоВнешнемуСервису",
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		СообщитьИзМодуля(СообщениеОбОшибке);
		//ЗаписатьВЛог("МП_РаботаСВнешнимиСервисами", СообщениеОбОшибке, "Ошибка");
	КонецПопытки;
	
	// В случае если результата нет, то на код состояния не проверяем, иначе будет ошибка
	Если Результат <> Неопределено Тогда
		// Обрабатываем ошибки и перенаправление
		Если Результат.КодСостояния >= 300 и Результат.КодСостояния < 500 Тогда
			Шаблон_СообщениеОбОшибке = НСтр("ru='%1. При выполнении запроса на стороне сервиса возникла ошибка!
				|Сервис вернул ошибку на запрос:
				|%2'", "ru");
			СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ВыполнениеЗапросаКоВнешнемуСервису",
				Результат.ПолучитьТелоКакСтроку());
			//ЗаписатьВЛог("МП_РаботаСВнешнимиСервисами", СообщениеОбОшибке, "Ошибка");
		КонецЕсли; 
	КонецЕсли;
	
	// Статусы 1XX и 2XX считаем хорошими
	Возврат Результат;
	
КонецФункции // ВыполнитьHTTPЗапрос()

// Функция - Обработать строку JSON
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Параметры:
//  СтрокаJSON - Строка - Строка в формате JSON.
// ИменаПолейСДатами				 - Массив - Массив строк с именами полей с типом Дата (необязательный).
//  ПоляСДатами - Неопределено - Поля с датами
//  ВосстанавливаемыеПоля - Массив - Массив строк для сопоставления в функции восстановления полей (необязательный).
// ДополнительныйеПараметры		 - Структура - Дополнительные параметры функции восстановления полей (необязательный).
//  ДополнительныеПараметры - Неопределено, Структура - Дополнительные параметры:
// * ИменаПолейСДатами - Неопределено - 
// * ИменаПолейДляВосстановления - Неопределено - 
// * ПараметрыЗапроса - Структура - 
// * ДанныеЗапроса - Структура - 
// * ИменаСвойствОшибок - Строка - 
// * ЗначенияСвойствОшибок - Строка - 
//  ПрочитатьВСоответствие - Булево - Для избежания проблем с переводом ключей.
// 
// Возвращаемое значение:
//  Структура, Массив - Данные преобразованные из строки JSON.
//@skip-check doc-comment-collection-item-type
//@skip-check method-too-many-params
Функция ОбработатьСтрокуJSON(СтрокаJSON, ПоляСДатами = Неопределено,  //ВосстанавливаемыеПоля...) Экспорт
	ВосстанавливаемыеПоля = Неопределено, ДополнительныеПараметры = Неопределено, ПрочитатьВСоответствие = Ложь) Экспорт
	
	МенеджерОбъекта = Неопределено;
	Если ДополнительныеПараметры <> Неопределено
		И ДополнительныеПараметры.Свойство("МенеджерОбъекта") Тогда
		МенеджерОбъекта = ДополнительныеПараметры.МенеджерОбъекта;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	ДанныеJSON = ПрочитатьJSON(ЧтениеJSON, 
		ПрочитатьВСоответствие,
		ПоляСДатами,
		ФорматДатыJSON.ISO,
		"МП_ВосстановлениеЗначенийПолейJSON",
		МенеджерОбъекта,
		ДополнительныеПараметры, // Эти параметры передадутся в переменную ДополнительныеПараметры
		ВосстанавливаемыеПоля);
	ЧтениеJSON.Закрыть();
	
	//@skip-check constructor-function-return-section
	Возврат ДанныеJSON;
	
КонецФункции // ОбработатьСтрокуJSON()

// Функция - Сформировать строку JSON
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
// 
// Параметры:
//  ДанныеДляJSON - Структура, Массив - Данные для сериализации JSON.
// ДополнительныйеПараметры		 - Структура - Дополнительные параметры функции восстановления полей (необязательный).
//  ДополнительныеПараметры - Неопределено, Структура - Дополнительные параметры:
// * ИменаПолейСДатами - Неопределено - 
// * ИменаПолейДляВосстановления - Неопределено - 
// * ПараметрыЗапроса - Структура - 
// * ДанныеЗапроса - Структура - 
// * ИменаСвойствОшибок - Строка - 
// * ЗначенияСвойствОшибок - Строка - 
// 
// Возвращаемое значение:
//  Структура, Массив - Данные преобразованные из строки JSON.
//@skip-check doc-comment-collection-item-type
Функция СформироватьСтрокуJSON(ДанныеДляJSON, ДополнительныеПараметры = Неопределено) Экспорт
	
	ПараметрыЗаписиJSON = Неопределено;
	НастройкиСериализацииJSON = Неопределено;
	МенеджерОбъекта = Неопределено;
	Если ДополнительныеПараметры <> Неопределено Тогда
		Если ДополнительныеПараметры.Свойство("ПараметрыЗаписиJSON") Тогда
			ПараметрыЗаписиJSON = ДополнительныеПараметры.ПараметрыЗаписиJSON;
		КонецЕсли;
		
		Если ДополнительныеПараметры.Свойство("НастройкиСериализацииJSON") Тогда
			НастройкиСериализацииJSON = ДополнительныеПараметры.НастройкиСериализацииJSON;
		КонецЕсли;
		
		Если ДополнительныеПараметры.Свойство("МенеджерОбъекта") Тогда
			МенеджерОбъекта = ДополнительныеПараметры.МенеджерОбъекта;
		КонецЕсли;
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON();
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
	ЗаписьJSON.ПроверятьСтруктуру = Истина;
	ЗаписатьJSON(ЗаписьJSON, 
		ДанныеДляJSON, 
		НастройкиСериализацииJSON,
		"МП_ПреобразованиеЗначенийПолейJSON",
		МенеджерОбъекта,
		ДополнительныеПараметры);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции // СформироватьСтрокуJSON()

// Функция - Получить дату time stamp
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
//
// Параметры:
//  Дата - Дата	 - Дата, которуб необходимо перевести в unixtime
// 
// Возвращаемое значение:
//  Число - Дата в формате time stamp
//
Функция СформироватьДатуTimeStamp(Дата) Экспорт
	
	Возврат УниверсальноеВремя(Дата) - '19700101';
	
КонецФункции // ПолучитьДатуTimeStamp()

// Функция - Обработать дату time stamp
// Ихсанов Д. А. 11.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2085
//
// Параметры:
//  ДатаTimeStamp	 - Число	 - Данные даты в формате time stamp
// 
// Возвращаемое значение:
//  Дата - Обработанная дата
//
Функция ОбработатьДатуTimeStamp(ДатаTimeStamp) Экспорт
	
	Возврат МестноеВремя('19700101' + ДатаTimeStamp);
	
КонецФункции // ОбработатьДатуTimeStamp()

