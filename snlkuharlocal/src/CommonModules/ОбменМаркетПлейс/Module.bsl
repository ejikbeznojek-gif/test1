Функция МаркаИлиНет(МаркетПлейс,ВхТаблицаЗначений) Экспорт
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//|	*
	//|ПОМЕСТИТЬ НужныйТовар
	//|ИЗ
	//|	&ТЗОстаток КАК ТЗОстаток
	//|;
	//|
	//|   ВЫБРАТЬ
	//|	*,
	//|	ВЫБОР
	//|		КОГДА Номенклатура.Родитель.ТНВЭД.ДатаНачалаРаботыСМаркировкой<>&ПустаяДата и Номенклатура.Родитель.ТНВЭД.ДатаНачалаРаботыСМаркировкой<=&ДатаОтгрузки
	//|			ТОГДА 1
	//|		ИНАЧЕ 0
	//|	КОНЕЦ КАК НужнаМаркировка
	//|ИЗ
	//|	НужныйТовар КАК НужныйТовар"; 
	//
	
	
	СтруктураДанныхНакладной=новый Структура("Номенклатура,ПунктДоставки,Договор,Дата,Контрагент,ПостояннаяАкция"); 
	СтруктураДанныхНакладной.Вставить("Номенклатура",   ВхТаблицаЗначений.ВыгрузитьКолонку("Номенклатура"));
	СтруктураДанныхНакладной.Вставить("ПунктДоставки",  МаркетПлейс.ПунктДоставки);
	СтруктураДанныхНакладной.Вставить("Контрагент",     МаркетПлейс.Контрагент);
	СтруктураДанныхНакладной.Вставить("Договор",        МаркетПлейс.Договор);
	СтруктураДанныхНакладной.Вставить("Дата",           ТекущаяДата());
	СтруктураДанныхНакладной.Вставить("ПостояннаяАкция", Ложь);
	СтруктураДанныхНакладной.Вставить("Товары",         ВхТаблицаЗначений);
	
	ТЗДАТЫМАРКИ =МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(СтруктураДанныхНакладной,"Товары");
	
	//вернет туже таблицу + одну колонку НужнаМаркировка
	//сделал колонку тип Число - для получения ИТОГА
	
	
	////!!!!ВНИМАНИЕ ТЕКСТ ЗАПРОСА РЕДАКТИРОВАТЬ СТРОГО В РУЧНУЮ
	////КОНСТРУКТОР убивает * (звездочку и КАРЕТА превращается в ТЫКВУ
	//	
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ НужныйТовар
	|ИЗ
	|	&ТЗОстаток КАК ТЗОстаток
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗДАТЫМАРКИ.Номенклатура КАК Номенклатура,
	|	ТЗДАТЫМАРКИ.ДатаНачалаРаботыСМаркировкой КАК ДатаМарки
	|ПОМЕСТИТЬ ДанныеМарки
	|ИЗ
	|	&ТЗДАТЫМАРКИ КАК ТЗДАТЫМАРКИ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ЕСТЬNULL(ДанныеМарки.ДатаМарки, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаМарки
	|ПОМЕСТИТЬ НаВывод
	|ИЗ
	|	НужныйТовар КАК НужныйТовар
	|		ПОЛНОЕ СОЕДИНЕНИЕ ДанныеМарки КАК ДанныеМарки
	|		ПО НужныйТовар.Номенклатура = ДанныеМарки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	*,
	|	ВЫБОР
	|		КОГДА НаВывод.ДатаМарки < &ДатаОтгрузки
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НужнаМаркировка
	|ИЗ
	|	НаВывод КАК НаВывод";
	////!!!!ВНИМАНИЕ ТЕКСТ ЗАПРОСА РЕДАКТИРОВАТЬ СТРОГО В РУЧНУЮ
	////КОНСТРУКТОР убивает * (звездочку и КАРЕТА прерващается в ТЫКВУ
	//
	
	
	Запрос.УстановитьПараметр("ТЗОстаток",      ВхТаблицаЗначений);
	Запрос.УстановитьПараметр("ТЗДАТЫМАРКИ",    ТЗДАТЫМАРКИ);
	Запрос.УстановитьПараметр("ПустаяДата",     Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОтгрузки",   ТекущаяДата());
	
	Результат = Запрос.Выполнить().Выгрузить(); 
	
	Возврат Результат;   	
	
КонецФункции

Процедура МП_Вайлбериз_ПостОбработкаЗаказа(МаркПл,ТЗЗакНом,Стат1="0",Тест1=Ложь,ПисатьВРегистрМарка=Ложь,СтруктураПараметров) Экспорт	
	
	ПрефиксМаркета=ПрефМаркет(МаркПл);
	
	ТЗЗакНом1=ТЗЗакНом.Скопировать();
	
	н=ТЗЗакНом.Количество()-1;
	
	Пока н>=0 Цикл
		ТСтр=ТЗЗакНом.Получить(н);
		Если ТСтр.Комплект Тогда
			ТЗЗакНом.Удалить(н);
		КонецЕсли;	
		н=н-1;
	КонецЦикла;
	
	н=ТЗЗакНом1.Количество()-1;
	
	Пока н>=0 Цикл
		ТСтр=ТЗЗакНом1.Получить(н);
		Если НЕ ТСтр.Комплект Тогда
			ТЗЗакНом1.Удалить(н);
		КонецЕсли;	
		н=н-1;
	КонецЦикла;	
	
	КНеТовар=МП_ПровкаНеТовар(ТЗЗакНом1);
	
	
	ТЗЗакНом2=ТЗЗакНом1.Скопировать();
	ТЗЗакНом2.Очистить();
	Если КНеТовар.МассивНеТовар.Количество() Тогда
		
		н=ТЗЗакНом1.Количество()-1;
		
		Пока н>=0 Цикл
			ТСтр=ТЗЗакНом1.Получить(н);
			Если ТСтр.КолНеТовар Тогда
				НовС=ТЗЗакНом2.Добавить();
				ЗаполнитьЗначенияСвойств(НовС,ТСтр);
				ТЗЗакНом1.Удалить(н);
			КонецЕсли;	
			н=н-1;
		КонецЦикла;
	КонецЕсли;
	
	
	///узанаем лимит на разделение накладных
	
	ЛимитПозиций=МаркПл.ЛимитПоКоличеству;
	
	//узанаем лимит на разделение накладных  	
	
	СтруктураПараметров.Вставить("ПисатьВРегистрМарка",ПисатьВРегистрМарка);
	СтруктураПараметров.Вставить("ЛимитПозиций"       ,ЛимитПозиций);
	
	МЗ1=МП_Вайлбериз_СоздатьДокиНеКомпл(ТЗЗакНом,МаркПл,,СтруктураПараметров); //Тимофеев Ю.А.
	МЗ2=МП_Вайлбериз_СоздатьДокиКомпл(ТЗЗакНом1,МаркПл,,СтруктураПараметров);  //Тимофеев Ю.А.
	
	КолвоНеТовар=КНеТовар.МассивНеТовар.Количество();
	МН=КНеТовар.МассивНеТовар;
	
	
	ММЗ=Новый Массив;
	
	нн=0;
	Пока нн<КолвоНеТовар Цикл
		ТНом=МН[нн];
		ТТЗ=ТЗЗакНом2.Скопировать();
		ТТЗ.Очистить();
		рр=ТЗЗакНом2.Количество()-1;
		
		Пока рр>=0 Цикл
			ТСтр=ТЗЗакНом2.Получить(рр);
			Если ТСтр.НомРП1=ТНом Тогда
				НовС=ТТЗ.Добавить();
				ЗаполнитьЗначенияСвойств(НовС,ТСтр);
				ТЗЗакНом2.Удалить(рр);
			КонецЕсли;	
			рр=рр-1;
		КонецЦикла;
		
		ТМЗ=МП_Вайлбериз_СоздатьДокиКомпл(ТТЗ,МаркПл,,СтруктураПараметров); //Тимофеев Ю.А.
		
		ММЗ.Добавить(ТМЗ);
		
		нн=нн+1;
	КонецЦикла;	
	
	Если ТЗЗакНом2.Количество() Тогда
		
		ТМЗ=МП_Вайлбериз_СоздатьДокиКомпл(ТЗЗакНом2,МаркПл,,СтруктураПараметров); //Тимофеев Ю.А.
		ММЗ.Добавить(ТМЗ);
		
	КонецЕсли;	
	
	Если Стат1="0" Тогда
		Статус="1";
		
		СостояниеУКлиента=Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(Статус);
		
		Для Каждого М1 Из МЗ1 Цикл
			
			Если НЕ М1.ПометкаУдаления Тогда
				
				//получение номера поставки и привязка в нее на портале
				Р=МП_ВыгрузитьСтатусыНаПортал(М1,МаркПл);
				
				Если Р>0 Тогда
					
					ДокОб=М1.ПолучитьОбъект();
					
					НужноЗаписывать = Ложь;
					
					Для Каждого ТСтр Из ДокОб.Товары Цикл
						
						Если ТСтр.СостояниеУКлиента<>СостояниеУКлиента Тогда
							
							ТСтр.СостояниеУКлиента=СостояниеУКлиента;
							НужноЗаписывать = Истина;
							
						КонецЕсли;
						
					КонецЦикла;	
					
					Если НужноЗаписывать Тогда
						
						
						Если ДокОб.ПометкаУдаления Тогда
							ДокОб.Записать(РежимЗаписиДокумента.Запись);
						Иначе  							
							ДокОб.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;	
		
		Для Каждого М2 Из МЗ2 Цикл
			
			Если НЕ М2.ПометкаУдаления Тогда
				
				//получение номера поставки и привязка в нее на портале
				Д=МП_ВыгрузитьСтатусыНаПортал(М1,МаркПл);
				
				Если Д>0 Тогда
					
					ДокОб=М2.ПолучитьОбъект();
					
					НужноЗаписывать = Ложь;
					
					Для Каждого ТСтр Из ДокОб.Товары Цикл
						
						Если ТСтр.СостояниеУКлиента<>СостояниеУКлиента Тогда
							
							ТСтр.СостояниеУКлиента=СостояниеУКлиента;
							НужноЗаписывать = Истина;
							
						КонецЕсли;
						
					КонецЦикла;	
					
					Если НужноЗаписывать Тогда
						
						Если ДокОб.ПометкаУдаления Тогда
							ДокОб.Записать(РежимЗаписиДокумента.Запись);
						Иначе  							
							ДокОб.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
						
						
					КонецЕсли;    				
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;  		
		
		
		Для Каждого ТМЗ Из ММЗ Цикл  			
			
			Для Каждого МТ Из ТМЗ Цикл
				
				Если НЕ МТ.ПометкаУдаления Тогда
					
					//получение номера поставки и привязка в нее на портале 					
					Д=МП_ВыгрузитьСтатусыНаПортал(М1,МаркПл);
					
					Если Д>0 Тогда
						ДокОб=МТ.ПолучитьОбъект();
						
						НужноЗаписывать = Ложь;
						
						Для Каждого ТСтр Из ДокОб.Товары Цикл
							
							Если ТСтр.СостояниеУКлиента<>СостояниеУКлиента Тогда
								
								ТСтр.СостояниеУКлиента=СостояниеУКлиента;
								НужноЗаписывать = Истина;
								
							КонецЕсли;
							
						КонецЦикла;	
						
						Если НужноЗаписывать Тогда
							
							Если ДокОб.ПометкаУдаления Тогда
								ДокОб.Записать(РежимЗаписиДокумента.Запись);
							Иначе  							
								ДокОб.Записать(РежимЗаписиДокумента.Проведение);
							КонецЕсли;
							
							
						КонецЕсли;  					
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла; 		
		КонецЦикла;  
		
	КонецЕсли;	
	
	Если Стат1="1" Тогда
		
		СостояниеУКлиента=Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(Стат1);
		
		Для Каждого М1 Из МЗ1 Цикл
			
			Если НЕ М1.ПометкаУдаления Тогда
				ДокОб=М1.ПолучитьОбъект();
				
				Для Каждого ТСтр Из ДокОб.Товары Цикл
					
					ТСтр.СостояниеУКлиента=СостояниеУКлиента;
					
				КонецЦикла;	
				
				Если ДокОб.ПометкаУдаления Тогда
					ДокОб.Записать(РежимЗаписиДокумента.Запись);
				Иначе  							
					ДокОб.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;	
		
		Для Каждого М2 Из МЗ2 Цикл
			
			Если НЕ М2.ПометкаУдаления Тогда
				
				ДокОб=М2.ПолучитьОбъект();
				
				Для Каждого ТСтр Из ДокОб.Товары Цикл
					ТСтр.СостояниеУКлиента=СостояниеУКлиента;
				КонецЦикла;	
				
				Если ДокОб.ПометкаУдаления Тогда
					ДокОб.Записать(РежимЗаписиДокумента.Запись);
				Иначе  							
					ДокОб.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
				
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого ТМЗ Из ММЗ Цикл  			
			
			Для Каждого МТ Из ТМЗ Цикл
				
				Если НЕ МТ.ПометкаУдаления Тогда
					
					ДокОб=МТ.ПолучитьОбъект();
					
					Для Каждого ТСтр Из ДокОб.Товары Цикл
						ТСтр.СостояниеУКлиента=СостояниеУКлиента;
					КонецЦикла;	
					
					Если ДокОб.ПометкаУдаления Тогда
						ДокОб.Записать(РежимЗаписиДокумента.Запись);
					Иначе  							
						ДокОб.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
