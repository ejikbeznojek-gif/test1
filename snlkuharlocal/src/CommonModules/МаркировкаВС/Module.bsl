Функция СоздатьОбработкуАПИ() Экспорт
	Отладка = Ложь;
	
	Если Отладка Тогда
		ИмяФайла 	= Константы.КаталогВнешнихОтчетов.Получить()+"Маркировка\АпиЧЗ.epf";
	
		ОЗОД = Новый ОписаниеЗащитыОтОпасныхДействий;
		ОЗОД.ПредупреждатьОбОпасныхДействиях = Ложь;
		
		Обработка	= ВнешниеОбработки.Создать(ИмяФайла, Ложь, ОЗОД);		
	Иначе
		Обработка	= Обработки.АпиЧЗ.Создать();	
	КонецЕсли;	
	
	Возврат Обработка;
КонецФункции //СоздатьОбработкуАПИ(Отладка = Ложь)
 
