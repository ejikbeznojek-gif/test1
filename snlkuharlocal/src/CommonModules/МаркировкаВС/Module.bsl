Функция ПолучитьМаркируемыеТоварыДокумента(ДокСсылка, ИмяТЧ = "Товары") Экспорт
	МетаДок = ДокСсылка.Метаданные();
	МетаТЧ	= МетаДок.ТабличныеЧасти[ИмяТЧ];
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,	
	|	СУММА("+?(МетаТЧ.Реквизиты.Найти("Количество")<>Неопределено,"Количество","1")+") КАК Количество
	|ИЗ
	|	"+ДокСсылка.Метаданные().ПолноеИмя()+"."+ИмяТЧ+"
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|	И НЕ (
	|		Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|		ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)
	|	)
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);	
	
	Возврат Запрос.Выполнить().Выгрузить();	
КонецФункции //ПолучитьМаркируемыеТоварыДокумента(ДокСсылка, ИмяТЧ = "Товары") Экспорт
//++Данилова Е.В. 27.03.2025 по ГН 
Функция РазбитьТЧнаЧасти(тТовары, СтрокаНаДокумент = 10, МаксКоличествоПоПозиции = 1000, НомерЧасти = 0) Экспорт
	
	Части = Новый Массив;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Товары ИЗ &тТовары КАК тТовары
	|;
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Номенклатура.ГТИН КАК ГТИН,
	|	СУММА(Количество) КАК Количество
	|ИЗ
	|	ВТ_Товары	
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Количество УБЫВ
	|";
	
	Запрос.УстановитьПараметр("тТовары", тТовары);	
	
	Выборка 		= Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		Номенклатура	= Выборка.Номенклатура;
		НадоСписать 	= Выборка.Количество;		
		
		Пока НадоСписать > 0 Цикл
//			ОбработкаПрерыванияПользователя();
			
			ТекКол = Макс(0, Мин(НадоСписать, МаксКоличествоПоПозиции));		
			Если ТекКол > 0 Тогда
				ТекЧасть = Неопределено;
				Для Каждого Часть Из Части Цикл
					Если Часть.Количество() < СтрокаНаДокумент И Часть[Номенклатура] = Неопределено Тогда
						ТекЧасть = Часть;
						Прервать;
					КонецЕсли;				
				КонецЦикла; 	
				
				Если ТекЧасть = Неопределено Тогда
					ТекЧасть = Новый Соответствие;				
					Части.Добавить(ТекЧасть);
				КонецЕсли; 
				
				ТекЧасть[Номенклатура] = ТекКол;
				НадоСписать = НадоСписать - ТекКол;				
			КонецЕсли;			
		КонецЦикла;		
	КонецЦикла;	
	
	ТР = Новый ТаблицаЗначений;
	ТР.Колонки.Добавить("Часть", 		ПолучитьОписаниеТиповЧисла(9,0));
	ТР.Колонки.Добавить("Номенклатура",	Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));	
	ТР.Колонки.Добавить("Количество", 	ПолучитьОписаниеТиповЧисла(12,0));
	//++Данилова Е.В. 27.03.2025 MARK-1288
	//Сч = 1;
	Сч = НомерЧасти + 1; 
	//--Данилова Е.В. 27.03.2025
	Для Каждого Часть Из Части Цикл		
		Для Каждого КиЗ Из Часть Цикл
			СтрокаТР = ТР.Добавить();
			
			СтрокаТР.Часть 			= Сч;
			СтрокаТР.Номенклатура   = КиЗ.Ключ;
			СтрокаТР.Количество		= КиЗ.Значение;			
		КонецЦикла; 
		Сч=Сч+1;
	КонецЦикла;
	//++Данилова Е.В. 27.03.2025 MARK-1922
	НомерЧасти = Сч; 
	//--Данилова Е.В. 27.03.2025
	Возврат ТР;	
КонецФункции

