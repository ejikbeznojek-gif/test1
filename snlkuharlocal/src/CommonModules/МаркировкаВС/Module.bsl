Функция ПолучитьОсновнойШК(Номенклатура) Экспорт
	Результат = "";
	
	ШК = ПолучитьВсеШКТовара(Номенклатура, Перечисления.ТипыШтрихКодов.Штука, Перечисления.ВидыШК.Основной);
	
	Если ШК.Количество()=1 Тогда
		Результат = ШК[0].Наименование;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьОсновнойШК(Номенклатура) Экспорт

