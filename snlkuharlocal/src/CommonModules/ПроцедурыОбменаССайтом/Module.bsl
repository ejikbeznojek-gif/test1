	             |												ТОГДА ""Да""
	             |											КОГДА ном.Родитель.Родитель.Родитель.Родитель."+ПеременнаяОбмена+".Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
	             |												ТОГДА ""Нет""
	             |											ИНАЧЕ ""Нет""
	             |										КОНЕЦ
	             |								КОНЕЦ
	             |						КОНЕЦ
	             |				КОНЕЦ
	             |		КОНЕЦ = ""Да"" ";
	
	
	//нечаева 10,08,22+++  если на цвет-размер, то признак смотрим у родителя.
		
	// нечаева 10,08,22--
	Запрос.УстановитьПараметр("ТНВЭД",ТНВЭД);  //ложь
	Запрос.УстановитьПараметр("Пустая",справочники.Номенклатура.ПустаяСсылка());  //ложь
	Выборка=Запрос.Выполнить().Выгрузить();
	
	СписокНом = выборка.ВыгрузитьКолонку("Модель");	
	
	возврат СписокНом;
	
	
	
КонецФункции

