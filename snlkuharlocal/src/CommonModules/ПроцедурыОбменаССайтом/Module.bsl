Процедура ОчиститьЗаписиВРегистреСведенийСОтбором(ИмяРегистра,Дата) Экспорт 
	
	НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Дата.Установить(Дата);
	НаборЗаписей.Записать();    
КонецПроцедуры


Процедура ОтборИОчисткаРегистраСведений(ИмяРегистра) Экспорт 
		
	//имя = "ЛогиОбменаССайтомb2bЦены";
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЛогиОбменаССайтомb2b.Дата КАК ДатаО
	               |ИЗ
	               |	РегистрСведений."+ИмяРегистра+" КАК ЛогиОбменаССайтомb2b
	               |ГДЕ
	               |	ЛогиОбменаССайтомb2b.Дата <= &ДатаОчистки";
	
	Запрос.УстановитьПараметр("ДатаОчистки",(НачалоДня(ТекущаяДата())-7*24*60*60));
	Рез = запрос.Выполнить().Выбрать();
	
	
	Пока рез.Следующий() цикл
		
		ОчиститьЗаписиВРегистреСведенийСОтбором(ИмяРегистра,рез.ДатаО);

	КонецЦикла;

	
КонецПроцедуры


