	КонецЕсли;	
		
	//нечаева25102022 +++
	ВыгружатьНаСайт = ВыгружатьНаСайт(ССылка,ОбменСтильпарк,ОБъект);
	
	//нечаева 26,01,24+++
	// для новых  товаров, у которых у родителя стоит = нет. не записываем.
	Если (ссылка[ПризнакВыгрузкиНаСайт] =перечисления.ВыгружатьНаСайт.ПустаяСсылка() и Объект[ПризнакВыгрузкиНаСайт] = перечисления.ВыгружатьНаСайт.Нет) 
		или 
	    (ссылка.родитель[ПризнакВыгрузкиНаСайт] =перечисления.ВыгружатьНаСайт.ПустаяСсылка() и Объект.родитель[ПризнакВыгрузкиНаСайт] = перечисления.ВыгружатьНаСайт.Нет) 
	Тогда
	    Выгружать=ложь;
		возврат ложь;
	КонецЕсли;
	//нечаева 26,01,24---
	
	ПризнакВыгрузкиИзменен = ложь;
	// если изменилась, сразу на сайт выгружаем
	Если ссылка[ПризнакВыгрузкиНаСайт]<>Объект[ПризнакВыгрузкиНаСайт] 
		или (ссылка.родитель[ПризнакВыгрузкиНаСайт]<>Объект.родитель[ПризнакВыгрузкиНаСайт] и ссылка.этоГруппа=ложь)
		
		Тогда
		Выгружать=Истина;
		ПризнакВыгрузкиИзменен = истина;

		возврат Истина;
	Иначе
		// признак выгрузки не менялся!!!
	КонецЕсли;	

	Если ссылка.ЖизненныйЦиклНоменклатуры<>Объект.ЖизненныйЦиклНоменклатуры  и ВыгружатьНаСайт = "Да"  Тогда
		Выгружать=Истина;
		возврат Истина;
	КонецЕсли;	
	
	// тут признак выгрузки на сайт не меняли, и если нет, то дальше не проверяем
	Если ВыгружатьНаСайт = "Нет" Тогда
		Выгружать=ложь;
		возврат ложь;
	КонецЕсли;	
	
	// для номенклатуры
	Выгружать=Ложь;                                                                                              // нечаева 23,08,24++ ТНВЭД
	ГрупповыеРеквизиты	=Новый Структура("Цвет,Размер,ЦветИМ,СтавкаНДС,Наименование,Состав,ПоловозрастнойПризнак,Родитель,ТНВЭД,ОтгрузкаТолькоЧерезЧЗ,"+
	"ВыгружатьВИнтернетМагазин,ПоловозрастнойПризнак,КатегорияИспользованияДляСайта,ТипТовараДляСайта,ЖизненныйЦиклНоменклатуры,ФР_ГруппаТоваров,ФР_ВидНоменклатуры,ФР_Пол,ФР_Бренд,ФР_Коллекция,ФР_Размер,"+
	"БрендДляСайта,КоллекцияДляСайта,ОписаниеТовараДляСайта,РазмерДляСайта,ПодТипТовараДляСайта,НазваниеТовараДляСайта,Ведущий,ШтукВКоробочке,ШтукВКоробке");

	
	// проверяем есть ли изменения.
	Для Каждого Реквизит Из ГрупповыеРеквизиты Цикл
		Попытка
			Если ссылка[Реквизит.Ключ]<>Объект[Реквизит.Ключ] Тогда
				Выгружать=Истина;
			КонецЕсли;		
		Исключение
		КонецПопытки;
		
	КонецЦикла;	
	
	// СоставНоменклатуры, ПодТипыТовараДляСайта  - таб. части  проверка через "ЗначениеВСтрокуВнутренняя"
	ТабличныеРеквизиты	=Новый Структура("СоставНоменклатуры,ПодТипыНоменклатурыДляСайта");
	
	Для Каждого Реквизит Из ТабличныеРеквизиты Цикл
		
		Попытка
			Тз1=Ссылка[Реквизит.Ключ].Выгрузить();
			Тз2=Объект[Реквизит.Ключ].Выгрузить();
			Если ЗначениеВСтрокуВнутр(Тз1)<>ЗначениеВСтрокуВнутр(Тз2) Тогда
				Выгружать=Истина;
			КонецЕсли;		
		Исключение
		КонецПопытки;
		
	КонецЦикла;	
	
//	Сообщить(" писать изменение в план обмена "+выгружать);

	Возврат Выгружать;
	
КонецФункции

