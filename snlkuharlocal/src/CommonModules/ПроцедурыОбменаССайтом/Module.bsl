Функция ПолучитьСписокУзловМонобрендовыхСайтов(ТекСсылка,ТолькоАктивныеУзлы=Истина) Экспорт
	
	// на активность уже не смотрим, если по изменению табличной части, иначе если поменялось на неактивность, то не снимется активность на сайте
	Если НЕ текссылка.ЭтоГруппа Тогда
		Модель = Модель = ТекССылка.Родитель.ссылка;;
	иначе
		модель = текссылка.Ссылка;
	КонецЕсли;
	
	Если ТолькоАктивныеУзлы Тогда
		ПеременнаяОбмена = "НоменклатураПолучателиИзмененийНоменклатуры.Активность = &активна и";
	иначе
		ПеременнаяОбмена = "";
	конецЕсли;
	
	Запрос = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НоменклатураПолучателиИзмененийНоменклатуры.узелОбмена КАК узелОбмена
				   |ИЗ
	               |	Справочник.Номенклатура.ПолучателиИзмененийНоменклатуры КАК НоменклатураПолучателиИзмененийНоменклатуры
	               |ГДЕ
	               |	  "+ПеременнаяОбмена+"
				   |	 НоменклатураПолучателиИзмененийНоменклатуры.Ссылка = &тексылка";
	Запрос.УстановитьПараметр("Активна",перечисления.ВыгружатьНаСайт.Да);
	Запрос.УстановитьПараметр("тексылка",Модель);
	
	Рез = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("узелОбмена");;
	
	возврат Рез;
	
	
