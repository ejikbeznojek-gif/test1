Функция РегистрироватьИзмененияКонтрагентовДляСайта_b2b(Ссылка,Объект) Экспорт
	
	//нечаева 02,06,22++
	Если ССылка.ЭтоГруппа = Истина ТОгда
		выгружатьНаСайт=ложь;
		возврат ложь;
	КонецЕсли;	
	//02,06,22 --
	
	ВыгружатьНаСайт = ложь;
	Если Ссылка.ведущий.выгружатьвинтернетмагазин = перечисления.ВыгружатьНаСайт.Да или Ссылка.выгружатьвинтернетмагазин = перечисления.ВыгружатьНаСайт.Да ТОгда
		выгружатьНаСайт=Истина;
	КонецЕсли;	
		
	// это к сайту b2b 
	Если ссылка.ВыгружатьВИнтернетМагазин<>Объект.ВыгружатьВИнтернетМагазин Тогда
		Выгружать=Истина;
		возврат Истина;
	КонецЕсли;	
	
	Если Не ВыгружатьНаСайт ТОгда
	
		возврат ложь;
		
	КонецЕсли;	
	
	Выгружать = Истина;
	
	
	Возврат Выгружать;
	
КонецФункции
