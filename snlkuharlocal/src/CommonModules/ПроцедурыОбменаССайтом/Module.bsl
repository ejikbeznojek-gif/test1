Процедура ЗарегистрироватьИзменения(Объект, ОбменСтильпарк = ложь)
	
	Если Не ПараметрыСеанса.НаличиеОбменаССайтом Тогда
		Возврат;
	КонецЕсли;
	// только для центральной базы!!!
			
	ТипОбъекта = ТипЗнч(Объект);
	ТипОбъектаДокумент = Метаданные.Документы.Содержит(Объект.Метаданные());
	
	// Номенклатура и картинки
	Если ТипОбъекта = Тип("РегистрСведенийНаборЗаписей.ЗначенияСвойствОбъектовИнтернетМагазин") Тогда
		
		МассивУзлов = ПолучитьМассивУзловДляРегистрации(Истина);
		Для каждого Запись Из Объект Цикл
			
			ТипДанных = ТипЗнч(Запись.Объект);
			
			Если ТипДанных = Тип("СправочникСсылка.Номенклатура") Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Запись.Объект);
			//ИначеЕсли ТипДанных = Тип("СправочникСсылка.ХарактеристикиНоменклатуры") Тогда
			//	ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Запись.Объект.Владелец);
			КонецЕсли;	
			
		КонецЦикла;
		
	ИначеЕсли ТипОбъекта = Тип("СправочникСсылка.Номенклатура") Тогда 
		  
		МассивУзлов = ПолучитьМассивУзловДляРегистрации(Истина,ложь,ОбменСтильпарк);  
		Попытка
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Объект);
		Исключение 
		конецПопытки;
	// нечаева 310522 ++	
	ИначеЕсли ТипОбъекта = Тип("СправочникСсылка.Контрагенты") Тогда 
		  
		МассивУзлов = ПолучитьМассивУзловДляРегистрации(Ложь,Истина,ложь); // первая товары, вторая контрагенты 
		Попытка
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Объект);
		Исключение 
		конецПопытки;
	 //нечаева 310522---
	// если изменился ШК, тоже выгружаем	нечаева 120422
	ИначеЕсли ТипОбъекта = Тип("СправочникСсылка.Штрихкоды") Тогда 
		  
		МассивУзлов = ПолучитьМассивУзловДляРегистрации(Истина, ложь, ложь); // тут только на b2b будем грузить. 
		Попытка
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Объект.Владелец.ссылка);
		Исключение 
		конецПопытки;
		
	// Смирнов М.Ю. 18.06.2025 WEB-3352 начало
	ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.УстановкаСкидокПоКонтрагентам") Тогда
		
		МассивУзлов = ПолучитьМассивУзловДляРегистрации(Ложь, Истина, Ложь); // первая товары, вторая контрагенты 
		Попытка
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Объект);
		Исключение 
		КонецПопытки;
	// Смирнов М.Ю. 18.06.2025 WEB-3352 конец	
		
	КонецЕсли;		
		
КонецПроцедуры	



