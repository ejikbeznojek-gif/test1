	             |								КОГДА ном.Родитель.Родитель.Родитель."+ПеременнаяОбмена+".Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
	             |									ТОГДА ""Да""
	             |								КОГДА ном.Родитель.Родитель.Родитель."+ПеременнаяОбмена+".Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
	             |									ТОГДА ""Нет""
	             |								ИНАЧЕ ВЫБОР
	             |										КОГДА ном.Родитель.Родитель.Родитель.Родитель."+ПеременнаяОбмена+".Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
	             |											ТОГДА ""Да""
	             |										КОГДА ном.Родитель.Родитель.Родитель.Родитель."+ПеременнаяОбмена+".Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
	             |											ТОГДА ""Нет""
