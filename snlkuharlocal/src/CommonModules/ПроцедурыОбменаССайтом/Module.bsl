Функция   ПроверитьЗагрузкуФайлаНаСайте(СтруктураПараметровСайта,ТипФайла) Экспорт

	Успешно = Истина;
	
	команда = "local/crons/notify/import_status.php?import_id="+ТипФайла;   //"Offers-22"; 
	ПутьКФайлу = КомандаЗагрузки(СтруктураПараметровСайта,команда);
	
	Успешно = ПрочитатьФайлXMLПоследовательно(ПутьКФайлу);
		 
	Возврат Успешно;
	
КонецФункции


Функция ПостроитьПуть(СтекИмен)
    Путь = "";
    
    Для Каждого Имя Из СтекИмен Цикл
        Путь = Путь + "/" + Имя;
    КонецЦикла;
    
    Возврат Путь;
КонецФункции


Функция ПрочитатьФайлXMLПоследовательно(ПутьКФайлу)
    // Этот способ подойдёт для очень больших файлов,
 
    Парсер = Новый ЧтениеXML;
    Парсер.ОткрытьФайл(ПутьКФайлу);
	
	СписокОшибок = Новый Массив;
	
    СтекИмен = Новый СписокЗначений;
    
 	ЗагрузкаСОшибкой = ложь;
 
       Пока Парсер.Прочитать() Цикл
        Если Парсер.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
            СтекИмен.Добавить(Парсер.Имя);
            ПолныйПуть = ПостроитьПуть(СтекИмен);
 
            Если ПолныйПуть = "/Результат/Заказ/ИдЗаказа" Тогда
                //ИДЗаказа = Парсер.ЗначениеАтрибута("ИдЗаказа"); // если внутри есть атирибуты, то так.
				
				Парсер.Прочитать();
                Если Парсер.ТипУзла = ТипУзлаXML.Текст Тогда
                    //Сообщить("ИДЗаказа:");
                    //Сообщить(Парсер.Значение);
                КонецЕсли;
				ИДЗаказа = Парсер.Значение;
				
				
			ИначеЕсли ПолныйПуть = "/Результат/Заказ/Статус/Название" Тогда
				
				Парсер.Прочитать();
               	Название = Парсер.Значение;
				Если Название = "Ошибка" Тогда
					ЗагрузкаСОшибкой = истина;
				КонецЕсли;	
							
            ИначеЕсли ПолныйПуть = "/Результат/Заказ/Ошибки/Ошибка" Тогда
				
				Парсер.Прочитать();
               	Название = Парсер.Значение;
			    Если Название <> Неопределено Тогда
                    //Сообщить(" " + Название);
					СписокОшибок.Добавить(Название);
                КонецЕсли;
            КонецЕсли;
        ИначеЕсли Парсер.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
            СтекИмен.Удалить(СтекИмен.Количество() - 1);
        КонецЕсли;

		
    КонецЦикла;
  
    Парсер.Закрыть();

	// отправить письмо, если ошибки
	
	Если ЗагрузкаСОшибкой ТОгда
		
		СообщитьОшибки(ИДЗаказа,СписокОшибок);
		СписокОшибок.Очистить();
		
	КонецЕсли;	
	
	
	возврат НЕ ЗагрузкаСОшибкой;
	
	
КонецФункции


