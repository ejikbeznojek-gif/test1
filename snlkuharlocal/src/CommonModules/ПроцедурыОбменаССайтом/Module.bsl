Функция РегистрироватьИзмененияУзловДляМонобрендовыхСайтов(Ссылка,Объект) Экспорт
	
	//Выгружать =неопределено;	
	//возврат ложь; // временно не регистрируем
	
	
	//----------------------------------------------------------------
	//сначала смену активности, для монобрендовых сайтов, потом остальные. основное это снятие активности!!!!
	//  - таб. части  проверка через "ЗначениеВСтрокуВнутренняя"
		Выгружать = ложь;	
	
	//----------------------------------------------------------------
	//сначала смену активности, для монобрендовых сайтов, потом остальные. основное это снятие активности!!!!
	//  - таб. части  проверка через "ЗначениеВСтрокуВнутренняя"
	ТабличныеРеквизиты	=Новый Структура("ПолучателиИзмененийНоменклатуры");
	СменаАктивМонобренд = ложь;
	Для Каждого Реквизит Из ТабличныеРеквизиты Цикл
		
		Попытка
			Тз1=Ссылка[Реквизит.Ключ].Выгрузить();
			Тз2=Объект[Реквизит.Ключ].Выгрузить();
			Если ЗначениеВСтрокуВнутр(Тз1)<>ЗначениеВСтрокуВнутр(Тз2) Тогда
				Выгружать=Истина;
				СменаАктивМонобренд = истина;
			КонецЕсли;		
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
	Если выгружать =ложь Тогда 
		возврат ложь;
	КонецЕсли;	
	
	
	ТаблицаНовая=новый ТаблицаЗначений;
	ТаблицаНовая.Колонки.Добавить("УзелОбмена", Новый ОписаниеТипов("ПланОбменаСсылка.ОбменССайтомТоварами"));
	ТаблицаНовая.Колонки.Добавить("Активность", Новый ОписаниеТипов("ПеречислениеСсылка.ВыгружатьНаСайт"));
	ТаблицаНовая2=новый ТаблицаЗначений;
	ТаблицаНовая2.Колонки.Добавить("УзелОбмена", Новый ОписаниеТипов("ПланОбменаСсылка.ОбменССайтомТоварами"));
	ТаблицаНовая2.Колонки.Добавить("Активность", Новый ОписаниеТипов("ПеречислениеСсылка.ВыгружатьНаСайт"));

	
	
	ТаблицаНовая = Ссылка.ПолучателиИзмененийНоменклатуры.выгрузить();
	ТаблицаНовая2 = Объект.ПолучателиИзмененийНоменклатуры.выгрузить();
	
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	ТНов.УзелОбмена КАК УзелОбмена,
	             |	ТНов.Активность КАК Активность
	             |ПОМЕСТИТЬ ТНов
	             |ИЗ
	             |	&ТаблицаНовое КАК ТНов
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ТНов2.УзелОбмена КАК УзелОбмена,
	             |	ТНов2.Активность КАК Активность
	             |ПОМЕСТИТЬ ТНов2
	             |ИЗ
	             |	&ТаблицаНовое2 КАК ТНов2
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ 
	             |	ТНов1.УзелОбмена КАК УзелОбмена,
	             |	ТНов1.Активность КАК Активность,
	             |	1 КАК Сумма
	             |ИЗ
	             |	ТНов КАК ТНов1
	             |
	             |ОБЪЕДИНИТЬ ВСЕ
	             |
	             |ВЫБРАТЬ
	             |	ТНов2.УзелОбмена,
	             |	ТНов2.Активность,
	             |	1
	             |ИЗ
	             |	ТНов2 КАК ТНов2 ";
	запрос.УстановитьПараметр("ТаблицаНовое",ТаблицаНовая);       // выбрать различные.
	
	запрос.УстановитьПараметр("ТаблицаНовое2",ТаблицаНовая2);

	ТЗОбщая=запрос.Выполнить().Выгрузить();
	ТЗОбщая.свернуть("УзелОбмена,Активность","Сумма");
	пп=1;
	//********
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	ТНов.УзелОбмена КАК УзелОбмена,
	             |	ТНов.Активность КАК Активность,
	             |	ТНов.Сумма КАК Сумма
	             |ПОМЕСТИТЬ ТНов
	             |ИЗ
	             |	&ТаблицаНовое КАК ТНов
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ различные
	             |	ТНов1.УзелОбмена КАК УзелОбмена,
	             |	ТНов1.Активность КАК Активность,
	             |	ТНов1.Сумма КАК сумма
	             |ИЗ
	             |	ТНов КАК ТНов1
	             |ГДЕ
	             |	ТНов1.Сумма = 1";
	запрос.УстановитьПараметр("ТаблицаНовое",ТЗОбщая);       // выбрать различные.

	СписокУзловСИзменениями =запрос.Выполнить().Выгрузить();
	СписокУзловСИзменениями.свернуть("УзелОбмена");
	МассивУзлов = СписокУзловСИзменениями.ВыгрузитьКолонку("УзелОбмена");
	
	//--------------------------------------------------------------------------------------------	
	
	Если Не ПараметрыСеанса.НаличиеОбменаССайтом Тогда
		Возврат ложь;
	КонецЕсли;
	// только для центральной базы!!!
	Если СменаАктивМонобренд и СписокУзловСИзменениями.Количество()>0 Тогда		
			
			Попытка
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Объект);
			Исключение
				сообщить(ОписаниеОшибки());
			конецПопытки;
	КонецЕсли;
	

	Возврат Выгружать;
	

	
КонецФункции

