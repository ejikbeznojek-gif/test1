Процедура ЗаписатьВЖурналИзмененийРеквизитов(Документ,ИмяРеквизита,СтароеЗначение,НовоеЗначение,ОбменДанными,ПерваяЗапись,источник)
	
	//если замещение тогда 
	//	сообщить ("Замещение");
	//иначе
	//	Сообщить("Не замещение");
	//КонецЕсли;   
	//Кухарь 04.06.19 начало
	//По просьбе Никиты. Т.к. висит.
	Возврат;
	//Кухарь 04.06.19 конец	
	
	
	если ОбменДанными<>Неопределено тогда
		загрузка=ОбменДанными.загрузка;
	иначе
		загрузка=ложь;
	КонецЕсли;
	
	если ПерваяЗапись Тогда 
		Запись=РегистрыСведений.ЖурналИзмененийРеквизитов.СоздатьМенеджерЗаписи();	
		Запись.Дата				=ТекущаяДата();
		Запись.Документ			=Документ;
		Запись.ТипДокумента		=Документ.метаданные().имя;
		Запись.ИмяРеквизита		=ИмяРеквизита;
		Запись.СтароеЗначение	=СтароеЗначение;
		Запись.НовоеЗначение	=0;
		Запись.Пользователь		=ПараметрыСеанса.Пользователь;
		Если загрузка Тогда
			Запись.Отправитель		=ОбменДанными.Отправитель;		
			Запись.НомерСообщения	=ПараметрыСеанса.НомерСообщения;
		КонецЕсли;		
		Запись.Записать();
	иначе		
		ДанныеВБазе=РегистрыСведений.ЖурналИзмененийРеквизитов.СоздатьНаборЗаписей();		
		ДанныеВБазе.Отбор.Документ.Установить(Источник.Отбор.Документ.Значение);
		ДанныеВБазе.Отбор.ИмяРеквизита.Установить(источник.Отбор.ИмяРеквизита.Значение);	
		ДанныеВБазе.Прочитать();
		Для Каждого Запись Из ДанныеВБазе Цикл
			СтароеЗначение=Запись.СтароеЗначение;
		КонецЦикла;
		//кухарь 23.10.14 начало 
		//  20.05.2019 начало
		//  Вернул как было
		если СтароеЗначение<>НовоеЗначение тогда 
			//  20.05.2019 конец
			
			//если СтароеЗначение<>НовоеЗначение тогда
			//Запись=РегистрыСведений.ЖурналИзмененийРеквизитов.СоздатьМенеджерЗаписи();
			если запись<>Неопределено тогда
				Запись.Дата				=ТекущаяДата();
				Запись.Документ			=Документ;
				Запись.ТипДокумента		=Документ.метаданные().имя;
				Запись.ИмяРеквизита		=ИмяРеквизита;
				Запись.СтароеЗначение	=СтароеЗначение;
				Запись.НовоеЗначение	=НовоеЗначение;
				Запись.Пользователь		=ПараметрыСеанса.Пользователь;
				Если загрузка Тогда
					Запись.Отправитель		=ОбменДанными.Отправитель;		
					Запись.НомерСообщения	=ПараметрыСеанса.НомерСообщения;
				КонецЕсли;	
				если СтароеЗначение<>НовоеЗначение тогда
					Запись.Дата	=ТекущаяДата();				
				иначе 
					Запись.Дата	=ТекущаяДата()-100*365*24*3600;
				КонецЕсли;
				
				//Запись.Записать(); 
				ДанныеВБазе.Записать();
			иначе
				Запись=РегистрыСведений.ЖурналИзмененийРеквизитов.СоздатьМенеджерЗаписи();
				Запись.Дата				=ТекущаяДата();
				Запись.Документ			=Документ;
				Запись.ТипДокумента		=Документ.метаданные().имя;
				Запись.ИмяРеквизита		=ИмяРеквизита;
				Запись.СтароеЗначение	=СтароеЗначение;
				Запись.НовоеЗначение	=НовоеЗначение;
				Запись.Пользователь		=ПараметрыСеанса.Пользователь;
				Если загрузка Тогда
					Запись.Отправитель		=ОбменДанными.Отправитель;		
					Запись.НомерСообщения	=ПараметрыСеанса.НомерСообщения;
				КонецЕсли;	
				если СтароеЗначение<>НовоеЗначение тогда
					Запись.Дата	=ТекущаяДата();				
				иначе 
					Запись.Дата	=ТекущаяДата()-10*365*24*3600;
				КонецЕсли;				
				Запись.Записать(); 	
			КонецЕсли;
			//кухарь 23.10.14 конец
			//  20.05.2019 начало
			//  Вернул как было
		КонецЕсли;
		//  20.05.2019 конец
		
	КонецЕсли;
КонецПроцедуры 

Функция ПолучитьСтароеЗначение(Источник)
	ДанныеВБазе=РегистрыСведений[Источник.метаданные().имя].СоздатьНаборЗаписей();
	
	ДанныеВБазе.Отбор.Документ.Установить(Источник.Отбор.Документ.Значение);
	ДанныеВБазе.Отбор.ИмяРеквизита.Установить(Источник.Отбор.ИмяРеквизита.Значение);	
	
	ДанныеВБазе.Прочитать();
	ТЗ=новый ТаблицаЗначений;
	тз.колонки.Добавить("ЗначениеРеквизита");
	тз.колонки.Добавить("Документ");
	тз.колонки.Добавить("ИмяРеквизита");
	Для Каждого Запись Из ДанныеВБазе Цикл
		стр=тз.Добавить();
		ЗаполнитьЗначенияСвойств(стр,Запись);
	КонецЦикла;
	возврат ТЗ;
КонецФункции	
