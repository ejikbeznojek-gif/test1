Процедура Объект_ПередЗаписью(Источник, Отказ)
	Если ПараметрыСеанса.ОтключитьЖурнализациюЗаписи Тогда Возврат КонецЕсли;	
	Если Отказ Тогда Возврат КонецЕсли;
	
	//+++Чирков 25.05.2025 - в некоторых документах выполняется куча действий в процедуре "ПередЗаписью"
	//лучше Начало ставить там
	//Источник.ДополнительныеСвойства.Вставить("Начало",ТекущаяУниверсальнаяДатаВМиллисекундах());
	Если НЕ Источник.ДополнительныеСвойства.Свойство("Начало") Тогда	
		Источник.ДополнительныеСвойства.Вставить("Начало",ТекущаяУниверсальнаяДатаВМиллисекундах());
	КонецЕсли;	
	//---Чирков 25.05.2025 - в некоторых документах выполняется куча действий в процедуре "ПередЗаписью"
	Если Источник.ДополнительныеСвойства.Свойство("ОтключитьЖурнализациюЗаписи") Тогда Возврат КонецЕсли;
	
	Загрузка	= Источник.ОбменДанными.Загрузка;
	Отправитель = Неопределено;
	
	Если Загрузка Тогда
		Отправитель=Источник.ОбменДанными.Отправитель;
		Если НЕ ЗначениеЗаполнено(Отправитель) Тогда
			Отправитель=ПараметрыСеанса.Отправитель;	
		КонецЕсли;
	КонецЕсли;
	
	Источник.ДополнительныеСвойства.Вставить("ПараметрыЗагрузки",	Новый Структура("Загрузка,Отправитель",Загрузка,Отправитель));	
	Источник.ДополнительныеСвойства.Вставить("НачальноеСостояние",	ПолучитьСостояниеОбъекта(Источник.Ссылка,Источник.Модифицированность()));	
КонецПроцедуры

