Процедура УдалениеСвязанныхДокументовРНК_ПНК(Источник, Отказ) Экспорт
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если Источник.ПометкаУдаления Тогда
		//++Данилова Е.В. 27.10.2025  HELP-7587 
		Если Источник.ДополнительныеСвойства.Свойство("НепомечатьПодчиненные")
			И Источник.ДополнительныеСвойства.НепомечатьПодчиненные = Истина Тогда
			
			Возврат; 	
			
		КонецЕсли;
		//--Данилова Е.В. 27.10.2025
		МассивПодчиненных = Новый Массив;
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Документы.Ссылка КАК Ссылка
		|ИЗ
		|	КритерийОтбора.СвязанныеДокументыПНК_РНК(&ДокОснование) КАК Документы
		|ГДЕ
		|	НЕ Документы.Ссылка.ПометкаУдаления";
		
		УстановитьПривилегированныйРежим(Истина);
		
		Запрос.УстановитьПараметр("ДокОснование", Источник.Ссылка);

		Выборка = Запрос.Выполнить().Выбрать();
		
		ПараметрыСеанса.ЗапущенаОбработка = Истина;
		//++Данилова Е.В. 27.10.2025  HELP-7587 
		//НачатьТранзакцию();
		//--Данилова Е.В. 27.10.2025
		Пока Выборка.Следующий() Цикл
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			Если ДокОбъект <> Неопределено Тогда
				Попытка
					ДокОбъект.УстановитьПометкуУдаления(Истина);
					Если ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.РекламационнаяНакладная") Тогда
						МассивПодчиненных.Добавить(ДокОбъект.Ссылка);	
					КонецЕсли;
				Исключение
					СообщитьИзМодуля(ИнформацияОбОшибке());
					ПараметрыСеанса.ЗапущенаОбработка = Ложь;
					//++Данилова Е.В. 27.10.2025  HELP-7587
					//ОтменитьТранзакцию();
					//--Данилова Е.В. 27.10.2025
					Возврат;
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
		
		Если МассивПодчиненных.Количество() > 0 Тогда
			Для Каждого ЭлементСсылка Из МассивПодчиненных Цикл
				
				Запрос.УстановитьПараметр("ДокОснование", ЭлементСсылка);
				
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
					Если ДокОбъект <> Неопределено Тогда
						Попытка
							ДокОбъект.УстановитьПометкуУдаления(Истина);
						Исключение
							СообщитьИзМодуля(ИнформацияОбОшибке());
							ПараметрыСеанса.ЗапущенаОбработка = Ложь; 
							//++Данилова Е.В. 27.10.2025  HELP-7587
							//ОтменитьТранзакцию();
							//--Данилова Е.В. 27.10.2025
							Возврат;
						КонецПопытки;
					КонецЕсли;
				КонецЦикла;
				
			КонецЦикла;
		КонецЕсли;
		
		ПараметрыСеанса.ЗапущенаОбработка = Ложь;
		//++Данилова Е.В. 27.10.2025  HELP-7587
		//ЗафиксироватьТранзакцию();
		//--Данилова Е.В. 27.10.2025
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;

КонецПроцедуры

