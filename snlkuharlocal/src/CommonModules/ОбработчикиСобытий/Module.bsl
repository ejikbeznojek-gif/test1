Процедура ЗаписьРегистраСведенийПередЗаписью(Источник, Отказ, Замещение) Экспорт
	//если замещение тогда 
	//	сообщить ("Замещение");
	//иначе
	//	Сообщить("Не замещение");
	//КонецЕсли;   
	
	попытка	
		ОбменДанными=Источник.ОбменДанными;	
	Исключение
		ОбменДанными=Неопределено;
	КонецПопытки;
	
	
	если ОбменДанными<>Неопределено тогда
		загрузка=ОбменДанными.загрузка;
	иначе
		загрузка=ложь;
	КонецЕсли;
	
	//Кухарь 20.11.17 начало
	//На складе и без того всё висит.
	если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.Склад тогда
		//Кухарь 20.11.17 конец		
		СтароеЗначение=ПолучитьСтароеЗначение(Источник);
		Для каждого стр из СтароеЗначение Цикл 
			ЗаписатьВЖурналИзмененийРеквизитов(стр.Документ,стр.ИмяРеквизита,стр.ЗначениеРеквизита,0,ОбменДанными,Истина,источник);
		КонецЦикла;
		если не Замещение или загрузка тогда
			Для Каждого Запись Из источник Цикл
				ЗаписатьВЖурналИзмененийРеквизитов(Запись.Документ,запись.ИмяРеквизита,"",Запись.ЗначениеРеквизита,ОбменДанными,ложь,источник);
			КонецЦикла; 
		КонецЕсли;
		//Кухарь 20.11.17 начало
		//На складе и без того всё висит.
	КонецЕсли;
	//Кухарь 20.11.17 конец		
	
