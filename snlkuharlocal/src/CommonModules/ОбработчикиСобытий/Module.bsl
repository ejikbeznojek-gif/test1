	//+++Чирков 04.04.2025
	ОценкаПроизводительностиКлиентСервер.ЗаписатьЗамерПроизводительности_ПриЗаписи(Источник);
	//---Чирков 04.04.2025
	
	НачальноеСостояние=Неопределено;
	Если Источник.ДополнительныеСвойства.Свойство("НачальноеСостояние", НачальноеСостояние) Тогда
		РежимЗаписи = МаркировкаКС.ПолучитьЗначениеПараметра(Источник.ДополнительныеСвойства, "РежимЗаписи");
		
		ЗаписатьИзмененияВЖурнал(Источник.Ссылка, НачальноеСостояние, Источник.ДополнительныеСвойства.ПараметрыЗагрузки, Новый Структура("РежимЗаписи", РежимЗаписи));
	КонецЕсли;	
КонецПроцедуры

