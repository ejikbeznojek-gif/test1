Процедура РНК_ПодтвержденныйЗаказПриЗаписи(Источник, Отказ) Экспорт
	//+++Чирков Свертка. НИЧЕГО НЕ ВСТАВЛЯТЬ ПЕРЕД ЭТОЙ СТРОКОЙ !!!
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли;
	//---Чирков Свертка.
	
	Если НЕ ЗначениеЗаполнено(Источник.ДокОснование) Тогда Возврат; КонецЕсли;
	Если Отказ Тогда Возврат; КонецЕсли;
	
	Если ТипЗнч(Источник.ДокОснование) <> Тип("ДокументСсылка.Заказ") Тогда
		Возврат;
	КонецЕсли;
	//++Данилова Е.В. 26.08.2024
	b2b_ОбменЗаявками.ОтработатьОтгрузкуРНК(Источник.ссылка); 
	//--Данилова Е.В. 26.08.2024
	
	Если ЗначениеРеквизитаОбъекта(Источник.ДокОснование, "СостояниеНакладной") <> Перечисления.СостоянияЗаказаКонтрагента.ВРаботе Тогда
		Возврат;
	КонецЕсли;    
	
	// Кухарь А.Ю.  08.11.2023 начало
	//
	если ТипЗнч(Источник)= Тип("ДокументОбъект.Перемещение")  тогда
		Если Источник.склад <> ПолучитьРеквизитШапки(Источник.ДокОснование,"Склад","Документ")  тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	// Кухарь А.Ю.  08.11.2023 конец
	
	
	
	// Кухарь А.Ю.  29.08.2023 начало
	// 	Документы.Заказ.ОбработатьЗаказПриСозданииРНК(Источник.ДокОснование);	
	если не Источник.ПометкаУдаления тогда 		
		Документы.Заказ.ОбработатьЗаказПриСозданииРНК(Источник.ДокОснование,Источник.ссылка); 
	КонецЕсли; 
	// Кухарь А.Ю.  29.08.2023 конец
	
	
КонецПроцедуры
