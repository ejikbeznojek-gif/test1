// Функция возвращает значение по умолчанию для передаваемого пользователя и настройки.
//
// Параметры:
//  Пользователь - текущий пользователь программы
//  Настройка    - признак, для которого возвращается значение по умолчанию
//
// Возвращаемое значение:
//  Значение по умолчанию для настройки.
//
Функция ПолучитьЗначениеПоУмолчанию(Настройка,Знач Пользователь=Неопределено,Рекурсивно=Истина) Экспорт

	Пользователь=?(Пользователь=Неопределено,ПараметрыСеанса.Пользователь,Пользователь); 
	
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Настройка"   , ПланыВидовХарактеристик.НастройкиПользователей[Настройка]);

	Запрос.Текст = "
		|ВЫБРАТЬ
		|	Значение
		|ИЗ
		|	РегистрСведений.НастройкиПользователей КАК РегистрЗначениеПрав
		|
		|ГДЕ
		|	Пользователь = &Пользователь
		| И Настройка    = &Настройка
		|";

	Выборка = Запрос.Выполнить().Выбрать();

	ПустоеЗначение = ПланыВидовХарактеристик.НастройкиПользователей[Настройка].ТипЗначения.ПривестиЗначение();
	
	Если Выборка.Следующий() И НЕ ЗначениеНеЗаполнено(Выборка.Значение) Тогда
		Возврат Выборка.Значение;	
	ИначеЕсли Пользователь<>Справочники.Пользователи.НастройкиПоУмолчанию И Рекурсивно Тогда
		Возврат ПолучитьЗначениеПоУмолчанию(Настройка,Справочники.Пользователи.НастройкиПоУмолчанию);
	Иначе
		Возврат ПустоеЗначение;		
	КонецЕсли;
КонецФункции // ПолучитьЗначениеПоУмолчанию()

Функция ПолучитьПолномочиеПользователя(Знач ПолномочиеВход,Знач Пользователь=Неопределено) Экспорт
	
	Если ТипЗнч(ПолномочиеВход) = Тип("Строка") Тогда
		
		Успешно = ОбщегоНазначения_ПИ.СуществуетПолномочие(ПолномочиеВход);
		
		Если НЕ Успешно Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Полномочие = ПланыВидовХарактеристик.ПолномочияПользователей[ПолномочиеВход];
		ПустоеЗначение = Полномочие.ТипЗначения.ПривестиЗначение();
		
		Если Полномочие.Пустая() Тогда
			Возврат ПустоеЗначение;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ПолномочиеВход) = Тип("ПланВидовХарактеристикСсылка.ПолномочияПользователей") Тогда
		
		Полномочие = ПолномочиеВход;
		ПустоеЗначение = Полномочие.ТипЗначения.ПривестиЗначение();
		
	КонецЕсли;	
	
	Пользователь=?(Пользователь=Неопределено, ПараметрыСеанса.Пользователь,Пользователь);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Полномочие"   , Полномочие);

	Запрос.Текст = "
		|ВЫБРАТЬ
		|	Значение
		|ИЗ
		|	РегистрСведений.ПолномочияПользователей КАК РегистрЗначениеПрав
		|
		|ГДЕ
		|	Пользователь = &Пользователь
		| И Полномочие    = &Полномочие
		|";

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат ПустоеЗначение;
	ИначеЕсли Выборка.Следующий() Тогда
		Если ЗначениеНеЗаполнено(Выборка.Значение) Тогда
			Возврат ПустоеЗначение;
		Иначе
			Возврат Выборка.Значение;
		КонецЕсли;
	Иначе
		Возврат ПустоеЗначение;
	КонецЕсли;

КонецФункции


