Функция ПолучитьСуммуДенежныхСредствВКассе(ФискальноеУстройство) Экспорт
	СуммаВКассе = 0;
	
	ДанныеККТ	= ПолучитьПараметрыККТ(ФискальноеУстройство);
	
	Если ДанныеККТ.Успешно И ДанныеККТ.Свойство("Данные") Тогда
		СуммаВКассе	= XMLЗначение(Тип("Число"), СтрЗаменить(ДанныеККТ.Данные.ПараметрыСмены.ОстатокНаличных, ",", "."));
	КонецЕсли;
	
	Возврат СуммаВКассе;
КонецФункции


Функция ВыемкаВнесениеДенежныхСредств(ФискальноеУстройство, ВидОперации, СуммаОперации = Неопределено)
	Результат = Новый Структура("Успешно,Ошибки,СуммаОперации", Ложь, "", 0);
	
	СуммаВКассе = ПолучитьСуммуДенежныхСредствВКассе(ФискальноеУстройство);
	
	Если СуммаОперации = Неопределено Тогда
		СуммаОперации = СуммаВКассе;
		Если НЕ ВвестиЧисло(СуммаОперации, Строка(ВидОперации), 15, 2) Тогда
			Возврат Результат;		
		КонецЕсли;		
	КонецЕсли;
	
	Если СуммаОперации = Неопределено Или СуммаОперации <= 0 Тогда
		Результат.Ошибки = "Введите значение суммы операции!";
		Возврат Результат;
	КонецЕсли;
	
	Если ВидОперации = "Выемка" И СуммаОперации > СуммаВКассе Тогда
		Результат.Ошибки = "Сумма выемки не может быть больше остатка в кассе!";
		Возврат Результат;
	КонецЕсли;
	
	Если ВидОперации = "Выемка" Тогда
		РезультатОперации = ВыемкаДенежныхСредств(ФискальноеУстройство, СуммаОперации);
	ИначеЕсли ВидОперации = "Внесение" Тогда
		РезультатОперации = ВнесениеДенежныхСредств(ФискальноеУстройство, СуммаОперации);
	КонецЕсли;
	
	РезультатОперации.Вставить("СуммаОперации", СуммаОперации);
	
	Возврат РезультатОперации;
	
КонецФункции

Функция ВыемкаДенежныхСредств(ФискальноеУстройство, СуммаОперации)
	
	Результат = Новый Структура("Успешно, Ошибки", Ложь, "");
	
	РезультатПодключения = МенеджерОборудованияКлиент.ПроверитьПодключитьОборудование(ФискальноеУстройство);
	
