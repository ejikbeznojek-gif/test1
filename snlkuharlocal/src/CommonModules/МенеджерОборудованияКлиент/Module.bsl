		Результат.Ошибки = РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	РевизияИнтерфейса		= МенеджерОборудованияКлиент.РевизияИнтерфейса(ФискальноеУстройство);
	ОбъектДрайвера			= МенеджерОборудованияКлиент.ПолучитьОбъектДрайвера(ФискальноеУстройство);
	ИД_Устройства			= МенеджерОборудованияКлиент.ИдентификаторПодключенногоОборудования(ФискальноеУстройство);
	ВходныеПараметрыXML		= ВходныеПараметрыXML(Новый Структура, РевизияИнтерфейса);

	Попытка
		РезультатДрайвера = ОбъектДрайвера.НапечататьЧекВнесенияВыемки(ИД_Устройства, ВходныеПараметрыXML, -СуммаОперации);
		Если РезультатДрайвера Тогда
			Результат.Успешно = Истина;
		Иначе
			ОбъектДрайвера.ПолучитьОшибку(Результат.Ошибки);
		КонецЕсли;
	Исключение
		Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.НапечататьЧекВнесенияВыемки>.'") + Символы.ПС + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ВнесениеДенежныхСредств(ФискальноеУстройство, СуммаОперации)
	Возврат ВыемкаДенежныхСредств(ФискальноеУстройство, -СуммаОперации);
КонецФункции

Функция ПечатьСлипЧека(ФискальноеУстройство, ТекстСлипЧека, КоличествоСлипЧеков)
	
	Результат = Новый Структура("Успешно,Ошибки", Ложь, "");	
	
	РезультатПодключения	= МенеджерОборудованияКлиент.ПроверитьПодключитьОборудование(ФискальноеУстройство);
	Если НЕ РезультатПодключения.Успешно Тогда
		Результат.Ошибки=РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ИДУстройства			= МенеджерОборудованияКлиент.ИдентификаторПодключенногоОборудования(ФискальноеУстройство);
	РевизияИнтерфейса		= МенеджерОборудованияКлиент.РевизияИнтерфейса(ФискальноеУстройство);
	ОбъектДрайвера			= МенеджерОборудованияКлиент.ПолучитьОбъектДрайвера(ФискальноеУстройство);	
	
	ДанныеСлипЧекаXML		= ПолучитьXMLДляПечатиСлипЧеков(ТекстСлипЧека, РевизияИнтерфейса);
	
	Для НомерСлипЧека = 1 По КоличествоСлипЧеков Цикл
		Попытка
			Результат.Успешно = ОбъектДрайвера.НапечататьТекстовыйДокумент(ИДУстройства, ДанныеСлипЧекаXML);
			Если НЕ Результат.Успешно Тогда				
				ОбъектДрайвера.ПолучитьОшибку(Результат.Ошибки);
			КонецЕсли;
		Исключение		
			Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.НапечататьТекстовыйДокумент>.'") + Символы.ПС + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	
	Возврат Результат;	
	
КонецФункции

Функция ПолучитьXMLДляПечатиСлипЧеков(ТекстСлипЧека, РевизияИнтерфейса) Экспорт
	
	// формируем пакет для печати подарочных сертификатов
	ЗаписьXML = Новый ЗаписьXML();
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("Document");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Positions");
	
	Для НомерСтроки = 1 По СтрЧислоСтрок(ТекстСлипЧека) Цикл
			
