Функция КонтрольнаяЛента()
	
	Результат = Новый Структура("Успешно,Ошибки", Ложь, "");

	ТекстКвитанции = "";
	
	Попытка
		ОбъектДрайвера = Новый COMОбъект("SBRFSRV.Server");
	Исключение
		Результат.Ошибки = "Ошибка при подключении библиотеки sbrf.dll" + Символы.ПС + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	
	РезультатОперации = ОбъектДрайвера.NFun(7000);
	
	Попытка
		Если РезультатОперации = 0 Тогда
			
			ТекстСлипЧека	= ОбъектДрайвера.GParamString("Cheque");
			ТекстСлипЧека2	= ОбъектДрайвера.GParamString("Cheque1251");
			
			СтрокаПоиска = ?(Найти(ТекстСлипЧека, "=" + Символы.ПС) > 0, "=" + Символы.ПС, "=" + Символы.ВК);
			ТекстСлипЧека = Лев(ТекстСлипЧека, Найти(ТекстСлипЧека, СтрокаПоиска));
			
			Результат.Вставить("ТекстКвитанции", ТекстСлипЧека);
			Результат.Успешно = Истина;
			
		Иначе
			Результат.Ошибки = "Ошибка при получении контрольной ленты, код ошибки " + Строка(РезультатОперации);
		КонецЕсли;
