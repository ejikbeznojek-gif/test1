			ПараметрыККТ.КодыСистемыНалогообложения = ЧтениеXML.ЗначениеАтрибута("TaxationSystems");
			ПараметрыККТ.ПризнакАвтономногоРежима   = ВРег(ЧтениеXML.ЗначениеАтрибута("IsOffline")) = "TRUE";
			ПараметрыККТ.ПризнакШифрованиеДанных    = ВРег(ЧтениеXML.ЗначениеАтрибута("IsEncrypted")) = "TRUE";
			ПараметрыККТ.ПризнакРасчетовЗаУслуги    = ВРег(ЧтениеXML.ЗначениеАтрибута("IsService")) = "TRUE";
			ПараметрыККТ.ПродажаПодакцизногоТовара  = ВРег(ЧтениеXML.ЗначениеАтрибута("IsExcisable")) = "TRUE";
			ПараметрыККТ.ПроведенияАзартныхИгр      = ВРег(ЧтениеXML.ЗначениеАтрибута("IsGambling")) = "TRUE";
			ПараметрыККТ.ПроведенияЛотерей          = ВРег(ЧтениеXML.ЗначениеАтрибута("IsLottery")) = "TRUE";
			ПараметрыККТ.ПризнакиАгента             = ЧтениеXML.ЗначениеАтрибута("AgentTypes");
			ПараметрыККТ.ПризнакФормированияБСО         = ВРег(ЧтениеXML.ЗначениеАтрибута("BSOSing")) = "TRUE";
			ПараметрыККТ.ПризнакРасчетовТолькоВИнтернет = ВРег(ЧтениеXML.ЗначениеАтрибута("IsOnlineOnly")) = "TRUE";
			ПараметрыККТ.УстановкаПринтераВАвтомате     = ВРег(ЧтениеXML.ЗначениеАтрибута("IsAutomaticPrinter")) = "TRUE";;
			ПараметрыККТ.ПризнакАвтоматическогоРежима   = ВРег(ЧтениеXML.ЗначениеАтрибута("IsAutomatic")) = "TRUE";
			ПараметрыККТ.НомерАвтоматаДляАвтоматическогоРежима = ЧтениеXML.ЗначениеАтрибута("AutomaticNumber");
			ПараметрыККТ.ОрганизацияОФДНазвание     = ЧтениеXML.ЗначениеАтрибута("OFDCompany");
			ПараметрыККТ.ОрганизацияОФДИНН          = СокрЛП(ЧтениеXML.ЗначениеАтрибута("OFDCompanyINN"));
			ПараметрыККТ.ПризнакФискализации        = ВРег(ЧтениеXML.ЗначениеАтрибута("Fiscal")) = "TRUE";
			ПараметрыККТ.НомерДокументаФискализации = ЧтениеXML.ЗначениеАтрибута("DocumentNumber");
			ПараметрыККТ.ДатаВремяФискализации      = ЧтениеXML.ЗначениеАтрибута("DateTime");
			ПараметрыККТ.ОтправительEmail           = ЧтениеXML.ЗначениеАтрибута("SenderEmail");
			ПараметрыККТ.АдресСайтаФНС              = ЧтениеXML.ЗначениеАтрибута("FNSURL");
		КонецЕсли;
		
	Иначе
		
		Если ЧтениеXML.Имя = "Parameters" И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
			ПараметрыККТ.ВерсияФФДФН   = ЧтениеXML.ЗначениеАтрибута("FFDVersionFN");
