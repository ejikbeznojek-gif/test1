Функция ВыполнитьКомандуККМ(Команда, ФискальноеУстройство, ЭквайринговыйТерминал, КассоваяСмена, СуммаОперации = Неопределено, ПоказыватьСообщения = Истина) Экспорт
				
	Если НЕ ЗначениеЗаполнено(ФискальноеУстройство) Тогда
		ПоказатьПредупреждение(, "Не указан фискальный регистратор! Невозможно выполнить операции с ККМ!");
		Возврат Неопределено;
	КонецЕсли;
	
	ТекстСообщения			= "";
	РезультатФискализации	= Неопределено;
	
	Если Команда = "СнятьXОтчет" Тогда
		РезультатФискализации = СнятьХОтчет(ФискальноеУстройство);
		Если Не РезультатФискализации.Успешно Тогда
			ТекстСообщения = "Не удалось снять Х-отчет!" + Символы.ПС + РезультатФискализации.Ошибки;
		Иначе
			ТекстСообщения = "Снят Х-отчет (без гашения)";
		КонецЕсли;
		
	ИначеЕсли Команда = "ОткрытьДенежныйЯщик" Тогда
		РезультатФискализации = ОткрытьДенежныйЯщик(ФискальноеУстройство);
		Если Не РезультатФискализации.Успешно Тогда
			ТекстСообщения = "Не открыть денежный ящик!" + Символы.ПС + РезультатФискализации.Ошибки;
		Иначе
			ТекстСообщения = "Открыт денежный ящик";
		КонецЕсли;
		
	ИначеЕсли Команда = "ОткрытьСмену" Тогда
		// проверим, что предыдущая кассовая смена закрыта
		СтатусПоследнейСмены = СтатусПоследнейСмены(ФискальноеУстройство);
		Если СтатусПоследнейСмены.Открыта Тогда
			// не закрыли крайнюю смену в 1С
			ТекстСообщения = "Необходимо закрыть кассовую смену в 1С !";
			РезультатФискализации = Новый Структура("Успешно,Ошибки", Ложь, ТекстСообщения);
		Иначе
			// крайняя смена закрыта, пробуем открыть новую смену
			РезультатФискализации = ОткрытьСмену(ФискальноеУстройство);
			Если Не РезультатФискализации.Успешно Тогда
				ТекстСообщения = "Не удалось открыть кассовую смену!" + Символы.ПС + РезультатФискализации.Ошибки;
			Иначе
				КассоваяСмена = ОткрытьСменуНаСервере(РезультатФискализации, ФискальноеУстройство);
				ТекстСообщения = "На фискальном устройстве открыта кассовая смена"; 
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Команда = "ЗакрытьСмену" Тогда
		
		// проверим, что в кассе не осталось наличных
		ОстатокФР = ПолучитьСуммуДенежныхСредствВКассе(ФискальноеУстройство);
		Если ОстатокФР > 0 Тогда
			РезультатФискализации = Новый Структура("Успешно,Ошибки", Ложь, "В кассе остались наличные, необходимо произвести выемку!");
		Иначе
			// закрываем смену на устройстве
			РезультатФискализации	= ЗакрытьСмену(ФискальноеУстройство);
		КонецЕсли;
		
		// печатаем отчет эквайринга, если подключен эквайринговый терминал
		Если Не ЭквайринговыйТерминал.Пустая() И РезультатФискализации.Успешно Тогда
			РезультатИтогиДня = ИтогиДня(ЭквайринговыйТерминал);
			Если РезультатИтогиДня.Успешно И Не ПустаяСтрока(РезультатИтогиДня.ТекстКвитанции) Тогда
				РезультатПечатиСлипЧеков = ПечатьСлипЧека(ФискальноеУстройство, РезультатИтогиДня.ТекстКвитанции, 1);
				РезультатФискализации.Вставить("ТекстСлипЧека", РезультатИтогиДня.ТекстКвитанции);
			Иначе
				РезультатФискализации.Вставить("ТекстСлипЧека", "");
			КонецЕсли;
		Иначе
			РезультатФискализации.Вставить("ТекстСлипЧека", "");
		КонецЕсли;
		
		Если Не РезультатФискализации.Успешно Тогда
			ТекстСообщения = "Не удалось закрыть кассовую смену!" + Символы.ПС + РезультатФискализации.Ошибки;
		Иначе
			// доступна смешанная оплата, создаем один ОКС
			ОКС_Ссылка = Документы.ОтчетКассовойСмены.СоздатьОКС(РезультатФискализации, КассоваяСмена);	
			Если ЗначениеЗаполнено(ОКС_Ссылка) Тогда
				ПараметрыФормы = Новый Структура("Ссылка", ОКС_Ссылка);
				ОткрытьФорму("Документ.ОтчетКассовойСмены.Форма.ФормаКонтрольныеПоказатели", ПараметрыФормы,,,,,, РежимОткрытияОкнаФормы.Независимый);
			Иначе
				ТекстСообщения = "За кассовую смену не было пробито чеков. ОКС не создан!";
			КонецЕсли;
		КонецЕсли;
		
		
		
	ИначеЕсли Команда = "ВыемкаНаличных" Тогда
		
		рФискализации = ВыемкаВнесениеДенежныхСредств(ФискальноеУстройство, "Выемка", СуммаОперации);
		Если рФискализации.Успешно Тогда
			////создать документ ПКО, из кассы в сейф
			//пФункции = Новый Структура;
			//пФункции.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПереводДенежныхСредств.ПереводДенегВСейф"));
			//пФункции.Вставить("СуммаОперации",	РезультатФискализации.СуммаОперации);
			//
			//рСозданияДокумента = ШлюзВызовСервера.ВызватьФункциюМенеджера("Документы.ПеремещениеДенежныхСредств", "СоздатьДокументПеремещениеДС", ПараметрыФункции);
			//
			//Если рСозданияДокумента.Успешно Тогда
			//	ТекстСообщения = "Создан документ Перемещение денежных средств (выемка) на сумму #СуммаОперации# руб.";
			//	ТекстСообщения = СтрЗаменить(ТекстСообщения, "#СуммаОперации#", Формат(РезультатФискализации.СуммаОперации, "ЧДЦ=2; ЧН=0,00"));
			//Иначе				
			//	ТекстСообщения = "Ошибка при создании документа Перемещение денежных средств!";				
			//КонецЕсли;																						
		Иначе			
			ТекстСообщения = "Не удалось произвести выемку денежных средств!" + Символы.ПС + РезультатФискализации.Ошибки;			
		КонецЕсли;		
	ИначеЕсли Команда.Имя = "ВнесениеНаличных" Тогда
		РезультатФискализации = ВыемкаВнесениеДенежныхСредств(ФискальноеУстройство, "Внесение", СуммаОперации);
		Если Не РезультатФискализации.Успешно Тогда
			ТекстСообщения = "Не удалось произвести внесение денежных средств!" + Символы.ПС + РезультатФискализации.Ошибки;
		Иначе
			//создать документ РКО, из сейфа в кассу
			ПараметрыФункции = Новый Структура;
			ПараметрыФункции.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПереводДенежныхСредств.ВыдачаДенегИзСейфа"));
			ПараметрыФункции.Вставить("СуммаОперации",	РезультатФискализации.СуммаОперации);
			
			рСозданияДокумента = Документы.ПереводСредств.СоздатьДокументПеремещениеДС(ПараметрыФункции);
			
			Если рСозданияДокумента = Неопределено Тогда
				ТекстСообщения = "Ошибка при создании документа Перемещение денежных средств!";
			Иначе
				ТекстСообщения = "Создан документ Перемещение денежных средств (внесение) на сумму #СуммаОперации# руб.";
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "#СуммаОперации#", Формат(РезультатФискализации.СуммаОперации, "ЧДЦ=2; ЧН=0,00"));
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Команда = "ИтогиДняПоКартам" Тогда
		Если ЭквайринговыйТерминал.Пустая() Тогда
			ТекстСообщения = "Не подключен эквайринговый терминал!";
		Иначе
			РезультатИтогиДня = ИтогиДня(ЭквайринговыйТерминал);
			Если РезультатИтогиДня.Успешно И Не ПустаяСтрока(РезультатИтогиДня.ТекстКвитанции) Тогда
				РезультатПечатиСлипЧеков = ПечатьСлипЧека(ФискальноеУстройство, РезультатИтогиДня.ТекстКвитанции, 1);
				ТекстСообщения = "Сняты итоги дня по картам";
			ИначеЕсли Не РезультатИтогиДня.Успешно Тогда
				ТекстСообщения = РезультатИтогиДня.Ошибки;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Команда = "АварийнаяОтменаОперации" Тогда
		
		РезультатВопроса = Вопрос("Выполнить аварийную отмену последней операции по эквайринговому терминалу?", РежимДиалогаВопрос.ДаНет);
		
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
			Если ЭквайринговыйТерминал.Пустая() Тогда
				ТекстСообщения = "Не подключен эквайринговый терминал!";
			Иначе
				РезультатАварийнаяОтмена = АварийнаяОтменаОперации(ЭквайринговыйТерминал);
				Если РезультатАварийнаяОтмена.Успешно Тогда
					ТекстСообщения = "Выполнена аварийная отмена последней операции!";
				Иначе
					ТекстСообщения = РезультатАварийнаяОтмена.Ошибки;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Команда = "КонтрольнаяЛента" Тогда
		Если ЭквайринговыйТерминал.Пустая() Тогда
			ТекстСообщения = "Не подключен эквайринговый терминал!";
		Иначе
			РезультатКонтрольнаяЛента = КонтрольнаяЛента();
			Если РезультатКонтрольнаяЛента.Успешно И Не ПустаяСтрока(РезультатКонтрольнаяЛента.ТекстКвитанции) Тогда
				РезультатПечатиСлипЧеков = ПечатьСлипЧека(ФискальноеУстройство, РезультатКонтрольнаяЛента.ТекстКвитанции, 1);
				ТекстСообщения = "Напечатана контрольная лента эквайрингового терминала";
			ИначеЕсли Не РезультатКонтрольнаяЛента.Успешно Тогда
				ТекстСообщения = РезультатКонтрольнаяЛента.Ошибки;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ПустаяСтрока(ТекстСообщения) Тогда
		Если ПоказыватьСообщения Тогда
			ПоказатьПредупреждение(, ТекстСообщения, 5);
		КонецЕсли;
	КонецЕсли;
	
	Если МаркировкаКС.ПолучитьЗначениеПараметра(РезультатФискализации, "Успешно", Ложь) = Истина Тогда
		//Оповестить(ОбщегоНазначенияКлиент.ИмяСобытияИзменениеСостоянияКассовойСмены(), РезультатФискализации);
		//Оповестить(ОбщегоНазначенияКлиент.ИмяСобытияОбновитьОстаткиДенежныхСредств(), РезультатФискализации);
	КонецЕсли;
	
	Возврат РезультатФискализации;
	
КонецФункции

#Область Открытие_смены

Функция ОткрытьСмену(ФискальноеУстройство)
	
	Результат = Новый Структура("Успешно,Ошибки", Ложь, "");	
	
	РезультатПодключения = МенеджерОборудованияКлиент.ПроверитьПодключитьОборудование(ФискальноеУстройство);
	Если Не РезультатПодключения.Успешно Тогда
		Результат.Ошибки = РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ВходныеПараметры = ПолучитьВходныеПараметры_ККМ();
	
	Кассир			= ВходныеПараметры.Кассир;
	КассирИНН		= ВходныеПараметры.КассирИНН;
	
	Если Не ПроверитьИННКассира(КассирИНН, Результат.Ошибки) Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	НомерСмены     	= 0;
	НомерДокумента 	= 0;
	ПараметрыСмены	= Неопределено;	
		
	РевизияИнтерфейса	= МенеджерОборудованияКлиент.РевизияИнтерфейса(ФискальноеУстройство);
	ОбъектДрайвера		= МенеджерОборудованияКлиент.ПолучитьОбъектДрайвера(ФискальноеУстройство);		
	
	МенеджерОборудованияКлиент.ПроверитьДемоРежим(ОбъектДрайвера);
	
	ИД_Устройства		= МенеджерОборудованияКлиент.ИдентификаторПодключенногоОборудования(ФискальноеУстройство);
	
	// Получить параметры ККТ при открытии смены.
	ПараметрыККТ_XML = "";
	Попытка		
		Если НЕ ОбъектДрайвера.ПолучитьПараметрыККТ(ИД_Устройства, ПараметрыККТ_XML) Тогда
			ОписаниеОшибки = "";
			ОбъектДрайвера.ПолучитьОшибку(ОписаниеОшибки); 
			Результат.Ошибки = "Ошибка результата метода <ОбъектДрайвера.ПолучитьПараметрыККТ>. " + Символы.ПС + ОписаниеОшибки;
			Возврат Результат;
		КонецЕсли;
	Исключение		
		Результат.Ошибки	= НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ПолучитьПараметрыККТ>.'") + Символы.ПС + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	
	ПараметрыККТ = МенеджерОборудованияКлиент.ПараметрыККТИзXMLПакета(ПараметрыККТ_XML, РевизияИнтерфейса);
	
	Вход 	= ВходныеПараметрыXML(ВходныеПараметры, РевизияИнтерфейса);
	Выход   = "";
	
	Попытка
		
		Если РевизияИнтерфейса >= 3000 Тогда // Версия стандарта 3.0 (ОФД 1.1)
			РезультатДрайвера = ОбъектДрайвера.ПолучитьТекущееСостояние(ИД_Устройства, Вход, Выход); 
			Если РезультатДрайвера Тогда
				ПараметрыСмены	= МенеджерОборудованияКлиент.ПолучитьПараметрыСменыИзXMLПакета(Выход, РевизияИнтерфейса);	
				
				//Состояние смены
				//1 - Закрыта
				//2 - Открыта
				//3 - Истекла
				
				Если ПараметрыСмены.СтатусСмены = 1 Тогда //Закрыта
					РезультатДрайвера = ОбъектДрайвера.ОткрытьСмену(ИД_Устройства, Вход, Выход);
					Если РезультатДрайвера Тогда
						ФискальныеДанныеСтруктура 	= МенеджерОборудованияКлиент.ПолучитьПараметрыСменыИзXMLПакета(Выход, РевизияИнтерфейса);
						
						НомерСмены     				= ФискальныеДанныеСтруктура.НомерСменыККТ;
						НомерДокумента 				= ФискальныеДанныеСтруктура.НомерЧекаККТ;
						
						Результат.Успешно	 = Истина;			
					КонецЕсли;					
				Иначе
					Результат.Ошибки="Не допустимый текущий статус смены: "+ПараметрыСмены.СтатусСмены;										
				КонецЕсли;				
			КонецЕсли;
			
		Иначе
			
			Результат.Ошибки = "Ревизия интерфейса меньше 3000";
		
		КонецЕсли;
		
	Исключение
		
		Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ОткрытьСмену>.'") + Символы.ПС + ОписаниеОшибки();			
		
	КонецПопытки;
	
	
	Если Результат.Успешно Тогда
		// Заполнение выходных параметров.
		ВыходныеПараметры = Новый Структура();		
		
		ВыходныеПараметры.Вставить("КассаККМ", 				Справочники.Кассы.ПолучитьКассуПоОборудованию(ФискальноеУстройство));
		
		ВыходныеПараметры.Вставить("НомерСмены",			НомерСмены);
		ВыходныеПараметры.Вставить("НомерДокумента",		НомерДокумента);
		ВыходныеПараметры.Вставить("Открыта",				Истина); // 2 - Открыта - Состояние смены  
		ВыходныеПараметры.Вставить("ДатаСеанса",			ТекущаяДата());
		
		ВыходныеПараметры.Вставить("ПараметрыСмены",		ПараметрыСмены);
		ВыходныеПараметры.Вставить("ПараметрыСостояния",	Выход);
		ВыходныеПараметры.Вставить("ПараметрыККТ",			ПараметрыККТ);
		
		Результат.Успешно = Истина;
		Результат.Вставить("Данные", ВыходныеПараметры);
	Иначе		
		Ошибки = "";
		ОбъектДрайвера.ПолучитьОшибку(Ошибки);
		
		Результат.Ошибки = СокрЛП(Результат.Ошибки + "; " + Ошибки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// обертка для вызова функции модуля менеджера
Функция ОткрытьСменуНаСервере(РезультатФискализации, ФискальноеУстройство)
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("ФискальноеУстройство",	ФискальноеУстройство);
	ПараметрыФункции.Вставить("РезультатФискализации",	РезультатФискализации);
	
	//Возврат  Документы.КассоваяСмена.Создать(ПараметрыФункции);
	
	Возврат Неопределено; //Нету тут такого документа
КонецФункции

#КонецОбласти

#Область Закрытие_смены

Функция ЗакрытьСмену(ФискальноеУстройство)
	
	Результат	= Новый Структура("Успешно,Ошибки", Ложь, "");	
	
	РезультатПодключения = МенеджерОборудованияКлиент.ПроверитьПодключитьОборудование(ФискальноеУстройство);
	Если Не РезультатПодключения.Успешно Тогда
		Результат.Ошибки = РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ВходныеПараметры = ПолучитьВходныеПараметры_ККМ();
	
	Кассир				= ВходныеПараметры.Кассир;
	КассирИНН			= ВходныеПараметры.КассирИНН;	
	
	Если Не ПроверитьИННКассира(КассирИНН, Результат.Ошибки) Тогда
		Возврат Результат;	
	КонецЕсли;
	
	НомерСмены     		= 0;
	НомерДокумента		= 0;
	ПараметрыСмены		= Неопределено;
	
	
	РевизияИнтерфейса	= МенеджерОборудованияКлиент.РевизияИнтерфейса(ФискальноеУстройство);
	ОбъектДрайвера		= МенеджерОборудованияКлиент.ПолучитьОбъектДрайвера(ФискальноеУстройство);
	
	МенеджерОборудованияКлиент.ПроверитьДемоРежим(ОбъектДрайвера);
	
	ИД_Устройства		= МенеджерОборудованияКлиент.ИдентификаторПодключенногоОборудования(ФискальноеУстройство);
	
	Вход 				= ВходныеПараметрыXML(ВходныеПараметры, РевизияИнтерфейса);
	Выход				= "";
	
	Попытка
		Если РевизияИнтерфейса >= 3000 Тогда // Версия стандарта 3.0 (ОФД 1.1)
			РезультатДрайвера = ОбъектДрайвера.ЗакрытьСмену(ИД_Устройства, Вход, Выход);
			Если РезультатДрайвера Тогда
				ПараметрыСмены = МенеджерОборудованияКлиент.ПолучитьПараметрыСменыИзXMLПакета(Выход, РевизияИнтерфейса);
				
				НомерСмены     = ПараметрыСмены.НомерСменыККТ;
				НомерДокумента = ПараметрыСмены.НомерЧекаККТ;
				
				Результат.Успешно	= Истина;
			КонецЕсли;
		Иначе
			Результат.Ошибки = "Ревизия интерфейса меньше 3000";
		КонецЕсли;
	Исключение
		Результат.Ошибки = НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ЗакрытьСмену>.'") + Символы.ПС + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;			
		
	Если Результат.Успешно Тогда
		ВыходныеПараметры	= Новый Структура;
		
		ВыходныеПараметры.Вставить("НомерСмены",		НомерСмены);
		ВыходныеПараметры.Вставить("НомерДокумента",	НомерДокумента);
		ВыходныеПараметры.Вставить("СостояниеСмены",	1); // 1 - Закрыта - Состояние смены  
		ВыходныеПараметры.Вставить("ДатаСеанса",		ТекущаяДата());
		ВыходныеПараметры.Вставить("ПараметрыСмены",	ПараметрыСмены);
		ВыходныеПараметры.Вставить("ПараметрыСостояния",Выход);
		
		Результат.Вставить("Данные", ВыходныеПараметры);
		Результат.Успешно = Истина;
	Иначе		
		ОбъектДрайвера.ПолучитьОшибку(Результат.Ошибки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

