Функция ЗапомнитьУстановленныйДрайвер(ДрайверСсылка,ДрайверОбъект) Экспорт
	глПодключаемоеОборудование.ЗагруженныеДрайверы[ДрайверСсылка]=ДрайверОбъект;
КонецФункции //ЗапомнитьУстановленныйДрайвер(ДрайверСсылка,ДрайверОбъект) Экспорт

Функция ЗапомнитьПодключеннноеОборудование(Оборудование,Идентификатор) Экспорт
	глПодключаемоеОборудование.ПодключенноеОборудование.Вставить(Оборудование,Новый Структура("Оборудование,Идентификатор",Оборудование,Идентификатор));
КонецФункции //ЗапомнитьПодключеннноеОборудование(Оборудование,Идентификатор) Экспорт

//Загружает ВК драйвера
//	Создает объект драйвера
//	Возврат Структура("Успешно,ДрайверОбъект,Ошибки",Булево,Addin.Object,Строка)
Функция ПодключитьДрайвер(ДрайверСсылка)	
	РезультатСтруктура	= Новый Структура("Успешно,ДрайверОбъект,Ошибки",Ложь,Неопределено);
	
	Если ДрайверЗагружен(ДрайверСсылка) Тогда
		РезультатСтруктура.Успешно			= Истина;		
		РезультатСтруктура.ДрайверОбъект	= ПолучитьЗагруженныйДрайвер(ДрайверСсылка);	
	Иначе
		Сведения			= ПолучитьРеквизитыШапки(ДрайверСсылка,"ИдентификаторОбъекта,ИмяФайлаДрайвера");
		
		ДрайверНавСсылка 	= ПолучитьНавигационнуюСсылку(ДрайверСсылка, "ЗагруженныйДрайвер");		
		ProgID			 	= Сведения.ИдентификаторОбъекта;
		Части				= СтрРазделить(ProgID,".");	
		ИмяОбъекта			= Части[1];	
		Части.Вставить(1,ИмяОбъекта);		
		
		ProgId_Native	= СтрСоединить(Части,"."); 
		ProgId_COM		= ProgId;
		
		
		Подключено = ПодключитьВнешнююКомпоненту(ДрайверНавСсылка,ИмяОбъекта);
		Если НЕ Подключено Тогда        
			УстановитьВнешнююКомпоненту(ДрайверНавСсылка);        
			
			//+++++ Лепешкин А.В.
			Подключено = ПодключитьВнешнююКомпоненту(ДрайверНавСсылка, ИмяОбъекта);
			//Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(ProgId_COM);
			//----- Лепешкин А.В.
		КонецЕсли;
		
		Если Подключено Тогда
			ДрайверОбъект	= Неопределено;			
			Попытка			
				РезультатСтруктура.ДрайверОбъект	= Новый(ProgId_Native);
				РезультатСтруктура.Успешно			= Истина;
				
				ЗапомнитьУстановленныйДрайвер(ДрайверСсылка,РезультатСтруктура.ДрайверОбъект);
			Исключение
				РезультатСтруктура.Ошибки	= "Не удалось создать объект драйвера: """+ProgId_Native+"""";			
			КонецПопытки;		
		Иначе //А может это дворник был......
			Подключено = ПодключитьВнешнююКомпоненту(ProgId_COM);
			Если Подключено Тогда
				Попытка			
					РезультатСтруктура.ДрайверОбъект	= Новый(ProgId_COM);
					РезультатСтруктура.Успешно			= Истина;
				
					ЗапомнитьУстановленныйДрайвер(ДрайверСсылка,РезультатСтруктура.ДрайверОбъект);
				Исключение
					РезультатСтруктура.Ошибки	= "Не удалось создать объект драйвера: """+ProgId_COM+"""";			
				КонецПопытки;			
			Иначе
				РезультатСтруктура.Ошибки	= "Не удалось подключить внешнюю компоненту: """+Сведения.ИмяФайлаДрайвера+""" !";				
			КонецЕсли;		
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатСтруктура;	
КонецФункции //ПодключитьДрайверТО(ДрайверСсылка)

Функция ДрайверЗагружен(ДрайверСсылка) Экспорт
	Возврат ПолучитьЗагруженныйДрайвер(ДрайверСсылка)<>Неопределено; 
КонецФункции //ДрайверЗагружен(ДрайверСсылка)

Функция ОборудованиеПодключено(Оборудование) Экспорт
	Возврат ПолучитьПодключенноеОборудование(Оборудование)<>Неопределено; 
КонецФункции //ДрайверЗагружен(ДрайверСсылка)

Функция ИдентификаторПодключенногоОборудования(Оборудование) Экспорт
	ПодключенноеОборудование=ПолучитьПодключенноеОборудование(Оборудование);
	
	Идентификатор="";
	Если ПодключенноеОборудование<>Неопределено Тогда
		Идентификатор=ПодключенноеОборудование.Идентификатор;	
	КонецЕсли;
	
	Возврат Идентификатор; 
КонецФункции //ИдентификаторПодключенногоОборудования(Оборудование) Экспорт

Функция ПолучитьЗагруженныйДрайвер(ДрайверСсылка) Экспорт
	ЗагруженныеДрайверы = Неопределено;
	Если НЕ глПодключаемоеОборудование.Свойство("ЗагруженныеДрайверы", ЗагруженныеДрайверы) 
		ИЛИ ТипЗнч(ЗагруженныеДрайверы)<>Тип("Соответствие") Тогда
		
		глПодключаемоеОборудование.Вставить("ЗагруженныеДрайверы", Новый Соответствие);			
	КонецЕсли; 
	
	Возврат глПодключаемоеОборудование.ЗагруженныеДрайверы[ДрайверСсылка];
КонецФункции //ПолучитьЗагруженныйДрайвер(ДрайверСсылка) Экспорт

Функция ПолучитьПодключенноеОборудование(Оборудование) Экспорт
	Если глПодключаемоеОборудование = Неопределено Тогда
		глПодключаемоеОборудование = Новый Структура;	
	КонецЕсли;
	
	ПодключенноеОборудование = МаркировкаКС.ПолучитьЗначениеПараметра(глПодключаемоеОборудование, "ПодключенноеОборудование");
	Если ПодключенноеОборудование = Неопределено Тогда	
		ПодключенноеОборудование = Новый Соответствие;
		глПодключаемоеОборудование.Вставить("ПодключенноеОборудование", ПодключенноеОборудование);		
	КонецЕсли;	
	
	Возврат глПодключаемоеОборудование.ПодключенноеОборудование[Оборудование];
КонецФункции //ПолучитьПодключенноеОборудование(Оборудование) Экспорт

Функция ПолучитьОбъектДрайвера(Оборудование) Экспорт
	ДрайверСсылка	= ПолучитьРеквизитОбъекта(Оборудование, "ДрайверОборудования");
	Возврат  ПолучитьЗагруженныйДрайвер(ДрайверСсылка);
КонецФункции //ПолучитьОбъектДрайвера(Оборудование) Экспорт
 

Функция ОписаниеИзДрайвера(ДрайверОбъект) Экспорт
	РевизияИнтерфейса = 0;
	
	НомерВерсии		= "";
	НомерВерсииИнтеграционногоКомпонента = "";
	Наименование	= "";
	Описание		= "";
	ТипОборудования = "";
	РевизияИнтерфейса = 0;
	ИнтеграционныйКомпонент = Ложь;	
	ОсновнойДрайверУстановлен = Ложь;	
	URLCкачивания	= "";
	
	Попытка		
		//Версии 3003,3002,3001
		
		
		РевизияИнтерфейса = ДрайверОбъект.ПолучитьРевизиюИнтерфейса();			
		
		Если РевизияИнтерфейса=0 Тогда
			Описание = "";
			ДрайверОбъект.ПолучитьОписание(Описание);		
		КонецЕсли; 		

	Исключение			
		Ошибки="";
		ДрайверОбъект.ПолучитьОшибку(Ошибки);
	КонецПопытки;	
	
	Если НЕ ЗначениеЗаполнено(РевизияИнтерфейса) Тогда
		//Не получилось.....видимо версии 2005,2004,2003,2002		
		Попытка
			ДрайверОбъект.ПолучитьОписание(Наименование,Описание,ТипОборудования,РевизияИнтерфейса,ИнтеграционныйКомпонент,ОсновнойДрайверУстановлен,URLCкачивания);
			НомерВерсии	= ДрайверОбъект.ПолучитьНомерВерсии();
		Исключение
			Ошибки="";
			Сообщить(ДрайверОбъект.ПолучитьОшибку(Ошибки));
			Сообщить(Ошибки);
		КонецПопытки;	
	КонецЕсли;
	
	Результат=Новый Структура("РевизияИнтерфейса,НомерВерсии,НомерВерсииИнтеграционногоКомпонента,
		|Наименование,Описание,ТипОборудования,ИнтеграционныйКомпонент,ОсновнойДрайверУстановлен,URLCкачивания",
		РевизияИнтерфейса,НомерВерсии,НомерВерсииИнтеграционногоКомпонента,Наименование,Описание,ТипОборудования,ИнтеграционныйКомпонент,ОсновнойДрайверУстановлен,URLCкачивания);
		
	Если РевизияИнтерфейса>=3000 Тогда
		ОписаниеXML	= "";
		ДрайверОбъект.ПолучитьОписание(ОписаниеXML);					
		
		Поля		= ПолучитьОписаниеДрайвераИзXML(ОписаниеXML);
		ЗаполнитьЗначенияСвойств(Результат,Поля);		
	КонецЕсли;	
	
	ПараметрыДрайвера="";	
	ДрайверОбъект.ПолучитьПараметры(ПараметрыДрайвера);
	
	ДополнительныеДействия="";
	ДрайверОбъект.ПолучитьДополнительныеДействия(ДополнительныеДействия);
	
	Результат.Вставить("ПараметрыДрайвера",			ПараметрыДрайвера);
	Результат.Вставить("ДополнительныеДействия",	ДополнительныеДействия);
		
	Возврат Результат;	
КонецФункции // ()

// Получить описание драйвера из XML пакета.
//
Функция ПолучитьОписаниеДрайвераИзXML(ОписаниеXML) Экспорт
	
	Возврат Справочники.ДрайверыОборудования.ПолучитьОписаниеДрайвераИзXML(ОписаниеXML);
	
	
КонецФункции

Функция ПодключитьДрайверТО(ДрайверСсылка,ПолучитьОписание=Ложь) Экспорт
	
	РезультатПодключения = ПодключитьДрайвер(ДрайверСсылка);	
		
	Если РезультатПодключения.Успешно И ПолучитьОписание Тогда
		РезультатПодключения.Вставить("Описание", ОписаниеИзДрайвера(РезультатПодключения.ДрайверОбъект));	
	КонецЕсли;	
	
	Возврат РезультатПодключения;		
КонецФункции

Функция ТестУстройства(Оборудование) Экспорт	  
КонецФункции // ()

Функция ПодключитьОборудование(Оборудование) Экспорт	
	Результат				= Новый Структура("Успешно,Идентификатор,Ошибки,КассаККМ", Ложь, "", , Справочники.Кассы.ПустаяСсылка());
	
	Если ОборудованиеПодключено(Оборудование) Тогда
		Результат.Успешно	= Истина;
		Идентификатор		= ИдентификаторПодключенногоОборудования(Оборудование);		
	Иначе		
		ПараметрыОборудования	= ПолучитьПараметрыУстройства(Оборудование);
		ДрайверСсылка			= ПолучитьРеквизитШапки(Оборудование, "ДрайверОборудования");	
		
		РезультатПодключения	= ПодключитьДрайверТО(ДрайверСсылка);
		Если РезультатПодключения.Успешно Тогда		
			ДрайверОбъект	= РезультатПодключения.ДрайверОбъект;		
			
			УстановитьПараметрыУстройства(ДрайверОбъект,ПараметрыОборудования);
			
			//ДрайверОбъект.УстановитьПараметр("EquipmentType", "СканерШтрихкода");		
			
			Идентификатор	= "";		// Acquiring_3001#1
			
			Если ДрайверОбъект.Подключить(Идентификатор) Тогда			
				ЗапомнитьПодключеннноеОборудование(Оборудование,Идентификатор);
				
				Результат.Успешно			= Истина;
				Результат.Идентификатор     = Идентификатор;
			Иначе			
				Ошибки				= "";
				ДрайверОбъект.ПолучитьОшибку(Ошибки);
				Результат.Ошибки	= Ошибки; 
			КонецЕсли;
		Иначе
			Результат.Ошибки	= "Не удалось загрузить драйвер ТО ! "+РезультатПодключения.Ошибки;			
		КонецЕсли; 
	КонецЕсли;
	
	Если Результат.Успешно Тогда
		Результат.Вставить("КассаККМ", Справочники.ТорговоеОборудование.ПолучитьКассуПоОборудованию(Оборудование, ИмяКомпьютера()));	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПодключитьОборудование(Оборудование) Экспорт

Функция УстановитьПараметрыУстройства(ДрайверОбъект,Параметры) Экспорт
	Для Каждого Элемент Из Параметры Цикл
		ВремКлюч	= Элемент.Ключ; //
		ВремЗнач	= Элемент.Значение;
		
		Попытка
			ДрайверОбъект.УстановитьПараметр(ВремКлюч, ВремЗнач);
		Исключение
			Сообщить("Не удалось установить параметр драйвера: "+ВремКлюч+" "+ВремЗнач+". "+ОписаниеОшибки(), СтатусСообщения.Важное);
		КонецПопытки;		
	КонецЦикла;
КонецФункции // ()
 
Функция РевизияИнтерфейса(Оборудование) Экспорт
	Результат	= 0;
	
	Если ОборудованиеПодключено(Оборудование) Тогда
		ДрайверСсылка	= ПолучитьРеквизитШапки(Оборудование,	"ДрайверОборудования");		
		Результат		= ПолучитьРеквизитШапки(ДрайверСсылка,	"РевизияИнтерфейса");
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //РевизияИнтерфейса(Оборудование)
 
Функция ПроверитьПодключитьОборудование(Оборудование) Экспорт
	Результат	= Новый Структура("Успешно,Ошибки,Идентификатор,КассаККМ", Ложь, "", "", Справочники.Кассы.ПустаяСсылка());	 
	
	Если ОборудованиеПодключено(Оборудование) Тогда 
		Результат.Успешно = Истина;		
	Иначе		
		рПодключения = ПодключитьОборудование(Оборудование);
		Если рПодключения.Успешно Тогда			
			Результат.Идентификатор = рПодключения.Идентификатор;
			Результат.КассаККМ		= рПодключения.КассаККМ;
			
			Результат.Успешно = Истина;			
		Иначе              
			Результат.Ошибки = "Ошибка при подключении ТО ! "+рПодключения.Ошибки;			
		КонецЕсли; 
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПроверитьПодключитьОборудование(Оборудование) Экспорт

Функция ПолучитьПараметрыККТ(Оборудование) Экспорт
	Результат	= Новый Структура("Успешно,Ошибки",Ложь,"");	
	
	РезультатПодключения	= ПроверитьПодключитьОборудование(Оборудование);
	Если НЕ РезультатПодключения.Успешно Тогда
		Результат.Ошибки=РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура("Кассир,КассирИНН,АдресРасчетов,МестоРасчетов","Администратор");
	
	Кассир			= ВходныеПараметры.Кассир;
	КассирИНН		= ВходныеПараметры.КассирИНН;
	
	Если НЕ ПроверитьИННКассира(КассирИНН,Результат.Ошибки) Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	НомерСмены     	= 0;
	НомерДокумента 	= 0;
	СтатусСмены		= 0;
	ПараметрыСмены	= Неопределено;	
	
		
	РевизияИнтерфейса	= РевизияИнтерфейса(Оборудование);
	ОбъектДрайвера		= ПолучитьОбъектДрайвера(Оборудование);		
	
	ПроверитьДемоРежим(ОбъектДрайвера);
	
	ИДУстройства		= МенеджерОборудованияКлиент.ИдентификаторПодключенногоОборудования(Оборудование);
	
	// Получить параметры ККТ при открытии смены.
	ПараметрыККТ = "";
	Попытка		
		Если НЕ ОбъектДрайвера.ПолучитьПараметрыККТ(ИДУстройства, ПараметрыККТ) Тогда
			ОписаниеОшибки = "";
			ОбъектДрайвера.ПолучитьОшибку(ОписаниеОшибки); 
			Результат.Ошибки	= "Ошибка результата метода <ОбъектДрайвера.ПолучитьПараметрыККТ>. " + Символы.ПС + ОписаниеОшибки;
			Возврат Результат;
		КонецЕсли;
	Исключение		
		Результат.Ошибки	= НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ПолучитьПараметрыККТ>.'") + Символы.ПС + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	
	ПараметрыККТ = ПараметрыККТИзXMLПакета(ПараметрыККТ, РевизияИнтерфейса);
	
	Вход 	= ВходныеПараметрыXML(ВходныеПараметры, РевизияИнтерфейса);
	Выход   = "";	
	
	Попытка
		
		Если РевизияИнтерфейса >= 3000 Тогда // Версия стандарта 3.0 (ОФД 1.1)
			РезультатДрайвера = ОбъектДрайвера.ПолучитьТекущееСостояние(ИДУстройства, Вход, Выход); 
			Если РезультатДрайвера Тогда
				ПараметрыСмены		= ПолучитьПараметрыСменыИзXMLПакета(Выход,РевизияИнтерфейса);				
				СтатусСмены			= ПараметрыСмены.СтатусСмены;
				Результат.Успешно   = Истина;
			Иначе
				Ошибка	= "";
				ОбъектДрайвера.ПолучитьОшибку(Ошибка);
			КонецЕсли;
		Иначе
			Если РевизияИнтерфейса >= 2002 Тогда // Версия стандарта 2.2 (ОФД 1.0.5)
				ОбъектДрайвера.ПолучитьТекущееСостояние(ИДУстройства,НомерДокумента,НомерСмены,СтатусСмены,Выход);
				ПараметрыСмены = ПолучитьПараметрыСменыИзXMLПакета(Выход, РевизияИнтерфейса);
			Иначе				
				Результат.Ошибки = "Недопустимая ревизия интерфейса: """+РевизияИнтерфейса+""" !";
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		
		Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ОткрытьСмену>.'") + Символы.ПС + ОписаниеОшибки();			
		
	КонецПопытки;
	
	
	Если Результат.Успешно Тогда
		// Заполнение выходных параметров.
		ВыходныеПараметры=Новый Структура();
		
		
		ВыходныеПараметры.Вставить("НомерСмены",			НомерСмены);
		ВыходныеПараметры.Вставить("НомерДокумента",		НомерДокумента);
		ВыходныеПараметры.Вставить("СтатусСмены",			СтатусСмены); // 1- закрыта, 2 - Открыта, 3 - просрочена
		ВыходныеПараметры.Вставить("ДатаСеанса",			ТекущаяДата());
		
		ВыходныеПараметры.Вставить("ПараметрыСмены",		ПараметрыСмены);
		ВыходныеПараметры.Вставить("ПараметрыККТ",			ПараметрыККТ);
		ВыходныеПараметры.Вставить("ПараметрыСостояния",	Выход);		
		ВыходныеПараметры.Вставить("ОбъектДрайвера",		ОбъектДрайвера);
		
		Результат.Успешно	= Истина;
		Результат.Вставить("Данные",ВыходныеПараметры);
	Иначе		
		Ошибки	= "";
		ОбъектДрайвера.ПолучитьОшибку(Ошибки);
		
		Результат.Ошибки	= СокрЛП(Результат.Ошибки+" "+Ошибки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьДемоРежим(ОбъектДрайвера) Экспорт
	ОписаниеРезультата		= "";
	АктивированДемоРежим	= "";
	РезультатТеста = ОбъектДрайвера.ТестУстройства(ОписаниеРезультата, АктивированДемоРежим);
	Если РезультатТеста И Не ПустаяСтрока(АктивированДемоРежим) Тогда
		Сообщить(АктивированДемоРежим);
	КонецЕсли;
КонецФункции // ()

Функция ВходныеПараметрыXML(ОбщиеПараметры, РевизияИнтерфейса = 0) Экспорт
	ПараметрыПоУмолчанию	= Новый Структура("Кассир,КассирИНН","Администратор","");
	
	Кассир			= ПолучитьПараметр(ОбщиеПараметры,"Кассир",			ПараметрыПоУмолчанию);
	КассирИНН		= ПолучитьПараметр(ОбщиеПараметры,"КассирИНН",		ПараметрыПоУмолчанию);	
	АдресРасчетов   = ПолучитьПараметр(ОбщиеПараметры,"АдресРасчетов",	ПараметрыПоУмолчанию);
	МестоРасчетов   = ПолучитьПараметр(ОбщиеПараметры,"МестоРасчетов",	ПараметрыПоУмолчанию);
	
	ЗаписьXML = Новый ЗаписьXML();
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("InputParameters");
	ЗаписьXML.ЗаписатьНачалоЭлемента("Parameters");
	
	Если РевизияИнтерфейса >= 3000 Тогда  // Версия стандарта 3.0 (ОФД 1.1)
		ЗаписьXML.ЗаписатьАтрибут("CashierName", Кассир);
		ЗаписьXML.ЗаписатьАтрибут("CashierINN" , КассирИНН);
		Если ЗначениеЗаполнено(АдресРасчетов) Тогда   
			ЗаписьXML.ЗаписатьАтрибут("SaleAddress", АдресРасчетов);
		КонецЕсли;
		Если ЗначениеЗаполнено("МестоРасчетов") Тогда  
			ЗаписьXML.ЗаписатьАтрибут("SaleLocation", МестоРасчетов);
		КонецЕсли;
	Иначе
		ЗаписьXML.ЗаписатьАтрибут("CashierName" , Кассир);
		ЗаписьXML.ЗаписатьАтрибут("CashierVATIN", КассирИНН);
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции

Функция ПолучитьПараметр(Параметры, Имя, ЗначенияПоУмолчанию)
	ТекЗнач	= Неопределено;
	Параметры.Свойство(Имя,ТекЗнач);
	Если НЕ ЗначениеЗаполнено(ТекЗнач) Тогда
		ЗначенияПоУмолчанию.Свойство(Имя,ТекЗнач);		
	КонецЕсли; 
	
	//Возврат XMLСтрока(ТекЗнач); ?????? TODO проверить зачем XMLСтрока 
	//пока заменил т.к. не работает в web клиенте
	Возврат Строка(ТекЗнач);
КонецФункции // ()


#КонецОбласти 


Функция ПараметрыККТИзXMLПакета(Данные, РевизияИнтерфейса = 0) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML; 
	ЧтениеXML.УстановитьСтроку(Данные);
	ЧтениеXML.ПерейтиКСодержимому();
	
	ПараметрыККТ = ПараметрыРегистрацииККТ();
	ПараметрыККТ.Вставить("ТипОборудования", "ККТ");
	
	Если РевизияИнтерфейса >= 3000 Тогда  // Версия стандарта 3.0 (ОФД 1.1)
		
		Если (ЧтениеXML.Имя = "Parameters" Или ЧтениеXML.Имя = "TableParametersKKT") И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
			ПараметрыККТ.ВерсияФФДФН   = ЧтениеXML.ЗначениеАтрибута("FFDVersionFN");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДФН) Тогда
				ПараметрыККТ.ВерсияФФДФН = "1.0";
			КонецЕсли;
			ПараметрыККТ.ВерсияФФДККТ  = ЧтениеXML.ЗначениеАтрибута("FFDVersionKKT");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДККТ) Тогда
				ПараметрыККТ.ВерсияФФДККТ = "1.0";
			КонецЕсли;
			// ФФД 1.0
			ПараметрыККТ.РегистрационныйНомерККТ    = СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTNumber"));
			ПараметрыККТ.ЗаводскойНомерККТ          = СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTSerialNumber"));
			ПараметрыККТ.ЗаводскойНомерФН           = СокрЛП(ЧтениеXML.ЗначениеАтрибута("FNSerialNumber"));
			ПараметрыККТ.ОрганизацияНазвание        = ЧтениеXML.ЗначениеАтрибута("CompanyName");
			ПараметрыККТ.ОрганизацияИНН             = СокрЛП(ЧтениеXML.ЗначениеАтрибута("INN"));
