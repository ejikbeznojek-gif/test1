Функция ПодключитьОборудованиеНаРабочемМесте(ОборудованиеНаРабочемМесте)
	
	Для Каждого ДанныеОборудования Из ОборудованиеНаРабочемМесте Цикл
		
		РезультатПодключения = ПодключитьОборудование(ДанныеОборудования.Оборудование);
		Если Не РезультатПодключения.Успешно Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "При подключении #ТипОборудования# #НаименованиеОборудования# произошла ошибка." + Символы.ПС;
			Сообщение.Текст = Сообщение.Текст + РезультатПодключения.Ошибки;
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "#ТипОборудования#", Строка(ДанныеОборудования.ТипОборудования));
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "#НаименованиеОборудования#", ДанныеОборудования.Представление);
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции
