КонецФункции // ПолучитьЭтотУзел()


//РАБОТА С ФАЙЛАМИ ОБМЕНА
// Функция получения файла с новым сообщением обмена
// Ищет и копирует в указанный файл файл с последним сообщением обмена
//
// Параметры:
//  ИмяФайла	- файл, в который будет произведено копирование файла с сообщением обмена
//
// Возвращаемое значение:
//  Булево - Истина - если файл с сообщением обмена получен и Ложь - в противном случае
//

// Функция получает имя файла обмена
// Формирует имя файла обмена для двух узлов
//
// Параметры:
//  УзелИсточник - ссылка на узел-источник сообщения обмена
//  УзелПриемник - ссылка на узел-приемник сообщения обмена
//  Постфикс - строка, добавляемая в конец имени файла
//
// Возвращаемое значение:
//  ИмяФайла - строка с именем файла
//
Функция ПолучитьИмяФайлаОбмена(УзелИсточник, УзелПриемник, Постфикс = "",Расширение="xml") Экспорт
	
	// формируем имя файла, исходя из кодов источника и приемника сообщения обмена
	Возврат "Msg_" + СокрЛП(УзелИсточник.Код) + "_" + СокрЛП(УзелПриемник.Код)+"_" + СокрЛП(Постфикс) + "."+Расширение;
	
КонецФункции // ПолучитьИмяФайлаОбмена(УзелИсточник, УзелПриемник, Постфикс = "")

Функция ПолучитьФайлОбмена(Знач ИмяФайла,Узел,Распаковывать=Истина) Экспорт
	// Выбираем метод получения файла обмена
	Если Узел.Переключатель = 0 Тогда //Локальная сеть
		// Получаем копию файла обмена с новым сообщением во временный файл
		Возврат ПолучитьФайлОбменаСеть(ИмяФайла,Узел,Распаковывать);		
	ИначеЕсли Узел.Переключатель = 1 Тогда //E-Mail			
		// Получаем файл обмена с новым сообщением во временный файл
		Возврат  ПринятьФайлОбменаМыло(ИмяФайла,Узел)		
	ИначеЕсли Узел.Переключатель = 2 Тогда //Очередь MSMQ				
		Возврат  ПолучитьФайлОбменаИЗОчереди(ИмяФайла,Узел);				
	ИначеЕсли Узел.Переключатель = 3 Тогда //Очередь IBMMQ					
		Возврат  ПолучитьФайлОбменаИЗОчередиWSMQ(ИмяФайла,Узел);								
	ИначеЕсли Узел.Переключатель = 4 Тогда
		Возврат  ПолучитьФайлОбменаFTP(ИмяФайла,Узел);
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции // ПолучитьФайлОбмена()

Функция ОтправитьФайлОбмена(ИмяФайла,НомерСообщения,Узел,Архивировать=Истина) Экспорт
	Результат=Новый Структура("Результат,Описание",Истина,Неопределено);		
	
	Если Узел.Переключатель = 0 Тогда 		
		// Публикуем файл с сообщением обмена
		РезультатОтправки=ОпубликоватьФайлОбмена(ИмяФайла, НомерСообщения,Узел,Архивировать);				
		
		Результат.Вставить("Результат",	РезультатОтправки.Результат);
		Результат.Вставить("Описание",	РезультатОтправки.Описание);
	ИначеЕсли Узел.Переключатель = 1 Тогда			
		ОтправитьФайлОбменаМыло(ИмяФайла, НомерСообщения,Узел);   		
	ИначеЕсли Узел.Переключатель = 2 Тогда				
		ПоместитьДанныеОбменаВОчередь(ИмяФайла, НомерСообщения,Узел);			
	ИначеЕсли Узел.Переключатель = 3 Тогда				
		ПоместитьДанныеОбменаВОчередьWSMQ(ИмяФайла, НомерСообщения,Узел);
	ИначеЕсли Узел.Переключатель = 4 Тогда					
		РезультатОтправки=ОтправитьФайлОбменапоFTP(ИмяФайла, НомерСообщения,Узел);			
		
		Результат.Вставить("Результат",	РезультатОтправки.Результат);
		Результат.Вставить("Описание",	РезультатОтправки.Описание);
	КонецЕсли;
	
	Попытка		
		// Удаляем файл с сообщением обмена
		УдалитьФайлы(ИмяФайла);		
	Исключение
		ЗаписатьВЛог("ОбменДанными","Ошибка удаления файла: """+ИмяФайла+""" !","Ошибка");
	КонецПопытки;	
	
	Возврат Результат;	
КонецФункции // ОтправитьФалОбмена()

Функция ПолучитьФайлОбменаСеть(ИмяФайла, Узел, Распаковывать=Истина) Экспорт
	
	// Получаем маску для поиска файлов с сообщениями обмена
	МаскаФайлов = ПолучитьИмяФайлаОбмена(Узел,ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел(), "??????????",?(Распаковывать,"zip","xml"));
	
	ИмяФайлаСообщения = "";
	// Ищем файлы по маске в каталоге загрузки
	Файлы = НайтиФайлы(Узел.АдресОбмена, МаскаФайлов);
	
	// Отбираем файл с максимальным номером в имени
	Для Каждого Файл Из Файлы Цикл		
		Если ПустаяСтрока(ИмяФайлаСообщения) Или Файл.ПолноеИмя > ИмяФайлаСообщения Тогда			
			ИмяФайлаСообщения = Файл.ПолноеИмя;			
		КонецЕсли;			
	КонецЦикла;
	
	Если Не ПустаяСтрока(ИмяФайлаСообщения) Тогда		
		ЗаписатьВЛог("ОбменДаннымиОсновной","Получение файла: "+ИмяФайлаСообщения,Перечисления.ТипыСообщенийЛога.Информация);	
		
		Если Распаковывать Тогда
			ИмяАрхива			=ИмяФайлаСообщения;
			ИмяФайлаСообщения	=ПолучитьЧастьИмениФайла(ИмяАрхива,"ПолноеИмяБезРасширения")+".xml";
			
			Попытка
				ЧтениеZIP=Новый ЧтениеZipФайла;
				
				ЧтениеZIP=Новый ЧтениеZipФайла(ИмяАрхива);
				ЧтениеZIP.ИзвлечьВсе(ПолучитьЧастьИмениФайла(ИмяАрхива,"ПолныйПуть"),РежимВосстановленияПутейФайловZIP.НеВосстанавливать);		
			Исключение
				ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка распаковки файла: "+ИмяФайлаСообщения+". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка);								
				Возврат Ложь;
			КонецПопытки;			
		КонецЕсли;		
		
		//ПереместитьФайл(ИсходноеИмяФайла,ИмяФайла);
		
		Попытка			
			// Копируем файл с сообщением обмена в указанный файл
			ПереместитьФайл(ИмяФайлаСообщения, ИмяФайла);			
		Исключение			
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка перемещения файла: """+ИмяФайлаСообщения+""" - """+ИмяФайла+""". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка);				
			Возврат Ложь;			
		КонецПопытки;
		
		// Файл с сообщением обмена получен успешно
		Возврат Истина;		
	КонецЕсли;	
	
	Возврат Ложь;	
КонецФункции // ПолучитьФайлОбмена(ИмяФайла)

Функция ПолучитьФайлОбменаFTP(ИмяФайла,Узел)
	
	// Получаем маску для поиска файлов с сообщениями обмена
	МаскаФайлов = ПолучитьИмяФайлаОбмена(Узел.Ссылка, ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел(), "??????????","zip");
	
	ИмяФайлаСообщения = "";
	
	Соединение=УстановитьFTPСоединение(Узел.АдресОбмена,Узел.Пользователь,Узел.Пароль,,Узел.ПассивныйРежим);
	Если Соединение=Неопределено Тогда
		ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка установки соединения с FTP сервером: "+Узел.АдресОбмена,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);		
		Возврат Ложь;	
	КонецЕсли;
	
	КаталогНаСервере="/"+?(ПустаяСтрока(Узел.КаталогFTP),"",Узел.КаталогFTP+"/");
	
	
	ИмяФайлаСообщения = "";
	
	// Ищем файлы по маске в каталоге загрузки
	Файлы = Соединение.НайтиФайлы(КаталогНаСервере, МаскаФайлов);
	
	// Отбираем файл с максимальным номером в имени
	Для Каждого Файл Из Файлы Цикл		
		Если ПустаяСтрока(ИмяФайлаСообщения) Или Файл.ПолноеИмя > ИмяФайлаСообщения Тогда			
			ИмяФайлаСообщения = Файл.ПолноеИмя;			
		КонецЕсли;		
	КонецЦикла;
	
	КаталогЗагрузки	=ПолучитьЧастьИмениФайла(ИмяФайла,"ПолныйПуть");
	
	ИмяАрхива		=КаталогЗагрузки+ПолучитьЧастьИмениФайла(ИмяФайлаСообщения,"Имя");
	ИсходноеИмяФайла=КаталогЗагрузки+ПолучитьЧастьИмениФайла(ИмяФайлаСообщения,"ИмяБезРасширения")+".xml";
	
	Если Не ПустаяСтрока(ИмяФайлаСообщения) Тогда
		ЗаписатьВЛог("ОбменДаннымиОсновной","Получение файла: " + ИмяФайлаСообщения,Перечисления.ТипыСообщенийЛога.Информация);		
		
		Попытка			
			// Копируем файл с сообщением обмена в указанный файл
			Соединение.Получить(ИмяФайлаСообщения, ИмяАрхива);
			
			ЧтениеZIP=Новый ЧтениеZipФайла(ИмяАрхива);
			ЧтениеZIP.ИзвлечьВсе(ПолучитьЧастьИмениФайла(ИмяАрхива,"ПолныйПуть"),РежимВосстановленияПутейФайловZIP.НеВосстанавливать);
			
			ПереместитьФайл(ИсходноеИмяФайла,ИмяФайла);			
		Исключение
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка получения файла: " + ИмяФайлаСообщения+". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка);
			Возврат Ложь;			
		КонецПопытки;
		
		// Файл с сообщением обмена получен успешно
		Возврат Истина;		
	КонецЕсли;	
	
	Возврат Ложь;	
КонецФункции // ПолучитьФайлОбмена(ИмяФайла)

// Функция получения файла с новым сообщением обмена по электронной почте
// Ищет и записывает в указанный файл файл с последним сообщением обмена
//
// Параметры:
//  ИмяФайла - файл, в который будет записан файл с сообщением обмена
//
// Возвращаемое значение:
//  Булево - Истина - если файл с сообщением обмена получен и Ложь - в противном случае
//
Функция ПринятьФайлОбменаМыло(ИмяФайла,Узел)
	ЭтотУзел=ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	
	Профиль = Новый ИнтернетПочтовыйПрофиль;
	Профиль.АдресСервераPOP3 = Узел.СерверPOP3;
	Профиль.Пользователь = Узел.Пользователь;
	Профиль.Пароль = Узел.Пароль;
	
	Попытка
		
		Почта = Новый ИнтернетПочта;
		Почта.Подключиться(Профиль);
		
		// Получаем все сообщения из почтового ящика
		МассивСообщений = Новый Массив;
		МассивСообщений = Почта.Выбрать(Ложь);
		
	Исключение
		
		// Ошибка при подключении к серверу или при приеме сообщения обмена
		Сообщить(" - Ошибка при подключении или приеме" + ОписаниеОшибки());
		Возврат Ложь;
		
	КонецПопытки;
	
	// Далее все оставшиеся сообщения в МассивСообщенийОбмена, и только они, 
	// будут удалены с сервера. Это исключает удаление личных сообщений из
	// почтового ящика.
	МассивСообщенийОбмена = Новый Массив;
	
	Если МассивСообщений.Количество() = 0 Тогда
		
		// Сообщений в почтовом ящике нет
		Возврат Ложь;
		
	КонецЕсли;
	
	ИмяФайлаСообщения = "";
	Для Индекс = 0 По МассивСообщений.Количество() - 1 Цикл
		
		// Отсеиваем только сообщения, которые содержат файлы обмена 
		// для участвующих в обмене узлов.
		ЧастьТемы = "СООБЩЕНИЕ_ОБМЕНА: " + "Message" + СокрП(Узел.Код) + "_" + СокрП(ПланыОбмена.Оснвной.ЭтотУзел().Код);
		Если Лев(МассивСообщений[Индекс].Тема, СтрДлина(ЧастьТемы)) = ЧастьТемы Тогда
			
			Если МассивСообщений[Индекс].Вложения[0].Имя > ИмяФайлаСообщения Тогда
				
				// Выбираем сообщение с последним номером сообщения обмена
				ИмяФайлаСообщения = МассивСообщений[Индекс].Вложения[0].Имя;
				ИндексСообщения = Индекс;
				
			КонецЕсли;	
			
			МассивСообщенийОбмена.Добавить(МассивСообщений[Индекс]);
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Если ИндексСообщения <> Неопределено Тогда 
		
		// Записываем файл обмена во временный файл
		МассивСообщений[ИндексСообщения].Вложения[0].Данные.Записать(ИмяФайла);
		
		Сообщить(" - Принят файл обмена данными " + ИмяФайлаСообщения + " с адреса " + Узел.ПочтовыйАдресОбмена);
		
		// Удаляем все сообщения обмена с сервера для узлов, участвующих в обмене
		Почта.УдалитьСообщения(МассивСообщенийОбмена);
		Почта.Отключиться();        
		Возврат Истина;
		
	Иначе
		
		// Сообщений обмена в почтовом ящике нет
		Почта.Отключиться();        
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции // ПринятьФайлОбмена(ИмяФайла)

// Функция получения файла с новым сообщением обмена из очереди
// Выбирает из очереди сообщение обмена и сохраняет в файле
//
// Параметры:
//  ИмяФайла - файл, в который будет произведено копирование файла с сообщением обмена
//
// Возвращаемое значение:
//  Булево - Истина - если файл с сообщением обмена получен и Ложь - в противном случае
//
Функция ПолучитьФайлОбменаИЗОчереди(ИмяФайла,Узел)
	
	// Флаги
	MQ_DENY_NONE = 0;
	MQ_RECEIVE_ACCESS = 1;
	MQ_NO_TRANSACTION = 0;
	
	qinfo = Новый COMОбъект("MSMQ.MSMQQueueInfo");
	
	// Находим позицую начала имени очереди в АдресОбменаMSMQ
	Индекс = СтрДлина(Узел.ОчередьОбменаMSMQ);
	Пока (Индекс <> 0) Цикл
		
		Если Сред(Узел.ОчередьОбменаMSMQ, Индекс, 1) = "\" Тогда
			Прервать;
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
	// Собираем путь к очереди для чтения данных обмена
	qinfo.PathName = ".\" + Прав(Узел.ОчередьОбменаMSMQ, СтрДлина(Узел.ОчередьОбменаMSMQ) - Индекс) + 
	"_" + СокрП(ПланыОбмена.Основной.ЭтотУзел().Код);
	
	Попытка
		
		qinfo.Create();
		
	Исключение
	КонецПопытки;
	
	// Открываем очередь
	Очередь = qinfo.Open(MQ_RECEIVE_ACCESS, MQ_DENY_NONE);
	
	// Временный объект необходим для поиска последнего сообщения
	СообщениеВрем = Новый COMОбъект("MSMQ.MSMQMessage");
	// Читаем первое сообщение
	СообщениеВрем = Очередь.Receive(MQ_NO_TRANSACTION, , , 0);
	
	Пока (СообщениеВрем <> Неопределено) Цикл
		
		Сообщение = СообщениеВрем;
		// Читаем последующие сообщения, если они присутствуют
		СообщениеВрем = Очередь.Receive(MQ_NO_TRANSACTION, , , 0);
		
	КонецЦикла;
	
	// Закрываем очередь
	Очередь.Close();
	
	// Если получили сообщение, разбираем его и передаем данные обмена 
	// дальше для обработки
	Если Сообщение <> Неопределено Тогда
		
		ИмяФайлаСообщения = Сообщение.Label;
		ФайлОбмена = Новый ЗаписьТекста(ИмяФайла);
		ФайлОбмена.Записать(Сообщение.Body);
		ФайлОбмена.Закрыть();
		
		Сообщить(" - Принят файл обмена данными " + ИмяФайлаСообщения + " из очереди " + Узел.ОчередьОбменаMSMQ);
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Функция получения файла с новым сообщением обмена из очереди IBM WebSphere MQ
// Выбирает из очереди сообщение обмена и сохраняет в файле
//
// Параметры:
//  ИмяФайла - файл, в который будет произведено копирование файла с сообщением обмена
//
// Возвращаемое значение:
//  Булево - Истина - если файл с сообщением обмена получен и Ложь - в противном случае
//
Функция ПолучитьФайлОбменаИЗОчередиWSMQ(ИмяФайла,Узел)
	
	// Определяем флаг
	MQOO_INPUT_AS_Q_DEF = 1;
	
	Попытка
		
		// Подключаемся к менеджеру очереди
		Сессия = Новый COMОбъект("MQAX200.MQSession");
		МенеджерОчереди = Сессия.AccessQueueManager("");     
		
	Исключение
		
		Сообщить(" - Ошибка доступа к очереди: " + ОписаниеОшибки());
		Возврат Ложь;
		
	КонецПопытки;
	
	// Открываем очередь для чтения из неё данных обмена
	Попытка
		
		Очередь = МенеджерОчереди.AccessQueue(Узел.ЛокальнаяОчередь, MQOO_INPUT_AS_Q_DEF);
		
	Исключение
		
		Сообщить(" - Ошибка открытия очереди: " + ОписаниеОшибки());
		Возврат Ложь;
		
	КонецПопытки;
	
	Попытка
		
		// Создаем сообщение
		Сообщение = Сессия.AccessMessage();
		// получаем сообщение
		Очередь.Get(Сообщение);
		
	Исключение
		
		Сообщить(" - Ошибка чтения данных из очереди: " + ОписаниеОшибки());
		Возврат Ложь;
		
	КонецПопытки;
	
	// Читаем из сообщения данные обмена и сохраняем их в файл
	Данные = Сообщение.ReadString(Сообщение.MessageLength);
	
	ФайлОбмена = Новый ЗаписьТекста(ИмяФайла);
	ФайлОбмена.Записать(Данные);
	ФайлОбмена.Закрыть();
	
	Сообщить(" - Принят файл обмена данными из очереди " + Узел.ЛокальнаяОчередь);
	
	Возврат Истина;
	
КонецФункции


Функция ПолучитьЧастьИмениФайла(Имяфайла,ЧастьИмени) Экспорт
	Файл=Новый Файл(Имяфайла);
	
	Если ЧастьИмени="ПолныйПуть" Тогда
		Возврат Файл.Путь;
	ИначеЕсли ЧастьИмени="ПолноеИмяБезРасширения" Тогда
		Возврат Файл.Путь+Файл.ИмяБезРасширения;
	ИначеЕсли ЧастьИмени="Имя" Тогда
		Возврат Файл.Имя;
	ИначеЕсли ЧастьИмени="ИмяБезРасширения" Тогда
		Возврат Файл.ИмяБезРасширения;		
	Иначе
		Возврат Файл.ПолноеИмя;
	КонецЕсли;	
КонецФункции // ПолучитьЧастьИмениФайла()

/////////////////////////////////////////////////////////////////////////////////////////////
/// ОТПРАВКА ФАЙЛОВ ОБМЕНА
// Процедура публикации файла с сообщением обмена
//
// Параметры:
//  ИмяФайла 		- имя файла, содержащего сообщение обмена
//  НомерСообщения  - номер сообщения отправляемых данных

// Сохранение на диск, или сеть
Функция ОпубликоватьФайлОбмена(ИсходноеИмяФайла, НомерСообщения, Узел, Архивировать = Истина) Экспорт
	РезультатОтправки	=Новый Структура("Результат,Описание",Истина,"");
	ЭтотУзел		  = ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	
	//	Архивировать	  = Истина;
	
	ИмяФайлаСообщения = ПолучитьИмяФайлаОбмена(ЭтотУзел,Узел,Формат(НомерСообщения, "ЧЦ=10; ЧВН=; ЧГ=0"));	
	
	ИмяФайла		  = ИсходноеИмяФайла;
	
	Если Архивировать Тогда
		ПолноеИмяФайлаСообщения	=ПолучитьЧастьИмениФайла(ИсходноеИмяФайла,"ПолныйПуть")+ИмяФайлаСообщения;
		ПереместитьФайл(ИмяФайла,ПолноеИмяФайлаСообщения);
		
		ПолноеИмяфайлаАрхива	=ПолучитьЧастьИмениФайла(ПолноеИмяФайлаСообщения,"ПолноеИмяБезРасширения")+".zip";	
		
		Если НЕ ЗаархивироватьФайл(ПолноеИмяФайлаСообщения,ПолноеИмяфайлаАрхива) Тогда
			ТекстОшибки="Ошибка архивации файла !";
			ЗаписатьВЛог("ОбменДанными",ТекстОшибки,"Ошибка");
			
			РезультатОтправки.Результат	=Ложь;
			РезультатОтправки.Описание  =ТекстОшибки;
			
			Возврат РезультатОтправки;
		Иначе
			ИмяФайла			=ПолноеИмяфайлаАрхива;
			ИмяФайлаСообщения	=ПолучитьЧастьИмениФайла(ПолноеИмяфайлаАрхива,"Имя");			
		КонецЕсли;		
	КонецЕсли; 
	
	Путь = СтрЗаменить(Узел.АдресОбмена, "\", "/");
	// Копируем файл в каталог, определенный для данного узла
	Попытка		
		ИмяФайлаПолучателя=Путь + ?(Прав(Путь, 1) = "/", "", "/") + ИмяФайлаСообщения;		
		КопироватьФайл(ИмяФайла,ИмяФайлаПолучателя);		
	Исключение
		ТекстОшибки="Ошибка копирования файла: """+ИмяФайла+"""-->"""+ИмяФайлаПолучателя+""" ! "+ОписаниеОшибки();
		
		ЗаписатьВЛог("ОбменДанными",ТекстОшибки,"Ошибка",Истина);
		
		РезультатОтправки.Результат	=Ложь;
		РезультатОтправки.Описание  =ТекстОшибки;
		
		Возврат РезультатОтправки;		
	КонецПопытки;
	
	Сообщить(" - Опубликован файл: """ + ИмяФайлаПолучателя+""".");
	
	Попытка	
		УдалитьФайлы(ИмяФайла);	
	Исключение
		ЗаписатьВЛог("ОбменДанными","Ошибка удаления файла: """+ИмяФайла+""" ! "+ОписаниеОшибки(),"Ошибка",Истина);		
	КонецПопытки;
	
	// Удаляем ранее выгруженные файлы
	ФайлСообщения = Новый Файл(ИмяФайлаСообщения);
	МаскаФайлов = ПолучитьИмяФайлаОбмена(ЭтотУзел, Узел, "??????????",?(Архивировать,"zip","xml"));
	Файлы = НайтиФайлы(Узел.АдресОбмена, МаскаФайлов);
	Для Каждого Файл Из Файлы Цикл		
		Если Файл.Имя <> ФайлСообщения.Имя Тогда			
			Попытка				
				// Пытаемся удалить файл со старым сообщением
				УдалитьФайлы(Файл.ПолноеИмя);				
			Исключение
				ЗаписатьВЛог("ОбменДанными","Ошибка удаления файла: """+Файл.ПолноеИмя+""" ! "+ОписаниеОшибки(),"Ошибка",Истина);						
			КонецПопытки;			
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат РезультатОтправки;
КонецФункции// ОпубликоватьФайлОбмена(ИмяФайла, НомерСообщения)

// Отправка по FTP
Функция УстановитьFTPСоединение(Сервер,Пользователь,Пароль,Прокся=Неопределено,Пассивный=Ложь) Экспорт
	Попытка	
		//крохин начало
		//Соединение=Новый FTPСоединение(Сервер,,Пользователь,Пароль,Прокся,Пассивный);
		Соединение=Новый FTPСоединение(Сервер,,Пользователь,Пароль,Прокся,Пассивный,180);
		//крохин конец
		
		Возврат Соединение;		
	Исключение		
		ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка установки соединения с FTP сервером ! Сервер: " + Сервер,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);		
		Возврат Неопределено;
	КонецПопытки;
КонецФункции // ()

Функция ОтправитьФайлОбменапоFTP(ИсходноеИмяФайла, НомерСообщения,Узел)
	Результат	=Новый Структура("Результат,Описание",Ложь,"Неизвестная ошибка! Смотри лог !");
	
	ЭтотУзел=ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	
	Архивировать=Истина;
	
	ИмяФайлаСообщения = ПолучитьИмяФайлаОбмена(ЭтотУзел,Узел,Формат(НомерСообщения, "ЧЦ=10; ЧВН=; ЧГ=0"));	
	
	ИмяФайла		  = ИсходноеИмяФайла;
	
	Если Архивировать Тогда
		ПолноеИмяФайлаСообщения	=ПолучитьЧастьИмениФайла(ИсходноеИмяФайла,"ПолныйПуть")+ИмяФайлаСообщения;
		ПереместитьФайл(ИмяФайла,ПолноеИмяФайлаСообщения);
		
		ПолноеИмяфайлаАрхива	=ПолучитьЧастьИмениФайла(ПолноеИмяФайлаСообщения,"ПолноеИмяБезРасширения")+".zip";	
		
		Если НЕ ЗаархивироватьФайл(ПолноеИмяФайлаСообщения,ПолноеИмяфайлаАрхива) Тогда
			Сообщение="Ошибка архивации сообщения ! Сообщение: "+ПолноеИмяФайлаСообщения;
			
			ЗаписатьВЛог("ОбменДаннымиОсновной",Сообщение,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);			
			
			Результат.Вставить("Сообщение",Сообщение);
			Возврат Результат;
		Иначе
			ИмяФайла			=ПолноеИмяфайлаАрхива;
			ИмяФайлаСообщения	=ПолучитьЧастьИмениФайла(ПолноеИмяфайлаАрхива,"Имя");			
		КонецЕсли;		
	КонецЕсли;
	
	Соединение=УстановитьFTPСоединение(Узел.АдресОбмена,Узел.Пользователь,Узел.Пароль,,Узел.ПассивныйРежим);
	Если Соединение=Неопределено Тогда
		Сообщение="Ошибка установки соединения с FTP сервером ! Свервер: "+Узел.АдресОбмена;
		ЗаписатьВЛог("ОбменДаннымиОсновной",Сообщение,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);		
		
		Результат.Вставить("Сообщение",Сообщение);
		Возврат Результат;
	КонецЕсли;
	
	ИмяФайлаСообщения=ПолучитьЧастьИмениФайла(ИмяФайла,"Имя");
	
	Если НЕ ПустаяСтрока(Узел.КаталогFTP) Тогда
		Соединение.УстановитьТекущийКаталог(Узел.КаталогFTP);	
	КонецЕсли;
	
	Попытка
		Соединение.Записать(ИмяФайла,ИмяФайлаСообщения);
	Исключение
		Сообщение="Ошибка передачи файла на FTP сервер ! Сервер: "+Узел.АдресОбмена+" файл: "+ИмяФайлаСообщения;
		ЗаписатьВЛог("ОбменДаннымиОсновной",Сообщение,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);
		
		Результат.Вставить("Сообщение",Сообщение);
		Возврат Результат;
	КонецПопытки;	
	
	КаталогНаСервере="/"+?(ПустаяСтрока(Узел.КаталогFTP),"",Узел.КаталогFTP+"/");
	
	Отправлен=Ложь;	
	Файлы=Соединение.НайтиФайлы(КаталогНаСервере+ИмяФайлаСообщения);
	Для Каждого Файл Из Файлы Цикл
		Отправлен=Истина;
		
		ЗаписатьВЛог("ОбменДаннымиОсновной","Файл отправлен на FTP сервер ! Сервер: "+Узел.АдресОбмена+", файл: "+Файл.Имя,Перечисления.ТипыСообщенийЛога.Информация);
	КонецЦикла;
	
	Если Отправлен Тогда
		// Удаляем ранее выгруженные файлы на FTP сервере
		ФайлСообщения = Новый Файл(ИмяФайлаСообщения);
		МаскаФайлов = ПолучитьИмяФайлаОбмена(ЭтотУзел, Узел, "??????????",?(Архивировать,"zip","xml"));
		Файлы = Соединение.НайтиФайлы(КаталогНаСервере, МаскаФайлов);
		Для Каждого Файл Из Файлы Цикл		
			Если Файл.Имя <> ФайлСообщения.Имя Тогда			
				Попытка				
					// Пытаемся удалить файл со старым сообщением
					Соединение.Удалить(КаталогНаСервере,Файл.Имя);				
				Исключение
					ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка удаления Файла на FTP сервере ! Сервер: "+Узел.АдресОбмена+", файл: "+Файл.Имя+". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка,Истина);
				КонецПопытки;			
			КонецЕсли;		
		КонецЦикла;		
		
		// Удаляем ранее выгруженные локальные файлы		
		ЛокальныйКаталогВыгрузки    = ПолучитьЧастьИмениФайла(ИсходноеИмяФайла,"ПолныйПуть");
		
		МаскаФайлов = ПолучитьИмяФайлаОбмена(ЭтотУзел, Узел, "??????????",?(Архивировать,"zip","xml"));
		Попытка				
			// Пытаемся удалить файл со старым сообщением
			УдалитьФайлы(ЛокальныйКаталогВыгрузки,МаскаФайлов);				
		Исключение
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка удаления Файлов на FTP сервере ! Сервер: "+Узел.АдресОбмена+", файлы: "+МаскаФайлов+". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка,Истина);
		КонецПопытки;		
		
	Иначе
		ЗаписатьВЛог("ОбменДаннымиОсновной","Отправленный файл не найден на FTP сервере ! Сервер: "+Узел.АдресОбмена+", файл: "+ИмяФайлаСообщения,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);		
	КонецЕсли;
	
	Результат.Результат	=Отправлен;
	Результат.Описание	="Оправлено сообщение: "+НомерСообщения;
	
	Возврат Результат;
КонецФункции

// Процедура публикации файла с сообщением обмена по электронной почте
//
// Параметры:
//  ИмяФайла 		- имя файла, содержащего сообщение обмена
//  НомерСообщения  - номер сообщения отправляемых данных
//
Процедура ОтправитьФайлОбменаМыло(ИмяФайла, НомерСообщения,Узел)
	ЭтотУзел=ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	
	Профиль = Новый ИнтернетПочтовыйПрофиль;
	Профиль.АдресСервераSMTP = Узел.СерверSMTP;
	
	ИмяФайлаСообщения = ПолучитьИмяФайлаОбмена(ЭтотУзел,Узел,Формат(НомерСообщения, "ЧЦ=10; ЧВН=; ЧГ=0"));
	
	// Формируем сообщение обмена
	Сообщение = Новый ИнтернетПочтовоеСообщение;
	Сообщение.Тема = "СООБЩЕНИЕ_ОБМЕНА: " + ИмяФайлаСообщения;
	Сообщение.Получатели.Добавить(Узел.ПочтовыйАдресОбмена);
	
	ФайлСообщения = Новый Файл(ИмяФайлаСообщения);
	// Создаем вложение с файлом обмена
	Сообщение.Вложения.Добавить(ИмяФайла, ФайлСообщения.Имя);
	
	Почта = Новый ИнтернетПочта;
	
	Попытка
		
		Почта.Подключиться(Профиль);
		// Отправляем сообщение с файлом обмена
		Почта.Послать(Сообщение);
		
	Исключение
		
		Сообщить(" - Ошибка при отправки файла: " + ИмяФайлаСообщения);
		Сообщить(ОписаниеОшибки());
		Возврат;
		
	КонецПопытки;
	
	Сообщить(" - Отправлен файл " + ИмяФайлаСообщения + " на адрес " + Узел.ПочтовыйАдресОбмена);
	
	Почта.Отключиться();
	
КонецПроцедуры // ОтправитьФайлОбмена(ИмяФайла, НомерСообщения)

// Процедура размещения сообщения обмена в очереди
//
// Параметры:
//  ИмяФайла 		- имя файла, содержащего сообщение обмена
//  НомерСообщения  - номер сообщения отправляемых данных
//
Процедура ПоместитьДанныеОбменаВОчередь(ИмяФайла, НомерСообщения,Узел)
	ЭтотУзел=ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	// Флаги
	MQ_SEND_ACCESS = 2;
	MQ_DENY_NONE = 0;
	
	// Получаем имя файла с номером сообщения
	ИмяФайлаСообщения = ПолучитьИмяФайлаОбмена(ЭтотУзел,Узел, Формат(НомерСообщения, "ЧЦ=10; ЧВН=; ЧГ=0"));
	
	qinfo = Новый COMОбъект("MSMQ.MSMQQueueInfo");
	// Формируем путь к очереди на удаленном компьютере
	qinfo.PathName = Узел.ОчередьОбменаMSMQ + "_" + СокрП(Узел.Код);
	
	// Если очередь не создана, создаем
	Попытка
		
		qinfo.Create();
		
	Исключение
	КонецПопытки;
	
	// Открываем очередь на запись
	Очередь = qinfo.Open(MQ_SEND_ACCESS, MQ_DENY_NONE);
	
	ДанныеОбмена = Новый ЧтениеТекста;
	ДанныеОбмена.Открыть(ИмяФайла);
	
	// Создаем сообщение, содержащее данные обмена
	Сообщение = Новый COMОбъект("MSMQ.MSMQMessage");
	Сообщение.Label = ИмяФайлаСообщения;
	Сообщение.Body = ДанныеОбмена.Прочитать();
	Сообщение.ResponseQueueInfo = qinfo;
	
	// Помещаем сообщение в очередь
	Сообщение.Send(Очередь);
	
	Сообщить(" - Помещен файл " + ИмяФайлаСообщения + " в очередь " + Узел.ОчередьОбменаMSMQ);
	
	Очередь.Close();
	ДанныеОбмена.Закрыть();
	
КонецПроцедуры

// Процедура размещения сообщения обмена в очереди IBM WebSphere MQ
//
// Параметры:
//  ИмяФайла 		- имя файла, содержащего сообщение обмена
//  НомерСообщения  - номер сообщения отправляемых данных
//
Процедура ПоместитьДанныеОбменаВОчередьWSMQ(ИмяФайла, НомерСообщения,Узел)
	
	// Определяем флаг
	MQOO_OUTPUT = 16;
	
	Попытка
		
		// Подключаемся к менеджеру очереди
		Сессия = Новый COMОбъект("MQAX200.MQSession");
		МенеджерОчереди = Сессия.AccessQueueManager("");     
		
	Исключение
		
		Сообщить(" - Ошибка доступа к очереди: " + ОписаниеОшибки());
		Возврат;
		
	КонецПопытки;
	
	Попытка
		
		// Открываем очередь на запись
		Очередь = МенеджерОчереди.AccessQueue(Узел.УдаленнаяОчередь, MQOO_OUTPUT);
		
	Исключение
		
		Сообщить(" - Ошибка открытия очереди: " + ОписаниеОшибки());
		Возврат;
		
	КонецПопытки;
	
	Попытка
		
		// Создаем новое сообщение
		Сообщение = Сессия.AccessMessage();
		
		// Открываем файл с данными обмена
		ДанныеОбмена = Новый ЧтениеТекста;
		ДанныеОбмена.Открыть(ИмяФайла);
		
		// Считываем данные из файла в сообщение, которое затем помещается в очередь
		Сообщение.writeString(ДанныеОбмена.Прочитать());
		// Помещаем сообщение в очередь
		Очередь.Put(Сообщение);
		
	Исключение
		
		Сообщить(" - Ошибка размещения сообщения в очереди: " + ОписаниеОшибки());
		Возврат;
		
	КонецПопытки;
	
	Сообщить(" - Помещен файл в очередь " + Узел.УдаленнаяОчередь);
	
	ДанныеОбмена.Закрыть();
	
КонецПроцедуры



// Процедура удаления файлов со старыми сообщениями обмена
// Удаляет файлы с именами равными или меньшими переданному номеру сообщения
// 
// Параметры:
//  НомерСообщения - номер сообщения
//
Процедура УдалитьФайлыОбмена(НомерСообщения,Узел) Экспорт
	ЭтотУзел=ПланыОбмена[Узел.Метаданные().Имя].ЭтотУзел();
	
	// Получаем имя файла с номером сообщения
	МаксИмяФайла = ПолучитьИмяФайлаОбмена(Узел,ЭтотУзел,Формат(НомерСообщения, "ЧЦ=10; ЧВН=; ЧГ=0"),"zip"); 		
	// Получаем маску для поиска файлов с сообщениями обмена
	МаскаФайлов = ПолучитьИмяФайлаОбмена(Узел,ЭтотУзел, "??????????","zip");
	
	Если Узел.Переключатель=4 Тогда //FTP		
		Соединение=УстановитьFTPСоединение(Узел.АдресОбмена,Узел.Пользователь,Узел.Пароль,,Узел.ПассивныйРежим);
		
		Если Соединение=Неопределено Тогда 
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка установки FTP соединения ! Сервер: "+Узел.АдресОбмена,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);			
			Возврат;  
		КонецЕсли;
		
		КаталогНаСервере="/"+?(ПустаяСтрока(Узел.КаталогFTP),"",Узел.КаталогFTP+"/");		
		// Ищем файлы по маске в каталоге загрузки
		Файлы = Соединение.НайтиФайлы(КаталогНаСервере, МаскаФайлов);
		// Удаление файлов со старыми сообщениями обмена
		Для Каждого Файл Из Файлы Цикл			
			// Удаляем только файлы, имена которых меньше или равны имени файла с указанным номером сообщения
			Если Файл.Имя <= МаксИмяФайла Тогда				
				Попытка					
					// Пытаемся удалить файл
					Соединение.Удалить(КаталогНаСервере,Файл.Имя);					
				Исключение
					ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка удаления файла на FTP сервере ! Сервер: "+Узел.АдресОбмена+", файл: "+Файл.Имя,Перечисления.ТипыСообщенийЛога.Ошибка,Истина);
					//крохин начало 20.02.2013
					//тут тоже может быть ошибка
					//Сообщить("Ошибка: "+ОписаниеОшибки(),СтатусСообщения.Важное);
					#Если Клиент Тогда
						Сообщить("Ошибка: "+ОписаниеОшибки(),СтатусСообщения.Важное);
					#КонецЕсли
					//крохин конец
				КонецПопытки;				
			КонецЕсли;			
		КонецЦикла;
	Иначе		
		// Ищем файлы по маске в каталоге загрузки
		Файлы = НайтиФайлы(СокрЛП(Узел.АдресОбмена), МаскаФайлов);		
		// Удаление файлов со старыми сообщениями обмена
		Для Каждого Файл Из Файлы Цикл			
			// Удаляем только файлы, имена которых меньше или равны имени файла с указанным номером сообщения
			Если Файл.Имя <= МаксИмяФайла Тогда				
				Попытка					
					// Пытаемся удалить файл
					УдалитьФайлы(Файл.ПолноеИмя);					
				Исключение
					ЗаписатьВЛог("ОбменДанными","Ошибка удаления файла: """+Файл.ПолноеИмя+"""."+ОписаниеОшибки(),"Ошибка");
				КонецПопытки;				
			КонецЕсли;			
		КонецЦикла;
	КонецЕсли;	
КонецПроцедуры // УдалитьФайлыОбмена(НомерСообщения)

Функция НужноВыгружатьДокумент(Модифицированность,Ссылка,РежимЗаписи,ПометкаУдаления) Экспорт
	РеквизитыШапки=ПолучитьРеквизитыШапки(Ссылка,Новый Структура("ПометкаУдаления,Проведен"),"Документ");
	
	Если 
		Модифицированность
		ИЛИ (НЕ РеквизитыШапки.Проведен И РежимЗаписи=РежимЗаписиДокумента.Проведение) 
		ИЛИ (РеквизитыШапки.Проведен И РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения) 
		ИЛИ РеквизитыШапки.ПометкаУдаления<>ПометкаУдаления Тогда
		Возврат Истина;				
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

