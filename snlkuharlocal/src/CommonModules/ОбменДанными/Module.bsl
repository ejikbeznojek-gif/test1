//Процедура ДобавитьВУзелФилиала(СписокПолучателей, Отправитель, Загрузка, Контрагент, УзелСклада=Неопределено)
Процедура ДобавитьВУзелФилиала(СписокПолучателей, Отправитель, Загрузка, Контрагент, УзелСклада=Неопределено, ЗагружатьНаСклад = Ложь)
	//Катаев- 17/10/14
	//Катаев+ 05/05/14 Переделал немного проверку
	////Катаев+ 20/03/14 Если Узел склада не принадлежит текущему узлу или это не ЦО, то в филиалы не регистрируем
	//Если ПланыОбмена.Основной.ЭтотУзел() <> УзелСклада или ПланыОбмена.Основной.ЭтотУзел().Код <> "SNL" Тогда
	//	Возврат;
	//Конецесли;
	////Катаев- 20/03/14
	Если ПланыОбмена.Основной.ЭтотУзел().Код <> "SNL" Тогда
		Если ПланыОбмена.Основной.ЭтотУзел() <> УзелСклада Тогда
			Возврат;
		Конецесли;
	КонецЕсли;
	//Катаев- 05/05/14
	Контрагент1 = Контрагент;
	//Катаев+ 11/06/13
	Если ТипЗнч(Контрагент1) <> Тип("СправочникСсылка.Контрагенты") Тогда
		Возврат;
	КонецЕсли;
	//Катаев- 11/06/13
	//крохин начало 18.06.2013
	Попытка 
		Тест = Контрагент1.Уровень();
	Исключение
		Возврат;
	КонецПопытки;
	//крохин конец 18.06.2013
	//Катаев+ 25/12/13 Если контрагент не в группе "Покупатели", то в узел не добавляем
	Контрагент2 = Контрагент;
	Пока Контрагент2.Уровень() <> 0 Цикл
		Контрагент2 = Контрагент2.Родитель;
	КонецЦикла;
	//Катаев+ 29/01/14 Контрагент может быть и из интегральной базы. Добавил в проперку еще и его.
	Если Контрагент2 <> справочники.Контрагенты.НайтиПоКоду("SSP-0001") и Контрагент2 <> справочники.Контрагенты.НайтиПоКоду("SMN-0001") Тогда 
		Возврат;
	КонецЕсли;
	//Катаев- 25/12/13
	//Катаев+ 10/07/13 Есть контрагенты у которых узлы прописаны как в контрагенте, так и в вышестоящих узлах. Добавлять необходимо во все узлы.
	//Пока Контрагент1.РегиональныеУзлы.Количество()=0 И Контрагент1.Уровень()>1 Цикл
	//	Контрагент1 = Контрагент1.Родитель;
	//КонецЦикла;
	//Если Контрагент1.РегиональныеУзлы.Количество() <> 0 Тогда
	//	Для каждого Фил Из Контрагент1.РегиональныеУзлы Цикл
	//		УзелФил = ПланыОбмена.Основной.НайтиПоКоду(Фил.КодУзла);
	//		Если УзелФил <> ПланыОбмена.Основной.НайтиПоКоду("SNL") И УзелФил <> УзелСклада Тогда
	//			ДобавитьУзелВПолучателей(СписокПолучателей,УзелФил,Отправитель,Загрузка);
	//		КонецЕсли;
	//	КонецЦикла;
	//КонецЕсли;
	Пока Контрагент1.Уровень() > 1 цикл
		Пока Контрагент1.РегиональныеУзлы.Количество()=0 И Контрагент1.Уровень()>1 Цикл
			Контрагент1 = Контрагент1.Родитель;
		КонецЦикла;
		Если Контрагент1.РегиональныеУзлы.Количество() <> 0 Тогда
			Для каждого Фил Из Контрагент1.РегиональныеУзлы Цикл
				УзелФил = ПланыОбмена.Основной.НайтиПоКоду(Фил.КодУзла);
				Если УзелФил <> ПланыОбмена.Основной.НайтиПоКоду("SNL") И УзелФил <> УзелСклада Тогда
					//Катаев+ 17/10/14 В узел склада добавляем если при условии что загружать в склад можно 
					//ДобавитьУзелВПолучателей(СписокПолучателей,УзелФил,Отправитель,Загрузка);
					Если ЗагружатьНаСклад Тогда
						ДобавитьУзелВПолучателей(СписокПолучателей,УзелФил,Отправитель,Загрузка);
					Иначе
						Если УзелФил.ТипУзла <> Перечисления.ТипУзлаИБ.Склад Тогда
							ДобавитьУзелВПолучателей(СписокПолучателей,УзелФил,Отправитель,Загрузка);
						КонецЕсли;
					КонецЕсли;
					//Катаев- 17/10/14
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		//Катаев+ 11/07/13
		Контрагент1 = Контрагент1.Родитель;
		УровеньК = Контрагент1.Уровень();
		//Катаев- 11/07/13
	КонецЦикла;
	//Еатаев- 10/07/13
КонецПроцедуры
