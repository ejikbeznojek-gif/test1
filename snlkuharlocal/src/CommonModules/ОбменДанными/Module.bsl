Функция ПеревестиИмяУзла(Имя)
	Словарь=Новый Соответствие();
	
	Словарь.Вставить("DocumentObject","Документ");
	Словарь.Вставить("CatalogObject","Справочник");
	Словарь.Вставить("Ref","Ссылка");
	Словарь.Вставить("Date","Дата");
	Словарь.Вставить("Number","Номер");
	Словарь.Вставить("Code","Код");	
	
	Попытка	
		Возврат Словарь[Имя];	
	Исключение
		Возврат Имя;	
	КонецПопытки;
КонецФункции // ПеревестиИмяУзла()

Функция ПолучитьРезвизитыИзXML(ПредставлениеXML) Экспорт
	Чтение=Новый ЧтениеXML;
	Чтение.УстановитьСтроку(ПредставлениеXML);
	
	ИзвлекаемыеПоля=Новый Структура("Ref,Date,Number,Code","Ссылка","Дата","Номер","Код");
	
	СтруктураРеквизитов=Новый Структура;
	
	СчитаноЭлементов=0;
	
	Пока Чтение.Прочитать() Цикл
		Если Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда
			ИмяУзла=Чтение.Имя;
			Поз=Найти(ИмяУзла,".");
			Если Поз<>0 Тогда
				Тип=Лев(Чтение.Имя,Поз-1);
				Вид=Сред(Чтение.Имя,Поз+1);			
				
				СтруктураРеквизитов.Вставить("Тип",ПеревестиИмяУзла(Тип));
				СтруктураРеквизитов.Вставить("Вид",Вид);
			КонецЕсли; 
		ИначеЕсли Чтение.ТипУзла=ТипУзлаXML.Текст Тогда			
			СчитаноЭлементов=СчитаноЭлементов+1;
			
			ЗначениеЭлемента=ТипУзлаXML.Текст;
			Если ИзвлекаемыеПоля.Свойство(ИмяУзла) Тогда
				СтруктураРеквизитов.Вставить(ПеревестиИмяУзла(ИмяУзла),?(ИмяУзла="Date",XMLЗначение(Тип("Дата"),Чтение.Значение),Чтение.Значение));			
			КонецЕсли; 
		КонецЕсли;		
		
		Если СчитаноЭлементов>7 Тогда Прервать КонецЕсли; 
	КонецЦикла;	
	
	Возврат  СтруктураРеквизитов;
КонецФункции // ПолучитьРезвизитыПакета()


