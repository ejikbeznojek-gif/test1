Функция ПолучитьСписокПолучателейЦен(ТипЦен) Экспорт
	СписокПолучателей=Новый Массив;
	
	Запрос=Новый Запрос;					
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка
	|ИЗ
	|	ПланОбмена.Основной.ТипыЦен КАК ОсновнойТипыЦен
	|ГДЕ
	|	ТипЦен = &ТипЦен";
	
	Запрос.УстановитьПараметр("ТипЦен",ТипЦен);
	
	Выборка=Запрос.Выполнить().Выбрать();	
	
	Если Выборка.Количество()=0 Тогда
		//если данный тип цен не имеет персональной адресации
		//отправляем во все розничные подразделения
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Основной.Ссылка
		|ИЗ
		|	ПланОбмена.Основной КАК Основной
		|ГДЕ
		//крохин начало 31.05.2019
		|   НЕ Ссылка.ПометкаУдаления И
		//крохин конец 31.05.2019
		|	Основной.ТипУзла = &ТипУзла";
		Запрос.УстановитьПараметр("ТипУзла",Перечисления.ТипУзлаИБ.ТорговоеПодразделение);	
		
		Выборка=Запрос.Выполнить().Выбрать();	
	КонецЕсли; 
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.Ссылка<>ПланыОбмена.Основной.ЭтотУзел() Тогда
			СписокПолучателей.Добавить(Выборка.Ссылка);
		КонецЕсли;				
	КонецЦикла;	
	
	Возврат СписокПолучателей;	
КонецФункции // ПолучитьСписокПолучателейЦен()

