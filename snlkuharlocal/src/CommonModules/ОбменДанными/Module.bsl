Функция ПолучитьТаблицуУзловОсновногоОбмена (НужныСклады=ложь,НужныФилиалы=ложь,НужныТЦ=Ложь) экспорт
	
	если не НужныСклады и не НужныФилиалы и не НужныТЦ  тогда
		ТЗ=новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Узел");
		Возврат ТЗ; //Для совместимости
	КонецЕсли;
	
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	Основной.Ссылка КАК Узел
	             |ИЗ
	             |	ПланОбмена.Основной КАК Основной
	             |ГДЕ
	             |	Основной.Ссылка <> &ЭтотУзел
	             |	И НЕ Основной.ПометкаУдаления
	             |	И Основной.ТипУзла = &Склад
	             |	И &НужныСклады
	             |
	             |ОБЪЕДИНИТЬ ВСЕ
	             |
	             |ВЫБРАТЬ
	             |	Основной.Ссылка
	             |ИЗ
	             |	ПланОбмена.Основной КАК Основной
	             |ГДЕ
	             |	Основной.Ссылка <> &ЭтотУзел
	             |	И НЕ Основной.ПометкаУдаления
	             |	И Основной.ТипУзла = &Магазин
	             |	И Основной.Подразделение.ЕстьВыделенныйСклад
	             |	И &НужныФилиалы
	             |
	             |ОБЪЕДИНИТЬ ВСЕ
	             |
	             |ВЫБРАТЬ
	             |	Основной.Ссылка
	             |ИЗ
	             |	ПланОбмена.Основной КАК Основной
	             |ГДЕ
	             |	Основной.Ссылка <> &ЭтотУзел
	             |	И НЕ Основной.ПометкаУдаления
	             |	И Основной.ТипУзла = &Магазин
	             |	И НЕ Основной.Подразделение.ЕстьВыделенныйСклад
	             |	И &НужныТЦ";	
	
	запрос.УстановитьПараметр("ЭтотУзел",ПланыОбмена.Основной.ЭтотУзел());
	
	запрос.УстановитьПараметр("НужныСклады",НужныСклады);
	запрос.УстановитьПараметр("Склад",Перечисления.ТипУзлаИБ.Склад);
	
	запрос.УстановитьПараметр("НужныФилиалы",НужныФилиалы);
	запрос.УстановитьПараметр("НужныТЦ",НужныТЦ);
	запрос.УстановитьПараметр("Магазин",Перечисления.ТипУзлаИБ.ТорговоеПодразделение);

	возврат запрос.Выполнить().выгрузить();
