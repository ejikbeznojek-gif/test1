Процедура УстановитьПолучателейИзмененийОбъектаВнешние(Объект)	Экспорт
	
	ЭтотУзел	=ПланыОбмена.ВнешниеКлиенты.ЭтотУзел();		
	ТипОбъекта	=ТипОбъекта(Объект);
	ВидОбъекта	=Объект.Метаданные().Имя;
	ОбменДанными=Объект.ОбменДанными;
	
	//Мессерле 25,10,2012 -по пунктам доставки
	Если ВидОбъекта="РасходнаяНакладная" и ЗначениеЗаполнено(объект.ПунктДоставки) Тогда
		Если ЗначениеЗаполнено(объект.ПунктДоставки.УзелОбменаВнешнихКлиентов) тогда
			ОбменДанными.Получатели.Добавить(объект.ПунктДоставки.УзелОбменаВнешнихКлиентов);
		Конецесли;
	Конецесли;	
	
	//Катаев+ 24/09/14 Типы цен теперь будут браться из карточки внешнего клиента
	//Если ВидОбъекта="ПрайсЛист" и (объект.ТипЦен.код="SNL-0229" или объект.ТипЦен.код="SSP-0314" или объект.ТипЦен.код="SSP-0333 ") Тогда //Коды дал Гришаков  ));//Катаев+ 20/06/14 добавил прайс по белью
	//	уз=планыобмена.ВнешниеКлиенты.Выбрать();
	//	пока уз.Следующий() цикл
	//		если Уз.Ссылка<>планыобмена.ВнешниеКлиенты.ЭтотУзел() тогда
	//			ОбменДанными.Получатели.Добавить(уз.ссылка);
	//		Конецесли;
	//	Конеццикла;
	//Конецесли;	
	Если ВидОбъекта="ПрайсЛист" Тогда
		уз=планыобмена.ВнешниеКлиенты.Выбрать();
		пока уз.Следующий() цикл
			//крохин начало 30.09.2020
			Если уз.ПометкаУдаления Тогда Продолжить; КонецЕсли;
			//крохин конец 30.09.2020
			если Уз.Ссылка<>планыобмена.ВнешниеКлиенты.ЭтотУзел() тогда
				Если уз.ТипыЦен.Количество() = 0 Тогда
					// Если типы цен не указаны, то проверяем входит ли тип цен в следующие - (0) Оптовый Базовый Ценовой Лист (ОБЦЛ), SALE ОПТ (оптовые клиенты) или Базовый прайс  - БЕЛЬЕ
					Если объект.ТипЦен.код="SNL-0229" или объект.ТипЦен.код="SSP-0314" или объект.ТипЦен.код="SNL-0333" Тогда
						ОбменДанными.Получатели.Добавить(уз.ссылка);
					КонецЕсли;
				Иначе
					для Каждого типЦен из уз.ТипыЦен Цикл
						Если типЦен.ТипЦен = объект.ТипЦен Тогда
							ОбменДанными.Получатели.Добавить(уз.ссылка);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Конецесли;
		Конеццикла;
	Конецесли;	
	//Катаев- 24/09/14
	//Катаев+ 17/06/14 Регистрация справочников Номенклатуры и ШК
	Если ВидОбъекта = "Номенклатура" или ВидОбъекта = "ШтрихКоды" Тогда
		уз=планыобмена.ВнешниеКлиенты.Выбрать();
		Если ВидОбъекта = "Номенклатура" Тогда
			текОбъект = Объект.Ссылка;
		Иначе
			текОбъект = Объект.Владелец.Ссылка;
		КонецЕсли;
		пока уз.Следующий() цикл
			//крохин начало 30.09.2020
			Если уз.ПометкаУдаления Тогда Продолжить; КонецЕсли;
			//крохин конец 30.09.2020
			Если Уз.Ссылка <> ПланыОбмена.ВнешниеКлиенты.ЭтотУзел() Тогда
				Если Уз.ВыгружаемаяНоменклатура.Количество() = 0 Тогда
					ОбменДанными.Получатели.Добавить(уз.ссылка);
				Иначе
					Запрос = Новый запрос;
					Запрос.Текст =
					"ВЫБРАТЬ
					|	ВнешниеКлиентыВыгружаемаяНоменклатура.Номенклатура
					|ПОМЕСТИТЬ тз
					|ИЗ
					|	ПланОбмена.ВнешниеКлиенты.ВыгружаемаяНоменклатура КАК ВнешниеКлиентыВыгружаемаяНоменклатура
					|ГДЕ
					|	ВнешниеКлиентыВыгружаемаяНоменклатура.Ссылка = &Узел
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	тз.Номенклатура
					|ИЗ
					|	тз КАК тз
					|ГДЕ
					|	тз.Номенклатура В (&сзНоменклатура)";
					сзНоменклатура = Новый СписокЗначений;
					Пока текОбъект.Уровень() <> 0 Цикл
						сзНоменклатура.Добавить(текОбъект);
						текОбъект = текОбъект.Родитель;
					КонецЦикла;
					сзНоменклатура.Добавить(текОбъект);
					Запрос.УстановитьПараметр("сзНоменклатура", сзНоменклатура);
					Запрос.УстановитьПараметр("Узел", уз.ссылка);
					выборка = запрос.Выполнить().Выбрать();
					Если Выборка.Следующий() Тогда
						ОбменДанными.Получатели.Добавить(уз.ссылка);
					КонецЕсли;
				КонецЕсли;
			Конецесли;
		Конеццикла;
	КонецЕсли;
	//Катаев- 17/06/14
КонецПроцедуры
