Процедура УстановитьПолучателейИзмененийОбъекта(Объект)	Экспорт
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	ОбменДанными=Объект.ОбменДанными;
	
	ЭтотУзел	=ПланыОбмена.Основной.ЭтотУзел();		
	ТипУзла		=ПараметрыСеанса.ТипУзла;
	
	ТипОбъекта	=ТипОбъекта(Объект);
	ВидОбъекта	=Объект.Метаданные().Имя;
	
	//ОбменДанными.Получатели.Очистить();
	СписокПолучателей=ПолучитьСписокПолучателейИзмененийОбъекта(Объект);
	Для Каждого Получатель Из СписокПолучателей Цикл		
		УзелПолучатель=Получатель.Значение;
		Если ТипОбъекта="Документ" И УзелПолучатель.ОтключитьОбменДокументами Тогда
			Если ВидОбъекта="УстановкаСкидок" ИЛИ ВидОбъекта="ПрайсЛист" ИЛИ ВидОбъекта="ПланПродаж" Тогда
			Иначе
				Продолжить;			
			КонецЕсли;			
		КонецЕсли;
		Если НЕ УзелПолучатель.Пустая() и УзелПолучатель <> ЭтотУзел Тогда
			ОбменДанными.Получатели.Добавить(УзелПолучатель);		
		КонецЕсли;		
	КонецЦикла;	
	
	//Отправка подтверждений о приеме накладных складом или магазином
	Если ТипОбъекта="Документ" И ОбменДанными.Загрузка И ОбменДанными.Отправитель<>Неопределено Тогда
		Отправитель				=ОбменДанными.Отправитель;
		
		Если НЕ Объект.Ссылка.Пустая() И ПланыОбмена.ИзменениеЗарегистрировано(Отправитель,Объект) И СписокПолучателей.НайтиПоЗначению(Отправитель)=Неопределено Тогда	
			ОбменДанными.Отправитель
			=Неопределено;
			ОбменДанными.Получатели.Добавить(Отправитель);
		КонецЕсли; 
		
		Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если ВидОбъекта="Перемещение" Тогда
				Если Объект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.КОтправкеВОфис Тогда
					Объект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.ПолученоОфисом;				
					
					ОбменДанными.Отправитель=Неопределено;
					ОбменДанными.Получатели.Добавить(Отправитель);
				ИначеЕсли Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеВОфис Тогда
					Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоОфисом;				
					
					ОбменДанными.Отправитель=Неопределено;
					ОбменДанными.Получатели.Добавить(Отправитель);					
				КонецЕсли;		
			ИначеЕсли (ВидОбъекта="РасходнаяНакладная" ИЛИ ВидОбъекта="ПриходнаяНакладная") И Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеВОфис Тогда
				Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоОфисом;
				
				ОбменДанными.Отправитель=Неопределено;
				ОбменДанными.Получатели.Добавить(Отправитель);
			КонецЕсли;
		ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.Склад ИЛИ ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			Если Отправитель<>Неопределено Тогда
				Если (ВидОбъекта="РасходнаяНакладная" ИЛИ ВидОбъекта="ПриходнаяНакладная" ИЛИ ВидОбъекта="Комплектация" ИЛИ ВидОбъекта="АктПриемкиМашины") И Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда
					Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоСкладом;			
					
					ОбменДанными.Отправитель=Неопределено;
					ОбменДанными.Получатели.Добавить(Отправитель);					
				ИначеЕсли ВидОбъекта="Перемещение" Тогда
					Если Объект.Склад.КодФизическогоУзла=ЭтотУзел.Код И Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда
						Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоСкладом;
						
						ОбменДанными.Отправитель=Неопределено;
						ОбменДанными.Получатели.Добавить(Отправитель);		
					ИначеЕсли Объект.СкладПолучатель.КодФизическогоУзла=ЭтотУзел.Код И Объект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда				
						Объект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.ПолученоСкладом;
						
						ОбменДанными.Отправитель=Неопределено;
						ОбменДанными.Получатели.Добавить(Отправитель);		
					КонецЕсли;					
				КонецЕсли;				
			КонецЕсли;		
		КонецЕсли;
		
		Если ВидОбъекта="ЗаявкаНаОтгрузку" И ЭтотУзел=Константы.УзелТранспортногоОтдела.Получить() И Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда
			Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоСкладом; 
			
			ОбменДанными.Отправитель=Неопределено;
			ОбменДанными.Получатели.Добавить(Отправитель);							
		КонецЕсли; 
	КонецЕсли;	
КонецПроцедуры


//Возвращает Узел текущей ИБ для заданного узла
