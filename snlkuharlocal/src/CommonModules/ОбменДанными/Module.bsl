Функция ПолучитьСписокПолучателейИзмененийОбъекта(Объект,ДопИнфо=Неопределено)
	ЭтотУзел			=ПланыОбмена.Основной.ЭтотУзел();		
	УправляющийУзел		=ЭтотУзел.УправляющийУзел;
	ТипУзла				=ПараметрыСеанса.ТипУзла;
	
	ОбменДанными		=Объект.ОбменДанными;
	Отправитель			=ОбменДанными.Отправитель;
	Загрузка			=ОбменДанными.Загрузка;
	
	СписокПолучателей	=Новый СписокЗначений;
	ТипОбъекта			=ТипОбъекта(Объект);
	ВидОбъекта			=Объект.Метаданные().Имя;

	ДокументВзаиморасчетов = Ложь;
	
	Если ТипОбъекта="Документ" Тогда
		Если ВидОбъекта="РасходнаяНакладная" ИЛИ ВидОбъекта="ПриходнаяНакладная" Тогда
			Склад		=Объект.Склад;
			УзелСклада	=ПланыОбмена.Основной.НайтиПоКоду(Склад.КодФизическогоУзла);			
			
			Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				Если Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе Тогда 
				ИначеЕсли Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоОфисом Тогда 
				Иначе					
					ДобавитьУзелВПолучателей(СписокПолучателей,УзелСклада,Отправитель,Загрузка);
				КонецЕсли; //На склад выгружаются только накладные к отправке и измененные после отправки				

				Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И (Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена ИЛИ Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.Принята) Тогда
					ДобавитьВУзелФилиала(СписокПолучателей, Отправитель, Загрузка, Объект.Контрагент, УзелСклада);
					ДокументВзаиморасчетов = Истина;
				ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И Объект.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе И ВидОбъекта="ПриходнаяНакладная" Тогда
					ДобавитьВУзелФилиала(СписокПолучателей, Отправитель, Загрузка, Объект.Контрагент, УзелСклада);
					ДокументВзаиморасчетов = Истина;
				КонецЕсли; 
				Если Объект.ПометкаУдаления Тогда
					ДобавитьВУзелФилиала(СписокПолучателей, Отправитель, Загрузка, Объект.Контрагент, УзелСклада);
					ДокументВзаиморасчетов = Истина;
				КонецЕсли;
			ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.Склад ИЛИ ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
				Если Объект.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе Тогда 
					Если Объект.Склад.КодФизическогоУзла=ЭтотУзел.Код Тогда
						ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);					
					КонецЕсли;
					//теперь резервные РНК выгружаются в офис
				Иначе
					Если ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение И ВидОбъекта="РасходнаяНакладная" Тогда
						//теперь из оптовых ТЦ не выгружаются РНК
						Если Объект.Склад.КодФизическогоУзла=ЭтотУзел.Код И (Объект.Склад.ТипСклада = Перечисления.ТипСклада.Филиал) Тогда
							ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);					
						КонецЕсли;	
					КонецЕсли;
				КонецЕсли; //На склад выгружаются только накладные к отправке и измененные после отправки
			КонецЕсли;
		ИначеЕсли ВидОбъекта="ОтчетКассовойСмены" Тогда
			Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				//ОКСЫ - в обратку не отправляем принципиально !!!
			ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
				ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
			КонецЕсли;
			//нечаева 02,09,16+++ 
		//нечаева 09.06.26 +++ эТРН
		ИначеЕсли ВидОбъекта="ЭлТранспортнаяНакладная" Тогда
			//Только со склада в офис.
			Если ТипУзла=Перечисления.ТипУзлаИБ.склад Тогда
				ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
			КонецЕсли;
		//нечаева 09.06.26 ---	
	    ИначеЕсли ВидОбъекта="Паллета" Тогда
			Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				//обратно паллеты не отправляем, только склад их редактирует.
				// и грузим в офис только по Ленте, для екода, по паллетам
			ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.склад Тогда
				ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
			КонецЕсли;	                      //нечаева 12,11,18 +++
		ИначеЕсли ВидОбъекта="ЛистНабора" или ВидОбъекта="ЛистПереукладки"  Тогда
			//нечаева 12,11,18 ---
			Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
				//обратно на склад не отправляем, только склад их редактирует.
				// и грузим в офис только по Ленте, для екода, по паллетам
			ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.склад Тогда
				ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
			КонецЕсли;	
			//нечаева 02,09,16--- 		
		ИначеЕсли ВидОбъекта="Перемещение" Тогда
			Склад			=Объект.Склад;
			СкладПолучатель =Объект.СкладПолучатель;
			
			УзелСклада				=ПланыОбмена.Основной.НайтиПоКоду(Склад.КодФизическогоУзла);
			УзелСкладаПолучателя	=ПланыОбмена.Основной.НайтиПоКоду(СкладПолучатель.КодФизическогоУзла);
			
			Если НЕ (СкладПолучатель.ФизическийСклад=Склад ИЛИ СкладПолучатель=Склад.ФизическийСклад ИЛИ (СкладПолучатель.ФизическийСклад = Склад.ФизическийСклад И Не ПустаяСтрока(Склад.ФизическийСклад))) Тогда //виртуалки пропускаем
				Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
					Если Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе Тогда
					ИначеЕсли Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ПолученоОфисом Тогда
					Иначе						
						ДобавитьУзелВПолучателей(СписокПолучателей,УзелСклада,Отправитель,Загрузка);						
					КонецЕсли; 
					Если Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена
						ИЛИ Объект.СостояниеНакладной=Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда //накладные на склад получатель отправляем только после отгрузки
						Если Объект.СостояниеНакладнойУПолучателя.Пустая() Тогда
							Объект.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.КОтправкеНаСклад;						
						КонецЕсли;
						ДобавитьУзелВПолучателей(СписокПолучателей,УзелСкладаПолучателя,Отправитель,Загрузка);						
					КонецЕсли;					
				ИначеЕсли ТипУзла=Перечисления.ТипУзлаИБ.Склад ИЛИ ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда		
					Если Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код И Объект.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе Тогда
						ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
