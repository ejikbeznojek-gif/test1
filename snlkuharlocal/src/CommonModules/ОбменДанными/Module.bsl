Функция ПолучитьСписокПолучателейИННКонтрагентов() Экспорт
	СписокПолучателей=Новый Массив;
	
	Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		// филиалы
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	Основной.Ссылка,
		|	Основной.Наименование
		|ИЗ
		|	ПланОбмена.Основной КАК Основной
		|ГДЕ
		|	(НЕ Основной.ПометкаУдаления)
		|	И Основной.Ссылка <> &ЭтотУзел
		|	И Основной.Подразделение В ИЕРАРХИИ(&Филиалы)";
		
		Запрос.УстановитьПараметр("ЭтотУзел",ПараметрыСеанса.ЭтотУзел);
		// деп. опт. продаж
		Запрос.УстановитьПараметр("Филиалы",Справочники.Подразделения.НайтиПоКоду("GRP-0419"));
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если истина Тогда
				СписокПолучателей.Добавить(Выборка.Ссылка);		
			КонецЕсли;
		КонецЦикла; 
		// склады
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	Основной.Ссылка,
		|	Основной.Наименование
		|ИЗ
		|	ПланОбмена.Основной КАК Основной
		|ГДЕ
		|	(НЕ Основной.ПометкаУдаления)
		|	И Основной.Ссылка <> &ЭтотУзел
		|	И Основной.ТипУзла = &Склады";
		
		Запрос.УстановитьПараметр("ЭтотУзел",ПараметрыСеанса.ЭтотУзел);
		Запрос.УстановитьПараметр("Склады",Перечисления.ТипУзлаИБ.Склад);
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если истина Тогда
				СписокПолучателей.Добавить(Выборка.Ссылка);		
			КонецЕсли;
		КонецЦикла; 
		
	Иначе
		СписокПолучателей.Добавить(ПараметрыСеанса.ЭтотУзел.УправляющийУзел);
	КонецЕсли;	
	
	Возврат СписокПолучателей;
КонецФункции // ПолучитьСписокПолучателейЦен()
