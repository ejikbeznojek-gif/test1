				ДобавитьУзелВПолучателей(СписокПолучателей,УправляющийУзел,Отправитель,Загрузка);
			ИначеЕсли ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
				СписокКодовУзлов=новый СписокЗначений;
				
				СписокКодовУзлов.Добавить("OD7");
				
				для каждого СтрСписка из СписокКодовУзлов цикл
					ДобавитьУзелВПолучателей(СписокПолучателей,ПланыОбмена.Основной.НайтиПоКоду(СтрСписка.Значение),Отправитель,Загрузка);
				КонецЦикла;
			КонецЕсли;   
		КонецЕсли;
	ИначеЕсли ТипОбъекта="Задача" Тогда    
		Если ВидОбъекта="ЗадачиПользователя" тогда
			Если ТипУзла=Перечисления.ТипУзлаИБ.Склад тогда
