		Иначе
			ЭтоГруппа=Ложь;
		КонецЕсли;		
		
		Объект=?(ЭтоГруппа,Справочники[Вид].СоздатьГруппу(),Справочники[Вид].СоздатьЭлемент());		
		Объект.УстановитьСсылкуНового(ОбъектXDTO.Ссылка);
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(Объект,ОбъектXDTO);
	
	Возврат Объект;
