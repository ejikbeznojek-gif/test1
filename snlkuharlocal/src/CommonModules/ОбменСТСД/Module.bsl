Функция ЗаписатьЛоги(УзелОбмена, ДанныеОбмена, ДопПараметры=Неопределено,ТекстОшибки="") Экспорт
	
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	КодУзда=УзелОбмена.код;
	
	МассивЗаписей=СтрЗаменить(ДанныеОбмена,"##",Символы.ПС);
	для сч=1 по СтрЧислоСтрок(МассивЗаписей) цикл
		ТекСтрока=СтрПолучитьСтроку(МассивЗаписей,сч);
		МассивАтрибутов=СтрЗаменить(ТекСтрока,"#",Символы.ПС);
		если СтрЧислоСтрок(МассивАтрибутов)<>3 тогда
			Продолжить;
		КонецЕсли;
		
		Период=СтрПолучитьСтроку(МассивАтрибутов,1);
		Действие=СтрПолучитьСтроку(МассивАтрибутов,2);
		Данные=СтрПолучитьСтроку(МассивАтрибутов,3);
		
		
		СтрокаЗаписи="Узел: "+КодУзда+", Дата "+Период+", Действие "+Действие+" ,Данные "+ Данные;
		ЗаписатьВЛог("Отладка",СтрокаЗаписи,"Информация");
		
	КонецЦикла;
	если ТранзакцияАктивна() тогда
		ЗафиксироватьТранзакцию();
	КонецЕсли;	
	
	
	
	Возврат Истина;
КонецФункции

