		НачатьТранзакцию();
	КонецЕсли;	
	// Кухарь А.Ю.  30.06.2025 конец

	Пока ЧтениеXML.ТипУзла <> ТипУзлаXML.КонецЭлемента Цикл	
		
		Данные = ПрочитатьДанные(ЧтениеXML, Фабрика);

		Если Данные = Неопределено Тогда 
			Продолжить; 
		КонецЕсли;
		
		Если ТипЗнч(Данные) = Тип("ДокументОбъект.ЗаданиеНабора") Тогда
			
			ЗНБ = Данные.Ссылка;
			
			Продолжить;
			
		КонецЕсли;		 

		Если Не ПринятьИзменения(Отправитель, Данные, ТекстОшибки) Тогда 
			Продолжить; 
		КонецЕсли;

		Данные.ОбменДанными.Отправитель = Отправитель;
		Данные.ОбменДанными.Загрузка = Истина;    
		
		если ТипЗнч(Данные)=Тип("ДокументОбъект.ЛистПереукладки") или
			ТипЗнч(Данные)=Тип("ДокументОбъект.ЛистНабора")
			тогда      
			Данные.УзелТСД = УзелОбмена;
		КонецЕсли;

		// Кельманов А.В. - SNL-187 - 2026.04.21 {
		Если ТипЗнч(Данные) = Тип("ДокументОбъект.ЛистПереукладки")
			И ТипЗнч(ДопПараметры) = Тип("Структура") 
			И ДопПараметры.Свойство("ДанныеТекущаяБригада") Тогда
			
			МассивТекущаяБригада = Десериализовать(Десериализовать(ДопПараметры.ДанныеТекущаяБригада).Получить());
			
			Данные.Бригада.Очистить();
			
			Если МассивТекущаяБригада <> Неопределено Тогда
				
				Для Каждого Сотрудник Из МассивТекущаяБригада Цикл
					
					СтрБригада = Данные.Бригада.Добавить();
					
					СтрБригада.Сотрудник = Сотрудник;
					
				КонецЦикла;
				
			КонецЕсли; 
			
		КонецЕсли;
		// Кельманов А.В. - SNL-187 - 2026.04.21 }
		
		Попытка  
			// Кухарь А.Ю.  03.07.2025 начало
			// Данные.Записать();				 			
			если ТипЗнч(Данные)=Тип("ДокументОбъект.ЛистПереукладки") тогда   
				Данные.ПростоЗаписать();	
			иначе		
				Данные.Записать();			
			КонецЕсли;		
			// Кухарь А.Ю.  03.07.2025 конец
			
		Исключение
			
			Инфо = ИнформацияОбОшибке();
			ТекстОшибки = ТекстОшибки + Символы.ПС + ОбработкаОшибок.КраткоеПредставлениеОшибки(Инфо);
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			Возврат Истина;
			
		КонецПопытки;	

		КоличествоЗагружаемыхОбъектов = КоличествоЗагружаемыхОбъектов + 1;
		
	КонецЦикла;	

	// Кельманов А.В. - HELP-7030 - 2025.09.16 {
	//Если КоличествоЗагружаемыхОбъектов > 0 Тогда
