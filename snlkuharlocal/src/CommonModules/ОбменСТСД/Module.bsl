Функция ЗарегистрироватьНачальныеДанные(Узел) Экспорт 
	
	Запрос = Новый Запрос;
	
	// Кухарь А.Ю. 28.01.2022 начало
	//Нужны только физ. лица
	//   	запрос.Текст=  "ВЫБРАТЬ
	//|	Пользователи.Ссылка КАК Ссылка,
	//|	Пользователи.ФизЛицо КАК ФизЛицо
	//|ИЗ
	//|	Справочник.Пользователи КАК Пользователи
	//|ГДЕ
	//|	НЕ Пользователи.ЭтоГруппа
	//|	И НЕ Пользователи.ПометкаУдаления
	//|	И Пользователи.ФизЛицо В ИЕРАРХИИ(&Логистика)" ;
	Запрос.Текст = "ВЫБРАТЬ
	|	ФизическиеЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	НЕ ФизическиеЛица.ЭтоГруппа
	|	И НЕ ФизическиеЛица.ПометкаУдаления
	// Кельманов А.В. - HELP-7119 - 2025.09.19 {
	//|	И ФизическиеЛица.Ссылка В ИЕРАРХИИ(&Логистика)";	
	|	И (ФизическиеЛица.Ссылка В ИЕРАРХИИ (&Логистика)
	// Кельманов А.В. - Оптимизация работы - 2025.12.04 {
	|			ИЛИ ФизическиеЛица.Ссылка В ИЕРАРХИИ (&СкладЧасцы)	
	// Кельманов А.В. - Оптимизация работы - 2025.12.04 }
	|			ИЛИ ФизическиеЛица.Ссылка В ИЕРАРХИИ (&Аутсорсинг))";	
	// Кельманов А.В. - HELP-7119 - 2025.09.19 }
	// Кухарь А.Ю. 28.01.2022 конец
	
	Запрос.УстановитьПараметр("Логистика", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00850"));
	Запрос.УстановитьПараметр("Аутсорсинг", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-09056"));
	Запрос.УстановитьПараметр("СкладЧасцы", Справочники.ФизическиеЛица.НайтиПоКоду("SNL-09136")); // Кельманов А.В. - Оптимизация работы - 2025.12.04
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		
		//ПланыОбмена.ЗарегистрироватьИзменения(Узел,результат.ссылка);
		// Кухарь А.Ю. 28.01.2022 начало
		// 		ПланыОбмена.ЗарегистрироватьИзменения(Узел,результат.ФизЛицо);		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Результат.Ссылка);				 
		// Кухарь А.Ю. 28.01.2022 конец
		
	КонецЦикла;
	
	// Кухарь А.Ю. 06.04.2022 начало
	//Выгрузка типов коробов в ТСД
	СписокКоробов=новый СписокЗначений;
	СписокКоробов.Добавить(Справочники.ТипыКоробов.СтандартныеКороба);
	СписокКоробов.Добавить(Справочники.ТипыКоробов.ПустаяСсылка());
	
	запрос.текст="ВЫБРАТЬ
	|	ТипыКоробов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ТипыКоробов КАК ТипыКоробов
	|ГДЕ
	|	ТипыКоробов.Родитель В(&СписокТиповКоробов)
	|	И ТипыКоробов.ШтрихКод <> """"""""
