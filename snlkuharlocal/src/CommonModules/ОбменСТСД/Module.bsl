// Кухарь А.Ю.  22.06.2025 начало  
Функция ЗарегистрироватьДанныеЗНА (СтруктураПараметров) экспорт  
	ШтрихКод			 = СтруктураПараметров.ШтрихКод;
	КоличествоКоробок	 = СтруктураПараметров.КоличествоКоробок;
	НужныТолькоЛП		 = СтруктураПараметров.НужныТолькоЛП;
	Узел		 		 = СтруктураПараметров.Узел;   
	Сканировщик 		 = Справочники.ФизическиеЛица.ПолучитьСсылку(новый УникальныйИдентификатор(СтруктураПараметров.Сканировщик));
	УИД_ЗНА				 = СтруктураПараметров.УИД_ЗНА;

	
	
	ПланыОбмена.УдалитьРегистрациюИзменений(Узел);
	
	СтруктураВозврата = новый Структура("Успех,Ошибки",ложь, новый Массив);
	если ШтрихКод <> "" тогда 
		Попытка
			ЗНА = ЗначениеИзСтрокиВнутр(ШтрихКод);
		исключение                                
			СтруктураВозврата.Ошибки.Добавить("Не удалось найти ЗНА по ШК. "+ОписаниеОшибки());
			возврат СтруктураВозврата;
		КонецПопытки;    
	иначе
		Попытка
			ЗНА = Документы.ЗаданиеНаАгрегацию.ПолучитьСсылку(новый УникальныйИдентификатор(СтруктураПараметров.УИД_ЗНА));
		исключение                                
			СтруктураВозврата.Ошибки.Добавить("Не удалось найти ЗНА по УИД. "+ОписаниеОшибки());
			возврат СтруктураВозврата;
		КонецПопытки;  
	КонецЕсли;
	
	если ТипЗнч(ЗНА) <> Тип("ДокументСсылка.ЗаданиеНаАгрегацию") тогда  
		СтруктураВозврата.Ошибки.Добавить("Не правильный тип найденного ЗНА -"+Строка(ТипЗнч(ЗНА)));	
	КонецЕсли;
	
	
	Запрос = новый запрос;    
	Запрос.УстановитьПараметр("ЗНА", ЗНА);   
	Запрос.УстановитьПараметр("Узел", Узел);  	
	Запрос.Текст="ВЫБРАТЬ
	             |	ЛистПереукладки.Ссылка КАК Ссылка,
	             |	ЛистПереукладки.Представление КАК Представление
	             |ИЗ
	             |	Документ.ЛистПереукладки КАК ЛистПереукладки
	             |ГДЕ
	             |	ЛистПереукладки.УзелТСД = &Узел
	             |	И ЛистПереукладки.ОтправленНаТСД
	             |	И НЕ ЛистПереукладки.ЗагруженИзТСД
	             |	И ЛистПереукладки.Проведен
	             |	И ЛистПереукладки.ЗаданиеНаАгрегацию = &ЗНА";
	выборка = запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл                                         
		ЗаписатьВЛог("ЗагрузкаАгрегацийТСД",СтрШаблон("Возвращение в работу листа %1, с ТСД %2, Сканировщик %3",выборка.Представление,Строка(Узел),Строка(Сканировщик)),"Информация");
		документы.ЛистПереукладки.ВернутьЛистОтЗНАВРаботу(выборка.ссылка);
	КонецЦикла;
	
	если КоличествоКоробок > 0 тогда
		Запрос.Текст = "ВЫБРАТЬ
		|	ЛистПереукладки.Ссылка КАК Лист,
		|	ЛистПереукладки.КодАгрегации КАК КодАгрегации
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|ГДЕ
		|	ЛистПереукладки.ЗаданиеНаАгрегацию = &ЗНА
		|	И ЛистПереукладки.Проведен
		|	И НЕ ЛистПереукладки.ОтправленНаТСД
		|	И НЕ ЛистПереукладки.ЗагруженИзТСД
		|	И ЛистПереукладки.КодАгрегации <> Значение(Справочник.ШтрихКодыУпаковокТоваров.ПустаяСсылка)	               
		|УПОРЯДОЧИТЬ ПО
		|	ЛистПереукладки.Дата";  
		Выборка = запрос.Выполнить().Выбрать();   
		
		если Выборка.Количество() = 0 тогда  
			СтруктураВозврата.Ошибки.Добавить("Не осталось свободных листов переукладки, для выполнения агрегации");  
			возврат СтруктураВозврата;
		КонецЕсли;     
		СчУспешноЗаписанныхЛистов = 0; 
		пока Выборка.Следующий() цикл
			ЛистОбъект = Выборка.Лист.ПолучитьОбъект();
			если ложь тогда ЛистОбъект = документы.ЛистПереукладки.СоздатьДокумент();КонецЕсли;
			
			попытка
				ЛистОбъект.Заблокировать();
			Исключение 
				Продолжить;
			КонецПопытки; 
			
			если ЛистОбъект.ОтправленНаТСД тогда
				Продолжить;
			КонецЕсли;     
			
			ЛистОбъект.ОтправленНаТСД	  = Истина;
			ЛистОбъект.УзелТСД		 	  = Узел;  
			ЛистОбъект.СканировщикФизЛицо = Сканировщик;
			ЛистОбъект.ПростоЗаписать();
			
			ПланыОбмена.ЗарегистрироватьИзменения(Узел, ЛистОбъект.Ссылка);
			ПланыОбмена.ЗарегистрироватьИзменения(Узел, ЛистОбъект.КодАгрегации);   
			
			// Кельманов А.В. - HELP-6412 - 2025.10.28 {
			Для Каждого СтрШКБлочков Из ЛистОбъект.ШтрихкодыУпаковокБлочков Цикл
				
				ПланыОбмена.ЗарегистрироватьИзменения(Узел, СтрШКБлочков.ШтрихкодУпаковки);
				
			КонецЦикла;
			// Кельманов А.В. - HELP-6412 - 2025.10.28 }
			
			СчУспешноЗаписанныхЛистов 		= СчУспешноЗаписанныхЛистов + 1;
			если СчУспешноЗаписанныхЛистов  = КоличествоКоробок тогда
				Прервать;
			КонецЕсли;   
			
		КонецЦикла;
		
		если СчУспешноЗаписанныхЛистов = 0 тогда  
			СтруктураВозврата.Ошибки.Добавить("Не удалось получить свободных листов переукладки, для выполнения агрегации. Попробуйте чуть позже.");
			возврат СтруктураВозврата;
		КонецЕсли;
	КонецЕсли;   
	
	
	если не НужныТолькоЛП тогда   //если последовательно загружают 1 листы от одного и того же ЗНА, то данные из этого блока  уже есть на ТСД.  
		
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, ЗНА);
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ТЧ.Номенклатура КАК Номенклатура,
		               |	ТЧ.Номенклатура.ОсновнаяЕдиница КАК ОсновнаяЕдиница,
		               |	ТЧ.Номенклатура.Цвет КАК Цвет,
		               |	ТЧ.Номенклатура.Размер КАК Размер
		               |ИЗ
		               |	Документ.ЗаданиеНаАгрегацию.Товары КАК ТЧ
		               |ГДЕ
		               |	ТЧ.Ссылка = &ЗНА";	
	
		ТЗПозиций = Запрос.Выполнить().Выгрузить();			
		Для Каждого СтрТЗ Из ТЗПозиций Цикл
			//ПланыОбмена.ЗарегистрироватьИзменения(Узел, СтрТЗ.Цвет);
			//ПланыОбмена.ЗарегистрироватьИзменения(Узел, СтрТЗ.Размер);
			ПланыОбмена.ЗарегистрироватьИзменения(Узел, СтрТЗ.Номенклатура);	
			//ПланыОбмена.ЗарегистрироватьИзменения(Узел, СтрТЗ.ОсновнаяЕдиница);			
		КонецЦикла;
		
		СписокПозиций = ТЗПозиций.ВыгрузитьКолонку("Номенклатура");
		запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		              |	ШтрихКоды.Ссылка КАК Ссылка
		              |ИЗ
		              |	Справочник.ШтрихКоды КАК ШтрихКоды
		              |ГДЕ
		              |	ШтрихКоды.Владелец В(&Владелец)
		              |	И НЕ ШтрихКоды.ПометкаУдаления
		              |	И ПОДСТРОКА(ШтрихКоды.Наименование, 1, 7) <> ""9999999""
		              |	И ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)";
		запрос.УстановитьПараметр("Владелец",СписокПозиций);
		результат=запрос.Выполнить().Выбрать();
		пока результат.Следующий() цикл
			ПланыОбмена.ЗарегистрироватьИзменения(Узел,результат.ссылка);	
		КонецЦикла;	
	КонецЕсли;
	
	
		
	если СтруктураВозврата.Ошибки.Количество() = 0 тогда  
		СтруктураВозврата.Успех = Истина;
	КонецЕсли; 
	
	
	Возврат СтруктураВозврата;
КонецФункции


Функция ПроверитьЛистПереукладкиПередВыгрузкойИзТСД (ДанныеТСД) Экспорт
	
	СтруктураВозврата = новый Структура ("Успех,Данные,Ошибки",Истина,Неопределено, новый Массив);
	
	//Лист = Документы.ЛистПереукладки.ПолучитьСсылку(новый УникальныйИдентификатор(ДанныеТСД.Лист));   
	Лист = ДанныеТСД.Лист;          
	Узел = ДанныеТСД.Узел;
	
	РеквизитыШапки = ПолучитьРеквизитыШапки(Лист,"Дата","Документ");  
	
	//МассивКодов = новый Массив;
	//для каждого СтрокаМассива из ДанныеТСД.МассивШтучныхКодов тогда   
	//	МассивКодов.Добавить(Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСсылку(новый УникальныйИдентификатор(СтрокаМассива)));
	//КонецЦикла;      
	МассивКодов = ДанныеТСД.МассивШтучныхКодов;
	
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
	|ГДЕ
	|	ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Проведен
	|	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка <> &Ссылка
	|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки В(&ШтрихкодУпаковки)
	|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки <> &ПустойШК
	|	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Дата >= &Дата";
	запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());	
	запрос.УстановитьПараметр("ссылка",Лист);	
	запрос.УстановитьПараметр("Дата",РеквизитыШапки.Дата-3*86400);	
	запрос.УстановитьПараметр("ШтрихкодУпаковки",МассивКодов); 
	МассивДублейКодов = запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	если МассивДублейКодов.Количество()>0 тогда
		СтруктураВозврата.Ошибки.Добавить("Обнаружены дубли кодов в других листах");
	КонецЕсли;    
	СтруктураВозврата.Данные = МассивДублейКодов;
	
	УзелЛиста = Строка(ПолучитьРеквизитШапки(Лист,"УзелТСД","Документ"));
	если ВРег(УзелЛиста)<> ВРег(Узел) тогда 
		СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Выгружаемый лист, уже загружен на другом ТСД %1. Удалите этот лист на главном меню агрегации и загрузите новый.",УзелЛиста));
	КонецЕсли;   
	если СтруктураВозврата.Ошибки.количество()> 0 тогда
		СтруктураВозврата.Успех = ложь;          
	КонецЕсли;
	
	возврат СтруктураВозврата;
КонецФункции


