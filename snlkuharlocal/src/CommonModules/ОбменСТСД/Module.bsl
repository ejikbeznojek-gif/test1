функция  ПолучитьЗаданиеИПолныеДанныеЗаданияНабораQRWB (ШтрихКод)
	СтруктураВозврата=новый Структура("Задание,ПолныеДанные");
	
	 //В тестовом варианте ищется левый документ, потом переделаю на ШК.
	 запрос=новый запрос;
	 запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	              |	ПолныеДанныеЗаданияНабора.ДокОснование КАК Задание,
	              |	ПолныеДанныеЗаданияНабора.Ссылка КАК ПолныеДанные
	              |ИЗ
	              |	Документ.ПолныеДанныеЗаданияНабора КАК ПолныеДанныеЗаданияНабора
	              |ГДЕ
	              |	ПолныеДанныеЗаданияНабора.Товары.ШтрихКодFBS = &ШтрихКодFBS
	              |	И ПолныеДанныеЗаданияНабора.Дата >= &Дата
	              |	И ПолныеДанныеЗаданияНабора.Проведен";
	 запрос.УстановитьПараметр("ШтрихКодFBS",ШтрихКод);
	 запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
	 
	 результат=запрос.Выполнить().Выбрать();
	 пока результат.Следующий() цикл
		 СтруктураВозврата.Задание=результат.задание;
		 СтруктураВозврата.ПолныеДанные=результат.полныеданные;
		 Возврат СтруктураВозврата;
	 КонецЦикла;
	 
	 возврат Неопределено;
	
КонецФункции
