// Кельманов А.В. - SNL-120 - 2026.04.08
Функция ЗарегистрироватьДанныеFBSПоНакладной(Узел, ШтрихКод, Ошибки = "", СтруктураДопПараметров) Экспорт
	
	ЗаданиеПоШК = ПолучитьЗаданиеПоШК(ШтрихКод);
		
	Если ЗаданиеПоШК = Неопределено Тогда
		
		Ошибки = "Не найдено задание по ШК"; 
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Накладная = ЗаданиеПоШК.Накладная;

	ИспользоватьЛНТолькоДляНабора = ИспользоватьЛНТолькоДляНабора(Накладная);
	
	Если Не ИспользоватьЛНТолькоДляНабора Тогда
		
		Ошибки = "Для накладной не установлен признак ""Использовать ЛН только для набора""!"; 
		
		Возврат Ложь;
		
	КонецЕсли;

	ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);
	
	Если Не ДопПараметрыНакладной.ОтгрузкаFBS Тогда
		
		Ошибки = "Это не накладная FBS!";
		
		Возврат Ложь;
		
	КонецЕсли;

	Если Накладная.СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеПереукладки Тогда
		
		Ошибки = "Состояние накладной: " + Накладная.СостояниеНакладной + ". Допустимое состояние для загрузки: ""Ожидание переукладки""";
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабора.Ссылка КАК ПолныеДанные
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора КАК ПолныеДанныеЗаданияНабора
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабора.Накладная = &Накладная
	               |	И ПолныеДанныеЗаданияНабора.Проведен";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	ТЗ_ПолныеДанные = Запрос.Выполнить().Выгрузить();
	
	Если ТЗ_ПолныеДанные.Количество() = 0 Тогда
		
		Ошибки = "Для накладной не создан документ ""Полные данные задания набора""!";
		
		Возврат Ложь;
		
	КонецЕсли;
	
	// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 {
	Если НужноОбновитьНакладнуюПоЗаказу(Накладная) Тогда
		
		ОбновитьНакладнуюПоЗаказу(Накладная);
		
	КонецЕсли;
	// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 }
	
	Если Накладная.ОтгрузкаКомплектов Тогда
		
		ЗСБЧЗ = Документы.ЗаданиеНаСборкуКомплектовЧЗ.ЗСБЧЗПоОснованию(Накладная);
		
		Если Не ЗначениеЗаполнено(ЗСБЧЗ) Тогда
			
			СтруктураОтвета = Документы.ЗаданиеНаСборкуКомплектовЧЗ.НайтиСоздатьДокНаРезервированиеКомплектовПодОтгрузку(Накладная, , Истина);
			
			Если Не СтруктураОтвета.Успех Тогда
				
				Ошибки = СтруктураОтвета.Ошибки;
				
				Возврат Ложь;
				
			Иначе
				
				ЗСБЧЗ = Документы.ЗаданиеНаСборкуКомплектовЧЗ.ЗСБЧЗПоОснованию(Накладная);
				
			КонецЕсли;
			
		КонецЕсли;
		
		ТекстОшибки = Документы.ЗаданиеНаСборкуКомплектовЧЗ.ПроверитьЗСБЧЗ(ЗСБЧЗ, Накладная);
		
		Если ТекстОшибки <> "" Тогда
			
			Ошибки = ТекстОшибки;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Накладная.Контрагент) Тогда
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Накладная.Контрагент);
		
	КонецЕсли;
	
	Для Каждого Стр Из ТЗ_ПолныеДанные Цикл
		
		// Кельманов А.В. - Изменение 0000000187 - 2026.07.08 {
		Ошибки = ПроверитьПустыеЗначенияВКолонкахПолныхДанных(Стр.ПолныеДанные);
		
		Если ЗначениеЗаполнено(Ошибки) Тогда
			
			Ошибки = "Ошибки в документе " + Стр.ПолныеДанные + ":" + Символы.ПС + Ошибки;
			
			Возврат Ложь;
			
		КонецЕсли;
		// Кельманов А.В. - Изменение 0000000187 - 2026.07.08 }
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр.ПолныеДанные);
				
	КонецЦикла;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТ_Номенклатура
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Товары КАК ПолныеДанныеЗаданияНабораТовары
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораТовары.Ссылка.Проведен
	               |	И ПолныеДанныеЗаданияНабораТовары.Ссылка.Накладная = &Накладная
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Номенклатура
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Комплектующие КАК ПолныеДанныеЗаданияНабораКомплектующие
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Проведен
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Накладная = &Накладная
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
	               |	ВТ_Номенклатура.Номенклатура.Родитель КАК Родитель,
	               |	ВТ_Номенклатура.Номенклатура.Цвет КАК Цвет,
	               |	ВТ_Номенклатура.Номенклатура.Размер КАК Размер
	               |ИЗ
	               |	ВТ_Номенклатура КАК ВТ_Номенклатура
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_Номенклатура.Номенклатура,
	               |	ВТ_Номенклатура.Номенклатура.Родитель,
	               |	ВТ_Номенклатура.Номенклатура.Цвет,
	               |	ВТ_Номенклатура.Номенклатура.Размер";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	ТЗПозиций = Запрос.Выполнить().Выгрузить();		
	
	Для Каждого Стр Из ТЗПозиций Цикл
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр.Цвет);
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр.Размер);
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр.Номенклатура);	
		
		Если ЗначениеЗаполнено(Стр.Родитель) Тогда
			
			ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр.Родитель);
			
		КонецЕсли;
		
	КонецЦикла;
	
	СписокПозиций = ТЗПозиций.ВыгрузитьКолонку("Номенклатура");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ШтрихКоды.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ШтрихКоды КАК ШтрихКоды
	               |ГДЕ
	               |	ШтрихКоды.Владелец В(&Владелец)
	               |	И НЕ ШтрихКоды.ПометкаУдаления
	               |	И ПОДСТРОКА(ШтрихКоды.Наименование, 1, 7) <> ""9999999""";
	
	Запрос.УстановитьПараметр("Владелец", СписокПозиций);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, Выборка.Ссылка);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ЗСБЧЗ) Тогда
		
		ПланыОбмена.ЗарегистрироватьИзменения(Узел, ЗСБЧЗ);
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
		|ИЗ
		|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок
		|ГДЕ
		|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", ЗСБЧЗ);
		
		ТЗ_Коды = Запрос.Выполнить().Выгрузить();
		
		Для Каждого Стр_Коды Из ТЗ_Коды Цикл
			
			ПланыОбмена.ЗарегистрироватьИзменения(Узел, Стр_Коды.ШтрихкодУпаковки);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Проведен
	|	И ЗаданиеНабора.Накладная = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ЗНБОбъект = Выборка.ЗНБ.ПолучитьОбъект();
		
		ЗНБОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.Переукладка;
		
		ЗНБОбъект.Записать();
		
	КонецЦикла;
	
	РНКОбъект = Накладная.ПолучитьОбъект();
	
	РНКОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.Переукладка;
	
	РНКОбъект.Записать();
			
	Возврат Истина;
	
КонецФункции

