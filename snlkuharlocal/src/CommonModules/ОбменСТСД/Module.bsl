	//НачатьТранзакцию();
	если ТипЗнч(ДопПараметры) = тип("Структура") 
		и ДопПараметры.Свойство("ВидВыгрузки") 
		и ДопПараметры.ВидВыгрузки = "ЛистыСАгрегациями" тогда 
		НужнаТранзакция = ложь;    
		ПроверятьЗНБ = ложь;
	иначе     
		НужнаТранзакция = Истина; 
		ПроверятьЗНБ = Истина;
	КонецЕсли;
	
