// Кухарь А.Ю. 16.02.2021 начало
Функция      НайтиДокПоШК (ШК) 
	ТекСтр=СокрЛП(ШК);
	ТекСтр=Раскодировать64Локальный(ТекСтр);
	
	Если Сред(ТекСтр,1,1)<>"*" Тогда
		Сообщить("Штрих-код: """+ШК+""" не является штрих-кодом документа !");
		Возврат "";
	КонецЕсли;	
	
	Если ПустаяСтрока(ТекСтр)=0 Тогда
		ТекСтр=Сред(ТекСтр,2,СтрДлина(ТекСтр)-2);
		ТекСтр=СтрЗаменить(ТекСтр,"*",Символы.ПС);
		
		СЗ=Новый Структура;
		
		Для Сч=1 По СтрЧислоСтрок(ТекСтр) Цикл
			СЗ.Вставить("Пар"+Сч,СтрПолучитьСтроку(ТекСтр,Сч));					
		КонецЦикла; 		
		
		Ид  	=СЗ.Пар1;
		Номер 	=СЗ.Пар2;         
		Дт  	=СЗ.Пар3;
		Дт  	=Дата("20"+Дт,1,1);
		
		Вид=ВидПоИДДокументаЛокальный(Ид);
		Если ПустаяСтрока(Вид)=1 Тогда
			Сообщить("Не обнаружен вид документа соответствующий ИД: """+Ид+""" !","!");     
			Возврат Неопределено;
		КонецЕсли;
		
		Док=Документы[Вид].НайтиПоНомеру(Номер,Дт);
		
		Если Док<>Неопределено И НЕ Док.Пустая() Тогда
			Возврат Док;   
		КонецЕсли;
	КонецЕсли; 
	
	Возврат Неопределено;
КонецФункции

Функция ВидПоИДДокументаЛокальный(Ид)  
	Для Каждого МетаДок Из Метаданные.Документы Цикл
		Если МетаДок.Синоним=Ид Тогда
			Возврат МетаДок.Имя;
		КонецЕсли;	    
	КонецЦикла;    
	Возврат "";
КонецФункции 


Функция Раскодировать64Локальный(НачСтр) Экспорт 
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=СокрЛП(НачСтр);
	
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		Символ=Сред(Стр,Сч,1);
		Десятичное=Найти(База,Символ)-1;		
		СтрокаБит=СтрокаБит+Сред(БинарноеЛокальный(Десятичное),3);		
	КонецЦикла;
	//КодировкаПрямая=Новый Соответствие;
	КодировкаОбратная=Новый Соответствие;
	ЗаполнитьКодировкиЛокальное(КодировкаОбратная);        
	СтрокаИсходная="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение=Лев(СтрокаБит,8);
		СтрокаИсходная	=СтрокаИсходная+СимволПоБайтовомуКодуЛокальный(ДесятичноеЛокальное(БитовоеЗначение),КодировкаОбратная);			    
		СтрокаБит		=Сред(СтрокаБит,9);
	КонецЦикла;                      
	
	Возврат СтрокаИсходная;	    
КонецФункции //Раскодировать

Функция БайтовыйКодСимволаЛокальный(Символ,КодировкаПрямая) Экспорт
	Возврат КодировкаПрямая[Символ];
КонецФункции // КодСимвола()

Функция СимволПоБайтовомуКодуЛокальный(Код,КодировкаОбратная)
	Возврат КодировкаОбратная[Код];
КонецФункции // ()

Функция БинарноеЛокальный(НачЗн)
	Зн=НачЗн;	
	Стр="";	
	Для Сч=1 по 8 Цикл
		Бит=Зн%2;
		
		Стр=""+Бит+Стр;   
		Зн=(Зн-Бит)/2;		
	КонецЦикла;     
	
	Возврат Стр;
КонецФункции //

Функция ДесятичноеЛокальное(НачЗн)
	Зн=0;
	База=128;
	
	ТекДлинна=Мин(СтрДлина(НачЗн),8);
	
	Для Сч=1 по ТекДлинна Цикл
		Зн=Зн+База*Число(Сред(НачЗн,Сч,1));					    
		База=База/2;
	КонецЦикла;
	
	Возврат Зн;
КонецФункции //Десятичное

