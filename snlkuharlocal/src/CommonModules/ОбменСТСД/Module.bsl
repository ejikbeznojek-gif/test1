						Если ЗначениеЗаполнено(ЗонаХранения) Тогда
							
							ЗаписатьЗначениеВРеквизитыДокументов(ЗонаХранения, РеквизитыШапкиЗНБ.Накладная, "ЗонаХранения");
							
						Иначе
							
							ЗаписатьЗначениеВРеквизитыДокументов(ДопПараметры.ШКЗоныХранения, РеквизитыШапкиЗНБ.Накладная, "ЗонаХранения");
							
						КонецЕсли;

						// Кельманов А.В. - HELP-9378 - 2026.04.07 {
						//Документы.ЗаданиеНабора.ОбработатьОкончаниеЗагрузкиЛНизТСД(ЗНБ, ТекстОшибки, ТекстОповещения);
						Документы.ЗаданиеНабора.ОбработатьОкончаниеЗагрузкиЛНизТСД(ЗНБ, ТекстОшибки, ТекстОповещения, Наборщик);
						// Кельманов А.В. - HELP-9378 - 2026.04.07 }
						
					Иначе	
						
						ТекстОшибки = "ЗНБ частично завершить не удалось. Продолжите набор";
						
						// Кельманов А.В. - ПРО-0000000110 - 2026.06.18 {
						Если ЗначениеЗаполнено(ТекстОшибкиПриЧастичномЗавершении) Тогда
							
							ТекстОшибки = ТекстОшибки + Символы.ПС + "Комментарий: " + ТекстОшибкиПриЧастичномЗавершении;
							
						КонецЕсли;
						// Кельманов А.В. - ПРО-0000000110 - 2026.06.18 }
						
					КонецЕсли;
					
				Иначе
					
					// Кельманов А.В. - HELP-9378 - 2026.04.07 {
					//Документы.ЗаданиеНабора.ОбработатьОкончаниеЗагрузкиЛНизТСД(ЗНБ, ТекстОшибки, ТекстОповещения);
					Документы.ЗаданиеНабора.ОбработатьОкончаниеЗагрузкиЛНизТСД(ЗНБ, ТекстОшибки, ТекстОповещения, Наборщик);
					// Кельманов А.В. - HELP-9378 - 2026.04.07 }
					
				КонецЕсли;	    				
				// Кельманов А.В. - SNL-169 - 2026.03.18 }
                								
			КонецЕсли;		

		КонецЕсли;

		
	Иначе
		
