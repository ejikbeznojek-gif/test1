	//		
	//		НетДублейКодовСУчетомВложенных = Документы.ЗаданиеНабора.ПроверитьДублиКодовЧЗВЛН_СУчетомВложенных(ЗНБ, ТекстОшибки, МассивОбъектовСОшибками);
	//		
	//		Если Не НетДублейКодовСУчетомВложенных Тогда
	//			
	//			ОтменитьТранзакцию();
	//			
	//		КонецЕсли;
	//		
	//		РезультатПроверкиУспех = Документы.ЗаданиеНабора.КонтрольКорректностиСканированияЧЗВЛЗ_ПоВсемЛН(ЗНБ, ТекстОшибки, МассивОбъектовСОшибками);
	//		
	//		Если Не РезультатПроверкиУспех Тогда
	//			
	//			ОтменитьТранзакцию();
	//			
	//		КонецЕсли;
    //
	//		Если ТранзакцияАктивна() Тогда
	//			ЗафиксироватьТранзакцию();
	//		КонецЕсли;	
    //
	//		Документы.ЗаданиеНабора.ОбработатьОкончаниеЗагрузкиЛНизТСД(ЗНБ, ТекстОшибки, ТекстОповещения);
    //
	//	Иначе
	//		
	//		// Кухарь А.Ю.  30.06.2025 начало
	//		// Пустая задача   
	//		//			ЗаписатьВЛог("Отладка", "Не определился ЗНБ", "Важное");
	//		//ОтменитьТранзакцию();		
	//		если ПроверятьЗНБ тогда
	//			ЗаписатьВЛог("Отладка", "Не определился ЗНБ", "Важное");
