	//КонецЕсли;
	//// Кухарь А.Ю. 07.04.2022 конец
	Если ЗначениеЗаполнено(ЗНБ)  Тогда
		
		Если ТранзакцияАктивна() Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;	
		
		ЛНУжеВыгружались = ОбщегоНазначения_ПИ.ЗНБУжеЗагружен(ЗНБ);
		
		
		Если ЛНУжеВыгружались Тогда
			
			ТекстОшибки = "ЗНБ уже выгружался из ТСД в 1С.";
			
