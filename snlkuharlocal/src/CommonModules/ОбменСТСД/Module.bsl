Функция ЗагрузитьДокумент(ОбъектXDTO,Вид)
	МетаОбъект=Метаданные.Документы[Вид];     
	//попытка
		Если ОбъектСуществует(ОбъектXDTO.Ссылка,"Документ."+Вид) Тогда
			Объект=ОбъектXDTO.Ссылка.ПолучитьОбъект();
		Иначе		
			Объект=Документы[Вид].СоздатьДокумент();		
			Объект.УстановитьСсылкуНового(ОбъектXDTO.Ссылка);
		КонецЕсли; 
	//Исключение
	//	ошибка = ОписаниеОшибки();
	//КонецПопытки;
	ЗаполнитьЗначенияСвойств(Объект,ОбъектXDTO);
	
	Для Каждого МетаТЧ Из МетаОбъект.ТабличныеЧасти Цикл
		СвойствоXDTO=ОбъектXDTO.Свойства().Получить(МетаТЧ.Имя);
		Если СвойствоXDTO<>Неопределено Тогда		
			ТЧТчXDTO	=ОбъектXDTO[МетаТЧ.Имя];
			Если ТЧТчXDTO<>Неопределено Тогда
				ТабЧасть=Объект[МетаТЧ.Имя];
				ТабЧасть.Очистить();
				Для Каждого СтрокаТчXDTO Из ТЧТчXDTO Цикл
					СтрокаТЧ=ТабЧасть.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТчXDTO);		
				КонецЦикла;		
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Объект;	
КонецФункции

Функция ОбъектСуществует(Ссылка,Таблица)
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1 ВерсияДанных
	|
	|ИЗ "+Таблица+"
	|ГДЕ Ссылка=&Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выборка=Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ВерсияДанных));
