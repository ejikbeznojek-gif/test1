Функция _ТипОбъекта(Объект,МетаОбъект="") Экспорт
	ТипОбъекта=ТипЗнч(Объект);
	
	Если ТипОбъекта=Тип("Строка") ИЛИ ТипОбъекта=Тип("Дата") ИЛИ ТипОбъекта=Тип("Число") ИЛИ ТипОбъекта=Тип("Булево") Тогда
		Возврат ""+ТипОбъекта;	
	КонецЕсли; 
	
	Если ТипОбъекта=Тип("ОбъектМетаданных") Тогда
		МетаОбъект=Объект;
	ИначеЕсли ТипОбъекта=Тип("Тип") Тогда
		МетаОбъект=Метаданные.НайтиПоТипу(Объект);			
	Иначе
		МетаОбъект=Метаданные.НайтиПоТипу(ТипОбъекта);	
	КонецЕсли;	
	
	Если МетаОбъект<>Неопределено Тогда
		ПолноеИмя=МетаОбъект.ПолноеИмя();
		Поз=Найти(ПолноеИмя,".");
		Если Поз<>0 Тогда
			Возврат Лев(ПолноеИмя,Поз-1);		
		Иначе
			Возврат "ПокаНеопределенный";		
		КонецЕсли;		
	Иначе
		Если ТипОбъекта=Тип("УдалениеОбъекта") Тогда
			Возврат "Удаление";
		ИначеЕсли ТипОбъекта=Тип("Структура")  Тогда
			Возврат "Структура";		
		ИначеЕсли ТипОбъекта=Тип("Соответствие")  Тогда
			Возврат "Соответствие";		
		ИначеЕсли ТипОбъекта=Тип("СписокЗначений")  Тогда
			Возврат "СписокЗначений";		
		ИначеЕсли ТипОбъекта=Тип("ТаблицаЗначений") Тогда
			Возврат "ТаблицаЗначений";
		ИначеЕсли ТипОбъекта=Тип("Тип") Тогда
			Возврат ""+Объект;
		Иначе			
			Возврат ""+ТипОбъекта;
		КонецЕсли;	
	КонецЕсли;
	
КонецФункции // ТипОбъекта()

Функция СоздатьНашуФабрикуХДТО()
	ЧтениеXML = Новый ЧтениеXML;    
	ЧтениеXML.УстановитьСтроку(ПолучитьОбщийМакет("СхемаОбменаXDTO").ПолучитьТекст());   
	
	ПостроительDOM	= Новый ПостроительDOM;
	ДокументДом		= ПостроительDOM.Прочитать(ЧтениеXML);   
	ЧтениеXML.Закрыть();
	
	ПостроительСхем = Новый ПостроительСхемXML;
	Схема 			= ПостроительСхем.СоздатьСхемуXML(ДокументДом);	
	
	НаборСхем	= Новый НаборСхемXML;	
	НаборСхем.Добавить(Схема);
	
	НаборСхемТекКонф	= ФабрикаXDTO.ЭкспортСхемыXML("http://v8.1c.ru/8.1/data/enterprise/current-config");	
	Для Каждого Схема Из НаборСхемТекКонф Цикл
		НаборСхем.Добавить(Схема);	
	КонецЦикла;	
	
	Возврат Новый ФабрикаXDTO(НаборСхем);
КонецФункции //СоздатьФабрикуХДТО()

