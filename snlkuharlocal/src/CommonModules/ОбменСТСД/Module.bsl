Процедура ЗаписатьДанные(ЗаписьXML, Фабрика, Данные) Экспорт	
	мТипОбъекта=_ТипОбъекта(Данные);
	Если мТипОбъекта = "Справочник" Тогда
		ЗаписатьСправочник(ЗаписьXML,Фабрика,Данные);
	ИначеЕсли мТипОбъекта = "Документ" Тогда		
		ЗаписатьДокумент(ЗаписьXML,Фабрика,Данные);	
	КонецЕсли	
КонецПроцедуры

Процедура ЗаписатьСправочник(ЗаписьXML,Фабрика,Объект)
	Если Объект=Неопределено Тогда Возврат КонецЕсли;
	
	//ЗаписатьВЛог("Отладка",""+Объект.Код+" "+Объект,"Информация");
	//ЗаписатьВЛог("Отладка",""+ТипЗнч(Объект)+" "+Объект,"Информация");
	//Кухарь 14.08.19 начало	
	МетаОбъект=Объект.Метаданные();
	МетаОбъектСтрока=МетаОбъект.имя;
	СтрокаИсключаемыхПараметровЭлемент=Неопределено;
	СтрокаИсключаемыхПараметровГруппа=Неопределено;
	СтрокаЗаполняемыхПараметровЭлемент=Неопределено;
	СтрокаЗаполняемыхПараметровГруппа=Неопределено;
	СтрокаЗаполняемыхПараметровГруппа="Ссылка,Код,Наименование,ЭтоГруппа,ПометкаУдаления,Родитель";
	если МетаОбъектСтрока="Номенклатура" тогда
		// Кельманов А.В. - ASU-1746 - 2025.02.19 {
		//СтрокаЗаполняемыхПараметровГруппа=СтрокаЗаполняемыхПараметровГруппа+",ШтукВКоробке,ШтукВКоробочке";
		
		// Кельманов А.В. - HELP-3228 - 2025.03.12 {
		//СтрокаЗаполняемыхПараметровГруппа=СтрокаЗаполняемыхПараметровГруппа+",ШтукВКоробке,ШтукВКоробочке,КодПроизводителя";
		СтрокаЗаполняемыхПараметровГруппа=СтрокаЗаполняемыхПараметровГруппа+",ШтукВКоробке,ШтукВКоробочке,КодПроизводителя,ВидНоменклатуры";
		// Кельманов А.В. - HELP-3228 - 2025.03.12 }
		
		// Кельманов А.В. - ASU-1746 - 2025.02.19 }
		СтрокаИсключаемыхПараметровЭлемент="ШтукВКоробке,ШтукВКоробочке";
	ИначеЕсли МетаОбъектСтрока="ФизическиеЛица" тогда
		СтрокаИсключаемыхПараметровГруппа="ШтрихКод";		
	КонецЕсли;
	//Кухарь 14.08.19 конец
	
	
	ТипXDTO	= Фабрика.Тип(ПространствоИмен(),"СправочникОбъект."+МетаОбъект.Имя);
	Если ТипXDTO=Неопределено Тогда
		Сообщить("Не найден тип XDTO: "+МетаОбъект.Имя);
		Возврат;	
	КонецЕсли; 
	
	ЭлементXDTO	= Фабрика.Создать(ТипXDTO);		
	//Кухарь 14.08.19 начало	
	//Если Объект.ЭтоГруппа Тогда
	//	ЗаполнитьЗначенияСвойств(ЭлементXDTO,Объект,"Ссылка,Код,Наименование,ЭтоГруппа,ПометкаУдаления,Родитель");
	//Иначе
	//	ЗаполнитьЗначенияСвойств(ЭлементXDTO,Объект,,);
	//КонецЕсли;	
	Если Объект.ЭтоГруппа Тогда
		ЗаполнитьЗначенияСвойств(ЭлементXDTO,Объект,СтрокаЗаполняемыхПараметровГруппа,СтрокаИсключаемыхПараметровГруппа);
	Иначе
		ЗаполнитьЗначенияСвойств(ЭлементXDTO,Объект,СтрокаЗаполняемыхПараметровЭлемент,СтрокаИсключаемыхПараметровЭлемент);
	КонецЕсли;		
	//Кухарь 14.08.19 конец
	
	Фабрика.ЗаписатьXML(ЗаписьXML,ЭлементXDTO,,ПространствоИмен(),,НазначениеТипаXML.Явное);
	
	Если МетаОбъект.Иерархический И ЗначениеЗаполнено(Объект.Родитель) Тогда
		ЗаписатьСправочник(ЗаписьXML,Фабрика,Объект.Родитель.ПолучитьОбъект());	
	КонецЕсли; 
КонецПроцедуры

Процедура ЗаписатьДокумент(ЗаписьXML,Фабрика,Объект)
	МетаОбъект=Объект.Метаданные();
	
	ОбъектXDTO	= Фабрика.Создать(Фабрика.Тип(ПространствоИмен(),"ДокументОбъект."+МетаОбъект.Имя));			
	
	ЗаполнитьЗначенияСвойств(ОбъектXDTO,Объект);	
	Для Каждого МетаТЧ Из МетаОбъект.ТабличныеЧасти Цикл
		СвойствоXDTO=ОбъектXDTO.Свойства().Получить(МетаТЧ.Имя);
		Если СвойствоXDTO<>Неопределено Тогда					
			ТЧТчXDTO=ОбъектXDTO[МетаТЧ.Имя];
			Для Каждого СтрокаТЧ Из Объект[МетаТЧ.Имя] Цикл
				СтрокаТчXDTO	= Фабрика.Создать(Фабрика.Тип(ПространствоИмен(),"ДокументСтрокаТЧ."+МетаОбъект.Имя+"."+МетаТЧ.Имя));
				ЗаполнитьЗначенияСвойств(СтрокаТчXDTO,СтрокаТЧ);			
				ТЧТчXDTO.Добавить(СтрокаТчXDTO);					
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;		
	
	Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектXDTO,,,,НазначениеТипаXML.Явное);	
КонецПроцедуры


