Функция ВернутьПолныйПутьКОбработке(ОбработкаСсылка) экспорт

	ИмяОбработки = ОбработкаСсылка.ИмяФайла; 
	ИмяОбработки = СтрЗаменить(ИмяОбработки,"ВН_",""); 
	//только внешние
	Если ОбработкаСсылка.ВидОбработкиУпр  = Перечисления.ВидыДополнительныхОтчетовИОбработок.ЗаполнениеОбъекта Тогда
		ДопКаталог="FillForms\";
	Иначе 	
		ДопКаталог="";
	КонецЕсли;

	ИмяФайлаОбработки	=Константы.КаталогВнешнихОтчетов.Получить() + ДопКаталог + ИмяОбработки + ".epf";
	
	Возврат ИмяФайлаОбработки; 

КонецФункции // ВернутьПолныйПутьКОбработке()


