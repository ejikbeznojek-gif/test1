#Область СлужебныеПроцедурыИФункции
#Область Общего_назначения


Функция ПолучитьСсылкуНаОбработку(ИмяКоманды, Префикс = "КомандаПечати_") Экспорт

	СтрокаГУИД = СтрЗаменить(ИмяКоманды, Префикс, "");
	СтрокаГУИД = СтрЗаменить(СтрокаГУИД, "_", "-");
	ВнешняяОбработкаСсылка = Справочники.ВнешниеОтчеты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаГУИД));

	Возврат ВнешняяОбработкаСсылка;

КонецФункции

Функция ПолучитьИмяДокументаДляФормыСписка(ЭтаФорма) Экспорт
	
	//Документ.ПриходнаяНакладная.Форма.ФормаСписка
	ИмяФормы = ЭтаФорма.ИмяФормы;

	МассивЧастиИмениФормы = СтрРазделить(ИмяФормы, ".");
	Если МассивЧастиИмениФормы.Количество() >= 2 Тогда
		Результат = МассивЧастиИмениФормы[1];
	Иначе
		Результат = Неопределено;
	КонецЕсли;

	Возврат Результат;

КонецФункции


Функция ПустаяСтруктураПараметры()

	Результат = Новый Структура;

	Результат.Вставить("ВидОбработки");
	Результат.Вставить("ИмяГруппыКнопок");
	Результат.Вставить("ЗаголовокГруппыКнопок");
	Результат.Вставить("КартинкаГруппыКнопок");
	Результат.Вставить("Префикс");
	Результат.Вставить("ИмяПроцедурыФормы");

	Возврат Результат;

КонецФункции

Процедура ДобавитьКомандыНаФорму(ОбъектСсылка, ЭтаФорма, ИмяГруппыКоманднаяПанель, Параметры)

	ПолноеИмяМД = ОбъектСсылка.Метаданные().ПолноеИмя();

	ИмяДокумента = ОбъектСсылка.Метаданные().Имя;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВнешниеОтчеты_ИнтНазначения.Ссылка КАК Ссылка,
	|	ВнешниеОтчеты_ИнтНазначения.Ссылка.ВидОбработкиУпр КАК ВидОбработки,
	|	ВнешниеОтчеты_ИнтНазначения.Ссылка.Наименование КАК Наименование,
	|	ВнешниеОтчеты_ИнтНазначения.ИмяТЧ КАК ИмяТабличнойЧасти
	|ИЗ
	|	Справочник.ВнешниеОтчеты КАК ВнешниеОтчеты_ИнтНазначения
	|ГДЕ
	|	ВнешниеОтчеты_ИнтНазначения.ВидДокумента = &Назначение
	|	И ВнешниеОтчеты_ИнтНазначения.ВидОбработкиУпр В (&ВидыОбработки)
	|	И НЕ ВнешниеОтчеты_ИнтНазначения.ПометкаУдаления";

	Запрос.УстановитьПараметр("Назначение", ИмяДокумента);
	
	// один вид обработки
	Если ТипЗнч(Параметры.ВидОбработки) = Тип("ПеречислениеСсылка.ВидыДополнительныхОтчетовИОбработок") Тогда
		ВидыОбработки = Новый Массив;
		ВидыОбработки.Добавить(Параметры.ВидОбработки);
		
	// несколько видов обработки	
	ИначеЕсли ТипЗнч(Параметры.ВидОбработки) = Тип("Массив") Тогда
		ВидыОбработки = Параметры.ВидОбработки;
	КонецЕсли;

	Запрос.УстановитьПараметр("ВидыОбработки", ВидыОбработки);

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	// создадим группу кнопок
	ГруппаКоманднаяПанель = ?(ЗначениеЗаполнено(ИмяГруппыКоманднаяПанель), ЭтаФорма.Элементы[ИмяГруппыКоманднаяПанель],
		ЭтаФорма.КоманднаяПанель);
	
	// проверим наличие элемента управления ГруппаКнопок и создадим его при необходимости
	Если ЭтаФорма.Элементы.Найти(Параметры.ИмяГруппыКнопок) = Неопределено Тогда
		ГруппаКнопок = ЭтаФорма.Элементы.Добавить(Параметры.ИмяГруппыКнопок, Тип("ГруппаФормы"), ГруппаКоманднаяПанель);
		ГруппаКнопок.Вид		= ВидГруппыФормы.Подменю;
		ГруппаКнопок.Заголовок	= Параметры.ЗаголовокГруппыКнопок;
		ГруппаКнопок.Картинка	= Параметры.КартинкаГруппыКнопок;
	Иначе
		ГруппаКнопок = ЭтаФорма.Элементы[Параметры.ИмяГруппыКнопок];
	КонецЕсли;
	
	// Если это подключаемый отчет, то создадим таблицу соответствия 
	//	*	ВнешнийОтчет_Инт, ИмяТабличнойЧасти, ПолеРезультат, ИспользованиеПараметра, ПолеОтбор, ВидСравнения
	// ПолеРезультат которое передается в подключаемый отчет
	// в зависимости от ИспользованиеПараметра - как ПараметрДанных или как ЭлементОтбора
	// если передается как ЭлементОтбора, то отбирается по полю ПолеОтбор
	Если ЭтоПодключаемыйОтчет(Параметры) Тогда		
		
	// если это заполнение объекта, то создадим таблицу соответствия ВнешнийОтчет_Инт и ИмяТабличнойЧасти	
	ИначеЕсли Параметры.ВидОбработки = Перечисления.ВидыДополнительныхОтчетовИОбработок.ЗаполнениеОбъекта Тогда
		ДобавитьРеквизитФормыТабличныеЧастиДляЗаполнения(ЭтаФорма);
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		// добавляем команду формы
		ГУИД = Выборка.Ссылка.УникальныйИдентификатор();
		СтрокаГУИД = СтрЗаменить(Строка(ГУИД), "-", "_");

		НоваяКоманда = ЭтаФорма.Команды.Добавить(Параметры.Префикс + СтрокаГУИД);
		НоваяКоманда.Действие	= Параметры.ИмяПроцедурыФормы;
		НоваяКоманда.Заголовок	= Выборка.Наименование;
		
		// если указана ТЧ для команды заполнения объекта, то добавляем кнопки в командную панель табличной части
		Если Не ПустаяСтрока(Выборка.ИмяТабличнойЧасти) И Выборка.ВидОбработки
			= Перечисления.ВидыДополнительныхОтчетовИОбработок.ЗаполнениеОбъекта Тогда

			ИмяГруппыКоманднаяПанельТабЧасти	= Выборка.ИмяТабличнойЧасти + "КоманднаяПанель";
			ИмяГруппыКнопок						= Параметры.ИмяГруппыКнопок + Выборка.ИмяТабличнойЧасти;

			Если ЭтаФорма.Элементы.Найти(ИмяГруппыКнопок) = Неопределено Тогда
				ГруппаКнопок = ЭтаФорма.Элементы.Добавить(ИмяГруппыКнопок, Тип("ГруппаФормы"),
					ЭтаФорма.Элементы[ИмяГруппыКоманднаяПанельТабЧасти]);
				ГруппаКнопок.Вид		= ВидГруппыФормы.Подменю;
				ГруппаКнопок.Заголовок	= Параметры.ЗаголовокГруппыКнопок;
				ГруппаКнопок.Картинка	= Параметры.КартинкаГруппыКнопок;
			Иначе
				ГруппаКнопок = ЭтаФорма.Элементы[ИмяГруппыКнопок];
			КонецЕсли;

		КонецЕсли;
		
		// добавляем кнопку
		НоваяКнопка = ЭтаФорма.Элементы.Добавить(НоваяКоманда.Имя, Тип("КнопкаФормы"), ГруппаКнопок);
		НоваяКнопка.ИмяКоманды	= НоваяКоманда.Имя;
		
		// заполняем поля параметров для подключаемых отчетов
		Если ЭтоПодключаемыйОтчет(Параметры) Тогда
			НоваяСтр = ЭтаФорма.ПоляДляПодключаемыхОтчетов.Добавить();
			ЗаполняемыеКолонки = "Ссылка,ИмяТабличнойЧасти,ПолеПараметр,ИспользованиеПараметра,ПолеОтбор,ВидСравнения,ИмяВарианта";
			ЗаполнитьЗначенияСвойств(НоваяСтр, Выборка, ЗаполняемыеКолонки);
			
		// заполняемые твбличные части для обработок заполнения
		ИначеЕсли Параметры.ВидОбработки = Перечисления.ВидыДополнительныхОтчетовИОбработок.ЗаполнениеОбъекта Тогда
			НоваяСтр = ЭтаФорма.ТабличныеЧастиДляЗаполнения.Добавить();
			ЗаполняемыеКолонки = "Ссылка,ИмяТабличнойЧасти";
			ЗаполнитьЗначенияСвойств(НоваяСтр, Выборка, ЗаполняемыеКолонки);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры


Процедура ПриСозданииНаСервере(ОбъектСсылка, ЭтаФорма, ИмяГруппыКоманднаяПанель = Неопределено) Экспорт

	Если СтрНайти(ЭтаФорма.ИмяФормы, "ФормаСписка") = 0 Тогда
		ПриСозданииНаСервере_ЗаполнениеОбъекта(ОбъектСсылка, ЭтаФорма, ИмяГруппыКоманднаяПанель);
	КонецЕсли;

КонецПроцедуры

