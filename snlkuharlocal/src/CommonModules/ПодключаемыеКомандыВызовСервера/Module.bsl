#Область Заполнение_объекта

Процедура ПриСозданииНаСервере_ЗаполнениеОбъекта(ОбъектСсылка, ЭтаФорма, ИмяГруппыКоманднаяПанель = Неопределено)

	Параметры = ПустаяСтруктураПараметры();

	Параметры.ВидОбработки			= Перечисления.ВидыДополнительныхОтчетовИОбработок.ЗаполнениеОбъекта;
	Параметры.ИмяГруппыКнопок		= "ГруппаКнопокЗаполнениеОбъекта";
	Параметры.ЗаголовокГруппыКнопок	= "Заполнить";
	Параметры.КартинкаГруппыКнопок	= БиблиотекаКартинок.РазвернутьВсе;
	Параметры.Префикс				= "ЗаполнениеОбъекта_";
	Параметры.ИмяПроцедурыФормы		= "ЗаполнениеОбъекта";

	ДобавитьКомандыНаФорму(ОбъектСсылка, ЭтаФорма, ИмяГруппыКоманднаяПанель, Параметры);

КонецПроцедуры


Процедура ДобавитьРеквизитФормыТабличныеЧастиДляЗаполнения(ЭтаФорма)

	ДобавляемыеРеквизиты = Новый Массив;

	РеквизитТаблица = Новый РеквизитФормы("ТабличныеЧастиДляЗаполнения", Новый ОписаниеТипов("ТаблицаЗначений"));

	ДобавляемыеРеквизиты.Добавить(РеквизитТаблица);

	РеквизитКолонка = Новый РеквизитФормы("Ссылка", Новый ОписаниеТипов("СправочникСсылка.ВнешниеОтчеты"),
		"ТабличныеЧастиДляЗаполнения");
	ДобавляемыеРеквизиты.Добавить(РеквизитКолонка);

	РеквизитКолонка = Новый РеквизитФормы("ИмяТабличнойЧасти", Новый ОписаниеТипов("Строка"),
		"ТабличныеЧастиДляЗаполнения");
	ДобавляемыеРеквизиты.Добавить(РеквизитКолонка);

	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

КонецПроцедуры


Функция ЗаполнениеОбъекта(ОбработкаСсылка, ОбъектСсылка, ИмяТабличнойЧасти) Экспорт
	ОбработкаОбъект = ПолучитьОбъектДополнительнойОбработки(ОбработкаСсылка);
	Возврат ОбработкаОбъект.ЗаполнениеОбъекта(ОбъектСсылка, ИмяТабличнойЧасти);
КонецФункции

 
Функция ПолучитьПараметрыЗаполнения(ОбработкаСсылка, ОбъектСсылка, ИмяТабличнойЧасти) Экспорт
	ОбработкаОбъект = ПолучитьОбъектДополнительнойОбработки(ОбработкаСсылка);
	Возврат ОбработкаОбъект.ПолучитьПараметрыЗаполнения(ОбъектСсылка, ИмяТабличнойЧасти);
КонецФункции


Функция ТребуетсяОткрыватьФормуОбработкиЗаполнения(ОбработкаСсылка) Экспорт
	ОбработкаОбъект = ПолучитьОбъектДополнительнойОбработки(ОбработкаСсылка);
	Возврат ОбработкаОбъект.ТребуетсяОткрыватьФормуОбработки();
КонецФункции


Функция ПолучитьНастройкиОбработкиЗаполнения(ОбработкаСсылка) Экспорт
	Настройки = ХранилищеОбщихНастроек.Загрузить(ПолучитьКлючНастроек(ОбработкаСсылка), , , ИмяПользователя());
	Возврат Настройки;
КонецФункции


Процедура ЗаписатьНастройкиОбработкиЗаполнения(ОбработкаСсылка, АдресНастроек) Экспорт

	Если ПустаяСтрока(АдресНастроек) Или Не ЭтоАдресВременногоХранилища(АдресНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	// настройки, с которыми выполнено заполнение
	Настройки = ПолучитьИзВременногоХранилища(АдресНастроек);
	ХранилищеОбщихНастроек.Сохранить(ПолучитьКлючНастроек(ОбработкаСсылка), , Настройки, , ИмяПользователя());

КонецПроцедуры

Функция ПолучитьКлючНастроек(ОбработкаСсылка)
	ГУИД = ОбработкаСсылка.УникальныйИдентификатор();
	СтрокаГУИД = СтрЗаменить(Строка(ГУИД), "-", "_");
	КлючНастроек = "ЗаполнениеОбъектов/" + ОбработкаСсылка.Наименование + "/" + СтрокаГУИД;
	Возврат КлючНастроек;
КонецФункции

#КонецОбласти

#Область Заполнение_объекта_Форма


Процедура ПриСозданииНаСервере_ФормаЗаполнениеОбъекта(ЭтаФорма, Отказ, СтандартнаяОбработка) Экспорт
	
	// добавляем на форму необходимые реквизиты и элементы управления
	ДобавитьРеквизитыЭлементыФормы(ЭтаФорма);

	СхемаКомпоновкиДанных = ЭтаФорма.РеквизитФормыВЗначение("Объект").ПолучитьМакет("СхемаКомпоновкиДанных");
	
	// параметры данных для СКД
	//ПараметрыЗаполнения		= ОбщегоНазначения.ПолучитьЗначениеПараметра(ЭтаФорма.Параметры,"ПараметрыЗаполнения",Новый Структура);
	//Для Каждого КлючЗначение Из ЭтаФорма.Параметры.ПараметрыЗаполнения Цикл
	//	ПараметрыЗаполнения.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	//КонецЦикла;
	ЭтаФорма.ПараметрыЗаполнения 		= ОбщегоНазначенияС.ПолучитьЗначениеПараметра(ЭтаФорма.Параметры,
		"ПараметрыЗаполнения", Новый Структура);

	ЭтаФорма.АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных,
		ЭтаФорма.УникальныйИдентификатор);

	ЭтаФорма.КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(ЭтаФорма.АдресСхемыКомпоновкиДанных));
	
	// пытаемся взять настройки, сохраненные в базе
	ТекНастройки = Неопределено;
	ЭтаФорма.Параметры.Свойство("НастройкиЗаполнения", ТекНастройки);

	Если ТекНастройки = Неопределено Тогда
		// если сохраненных настроек нет, то берем настройки по умолчанию из СхемыКомпоновкиДанных
		ТекНастройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	Иначе
		// добавим выбранные поля из СКД
		ТекНастройки.Выбор.Элементы.Очистить();
		Для Каждого ВыбранноеПоле Из СхемаКомпоновкиДанных.НастройкиПоУмолчанию.Выбор.Элементы Цикл
			ТипЗначенияВыбранногоПоля = ТипЗнч(ВыбранноеПоле);
			Если ТипЗначенияВыбранногоПоля = Тип("ВыбранноеПолеКомпоновкиДанных") Тогда
				НовоеПоле = ТекНастройки.Выбор.Элементы.Добавить(ТипЗначенияВыбранногоПоля);
				НовоеПоле.Использование		= Истина;
				НовоеПоле.Поле				= ВыбранноеПоле.Поле;
				НовоеПоле.РежимОтображения	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ЭтаФорма.КомпоновщикНастроек.ЗагрузитьНастройки(ТекНастройки);

	ЭтаФорма.ЗакрыватьПриВыборе = Истина;

КонецПроцедуры

Процедура ДобавитьРеквизитыЭлементыФормы(ЭтаФорма) Экспорт
	
	//////////////////////////////////////////////////////////////////
	// добавим необходимые реквизиты формы
	ДобавляемыеРеквизиты = Новый Массив;
	
	// адрес во временном хранилище, по которому лежит СКД
	АдресСхемыКомпоновкиДанных = Новый РеквизитФормы("АдресСхемыКомпоновкиДанных", Новый ОписаниеТипов("Строка"));
	ДобавляемыеРеквизиты.Добавить(АдресСхемыКомпоновкиДанных);
	
	// адрес во временном хранилище, по которому лежат настройки
	АдресНастроек = Новый РеквизитФормы("АдресНастроек", Новый ОписаниеТипов("Строка"));
	ДобавляемыеРеквизиты.Добавить(АдресНастроек);
	
	// параметры данных для СКД, структура;
	ПараметрыЗаполнения = Новый РеквизитФормы("ПараметрыЗаполнения", Новый ОписаниеТипов);
	ДобавляемыеРеквизиты.Добавить(ПараметрыЗаполнения);

	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	//////////////////////////////////////////////////////////////////
	// добавим команды формы

	КомандаЗаполнить = ЭтаФорма.Команды.Добавить("Заполнить");
	КомандаЗаполнить.Действие	= "Заполнить";
	КомандаЗаполнить.Заголовок	= "Заполнить";

	КомандаОтмена = ЭтаФорма.Команды.Добавить("Отмена");
	КомандаОтмена.Действие		= "Отмена";
	КомандаОтмена.Заголовок		= "Отмена";
	
	//////////////////////////////////////////////////////////////////
	// добавим элементы управления

	КнопкаЗаполнить = ЭтаФорма.Элементы.Добавить("ФормаЗаполнить", Тип("КнопкаФормы"), ЭтаФорма.КоманднаяПанель);
	КнопкаЗаполнить.ИмяКоманды								= "Заполнить";
	КнопкаЗаполнить.КнопкаПоУмолчанию						= Истина;

	КнопкаОтмена = ЭтаФорма.Элементы.Добавить("ФормаОтмена", Тип("КнопкаФормы"), ЭтаФорма.КоманднаяПанель);
	КнопкаОтмена.ИмяКоманды									= "Отмена";
	
	////КомпоновщикНастроекНастройкиОтбор = ЭтаФорма.Элементы.Добавить("КомпоновщикНастроекНастройкиОтбор", Тип("ТаблицаФормы"), ЭтаФорма);
	////КомпоновщикНастроекНастройкиОтбор.ПутьКДанным 			= "КомпоновщикНастроек.Настройки.Отбор";
	////КомпоновщикНастроекНастройкиОтбор.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Нет;

КонецПроцедуры


Функция ПолучитьТаблицуДанныеЗаполнения(ЭтаФорма) Экспорт

	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(ЭтаФорма.АдресСхемыКомпоновкиДанных);	
	
	// заполним параметры
	Для Каждого ЭлементПараметра Из ЭтаФорма.ПараметрыЗаполнения Цикл
		РаботаНадСКД_КС.УстановитьПараметрДанных(ЭтаФорма.КомпоновщикНастроек, ЭлементПараметра.Ключ,
			ЭлементПараметра.Значение);
	КонецЦикла;

	Настройки = ЭтаФорма.КомпоновщикНастроек.ПолучитьНастройки();
	
	// сохраним во временном хранилище настройки, с которыми заполняли. В компоновщике настройки сбиваются после возвращения на клиент
	ЭтаФорма.АдресНастроек = ПоместитьВоВременноеХранилище(Настройки, ЭтаФорма.УникальныйИдентификатор);
		
	//Помещаем в переменную данные о расшифровке данных
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	//Формируем макет, с помощью компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	//Передаем в макет компоновки схему, настройки и данные расшифровки
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки, , Тип(
		"ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	//Выполним компоновку с помощью процессора компоновки
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);

	ТаблицаРезультат = Новый ТаблицаЗначений;
	
	//Выводим результат в табличный документ
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаРезультат);

	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);

	Возврат ТаблицаРезультат;

КонецФункции

