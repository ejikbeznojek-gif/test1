Функция ОткрытьФормуНастроекЧЗ() Экспорт
	#ЕСЛИ ТолстыйКлиентОбычноеПриложение ТОГДА
	Обработки.АпиЧЗ.ПолучитьФорму("НастройкаПараметров").Открыть();
	#КОНЕЦЕСЛИ 
КонецФункции //ОткрытьФормуНастроекЧЗ() Экспорт

Процедура УстановитьСтатусДокументаМаркировки(ДокСсылка, Статус, ТекстОшибки = Неопределено ) Экспорт
	#ЕСЛИ ТолстыйКлиентОбычноеПриложение ТОГДА
	Реквизты = Новый Структура("Статус", Статус);
	Если ТекстОшибки <> Неопределено Тогда
		Реквизты.Вставить("ТекстОшибки", ТекстОшибки);	
	КонецЕсли; 
	УстановитьРеквизитыОбъекта(ДокСсылка, Реквизты);
					
	ОповеститьОбИзменении(ДокСсылка);
	Оповестить("ИзмененСтатус", , ДокСсылка);
	#КОНЕЦЕСЛИ
КонецПроцедуры //УстановитьСтатусДокументаМаркировки(ДокСсылка, Статус) Экспорт

Процедура ОткрытьПодчиненныеДокументы_МаркировкаТоваровИСМП(Список, ВидОперации) Экспорт
	ТекДанные = Список.ТекущиеДанные;
	Если ТекДанные<>Неопределено Тогда                          
		ДокСсылка = ТекДанные.Ссылка;
		
		Если ТипЗнч(ВидОперации) = Тип("ПеречислениеСсылка.ВидыОперацийИСМП") Тогда
			ПараметрыВыбора = Новый Структура("Отбор", Новый Структура("ДокументОснование,ВидОперацииИСМП", ТекДанные.Ссылка, ВидОперации));		
			ОткрытьФорму("Документ.МаркировкаТоваровИСМП.ФормаСписка", ПараметрыВыбора, , ДокСсылка);			
		ИначеЕсли ТипЗнч(ВидОперации) = Тип("ПеречислениеСсылка.ВидыОперацийМаркировки") Тогда		
			ПараметрыВыбора = Новый Структура("Отбор", Новый Структура("ДокументОснование,ВидОперации", ТекДанные.Ссылка, ВидОперации));		
			ОткрытьФорму("Документ.МаркировкаТоваровИСМП.ФормаСписка", ПараметрыВыбора, , ДокСсылка);
		Иначе			
			Сообщить("Недопустимый тип параметра отбора по виду операции: " + ТипЗнч(ВидОперации), СтатусСообщения.Важное);		
		КонецЕсли; 		
	Иначе
		Сообщить("Не выбран док. основание !", СтатусСообщения.Важное);
	КонецЕсли;

КонецПроцедуры

Процедура ОткрытьПодчиненныеДокументы_ЗаказКМ(Список, ВидОперации) Экспорт
	ТекДанные = Список.ТекущиеДанные;
	Если ТекДанные<>Неопределено Тогда                          
		ДокументОснование = ТекДанные.Ссылка;
		
		ПараметрыВыбора = Новый Структура("Отбор", Новый Структура("ДокументОснование", ДокументОснование));		
		ОткрытьФорму("Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ФормаСписка", ПараметрыВыбора, , ДокументОснование);		
	Иначе
		Сообщить("Не выбран док. основание !", СтатусСообщения.Важное);
	КонецЕсли;
КонецПроцедуры

Процедура ВоспроизвестиЗвукОшибки(КоличествоПовторов = 0) Экспорт
	oVoice = Новый COMObject("SAPI.SpVoice");
	oSpFileStream = Новый COMObject("SAPI.SpFileStream");	
	
	ИмяФайла = Маркировка_ПИ.КаталогВнешнихОтчетов() + "Alert.wav";
	Файл = Новый Файл(ИмяФайла);
	Если Файл.Существует() Тогда
		oSpFileStream.Open(ИмяФайла);
		oVoice.SpeakStream(oSpFileStream);
		Если КоличествоПовторов > 0 Тогда
			Для Сч = 2 По КоличествоПовторов Цикл
				oVoice.SpeakStream(oSpFileStream);				
			КонецЦикла;	
		КонецЕсли;	
		oSpFileStream.Close();
	Иначе
		Сигнал();
	КонецЕсли;
КонецПроцедуры

Функция ВывестиОшибки(рОбработки) Экспорт
	ТекстСообщения = СтрСоединить(рОбработки.Ошибки, Символы.ПС);
	Сообщить(ТекстСообщения, СтатусСообщения.Важное);
	
	Возврат ТекстСообщения;
КонецФункции //ВывестиОшибки(рОбработки) Экспорт
 
Функция ВывестиСообщения(рОбработки, Знач Статус = Неопределено) Экспорт
	Если Статус = Неопределено Тогда
		Статус = СтатусСообщения.БезСтатуса;	
	КонецЕсли; 
	Сообщения		= МаркировкаКС.ПолучитьЗначениеПараметра(рОбработки, "Сообщения", Новый Массив);
	ТекстСообщения	= "";
	
	Если Сообщения.Количество() > 0 Тогда	
		ТекстСообщения = СтрСоединить(Сообщения, Символы.ПС);
		Сообщить(ТекстСообщения, Статус);
	КонецЕсли;
	
	Возврат ТекстСообщения;
КонецФункции //ВывестиСообщения(рОбработки) Экспорт

Функция ПолноеИмяФайла(ИмяКаталога, ИмяФайла) Экспорт
	мКаталог= СокрЛП(ИмяКаталога);
	РП = ПолучитьРазделительПутиКлиента();
	Если НЕ СтрЗаканчиваетсяНа(мКаталог, РП) Тогда
		мКаталог = мКаталог + РП;	
	КонецЕсли;
	
	Возврат мКаталог + ИмяФайла;
КонецФункции //ПолноеИмяФайла(ИмяКаталога, ИмяФайла)

Функция ЗаписатьИзмененныйОбъектВУпрФорме(УпрФорма, Провести = Ложь) Экспорт
	
	Если УпрФорма.Модифицированность ИЛИ (Провести И НЕ УпрФорма.Объект.Проведен) Тогда		
		Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(УпрФорма.Объект.Ссылка)) Тогда //Документ
			Если Провести Тогда
				ТекстВопроса = "Для выполнения данной операции необходимо провести документ. Провести ?";			
			Иначе
				ТекстВопроса = "Для выполнения данной операции необходимо записать документ. Записать ?";			
			КонецЕсли;			
		Иначе // Справочник
			ТекстВопроса = "Для выполнения данной операции необходимо записать элемент. Записать?";
		КонецЕсли; 
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			Возврат Ложь;
		Иначе
			Попытка
				Если Провести Тогда					
					Возврат УпрФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
				Иначе                           
					Возврат УпрФорма.Записать();					
				КонецЕсли;				
			Исключение
				Сообщить(ОписаниеОшибки());
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции // ЗаписатьИзмененныйОбъектВУпрФорме()

Функция ЗаписатьНовыйОбъектВУпрФорме(УпрФорма) Экспорт
	
	Если УпрФорма.Объект.Ссылка.Пустая() Тогда
		Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(УпрФорма.Объект.Ссылка)) Тогда
			ТекстВопроса = "Для выполнения данной операции необходимо записать документ. Записать?";
		Иначе // Справочник
			ТекстВопроса = "Для выполнения данной операции необходимо записать элемент. Записать?";
		КонецЕсли; 
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			Возврат Ложь;
		Иначе
			Попытка
				Возврат УпрФорма.Записать();
			Исключение
				Сообщить(ОписаниеОшибки());
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	Иначе
		Возврат Истина;
	КонецЕсли; 
	
КонецФункции // ЗаписатьНовыйОбъектВФорме()

Функция ПроверкаРазрешенияРедактированияУФ(УФ) Экспорт
	Результат = Истина;
	Если УФ.Объект.Дата <= КонецДня(ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()) Тогда
		УФ.ТолькоПросмотр = Истина;	
		Результат = Ложь;
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПроверкаРазрешенияРедактирования(УФ) Экспорт

Функция ВвестиКоды() Экспорт
	мКоды = Новый Массив;
	
	СтрокаКодов = "";
	Если ВвестиСтроку(СтрокаКодов, "Введите коды маркировки", , Истина) Тогда
		Для Каждого Строка Из СтрРазделить(СтрокаКодов, Символы.ПС) Цикл
			Строка = СтрЗаменить(Строка,"(01)","");		
			Строка = СтрЗаменить(Строка,"(21)","");		
			Строка = СтрЗаменить(Строка," ","");
			
			мКоды.Добавить(Строка);
		КонецЦикла;
		
		мКоды = МаркировкаС.НайтиКоды(мКоды);
	КонецЕсли;
	
	Возврат мКоды;
КонецФункции //ВвестиКоды() Экспорт

Функция ЗаписатьФактСканирования(ШтрихКод, ДокументСканирования = Неопределено, ДопПараметры = Неопределено) Экспорт
	Если НЕ Маркировка_ПИ.ЗаписыватьКаждыйЩелчокСканера() Тогда Возврат Неопределено КонецЕсли;
	
	Попытка
		МаркировкаС.ЗаписатьФактСканирования(ШтрихКод, ДокументСканирования, ДопПараметры);
	Исключение                                   
		ТекстСообщения = СтрШаблон("Ошибка записи пика ! ШК: '%1', док-т: '%2', ошибка: '%3' !", СокрЛП(ШтрихКод), ДокументСканирования, ОписаниеОшибки());
		ЗаписатьВЛог("Фиксация пиков", ТекстСообщения, "Ошибка"); 
	КонецПопытки;
КонецФункции //ЗаписатьФактСканирования(ШтрихКод, ДокументСканирования, ДопПараметры = Неопределено) Экспорт
