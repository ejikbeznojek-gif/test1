				Движение.ВалютаДокумента=  ТекДок.ДокОснование.Валюта;
				Движение.оборот         = -СтрокаТД.Всего;
				Движение.оборотБезСкидки= -СтрокаТД.Всего;
				Движение.оборотУпр      = -СтрокаТД.Всего;
				Движение.оборотБезСкидкиУпр= -СтрокаТД.Всего;
				//++Данилова Е.В. 03.10.2025 HELP-7050
				Если ТекДок.дата >= Дата(2025,09,01) Тогда 
					//Движение.Подразделение  = ТекДок.ДокОснование.Подразделение;
					Движение.Подразделение  = ?(ЗначениеЗаполнено(ТекДок.Подразделение),ТекДок.Подразделение,ТекДок.ДокОснование.Подразделение);
				Иначе
					Движение.Подразделение  = ТекДок.ДокОснование.Подразделение; 
				КонецЕсли;  
				//--Данилова Е.В. 03.10.2025
				Движение.ПунктДоставки  = ТекДок.ДокОснование.ПунктДоставки;
				Движение.КодОперации	= Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
				Если  ТекДок.Дата >='20191001' Тогда
					Движение.КодОперации	=Перечисления.КодыОперацийОстатки.Реализация;
				Иначе
					Движение.КодОперации	=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
				КонецЕсли;
				Если Движение.Количество < 0 Тогда
					Движение.Количество = - Движение.Количество;
					Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
					Движение.КодОперации	= Перечисления.КодыОперацийОстатки.Реализация;
					Движение.Сумма			= -СтрокаТД.СписанаСтоимость;
				КонецЕсли;
			КонецЕсли;
			Движение.акция = СтрокаТД.Акция;
		КонецЦикла;
		
		Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если ТекДок.ВидРекламации = Перечисления.ВидыРекламаций.Вычерк Тогда
				Если ТекДок.ДокОснование.Метаданные().Имя = "РасходнаяНакладная" Тогда
					Если ТекДок.ДокОснование.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда						
						//крохин начало 15.07.2020
						//обороты в комиссионных РНК и РКМ нулевые
						Для Каждого СтрокаТЧ Из ТДВО Цикл						
							СтрокаТЧ.Оборот = 0;
							СтрокаТЧ.ОборотБезСкидки = 0;
							СтрокаТЧ.ОборотУпр = 0;
							СтрокаТЧ.ОборотБезСкидкиУпр = 0;
						КонецЦикла;
						//крохин конец 15.07.2020	
						ТП = ТДВО.Скопировать();
						СкладКомиссия = ТекДок.СкладКомиссия;
						Для Каждого СтрокаТЧ Из ТП Цикл
							НоваяСтрокаТДВО = ТДВО.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрокаТДВО,СтрокаТЧ);
							НоваяСтрокаТДВО.Склад = СкладКомиссия;
							Если  СтрокаТЧ.ВидДвижения =  ВидДвиженияНакопления.Расход Тогда
								НоваяСтрокаТДВО.ВидДвижения = ВидДвиженияНакопления.Приход;
							Иначе
								НоваяСтрокаТДВО.ВидДвижения = ВидДвиженияНакопления.Расход;
							КонецЕсли;
						КонецЦикла;
						ТДВО.ЗаполнитьЗначения(Перечисления.КодыОперацийОстатки.Комиссия,"КодОперации");
					КонецЕсли;				 
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;

		Если ТипЗнч(ТекДок.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная")
			И (ТекДок.ВидРекламации = Перечисления.ВидыРекламаций.Вычерк ИЛИ ТекДок.ВидРекламации = Перечисления.ВидыРекламаций.Возврат)
			И ТекДок.Дата >=  '20240401' 
			и ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение
			Тогда 
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РеквизитыСправочников.ЗначениеРеквизита КАК Подразделение
			|ИЗ
			|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
			|ГДЕ
			|	РеквизитыСправочников.ИмяРеквизита = ""ПодразделениеФранчайзинга""
			|	И РеквизитыСправочников.Справочник.Ссылка = &ПунктДоставки";
			Запрос.УстановитьПараметр("ПунктДоставки",ТекДок.ПунктДоставки);
			ПунктДоставкиРезультат = Запрос.Выполнить().Выгрузить();
			Если ПунктДоставкиРезультат.Количество() > 0 Тогда  
				Для Каждого ТекСтрокаТовары Из ТекДок.Товары Цикл 
					
					Если ТекСтрокаТовары.Количество < 0 Тогда
						ВидДвиженияДопЗапись = ВидДвиженияНакопления.Приход;
					ИначеЕсли ТекСтрокаТовары.Количество > 0 Тогда 
						ВидДвиженияДопЗапись = ВидДвиженияНакопления.Расход;
					Иначе
						Продолжить;
					КонецЕсли;
					
					ДопЗаписьОстаковТМЦ = ТДВО.Добавить();
					ДопЗаписьОстаковТМЦ.ВидДвижения		= ВидДвиженияДопЗапись;
					ДопЗаписьОстаковТМЦ.Активность		= Истина;
					ДопЗаписьОстаковТМЦ.КодОперации 	= Перечисления.КодыОперацийОстатки.Перемещение;
					ДопЗаписьОстаковТМЦ.Период 			= ТекДок.Дата;
					ДопЗаписьОстаковТМЦ.Номенклатура 	= ТекСтрокаТовары.Номенклатура;
					ДопЗаписьОстаковТМЦ.Склад 			= ПунктДоставкиРезультат[0].Подразделение.ОсновнойСклад;
					ДопЗаписьОстаковТМЦ.Количество      = ?(ТекСтрокаТовары.Количество > 0,ТекСтрокаТовары.Количество,ТекСтрокаТовары.Количество * -1);
					ДопЗаписьОстаковТМЦ.Отправитель		= ТекДок.Склад;
					ДопЗаписьОстаковТМЦ.Сумма			= 0;
					
				КонецЦикла;
			КонецЕсли;	
		КонецЕсли;
		//Валетов -
		
		
		Результат=1;
		
		//**************************************************************************************************************************************		
		//Нечаева 15,02,14 +++	
	ИначеЕсли ТекВид="КорректировкаЦенВНакладной" Тогда
		
		ТДНакл=ПолучитьТЧДокумента(Документ.ДокОснование.Ссылка,"РасходнаяНакладная","Товары");	
		
		ВидОснования=ТекДок.ДокОснование.Метаданные().Имя;		
		// делается 2 проводки, на списание по даннным РНК и приход по даным РКМ (или наоборот).
		Если ВидОснования="ПриходнаяНакладная" ИЛИ ВидОснования="Перемещение" Тогда
			// ПНК и ПРК с точки зрения рекламаций - приходные документы соответственно недостачи по ним списываются
			ВидДвижения=ВидДвиженияНакопления.Расход;
			
			Если ТекДок.ДокОснование.КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР Тогда
				ТД.Очистить();			
			КонецЕсли; 
		ИначеЕсли ВидОснования="РасходнаяНакладная" Тогда
			//приходуем на склад
			ВидДвижения=ВидДвиженияНакопления.Приход;
		Иначе
			ВидДвижения=ВидДвиженияНакопления.Приход;
		КонецЕсли;		
		
		Для Каждого СтрокаТД Из ТД Цикл
			Если СтрокаТД.Количество=0 или СтрокаТД.Количество=0 Тогда Продолжить КонецЕсли; 
				ТО = ПолучитьОстаткиТМЦ(ТекДок,Загрузка);
				ТДВО.очистить();
				
				Для Каждого СтрокаТД Из ТекДок.Товары Цикл
					
					Движение=ТДВО.Добавить();	
					
					Движение.Активность		= Истина;
					Движение.Период			= ТекДок.Дата;		
					
					Движение.Склад			= ТекСклад;
					Движение.Номенклатура	= СтрокаТД.Номенклатура;
					
					Движение.Количество		= 0;
					Движение.Оборот			= -СтрокаТД.Всего;	
					Движение.Сумма          = 0;
					
					Движение.Отправитель	= ТекДок.Корреспондент;
					Движение.ВалютаДокумента=  ТекДок.ДокОснование.Валюта;
					Движение.оборотБезСкидки= Движение.оборот;
					Движение.оборотУпр      = Движение.оборот;
					Движение.оборотБезСкидкиУпр= Движение.оборот;
					//++Данилова Е.В. 03.10.2025 HELP-7050
					Если ТекДок.дата >= Дата(2025,09,01) Тогда 
						//	Движение.Подразделение  = ТекДок.ДокОснование.Подразделение;
						Движение.Подразделение  = ?(ЗначениеЗаполнено(ТекДок.Подразделение),ТекДок.Подразделение,ТекДок.ДокОснование.Подразделение);
					Иначе
						Движение.Подразделение  = ТекДок.ДокОснование.Подразделение; 
					КонецЕсли; 
					//--Данилова Е.В. 03.10.2025
					Движение.ПунктДоставки  = ТекДок.ДокОснование.ПунктДоставки;
					Движение.КодОперации	= Перечисления.КодыОперацийОстатки.Реализация;
				КонецЦикла;
				//какая-то ошибка, проводки формируются много раз
				Если ТекДок.Дата >= '20171101' Тогда
					Прервать;
				КонецЕсли;
		КонецЦикла;
		
		Результат=1;
		//Нечаева 15,02,14 ---
		//**************************************************************************************************************************************	
		
		
	ИначеЕсли ТекВид="СписаниеТМЦ" Тогда
		КодОперации=ТекДок.КодОперации;
		
		ТО=ПолучитьОстаткиТМЦ(ТекДок,Загрузка);

		НадоОбнулятьСебестоимость = Ложь;
		Если ТекДок.Дата >= '20040101' Тогда
			Если  ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения <> Перечисления.ВидыПодразделений.Франчайзинг И  ТекДок.Склад.Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
				НадоОбнулятьСебестоимость = Истина;	
			КонецЕсли;
		Иначе	
			Если ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения <> Перечисления.ВидыПодразделений.Франчайзинг И (ТекДок.Дата >= '20130301' И ТекДок.Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг) Тогда
				НадоОбнулятьСебестоимость = Истина;
			КонецЕсли;
		КонецЕсли;
		Если НадоОбнулятьСебестоимость Тогда
			ТО.ЗаполнитьЗначения(0,"Стоимость");
		КонецЕсли;
		
		Результат	=ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.СтатьяЗатрат,,ТОшибок,Истина);
		
	ИначеЕсли ТекВид="ЗаказПоставщику" Тогда
		КодОперации=Перечисления.КодыОперацийОстатки.Перемещение;

		ТО			=ПолучитьОстаткиТМЦ(ТекДок,Загрузка,ТекДок.ТранзитныйСклад);

		Результат	=ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Контрагент,,ТОшибок,Истина);
	ИначеЕсли ТекВид="Комплектация" Тогда
		КодОперации=Перечисления.КодыОперацийОстатки.Комплектация;
		
		Если ТекДок.Отгружен=Перечисления.Отгружен.Резерв Тогда	
			ТО=ПолучитьРезервыТМЦ(ТекДок,Загрузка);
			Результат	=ПогаситьРезервы(ТекДок,ТД,ТО,ТДВР,ТекДок.Склад,ТОшибок);			
		Иначе
			ТО			=ПолучитьОстаткиТМЦ(ТекДок,Загрузка);
			Результат	=ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Склад,,ТОшибок,Истина);		
			
			ТД.Свернуть("Продукция,Номенклатура","Количество,СписанаСтоимость,Амортизация");
			
			ТПрихода=ТД.Скопировать();		
			ТПрихода.Свернуть("Продукция","Количество,СписанаСтоимость,Амортизация");

			Если ТекДок.Дата >= '20110501' Тогда
				ЗаписиЦПП=РегистрыСведений.История.СоздатьНаборЗаписей();
				ЗаписиЦПП.Отбор.Документ.Использование	=Истина;
				ЗаписиЦПП.Отбор.Документ.Значение		=ТекДок.Ссылка;
				
				ЗаписиЦПП.Отбор.Реквизит.Использование	=Истина;
				ЗаписиЦПП.Отбор.Реквизит.Значение		="ЦенаПоследнегоПрихода";
			КонецЕсли;

			Если ТекДок.ЭтоРаскомплектация И (ТекДок.дата >= '20240201' И ТекДок.дата < '20260701') тогда
				ТПрихода=ТД.Скопировать();
				ТПрихода.Свернуть("Номенклатура","Количество,СписанаСтоимость");
				//Валетов + 02.07.2026 Проблема 0000000166 Приход делаем по ТЧ Продукция 
				Для Каждого СтрокаТЧ Из ТекДок.Товары Цикл   
				//Валетов-
					Если СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда Продолжить; КонецЕсли;
					
					Движение = ТДВО.Добавить();
					
					Движение.Активность		= Истина;
					Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
					Движение.Период 		= ТекДок.Дата;
					Движение.Склад = ТекСклад;   
					//Валетов + 02.07.2026 Проблема 0000000166 Приход делаем по ТЧ Продукция
				    Движение.Номенклатура	= СтрокаТЧ.Номенклатура; 
					Движение.Количество		= СтрокаТЧ.КоличествоКомплектующих;	
					
					ПараметрыОтбора = Новый Структура;
					//Валетов + 02.07.2026 Проблема 0000000166 Приход делаем по ТЧ Продукция
					ПараметрыОтбора.Вставить("Продукция", СтрокаТЧ.Номенклатура);  
					
					МассивСтрокТЧ = ТекДок.Комплектующие.НайтиСтроки(ПараметрыОтбора);
					КоличествоТоваров = 0;
					Для Сч=0 По (МассивСтрокТЧ.Количество() - 1) Цикл
						Если МассивСтрокТЧ[СЧ].Продукция.Родитель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда
							КоличествоТоваров = КоличествоТоваров + МассивСтрокТЧ[СЧ].КоличествоКомплектующих;
						КонецЕсли;
					КонецЦикла;
					
					СтрокаКМП	= ТПрихода.Найти(СтрокаТЧ.Номенклатура,"Номенклатура");
					
					Если СтрокаКМП<>Неопределено И КоличествоТоваров <> 0 Тогда			
						Движение.Сумма		= СтрокаКМП.СписанаСтоимость*СтрокаТЧ.КоличествоКомплектующих/КоличествоТоваров;
					Иначе
						Движение.Сумма		= 0;				
					КонецЕсли;	
					
					Движение.КодОперации	= КодОперации;
					Движение.Отправитель	= ТекДок.Склад;	
				КонецЦикла;
				//упаковка из ТЧ "товары"
				Для Каждого СтрокаТЧ Из ТекДок.Товары Цикл	
					Если СтрокаТЧ.Номенклатура.Родитель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар Тогда Продолжить; КонецЕсли;
					
					Движение = ТДВО.Добавить();
					
					Движение.Активность		= Истина;
					Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
					Движение.Период 		= ТекДок.Дата;
					Движение.Склад = ТекСклад;
					Движение.Номенклатура	= СтрокаТЧ.Номенклатура;						
					Движение.Количество		= СтрокаТЧ.Количество;							
					Движение.Сумма		= 0;							
					Движение.КодОперации	= КодОперации;
					Движение.Отправитель	= ТекДок.Склад;	
				КонецЦикла;
				//добавим разницу из-за округления в первую строку
				ТДВОКопия = ТДВО.Скопировать();
				ТДВОКопия.Свернуть("ВидДвижения","Сумма");
				Разница = 0;
				Для Каждого СтрокаТДВОКопия Из ТДВОКопия Цикл
					Если СтрокаТДВОКопия.ВидДвижения = ВидДвиженияНакопления.Приход Тогда
						Разница = Разница + СтрокаТДВОКопия.Сумма;	
					Иначе
						Разница = Разница - СтрокаТДВОКопия.Сумма;
					КонецЕсли;
				КонецЦикла;
				Если Разница <> 0 Тогда
					Для Каждого СтрокаТДВО Из ТДВО Цикл
						Если СтрокаТДВО.ВидДвижения  = ВидДвиженияНакопления.Приход И СтрокаТДВО.Сумма > Разница Тогда
							СтрокаТДВО.Сумма = СтрокаТДВО.Сумма - Разница;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Иначе
				//крохин конец 04.12.2024	
				Для Каждого СтрокаТЧ Из ТекДок.Товары Цикл			
					Движение = ТДВО.Добавить();
					
					Движение.Активность		= Истина;
