Функция ДвиженияЗаказаПоставщику(ТекДок,ТД)		
	Результат=1;
	
	ДатаДок		=ТекДок.Дата;
	
	ВалютаУпр	= ?(ТекДок.Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр		= ПолучитьКурсВалюты(ВалютаУпр,ДатаДок);	
	
	ВалютаДок	=ТекДок.Валюта;
	КурсДок		=ТекДок.Курс;
	
	Если ВалютаДок<>ВалютаУпр Тогда
		Для Каждого СтрокаТД Из ТД Цикл		
			СтрокаТД.Всего	=глПересчет(СтрокаТД.Всего,ВалютаДок,КурсДок,ВалютаУпр,КурсУпр);	
		КонецЦикла;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции

Функция ДвиженияОприходования(ТекДок,ТД,ТО,Загрузка)
	ВалютаУпр	=?(ТекДок.Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	КурсУпр		=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,ТекДок.Дата);
	
	ВалютаДок	=?(ЗначениеЗаполнено(ТекДок.Валюта),ТекДок.Валюта,ПараметрыСеанса.ВалютаУпр);
	КурсДок		=?(ЗначениеЗаполнено(ТекДок.Курс),ТекДок.Курс,ПолучитьКурсВалюты_ПоРусски(ВалютаДок,ТекДок.Дата));
	
	Результат=1;
	
	ТД.Колонки.Добавить("РасчетнаяЦена",ПолучитьОписаниеТиповЧисла(15,2));
	
	СписокМоделей=Новый Массив;
	
	ТипУзла=ПараметрыСеанса.ТипУзла;
	
	НеНашлиЦены=Новый Соответствие;
	Для Каждого СтрокаТД Из ТД Цикл
		Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если СтрокаТД.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.ОсновноеСредство Тогда			
				СтрокаОстатка=ТО.Найти(СтрокаТД.Номенклатура,"Номенклатура");	
				Если СтрокаОстатка<>Неопределено И СтрокаОстатка.Остаток>0 Тогда
					Если СтрокаОстатка.Стоимость>0 Тогда
						СтрокаТД.РасчетнаяЦена=СтрокаОстатка.Стоимость/СтрокаОстатка.Остаток;
					Иначе
						Если ТекДок.Дата>='20091101'Тогда //По просьбе Сибилева от 17.11.2009 приходуем по нулевым ценам
							СтрокаТД.РасчетнаяЦена=0
						Иначе
							НеНашлиЦены.Вставить(СтрокаТД,Истина);
							Если СписокМоделей.Найти(СтрокаТД.Номенклатура.Родитель)=Неопределено Тогда
								СписокМоделей.Добавить(СтрокаТД.Номенклатура.Родитель);			
							КонецЕсли; 						
						КонецЕсли;					
					КонецЕсли;
				Иначе
					НеНашлиЦены.Вставить(СтрокаТД,Истина);
					Если СписокМоделей.Найти(СтрокаТД.Номенклатура.Родитель)=Неопределено Тогда
						СписокМоделей.Добавить(СтрокаТД.Номенклатура.Родитель);			
					КонецЕсли; 
				КонецЕсли;			
			КонецЕсли;			
		Иначе //в периферийных узлах просто берем цены из ТЧ
			НеНашлиЦены.Вставить(СтрокаТД,Истина);
			Если СписокМоделей.Найти(СтрокаТД.Номенклатура.Родитель)=Неопределено Тогда
				СписокМоделей.Добавить(СтрокаТД.Номенклатура.Родитель);			
			КонецЕсли;			
		КонецЕсли;		
	КонецЦикла;
	
	//если не нашли на остатках попробуем найти по остаткам модели
	Если НеНашлиЦены.Количество()>0 Тогда
		ТО=ПолучитьЦеныМоделей(ТекДок,СписокМоделей,Загрузка);	
		Для Каждого Элемент Из НеНашлиЦены Цикл		
			СтрокаТД=Элемент.Ключ;
			СтрокаОстатка=ТО.Найти(СтрокаТД.Номенклатура.Родитель,"Модель");	
			Если СтрокаОстатка<>Неопределено И ЗначениеЗаполнено(СтрокаОстатка.РасчетнаяЦена) Тогда
				СтрокаТД.РасчетнаяЦена=СтрокаОстатка.РасчетнаяЦена;
				НеНашлиЦены.Удалить(СтрокаТД);
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;	
	
	//если совсем ничего не нашли тогда берем ЦПП
	Если НеНашлиЦены.Количество()>0 Тогда
		Если ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Для Каждого Элемент Из НеНашлиЦены Цикл
				СтрокаТД=Элемент.Ключ;
				//ПолучитьПериодическийРеквизит(Объект,ИмяРеквизита,Знач Дата2=Неопределено,КодИБ=Неопределено,ДатаРеквизита="") Экспорт
				
				ДатаЦены="";
				СтрокаТД.РасчетнаяЦена=ПолучитьПериодическийРеквизит(СтрокаТД.Номенклатура,"ЦенаПоследнегоПрихода",ТекДок.Дата,,ДатаЦены);
				Если ЗначениеЗаполнено(СтрокаТД.РасчетнаяЦена) И ДатаЦены<'20090101' И ТекДок.Дата>='20090101' Тогда
					СтрокаТД.РасчетнаяЦена=глПересчет(СтрокаТД.РасчетнаяЦена,ПараметрыСеанса.ВалютаУпр,ДатаЦены,ВалютаУпр,КурсУпр);									
				КонецЕсли; 
			КонецЦикла;	
		КонецЕсли;	
	КонецЕсли;
	
	ТекСкладДокумента=ТекДок.Склад;
	
	Склады=Новый Массив;
	Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда	
		//Кухарь 13.05.16 начало
		//Не увидел что у ОПР отдельно всё
		//Если НЕ ТекДок.Склад.ФизическийСклад.Пустая()  Тогда
		Если НЕ ТекДок.Склад.ФизическийСклад.Пустая()  и не (ТекДок.склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.Склад) Тогда
			//Кухарь 13.05.16 конец
			ТекСкладДокумента=ТекДок.Склад.ФизическийСклад;
		КонецЕсли;
		//Кухарь 13.05.16 начало
		//крохин начало 20.12.2018
		//опечатка
		//ИначеЕсли ТекСкладДокумента.видсклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и НЕ ТекСкладДокумента.Склад.ФизическийСклад.Пустая()  тогда
	ИначеЕсли ТекСкладДокумента.видсклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и НЕ ТекСкладДокумента.ФизическийСклад.Пустая()  тогда
		//крохин конец 20.12.2018
		ТекСкладДокумента=ТекСкладДокумента.ФизическийСклад;
		//Кухарь 13.05.16 конец		
		
	КонецЕсли;		
	
	ТД.ЗаполнитьЗначения(ТекСкладДокумента,"Склад");	
	Для Каждого СтрокаТД ИЗ ТД Цикл
		Если ЗначениеЗаполнено(СтрокаТД.ЦенаОприходования) Тогда
			СтрокаТД.РасчетнаяЦена=глПересчет(СтрокаТД.ЦенаОприходования,ВалютаДок,КурсДок,ВалютаУпр,КурсУпр);		
		КонецЕсли;
		Если СтрокаТД.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.ОсновноеСредство Тогда
			СтрокаТД.Всего=СтрокаТД.Количество*СтрокаТД.РасчетнаяЦена;
		Иначе
			Если СтрокаТД.Количество<>0 Тогда				
				СтрокаТД.Всего=СтрокаТД.Количество*СтрокаТД.РасчетнаяЦена;			
			КонецЕсли;			
		КонецЕсли;			
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции // ДвиженияОприходования() 

Функция ДвиженияИнвентаризации(ТекДок,ТД)
	//крохин начало 20.12.2018
	//разрешаем ИНВ по вспомогательному складу, в ЦО проводки по основному
	//ТД.ЗаполнитьЗначения(ТекДок.Склад,"Склад");
	Если ТекДок.Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада И ПараметрыСеанса.ЭтотУзел.ТипУзла <> Перечисления.ТипУзлаИБ.Склад Тогда
		ТД.ЗаполнитьЗначения(ТекДок.Склад.ФизическийСклад,"Склад");
	Иначе
		ТД.ЗаполнитьЗначения(ТекДок.Склад,"Склад");
	КонецЕсли;
	//крохин конец 20.12.2018	
	ТС=ТД.Скопировать(); ТС.Очистить();
	ТО=ТД.Скопировать(); ТО.Очистить();
	
	Для Каждого СтрокаТЧ Из ТД Цикл
		Если СтрокаТЧ.Количество<0 Тогда		
			СтрокаТС=ТС.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТС,СтрокаТЧ);
			СтрокаТС.Количество=-СтрокаТС.Количество;
		ИначеЕсли СтрокаТЧ.Количество>0 Тогда		
			СтрокаТО=ТО.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТО,СтрокаТЧ);
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат Новый Структура("ТС,ТО",ТС,ТО);
КонецФункции // ДвиженияИнвентаризации()


Функция ПолучитьТаблицуСписания(Документ)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ОстаткиТМЦ.Склад,
	|	ОстаткиТМЦ.Номенклатура,
	|	ОстаткиТМЦ.Марка,
	|	ОстаткиТМЦ.Количество,
	|	ОстаткиТМЦ.Вес,
	|	ОстаткиТМЦ.Сумма
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|ГДЕ
	|	ОстаткиТМЦ.Регистратор = &Регистратор
	|	И ОстаткиТМЦ.ВидДвижения = &Расход"
	;
	
	Запрос.УстановитьПараметр("Регистратор",Документ);
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ПолучитьТаблицуСписания() 


Функция СоздатьТаблицуДвижений(ИмяРегистра)
	Набор=РегистрыНакопления[ИмяРегистра].СоздатьНаборЗаписей();
	
	Возврат Набор.Выгрузить();	
КонецФункции // СоздатьТаблицуДвижений(ИмяРегистра) 

Функция ПолучитьТЧДокумента(Ссылка,ВидДокумента,ИмяТЧ="Товары")
	МетаДок=Метаданные.Документы[ВидДокумента];
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура.Услуга 					КАК ЭтоУслуга,
	|	Номенклатура.Родитель.ВидНоменклатуры	КАК ВидНоменклатуры,
	|	*
	|ИЗ
	|	Документ."+ВидДокумента+"."+ИмяТЧ+"
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И (
	|		Количество<>0 
	|		"+?(ЕстьРеквизитТабЧастиДокумента("Всего",МетаДок,ИмяТЧ),"ИЛИ Всего<>0","")+"
	|		"+?(ВидДокумента="Перемещение"," ИЛИ ПодтвержденнаяЗаявка<>0","")+"
	|	)
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура";	
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ПолучитьТЧДокумента()

Функция ПолучитьТЧУпаковкаДокумента(Ссылка,ВидДокумента,ИмяТЧ="Упаковка")
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура.Услуга 					КАК ЭтоУслуга,
	|	Номенклатура.Родитель.ВидНоменклатуры	КАК ВидНоменклатуры,
	|   0 КАК Всего,
	|   0 КАК ВсегоБезСкидки,
	|	*
	|ИЗ
	|	Документ."+ВидДокумента+"."+ИмяТЧ+"
	|ГДЕ
	|	Ссылка = &Ссылка
	//|	И (Количество<>0 ИЛИ Всего<>0"+?(ВидДокумента="Перемещение"," ИЛИ ПодтвержденнаяЗаявка<>0","")+")
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура";	
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ПолучитьТЧДокумента()

Функция РассчитатьОбороты(ТД,ВалютаДокумента,КурсДокумента,Рубли,КурсРубля,ВалютаУпр,КурсВалютыУпр,Знак=1)
	Для Каждого СтрокаТД Из ТД Цикл
		Если ВалютаДокумента<>ВалютаУпр Тогда
			СтрокаТД.ОборотУпр			=Знак*глПересчет(СтрокаТД.Всего,			ВалютаДокумента,КурсДокумента,ВалютаУпр,КурсВалютыУпр);							
			СтрокаТД.ОборотБезСкидкиУпр =Знак*глПересчет(СтрокаТД.ВсегоБезСкидки,	ВалютаДокумента,КурсДокумента,ВалютаУпр,КурсВалютыУпр);
		Иначе
			СтрокаТД.ОборотУпр			=Знак*СтрокаТД.Всего;				
			СтрокаТД.ОборотБезСкидкиУпр =Знак*СтрокаТД.ВсегоБезСкидки;
		КонецЕсли;
		
		Если ВалютаДокумента<>Рубли Тогда
			СтрокаТД.Оборот				=Знак*глПересчет(СтрокаТД.Всего,			ВалютаДокумента,КурсДокумента,Рубли,29);							
			СтрокаТД.ОборотБезСкидки	=Знак*глПересчет(СтрокаТД.ВсегоБезСкидки,	ВалютаДокумента,КурсДокумента,Рубли,29);
		Иначе
			СтрокаТД.Оборот				=Знак*СтрокаТД.Всего;				
			СтрокаТД.ОборотБезСкидки	=Знак*СтрокаТД.ВсегоБезСкидки;
		КонецЕсли;
	КонецЦикла;	
КонецФункции // РассчитатьОборот()


Функция ПровестиПоОстаткам(Документ,Движения,Загрузка=Ложь,ТаблицаСписания) Экспорт	
	Если ПараметрыСеанса.Отладка Тогда
		Сообщить("Проведение: "+Документ);
	КонецЕсли;
	
	ЭтотУзел=ПараметрыСеанса.ЭтотУзел;
	
	Результат	=1;
	ТОшибок		=Неопределено;	
	
	ТДВО=СоздатьТаблицуДвижений("ОстаткиТМЦ");
	ТДВР=СоздатьТаблицуДвижений("РезервыТМЦ");
	
	КонтрольОстатковНаТА=НЕ ПолучитьПолномочиеПользователя("НеКонтролироватьОстаткиНаТА");
	
	ТекВид			= Документ.Метаданные().Имя;	
	ТекДок			= Документ;
	
	ДатаДокумента	= ПолучитьРеквизитыШапки(ТекДок,Новый Структура("Дата")).Дата;	
	
	#Если Клиент Тогда
		Состояние(""+ТекВид+" "+ТекДок.Номер+" "+ДатаДокумента);
	#КонецЕсли
	
	ВалютаУпр	= ?(ДатаДокумента>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);	
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Документ.Дата);
	
	Рубли		= ПараметрыСеанса.ВалютаНац;	
	КурсРубля	= ПолучитьКурсВалюты_ПоРусски(Рубли,ДатаДокумента);
	
	ТС=Новый ТаблицаЗначений;
	ТС.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));	
	
	// *** РНК+КМПЛ
	ИмяТЧ = ПолучитьИмяТоварнойТЧ(Документ);
	// РНК+КМПЛ ***	
	
	ТД=ПолучитьТЧДокумента(Документ,ТекВид,ИмяТЧ);
	ТД.Колонки.Добавить("КодОперации");
	//упаковка
	Если ТекВид="РасходнаяНакладная" И ТребуетсяУпаковка(Документ.ДопОбработки,Документ.КодОперации) Тогда
		если  Документ.КМПЛУпаковка тогда
			ТДУпаковка = ПолучитьТЧУпаковкаДокумента(Документ.Ссылка,ТекВид,"КомплектующиеУпаковки");
			Если  ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
				ТекСклад			=?(ТекДок.Склад.ФизическийСклад.Пустая(),ТекДок.Склад,ТекДок.Склад.ФизическийСклад);
			Иначе
				ТекСклад			=ТекДок.Склад;
			КонецЕсли;
			
			Для Каждого СтрокаТДУпаковка ИЗ ТДУпаковка Цикл	
				если СтрокаТДУпаковка.Номенклатура<> СтрокаТДУпаковка.Продукция тогда
					
					НоваяСтрокаТД = ТД.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаТД,СтрокаТДУпаковка);
					НоваяСтрокаТД.КодОперации = Перечисления.КодыОперацийОстатки.Комплектация;
					
					Движение = ТДВО.Добавить();		
					
					Движение.Активность		= Истина;
					Движение.подразделение=ТекДок.подразделение;
					движение.валютаДокумента=ТекДок.валюта;
					Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
					Движение.ПунктДоставки	= ТекДок.пунктДоставки;
					
					Движение.Период 		= ТекДок.Дата;
					Движение.Склад			= ТекСклад;
					Движение.Номенклатура	= СтрокаТДУпаковка.Продукция;										
					Движение.Количество		= СтрокаТДУпаковка.КоличествоПродукции;
					Движение.КодОперации	= Перечисления.КодыОперацийОстатки.Комплектация;
					Движение.Отправитель	= ТекДок.Склад;	
				КонецЕсли;
				
				
			КонецЦикла;
			ТДПродукции=ТДУпаковка.скопировать();
			ТДПродукции.свернуть("Продукция","Количество,КоличествоПродукции");
			Для каждого СтрПродукции из ТДПродукции цикл
				НоваяСтрокаТД = ТД.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТД,СтрПродукции);
				НоваяСтрокаТД.Номенклатура=СтрПродукции.Продукция;
				НоваяСтрокаТД.КодОперации = Перечисления.КодыОперацийОстатки.Списание;	
				НоваяСтрокаТД.Всего=0;
				НоваяСтрокаТД.ВсегоБезСкидки=0;				
				НоваяСтрокаТД.ЭтоУслуга=ложь;
			КонецЦикла;
			
			
		иначе
			ТДУпаковка = ПолучитьТЧУпаковкаДокумента(Документ.Ссылка,ТекВид,"Упаковка");
			Для Каждого СтрокаТДУпаковка ИЗ ТДУпаковка Цикл	
				НоваяСтрокаТД = ТД.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТД,СтрокаТДУпаковка);
				//крохин начало 29.10.2015
				Если Документ.дата >= '20151001' Тогда
					НоваяСтрокаТД.КодОперации = Перечисления.КодыОперацийОстатки.Списание;
				КонецЕсли;
				//крохин конец 29.10.2015
			КонецЦикла;
			
		КонецЕсли;
		//Кухарь 01.04.19 конец
		
	КонецЕсли;
	//крохин конец 10.07.2015
	
	//крохин начало 29.10.2015
	//упаковка ПРМ
	Если ТекВид = "Перемещение" Тогда
		ТДУпаковка = ПолучитьТЧУпаковкаДокумента(Документ.Ссылка,ТекВид,"Упаковка");
		Для Каждого СтрокаТДУпаковка ИЗ ТДУпаковка Цикл	
			НоваяСтрокаТД = ТД.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТД,СтрокаТДУпаковка);
			Если Документ.дата >= '20151001' Тогда
				НоваяСтрокаТД.КодОперации = Перечисления.КодыОперацийОстатки.Списание;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если НЕ ЕстьРеквизитТабЧастиДокумента("Склад",ТекДок.Метаданные(), ИмяТЧ) Тогда	
		ТД.Колонки.Добавить("Склад",Новый ОписаниеТипов("СправочникСсылка.Склады"));	
	КонецЕсли;	
	
	Если НЕ ЕстьРеквизитТабЧастиДокумента("Подразделение",ТекДок.Метаданные(), ИмяТЧ) Тогда
		ТД.Колонки.Добавить("Подразделение",Новый ОписаниеТипов("СправочникСсылка.Подразделения"));	
	КонецЕсли;
	
	
	ТД.Колонки.Добавить("ЦенаСписания", 		ПолучитьОписаниеТиповЧисла(19,10));
	ТД.Колонки.Добавить("СписанаСтоимость", 	ПолучитьОписаниеТиповЧисла(19,2));
	ТД.Колонки.Добавить("Оборот",				ПолучитьОписаниеТиповЧисла(19,2));	
	ТД.Колонки.Добавить("ОборотБезСкидки",		ПолучитьОписаниеТиповЧисла(19,2));	
	ТД.Колонки.Добавить("ОборотУпр",			ПолучитьОписаниеТиповЧисла(19,2));	
	ТД.Колонки.Добавить("ОборотБезСкидкиУпр",	ПолучитьОписаниеТиповЧисла(19,2));	
	ТД.Колонки.Добавить("ВалютаДокумента",		ПолучитьОписаниеТиповЧисла(19,2));	
	ТД.Колонки.Добавить("Амортизация",			ПолучитьОписаниеТиповЧисла(19,2));
	
	Если ТД.Колонки.Найти("ДК")=Неопределено Тогда
		ТД.Колонки.Добавить("ДК");		
	КонецЕсли;	
	
	Если ТекДок.Дата<'20080201' ИЛИ ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		ТекСклад			=?(ТекДок.Склад.ФизическийСклад.Пустая(),ТекДок.Склад,ТекДок.Склад.ФизическийСклад);
	Иначе
		ТекСклад			=ТекДок.Склад;
	КонецЕсли;
	
	//ЗПС формирует движения только по транзитному складу
	Если ТекВид="ЗаказПоставщику" Тогда
		ТекСклад = ТекДок.ТранзитныйСклад;
	Конецесли;
	//Новый вид склада
	если ТекДок.склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада тогда
		если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.Склад тогда
			ТекСклад=ТекДок.склад;
		иначе
			ТекСклад=ТекДок.склад.физическийсклад;
		КонецЕсли;
	КонецЕсли;
	ТД.ЗаполнитьЗначения(ТекСклад,"Склад");
	// +++ 2011-11-21 сезонные бонусы
	Если ТекВид="РасходнаяНакладная" 
		И ЕстьРеквизитТабЧастиДокумента("ЦенаБезБонуса", ТекДок.Метаданные(), ИмяТЧ) Тогда
		Если Документ.СезонныйБонус	Тогда
			// для РНК с сезонным бонусом вместо Цена и Всего используем ЦенаБезБонуса и ВсегоБезБонуса
			Для Каждого СтрокаТД Из ТД Цикл
				СтрокаТД.Цена	= СтрокаТД.ЦенаБезБонуса;
				СтрокаТД.Всего	= СтрокаТД.ВсегоБезБонуса;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// 2011-11-21 сезонные бонусы +++
	Если ТекВид="ПриходнаяНакладная" Тогда
		//крохин начало
		//по услугам ИМ движений не делаем
		СписокУдаляемыхСтрок = Новый СписокЗначений;
		Для Каждого СтрокаТД Из ТД Цикл
			//Если ПолучитьРеквизитРодителя(СтрокаТД.Номенклатура,"ВидНоменклатуры") =  Перечисления.ВидыНоменклаутры.Услуга Тогда
			Если СтрокаТД.ВидНоменклатуры =  Перечисления.ВидыНоменклаутры.Услуга Тогда //Чирков
				СписокУдаляемыхСтрок.Добавить(СтрокаТД);
			КонецЕсли;
			//по упаковке тоже не делаем движений
			//Если ПолучитьРеквизитРодителя(СтрокаТД.Номенклатура,"ВидНоменклатуры") =  Перечисления.ВидыНоменклаутры.Упаковка Тогда
			Если СтрокаТД.ВидНоменклатуры =  Перечисления.ВидыНоменклаутры.Упаковка Тогда //Чирков
				СписокУдаляемыхСтрок.Добавить(СтрокаТД);
			КонецЕсли;
			//крохин конец	
		КонецЦикла;
		
		Для Каждого СтрокаСписка Из СписокУдаляемыхСтрок Цикл
			Тд.Удалить(СтрокаСписка.Значение);	
		КонецЦикла;		
		//крохин конец
		
		ТД.ЗаполнитьЗначения(ТекДок.Подразделение,"Подразделение");
		
		Результат	=ДвиженияПриходнойНакладной(ТекДок,ТД);
		
		ТекРезультат=ОприходоватьПартию(ТекДок,ТекДок.КодОперации,ТД,ТДВО,ТекДок.Контрагент,ТекДок.ПунктДоставки);
		//крохин начало 25.01.2017
		//возвраты сертификатов формируют доп. проводку, на списание сертификата
		Если ТекДок.ВозвратПСотЧЛ Тогда
			ТДСертификатов = ТД.скопировать();
