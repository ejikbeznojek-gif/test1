Функция ПроверитьОстатки(ТекДок,КодОперации,Товары,Остатки,ТДВО,Получатель=Неопределено,ПунктДоставки=Неопределено,ТО=Неопределено,КонтрольОстатков=Истина,Период=Неопределено,КолонкаКоличества="Количество")
	МетаДок=ТекДок.Метаданные();
	Если ЕстьРеквизитДокумента("Валюта",МетаДок) Тогда
		ВалютаДокумента=ТекДок.Валюта;		
	Иначе
		ВалютаДокумента=?(ТекДок.Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);						
	КонецЕсли;	
	
	НеСписыватьКоличество=Ложь;
	
	КурсУпр		=	глПересчет(1,ВалютаДокумента,ТекДок.Дата,ПараметрыСеанса.ВалютаУпр_2009,ТекДок.Дата,Ложь);		
	
	Результат=1;
	
	КэшЦенСписания	=Новый Соответствие;
	ПолучательВТЧ	=?(Товары.Колонки.Найти("Получатель")=Неопределено,Ложь,Истина); 
	ТекПериод		=?(Период=Неопределено,ТекДок.Дата,Период);
	
	Для Каждого СтрокаТоваров Из Товары Цикл	
		
		НадоСписать 	=СтрокаТоваров.Количество;			
		
		Если КонтрольОстатков Тогда
			
			Номенклатура	=СтрокаТоваров.Номенклатура;
			ТекОстатки		=Остатки.НайтиСтроки(Новый Структура("Номенклатура",СтрокаТоваров.Номенклатура));
			
			Остаток			=0;  Резерв		=0;
			
			ЦенаСписания	=Неопределено;
			
			Для Каждого СтрокаОстатка Из ТекОстатки Цикл
				Остаток					=СтрокаОстатка.Остаток;
				Резерв					=СтрокаОстатка.Резерв;					
				
				ОперационныйОстаток		=СтрокаОстатка.Остаток	-Макс(СтрокаОстатка.Резерв,0);
				
				Если Остаток<>0 Тогда
					ЦенаСписания=СтрокаОстатка.Стоимость/Остаток;
					КэшЦенСписания.Вставить(Номенклатура,ЦенаСписания);
				КонецЕсли; 
				
				ТекКоличество=Мин(НадоСписать,ОперационныйОстаток);
				Если ТекКоличество>0 Тогда			
					
					НадоСписать=НадоСписать-ТекКоличество;
				КонецЕсли;
			КонецЦикла; 
			Если НадоСписать<>0 Тогда				
				ЗаписатьВТаблицуОшибок(ТО,ТекДок,"Недостаточно товара",Товары.Индекс(СтрокаТоваров),СтрокаТоваров,Остаток,Резерв);
				
				Результат=-1;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции
