			КонецЦикла;
			
		КонецЕсли;
		
		Если ТекДок.КодОперации = Перечисления.КодыОперацийОстатки.Реализация
			И ТекДок.Склад.ТипСклада = Перечисления.ТипСклада.КомиссионныйСклад
			И ТО <> Неопределено Тогда
				
			Для Каждого СтрокаТЧ Из ТекДок.Товары Цикл
				
				Если СтрокаТЧ.Количество = 0 Тогда 
					Продолжить;
				КонецЕсли;
				
				Запись = ТДВ.Добавить();
				Запись.Активность = Истина;
				Запись.ВидДвижения = ВидДвиженияНакопления.Расход;
				Запись.Период = ТекДок.Дата;
				Запись.Склад = ТекДок.Склад;
