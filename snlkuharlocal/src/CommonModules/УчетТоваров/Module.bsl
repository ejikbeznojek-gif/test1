			КонецЕсли;
			//крохин конец 07.12.2020
			Запись.Период = ТекДок.Дата;
			Запись.Склад = ТекДок.Склад;
			Запись.Номенклатура = СтрокаТЧ.номенклатура;
			
			//крохин начало 07.12.2020
			//Запись.Количество = СтрокаТЧ.Количество;
