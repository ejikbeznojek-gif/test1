//Мессерле
функция ВернутьТипГруппыНоменклатуры(Группа) экспорт
	//Возвращает тип. номенклатуры, считая уровни СНИЗУ (станд. Уровень()-сверху)
	Родитель=Группа.родитель;
	
	//Для новых товаров будет незаполнено, также и для товаров первого уровня- все можно редактировать
	Если НЕ ЗначениеЗаполнено(Родитель) тогда
		возврат("Модель");
	Конецесли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Родитель = &ССылка
	|	И (НЕ Номенклатура.ЭтоГруппа)";
	
	Запрос.УстановитьПараметр("ССылка", Группа);
	выб=запрос.Выполнить().Выбрать();
	Если выб.Количество()>0 тогда
		Возврат("Модель");
	Конецесли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Номенклатура.Родитель КАК Коллекция,
	|	Номенклатура.Родитель.Родитель КАК Бренд
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
	|		ПО Номенклатура.Ссылка = Номенклатура1.Родитель
	|			И ((НЕ Номенклатура1.ЭтоГруппа))
	|ГДЕ
	|	Номенклатура.Родитель В ИЕРАРХИИ(&ССылка)
	|	И Номенклатура.ЭтоГруппа
	|
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура.Родитель,
	|	Номенклатура.Родитель.Родитель
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Номенклатура1.Ссылка) > 0";
	
	Запрос.УстановитьПараметр("ССылка", Родитель);
	
	Результат = Запрос.Выполнить();
	тз=Результат.Выгрузить();
	НАШЛИ=ЛОЖЬ;
	ВыборкаДетали = Результат.Выбрать();
	Если ВыборкаДетали.Количество()=1 тогда
		ВыборкаДетали.Следующий();
		Если  ВыборкаДетали.Коллекция=Родитель тогда
			Возврат("Модель");
		иначеесли	ВыборкаДетали.Бренд=Родитель тогда
			Возврат("Коллекция");
		иначе	
			Возврат("Модель");
		Конецесли;
	иначеесли  ВыборкаДетали.Количество()>1 тогда
		//Бренд или выше
		
		пока выборкадетали.Следующий() цикл
			
			Если	ВыборкаДетали.Бренд=Родитель тогда
				Возврат("Коллекция");
			Конецесли;
			
		Конеццикла; 
	иначеесли ВыборкаДетали.Количество()=0 тогда
		Нашли=Ложь;
	иначе
		Нашли=ИСТИНА;
	Конецесли;
	
	Если НЕ НАШЛИ тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В ИЕРАРХИИ(&ССылка)
		|	И (НЕ Номенклатура.ЭтоГруппа)";
		
		Запрос.УстановитьПараметр("ССылка", Родитель);
		выб=запрос.Выполнить().Выбрать();
		Если выб.Количество()=0 тогда //Нет элементов внутри родителя- считаем моделью
			Возврат("Модель");
		Конецесли;
		
		Возврат("ТипТовара");
	Конецесли;
	
Конецфункции	


