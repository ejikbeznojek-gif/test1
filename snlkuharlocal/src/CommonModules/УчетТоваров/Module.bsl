			//крохин конец 16.04.2012
			
			РассчитатьОбороты(ТД,ТекДок.Валюта,ТекДок.Курс,Рубли,КурсРубля,ВалютаУпр,КурсУпр);
			
			Если ТекДок.Отгружен=Перечисления.Отгружен.Резерв ИЛИ ТекДок.Отгружен=Перечисления.Отгружен.РезервТранзит или ТекДок.Отгружен=Перечисления.Отгружен.Отменен Тогда
				//РНК+КМПЛ				
