			СтрокаТР=ТР.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТР,СтрокаТР_Попустым);			
		КонецЦикла; 			
	КонецЕсли;
	
	Для Каждого СтрокаТР Из ТР Цикл
