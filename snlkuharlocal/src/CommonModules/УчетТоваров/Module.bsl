Функция ПолучитьОстаткиТМЦКомиссия(Конт,Загрузка,Склад=Неопределено,Период=Неопределено,ИмяТЧ=Неопределено) Экспорт
	// РНК+КМПЛ ***
	//крохин конец	
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	Если Загрузка Тогда
		
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	&СкладДокумента				КАК Склад,
		|	Номенклатура,
		|	СУММА(Количество)			КАК Остаток,
		|	СУММА(Всего)				КАК Стоимость	
		|ИЗ
		|	Документ."+ВидДокумента+".Товары ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО 
		|	Ссылка.Склад,
		|	Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Ссылка.Склад.Код";
	Иначе		
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	Склад,
		|	Номенклатура,
		|	СУММА(Остаток)				КАК Остаток,
		|	СУММА(Стоимость)			КАК Стоимость		
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	Склад,
		|	Номенклатура,	
		|	КоличествоОстаток	Как Остаток,	
		|	СуммаОстаток 		Как Стоимость			
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦКомиссия.Остатки(&МоментВремени,
		|	Склад В (&Склады)
		|	И Номенклатура В  (&МассивНоменклатуры)
		|)	
		|КАК ОстаткиОпер
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.ОстаткиТМЦКомиссия.Остатки";
		
		
		ТекстЗапроса=ТекстЗапроса+"
		|) КАК ОбщийЗапрос
		|СГРУППИРОВАТЬ ПО Склад,Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Склад.Код";
	КонецЕсли;	
	
	Запрос.Текст=ТекстЗапроса;	
	
	Запрос.УстановитьПараметр("Ссылка",				Конт.Ссылка);
	Запрос.УстановитьПараметр("МассивНоменклатуры",	ПолучитьНоменклатуруДокумента(Конт.Ссылка, ИмяТЧ));
	
	ТекСкладДокумента=Конт.Склад;
	
	Склады=Новый Массив;
	Склады.Добавить(Конт.Склад);						
	
	Запрос.УстановитьПараметр("СкладДокумента",ТекСкладДокумента);
	Запрос.УстановитьПараметр("Склады",Склады);
	Если Период=Неопределено Тогда
		Запрос.УстановитьПараметр("МоментВремени",новый граница(Конт.МоментВремени(),видграницы.Исключая));	
	Иначе
		Запрос.УстановитьПараметр("МоментВремени",Период);
	КонецЕсли;	
	
	Результат	=Запрос.Выполнить();
	
	ТО=Результат.Выгрузить();	
	
	ТО.Колонки.Добавить("Погашено",			ПолучитьОписаниеТиповЧисла(12,3));
	ТО.Колонки.Добавить("СписанаСтоимость",	ПолучитьОписаниеТиповЧисла(19,2));
	
	Возврат ТО;
КонецФункции

