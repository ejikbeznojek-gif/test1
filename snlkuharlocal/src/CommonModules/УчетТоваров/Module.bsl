	|	СуммаОстаток		КАК Стоимость	
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2,Склад = &Склад И Номенклатура В (&Номенклатура))
	|КАК ОстаткиТМЦОстатки";
	
	Запрос.УстановитьПараметр("Дата2", Новый Граница(Документ.МоментВремени(),ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Склад",Документ.ДокОснование.СкладКомиссия);
	Запрос.УстановитьПараметр("Номенклатура",СписокНоменклатуры);	
	
	ТР=Запрос.Выполнить().Выгрузить();
	
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	* 
	|ПОМЕСТИТЬ ТР
	|ИЗ
	|	&ТР КАК ТР
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура	
	|ПОМЕСТИТЬ ПНК
	|ИЗ
	|	Документ.Претензия.Товары КАК ПНК
	|ГДЕ
	|	Ссылка=&Ссылка
	|	И Количество<0
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПНК.Номенклатура КАК Номенклатура
	|ИЗ
	|	ПНК
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ТР
	|ПО		
	|	ТР.Номенклатура=ПНК.Номенклатура
	|ГДЕ
	|	ТР.Количество ЕСТЬ NULL ИЛИ ТР.Количество=0";
	
	Запрос.УстановитьПараметр("ТР",ТР);
	Запрос.УстановитьПараметр("Ссылка",Документ.Ссылка);
	СписокПустыхПозиций=Запрос.Выполнить().Выгрузить();
	
	Если СписокПустыхПозиций.Количество()>0 И Документ.Дата>='20110601' Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура,
		|	Период,
		|	Регистратор,
		|	Сумма,
		|	Количество
		|ПОМЕСТИТЬ Приходы
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
		|ГДЕ
		|	ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|	И (КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Закупка) ИЛИ КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Комплектация))
		|	И Номенклатура В (&Номенклатура)
		|	И Период МЕЖДУ &ДатаЧ И &Дата2
		|;
		|ВЫБРАТЬ 
		|	Номенклатура,
		|	МАКСИМУМ(Период) КАК Период
		|ПОМЕСТИТЬ ПоследниеПриходы
		|ИЗ Приходы
		|СГРУППИРОВАТЬ ПО 
		|	Номенклатура
		|;
		|ВЫБРАТЬ 
		|	Приходы.Номенклатура,
		|	СУММА(Приходы.Сумма) 		КАК Стоимость,
		|	СУММА(Приходы.Количество) 	КАК Количество
		|ИЗ
		|	ПоследниеПриходы
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	Приходы
		|ПО
		|	ПоследниеПриходы.Номенклатура=Приходы.Номенклатура
		|	И ПоследниеПриходы.Период=Приходы.Период
		|СГРУППИРОВАТЬ ПО
		|	Приходы.Номенклатура";
		
		Запрос.УстановитьПараметр("ДатаЧ", ДатаЧ);
		Запрос.УстановитьПараметр("Дата2", Документ.Дата);			
		Запрос.УстановитьПараметр("Номенклатура",СписокПустыхПозиций);
		
		ТР_ПоПустым=Запрос.Выполнить().Выгрузить();
		Для Каждого СтрокаТР_Попустым Из ТР_ПоПустым Цикл
			СтрокаТР=ТР.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТР,СтрокаТР_Попустым);			
		КонецЦикла; 			
	КонецЕсли;
	
	Для Каждого СтрокаТР Из ТР Цикл
		Если СтрокаТР.Количество<>0 Тогда
			СтрокаТР.Стоимость	=1000000*СтрокаТР.Стоимость/СтрокаТР.Количество;
			СтрокаТР.Количество	=1000000;
		КонецЕсли; 
	КонецЦикла;   
	
	
	Возврат ТР;
КонецФункции // ()

Функция ПогаситьРезервы(ТекДок,Товары,Остатки,ТДВР,Получатель,ТО=Неопределено)		
	//Товары.Сортировать("Номенклатура"); //Чирков - а на хрена оно надо ?
	
	Результат=1;
	ВидДокумента=ТекДок.Метаданные().Имя;
	
	Если ВидДокумента="ЗаданиеНабора" Тогда
		Заказ=ТекДок.Накладная;
	Иначе
		Заказ=ТекДок.Ссылка;
	КонецЕсли;
	
	Для Каждого СтрокаТоваров Из Товары Цикл	
		Если СтрокаТоваров.ЭтоУслуга Тогда 			
		Иначе			
			ТекОстатки		=Остатки.НайтиСтроки(Новый Структура("Номенклатура",СтрокаТоваров.Номенклатура));
			
			Если ВидДокумента="Перемещение" Тогда
				НадоСписать 	=СтрокаТоваров.ПодтвержденнаяЗаявка;
			Иначе				
				НадоСписать 	=СтрокаТоваров.Количество;			
			КонецЕсли;			
			
			Остаток			=0; Резерв		=0;
			
			Для Каждого СтрокаОстатка Из ТекОстатки Цикл
				Остаток					=СтрокаОстатка.Остаток;
				Резерв					=СтрокаОстатка.Резерв;
				
				ОперационныйОстаток		=СтрокаОстатка.Остаток	-Макс(СтрокаОстатка.Резерв,0);				
				
				ТекКоличество=Мин(НадоСписать,ОперационныйОстаток);
				
				Если ТекКоличество>0 Тогда					
					СтрокаОстатка.Остаток	=СтрокаОстатка.Остаток	-ТекКоличество;				
					
					Движение 				= ТДВР.Добавить();
					
					Движение.Активность		= Истина;					
					Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
					
					Движение.Период 		= ТекДок.Дата;
					
					Движение.Склад			= СтрокаТоваров.Склад;
					Движение.Номенклатура	= СтрокаТоваров.Номенклатура;					
					Движение.Заказ			= Заказ;
					Движение.Получатель		= Получатель;					
					
					Движение.Количество		= ТекКоличество;
					
					НадоСписать				= НадоСписать-ТекКоличество;					
				КонецЕсли;
			КонецЦикла; 
			
			Если НадоСписать<>0 Тогда
				ЗаписатьВТаблицуОшибок(ТО,ТекДок,"Недостаточно товара",Товары.Индекс(СтрокаТоваров),СтрокаТоваров,Остаток,Резерв);
				
				Результат=-1;
				
				Движение				= ТДВР.Добавить();
				
				Движение.Активность		= Истина;
				Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
				
				Движение.Период 		= ТекДок.Дата;
				
				Движение.Склад			= СтрокаТоваров.Склад;
				Движение.Номенклатура	= СтрокаТоваров.Номенклатура;				
				Движение.Заказ			= Заказ;
				Движение.Получатель		= Получатель;
				
				Движение.Количество		= НадоСписать;				
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции

