Функция ЕстьДвиженияПоЗаказам(ДокОснование)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Количество
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам КАК ЗаказыПоставщикам
	|ГДЕ
	|	Регистратор = &Заказ
	|	И Заказ = &Заказ
	|	И Количество <> 0
	|	И ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)";
	
	Запрос.УстановитьПараметр("Заказ",ДокОснование);
	
	Если Запрос.Выполнить().Выбрать().Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;	
	КонецЕсли; 
КонецФункции // ()

Функция ПолучитьОстаткиЗаявок(Ссылка,ДокОснование)
	ВидДокумента=Ссылка.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	ЗаявкаПоставщику КАК Заказ
	|ПОМЕСТИТЬ Заявки
	|ИЗ Документ."+ВидДокумента+".Товары ГДЕ Ссылка=&Ссылка
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Номенклатура 
	|ПОМЕСТИТЬ СписокНоменклатуры
	|ИЗ Документ."+ВидДокумента+".Товары ГДЕ Ссылка=&Ссылка
	|;	
	|ВЫБРАТЬ
	|	Номенклатура,
	|	Заказ,
	|	КоличествоОстаток	КАК Количество,
	|	СуммаРубОстаток		СуммаРуб,
	|	СуммаUSDОстаток		СуммаUSD,
	|	СуммаEURОстаток		СуммаEUR
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам.Остатки(&МоментВремени,
	|		(Заказ=&ДокОснование ИЛИ Заказ В (ВЫБРАТЬ Заказ ИЗ Заявки))
	|		И Номенклатура В (ВЫБРАТЬ Номенклатура ИЗ СписокНоменклатуры)
	|		) КАК ЗаказыПоставщикамОстатки";
	
	Запрос.УстановитьПараметр("МоментВремени",	Ссылка.МоментВремени());
	Запрос.УстановитьПараметр("Ссылка",			Ссылка);
	Запрос.УстановитьПараметр("ДокОснование",	ДокОснование);		
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ()

Функция СписатьСтарыеЗаказыПоставщикам(Ссылка,Валюты_Курсы) Экспорт
	ТаблицаДвижений=РегистрыНакопления.ЗаказыПоставщикам.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	
	ДокОснование		= Ссылка.ДокОснование;
	СписыватьЗаказы		= ЕстьДвиженияПоЗаказам(ДокОснование);
	//крохин начало 15.02.2011
	//по заказам не проводим только если нет док основания и не заполнены КП
	//Если НЕ СписыватьЗаказы Тогда 
	//	Возврат Новый Структура("ЗаказыПоставщикам",ТаблицаДвижений); 
	//КонецЕсли;
	//крохин конец 15.02.2011
	
	ВалютаДокумета  = Валюты_Курсы.ВалютаДокумента;
	КурсДокумента	= Валюты_Курсы.КурсДокумента;
	//крохин начало
	//заказы поставщикам списываем по складам из основания
	//ФиксированныеРеквизиты=Новый Структура("Период,ВидДвижения,Активность,Склад",Ссылка.Дата,ВидДвиженияНакопления.Расход,Истина,Ссылка.Склад);
	//крохин начало 15.02.2011
	//склад используем из исходного заказа, а не Докоснования. Может быть указан в КП
	//ФиксированныеРеквизиты=Новый Структура("Период,ВидДвижения,Активность,Склад",Ссылка.Дата,ВидДвиженияНакопления.Расход,Истина,ДокОснование.Склад);
	ФиксированныеРеквизиты=Новый Структура("Период,ВидДвижения,Активность",Ссылка.Дата,ВидДвиженияНакопления.Расход,Истина);
	//крохин конец 15.02.2011
	//крохин конец
	
	ОстаткиЗаказов=ПолучитьОстаткиЗаявок(Ссылка,ДокОснование);	
	
	Для Каждого СтрокаТЧ Из Ссылка.Товары Цикл
		//крохин начало 15.02.2011
		//по заказам не проводим только если нет док основания и не заполнены КП
		Если НЕ СписыватьЗаказы И НЕ ЗначениеЗаполнено(СтрокаТЧ.ЗаявкаПоставщику) Тогда
			Продолжить;
		КонецЕсли;
		//строки с нулевым количеством движений не делают
		Если СтрокаТЧ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		//крохин конец 15.02.2011
		
		Движение=ТаблицаДвижений.Добавить();			
		
		ЗаполнитьЗначенияСвойств(Движение,ФиксированныеРеквизиты);
		
		ИсходныйЗаказ			= ?(ЗначениеЗаполнено(СтрокаТЧ.ЗаявкаПоставщику),СтрокаТЧ.ЗаявкаПоставщику,ДокОснование);
		//крохин начало 15.02.2011
		//склад используем из исходного заказа, а не Докоснования. Может быть указан в КП
		//ФиксированныеРеквизиты=Новый Структура("Период,ВидДвижения,Активность,Склад",Ссылка.Дата,ВидДвиженияНакопления.Расход,Истина,ДокОснование.Склад);
		Движение.Склад = ИсходныйЗаказ.Склад;	
		//крохин конец 15.02.2011
		
		СтрокиОстатка			= ОстаткиЗаказов.НайтиСтроки(Новый Структура("Заказ,Номенклатура",ИсходныйЗаказ,СтрокаТЧ.Номенклатура));
		СтрокаОстатка			= Неопределено;
		Если СтрокиОстатка.Количество()>0 Тогда
			Для Каждого СтрокаОстатка Из СтрокиОстатка Цикл
				Если СтрокаОстатка.Количество<>0 Тогда Прервать КонецЕсли;						
			КонецЦикла; 						
		КонецЕсли;
		//крохин начало
		//при нулевых остатках КП используем цену из документа-списания
		//Если СтрокаОстатка<>Неопределено Тогда
		Если СтрокаОстатка<>Неопределено И СтрокаОстатка.Количество <> 0 Тогда
			//крохин конец
			ЦенаРуб=СтрокаОстатка.СуммаРуб/СтрокаОстатка.Количество;
			ЦенаUSD=СтрокаОстатка.СуммаUSD/СтрокаОстатка.Количество;
			ЦенаEUR=СтрокаОстатка.СуммаEUR/СтрокаОстатка.Количество;
		Иначе
			ЦенаРуб=глПересчет(СтрокаТЧ.Всего/СтрокаТЧ.Количество,ВалютаДокумета,КурсДокумента,Валюты_Курсы.ВалютаНац,	1);
			// Кельманов А.В. - HELP-1735 - 2024.12.13 {
			//ЦенаUSD=глПересчет(СтрокаТЧ.Всего/СтрокаТЧ.Количество,ВалютаДокумета,КурсДокумента,Валюты_Курсы.Евро,		Валюты_Курсы.КурсЕвро);
			//ЦенаEUR=глПересчет(СтрокаТЧ.Всего/СтрокаТЧ.Количество,ВалютаДокумета,КурсДокумента,Валюты_Курсы.Доллары,	Валюты_Курсы.КурсДоллара);
			Если Ссылка.Дата  >= '20241201' Тогда
				
				ЦенаUSD = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Доллары, Валюты_Курсы.КурсДоллара);
				ЦенаEUR = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Евро, Валюты_Курсы.КурсЕвро);
				
			Иначе
				
				ЦенаUSD = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Евро, Валюты_Курсы.КурсЕвро);
				ЦенаEUR = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Доллары, Валюты_Курсы.КурсДоллара);
				
			КонецЕсли;
			// Кельманов А.В. - HELP-1735 - 2024.12.13 }
		КонецЕсли;
		
		
		Движение.Номенклатура	= СтрокаТЧ.Номенклатура;
		Движение.Заказ			= ИсходныйЗаказ;
		
		Движение.Количество		= СтрокаТЧ.Количество;				
		Движение.СуммаРуб		= СтрокаТЧ.Количество*ЦенаРуб;
		Движение.СуммаEUR		= СтрокаТЧ.Количество*ЦенаEUR;
		Движение.СуммаUSD		= СтрокаТЧ.Количество*ЦенаUSD;
		
		//крохин начало 04.08.2011
		Если ЕстьРеквизитДокумента("Контракт",Движение.Заказ.Метаданные()) Тогда
			Движение.Контракт =  Движение.Заказ.Контракт;
		КонецЕсли;
		//крохин конец 04.08.2011
		
		Если ЗначениеЗаполнено(Движение.Заказ) Тогда
			Движение.Отправитель	= Движение.Заказ.Контрагент;		
		КонецЕсли; 		
	КонецЦикла;	
	
	Возврат Новый Структура("ЗаказыПоставщикам",ТаблицаДвижений);
КонецФункции
//++Данилова Е.В. 29.07.2025 HELP-6187 
Функция СписатьСтарыеЗаказыПоставщикамПоКомплектующим(Ссылка,Валюты_Курсы,ПоДокОснованию = Истина,СписатьШтуки = истина) Экспорт
	
	ВидДокумента  = Ссылка.Метаданные().Имя;
	
	Если СписатьШтуки Тогда
		
		ТаблицаДвижений = РегистрыНакопления.ЗаказыПоставщикамШтуки.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	Иначе 
		
		ТаблицаДвижений = РегистрыНакопления.ЗаказыПоставщикам.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	КонецЕсли;
	
	
	ДокОснование		= Ссылка.ДокОснование;
	Если ПоДокОснованию Тогда 
		СписыватьЗаказы		= ЕстьДвиженияПоЗаказамШтуки(ДокОснование);
	Иначе
		СписыватьЗаказы = ЛОЖЬ; 
	КонецЕсли;
	
	ВалютаДокумета  = Валюты_Курсы.ВалютаДокумента;
	КурсДокумента	= Валюты_Курсы.КурсДокумента;
	
	ФиксированныеРеквизиты = Новый Структура("Период,ВидДвижения,Активность",Ссылка.Дата,ВидДвиженияНакопления.Расход,Истина);
	
	ОстаткиЗаказов = ПолучитьОстаткиЗаявокПоКомплектующим(Ссылка,ДокОснование,ПоДокОснованию,СписатьШтуки);	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтрактСПроизводителемКомплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(КонтрактСПроизводителемКомплектующие.Количество) КАК Количество,
	|	МАКСИМУМ(КонтрактСПроизводителемКомплектующие.Цена) КАК Цена,
	|	СУММА(КонтрактСПроизводителемКомплектующие.Всего) КАК Всего,
	|	КонтрактСПроизводителемКомплектующие.Коэффициент КАК Коэффициент,
	|	КонтрактСПроизводителемКомплектующие.ЗаявкаПоставщику КАК ЗаявкаПоставщику
	|ИЗ
	|	Документ.%ВидДокумента%.Комплектующие КАК КонтрактСПроизводителемКомплектующие
	|ГДЕ
	|	КонтрактСПроизводителемКомплектующие.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрактСПроизводителемКомплектующие.Номенклатура,
	|	КонтрактСПроизводителемКомплектующие.Коэффициент,
	|	КонтрактСПроизводителемКомплектующие.ЗаявкаПоставщику";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ВидДокумента%",ВидДокумента); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтрокаТЧ = РезультатЗапроса.Выбрать();

	Пока СтрокаТЧ.Следующий() Цикл
		
		Если НЕ СписыватьЗаказы И НЕ ЗначениеЗаполнено(СтрокаТЧ.ЗаявкаПоставщику) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СписатьШтуки
			И НЕ ПоДокОснованию 
			И СтрокаТЧ.ЗаявкаПоставщику = ссылка Тогда //КПНаКомплекты
		
			Продолжить; 	
		
		КонецЕсли;
		
		Если СтрокаТЧ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
				
		Движение = ТаблицаДвижений.Добавить();			
		
		ЗаполнитьЗначенияСвойств(Движение,ФиксированныеРеквизиты);
		
		ИсходныйЗаказ			= ?(ЗначениеЗаполнено(СтрокаТЧ.ЗаявкаПоставщику),СтрокаТЧ.ЗаявкаПоставщику,ДокОснование);
		
		Движение.Склад = ИсходныйЗаказ.Склад;	
		
		СтрокиОстатка			= ОстаткиЗаказов.НайтиСтроки(Новый Структура("Заказ,Номенклатура",ИсходныйЗаказ,СтрокаТЧ.Номенклатура));
		СтрокаОстатка			= Неопределено;
		Если СтрокиОстатка.Количество()>0 Тогда
			Для Каждого СтрокаОстатка Из СтрокиОстатка Цикл
				Если СтрокаОстатка.Количество<>0 Тогда Прервать КонецЕсли;						
			КонецЦикла; 						
		КонецЕсли;
		Если СтрокаОстатка<>Неопределено И СтрокаОстатка.Количество <> 0 Тогда
			ЦенаРуб=СтрокаОстатка.СуммаРуб/СтрокаОстатка.Количество;
			ЦенаUSD=СтрокаОстатка.СуммаUSD/СтрокаОстатка.Количество;
			ЦенаEUR=СтрокаОстатка.СуммаEUR/СтрокаОстатка.Количество;
		Иначе
			ЦенаРуб = глПересчет(СтрокаТЧ.Всего/СтрокаТЧ.Количество,ВалютаДокумета,КурсДокумента,Валюты_Курсы.ВалютаНац,	1);
			
			Если Ссылка.Дата  >= '20241201' Тогда
				
				ЦенаUSD = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Доллары, Валюты_Курсы.КурсДоллара);
				ЦенаEUR = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Евро, Валюты_Курсы.КурсЕвро);
				
			Иначе
				
				ЦенаUSD = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Евро, Валюты_Курсы.КурсЕвро);
				ЦенаEUR = глПересчет(СтрокаТЧ.Всего / СтрокаТЧ.Количество, ВалютаДокумета, КурсДокумента, Валюты_Курсы.Доллары, Валюты_Курсы.КурсДоллара);
				
			КонецЕсли;
			
		КонецЕсли;
		
		
		Движение.Номенклатура	= СтрокаТЧ.Номенклатура;
		Движение.Заказ			= ИсходныйЗаказ;
		
		Движение.Количество		= СтрокаТЧ.Количество;				
		Движение.СуммаРуб		= СтрокаТЧ.Количество*ЦенаРуб;
		Движение.СуммаEUR		= СтрокаТЧ.Количество*ЦенаEUR;
		Движение.СуммаUSD		= СтрокаТЧ.Количество*ЦенаUSD;
		
		
		Если ЕстьРеквизитДокумента("Контракт",Движение.Заказ.Метаданные()) Тогда
			Движение.Контракт =  Движение.Заказ.Контракт;
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Движение.Заказ) Тогда
			Движение.Отправитель	= Движение.Заказ.Контрагент;		
		КонецЕсли; 		
	КонецЦикла;	
	Если СписатьШтуки Тогда 
		Возврат Новый Структура("ЗаказыПоставщикамШтуки",ТаблицаДвижений);
	Иначе
		Возврат Новый Структура("ЗаказыПоставщикам",ТаблицаДвижений);
	КонецЕсли;
КонецФункции

Функция ПолучитьОстаткиЗаявокПоКомплектующим(Ссылка,ДокОснование,ПоДокОснованию,СписатьШтуки)
	ВидДокумента  = Ссылка.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	ЗаявкаПоставщику КАК Заказ
	|ПОМЕСТИТЬ Заявки
	|ИЗ Документ."+ВидДокумента+".Комплектующие ГДЕ Ссылка=&Ссылка
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Номенклатура 
	|ПОМЕСТИТЬ СписокНоменклатуры
	|ИЗ Документ."+ВидДокумента+".Комплектующие ГДЕ Ссылка=&Ссылка
	|;	
	
	|ВЫБРАТЬ
	|	ЗаказыПоставщикамОстатки.Номенклатура КАК Номенклатура,
	|	ЗаказыПоставщикамОстатки.Заказ КАК Заказ,
	|	ЗаказыПоставщикамОстатки.КоличествоОстаток КАК Количество,
	|	ЗаказыПоставщикамОстатки.СуммаРубОстаток КАК СуммаРуб,
	|	ЗаказыПоставщикамОстатки.СуммаUSDОстаток КАК СуммаUSD,
	|	ЗаказыПоставщикамОстатки.СуммаEURОстаток КАК СуммаEUR
	|ИЗ
	|	РегистрНакопления.%ЗаказыПоставщикамШтуки%.Остатки(
	|			&МоментВремени,
	|			ВЫБОР
	|					КОГДА &ПоДокоснованию
	|						ТОГДА Заказ = &ДокОснование
	|								ИЛИ Заказ В
	|									(ВЫБРАТЬ
	|										Заявки.Заказ
	|									ИЗ
	|										Заявки КАК Заявки)
	|					ИНАЧЕ Заказ В
	|							(ВЫБРАТЬ
	|								Заявки.Заказ
	|							ИЗ
	|								Заявки КАК Заявки)
	|				КОНЕЦ
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						СписокНоменклатуры.Номенклатура
	|					ИЗ
	|						СписокНоменклатуры КАК СписокНоменклатуры)) КАК ЗаказыПоставщикамОстатки";
	
	Запрос.УстановитьПараметр("МоментВремени",	Ссылка.МоментВремени());
	Запрос.УстановитьПараметр("Ссылка",			Ссылка);
	Запрос.УстановитьПараметр("ДокОснование",	ДокОснование);
	
	Запрос.УстановитьПараметр("ПоДокоснованию",	ПоДокОснованию); 
	Если СписатьШтуки Тогда 	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ЗаказыПоставщикамШтуки%","ЗаказыПоставщикамШтуки"); 
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ЗаказыПоставщикамШтуки%","ЗаказыПоставщикам");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // () 

Функция ЕстьДвиженияПоЗаказамШтуки(ДокОснование)
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ЗаказыПоставщикам.Количество КАК Количество
	             |ИЗ
	             |	РегистрНакопления.ЗаказыПоставщикамШтуки КАК ЗаказыПоставщикам
	             |ГДЕ
	             |	ЗаказыПоставщикам.Регистратор = &Заказ
	             |	И ЗаказыПоставщикам.Заказ = &Заказ
	             |	И ЗаказыПоставщикам.Количество <> 0
	             |	И ЗаказыПоставщикам.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)";
	
	Запрос.УстановитьПараметр("Заказ",ДокОснование);
	
	Если Запрос.Выполнить().Выбрать().Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;	
	КонецЕсли; 
КонецФункции

