Функция ПолучитьЦенуПрихода(Номенклатура,Склад,Дата,Инвентаризация=Ложь)	Экспорт
	Цена		= Неопределено;
	ВалютаУпр	= ?(Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);			
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Дата);
	
	//крохин начало 10.05.2011
	//у не товара используем ЦПП
	Если Инвентаризация И Дата >= '20110401' И Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
		Цена=ПолучитьПериодическийРеквизит(Номенклатура,"ЦенаПоследнегоПрихода",Дата);
		Если ЗначениеНеЗаполнено(Цена) Тогда
			Возврат 0;
		Иначе 
			Возврат Цена;
		КонецЕсли;
	КонецЕсли;
	//крохин конец 10.05.2011
	
	Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Сумма/Количество Как Цена,Период
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ
		|ГДЕ
		|	Период<=&Дата2
		|	И Номенклатура = &Номенклатура И Склад=&Склад
		|	И ВидДвижения = &Приход
		|	И Сумма <> 0 И Количество <> 0
		|УПОРЯДОЧИТЬ ПО Период УБЫВ";
		
		Запрос.УстановитьПараметр("Номенклатура",Номенклатура);	
		Запрос.УстановитьПараметр("Склад",Склад);
		Запрос.УстановитьПараметр("Приход",ВидДвиженияНакопления.Приход);
		Запрос.УстановитьПараметр("Дата2",Дата);		
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Дата>='20090101' И Выборка.Период<'20090101' Тогда
				Возврат глПересчет(Выборка.Цена,ПараметрыСеанса.ВалютаУпр,Выборка.Период,ВалютаУпр,КурсУпр);
			Иначе
				Возврат Выборка.Цена;			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;	
	
	Если Инвентаризация Тогда
		Цена=ПолучитьПериодическийРеквизит(Номенклатура,"ЦенаПоследнегоПрихода",Дата);
		Если ЗначениеНеЗаполнено(Цена) И НЕ Константы.РозничныйТипЦен.Получить().Пустая() Тогда		
			//ПолучитьЦенуНоменклатуры(Номенклатура,Единица=Неопределено,ТипЦен,ВалютаДокумента,КурсДокумента,ДатаРасчета=Неопределено) Экспорт
			
			Цена	= ПолучитьЦенуНоменклатуры(Номенклатура,,Константы.РозничныйТипЦен.Получить(),ВалютаУпр,КурсУпр,Дата);	
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Цена;
КонецФункции //ПолучитьЦенуПрихода()

Функция ПолучитьЦенуПоследнегоПрихода(Номенклатура,Склад,Период)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СУММА(Количество)	КАК Количество,
	|	СУММА(Сумма)		КАК Сумма,
	|	Регистратор.Дата	КАК Дата,
	|	Регистратор.Курс	КАК Курс
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|ГДЕ	
	|	ОстаткиТМЦ.Номенклатура = &Номенклатура
	|	И КодОперации В (&КодыОпераций)
	|	И Период		<=&Период	
	|	И Количество	> 0
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиТМЦ.Регистратор
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор.Дата УБЫВ"
	;
	
	КодыОпераций=Новый СписокЗначений;
	КодыОпераций.Добавить(Перечисления.КодыОперацийОстатки.Закупка);	
	
	Запрос.УстановитьПараметр("КодыОпераций",КодыОпераций);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Период",Период);
	
	ДатаЧ='20090101';
	
	Цена=0;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда		
		Цена=Окр(Выборка.Сумма/Выборка.Количество,2,1);				
		Если Период>=ДатаЧ И Выборка.Дата<ДатаЧ Тогда				
			Цена=Окр((Выборка.Сумма/Выборка.Курс)/Выборка.Количество,2,1);			
		КонецЕсли;
	КонецЕсли;
	
	Возврат Цена;
КонецФункции // ПолучитьЦенуПоследнегоПрихода()

