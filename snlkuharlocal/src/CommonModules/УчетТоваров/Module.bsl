					ТДКомплектующие.Колонки.Добавить("Оборот",				ПолучитьОписаниеТиповЧисла(19,2));	
					ТДКомплектующие.Колонки.Добавить("ОборотБезСкидки",		ПолучитьОписаниеТиповЧисла(19,2));	
					ТДКомплектующие.Колонки.Добавить("ОборотУпр",			ПолучитьОписаниеТиповЧисла(19,2));	
					ТДКомплектующие.Колонки.Добавить("ОборотБезСкидкиУпр",	ПолучитьОписаниеТиповЧисла(19,2));	
					ТДКомплектующие.Колонки.Добавить("ВалютаДокумента",		ПолучитьОписаниеТиповЧисла(19,2));	
					ТДКомплектующие.Колонки.Добавить("Амортизация",			ПолучитьОписаниеТиповЧисла(19,2));				
					Если ТДКомплектующие.Колонки.Найти("ДК")=Неопределено Тогда
						ТДКомплектующие.Колонки.Добавить("ДК");		
