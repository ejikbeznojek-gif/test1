		КонецЕсли;
		//крохин конец 10.12.2020
		/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// Если в ПНК не заполнена ТЧ "рекламации", то проводки делает ПНК. Если заполнена ТЧ "документ клиента", то по данным ТЧ
		// "документ клиента", если не заполнена, то по данным ТЧ "товары". Проводки в ПНК делаются только в состоянии "принята складом".
		/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		
		//Валетов + 20.03.24 Добавления движения По ОстаткамТМЦ как в ПРМ чтоб не создавать дополнительный документ 
		//Проверяются: СкладПолучатель=ПодразделениеФранчайзинга,определенные статусы РНК, дата внедрения, Количество в ТЧ
		//+HELP-1937 20241217 Михайловский , 20250122 Крохин, другая дата , HELP-2633
		//УслРКМ = ?(ТекДок.Дата >= Дата('20241201'), Истина, ?(ТекДок.Рекламации.Количество() = 0, Истина, Ложь));
		УслРКМ = ?(ТекДок.Дата >= Дата('20250101'), Истина, ?(ТекДок.Рекламации.Количество() = 0, Истина, Ложь));
		//-HELP-1937 20241217 Михайловский
		Если ТекДок.СостояниеНакладной = Перечисления.СостоянияНакладной.Принята
			//+HELP-1937 20241217 Михайловский
			//вместо
			//И ТекДок.Рекламации.Количество() = 0
			И УслРКМ
			//-HELP-1937 20241217 Михайловский
			
			И ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение 
			// Кухарь А.Ю.  11.09.2024 начало
			И ТекДок.дата>='20240901'
			// Кухарь А.Ю.  11.09.2024 конец
			
			Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РеквизитыСправочников.ЗначениеРеквизита КАК Подразделение,
			|	РеквизитыСправочников.ЗначениеРеквизита.ОсновнойСклад КАК ОсновнойСклад
			|ИЗ
			|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
			|ГДЕ
			|	РеквизитыСправочников.ИмяРеквизита = ""ПодразделениеФранчайзинга""
			|	И РеквизитыСправочников.Справочник = &ПунктДоставки";			 
			
			Запрос.УстановитьПараметр("ПунктДоставки", ТекДок.ПунктДоставки);
			
