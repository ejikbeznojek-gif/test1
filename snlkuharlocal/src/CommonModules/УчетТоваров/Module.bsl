Функция ПолучитьНоменклатуруДокумента(Ссылка, ИмяТЧ = Неопределено)
	
	ИмяТоварнойТЧ = ?(ЗначениеЗаполнено(ИмяТЧ), ИмяТЧ, ПолучитьИмяТоварнойТЧ(Ссылка));
	
	Запрос=Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура
	|ИЗ
	|	Документ." + Ссылка.Метаданные().Имя + "." + ИмяТоварнойТЧ + "
	|ГДЕ
	|	Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	МН = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МН.Добавить(Выборка.Номенклатура);
	КонецЦикла; 
	
	Возврат МН;
	
КонецФункции //ПолучитьНоменклатуруДокумента()

Функция ПолучитьВиртуальныеСклады(ФизическийСклад)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.ФизическийСклад = &ФизическийСклад";
	
	МассивСкладов=Новый Массив;
	Запрос.УстановитьПараметр("ФизическийСклад",ФизическийСклад);
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		//Кухарь 13.05.16 начало
		//Уберём виртуальные для склада
		если выборка.склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада тогда Продолжить; КонецЕсли;			
		//Кухарь 13.05.16 конец
		МассивСкладов.Добавить(Выборка.Склад);			
	КонецЦикла; 
	
	Возврат МассивСкладов;
КонецФункции //ПолучитьВиртуальныеСклады() 

//крохин начало
//добавил слово "Экспорт" в "ПолучитьОстаткиТМЦ"
