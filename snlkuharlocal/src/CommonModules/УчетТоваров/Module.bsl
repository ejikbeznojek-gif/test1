						ДопЗаписьОстатковТМЦ.ВидДвижения		= ВидДвиженияНакопления.Расход;
						// - HELP-1937 20241106 Михайловский
						ДопЗаписьОстатковТМЦ.Активность		= Истина;
						ДопЗаписьОстатковТМЦ.КодОперации 		= Перечисления.КодыОперацийОстатки.Перемещение;
						ДопЗаписьОстатковТМЦ.Период 		= ТекДок.Дата;
						ДопЗаписьОстатковТМЦ.Номенклатура 		= ТекСтрокаТовары.Номенклатура;
						ДопЗаписьОстатковТМЦ.Склад 			= ОсновнойСклад;
						ДопЗаписьОстатковТМЦ.Количество     	= ТекСтрокаТовары.Количество;
						ДопЗаписьОстатковТМЦ.Отправитель		= ТекДок.Склад;
						ДопЗаписьОстатковТМЦ.Сумма			= 0;
						
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;

		Результат	=Мин(Результат,ТекРезультат);	
	ИначеЕсли ТекВид="ОтчетКомиссионера" Тогда
		
		ТД.Колонки.Добавить("ВсегоБезСкидки");	
		Для Каждого СтрокаТД Из ТД Цикл
			СтрокаТД.ВсегоБезСкидки = СтрокаТД.Всего;
			СтрокаТД.Подразделение = ТекДок.Подразделение;
		КонецЦикла;
		ТД.Свернуть("ВалютаДокумента,ВидНоменклатуры,ДК,Подразделение,КодОперации,Номенклатура,Подразделение,Склад,Ссылка,СтавкаНДС,ЭтоУслуга,Цена",
		"АгентскоеВознаграждение,Амортизация,Всего,ВсегоБезСкидки,ВсегоПередачи,Количество,КомиссионныеРасходы,НДС,НДСОплата,Оборот,ОборотБезСкидки,ОборотБезСкидкиУпр,ОборотУпр,Оплата,ПлатноеХранение,ПрочиеРасходы,СкладскаяОбработка,СписанаСтоимость,Сумма,ТранспортныеРасходы");
		
		
		РассчитатьОбороты(ТД,Рубли,КурсРубля,Рубли,КурсРубля,ВалютаУпр,КурсУпр);
		КодОперации = Перечисления.КодыОперацийОстатки.Реализация;
		ТО=ПолучитьОстаткиТМЦ(ТекДок,Загрузка);
		Результат=ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Контрагент,ТекДок.ПунктДоставки,ТОшибок);
	ИначеЕсли ТекВид="Претензия" Тогда    	

		Для Каждого СтрокаТЧ ИЗ ТД Цикл
			СтрокаТЧ.Количество = - СтрокаТЧ.Количество;
			СтрокаТЧ.Сумма = - СтрокаТЧ.Сумма;
		КонецЦикла;

		КодОперации = Перечисления.КодыОперацийОстатки.Комиссия;
		
		ТД.ЗаполнитьЗначения(ТекДок.ДОкОснование.СкладКомиссия,"Склад");
		ТО=ПолучитьОстаткиТМЦ(ТекДок,Загрузка,ТекДок.ДОкОснование.СкладКомиссия);
		Результат=ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Контрагент,ТекДок.ДокОснование.ПунктДоставки,ТОшибок);
		
	ИначеЕсли ТекВид="РасходнаяНакладная" Тогда				
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение ИЛИ ТекДок.Склад.КодФизическогоУзла=ЭтотУзел.Код Тогда
			ТД.ЗаполнитьЗначения(ТекДок.Подразделение,"Подразделение");
			//по услугам ИМ движений не делаем
			СписокУдаляемыхСтрок = Новый СписокЗначений;
			Для Каждого СтрокаТД Из ТД Цикл
				Если СтрокаТД.ВидНоменклатуры =  Перечисления.ВидыНоменклаутры.Услуга Тогда //Чирков
					СписокУдаляемыхСтрок.Добавить(СтрокаТД);
				КонецЕсли;
				//по упаковке тоже не делаем движений
				Если СтрокаТД.ВидНоменклатуры =  Перечисления.ВидыНоменклаутры.Упаковка Тогда //Чирков
					СписокУдаляемыхСтрок.Добавить(СтрокаТД);
				КонецЕсли;
			КонецЦикла;
			
