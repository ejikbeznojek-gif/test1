			Если ТекДок.Отгружен=Перечисления.Отгружен.ОтгруженТранзит Тогда
				КодОперации=Перечисления.КодыОперацийОстатки.Перемещение;						
			Иначе			
				КодОперации=?(ТекДок.КодОперации.Пустая(),Перечисления.КодыОперацийОстатки.Реализация,ТекДок.КодОперации);						
			КонецЕсли;

			//в РНК-подарках код операции - списание
			Если ТекДок.Отгружен=Перечисления.Отгружен.Отгружен И ТекДок.Подарок Тогда
				КодОперации = Перечисления.КодыОперацийОстатки.Списание;	
