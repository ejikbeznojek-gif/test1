	ИначеЕсли ТекВид = "ЗаявкаНаПерепаковку" Тогда
		ТипУзла=ПараметрыСеанса.ЭтотУзел.ТипУзла; 
		Если ТипУзла=ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			Склад = ТекДок.Склад;
		Иначе
			Если ТекДок.Склад.ВидСклада=Перечисления.ВидСклада.Виртуальный тогда
				Склад = ТекДок.Склад.ФизическийСклад;
			Иначе
				Склад = ТекДок.Склад;
			КонецЕсли;
		КонецЕсли;
		
		Если ТекДок.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.ВРаботе
			ИЛИ ТекДок.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.КОтправкеНаСклад Тогда
			ТО			= ПолучитьОстаткиТМЦ(ТекДок, Загрузка, ,, "Комплектующие");			 
			Результат	= ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Склад,,ТОшибок,Истина);
			
			Если ТекДок.Комплектующие.Количество() > 0 И ТОшибок = Неопределено Тогда
				ТДВР.Очистить();
				Для Каждого ТекСтрока Из ТекДок.Комплектующие Цикл
					Если ТекСтрока.Количество > 0 Тогда
						НоваяСтрока = ТДВР.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
						НоваяСтрока.Активность = Истина;
						НоваяСтрока.Период = ТекДок.Дата;
						НоваяСтрока.Регистратор = ТекДок.Ссылка;
						НоваяСтрока.Заказ = ТекДок.Ссылка;
						НоваяСтрока.Склад = Склад;
						НоваяСтрока.Получатель = Склад;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		ИначеЕсли ТекДок.Статус = Перечисления.СтатусыЗаявокНаПерепаковку.Закрыта Тогда
			ТО			= ПолучитьОстаткиТМЦ(ТекДок, Загрузка, ,, "Товары");		 
			Результат	= ПогаситьПартии(ТекДок,КодОперации,ТД,ТО,ТДВО,ТекДок.Склад,,ТОшибок,Истина);
			
			Если ТекДок.Товары.Количество() > 0 И ТОшибок = Неопределено Тогда
				ТДВР.Очистить();
				Для Каждого ТекСтрока Из ТекДок.Товары Цикл
					Если ТекСтрока.Количество > 0 Тогда
						НоваяСтрока = ТДВР.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
						НоваяСтрока.Активность = Истина;
						НоваяСтрока.Период = ТекДок.Дата;
						НоваяСтрока.Регистратор = ТекДок.Ссылка;
						НоваяСтрока.Заказ = ТекДок.Ссылка;
						НоваяСтрока.Получатель = Склад;
						НоваяСтрока.Склад = Склад;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		Иначе
			ТДВР.Очистить();
		КонецЕсли;
	КонецЕсли;  
	
	ТаблицаСписания	= ТД;
	
	Запрос=Новый Запрос;
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	Период,Активность,ВидДвижения,Склад,Номенклатура,Амортизация 
	|ПОМЕСТИТЬ ТДВА 
	|ИЗ 	
	|	&ТДВО КАК ТДВО
	|;
	|ВЫБРАТЬ Период,Активность,ВидДвижения,Склад,Номенклатура КАК ОС,СУММА(Амортизация) КАК Амортизация
	|ИЗ ТДВА 
	|ГДЕ Амортизация<>0
	|СГРУППИРОВАТЬ ПО Период,Активность,ВидДвижения,Склад,Номенклатура";
	
	Запрос.УстановитьПараметр("ТДВО",ТДВО);
	
	ТДВА=Запрос.Выполнить().Выгрузить();
	
	ТДВЗ=СоздатьТаблицуДвижений("Затраты");
	
	Если ТДВА.Количество()>0 И (КодОперации=Перечисления.КодыОперацийОстатки.Реализация ИЛИ КодОперации=Перечисления.КодыОперацийОстатки.Списание) Тогда				
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Склад.Подразделение 		КАК Подразделение,
		|	Номенклатура 				КАК ОС,
		|	СостояниеОС.СтатьяЗатрат 	КАК СтатьяЗатрат,
		|	СУММА(Амортизация) 			КАК СуммаУпр
		|ИЗ ТДВА 		
		|ЛЕВОЕ СОЕДИНЕНИЕ		
		|	РегистрСведений.СостояниеОС.СрезПоследних(&Дата2,ОС В (Выбрать Различные Номенклатура ИЗ ТДВА)) КАК СостояниеОС
		|ПО 
		|	ТДВА.Номенклатура=СостояниеОС.ОС
		|ГДЕ 
		|	Амортизация<>0
		|СГРУППИРОВАТЬ ПО
		|	Склад.Подразделение,
		|	Номенклатура,
		|	СостояниеОС.СтатьяЗатрат";		
		
		Если КодОперации=Перечисления.КодыОперацийОстатки.Списание Тогда
			ФиксированныеРеквизиты=Новый Структура("Период,Активность,ВидДвижения,Контрагент,ВалютаДокумента,ДатаЗаписи",ДатаДокумента,Истина,ВидДвиженияНакопления.Расход,ТекДок.Склад,ПараметрыСеанса.ВалютаНац,ТекущаяДата());		
		Иначе
			ФиксированныеРеквизиты=Новый Структура("Период,Активность,ВидДвижения,Контрагент,Договор,ВалютаДокумента,ДатаЗаписи",ДатаДокумента,Истина,ВидДвиженияНакопления.Расход,ТекДок.Контрагент,ТекДок.Договор,ПараметрыСеанса.ВалютаНац,ТекущаяДата());			
		КонецЕсли;		
		
		Запрос.УстановитьПараметр("Дата2",ТекДок.Дата);
		РезультатЗапроса=Запрос.Выполнить();
		Выборка			=РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Движение=ТДВЗ.Добавить();
			
			Если 1=2 Тогда
				Движение=РегистрыНакопления.Затраты.СоздатьНаборЗаписей().Добавить();			
			КонецЕсли; 
			
			ЗаполнитьЗначенияСвойств(Движение,ФиксированныеРеквизиты);
			ЗаполнитьЗначенияСвойств(Движение,Выборка,"Подразделение,СтатьяЗатрат,СуммаУпр");			
		КонецЦикла; 
		
		ПА=РезультатЗапроса.Выгрузить();
		
		ФиксированныеРеквизиты.Вставить("ВидДвижения",ВидДвиженияНакопления.Приход);
		ФР_Остатки=Новый Структура("КодОперации,Оборот,ОборотБезСкидки,ОборотУпр,ОборотБезСкидкиУпр",Перечисления.КодыОперацийОстатки.Списание,0,0,0,0);
		
		Если КодОперации=Перечисления.КодыОперацийОстатки.Реализация Тогда			
			ТДВО_Доп=ТДВО.СкопироватьКолонки();
			Для Каждого СтрокаТД Из ТДВО Цикл
				Если СтрокаТД.Амортизация<>0 Тогда
					СтрокаДоп=ТДВО_Доп.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаДоп,СтрокаТД);
					
					СтрокаТД.Сумма		=СтрокаТД.Сумма-СтрокаТД.Амортизация;				
					СтрокаДоп.Сумма		=СтрокаТД.Амортизация;
					СтрокаДоп.Количество=0;
					
					СтрокаТД.Амортизация=0;
					
					ЗаполнитьЗначенияСвойств(СтрокаДоп,ФР_Остатки);				
					
					Движение=ТДВЗ.Добавить();			
					ЗаполнитьЗначенияСвойств(Движение,ФиксированныеРеквизиты);				
					Движение.СуммаУпр				=СтрокаДоп.Сумма;
					
					СтрокаПА=ПА.Найти(СтрокаТД.Номенклатура,Номенклатура);
					Если СтрокаПА<>Неопределено Тогда					
						ЗаполнитьЗначенияСвойств(Движение,СтрокаПА,"Подразделение,СтатьяЗатрат");			
					КонецЕсли; 
				КонецЕсли; 		
			КонецЦикла;
			
			Для Каждого СтрокаДоп Из ТДВО_Доп Цикл
				СтрокаТД=ТДВО.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТД,СтрокаДоп);
			КонецЦикла; 
		КонецЕсли;
	КонецЕсли; 
	//крохин начало
	//вместо пустого склада движения по остаткам ТМЦ проводим по складу "Пустой Склад", чтобы не вешать олап
	Для Каждого СтрокаТДВО ИЗ ТДВО Цикл
		Если СтрокаТДВО.Склад = Неопределено ИЛи СтрокаТДВО.Склад = Справочники.Склады.ПустаяСсылка() Тогда
			СтрокаТДВО.Склад = Справочники.Склады.НайтиПоКоду("SSR-64");	
		КонецЕсли;
	КонецЦикла;
	//крохин конец
	
	Движения		=Новый Структура("ОстаткиТМЦ,РезервыТМЦ,Амортизация,Затраты",ТДВО,ТДВР,ТДВА,ТДВЗ);
	
	Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
КонецФункции

//крохин начало 08.10.2020
Функция ПроведениеПоРегистрамЗаказыКонтрагентов(ДокументСсылка,Движения,Загрузка=Ложь) Экспорт	
	РезультатПроведения	=ПровестиПоЗаказамКонтрагентов(ДокументСсылка,Движения,Загрузка);	
	Возврат РезультатПроведения;		
КонецФункции

Функция  ПровестиПоЗаказамКонтрагентов(Документ,Движения,Загрузка=Ложь) Экспорт
	Если ПараметрыСеанса.Отладка Тогда
		Сообщить("Проведение: "+Документ);
	КонецЕсли;
	
	ЭтотУзел=ПараметрыСеанса.ЭтотУзел;
	
	Результат	=1;
	ТОшибок		=Неопределено;	
	ТДВЗК=СоздатьТаблицуДвижений("ЗаказыКонтрагентов");
	
	
	ТекВид			= Документ.Метаданные().Имя;	
	ТекДок			= Документ;
	
	ДатаДокумента	= ПолучитьРеквизитыШапки(ТекДок,Новый Структура("Дата")).Дата;	
	
	#Если Клиент Тогда
		Состояние(""+ТекВид+" "+ТекДок.Номер+" "+ДатаДокумента);
	#КонецЕсли
	
	ВалютаУпр	= ?(ДатаДокумента>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);	
	КурсУпр		= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,Документ.Дата);
	
	Рубли		= ПараметрыСеанса.ВалютаНац;	
	КурсРубля	= ПолучитьКурсВалюты_ПоРусски(Рубли,ДатаДокумента);
	
	ТС=Новый ТаблицаЗначений;
	ТС.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));	
	
	ИмяТЧ = ПолучитьИмяТоварнойТЧ(Документ);	
	
	ТД=ПолучитьТЧДокумента(Документ,ТекВид,ИмяТЧ);
	
	
	Для Каждого СтрокаТД Из ТД Цикл
		Если СтрокаТД.Количество = 0 И СтрокаТД.Всего = 0 Тогда Продолжить; КонецЕсли;
		СтрокаТДВЗК = ТДВЗК.Добавить();
		СтрокаТДВЗК.Контрагент = ТекДок.Контрагент;
		СтрокаТДВЗК.Номенклатура = СтрокаТД.Номенклатура;
		
		СтрокаТДВЗК.Количество = СтрокаТД.Количество;
		СтрокаТДВЗК.Сумма = СтрокаТД.Всего;
		СтрокаТДВЗК.Период = ДатаДокумента;
		Если ТекВид = "Заказ" Тогда
			СтрокаТДВЗК.ВидДвижения = ВидДвиженияНакопления.Приход;
			СтрокаТДВЗК.Заказ = ТекДок;
		Иначе
			СтрокаТДВЗК.ВидДвижения = ВидДвиженияНакопления.Расход;
			СтрокаТДВЗК.Заказ = ТекДок.ДокОснование;
		КонецЕсли; 
		СтрокаТДВЗК.Активность = Истина;
	КонецЦикла;
	
	Движения		=Новый Структура("ЗаказыКонтрагентов",ТДВЗК);
	
	Возврат Новый Структура("Результат,ТОшибок",Результат,ТОшибок);
	
	
КонецФункции

