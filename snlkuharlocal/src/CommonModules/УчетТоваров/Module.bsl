// *** РНК+КМПЛ
// Функция ПолучитьОстаткиТМЦ(Конт,Загрузка,Склад=Неопределено,Период=Неопределено) Экспорт
// ---------- заменено на:
Функция ПолучитьОстаткиТМЦ(Конт,Загрузка,Склад=Неопределено,Период=Неопределено,ИмяТЧ=Неопределено) Экспорт
	// РНК+КМПЛ ***
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	Если Загрузка ИЛИ (ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения = Перечисления.ВидыПодразделений.Франчайзинг И (КОНТ.Метаданные().Имя = "Перемещение" И Конт.СкладПолучатель.КодФизическогоУзла = ПараметрыСеанса.ЭтотУзел.Подразделение.КодФизическогоУзла77)) ИЛИ (ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.Склад И (КОНТ.Метаданные().Имя = "Перемещение" ИЛИ КОНТ.Метаданные().Имя = "РасходнаяНакладная") И Конт.СостояниеНакладной = Перечисления.СостоянияНакладной.ПроверенаПоОстаткам) Тогда
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	&СкладДокумента				КАК Склад,
		|	Номенклатура,
		|	СУММА(Количество)			КАК Остаток,
		|	СУММА(Всего)				КАК Стоимость,	
		|	СУММА(0)					КАК Амортизация,	
		|	СУММА(0)					КАК Резерв		
		|ИЗ
		|	Документ."+ВидДокумента+".Товары ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО 
		|	Ссылка.Склад,
		|	Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Ссылка.Склад.Код";
	Иначе		
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	Склад,
		|	Номенклатура,
		|	СУММА(Остаток)				КАК Остаток,
		|	СУММА(Стоимость)			КАК Стоимость,	
		|	СУММА(Амортизация)			КАК Амортизация,
		|	СУММА(Резерв)				КАК Резерв		
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	Склад,
		|	Номенклатура,	
		|	КоличествоОстаток	Как Остаток,	
		|	СуммаОстаток 		Как Стоимость,			
		|	0					Как Амортизация,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&МоментВремени,
		|	Склад В (&Склады)
		|	И Номенклатура В  (&МассивНоменклатуры)
		|)	
		|КАК ОстаткиОпер
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.ОстаткиТМЦ.Остатки	
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ
		|	Склад,
		|	ОС,	
		|	0					Как Остаток,	
		|	0			 		Как Стоимость,			
		|	АмортизацияОстаток	Как Амортизация,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.Амортизация.Остатки(&МоментВремени,Склад В (&Склады) И ОС В (&МассивНоменклатуры))	
		|КАК ОстаткиАморт
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.Амортизация.Остатки";
		
		КонтрольРезервов=Истина;
		Если ПараметрыСеанса.ОтключитьКонтрольРезервов ИЛИ ВидДокумента="СписаниеТМЦ" Тогда			
			КонтрольРезервов=Ложь;
		КонецЕсли; 
		
		Если КонтрольРезервов Тогда
			ТекстЗапроса=ТекстЗапроса+"
			|ОБЪЕДИНИТЬ ВСЕ
			|ВЫБРАТЬ
			|	Склад,
			|	Номенклатура,	
			|	0 				Как Остаток,	
			|	0				Как Стоимость,			
			|	0				Как Амортизация,
			|	КоличествоОстаток Как Резерв			
			|ИЗ
			|	РегистрНакопления.РезервыТМЦ.Остатки(&МоментВремени,
			|	Склад В (&Склады)
			|	И Номенклатура В (&МассивНоменклатуры))	
			|КАК РезервыОпер
			|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.РезервыТМЦ.Остатки";
		КонецЕсли;
		
		ТекстЗапроса=ТекстЗапроса+"
		|) КАК ОбщийЗапрос
		|СГРУППИРОВАТЬ ПО Склад,Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Склад.Код";
	КонецЕсли;	
	
	Запрос.Текст=ТекстЗапроса;	
	
	Запрос.УстановитьПараметр("Ссылка",				Конт.Ссылка);
	// *** РНК+КМПЛ
	Запрос.УстановитьПараметр("МассивНоменклатуры",	ПолучитьНоменклатуруДокумента(Конт.Ссылка, ИмяТЧ));
	// РНК+КМПЛ ***
	
	ТекСкладДокумента=Конт.Склад;
	если ТекСкладДокумента.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
		ТекСкладДокумента=ТекСкладДокумента.ФизическийСклад;
		НеиспользоватьСкладДокумента=Истина;
	иначе
		НеиспользоватьСкладДокумента=Ложь;
	КонецЕсли;
	
	Склады=Новый Массив;
	Если Склад=Неопределено Тогда		
		Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
			Если Конт.Склад.ФизическийСклад.Пустая() Тогда
				Склады.Добавить(Конт.Склад);						
			Иначе
				если Конт.Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.Склад тогда 	
					Склады.Добавить(Конт.Склад);
					ТекСкладДокумента=Конт.Склад;
				иначе
					Склады.Добавить(Конт.Склад.ФизическийСклад);
					ТекСкладДокумента=Конт.Склад.ФизическийСклад;
				КонецЕсли;
			КонецЕсли;	
		Иначе   
			если НеиспользоватьСкладДокумента тогда
				Склады.Добавить(ТекСкладДокумента);
			иначе
				Склады.Добавить(Конт.Склад);
			КонецЕсли;
			// Кухарь А.Ю. 12.02.2024 конец
			
			//все-таки проще исправлять потом, чем списывать по разным складам. С 1 сентября 2009 
			//Если ВидДокумента="СписаниеТМЦ" Тогда
			Если ВидДокумента="СписаниеТМЦ" И Конт.Дата < '20090901' Тогда
				ВиртуальныеСклады=ПолучитьВиртуальныеСклады(Конт.Склад);					
				Для Каждого ВиртСклад Из ВиртуальныеСклады Цикл
					Склады.Добавить(ВиртСклад);			
				КонецЦикла; 
			КонецЕсли; 
		КонецЕсли;		
	Иначе
		Склады.Добавить(Склад);
	КонецЕсли;	
	
	
	//Мессерле 23,01,2012
	Если  ТипЗнч(Конт)=Тип("ДокументСсылка.ЗаказПоставщику") и ЗначениеЗаполнено(Конт.транзитныйСклад)  тогда  //Мессерле 05.04.12 и Загрузка
		ТекСкладДокумента=Конт.ТранзитныйСклад;
	Конецесли;	
	
	Запрос.УстановитьПараметр("СкладДокумента",ТекСкладДокумента);
	Запрос.УстановитьПараметр("Склады",Склады);
	Если Период=Неопределено Тогда
		Запрос.УстановитьПараметр("МоментВремени",новый граница(Конт.МоментВремени(),видграницы.Исключая));	
	Иначе
		Запрос.УстановитьПараметр("МоментВремени",Период);
	КонецЕсли;	
	
	Результат	=Запрос.Выполнить();
	
	ТО=Результат.Выгрузить();	

	Если ВидДокумента="ОтчетКомиссионера" тогда		
		ВозвратыКомиссия=ПолучитьВозвратыКомиссииТекущегоДокумента(Конт);
		пока ВозвратыКомиссия.Следующий() цикл
			если  ВозвратыКомиссия.ДатаИзДокумента>='20230301' тогда
				МассивСтарыхСтрок=ТО.НайтиСтроки(новый Структура("Номенклатура",ВозвратыКомиссия.Номенклатура)); 	
				Если МассивСтарыхСтрок.Количество()= 0 тогда
					НоваяСтрокаТО = ТО.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,ВозвратыКомиссия);
					ЦенаПрихода=ПолучитьЦенуПрихода(НоваяСтрокаТО.Номенклатура,НоваяСтрокаТО.Склад,ВозвратыКомиссия.ДатаИзДокумента);
					
					если ЦенаПрихода=0 или ЦенаПрихода = Неопределено тогда
						НоваяСтрокаТО.Стоимость=-ВозвратыКомиссия.ВсегоИзДокумента;
					Иначе
						НоваяСтрокаТО.Стоимость=ЦенаПрихода*ВозвратыКомиссия.Остаток;
					КонецЕсли;
				иначе
					СтараяСтрока=МассивСтарыхСтрок.Получить(0);
					СтарыйОстаток=СтараяСтрока.Остаток;
					СтараяСтоимость=СтараяСтрока.Стоимость;
					СтараяЦена=?(СтарыйОстаток=0,0,СтараяСтоимость/СтарыйОстаток);
					НоваяСтоимость=ВозвратыКомиссия.Остаток*СтараяЦена;
					СтараяСтрока.Остаток=СтараяСтрока.Остаток+ВозвратыКомиссия.Остаток;
					СтараяСтрока.Стоимость=СтараяСтрока.Стоимость+НоваяСтоимость;		
				КонецЕсли;
			Иначе
				НоваяСтрокаТО = ТО.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,ВозвратыКомиссия);			
			КонецЕсли;
			// Кухарь А.Ю.  12.04.2023 конец
			
		КонецЦикла;
	КонецЕсли;
	// Кухарь А.Ю. 23.09.2021 конец
	
	
	//крохин начало 10.07.2015
	//добавляем остатки упаковки
	Если ВидДокумента="РасходнаяНакладная" И ТребуетсяУпаковка(Конт.ДопОбработки,Конт.КодОперации) Тогда
		если Конт.КМПЛУпаковка тогда
			ТОупаковки = ПолучитьОстаткиТМЦУпаковка(Конт,Загрузка,Склад,Период,"КомплектующиеУпаковки");
		иначе
			ТОупаковки = ПолучитьОстаткиТМЦУпаковка(Конт,Загрузка,Склад,Период,"Упаковка");	
		КонецЕсли;
		Для каждого СтрокаТОУпаковка Из ТОупаковки Цикл
			НоваяСтрокаТО = ТО.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,СтрокаТОУпаковка);
		КонецЦикла;
	КонецЕсли;
	Если ВидДокумента="Перемещение" Тогда
		ТОупаковки = ПолучитьОстаткиТМЦУпаковка(Конт,Загрузка,Склад,Период,"Упаковка");
		Для каждого СтрокаТОУпаковка Из ТОупаковки Цикл
			НоваяСтрокаТО = ТО.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,СтрокаТОУпаковка);
		КонецЦикла;
	КонецЕсли;	
	
	ТО.Колонки.Добавить("Погашено",			ПолучитьОписаниеТиповЧисла(12,3));
	ТО.Колонки.Добавить("СписанаСтоимость",	ПолучитьОписаниеТиповЧисла(19,2));
	
	Возврат ТО;
КонецФункции

//крохин начало 10.07.2015
//остатки упаковки
Функция ПолучитьОстаткиТМЦУпаковка(Конт,Загрузка,Склад=Неопределено,Период=Неопределено,ИмяТЧ=Неопределено) Экспорт
	// РНК+КМПЛ ***
	//крохин конец	
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	//крохин начало 23.12.2013
	//в Брянске тоже для ПРМ тоже ТЧ документа, переделать на реквизит
	//Если Загрузка Тогда //при загрузке тупо берем в качестве остатков ТЧ документа
	//крохин начало 29.05.2014
	//переделал на реквизит, требуется всем франчам
	//Если Загрузка ИЛИ (ПараметрыСеанса.ЭтотУзел.Подразделение.код = "SSP-0162" И КОНТ.Метаданные().Имя = "Перемещение") Тогда	
	Если Загрузка ИЛИ (ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения = Перечисления.ВидыПодразделений.Франчайзинг И КОНТ.Метаданные().Имя = "Перемещение") Тогда	
		//крохин конец 29.05.2014	
		//крохин конец 23.12.2013	
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	&СкладДокумента				КАК Склад,
		|	Номенклатура,
		|	СУММА(Количество)			КАК Остаток,
		|	СУММА(0)				    КАК Стоимость,	
		|	СУММА(0)					КАК Амортизация,	
		|	СУММА(0)					КАК Резерв		
		|ИЗ
		|	Документ."+ВидДокумента+".Упаковка ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО 
		|	Ссылка.Склад,
		|	Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Ссылка.Склад.Код";
	Иначе		
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	Склад,
		|	Номенклатура,
		|	СУММА(Остаток)				КАК Остаток,
		|	СУММА(Стоимость)			КАК Стоимость,	
		|	СУММА(Амортизация)			КАК Амортизация,
		|	СУММА(Резерв)				КАК Резерв		
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	Склад,
		|	Номенклатура,	
		|	КоличествоОстаток	Как Остаток,	
		|	СуммаОстаток 		Как Стоимость,			
		|	0					Как Амортизация,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&МоментВремени,
		|	Склад В (&Склады)
		|	И Номенклатура В  (&МассивНоменклатуры)
		|)	
		|КАК ОстаткиОпер
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.ОстаткиТМЦ.Остатки	
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ
		|	Склад,
		|	ОС,	
		|	0					Как Остаток,	
		|	0			 		Как Стоимость,			
		|	АмортизацияОстаток	Как Амортизация,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.Амортизация.Остатки(&МоментВремени,Склад В (&Склады) И ОС В (&МассивНоменклатуры))	
		|КАК ОстаткиАморт
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.Амортизация.Остатки";
		
		КонтрольРезервов=Истина;
		Если ПараметрыСеанса.ОтключитьКонтрольРезервов ИЛИ ВидДокумента="СписаниеТМЦ" Тогда			
			КонтрольРезервов=Ложь;
		КонецЕсли; 
		
		Если КонтрольРезервов Тогда
			ТекстЗапроса=ТекстЗапроса+"
			|ОБЪЕДИНИТЬ ВСЕ
			|ВЫБРАТЬ
			|	Склад,
			|	Номенклатура,	
			|	0 				Как Остаток,	
			|	0				Как Стоимость,			
			|	0				Как Амортизация,
			|	КоличествоОстаток Как Резерв			
			|ИЗ
			|	РегистрНакопления.РезервыТМЦ.Остатки(&МоментВремени,
			|	Склад В (&Склады)
			|	И Номенклатура В (&МассивНоменклатуры))	
			|КАК РезервыОпер
			|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.РезервыТМЦ.Остатки";
		КонецЕсли;
		
		ТекстЗапроса=ТекстЗапроса+"
		|) КАК ОбщийЗапрос
		|СГРУППИРОВАТЬ ПО Склад,Номенклатура
		|УПОРЯДОЧИТЬ ПО Номенклатура,Склад.Код";
	КонецЕсли;	
	
	Запрос.Текст=ТекстЗапроса;	
	
	Запрос.УстановитьПараметр("Ссылка",				Конт.Ссылка);
	// *** РНК+КМПЛ
	//Запрос.УстановитьПараметр("МассивНоменклатуры",	ПолучитьНоменклатуруДокумента(Конт.Ссылка));
	// ---------- заменено на:
	Запрос.УстановитьПараметр("МассивНоменклатуры",	ПолучитьНоменклатуруДокумента(Конт.Ссылка, ИмяТЧ));
	// РНК+КМПЛ ***
	
	ТекСкладДокумента=Конт.Склад;
	
	Склады=Новый Массив;
	Если Склад=Неопределено Тогда		
		Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
			Если Конт.Склад.ФизическийСклад.Пустая()  Тогда
				Склады.Добавить(Конт.Склад);						
			Иначе
				Склады.Добавить(Конт.Склад.ФизическийСклад);
				ТекСкладДокумента=Конт.Склад.ФизическийСклад;
			КонецЕсли;	
		Иначе   
			Склады.Добавить(Конт.Склад);
			//все-таки проще исправлять потом, чем списывать по разным складам. С 1 сентября 2009 
			//Если ВидДокумента="СписаниеТМЦ" Тогда
			Если ВидДокумента="СписаниеТМЦ" И Конт.Дата < '20090901' Тогда
				ВиртуальныеСклады=ПолучитьВиртуальныеСклады(Конт.Склад);					
				Для Каждого ВиртСклад Из ВиртуальныеСклады Цикл
					Склады.Добавить(ВиртСклад);			
				КонецЦикла; 
			КонецЕсли; 
		КонецЕсли;		
	Иначе
		Склады.Добавить(Склад);
	КонецЕсли;	
	
	
	//Мессерле 23,01,2012
	Если  ТипЗнч(Конт)=Тип("ДокументСсылка.ЗаказПоставщику") и ЗначениеЗаполнено(Конт.транзитныйСклад)  тогда  //Мессерле 05.04.12 и Загрузка
		ТекСкладДокумента=Конт.ТранзитныйСклад;
	Конецесли;	
	
	Запрос.УстановитьПараметр("СкладДокумента",ТекСкладДокумента);
	Запрос.УстановитьПараметр("Склады",Склады);
	Если Период=Неопределено Тогда
		Запрос.УстановитьПараметр("МоментВремени",новый граница(Конт.МоментВремени(),видграницы.Исключая));	
	Иначе
		Запрос.УстановитьПараметр("МоментВремени",Период);
	КонецЕсли;	
	
	Результат	=Запрос.Выполнить();
	
	ТО=Результат.Выгрузить();	
	
	
	
	//ТО.Колонки.Добавить("Погашено");
	//ТО.Колонки.Добавить("СписанаСтоимость");	
	
	Возврат ТО;
КонецФункции
//крохин конец 10.07.2015


Функция ПолучитьРезервыТМЦ(Конт,Загрузка=Ложь,ИмяТЧ="Товары")	
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	
	Если Загрузка ИЛИ ПараметрыСеанса.ОтключитьКонтрольРезервов Тогда
		
		Запрос.Текст="
		|ВЫБРАТЬ 
		|	Ссылка.Склад				КАК Склад,
		|	Номенклатура,
		|	СУММА(Количество)			КАК Остаток,
		// Кухарь А.Ю. 13.01.2020 начало
		//Стоимость вроде бы не нужна, на всякий само поле оставлю
		// 		|	СУММА(Всего)				КАК Стоимость,	
		|	СУММА(0)				КАК Стоимость,	
		// Кухарь А.Ю. 13.01.2020 конец
		|	СУММА(0)					КАК Резерв	
		|ИЗ
		|	Документ."+ВидДокумента+"."+ИмяТЧ+" ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО Ссылка.Склад,Номенклатура";
	Иначе
		Запрос.Текст="
		|ВЫБРАТЬ 
		|	Склад,
		|	Номенклатура,
		|	СУММА(Остаток)				КАК Остаток,	
		|	СУММА(Резерв)				КАК Резерв		
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	ОстаткиОпер.Склад,
		|	ОстаткиОпер.Номенклатура,	
		|	ОстаткиОпер.КоличествоОстаток Как Остаток,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&МоментВремени,Склад = &Склад И Номенклатура В (&МассивНоменклатуры)
		|)	
		|КАК ОстаткиОпер	
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.ОстаткиТМЦ.Остатки	
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ
		|	РезервыОпер.Склад,
		|	РезервыОпер.Номенклатура,	
		|	0 Как Остаток,		
		|	РезервыОпер.КоличествоОстаток Как Резерв		
		|ИЗ
		|	РегистрНакопления.РезервыТМЦ.Остатки(&МоментВремени,Склад = &Склад И Номенклатура В (&МассивНоменклатуры))	
		|КАК РезервыОпер
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.РезервыТМЦ.Остатки	
		|) КАК ОбщийЗапрос
		|СГРУППИРОВАТЬ ПО Склад,Номенклатура
		|"
		;
	КонецЕсли;	
	
	Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		// Кухарь А.Ю. 24.08.2020 начало
		// Для ЗНБ с верхнего склада
		//Если Конт.Склад.ФизическийСклад.Пустая()  Тогда		
		Если Конт.Склад.ФизическийСклад.Пустая() или (ВидДокумента= "ЗаданиеНабора" и Конт.Склад.ВидСклада=Перечисления.ВидСклада.ВиртуальныйДляСклада)  Тогда
			// Кухарь А.Ю. 24.08.2020 конец
			Запрос.УстановитьПараметр("Склад",						Конт.Склад);					
		Иначе
			Запрос.УстановитьПараметр("Склад",						Конт.Склад.ФизическийСклад);			
		КонецЕсли;
	Иначе
		Запрос.УстановитьПараметр("Склад",							Конт.Склад);		
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);
	Запрос.УстановитьПараметр("Приход",ВидДвиженияНакопления.Приход);
	Запрос.УстановитьПараметр("Ссылка",Конт.Ссылка);
	Запрос.УстановитьПараметр("МассивНоменклатуры",ПолучитьНоменклатуруДокумента(Конт.Ссылка));	
	
	//++Ратманов
	//Запрос.УстановитьПараметр("МоментВремени",Конт.МоментВремени());
	Запрос.УстановитьПараметр("МоментВремени",Новый Граница(Конт.МоментВремени(),ВидГраницы.Исключая));
	//--Ратманов
	
	Результат	=Запрос.Выполнить();
	
	ТО=Результат.Выгрузить();
	
	//крохин начало 10.07.2015
	//добавляем резервы упаковки
	Если ВидДокумента="РасходнаяНакладная" И ТребуетсяУпаковка(Конт.ДопОбработки,Конт.КодОперации) Тогда
		ТОупаковки = ПолучитьРезервыТМЦУпаковка(Конт,Загрузка,"Упаковка");
		Для каждого СтрокаТОУпаковка Из ТОупаковки Цикл
			НоваяСтрокаТО = ТО.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,СтрокаТОУпаковка);
		КонецЦикла;
	КонецЕсли;
	//крохин конец 10.07.2015
	//крохин начало 21.10.2015
	Если ВидДокумента="Перемещение" Тогда
		ТОупаковки = ПолучитьРезервыТМЦУпаковка(Конт,Загрузка,"Упаковка");
		Для каждого СтрокаТОУпаковка Из ТОупаковки Цикл
			НоваяСтрокаТО = ТО.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТО,СтрокаТОУпаковка);
		КонецЦикла;
	КонецЕсли;
	
	//крохин конец 21.10.2015
	
	Возврат ТО;
КонецФункции


Функция ПолучитьРезервыТМЦУпаковка(Конт,Загрузка=Ложь,ИмяТЧ="Товары")	
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	
	Если Загрузка ИЛИ ПараметрыСеанса.ОтключитьКонтрольРезервов Тогда
		
		Запрос.Текст="
		|ВЫБРАТЬ 
		|	Ссылка.Склад				КАК Склад,
		|	Номенклатура,
		|	СУММА(Количество)			КАК Остаток,
		|	СУММА(0)				КАК Стоимость,	
		|	СУММА(0)					КАК Резерв	
		|ИЗ
		|	Документ."+ВидДокумента+"."+ИмяТЧ+" ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО Ссылка.Склад,Номенклатура";
	Иначе
		Запрос.Текст="
		|ВЫБРАТЬ 
		|	Склад,
		|	Номенклатура,
		|	СУММА(Остаток)				КАК Остаток,	
		|	СУММА(Резерв)				КАК Резерв		
		|ИЗ
		|(
		|ВЫБРАТЬ
		|	ОстаткиОпер.Склад,
		|	ОстаткиОпер.Номенклатура,	
		|	ОстаткиОпер.КоличествоОстаток Как Остаток,		
		|	0 Как Резерв		
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&МоментВремени,Склад = &Склад И Номенклатура В (&МассивНоменклатуры)
		|)	
		|КАК ОстаткиОпер	
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.ОстаткиТМЦ.Остатки	
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ
		|	РезервыОпер.Склад,
		|	РезервыОпер.Номенклатура,	
		|	0 Как Остаток,		
		|	РезервыОпер.КоличествоОстаток Как Резерв		
		|ИЗ
		|	РегистрНакопления.РезервыТМЦ.Остатки(&МоментВремени,Склад = &Склад И Номенклатура В (&МассивНоменклатуры))	
		|КАК РезервыОпер
		|ДЛЯ ИЗМЕНЕНИЯ РегистрНакопления.РезервыТМЦ.Остатки	
		|) КАК ОбщийЗапрос
		|СГРУППИРОВАТЬ ПО Склад,Номенклатура
		|"
		;
	КонецЕсли;	
	
	Если ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если Конт.Склад.ФизическийСклад.Пустая() Тогда
			Запрос.УстановитьПараметр("Склад",						Конт.Склад);					
		Иначе
			Запрос.УстановитьПараметр("Склад",						Конт.Склад.ФизическийСклад);			
		КонецЕсли;
	Иначе
		Запрос.УстановитьПараметр("Склад",							Конт.Склад);		
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);
	Запрос.УстановитьПараметр("Приход",ВидДвиженияНакопления.Приход);
	Запрос.УстановитьПараметр("Ссылка",Конт.Ссылка);
	//Кухарь 01.04.19 начало	
	//Комплектующие упаковки	
	//Запрос.УстановитьПараметр("МассивНоменклатуры",ПолучитьНоменклатуруДокумента(Конт.Ссылка,"Упаковка"));		
	если Конт.КМПЛУпаковка тогда
		Запрос.УстановитьПараметр("МассивНоменклатуры",ПолучитьНоменклатуруДокумента(Конт.Ссылка,"КомплектующиеУпаковки"));	
	иначе
		Запрос.УстановитьПараметр("МассивНоменклатуры",ПолучитьНоменклатуруДокумента(Конт.Ссылка,"Упаковка"));	
	КонецЕсли;
	//Кухарь 01.04.19 конец	
	
	
	Запрос.УстановитьПараметр("МоментВремени",Конт.МоментВремени());
	
	Результат	=Запрос.Выполнить();
	
	ТО=Результат.Выгрузить();
	
	
	Возврат ТО;
КонецФункции


Функция ПолучитьЦеныМоделей(Конт,СписокМоделей,Загрузка)
	ВидДокумента=Конт.Метаданные().Имя;
	
	Запрос=Новый Запрос;
	
	Если Загрузка ИЛИ ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда //при загрузке (или на складах и ТЦ) тупо берем в качестве цен ТЧ документа
		ТекстЗапроса="
		|ВЫБРАТЬ		
		|	Номенклатура.Родитель		КАК Модель,
		|	СУММА(Количество)			КАК Остаток,
		|	СУММА(Всего)				КАК Стоимость,
		|	ВЫБОР КОГДА СУММА(Количество)=0 ТОГДА NULL ИНАЧЕ СУММА(Всего)/СУММА(Количество) КОНЕЦ КАК РасчетнаяЦена
		|ИЗ
		|	Документ."+ВидДокумента+".Товары ГДЕ Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО Номенклатура.Родитель";
	Иначе		
		ТекстЗапроса="
		|ВЫБРАТЬ 
		|	Модель,
		|	СУММА(Остаток)		КАК Остаток,
		|	СУММА(Стоимость)	КАК Стоимость,
		|	ВЫБОР КОГДА СУММА(Остаток)=0 ТОГДА NULL ИНАЧЕ СУММА(Стоимость)/СУММА(Остаток) КОНЕЦ КАК РасчетнаяЦена
		|ИЗ
		|(
		|ВЫБРАТЬ		
		|	Номенклатура.Родитель	КАК Модель,	
		|	КоличествоОстаток		КАК Остаток,	
		|	СуммаОстаток 			КАК Стоимость
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&МоментВремени,
		//|	Склад = &Склад И 	
		//крохин начало 15.05.2024
		|";
		Если Конт.Дата > '20240501' Тогда
			ТекстЗапроса=ТекстЗапроса + "
			| Склад.Подразделение.ВидПодразделения <> Значение(Перечисление.ВидыПодразделений.Франчайзинг) И
			|";	
		КонецЕсли;
		ТекстЗапроса=ТекстЗапроса + "
		//крохин конец 15.05.2024
		|	Номенклатура В ИЕРАРХИИ (&СписокМоделей)
		|)) КАК Остатки
		|СГРУППИРОВАТЬ ПО Модель";
	КонецЕсли; 
	
	
	Запрос.Текст=ТекстЗапроса;	
	
	Запрос.УстановитьПараметр("МоментВремени",Конт.МоментВремени());
	
	Запрос.УстановитьПараметр("Ссылка",			Конт.Ссылка);
	Запрос.УстановитьПараметр("Склад",			Конт.Склад);
	Запрос.УстановитьПараметр("СписокМоделей",	СписокМоделей);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ПолучитьЦеныМоделец()


Функция ПолучитьЦеныОстатков(ПНК)
	Запрос=Новый Запрос;
	
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Номенклатура		КАК Номенклатура,	
	|	ВЫБОР 
	|		КОГДА Склад = &Склад ТОГДА КоличествоОстаток	
	|	ИНАЧЕ 0 
	|	КОНЕЦ				КАК Остаток_Склад,		
	|	КоличествоОстаток	КАК Остаток_Общий,
	|	ВЫБОР 
	|		КОГДА Склад = &Склад ТОГДА СуммаОстаток
	|	ИНАЧЕ 0 
	|	КОНЕЦ 				КАК Стоимость_Склад,		
	|	СуммаОстаток		КАК Стоимость_Общий	
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2,
	//|		Склад = &Склад И 
	//крохин начало 06.08.2019
	//без франчайзинга
	|";
	Если ПНК.Дата > '20190701' Тогда
		Запрос.Текст=Запрос.Текст + "
		| Склад.Подразделение.ВидПодразделения <> Значение(Перечисление.ВидыПодразделений.Франчайзинг) И";	
	КонецЕсли;
	Запрос.Текст=Запрос.Текст + "
	//крохин конец 06.08.2019
	|		Номенклатура В (&Номенклатура))
	|КАК ОстаткиТМЦОстатки";
	
	Запрос.УстановитьПараметр("Дата2", Новый Граница(ПНК.МоментВремени(),ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Склад",ПНК.Склад);
	Запрос.УстановитьПараметр("Номенклатура",ПНК.Товары.ВыгрузитьКолонку("Номенклатура"));
	
	ТР		=Запрос.Выполнить().Выгрузить();
	ТР.Свернуть("Номенклатура","Остаток_Склад,Остаток_Общий,Стоимость_Склад,Стоимость_Общий");
	
	Возврат ТР;
КонецФункции //ПолучитьЦеныОстатков(ПНК)


Функция ПолучитьТаблицуРеализацииДляВозврата(ПНК)
	Запрос=Новый Запрос;	
	ДатаЧ='20090101';
	
	Если ПНК.ДокОснование<>Неопределено И НЕ ПНК.ДокОснование.Пустая() Тогда	
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура КАК Номенклатура,
		|	Количество КАК Количество,
		|	Сумма КАК Стоимость
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
		|ГДЕ
		|	ОстаткиТМЦ.Регистратор = &Регистратор
		|	И ОстаткиТМЦ.ВидДвижения = &ВидДвижения";
		
		Запрос.УстановитьПараметр("Регистратор",ПНК.ДокОснование);
		Запрос.УстановитьПараметр("ВидДвижения",ВидДвиженияНакопления.Расход);
		
		ТР=Запрос.Выполнить().Выгрузить();
		
		Если ЗначениеЗаполнено(Константы.ДатаЗапретаВидимости.Получить()) Тогда
			ДатаОтгрузки=ПНК.Дата;
		Иначе
			ДатаОтгрузки=ПНК.ДокОснование.Дата;
		КонецЕсли;
		
		Если ПНК.Дата>=ДатаЧ И ДатаОтгрузки<ДатаЧ Тогда		
			ВалютаУпр_Старая	=ПараметрыСеанса.ВалютаУпр;
			КурсУпр_Старый		=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр_Старая,ДатаОтгрузки);
			
			ВалютаУпр			=ПараметрыСеанса.ВалютаУпр_2009;
			КурсУпр				=ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,ДатаОтгрузки);
			
			Для Каждого СтрокаТР ИЗ ТР Цикл
				СтрокаТР.Стоимость=глПересчет(СтрокаТР.Стоимость,ВалютаУпр_Старая,КурсУпр_Старый,ВалютаУпр,КурсУпр);			
			КонецЦикла; 			
		КонецЕсли;				
	Иначе
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Номенклатура		КАК Номенклатура,
		|	КоличествоОстаток	КАК Количество,
		|	СуммаОстаток		КАК Стоимость	
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2,Склад = &Склад И Номенклатура В (&Номенклатура))
		|КАК ОстаткиТМЦОстатки";
		
		Запрос.УстановитьПараметр("Дата2", Новый Граница(ПНК.МоментВремени(),ВидГраницы.Исключая));
		Запрос.УстановитьПараметр("Склад",ПНК.Склад);
		Запрос.УстановитьПараметр("Номенклатура",ПНК.Товары.ВыгрузитьКолонку("Номенклатура"));	
		
		ТР=Запрос.Выполнить().Выгрузить();
		
		Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
		Запрос.Текст="
		|ВЫБРАТЬ 
		|	* 
		|ПОМЕСТИТЬ ТР
		|ИЗ
		|	&ТР КАК ТР
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура	
		|ПОМЕСТИТЬ ПНК
		|ИЗ
		|	Документ.ПриходнаяНакладная.Товары КАК ПНК
		|ГДЕ
		|	Ссылка=&Ссылка
		|	И Количество<>0
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПНК.Номенклатура КАК Номенклатура
		|ИЗ
		|	ПНК
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	ТР
		|ПО		
		|	ТР.Номенклатура=ПНК.Номенклатура
		|ГДЕ
		|	ТР.Количество ЕСТЬ NULL ИЛИ ТР.Количество=0";
		
		Запрос.УстановитьПараметр("ТР",ТР);
		Запрос.УстановитьПараметр("Ссылка",ПНК.Ссылка);
		СписокПустыхПозиций=Запрос.Выполнить().Выгрузить();
		
		/////////////////////////////////////////////////////////////////////////////////
		// НОВОЕ УСЛОВИЕ И ПНК.КодОперации <> Перечисления.КодыОперацийОстатки.Комиссия
		/////////////////////////////////////////////////////////////////////////////////
		
		Если СписокПустыхПозиций.Количество()>0 И ПНК.Дата>='20110601'
			И ПНК.КодОперации <> Перечисления.КодыОперацийОстатки.Комиссия Тогда
			
			Запрос=Новый Запрос;
			Запрос.Текст="
			|ВЫБРАТЬ
			|	Номенклатура,
			|	Период,
			|	Регистратор,
			|	Сумма,
			|	Количество
			|ПОМЕСТИТЬ Приходы
			|ИЗ
			|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
			|ГДЕ
			|	ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
			|	И (КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Закупка) ИЛИ КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Комплектация))
			|	И Номенклатура В (&Номенклатура)
			|	И Период МЕЖДУ &ДатаЧ И &Дата2
			|;
			|ВЫБРАТЬ 
			|	Номенклатура,
			|	МАКСИМУМ(Период) КАК Период
			|ПОМЕСТИТЬ ПоследниеПриходы
			|ИЗ Приходы
			|СГРУППИРОВАТЬ ПО 
			|	Номенклатура
			|;
			|ВЫБРАТЬ 
			|	Приходы.Номенклатура,
			|	СУММА(Приходы.Сумма) 		КАК Стоимость,
			|	СУММА(Приходы.Количество) 	КАК Количество
			|ИЗ
			|	ПоследниеПриходы
			|ЛЕВОЕ СОЕДИНЕНИЕ
			|	Приходы
			|ПО
			|	ПоследниеПриходы.Номенклатура=Приходы.Номенклатура
			|	И ПоследниеПриходы.Период=Приходы.Период
			|СГРУППИРОВАТЬ ПО
			|	Приходы.Номенклатура";
			
			Запрос.УстановитьПараметр("ДатаЧ", ДатаЧ);
			Запрос.УстановитьПараметр("Дата2", ПНК.Дата);			
			Запрос.УстановитьПараметр("Номенклатура",СписокПустыхПозиций);
			
			ТР_ПоПустым=Запрос.Выполнить().Выгрузить();
			Для Каждого СтрокаТР_Попустым Из ТР_ПоПустым Цикл
				СтрокаТР=ТР.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТР,СтрокаТР_Попустым);			
			КонецЦикла; 			
		КонецЕсли;
		
		Для Каждого СтрокаТР Из ТР Цикл
			Если СтрокаТР.Количество<>0 Тогда
				СтрокаТР.Стоимость	=1000000*СтрокаТР.Стоимость/СтрокаТР.Количество;
				СтрокаТР.Количество	=1000000;
			КонецЕсли; 
		КонецЦикла;   
	КонецЕсли;	
	
	Возврат ТР;
КонецФункции // ()

