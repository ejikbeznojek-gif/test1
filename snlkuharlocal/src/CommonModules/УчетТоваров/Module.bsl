#Область Партии

Функция ОприходоватьПартию(ТекДок,КодОперации,ТП,ТДВО,Отправитель=Неопределено,ПунктДоставки=Неопределено,Период=Неопределено,КолонкаКоличества="Количество") //ТП - ТаблицаПрихода		
	Если ЕстьРеквизитДокумента("Валюта",ТекДок.Метаданные()) Тогда
		ВалютаДокумента=ТекДок.Валюта;		
	Иначе
		ВалютаДокумента=?(ТекДок.Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);						
	КонецЕсли;	
	КурсУпр		=	глПересчет(1,ВалютаДокумента,ТекДок.Дата,ПараметрыСеанса.ВалютаУпр_2009,ТекДок.Дата,Ложь);		
	
	ТекПериод		=?(Период=Неопределено,ТекДок.Дата,Период);
	
	ОтправительВТЧ	=?(ТП.Колонки.Найти("Получатель")=Неопределено,Ложь,Истина);	
	
	//крохин начало 12.04.2021
	//ПНК-возвраты по комиссионной схеме приходуют товар по себестоимости
	Если ТекДок.Метаданные().Имя <> "РасходнаяНакладная" И КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
		ТО = ПолучитьОстаткиТМЦ(ТекДок,Ложь,ТекДок.СкладКомиссия);	
	КонецЕсли;
	//крохин конец 12.04.2021
	
	Для Каждого СтрокаТП Из ТП Цикл
		////крохин начало 11.11.2015
		//для упаковки в ПРМ проводок не делаем
		//Если ТекДок.Метаданные().Имя = "Перемещение" И (СтрокаТП.КодОперации = Перечисления.КодыОперацийОстатки.Списание ИЛИ СтрокаТП.КодОперации = Перечисления.КодыОперацийОстатки.ПустаяСсылка()) Тогда
		//Продолжить;	
		//КонецЕсли;
		////крохин конец 11.11.2015
		НадоОприходовать=СтрокаТП[КолонкаКоличества];
		Если (КодОперации=Перечисления.КодыОперацийОстатки.Списание ИЛИ КодОперации=Перечисления.КодыОперацийОстатки.Оприходование) Тогда
			Если НадоОприходовать=0 И СтрокаТП.Всего=0 Тогда
				Продолжить;			
			КонецЕсли;			
		ИначеЕсли НадоОприходовать=0 Тогда 
			Продолжить;					
		КонецЕсли;		
		
		Движение=ТДВО.Добавить();	
		
		Движение.Активность		= Истина;
		Движение.Период		= ТекПериод;		
		
		Движение.Склад		= СтрокаТП.Склад;	
		
		Движение.Номенклатура	= СтрокаТП.Номенклатура;			
		Движение.Количество		= НадоОприходовать;		
		
		Движение.Сумма		= СтрокаТП.Всего;	
		
		//крохин начало 12.04.2021
		//ПНК-возвраты по комиссионной схеме приходуют товар по себестоимости
		
		// Шворобей ВЮ 30.10.2024 ++ https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-1856
		Если КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
			
			Если ТекДок.Метаданные().Имя = "ПриходнаяНакладная" Тогда
				СтрокаОстатка=ТО.Найти(СтрокаТП.Номенклатура,"Номенклатура");
				Если СтрокаОстатка <> Неопределено И СтрокаОстатка.Остаток > 0 Тогда
					//крохин начало 04.12.2024
					//условие косячное 
					//Если СтрокаОстатка.Стоимость = 0 И ТекДок.Дата >= '20241101' Тогда
					//	Движение.Сумма = 0;
					//КонецЕсли;
					Если СтрокаОстатка.Стоимость = 0 И ТекДок.Дата >= '20240101' Тогда
						Движение.Сумма = 0;
					ИначеЕсли СтрокаОстатка.Стоимость>0 Тогда
						Движение.Сумма = НадоОприходовать*СтрокаОстатка.Стоимость/СтрокаОстатка.Остаток;
					КонецЕсли;
					//крохин конец 04.12.2024
				КонецЕсли;
			ИначеЕсли ТекДок.Метаданные().Имя <> "РасходнаяНакладная" Тогда
				СтрокаОстатка=ТО.Найти(СтрокаТП.Номенклатура,"Номенклатура");	
				Если СтрокаОстатка<>Неопределено И СтрокаОстатка.Остаток>0 Тогда
					Если СтрокаОстатка.Стоимость>0 Тогда
						Движение.Сумма = НадоОприходовать*СтрокаОстатка.Стоимость/СтрокаОстатка.Остаток;					
					КонецЕсли;
				КонецЕсли; 		
			КонецЕсли;
			
		КонецЕсли;
		// Шворобей ВЮ 30.10.2024 ++ https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-1856
		
		Движение.Оборот		= СтрокаТП.Оборот;		
		Движение.ОборотБезСкидки= СтрокаТП.ОборотБезСкидки;
		
		Движение.ОборотУпр		= КурсУпр*СтрокаТП.Оборот;		
		Движение.ОборотБезСкидкиУпр	= КурсУпр*СтрокаТП.ОборотБезСкидки;
		
		Движение.КодОперации	= КодОперации;		
		
		Если ОтправительВТЧ Тогда
			Движение.Отправитель = СтрокаТП.Получатель;
		Иначе
			Движение.Отправитель = Отправитель;
		КонецЕсли; 	
		
		Движение.Подразделение	= СтрокаТП.Подразделение;
		Движение.ПунктДоставки	= ПунктДоставки;
		
		Движение.Амортизация	= СтрокаТП.Амортизация;
		
	КонецЦикла;
	
	Возврат 1;
КонецФункции

// Кухарь А.Ю.  14.03.2024 начало
//Функция ПогаситьПартии(ТекДок,КодОперации,Товары,Остатки,ТДВО,Получатель=Неопределено,ПунктДоставки=Неопределено,ТО=Неопределено,КонтрольОстатков=Истина,Период=Неопределено,КолонкаКоличества="Количество")
Функция ПогаситьПартии(ТекДок,КодОперации,Товары,Остатки,ТДВО,Получатель=Неопределено,ПунктДоставки=Неопределено,ТО=Неопределено,КонтрольОстатков=Истина,Период=Неопределено,КолонкаКоличества="Количество",Загрузка=ложь) 
	// Кухарь А.Ю.  14.03.2024 конец
	
	МетаДок=ТекДок.Метаданные();
	//крохин начало 12.04.2021
	МетаДокИмя = МетаДок.Имя;
	//крохин конец 12.04.2021
