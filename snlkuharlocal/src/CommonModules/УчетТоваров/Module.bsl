Функция ДвиженияПриходнойНакладной(ТекДок,ТД)
	ЭтоЛена			 	= ?(Найти(Константы.НеПроводитьПриходПоИБ.Получить(),ТекДок.ИБ.Код)<>0,?(ТекДок.КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР,Ложь,Истина),Ложь);	
	Если ТекДок.Дата>='20080901' Тогда ЭтоЛена=Ложь КонецЕсли; 
	
	ЦеныОстатков		= Неопределено;
	
	Результат=1;
	
	//закупку по Лене в ЦИБ не проводим
	Если ЭтоЛена и ТекДок.КодОперации=Перечисления.КодыОперацийОстатки.Закупка Тогда
		ТД.Очистить();	
		Возврат Результат;
	КонецЕсли; 
	
	ДатаДок				= ТекДок.Дата;
	
	ВалютаУпр_Старая	= ПараметрыСеанса.ВалютаУпр;	
	
	ВалютаУпр			= ?(ТекДок.Дата>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);	
	КурсУпр				= ПолучитьКурсВалюты_ПоРусски(ВалютаУпр,ДатаДок);
	
	Рубли		= ПараметрыСеанса.ВалютаНац;
	КурсРубля	= ПолучитьКурсВалюты_ПоРусски(Рубли,ДатаДок);
	
	ВалютаДок	=ТекДок.Валюта;
	КурсДок		=ТекДок.Курс;	
	
	КодОперации		=ТекДок.КодОперации;
	
	ЕстьРНКОснование=Ложь;
	//крохин начало 19.07.2022
	//Если КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда	
	//при возврате комиссионного товара себестоимость рассчитывается аналогично обычному возврату 
	Если КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя ИЛИ (КодОперации=Перечисления.КодыОперацийОстатки.Комиссия И ТекДок.Дата >= '20220701') Тогда		
		//крохин конец 19.07.2022	
		
		ТС=ПолучитьТаблицуРеализацииДляВозврата(ТекДок);
		
		РассчитатьОбороты(ТД,ТекДок.Валюта,ТекДок.Курс,Рубли,КурсРубля,ВалютаУпр,КурсУпр,-1);
		
		Если ЗначениеЗаполнено(ТекДок.ДокОснование) И ТекДок.ДокОснование.Метаданные().Имя="РасходнаяНакладная" Тогда	
			ЕстьРНКОснование=Истина;
		КонецЕсли;
	КонецЕсли;
	
	ЗаписиЦПП=РегистрыСведений.История.СоздатьНаборЗаписей();
	ЗаписиЦПП.Отбор.Документ.Использование	=Истина;
	ЗаписиЦПП.Отбор.Документ.Значение		=ТекДок.Ссылка;
	
	ЗаписиЦПП.Отбор.Реквизит.Использование	=Истина;
	ЗаписиЦПП.Отбор.Реквизит.Значение		="ЦенаПоследнегоПрихода";
	
	СписокПозиций=Новый Соответствие;
	
	ВалСто		=0;	
	//крохин начало 10.04.2013
	//франчайзинг - реквизит подразделения	
	//+++Чирков франчи и розницные ТЦ 21.01.13				
	//Если ТекДок.Подразделение.Код="SSP-0148" ИЛИ ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
	//крохин начало 23.12.2013
	//в Брянске нужен оборот, потом переделать на реквизит
	//Если ТекДок.Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг ИЛИ ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
	//крохин начало 29.05.2014
	//переделал на реквизит
	//крохин начало 05.06.2014
	//в ЦО проводки не нужны, ошибка
	//Если ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения<>Перечисления.ВидыПодразделений.Франчайзинг И ПараметрыСеанса.ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
	Если ПараметрыСеанса.ЭтотУзел.Подразделение.ВидПодразделения<>Перечисления.ВидыПодразделений.Франчайзинг И (ТекДок.Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг) Тогда
		//крохин конец 05.06.2014
		//крохин конец 29.05.2014
		//крохин конец 23.12.2013	
		//крохин конец 10.04.2013
		ЗаписыватьСтоимость=Ложь;
	Иначе
		ЗаписыватьСтоимость=Истина;		
	КонецЕсли;	
	//---Чирков франчи и розницные ТЦ 21.01.13
	
	Для Каждого СтрокаТД Из ТД Цикл
		
		СтрокаТД.ВалютаДокумента=ВалютаДок;
		
		Если ЭтоЛена Тогда
			// Ленина накладная в центральной базе			
			ЦПП=ПолучитьПериодическийРеквизит(СтрокаТД.Номенклатура,"ЦенаПоследнегоПрихода",ТекДок.Дата);			
			
			ВалСто=СтрокаТД.Количество*?(ЦПП=Неопределено,0,ЦПП);			
			Если ВалСто=0 Тогда
				Сообщить("При проведении приходной накладной по ИБ: """+ТекДок.ИБ+""" не задана цена последнего прихода ! Товар: "+СтрокаТД.Номенклатура,СтатусСообщения.Важное);
			КонецЕсли;				
		Иначе				
			// если стоит цена возврата то используем ее
			//крохин начало 19.07.2022
			//Если КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда	
			//при возврате комиссионного товара себестоимость рассчитывается аналогично обычному возврату 
			Если КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя ИЛИ (КодОперации=Перечисления.КодыОперацийОстатки.Комиссия И ТекДок.Дата >= '20220701') Тогда		
				//крохин конец 19.07.2022
				ТекСтоимость	=СтрокаТД.Количество*СтрокаТД.ЦенаВозврата;				
				ВалСто			=глПересчет(ТекСтоимость,ВалютаДок,КурсДок,ВалютаУпр,КурсУпр);
				
				Если ВалютаДок<>ВалютаУпр Тогда
					ВалСто			=0; //ха-ха именно так оно всегда и работалов 7.7				
				КонецЕсли;				
				
				Если ТекДок.Дата>='20080901' Тогда
					ВалСто			=0;				
				КонецЕсли; 
				
			Иначе
				ТекСтоимость	=СтрокаТД.Всего;
				//для контрагентов без НДС с/с увеличивается и формируются затраты
				// Шворобей 09.01.2024 ++ https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2458
				Если ТекДок.Дата >= '20151201' И КодОперации = Перечисления.КодыОперацийОстатки.ЗакупкаР И ТекДок.Контрагент.СтавкаНДСКонтрагента = Перечисления.СтавкиНДС.БезНДС Тогда
					ТекСТавкаНДС = ПроцентНДСпоСтавке(ПолучитьСтавкуНДС(СтрокаТД.Номенклатура));
					//крохин начало 26.02.2016
					//НДС сверху с февраля 2016
					//ТекСтоимость = ТекСтоимость*(1 + ТекСТавкаНДС/(1+ТекСТавкаНДС));
					Если ТекДок.Дата >= '20160201' Тогда
