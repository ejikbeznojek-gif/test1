Функция ЗаписатьВтаблицуОшибок(ТО,Объект,ТипОшибки,НомерСтроки,СтрокаТовара=Неопределено,Остаток=0,Резерв=0)
	Если ТипЗнч(ТО)<>Тип("ТаблицаЗначений") Тогда
		ТО=Новый ТаблицаЗначений;	
		
		ТО.Колонки.Добавить("Объект");		
		ТО.Колонки.Добавить("ТипОшибки");
		ТО.Колонки.Добавить("НомерСтроки");		
		ТО.Колонки.Добавить("Склад");		
		ТО.Колонки.Добавить("Номенклатура");		
		ТО.Колонки.Добавить("Количество");
		ТО.Колонки.Добавить("Остаток");
		ТО.Колонки.Добавить("Резерв");
		ТО.Колонки.Добавить("ВиртуальныйРезерв");		
	КонецЕсли;
	
	СтрокаТО=ТО.Добавить();
	
	СтрокаТО.Объект				=Объект.Ссылка;
	СтрокаТО.ТипОшибки			=ТипОшибки;
	
	Если СтрокаТовара<>Неопределено Тогда
		СтрокаТО.Склад			=СтрокаТовара.Склад;
		СтрокаТО.Номенклатура	=СтрокаТовара.Номенклатура;
		СтрокаТО.Количество		=СтрокаТовара.Количество;	
		
		// Кухарь А.Ю. 04.04.2025 начало
		// ХЗ зачем это
		//	БЕ						=СтрокаТовара.Номенклатура.БазоваяЕдиница;
		//Иначе
		//	БЕ="";	 
		// Кухарь А.Ю. 04.04.2025 конец
		
	
	КонецЕсли;	
	
	СтрокаТО.Остаток			=Остаток;
	СтрокаТО.Резерв				=Резерв;	
КонецФункции // ЗаписатьВтаблицуОшибок()

Процедура ОчиститьДвиженияДокументаПоИстории(Ссылка) Экспорт
	НаборЗаписей=РегистрыСведений.История.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Использование	=Истина;
	НаборЗаписей.Отбор.Документ.Значение		=Ссылка;
	
	НаборЗаписей.Записать();
КонецПроцедуры

// +++ РНК+КМПЛ+ЗаявкаНаПерепаковку
Функция ПолучитьИмяТоварнойТЧ(Документ)
	
	ВидДок	= Документ.Метаданные().Имя;	
	ИмяТЧ	= "Товары"; // для большинства документов
	
	// Шворобей ВЮ 28.04.2022 +
	Если ВидДок = "Комплектация" ИЛИ ВидДок = "ЗаявкаНаПерепаковку" Тогда
		ИмяТЧ = "Комплектующие";
	ИначеЕсли ВидДок = "РасходнаяНакладная" И Документ.ОтгрузкаКомплектов Тогда
		ЭтоРезерв = (Документ.Отгружен = Перечисления.Отгружен.Резерв Или Документ.Отгружен = Перечисления.Отгружен.РезервТранзит);
		Если ЭтоРезерв Тогда
			ИмяТЧ = "Комплектующие";
		КонецЕсли;
	КонецЕсли;
	
	Возврат ИмяТЧ;
	
КонецФункции

