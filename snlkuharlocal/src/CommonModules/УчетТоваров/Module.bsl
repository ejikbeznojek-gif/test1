					// Результат	= ПогаситьПартии(ТекДок, КодОперацииКомплектация, ТДКомплектующие, ТО, ТДВО, ТекДок.Склад,, ТОшибок, Истина);
					Результат	= ПогаситьПартии(ТекДок, КодОперацииКомплектация, ТДКомплектующие, ТО, ТДВО, ТекДок.Склад,, ТОшибок, Истина,,,Загрузка); 
