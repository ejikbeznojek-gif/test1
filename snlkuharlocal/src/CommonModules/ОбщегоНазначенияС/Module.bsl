// Устанавливает номер документа в соответствии с правилами нумерации конфигурации.
// Определяет префикс нумерации в зависимости от типа документа, организации, склада и типа узла ИБ.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект - документ, для которого устанавливается номер
//
Процедура УстановитьНомерДокументаСервер(ДокументОбъект) Экспорт

	МетаданныеДокумента = ДокументОбъект.Метаданные();

	ДопБуква = "";

	Если МетаданныеДокумента.Имя = "РасходнаяНакладная" Тогда

		Если ДокументОбъект.Дата >= '20250101' Тогда

			ДопБуква = "";

		ИначеЕсли ДокументОбъект.Дата >= '20200101' Тогда

			ДопБуква = "б";

		Иначе

			ДопБуква = ?(ДокументОбъект.ВидОплаты = Перечисления.ВидыОплаты.БН, "б", "а");

		КонецЕсли;

	ИначеЕсли МетаданныеДокумента.Имя = "ОтчетКассовойСмены" Тогда

		ДопБуква = ?(ДокументОбъект.ВидОплаты = Перечисления.ВидыОплаты.БН, "кб", "кн");

	КонецЕсли;

	Вид = МетаданныеДокумента.Имя;

	Если Вид = "ЛистНабора" Или Вид = "ЛистПереукладки" Тогда

		НомерДокумента = ПолучитьРеквизитШапкиСервер(ДокументОбъект.ДокОснование, "Номер");

		ИмяДокумента = СокрЛП(НомерДокумента);

		ТипДокОсн = ДокументОбъект.ДокОснование.Метаданные().Имя;

		Если ТипДокОсн = "Инвентаризация" Тогда

			ИмяДокумента = "" + ИмяДокумента + "i";
			ИмяДокумента = Лев(ИмяДокумента, 4) + Сред(ИмяДокумента, 6, СтрДлина(ИмяДокумента)) + "/";

			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ИмяДокумента));

		Иначе

			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(НомерДокумента) + "/");

		КонецЕсли;

	ИначеЕсли Вид = "КорректировочныйСчетФактура" Тогда

		Попытка

			НакладнаяРНК = ПолучитьРеквизитШапкиСервер(ДокументОбъект.накладные[0], "накладная");
			ДокОснование = ПолучитьРеквизитШапкиСервер(НакладнаяРНК, "докоснование");
			ДокРНК       = ПолучитьРеквизитШапкиСервер(ДокОснование, "ссылка");

		Исключение

			Сообщить("Сначала сохраните документ!");

		КонецПопытки;

		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда

			Префикс = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

			ПрефиксСклада = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "Префикс"));

			Префикс = Префикс + ПрефиксСклада;

			ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация, "Префикс");

			Если ДокументОбъект.Организация <> Справочники.Организации.НайтиПоКоду("SS-001") И Не ПустаяСтрока(
				ПрефиксОрганизации) Тогда

				Префикс = Лев(ПрефиксОрганизации, 1) + Прав(Префикс, СтрДлина(Префикс) - 1);

			КонецЕсли;

		Иначе

			ПрефиксКонтрагента = "";

			Если ДокументОбъект.Накладные.Количество() > 0 Тогда

				Накладная 		= ПолучитьРеквизитШапкиСервер(ДокументОбъект.Накладные[0],
					"Накладная");
				ПунктДоставки	= ПолучитьРеквизитШапкиСервер(Накладная, "ПунктДоставки");
				ПрефиксСФ  		= ПолучитьРеквизитШапкиСервер(ПунктДоставки, "ПрефиксСФ");

				Если ЕстьРеквизитДокумента("ПунктДоставки", Накладная.Метаданные()) И ЗначениеЗаполнено(ПрефиксСФ) Тогда

					ПрефиксКонтрагента = СокрЛП(ПрефиксСФ);

				КонецЕсли;

			КонецЕсли;

			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда

				ПрефиксКонтрагента = СокрЛП(ПолучитьРеквизитРодителя(ДокументОбъект.Контрагент, "ПрефиксСФ"));

			КонецЕсли;

			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда

				ПрефиксСклада	= СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад,
					"Префикс")); 				

				//@skip-check empty-except-statement
				Попытка

					ДокРКМ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.накладные[0], "Накладная");

					ДокументВозврата = ПолучитьРеквизитШапкиСервер(ДокРКМ, "ДокументВозврата");

					Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение
						И ДокРКМ.Метаданные().Имя = "РекламационнаяНакладная" И Не (ДокументВозврата.Пустая()) Тогда

						ПрефиксСклада = "v";

					КонецЕсли;

				Исключение

				КонецПопытки;

				ПрефиксИБ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "ПрефиксИБ");

				Если ПрефиксИБ = "SNL" Тогда

					Префикс = ПрефиксИБ;

				Иначе

					ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация,
						"Префикс");

					КодИБ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.ИБ, "Код");

					Префикс = ?(Не ПустаяСтрока(ПрефиксОрганизации), СокрЛП(
						ПрефиксОрганизации) + ПрефиксСклада, КодИБ);

				КонецЕсли;

			Иначе

				ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация,
					"Префикс");

				КодИБ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.ИБ, "Код");

				Префикс = ?(Не ПустаяСтрока(ПрефиксОрганизации), СокрЛП(
					ПрефиксОрганизации) + ПрефиксКонтрагента, КодИБ);

			КонецЕсли;

		КонецЕсли;

		Если ПерваяСФ(Префикс, ДокументОбъект.Дата) Тогда

			КоличествоПропусков = 1;

		Иначе

			КоличествоПропусков=0;

		КонецЕсли;

		УстановитьНормальныйНовыйНомер(ДокументОбъект, Префикс + "-", КоличествоПропусков);

	ИначеЕсли Вид = "СчетФактура" Тогда

		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда

			Префикс = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

			ПрефиксСклада = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "Префикс"));

			Префикс = Префикс + ПрефиксСклада;

			ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация, "Префикс");

			Если ДокументОбъект.Организация <> Справочники.Организации.НайтиПоКоду("SS-001") И Не ПустаяСтрока(
				ПрефиксОрганизации) Тогда

				Префикс = Лев(ПрефиксОрганизации, 1) + Прав(Префикс, СтрДлина(Префикс) - 1);

			КонецЕсли;

		Иначе
			ПрефиксКонтрагента = "";

			Если ДокументОбъект.Накладные.Количество() > 0 Тогда
				Накладная = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Накладные[0], "Накладная");

				Если ЕстьРеквизитДокумента("ПунктДоставки", Накладная.Метаданные()) Тогда

					ПунктДоставки = ПолучитьРеквизитШапкиСервер(Накладная, "ПунктДоставки");
					ПрефиксСФ = ПолучитьРеквизитШапкиСервер(ПунктДоставки, "ПрефиксСФ");

					Если ЗначениеЗаполнено(ПрефиксСФ) Тогда

						ПрефиксКонтрагента = СокрЛП(Накладная.ПунктДоставки.ПрефиксСФ);

					КонецЕсли;

				КонецЕсли;

			КонецЕсли;

			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда

				ПрефиксКонтрагента = СокрЛП(ПолучитьРеквизитРодителя(ДокументОбъект.Контрагент, "ПрефиксСФ"));

			КонецЕсли;

			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда

				ПрефиксСклада = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "Префикс"));
				ПрефиксИБ = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "ПрефиксИБ"));

				Если ПрефиксИБ = "SNL" Тогда

					Префикс = ПрефиксИБ;

				Иначе

					ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация,
						"Префикс");
					КодИБ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.ИБ, "Код");

					Префикс = ?(Не ПустаяСтрока(ПрефиксОрганизации), СокрЛП(
						ПрефиксОрганизации) + ПрефиксСклада, КодИБ);

				КонецЕсли;

			Иначе

				ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация,
					"Префикс");

				КодИБ = ПолучитьРеквизитШапкиСервер(ДокументОбъект.ИБ, "Код");

				Префикс = ?(Не ПустаяСтрока(ПрефиксОрганизации), СокрЛП(
					ПрефиксОрганизации) + ПрефиксКонтрагента, КодИБ);

			КонецЕсли;

		КонецЕсли;

		Если ПерваяСФ(Префикс, ДокументОбъект.Дата) Тогда

			КоличествоПропусков = 1;

		Иначе

			КоличествоПропусков = 0;

		КонецЕсли;

		УстановитьНормальныйНовыйНомер(ДокументОбъект, Префикс + "-", КоличествоПропусков);

	ИначеЕсли ЕстьРеквизитДокумента("ИБ", МетаданныеДокумента) Тогда

		ЭтотУзел = ПараметрыСеанса.ЭтотУзел;

		Если ЕстьРеквизитДокумента("Склад", МетаданныеДокумента) Тогда

			ПрефиксИБ = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "ПрефиксИБ"));

		КонецЕсли;

		ПрефиксИБ = ОбщегоНазначения_ПИ.ПолучитьПрефиксПоДатеИУзлу(НачалоГода(ДокументОбъект.Дата), ЭтотУзел);

		КодИБ = ПрефиксИБ;

		Если МетаданныеДокумента.Имя = "Заказ" Тогда

			Если ЕстьРеквизитДокумента("Склад", МетаданныеДокумента) Тогда

				ПрефиксИБ = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад, "ПрефиксИБ"));

			КонецЕсли;

			Если ПустаяСтрока(ПрефиксИБ) Тогда

				ПрефиксИБ = СокрЛП(ПолучитьРеквизитШапкиСервер(ДокументОбъект.ИБ, "Код"));

			КонецЕсли;

			РеквизитыУзла = ПолучитьРеквизитыШапкиСервер(ЭтотУзел, "ТипУзла,Код");

			КодИБ = ?(РеквизитыУзла.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение, ПрефиксИБ,
				РеквизитыУзла.Код);

		КонецЕсли;

		Если МетаданныеДокумента.Имя = "РекомендованныйОстаток" Тогда

			ПрефиксИБ = "";

			КодИБ = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

		КонецЕсли;

		Если МетаданныеДокумента.Имя = "ПриходнаяНакладная" И (КодИБ = "SSP" Или КодИБ = "SST" Или КодИБ = "SSV") Тогда

			ДокументОбъект.УстановитьНовыйНомер(КодИБ + "-0");

		ИначеЕсли МетаданныеДокумента.Имя = "ПланНабора" Тогда

			Если КодИБ = "OD7" И ДеньГода(ТекущаяДатаСеанса()) > 180 Тогда

				КодИБ = "OD8";

			КонецЕсли;

			ДокументОбъект.УстановитьНовыйНомер(КодИБ + "_");

		Иначе

			ДокументОбъект.УстановитьНовыйНомер(КодИБ + ДопБуква + "-");

		КонецЕсли;

	ИначеЕсли Вид = "УслугиСтороннихОрганизаций" Или Вид = "СчетЗаДоставку" Или Вид
		= "НоменклатурноеПриложениеКПаллете" Тогда

		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда

			ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация, "Префикс");

			Префикс = ПрефиксОрганизации + "-";

		Иначе

			КодУзла = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

			Префикс = КодУзла + "-";

		КонецЕсли;

		ДокументОбъект.УстановитьНовыйНомер(Префикс);

	ИначеЕсли Вид = "АвансовыйОтчет" Тогда

		Если ДокументОбъект.ВидОплаты = Перечисления.ВидыОплаты.БН Тогда

			ПрефиксОрганизации = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Организация, "Префикс");

			Префикс = ПрефиксОрганизации + "-";

		Иначе

			Префикс = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

		КонецЕсли;

		ДокументОбъект.УстановитьНовыйНомер(Префикс);

	Иначе

		КодИБ = ПолучитьРеквизитШапкиСервер(ПараметрыСеанса.ЭтотУзел, "Код");

		ДокументОбъект.УстановитьНовыйНомер(КодИБ + "-");

	КонецЕсли;

КонецПроцедуры // УстановитьНомерДокумента()

Функция ПерваяСФ(Префикс,Дата)
	
	Запрос = Новый Запрос;
	Запрос.Текст ="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка
	|ИЗ
	|	Документ.СчетФактура КАК СчетФактура
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	И Номер ПОДОБНО &Номер
	|	И НЕ ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Дата1", НачалоДня(Дата));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата));
	Запрос.УстановитьПараметр("Номер", Префикс + "%");		
	
	Возврат Запрос.Выполнить().Пустой();

КонецФункции
	
Процедура УстановитьНормальныйНовыйНомер(ДокументОбъект, Префикс, КоличествоПропусков = 0)

	МетаДок 	= 	ДокументОбъект.Метаданные();
	
	ДлинаЧисловойЧасти	= МетаДок.ДлинаНомера - СтрДлина(СокрЛП(Префикс));
		
	Если МетаДок.ПериодичностьНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Год Тогда

		Дата1 = НачалоГода(ДокументОбъект.Дата);
		Дата2 = КонецГода(ДокументОбъект.Дата);

	ИначеЕсли МетаДок.ПериодичностьНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Квартал Тогда

		Дата1 = НачалоКвартала(ДокументОбъект.Дата);
		Дата2 = КонецКвартала(ДокументОбъект.Дата);

	ИначеЕсли МетаДок.ПериодичностьНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Месяц Тогда

		Дата1 = НачалоМесяца(ДокументОбъект.Дата);
		Дата2 = КонецМесяца(ДокументОбъект.Дата);

	ИначеЕсли МетаДок.ПериодичностьНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.День Тогда

		Дата1 = НачалоДня(ДокументОбъект.Дата);
		Дата2 = КонецДня(ДокументОбъект.Дата);

	Иначе

		Дата1 = Неопределено;
		Дата2 = Неопределено;

	КонецЕсли;

	Шаблон = СокрЛП(Префикс);
	
	Для Сч = 1 По ДлинаЧисловойЧасти Цикл

		Шаблон = Шаблон + "[0-9]";

	КонецЦикла;

	Если МетаДок.Имя = "ПланНабора" И ДеньГода(ТекущаяДатаСеанса()) > 180 Тогда

		Префикс = "OD8";

	КонецЕсли;
	Запрос = Новый Запрос;

	Если МетаДок.Имя = "СчетФактура" Или МетаДок.Имя = "КорректировочныйСчетФактура" Тогда

		Запрос.Текст="ВЫБРАТЬ РАЗРЕШЕННЫЕ
					 |	МАКСИМУМ(СчетФактура.Номер) КАК Номер
					 |ИЗ
					 |	Документ.СчетФактура КАК СчетФактура
					 |ГДЕ
					 |	" + ?(Дата1 = Неопределено, "", "Дата МЕЖДУ &Дата1 И &Дата2 И ") + "
					 |	СчетФактура.Номер ПОДОБНО &Шаблон
					 |
					 |ОБЪЕДИНИТЬ ВСЕ
					 |
					 |ВЫБРАТЬ
					 |	МАКСИМУМ(КорректировочныйСчетФактура.Номер)
					 |ИЗ
					 |	Документ.КорректировочныйСчетФактура КАК КорректировочныйСчетФактура
					 |ГДЕ
					 |	" + ?(Дата1 = Неопределено, "", "Дата МЕЖДУ &Дата1 И &Дата2 И ") + "
					 |	КорректировочныйСчетФактура.Номер ПОДОБНО &Шаблон
					 |
					 |УПОРЯДОЧИТЬ ПО
					 |	Номер УБЫВ";

	Иначе
		
		Запрос.Текст="
					 |ВЫБРАТЬ РАЗРЕШЕННЫЕ
					 |	МАКСИМУМ(Номер) КАК Номер
					 |ИЗ
					 |	Документ." + МетаДок.Имя + "
					 |ГДЕ
					 |	" + ?(Дата1 = Неопределено, "",	"Дата МЕЖДУ &Дата1 И &Дата2 И ") + "
					 |	Номер ПОДОБНО &Шаблон";

	КонецЕсли;

	Запрос.УстановитьПараметр("Шаблон", Шаблон);

	Если Дата1 <> Неопределено Тогда

		Запрос.УстановитьПараметр("Дата1", Дата1);
		Запрос.УстановитьПараметр("Дата2", Дата2);

	КонецЕсли;

	НомерДока	= Неопределено;
	ПоследнийНомер = 0;

	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда

		Если ЗначениеЗаполнено(Выборка.Номер) Тогда

			НомерДока		= Выборка.Номер;
			ПоследнийНомер	= Число(СтрЗаменить(Выборка.Номер, СокрЛП(Префикс), ""));

		КонецЕсли;

	КонецЕсли;

	Коэффициент = 1;

	Если КоличествоПропусков = 1 Тогда

		КоличествоПропусков = 0;

		ПоследнийДок = Документы[МетаДок.Имя].НайтиПоНомеру(НомерДока, ДокументОбъект.Дата);

		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
					   |	ПропускСФ.КоличествоПропусков,
					   |	ПропускСФ.Дата,
					   |	ПропускСФ.ТипСклада
					   |ИЗ
					   |	Справочник.ПропускСФ КАК ПропускСФ
					   |ГДЕ
					   |	(НЕ ПропускСФ.ПометкаУдаления)
					   |	И ПропускСФ.ТипСклада = &ТипСклада
					   |	И ПропускСФ.Дата МЕЖДУ &Дата1 И &Дата2";

		Если Дата1 <> Неопределено Тогда

			Если ПоследнийДок <> Документы[МетаДок.Имя].ПустаяСсылка() Тогда
				
				Запрос.УстановитьПараметр("Дата1", КонецДня(ПоследнийДок.Дата) + 1);
			
			Иначе
				
				Запрос.УстановитьПараметр("Дата1", КонецДня(НачалоГода(ДокументОбъект.Дата)));
			
			КонецЕсли;

			Запрос.УстановитьПараметр("Дата2", КонецДня(ДокументОбъект.Дата));

		КонецЕсли;

		Если Лев(Префикс, 2) = "КБ" Тогда
			
			Запрос.УстановитьПараметр("ТипСклада", Перечисления.ТипСклада.КБСтиль);
		
		Иначе
			
			ТипСклада = ПолучитьРеквизитШапкиСервер(ДокументОбъект.Склад,"ТипСклада");
			 
			Запрос.УстановитьПараметр("ТипСклада", ТипСклада);
		
		КонецЕсли;

		Выборка = Запрос.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			
			КоличествоПропусков = Выборка.КоличествоПропусков + КоличествоПропусков;
		
		КонецЦикла;

	КонецЕсли;

	ДокументОбъект.Номер = СокрЛП(Префикс) + Формат(ПоследнийНомер + 1 + КоличествоПропусков * Коэффициент, "ЧЦ="
		+ ДлинаЧисловойЧасти + "; ЧВН=");

КонецПроцедуры


#КонецОбласти
