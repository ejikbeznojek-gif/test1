// Изменение 0000000060
// Вычисляет дату оплаты на основе параметров расчета. Учитывает дату отгрузки, отсрочку платежа (в том числе банковские дни) и логистическое плечо из договора.
//
// Параметры:
//  ПараметрыРасчета - Структура - параметры для расчета даты оплаты, должна содержать:
//    * ДатаОтгрузки - Дата - дата отгрузки (может быть Неопределено)
//    * ОтсрочкаПлатежа - СправочникСсылка.ОтсрочкиПлатежа - отсрочка платежа (может быть Неопределено)
//    * Договор - СправочникСсылка.Договоры - договор (может быть Неопределено)
//
// Возвращаемое значение:
//  Дата - дата оплаты. Если дата отгрузки не задана, возвращает 01.01.0001
//
Функция ПолучитьДатуОплатыСервер (ПараметрыРасчета) Экспорт            
	
	ДатаОтгрузки	 = ПараметрыРасчета.ДатаОтгрузки; 
	Если ДатаОтгрузки = Неопределено тогда
		ДатаОтгрузки = Дата(1, 1, 1);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыРасчета.ОтсрочкаПлатежа) Тогда
		ДанныеОтсрочкиПлатежа  = ОбщегоНазначенияС.ПолучитьРеквизитыШапкиСервер(ПараметрыРасчета.ОтсрочкаПлатежа, "ВидОтсрочки, Отсрочка, Ссылка", "Справочник");
	Иначе      
		ДанныеОтсрочкиПлатежа = Новый Структура ("ВидОтсрочки, Отсрочка, Ссылка", 
		Перечисления.ВидыОтсрочки.ПустаяСсылка(), 0 , Справочники.ОтсрочкиПлатежа.ПустаяСсылка());	
	КонецЕсли;   
	
	Если ЗначениеЗаполнено(ПараметрыРасчета.Договор) Тогда
		ДанныеДоговора  = ОбщегоНазначенияС.ПолучитьРеквизитыШапкиСервер(ПараметрыРасчета.Договор, "ЛогистическоеПлечо, Ссылка", "Справочник");
	Иначе      
		ДанныеДоговора = Новый Структура ("ЛогистическоеПлечо, Ссылка", 0, Справочники.Договоры.ПустаяСсылка()); 
	КонецЕсли;   
	
	Если ДатаОтгрузки = Дата(1, 1, 1) Тогда
		ДатаОплаты = ДатаОтгрузки;
	Иначе
		Если  ДанныеОтсрочкиПлатежа.ВидОтсрочки = Перечисления.ВидыОтсрочки.БанковскиеДни Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	КалендарьДни.Дата КАК Дата
			|ИЗ
			|	Справочник.Календарь.Дни КАК КалендарьДни
			|ГДЕ
			|	КалендарьДни.Дата >= &ДатаОтгрузки
			|	И КалендарьДни.Часы <> 0
			|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Дата
			|АВТОУПОРЯДОЧИВАНИЕ";
			Запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
			Выборка = Запрос.Выполнить().Выбрать();
			НПП = 0;
			Пока Выборка.Следующий() Цикл		
				Если НПП = ДанныеОтсрочкиПлатежа.Отсрочка Тогда
					Возврат Выборка.Дата;	
				Конецесли;
				НПП = НПП + 1;
			КонецЦикла;
			
			ДатаОплаты = ДатаОтгрузки + ДанныеОтсрочкиПлатежа.Отсрочка * 24 * 60 * 60;		
		Иначе		
			ДатаОплаты =  ДатаОтгрузки + ДанныеОтсрочкиПлатежа.Отсрочка * 24 * 60 * 60;
		КонецЕсли;
	КонецЕсли;
	
	если ДатаОплаты <> Дата(1, 1, 1) тогда
		ДатаОплаты 	= ДатаОплаты + ДанныеДоговора.ЛогистическоеПлечо * 24 * 60 * 60;
	КонецЕсли;          
	
	Возврат ДатаОплаты;
	
КонецФункции

