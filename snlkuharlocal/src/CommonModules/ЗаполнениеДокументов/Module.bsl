Функция БайтовыйКодСимволаСервер(КодировкаПрямая, Символ)
	Возврат КодировкаПрямая[Символ];
КонецФункции // КодСимвола()

Функция СимволПоБайтовомуКодуСервер(КодировкаОбратная, Код)
	Возврат КодировкаОбратная[Код];
КонецФункции // ()

Функция Бинарное(НачЗн)
	Зн=НачЗн;	
	Стр="";	
	Для Сч=1 по 8 Цикл
		Бит=Зн%2;
		
		Стр=""+Бит+Стр;   
		Зн=(Зн-Бит)/2;		
	КонецЦикла;     
	
	Возврат Стр;
КонецФункции //

Функция Десятичное(НачЗн)
	Зн=0;
	База=128;
	
	ТекДлинна=Мин(СтрДлина(НачЗн),8);
	
	Для Сч=1 по ТекДлинна Цикл
		Зн=Зн+База*Число(Сред(НачЗн,Сч,1));					    
		База=База/2;
	КонецЦикла;
	
	Возврат Зн;
КонецФункции //Десятичное

Функция Закодировать64Сервер(НачСтр) Экспорт
	
	СтруктураВозврата = ЗаполнитьКодировки();
	
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=НачСтр;
	
	Остаток=СтрДлина(Стр) % 3;
	НеХватает=?(Остаток=0,0,3-Остаток); 
	
	Для Сч=1 по НеХватает Цикл
		Стр=Стр+" ";	    
	КонецЦикла;	
	    
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		СтрокаБит=СтрокаБит+Бинарное(БайтовыйКодСимволаСервер(СтруктураВозврата.КодировкаПрямая, Сред(Стр,Сч,1)));		
	КонецЦикла;
	
	СтрокаКода="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение="00"+Лев(СтрокаБит,6);
		
		СтрокаКода	=СтрокаКода+Сред(База,Десятичное(БитовоеЗначение)+1,1);			    
		СтрокаБит	=Сред(СтрокаБит,7);
	КонецЦикла;                                                      
	
	Возврат СтрокаКода;	
КонецФункции // 

Функция Раскодировать64Сервер(НачСтр)
	
	СтруктураВозврата = ЗаполнитьКодировки();
	
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=СокрЛП(НачСтр);
	
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		Символ=Сред(Стр,Сч,1);
		Десятичное=Найти(База,Символ)-1;		
		СтрокаБит=СтрокаБит+Сред(Бинарное(Десятичное),3);		
	КонецЦикла;
	              
	СтрокаИсходная="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение=Лев(СтрокаБит,8);
		
		СтрокаИсходная	=СтрокаИсходная+СимволПоБайтовомуКодуСервер(СтруктураВозврата.КодировкаОбратная, Десятичное(БитовоеЗначение));			    
		СтрокаБит		=Сред(СтрокаБит,9);
	КонецЦикла;                      
	
	Возврат СтрокаИсходная;	    
КонецФункции //Раскодировать

