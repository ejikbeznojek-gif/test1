Функция ПолучитьРеквизитыОбъектаСтрокой(Знач ИсточникСсылка) Экспорт
	
	МетаданныеОбъекта = ИсточникСсылка.Метаданные();
	
	ЭтоСправочник = Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка));
	ЭтоПланОбмена = ПланыОбмена.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка));
	ЭтоПланВидовХарактеристик = ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка));
	ЭтоПланВидовРасчета = ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка));
	ЭтоДокумент = (Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка)) ИЛИ БизнесПроцессы.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка)));
	ЭтоЗадача = Задачи.ТипВсеСсылки().СодержитТип(ТипЗнч(ИсточникСсылка));
	
	СписокРеквизитов = "";
	
	Если ЭтоСправочник ИЛИ ЭтоПланОбмена ИЛИ ЭтоПланВидовХарактеристик ИЛИ ЭтоПланВидовРасчета Тогда
		Если МетаданныеОбъекта.ДлинаКода > 0 Тогда
			СписокРеквизитов = "Код,";
		КонецЕсли;
		Если МетаданныеОбъекта.ДлинаНаименования > 0 Тогда
			СписокРеквизитов = СписокРеквизитов + "Наименование,";
		КонецЕсли;
		Если ЭтоСправочник ИЛИ ЭтоПланВидовХарактеристик Тогда
			Если МетаданныеОбъекта.Иерархический Тогда
				СписокРеквизитов = СписокРеквизитов + "Родитель,";
			КонецЕсли;
			Если ЭтоСправочник И (МетаданныеОбъекта.Владельцы.Количество() <> 0) Тогда
				СписокРеквизитов = СписокРеквизитов + "Владелец,";
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЭтоДокумент Тогда
		Если МетаданныеОбъекта.ДлинаНомера > 0 Тогда
			СписокРеквизитов = "Номер,";
		КонецЕсли;
		СписокРеквизитов =  СписокРеквизитов + "Дата,";
	ИначеЕсли ЭтоЗадача Тогда
		Если МетаданныеОбъекта.ДлинаНомера > 0 Тогда
			СписокРеквизитов = "Номер,";
		КонецЕсли;
		СписокРеквизитов =  СписокРеквизитов + "Дата,";
		Если МетаданныеОбъекта.ДлинаНаименования > 0 Тогда
			СписокРеквизитов = СписокРеквизитов + "Наименование,";
		КонецЕсли;
	КонецЕсли;
	
	СписокРеквизитов = СписокРеквизитов + "ПометкаУдаления,";
	
	Для каждого Реквизит Из МетаданныеОбъекта.Реквизиты Цикл
		СписокРеквизитов = СписокРеквизитов + Реквизит.Имя + ",";
	КонецЦикла;

    //Отрезаем последнюю запятую
    СписокРеквизитов = Лев(СписокРеквизитов, СтрДлина(СписокРеквизитов) - 1);
	
	Возврат СписокРеквизитов;
	
КонецФункции
