Функция ПроверкаГТД(Знач Наименование) Экспорт
	
	СтруктураВозврата = Новый Структура("Успех, ТекстОшибки", Ложь, "");
	
	Если СтрДлина(Наименование) = 23 тогда
		СтрДлинаЗначения = СтрДлина(Наименование);
		ПервоеЗначение = Найти(Наименование,"/");
		Если ПервоеЗначение <> 9 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность первого сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;
		ВтороеЗначение = Найти(Прав(Наименование,СтрДлинаЗначения-ПервоеЗначение),"/"); 
		Если ВтороеЗначение <> 7 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность второго сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;
		//Какие то странные ГТД, когда товар сделан в польше, но ввезён из Белорусии
	ИначеЕсли СтрДлина(Наименование) = 20  тогда
		СтрДлинаЗначения = СтрДлина(Наименование);
		ПервоеЗначение = Найти(Наименование,"/");
		Если ПервоеЗначение <> 6 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность первого сегмента ГТД");
			Возврат СтруктураВозврата;                              
		КонецЕсли;
		ВтороеЗначение = Найти(Прав(Наименование,СтрДлинаЗначения-ПервоеЗначение),"/"); 
		Если ВтороеЗначение <> 7 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность второго сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;      
	Иначе
		СтрДлинаЗначения = СтрДлина(Наименование);
		ПервоеЗначение = Найти(Наименование,"/");
		Если ПервоеЗначение <> 9 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность первого сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;
		ВтороеЗначение = Найти(Прав(Наименование,СтрДлинаЗначения-ПервоеЗначение),"/"); 
		Если ВтороеЗначение <> 7 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность второго сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;
		ТретиеЗначение = Найти(Прав(Наименование,СтрДлинаЗначения-ПервоеЗначение-ВтороеЗначение),"/");
		Если ТретиеЗначение <> 8 тогда
			СтруктураВозврата.Вставить("ТекстОшибки", "Проверьте правильность третьего сегмента ГТД");
			Возврат СтруктураВозврата;
		КонецЕсли;
	КонецЕсли;
	
	СтруктураВозврата.Вставить("Успех", Истина);
	Возврат СтруктураВозврата;
	
КонецФункции

#Если Клиент Тогда
Процедура ШкалаВСтрокеСостояния(ТекЗапись, Записей = 1, ПоказыватьПроцент = Истина, ПоказыватьПозицию = Истина, СвойТекстВКонце = "") Экспорт
    Текст = СокрЛП(СвойТекстВКонце);
    Если НЕ Текст = "" Тогда Текст = " " + Текст; КонецЕсли;
    Точки = "....................................................................................................";
    Черточки = "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!";
    Процент = ТекЗапись/Записей * 100;
    Если ПоказыватьПроцент = Истина Тогда
        ПроцентТекст = Формат(Процент, "ЧДЦ=1; ЧН=0,0");
    Иначе
        ПроцентТекст = "";
    КонецЕсли;
    Если ПоказыватьПозицию = Истина Тогда
        Позиция = Формат(ТекЗапись, "ЧН=0; ЧГ=") + "/" + Формат(Записей, "ЧН=0; ЧГ=");
    Иначе
        Позиция = "";
    КонецЕсли;
    Шкала = Лев(Лев(Черточки, Цел(Процент)) + Точки, 100);
    Если ПоказыватьПозицию И ПоказыватьПроцент Тогда
        Состояние(Шкала + " (" + ПроцентТекст + "% - " + Позиция + ")" + Текст);
    ИначеЕсли ПоказыватьПозицию Тогда
        Состояние(Шкала + " (" + Позиция + ")" + Текст);
    ИначеЕсли ПоказыватьПроцент Тогда
        Состояние(Шкала + " (" + ПроцентТекст + "%)" + Текст);
    Иначе
        Состояние(Шкала + Текст);
    КонецЕсли;
КонецПроцедуры
