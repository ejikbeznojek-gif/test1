Функция НайтиСоздатьПроизвольныйДокументОбъект (ВидДокумента,СтруктураРеквизитов=Неопределено,ИскатьСуществующийДокумент=ложь,СтруктураПоискаДокумента=Неопределено,ПерезаполнятьШапкуДокумента=ложь,ИскатьТолькоВОткрытомПериоде=Истина) экспорт
	НовыйДокумент=Неопределено;
	если СтруктураРеквизитов=Неопределено тогда
		СтруктураРеквизитов=новый Структура;
	КонецЕсли;
	
	если ИскатьСуществующийДокумент и СтруктураПоискаДокумента<>Неопределено тогда
		СтарыйДокумент=НайтиСуществуюшийДокументСсылку(ВидДокумента,СтруктураПоискаДокумента,ИскатьТолькоВОткрытомПериоде);
		если СтарыйДокумент<>Неопределено тогда
			НовыйДокумент=СтарыйДокумент.ПолучитьОбъект();
		КонецЕсли;
	КонецЕсли;
	
	если НовыйДокумент=Неопределено тогда
		
		ПерезаполнятьШапкуДокумента=Истина;
		НовыйДокумент=Документы[ВидДокумента].СоздатьДокумент();
		НовыйДокумент.Дата=ТекущаяДата();
		ЗаполнитьШапкуДокумента(НовыйДокумент,ПараметрыСеанса.Пользователь);	
		ЗаполнитьЗначенияСвойств(НовыйДокумент,СтруктураРеквизитов);
		УстановитьНомерДокументаКлиентСервер(НовыйДокумент);
	иначе		
		если ПерезаполнятьШапкуДокумента тогда
			ЗаполнитьЗначенияСвойств(НовыйДокумент,СтруктураРеквизитов);	
		КонецЕсли;		
	КонецЕсли;
	
	
	//////////////////////////////////////////////////////////////////////// 
	//Дальше будут всякие не универсальные куски для отдельных видов
	если ложь тогда НовыйДокумент=документы.РасходнаяНакладная.СоздатьДокумент();КонецЕсли;
	если ВидДокумента = "РасходнаяНакладная" или 
		ВидДокумента = "Перемещение"  или  
		ВидДокумента = "ПриходнаяНакладная"	
		тогда
		
		если ВидДокумента = "Перемещение" тогда 
			ИмяРеквизитаПолучателя="СкладПолучатель";
		иначе
			ИмяРеквизитаПолучателя="Контрагент";
		КонецЕсли;
		
		если не ЗначениеЗаполнено(НовыйДокумент.ПунктДоставки) и ЗначениеЗаполнено(НовыйДокумент.Контрагент)  тогда
			УстановитьПунктДоставкиКлиентСервер(НовыйДокумент,ИмяРеквизитаПолучателя,"ПунктДоставки");		
			если ЗначениеЗаполнено(НовыйДокумент.ПунктДоставки) тогда
				ПунктДоставки_ПриИзмененииКлиентСервер(НовыйДокумент);
			КонецЕсли;
		КонецЕсли;
		если ВидДокумента="РасходнаяНакладная" тогда
			если не ЗначениеЗаполнено(НовыйДокумент.Договор) тогда
				УстановитьДоговорКлиентСервер(НовыйДокумент);
			КонецЕсли;		
			если не ЗначениеЗаполнено(НовыйДокумент.ОтсрочкаПлатежа) тогда
				УстановитьОтсрочкуПлатежаКлиентСервер(НовыйДокумент);	
				
				//Валетов + 30.06.2026 Изменение 0000000060
				//#Если Клиент Тогда
				//	НовыйДокумент.ДатаОплаты =ПолучитьДатуОплаты(НовыйДокумент.ДатаОтгрузки,НовыйДокумент.ОтсрочкаПлатежа);
				//#КонецЕсли
				ПараметрыРасчетаДатыОплаты 	= ОбщегоНазначенияКС.ПолучитьЗаполнитьПараметрыРасчетаДатыОплатыПоДокументу(НовыйДокумент);
				НовыйДокумент.ДатаОплаты 	= ОбщегоНазначенияКС.ПолучитьДатуОплатыПоДокументуКлиентСервер(ПараметрыРасчетаДатыОплаты); 
				//Валетов-
				//Кухарь А.Ю.  21.04.2023 конец
				
				КонецЕсли;		
		КонецЕсли;
	КонецЕсли;	
	возврат НовыйДокумент;
КонецФункции

Функция НайтиСуществуюшийДокументСсылку (ВидДокумента,СтруктураПоискаДокумента,ИскатьТолькоВОткрытомПериоде)
	
	МетаданныеДокумента=Документы[ВидДокумента].ПустаяСсылка().метаданные();
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Док
	|ГДЕ
	|	&ФильтрУсловие=истина";
	НаборноеУсловие="";
	Для Каждого Элемент из СтруктураПоискаДокумента Цикл 
		если ЕстьРеквизитДокумента(Элемент.Ключ,МетаданныеДокумента) тогда
			НаборноеУсловие=НаборноеУсловие+" и "+"Док."+Элемент.Ключ+" = "+"&"+Элемент.Ключ;
			Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);
		КонецЕсли;
	КонецЦикла;
	
	если ИскатьТолькоВОткрытомПериоде тогда
		НаборноеУсловие=НаборноеУсловие+" и Док.Дата>= &ДатаЗапретаРедактирования ";
					//++Ратманов Без задачи
		//запрос.УстановитьПараметр("ДатаЗапретаРедактирования",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());
		запрос.УстановитьПараметр("ДатаЗапретаРедактирования",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());
					//--Ратманов Без задачи
	КонецЕсли;
	
	запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.РасходнаяНакладная КАК Док","Документ."+ВидДокумента+" КАК Док");
	запрос.Текст=СтрЗаменить(запрос.Текст,"&ФильтрУсловие=истина","истина" + НаборноеУсловие);
	выборка=запрос.выполнить().выбрать();
	пока выборка.следующий() цикл
		возврат выборка.Ссылка;
	КонецЦикла;
	
	возврат Неопределено;
КонецФункции
