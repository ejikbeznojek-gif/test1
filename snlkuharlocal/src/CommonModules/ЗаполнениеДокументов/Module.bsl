// Функция производит поиск документа заданного вида, имеющего в реквизите "ДокОснование" значение,
// равное переданной ссылке.
//
// Параметры:
//  ДокСсылка  - ссылка на документ, для которого надо найти подчиненный документ,
//  ВидДокумента - строка, вид документа, по умолчанию "РекламационнаяНакладная"
//
// Возвращаемое значение:
//  Если нашли, то возвращаем ссылку, не нашли - Неопределено
//
Функция НайтиПодчиненныйДокумент(ДокументСсылка, ВидДокумента = "РекламационнаяНакладная", ФлагТолькоПроведенные = Ложь,
								ФлагБезПомеченныхНаУдаление = Ложь) Экспорт
								
	ТекстДокОснование = "ДокОснование";							
	Если ВидДокумента = "РекламационнаяНакладная" Тогда
		ТекстДокОснование = "ЗаявкаНаРекламацию";
	КонецЕсли;

	НайденныйДокумент = Неопределено;
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		
		ИмяДокументаСсылка = ДокументСсылка.Метаданные().Имя;

		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);

		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Ссылка 
		|ИЗ
		|	Документ." + ВидДокумента + " Как Документ
		|
		|ГДЕ
		|	Документ." + ТекстДокОснование + " = &ДокументСсылка
		|   И ТИПЗНАЧЕНИЯ(Документ." + ТекстДокОснование + ") = ТИП(Документ." + ИмяДокументаСсылка + ")";
		
		Если ФлагТолькоПроведенные Тогда
			Запрос.Текст = Запрос.Текст + "
				|	И Документ.Ссылка.Проведен И НЕ Документ.Ссылка.ПометкаУдаления
				|";
		КонецЕсли;
			
		Если ФлагБезПомеченныхНаУдаление Тогда
			Запрос.Текст = Запрос.Текст + "
				|	И НЕ Документ.Ссылка.ПометкаУдаления
				|";
		КонецЕсли;

		УстановитьПривилегированныйРежим(Истина);
		ВыборкаИзЗапроса = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);

		Если ВыборкаИзЗапроса.Следующий() Тогда
			НайденныйДокумент = ВыборкаИзЗапроса.Ссылка;
		КонецЕсли;

	КонецЕсли;

	Возврат НайденныйДокумент;
	
КонецФункции // НайтиПодчиненныйДокумент()

// Функция производит поиск документов заданного вида, имеющего в реквизите "ДокОснование" значение,
// равное переданной ссылке.
//
// Параметры:
//  ДокСсылка  - ссылка на документ, для которого надо найти подчиненный документ,
//  ВидДокумента - строка, вид документа, по умолчанию "РекламационнаяНакладная"
//
// Возвращаемое значение:
//  Если нашли, то возвращаем Массив ссылок, не нашли - Пустой массив
//
Функция НайтиПодчиненныеДокументы(ДокументСсылка, ВидДокумента = "РекламационнаяНакладная", ФлагТолькоПроведенные = Ложь, ФлагБезПомеченныхНаУдаление = Ложь, Упорядочивание = "ВОЗР") Экспорт

	Если ЗначениеНеЗаполнено(ДокументСсылка) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	ТекстДокОснование = "ДокОснование";							
	Если ВидДокумента = "РекламационнаяНакладная" Тогда
		ТекстДокОснование = "ЗаявкаНаРекламацию";
	КонецЕсли;
		
	ИмяДокументаСсылка = ДокументСсылка.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка 
	|ИЗ
	|	Документ." + ВидДокумента + " Как Документ
	|
	|ГДЕ
	|	Документ." + ТекстДокОснование + " = &ДокументСсылка
	|   И ТИПЗНАЧЕНИЯ(Документ." + ТекстДокОснование + ") = ТИП(Документ." + ИмяДокументаСсылка + ")";
	
	Если ФлагТолькоПроведенные Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И Документ.Ссылка.Проведен И НЕ Документ.Ссылка.ПометкаУдаления
		|";
	КонецЕсли;
	
	Если ФлагБезПомеченныхНаУдаление Тогда
		Запрос.Текст = Запрос.Текст + "
		|	И НЕ Документ.Ссылка.ПометкаУдаления
		|";
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	Документ.Дата " + Упорядочивание + "
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка
		ТЗ = Запрос.Выполнить().Выгрузить();
	Исключение
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокОснование", "ДокументОснование");
		ТЗ = Запрос.Выполнить().Выгрузить();	
	КонецПопытки;
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТЗ.Количество() Тогда
		Возврат ТЗ.ВыгрузитьКолонку("Ссылка");
	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	
КонецФункции // НайтиПодчиненныеДокументы()

Функция ЗаполнитьТЧКомплектующие(ДокументОбъект, Продукция = Неопределено, ФлагЗаменятьНоменклатуру = Ложь, ИмяТЧ = "Товары", ТолькоТовар = ложь)  Экспорт
	//++Данилова Е.В. 28.07.2025 HELP-6187 
	Если  ИмяТЧ = неопределено Тогда
	
		ИмяТЧ = "Товары"; 	
	
	КонецЕсли;
	//--Данилова Е.В. 28.07.2025
	ТаблицаКомплектующих = Новый ТаблицаЗначений;
	ТаблицаКомплектующих.Колонки.Добавить("Продукция");
	ТаблицаКомплектующих.Колонки.Добавить("Номенклатура");
	ТаблицаКомплектующих.Колонки.Добавить("Количество");
	//++Данилова Е.В. 28.07.2025 HELP-6187
	//Для Каждого СтрокаТЧ Из ДокументОбъект.Товары Цикл
	Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТЧ] Цикл
	//--Данилова Е.В. 28.07.2025
		Если Продукция <> Неопределено И СтрокаТЧ.Номенклатура <> Продукция Тогда
			Продолжить;
		КонецЕсли;
		ВремТЗ = ПолучитьТаблицуКомплектующих(СтрокаТЧ.Номенклатура);
		Для Каждого СтрокаВремТЗ Из ВремТЗ Цикл
			//++Данилова Е.В. 28.07.2025
			Если ТолькоТовар
				И СтрокаВремТЗ.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
				
				Продолжить;	
			КонецЕсли;
			//--Данилова Е.В. 28.07.2025
			НоваяСтрока = ТаблицаКомплектующих.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаВремТЗ);
			
		КонецЦикла;			
	КонецЦикла;
	
	ТР = Новый ТаблицаЗначений;	
	ТР.Колонки.Добавить("Продукция");
	ТР.Колонки.Добавить("Номенклатура");
	ТР.Колонки.Добавить("Количество");
	ТР.Колонки.Добавить("Всего");
	//++Данилова Е.В. 28.07.2025 HELP-6187
	ЭтоЗаказПоставщику = ТипЗнч(ДокументОбъект) = Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ЗаказПоставщику"); 
	//Для Каждого СтрокаТЧ Из ДокументОбъект.Товары Цикл
	Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТЧ] Цикл
	//--Данилова Е.В. 28.07.2025	
		Если Продукция <> Неопределено И СтрокаТЧ.Номенклатура <> Продукция Тогда
			Продолжить;
		КонецЕсли; 
		//++Данилова Е.В. 11.08.2025 HELP-6187 
		Если ЭтоЗаказПоставщику
			И СтрокаТЧ.Коэффициент = 0 Тогда
		
			СтрокаТЧКоэффициент = 1;  	
		Иначе 
			СтрокаТЧКоэффициент =  СтрокаТЧ.Коэффициент; 
		КонецЕсли;
		//--Данилова Е.В. 11.08.2025
				
		КолвоПродукции	= СтрокаТЧ.Количество * СтрокаТЧКоэффициент; //СтрокаТЧ.Коэффициент;   //Данилова Е.В. 11.08.2025 HELP-6187
		
		СтрокиТаблицыКомплектующих = ТаблицаКомплектующих.НайтиСтроки(Новый Структура("Продукция", СтрокаТЧ.Номенклатура));
		
		Для Каждого СтрокаТаблицыКомплектующих Из СтрокиТаблицыКомплектующих Цикл			
			
			ТекНоменклатура		= СтрокаТаблицыКомплектующих.Номенклатура;
			ТребуемоеКоличество	= КолвоПродукции * СтрокаТаблицыКомплектующих.Количество;
			
			Если ТребуемоеКоличество = 0 Тогда
				Продолжить;
			КонецЕсли;
			//++Данилова Е.В. 27.01.2025
			//Если ТекНоменклатура.Коплектующие.Количество() = 0 Тогда
			Если ТекНоменклатура.Коплектующие.Количество() = 0 
				ИЛИ ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
			//--Данилова Е.В. 27.01.2025
				СтрокаТР = ТР.Добавить();
				СтрокаТР.Продукция		= СтрокаТЧ.Номенклатура;
				СтрокаТР.Номенклатура	= ТекНоменклатура;				
				СтрокаТР.Количество		= ТребуемоеКоличество; 
				//++Данилова Е.В. 18.05.2026 MARK-3615
				Если ЕстьРеквизитТабЧастиДокумента("Всего", ДокументОбъект.Метаданные(), ИмяТЧ)
					И  ЕстьРеквизитТабЧастиДокумента("Цена", ДокументОбъект.Метаданные(), ИмяТЧ)  Тогда
				//--Данилова Е.В. 18.05.2026 
					Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
						СтрокаТР.Всего = СтрокаТР.Количество * СтрокаТЧ.Цена;
					КонецЕсли;
				КонецЕсли; 			 
				// 1. ОБРАБОТКА "ПРОСТОГО ТОВАРА" }
				
			ИначеЕсли (ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
				Или (НЕ ЗначениеЗаполнено(ТекНоменклатура.ВидКомплекта)) Тогда
				
				ТЗПропорций = Новый ТаблицаЗначений;
				ТЗПропорций.Колонки.Добавить("Номенклатура");
				ТЗПропорций.Колонки.Добавить("Количество");
				
				для каждого СтрТЧКМП из ТекНоменклатура.Коплектующие цикл
					СтрПроп=ТЗПропорций.Добавить();
					СтрПроп.Номенклатура=СтрТЧКМП.Номенклатура;
					СтрПроп.Количество=Окр(ТребуемоеКоличество*СтрТЧКМП.Количество/ТекНоменклатура.Коплектующие.Итог("Количество"),0);			
				КонецЦикла;
				если ТЗПропорций.Итог("Количество")<>ТребуемоеКоличество тогда
					СтрДоберём = ТЗПропорций.Получить(ТЗПропорций.Количество()-1);
					СтрДоберём.количество=СтрДоберём.количество+(ТребуемоеКоличество-ТЗПропорций.Итог("Количество"));
				КонецЕсли;
				
				
				ТЗПропорций.Свернуть("Номенклатура","Количество");
				Для каждого СтрТЗПроп из ТЗПропорций цикл
					СтрокаТР=ТР.Добавить();
					СтрокаТР.Продукция 		= СтрокаТЧ.Номенклатура;
					СтрокаТР.Номенклатура	= СтрТЗПроп.Номенклатура;				
					СтрокаТР.Количество		= + СтрТЗПроп.Количество;
					//++Данилова Е.В. 18.05.2026 MARK-3615
					Если ЕстьРеквизитТабЧастиДокумента("Всего", ДокументОбъект.Метаданные(), ИмяТЧ)
						И  ЕстьРеквизитТабЧастиДокумента("Цена", ДокументОбъект.Метаданные(), ИмяТЧ)  Тогда
						//--Данилова Е.В. 18.05.2026
						Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
							СтрокаТР.Всего = СтрТЗПроп.Количество * СтрокаТЧ.Цена;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;	
				// 2. ОБРАБОТКА "АССОРТИТО" }
				
			Иначе
				СообщитьИзМодуля("ВНУТРЕННЯЯ ОШИБКА! Комплекты с Вид комплекта = " + ТекНоменклатура.ВидКомплекта + " не поддерживаются!");					
			КонецЕсли;							
		КонецЦикла;			
	КонецЦикла;	
	
	ТР.Свернуть("Номенклатура, Продукция","Количество, Всего");
	
	Если Продукция <> Неопределено Тогда
		Если ФлагЗаменятьНоменклатуру Тогда
			//++Данилова Е.В. 28.07.2025
			//ТЗТовары = ДокументОбъект.Товары.Выгрузить(, "Номенклатура");
			ТЗТовары = ДокументОбъект[ИмяТЧ].Выгрузить(, "Номенклатура");
			//--Данилова Е.В. 28.07.2025
			ТЗКомплектующие = ДокументОбъект.Комплектующие.Выгрузить(, "Продукция");
			ТЗКомплектующие.Свернуть("Продукция");
			ТЗКомплектующие.Колонки.Найти("Продукция").Имя = "Номенклатура";
			
			ТЗРазница = ЗаполнениеДокументов.РазницаТаблицЗначений(ТЗТовары, ТЗКомплектующие, "Номенклатура");
			
			Для Каждого Стр ИЗ ТЗРазница Цикл
				СтрокиКУдалению = ДокументОбъект.Комплектующие.НайтиСтроки(Новый Структура("Продукция", Стр.Номенклатура));
				Если СтрокиКУдалению.Количество() > 0 Тогда
					Для каждого Строка Из СтрокиКУдалению Цикл 
						ДокументОбъект.Комплектующие.Удалить(Строка); 
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		Иначе
			СтрокиКУдалению = ДокументОбъект.Комплектующие.НайтиСтроки(Новый Структура("Продукция", Продукция));
			Если СтрокиКУдалению.Количество() > 0 Тогда
				Для каждого Строка Из СтрокиКУдалению Цикл 
					ДокументОбъект.Комплектующие.Удалить(Строка); 
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ДокументОбъект.Комплектующие.Очистить();
	КонецЕсли;
	
	Для Каждого СтрокаТР Из ТР Цикл
		Если СтрокаТР.Количество = 0 тогда
			Продолжить;
		КонецЕсли;
		СтрокаТЧ = ДокументОбъект.Комплектующие.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТР);
		// Кухарь А.Ю.  28.09.2022 начало
		//Если ЕстьРеквизитТабЧастиДокумента("КоличествоПродукции", ДокументОбъект.Метаданные(), "Комплектующие") Тогда
		//	СтрокаТЧ.КоличествоПродукции = СтрокаТР.Количество;
		//КонецЕсли;		 
		// Кухарь А.Ю.  28.09.2022 конец

		ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ, ДокументОбъект);
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ДокументОбъект, "ОтВсего");			
	КонецЦикла;	
	
	// Кухарь А.Ю.  13.01.2025 начало
	// https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2527
	если ДокументОбъект.метаданные().имя="РасходнаяНакладная" тогда
		ДокументОбъект.ЗаполнитьКоличествоПродукции();
	КонецЕсли;
	// Кухарь А.Ю.  13.01.2025 конец
	
КонецФункции
//++Данилова Е.В. 15.08.2025
Функция ЗаполнитьТЧКомплектующиеСоСверткой(ДокументОбъект, Продукция = Неопределено, ФлагЗаменятьНоменклатуру = Ложь, ИмяТЧ = "Товары", ТолькоТовар = ложь)  Экспорт
	//++Данилова Е.В. 28.07.2025 HELP-6187 
	Если  ИмяТЧ = неопределено Тогда
	
		ИмяТЧ = "Товары"; 	
	
	КонецЕсли;
	//--Данилова Е.В. 28.07.2025
	ТаблицаКомплектующих = Новый ТаблицаЗначений;
	ТаблицаКомплектующих.Колонки.Добавить("Продукция");
	ТаблицаКомплектующих.Колонки.Добавить("Номенклатура");
	ТаблицаКомплектующих.Колонки.Добавить("Количество");
	//++Данилова Е.В. 28.07.2025 HELP-6187
	//Для Каждого СтрокаТЧ Из ДокументОбъект.Товары Цикл
	ТаблицаТоваров = ДокументОбъект[ИмяТЧ].Выгрузить(); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧТовары.Номенклатура КАК Номенклатура,
		|	ТЧТовары.Количество КАК Количество,
		|	ТЧТовары.Единица КАК Единица,
		|	ТЧТовары.Коэффициент КАК Коэффициент,
		|	ТЧТовары.Цена КАК Цена
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	&Товары КАК ТЧТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТовары.Номенклатура КАК Номенклатура,
		|	СУММА(ВтТовары.Количество) КАК Количество,
		|	ВтТовары.Единица КАК Единица,
		|	МАКСИМУМ(ВтТовары.Коэффициент) КАК Коэффициент,
		|	МАКСИМУМ(ВтТовары.Цена) КАК Цена
		|ИЗ
		|	ВтТовары КАК ВтТовары
		|
		|СГРУППИРОВАТЬ ПО
		|	ВтТовары.Единица,
		|	ВтТовары.Номенклатура";
	
	Запрос.УстановитьПараметр("Товары",ТаблицаТоваров); 
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЧТовары =  РезультатЗапроса.Выгрузить(); 
 
	Для Каждого СтрокаТЧ Из ТЧТовары Цикл //ДокументОбъект[ИмяТЧ] Цикл
	//--Данилова Е.В. 28.07.2025
		Если Продукция <> Неопределено И СтрокаТЧ.Номенклатура <> Продукция Тогда
			Продолжить;
		КонецЕсли;
		ВремТЗ = ПолучитьТаблицуКомплектующих(СтрокаТЧ.Номенклатура);
		Для Каждого СтрокаВремТЗ Из ВремТЗ Цикл
			//++Данилова Е.В. 28.07.2025
			Если ТолькоТовар
				И СтрокаВремТЗ.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
				
				Продолжить;	
			КонецЕсли;
			//--Данилова Е.В. 28.07.2025
			НоваяСтрока = ТаблицаКомплектующих.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаВремТЗ);
			
		КонецЦикла;			
	КонецЦикла;
	
	ТР = Новый ТаблицаЗначений;	
	ТР.Колонки.Добавить("Продукция");
	ТР.Колонки.Добавить("Номенклатура");
	ТР.Колонки.Добавить("Количество");
	ТР.Колонки.Добавить("Всего");
	//++Данилова Е.В. 28.07.2025 HELP-6187
	ЭтоЗаказПоставщику = ТипЗнч(ДокументОбъект) = Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ЗаказПоставщику"); 
	//Для Каждого СтрокаТЧ Из ДокументОбъект.Товары Цикл
	Для Каждого СтрокаТЧ Из ТЧТовары Цикл //ДокументОбъект[ИмяТЧ] Цикл
	//--Данилова Е.В. 28.07.2025	
		Если Продукция <> Неопределено И СтрокаТЧ.Номенклатура <> Продукция Тогда
			Продолжить;
		КонецЕсли; 
		//++Данилова Е.В. 11.08.2025 HELP-6187 
		Если ЭтоЗаказПоставщику
			И СтрокаТЧ.Коэффициент = 0 Тогда
		
			СтрокаТЧКоэффициент = 1;  	
		Иначе 
			СтрокаТЧКоэффициент =  СтрокаТЧ.Коэффициент; 
		КонецЕсли;
		//--Данилова Е.В. 11.08.2025
				
		КолвоПродукции	= СтрокаТЧ.Количество * СтрокаТЧКоэффициент; //СтрокаТЧ.Коэффициент;   //Данилова Е.В. 11.08.2025 HELP-6187
		
		СтрокиТаблицыКомплектующих = ТаблицаКомплектующих.НайтиСтроки(Новый Структура("Продукция", СтрокаТЧ.Номенклатура));
		
		Для Каждого СтрокаТаблицыКомплектующих Из СтрокиТаблицыКомплектующих Цикл			
			
			ТекНоменклатура		= СтрокаТаблицыКомплектующих.Номенклатура;
			ТребуемоеКоличество	= КолвоПродукции * СтрокаТаблицыКомплектующих.Количество;
			
			Если ТребуемоеКоличество = 0 Тогда
				Продолжить;
			КонецЕсли;
			//++Данилова Е.В. 27.01.2025
			//Если ТекНоменклатура.Коплектующие.Количество() = 0 Тогда
			Если ТекНоменклатура.Коплектующие.Количество() = 0 
				ИЛИ ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
			//--Данилова Е.В. 27.01.2025
				СтрокаТР = ТР.Добавить();
				СтрокаТР.Продукция		= СтрокаТЧ.Номенклатура;
				СтрокаТР.Номенклатура	= ТекНоменклатура;				
				СтрокаТР.Количество		= ТребуемоеКоличество;
				Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
					СтрокаТР.Всего = СтрокаТР.Количество * СтрокаТЧ.Цена;
				КонецЕсли;				
				// 1. ОБРАБОТКА "ПРОСТОГО ТОВАРА" }
				
			ИначеЕсли (ТекНоменклатура.ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито)
				Или (НЕ ЗначениеЗаполнено(ТекНоменклатура.ВидКомплекта)) Тогда
				
				ТЗПропорций = Новый ТаблицаЗначений;
				ТЗПропорций.Колонки.Добавить("Номенклатура");
				ТЗПропорций.Колонки.Добавить("Количество");
				
				для каждого СтрТЧКМП из ТекНоменклатура.Коплектующие цикл
					СтрПроп=ТЗПропорций.Добавить();
					СтрПроп.Номенклатура=СтрТЧКМП.Номенклатура;
					СтрПроп.Количество=Окр(ТребуемоеКоличество*СтрТЧКМП.Количество/ТекНоменклатура.Коплектующие.Итог("Количество"),0);			
				КонецЦикла;
				если ТЗПропорций.Итог("Количество")<>ТребуемоеКоличество тогда
					СтрДоберём = ТЗПропорций.Получить(ТЗПропорций.Количество()-1);
					СтрДоберём.количество=СтрДоберём.количество+(ТребуемоеКоличество-ТЗПропорций.Итог("Количество"));
				КонецЕсли;
				
				
				ТЗПропорций.Свернуть("Номенклатура","Количество");
				Для каждого СтрТЗПроп из ТЗПропорций цикл
					СтрокаТР=ТР.Добавить();
					СтрокаТР.Продукция 		= СтрокаТЧ.Номенклатура;
					СтрокаТР.Номенклатура	= СтрТЗПроп.Номенклатура;				
					СтрокаТР.Количество		= + СтрТЗПроп.Количество;
					Если СтрокаТЧ.Номенклатура.ВидКомплекта <> Перечисления.ВидыКомплектов.Комплект Тогда // Если ЭтоПродукцияБезВложенныхКомплектов Тогда
						СтрокаТР.Всего = СтрТЗПроп.Количество * СтрокаТЧ.Цена;
					КонецЕсли;
				КонецЦикла;	
				// 2. ОБРАБОТКА "АССОРТИТО" }
				
			Иначе
				СообщитьИзМодуля("ВНУТРЕННЯЯ ОШИБКА! Комплекты с Вид комплекта = " + ТекНоменклатура.ВидКомплекта + " не поддерживаются!");					
			КонецЕсли;							
		КонецЦикла;			
	КонецЦикла;	
	
	ТР.Свернуть("Номенклатура, Продукция","Количество, Всего");
	
	Если Продукция <> Неопределено Тогда
		Если ФлагЗаменятьНоменклатуру Тогда
			//++Данилова Е.В. 28.07.2025
			//ТЗТовары = ДокументОбъект.Товары.Выгрузить(, "Номенклатура");
			ТЗТовары = ТЧТовары; //ДокументОбъект[ИмяТЧ].Выгрузить(, "Номенклатура");
			//--Данилова Е.В. 28.07.2025
			ТЗКомплектующие = ДокументОбъект.Комплектующие.Выгрузить(, "Продукция");
			ТЗКомплектующие.Свернуть("Продукция");
			ТЗКомплектующие.Колонки.Найти("Продукция").Имя = "Номенклатура";
			
			ТЗРазница = ЗаполнениеДокументов.РазницаТаблицЗначений(ТЗТовары, ТЗКомплектующие, "Номенклатура");
			
			Для Каждого Стр ИЗ ТЗРазница Цикл
				СтрокиКУдалению = ДокументОбъект.Комплектующие.НайтиСтроки(Новый Структура("Продукция", Стр.Номенклатура));
				Если СтрокиКУдалению.Количество() > 0 Тогда
					Для каждого Строка Из СтрокиКУдалению Цикл 
						ДокументОбъект.Комплектующие.Удалить(Строка); 
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		Иначе
			СтрокиКУдалению = ДокументОбъект.Комплектующие.НайтиСтроки(Новый Структура("Продукция", Продукция));
			Если СтрокиКУдалению.Количество() > 0 Тогда
				Для каждого Строка Из СтрокиКУдалению Цикл 
					ДокументОбъект.Комплектующие.Удалить(Строка); 
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ДокументОбъект.Комплектующие.Очистить();
	КонецЕсли;
	
	Для Каждого СтрокаТР Из ТР Цикл
		Если СтрокаТР.Количество = 0 тогда
			Продолжить;
		КонецЕсли;
		СтрокаТЧ = ДокументОбъект.Комплектующие.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТР);
		// Кухарь А.Ю.  28.09.2022 начало
		//Если ЕстьРеквизитТабЧастиДокумента("КоличествоПродукции", ДокументОбъект.Метаданные(), "Комплектующие") Тогда
		//	СтрокаТЧ.КоличествоПродукции = СтрокаТР.Количество;
		//КонецЕсли;		 
		// Кухарь А.Ю.  28.09.2022 конец

		ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ, ДокументОбъект);
		РассчитатьСуммуТабЧасти(СтрокаТЧ, ДокументОбъект, "ОтВсего");			
	КонецЦикла;	
	
	// Кухарь А.Ю.  13.01.2025 начало
	// https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2527
	если ДокументОбъект.метаданные().имя="РасходнаяНакладная" тогда
		ДокументОбъект.ЗаполнитьКоличествоПродукции();
	КонецЕсли;
	// Кухарь А.Ю.  13.01.2025 конец
	
КонецФункции

//--Данилова Е.В. 15.08.2025
Функция ПолучитьТаблицуКомплектующих(Продукция, МассивПродукцииВерхнегоУровня = Неопределено)
	
	ТаблицаКомплектующих = Новый ТаблицаЗначений;
	ТаблицаКомплектующих.Колонки.Добавить("Продукция");
	ТаблицаКомплектующих.Колонки.Добавить("Номенклатура");
	ТаблицаКомплектующих.Колонки.Добавить("Количество");
	
	// чтобы отслеживать ситуацию зацикливания комплектов
	МассивПВУ = Новый Массив;
	Если МассивПродукцииВерхнегоУровня <> Неопределено Тогда
		Для Каждого Элемент Из МассивПродукцииВерхнегоУровня Цикл 
			МассивПВУ.Добавить(Элемент);
		КонецЦикла;
	КонецЕсли;
	МассивПВУ.Добавить(Продукция);
	
	ОбщКолКомп=Продукция.Коплектующие.Итог("Количество");
	
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураКоплектующие.Номенклатура КАК Запчасть,
	|	НоменклатураКоплектующие.Номенклатура.НоменклатураЗамены КАК ЗаменаЗапчасти,
	|	НоменклатураКоплектующие.Ссылка КАК Продукция
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Ссылка = &Продукция";
	запрос.УстановитьПараметр("Продукция",Продукция);
	ТаблицаЗамен=запрос.Выполнить().Выгрузить();
	
	Если (Продукция.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект)
		И (Продукция.Коплектующие.Количество() > 0) Тогда		
		Для Каждого СтрокаТЧ Из Продукция.Коплектующие Цикл
			Комплектующее = СтрокаТЧ.Номенклатура;
			
			СтрокаЗамены=ТаблицаЗамен.Найти(Комплектующее,"Запчасть");
			если СтрокаЗамены<>Неопределено и ЗначениеЗаполнено(СтрокаЗамены.ЗаменаЗапчасти) тогда
				Комплектующее	= СтрокаЗамены.ЗаменаЗапчасти;
			КонецЕсли;				
			Если МассивПВУ.Найти(Комплектующее) <> Неопределено Тогда
				СообщитьИзМодуля("ОШИБКА! Обнаружено зацикливание комплектующих у комплекта """ + МассивПВУ[0] + """!" + Символы.ПС
				+ " - зацикливание возникло на комплектующем """ + Комплектующее + """"
				+ " из вложенного комплекта """ + Продукция + """");
				Продолжить;
			КонецЕсли;
			
			КолвоКомплектующих	= СтрокаТЧ.Количество * СтрокаТЧ.Единица.Коэффициент;
			ВремТЗ				= ПолучитьТаблицуКомплектующих(Комплектующее, МассивПВУ);
			Для Каждого СтрокаВремТЗ Из ВремТЗ Цикл
				НоваяСтрока = ТаблицаКомплектующих.Добавить();
				НоваяСтрока.Продукция		= Продукция;
				НоваяСтрока.Номенклатура	= СтрокаВремТЗ.Номенклатура;			
				НоваяСтрока.Количество		= КолвоКомплектующих * СтрокаВремТЗ.Количество;				
			КонецЦикла;			
		КонецЦикла;				
	Иначе
		НоваяСтрока					= ТаблицаКомплектующих.Добавить();
		НоваяСтрока.Продукция		= Продукция; // МассивПВУ[0];
		НоваяСтрока.Номенклатура	= Продукция;
		НоваяСтрока.Количество		= 1;
	КонецЕсли;
	
	Возврат ТаблицаКомплектующих; 
	
КонецФункции
