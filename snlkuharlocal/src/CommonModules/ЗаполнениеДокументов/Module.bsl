Функция СформироватьСтрокуРеквизитовПоШаблону(Знач ИсточникСсылка, ШаблонРеквизитов = "") Экспорт
	
	СписокРеквизитовИсточника = ПолучитьРеквизитыОбъектаСтрокой(ИсточникСсылка);
	
	СписокРеквизитов = "";
	
	Если НЕ ПустаяСтрока(СписокРеквизитовИсточника) И НЕ ПустаяСтрока(ШаблонРеквизитов) Тогда
		
		МассивШаблонаРеквизитов = РазложитьСтрокуВМассивПодстрок(ШаблонРеквизитов, ",");
		
		Для Каждого ИмяРеквизита ИЗ МассивШаблонаРеквизитов Цикл
			Позиция = Найти(СписокРеквизитовИсточника, ИмяРеквизита);
			Если Позиция <> 0 Тогда
				СписокРеквизитов = СписокРеквизитов + ИмяРеквизита + ",";	
			КонецЕсли;
		КонецЦикла;
		
		//Отрезаем последнюю запятую
    	СписокРеквизитов = Лев(СписокРеквизитов, СтрДлина(СписокРеквизитов) - 1);
		
	КонецЕсли;
	
