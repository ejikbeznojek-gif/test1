Функция СоздатьПеремещение(ДокументСсылка = Неопределено, ТаблицаКЗагрузке, СкладИсточник = Неопределено, СкладПолучатель = Неопределено,
			Комментарий = "", ДополнительныеРеквизиты = Неопределено, Проводить = Истина, СоздаватьНовый = Ложь, ЗаписыватьБезПроверкиФизСкладов = ложь) Экспорт 
			//++Данилова Е.В. 09.10.2025 HELP-5978
	
	Если ТаблицаКЗагрузке.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	Перемещение = СоздатьИзменитьДокумент(ДокументСсылка, "Перемещение",,,СоздаватьНовый);
	Перемещение.Дата = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	Перемещение.ДатаОтгрузки = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	Перемещение.ДатаПриемки = ?(ДокументСсылка = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(ДокументСсылка.Дата));
	
	ЗаполнитьШапкуДокумента(Перемещение,ПараметрыСеанса.Пользователь);
	
	Перемещение.ДокОснование = ?(ДокументСсылка <> Неопределено, ДокументСсылка, Неопределено);
	Перемещение.ЗаявкаНаПерепаковку = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаявкаНаПерепаковку"), ДокументСсылка, Неопределено);
	
	Перемещение.СкладПолучатель = СкладПолучатель; // ДокументСсылка.Склад
	ОбменЭДО.УстановитьПунктДоставкиСб2б(Перемещение,"СкладПолучатель","ПунктДоставки");
	
	Перемещение.Валюта = Справочники.Валюты.НайтиПоКоду("810");
	Перемещение.Курс = 1;
		
	Перемещение.Склад = СкладИсточник;
	Перемещение.Комментарий = ?(СокрЛП(Комментарий) <> "", Комментарий, "Перемещение для Перепаковки" + Строка(ДокументСсылка));
	
	УстановитьНомерДокументаКлиентСервер(Перемещение);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			УстановитьРеквизитШапки(Перемещение, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Перемещение.Товары.Очистить();
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаКЗагрузке Цикл
		
		НоваяСтрока = Перемещение.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		
		Если ТаблицаКЗагрузке.Колонки.Найти("Заявка") = Неопределено Тогда
			НоваяСтрока.Заявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("ПодтвержденнаяЗаявка") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("ПодтвержденнаяЗаявкаПеремещения") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявкаПеремещения = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("Коэффициент") = Неопределено Тогда
			НоваяСтрока.Коэффициент = 1;
		КонецЕсли;
		Если ТаблицаКЗагрузке.Колонки.Найти("Единица") = Неопределено Тогда
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЕсли;
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, Перемещение);
		РассчитатьСуммуТабЧасти(НоваяСтрока, Перемещение);	
		
	КонецЦикла;
    //++Данилова Е.В. 17.10.2025  HELP-5978
	Если ТипЗНЧ(ДополнительныеРеквизиты) = Тип("Структура") 
		И ДополнительныеРеквизиты.Свойство("НеЗаписыватьДокумент") Тогда
	
		Возврат Перемещение; 	
	
	КонецЕсли;
	//--Данилова Е.В. 17.10.2025
	Попытка 
		//++Данилова Е.В. 09.10.2025 HELP-5978
		Если ЗаписыватьБезПроверкиФизСкладов Тогда
			
			Перемещение.ДополнительныеСвойства.Вставить("ЗаписыватьБезПроверкиФизСкладов",истина); 	
			
		КонецЕсли;
		//--Данилова Е.В. 09.10.2025 
		Перемещение.Записать(?(Проводить, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		СообщитьИзМодуля(""+Перемещение); 
		Возврат Перемещение.Ссылка;
	Исключение
		Перемещение.Записать();
		СообщитьИзМодуля(ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция СоздатьКомплектацию(ДокСсылка, ТаблицаТоваров = Неопределено, ТаблицаКомплектующих = Неопределено, ДополнительныеРеквизиты = Неопределено) Экспорт
	
	Если ТаблицаТоваров.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	ДокКомпл = СоздатьИзменитьДокумент(ДокСсылка, "Комплектация");
	
	ЗаполнитьШапкуДокумента(ДокКомпл, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
	
	УстановитьНезаполненныйРеквизитШапки(ДокКомпл,"КодОперации", Перечисления.КодыОперацийОстатки.ЗакупкаР);
	УстановитьНезаполненныйРеквизитШапки(ДокКомпл,"ВидОплаты",ПолучитьЗначениеПоУмолчанию("ОсновнойВидОплаты"));
	
	ДокКомпл.ДокОснование = ДокСсылка;
	ДокКомпл.Склад = ДокСсылка.Склад;
	Если ЗначениеЗаполнено(ДокСсылка.ВходящееПРМТовар) Тогда
		ДокКомпл.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	Иначе
		ДокКомпл.СостояниеНакладной = Перечисления.СостоянияНакладной.ПолученоСкладом;
	КонецЕсли;
	
	УстановитьНомерДокументаКлиентСервер(ДокКомпл);
	ДокКомпл.Комментарий = "Создано документом " + Строка(ДокСсылка);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			ДокКомпл[Элемент.Ключ]=Элемент.Значение;
			//УстановитьНезаполненныйРеквизитШапки(ДокКомпл, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	ДокКомпл.Товары.Очистить();
	
	Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
		НоваяСтрока = ДокКомпл.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
		НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
		НоваяСтрока.Коэффициент = 1;
		НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		НоваяСтрока.Всего = НоваяСтрока.Количество;
		ЗаполнитьКоличествоКомплектующихПоСтроке(НоваяСтрока);
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокКомпл);
		РассчитатьСуммуТабЧасти(НоваяСтрока, ДокКомпл, "ОтВсего");
	КонецЦикла;
	
	////////////////// КОМПЛЕКТУЮЩИЕ /////////////////////////////////////////////////////////////////////////
	
	Если ТаблицаКомплектующих = Неопределено Тогда
		Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
			//++Данилова Е.В. 27.01.2025
			//Если СтрокаТоваров.Номенклатура.Коплектующие.Количество() > 0
			Если СтрокаТоваров.Номенклатура.Коплектующие.Количество() > 0
				И ЗначениеРеквизитаОбъекта(СтрокаТоваров.Номенклатура,"ВидКомплекта") <> Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
			//--Данилова Е.В. 27.01.2025
				// комплект
				Для Каждого СтрокаКомплекта Из СтрокаТоваров.Номенклатура.Коплектующие Цикл
					
					Если СтрокаКомплекта.Количество = 0 Тогда 
						Продолжить; 
					КонецЕсли; 
					
					НоваяСтрока = ДокКомпл.Комплектующие.Добавить();
					НоваяСтрока.Номенклатура = СтрокаКомплекта.Номенклатура;
					НоваяСтрока.Количество	 = СтрокаКомплекта.Количество * СтрокаТоваров.Количество;
					НоваяСтрока.Продукция = СтрокаТоваров.Номенклатура;
					НоваяСтрока.Всего = НоваяСтрока.Количество;
					
				КонецЦикла; 
			Иначе			
				// обычный товар
				НоваяСтрока = ДокКомпл.Комплектующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
				НоваяСтрока.Продукция = СтрокаТоваров.Номенклатура;
				НоваяСтрока.Всего = НоваяСтрока.Количество;
			КонецЕсли;
			
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
			
		КонецЦикла;
	Иначе
		Для Каждого СтрокаТоваров ИЗ ТаблицаКомплектующих Цикл
			НоваяСтрока = ДокКомпл.Комплектующие.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
			НоваяСтрока.Всего = НоваяСтрока.Количество;
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого Стр ИЗ ДокКомпл.Комплектующие Цикл
		ЗаполнитьКоличествоКомплектующихПоСтроке(Стр);
		ПриИзмененииНоменклатурыТабЧасти(Стр, ДокКомпл);
		РассчитатьСуммуТабЧасти(Стр, ДокКомпл, "ОтВсего");
	КонецЦикла;
	
	Попытка
		ДокКомпл.Записать(РежимЗаписиДокумента.Проведение);
		СообщитьИзМодуля(""+ДокКомпл); 
		Возврат ДокКомпл.Ссылка;
	Исключение
		ДокКомпл.Записать();
		СообщитьИзМодуля(""+ДокКомпл); 
		Возврат ДокКомпл.Ссылка;
		//СообщитьИзМодуля(ОписаниеОшибки());
		//Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция СоздатьСписаниеТМЦ(ДокСсылка, ТаблицаТоваров = Неопределено, Комментарий = "", ДополнительныеРеквизиты = Неопределено, Проводить = Ложь) Экспорт
	
	ДокСписание = СоздатьИзменитьДокумент(ДокСсылка, "СписаниеТМЦ");
	
	ЗаполнитьЗначенияСвойств(ДокСписание, ДокСсылка);
	
	ЗаполнитьШапкуДокумента(ДокСписание, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
	
	УстановитьНезаполненныйРеквизитШапки(ДокСписание,"ВидОплаты",	ПолучитьЗначениеПоУмолчанию("ОсновнойВидОплаты"));		
	
	ДокСписание.КодОперации = Перечисления.КодыОперацийОстатки.Списание;	
	ДокСписание.ДокОснование = ДокСсылка;
	
	УстановитьНомерДокументаКлиентСервер(ДокСписание);
	
	Если СокрЛП(Комментарий) <> "" Тогда
		ДокСписание.Комментарий = СокрЛП(Комментарий);
	Иначе
		ДокСписание.Комментарий = "Создано документом " + Строка(ДокСсылка);
	КонецЕсли;
	
	// Шворобей ВЮ 16.01.2023 ++
	Если ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
		Если ЕстьРеквизитДокумента("Подразделение", ДокСсылка.ДокОснование.Метаданные()) Тогда
			ДокСписание.Подразделение = ЗначениеРеквизитаОбъекта(ДокСсылка.ДокОснование, "Подразделение");		
		КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 16.01.2023 ++
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			ДокСписание[Элемент.Ключ]=Элемент.Значение;
		КонецЦикла;
	КонецЕсли;
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	Если ТаблицаТоваров <> Неопределено Тогда
		
		ДокСписание.Товары.Очистить();
		
		Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
			
			НоваяСтрока = ДокСписание.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
			
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
			НоваяСтрока.Коэффициент = 1;
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
			НоваяСтрока.Всего = НоваяСтрока.Количество;
			
			/////////////////////////////////////////////////////////////////////////////////////////////////////
			//    НУЖНО БУДЕТ УСТАНОВИТЬ ЦЕНУ
			/////////////////////////////////////////////////////////////////////////////////////////////////////
			
			НоваяСтрока.Цена = ПолучитьЦенуИзДокументаОснования(НоваяСтрока.Номенклатура, ДокСсылка);
			
			ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокСписание);
			РассчитатьСуммуТабЧасти(НоваяСтрока, ДокСписание);
		КонецЦикла;
		
	КонецЕсли;
	
	// Шворобей ВЮ 08.02.2023 ++
	Если Проводить Тогда
		Попытка
			ДокСписание.Записать(РежимЗаписиДокумента.Проведение);
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		Исключение
			ДокСписание.Записать();
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		КонецПопытки;
	Иначе
		Попытка
			ДокСписание.Записать();
			СообщитьИзМодуля("" + ДокСписание);
			Возврат ДокСписание.Ссылка;
		Исключение
			СообщитьИзМодуля("" + ОписаниеОшибки());
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	// Шворобей ВЮ 08.02.2023 ++
	
КонецФункции

Функция СоздатьРасходнуюНакладную(ДокСсылка = Неопределено, ТаблицаТоваров, ДополнительныеРеквизиты = Неопределено,
	//Добавился входящий параметр ИспользоватьДокОснование
	Проводить = Ложь, Комментарий = "", ОтгрузкаКомплектов = Ложь, СоздаватьНовый = Ложь, ЗаполнитьДопОбработки = Ложь,
	ИспользоватьДокОснование = Истина) Экспорт
	
	Если ТаблицаТоваров.Количество() = 0 Тогда Возврат Неопределено; КонецЕсли;
	
	ДокРасходнаяНакладная = СоздатьИзменитьДокумент(ДокСсылка, "РасходнаяНакладная", , , СоздаватьНовый);
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	МетаданныеДокСсылка = Неопределено;
	МетаданныеДокСсылка = ?(ДокСсылка <> Неопределено, ДокСсылка.Метаданные(), Неопределено);
	
	ЕстьРеквизитОснование = Ложь; ЕстьРеквизитПунктДоставки = Ложь;
	Если МетаданныеДокСсылка <> Неопределено Тогда
		ЕстьРеквизитОснование = ЕстьРеквизитДокумента("ДокОснование", МетаданныеДокСсылка);
		ЕстьРеквизитПунктДоставки = ЕстьРеквизитДокумента("ПунктДоставки", МетаданныеДокСсылка);
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	// Кухарь А.Ю.  04.09.2024 начало
	// 	Если ДокСсылка <> Неопределено И ЕстьРеквизитОснование И ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
	Если ДокСсылка <> Неопределено И ЕстьРеквизитОснование И ЗначениеЗаполнено(ДокСсылка.ДокОснование) и ИспользоватьДокОснование Тогда
		// Кухарь А.Ю.  04.09.2024 конец	
		ЗаполнитьЗначенияСвойств(ДокРасходнаяНакладная, ДокСсылка.ДокОснование);
	ИначеЕсли ДокСсылка <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ДокРасходнаяНакладная, ДокСсылка);
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////
	
	ЗаполнитьШапкуДокумента(ДокРасходнаяНакладная, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
	
	ДокРасходнаяНакладная.ДокОснование =  ?(ДокСсылка = Неопределено, Неопределено, ДокСсылка);
	ДокРасходнаяНакладная.Комментарий = ?(СокрЛП(Комментарий) <> "", Комментарий, "Создано документом " + Строка(ДокСсылка));
	
	УстановитьНомерДокументаКлиентСервер(ДокРасходнаяНакладная);
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			УстановитьРеквизитШапки(ДокРасходнаяНакладная, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	///////////// ОБЯЗАТЕЛЬНОЕ ЗАПОЛНЕНИЕ РЕКВИЗИТОВ ////////////////////////////////////////////////////////
	
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.СостояниеНакладной) Тогда
		ДокРасходнаяНакладная.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ТипЦен) Тогда
		ДокРасходнаяНакладная.ТипЦен = ДокРасходнаяНакладная.Контрагент.ТипЦен;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ТипЦенРаспродажа) Тогда
		ДокРасходнаяНакладная.ТипЦенРаспродажа = ДокРасходнаяНакладная.Контрагент.ТипЦенРаспродажа;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки) Тогда
		Если ЕстьРеквизитПунктДоставки И ЗначениеЗаполнено(ДокСсылка.ПунктДоставки) Тогда
			ДокРасходнаяНакладная.ПунктДоставки = ДокСсылка.ПунктДоставки;
		Иначе
		     ДокРасходнаяНакладная.ПунктДоставки = УстановитьПунктДоставкиСервер(ДокРасходнаяНакладная);
			Если ДокРасходнаяНакладная.ПунктДоставки = Неопределено ИЛИ
				ДокРасходнаяНакладная.ПунктДоставки = Справочники.ПунктыДоставки.ПустаяСсылка() Тогда
				СообщитьИзМодуля("Не удалось заполнить Пункт Доставки");
				Возврат Неопределено;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки) И ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.ОтсрочкаПлатежа) Тогда
		ДокРасходнаяНакладная.ОтсрочкаПлатежа = ДокРасходнаяНакладная.ПунктДоставки.ОтсрочкаПлатежа;
	Иначе
		ДокРасходнаяНакладная.ОтсрочкаПлатежа = ДокРасходнаяНакладная.Договор.ОтсрочкаПлатежа;
	КонецЕсли;
	
	// Шворобей ВЮ 11.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396
	// Передадим через ДополнительныеРеквизиты
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ДатаОтгрузки) Тогда
		ДокРасходнаяНакладная.ДатаОтгрузки = ?(ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") И ДополнительныеРеквизиты.Свойство("ДатаОтгрузки"),
			ДополнительныеРеквизиты.ДатаОтгрузки,
			ДокРасходнаяНакладная.Дата);
	КонецЕсли;
	// Шворобей ВЮ 11.06.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5396
	
	Если НЕ ЗначениеЗаполнено(ДокРасходнаяНакладная.ДатаОплаты) Тогда
		Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ДатаОтгрузки) И ЗначениеЗаполнено(ДокРасходнаяНакладная.ОтсрочкаПлатежа) Тогда
			//Валетов + 30.06.2026 Изменение 0000000060
				//ДокРасходнаяНакладная.ДатаОплаты = ПолучитьДатуОплатыСервер(ДокРасходнаяНакладная.ДатаОтгрузки, ДокРасходнаяНакладная.ОтсрочкаПлатежа);
				ПараметрыРасчетаДатыОплаты 			= ОбщегоНазначенияКС.ПолучитьЗаполнитьПараметрыРасчетаДатыОплатыПоДокументу(ДокРасходнаяНакладная);
				ДокРасходнаяНакладная.ДатаОплаты 	= ОбщегоНазначенияКС.ПолучитьДатуОплатыПоДокументуКлиентСервер(ПараметрыРасчетаДатыОплаты); 
			//Валетов-
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки) Тогда
	
		Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.РайонДоставки) Тогда
			ДокРасходнаяНакладная.РайонДоставки = ДокРасходнаяНакладная.ПунктДоставки.РайонДоставки;			
		КонецЕсли;	
		Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.Регион) Тогда
			ДокРасходнаяНакладная.Регион = ДокРасходнаяНакладная.ПунктДоставки.Регион;			
		КонецЕсли;
		
		Если ДокРасходнаяНакладная.ПунктДоставки.ТипДоставки = Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда
			ДокРасходнаяНакладная.ТранспортнаяКомпания = ?(ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.ТраспортнаяКомпания), ДокРасходнаяНакладная.ПунктДоставки.ТраспортнаяКомпания, Неопределено);
			ДокРасходнаяНакладная.ПунктПерегруза = ?(ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.ПунктПерегруза), ДокРасходнаяНакладная.ПунктДоставки.ПунктПерегруза, Неопределено);
		Иначе
			ДокРасходнаяНакладная.ТранспортнаяКомпания = Неопределено;	
			ДокРасходнаяНакладная.ПунктПерегруза = Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.Грузополучатель) Тогда
			ДокРасходнаяНакладная.Грузополучатель = ДокРасходнаяНакладная.ПунктДоставки.Грузополучатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ДокРасходнаяНакладная.ПунктДоставки.Получатель) Тогда
			ДокРасходнаяНакладная.Получатель = ДокРасходнаяНакладная.ПунктДоставки.Получатель;		
		КонецЕсли;
		
	КонецЕсли;
	
	///////////// ОБЯЗАТЕЛЬНОЕ ЗАПОЛНЕНИЕ РЕКВИЗИТОВ ////////////////////////////////////////////////////////
	
	////////////////// ТОВАРЫ ///////////////////////////////////////////////////////////////////////////////
	
	ДокРасходнаяНакладная.Товары.Очистить();
	
	Для Каждого СтрокаТоваров ИЗ ТаблицаТоваров Цикл
		
		НоваяСтрока = ДокРасходнаяНакладная.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
		
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.СтавкаНДС) Тогда
			НоваяСтрока.СтавкаНДС = ПолучитьРеквизитРодителя(НоваяСтрока.Номенклатура,"СтавкаНДС");
		КонецЕсли;
		
		Если ТаблицаТоваров.Колонки.Найти("Коэффициент") = Неопределено Тогда
			НоваяСтрока.Коэффициент = 1;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("Единица") = Неопределено Тогда
			НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("Заявка") = Неопределено Тогда
			НоваяСтрока.Заявка = НоваяСтрока.Количество;
		КонецЕсли;
		Если ТаблицаТоваров.Колонки.Найти("ПодтвержденнаяЗаявка") = Неопределено Тогда
			НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		КонецЕсли;
		
		/////////////////////////////////////////////////////////////////////////////////////////////////////
		//    НУЖНО БУДЕТ УСТАНОВИТЬ ЦЕНУ
		/////////////////////////////////////////////////////////////////////////////////////////////////////
		
		Если ДокСсылка <> Неопределено И ЕстьРеквизитОснование И ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
			НоваяСтрока.Цена = ПолучитьЦенуИзДокументаОснования(НоваяСтрока.Номенклатура, ДокСсылка);
		ИначеЕсли ДокСсылка <> Неопределено И НЕ ИспользоватьДокОснование Тогда
			НоваяСтрока.Цена = ПолучитьЦенуИзВходящегоДокумента(НоваяСтрока.Номенклатура, ДокСсылка);
		КонецЕсли;
		
		НоваяСтрока.Всего = НоваяСтрока.Количество * НоваяСтрока.Цена;
		
		ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ДокРасходнаяНакладная);
		РассчитатьСуммуТабЧасти(НоваяСтрока, ДокРасходнаяНакладная);
		
	КонецЦикла;
	
	ДокРасходнаяНакладная.ОтгрузкаКомплектов = ОтгрузкаКомплектов;
	ДокРасходнаяНакладная.Комплектующие.Очистить();
	
	Если ОтгрузкаКомплектов Тогда
		ЗаполнениеДокументов.ЗаполнитьТЧКомплектующие(ДокРасходнаяНакладная);	
	КонецЕсли;
	
	ДокРасходнаяНакладная.ДопОбработки.Очистить();
	
	ЗаполнитьУпаковку = Ложь;
	
	Если ЗаполнитьДопОбработки Тогда
		Если ДокРасходнаяНакладная.ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
			Для Каждого СтрокаТЧ Из ДокРасходнаяНакладная.Контрагент.ВидыДопОбработок Цикл
				СтрокаДО = ДокРасходнаяНакладная.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
				//++Данилова Е.В. 15.01.2025
				//Если СтрокаДО.ВидДопОбработки.РассчитыватьУпаковку Тогда
				Если ТребуетсяУпаковкаПоДопОбработке(СтрокаТЧ.ДопОбработка) Тогда
					//--Данилова Е.В. 15.01.2025
					ЗаполнитьУпаковку = Истина;
				КонецЕсли;
			КонецЦикла;
		Иначе
			Для Каждого СтрокаТЧ Из ДокРасходнаяНакладная.ПунктДоставки.ВидыДопОбработок Цикл
				СтрокаДО = ДокРасходнаяНакладная.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
				//++Данилова Е.В. 15.01.2025
				//Если СтрокаДО.ВидДопОбработки.РассчитыватьУпаковку Тогда
				Если ТребуетсяУпаковкаПоДопОбработке(СтрокаТЧ.ДопОбработка) Тогда
				//--Данилова Е.В. 15.01.2025
					ЗаполнитьУпаковку = Истина;
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	ДокРасходнаяНакладная.Упаковка.Очистить();
	
	Если ЗаполнитьУпаковку Тогда
		ТЗУпаковки = ПолучитьТЗУпаковки(ДокРасходнаяНакладная.Товары.Выгрузить(,"Номенклатура,Количество"), ДокРасходнаяНакладная.Контрагент);
		Для Каждого СтрокаТЗ ИЗ ТЗУпаковки Цикл
			Если СтрокаТЗ.ДопОбработка <> Справочники.ВидыДопОбработки.ПустаяСсылка() Тогда
				Если ДокРасходнаяНакладная.ДопОбработки.Найти(СтрокаТЗ.ДопОбработка)=Неопределено тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
					
			Если СтрокаТЗ.Количество = 0 Тогда Продолжить; КонецЕсли;
			
			НоваяСтрока = ДокРасходнаяНакладная.Упаковка.Добавить();
			НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
			НоваяСтрока.Количество = СтрокаТЗ.Количество;
			НоваяСтрока.ПодтвержденнаяЗаявка = СтрокаТЗ.Количество;		
		КонецЦикла;
	КонецЕсли; 
	//++Данилова Е.В. 17.10.2025  HELP-5978
	Если ТипЗНЧ(ДополнительныеРеквизиты) = Тип("Структура") 
		И ДополнительныеРеквизиты.Свойство("НеЗаписыватьДокумент") Тогда
	
		Возврат ДокРасходнаяНакладная; 	
	
	КонецЕсли;
	//--Данилова Е.В. 17.10.2025
	
	Попытка
		// Шворобей ВЮ 29.11.2022 ++
		Если Проводить Тогда
			ДокРасходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ДокРасходнаяНакладная.ОбменДанными.Загрузка = Истина;
			ДокРасходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		// Шворобей ВЮ 29.11.2022 ++
		СообщитьИзМодуля("" + ДокРасходнаяНакладная);
		Возврат ДокРасходнаяНакладная.Ссылка;
	Исключение
		СообщитьИзМодуля(ОписаниеОшибки());
		Возврат Неопределено;	
	КонецПопытки;
	
КонецФункции
//++Данилова Е.В. 15.01.2025
Функция ТребуетсяУпаковкаПоДопОбработке(ДопОбработка)  Экспорт
	
	Если ДопОбработка.Код = "OD7-00103" 
		ИЛИ  ДопОбработка.Код = "OD7-00126"
		ИЛИ ДопОбработка.Код = "OD7-00128"
		ИЛИ ДопОбработка.Код = "OD7-00127"
		ИЛИ ДопОбработка.Код = "OD7-00104"
		ИЛИ ДопОбработка.Код = "OD7-00113"
		ИЛИ ДопОбработка = Справочники.ВидыДопОбработки.ОтгрузкаУпаковкиОтдельно 
		ИЛИ ДопОбработка.РассчитыватьУпаковку  Тогда
		
		Возврат Истина;	 
		
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции
//--Данилова Е.В. 15.01.2025

Функция СоздатьДокументРекламационнаяНакладная(ДокСсылка, ДополнительныеРеквизиты = Неопределено, Проводить = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда Возврат Неопределено; КонецЕсли;
	
	ДокРекламация = СоздатьИзменитьДокумент(ДокСсылка, "РекламационнаяНакладная");
	Если ДокРекламация <> Неопределено Тогда
		
		ЗаполнитьШапкуДокумента(ДокРекламация, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Покупка");
		
		ДокРекламация.Заполнить(ДокСсылка);
		
		Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
			Для Каждого Элемент из ДополнительныеРеквизиты Цикл
				//УстановитьНезаполненныйРеквизитШапки(ДокРекламация, Элемент.Ключ, Элемент.Значение);
				Если ЕстьРеквизитДокумента(Элемент.Ключ, ДокРекламация.Метаданные()) Тогда
					ДокРекламация[Элемент.Ключ] = Элемент.Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Попытка
			Если Проводить Тогда
				ДокРекламация.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				ДокРекламация.ОбменДанными.Загрузка = Истина;
				ДокРекламация.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			СообщитьИзМодуля("" + Строка(ДокРекламация));
			Возврат ДокРекламация.Ссылка;		
		Исключение
			ДокРекламация.ОбменДанными.Загрузка = Истина;
			ДокРекламация.Записать(РежимЗаписиДокумента.Запись);
			СообщитьИзМодуля(ОписаниеОшибки());
			Возврат ДокРекламация.Ссылка;
		КонецПопытки;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СоздатьИзменитьДокумент(ДокСсылка = Неопределено, ВидДокумента = "РекламационнаяНакладная", ФлагТолькоПроведенные = Ложь, ФлагБезПомеченныхНаУдаление = Истина, СоздаватьНовый = Ложь) Экспорт
	
	Если ДокСсылка = Неопределено ИЛИ СоздаватьНовый Тогда
		НовыйДок = Неопределено;
	Иначе
		НовыйДок = ЗаполнениеДокументов.НайтиПодчиненныйДокумент(ДокСсылка, ВидДокумента, ФлагТолькоПроведенные, ФлагБезПомеченныхНаУдаление);
	КонецЕсли;
	
	Если НовыйДок = Неопределено Тогда
		НовыйДокОбъект = Документы[ВидДокумента].СоздатьДокумент();
		НовыйДокОбъект.Дата = ТекущаяДатаСеанса();
		КодИБ = ПараметрыСеанса.ЭтотУзел.Код;
		НовыйДокОбъект.УстановитьНовыйНомер(КодИБ + "-");		
	Иначе
		НовыйДокОбъект = НовыйДок.ПолучитьОбъект();
	КонецЕсли;
	
	Возврат НовыйДокОбъект;
	
КонецФункции

Функция ПолучитьЦенуИзДокументаОснования(Номенклатура, ДокСсылка, ИмяТабличнойЧастиДокументаСсылка = "Товары", ИмяТабличнойЧастиДокументаОснования = "Товары") Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка.ДокОснование) Тогда
		Возврат 0;
	КонецЕсли;
	
	ИмяДокументаСсылка = ДокСсылка.Метаданные().Имя;
	ИмяДокументаОснования = ДокСсылка.ДокОснование.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЧ.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(ТЧ_Основание.Цена, 0)) КАК Цена
	|ИЗ
	|	Документ." + ИмяДокументаСсылка + "." + ИмяТабличнойЧастиДокументаСсылка + " КАК ТЧ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ." + ИмяДокументаОснования + "." + ИмяТабличнойЧастиДокументаОснования + " КАК ТЧ_Основание
	|		ПО ТЧ.Номенклатура = ТЧ_Основание.Номенклатура
	|ГДЕ
	|	ТЧ.Ссылка = &ДокСсылка
	|	И ТЧ.Номенклатура = &Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧ.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЦенуИзВходящегоДокумента(Номенклатура, ДокСсылка, ИмяТабличнойЧастиДокументаСсылка = "Товары") Экспорт
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Возврат 0;
	КонецЕсли;
	
	Если НЕ ЕстьРеквизитТабЧастиДокумента("Цена", ДокСсылка.Метаданные(), "Товары") Тогда
		Возврат 0;
	КонецЕсли;
	
	ИмяДокументаСсылка = ДокСсылка.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЧ.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(ТЧ.Цена, 0)) КАК Цена
	|ИЗ
	|	Документ." + ИмяДокументаСсылка + "." + ИмяТабличнойЧастиДокументаСсылка + " КАК ТЧ
	|ГДЕ
	|	ТЧ.Ссылка = &ДокСсылка
	|	И ТЧ.Номенклатура = &Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧ.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

