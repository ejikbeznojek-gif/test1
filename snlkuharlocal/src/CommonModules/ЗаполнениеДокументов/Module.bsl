// Возврат Истина - нашли недопустимый символ, Ложь - всё хорошо!
Функция НайтиНедопустимыеСимволыКодаМаркировки(Знач ИсходныйТекст) Экспорт
	
	ДопустимыеСимволыСтрока = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!%&’'()*+,-./_:;=<>?""";
	
	ИсходныйТекст = СокрЛП(ИсходныйТекст);
	
	Для Индекс = 1 по СтрДлина(ИсходныйТекст) Цикл
		
		ТекущийСимвол = Сред(ИсходныйТекст, Индекс, 1);
		
		Если Найти(ДопустимыеСимволыСтрока, ТекущийСимвол) = 0 Тогда
			Возврат Истина;	
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

