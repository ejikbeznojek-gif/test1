Функция УстановитьПунктДоставкиСервер(ДокументОбъект, ИмяРеквизитаКонтрагент = "Контрагент", ИмяРеквизитаПД = "ПунктДоставки") Экспорт
	
	Контрагент = ДокументОбъект[ИмяРеквизитаКонтрагент];
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЕстьРеквизитДокумента("ОсновнойПунктДоставки",Контрагент.Метаданные()) И ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект[ИмяРеквизитаПД] = Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПДСервер(Контрагент) = 1 Тогда		
			Выборка = Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД] = Выборка.Ссылка;			
			КонецЦикла;
		ИначеЕсли ИмяРеквизитаКонтрагент = "СкладПолучатель" Тогда
			Выборка = Справочники.ПунктыДоставки.Выбрать(,Контрагент,,"Наименование Убыв");
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД] = Выборка.Ссылка;			
			КонецЦикла;
		Иначе
			ДокументОбъект[ИмяРеквизитаПД] = Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект[ИмяРеквизитаПД] = Неопределено;		
	КонецЕсли;
	
	Возврат ДокументОбъект[ИмяРеквизитаПД];
	
КонецФункции//УстановитьПунктДоставкиСервер(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент")

Функция КоличествоПДСервер(Контрагент) Экспорт
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	Владелец = &Владелец";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;		
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции // КоличествоПДСервер(Контрагент)

Функция ПолучитьДатуОплатыСервер(ДатаОтгрузки, ОтсрочкаПлатежа)  Экспорт
	
	Если   ДатаОтгрузки = '00010101000000' Тогда
		Возврат  '00010101000000'
	Иначе
		Если  ОтсрочкаПлатежа.ВидОтсрочки = Перечисления.ВидыОтсрочки.БанковскиеДни Тогда
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
			Запрос.Текст = "ВЫБРАТЬ
			|	КалендарьДни.Дата КАК Дата
			|ИЗ
			|	Справочник.Календарь.Дни КАК КалендарьДни
			|ГДЕ
			|	КалендарьДни.Дата >= &ДатаОтгрузки
			|	И КалендарьДни.Часы <> 0
			|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Дата
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			
			Выборка = Запрос.Выполнить().Выбрать();
			НПП = 0;
			Пока Выборка.Следующий() Цикл
				Если НПП = ОтсрочкаПлатежа.Отсрочка Тогда
					Возврат Выборка.Дата;	
				Конецесли;
				НПП = НПП + 1;
			КонецЦикла;
			
			Возврат ДатаОтгрузки + ОтсрочкаПлатежа.Отсрочка*24*60*60;		
		Иначе		
			Возврат ДатаОтгрузки + ОтсрочкаПлатежа.Отсрочка*24*60*60;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

