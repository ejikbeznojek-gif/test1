Функция ПодразделениеПродажПоМенеджеру(Знач Менеджер) Экспорт 

	Если ТипЗнч(Менеджер) = Тип("СправочникСсылка.ФизическиеЛица")
		И ЗначениеЗаполнено(Менеджер) Тогда
		
		Если ЗначениеЗаполнено(Менеджер.ПодразделениеПродаж) Тогда
			
			Возврат Менеджер.ПодразделениеПродаж; 	
			
		КонецЕсли;
		
		Возврат Менеджер.Подразделение; 
		
	Иначе 
		Возврат Справочники.Подразделения.ПустаяСсылка(); 
	КонецЕсли;	

КонецФункции // ПодразделениеПродажПоМенеджеру()

