Процедура ПроверитьДокументыСклад()   Экспорт
	
	
	СЗ = Новый СписокЗначений;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	КоличествоЗаписей.Колво КАК Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.ЗаданиеНабора КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			РезервыТМЦ.Регистратор КАК Регистратор,
