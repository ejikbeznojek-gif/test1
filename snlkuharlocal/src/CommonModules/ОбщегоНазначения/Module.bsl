	//			ДЗР_Авансы = Константы.ДатаЗапретаРедактированияРНКпоАвансовымДоговорам.Получить();
	//			Если ДатаЗапрета < ДЗР_Авансы Тогда
	//				ДатаЗапрета = ДЗР_Авансы;							
	//			КонецЕсли;			
	//		КонецЕсли;			
