//Кухарь А.Ю. 22.01.2026 начало   
// HELP-8550
//Функция РаскодироватьЛистИКоробкуИзСтроки(Данные) Экспорт    
Функция РаскодироватьЛистИКоробкуИзСтроки(знач Данные) Экспорт    
//Кухарь А.Ю. 22.01.2026 конец
	
	
	Данные = СтрЗаменить(Данные, "¶", "");
	
	СтруктураВозврата = Новый Структура("Успех, Ошибки, Лист, НомерКоробки", Ложь, Новый Массив, Неопределено, 0);
	
	// Кельманов А.В. - SNL-66 - 2025.12.24 {
	Если Лев(Данные, 4) = "{""##" Тогда
		
		Данные = Прав(Данные, СтрДлина(Данные) - 4);
		
		ПозицияНачалаЗадвоеннойСтроки = СтрНайти(Данные, "{""##");
		
		Если ПозицияНачалаЗадвоеннойСтроки > 0 Тогда
			
			Данные = Лев(Данные, ПозицияНачалаЗадвоеннойСтроки - 1);
			
		КонецЕсли;
		
		ПозицияРазделителя = СтрНайти(Данные, "##");
		
		Если ПозицияРазделителя = 0 Тогда
			
			СтруктураВозврата.Ошибки.Добавить("Не удалось раскодировать строку. Отсутствует разделитель ##. " + Данные);
			
			Возврат СтруктураВозврата;
			
		КонецЕсли;
		
		ПодстрокаЛист = Лев(Данные, ПозицияРазделителя - 1);
		
		УИД_Листа = Новый УникальныйИдентификатор(ПодстрокаЛист);
		
		Лист_Ссылка = Документы.ЛистНабора.ПолучитьСсылку(УИД_Листа);
		
		Лист_Объект = Лист_Ссылка.ПолучитьОбъект();
		
		Если Лист_Объект = Неопределено Тогда
			
			Лист_Ссылка = Документы.ЛистПереукладки.ПолучитьСсылку(УИД_Листа);
			
			Лист_Объект = Лист_Ссылка.ПолучитьОбъект();
			
			Если Лист_Объект = Неопределено Тогда
				
				СтруктураВозврата.Ошибки.Добавить("Строка не содержит ссылку на ЛН или ЛП");
				
				Возврат СтруктураВозврата;
								
			КонецЕсли;   
			
		КонецЕсли;
		
		ПодстрокаНомерКоробки = Прав(Данные, СтрДлина(Данные) - ПозицияРазделителя - 1);
		
		Попытка
			
			НомерКоробки = Число(ПодстрокаНомерКоробки);
			
		Исключение
			
			СтруктураВозврата.Ошибки.Добавить("Некорректно задан номер коробки");
			
			Возврат СтруктураВозврата;
								
		КонецПопытки;
		
		СтруктураВозврата.Успех = Истина;	
		СтруктураВозврата.Лист = Лист_Ссылка;
		СтруктураВозврата.НомерКоробки = НомерКоробки;
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	// Кельманов А.В. - SNL-66 - 2025.12.24 }
	
	Попытка
		
		МассивДанных = ЗначениеИзСтрокиВнутр(Данные);
		
	Исключение   
		
		СтруктураВозврата.Ошибки.Добавить("Не удалось раскодировать строку. " + Данные);
		
		Возврат СтруктураВозврата;
		
	КонецПопытки;
	
	Если ТипЗнч(МассивДанных) <> Тип("Массив") Тогда
		
		СтруктураВозврата.Ошибки.Добавить("Строка не содержит массива данных");
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	Если МассивДанных.Количество() <> 2 Тогда  
		
		СтруктураВозврата.Ошибки.Добавить("Массив содержит неправильное количество данных");
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	Если ТипЗнч(МассивДанных[0]) <> Тип("ДокументСсылка.ЛистНабора") 
		И ТипЗнч(МассивДанных[0]) <> Тип("ДокументСсылка.ЛистПереукладки") 
		Тогда             
		
		СтруктураВозврата.Ошибки.Добавить("Массив не содержит ЛН или ЛП");
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;   
	
	Если ТипЗнч(МассивДанных[1]) <> Тип("Число") Тогда 
		
		СтруктураВозврата.Ошибки.Добавить("Массив не содержит номера коробки");
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;      
	
	СтруктураВозврата.Успех = Истина;	
	СтруктураВозврата.Лист = МассивДанных[0];
	СтруктураВозврата.НомерКоробки = МассивДанных[1];
	
	Возврат СтруктураВозврата;
	
КонецФункции  
