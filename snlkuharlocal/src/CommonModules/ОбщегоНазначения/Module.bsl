				СостояниеНакладной <> Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда	
				
				МожноВыводитьОбщееКоличествоМест = Ложь;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ДопПараметрыНакладной <> Неопределено И ДопПараметрыНакладной.ОтгрузкаFBS = Истина И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеПаллетирования И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеДопОбработки И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.ДопОбработка И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.Паллетирование И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеТермоусадки И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.Термоусадка И
			СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена И 	
			СостояниеНакладной <> Перечисления.СостоянияНакладной.ГотоваКОтгрузке Тогда
			
			МожноВыводитьОбщееКоличествоМест = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если МожноВыводитьОбщееКоличествоМест Тогда	
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	СУММА(ЕСТЬNULL(ЛистНабора.КоличествоКоробок, 0)) КАК КоличествоКоробок
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабора
		|ГДЕ
		|	ЛистНабора.Проведен
		|	И ЛистНабора.ДокОснование = &ДокОснование";
		
		// Кельманов А.В. - SNL-120 - 2026.04.16 {
		Если ЭтоЛП Тогда
			
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛистНабора", "ЛистПереукладки"); 
			
		КонецЕсли;
		// Кельманов А.В. - SNL-120 - 2026.04.16 }
		
		Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.КоличествоКоробок = Null Тогда 
				
				Продолжить;
				
			КонецЕсли;
			
			КолКоробок = КолКоробок + Выборка.КоличествоКоробок;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Для Каждого СтрТЗ Из СтруктураКоробок Цикл
		
		СтруктураРеквизитов = Новый Структура("НомерКоробки, ВсегоКоробок, КоличествоВКоробке, НаименованиеНоменклатуры, QRКод", "", "", "", "", "");
		
		СтруктураРеквизитов.НомерКоробки = СтрТЗ.НомерКоробки;
		СтруктураРеквизитов.НаименованиеНоменклатуры = СтрТЗ.Номенклатура;
		СтруктураРеквизитов.QRКод = ЗакодироватьЛистИКоробкуВСтроку(ЛН, СтрТЗ.НомерКоробки);
		
		Если ЛН.ТипШК <> Перечисления.ТипыШтрихКодов.Коробка Тогда
			
			СтруктураРеквизитов.КоличествоВКоробке = ЛН.Товары.Итог("Количество");
			
		КонецЕсли;
		
		Если ТипЗнч(СтрТЗ.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
			
			Если ЗначениеЗаполнено(СтрТЗ.ШтукВКоробке) Тогда
				ШтукВКоробке = СтрТЗ.ШтукВКоробке;
			Иначе
				ШтукВКоробке = СтрТЗ.Номенклатура.Родитель.ШтукВКоробке;
			КонецЕсли;
			
			Если ШтукВКоробке > 0 Тогда
				СтруктураРеквизитов.КоличествоВКоробке = ШтукВКоробке;
			КонецЕсли;
			
		КонецЕсли;
		
		Если МожноВыводитьОбщееКоличествоМест И СтрТЗ.НомерКоробки = КолКоробок Тогда			
			
			СтруктураРеквизитов.ВсегоКоробок = КолКоробок;
			
		КонецЕсли;
		
		МассивРеквизитов.Добавить(СтруктураРеквизитов);
		
	КонецЦикла;
	
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(МассивРеквизитов), Новый СжатиеДанных(9)));
	
	Возврат Ответ;
	
КонецФункции

// Кельманов А.В. - SNL-122 - 2026.03.19
Функция ПроверитьОтсканированныйИдКоробки(ШК) Экспорт

	Ошибки = "";
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ИДКоробок.ИДКоробки КАК ИДКоробки,
	               |	ИДКоробок.ЛистНабора КАК ЛистНабора,
	               |	ИДКоробок.ДатаЗаписи КАК ДатаЗаписи
	               |ИЗ
	               |	РегистрСведений.ИДКоробок КАК ИДКоробок
	               |ГДЕ
	               |	ИДКоробок.ИДКоробки = &ИДКоробки";
	
	Запрос.УстановитьПараметр("ИДКоробки", ШК);
	
	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		
		Ошибки = "ID коробки " + ШК + " уже был ранее отсканирован";
		
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции

Функция Сериализовать(ОбъектСериализации) Экспорт
	ДеревоВОбъектеXDTO = СериализаторXDTO.ЗаписатьXDTO(ОбъектСериализации);
	МойXML = Новый ЗаписьXML;
	МойXML.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(МойXML, ДеревоВОбъектеXDTO);
	Возврат МойXML.Закрыть();
КонецФункции

Функция Десериализовать(XMLСтруктураСериализованногоОбъекта)
	ЧтениеXMLДанных = Новый ЧтениеXML;
	ЧтениеXMLДанных.УстановитьСтроку(XMLСтруктураСериализованногоОбъекта);
	ТЗ = СериализаторXDTO.ПрочитатьXML(ЧтениеXMLДанных);
	ЧтениеXMLДанных.Закрыть();  
	Возврат ТЗ;
КонецФункции

