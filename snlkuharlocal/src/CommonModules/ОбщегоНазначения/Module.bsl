//Получение таблица деклараций с учётом того, что они могут быть указаны на элемент, а не только на модель
Функция ПолучитьТаблицуДекларацийПоМассивуНоменклатуры (МассивНоменклатуры,Дата) экспорт
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	Номенклатура.Родитель КАК Модель,
	|	Номенклатура.Родитель.ТипТовара КАК РодительТипТовара
	|ПОМЕСТИТЬ ТЗНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&СписокНоменклатуры)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(т1.НоменклатураИзДекларацииЭлемент, т1.НоменклатураИзДекларацииГруппа) КАК НоменклатураСертификата,
	|	ЕСТЬNULL(т1.СертификатЭлемент, т1.СертификатГруппа) КАК Сертификат,
	|	т1.ТипТовара КАК ТипТовара,
	|	ЕСТЬNULL(т1.НоменклатураНачальнаяЭлемент, т1.НоменклатураНачальнаяГруппа) КАК НоменклатураНачальная,
	|	МАКСИМУМ(т1.ПризнакДекларацииНаЭлемент) КАК ПризнакДекларацииНаЭлемент,
	|	ЕСТЬNULL(т1.ПериодЭлементы, т1.ПериодГруппы) КАК ПериодСертификата
	|ПОМЕСТИТЬ ТЗДекларацийСдублями
	|ИЗ
	|	(ВЫБРАТЬ
	|		ИсторияСрезПоследних.Значение КАК СертификатЭлемент,
	|		ИсторияСрезПоследних.Объект КАК НоменклатураИзДекларацииЭлемент,
	|		NULL КАК НоменклатураИзДекларацииГруппа,
	|		ТЗНоменклатуры.РодительТипТовара КАК ТипТовара,
	|		NULL КАК СертификатГруппа,
	|		ТЗНоменклатуры.Номенклатура КАК НоменклатураНачальнаяЭлемент,
	|		NULL КАК НоменклатураНачальнаяГруппа,
	|		ИСТИНА КАК ПризнакДекларацииНаЭлемент,
	|		ИсторияСрезПоследних.Период КАК ПериодЭлементы,
	|		NULL КАК ПериодГруппы
	|	ИЗ
	|		ТЗНоменклатуры КАК ТЗНоменклатуры
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.История.СрезПоследних(&Дата2, Реквизит = ""Декларация"") КАК ИсторияСрезПоследних
	|			ПО ТЗНоменклатуры.Номенклатура = ИсторияСрезПоследних.Объект
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		NULL,
	|		NULL,
	|		ИсторияСрезПоследних.Объект,
	|		ТЗНоменклатуры.РодительТипТовара,
	|		ИсторияСрезПоследних.Значение,
	|		ТЗНоменклатуры.Номенклатура,
	|		ТЗНоменклатуры.Номенклатура,
	|		ЛОЖЬ,
	|		NULL,
	|		ИсторияСрезПоследних.Период
	|	ИЗ
	|		ТЗНоменклатуры КАК ТЗНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.История.СрезПоследних(&Дата2, Реквизит = ""Декларация"") КАК ИсторияСрезПоследних
	|			ПО ТЗНоменклатуры.Модель = ИсторияСрезПоследних.Объект) КАК т1
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(т1.НоменклатураИзДекларацииЭлемент, т1.НоменклатураИзДекларацииГруппа),
	|	ЕСТЬNULL(т1.СертификатЭлемент, т1.СертификатГруппа),
	|	т1.ТипТовара,
	|	ЕСТЬNULL(т1.НоменклатураНачальнаяЭлемент, т1.НоменклатураНачальнаяГруппа),
	|	ЕСТЬNULL(т1.ПериодЭлементы, т1.ПериодГруппы)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗДекларацийСдублями.НоменклатураСертификата КАК НоменклатураСертификата,
	|	ТЗДекларацийСдублями.НоменклатураНачальная КАК НоменклатураНачальная,
	|	МАКСИМУМ(ТЗДекларацийСдублями.ПериодСертификата) КАК ПериодСертификата,
	|	ТЗДекларацийСдублями.ПризнакДекларацииНаЭлемент КАК ПризнакДекларацииНаЭлемент
	|ПОМЕСТИТЬ МаксимумыДатСертификатов
	|ИЗ
	|	ТЗДекларацийСдублями КАК ТЗДекларацийСдублями
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЗДекларацийСдублями.НоменклатураСертификата,
	|	ТЗДекларацийСдублями.НоменклатураНачальная,
	|	ТЗДекларацийСдублями.ПризнакДекларацииНаЭлемент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаксимумыДатСертификатов.НоменклатураСертификата КАК НоменклатураСертификата,
	|	МаксимумыДатСертификатов.НоменклатураНачальная КАК НоменклатураНачальная,
	|	МаксимумыДатСертификатов.ПериодСертификата КАК ПериодСертификата,
	|	МаксимумыДатСертификатов.ПризнакДекларацииНаЭлемент КАК ПризнакДекларацииНаЭлемент,
	|	ТЗДекларацийСдублями.Сертификат КАК Сертификат,
