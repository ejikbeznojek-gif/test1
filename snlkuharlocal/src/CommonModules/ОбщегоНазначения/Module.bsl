Функция НайтиПунктДоставки(ГлнПунктаДоставки) Экспорт
	
	ПунктДоставкиН = Справочники.ПунктыДоставки.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	аа.Ссылка КАК Ссылка,
	|	аа.Владелец КАК Владелец,
	|	аа.комментарий КАК комментарий
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПунктыДоставки.Ссылка КАК Ссылка,
	|		ПунктыДоставки.Ссылка.Владелец КАК Владелец,
	|		ВЫРАЗИТЬ(ПунктыДоставки.Комменатрий КАК СТРОКА(100)) КАК комментарий
	|	ИЗ
	|		Справочник.ПунктыДоставки.ИЛН КАК ПунктыДоставки
	|	ГДЕ
	|		ПунктыДоставки.КодИЛН = &ТекКод
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПунктыДоставки.Ссылка,
	|		ПунктыДоставки.Ссылка.Владелец,
	|		""""
	|	ИЗ
	|		Справочник.ПунктыДоставки КАК ПунктыДоставки
	|	ГДЕ
	|		ПунктыДоставки.КодИЛН = &ТекКод) КАК аа
	|
	|УПОРЯДОЧИТЬ ПО
	|	комментарий";
	
	Запрос.УстановитьПараметр("ТекКод", СокрЛП(ГлнПунктаДоставки));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ПунктДоставкиН = Выборка.Ссылка;
		
	КонецЕсли; 
	
	Возврат ПунктДоставкиН;
	
КонецФункции 



