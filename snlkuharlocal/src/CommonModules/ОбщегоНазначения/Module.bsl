Функция ОпределитьПараметрыСкладаКомиссионера(СкладКомиссионера) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПунктыДоставки.Ссылка КАК ПунктДоставки,
	|	ПунктыДоставки.Владелец КАК Контрагент
	|ИЗ
	|	Справочник.ПунктыДоставки КАК ПунктыДоставки
	|ГДЕ
	|	ПунктыДоставки.СкладКомиссия = &СкладКомиссия
	|	И НЕ ПунктыДоставки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("СкладКомиссия",СкладКомиссионера);
	ПараметрыСкладаКомиссионера  = Новый Структура;
	
	Выборка = запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПараметрыСкладаКомиссионера.Вставить("Контрагент",Выборка.Контрагент);
		ПараметрыСкладаКомиссионера.Вставить("ПунктДоставки",Выборка.ПунктДоставки);
	Иначе
		ПараметрыСкладаКомиссионера.Вставить("Контрагент",Справочники.Контрагенты.ПустаяСсылка());
		ПараметрыСкладаКомиссионера.Вставить("ПунктДоставки",Справочники.ПунктыДоставки.ПустаяСсылка());
	КонецЕсли;
	Возврат ПараметрыСкладаКомиссионера;
КонецФункции

