Функция ПолучитьДатуЗапретаРедактирования(Ссылка,Знач Пользователь=Неопределено) Экспорт
	Пользователь=?(Пользователь=Неопределено,ПараметрыСеанса.Пользователь,Пользователь);	
	
	ПериодРедактирования					=ПолучитьПолномочиеПользователя("ПериодРедактированияДокументов",Пользователь);	
	ПерсональнаяДатаЗапретаРедактирования	=ПолучитьПолномочиеПользователя("ПерсональнаяДатаЗапретаРедактирования",Пользователь);	
	
	МетаДок=Ссылка.Метаданные();
	
	ВидДокумента=МетаДок.Имя;
	
	ПериодРедактирования=ПолучитьПериодРедактированияПоПользователю(Пользователь,ВидДокумента,ПериодРедактирования);	 	
	
	Если ЕстьРеквизитДокумента("Склад",МетаДок) Тогда
		КонстантаЗапрета=Макс(Ссылка.Склад.ДатаЗапретаРедактирования,Константы.ДатаЗапретаРедактирования.Получить());
	Иначе
		КонстантаЗапрета=Константы.ДатаЗапретаРедактирования.Получить();	
	КонецЕсли;	
	
	ДатаЗапрета=Макс(?(ПериодРедактирования=0,КонстантаЗапрета,ТекущаяДата()-ПериодРедактирования*24*60*60),КонстантаЗапрета);
	
	Если НЕ ЗначениеНеЗаполнено(ПерсональнаяДатаЗапретаРедактирования) Тогда
		ДатаЗапрета=Мин(ПерсональнаяДатаЗапретаРедактирования,ДатаЗапрета);	
