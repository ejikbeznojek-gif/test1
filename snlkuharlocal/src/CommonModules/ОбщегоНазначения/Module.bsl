		//	Сдвиг=Сдвиг+24*60*60;
		если ДеньНедели(Документ.ДатаОтгрузки+Сдвиг+Документ.ПунктДоставки.ДнейВпути*24*60*60)=6 и не ГрузимВСубботу тогда
			Сдвиг=Сдвиг+2*24*60*60;
		ИначеЕсли ДеньНедели(Документ.ДатаОтгрузки+Сдвиг+Документ.ПунктДоставки.ДнейВпути*24*60*60)=7 и не ГрузимВВоскресенье тогда
			Сдвиг=Сдвиг+24*60*60;
			
			//Кухарь 10.06.16 	
		КонецЕсли;
		
		возврат Сдвиг;
		
		
	КонецЕсли;
	
	
	
	
	
