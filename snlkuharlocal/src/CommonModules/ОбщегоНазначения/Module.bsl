		Возврат ТекстОповещения;
		
	КонецЕсли;
	// Кельманов А.В. - ИЗМ-0000000164 - 2026.06.16 }

	ВидДокументаОснования = ДокОснование.Метаданные().Имя;
	
	ДопПараметрыНакладной = Неопределено;
	
	Если ВидДокументаОснования = "РасходнаяНакладная" Тогда
		
		ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(ДокОснование);
		
	КонецЕсли;
	
	РеквизитыДокОснования = ПолучитьРеквизитыШапки(ДокОснование, "СостояниеНакладной", "Документ");
	
	СостояниеНакладной = РеквизитыДокОснования.СостояниеНакладной;
	
	// Кельманов А.В. - SNL-120 - 2026.04.16 {
	//СтруктураКоробок = ПолучитьСписокШКкоробокЛистаНабора(ЛН, Истина);
	ДанныеДляПерезаполнения = Неопределено;
	ЛНОбъект = ЛН.ПолучитьОбъект();

	// Кельманов А.В. - Оптимизация работы - 2026.04.23 {
	Если Не ЭтоЛП Тогда
		
		ЛНОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим", Истина);
		
	КонецЕсли;
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 }

	// Кельманов А.В. - 0000000966 - 2026.06.09 {
	//СтруктураКоробок = ПолучитьСписокШКкоробокЛистаНабора(ЛНОбъект, Истина, ДанныеДляПерезаполнения);
	СтруктураКоробок = ПолучитьСписокШКкоробокЛистаНабора(ЛНОбъект, Истина, ДанныеДляПерезаполнения, Ложь);
	// Кельманов А.В. - 0000000966 - 2026.06.09 }

	Обработки.ПечатьЛистаНабора.ПерезаполнитьНомераКоробок(ЛНОбъект, ДанныеДляПерезаполнения);
	// Кельманов А.В. - SNL-120 - 2026.04.16 }
	
	МожноВыводитьОбщееКоличествоМест = Истина;
	КолКоробок = 0;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ПланНабора.Ссылка КАК ПланНабора
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	ПланНабора.Проведен
	|	И ПланНабора.Накладная = &ДокОснование";	
	
	Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	
	Выборка = Запрос.Выполнить().Выбрать();       
	
	Пока Выборка.Следующий() Цикл
		
		ПланНабора = Выборка.ПланНабора.ПолучитьОбъект();
		
		ТЗБР = ПланНабора.тБрэндов.Выгрузить();
		ТЗБР.Свернуть("Состояние, СекторХранения");	 
		
		Для Каждого СтрТЗБР Из ТЗБР Цикл			
			
			Если ПолучитьНомерСостоянияНакладной(СтрТЗБР.Состояние, СтрТЗБР.СекторХранения = "2") < 800 Тогда				 
				МожноВыводитьОбщееКоличествоМест = Ложь;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если МожноВыводитьОбщееКоличествоМест Тогда		
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита КАК ЗначениеРеквизита
		|ИЗ
		|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
		|ГДЕ
		|	РеквизитыРНКПНКПРМ.Документ = &Документ
		|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = ""СмешаннаяНакладная""";
		
		Запрос.УстановитьПараметр("Документ", ДокОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.ЗначениеРеквизита = Истина И
				СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеПаллетирования И
