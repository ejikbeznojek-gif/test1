Функция ДополнитьРеестрСканированияДаннымиСТСД(ДанныеСканирования) Экспорт
	
	Ошибки = "";
	
	МассивДанныхСканирования = Десериализовать(Десериализовать(ДанныеСканирования).Получить());
	
	МассивОшибок = Новый Массив;
	
	Если МассивДанныхСканирования <> Неопределено Тогда
		
		Для Каждого ЭлементДанныхСканирования Из МассивДанныхСканирования Цикл
			
			ШтрихКод = ЭлементДанныхСканирования.ШтрихКод;
			ДокументСканирования = ЭлементДанныхСканирования.ДокументСканирования;  

			ДопПараметры = Новый Структура;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ИД_Записи) Тогда
				ДопПараметры.Вставить("ИД_Записи", ЭлементДанныхСканирования.ИД_Записи);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ФизЛицо) Тогда
				ДопПараметры.Вставить("ФизЛицо", ЭлементДанныхСканирования.ФизЛицо);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.РабочееМесто) Тогда
				ДопПараметры.Вставить("РабочееМесто", Справочники.РабочиеМеста.НайтиПоНаименованию(ЭлементДанныхСканирования.РабочееМесто));
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.Знак) Тогда
				ДопПараметры.Вставить("Знак", ЭлементДанныхСканирования.Знак);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.СостояниеСканера) Тогда
				ДопПараметры.Вставить("СостояниеСканера", ЭлементДанныхСканирования.СостояниеСканера);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.Дата) Тогда
				ДопПараметры.Вставить("Дата", ЭлементДанныхСканирования.Дата);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.КодировкаШК) Тогда
				ДопПараметры.Вставить("КодировкаШК", ЭлементДанныхСканирования.КодировкаШК);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ТипШК) Тогда
				ДопПараметры.Вставить("ТипШК", ЭлементДанныхСканирования.ТипШК);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.НазначениеШК) Тогда
				ДопПараметры.Вставить("НазначениеШК", Справочники.НазначенияШК[ЭлементДанныхСканирования.НазначениеШК]);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ДанныеПоШК) Тогда
				ДопПараметры.Вставить("ДанныеПоШК", ЭлементДанныхСканирования.ДанныеПоШК);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ТекстОшибки) Тогда
				ДопПараметры.Вставить("ТекстОшибки", ЭлементДанныхСканирования.ТекстОшибки);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ДопИнфо) Тогда
				ДопПараметры.Вставить("ДопИнфо", ЭлементДанныхСканирования.ДопИнфо);
			КонецЕсли;
			
			// Кельманов А.В. - SNL-196 - 2026.04.14 {
			Если ЭлементДанныхСканирования.Свойство("ДокументЗадание") И ЗначениеЗаполнено(ЭлементДанныхСканирования.ДокументЗадание) Тогда
				
				ДопПараметры.Вставить("ДокументЗадание", ЭлементДанныхСканирования.ДокументЗадание);
				
			Иначе
				
				Если ЗначениеЗаполнено(ЭлементДанныхСканирования.ДокументСканирования) Тогда
					
					Если ТипЗнч(ЭлементДанныхСканирования.ДокументСканирования) = Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ")
						И ЗначениеЗаполнено(ЭлементДанныхСканирования.ДокументСканирования.ДокОснование) Тогда
						
						ДопПараметры.Вставить("ДокументЗадание", ЭлементДанныхСканирования.ДокументСканирования.ДокОснование);
						
					ИначеЕсли ТипЗнч(ЭлементДанныхСканирования.ДокументСканирования) = Тип("ДокументСсылка.ЛистПереукладки") 
						И ЗначениеЗаполнено(ЭлементДанныхСканирования.ДокументСканирования.ЗаданиеНаАгрегацию) Тогда
						
						ДопПараметры.Вставить("ДокументЗадание", ЭлементДанныхСканирования.ДокументСканирования.ЗаданиеНаАгрегацию);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			// Кельманов А.В. - SNL-196 - 2026.04.14 }
			
			Попытка
				
				ЗаписатьФактСканирования_Временная(ШтрихКод, ДокументСканирования, ДопПараметры);
				
			Исключение                                   
				
				ТекстСообщения = СтрШаблон("Ошибка записи пика ! ШК: '%1', док-т: '%2', ошибка: '%3' !", СокрЛП(ШтрихКод), ДокументСканирования, ОписаниеОшибки());
				
				МассивОшибок.Добавить(ТекстСообщения);
				
			КонецПопытки;
					
		КонецЦикла;
		
	КонецЕсли;
	
	Если МассивОшибок.Количество() > 0 Тогда
		
		Ошибки = СтрСоединить(МассивОшибок, Символы.ПС);
		
	КонецЕсли;
		
	Возврат Ошибки;
	
КонецФункции

// Кельманов А.В. - ASU-2700 - 2026.02.03
Функция ЗаписатьФактСканирования_Временная(ШтрихКод, ДокументСканирования, ДопПараметры = Неопределено) Экспорт
	
	НазначениеШК = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "НазначениеШК");

	Если НазначениеШК = Неопределено Тогда
		НазначениеШК = Маркировка_ПИ.ПолучитьНазначениеПоШК(ШтрихКод);
	КонецЕсли;
	
	Накладная = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Накладная");
	
	Если Не ЗначениеЗаполнено(Накладная) Тогда
		Накладная = МаркировкаС.НакладнаяПоДокументуСканирования(ДокументСканирования);	
	КонецЕсли; 

	// Кельманов А.В. - SNL-119 - 2026.03.16 {
	//ИД_Записи = Новый УникальныйИдентификатор(МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ИД_Записи"));
	ПараметрИД_Записи = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ИД_Записи");
	
	Если ПараметрИД_Записи = Неопределено Тогда
		ИД_Записи = Новый УникальныйИдентификатор;
	Иначе
		ИД_Записи = Новый УникальныйИдентификатор(ПараметрИД_Записи);
	КонецЕсли;
	// Кельманов А.В. - SNL-119 - 2026.03.16 }	
	
	Запись = РегистрыСведений.РеестрСканирования.СоздатьМенеджерЗаписи();
	
	Запись.ИД_Записи = ИД_Записи;
	
	Запись.Прочитать();
	
	Если Не Запись.Выбран() Тогда
		
		Запись.ИД_Записи = ИД_Записи;
		Запись.Автор = ПараметрыСеанса.Пользователь;
		Запись.ФизЛицо = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ФизЛицо");
		Запись.РабочееМесто = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "РабочееМесто");
		Запись.Знак = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Знак");
		Запись.СостояниеСканера = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "СостояниеСканера");
		Запись.ДокументСканирования = ДокументСканирования;
		Запись.Накладная = Накладная;
		Запись.Дата = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Дата");
		Запись.КодировкаШК = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "КодировкаШК");
		Запись.ТипШК = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТипШК");	
		Запись.НазначениеШК	= НазначениеШК;
		Запись.ДанныеПоШК = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДанныеПоШК");
		Запись.ШтрихКод = ШтрихКод;	
		Запись.ТекстОшибки = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТекстОшибки"); 
		Запись.ДопИнфо = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДопИнфо");
		Запись.ДокументЗадание = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДокументЗадание"); // Кельманов А.В. - SNL-196 - 2026.04.14
		
		Запись.Записать(Ложь);
		
	КонецЕсли;
		
КонецФункции

