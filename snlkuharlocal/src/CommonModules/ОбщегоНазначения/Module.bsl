					Сдвиг=Сдвиг+2*24*60*60;
				ИначеЕсли ДеньНедели(Документ.ДатаОтгрузки+Сдвиг+Документ.ПунктДоставки.ДнейВпути*24*60*60)=7 и не ГрузимВВоскресенье тогда
					Сдвиг=Сдвиг+24*60*60;
					
					//Кухарь 10.06.16 	
				КонецЕсли;
				возврат Сдвиг;
			КонецЕсли;
		КонецЦикла;
		Сдвиг=(тз.Получить(0).Значение+7-ДеньНедели(Документ.ДатаОтгрузки))*24*60*60;
		//Кухарь 10.06.16 начало
		//У некоторых в субботу принимают, им на будние дни не перекидываем
		//если ДеньНедели(Документ.ДатаОтгрузки+Сдвиг+Документ.ПунктДоставки.ДнейВпути*24*60*60)=6 тогда
		//	Сдвиг=Сдвиг+2*24*60*60;
