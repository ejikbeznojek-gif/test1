Функция ПолучитьТекстZPLИзPDFПоНомеруЗаказа(НомерЗаказа) Экспорт
	
	СтруктураВозврата = Новый Структура("ZPL, Ошибки", "", "");
	
	КаталогФайловОзон = "\\srvfile-sk\FBS";
	КаталогФайловОзонZPL = КаталогФайловОзон + "\Ozon-ZPL-TXT";
	
	ИмяФайлаTXT = КаталогФайловОзонZPL + "\" + НомерЗаказа + ".txt";
	
	ФайлTXT = Новый Файл(ИмяФайлаTXT);
	
	Если ФайлTXT.Существует() Тогда
		
		Текст = Новый ЧтениеТекста(ИмяФайлаTXT);
		ZPL = Текст.Прочитать();	
		
		Если ZPL <> Неопределено Тогда
			
			СтруктураВозврата.ZPL = ZPL;
			
		Иначе
			
			СтруктураВозврата.Ошибки = "Не удалось прочитать текст ZPL для этикетки по номеру заказа " + НомерЗаказа + "!";
			
		КонецЕсли;
		
	Иначе
		
		СтруктураВозврата.Ошибки = "Для номера заказа " + НомерЗаказа + " не найден файл этикетки!";
		
	КонецЕсли;
	
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураВозврата), Новый СжатиеДанных(9)));
	
	Возврат Ответ;
	
