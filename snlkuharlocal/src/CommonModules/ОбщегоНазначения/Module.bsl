Функция СформСписокПолучат(ТипРассылки, ОбъектРассылки = Неопределено, ФлагРассылки = "РассылкиЭлПочта") Экспорт
	
	СписокПолучат = Новый СписокЗначений;
	
	// Кухарь А.Ю. 05.08.2024 начало
	// ДУ=?(ЗначениеЗаполнено(ОбъектРассылки)," И РассылкиЭлПочтаПолучателиУведомлений.Ссылка.ОбъектРассылки = &ОбъектРассылки ","");
	ДУ=?(ЗначениеЗаполнено(ОбъектРассылки)," И Рассылки.Ссылка.ОбъектРассылки = &ОбъектРассылки ","");	 
	// Кухарь А.Ю. 05.08.2024 конец
	
	
	Запрос = Новый Запрос;
	
	Если ФлагРассылки = "ФизЛицаРазрешениеОтгрузки" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка КАК Сотрудник,
		|	ФизическиеЛица.ЕМэйл КАК СотрудникЕМэйл
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.РазрешениеОтгрузки
		|АВТОУПОРЯДОЧИВАНИЕ
		|";
		
	ИначеЕсли ФлагРассылки = "РассылкиЭлПочта" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Рассылки.Сотрудник.ЕМэйл КАК СотрудникЕМэйл
		|ИЗ
		|	Справочник.РассылкиЭлПочта.ПолучателиУведомлений КАК Рассылки
		|ГДЕ
		|	Рассылки.Ссылка.ТипРассылки = &ТипРассылки
		|	"+ДУ+"
		|";
		
		Запрос.УстановитьПараметр("ТипРассылки",ТипРассылки);
		
		Если ЗначениеЗаполнено(ОбъектРассылки) Тогда
			Запрос.УстановитьПараметр("ОбъектРассылки",ОбъектРассылки);
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Выб = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выб.Следующий() Цикл
		Мыло = Выб.СотрудникЕМэйл;
		Если ЗначениеЗаполнено(Мыло) Тогда
			СписокПолучат.Добавить(Мыло);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат СписокПолучат;
	
КонецФункции
