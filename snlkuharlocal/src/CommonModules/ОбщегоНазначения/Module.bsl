//в ЦО проверяем отсутствие проводок и перепроводим
Процедура ПроверитьДокументы()   Экспорт
	
	
	СЗ = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПриходнаяНакладная.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОстаткиТМЦ.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ГДЕ
	|			ОстаткиТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ОстаткиТМЦ.Регистратор
	|		
	|		ОБЪЕДИНИТЬ ВСЕ
	|		
	|		ВЫБРАТЬ
	|			РезервыТМЦ.Регистратор,
	|			СУММА(1)
	|		ИЗ
	|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|		ГДЕ
	|			РезервыТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РезервыТМЦ.Регистратор) КАК КоличествоЗаписей
	|		ПО ПриходнаяНакладная.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И ПриходнаяНакладная.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ПриходнаяНакладная.Проведен
	|	И ПриходнаяНакладная.КоличествоДокумента > 0 
	//крохин начало 07.04.2026                                        
	//https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-193
	//|	И ПриходнаяНакладная.СостояниеНакладной <> &СостояниеНакладной 
	|	И ПриходнаяНакладная.СостояниеНакладной В(&СписокСостоянийНакладной)
	//крохин конец 07.04.2026
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриходнаяНакладная.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
	//крохин начало 07.04.2026                                        
	//https://yougile.collant.ru/team/ab6bad3a05c0/#SNL-193
	//Запрос.УстановитьПараметр("СостояниеНакладной",Перечисления.СостоянияНакладной.ВРаботе);
	СписокСостоянийНакладной = Новый СписокЗначений;
	СписокСостоянийНакладной.Добавить(Перечисления.СостоянияНакладной.ГотоваКПриемке);
	СписокСостоянийНакладной.Добавить(Перечисления.СостоянияНакладной.Принята);
Запрос.УстановитьПараметр("СписокСостоянийНакладной",СписокСостоянийНакладной);	
	//крохин конец 07.04.2026
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаписатьВЛог("Исправление ошибки записи при обмене","Перепроведение "+Выборка.Ссылка,"Информация");
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Перемещение.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.Перемещение КАК Перемещение
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОстаткиТМЦ.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ГДЕ
	|			ОстаткиТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ОстаткиТМЦ.Регистратор
	|		
	|		ОБЪЕДИНИТЬ ВСЕ
	|		
	|		ВЫБРАТЬ
	|			РезервыТМЦ.Регистратор,
	|			СУММА(1)
	|		ИЗ
	|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|		ГДЕ
	|			РезервыТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РезервыТМЦ.Регистратор) КАК КоличествоЗаписей
	|		ПО Перемещение.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И Перемещение.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Перемещение.Проведен
	|	И Перемещение.КоличествоДокумента > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Перемещение.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		//крохин начало 16.03.2017
		//не проверяем ПРМ с РС франчайзинг
		Если Выборка.Ссылка.Склад.Код = "SSX-66" Тогда Продолжить; КонецЕсли;
		//крохин конец 16.03.2017
		ЗаписатьВЛог("Исправление ошибки записи при обмене","Перепроведение "+Выборка.Ссылка,"Информация");	
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОстаткиТМЦ.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ГДЕ
	|			ОстаткиТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ОстаткиТМЦ.Регистратор
	|		
	|		ОБЪЕДИНИТЬ ВСЕ
	|		
	|		ВЫБРАТЬ
	|			РезервыТМЦ.Регистратор,
	|			СУММА(1)
	|		ИЗ
	|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|		ГДЕ
	|			РезервыТМЦ.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РезервыТМЦ.Регистратор) КАК КоличествоЗаписей
	|		ПО РасходнаяНакладная.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И РасходнаяНакладная.Дата МЕЖДУ &Дата1 И &Дата2
	|	И РасходнаяНакладная.Проведен
	|	И РасходнаяНакладная.КоличествоДокумента > 0
	//крохин начало 04.10.2022
	|	И РасходнаяНакладная.СостояниеНакладной <> Значение(Перечисление.СостоянияНакладной.Отменена)
	//крохин конец 04.10.2022
	|
	|УПОРЯДОЧИТЬ ПО
	|	РасходнаяНакладная.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаписатьВЛог("Исправление ошибки при обмене","Перепроведение "+Выборка.Ссылка,"Информация");	
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;	
	
	
	Если СЗ.Количество() > 0 Тогда
		Текст = "Список перепроведенных документов: "+ Символы.ВК;
		
		Для Н = 1 По СЗ.Количество() Цикл
			Текст = Текст + СЗ.Получить(Н-1) + Символы.ВК;
			ДокОбъект = СЗ.Получить(Н-1).Значение.ПолучитьОбъект();
			//Кухарь 14.05.20 начало
			//Иногда не удаётся записать. И обмен встаёт.
			//ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			попытка
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ЗаписатьВЛог("Исправление ошибки при обмене","Не удалось перепровести "+ДокОбъект.Ссылка,"Ошибки записи при обмене");
			КонецПопытки;
			//Кухарь 14.05.20 конец
			
		КонецЦикла;
		ПослатьПисьмоОПерепроведении(Текст);
	Иначе
	КонецЕсли;
	
	//крохин начало 24.03.2017
	//ИНВ
	//СПН
	//ОПР
	//крохин конец 24.03.2017
	
	
	
КонецПроцедуры

