			Сообщить("	Брэнд: "+Номенклатура.Родитель.Родитель+", модель: "+Номенклатура.Родитель+", позиция: "+Номенклатура+" ("+Номенклатура.Код+")",СтатусСообщения.Важное);
		КонецЦикла;
		
		Возврат Ложь;		
	КонецЕсли;
	
	Возврат Истина;	
КонецФункции //КонтрольДублейШК(ШК,ТипШК,Ссылка) Экспорт

