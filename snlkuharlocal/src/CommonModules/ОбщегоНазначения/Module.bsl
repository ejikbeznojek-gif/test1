Функция ФинальныйПересчетКоробокИОбъемов(Докобъект)  экспорт
	ТЗ=новый ТаблицаЗначений;
	тз.Колонки.Добавить("КоличествоКоробок");
	тз.Колонки.Добавить("ОбъемКоробов");
	
	СтрТз=тз.Добавить();
	стртз.КоличествоКоробок=0;
	стртз.ОбъемКоробов=0;
	/////////////Листы переукладки
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК КоличествоКоробок,
	|	СУММА(ЛистПереукладки.ОбъемДокумента) КАК ОбъемКоробов
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &ДокОснование
	|	И НЕ ЛистПереукладки.НеУчитыватьПриОпределенииКоличестваМест";
	запрос.УстановитьПараметр("ДокОснование",Докобъект.ссылка);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		если результат.КоличествоКоробок<>Null тогда
			если результат.КоличествоКоробок>0 Тогда
				ЗаполнитьЗначенияСвойств(СтрТз,результат);
				возврат СтрТз;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	/////////////Листы набора
	запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	СУММА(ЛистНабора.ОбъемКоробов) КАК ОбъемКоробов,
	|	СУММА(ЛистНабора.КоличествоКоробок) КАК КоличествоКоробок
	|ИЗ
	|	Документ.ЛистНабора КАК ЛистНабора
	|ГДЕ
	|	ЛистНабора.Проведен
	// Кухарь А.Ю.  07.08.2022 начало
	// Загруженные с ТСД ЛН
	| и не	ЛистНабора.ТребуетПроверки
	// Кухарь А.Ю.  07.08.2022 конец	
	|	И ЛистНабора.ДокОснование = &ДокОснование";
	запрос.УстановитьПараметр("ДокОснование",Докобъект.ссылка);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		если результат.КоличествоКоробок<>Null тогда
			если результат.КоличествоКоробок>0 Тогда
				ЗаполнитьЗначенияСвойств(СтрТз,результат);
				возврат СтрТз;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	////////////
	
	
	ЗаполнитьЗначенияСвойств(СтрТз,Докобъект);
	возврат СтрТз;
	
	
КонецФункции
