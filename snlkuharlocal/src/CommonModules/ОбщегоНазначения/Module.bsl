Функция ПолучитьДанныеКоробкиПоКодуАгрегации (КодАгрегацииСтрокой) экспорт                 
	СтруктураВозврата	=	Новый Структура("Успех,Ошибки,НомерКоробки,Лист",ложь,новый Массив,0,Неопределено);
	КА					=	Справочники.ШтрихкодыУпаковокТоваров.НайтиПоНаименованию(Прав(КодАгрегацииСтрокой,18),Истина);
	если КА=Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() тогда  
		СтруктураВозврата.Ошибки.Добавить("Не найден код агрегации");
		возврат СтруктураВозврата;
	КонецЕсли;
	
	запрос=новый запрос;  
	запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Лист.Ссылка КАК Лист,
	|	Лист.Дата КАК Дата,
	|	Лист.ДокОснование КАК ДокОснование,      
	// Кухарь А.Ю.  11.12.2025 начало
	// OUT-175
	|	выразить(Лист.ДокОснование как документ.расходнаянакладная).ВиртуальнаяНакладная КАК Виртуальная,
	|	выразить(Лист.ДокОснование как документ.расходнаянакладная).Проведен КАК ДокОснованиеПроведено
	
	// Кухарь А.Ю.  11.12.2025 конец			  
	|ИЗ
	|	Документ.ЛистНабора КАК Лист
	|ГДЕ
	|	Лист.ДокОснование ССЫЛКА Документ.РасходнаяНакладная
	|	И Лист.Проведен
	|	И Лист.КодАгрегации = &КодАгрегации
	|	И Лист.Дата >= &Дата1
	| 	
	|ОБЪЕДИНИТЬ ВСЕ     
	// Кухарь А.Ю.  25.02.2026 начало
	// Не находило код агрегации полученный из переклейки импортного кода через ЛН
	|ВЫБРАТЬ первые 1
	|Лист.Ссылка КАК Ссылка,
	|Лист.Ссылка.Дата КАК Дата,
	|Лист.Ссылка.ДокОснование КАК ДокОснование,
	|ВЫРАЗИТЬ(Лист.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).ВиртуальнаяНакладная КАК Виртуальная,
	|ВЫРАЗИТЬ(Лист.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).Проведен КАК ДокОснованиеПроведено
	|ИЗ
	|Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК Лист
	|ГДЕ
	|Лист.НовыйКодКоробки = &КодАгрегации
	|И Лист.Ссылка.Проведен       
	|И Лист.ссылка.Дата >= &Дата1
	|ОБЪЕДИНИТЬ ВСЕ  
	// Кухарь А.Ю.  25.02.2026 конец	
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Лист.Ссылка,
	|	Лист.Дата,
	|	Лист.ДокОснование,
	|	выразить(Лист.ДокОснование как документ.расходнаянакладная).ВиртуальнаяНакладная,
	|	выразить(Лист.ДокОснование как документ.расходнаянакладная).Проведен
	|ИЗ
	|	Документ.ЛистПереукладки КАК Лист
	|ГДЕ
	|	Лист.ДокОснование ССЫЛКА Документ.РасходнаяНакладная
	|	И Лист.Проведен
	|	И Лист.КодАгрегации = &КодАгрегации
	|	И Лист.Дата >= &Дата1";
	запрос.УстановитьПараметр("КодАгрегации",КА);  
	запрос.УстановитьПараметр("Дата1",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-6*30*86400);
	Выборка=запрос.Выполнить().Выбрать();   
	
	
	если Выборка.Количество() = 0 тогда
		СтруктураВозврата.Ошибки.Добавить("Не найден лист с отсканированным кодом агрегации");
		возврат СтруктураВозврата;		
	КонецЕсли;   
	
	
	пока Выборка.Следующий() цикл 
		// Кухарь А.Ю.  11.12.2025 начало
		// OUT-175
		// Если это код виртуальной РНК, то наверное его куда-то сканировали.     
		//		Лист=Выборка.Лист;  
		//ДатаЛиста=Выборка.Дата;
		//ДокОснование=выборка.ДокОснование;
		
		ПереопределяемДанныеЛиста = ложь;
		если выборка.Виртуальная и не выборка.ДокОснованиеПроведено тогда
			запрос.Текст= "ВЫБРАТЬ
			              |	т1.Лист КАК Лист,
			              |	т1.Дата КАК Дата,
			              |	т1.ДокОснование КАК ДокОснование
			              |ИЗ
			              |	(ВЫБРАТЬ ПЕРВЫЕ 1
			              |		Лист.Ссылка КАК Лист,
			              |		Лист.Ссылка.Дата КАК Дата,
			              |		Лист.Ссылка.ДокОснование КАК ДокОснование
			              |	ИЗ
			              |		Документ.ЛистНабора.ШтрихкодыУпаковок КАК Лист
			              |	ГДЕ
			              |		Лист.ШтрихкодУпаковки = &КодАгрегации
			              |		И Лист.Ссылка.Проведен
			              |		И Лист.Ссылка.Дата >= &Дата1
			              |		И ВЫРАЗИТЬ(Лист.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).Проведен
			              |		И Лист.Ссылка.ДокОснование ССЫЛКА Документ.РасходнаяНакладная           
						  // Кухарь А.Ю.  11.04.2026 начало
						  // HELP-9421
			              |	ОБЪЕДИНИТЬ ВСЕ
			              |	
			              |	ВЫБРАТЬ ПЕРВЫЕ 1
			              |		Лист.Ссылка,
			              |		Лист.Ссылка.Дата,
			              |		Лист.Ссылка.ДокОснование
			              |	ИЗ
			              |		Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК Лист
			              |	ГДЕ
			              |		Лист.ШтрихкодУпаковки = &КодАгрегации
			              |		И Лист.Ссылка.Проведен
			              |		И Лист.Ссылка.Дата >= &Дата1
			              |		И ВЫРАЗИТЬ(Лист.Ссылка.ДокОснование КАК Документ.РасходнаяНакладная).Проведен
			              |		И Лист.Ссылка.ДокОснование ССЫЛКА Документ.РасходнаяНакладная) КАК т1   
						  // Кухарь А.Ю.  11.04.2026 конец
						  
			              |УПОРЯДОЧИТЬ ПО
			              |	Дата УБЫВ";
			ВыборкаДополнительная = запрос.Выполнить().Выбрать();
			пока ВыборкаДополнительная.Следующий() цикл  
				Лист=ВыборкаДополнительная.Лист;  
				ДатаЛиста=ВыборкаДополнительная.Дата;
				ДокОснование=ВыборкаДополнительная.ДокОснование;
				ПереопределяемДанныеЛиста = Истина;
			КонецЦикла;
		КонецЕсли;            
		
		если не ПереопределяемДанныеЛиста тогда   
			Лист=Выборка.Лист;  
			ДатаЛиста=Выборка.Дата;
			ДокОснование=выборка.ДокОснование;		
		КонецЕсли;
		// Кухарь А.Ю.  11.12.2025 конец
		
		
	КонецЦикла;   

	//++Данилова Е.В. 20.04.2026 SNL-205 по листам переукладки тоже самое
	// Кухарь А.Ю.  10.04.2026 начало
	// Добавили новую ТЧ с коробами в ЛН 	 
	//если ТипЗнч(лист) = Тип("ДокументСсылка.ЛистНабора") тогда 
	ДанныеДляПерезаполнения = Неопределено;	
	//++Данилова Е.В. 13.05.2026 HELP-9756 
	//СтруктураКоробок=ПолучитьСписокШКкоробокЛистаНабора(Лист,Истина,ДанныеДляПерезаполнения);
	СтруктураКоробок=ПолучитьСписокШКкоробокЛистаНабора(Лист,Истина,ДанныеДляПерезаполнения,Ложь);
	//--Данилова Е.В. 13.05.2026 
	если СтруктураКоробок.количество() = 1 тогда     
		СтруктураВозврата.Успех				= Истина;
		СтруктураВозврата.НомерКоробки 		= СтруктураКоробок[0].НомерКоробки;
		СтруктураВозврата.Лист 				= Лист;		
		возврат СтруктураВозврата;
	КонецЕсли;		                                  
	//КонецЕсли;	
	// Кухарь А.Ю.  10.04.2026 конец 
	//--Данилова Е.В. 20.04.2026 
	
	
	запрос.Текст="ВЫБРАТЬ
	|	Лист.Ссылка КАК Ссылка,
	|	Лист.Номер КАК Номер,
	|	Лист.Дата КАК Дата
	|ИЗ
	|	Документ.ЛистНабора КАК Лист
	|ГДЕ
	|	Лист.Проведен
	|	И Лист.ДокОснование = &ДокОснование
	|	И Лист.Дата <= &Дата2
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Номер";  
	запрос.УстановитьПараметр("Дата2",ДатаЛиста);
	запрос.УстановитьПараметр("ДокОснование",ДокОснование);	
	если ТипЗнч(лист) = Тип("ДокументСсылка.ЛистПереукладки") тогда 
		запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ЛистНабора КАК Лист","Документ.ЛистПереукладки КАК Лист");
	КонецЕсли;
	ТЗ=запрос.Выполнить().Выгрузить();
	НомерКоробки=тз.Индекс(тз.Найти(Лист,"Ссылка"))+1;
	
	СтруктураВозврата.Успех				= Истина;
	СтруктураВозврата.НомерКоробки 		= НомерКоробки;
	СтруктураВозврата.Лист 				= Лист;
	
	возврат СтруктураВозврата;
	
КонецФункции

