	Если Найти("Матрица,ПланПродажПоКлиентам",МетаДок.Имя)<>0 и не ВидДокумента = "ПланПродаж" Тогда 
	// Нечаева 15,01,26 -- OUT-179
	
		ДатаЗапрета='00010101';	
	КонецЕсли; 
	
	//крохин начало 19.02.2020
	//для КП открытый период больше стандартного на 90 дней
	//крохин начало 17.03.2020
	//для установки скидок такая же ДЗР
	//Если МетаДок.Имя = "КонтрактСПроизводителем" Тогда
	//крохин начало 11.05.2021
	//для заказов такая же ДЗР
	//Если МетаДок.Имя = "КонтрактСПроизводителем" ИЛИ МетаДок.Имя = "УстановкаСкидокПоКонтрагентам" Тогда
	ИмяМетаданныхДокумента = МетаДок.Имя;
	Если ИмяМетаданныхДокумента = "КонтрактСПроизводителем" ИЛИ ИмяМетаданныхДокумента = "УстановкаСкидокПоКонтрагентам" Тогда //ИЛИ ИмяМетаданныхДокумента = "Заказ" Тогда	
		//крохин конец 	11.05.2021
		//крохин конец 17.03.2020
		//крохин начало 28.12.2021
		//ДатаЗапрета = ДатаЗапрета - 90*24*60*60;
		//крохин начало 23.05.2023
		//ДатаЗапрета = ДатаЗапрета - 120*24*60*60;
		ДатаЗапрета = ДатаЗапрета - 365*24*60*60;
		//крохин конец 23.05.2023
		//крохин конец 28.12.2021
		//+++Чирков 16.10.2025 - унификация ДЗР по маркировке	
	ИначеЕсли ИмяМетаданныхДокумента = "МаркировкаТоваровИСМП" 
		ИЛИ ИмяМетаданныхДокумента = "УстановкаСтатусаКМ"
		ИЛИ ИмяМетаданныхДокумента = "ХранилищеКодовМаркировки" Тогда
		ДатаЗапрета = ДатаЗапрета - 14*24*60*60;
		//---Чирков 16.10.2025 - унификация ДЗР по маркировке
	//+++Чирков 30.03.2026 - ДЗР по авансовым РНК
