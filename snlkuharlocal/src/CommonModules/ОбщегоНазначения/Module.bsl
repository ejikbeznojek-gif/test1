	ТекСостав=СтрЗаменить(ТекСостав,"Люрекс","Lurex\Люрекс");
	ТекСостав=СтрЗаменить(ТекСостав,"люрекс","Lurex\Люрекс");	
	ТекСостав=СтрЗаменить(ТекСостав,"Бамбук","Bamboo\Бамбук");
	ТекСостав=СтрЗаменить(ТекСостав,"Полиэстер","Polyester\Полиэстер");
	ТекСостав=СтрЗаменить(ТекСостав,"Мерс.Хлопок","Mers.Cotton\Мерс.Хлопок");
	ТекСостав=СтрЗаменить(ТекСостав,"мерс. хлопок","Mers.Cotton\Мерс.Хлопок");
	ТекСостав=СтрЗаменить(ТекСостав,"Мерс. хлопок","Mers.Cotton\Мерс.Хлопок");	
	ТекСостав=СтрЗаменить(ТекСостав,"Вискоза","Viscose\Вискоза");
	ТекСостав=СтрЗаменить(ТекСостав,"Шерсть","Wool\Шерсть");
	ТекСостав=СтрЗаменить(ТекСостав,"Ангора","Angora\Ангора");
	ТекСостав=СтрЗаменить(ТекСостав,"Акрил","Acrylic\Акрил");
	ТекСостав=СтрЗаменить(ТекСостав,"Крапива","Nettle\Крапива");
	ТекСостав=СтрЗаменить(ТекСостав,"Лавсан","Lavsan\Лавсан");
	ТекСостав=СтрЗаменить(ТекСостав,"Микромодал","Micromodal\Микромодaл");
	ТекСостав=СтрЗаменить(ТекСостав,"Модал","Modal\Модал");
	ТекСостав=СтрЗаменить(ТекСостав,"модал","Modal\Модал");
	
