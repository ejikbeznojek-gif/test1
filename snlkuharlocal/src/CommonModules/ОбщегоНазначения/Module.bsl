Функция ПолучитьВесаПоОстаткамПартии(Им7, Номенклатура, Количество, Контракт, Дата) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПартииОстатки.ВесОстаток КАК Брутто,
	|	ПартииОстатки.ВесНеттоОстаток КАК Нетто,
	|	ПартииОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.Партии.Остатки(
	|			&Дата1,
	|			Партия = &ИМ7
	|				И Номенклатура = &Номенклатура
	|				И Контракт = &Контракт) КАК ПартииОстатки";
	Запрос.УстановитьПараметр("Дата1", Новый Граница(Дата, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ИМ7", ИМ7);
	Запрос.УстановитьПараметр("Контракт", Контракт);
	Выборка = Запрос.Выполнить().Выбрать();
	Веса = Новый Структура;
	Выборка.Следующий();
	Если Выборка.Количество <> 0 Тогда
		Веса.Вставить("Брутто", Количество*Выборка.Брутто/Выборка.Количество);
		Веса.Вставить("Нетто", Количество*Выборка.Нетто/Выборка.Количество);
	Иначе
		Веса.Вставить("Брутто", 0);
		Веса.Вставить("Нетто", 0);
	КонецЕсли;
	Возврат Веса;
КонецФункции
