Функция ПолучитьСуммуПоЗПС(ДокОснование, ЗаказыПоставщикам, Номенклатура) Экспорт
	сзЗПС = Новый СписокЗначений;
	Если ДокОснование = Неопределено Тогда
		для Каждого стр из ЗаказыПоставщикам Цикл
			сзЗПС.Добавить(стр.ЗПС);
		КонецЦикла;
	Иначе
		сзЗПС.Добавить(ДокОснование);
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Цена КАК Цена
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка В(&ЗПС)
	|	И ЗаказПоставщикуТовары.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("ЗПС", сзЗПС);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	тз = Запрос.Выполнить().Выгрузить();
	Если тз.Количество() = 0 Тогда
		Сообщить("В ЗПС "+ДокОснование+" не обнаружена номенклатура "+Номенклатура);
		Возврат 0;
	Иначе
		Возврат тз[0].Цена;
	КонецЕсли;
КонецФункции

