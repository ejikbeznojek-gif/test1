			ЗаписатьВЛог("ОшибкиЗаказов"," "+Номенклатура +" - "+ Количество+" - "+ Дата+" - "+ Склад+"  сумма - "+сумма+" - количество - "+количество+" - остаток - "+остаток,"Информация");
