Функция НайтиДокумент(Вид,СтруктураПоиска) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ."+Вид+"
	|ГДЕ
	|	Истина ";
	
	Для Каждого Элемент Из СтруктураПоиска Цикл
		Если Элемент.Ключ="Дата" Тогда
			Запрос.Текст=Запрос.Текст+"
			|	И НАЧАЛОПЕРИОДА("+Элемент.Ключ+",ГОД)=НАЧАЛОПЕРИОДА(&"+Элемент.Ключ+",ГОД)";
		Иначе
			Запрос.Текст=Запрос.Текст+"
			|	И "+Элемент.Ключ+"=&"+Элемент.Ключ;		
		КонецЕсли;		
		
		Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);
	КонецЦикла;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Ссылка;			
	КонецЦикла;	
	
	Возврат Документы[Вид].ПустаяСсылка();
КонецФункции //НайтиДокумент(Вид,СтруктураПоиска)

Функция ТребуетсяДопОбработка(ДокСсылка) Экспорт
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда Возврат Ложь КонецЕсли;
	
	ВидДокумента=ДокСсылка.Метаданные().Имя;
	Если ВидДокумента="Перемещение" Тогда
		ИмяТаблицы	=	"Справочник.ПунктыДоставки.ВидыДопОбработок";
		ИмяПоля		=	"ДопОбработка";
		
		ТекСсылка	=	ПолучитьРеквизитШапки(ДокСсылка,"ПунктДоставки","Документ");		
	ИначеЕсли ВидДокумента<>"Перемещение" и ВидДокумента<>"Комплектация" Тогда	
		ИмяТаблицы="Документ."+ВидДокумента+".ДопОбработки";
		ИмяПоля		=	"ВидДопОбработки";
		ТекСсылка	=	ДокСсылка;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Запрос=Новый Запрос;	
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1 "+ИмяПоля+" 
	|ИЗ "+ИмяТаблицы+" 
	|ГДЕ Ссылка=&Ссылка И "+ИмяПоля+"<>ЗНАЧЕНИЕ(Справочник.ВидыДопОбработки.БезОбработки)
	|";
	Запрос.УстановитьПараметр("Ссылка",ТекСсылка);
	Выборка=Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка[ИмяПоля]));	
КонецФункции //ТребуетсяДопОбработка(ДокСсылка)


