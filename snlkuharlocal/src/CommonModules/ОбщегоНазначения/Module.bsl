Функция ПолучитьЗначРеквСпр(ЭлемСпр,ИмяРекв) Экспорт 
	Запрос = Новый Запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	РеквизитыСправочников.Справочник КАК Справочник,
	|	РеквизитыСправочников.ИмяРеквизита КАК ИмяРеквизита,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	|	И РеквизитыСправочников.Справочник = &Справочник";
	Запрос.УстановитьПараметр("Справочник",ЭлемСпр);
	Запрос.УстановитьПараметр("ИмяРеквизита",ИмяРекв);
	Выборка = запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЗначениеРеквизита;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Процедура УстановитьЗначРеквСпр(ЭлемСпр,ИмяРекв,ЗначРекв) Экспорт  
	МенЗап=РегистрыСведений.РеквизитыСправочников.СоздатьМенеджерЗаписи();
	МенЗап.Справочник=ЭлемСпр;
	МенЗап.ИмяРеквизита=ИмяРекв;
	Если НЕ ЗначениеЗаполнено(ЗначРекв) Тогда
		Попытка МенЗап.Удалить(); Исключение КонецПопытки;
	Иначе
		Попытка
			МенЗап.ЗначениеРеквизита=ЗначРекв;
			МенЗап.Записать();
		Исключение
		КонецПопытки;	
	КонецЕсли;	
КонецПроцедуры
