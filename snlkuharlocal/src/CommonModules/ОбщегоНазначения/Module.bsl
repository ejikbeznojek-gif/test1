	|	И ДопРеквизитыСправочников.ВспомогательноеЗначениеРеквизита=истина";
	запрос.УстановитьПараметр("Справочник",Документ.ПунктДоставки);	
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()=0 тогда
		Сдвиг=0;
		
		//Кухарь 10.06.16 начало
