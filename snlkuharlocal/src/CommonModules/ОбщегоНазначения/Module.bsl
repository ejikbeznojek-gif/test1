Функция ПолучитьМассивСсылокНаШК(ШК,ТипШК=Неопределено)	
	ТекШК=СокрЛП(ШК);
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка 		КАК Ссылка,
	|	Владелец 	КАК Номенклатура,	
	|	ШтВКоробе 	КАК ШтВКоробе,	
	|	ВидШК 		КАК ВидШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	Ложь
	|";
	
	Если СтрДлина(ТекШК)<12 и СтрДлина(ТекШК)<>8 Тогда
		Сообщить("Неопознанный ШК: "+ТекШК,СтатусСообщения.ОченьВажное);
		Возврат Запрос.Выполнить().Выгрузить();	
	КонецЕсли;	
	
	ТекШК=Прав(ТекШК,13);	
	
	Если ТипШК=Неопределено Тогда
		ТипШК=Перечисления.ТипыШтрихКодов.Штука;	
	КонецЕсли;	
	
	Запрос.Текст=Запрос.Текст+"	
	|	ИЛИ (
	|		Наименование 	= &ШК	
	|		И ТипШК 		= &ТипШК
	|	)
	|";	
	
	Запрос.УстановитьПараметр("ШК",		ТекШК);
	Запрос.УстановитьПараметр("ТипШК",	ТипШК);	
	
	Результат=Запрос.Выполнить().Выгрузить();
	Если результат.Количество()>0 тогда
		Возврат результат;
	Иначе		
		Запрос.УстановитьПараметр("ШК",СокрЛП(ШК));		
		
		Результат=запрос.Выполнить().Выгрузить();		
	КонецЕсли;	
	
	Возврат Результат;	
КонецФункции //ПолучитьМассивСсылокНаШК(ШК,ТипШК=Неопределено)


