	если ложь тогда 
		Документ=Документы.РасходнаяНакладная.НайтиПоНомеру("");
	КонецЕсли;
	
	ВремяПриемки=Справочники.ВремяПриемки.ПустаяСсылка();
	
	если Документ.Ссылка=Документы.РасходнаяНакладная.ПустаяСсылка() тогда
		возврат ВремяПриемки;
	КонецЕсли;
	
	
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыДокументов.ЗначениеРеквизита КАК ВремяПриемки
	|ИЗ
	|	РегистрСведений.РеквизитыДокументов КАК РеквизитыДокументов
	|ГДЕ
	|	РеквизитыДокументов.Документ = &Документ
	|	И РеквизитыДокументов.ИмяРеквизита = ""ВремяПриемкиДляЗОГ""";
	
	запрос.УстановитьПараметр("Документ",Документ.Ссылка);
	результат=запрос.Выполнить().выбрать();
	пока результат.Следующий() цикл
		ВремяПриемки=результат.ВремяПриемки;
	КонецЦикла;
	
	Возврат ВремяПриемки;
	
	
	
КонецФункции


Процедура ЗаписатьВремяПриемкиДляЗОГ (Документ,ВремяПриемки) Экспорт 
	
	если ложь тогда 
		Документ=Документы.РасходнаяНакладная.НайтиПоНомеру("");
		ВремяПриемки=Справочники.ВремяПриемки.НайтиПоКоду("");
	КонецЕсли;
	
	если Документ.Ссылка=Документы.РасходнаяНакладная.ПустаяСсылка() тогда
		#Если Клиент Тогда
			Сообщить("Перед установкой времени приемки нужно записать документ.");
		#КонецЕсли	
		Возврат;
	КонецЕсли;
	
	если ВремяПриемки=Справочники.ВремяПриемки.ПустаяСсылка() тогда
		#Если Клиент Тогда
			Сообщить("Нельзя записывать пустое время приемки.");
		#КонецЕсли	
		Возврат;
	КонецЕсли;
	
	
	ЗаписьВРег=РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи();
	ЗаписьВРег.Документ=Документ.Ссылка;
	ЗаписьВРег.ИмяРеквизита="ВремяПриемкиДляЗОГ";
	ЗаписьВРег.Период=Документ.Ссылка.Дата;
	ЗаписьВРег.ЗначениеРеквизита=ВремяПриемки;
	ЗаписьВРег.Записать();
	
	
КонецПроцедуры
