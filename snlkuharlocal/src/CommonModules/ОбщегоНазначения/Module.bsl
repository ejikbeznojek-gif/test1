				текдень=1;
			иначеесли СтрРезультата.деньнедели="Вторник" тогда
				текдень=2;
			иначеесли СтрРезультата.деньнедели="Среда" тогда
				текдень=3;
			иначеесли СтрРезультата.деньнедели="Четверг" тогда
				текдень=4;
			иначеесли СтрРезультата.деньнедели="Пятница" тогда
				текдень=5;
			иначеесли СтрРезультата.деньнедели="Суббота" тогда
