Функция ПолучитьДанныеНоменклатурыПоВложеннымШК(КодАгрегации) Экспорт
	
	МассивВозврата = Новый Массив;
	
	ТЗ_Вложенные = ПолучитьВложенныеШК(КодАгрегации);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ТЗ_Вложенные.Номенклатура КАК Номенклатура,
	|	ТЗ_Вложенные.ЛинейныйШК КАК ЛинейныйШК,
	|	ТЗ_Вложенные.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВТ_Вложенные
	|ИЗ
	|	&ТЗ_Вложенные КАК ТЗ_Вложенные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Вложенные.Номенклатура КАК Номенклатура,
	|	ВТ_Вложенные.ЛинейныйШК КАК ЛинейныйШК,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_Вложенные.Штрихкод) КАК Количество
	|ИЗ
	|	ВТ_Вложенные КАК ВТ_Вложенные
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Вложенные.Номенклатура,
	|	ВТ_Вложенные.ЛинейныйШК";
	
	Запрос.УстановитьПараметр("ТЗ_Вложенные", ТЗ_Вложенные);
	
