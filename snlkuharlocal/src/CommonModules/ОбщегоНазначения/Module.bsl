Процедура УстановитьПунктДоставкиКлиентСервер(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент",ИмяРеквизитаПД="ПунктДоставки") Экспорт	
	Контрагент		=ДокументОбъект[ИмяРеквизитаКонтрагент];
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЕстьРеквизитДокумента("ОсновнойПунктДоставки",Контрагент.Метаданные()) И ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект[ИмяРеквизитаПД]=Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПДКлиентСервер(Контрагент)=1 Тогда		
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
		ИначеЕсли ИмяРеквизитаКонтрагент = "СкладПолучатель" Тогда
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент,,"Наименование Убыв");
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
		Иначе
			ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
	КонецЕсли;	
КонецПроцедуры 


Процедура УстановитьДоговорКлиентСервер (ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент",ИмяРеквизитаДоговор="Договор") Экспорт
	Контрагент	=ДокументОбъект[ИмяРеквизитаКонтрагент];
	Договор		=ДокументОбъект[ИмяРеквизитаДоговор];
	Организация	=ДокументОбъект.Организация;
	
	КодЦБ=?(ПустаяСтрока(Контрагент.КодЦБ),Контрагент.Код,Контрагент.КодЦБ);
	
	
	ДокументОбъект[ИмяРеквизитаДоговор]=Неопределено;
	Если Контрагент.Пустая() Тогда Возврат КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(Контрагент.ОсновнойДоговор) Тогда
		Договора=ПолучитьДоговорыКонтрагентаКлиентСервер(Контрагент,Организация);
	Иначе
		Договора=Новый Массив;	
		Договора.Добавить(Контрагент.ОсновнойДоговор);
	КонецЕсли;	
	
	Если Договора.ВГраница()=0 Тогда
		ДокументОбъект[ИмяРеквизитаДоговор]=Договора[0];
	КонецЕсли;
	
КонецПроцедуры  

Процедура УстановитьОтсрочкуПлатежаКлиентСервер (ДокументОбъект) экспорт
	Если ДокументОбъект.Контрагент.Ведущий.ТолькоПредоплата Тогда
		ДокументОбъект.ОтсрочкаПлатежа = Справочники.ОтсрочкиПлатежа.НайтиПоКоду("1");				
	ИначеЕсли ЗначениеЗаполнено(ДокументОбъект.Договор.ОтсрочкаПлатежа) тогда  
		ДокументОбъект.ОтсрочкаПлатежа = ДокументОбъект.Договор.ОтсрочкаПлатежа;
	ИначеЕсли ЗначениеЗаполнено(ДокументОбъект.ПунктДоставки.ОтсрочкаПлатежа) тогда
		ДокументОбъект.ОтсрочкаПлатежа = ДокументОбъект.ПунктДоставки.ОтсрочкаПлатежа;
	КонецЕсли;	
КонецПроцедуры

Функция ПолучитьДоговорыКонтрагентаКлиентСервер(Контрагент,Организация=Неопределено)
	МассивДоговоров=Новый Массив;
	
	КодЦБ=?(ПустаяСтрока(Контрагент.КодЦБ),Контрагент.Код,Контрагент.КодЦБ);
	
	Выборка=Справочники.Договоры.Выбрать(,,Новый Структура("КодЦБ",КодЦБ));
	Пока Выборка.Следующий() Цикл
		//Если задана организация то договора с другой организацией пропускаем
		//	Если Организация<>Неопределено И НЕ Организация.Пустая() И Выборка.Организация<>Организация Тогда Продолжить КонецЕсли; 	
		
		
		МассивДоговоров.Добавить(Выборка.Ссылка);
	КонецЦикла; 
	
	Возврат МассивДоговоров;
КонецФункции


Функция КоличествоПДКлиентСервер(Контрагент) Экспорт
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПунктыДоставки.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	ПунктыДоставки.Владелец = &Владелец
		|	И не ПунктыДоставки.ПометкаУдаления ";
		
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;		
	КонецЕсли;
	
	Возврат 0;
КонецФункции

Процедура ПунктДоставки_ПриИзмененииКлиентСервер(ДокументОбъект) экспорт
	ТипДокумента=ДокументОбъект.метаданные().имя;
	
	ПунктДоставки=ДокументОбъект.ПунктДоставки;
	НаборПолей=новый Структура("ТипДоставки,АдресПерегруза,Менеджер,РайонДоставки,Регион,Договор,ТранспортнаяКомпания,ПунктПерегруза,
	|Грузополучатель,Получатель,КодПоставщика,КодОперации,СкладКомиссия,ОтсрочкаПлатежа,ТипЦен,ТипСкидок,Скидка,НулеваяСтавкаНДС,
	|Контрагент");
	ЗаполнитьЗначенияСвойств(НаборПолей,ДокументОбъект);
	
	
	
	НаборПолей.ТипДоставки=ПунктДоставки.ТипДоставки;
	
	если ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.Перегруз или ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.Самовывоз тогда
		НаборПолей.АдресПерегруза=ПунктДоставки.АдресАнтор;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПунктДоставки.Менеджер)  Тогда
		Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			НаборПолей.Менеджер=ПунктДоставки.Менеджер;	
		Конецесли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПунктДоставки.Договор)  Тогда
		Договор=ПунктДоставки.Договор;
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
		НаборПолей.РайонДоставки=ПунктДоставки.РайонДоставки;			
	КонецЕсли;	
	Если ЗначениеЗаполнено(ПунктДоставки.Регион) Тогда
		НаборПолей.Регион=ПунктДоставки.Регион;			
	КонецЕсли;	
	
	
	если ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
		Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
			НаборПолей.ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
		иначе
			НаборПолей.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();
		КонецЕсли;	
		Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
			НаборПолей.ПунктПерегруза=ПунктДоставки.ПунктПерегруза;
		иначе
			НаборПолей.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
		КонецЕсли;	
	иначе
		НаборПолей.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();	
		НаборПолей.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
		НаборПолей.Грузополучатель=ПунктДоставки.Грузополучатель;		
	КонецЕсли;
	Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
		НаборПолей.Получатель=ПунктДоставки.Получатель;		
	КонецЕсли;
	
	если ТипДокумента="РасходнаяНакладная" тогда
		ДокументОбъект.ДопОбработки.Очистить();
		Если ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
			Для Каждого СтрокаТЧ Из ДокументОбъект.Контрагент.ВидыДопОбработок Цикл
				СтрокаДО=ДокументОбъект.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
			КонецЦикла;
		Иначе
			Для Каждого СтрокаТЧ Из ПунктДоставки.ВидыДопОбработок Цикл
				СтрокаДО=ДокументОбъект.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
			КонецЦикла;		
		КонецЕсли;
		
		Если ПунктДоставки.НулеваяСтавкаНДС или НаборПолей.Контрагент.НулеваяСтавкаНДС Тогда
			НаборПолей.НулеваяСтавкаНДС = Истина;	
		ИначеЕсли НаборПолей.НулеваяСтавкаНДС Тогда
			НаборПолей.НулеваяСтавкаНДС = Ложь;
		КонецЕсли;
		
		
	КонецЕсли;
	
	КодПоставщикаПунктаДоставки=ПунктДоставки.КодПоставщика;
	Если НЕ КодПоставщикаПунктаДоставки.Пустая() И НаборПолей.КодПоставщика<>КодПоставщикаПунктаДоставки Тогда
		НаборПолей.КодПоставщика=КодПоставщикаПунктаДоставки;
	КонецЕсли; 
	
	
	
	Если ЗначениеЗаполнено(ПунктДоставки.СкладКомиссия) Тогда
		НаборПолей.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия;
		НаборПолей.СкладКомиссия = ПунктДоставки.СкладКомиссия;
	Иначе
		Если НаборПолей.КодОперации = Перечисления.КодыОперацийОстатки.Комиссия Тогда
			НаборПолей.КодОперации = Перечисления.КодыОперацийОстатки.Реализация;
			НаборПолей.СкладКомиссия = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;	
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(ПунктДоставки.ОтсрочкаПлатежа) Тогда
		НаборПолей.ОтсрочкаПлатежа=ПунктДоставки.ОтсрочкаПлатежа;		
	КонецЕсли;
	
	//типы цен скидки
	Если ЗначениеЗаполнено(ПунктДоставки.ТипЦен) И НаборПолей.ТипЦен<>ПунктДоставки.ТипЦен Тогда
		НаборПолей.ТипЦен=ПунктДоставки.ТипЦен;		
	КонецЕсли; 
	Если ЗначениеЗаполнено(ПунктДоставки.ТипСкидок) И НаборПолей.ТипСкидок<>ПунктДоставки.ТипСкидок Тогда
		НаборПолей.ТипСкидок=ПунктДоставки.ТипСкидок;		
	КонецЕсли;
	Если ПунктДоставки.Скидка<>0 И ПунктДоставки.Скидка<>НаборПолей.Скидка Тогда
		НаборПолей.Скидка=ПунктДоставки.Скидка;		
	КонецЕсли;
	
	
	
	
	ЗаполнитьЗначенияСвойств(ДокументОбъект,НаборПолей);
КонецПроцедуры
