Функция КонтрольДатыЗапрета(Документ,Отказ=Ложь,ВывестиСообщение=Истина) Экспорт
	Если Отказ Тогда Возврат Ложь КонецЕсли; //И так уже нельзя
	Если ПараметрыСеанса.ОтключитьКонтрольДЗР Тогда Возврат Истина КонецЕсли; 
	
	ВидДокумента=Документ.Метаданные().Имя;
	Если ВидДокумента="УстановкаСкидок" или ВидДокумента="Контейнер" Тогда 
		Возврат Истина; //по просьбе Крохина не проверяем
	ИначеЕсли ВидДокумента="ПрайсЛист" Тогда 
		Возврат Истина;
	ИначеЕсли ВидДокумента = "РасходнаяНакладная" Тогда
		Если ТипЗнч(Документ) = Тип("ДокументОбъект.РасходнаяНакладная") Тогда
			РНК_Ссылка = Документ.Ссылка;
		Иначе
			РНК_Ссылка = Документ;			
		КонецЕсли;
		Если НЕ МожноРедактироватьРНКсАвансами(РНК_Ссылка) Тогда
			Отказ = Истина;
			#Если Клиент Тогда
			Если ВывестиСообщение Тогда                                          				
				Сообщить("Дата документа меньше ДЗР по предоплатным договорам ! Документ не записан !", СтатусСообщения.Важное);
			КонецЕсли;			
			#КонецЕсли
			Возврат Ложь;					
		КонецЕсли;
	КонецЕсли;
	
	Если Документ.Дата<=ПолучитьДатуЗапретаРедактирования(Документ) Тогда
		Отказ=Истина;
		#Если Клиент Тогда
			Если ВывестиСообщение Тогда
				Сообщить("Дата документа меньше даты запрета редактирования ! Документ не записан !",СтатусСообщения.Важное);			
			КонецЕсли;			
		#КонецЕсли
		Возврат Ложь;		
	КонецЕсли;
	Возврат Истина; //Можно записывать
КонецФункции// КонтрольДатыЗапрета() 


Функция ПолучитьПараметрыДоступаКДокументамПоСкладу(Склад) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	РедактированиеДокументов КАК Редактирование,
	|	ПросмотрДокументов КАК Просмотр,
	|	ОтгрузкаСоСклада КАК Отгрузка,
	|	ПриемкаНаСклад КАК Приемка
	|ИЗ
	|	Справочник.Пользователи.ДоступныеСклады КАК ПользователиДоступныеСклады
	|ГДЕ
	|	Ссылка = &Пользователь И Склад=&Склад";
	
	Запрос.УстановитьПараметр("Пользователь",	ПараметрыСеанса.Пользователь);
	Запрос.УстановитьПараметр("Склад",			Склад);
	
	
	Доступ=Новый Структура("Определены,Просмотр,Редактирование",Ложь,Ложь,Ложь);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Доступ.Вставить("Определены",Истина);
		Доступ.Вставить("Просмотр",			Выборка.Просмотр);
		Доступ.Вставить("Редактирование",	Выборка.Редактирование);	
		Доступ.Вставить("Отгрузка",			Выборка.Отгрузка);	
		Доступ.Вставить("Приемка",			Выборка.Приемка);	
	КонецЦикла; 
	
	Если НЕ Доступ.Определены Тогда
		ЕстьДоступ=(ПланыОбмена.Основной.ЭтотУзел().ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение);
		
		Доступ.Вставить("Просмотр",			ЕстьДоступ);
		Доступ.Вставить("Редактирование",	ЕстьДоступ);
		Доступ.Вставить("Отгрузка",			ЕстьДоступ);
		Доступ.Вставить("Приемка",			ЕстьДоступ);
	КонецЕсли; 
	
	Возврат Доступ;
КонецФункции // ПолучитьпараметрыДоступаКСкладу()


Функция МожноЗаписатьДокумент(Документ,Отказ,РежимЗаписи=Неопределено,ВывестиСообщение=Ложь) Экспорт
	Если Отказ Тогда Возврат Ложь КонецЕсли; //И так уже нельзя
	Если ПараметрыСеанса.ОтключитьКонтрольДЗР Тогда Возврат Истина КонецЕсли; 
	
	МетаДок=Документ.Метаданные();
	
	Вид=МетаДок.Имя;
	
	Если ЕстьРеквизитДокумента("Склад",МетаДок) Тогда
		Можно=Ложь;
		
		
		ПараметрыДоступаКДокументам=ПолучитьПараметрыДоступаКДокументамПоСкладу(Документ.Склад);
		Редактирование=ПараметрыДоступаКДокументам.Редактирование;
		
		
		//нечаева 19,01,16+++ 
		// для работников склада разрешаем работу со всеми документами или семеновский.
		Если параметрыСеанса.ТипУзла = перечисления.ТипУзлаИБ.Склад или  параметрыСеанса.ЭтотУзел.Код = "SEM"  Тогда
			редактирование = истина;
		КонецЕсли;	
		//нечаева 19,01,16---
		
		
		//для всех тц тоже не проверяем
		//нечаева 01,02,16 ++++
		Если    параметрысеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.ТорговоеПодразделение И   НЕ  параметрысеанса.ЭтотУзел.Подразделение.ЕстьВыделенныйСклад  Тогда
			редактирование = истина;
		КонецЕсли;
		//нечаева 01,02,16 ----
		
		Если НЕ Редактирование И ЕстьРеквизитДокумента("СкладПолучатель",МетаДок) Тогда
			ПараметрыДоступаКДокументам=ПолучитьПараметрыДоступаКДокументамПоСкладу(Документ.СкладПолучатель);						
			Редактирование=Макс(Редактирование,ПараметрыДоступаКДокументам.Редактирование);			
		КонецЕсли;
		
		Если НЕ Редактирование Тогда			
			Отказ=Истина;
			Сообщить("Недостаточно прав для изменения документа по складу: """+Документ.Склад+""" !",СтатусСообщения.Важное);		
		КонецЕсли;		
	КонецЕсли; 
	
	Если Отказ Тогда Возврат Ложь КонецЕсли;
	
	Если НЕ Документ.Ссылка.Пустая() Тогда //контроль изменения состояния проведения документа
		Если РежимЗаписи=РежимЗаписиДокумента.Проведение Тогда
			БудетПроведен=Истина;
		ИначеЕсли РежимЗаписи=РежимЗаписиДокумента.ОтменаПроведения Тогда
			БудетПроведен=Ложь;
		Иначе
			БудетПроведен=ПолучитьРеквизитыШапки(Документ.Ссылка,Новый Структура("Проведен"),"Документ").Проведен;
		КонецЕсли;
		
		Если Вид="РасходнаяНакладная" ИЛИ Вид="Перемещение" Тогда				
			РеквизитыШапки=ПолучитьРеквизитыШапки(Документ.Ссылка,Новый Структура("Проведен,СостояниеНакладной"),"Документ");
			
			ВРаботе=Ложь;
			Если Вид="РасходнаяНакладная" И РеквизитыШапки.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе Тогда
				ВРаботе=Истина;
			ИначеЕсли Вид="Перемещение" И РеквизитыШапки.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе Тогда				
				ВРаботе=Истина;
			КонецЕсли; 
			
			Если РеквизитыШапки.Проведен<>БудетПроведен И НЕ ВРаботе Тогда		
				Отказ=НЕ ПолучитьПолномочиеПользователя("ИзменениеПроведенияОтгруженныхНакладных");			
				Если Отказ И ВывестиСообщение Тогда
					Сообщить("Недостаточно полномочий для изменения признака проведения накладной !",СтатусСообщения.Важное);			
				КонецЕсли; 
			КонецЕсли;		
		ИначеЕсли Вид="Чек" Тогда
			Если Документ.Ссылка.ЧекПробитНаККМ И Документ.Ссылка.Проведен<>БудетПроведен Тогда
				Отказ=НЕ ПолучитьПолномочиеПользователя("ИзменениеПробитыхЧеков");		
				Если Отказ И ВывестиСообщение Тогда
					Сообщить("Недостаточно полномочий для изменения признака проведения пробитого чека !",СтатусСообщения.Важное);			
				КонецЕсли; 
			КонецЕсли;
			//крохин начало 11.11.2019
			//новый документ
		ИначеЕсли Вид="ОплатаЧерезККМ" Тогда
			Если Документ.Ссылка.ЧекПробитНаККМ И Документ.Ссылка.Проведен<>БудетПроведен Тогда
				Отказ=НЕ ПолучитьПолномочиеПользователя("ИзменениеПробитыхЧеков");		
				Если Отказ И ВывестиСообщение Тогда
					Сообщить("Недостаточно полномочий для изменения признака проведения пробитого чека !",СтатусСообщения.Важное);			
				КонецЕсли; 
			КонецЕсли;	
			//крохин конец 11.11.2019	
		КонецЕсли;	
	КонецЕсли;
	
	Возврат НЕ Отказ;
КонецФункции 

//пересчет сумм из одной валюты в другую
