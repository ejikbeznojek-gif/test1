Функция ЕстьЛПСАгрегацией(Накладная) экспорт
	запрос=новый запрос;
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Лист.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК Лист
	|ГДЕ
	|	Лист.Ссылка.Проведен
	|	И Лист.Ссылка.ДокОснование = &Накладная
	|	И (Лист.ШтрихкодБлочка <> &ПустойШК
	|			ИЛИ Лист.Ссылка.КодАгрегации <> &ПустойШК)";
	запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
	выборка=запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		возврат Истина;
	КонецЦикла;
	
	возврат Ложь;
КонецФункции

