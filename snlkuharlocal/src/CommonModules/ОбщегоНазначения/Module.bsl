Процедура ПечатьКМКоробкиДетскогоМира(КМКоробки,КМУпаковки,Знач Лист,Знач Контрагент, Знач Накладная, КМАгрегацииДМ = неопределено) экспорт
	Запрос = новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Лист.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.ЛистПереукладки.Товары КАК Лист
	|ГДЕ
	|	Лист.Ссылка = &Лист
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Лист.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК Лист
	|ГДЕ
	|	Лист.Ссылка = &Лист";
	запрос.УстановитьПараметр("Лист",Лист);
	Пакет = запрос.ВыполнитьПакет();
	ШтрихкодыУпаковок = Пакет[1].Выгрузить(); 
	МассивТоваров = Пакет[0].Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
	
	Если ШтрихкодыУпаковок.Количество() > 0 Тогда		
		//МассивТоваров = ЛистНабора.Товары.ВыгрузитьКолонку("Номенклатура");    
		
		
		
		Если НЕ МаркировкаС.ПроверитьЕАНКоробкиПоМассивуТоваровИзБлочка(МассивТоваров,Контрагент) Тогда
			Сообщить("ШККонтрагента коробки по товарам не совпадает, проверьте матрицу товаров"); 
			Возврат; 
		КонецЕсли;		
		КодАгрегацииНаПечать = ПреобразоватьКМКоробки(КМКоробки,КМУпаковки, Контрагент);
		
		Если Не ЗначениеЗаполнено(КодАгрегацииНаПечать) Тогда
			
			Сообщить("Не удалось записать  агрегационный код для печати для Детского МИРА"); 
			
			Возврат; 
			
			
		КонецЕсли;
	Иначе 
		Сообщить("Не удалось преобразовать  штрихкод для печати для Детского МИРА"); 
		Возврат; 
	КонецЕсли;
	
	НомерКоробки	= ПолучитьНомерКоробки (Накладная,Лист);
	
	ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
	ИмяМакета="Этикетка_75_120";
	Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
	
	ТД = Новый ТабличныйДокумент;
	ТД.ОтображатьСетку		= Ложь;
	ТД.ОтображатьЗаголовки	= Ложь;	
	ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_"+ИмяМакета;	
	
	ДанныеДляПечати	= Неопределено;
	
	ШтукЧЗВКоробке = ШтрихкодыУпаковок.Количество();
	
	ДопПараметры = Новый Структура("Артикул", "");
	
	
	ДопПараметры.Вставить("ОтображатьТекст",ложь); 
	ТипШКАгрегации = ПолучитьРеквизитШапки(Контрагент,"ТипШКАгрегации","Справочник"); 		 
	ПечататьCode128ДляАгрегаций = ТипШКАгрегации = Перечисления.ТипыКодировокШК.Code128;
	АгрегацияВCode128 = Ложь;
	Если ПечататьCode128ДляАгрегаций <> Неопределено Тогда
		АгрегацияВCode128 = ПечататьCode128ДляАгрегаций;	
	КонецЕсли;
	
	Если АгрегацияВCode128 Тогда 
		ДопПараметры.Вставить("АгрегацииВCode128",АгрегацияВCode128);		
	иначе
		ДопПараметры.Вставить("ДобавлятьСкобочкиВТекст",ЛОЖЬ);  		
	КонецЕсли;
	
	ДанныеИзМатрицы = МаркировкаС.ПолучитьДанныеПоНоменклатуреИзМатрицы(КМУпаковки.Владелец,Контрагент);  
	Если ДанныеИзМатрицы = неопределено Тогда	
		Возврат; 		
	КонецЕсли;
	
	АртикулКонтрагента = ДанныеИзМатрицы.КодПроизводителяКонтрагента; 	
	ДопПараметры.Вставить("Заголовок",АртикулКонтрагента + " Кол-во марок: " + Формат(ШтукЧЗВКоробке,"ЧГ=3,0"));
	ДопПараметры.Вставить("ШтрихкодСоСкобками",КодАгрегацииНаПечать.НаименованиеСоСкобками);
	ДопПараметры.Вставить("БезПрефикса",Истина);
	Область = ОбработкаПечати.СформироватьКА(Макет, ПолучитьРеквизитШапки(КодАгрегацииНаПечать,"Наименование","справочник"), НомерКоробки, ШтукЧЗВКоробке, ДопПараметры);	
	ТД.Вывести(Область);
	// Кухарь А.Ю.  27.05.2025 начало
	// HELP-5099
	// тд.Показать();
	если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр тогда
		тд.Показать();
	иначе
		тд.Напечатать();
	КонецЕсли; 
	// Кухарь А.Ю.  27.05.2025 конец 
	//++Данилова Е.В. 07.05.2026
	КМАгрегацииДМ = КодАгрегацииНаПечать;  
	//--Данилова Е.В. 07.05.2026 
КонецПроцедуры


Функция ПолучитьНомерКоробки (Накладная,Лист)
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка КАК Ссылка,
	|	ЛистПереукладки.Дата КАК Дата
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &Накладная
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата";
	запрос.УстановитьПараметр("Накладная",Накладная);
	ТЗ=запрос.Выполнить().Выгрузить();
	СтрокаТЗ=ТЗ.Найти(Лист,"ссылка");
	возврат ТЗ.Индекс(СтрокаТЗ)+1;
КонецФункции



Функция ПреобразоватьКМКоробки(Знач КМКоробки, Знач КМУпаковки,Знач Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АгрегационныеКодыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.АгрегационныеКодыКонтрагентов КАК АгрегационныеКодыКонтрагентов
	|ГДЕ
	|	АгрегационныеКодыКонтрагентов.ТипШК = &ТипШК
	|	И АгрегационныеКодыКонтрагентов.ШКЧЗ = &ШКЧЗ
	|	И АгрегационныеКодыКонтрагентов.Контрагент = &Контрагент
	|	И НЕ АгрегационныеКодыКонтрагентов.ПометкаУдаления
	|	///И АгрегационныеКодыКонтрагентов.Номенклатура = &Номенклатура";  //HELP-5557
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ТипШК", Перечисления.ТипыШтрихКодов.Коробка);
	Запрос.УстановитьПараметр("ШКЧЗ", КМКоробки);
	//++Данилова Е.В. 26.05.2025 ASU-2264 HELP-5557
	//Запрос.УстановитьПараметр("Номенклатура", КМУпаковки.Владелец);	
	//--Данилова Е.В. 26.05.2025 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда  	
		
		Возврат МаркировкаС.ЗаписатьНовыйАгрегационныйКодКонтрагентаДМ(КМУпаковки,Контрагент,Перечисления.ТипыШтрихКодов.Коробка,КМКоробки); 
		
	Иначе 
		Выборка = РезультатЗапроса.Выбрать(); 
		Выборка.Следующий(); 
		
		Возврат Выборка.ссылка; 
		
	КонецЕсли;
	
	
КонецФункции


