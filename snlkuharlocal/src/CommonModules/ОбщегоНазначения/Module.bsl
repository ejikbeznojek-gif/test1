Функция ДобавитьСпайкуВЛСКИЗаписатьСвязкуСНомеромЗаказа(ДанныеСпайки) Экспорт
	
	МассивДанныхСпайки = Десериализовать(Десериализовать(ДанныеСпайки).Получить());
	
	Если МассивДанныхСпайки <> Неопределено Тогда
		
		НомерЗаказаFBS = МассивДанныхСпайки[0].НомерЗаказаFBS;
		ЗСБ = МассивДанныхСпайки[0].ЗСБ;
		КодНабора = МассивДанныхСпайки[0].КодНабора;
		
		Результат = Документы.ЛистСборкиКомплектовЧЗ.ДобавитьСпайкуFBSВЛСК(МассивДанныхСпайки, КодНабора, ЗСБ); 
		
		Если Не Результат.Успех Тогда
			
			Ошибки = "Не удалось добавить спайку ЧЗ. Нужно исправить ошибки и отсканировать спайку заново" + Символы.ПС + Результат.Ошибки;
			
			Возврат Ошибки;
			
		КонецЕсли;
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		|	ЗаданиеНаСборкуКомплектовЧЗ.ДокОснование.Контрагент КАК Контрагент
		|ИЗ
		|	Документ.ЗаданиеНаСборкуКомплектовЧЗ КАК ЗаданиеНаСборкуКомплектовЧЗ
		|ГДЕ
		|	ЗаданиеНаСборкуКомплектовЧЗ.Ссылка = &ЗСБ";
		
		Запрос.УстановитьПараметр("ЗСБ", ЗСБ);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			
			Контрагент = Выборка.Контрагент;
			
			Если ЗначениеЗаполнено(Контрагент) Тогда
				
				Ошибки = ПроверитьЗаписатьСвязкуСНомеромЗаказа(Контрагент, НомерЗаказаFBS, КодНабора);
				
				Возврат Ошибки;
				
			Иначе
				
				Ошибки = "Не удалось определить контрагента по ЗСБ при записи в регистр ""Связь номеров заказа FBS и кодов ЧЗ спайки""";
				
				Возврат Ошибки;
				
			КонецЕсли;
			
		Иначе
			
			Ошибки = "Не удалось определить контрагента по ЗСБ при записи в регистр ""Связь номеров заказа FBS и кодов ЧЗ спайки""";
			
			Возврат Ошибки;
			
		КонецЕсли;
		
	Иначе
		
		Ошибки = "Ошибка в обработке данных спайки при добавлении в ЛСК";
		
		Возврат Ошибки;
		
	КонецЕсли;
	
КонецФункции

