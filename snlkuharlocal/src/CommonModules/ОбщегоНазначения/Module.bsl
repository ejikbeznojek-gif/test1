Функция ЕстьЛистБезКодаАгрегации(Накладная,ИмяЛиста = "ЛистПереукладки") экспорт
	запрос=новый запрос;
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());	
	запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Лист.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки КАК Лист
	|ГДЕ
	|	Лист.Проведен 
	|	И Лист.ДокОснование = &Накладная
	|	И Лист.КодАгрегации = &ПустойШК";
	если ИмяЛиста="ЛистПереукладки" тогда  
		Запрос.Текст=СтрЗаменить(запрос.Текст,"Документ.ЛистПереукладки КАК Лист","Документ.ЛистНабора КАК Лист");
	КонецЕсли;
	выборка=запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		возврат Истина;
	КонецЦикла;
	
	возврат Ложь;
КонецФункции


