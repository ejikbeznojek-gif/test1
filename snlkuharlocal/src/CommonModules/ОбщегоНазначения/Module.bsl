Функция _IDtoStr(Значение) Экспорт
	ТекЗнач=Значение;
	Если ТипЗнч(ТекЗнач)=Тип("Строка") Тогда
		ТекЗнач=Число(СокрЛП(ТекЗнач));	
	КонецЕсли; 
	
	Стр="";
	
	СтрБазы="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
	Пока 1=1 Цикл
		Поз=ТекЗнач % 36+1;		
		
		Стр=""+Сред(СтрБазы,Поз,1)+Стр;
		ТекЗнач=Цел(ТекЗнач/36);			
		Если ТекЗнач=0 Тогда Прервать КонецЕсли; 
	КонецЦикла; 
	
	Возврат Стр;
КонецФункции // ПриветстиКБазе()

Функция _StrToID(Значение) Экспорт
	ТекЗнач=СокрЛП(Значение);
	
	СтрБазы="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
	Рез=0;
	
	ДлинаСтроки=СтрДлина(ТекЗнач);
	База=1;
	
	Для Сч=0 По ДлинаСтроки-1 Цикл
		ТекСимвол=Сред(ТекЗнач,ДлинаСтроки-Сч,1);
		
		Поз=Найти(СтрБазы,ТекСимвол)-1;
		
		Рез=Рез+База*Поз;
		
		База=База*36;	
	КонецЦикла; 
	
	Возврат Рез;
КонецФункции // _StrToID() 


