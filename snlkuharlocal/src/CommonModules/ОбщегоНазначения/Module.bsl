Процедура СкопироватьЗначенияСвойствОбъекта(ОбъектИсточник, ОбъектПриемник) Экспорт
	
	СписокСвойств = ПолучитьСписокСвойствОбъекта(ОбъектИсточник);
	Для Каждого ЭлементСписка ИЗ СписокСвойств Цикл
		Значение = ПолучитьЗначениеСвойствОбъекта(ОбъектИсточник, ЭлементСписка.Ссылка.Наименование);
		ЗаписатьЗначениеСвойстваОбъекта(ОбъектПриемник, ЭлементСписка.Ссылка.Наименование, Значение);
	КонецЦикла;
	
КонецПроцедуры

Процедура СкопироватьЗначенияКатегорийОбъекта(ОбъектИсточник, ОбъектПриемник) Экспорт
	
	СписокСвойств = ПолучитьСписокКатегорийОбъекта(ОбъектИсточник);
	Для Каждого ЭлементСписка ИЗ СписокСвойств Цикл
		Значение = ПолучитьЗначениеКатегорииОбъекта(ОбъектИсточник, ЭлементСписка.Ссылка.Наименование);
		ЗаписатьЗначениеКатегорииОбъекта(ОбъектПриемник, ЭлементСписка.Ссылка.Наименование, Значение);
	КонецЦикла;
	
КонецПроцедуры

////////////////// Работа с Категориями объекта /////////////////////////////////

Функция ПолучитьЗначениеКатегорииОбъекта(Объект, НазваниеКатегории) Экспорт
	
	Категория = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КатегорииОбъектов.Ссылка КАК Категория
	|ИЗ
	|	Справочник.КатегорииОбъектов КАК КатегорииОбъектов
	|ГДЕ
	|	КатегорииОбъектов.Наименование = &Наименование
	|	И КатегорииОбъектов.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Наименование", НазваниеКатегории);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Категория = Выборка.Категория;
	КонецЕсли;
	
	Если Категория = Неопределено ИЛИ Категория.Пустая() Тогда
		Сообщить("Не существует Категория объекта "+ СокрЛП(НазваниеКатегории));
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КатегорииОбъектов.Объект
	|ИЗ
	|	РегистрСведений.КатегорииОбъектов КАК КатегорииОбъектов
	|ГДЕ
	|	КатегорииОбъектов.Объект = &Объект
	|	И КатегорииОбъектов.Категория = &Категория";
	
	Запрос.УстановитьПараметр("Объект", Объект);
	Запрос.УстановитьПараметр("Категория", Категория);
	
	Рез = Запрос.Выполнить();
	Если Рез.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьЗначениеКатегорииОбъектаПредопределенной(Объект, ИмяКатегории) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	КатегорииОбъектов.Объект
	|ИЗ
	|	РегистрСведений.КатегорииОбъектов КАК КатегорииОбъектов
	|ГДЕ
	|	КатегорииОбъектов.Объект = &Объект
	|	И КатегорииОбъектов.Категория = ЗНАЧЕНИЕ(Справочник.КатегорииОбъектов." + ИмяКатегории + ")";
	Запрос.УстановитьПараметр("Объект", Объект);
	Рез = Запрос.Выполнить();
	Если Рез.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

Функция ЗаписатьЗначениеКатегорииОбъекта(Объект, НазваниеКатегории, Значение = Истина) Экспорт
	
	Категория = Справочники.КатегорииОбъектов.НайтиПоНаименованию(СокрЛП(НазваниеКатегории)).Ссылка;
	
	Если Категория = Неопределено ИЛИ Категория.Пустая() Тогда
		Сообщить("Не установлена Категория объекта "+ СокрЛП(НазваниеКатегории));
		Возврат Неопределено;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.КатегорииОбъектов.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Объект.Установить(Объект); 
	НаборЗаписей.Отбор.Категория.Установить(Категория);
	
	Если Значение Тогда
		НоваяЗапись = НаборЗаписей.Добавить(); 
		НоваяЗапись.Объект = Объект; 
		НоваяЗапись.Категория = Категория; 
	КонецЕсли;
	
	Попытка
		НаборЗаписей.Записать();
		Возврат Истина;
	Исключение
		Сообщить("Не могу записать Категорию: " + ОписаниеОшибки(), СтатусСообщения.Важное);
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

функция ПолучитьОбъектыСУстановленнойКатегорией(НазваниеКатегории) Экспорт
	
	Категория = Справочники.КатегорииОбъектов.НайтиПоНаименованию(СокрЛП(НазваниеКатегории)).Ссылка;
	
	Если Категория = Неопределено ИЛИ Категория.Пустая() Тогда
		Сообщить("Не установлена Категория объекта "+ СокрЛП(НазваниеКатегории));
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КатегорииОбъектов.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.КатегорииОбъектов КАК КатегорииОбъектов
	|ГДЕ
	|	КатегорииОбъектов.Категория = &Категория
	|
	|УПОРЯДОЧИТЬ ПО
	|	Объект";
	
	Запрос.УстановитьПараметр("Категория", Категория);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

