Функция ПрочитатьРеквизитыРНКПНКПРМ (Ссылка,ИмяРеквизита) экспорт
	Запрос=новый запрос;
	запрос.УстановитьПараметр("Ссылка",Ссылка);
	запрос.УстановитьПараметр("ИмяРеквизита",ИмяРеквизита);
	
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита
	|	И РеквизитыРНКПНКПРМ.Документ = &Ссылка";
	
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		возврат результат.ЗначениеРеквизита;
	КонецЦикла;
	
	возврат Неопределено;
