	//---Чирков 14.04.2026 - по просьбе Александра Крохина контроль переделан на проверку даты запрета
	//---Чирков 30.03.2026 - ДЗР по авансовым РНК 	
	КонецЕсли;
	//крохин конец 19.02.2020
	//++Данилова Е.В. 12.12.2024
	Если ИмяМетаданныхДокумента = "Заказ" 
		И Ссылка.КодОперации = Перечисления.КодыОперацийОстатки.АгентскийДоговор Тогда
		
		ДатаЗапрета = ДатаЗапрета - 365*24*60*60;
		
	КонецЕсли;
	//--Данилова Е.В. 12.12.2024
	
	Возврат КонецДня(ДатаЗапрета);
