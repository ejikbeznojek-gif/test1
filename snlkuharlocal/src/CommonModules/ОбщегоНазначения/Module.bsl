Функция ПроверитьНаличиеТоваровБезСоставаПоНакладной (Накладная) Экспорт
	
	Получатель=Справочники.Контрагенты.ПустаяСсылка();
	ВидДокумента=Накладная.метаданные().имя;
	если ВидДокумента="РасходнаяНакладная" тогда
		Получатель=ПолучитьРеквизитШапки(Накладная,"Контрагент","Документ");
	ИначеЕсли ВидДокумента="Перемещение" тогда
		Получатель=ПолучитьРеквизитШапки(Накладная,"СкладПолучатель","Документ");
	иначе
		возврат Истина;
	КонецЕсли;
	НужноПроверять=ПрочитатьРСРеквизитСправочника("НоваяБазаТЦ",Получатель,ложь);
	
	если не НужноПроверять тогда
		возврат Истина;
	КонецЕсли;
	
	Результат=Истина;
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТЧДокумента.Номенклатура.Родитель КАК Модель
	|ПОМЕСТИТЬ ТЧТовары
	|ИЗ
	|	Документ."+ВидДокумента+".Товары КАК ТЧДокумента
	|ГДЕ
	|	ТЧДокумента.Ссылка = &Накладная
	|	И ТЧДокумента.Номенклатура.Родитель.ВидНоменклатуры = &ВидНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НоменклатураСоставНоменклатуры.Ссылка КАК НоменклатураСостава,
	|	ТЧТовары.Модель.Наименование КАК Наименование,
	|	ТЧТовары.Модель КАК Модель
	|ИЗ
	|	ТЧТовары КАК ТЧТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.СоставНоменклатуры КАК НоменклатураСоставНоменклатуры
	|		ПО ТЧТовары.Модель = НоменклатураСоставНоменклатуры.Ссылка
	|ГДЕ
	|	НоменклатураСоставНоменклатуры.Ссылка ЕСТЬ NULL";
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("ВидНоменклатуры",Перечисления.ВидыНоменклаутры.Товар);
	Выборка=запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл
		Результат=ложь;
		СообщитьИзМодуля("Не заполнен состав у "+Выборка.Наименование);
	КонецЦикла;
	Возврат Результат;
КонецФункции
