Функция ПолучитьРазбивкуНоменклатурыПоУпаковкеДокумента (Номенклатура,МассивДопОбработок,Контрагент=Неопределено) экспорт
	
	если ТипЗнч(Номенклатура) = Тип("СправочникСсылка.Номенклатура") тогда
		МассивНоменклатуры=новый Массив;
		МассивНоменклатуры.Добавить(Номенклатура);
	иначе
		МассивНоменклатуры=Номенклатура;
	КонецЕсли;
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	УпаковкаЭлементыУпаковки.Ссылка.Владелец КАК Владелец,
	|	УпаковкаЭлементыУпаковки.Номенклатура КАК Упаковка,
	|	УпаковкаЭлементыУпаковки.Количество КАК Количество
	|ИЗ
	|	Справочник.Упаковка.ЭлементыУпаковки КАК УпаковкаЭлементыУпаковки
	|ГДЕ
	|	УпаковкаЭлементыУпаковки.ВидДопОбработки В(&МассивДопОбработок)
	|	И УпаковкаЭлементыУпаковки.Ссылка.Владелец В(&МассивНоменклатуры)
	|	И НЕ УпаковкаЭлементыУпаковки.Ссылка.ПометкаУдаления
	// Кухарь А.Ю. 08.09.2021 начало
	|	И УпаковкаЭлементыУпаковки.Контрагент В(&СписокКонтрагентов)";	
	СписокКонтрагентов=новый СписокЗначений;
	СписокКонтрагентов.Добавить(Справочники.Контрагенты.ПустаяСсылка());
	если Контрагент<>Неопределено тогда
		СписокКонтрагентов.Добавить(Контрагент);
	КонецЕсли;
	запрос.УстановитьПараметр("СписокКонтрагентов",СписокКонтрагентов);			 
	// Кухарь А.Ю. 08.09.2021 конец
	
	
	
	запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);
	запрос.УстановитьПараметр("МассивДопОбработок",МассивДопОбработок);
	
	Возврат запрос.Выполнить().Выгрузить();	
	
КонецФункции
