Функция НайтиТоварПоШКИзМатрицы (ШК,Документ,ТипШК=Неопределено) экспорт
	если ТипШК=Неопределено тогда
		ТипШК=Перечисления.ТипыШтрихКодов.Штука;
	КонецЕсли;
	//Кухарь 13.10.17 начало
	//Одинаковые ШК в матрицах на разные позиции
	//Номенклатура=Справочники.Номенклатура.ПустаяСсылка();	
	СписокНоменклатуры=новый СписокЗначений;
	//Кухарь 13.10.17 конец	
	запрос=новый запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор.Организация = &Организация
	|	И МатрицаТовары.Ссылка.Дата <= &Дата
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &ДатаОкончания
	|	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	|	И (МатрицаТовары.ШККонтрагента = &ШККонтрагента или МатрицаТовары.ШККонтрагентаДополнительный = &ШККонтрагента) 
	|	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция";
	
	
	если ТипШК=Перечисления.ТипыШтрихКодов.Блочок тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"И МатрицаТовары.ШККонтрагента = ","И МатрицаТовары.ШККонтрагентаБлочок = ");
	ИначеЕсли ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда	
		запрос.Текст=СтрЗаменить(запрос.Текст,"И МатрицаТовары.ШККонтрагента = ","И МатрицаТовары.ШККонтрагентаКоробка = ");
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст +"
	|УПОРЯДОЧИТЬ ПО
	|	МатрицаТовары.Ссылка.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("ПостояннаяАкция",Документ.ПостояннаяАкция);	
	Запрос.УстановитьПараметр("ПунктДоставки",Документ.ПунктДоставки);
	Запрос.УстановитьПараметр("Контрагент",Документ.Контрагент);
	Запрос.УстановитьПараметр("Организация",Документ.Договор.Организация);
	запрос.УстановитьПараметр("Дата",КонецДня(Документ.Дата));
	Запрос.УстановитьПараметр("ДатаОкончания",НачалоДня(Документ.Дата));
	запрос.УстановитьПараметр("ШККонтрагента",ШК);
	результат=запрос.Выполнить().выбрать();
	
	//Кухарь 13.10.17 начало
	//Одинаковые ШК в матрицах на разные позиции
	//пока результат.Следующий() цикл
	//	возврат результат.номенклатура;
	//КонецЦикла;
	//возврат Номенклатура;
	пока результат.Следующий() цикл
