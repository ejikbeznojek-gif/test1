Функция ПолучитьСтруктуруДанныхМаркиЧЗПоНаименованию (Наименование,ЭтоОтгрузка=Истина)
	
	если СтрДлина(Наименование)=20 тогда
		Наименование=Сред(Наименование,3);
	КонецЕсли;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	//+MARK-704 20251126 Михайловский
	//СтруктураВозврата=новый Структура("МаркаЧЗ,ТипКода,ТипУпаковки,Количество,Количество1,ТипШК,Номенклатура,ШтрихКод,ОшибкаПоискаКодаЧЗ,СканировалиКодЧЗ,СпособВводаВОборот,Статус,КомментарийКОшибке");
	СтруктураВозврата=новый Структура("МаркаЧЗ,ТипКода,ТипУпаковки,Количество,Количество1,ТипШК,Номенклатура,ШтрихКод,ОшибкаПоискаКодаЧЗ,СканировалиКодЧЗ,СпособВводаВОборот,Статус,КомментарийКОшибке, ЗначениеШтрихкода, КМКоррекция");
	//-MARK-704 20251126 Михайловский
	ШтрихКодУпаковки=Справочники.ШтрихкодыУпаковокТоваров.НайтиПоНаименованию(Наименование);
	
	Если ЭтоОтгрузка = Истина Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК МаркаЧЗ, 
		//+MARK-704 20251126 Михайловский
		|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихКода КАК ЗначениеШтрихкода,
		//+MARK-704 20251126 Михайловский
		|	ШтрихкодыУпаковокТоваров.ТипКода КАК ТипКода,
		|	ШтрихкодыУпаковокТоваров.ТипУпаковки КАК ТипУпаковки,
