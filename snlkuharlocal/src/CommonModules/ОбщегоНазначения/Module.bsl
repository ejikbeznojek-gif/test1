	|ГДЕ
	|	РеквизитыДокументов.Документ = &Документ
	|	И РеквизитыДокументов.ИмяРеквизита = &ИмяРеквизита";
	
	запрос.УстановитьПараметр("Документ",ДокОбъектСсылка.Ссылка);
	если ИмяРеквизита=Неопределено тогда
