Функция ПолучитьСостояниеПоследнегоПланаНабора(Накладная) экспорт
	если ложь тогда накладная=документы.РасходнаяНакладная.ПустаяСсылка();КонецЕсли;
	////Чтобы не выполнять лишний запрос
	//В эти состояния накладная переводится только если все куски плана набора в нём же.
	СписокЗначенийСразуВозвращаем=новый СписокЗначений;
	СписокЗначенийСразуВозвращаем.Добавить(Перечисления.СостоянияНакладной.ОжиданиеПаллетирования);
	СписокЗначенийСразуВозвращаем.Добавить(Перечисления.СостоянияНакладной.Паллетирование);
	//Валетов + 17,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404 	
	СписокЗначенийСразуВозвращаем.Добавить(Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ);
	//Валетов -
	СписокЗначенийСразуВозвращаем.Добавить(Перечисления.СостоянияНакладной.ГотоваКОтгрузке);
	СписокЗначенийСразуВозвращаем.Добавить(Перечисления.СостоянияНакладной.Отгружена);
	если СписокЗначенийСразуВозвращаем.НайтиПоЗначению(накладная.СостояниеНакладной)<>Неопределено тогда
		возврат накладная.СостояниеНакладной;
	КонецЕсли;
	////Чтобы не выполнять лишний запрос
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПланНаборатБрэндов.Состояние КАК Состояние
	|ИЗ
	|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
	|ГДЕ
	|	ПланНаборатБрэндов.Ссылка.Дата >= &Дата
	|	И ПланНаборатБрэндов.Ссылка.Проведен
	|	И ПланНаборатБрэндов.Ссылка.ДокОснование = &Накладная";
	запрос.УстановитьПараметр("Дата",НачалоДня(накладная.дата));
	запрос.УстановитьПараметр("Накладная",Накладная);
	ТЗ=запрос.Выполнить().Выгрузить();
	если тз.Количество()=0 тогда
		возврат накладная.СостояниеНакладной;
	КонецЕсли;
	
	тз.Колонки.Добавить("ЧисловоеЗначение");
	для каждого СтрТЗ из ТЗ цикл
		СтрТЗ.ЧисловоеЗначение=ПолучитьНомерСостоянияНакладной(СтрТЗ.Состояние)
	КонецЦикла;
	
	ТЗ.Сортировать("ЧисловоеЗначение");
	возврат тз.Получить(0).Состояние;
	
КонецФункции
