Функция ЗаархивироватьФайл(ИмяФайла,ИмяАрхива) Экспорт
	ИсходныйФайл=Новый Файл(ИмяФайла);
	Если ИсходныйФайл.Существует() Тогда		
		ИмяАрхива=ИсходныйФайл.Путь+ИсходныйФайл.ИмяБезРасширения+".zip";
		
		Архив=Новый ЗаписьZipФайла(ИмяАрхива,,,МетодСжатияZIP.Сжатие,УровеньСжатияZIP.Оптимальный);
		Архив.Добавить(ИсходныйФайл.ПолноеИмя,РежимСохраненияПутейZIP.НеСохранятьПути,РежимОбработкиПодкаталоговZIP.НеОбрабатывать);		
		Архив.Записать();
		
		ФайлАрхива=Новый Файл(ИмяАрхива);
		Если Не ФайлАрхива.Существует() Тогда
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка архивации файла: """+ИсходныйФайл.ПолноеИмя+""" !",Перечисления.ТипыСообщенийЛога.Ошибка);
		Иначе
			УдалитьФайлы(ИсходныйФайл.Путь,ИсходныйФайл.Имя);
			Возврат Истина;
		КонецЕсли;
	Иначе
		ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка архивации файла: """+ИсходныйФайл.ПолноеИмя+""" ! Данный файл не найден !",Перечисления.ТипыСообщенийЛога.Ошибка);		
	КонецЕсли; 
	
	Возврат Ложь;	
КонецФункции // ЗаархивироватьФайл()

