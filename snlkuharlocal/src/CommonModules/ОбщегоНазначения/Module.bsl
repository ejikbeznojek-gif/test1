Функция ПолучитьКонтрДляСкидок(Ведущий)
	
	
	ВыборкаКонтрагентов = неопределено;
	
	Запрос=Новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ведущий.Ссылка В ИЕРАРХИИ(&текконтрагент)
	|	И Контрагенты.ПометкаУдаления = ЛОЖЬ
	|	И Контрагенты.НеИспользовать = ЛОЖЬ
	|	И Контрагенты.Ведущий.ВыгружатьВИнтернетМагазин = &выгружать
	|	И Контрагенты.Владелец = &СкВл";
	
	Запрос.УстановитьПараметр("СкВл", справочники.ИБ.НайтиПоКоду("SSP"));
	Запрос.УстановитьПараметр("выгружать", перечисления.ВыгружатьНаСайт.Да);
	Запрос.УстановитьПараметр("текконтрагент", ведущий);
	
	РезультатЗапрос = Запрос.Выполнить();
	ВыборкаКонтрагентов  = РезультатЗапрос.Выгрузить();
	
	
	Возврат  ВыборкаКонтрагентов;
	
	
	
