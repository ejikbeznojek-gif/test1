Функция ПолучитьИСформироватьОтчетРасшифровки (Знач ВнешнийОтчет, ТаблицаПолейОтбора) Экспорт  
	СтруктураВозврата = новый Структура("Успех,Ошибки",ложь,Новый Массив);	
	
	ВидОтчета = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(ВнешнийОтчет,"ОтчетРасшифровки","");     
	ИмяНастройки = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(ВнешнийОтчет,"ИмяНастройкиРасшифровки","");
	
	если не ЗначениеЗаполнено(ВидОтчета) тогда  
		СтруктураВозврата.Ошибки.Добавить("В РС реквизиты справочников не добавлен реквизит ОтчетРасшифровки");  
		Возврат СтруктураВозврата;
	КонецЕсли;                   
	
	если ИмяНастройки = "" тогда  
		СтруктураВозврата.Ошибки.Добавить("В РС реквизиты справочников не добавлен реквизит ИмяНастройки");
		Возврат СтруктураВозврата;
	КонецЕсли;            
	
       
	
	
	Отчет=Отчеты.ОбщийОтчетНаКомпоновке.Создать();	
	Отчет.ВидОтчета=ВидОтчета;					
	
	ИмяОтчета = "ОбщийОтчетНаКомпоновке_"+ПолучитьРеквизитШапки(ВидОтчета,"Код","Справочник");
	
	
	запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	НастройкиОбъектов.ЗначениеНастройки КАК ЗначениеНастройки
	|ИЗ
	|	РегистрСведений.НастройкиОбъектов КАК НастройкиОбъектов
	|ГДЕ
	|	НастройкиОбъектов.ИмяОбъекта = &ИмяОтчета
	|	И НастройкиОбъектов.Пользователь = &Пользователь";
	запрос.УстановитьПараметр("Пользователь",Справочники.Пользователи.НастройкиПоУмолчанию);      
	запрос.УстановитьПараметр("ИмяОтчета",ИмяОтчета);
	
	результат = запрос.Выполнить().Выбрать();   
	если результат.Количество() = 0 тогда   
		СтруктураВозврата.Ошибки.Добавить("Не найдены общие настройки отчёта по имени "+ИмяНастройки);
		возврат СтруктураВозврата;
	КонецЕсли;      
	
	пока результат.Следующий() цикл 
		ОбщиеНастройки = результат.ЗначениеНастройки.получить();       
		НужнаяНастройка = ОбщиеНастройки.Дерево.Строки.найти(ИмяНастройки);
		если НужнаяНастройка <> Неопределено тогда   
			НужнаяНастройкаКомпоновщика =  НужнаяНастройка.Значение.НастройкиКомпоновщика;
		иначе  
			СтруктураВозврата.Ошибки.Добавить("Не найдены общие настройки отчета по имени "+ИмяНастройки);
			возврат СтруктураВозврата;		
		КонецЕсли;
	КонецЦикла;    
	
	ФормаОтчета=Отчет.ПолучитьФорму();		
	Настройки = новый Структура("Дата1,Дата2,НастройкиКомпоновщика");  	
	настройки.Дата1 = НачалоГода(ТекущаяДата())-86400*365*2;
	настройки.Дата2 = КонецГода(ТекущаяДата())+86400*365*2; 
	ЭлементыОтбора = НужнаяНастройкаКомпоновщика.Отбор.Элементы;    
	
	
	
	для каждого ТекЭлемент из ЭлементыОтбора цикл      
		СтрокаТЗОтбора = ТаблицаПолейОтбора.найти(Строка(ТекЭлемент.ЛевоеЗначение),"ИмяПоля");
		если СтрокаТЗОтбора <> Неопределено тогда         
			ТекЭлемент.ПравоеЗначение = СтрокаТЗОтбора.ЗначениеПоля;	
		КонецЕсли;
	КонецЦикла;         
	
	
	
	настройки.НастройкиКомпоновщика = НужнаяНастройкаКомпоновщика;
	ФормаОтчета.Открыть();			
	ФормаОтчета.Дата1=Настройки.Дата1;											
	ФормаОтчета.Дата2=Настройки.Дата2;		
	ФормаОтчета.ВосстановитьНастройкуОтчета(Настройки);	
	ФормаОтчета.Сформировать(неопределено);
	
	если СтруктураВозврата.Ошибки.Количество() = 0 тогда
