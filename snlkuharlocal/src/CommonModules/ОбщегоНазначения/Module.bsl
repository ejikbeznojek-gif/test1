Функция ПолучитьДоговорДС(Контрагент)    Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Договоры.Ссылка КАК Договор
	|ИЗ
	|	Справочник.Договоры КАК Договоры
	|ГДЕ
	|	Договоры.ДопСоглашение
	//крохин начало 02.12.2020
	|   И НЕ Договоры.ПометкаУдаления
	//крохин конец 02.12.2020
	|	И Договоры.КодЦБ = &КодЦБ";
	Запрос.УстановитьПараметр("КодЦБ",Контрагент.КодЦБ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	КоличествоДоговоровДС = Выборка.Количество();
	Если КоличествоДоговоровДС = 0 Тогда
		СообщитьОбОшибке("Отсутствует договор ДС!");
		Возврат Справочники.Договоры.ПустаяСсылка();
	КонецЕсли;
	Если КоличествоДоговоровДС > 1 Тогда
		СообщитьОбОшибке("Обнаружено несколько договоров ДС!");
		Возврат Справочники.Договоры.ПустаяСсылка();
	КонецЕсли;
	Если КоличествоДоговоровДС = 1 Тогда
		Выборка.Следующий();	
		Возврат Выборка.Договор;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьНачислениеПоДС(Контрагент,ДоговорСкидкиДС)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВзаиморасчетыОстатки.СуммаУпрОстаток КАК СуммаУпрОстаток
	|ИЗ
	|	РегистрНакопления.Взаиморасчеты.Остатки(
	|			&Дата1,
	|			Контрагент = &Контрагент
	|				И Договор = &Договор) КАК ВзаиморасчетыОстатки";
	
	Запрос.УстановитьПараметр("Контрагент",Контрагент.ведущий);
	Запрос.УстановитьПараметр("Договор",ДоговорСкидкиДС);
	Запрос.УстановитьПараметр("Дата1",ТекущаяДата());
	Выборка = запрос.Выполнить().Выбрать();
