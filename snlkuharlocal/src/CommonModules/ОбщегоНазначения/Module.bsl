// <Описание функции>
//
// Параметры:
// МаркаЧЗ  - <СправочникСсылка.ШтрихкодыУпаковокТоваров> - отсканированный ШК, может быть коробка, штука, блочок
//                 
// ШКДляПроверки  - <Массив,СправочникСсылка.ШтрихкодыУпаковокТоваров> - ШК, по которым необходимо проверить статус
//                  Тип ШК - штука
//
// Возвращаемое значение:
//   <Соответствие>   - Ключ:ШтрихКодУпаковки Значение: Статус ШК 
//
Функция НекорректныеСтатусыМарокЧЗШтукиПриСканировании(Знач МаркаЧЗ, ШКДляПроверки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки КАК ШтрихКодУпаковки,
	|	СтатусыКМ_ФактСрезПоследних.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(
	|			,
	|			ШтрихКодУпаковки В (&ШК)
	|				И ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)) КАК СтатусыКМ_ФактСрезПоследних
	|ГДЕ
	|	НЕ СтатусыКМ_ФактСрезПоследних.Статус В (&Статусы)";
	
	СтатусыМассив = Новый Массив; 
	
	Если  МаркаЧЗ.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.ПокупкаВРФ
		ИЛИ МаркаЧЗ.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт 
		ИЛИ МаркаЧЗ.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Производство Тогда
		
		СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте);
		//Валетов + 10,03,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9103 
		Если НЕ МаркаЧЗ.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда 
			СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Нанесен); 
		КонецЕсли;
		//Валетов-
		
	Иначе
		
		СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Нанесен);
		СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте);
		СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Распечатан);   
		
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("ШК",ШКДляПроверки);
	Запрос.УстановитьПараметр("Статусы",СтатусыМассив);  
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ОшибкиШК = Новый Соответствие; 
	
	Пока Выборка.Следующий() Цикл
		
		
		ОшибкиШК.Вставить(Выборка.ШтрихКодУпаковки,Выборка.Статус); 
		
		
	КонецЦикла;
	
	Возврат ОшибкиШК; 
	
	
КонецФункции

