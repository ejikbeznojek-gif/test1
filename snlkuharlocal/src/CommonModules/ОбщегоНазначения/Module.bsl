Функция ПолучитьОстаткиПартий(ТаблицаПартий,ДатаОстатов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПартииОстатки.ВесОстаток КАК Брутто,
	|	ПартииОстатки.ВесНеттоОстаток КАК Нетто,
	|	ПартииОстатки.КоличествоОстаток КАК Количество,
	|	ПартииОстатки.СуммаОстаток КАК Сумма,
	|	ПартииОстатки.Партия КАК Им7,
	|	ПартииОстатки.Номенклатура
	|ИЗ
	|	РегистрНакопления.Партии.Остатки(
	|			&Дата1,
	|			Партия В (&ИМ7)
	|				И Номенклатура В (&Номенклатура)
	|				И Контракт = &Контракт) КАК ПартииОстатки";
	
	Запрос.УстановитьПараметр("Дата1", Новый Граница(ДатаОстатов, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Номенклатура", ТаблицаПартий.ВыгрузитьКолонку("Номенклатура"));
	Запрос.УстановитьПараметр("ИМ7", ТаблицаПартий.ВыгрузитьКолонку("ИМ7"));
	Запрос.УстановитьПараметр("Контракт", Справочники.КонтрактыСПроизводителем.ПустаяСсылка()); //исключаем склад-заказ,там контракт заполнен
	Выборка = Запрос.Выполнить().Выбрать();
	ТаблицаОстатов = Новый ТаблицаЗначений;
	ТаблицаОстатов.Колонки.Добавить("Им7");
	ТаблицаОстатов.Колонки.Добавить("Номенклатура");
	ТаблицаОстатов.Колонки.Добавить("Брутто");
	ТаблицаОстатов.Колонки.Добавить("Нетто");
	ТаблицаОстатов.Колонки.Добавить("Количество");
	ТаблицаОстатов.Колонки.Добавить("Сумма");
	Пока Выборка.Следующий() Цикл
		СтрокаТО = ТаблицаОстатов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТО,Выборка);
		Если Выборка.Количество = 0 Тогда
			СтрокаТО.Брутто = 0;
			СтрокаТО.Нетто = 0;
			СтрокаТО.Сумма = 0;
		КонецЕсли;
	КонецЦикла;
	Возврат ТаблицаОстатов;
	
КонецФункции

Функция ПолучитьВалютыПартий(СписокИм7) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Партии.Валюта,
	|	Партии.Партия КАК Им7
	|ИЗ
	|	РегистрНакопления.Партии КАК Партии
	|ГДЕ
	|	Партии.Партия В(&ИМ7)";
	Запрос.УстановитьПараметр("ИМ7", СписокИм7);
	Выборка = Запрос.Выполнить().Выбрать();
	СписокВалютИм7 = новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СписокВалютИм7.Вставить(Выборка.Им7,Выборка.Валюта);
	КонецЦикла;
	Возврат СписокВалютИм7;
КонецФункции

