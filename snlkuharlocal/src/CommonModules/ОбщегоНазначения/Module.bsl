	//	//иначе
	//	ТребуетсяМаркировка = Истина;
	//	//КонецЕсли;
	//	
	//Иначе
	//	
	//	ТребуетсяМаркировка = Ложь;
	//	
	//КонецЕсли;
	ТребуетсяМаркировка = Ложь;
	
	Если ТипЗнч(Накладная) = Тип("Структура") Тогда
		
		Если Накладная.Свойство("ВидНакладной") Тогда
			
			ВидНакладной = Накладная.ВидНакладной;
			
			Если ВидНакладной = "Перемещение" Тогда
				
				Если Накладная.Свойство("Склад_КодФизическогоУзла") И Накладная.Свойство("СкладПолучатель_КодФизическогоУзла") Тогда
					
					Если Накладная.СкладПолучатель_КодФизическогоУзла <> Накладная.Склад_КодФизическогоУзла Тогда 
						
						ТребуетсяМаркировка = Истина;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ВидНакладной = Накладная.Метаданные().Имя;
		
		Если ВидНакладной = "РасходнаяНакладная" Или ВидНакладной = "СписаниеТМЦ" Тогда	 
			
			РеквизитыШапки = ПолучитьРеквизитыШапки(Накладная, "ТребуетсяМаркировка", "Документ");
			
			Если РеквизитыШапки.ТребуетсяМаркировка Тогда
				
				ТребуетсяМаркировка = Истина;
				
			КонецЕсли;
			
		ИначеЕсли ВидНакладной = "Перемещение" Тогда
			
			
			// Кухарь А.Ю. 07.03.2025 начало
			// Пустая задача
			//РеквизитыНакладной = ПолучитьРеквизитыШапки(Накладная, "Склад,СкладПолучатель,Склад.КодФизическогоУзла,СкладПолучатель.КодФизическогоУзла", "Документ");
			//Если РеквизитыНакладной.СкладПолучатель_КодФизическогоУзла <> РеквизитыНакладной.Склад_КодФизическогоУзла Тогда 				
			//ТребуетсяМаркировка = Истина;			
			//КонецЕсли;
			РеквизитыНакладной = ПолучитьРеквизитыШапки(Накладная, "Склад,СкладПолучатель,Склад.КодФизическогоУзла,СкладПолучатель.КодФизическогоУзла,Склад.ВидСклада,СкладПолучатель.ВидСклада", "Документ");	
			Если РеквизитыНакладной.СкладПолучатель_ВидСклада <>Перечисления.ВидСклада.ВиртуальныйДляСклада
				и РеквизитыНакладной.Склад_ВидСклада <>Перечисления.ВидСклада.ВиртуальныйДляСклада Тогда 			
				ТребуетсяМаркировка = Истина;			
			КонецЕсли;
			// Кухарь А.Ю. 07.03.2025 конец
			
			
		ИначеЕсли ВидНакладной = "ПриходнаяНакладная" Тогда
			
			РеквизитыНакладной = ПолучитьРеквизитыШапки(Накладная, "КодОперации", "Документ");		
			
			ТребуетсяМаркировка = Истина;
			
		Иначе
			
			ТребуетсяМаркировка = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	// Кельманов А.В. - HELP-2442 - 2024.12.26 }
	
	Возврат ТребуетсяМаркировка;
	
