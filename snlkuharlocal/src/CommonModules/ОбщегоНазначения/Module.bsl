функция  ПолучитьСвободныйОстатокНаКонецДня(МассивНоменклатуры,Склад,Дата) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	СУММА(ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК СвободныйОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&Дата,
	|			Номенклатура В (&МассивНоменклатуры)
	|				И Склад = &Склад) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				&Дата,
	|				Номенклатура В (&МассивНоменклатуры)
	|					И Склад = &Склад) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиТМЦОстатки.Номенклатура";
	
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Дата",КонецДня(Дата));
	Запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);
	возврат Запрос.Выполнить().Выгрузить();
	
	
конецФункции	
