		//Кухарь 27.12.17 начало
		//Термоусадка
	ИначеЕсли НомерСостояния = 1130 Тогда
		Возврат Перечисления.СостоянияНакладной.ОжиданиеТермоусадки;
		
	ИначеЕсли НомерСостояния = 1135 Тогда
		Возврат Перечисления.СостоянияНакладной.Термоусадка;
		
		//Кухарь 27.12.17 конец		
		
	ИначеЕсли НомерСостояния = 1150 Тогда
		Возврат Перечисления.СостоянияНакладной.ОжиданиеПаллетирования;
		
	ИначеЕсли НомерСостояния = 1160 Тогда
		Возврат Перечисления.СостоянияНакладной.Паллетирование;
		
		//Кухарь  09.11.16 конец
		// Кухарь А.Ю.  15.10.2025 начало
		// HELP-5404 Кухарь
	ИначеЕсли НомерСостояния = 1180 Тогда
		Возврат Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ;		 
		// Кухарь А.Ю.  15.10.2025 конец
		
	ИначеЕсли НомерСостояния = 1200 Тогда
		Возврат Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
	ИначеЕсли НомерСостояния = 1300 Тогда
		Возврат Перечисления.СостоянияНакладной.ВМашине;	
		//Кухарь 18.08.14 конец
	ИначеЕсли НомерСостояния = 10000 Тогда
		Возврат Перечисления.СостоянияНакладной.Отгружена;		
	Иначе
		Возврат Перечисления.СостоянияНакладной.ПустаяСсылка();
	КонецЕсли;
	
