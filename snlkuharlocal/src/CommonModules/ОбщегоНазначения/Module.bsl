			СтруктураОтвета.Вставить("result","OK");
			СтруктураОтвета.Вставить("message","В 1с скидка по этому контрагенту уже установлена");
			
		КонецЕсли;	
		
		Если НЕ ЕстьИзменения и НЕ контрагентНайден Тогда
			СтруктураОтвета.Вставить("result","ERROR");
			СтруктураОтвета.Вставить("message","Не найден контрагент в документе скидок. код контрагента - "+СкидкаКодКонтрагента);
			
			записьJSON = новый ЗаписьJSON;
			ЗаписьJSON.УстановитьСтроку();
			ЗаписатьJSON(записьJSON,СтруктураОтвета);
			ЗаписатьВЛог("b2b test","Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки(),,,);
			#Если клиент  тогда
				сообщить("Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки());
			#КонецЕсли 
			
			возврат ЗаписьJSON.Закрыть()
		конецЕсли;	
		
		
		//**************************************************************************
		// ответ передать для сайта
		
		записьJSON = новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(записьJSON,СтруктураОтвета);
		
		ЗаписатьВЛог("b2b test","1Загрузка скидок конец. Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок+" "+ТекущаяДата(),,,);
		
		возврат ЗаписьJSON.Закрыть();   
		
		
	КонецЕсли;
	
	ЗаписатьВЛог("b2b test","2Загрузка скидок конец. Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок+" "+ТекущаяДата(),,,);
	
	
