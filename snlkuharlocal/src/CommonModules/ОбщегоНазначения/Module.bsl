		ТекЗнач=ПолучитьГрупповоеСвойствоОбъекта(Объект.Родитель,Свойство);		
	КонецЕсли; 	
	Возврат ТекЗнач;
КонецФункции //ПолучитьГрупповоеСвойствоОбъекта(Объект,Свойство)

