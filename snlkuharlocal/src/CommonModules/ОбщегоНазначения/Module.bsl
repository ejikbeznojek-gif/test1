Функция ПолучитьНовоеСостояниеЗНБ (ЗНБ,Состояние = Неопределено) экспорт
	ОжидаемоеНовоеСостояние=Неопределено;
	если Состояние = Неопределено тогда
		СтароеСостояние=ЗНБ.СостояниеНакладной;
	Иначе
		СтароеСостояние=Состояние;
	КонецЕсли;
	СтараяСтрока=знб.ПланируемыеСостояния.Найти(СтароеСостояние);
	если СтараяСтрока=Неопределено тогда      //Что-то наменяли руками с состояниями в ЗНБ
		// Кухарь А.Ю.  02.12.2022 начало
		//возврат Неопределено;
		возврат СтароеСостояние; 
		// Кухарь А.Ю.  02.12.2022 конец
	КонецЕсли;
	Сч=0;
	//Кухарь 27.10.2022 начало
	если ЗНБ.ПланируемыеСостояния.Индекс(СтараяСтрока)+1 = ЗНБ.ПланируемыеСостояния.количество() тогда
		возврат СтароеСостояние;
	КонецЕсли;
	//Кухарь 27.10.2022 конец
	
	
	Пока сч<ЗНБ.ПланируемыеСостояния.Количество() цикл 
		сч=сч+1;
		НоваяСтрока=ЗНБ.ПланируемыеСостояния.Получить(ЗНБ.ПланируемыеСостояния.Индекс(СтараяСтрока)+1);
		если НоваяСтрока.Пропустить тогда
			СтараяСтрока=НоваяСтрока;
		иначе
			ОжидаемоеНовоеСостояние=НоваяСтрока.Состояние;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	возврат  ОжидаемоеНовоеСостояние;
КонецФункции

