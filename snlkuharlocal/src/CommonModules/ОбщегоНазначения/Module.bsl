Функция ПолучитьСуммуСкидкиПоДСПоНеотгруженнымРНК(ДоговорСкидкиДС,ИсключатьРНК = Неопределено)   Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РасходнаяНакладная.СуммаСкидкиДС КАК СуммаСкидкиДС
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Проведен
	//крохин начало 01.06.2020
	//|	И РасходнаяНакладная.Договор = &Договор
	|	И РасходнаяНакладная.ДоговорСкидкиДС = &Договор
	//крохин конец 01.06.2020
	|	И РасходнаяНакладная.Отгружен <> &Отгружен";
	Запрос.УстановитьПараметр("Договор",ДоговорСкидкиДС);
	Запрос.УстановитьПараметр("Отгружен",Перечисления.Отгружен.Отгружен);
	ТЗРезультат = Запрос.Выполнить().Выгрузить();
	Если ТЗРезультат.Количество() > 0 Тогда
		СуммаСкидкиДСПоВсемРНК = ТЗРезультат.Итог("СуммаСкидкиДС");
		Если ИсключатьРНК = Неопределено Тогда
			Возврат СуммаСкидкиДСПоВсемРНК;
		Иначе
			Возврат (СуммаСкидкиДСПоВсемРНК - ИсключатьРНК.СуммаСкидкиДС);
		КонецЕсли;
	Иначе
		Возврат 0; 
	КонецЕсли;
