// Кельманов А.В. - ASU-2104 - 2025.03.22
Функция ДобавитьСпайкуВВыбранныйЛСК_СУдалениемСтрокСПустымКодомКомплектующего(ДанныеСпайки) Экспорт
	
	Ошибки = "";
	
	МассивДанныхСпайки = Десериализовать(Десериализовать(ДанныеСпайки).Получить());
	
	Если МассивДанныхСпайки <> Неопределено Тогда
		
		ЛСК = МассивДанныхСпайки[0].ЛСК;
		КодНабора = МассивДанныхСпайки[0].КодНабора;
		
		ЛСКОбъект = ЛСК.ПолучитьОбъект();
		
		ПараметрыПоиска = Новый Структура("ШтрихкодКомплекта, ШтрихкодУпаковки", КодНабора, Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
		
		МассивСтрокДляУдаления = ЛСКОбъект.ШтрихкодыУпаковок.НайтиСтроки(ПараметрыПоиска);
		
		Для Каждого Строка Из МассивСтрокДляУдаления Цикл
			ЛСКОбъект.ШтрихкодыУпаковок.Удалить(Строка);
		КонецЦикла;
		
		// Это нужно перенести в Документы.ЛистСборкиКомплектовЧЗ.ДобавитьСпайкуFBSВЛСК - добавить вариант по конкретному ЛСК
		МассивОшибок = Новый Массив;
		
		Если ЛСКОбъект.ШтрихкодыУпаковок.Найти(КодНабора, "ШтрихкодКомплекта") <> Неопределено Тогда
			МассивОшибок.Добавить("Обнаружен дубль набора в ЛСК " + ЛСКОбъект.Номер + " по коду " + КодНабора);
		КонецЕсли;
		
		Для Каждого СтрокаТЗ Из МассивДанныхСпайки Цикл
			
			КодЧЗ = СтрокаТЗ.МаркаЧЗ;
			
			Если Не ЗначениеЗаполнено(КодЧЗ) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЛСКОбъект.ШтрихкодыУпаковок.Найти(КодЧЗ, "ШтрихкодУпаковки") <> Неопределено Тогда
				МассивОшибок.Добавить("Обнаружен дубль комплектующей в ЛСК " + ЛСКОбъект.Номер + " по коду " + КодЧЗ);
				Продолжить;
			КонецЕсли;
			
			СтрТЧ = ЛСКОбъект.ШтрихкодыУпаковок.Добавить();
			
			СтрТЧ.ДатаФормированияКомплекта = ТекущаяДата();
			СтрТЧ.Комплектующее = СтрокаТЗ.Номенклатура;
			СтрТЧ.ШтрихкодКомплекта = КодНабора;
			СтрТЧ.ШтрихкодУпаковки = КодЧЗ;	
			СтрТЧ.КодКомплектующегоНеНанесен = СтрокаТЗ.НанесенияНеБыло; 
			
		КонецЦикла;
		
		Если МассивОшибок.Количество() = 0 Тогда
			
			Попытка
				ЛСКОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				МассивОшибок.Добавить("Не удалось записать документ по причине " + ОписаниеОшибки());
			КонецПопытки;
			
		КонецЕсли; 
		
		Если МассивОшибок.Количество() > 0 Тогда
			
			Ошибки = "Не удалось добавить спайку ЧЗ. Нужно исправить ошибки и отсканировать спайку заново" + Символы.ПС + СтрСоединить(МассивОшибок, Символы.ПС);
			
		КонецЕсли;
		
	Иначе
		
		Ошибки = "Ошибка в обработке данных спайки при добавлении в ЛСК";
		
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции

