//ШК-штрих-код
//ссылка-ссылка на текущий элемент ШК (чтобы сам на себя не ругался)
Функция КонтрольДублейШК(ШК) Экспорт
	
	ТипШК	=ШК.ТипШК;
	ВидШК	=ШК.ВидШК;
	ШтрихКод=ШК.Наименование;
	Ссылка	=ШК.Ссылка;
	
	//контроль основных ШК
	Если ВидШК=Перечисления.ВидыШК.Основной Тогда	
		ТШК=ПолучитьВсеШКТовара(ШК.Владелец,ТипШК,ВидШК);
		Если ТШК.Количество()>1 Тогда
			Сообщить("Дублирован основной ШК !",СтатусСообщения.Важное);
			
			Возврат Ложь;					
		КонецЕсли; 
	КонецЕсли;
	
	//контроль дублей
	//служебный ШК для забоя
	Если СокрЛП(ШтрихКод)="9999999999999" Тогда Возврат Истина КонецЕсли; 
	
	СписокДублей		=Новый Массив;
	СписокДублейВидов	=Новый Массив;
	
	ТШК=ПолучитьМассивСсылокНаШК(ШтрихКод,ТипШК);	
	
	Для Каждого СтрокаТШК Из ТШК Цикл	
		Если СтрокаТШК.Ссылка<>Ссылка Тогда
			СписокДублей.Добавить(СтрокаТШК.Номенклатура);
		КонецЕсли; 
	КонецЦикла;		
	
	Если СписокДублей.ВГраница()>=0 Тогда		
		Сообщить("ШК дублирован ! Тип ШК: "+ШК.ТипШК+", ШК: """+ШК+"""",СтатусСообщения.Важное);		
