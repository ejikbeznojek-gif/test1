Функция ПрочитатьКомплектующиеНоменклатуры (Номенклатура,ТолькоТовар=ложь) Экспорт 
	Запрос=новый запрос;
	запрос.УстановитьПараметр("Товар",Перечисления.ВидыНоменклаутры.Товар);
	запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	
	запрос.Текст="ВЫБРАТЬ
	|	НоменклатураКоплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(НоменклатураКоплектующие.Количество) КАК Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = &Товар
	|	И НоменклатураКоплектующие.Количество > 0
	|	И НоменклатураКоплектующие.Ссылка = &Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	НоменклатураКоплектующие.Номенклатура";
	
	если не ТолькоТовар тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"НоменклатураКоплектующие.Номенклатура.Родитель.ВидНоменклатуры = &Товар","Истина");
	КонецЕсли;
	
	возврат запрос.Выполнить().Выгрузить();
	
	
