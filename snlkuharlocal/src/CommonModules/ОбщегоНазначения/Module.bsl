Функция ЭтоБельё(ПланНабора,НомераСтрокПН,ВидРасчета=Неопределено) Экспорт
	если ВидРасчета=Неопределено тогда
		// Кухарь А.Ю. 15.01.2020 конец
		
		
		Если ТипЗнч(НомераСтрокПН)<>Тип("Массив") ИЛИ НомераСтрокПН.Количество()=0 Тогда
			Возврат Ложь;	
		КонецЕсли;	
		
		Запрос=Новый ("Запрос");
		Запрос.Текст="
		|ВЫБРАТЬ	
		|	Брэнд.СекторХранения КАК СекторХранения
		|ИЗ
		|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
		|ГДЕ
		|	Ссылка = &Ссылка
		|	И НомерСтроки = &НомерСтроки
		|	И Брэнд.СекторХранения=""2""	
		|";
		
		НомерСтроки=НомераСтрокПН[0];
		Если ТипЗнч(НомерСтроки)<>Тип("Число") Тогда
			НомерСтроки=Число(НомерСтроки);	
		КонецЕсли;
		
		Запрос.УстановитьПараметр("Ссылка",		ПланНабора);
		Запрос.УстановитьПараметр("НомерСтроки",НомерСтроки);
		// Кухарь А.Ю. 15.01.2020 начало
		// //Теперь почти всё по ЗНБ, а не по плану набора
	ИначеЕсли ВидРасчета="ЗНБ" тогда
		Запрос=Новый ("Запрос");
		Запрос.Текст="
		|ВЫБРАТЬ первые 1	
		|	Брэнд.СекторХранения КАК СекторХранения
		|ИЗ
		|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
		|ГДЕ
		|	Ссылка = &Ссылка
		|	И НомерЧасти = &НомерСтроки
		|	И Брэнд.СекторХранения=""2""	
		|";	
		Запрос.УстановитьПараметр("Ссылка",		ПланНабора);
		Запрос.УстановитьПараметр("НомерСтроки",НомераСтрокПН);
	КонецЕсли;	 
	// Кухарь А.Ю. 15.01.2020 конец
	
	Возврат НЕ Запрос.Выполнить().Пустой();	 
КонецФункции //ЭтоБельё(ПланНабора,НомераСтрокПН) Экспорт
