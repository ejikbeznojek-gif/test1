Функция ОбработкаСканированияКоробаЧЗДляТСД(ДанныеКороба) Экспорт
	
	СтруктураВозврата = Новый Структура("КодЧЗКороба_Новый, Ошибки, УИД_ЛН, СтруктураНовогоКода", Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(), "", "",
	// Кельманов А.В. - HELP-8583 - 2026.01.20 {
	//Новый Структура("УИДКодаЧЗ, Наименование, Количество, Количество1, ТипШК, ТипУпаковки, Номенклатура"));
	Новый Структура("УИДКодаЧЗ, Наименование, Количество, Количество1, ТипШК, ТипУпаковки, Номенклатура, ЗначениеШтрихкода"));
	// Кельманов А.В. - HELP-8583 - 2026.01.20 }
	
	МассивОшибок = Новый Массив;
	
	СтруктураДанныхКороба = Десериализовать(Десериализовать(ДанныеКороба).Получить());
	
	КодЧЗКороба = СтруктураДанныхКороба.КодЧЗКороба;
	ТипУпаковки = КодЧЗКороба.ТипУпаковки;
	ТипШК = КодЧЗКороба.ТипШК;
	
	ЗНБ = СтруктураДанныхКороба.ЗНБ;
	Накладная = ЗНБ.Накладная;
	
	РеквизитыНакладной = ПолучитьРеквизитыШапки(Накладная, "Контрагент,СостояниеНакладной", "Документ");
	
	Контрагент = РеквизитыНакладной.Контрагент;
	СостояниеНакладной = РеквизитыНакладной.СостояниеНакладной;
	
	УИД_ЛН = СтруктураДанныхКороба.УИД_ЛН;	
	ЛН = СтруктураДанныхКороба.ЛН;
	
	Если Не ЗначениеЗаполнено(ЛН) Тогда
		
		Если ЗначениеЗаполнено(УИД_ЛН) Тогда
			
			НовыйУИД = Новый УникальныйИдентификатор(УИД_ЛН);
			
		Иначе
			
			НовыйУИД = Новый УникальныйИдентификатор;
			
		КонецЕсли;
		
		ЛН = Документы.ЛистНабора.ПолучитьСсылку(НовыйУИД);
		
	КонецЕсли;
	
	ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(Накладная);		
	
	// Кельманов А.В. - Оптимизация работы - 2026.04.10 {
	//Если Не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков 
	Если Не ИспользоватьЛНТолькоДляНабора(Накладная) И Не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков 
	// Кельманов А.В. - Оптимизация работы - 2026.04.10 }
		И ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок Тогда
		
		Если ЕстьЛПСАгрегацией(Накладная) Тогда
			
			МассивОшибок.Добавить("Агрегация начата в листах переукладки");
			
		Иначе
			
			МассивВложенныхШК = КодЧЗКороба.ВложенныеШтрихкоды.ВыгрузитьКолонку("Штрихкод");
			
			ОтсканирШКОшибки = НекорректныеСтатусыМарокЧЗШтукиПриСканировании(КодЧЗКороба, МассивВложенныхШК); 
			
			Если ОтсканирШКОшибки.Количество() > 0 Тогда 
				
				МассивОшибок.Добавить("Во вложениях короба найден ЧЗ отгруженный или списанный!!! Отсканируйте другой короб!");					
				
				Для Каждого ЭлементСоответствия Из ОтсканирШКОшибки Цикл
					
					МассивОшибок.Добавить(СтрШаблон("Статус вложенного ЧЗ %1 в коробку %2", ЭлементСоответствия.Ключ, ЭлементСоответствия.Значение));	
					
				КонецЦикла; 	
				
			Иначе 
				
				МожноИспользоватьФиктКоробки = ПолучитьЗначРеквСпр(Контрагент, "МожноИсполКоробкиИзФиктРНК");
				
				КМНаПереклейку = Ложь;
				
				Если МожноИспользоватьФиктКоробки = Истина Тогда  
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихКодУпаковки
					|ИЗ
					|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
					|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИспользованныеКодыАгрегаций КАК ИспользованныеКодыАгрегаций
					|		ПО ШтрихкодыУпаковокТоваров.Ссылка = ИспользованныеКодыАгрегаций.ШтрихКодУпаковки
					|			И (ИспользованныеКодыАгрегаций.ШтрихКодУпаковки = &ШК)
					|			И (ИспользованныеКодыАгрегаций.Регистратор ССЫЛКА Документ.МаркировкаТоваровИСМП)
					|			И (ИспользованныеКодыАгрегаций.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
					|			И (ИспользованныеКодыАгрегаций.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация))
					|			И (ИспользованныеКодыАгрегаций.Регистратор.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная)
					|ГДЕ
					|	ШтрихкодыУпаковокТоваров.Ссылка = &ШК"; 
					
					Запрос.УстановитьПараметр("ШК", КодЧЗКороба); 
					
					РезультатЗапроса = Запрос.Выполнить();
					
					КМНаПереклейку = РезультатЗапроса.Пустой();
					
				Иначе 
					
					КМНаПереклейку = Истина; 
					
				КонецЕсли;
				
				Если Не КМНаПереклейку Тогда 			 
					
					СтруктураВозврата.КодЧЗКороба_Новый = КодЧЗКороба;
					
				Иначе
					
					рБронирования = Документы.МаркировкаТоваровИСМП.ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста(ЛН, Накладная, Перечисления.ТипыШтрихКодов.Коробка);
					
					ПолучаемыйКодАгрегации = Неопределено;
					
					Если Не рБронирования.Успешно Тогда            
						
						Если СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке
							Или СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена Тогда					
							
							МассивОшибок.Добавить(СтрШаблон("Недопустимый тип основания: '%1' !", ТипЗнч(ЛН)));
							
						Иначе
							
							ОперАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Накладная, ТипШК);
							
							рБронирования = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныйКодАгрегации(ТипШК, ТипУпаковки, ОперАгрегации, Новый Структура("Добавлять", Истина));
							
							Если рБронирования.Успешно Тогда
								
								ПолучаемыйКодАгрегации = рБронирования.Данные;
								
								рДобавления = Документы.МаркировкаТоваровИСМП.ДобавитьШККоробкиВАгрегацию(ОперАгрегации, ЛН, ПолучаемыйКодАгрегации);
								
								Если Не рДобавления.Успешно Тогда
									
									рБронирования.Успешно = Ложь;						
									
									МаркировкаКС.ДобавитьОшибки(рБронирования, рДобавления);
									
								КонецЕсли;
								
							КонецЕсли;	
							
						КонецЕсли;
						
					Иначе
						
						ПолучаемыйКодАгрегации = рБронирования.Данные[0];
						
					КонецЕсли;
					
					Если рБронирования.Успешно Тогда
						
						Запрос = Новый Запрос;
						
						Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
						|	ЛистНабора.КодАгрегации КАК КодАгрегации,
						|	ЛистНабора.Ссылка КАК Ссылка
						|ИЗ
						|	Документ.ЛистНабора КАК ЛистНабора
						|ГДЕ
						|	ЛистНабора.Проведен
						|	И ЛистНабора.КодАгрегации = &КодАгрегации
						|	И ЛистНабора.Ссылка <> &Ссылка";
						
						Запрос.УстановитьПараметр("КодАгрегации", ПолучаемыйКодАгрегации);
						Запрос.УстановитьПараметр("Ссылка", ЛН);
						
						Выборка = Запрос.Выполнить().Выбрать();
						
						Если Выборка.Следующий() Тогда 
							
							МассивОшибок.Добавить(СтрШаблон("Обнаружен дубль кода %1 в %2", ПолучаемыйКодАгрегации, Выборка.Ссылка));
							
						Иначе
							
							СтруктураВозврата.КодЧЗКороба_Новый = ПолучаемыйКодАгрегации; 
							
						КонецЕсли;
						
					Иначе
						
						МаркировкаКС.ДобавитьОшибки(МассивОшибок, рБронирования);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если МассивОшибок.Количество() > 0 Тогда
		
		СтруктураВозврата.Ошибки = СтрСоединить(МассивОшибок, Символы.ПС);
		
	Иначе
		
		СтруктураВозврата.УИД_ЛН = НовыйУИД;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураВозврата.КодЧЗКороба_Новый) Тогда
		
		ЗаполнитьЗначенияСвойств(СтруктураВозврата.СтруктураНовогоКода, СтруктураВозврата.КодЧЗКороба_Новый);
		
		СтруктураВозврата.СтруктураНовогоКода.УИДКодаЧЗ = СтруктураВозврата.КодЧЗКороба_Новый.УникальныйИдентификатор();	
		
	КонецЕсли;
	
	Ответ = Сериализовать(Новый ХранилищеЗначения(Сериализовать(СтруктураВозврата), Новый СжатиеДанных(9)));
	
	Возврат Ответ;
	
КонецФункции

