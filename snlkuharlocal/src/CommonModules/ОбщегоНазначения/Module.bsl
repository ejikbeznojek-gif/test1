Функция ПолучитьДанныеЛистаНабораПоДаннымЭтикеткиФБС (ШКЭтикетки,Контрагент) Экспорт
	
	// Шворобей ВЮ 21.11.2023 ++
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	Запрос.УстановитьПараметр("ШКЭтикетки", СокрЛП(ШКЭтикетки));
	
	МассивСтрокОтбора = Новый Массив();
	МассивСтрокОтбора.Добавить("Штрихкод");         // Озон и Вайлдберриз
	МассивСтрокОтбора.Добавить("ПрефиксЗаказа");    // СберМегаМаркет
	МассивСтрокОтбора.Добавить("НомерЗаказа");      // Яндекс
	
	Для Каждого СтрокаОтбора ИЗ МассивСтрокОтбора Цикл
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛистПереукладки.Ссылка КАК ЛистПереукладки,
		|	ЛистПереукладки.ЛистНабора КАК ЛистНабора, 
		//Валетов + 02,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6861 Ошибка. Было:
		//  |	ЛистПереукладки.ЛистНабора.Дата КАК ЛистНабора,	
		|	ЛистПереукладки.ЛистНабора.Дата КАК ЛистНабораДата,
		//Валетов -		
		|	ЛистПереукладки.ДокОснование КАК Документ,
		|	ЛистПереукладки.НомерЗаказа КАК НомерЗаказа,
		|	ЛистПереукладки.ЛистНабора.КоличествоДокумента КАК Количество,
		|	ЛистПереукладки.ДокОснование.ДатаОтгрузки КАК ДатаОтгрузки
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|ГДЕ
		|	ЛистПереукладки.Дата > &Дата
		|	И ЛистПереукладки.Проведен
		|	И ЛистПереукладки.ДокОснование.Контрагент = &Контрагент
		|	И ЛистПереукладки." + СтрокаОтбора + "  = &ШКЭтикетки";
		
		Результат = Запрос.Выполнить().Выгрузить();
		Если Результат.Количество() > 0 Тогда
			Для каждого СтрТЗ из Результат цикл
				Возврат СтрТЗ;
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	// Шворобей ВЮ 21.11.2023 ++
	
КонецФункции

