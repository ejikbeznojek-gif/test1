//доработка Родионова, для июней, исправление кратности
Функция глПересчет(Знач Сумма1,Знач Валюта1,Знач КурсВалюты1=Неопределено,Знач Валюта2,Знач КурсВалюты2=Неопределено,Знач Округлять=Истина) Экспорт	
	Если Валюта1 = Валюта2 Тогда
		Возврат Сумма1;
	Иначе		
		ВалютаНац 	= ПараметрыСеанса.ВалютаНац;
		ВалютаУпр	= ПараметрыСеанса.ВалютаУпр_2009;
		
		КурсВалюты1=?(КурсВалюты1=Неопределено,ТекущаяДата(),КурсВалюты1);	
		КурсВалюты2=?(КурсВалюты2=Неопределено,ТекущаяДата(),КурсВалюты2);	
		
		Если ТипЗнч(КурсВалюты1)=Тип("Дата") Тогда
			// *** 2011-11-22 курс/кратность (для CNY)
			//КурсВалюты1=ПолучитьКурсВалюты_ПоРусски(Валюта1,КурсВалюты1);
			// ---------- заменено на:
			СтруктураКурсаВалюты1	= ПолучитьКурсВалюты(Валюта1, КурсВалюты1);
			КурсВалюты1				= СтруктураКурсаВалюты1.Курс;
			КратностьВалюты1		= СтруктураКурсаВалюты1.Кратность;
		Иначе
			КратностьВалюты1 = ПолучитьКурсВалюты(Валюта1, ТекущаяДата()).Кратность;
			// курс/кратность (для CNY) 2011-11-22 ***
		КонецЕсли; 
		
		Если ТипЗнч(КурсВалюты2)=Тип("Дата") Тогда
			// *** 2011-11-22 курс/кратность (для CNY)
			//КурсВалюты2=ПолучитьКурсВалюты(Валюта2,КурсВалюты2).Курс;
			// ---------- заменено на:
			СтруктураКурсаВалюты2	= ПолучитьКурсВалюты(Валюта2, КурсВалюты2);
			КурсВалюты2				= СтруктураКурсаВалюты2.Курс;
			КратностьВалюты2		= СтруктураКурсаВалюты2.Кратность;			
		Иначе
			КратностьВалюты2 = ПолучитьКурсВалюты(Валюта2, ТекущаяДата()).Кратность;
			// курс/кратность (для CNY) 2011-11-22 ***
		КонецЕсли;		
		
		// +++ 2011-11-22 курс/кратность (для CNY)
		Если (КратностьВалюты1 <> 1) И (КратностьВалюты1 <> 0) Тогда
			КурсВалюты1 = КурсВалюты1 / КратностьВалюты1;
		КонецЕсли;
		Если (КратностьВалюты2 <> 1) И (КратностьВалюты2 <> 0) Тогда
			КурсВалюты2 = КурсВалюты2 / КратностьВалюты2;
		КонецЕсли;		
		// курс/кратность (для CNY) 2011-11-22 +++
		
		
		Если Валюта1 <> Валюта2 Тогда
			// если валюта товара не совпадает с валютой накладной
			Если  Валюта1=ВалютаНац Тогда //рубли
				
				//Тимофеев Ю.А. 29.11.2023
				//ОШИБКА деление на 0
				//Сумма2=Сумма1/?(Валюта2=ВалютаУпр,КурсВалюты1,КурсВалюты2);	
				
				Если Валюта2=ВалютаУпр Тогда
					делитель = КурсВалюты1;
				Иначе
					делитель = КурсВалюты2;
				КонецЕсли;
				
				Если делитель =0 тогда
					Сумма2=0; //не указан курс валюты 					
					#ЕСЛИ КЛИЕНТ ТОГДА
						Сообщить("Не указан курс валюты, для пересчета");	
					#КОНЕЦЕСЛИ   					
				Иначе
					Сумма2=Сумма1/Делитель;
				КонецЕсли;
				//Тимофеев Ю.А. 29.11.2023
				
				
				Сумма2=?(Округлять,Окр(Сумма2,2,1),Сумма2);			
			ИначеЕсли  Валюта2=ВалютаНац  Тогда
				//Сумма2=Сумма1*?(Валюта1=ВалютаУпр,КурсВалюты2,КурсВалюты1);
				Сумма2=Сумма1*КурсВалюты1;
				Сумма2=?(Округлять,Окр(Сумма2,2,1),Сумма2);
			Иначе
				// если валюта товара не совпадает с валютой накладной, и не рубли
				
				//Тимофеев Ю.А. Начало   25-12-2024
				//
				// было
				//Сумма2=(Сумма1*КурсВалюты1)/КурсВалюты2;
				
				//Стало
				Если КурсВалюты2=0 Тогда
					
					Сумма2=(Сумма1*КурсВалюты1);	
					
					#ЕСЛИ КЛИЕНТ ТОГДА
						Сообщить("Не указан курс валюты 2, для пересчета- без перерасчета.Проверьте");	
					#КОНЕЦЕСЛИ 
				Иначе	
					Сумма2=(Сумма1*КурсВалюты1)/КурсВалюты2; 					
				КонецЕсли;
				
				//Тимофеев Ю.А. Конец    25-12-2024
				
			КонецЕсли;    
		КонецЕсли;
	КонецЕсли;
	
	Возврат Сумма2;
КонецФункции
//крохин конец 07.02.2012

