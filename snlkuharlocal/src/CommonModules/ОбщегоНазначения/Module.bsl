//кухарь 04.07.14 начало
Функция КонтрольРасписанияОтгрузки(ДатаОтгрузки,ПунктДоставки) Экспорт
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	КалендарьДни.Ссылка
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	КалендарьДни.ПраздничныйДень
	|	И КалендарьДни.Дата = &ДатаОтгрузки
	|	И КалендарьДни.Ссылка.ПометкаУдаления = ложь";
	запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда   //праздничный день. отгрузки идут без контроля расписания
		Возврат Истина;
	КонецЕсли;
	
	
	Запрос=новый Запрос;
	Запрос.Текст="ВЫБРАТЬ различные
	|	ДопРеквизитыСправочников.ЗначениеРеквизита как ДеньНедели,
	|	ДопРеквизитыСправочников.ВспомогательноеЗначениеРеквизита как МожноОтгружать
	|ИЗ
	|	РегистрСведений.ДопРеквизитыСправочников КАК ДопРеквизитыСправочников
	|ГДЕ
	|	ДопРеквизитыСправочников.ИмяРеквизита = ""ДеньОтгрузки""
	|	И ДопРеквизитыСправочников.Справочник = &ПунктДоставки";
	запрос.УстановитьПараметр("ПунктДоставки",ПунктДоставки);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()=0 тогда    //расписание для этого пункта доставки ни кем не было установлено
		возврат Истина;
	иначе
		ДеньНеделиОтгрузки=ДеньНедели(ДатаОтгрузки);
		
		Если ДеньНеделиОтгрузки = 1 Тогда 
			ДеньНеделиПрописью = "Понедельник";
		ИначеЕсли ДеньНеделиОтгрузки = 2 Тогда
			ДеньНеделиПрописью = "Вторник";
		ИначеЕсли ДеньНеделиОтгрузки = 3 Тогда 
			ДеньНеделиПрописью = "Среда";
		ИначеЕсли ДеньНеделиОтгрузки = 4 Тогда
			ДеньНеделиПрописью = "Четверг";
		ИначеЕсли ДеньНеделиОтгрузки = 5 Тогда 
			ДеньНеделиПрописью = "Пятница";
		ИначеЕсли ДеньНеделиОтгрузки = 6 Тогда
			ДеньНеделиПрописью = "Суббота";
		ИначеЕсли ДеньНеделиОтгрузки = 7 Тогда
			ДеньНеделиПрописью = "Воскресенье";
		иначе
			#ЕСЛИ КЛИЕНТ ТОГДА
				Сообщить("Отгрузка запрещена, обратитесь в отдел АСУ (Программисты 1С)");
			#КонецЕсли
			возврат ложь;
		КонецЕсли;
		
		СписокРазрешенныхДней=новый СписокЗначений;	
		
		
		
		
		для каждого СтрокаРезультат из результат цикл
			Если ДеньНеделиПрописью=СтрокаРезультат.ДеньНедели и СтрокаРезультат.МожноОтгружать  тогда
				возврат Истина;
			иначе
				если СтрокаРезультат.МожноОтгружать=истина тогда
					СписокРазрешенныхДней.Добавить(СтрокаРезультат.ДеньНедели);
				КонецЕсли;
			КонецЕсли;		
		КонецЦикла;
		
		
		#ЕСЛИ КЛИЕНТ ТОГДА
			если СписокРазрешенныхДней.Количество()>0 тогда
				Сообщить("Отгрузка разрешена в следующие дни недели:");
				для Каждого СтрСписка из СписокРазрешенныхДней цикл
					Сообщить(Строка(СтрСписка.Значение));
				КонецЦикла;
			иначе
				Сообщить("Отгрузка запрещена, обратитесь в отдел АСУ (Программисты 1С)");
			КонецЕсли;
		#КонецЕсли
		возврат ложь;
	КонецЕсли;	
	
КонецФункции
