		//|		КОГДА ШтрихкодыУпаковокТоваров.Владелец.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
		//|				И ШтрихкодыУпаковокТоваров.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
		|		КОГДА ШтрихкодыУпаковокТоваров.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
		// Кельманов А.В. - HELP-8013 - 2025.11.28 }
		|			ТОГДА 1
		|		ИНАЧЕ ШтрихкодыУпаковокТоваров.Количество
		|	КОНЕЦ КАК Количество1,
		|	ШтрихкодыУпаковокТоваров.ТипШК КАК ТипШК,
		|	ШтрихкодыУпаковокТоваров.Владелец КАК Номенклатура,
		|	ПОДСТРОКА(ШтрихкодыУпаковокТоваров.Владелец.ГТИН, 2, 13) КАК ШтрихКод,
		|	ЛОЖЬ КАК ОшибкаПоискаКодаЧЗ,
		|	ИСТИНА КАК СканировалиКодЧЗ,
		|	ВЫБОР
		|		КОГДА ШтрихкодыУпаковокТоваров.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
		|			ТОГДА ШтрихкодыУпаковокТоваров.Владелец.Родитель.ШтукВКоробке
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК Количество,
		|	ЗНАЧЕНИЕ(ПЕречисление.СтатусыКодовМаркировкиФакт.Эмитирован) КАК Статус,
		|	ШтрихкодыУпаковокТоваров.СпособВводаВОборот КАК СпособВводаВОборот
		|
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.Ссылка = &ШтрихКодУпаковки";
		
		Запрос.УстановитьПараметр("ШтрихКодУпаковки", ШтрихКодУпаковки);
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ЭтоОтгрузка Тогда 
			
			МожноИспользовать = Ложь;
			
			Если (Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт 
				Или Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.ПокупкаВРФ  
				Или Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Производство) 
				
				И ((Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте
					// Ихсанов Д. А. Начало 04.01.2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8436
					Или Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Нанесен)
					// Ихсанов Д. А. Конец 04.01.2026
				Или (Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Списан) // Кельманов А.В. - HELP-5585 - 2025.06.18	
				Или (Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Расформирован)) //++Данилова Е.В. 30.05.2025 HELP-5130	
				
				Тогда 		 
				
				МожноИспользовать = Истина;	
				
			ИначеЕсли (Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков 
				Или Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка)  			
				
				И (Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Нанесен 
				Или Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте
				Или Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Распечатан //Валетов + 27,05,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-2262
				Или (Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Списан) // Кельманов А.В. - HELP-5585 - 2025.06.18	
				Или (Выборка.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Расформирован)) //++Данилова Е.В. 26.05.2025 HELP-5130, HELP-5109	
				
				Тогда
				
				МожноИспользовать = Истина;
				// Кухарь А.Ю.  03.12.2025 начало   OUT-173
			ИначеЕсли Выборка.ТипКода = Перечисления.ТипыКодовМаркировки.Набор и  Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.Распечатан тогда
				МожноИспользовать = Истина;	
				// Кухарь А.Ю.  03.12.2025 конец
				
			Иначе
				
				МожноИспользовать = Ложь; 
				
				СтруктураВозврата.КомментарийКОшибке = "Способ ввода в оборот: " + Выборка.СпособВводаВОборот + "; Статус: " + Выборка.Статус;  
				
				//++Данилова Е.В. 02.12.2025  MARK-1869 
				Если Выборка.Статус = Перечисления.СтатусыКодовМаркировкиФакт.ОтгруженПокупателю Тогда
					
					ТекстОшибки = "Код отгружен клиенту "; 
					Если ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") 
						И ТипЗнч(Выборка.Регистратор.ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
						
						ТекстОшибки = ТекстОшибки + Строка(Выборка.Регистратор.ДокОснование.Контрагент) +  " " + Строка(Выборка.Регистратор.ДокОснование); 	
						
					КонецЕсли;
					
					ТекстОшибки = ТекстОшибки + " , замените КМ"; 
					
					СтруктураВозврата.КомментарийКОшибке =  СтруктураВозврата.КомментарийКОшибке + Символы.ПС + ТекстОшибки; 
					
				КонецЕсли;
				МассивСтатусовВыбыл = Новый Массив; 
				МассивСтатусовВыбыл.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Списан);
				МассивСтатусовВыбыл.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Выбыл);
				МассивСтатусовВыбыл.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Карантин);
				Если МассивСтатусовВыбыл.Найти(Выборка.Статус) <> Неопределено Тогда
					
					ТекстОшибки = "Статус кода " + Строка(Выборка.Статус) + ", замените КМ";  	
					СтруктураВозврата.КомментарийКОшибке =  СтруктураВозврата.КомментарийКОшибке + Символы.ПС + ТекстОшибки;
				КонецЕсли;
				
				//--Данилова Е.В. 02.12.2025
				
			КонецЕсли;
			
		Иначе
			
			МожноИспользовать = Истина;
			
		КонецЕсли;
		
		Если МожноИспользовать Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);        
			//+MARK-704 20251126 Михайловский
			Если ЗначениеЗаполнено(СтрНайти(Выборка.ЗначениеШтрихкода, "******")) Тогда
				СтруктураВозврата.КМКоррекция = Истина;
			Иначе
				СтруктураВозврата.КМКоррекция = Ложь;
			КонецЕсли;	
			//-MARK-704 20251126 Михайловский
			Возврат СтруктураВозврата;
			
		КонецЕсли;
		
	КонецЦикла;
	//++Данилова Е.В. 02.12.2025 MARK-1869
	Если ЭтоОтгрузка
		И Выборка.Количество() = 0
		И ( ШтрихКодУпаковки.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт 
		Или ШтрихКодУпаковки.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.ПокупкаВРФ  
		Или ШтрихКодУпаковки.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Производство) Тогда
		
		ТекстОшибки = "Код не принят по ПНК, обратитесь в техподдержку";  	
		СтруктураВозврата.КомментарийКОшибке =  ТекстОшибки;
		
	КонецЕсли; 
	//--Данилова Е.В. 02.12.2025
	
	СтруктураВозврата.ОшибкаПоискаКодаЧЗ = Истина;
	
	ТекстСообщения = "ОбщегоНазначения.ПолучитьСтруктуруДанныхМаркиЧЗПоНаименованию";
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало) / 1000);
	
	Возврат СтруктураВозврата;
	
КонецФункции

