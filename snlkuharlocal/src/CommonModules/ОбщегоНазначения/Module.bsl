	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЛистНабора.Номер,
	|	ЛистНабора.КоличествоКоробок
	|ИЗ
	|	Документ.ЛистНабора КАК ЛистНабора
	|ГДЕ
	|	ЛистНабора.Проведен
	|	И ЛистНабора.Дата = &Дата
	|	И ЛистНабора.ДокОснование = &ДокОснование
	|	И ЛистНабора.Ссылка <> &Ссылка
	|АВТОУПОРЯДОЧИВАНИЕ";
	запрос.УстановитьПараметр("ДокОснование",ЛН.докоснование);
	запрос.УстановитьПараметр("Дата",ЛН.дата);
	запрос.УстановитьПараметр("Ссылка",ЛН.ссылка);
	Рез=запрос.Выполнить().выбрать();
	Пока рез.Следующий() цикл
		Если Число(Прав(Рез.Номер,5))<Число(Прав(ЛН.Номер,5)) тогда
			НомерНачКоробки=НомерНачКоробки+Рез.КоличествоКоробок;
		КонецЕсли;
	КонецЦикла;
	
	
	// Кухарь А.Ю.  08.06.2025 начало
	//НомерКоробкиЛН=Число(Сред(ШК,8,СтрДлина(ШК)-8));
	попытка	
		НомерКоробкиЛН=Число(Сред(ШК,8,СтрДлина(ШК)-8));
	Исключение
		возврат Неопределено;
	КонецПопытки;
	// Кухарь А.Ю.  08.06.2025 конец
	НомерКоробки=НомерНачКоробки+НомерКоробкиЛН-1;
	
	
	
	
	
	
	СтруктураВозврата.Вставить("НомерКоробкиЛН",НомерКоробкиЛН);
	СтруктураВозврата.Вставить("НомерКоробки",НомерКоробки);
	
	
	
	
	
	
	возврат СтруктураВозврата;	
КонецФункции


Функция ПолучитьВсеШкПоНакладной(Накладная, ЕстьЛП = Ложь, ПечатьПоНовому = Ложь) Экспорт
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("НомерКоробки");	
	ТЗ.Колонки.Добавить("ШК");		
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("ЛистНабора");
	ТЗ.Колонки.Добавить("Сканировщик");
	ТЗ.Колонки.Добавить("КоличествоДокумента");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Лист.Ссылка КАК ЛН,
	|	Лист.Сканировщик КАК Сканировщик,
	|	Лист.КоличествоДокумента КАК КоличествоДокумента,
	|	Лист.ШКЛистаНабора КАК ШКЛистаНабора
	|ИЗ
	|	Документ.ЛистНабора КАК Лист
	|ГДЕ
	|	Лист.ДокОснование = &Накладная
	|	И Лист.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	Лист.Дата";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);   
	
	// Кухарь А.Ю. 01.05.2025 начало
	Если ЕстьЛП Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ЛистНабора КАК Лист", "Документ.ЛистПереукладки КАК Лист");   
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Лист.ШКЛистаНабора", "123456789012");
	КонецЕсли;
	// Кухарь А.Ю. 01.05.2025 конец
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Сч = 0;
	
	Пока Результат.Следующий() Цикл	
		
		ЛН = Результат.ЛН;
		
		// Кухарь А.Ю.  04.04.2025 начало
		Если Результат.ШКЛистаНабора = "" И Не ПечатьПоНовому Тогда
			
			ЛНОбъект = ЛН.ПолучитьОбъект();
			ЛНОбъект.СформироватьШКЛистаНабора();
			ЛНОбъект.Записать();
			ЛН = ЛНОбъект.Ссылка;
			
		КонецЕсли;
		// Кухарь А.Ю.  04.04.2025 конец
		
		Сканировщик = Результат.Сканировщик;
		КоличествоДокумента = Результат.КоличествоДокумента; 
		
		// Кухарь А.Ю. 01.05.2025 начало
		Если Не ПечатьПоНовому Тогда 
			// Кухарь А.Ю. 01.05.2025 конец
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	ЛистНабора.ШКЛистаНабора
			|ИЗ
			|	Документ.ЛистНабора КАК ЛистНабора
			|ГДЕ
			|	ЛистНабора.Дата >= &Дата
			|	И ЛистНабора.ШКЛистаНабора = &ШКЛистаНабора
			|
			|СГРУППИРОВАТЬ ПО
			|	ЛистНабора.ШКЛистаНабора";
			
			Запрос.УстановитьПараметр("Дата", НачалоДня(ЛН.Дата));
			Запрос.УстановитьПараметр("ШКЛистаНабора", ЛН.ШКЛистаНабора); 
			
			// Кухарь А.Ю. 01.05.2025 начало
			Если ЕстьЛП Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ЛистНабора КАК ЛистНабора", "Документ.ЛистПереукладки КАК ЛистНабора");
			КонецЕсли;
			// Кухарь А.Ю. 01.05.2025 конец
			
			РезультатТЗ = Запрос.Выполнить().Выгрузить();
			
			Если РезультатТЗ.Количество() > 1 Тогда
				
				ШКЛистаНабора = "";
				
				лнОб = ЛН.получитьобъект();
				лнОб.Записать(РежимЗаписиДокумента.Проведение);
				
				#Если Клиент Тогда
					Предупреждение("Неудачная попытка распечатать этикетку, попробуйте ещё раз.");
				#КонецЕсли
				
				Прервать;
				
			КонецЕсли;
			//Кухарь 15.06.16 конец
			
		КонецЕсли;
		
		Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка Тогда
			
			ТабНоменклатурыПоКоробам = Новый ТаблицаЗначений;
			ТабНоменклатурыПоКоробам.Колонки.Добавить("Номенклатура");
			
			Для Каждого СтрокаТЧ Из ЛН.Товары Цикл
				
				//крохин начало 25.05.2017
				//при СтрокаТЧ.ШтВКоробе=0 считаем, что СтрокаТЧ.ШтВКоробе=1
				//КоличествоКоробов=?(СтрокаТЧ.ШтВКоробе=0,КоличествоКоробов,СтрокаТЧ.количество/СтрокаТЧ.ШтВКоробе);
				КоличествоКоробов = ?(СтрокаТЧ.ШтВКоробе = 0, СтрокаТЧ.Количество, СтрокаТЧ.Количество / СтрокаТЧ.ШтВКоробе);
				//крохин конец 25.05.2017
				
				Для СчКоробов=1 По КоличествоКоробов Цикл
					
					СтрТабНом = ТабНоменклатурыПоКоробам.Добавить();
					СтрТабНом.Номенклатура = СтрокаТЧ.Номенклатура;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Для СчЛн = 1 По Результат.ЛН.КоличествоКоробок Цикл
			
			Если ЛН.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И ТабНоменклатурыПоКоробам.Количество() > 0 Тогда
				
				ТекНоменклатура = ТабНоменклатурыПоКоробам.Получить(СчЛн - 1).Номенклатура;
				КоличествоДокумента = ТекНоменклатура.Родитель.ШтукВКоробке;
				
			Иначе
				
				Если ЛН.Товары.Количество() > 1 Тогда
					
					ТекНоменклатура = ЛН.ГруппыТоваров + " mix";
					
				ИначеЕсли ЛН.Товары.Количество() = 0 Тогда
					
					// Кельманов А.В. - HELP-6996 - 2025.11.13 {
					//ТекНоменклатура = "Номенклатура: Сборная ("+ ЛН.ГруппыТоваров+")";
					ТекНоменклатура = "Номенклатура: " + ЛН.ГруппыТоваров;
					// Кельманов А.В. - HELP-6996 - 2025.11.13 }
					
				Иначе
					
					ТекНоменклатура = "АРТ: " + ЛН.Товары.получить(0).Номенклатура;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Сч = Сч + 1;
			
			СтрТЗ = ТЗ.Добавить();
			СтрТЗ.НомерКоробки = Сч;
			СтрТЗ.Номенклатура = ТекНоменклатура; 
			
			Если Не ПечатьПоНовому Тогда
				ТекШК = Результат.ЛН.ШКЛистаНабора + Формат(СчЛн, "ЧЦ=5; ЧВН="); 
			Иначе
				ТекШК = "123456789012";
			КонецЕсли;
			
			ТекШК = ТекШК + КонтрольныйСимволEAN(ТекШК, 13);
			
			СтрТЗ.ШК = ТекШК;
			СтрТЗ.ЛистНабора = ЛН;
			СтрТЗ.Сканировщик = Сканировщик;
			СтрТЗ.КоличествоДокумента = КоличествоДокумента;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТЗ;	
	
КонецФункции
