Функция ПолучитьРеквизитШапки(Ссылка,ИмяРеквизита,ТипОбъекта=Неопределено) Экспорт
	ПредставлениеРеквизита=СтрЗаменить(ИмяРеквизита,".","_");	
	
	СписокРеквизитов=Новый Соответствие;
	СписокРеквизитов.Вставить(ИмяРеквизита,ПредставлениеРеквизита);
	
	Реквизиты=ПолучитьРеквизитыШапки(Ссылка,СписокРеквизитов,ТипОбъекта);
	Возврат Реквизиты[ПредставлениеРеквизита];
КонецФункции //ПолучитьРеквизитШапки(Ссылка,ИмяРеквизита,ТипОбъекта=Неопределено) Экспорт

Функция ПолучитьРеквизитыШапки(ОбъектСсылка,Знач СписокРеквизитов,ТипОбъекта=Неопределено) Экспорт
	Если ТипЗнч(СписокРеквизитов)=Тип("Строка") Тогда
		СписокЭлементов	=СтрРазделить(СписокРеквизитов,",");
		СписокРеквизитов=Новый Соответствие;
		Для Каждого Элемент Из СписокЭлементов Цикл
			СписокРеквизитов.Вставить(Элемент,СтрЗаменить(Элемент,".","_"));		
		КонецЦикла;
	КонецЕсли;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ Ссылка";
	Для Каждого Элемент Из СписокРеквизитов Цикл
		Запрос.Текст=Запрос.Текст+",
		|	"+Элемент.Ключ+" "+?(ПустаяСтрока(Элемент.Значение),"","КАК "+Элемент.Значение);
	КонецЦикла;
	
	Если ТипОбъекта=Неопределено Тогда
		ТипОбъекта=ТипОбъекта(ОбъектСсылка);	
	КонецЕсли;
	
	Результат=Новый Структура;
	Для Каждого Элемент Из СписокРеквизитов Цикл
		Результат.Вставить(?(ПустаяСтрока(Элемент.Значение),Элемент.Ключ,Элемент.Значение),Неопределено);	
	КонецЦикла; 
	Если ПустаяСтрока(ТипОбъекта) Тогда
		Возврат Результат;	
	КонецЕсли; 
	Запрос.Текст=Запрос.Текст+"
	|ИЗ
	|	"+ТипОбъекта+"."+ОбъектСсылка.Метаданные().Имя+"
	|ГДЕ
	|	Ссылка=&ОбъектСсылка";
	Запрос.УстановитьПараметр("ОбъектСсылка",ОбъектСсылка);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат,Выборка);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьРеквизитыШапки(ОбъектСсылка,СписокРеквизитов) Экспорт

