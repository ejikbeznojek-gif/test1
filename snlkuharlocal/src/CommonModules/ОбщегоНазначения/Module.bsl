Функция ПолучитьДоговорСертификатыФранчайзи(Справочник)  Экспорт
	Запрос = Новый Запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	РеквизитыСправочников.Справочник КАК Справочник,
	|	РеквизитыСправочников.ИмяРеквизита КАК ИмяРеквизита,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	|	И РеквизитыСправочников.Справочник = &Справочник";
	Запрос.УстановитьПараметр("Справочник",Справочник);
	Если ТипЗнч(Справочник) = ТипЗнч(Справочники.Контрагенты.ПустаяСсылка()) Тогда
		Запрос.УстановитьПараметр("ИмяРеквизита","ДоговорСертификатыКонтрагент");
	Иначе
		Запрос.УстановитьПараметр("ИмяРеквизита","ДоговорСертификатыТЦ");
	КонецЕсли;
	Выборка = запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЗначениеРеквизита;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции
