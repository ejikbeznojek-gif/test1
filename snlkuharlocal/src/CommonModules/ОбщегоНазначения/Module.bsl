Функция ПроверитьВЧЗКодыДокумента_ДляТСД(ДанныеДокумента) Экспорт
	
	Ошибки = "";
	
	СтруктураДанныхДокумента = Десериализовать(Десериализовать(ДанныеДокумента).Получить());
	
	ДокДляПроверки = СтруктураДанныхДокумента.Документ;
	
	Если Маркировка_ПИ.ВыполнятьОнлайнПроверкиКМ() Тогда			
		
		Результат = МаркировкаС.ПроверитьКМпоДокументу(ДокДляПроверки);
		
		Если Результат.Успешно = Ложь Тогда
			
			Если Результат.Ошибки.Количество() > 0 Тогда
				
				Ошибки = СтрСоединить(Результат.Ошибки, Символы.ПС);
				
			КонецЕсли;
			
			Если ТипЗнч(Результат.Данные) = Тип("ТаблицаЗначений") И Результат.Данные.Количество() > 0 Тогда
				
				Ошибки = СокрЛП(Ошибки + Символы.ПС + СтрШаблон("Обнаружено %1 ошибок в КМ !", Результат.Данные.Количество()));					

			КонецЕсли;				

		КонецЕсли;
		
		Если Результат.Свойство("ОшибкаЧЗ") И Результат.ОшибкаЧЗ = Истина Тогда
			
			Ошибки = "Ошибка ЧЗ";
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции
	
