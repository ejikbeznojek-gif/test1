//кухарь 11.04.14 начало
Функция ОпределитьДатуАвизацииДокумента (Документ) экспорт
	если 1=2 тогда
		документ=Документы.РасходнаяНакладная.НайтиПоНомеру();
	КонецЕсли;	
	
	//Кухарь 09.08.15 начало
	//Таки потребовалось ставить дату авизации меньше расчётной
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как ДатаАвизации
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &Документ
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = ""ДатаАвизацииДокументаЗаРасчетной"""; 
	запрос.УстановитьПараметр("Документ",Документ.Ссылка);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда
		//Кухарь 04.10.15 начало
		//косяк с типом данных
		//Возврат результат.Получить(0).ДатаАвизации;
		Возврат Дата(результат.Получить(0).ДатаАвизации);
		//Кухарь 04.10.15 конец
	КонецЕсли;	
	//Кухарь 09.08.15 конец	
	
	
	запрос=новый Запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как ДатаАвизации
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &Документ
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = ""ДатаАвизацииДокумента"""; 
	//кухарь 28.08.14 начало
	//запрос.УстановитьПараметр("Документ",Документ);
	запрос.УстановитьПараметр("Документ",Документ.Ссылка);
	//кухарь 28.08.14 конец
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда
		ДатаИзРег=результат.Получить(0).ДатаАвизации;
	иначе
		ДатаИзРег='00010101';
	КонецЕсли;
	
	//Кухарь 25.05.16 начало
	//Теперь тут ещё и ЗТО у него нет реквизита ПунктДоставки
	//если Документ.ПунктДоставки.ДнейВпути>0 и ЗначениеЗаполнено(Документ.ДатаОтгрузки) тогда 		
	//	ДатаИзЗог= Документ.ДатаОтгрузки+Документ.ПунктДоставки.ДнейВпути*24*3600;
	Если Документ.Метаданные().Имя="ЗаявкаВТранспортныйОтдел" тогда
		ПунктДоставки=Документ.ПунктДоставкиПолучатель;
	иначе
		ПунктДоставки=Документ.ПунктДоставки;
	КонецЕсли;       
	если ложь тогда
		документ=Документы.Перемещение.НайтиПоНомеру("");
	КонецЕсли;
	
	//Кухарь 27.10.16 начало
	//Для ПНК новая странная схема
	если Документ.Ссылка.Метаданные().Имя="ПриходнаяНакладная" тогда
		//Кухарь 04.05.18 начало
		//Тип доставки теперь есть в документе
		//если ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда		
		попытка
			если ЗначениеЗаполнено(документ.ТипДоставки) тогда
				ТипДоставки=Документ.ТипДоставки;
			иначе
				ТипДоставки=ПунктДоставки.ТипДоставки;
			КонецЕсли;
		Исключение
			ТипДоставки=ПунктДоставки.ТипДоставки;
		КонецПопытки;
		если ТипДоставки =Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
			//Кухарь 04.05.18 конец
			ДатаИзЗог= Документ.ДатаОтгрузки+24*3600;
			если ДеньНедели(ДатаИзЗог)=6 тогда
				Сдвиг=2*24*3600;
			ИначеЕсли ДеньНедели(ДатаИзЗог)=7 тогда
				сдвиг=24*3600;
			иначе 
				Сдвиг=0;
			КонецЕсли;
			ДатаИзЗог=ДатаИзЗог+сдвиг;
			
		иначе
			ДатаИзЗог= ПустаяДата();
		КонецЕсли;
		//Кухарь 13.07.17 начало
		//Почти такая же для некоторых ПРМ
	ИначеЕсли Документ.Ссылка.Метаданные().Имя="Перемещение"
		и (документ.Ссылка.Склад.ТипСклада=Перечисления.ТипСклада.ОптовыйТЦ
		или документ.Ссылка.Склад.ТипСклада=Перечисления.ТипСклада.РозничныйТЦ 
		или документ.Ссылка.Склад.ТипСклада=Перечисления.ТипСклада.Филиал) и документ.Ссылка.СкладПолучатель.ТипСклада=Перечисления.ТипСклада.Склад  тогда
		ДатаИзЗог= Документ.ДатаОтгрузки;
		если ДеньНедели(ДатаИзЗог)=6 тогда
			Сдвиг=2*24*3600;
		ИначеЕсли ДеньНедели(ДатаИзЗог)=7 тогда
			сдвиг=24*3600;
		иначе 
			Сдвиг=0;
		КонецЕсли;
		ДатаИзЗог=ДатаИзЗог+сдвиг;
		
		//Кухарь 13.07.17 конец	
	иначе	
		//Кухарь 27.10.16 конец
		
		
		если ПунктДоставки.ДнейВпути>0 и ЗначениеЗаполнено(Документ.ДатаОтгрузки) тогда 		
			ДатаИзЗог= Документ.ДатаОтгрузки+ПунктДоставки.ДнейВпути*24*3600;
			//Кухарь 25.05.16 конец	
			//кухарь 06.08.14 начало
			//если Документ.Метаданные().Имя="РасходнаяНакладная" тогда
			//Кухарь 27.10.16 начало
			//Таки для ПНК будет по другому
			//если Документ.Метаданные().Имя="РасходнаяНакладная" или  Документ.Метаданные().Имя="ПриходнаяНакладная"  тогда
			если Документ.Метаданные().Имя="РасходнаяНакладная"  тогда
				//Кухарь 27.10.16 конец
				
				//кухарь 28.11.14 конец
				
				
				
				Сдвиг=ПолучитьСдвигДатыАвизации(Документ);
				ДатаИзЗог=ДатаИзЗог+сдвиг;
			КонецЕсли;
			//кухарь 06.08.14 конец
		иначе
			//Кухарь 25.07.18 начало
			//Если истина, то дата авизации будет ставиться днём отгрузки
			//ДатаИзЗог='00010101';
			ДоставкаВДеньОтгрузки=ложь;
			если ПунктДоставки.ТипДоставки<>Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
				ЗапВРег=РегистрыСведений.РеквизитыСправочников.СоздатьНаборЗаписей();	
				ЗапВРег.Отбор.ИмяРеквизита.значение="ДоставкаВДеньОтгрузки";
				ЗапВРег.Отбор.Справочник.значение=ПунктДоставки;
				ЗапВРег.Отбор.ИмяРеквизита.использование=Истина;
				ЗапВРег.Отбор.Справочник.использование=Истина;
				
				ЗапВРег.Прочитать();
				для каждого СтрЗР из ЗапВРег цикл
					ДоставкаВДеньОтгрузки=СтрЗР.ЗначениеРеквизита;
				КонецЦикла;
			КонецЕсли;
			если ДоставкаВДеньОтгрузки=Истина тогда
				ДатаИзЗог=Документ.Ссылка.ДатаОтгрузки;
			иначе
				ДатаИзЗог='00010101';
			КонецЕсли;
			//Кухарь 25.07.18 конец
			
		КонецЕсли;
		//Кухарь 27.10.16 начало 	
	КонецЕсли;	
	//Кухарь 27.10.16 конец
	
	Возврат Макс(Дата(ДатаИзРег),Дата(ДатаИзЗог));	
	
КонецФункции


//Кухарь 13.02.19 начало
//Иногда нужно устанавливать меньше расчётной человеку без полномочий (отработка коррекций)
//Процедура УстановитьДатуАвизацииДокумента (Документ,ДатаАвизации) экспорт
Процедура УстановитьДатуАвизацииДокумента (Документ,ДатаАвизации,НеПроверятьПолномочия=Неопределено) экспорт
	
	//Кухарь 13.02.19 конец	
	
	//Кухарь 25.05.16 начало
	//Теперь тут ещё и ЗТО у него нет реквизита ПунктДоставки
	//если Документ.ПунктДоставки.ДнейВпути>0 и ЗначениеЗаполнено(Документ.ДатаОтгрузки) тогда 		
	//	ДатаИзЗог= Документ.ДатаОтгрузки+Документ.ПунктДоставки.ДнейВпути*24*3600;
	Если Документ.Метаданные().Имя="ЗаявкаВТранспортныйОтдел" тогда
		ПунктДоставки=Документ.ПунктДоставкиПолучатель;
	иначе
		ПунктДоставки=Документ.ПунктДоставки;
	КонецЕсли;       
	
	если ПунктДоставки.ДнейВпути>0 и ЗначениеЗаполнено(Документ.ДатаОтгрузки) тогда 		
		ДатаИзЗог= Документ.ДатаОтгрузки+ПунктДоставки.ДнейВпути*24*3600;
		//Кухарь 25.05.16 конец	
		
		//при определении расчётной даты нужно учитывать график отгрузки ТК
		//если Документ.Метаданные().Имя="РасходнаяНакладная" тогда
		если Документ.Метаданные().Имя="РасходнаяНакладная" или  Документ.Метаданные().Имя="ПриходнаяНакладная"  тогда
			//кухарь 28.11.14 конец
			Сдвиг=ПолучитьСдвигДатыАвизации(Документ);
			ДатаИзЗог=ДатаИзЗог+сдвиг;
		КонецЕсли;
		//кухарь 23.10.14 конец
		
		
	иначе 
		ДатаИзЗог='00010101';
	КонецЕсли;
	//кухарь 30.07.14 конец
	//кухарь 03.09.14 начало
	//запретим делать записи для не записанных накладных
	если Документ.дата<>'00010101' тогда	
		//кухарь 03.09.14 конец
		если ДатаАвизации>=ДатаИзЗог тогда	
			ЗаписьВРег=РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьМенеджерЗаписи();
			ЗаписьВРег.Документ=Документ;
			//Кухарь 09.08.15 начало
			//Таки потребовалось ставить дату авизации меньше расчётной
			//ЗаписьВРег.ИмяРеквизита="ДатаАвизацииДокумента";
			//Кухарь 13.02.19 начало
			//Иногда нужно устанавливать меньше расчётной человеку без полномочий (отработка коррекций)			
			//если ПолучитьПолномочиеПользователя("УстановкаДатыАвизацииМеньшеРасчетной")  тогда
			если ПолучитьПолномочиеПользователя("УстановкаДатыАвизацииМеньшеРасчетной")  или НеПроверятьПолномочия=истина тогда
				//Кухарь 13.02.19 конец	
				ЗаписьВРег.ИмяРеквизита="ДатаАвизацииДокументаЗаРасчетной";
			Иначе 
				ЗаписьВРег.ИмяРеквизита="ДатаАвизацииДокумента";
			КонецЕсли;
			//Кухарь 09.08.15 конец
			ЗаписьВРег.Период=Документ.Дата;
			ЗаписьВРег.ЗначениеРеквизита=ДатаАвизации;
			ЗаписьВРег.Записать();
			//Кухарь 04.10.15 начало
			#ЕСЛИ КЛИЕНТ ТОГДА
				//Кухарь 04.10.15 конец
				Сообщить("Дата авизации изменена");
				//Кухарь 04.10.15 Начало
			#КонецЕсли
			//Кухарь 04.10.15 конец
		иначе
			//Кухарь 09.08.15 начало
			//Таки потребовалось ставить дату авизации меньше расчётной
			//Сообщить("Нельзя ставить дату авизации, меньше чем расчётная.");
			//Кухарь 13.02.19 начало
			//Иногда нужно устанавливать меньше расчётной человеку без полномочий (отработка коррекций)			
			//если ПолучитьПолномочиеПользователя("УстановкаДатыАвизацииМеньшеРасчетной")  тогда
