//крохин конец 20.01.2020

// 	Кухарь А.Ю. 28.01.2020 начало
// 	Процедура создающая записи в РС из которых регл. заданием отправляются письма
//	СписокПолучателей - строка или список значений со строками. Если в строчке несколько адресатов, то их нужно разделить ##
//	ТекстПисьма и ТемаПисьма - строка
//	Основание - ссылка на документ, по которому уведомление
//  Вложение - двоичные данные
//	ИмяФайла - строка
//	УчетнаяЗаписьОтправителя - строка почтового адреса или ссылка на справочник УчетныеЗаписиЭлектроннойПочты
Функция СформироватьВнутреннееУведомление(СписокПолучателей, ТекстПисьма, ТемаПисьма, Основание = Неопределено, Вложение = Неопределено, ИмяФайла = "", УчетнаяЗаписьОтправителя = "",СписокВКопию="",Счетчик=0) экспорт
	
	если типзнч(СписокПолучателей)=тип("Строка") тогда
		СписокАдресов=СписокПолучателей
	ИначеЕсли типзнч(СписокПолучателей)=тип("СписокЗначений") тогда
		СписокАдресов="";
		для каждого Стр из СписокПолучателей цикл
			если Найти(СписокАдресов,Стр.Значение)=0 тогда
				СписокАдресов=СписокАдресов+Стр.Значение+"##";
			КонецЕсли;
		КонецЦикла;
		СписокАдресов=лев(СписокАдресов,СтрДлина(СписокАдресов)-2);
	иначе 
		Возврат "Неправильный список получателей. Разрешены строка и список значений.";
	КонецЕсли;
	
	///Тимофеев Ю.А. Начдало 03.08.2023 
	//список получателей копии
	если типзнч(СписокВКопию)=тип("Строка") тогда
		СписокПолучателейКопии=СписокВКопию;
	ИначеЕсли типзнч(СписокВКопию)=тип("СписокЗначений") тогда
		СписокПолучателейКопии="";
		для каждого Стр из СписокВКопию цикл
			если Найти(СписокПолучателейКопии,Стр.Значение)=0 тогда
				СписокПолучателейКопии=СписокПолучателейКопии+Стр.Значение+"##";
			КонецЕсли;
		КонецЦикла;
		СписокПолучателейКопии=лев(СписокПолучателейКопии,СтрДлина(СписокПолучателейКопии)-2);
	КонецЕсли;
	///Тимофеев Ю.А. конец 03.08.2023 
	
	
	
	
	
	
	если СписокАдресов="" или найти(СписокАдресов,"@")=0 или найти(СписокАдресов,".")=0  тогда
		Возврат "Пустой список получателей";
	КонецЕсли;
	
	Если ТекстПисьма= "" тогда
		Возврат "Пустой текст письма";
	КонецЕсли;
	
	ПереносСтроки="<br>";
	
	ТекстПисьма=СтрЗаменить(ТекстПисьма,символы.ПС,ПереносСтроки);
	ТекстПисьма=СтрЗаменить(ТекстПисьма,символы.НПП,ПереносСтроки);
	ТекстПисьма=СтрЗаменить(ТекстПисьма,символы.ВК,ПереносСтроки);
	
	ЗаписьВРег = РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
	
	//Тимофеев Ю.А. Начало 09.08.2023
	//ЗаписьВРег.ДатаСозданияПисьма = ТекущаяДата(); 	
	//ДатаСозданияПисьма = ВернутьСвободнуюДатуЗаписи(ТекущаяДата(),Основание);
	
	//Тимофеев Ю.А. Начало 17.08.2023
	ДатаСозданияПисьма = ТекущаяДата()+Счетчик; //разница на 1 секунду позволит создать несколько записей
	//Тимофеев Ю.А. Начало 17.08.2023
	
	ЗаписьВРег.ДатаСозданияПисьма = ДатаСозданияПисьма;
	//Тимофеев Ю.А. конец 09.08.2023  	
	
	ЗаписьВРег.период = ЗаписьВРег.ДатаСозданияПисьма;
	ЗаписьВРег.Основание = Основание;
	ЗаписьВРег.ТекстПисьма = ТекстПисьма;
	ЗаписьВРег.ТемаПисьма = ТемаПисьма;
	ЗаписьВРег.СписокПолучателей = СписокАдресов; 
	///Тимофеев Ю.А. Начдало 03.08.2023
	ЗаписьВРег.СписокПолучателейКопии = СписокПолучателейКопии;
	///Тимофеев Ю.А. конец 03.08.2023
	
	// Шворобей ВЮ 22.09.2022 ++
	Если ТипЗнч(УчетнаяЗаписьОтправителя) = Тип("Строка") И СокрЛП(УчетнаяЗаписьОтправителя) <> "" Тогда
		ЗаписьВРег.УчетнаяЗаписьОтправителя = СокрЛП(УчетнаяЗаписьОтправителя);
	ИначеЕсли ТипЗнч(УчетнаяЗаписьОтправителя) = Тип("СправочникСсылка.УчетныеЗаписиЭлектроннойПочты") Тогда
		ЗаписьВРег.УчетнаяЗаписьОтправителя = СокрЛП(УчетнаяЗаписьОтправителя.АдресЭлектроннойПочты);
	КонецЕсли;
	// Шворобей ВЮ 22.09.2022 ++
	
	Если Вложение = Неопределено И СокрЛП(ИмяФайла) <> "" Тогда
		ЗаписьВРег.ИмяФайлаВложения = ПолучитьЧастьИмениФайла(Имяфайла,"Имя");
		ЗаписьВРег.Вложение = Новый ХранилищеЗначения(Новый ДвоичныеДанные(ИмяФайла), Новый СжатиеДанных(9));
	КонецЕсли;
	Если Вложение <> Неопределено И СокрЛП(ИмяФайла) <> "" Тогда
		ЗаписьВРег.ИмяФайлаВложения = ИмяФайла;
		ЗаписьВРег.Вложение = Новый ХранилищеЗначения(Вложение, Новый СжатиеДанных(9));
	КонецЕсли;
	
	Попытка
		ЗаписьВРег.Записать();
	Исключение
		Возврат ОписаниеОшибки();
	КонецПопытки;
	
	Возврат "";
	
КонецФункции
// Кухарь А.Ю. 28.01.2020 конец


//Тимофеев Ю.А. 09.08.2023
//так измерения у регистра ДатаЗаписи и Основание
//чтобы ДатаЗаписи не повторялась 
//вернем свободную секунду
Функция ВернутьСвободнуюДатуЗаписи(ДатаЗап,Основание) 
	МенеджерЗаписи = РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ДатаСозданияПисьма  = ДатаЗап;
	МенеджерЗаписи.Основание           = Основание;
	МенеджерЗаписи.Прочитать();
	Если МенеджерЗаписи.Выбран() Тогда
		//если есть уже запись -увеличим на секунду
		ДатаЗап=МенеджерЗаписи.ДатаСозданияПисьма+1;
		ВернутьСвободнуюДатуЗаписи(ДатаЗап,Основание);		
	Иначе
		Возврат ДатаЗап;
	КонецЕсли;    	
КонецФункции	
