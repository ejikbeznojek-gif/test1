			#КонецЕсли		
			ПараметрыСеанса.ДатаЗапретаВидимости	=ДатаЗапретаВидимости;		
		КонецЕсли;		
		ПараметрыСеанса.КонтрольДатыВидимости	=Истина;
	Иначе				
		#Если Клиент ТОГДА
			Если ПараметрыСеанса.КонтрольДатыВидимости И ЗначениеЗаполнено(ПараметрыСеанса.Пользователь.Интерфейс) Тогда
