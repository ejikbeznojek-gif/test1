Функция ОбновитьЗначКМКонтрИнверсРег(МаркаЧЗ, ТекЗнач, НовЗнач) Экспорт
	//ОбновитьЗначКМ(ДанныеМаркиЧЗ.МаркаЧЗ, ДанныеМаркиЧЗ.ЗначениеШтрихкода, Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(ДанныеДубльПров))); 
	Рез = ""; 
	Прод = Истина;
	Если НЕ Лев(СокрЛП(ТекЗнач), 31) = Лев(СокрЛП(НовЗнач), 31) Тогда
		Если Лев(СокрЛП(ТекЗнач), 31) = СМенитьРег(Лев(СокрЛП(НовЗнач), 31)) Тогда
			Рез = "Проверьте нажат ли CapsLock! Если нажат-нажмите на эту клавишу!";
			НовЗнач1 = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(СМенитьРег(НовЗнач)));
		Иначе
			Прод = Ложь;
			Рез = "Корректировка КМ не зафиксирована, проблема соответствия sgtin";
			НовЗнач1 = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(СМенитьРег(НовЗнач)));
		КонецЕсли;	
	Иначе
		НовЗнач1 = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(НовЗнач));
	КонецЕсли;	  
	Если Прод Тогда
		Попытка	
			Если ЗначениеЗаполнено(МаркаЧЗ) Тогда
				Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
					ОбМаркаЧЗ = МаркаЧЗ.ПолучитьОбъект();
					ОбМаркаЧЗ.ЗначениеШтрихкода = НовЗнач1;
					ОбМаркаЧЗ.Записать();
				Иначе
					МенЗап = РегистрыСведений.КорректировкаЗначениеКМ.СоздатьМенеджерЗаписи();
					МенЗап.ШтрихКодУпаковки =  МаркаЧЗ;
					МенЗап.ЗначениеШтрихкода = ТекЗнач;
					МенЗап.ЗначениеШтрихкода1 = НовЗнач1;
					МенЗап.Записать();
				КонецЕсли;	
			КонецЕсли;
		Исключение
		КонецПопытки; 
	Иначе
	КонецЕсли;
	Возврат Рез;
КонецФункции

Функция СМенитьРег(Вх) Экспорт
	Рез = "";
	п= 1;
	Пока п <= СтрДлина(Вх) Цикл
		ТекС = Сред(Вх, п, 1);
		номс = КодСимвола(ТекС);
		Если (номс >= 65) И (номс <= 90) Тогда
			Рез = Рез + Символ(97 + (номс - 65));	
		ИначеЕсли (номс >= 97) И (номс <= 122) Тогда
			Рез = Рез + Символ(65 + (номс - 97));
		Иначе     
			Рез = Рез + ТекС;
		КонецЕсли;	
		п = п + 1;
	КонецЦикла;	
	Возврат Рез;
КонецФункции //+MARK-3664 20260419 Михайловский

