	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка = &КодАгрегации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК ШК_Родитель,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВложенныеВторойУровень
	|ИЗ
	|	ВложенныеПервыйУровень КАК ВложенныеПервыйУровень
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|		ПО ВложенныеПервыйУровень.Штрихкод = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК ШК_Родитель,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВложенныеТретийУровень
	|ИЗ
	|	ВложенныеВторойУровень КАК ВложенныеВторойУровень
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|		ПО ВложенныеВторойУровень.Штрихкод = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК ШК_Родитель,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВложенныеЧетвёртыйУровень
	|ИЗ
	|	ВложенныеТретийУровень КАК ВложенныеТретийУровень
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|		ПО ВложенныеТретийУровень.Штрихкод = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК ШК_Родитель,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВложенныеПятыйУровень
	|ИЗ
	|	ВложенныеЧетвёртыйУровень КАК ВложенныеЧетвёртыйУровень
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|		ПО ВложенныеЧетвёртыйУровень.Штрихкод = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныеПервыйУровень.ШК_Родитель КАК ШК_Родитель,
	|	ВложенныеПервыйУровень.Штрихкод КАК Штрихкод
	|ПОМЕСТИТЬ ВТ_Вложенные
	|ИЗ
	|	ВложенныеПервыйУровень КАК ВложенныеПервыйУровень
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныеВторойУровень.ШК_Родитель,
	|	ВложенныеВторойУровень.Штрихкод
	|ИЗ
	|	ВложенныеВторойУровень КАК ВложенныеВторойУровень
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныеТретийУровень.ШК_Родитель,
	|	ВложенныеТретийУровень.Штрихкод
	|ИЗ
	|	ВложенныеТретийУровень КАК ВложенныеТретийУровень
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныеЧетвёртыйУровень.ШК_Родитель,
	|	ВложенныеЧетвёртыйУровень.Штрихкод
	|ИЗ
	|	ВложенныеЧетвёртыйУровень КАК ВложенныеЧетвёртыйУровень
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныеПятыйУровень.ШК_Родитель,
	|	ВложенныеПятыйУровень.Штрихкод
	|ИЗ
	|	ВложенныеПятыйУровень КАК ВложенныеПятыйУровень
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Вложенные.ШК_Родитель КАК ШК_Родитель,
	|	ВТ_Вложенные.Штрихкод КАК Штрихкод,
	|	ВТ_Вложенные.Штрихкод.Владелец КАК Номенклатура
	// Кельманов А.В. - HELP-4798 - 2025.05.20 {
	|	,
	|	ПОДСТРОКА(ВТ_Вложенные.Штрихкод.Владелец.ГТИН, 2, 13) КАК ЛинейныйШК
	// Кельманов А.В. - HELP-4798 - 2025.05.20 }
	|ИЗ
	|	ВТ_Вложенные КАК ВТ_Вложенные
	|ГДЕ
	|	ВТ_Вложенные.ШК_Родитель.ТипШК <> ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И ВТ_Вложенные.Штрихкод.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)";
	
	Запрос.УстановитьПараметр("КодАгрегации", КодАгрегации);
	
	ТЗ_Вложенные = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗ_Вложенные;
	
КонецФункции

// Кухарь А.Ю.  17.03.2024 начало
Функция ЗаполнитьТаблицуМарокИзХКМ (ДокОснование) экспорт
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодКоробки = &ПустойШК
	|			ТОГДА ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки
	|		ИНАЧЕ ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодКоробки
	|	КОНЕЦ КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
	|ГДЕ
	|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка.Проведен
	| И	ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка.ДокОснование В(&ДокОснование)  
	|	И ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка.ПланФакт = &ПланФакт"; 
	Запрос.УстановитьПараметр("ПустойШК",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка()); 
	
	если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") тогда
		РеквизитыШапки=ПолучитьРеквизитыШапки(ДокОснование,"ДокОснование,КодОперации","Документ");
		ДокОснованиеХКМ=РеквизитыШапки.ДокОснование;
		КодОперации=РеквизитыШапки.КодОперации;
		
		если КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР  тогда
			если ТипЗнч(ДокОснованиеХКМ)<>Тип("ДокументСсылка.ЗаказПоставщику") тогда
				Сообщить("Неподходящее док. основание у ПНК. Должно быть ЗПС, а сейчас "+Строка(ТипЗнч(ДокОснованиеХКМ)));
				ТаблицаВозврата=новый ТаблицаЗначений;
				ТаблицаВозврата.Колонки.Добавить("ШтрихкодУпаковки");
				возврат ТаблицаВозврата;
			КонецЕсли;
			// Кухарь А.Ю.  24.03.2025 начало
			//запрос.УстановитьПараметр("ДокОснованиеХКМ",РеквизитыШапки.ДокОснование);
			//Валетов + 09,04,2025 Добавил поиск по ДокОснованию, если ТЧ ЗПС пустая.
			//Пустая Задача
			Если ДокОснование.ЗаказыПоставщикам.Количество() > 0 Тогда
				ДокОснованиеХКМ=ДокОснование.ЗаказыПоставщикам.Выгрузить().ВыгрузитьКОлонку("ЗПС");
			Иначе
				ДокОснованиеХКМ = новый Массив;
				ДокОснованиеХКМ.Добавить(ДокОснование.ДокОснование);
			КонецЕсли;
			//Валетов -
			// Кухарь А.Ю.  24.03.2025 конец
			ПланФакт=Перечисления.ПланФакт.Факт;  //У ПНК закупки - планом является факт от ЗПС
		иначе
			ДокОснованиеХКМ=ДокОснование;	
			ПланФакт=Перечисления.ПланФакт.План;
			
		КонецЕсли;		
	иначе
		ДокОснованиеХКМ=ДокОснование;
		ПланФакт=Перечисления.ПланФакт.Факт;
		
	КонецЕсли;
	//Валетов + 02,04,2025  ПустаяЗадача
	//Адаптация под исправление Андрея по массиву ЗПС при приемке ПНК 
	Если ТипЗнч(ДокОснованиеХКМ) <> Тип("Массив") Тогда
		ДокОснованиеХКМ = новый Массив;
		ДокОснованиеХКМ.Добавить(ДокОснование);
	КонецЕсли;
	//Валетов-
	
	Запрос.УстановитьПараметр("ДокОснование",ДокОснованиеХКМ); 
	Запрос.УстановитьПараметр("ПланФакт",ПланФакт); 	
	// Кухарь А.Ю.  22.10.2024 конец
	
	ТаблицаМарокИзХКМ=запрос.Выполнить().Выгрузить();
	
	ТаблицаМарокИзХКМ.Индексы.Добавить("ШтрихкодУпаковки");
	Возврат ТаблицаМарокИзХКМ;
КонецФункции

