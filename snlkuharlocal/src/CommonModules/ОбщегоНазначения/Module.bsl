	РеквизитыШапки = СтруктураДокумента.РеквизитыШапки;
	МассивТовары = СтруктураДокумента.МассивТовары;
	МассивШтрихкодыУпаковок = СтруктураДокумента.МассивШтрихкодыУпаковок;
	МассивОшибкиСотрудников = СтруктураДокумента.МассивОшибкиСотрудников;
	МассивЗаданияНабора = СтруктураДокумента.МассивЗаданияНабора;
	МассивШтрихкодыКоробокДляАгрегации = СтруктураДокумента.МассивШтрихкодыКоробокДляАгрегации; // Кельманов А.В. - HELP-5128 - 2025.10.01
	
	ЛНУжеВыгружались = ОбщегоНазначения_ПИ.ЗНБУжеЗагружен(РеквизитыШапки.ЗНБ);
	
	Если ЛНУжеВыгружались Тогда
		
		Ошибки = "ЗНБ уже выгружался из ТСД в 1С. Нельзя выгружать листы набора в базу склада.";
		
		Возврат Ошибки;
		
	КонецЕсли;
	
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 {
	//РеквизитыШапкиЗНБ = ПолучитьРеквизитыШапки(РеквизитыШапки.ЗНБ, "Накладная,СостояниеНакладной", "Документ");
	РеквизитыШапкиЗНБ = ПолучитьРеквизитыШапки(РеквизитыШапки.ЗНБ, "Накладная,СостояниеНакладной,Сектор", "Документ");
	// Кельманов А.В. - Оптимизация работы - 2026.04.23 }
	
	СостояниеЗНБ = РеквизитыШапкиЗНБ.СостояниеНакладной;
	
	Если СостояниеЗНБ <> Перечисления.СостоянияНакладной.ВНаборе И СостояниеЗНБ <> Перечисления.СостоянияНакладной.ОжиданиеСканирования  
		И СостояниеЗНБ <> Перечисления.СостоянияНакладной.Сканирование Тогда
		
		Ошибки = "Состояние ЗНБ: " + СостояниеЗНБ + ". Нельзя выгружать листы набора в базу склада.";
		
		Возврат Ошибки;
		
	КонецЕсли;		
	
	Накладная = РеквизитыШапкиЗНБ.Накладная;
	
	Новый_UID = Новый УникальныйИдентификатор(РеквизитыШапки.УИД);
	
	ЛН_НоваяСсылка = Документы.ЛистНабора.ПолучитьСсылку(Новый_UID);
	
	ЛН_Объект = ЛН_НоваяСсылка.ПолучитьОбъект();
	
	Если ЛН_Объект = Неопределено Тогда
		
		Если РеквизитыШапки.ПометкаУдаления Тогда
			
			Возврат Ошибки;
			
		КонецЕсли;
		
		ЛН_Объект = Документы.ЛистНабора.СоздатьДокумент();
		
		ЛН_Объект.УстановитьСсылкуНового(ЛН_НоваяСсылка);
		
	КонецЕсли;
	
	Если РеквизитыШапки.Свойство("КодУзла") Тогда
		
		ЛН_Объект.УзелТСД = ПланыОбмена.МобильныеТСД.НайтиПоКоду(РеквизитыШапки.КодУзла);
		
	КонецЕсли;
	
	ЛН_Объект.Товары.Очистить();
	ЛН_Объект.ШтрихкодыУпаковок.Очистить();
	ЛН_Объект.ОшибкиСотрудников.Очистить();
	ЛН_Объект.ЗаданияНабора.Очистить(); 
