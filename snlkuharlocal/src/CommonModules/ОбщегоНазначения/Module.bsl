Функция ПолучитьТаблицуТоваровКАдресногоХранения (Знач ДокументСсылка, Знач ИмяТЧ,ДопПараметры = Неопределено) Экспорт  
	ИмяДокумента = ДокументСсылка.Метаданные().Имя;  
	ИмяПоляНоменклатура = "Номенклатура";
	ИмяПоляКоличество = "Количество";
	СсылкаПН = "";
	
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда  
		Если ДопПараметры.Свойство("ИмяПоляНоменклатура") тогда  
			ИмяПоляНоменклатура = ДопПараметры.ИмяПоляНоменклатура;		
		КонецЕсли;   	
		Если ДопПараметры.Свойство("ИмяПоляКоличество") тогда  
			ИмяПоляКоличество = ДопПараметры.ИмяПоляКоличество;		
		КонецЕсли;	
		
		Если ДопПараметры.Свойство("ПН") тогда  
			СсылкаПН = ДопПараметры.ПН;		
		КонецЕсли;    
		
	КонецЕсли;
	
	Запрос = новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура КАК Номенклатура, 
	|	ТаблицаТоваров.Номенклатура.Код КАК Код,
	|	СУММА(ТаблицаТоваров.Количество) КАК Количество
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК ТаблицаТоваров
	|ГДЕ
	|	ТаблицаТоваров.Ссылка = &ДокументСсылка
	|	И ТаблицаТоваров.Количество > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаТоваров.Номенклатура";      
	
	запрос.Текст = СтрЗаменить(запрос.Текст,"Документ.РасходнаяНакладная"	,"Документ."+ИмяДокумента);	
	запрос.Текст = СтрЗаменить(запрос.Текст,"Товары КАК ТаблицаТоваров"		,ИмяТЧ+ " КАК ТаблицаТоваров");
	запрос.Текст = СтрЗаменить(запрос.Текст,"ТаблицаТоваров.Номенклатура"	,"ТаблицаТоваров."+ИмяПоляНоменклатура);	
	запрос.Текст = СтрЗаменить(запрос.Текст,"ТаблицаТоваров.Количество"		,"ТаблицаТоваров."+ИмяПоляКоличество);	
	запрос.УстановитьПараметр("ДокументСсылка",ДокументСсылка);  
	
	ТаблицаИсходная  = запрос.Выполнить().Выгрузить();
	//ТаблицаСАдресами = ВозвратНоменклатурыВАдресеВременная(ТаблицаИсходная);   
	
	//ТЮА 03.02.2026         сссылка на накладную
	ТаблицаСАдресами = ADRESS.ВернутьОстатокНоменклатурыВАдресномХранении(ТаблицаИсходная, ДокументСсылка); 
	
	если ТаблицаСАдресами = Неопределено тогда   //Тут можно воткнуть отключение адресного хранения, вернув неопределено   
		ТаблицаСАдресами = новый ТаблицаЗначений;
		ТаблицаСАдресами.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		ТаблицаСАдресами.Колонки.Добавить("КоличествоВСекторе",Новый ОписаниеТипов("Число"));
		ТаблицаСАдресами.Колонки.Добавить("Сектор",Новый ОписаниеТипов("Строка"));
	КонецЕсли;
	
	запрос.УстановитьПараметр("ТаблицаИсходная",ТаблицаИсходная); 	
	запрос.УстановитьПараметр("ТаблицаСАдресами",ТаблицаСАдресами); 	
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаИсходная.Номенклатура КАК Номенклатура,
	               |	ТаблицаИсходная.Количество КАК Количество,
	               |	ЛОЖЬ КАК АдресноеХранение
	               |ПОМЕСТИТЬ ВТИсходная
	               |ИЗ
	               |	&ТаблицаИсходная КАК ТаблицаИсходная
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаСАдресами.Номенклатура КАК Номенклатура,
	               |	ТаблицаСАдресами.КоличествоВСекторе КАК КоличествоВСекторе
	               |ПОМЕСТИТЬ ВТСАдресамиНачальная
	               |ИЗ
	               |	&ТаблицаСАдресами КАК ТаблицаСАдресами
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТСАдресамиНачальная.Номенклатура КАК Номенклатура,
	               |	СУММА(ВТСАдресамиНачальная.КоличествоВСекторе) КАК КоличествоВСекторе,
	               |	ИСТИНА КАК АдресноеХранение
	               |ПОМЕСТИТЬ ВтАдресаСвернутая
	               |ИЗ
	               |	ВТСАдресамиНачальная КАК ВТСАдресамиНачальная
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТСАдресамиНачальная.Номенклатура
	               |
	               |ИМЕЮЩИЕ
	               |	СУММА(ВТСАдресамиНачальная.КоличествоВСекторе) > 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТИсходная.Номенклатура КАК Номенклатура,
	               |	МАКСИМУМ(ЕСТЬNULL(ВтАдресаСвернутая.АдресноеХранение, ВТИсходная.АдресноеХранение)) КАК АдресноеХранение
	               |ИЗ
	               |	ВТИсходная КАК ВТИсходная
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВтАдресаСвернутая КАК ВтАдресаСвернутая
	               |		ПО ВТИсходная.Номенклатура = ВтАдресаСвернутая.Номенклатура
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТИсходная.Номенклатура";          
	
	   возврат запрос.Выполнить().Выгрузить();
	 
КонецФункции         


Функция ВозвратНоменклатурыВАдресеВременная (знач ТаблицаНоменклатуры)
	возврат Неопределено;
	запрос = новый запрос;   
	Запрос.УстановитьПараметр("ТЗ",ТаблицаНоменклатуры);
	запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	0 КАК КоличествоВСекторе,
	               |	"""" КАК Сектор
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.Номенклатура КАК Номенклатура,
	               |	ВТ.КоличествоВСекторе КАК КоличествоВСекторе,
	               |	ВТ.Сектор КАК Сектор
