Функция ПолучитьСтруктуруВалютИКурсы(ВалютаДокумента,КурсДокумента,ДатаДокумента,Договор=Неопределено) Экспорт
	Результат			=Новый Структура;
	
	Результат.Вставить("ВалютаДокумента",		ВалютаДокумента);
	Результат.Вставить("КурсДокумента",			КурсДокумента);
	Результат.Вставить("КурсВалютыДокумента",	ПолучитьКурсВалюты(ВалютаДокумента,ДатаДокумента).Курс);
	
	ВалютаРасчетов=ПолучитьВалютуРасчетов(Договор);
	Результат.Вставить("ВалютаРасчетов",		ВалютаРасчетов);
	Результат.Вставить("КурсВалютыРасчетов",	ПолучитьКурсВалюты(ВалютаРасчетов,ДатаДокумента).Курс);
	
	Результат.Вставить("ВалютаНац",				ПараметрыСеанса.ВалютаНац);
	
	Доллары		= Справочники.Валюты.НайтиПоКоду("840");
	Результат.Вставить("Доллары",				Доллары);
	Результат.Вставить("КурсДоллара",			ПолучитьКурсВалюты(Доллары,ДатаДокумента).Курс);
	
	Евро		= Справочники.Валюты.НайтиПоКоду("978");
	Результат.Вставить("Евро",					Евро);
	Результат.Вставить("КурсЕвро",				ПолучитьКурсВалюты(Евро,ДатаДокумента).Курс);
	
	ВалютаУпр	= ?(ДатаДокумента>='20090101',ПараметрыСеанса.ВалютаУпр_2009,ПараметрыСеанса.ВалютаУпр);
	Результат.Вставить("ВалютаУпр",				ВалютаУпр);
	Результат.Вставить("КурсВалютаУпр",			ПолучитьКурсВалюты(ВалютаУпр,ДатаДокумента).Курс);
	
	Возврат Результат;
КонецФункции

