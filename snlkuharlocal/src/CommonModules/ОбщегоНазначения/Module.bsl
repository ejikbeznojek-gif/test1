// Кельманов А.В. - ИЗМ-0000000124 - 2026.07.01
// Ищет имеющийся созданный ранее ЛП по данной накладной, совпадающий по продукции с переданным ЛСК
// и устанавливает переданный ЛСК в реквизит ЛСК найденного ЛП.
//
// Параметры:
//  ЛСК - ДокументСсылка.ЛистСборкиКомплектовЧЗ
//  Накладная - ДокументСсылка.РасходнаяНакладная
//  СоздаватьНовыйЛП - Булево - изменяемый параметр - на входе Ложь, если нужно искать ЛП, но ЛП не найден, то возвращает Истина
//
// Возвращаемое значение:
//  ДокументСсылка.ЛистПереукладки - если найден подходящий ЛП
//
//  Неопределено - если по каким-то условиям для данной накладной и данного ЛСК не нужно искать ЛП или подходящий ЛП не найден
//
Функция НайтиЛП_ПоЛСК(ЛСК, Накладная, СоздаватьНовыйЛП = Ложь) Экспорт
	
	Если ТипЗнч(Накладная) <> Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	РеквизитыЛСК = ПолучитьРеквизитыШапки(ЛСК, "Продукция, КоличествоДокумента", "Документ");
	
	Если Не ЗначениеЗаполнено(РеквизитыЛСК.Продукция) Или Не ЗначениеЗаполнено(РеквизитыЛСК.КоличествоДокумента) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ПравилаАгрегацииЧестногоЗнака = ПолучитьРеквизитШапки(Накладная, "ПравилаАгрегацииЧестногоЗнака", "Документ");
	
	Если ЗначениеЗаполнено(ПравилаАгрегацииЧестногоЗнака) И ПравилаАгрегацииЧестногоЗнака <> Справочники.ПравилаАгрегацииЧестногоЗнака.НайтиПоКоду("000000003") Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Накладная);
	
	Если ДопПараметрыНакладной.ОтгрузкаFBS Тогда
		
		Возврат Неопределено;
		
	КонецЕсли; 
	
	ЗапросКодыЧЗ = Новый Запрос;
	
	ЗапросКодыЧЗ.Текст = "ВЫБРАТЬ
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта КАК ШтрихкодКомплекта
	                     |ИЗ
	                     |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	                     |ГДЕ
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЛСК
	                     |
	                     |СГРУППИРОВАТЬ ПО
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта";
	
	ЗапросКодыЧЗ.УстановитьПараметр("ЛСК", ЛСК);
	
	КодыЧЗ = ЗапросКодыЧЗ.Выполнить().Выгрузить();
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистПереукладкиТовары.Ссылка КАК ЛП,
	               |	ЛистПереукладкиТовары.Ссылка.Номер КАК ЛПНомер,
	               |	МАКСИМУМ(ЛистПереукладкиТовары.Номенклатура) КАК Продукция,
	               |	СУММА(ЛистПереукладкиТовары.Количество) КАК Количество
	               |ПОМЕСТИТЬ ВТ_ЛП
	               |ИЗ
	               |	Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	               |ГДЕ
	               |	ЛистПереукладкиТовары.Ссылка.ДокОснование = &Накладная
	               |	И ЛистПереукладкиТовары.Ссылка.ЛСК = ЗНАЧЕНИЕ(Документ.ЛистСборкиКомплектовЧЗ.ПустаяСсылка)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЛистПереукладкиТовары.Ссылка
	               |
	               |ИМЕЮЩИЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладкиТовары.Номенклатура) = 1 И
	               |	СУММА(ЛистПереукладкиТовары.Отсканировано) = 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ВТ_ЛП.ЛП КАК ЛП
	               |ИЗ
	               |	ВТ_ЛП КАК ВТ_ЛП
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистСборкиКомплектовЧЗ КАК ЛистСборкиКомплектовЧЗ
	               |		ПО ВТ_ЛП.Продукция = ЛистСборкиКомплектовЧЗ.Продукция
	               |			И ВТ_ЛП.Количество = ЛистСборкиКомплектовЧЗ.КоличествоДокумента
	               |ГДЕ
	               |	ЛистСборкиКомплектовЧЗ.Ссылка = &ЛСК
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВТ_ЛП.ЛПНомер";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	Запрос.УстановитьПараметр("ЛСК", ЛСК);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЛПОбъект = Выборка.ЛП.ПолучитьОбъект();
		
		ЛПОбъект.ЛСК = ЛСК;
		
		Для Каждого Стр Из ЛПОбъект.Товары Цикл
			
			Стр.Отсканировано = Стр.Количество;
			
		КонецЦикла;
		
		Для Каждого СтрЧЗ Из КодыЧЗ Цикл
			
			НовСтр = ЛПОбъект.ШтрихкодыУпаковок.Добавить();
			
			НовСтр.ШтрихкодУпаковки = СтрЧЗ.ШтрихкодКомплекта;
			НовСтр.Количество = 1;
			
		КонецЦикла;
		
		ЛПОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		Возврат ЛПОбъект.Ссылка;
		
	КонецЕсли;

	СоздаватьНовыйЛП = Истина;

	Возврат Неопределено;
		
КонецФункции

// Кельманов А.В. - ИЗМ-0000000124 - 2026.07.01
// Создаёт ЛП по ЛСК.
//
// Параметры:
//  ЛСК - ДокументСсылка.ЛистСборкиКомплектовЧЗ
//  Накладная - ДокументСсылка.РасходнаяНакладная
//  ТипКороба - СправочникСсылка.ТипыКоробов - для записи реквизита в создаваемом ЛП
//
// Возвращаемое значение:
//  ДокументСсылка.ЛистПереукладки - если создан подходящий ЛП
//
//  Неопределено - если не удалось создать ЛП
//
Функция СоздатьЛП_ПоЛСК(ЛСК, Накладная, ТипКороба) Экспорт
	
	// ТИП КОРОБА С ПРОВЕРКОЙ ОБЪЁМА НА ТСД!!!!!
	
	Ошибки = "";
	
	РеквизитыЛСК = ПолучитьРеквизитыШапки(ЛСК, 
	"Продукция, КоличествоДокумента, Дата, ДатаНачалаСканирования, ДатаОкончанияСканирования, УзелТСД, СборщикКомплектаТСД", "Документ");
	
	ЗапросКодыЧЗ = Новый Запрос;
	
	ЗапросКодыЧЗ.Текст = "ВЫБРАТЬ
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта КАК ШтрихкодКомплекта
	                     |ИЗ
	                     |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
	                     |ГДЕ
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЛСК
	                     |
	                     |СГРУППИРОВАТЬ ПО
	                     |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта";
	
	ЗапросКодыЧЗ.УстановитьПараметр("ЛСК", ЛСК);
	
	КодыЧЗ = ЗапросКодыЧЗ.Выполнить().Выгрузить();
	
	ЛП_Объект = Документы.ЛистПереукладки.СоздатьДокумент();
	
	ЛП_Объект.Заполнить(Накладная);
	ЛП_Объект.Дата = РеквизитыЛСК.Дата;
	ЛП_Объект.ДатаНачалаСканирования = РеквизитыЛСК.ДатаНачалаСканирования;
	ЛП_Объект.ДатаОкончанияСканирования = РеквизитыЛСК.ДатаОкончанияСканирования;
	ЛП_Объект.УзелТСД = РеквизитыЛСК.УзелТСД;
	ЛП_Объект.СканировщикФизЛицо = РеквизитыЛСК.СборщикКомплектаТСД;
	ЛП_Объект.ТипКороба = ТипКороба;
	
	РезультатПоиска = Документы.ЛистПереукладки.НайтиЕдиныйЗНАПоРНК(Накладная);
	
	Если РезультатПоиска.Успех Тогда
		
		ЛП_Объект.ЗаданиеНаАгрегацию = РезультатПоиска.Данные;
		
	КонецЕсли; 
	
	ЛП_Объект.Товары.Очистить();
	ЛП_Объект.ШтрихкодыУпаковок.Очистить();
	ЛП_Объект.Бригада.Очистить(); 
	
	ЛП_Объект.РежимСканирования = Перечисления.РежимСканирования.Добавление; 
	
	НовСтр = ЛП_Объект.Товары.Добавить();

	НовСтр.Номенклатура = РеквизитыЛСК.Продукция;
	НовСтр.Количество = РеквизитыЛСК.КоличествоДокумента;
	НовСтр.Отсканировано = РеквизитыЛСК.КоличествоДокумента;
	
	Для Каждого СтрЧЗ Из КодыЧЗ Цикл
		
		НовСтр = ЛП_Объект.ШтрихкодыУпаковок.Добавить();
		
		НовСтр.ШтрихкодУпаковки = СтрЧЗ.ШтрихкодКомплекта;
		НовСтр.Количество = 1;
		
	КонецЦикла;
	
	Для Каждого Стр Из ЛСК.Бригада Цикл
		
		СтрБригада = ЛП_Объект.Бригада.Добавить();
		
		СтрБригада.Сотрудник = Стр.Сотрудник;
		
	КонецЦикла;			

	Попытка
		
		ЛП_Объект.ДополнительныеСвойства.Вставить("НеПроставлятьКоличествоКоробокПоЗНА", Истина); 
		
		ЛП_Объект.Записать(РежимЗаписиДокумента.Проведение);
		
	Исключение
		
		Ошибки = ОписаниеОшибки();
		
	КонецПопытки;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		
		Возврат Неопределено;
		
	Иначе
		
		Документы.ЛистПереукладки.ПроставитьКоличествоКоробокПоЗНА(Накладная);
		
		Возврат ЛП_Объект.Ссылка; 
		
	КонецЕсли;
	
КонецФункции

// Кельманов А.В. - Изменение 0000000187 - 2026.07.08
// Определяет, есть ли пустые значения реквизитов "НомерЗаказаFBS", "ШтрихКодFBS", "ШтрихКод" 
// в строках документа ПолныеДанныеЗаданияНабора.
//
// Параметры:
//  ПолныеДанные - ДокументСсылка.ПолныеДанныеЗаданияНабора - проверяемый документ
//
// Возвращаемое значение:
//  Строка - Перечисление строк документа ПолныеДанныеЗаданияНабора 
//  с незаполненными значениями перечисленных реквизитов
//
//  или пустая строка, если все проверяемые реквизиты заполнены
//
Функция ПроверитьПустыеЗначенияВКолонкахПолныхДанных(ПолныеДанные) Экспорт
	
	Ошибки = "";
	
	МассивОшибок = Новый Массив;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабораТовары.НомерСтроки КАК НомерСтроки,
	               |	ПолныеДанныеЗаданияНабораТовары.Номенклатура КАК Номенклатура,
	               |	ПолныеДанныеЗаданияНабораТовары.Количество КАК Количество,
	               |	ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS КАК НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораТовары.ШтрихКод КАК ШтрихКод,
	               |	ПолныеДанныеЗаданияНабораТовары.ПрефиксЗаказа КАК ПрефиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораТовары.СуффиксЗаказа КАК СуффиксЗаказа
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Товары КАК ПолныеДанныеЗаданияНабораТовары
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораТовары.Ссылка = &ПолныеДанные
	               |	И ПолныеДанныеЗаданияНабораТовары.Количество > 0
	               |	И (ПолныеДанныеЗаданияНабораТовары.НомерЗаказаFBS = """"
	               |			ИЛИ ПолныеДанныеЗаданияНабораТовары.ШтрихКодFBS = """"
	               |			ИЛИ ПолныеДанныеЗаданияНабораТовары.ШтрихКод = """")
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки";
	
	Запрос.УстановитьПараметр("ПолныеДанные", ПолныеДанные);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ЗначениеЗаполнено(Выборка.НомерЗаказаFBS) Тогда
			
			МассивОшибок.Добавить("Строка " + Выборка.НомерСтроки + ": не заполнен номер заказа FBS");
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Выборка.ШтрихКодFBS) Тогда
			
			МассивОшибок.Добавить("Строка " + Выборка.НомерСтроки + ": не заполнен ШК заказа FBS");
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Выборка.ШтрихКод) Тогда
			
			МассивОшибок.Добавить("Строка " + Выборка.НомерСтроки + ": не заполнен штрихкод");
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивОшибок.Количество() > 0 Тогда
		
		Ошибки = СтрСоединить(МассивОшибок, Символы.ПС);
		
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции

#КонецОбласти
