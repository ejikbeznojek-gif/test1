Функция ПолучитьШКНоменклатуры(СписокНоменклатуры,КэшШтрихКодов) Экспорт
	
	Если СписокНоменклатуры.ВГраница()<0 Тогда Возврат Неопределено	КонецЕсли; 
	
	Если ТипЗнч(КэшШтрихКодов)<>Тип("ТаблицаЗначений") Тогда		
		КэшШтрихКодов = Новый ТаблицаЗначений;
		КэшШтрихКодов.Колонки.Добавить("Номенклатура");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Штука_Ссылка");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Штука_Значение");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Коробка_Ссылка");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Коробка_Значение");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Блочок_Ссылка");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_Блочок_Значение");
		//Кухарь 08.07.19 начало
		//Новые колонки на форме номенклатуры
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_GS1_Ссылка");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_GS1_Значение");
		//Кухарь 08.07.19 конец		
		
		//Кухарь  24.10.2024 начало
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_GS1_Rus_Ссылка");
		КэшШтрихКодов.Колонки.Добавить("ШтрихКод_GS1_Rus_Значение");
		//Кухарь  24.10.2024 конец
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|			ТОГДА ШтрихКоды.Ссылка
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ШтрихКоды.ПустаяСсылка)
	|	КОНЕЦ КАК ШтрихКод_Штука_Ссылка,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	|			ТОГДА ШтрихКоды.Ссылка
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ШтрихКоды.ПустаяСсылка)
	|	КОНЕЦ КАК ШтрихКод_Блочок_Ссылка,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	|			ТОГДА ШтрихКоды.Ссылка
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ШтрихКоды.ПустаяСсылка)
	|	КОНЕЦ КАК ШтрихКод_Коробка_Ссылка,
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|			ТОГДА ШтрихКоды.Наименование
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ШтрихКод_Штука_Значение,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)
	|			ТОГДА ШтрихКоды.Наименование
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ШтрихКод_Блочок_Значение,
	|	ВЫБОР
	|		КОГДА ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
	|			ТОГДА ШтрихКоды.Наименование
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ШтрихКод_Коробка_Значение
	|ПОМЕСТИТЬ вр_ОсновныеШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Владелец В(&СписокНоменклатуры)
	|	И ШтрихКоды.Наименование <> ""9999999999999""
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.ВидШК = ЗНАЧЕНИЕ(Перечисление.ВидыШК.Основной)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихКоды.Ссылка КАК ШтрихКод_GS1_Ссылка,
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ШтрихКоды.Наименование КАК ШтрихКод_GS1_Значение
	|ПОМЕСТИТЬ вр_Описание
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Владелец В(&СписокНоменклатуры)
	|	И (ВЫРАЗИТЬ(ШтрихКоды.Описание КАК СТРОКА(3))) = ""GS1""
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихКоды.Ссылка КАК ШтрихКод_GS1_Rus_Ссылка,
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ШтрихКоды.Наименование КАК ШтрихКод_GS1_Rus_Значение
	|ПОМЕСТИТЬ вр_ШтрихкодыRus
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Владелец В(&СписокНоменклатуры)
	|	И НЕ ШтрихКоды.ПометкаУдаления
	|	И ШтрихКоды.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И ШтрихКоды.ЭтоКодGS1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ОсновныеШК.Номенклатура КАК Номенклатура,
	|	вр_ОсновныеШК.ШтрихКод_Штука_Ссылка КАК ШтрихКод_Штука_Ссылка,
	|	вр_ОсновныеШК.ШтрихКод_Блочок_Ссылка КАК ШтрихКод_Блочок_Ссылка,
	|	вр_ОсновныеШК.ШтрихКод_Коробка_Ссылка КАК ШтрихКод_Коробка_Ссылка,
	|	вр_ОсновныеШК.ШтрихКод_Штука_Значение КАК ШтрихКод_Штука_Значение,
	|	вр_ОсновныеШК.ШтрихКод_Блочок_Значение КАК ШтрихКод_Блочок_Значение,
	|	вр_ОсновныеШК.ШтрихКод_Коробка_Значение КАК ШтрихКод_Коробка_Значение,
	|	вр_Описание.ШтрихКод_GS1_Ссылка КАК ШтрихКод_GS1_Ссылка,
	|	вр_Описание.ШтрихКод_GS1_Значение КАК ШтрихКод_GS1_Значение,
	|	вр_ШтрихкодыRus.ШтрихКод_GS1_Rus_Ссылка КАК ШтрихКод_GS1_Rus_Ссылка,
	|	вр_ШтрихкодыRus.ШтрихКод_GS1_Rus_Значение КАК ШтрихКод_GS1_Rus_Значение
	|ИЗ
	|	вр_ОсновныеШК КАК вр_ОсновныеШК
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Описание КАК вр_Описание
	|		ПО вр_ОсновныеШК.Номенклатура = вр_Описание.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_ШтрихкодыRus КАК вр_ШтрихкодыRus
	|		ПО вр_ОсновныеШК.Номенклатура = вр_ШтрихкодыRus.Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	тзВыборка = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Для Каждого Стр ИЗ тзВыборка Цикл
		
		СтрокаКэша = глНайтиВТаблице(КэшШтрихКодов, Стр.Номенклатура,"Номенклатура",Истина);
		
		Для Каждого Колонка из тзВыборка.Колонки Цикл
			Если ЗначениеЗаполнено(Стр[Колонка.Имя]) Тогда
				СтрокаКэша[Колонка.Имя] = Стр[Колонка.Имя];		
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла; 
	
КонецФункции // ПолучитьШКТоваров()
