//ТИПЫ ШК
Функция ПолучитьТипШКПоУмолчанию(Объект=Неопределено) Экспорт
	ТипШК=ПолучитьЗначениеПоУмолчанию("ОсновнойТипШК");
	
	Если Объект<>Неопределено И ЕстьРеквизитДокумента("Склад",Объект.Метаданные()) И НЕ Объект.Склад.ТипШКПоУмолчанию.Пустая() Тогда
		ТипШК=Объект.Склад.ТипШКПоУмолчанию;		
	КонецЕсли; 
	
	Если ТипШК=Неопределено ИЛИ ТипШК.Пустая() Тогда
		ТипШК=Перечисления.ТипыШтрихКодов.Штука;	
	КонецЕсли; 
	
	Возврат ТипШК;
КонецФункции // ПолучитьТипШКПоУмолчанию()()

Процедура ЗаполнитьТипыШК(Форма) Экспорт
	Форма.ЭлементыФормы.тПоследняяСосканированнаяПозиция.Значение="";	
	
	СписокВыбора=Форма.ЭлементыФормы.ТипШК.СписокВыбора;
	Для Сч=0 По Перечисления.ТипыШтрихКодов.Количество()-1 Цикл
		СписокВыбора.Добавить(Перечисления.ТипыШтрихКодов[Сч]);	
	КонецЦикла;	
	
	Форма.ТипШК=ПолучитьТипШКПоУмолчанию(Форма.ЭтотОбъект);
КонецПроцедуры


Процедура УстановитьКолонтитулы(ТД,ПопожениеКолонтитула="Верхний") Экспорт
	Если ПопожениеКолонтитула="Верхний" Тогда
		Колонтитул=ТД.ВерхнийКолонтитул;
	Иначе
		Колонтитул=ТД.НижнийКолонтитул;	
	КонецЕсли; 
	
	Колонтитул.Выводить=Истина;
	Колонтитул.ВертикальноеПоложение=ВертикальноеПоложение.Верх;
	
	Колонтитул.ТекстСлева="Сформирован: "+СокрЛП(ПараметрыСеанса.Пользователь)+", "+ТекущаяДата();	
	// Кухарь А.Ю. 08.02.2021 начало
	//Глюк платформы какой-то 8.3.15.1830. В этот колонтитул криво передаётся сочетание пробела с цифрами	
	Колонтитул.ТекстСлева=СтрЗаменить(Колонтитул.ТекстСлева," ",Символы.НПП);  
	// Кухарь А.Ю. 08.02.2021 конец

	
	
	Колонтитул.ТекстСправа="Стр. № [&НомерСтраницы]из [&СтраницВсего]";
	
КонецПроцедуры

//вывод контрольной информации в печ. форму для сравнения спецификаций
Процедура ВывестиКонтрольнуюИнформациюВВыходнуюТаблицу(ДокОбъект,Таб,Макет) Экспорт	
	Если Константы.НеВыводитьКонтрольнуюИнформациюПриПечати.Получить() Тогда Возврат КонецЕсли;
	
	МетаДок=ДокОбъект.Метаданные();
	
	ПараметрыШапки=Новый Структура;
	
	Вид80=ДокОбъект.Метаданные().Имя;
	Если Вид80="РасходнаяНакладная" Тогда
		Вид77=?(ДокОбъект.ВидОплаты=Перечисления.ВидыОплаты.НАЛ,"РасходнаяНАЛ","РасходнаяБН");
	Иначе
		Вид77=Вид80;			
	КонецЕсли; 
	
	ПараметрыШапки.Вставить("Вид77",Вид77);
	ПараметрыШапки.Вставить("Номер",ДокОбъект.Номер);
	ПараметрыШапки.Вставить("Дата",	ДокОбъект.Дата);
	
	Если ЕстьРеквизитДокумента("ДатаОтгрузки",МетаДок) Тогда
		ПараметрыШапки.Вставить("ДатаОтгрузки",	ДокОбъект.ДатаОтгрузки);		
	КонецЕсли; 
	
	Если ЕстьРеквизитДокумента("Контрагент",МетаДок) Тогда
		ПараметрыШапки.Вставить("КонтрагентНаименование",	ДокОбъект.Контрагент.Наименование);	
		ПараметрыШапки.Вставить("КонтрагентКод",			ДокОбъект.Контрагент.Код);
	КонецЕсли;
	
	ПараметрыШапки.Вставить("СкладНаименование",		ДокОбъект.Склад.Наименование);
	ПараметрыШапки.Вставить("СкладКод",					ДокОбъект.Склад.Код);	
	Если ЕстьРеквизитДокумента("Организация",ДокОбъект.Метаданные()) Тогда
		попытка
			ПараметрыШапки.Вставить("ОрганизацияНаименование",	ДокОбъект.Организация.Наименование);
		исключение
			ПараметрыШапки.Вставить("ОрганизацияНаименование",	Справочники.Организации.НайтиПоКоду("SS-001"));
		КонецПопытки;
	КонецЕсли;	
	
	Обл_Шапка=Макет.ПолучитьОбласть("Контроль_Шапка");
	Обл_Шапка.Параметры.Заполнить(ПараметрыШапки);
	
	НачСтрока=Таб.ВысотаТаблицы+1;
	
	Таб.Вывести(Обл_Шапка);
	
	Для Каждого СтрокаТЧ Из ДокОбъект.Товары  Цикл
		ОблСтрока=Макет.ПолучитьОбласть("Контроль_Строка");
		
		ПараметрыСтроки=Новый Структура;
		
		ПараметрыСтроки.Вставить("Код77",		СтрокаТЧ.Номенклатура.Код77);
		ПараметрыСтроки.Вставить("Наименование",СтрокаТЧ.Номенклатура.Наименование);
		ПараметрыСтроки.Вставить("Количество",	СтрокаТЧ.Количество);
		
		Если Вид80<>"ЛистНабора" Тогда
			ПараметрыСтроки.Вставить("Цена",		СтрокаТЧ.Цена);
			ПараметрыСтроки.Вставить("НДС",			СтрокаТЧ.НДС);
			ПараметрыСтроки.Вставить("Всего",		СтрокаТЧ.Всего);		
		КонецЕсли; 
		
		ОблСтрока.Параметры.Заполнить(ПараметрыСтроки);		
		
		Таб.Вывести(ОблСтрока);
	КонецЦикла;
	
	Таб.Область(НачСтрока,,Таб.ВысотаТаблицы).Видимость=Ложь;
КонецПроцедуры

Функция БукваОтгружен(Отгружен) Экспорт
	Если Отгружен=Перечисления.Отгружен.Отгружен  Тогда
		Возврат "О";	
	ИначеЕсли Отгружен=Перечисления.Отгружен.Резерв Тогда
		Возврат "Р";
	ИначеЕсли Отгружен=Перечисления.Отгружен.РезервТранзит Тогда
		Возврат "т";
	ИначеЕсли Отгружен=Перечисления.Отгружен.ОтгруженТранзит Тогда
		Возврат "Т";
		// +++ {Кузнецов Сергей Владимирович [11.10.2022]
	ИначеЕсли Отгружен=Перечисления.Отгружен.Отменен Тогда
		Возврат "Х";
		// }Кузнецов Сергей Владимирович +++ [11.10.2022]
	Иначе
		Возврат "-";
	КонецЕсли; 	
КонецФункции // БукваОтгружен()

Функция БукваСостоянияНакладной(Состояние) Экспорт
	
	Если Состояние=Перечисления.СостоянияНакладной.ВРаботе Тогда
		Возврат "";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.КОтправкеНаСклад Тогда
		Возврат "д";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ПолученоСкладом Тогда
		Возврат "Д";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Сканирование Тогда
		Возврат "С";	
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ВНаборе Тогда
		Возврат "Н";
		//крохин начало 16.02.2012
		//новое состояние
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ДопОбработка Тогда
		Возврат "ДО";
		//крохин конец 16.02.2012
		//крохин начало 21.03.2013
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ВМашине Тогда
		Возврат "М";
		//крохин конец 21.03.2013
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ГотоваКОтгрузке ИЛИ Состояние=Перечисления.СостоянияНакладной.ГотоваКПриемке Тогда
		Возврат "Г";			
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Отгружена Тогда
		Возврат "О";			
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
		Возврат "Т";			
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Принята Тогда
		Возврат "П";			
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.КОтправкеВОфис Тогда
		Возврат "ф";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ПолученоОфисом Тогда
		Возврат "Ф";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Доставлена Тогда
		Возврат "Д";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеОплаты Тогда
		Возврат "ОО";
		//крохин начало 11.12.2013
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеНабора Тогда
		Возврат "ОН";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеСканирования Тогда
		Возврат "ОС";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеДопОбработки Тогда
		Возврат "ОД";
		//крохин конец 11.12.2013
		//Кухарь 18.08.14 начало
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеПереукладки Тогда
		Возврат "ОУ";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Переукладка Тогда
		Возврат "У";	
		//Кухарь 18.08.14 конец
		//кухарь 12.11.14 начало
	ИначеЕсли  Состояние=Перечисления.СостоянияНакладной.ВЗонеХранения тогда
		возврат "ЗХ"
		//кухарь 12.11.14 конец
		//Кухарь 10.12.15 начало
		//Переименовали в ПроверенаПоОстаткам
		//ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ГотоваКНабору тогда
		//возврат "ГН";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ПроверенаПоОстаткам тогда
		возврат "ПО";
		//Кухарь 16.06.16 начало
		//Кухарь 27.12.17 начало
		//Термоусадка
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеТермоусадки тогда
		возврат "ОТ";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Термоусадка тогда
		возврат "ТУ";
		
		//Кухарь 27.12.17 конец		
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеПаллетирования тогда
		возврат "ОП";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Паллетирование тогда
		возврат "ПЛ";	
		//Кухарь 16.06.16  конец
	
		//Кухарь 10.12.15 конец
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.СформированыЗаданияНабора Тогда
		Возврат "ЗН";
	// Кухарь А.Ю. 06.04.2020 начало
	// Накладная ждёт что где-то что-то руками что-то поменяют, до этих пор штатная схема смены состояний отключается.
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеКорректировки Тогда
		Возврат "ОЖ"; 
	// Кухарь А.Ю. 06.04.2020 конец
	// +++ {Кузнецов Сергей Владимирович [11.10.2022]
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.Отменена Тогда
		Возврат "Х";
		// }Кузнецов Сергей Владимирович +++ [11.10.2022]
		// Кухарь А.Ю.  11.11.2024 начало
		//
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеКомплектацииЧЗ Тогда
		Возврат "ОК";
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.КомплектацияЧЗ Тогда
		Возврат "К";
		
		// Кухарь А.Ю.  11.11.2024 конец
		// Кухарь А.Ю.  15.10.2025 начало    
		// HELP-5404 Кухарь
	ИначеЕсли Состояние=Перечисления.СостоянияНакладной.ОжиданиеОбработкиЧЗ Тогда
		Возврат "ЧЗ";
		// Кухарь А.Ю.  15.10.2025 конец
	
	Иначе
		Возврат "н/у";		
	КонецЕсли;
	
КонецФункции //глБукваСостоянияНакладной(ТекущийДокумент)

//крохин начало 08.10.2020

Функция БукваСостоянияЗаказаКонтрагента(Состояние) Экспорт
	
	Если Состояние=Перечисления.СостоянияЗаказаКонтрагента.ВРаботе Тогда
		Возврат "";
	ИначеЕсли Состояние=Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ Тогда
		Возврат "п";
	ИначеЕсли Состояние=Перечисления.СостоянияЗаказаКонтрагента.Оплачен Тогда
		Возврат "о";
	ИначеЕсли Состояние=Перечисления.СостоянияЗаказаКонтрагента.ЗаказаноПоставщику Тогда
		Возврат "пр";	
	ИначеЕсли Состояние=Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично Тогда
		Возврат "вч";
	ИначеЕсли Состояние=Перечисления.СостоянияЗаказаКонтрагента.Выполнен Тогда
		Возврат "в";
	Иначе
		Возврат "н/у";		
	КонецЕсли;
	
КонецФункции //глБукваСостоянияНакладной(ТекущийДокумент)

