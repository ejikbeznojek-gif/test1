Процедура ПодборДокаПоФрагментам(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,СписокВидов=Неопределено,Знач Дата1=Неопределено,СписокСкладов=Неопределено) Экспорт
	Дата1=?(Дата1=Неопределено,ТекущаяДата()-3*30*24*60*60,Дата1);
	
	ОбъектМетаданных=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
	СписокВыбора	=Новый СписокЗначений;
	
	Если СписокВидов=Неопределено Тогда
		Если ОбъектМетаданных<>Неопределено И Метаданные.Документы.Индекс(ОбъектМетаданных)>0 Тогда
			СписокВидов=Новый Структура;			
			СписокВидов.Вставить(ОбъектМетаданных.Имя);
		КонецЕсли;	
	КонецЕсли;
	
	ТекстЗапроса="";
	Для Каждого Вид Из СписокВидов Цикл
		ТекВид=Вид.Ключ;
		
		Если ТекВид="РасходнаяНакладная" ИЛИ ТекВид="ПриходнаяНакладная" Тогда
			ПолеДопИнфо="Контрагент";	
		ИначеЕсли ТекВид="Перемещение" Тогда
			ПолеДопИнфо="СкладПолучатель";
		Иначе
			ПолеДопИнфо="""""";	
		КонецЕсли;	
		
		ТекстЗапроса=ТекстЗапроса+?(ПустаяСтрока(ТекстЗапроса),""," ОБЪЕДИНИТЬ ВСЕ ")+"
		|ВЫБРАТЬ
		|	Ссылка,
		|	Номер, 
		|	Дата,
		|   "+ПолеДопИнфо+" КАК ДопИнфо
		|ИЗ
		|	Документ."+Вид.Ключ+"
		|ГДЕ
		|	Номер ПОДОБНО &ШаблонПоиска
		|	И Дата>&Дата1 ";
		
		Если ЕстьРеквизитДокумента("Склад",Метаданные.Документы[Вид.Ключ]) И СписокСкладов<>Неопределено Тогда
			ТекстЗапроса=ТекстЗапроса+"
			|	И Склад В (&СписокСкладов)";
		КонецЕсли; 
	КонецЦикла; 	
	
	ТекСтрока=СокрЛП(Текст);	
	Пока Найти(ТекСтрока,"  ")<>0 Цикл
		ТекСтрока=СтрЗаменить(ТекСтрока,"  "," ");			
	КонецЦикла;
	
	Если ПустаяСтрока(ТекСтрока) Тогда Возврат КонецЕсли; 
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка,
	|	Номер,Дата,ДопИнфо
	|ИЗ
	|("+ТекстЗапроса+") КАК Сводный
	|Упорядочить ПО Номер";
	
	Запрос.УстановитьПараметр("Дата1",Дата1);	
	Запрос.УстановитьПараметр("ШаблонПоиска","%"+СтрЗаменить(ТекСтрока," ","%")+"%");	
	Запрос.УстановитьПараметр("СписокСкладов",СписокСкладов);	
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СписокВыбора.Добавить(Выборка.Ссылка,""+Выборка.Ссылка.Метаданные()+" "+Выборка.Номер+" "+Формат(Выборка.Дата,"ДФ=dd.MM.yy")+" "+Выборка.ДопИнфо);		
	КонецЦикла;	
	
	СтандартнаяОбработка=Ложь;
	Если СписокВыбора.Количество()=0 Тогда
		Если ОбъектМетаданных<>Неопределено Тогда
			Значение=Документы[ОбъектМетаданных.Имя].ПустаяСсылка();
		Иначе     //хотя такого вообще быть не должно
			Значение=Элемент.Значение;		
		КонецЕсли;		
	ИначеЕсли СписокВыбора.Количество()=1 Тогда
		Значение=СписокВыбора.Получить(0).Значение;		
	Иначе
		Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
		Если Выбор<>Неопределено Тогда			
			Значение=Выбор.Значение;
		Иначе
			Значение=Элемент.Значение;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

