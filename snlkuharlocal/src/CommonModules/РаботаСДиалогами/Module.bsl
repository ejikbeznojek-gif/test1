	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка,
	|	Наименование,Код
	|ИЗ
	|	ПланСчетов.Хозрасчетный
	|ГДЕ
	|	(Наименование ПОДОБНО &ШаблонПоиска ИЛИ Код ПОДОБНО &ШаблонПоиска)
	|	И НЕ ЗапретитьИспользоватьВПроводках";
	
	Если ЗначениеЗаполнено(ДопФильтр) Тогда
		Запрос.Текст=Запрос.Текст+"
