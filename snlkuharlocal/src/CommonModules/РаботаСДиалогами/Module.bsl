	ТПФ=Новый ТаблицаЗначений;
	ТПФ.Колонки.Добавить("ИдКнопки");
	ТПФ.Колонки.Добавить("Наименование");
	
	Части=РазложитьСтрокуВМассивПодстрок(ВидОбъекта,".");
	Если Части.Количество()<>2 Тогда
		Возврат ТПФ;
	КонецЕсли; 
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ВнешниеОтчеты.Код КАК Код,
	             |	ВнешниеОтчеты.Наименование КАК Наименование,
	             |	ВнешниеОтчеты.Ссылка КАК Ссылка
	             |ИЗ
	             |	Справочник.ВнешниеОтчеты КАК ВнешниеОтчеты
	             |ГДЕ
	             |	ВнешниеОтчеты.ВидОбработки = ""Печать""
	             |	И ПОДСТРОКА(ВнешниеОтчеты.ТипОбъекта, 1, 1000) = &ТипОбъекта
	             |	И ВнешниеОтчеты.ВидДокумента = &ВидДокумента
	             |	И НЕ ВнешниеОтчеты.ЭтоГруппа
	             |	И НЕ ВнешниеОтчеты.ПометкаУдаления
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ВнешниеОтчеты.Наименование";
	
	Запрос.УстановитьПараметр("ТипОбъекта",		Части[0]);
	Запрос.УстановитьПараметр("ВидДокумента",	Части[1]);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		// Андреев И.Д. 27.10.2021 начало
		// Не выводит печатные формы, при условиях:	
		//Если ЗначениеЗаполнено(Контрагент) и Выборка.Ссылка.Контрагенты.количество()>0 тогда
		//	если Выборка.Ссылка.Контрагенты.Найти(Контрагент)=неопределено тогда
		//		продолжить
		//	конецесли;
		//КонецЕсли;	
		// Андреев И.Д. 27.10.2021 конец
			
		СтрокаТПФ				=ТПФ.Добавить();
		СтрокаТПФ.ИдКнопки		="_"+Формат(Выборка.Код,"ЧГ=0");
		СтрокаТПФ.Наименование  = Выборка.Наименование;
	КонецЦикла;
	
	Возврат ТПФ;
КонецФункции //ПолучитьТаблицуПечатныхФорм(ВидОбъекта="",ИмяФайлаОписания="") Экспорт

// Кухарь А.Ю. 27.10.2021 начало
//Процедура НастроитьПодменюПечати(Форма,ТипОбъекта=Неопределено,ВидОбъекта=Неопределено) Экспорт
Процедура НастроитьПодменюПечати(Форма,ТипОбъекта=Неопределено,ВидОбъекта=Неопределено,Контрагент=неопределено) Экспорт 
// Кухарь А.Ю. 27.10.2021 конец


	
	Тип=?(ТипОбъекта=Неопределено,ТипОбъекта(Форма.Ссылка),ТипОбъекта);
	Вид=?(ВидОбъекта=Неопределено,Форма.Метаданные().Имя,ВидОбъекта);
	
	// Андреев И.Д. 27.10.2021 начало
	// проверка на контрагента на форме
	//если Контрагент=неопределено тогда
	//	если форма.элементыформы.найти("Контрагент")<>Неопределено тогда
	//		Контрагент = форма.контрагент;
	//	иначе
	//		Контрагент = неопределено;
	//	КонецЕсли;				
	//конецесли;
	контрагент =Неопределено;
	// Андреев И.Д. 27.10.2021 конец

	
	
	ПодменюПечати	=Форма.ЭлементыФормы.ОсновныеДействияФормы.Кнопки.ПодменюПечати;	
	ПодменюПечати.Кнопки.Очистить();
	
	ИмяПечатнойФормы=ВосстановитьЗначение(Тип+"."+Вид+"ИмяПечатнойФормы");	
	ИдКнопкиПоУмолчанию=Неопределено;
	
	СтрокаТПФПоУмолчанию=Неопределено;
		
	// Андреев И.Д. 27.10.2021 начало
	//  + контрагент
	//ТПФ		=ПолучитьТаблицуПечатныхФорм(Тип+"."+Вид);
	ТПФ		=ПолучитьТаблицуПечатныхФорм(Тип+"."+Вид,,Контрагент);
	// Андреев И.Д. 27.10.2021 конец

	Для Каждого СтрокаТПФ Из ТПФ Цикл
		Кнопка=ПодменюПечати.Кнопки.Добавить(СтрокаТПФ.ИДКнопки,ТипКнопкиКоманднойПанели.Действие,СтрокаТПФ.Наименование,Новый Действие("Печать"));
		Кнопка.Пояснение=СтрокаТПФ.ИДКнопки;
		Если СтрокаТПФ.Наименование=ИмяПечатнойФормы Тогда
			СтрокаТПФПоУмолчанию=СтрокаТПФ;			
		КонецЕсли;		
	КонецЦикла;
	
	
	
	
	
	
	
	
	
	КнопкаПоУмолчанию=Форма.ЭлементыФормы.ОсновныеДействияФормы.Кнопки.ПечатьПоУмолчанию;	
	
	Если ТПФ.Количество()=0 Тогда
		КнопкаПоУмолчанию.Доступность=Ложь;
	Иначе
		КнопкаПоУмолчанию.Доступность=Истина;		
		
		Если СтрокаТПФПоУмолчанию=Неопределено Тогда
			СтрокаТПФПоУмолчанию=ТПФ[0];
		КонецЕсли;
		
		КнопкаПоУмолчанию.Текст		=СтрокаТПФПоУмолчанию.Наименование;			
		КнопкаПоУмолчанию.Пояснение	=СтрокаТПФПоУмолчанию.ИдКнопки;
	КонецЕсли;	
КонецПроцедуры

Процедура ВнешняяПечать(Форма,Объект,Элемент,ДопПараметры=Неопределено) Экспорт
	Тип				=ТипОбъекта(Объект);
	ВидОбъекта		=Тип+"."+Объект.Метаданные().Имя;
	
	КодОбработки=Число(Сред(Элемент.Пояснение,2));
	ЭлементОбработки=Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОбработки);	
	
	Обработка=ПолучитьОбработкуПоЭлементу(ЭлементОбработки,КодОбработки);	
	Если Обработка=Неопределено Тогда Возврат КонецЕсли; 
	
	КнопкаПоУмолчанию=Форма.ЭлементыФормы.ОсновныеДействияФормы.Кнопки.ПечатьПоУмолчанию;
	
	КнопкаПоУмолчанию.Текст	=ЭлементОбработки.Наименование;
	КнопкаПоУмолчанию.Пояснение="_"+Формат(ЭлементОбработки.Код,"ЧГ=0");
	
	ОбработкаПечати=Обработка.ПолучитьФорму(ЭлементОбработки.ИмяФормы);
	ОбработкаПечати.Печать(Объект,ДопПараметры);			
	
	СохранитьЗначение(ВидОбъекта+"ИмяПечатнойФормы",КнопкаПоУмолчанию.Текст);	
КонецПроцедуры


Функция ПолучитьПолучателяДокумента(Документ) Экспорт
	МетаДок=Документ.Метаданные();
	
	Если ЕстьРеквизитДокумента("ПунктДоставки",МетаДок) И НЕ Документ.ПунктДоставки.Пустая() Тогда
		Возврат Документ.ПунктДоставки;		
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("Контрагент",МетаДок) И НЕ Документ.Контрагент.Пустая()  Тогда
		Возврат Документ.Контрагент;				
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("СкладПолучатель",МетаДок) И НЕ Документ.СкладПолучатель.Пустая() Тогда
		Возврат Документ.СкладПолучатель;		
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции //ПолучитьПолучателяДокумента(Документ)


Функция ПолучитьНаборПечФормДокумента(Документ) Экспорт
	Если Документ=Неопределено Тогда
		Возврат Справочники.НаборыПечатныхФорм.Стандарт
	КонецЕсли; 
	
	МетаДок=Документ.Метаданные();
	ВидДокумента=Документ.Метаданные().Имя;
	
	Если ЕстьРеквизитДокумента("ПунктДоставки",МетаДок) И ЗначениеЗаполнено(Документ.ПунктДоставки.НаборПечатныхФорм) Тогда
		Возврат Документ.ПунктДоставки.НаборПечатныхФорм;
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("Контрагент",МетаДок) Тогда
		НаборПечФорм=ПолучитьРеквизитРодителя(Документ.Контрагент,"НаборПечатныхФорм");
		Если НЕ НаборПечФорм.Пустая() Тогда
			Возврат НаборПечФорм;		
		КонецЕсли; 
	КонецЕсли;
	
	Если ЕстьРеквизитДокумента("СкладПолучатель",МетаДок) Тогда
		НаборПечФорм=ПолучитьРеквизитРодителя(Документ.СкладПолучатель,"НаборПечатныхФорм");
		Если НЕ НаборПечФорм.Пустая() Тогда
			Возврат НаборПечФорм;		
		КонецЕсли; 
	КонецЕсли;
	
	Возврат Справочники.НаборыПечатныхФорм.Стандарт;
КонецФункции //ПолучитьНаборПечФормДокумента(Документ) 

//Кухарь 20.11.17 начало
//Процедура ПакетнаяПечать(ТекДок) Экспорт
Процедура ПакетнаяПечать(ТекДок,ЭтоМассоваяПечать=ложь) Экспорт
//Кухарь 20.11.17 конец	

	Если ТекДок<>Неопределено и НЕ(ТекДок.Пустая()) Тогда		
		Обработка=ПолучитьВнешнююОбработку("ПакетнаяПечать.epf","PrnForms\");
		Если Обработка=Неопределено Тогда Возврат КонецЕсли; 
		
		ФормаОбработки=Обработка.ПолучитьФорму();		
		ФормаОбработки.ТекДок		=ТекДок;
		
		//Кухарь 20.11.17 начало
		//Массовая печать
		ФормаОбработки.ЭтоМассоваяПечать=ЭтоМассоваяПечать;
		//Кухарь 20.11.17 конец	
		
		ФормаОбработки.НаборФорм	=ПолучитьНаборПечФормДокумента(ТекДок);			
		
		ФормаОбработки.ЗакрытьПослеПечати	=Истина;
		ФормаОбработки.СразуНаПринтер		=Истина;
		
		ФормаОбработки.Открыть();
	КонецЕсли;	
КонецПроцедуры


Функция ПолучитьСписокКодовПоставщика(Знач ВыбКонтрагент) Экспорт	    
	СВ=Новый СписокЗначений;
	
	Выборка=Справочники.КодыПоставщиков.Выбрать(,ВыбКонтрагент);
	Если НЕ Выборка.Следующий() Тогда
		Если НЕ ВыбКонтрагент.Родитель.Пустая() Тогда
			Возврат ПолучитьСписокКодовПоставщика(ВыбКонтрагент.Родитель);			
		КонецЕсли;	    
	Иначе 
		Выборка=Справочники.КодыПоставщиков.Выбрать(,ВыбКонтрагент);
		Пока Выборка.Следующий() Цикл
			СВ.Добавить(Выборка.Ссылка,""+Выборка.Наименование+", исп. для фирмы: "+Выборка.Организация+", прим.: "+Выборка.Примечание);
		КонецЦикла;		
	КонецЕсли;	
	
	Возврат СВ;
КонецФункции //ПолучитьСписокКодовПоставщика(Знач ВыбКонтрагент)

//РАБОТА С ВНЕШНИМИ ОБРАБОТКАМИ

//	ищет внешнюю обработку, если нет внешней пытается найти встроенную, 
//	если и ее нет возвращает "Неопределено"
Функция ПолучитьВнешнююОбработку(ИмяФайла,ПодКаталог="") Экспорт
	Обработка		= Неопределено;
	ИмяОбработки	= СтрЗаменить(ИмяФайла,".epf","");
	ПолноеИмяФайла  = Константы.КаталогВнешнихОтчетов.Получить()+ПодКаталог+ИмяФайла;
	
	Файл=Новый Файл(ПолноеИмяФайла);
	Если Файл.Существует() Тогда
		Обработка=ВнешниеОбработки.Создать(ПолноеИмяФайла);	
	ИначеЕсли Метаданные.Обработки.Найти(ИмяОбработки)<>Неопределено Тогда
		Обработка=Обработки[ИмяОбработки].Создать();
	ИначеЕсли Метаданные.Отчеты.Найти(ИмяОбработки)<>Неопределено Тогда
		Обработка=Отчеты[ИмяОбработки].Создать();	
	КонецЕсли; 
	
	Возврат Обработка;
КонецФункции // ПолучитьВнешнююОбработку(ИмяФайла,ПодКаталог="")



Процедура НастроитьПодменюКодовОпераций(Форма,ДопустимыеКоды) Экспорт
	Вид			=Форма.Ссылка.Метаданные().Имя;
	Подменю		=Форма.ЭлементыФормы.ДействияФормы.Кнопки.ПодменюКодовОпераций;
	Действие	=Новый Действие("ДействияФормыВыборКодаОперации");
	МетаЗначения=Метаданные.Перечисления.КодыОперацийОстатки.ЗначенияПеречисления;
	
	Для Каждого ТекКодОперации Из ДопустимыеКоды Цикл
		МетаКодОперации=МетаЗначениеПеречисления(ТекКодОперации.Значение); 
		Подменю.Кнопки.Добавить(МетаКодОперации.Имя, ТипКнопкиКоманднойПанели.Действие,МетаКодОперации.Синоним,Действие);
	КонецЦикла;		
	
	Подменю.Текст=""+Форма.КодОперации;
КонецПроцедуры 

//ПОДМЕНЮ ЗАПОЛНИТЬ,ПОДБОР
Функция ПолучитьТаблицуОбработокМодификации(Тип,Вид,ИмяТЧ,ВидОбработки)
	ТО=Новый ТаблицаЗначений;	
	
	ТО.Колонки.Добавить("ИдКнопки");
	ТО.Колонки.Добавить("ИмяКнопки");
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	Код,Наименование
	|ИЗ
	|	Справочник.ВнешниеОтчеты
	|ГДЕ
	|	ВидДокумента	=&Вид
	|	И ИмяТЧ			=&ИмяТЧ
	|	И ВидОбработки	=&ВидОбработки
	|	И Не ЭтоГруппа	
	|	И Не ПометкаУдаления
	|";
	
	Запрос.УстановитьПараметр("Вид",			Вид);
	Запрос.УстановитьПараметр("ИмяТЧ",			ИмяТЧ);
	Запрос.УстановитьПараметр("ВидОбработки",	ВидОбработки);
	
	Выборка  = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТО=ТО.Добавить();
		
		СтрокаТО.ИдКнопки	="_"+Формат(Выборка.Код,"ЧГ=0");
		СтрокаТО.ИмяКнопки	=Выборка.Наименование;		
	КонецЦикла;
	
	Возврат ТО;
КонецФункции //ПолучитьТаблицуОбработокМодификации(Тип,Вид,ИмяТЧ,ВидОбработки)

Процедура НастроитьПодменю(Форма,ИмяТЧ,ВидОбработки,ИмяПроцедурыОбработчика="")
	Сч=0;	
	
	Тип						=ТипОбъекта(Форма.ЭтотОбъект);
	Вид						=Форма.Метаданные().Имя;
	КоманднаяПанель 		=Форма.ЭлементыФормы["кп"+ИмяТЧ];
	
	КнопкаПоУмолчанию		=КоманднаяПанель.Кнопки.Найти(ВидОбработки+"ПоУмолчанию");
	
	ОбработкиМодификации	=ПолучитьТаблицуОбработокМодификации(Тип,Вид,ИмяТЧ,ВидОбработки);
	
	ИмяОбработки			=ВосстановитьЗначение(Тип+"_"+Вид+"_Обработка_"+ВидОбработки);
	УстановилиПоУмолчанию	=Ложь;
	
	Подменю			=КоманднаяПанель.Кнопки["Подменю"+ВидОбработки];		
	Если ПустаяСтрока(ИмяПроцедурыОбработчика) Тогда
		ДействиеПоКнопке=Новый Действие("ОбработкаОткрытия"+ВидОбработки);
	Иначе
		ДействиеПоКнопке=Новый Действие(ИмяПроцедурыОбработчика);
	КонецЕсли;	
	
	Для Каждого СтрокаОМ Из ОбработкиМодификации Цикл
		Кнопка=Подменю.Кнопки.Добавить(СтрокаОМ.ИдКнопки,ТипКнопкиКоманднойПанели.Действие,СтрокаОМ.ИмяКнопки,ДействиеПоКнопке);					
		Кнопка.Пояснение		=СтрокаОМ.ИдКнопки;
		Кнопка.ИзменяетДанные   =Истина;
		
		Если КнопкаПоУмолчанию<>Неопределено И ИмяОбработки=СтрокаОМ.ИдКнопки Тогда
			//	КнопкаПоУмолчанию.Имя		=СтрокаОМ.ИдКнопки;
			
			КнопкаПоУмолчанию.Текст    	=СтрокаОМ.ИмяКнопки;
			КнопкаПоУмолчанию.Пояснение =СтрокаОМ.ИдКнопки;			
			
			УстановилиПоУмолчанию=Истина;
		КонецЕсли; 
	КонецЦикла; 
	
	Если КнопкаПоУмолчанию<>Неопределено Тогда
		Если УстановилиПоУмолчанию=Ложь И ОбработкиМодификации.Количество()>0 Тогда		
			КнопкаПоУмолчанию.Текст    	=ОбработкиМодификации[0].ИмяКнопки;
			КнопкаПоУмолчанию.Пояснение =ОбработкиМодификации[0].ИдКнопки;						
		КонецЕсли;
		
		Если ОбработкиМодификации.Количество()=0 Тогда
			КнопкаПоУмолчанию.Доступность=Ложь;		
		КонецЕсли;		
	КонецЕсли;
КонецПроцедуры

Процедура НастроитьПодменюЗаполнить(Форма,ИмяТЧ="Товары",ИмяПроцедурыОбработчика="") Экспорт
	НастроитьПодменю(Форма,ИмяТЧ,"Заполнить",ИмяПроцедурыОбработчика)	
КонецПроцедуры

Процедура НастроитьПодменюПодбор(Форма,ИмяТЧ="Товары",ИмяПроцедурыОбработчика="") Экспорт
	НастроитьПодменю(Форма,ИмяТЧ,"Подбор",ИмяПроцедурыОбработчика)
КонецПроцедуры

Функция РазобратьСтрокуПоРазделителям(Знач Строка,Разделитель)
	Части=Новый Массив;
	
	Поз=Найти(Строка,Разделитель);
	Пока Поз<>0 Цикл
		Части.Добавить(Лев(Строка,Поз-1));			
		
		Строка=Сред(Строка,Поз+1);	
		Поз=Найти(Строка,Разделитель);
	КонецЦикла; 
	
	Если СтрДлина(Строка)<>0 Тогда
		Части.Добавить(Строка);	
	КонецЕсли; 
	
	Возврат Части;
КонецФункции // РазобратьСтрокуПоРазделителям()

Процедура УстановитьКнопкуПоУмолчанию(Форма,Элемент)
	КодОбработки=Число(Сред(Элемент.Пояснение,2));
	ЭлементОбработки=Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОбработки);
	
	Если Найти(Элемент.Имя,"ПоУмолчанию")=0 Тогда		
		ВидОбработки=ЭлементОбработки.ВидОбработки;
		
		КоманднаяПанель		=Форма.ЭлементыФормы["кп"+ЭлементОбработки.ИмяТЧ];
		КнопкаПоУмолчанию   =КоманднаяПанель.Кнопки[ВидОбработки+"ПоУмолчанию"];
		
		КнопкаПоУмолчанию.Текст		=Элемент.Текст;
		КнопкаПоУмолчанию.Пояснение	=Элемент.Пояснение;		
		
		Тип=ТипОбъекта(Форма.ЭтотОбъект);
		Вид=Форма.Метаданные().Имя;
		
		СохранитьЗначение(Тип+"_"+Вид+"_Обработка_"+ВидОбработки,Элемент.Пояснение);
	КонецЕсли; 
КонецПроцедуры

Функция ПолучитьОбработкуПоЭлементу(ЭлементОбработки,КодОбработки)
	Если ЭлементОбработки.Пустая() Тогда
		Сообщить("Не найден элемент справочника ""Внешние обработки"" с кодом: "+КодОбработки,СтатусСообщения.Важное);	
		Возврат Неопределено;
	КонецЕсли;
	
	//Кухарь 13.12.19 начало
	//Для анализа использования
	ЗаписатьДатуИспользованияВнешнегоОтчёта (ЭлементОбработки);
	//Кухарь 13.12.19 конец
	
	
	ИмяОбработки=ЭлементОбработки.ИмяФайла;
	
	Внешняя=Ложь;
	Если Лев(ИмяОбработки,3)="ВН_" Тогда
		ИмяОбработки=Сред(ИмяОбработки,4);	
		Внешняя=Истина;
	КонецЕсли; 
	
	Обработка=Неопределено;
	
	Если Внешняя Тогда
		Если ЭлементОбработки.ВидОбработки="Печать" Тогда
			ДопКаталог="PrnForms\";			
		ИначеЕсли ЭлементОбработки.ВидОбработки="Заполнить" Тогда
			ДопКаталог="FillForms\";						
		ИначеЕсли ЭлементОбработки.ВидОбработки="Подбор" Тогда
			ДопКаталог="SelForms\";									
		Иначе
			ДопКаталог="";		
		КонецЕсли; 
		
		ИмяФайлаОбработки	=Константы.КаталогВнешнихОтчетов.Получить()+ДопКаталог+ИмяОбработки+".epf";	
		ФайлОбработки		=Новый Файл(ИмяФайлаОбработки);
		Если ФайлОбработки.Существует() Тогда
			Возврат ВнешниеОбработки.Создать(ИмяФайлаОбработки);				
		КонецЕсли;
	Иначе
		Если Метаданные.Обработки.Найти(ИмяОбработки)<>Неопределено Тогда
			Возврат Обработки[ИмяОбработки].Создать();	
		КонецЕсли;
	КонецЕсли;	
	
	Предупреждение("Обработка: """+ИмяОбработки+""" не обнаружена !");
	Возврат Неопределено;	
КонецФункции  

Процедура ЗаполнитьТЧ(Форма,Элемент) Экспорт		
	Попытка
		КодОбработки=Число(Сред(Элемент.Пояснение,2));	
	Исключение
		Возврат;
	КонецПопытки;	
	
	ЭлементОбработки=Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОбработки);
	
	Обработка=ПолучитьОбработкуПоЭлементу(ЭлементОбработки,КодОбработки);	
	Если Обработка=Неопределено Тогда Возврат КонецЕсли; 
	
	УстановитьКнопкуПоУмолчанию(Форма,Элемент);
	
	ИмяФормы=?(ПустаяСтрока(ЭлементОбработки.ИмяФормы),Неопределено,ЭлементОбработки.ИмяФормы);
	
	Форма.Модифицированность = Ложь;
	
	Обработка.ДокОбъект	=Форма.ЭтотОбъект;
	ФормаОбработки		=Обработка.ПолучитьФорму(ИмяФормы,Форма,"Ключ");
	ФормаОбработки.Открыть();
КонецПроцедуры

Процедура ОткрытьПодборТЧ(Форма,Элемент,ИмяТЧ="Товары",КолонкаПодбора="Номенклатура",ДопПараметры=Неопределено) Экспорт
	КодОбработки=Число(Сред(Элемент.Пояснение,2));
	ЭлементОбработки=Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОбработки);	
	
	Обработка=ПолучитьОбработкуПоЭлементу(ЭлементОбработки,КодОбработки);	
	Если Обработка=Неопределено Тогда Возврат КонецЕсли; 
	
	УстановитьКнопкуПоУмолчанию(Форма,Элемент);
	
	ТекСтрока=Форма.ЭлементыФормы[ИмяТЧ].ТекущаяСтрока;
	НачальноеЗначениеВыбора=?(ТекСтрока<>Неопределено,ТекСтрока[КолонкаПодбора],Неопределено);	
	
	ИмяФормы=?(ПустаяСтрока(ЭлементОбработки.ИмяФормы),Неопределено,ЭлементОбработки.ИмяФормы);
	
	ФормаОбработки						=Обработка.ПолучитьФорму(ИмяФормы,Форма.ЭлементыФормы[ИмяТЧ],"Ключ");
	ФормаОбработки.Объект				=Форма.ЭтотОбъект;
	ФормаОбработки.РежимВыбора			=Истина;
	ФормаОбработки.НачальноеЗначениеВыбора=НачальноеЗначениеВыбора;
	ФормаОбработки.ЗакрыватьПриВыборе	=Ложь;	
	
	Попытка	
		ФормаОбработки.Параметры=ДопПараметры;
	Исключение	
	КонецПопытки;
	
	ФормаОбработки.Открыть();
КонецПроцедуры

// ЗАКЛАДКИ ПО СКЛАДАМ
Процедура УтановитьОтборПоСкладу(Форма) Экспорт
	ТекСклад=Форма.ЭлементыФормы.ПанельОтбораПоСкладам.ТекущаяСтраница.Значение;
	Если ТекСклад<>Неопределено Тогда
		Форма.ЭлементыФормы.Товары.ОтборСтрок["Склад"].Установить(ТекСклад);
	Иначе
		Форма.ЭлементыФормы.Товары.ОтборСтрок.Сбросить();
	КонецЕсли;
КонецПроцедуры 

Процедура ПерерисовкаЗакладокОтбора(Форма) Экспорт
	ПанельОтбора	=Форма.ЭлементыФормы.ПанельОтбораПоСкладам;
	Если Форма.ЭлементыФормы.Товары.ТекущаяСтрока=Неопределено Тогда
		ТекущийОтбор	=ПанельОтбора.ТекущаяСтраница.Значение;		
	Иначе		
		ТекущийОтбор	=Форма.ЭлементыФормы.Товары.ТекущаяСтрока.Склад;
	КонецЕсли;
	
	Пока ПанельОтбора.Страницы.Количество()>1 Цикл
		ПанельОтбора.Страницы.Удалить(1);		
	КонецЦикла; 
	
	Список=Новый СписокЗначений;	
	Склады=Форма.Товары.ВыгрузитьКолонку("Склад");
	Для Каждого Склад Из Склады Цикл
		Если Список.НайтиПоЗначению(Склад)=Неопределено Тогда
			Список.Добавить(Склад);			
			Страница=ПанельОтбора.Страницы.Добавить(""+Склад.Код,""+Склад,Склад);			
			Если ТекущийОтбор=Склад Тогда
				ПанельОтбора.ТекущаяСтраница=Страница;
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;	
	
	УтановитьОтборПоСкладу(Форма);
КонецПроцедуры 

//ВЫБОР НОМЕНКЛАТУРЫ
Процедура НачалоВыбораНоменклатуры(Элемент, СтандартнаяОбработка) Экспорт
	Если ПолучитьЗначениеПоУмолчанию("ВыборНоменклатурыПо77") Тогда
		СтандартнаяОбработка=Ложь;
		
		Форма=Справочники.Номенклатура.ПолучитьФормуСписка("ФормаСписка77",Элемент,"Подбор");
		Форма.РежимВыбора=Истина;
		Форма.НачальноеЗначениеВыбора=Элемент.Значение;
		Форма.Открыть();		
	КонецЕсли;	
КонецПроцедуры

Процедура ПоказатьСФ(Форма,РНК) Экспорт	
	СФ=СчетФактураНакладной(РНК);
	
	ФормаСФ=Неопределено;
	
	Если СФ.Пустая() Тогда
		Если РНК.ПометкаУдаления Тогда
			Предупреждение("СФ не обнаружена ! Невозможно выписать СФ на удаленную накладную !");
		ИначеЕсли РНК.СостояниеЗаказа=Перечисления.СостояниеЗаказа.РаспечатанИОтгружен Тогда
			Предупреждение("СФ не обнаружена ! Накладная была отгружена без СФ !");			
		ИначеЕсли РНК.Контрагент.СводныеСФ Тогда
			Предупреждение("Для контрагента: """+РНК.Контрагент+""" можно выписывать только сводные СФ !");
		Иначе
			ОбъектСФ=Документы.СчетФактура.СоздатьДокумент();				
			ОбъектСФ.Заполнить(РНК);
			ФормаСФ=ОбъектСФ.ПолучитьФорму("ФормаДокумента",Форма,"СФ"+РНК);			
		КонецЕсли;		
	Иначе
		Если СФ.ПометкаУдаления Тогда
			Предупреждение("Найденная СФ помечена на удаление !");
		КонецЕсли;		
		ФормаСФ=СФ.ПолучитьФорму("ФормаДокумента",Форма,"СФ"+РНК.Ссылка);
	КонецЕсли;
	
	Если ФормаСФ<>Неопределено Тогда
		ФормаСФ.Открыть();
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьДоговорыКорагента(Контрагент,Организация=Неопределено)
	МассивДоговоров=Новый Массив;
	
	КодЦБ=?(ПустаяСтрока(Контрагент.КодЦБ),Контрагент.Код,Контрагент.КодЦБ);
	
	Выборка=Справочники.Договоры.Выбрать(,,Новый Структура("КодЦБ",КодЦБ));
	Пока Выборка.Следующий() Цикл
		//Если задана организация то договора с другой организацией пропускаем
		//	Если Организация<>Неопределено И НЕ Организация.Пустая() И Выборка.Организация<>Организация Тогда Продолжить КонецЕсли; 	
		
		
		МассивДоговоров.Добавить(Выборка.Ссылка);
	КонецЦикла; 
	
	Возврат МассивДоговоров;
КонецФункции // ПолучитьДОговорыКорагента()

Процедура ВыбратьДоговор(Контрагент,Элемент,СтандартнаяОбработка,Организация=Неопределено) Экспорт
	СтандартнаяОбработка=Ложь;	
	
	Форма=Справочники.Договоры.ПолучитьФормуВыбора("ФормаВыбора",Элемент);
	Форма.ПараметрОтборПоВладельцу=Контрагент;
	Форма.Организация=Организация;
	
	Форма.Открыть();
КонецПроцедуры

Процедура ВыбратьДопЗначениеСубконто(Элемент,СтандартнаяОбработка,Организация=Неопределено) Экспорт
	СтандартнаяОбработка=Ложь;	
	
	Форма=Справочники.ДопЗначенияСубконто.ПолучитьФормуВыбора("ФормаВыбора",Элемент);
	Форма.ПараметрОтборПоВладельцу=Элемент.ВыборПоВладельцу;
	Форма.Организация=Организация;
	
	Форма.Открыть();
КонецПроцедуры

Процедура УстановитьДоговор(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент",ИмяРеквизитаДоговор="Договор") Экспорт
	Контрагент	=ДокументОбъект[ИмяРеквизитаКонтрагент];
	Договор		=ДокументОбъект[ИмяРеквизитаДоговор];
	Организация	=ДокументОбъект.Организация;
	
	КодЦБ=?(ПустаяСтрока(Контрагент.КодЦБ),Контрагент.Код,Контрагент.КодЦБ);
	
	//По просьбе Ярослава, задача № 0000000468 
	//Если НЕ(Договор.Пустая()) Тогда
	//	Если СокрЛП(Договор.КодЦБ)=СокрЛП(КодЦБ) Тогда
	//		Возврат;
	//	КонецЕсли; 		
	//КонецЕсли;
	
	ДокументОбъект[ИмяРеквизитаДоговор]=Неопределено;
	
	Если Контрагент.Пустая() Тогда Возврат КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(Контрагент.ОсновнойДоговор) Тогда
		Договора=ПолучитьДоговорыКорагента(Контрагент,Организация);
	Иначе
		Договора=Новый Массив;	
		Договора.Добавить(Контрагент.ОсновнойДоговор);
	КонецЕсли;	
	
	//Нечаева// 
	
	Если Договора.ВГраница()<0 Тогда
		Предупреждение("Невозможно определить договор контрагента !");
	ИначеЕсли Договора.ВГраница()=0 Тогда
		ДокументОбъект[ИмяРеквизитаДоговор]=Договора[0];			
	Иначе
		Предупреждение("У контрагента: """+Контрагент+""" заключено несколько договоров с организацией """+Организация+""" !"+Символы.ПС+
		"Основной договор для данного контрагента не указан !"+Символы.ПС+
		"Требуется вручную выбрать необходимый договор !");	
	КонецЕсли;	
КонецПроцедуры

Процедура УстановитьПунктДоставки(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент",ИмяРеквизитаПД="ПунктДоставки") Экспорт	
	Контрагент		=ДокументОбъект[ИмяРеквизитаКонтрагент];
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЕстьРеквизитДокумента("ОсновнойПунктДоставки",Контрагент.Метаданные()) И ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект[ИмяРеквизитаПД]=Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПД(Контрагент)=1 Тогда		
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин начало
			//для складов, если несколько ПД, выбираем первый
		ИначеЕсли ИмяРеквизитаКонтрагент = "СкладПолучатель" Тогда
			//крохин начало 28.07.2011
			//выбираем первый по наименованию
			//Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент,,"Наименование Убыв");
			//крохин конец 28.07.2011
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин конец
		Иначе
			ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
	КонецЕсли;	
КонецПроцедуры//УстановитьПунктДоставки(ДокументОбъект,ИмяРеквизитаКонтрагент="Контрагент")

Процедура НачалоВыбораДоговора(ДокументОбъект, ФормаДокумента, ЭлементФормы, Контрагент, Договор,СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	
	// В качестве владельца формы выбора устанавливаем данный элемент формы, чтобы выбранное
	// значение было присвоено стандартно.
	ФормаВыбора = Справочники.Договоры.ПолучитьФормуВыбора(,ЭлементФормы,);
	
	// Владельца менять по умолчанию не даем.
	ФормаВыбора.ПараметрОтборПоВладельцу = Контрагент;
	ФормаВыбора.ЭлементыФормы.СправочникСписок.НастройкаОтбора.Владелец.Доступность = Ложь;
	
	// Еще надо фильтровать по организации, если она заполнена
	Если ЕстьРеквизитДокумента("Организация",МетаданныеДокумента) Тогда
		ФормаВыбора.СправочникСписок.Отбор.Организация.Значение                            = ДокументОбъект.Организация;
		ФормаВыбора.СправочникСписок.Отбор.Организация.Использование                       = Истина;
		ФормаВыбора.СправочникСписок.Отбор.Организация.ВидСравнения                        = ВидСравнения.Равно;
		ФормаВыбора.ЭлементыФормы.СправочникСписок.НастройкаОтбора.Организация.Доступность = Ложь;
	КонецЕсли;
	
	ФормаВыбора.ЭлементыФормы.СправочникСписок.ТекущаяСтрока = Договор;
	ФормаВыбора.Открыть();
КонецПроцедуры

Процедура КонтрольДоговора(ДокументОбъект,Элемент) Экспорт	
	Если НЕ(Элемент.Значение.Пустая()) И Элемент.Значение.Организация<>ДокументОбъект.Организация Тогда
		Предупреждение("Нельзя выбирать договор другой организации !");	
		Элемент.Значение= Неопределено;			
	КонецЕсли;    
КонецПроцедуры

