			КонецЕсли;			
			
			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда
				ПрефиксКонтрагента=СокрЛП(ПолучитьРеквизитРодителя(ДокументОбъект.Контрагент,"ПрефиксСФ"));			
			КонецЕсли; 
			
			Если ПустаяСтрока(ПрефиксКонтрагента) Тогда
				ПрефиксСклада	=СокрЛП(ДокументОбъект.Склад.Префикс);
				//крохин начало 01.08.2019
				//для КСФ-возвратов в ЦО префикс склада всегда "v"
				Попытка
					ДокРКМ =  ДокументОбъект.накладные[0].накладная;
					Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение И ДокРКМ.Метаданные().Имя = "РекламационнаяНакладная" И НЕ (ДокРКМ.ДокументВозврата.Пустая()) Тогда
						ПрефиксСклада = "v";	
					КонецЕсли;
				Исключение
					
				КонецПопытки;
				//крохин конец 01.08.2019
				ПрефиксИБ		=СокрЛП(ДокументОбъект.Склад.ПрефиксИБ);
				
				Если ПрефиксИБ="SNL" Тогда
					Префикс=ПрефиксИБ;
				Иначе
					Префикс=?(НЕ ПустаяСтрока(ДокументОбъект.Организация.Префикс),СокрЛП(ДокументОбъект.Организация.Префикс)+ПрефиксСклада,ДокументОбъект.ИБ.Код);				
				КонецЕсли;				
			Иначе				
				Префикс=?(НЕ ПустаяСтрока(ДокументОбъект.Организация.Префикс),СокрЛП(ДокументОбъект.Организация.Префикс)+ПрефиксКонтрагента,ДокументОбъект.ИБ.Код);			
			КонецЕсли;			
		КонецЕсли; 
		
		Если ПерваяСФ(Префикс,ДокументОбъект.Дата) Тогда
			//Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			//	КоличествоПропусков=2;			
			//ИначеЕсли Лев(Префикс,2)="КБ" Тогда
			//	КоличествоПропусков=4;
			//Иначе	
			//	КоличествоПропусков=1;						
			//КонецЕсли;
			КоличествоПропусков = 1; 
		Иначе
			КоличествоПропусков=0;
		КонецЕсли;
		
		УстановитьНормальныйНовыйНомер(ДокументОбъект,Префикс+"-",КоличествоПропусков);
		//нечаева 06,02,17 ++++
		
		
		
		
		//// ищем СФ
		//Запрос= Новый Запрос;
		//Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		//			   |	СчетФактураНакладные.Ссылка
		//			   |ИЗ
		//			   |	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
