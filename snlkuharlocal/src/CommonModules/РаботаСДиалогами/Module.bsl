//ЗАКЛАДКИ В СПРАВОЧНИКАХ
Процедура УстановитьОтборПоВладельцу(Форма) Экспорт
	Список=Форма.ЭлементыФормы.Список.Значение;
	Дерево=Форма.ЭлементыФормы.Дерево.Значение;
	
	Владелец=Форма.ЭлементыФормы.Панель.ТекущаяСтраница.Значение;
	
	ОтборПоВладельцу=Список.Отбор.Владелец;
	
	ОтборПоВладельцу.ВидСравнения	=ВидСравнения.Равно;
	ОтборПоВладельцу.Значение		=Владелец;
	ОтборПоВладельцу.Использование	=Истина;
	
	ОтборПоВладельцу=Дерево.Отбор.Владелец;
	
	ОтборПоВладельцу.ВидСравнения	=ВидСравнения.Равно;
	ОтборПоВладельцу.Значение		=Владелец;
	ОтборПоВладельцу.Использование	=Истина;
КонецПроцедуры

Процедура УстановитьЗакладкиПоВладельцам(Форма) Экспорт
	ТекущаяСтраница			=Неопределено;
	Панель					=Форма.ЭлементыФормы.Панель;
	НачальноеЗначениеВыбора	=Форма.НачальноеЗначениеВыбора;
	Если НачальноеЗначениеВыбора=Неопределено Тогда
		НачальноеЗначениеВыбора=Форма.ПараметрТекущаяСтрока;
	КонецЕсли; 
	ПараметрОтборПоВладельцу=Форма.ПараметрОтборПоВладельцу;	
	
	ЕстьОтборПоВладельцу=Истина;
	Если НачальноеЗначениеВыбора<>Неопределено И НЕ НачальноеЗначениеВыбора.Пустая()  Тогда
		ТекВладелец=НачальноеЗначениеВыбора.Владелец;
	ИначеЕсли ПараметрОтборПоВладельцу<>Неопределено И НЕ ПараметрОтборПоВладельцу.Пустая() Тогда
		ТекВладелец=ПараметрОтборПоВладельцу;		
	Иначе
		ТекВладелец=ПолучитьИБПоУмолчанию();		
		ЕстьОтборПоВладельцу=Ложь;
	КонецЕсли; 
	
	ЗначенияОтбора=Новый ТаблицаЗначений;
	ЗначенияОтбора.Колонки.Добавить("ЗначениеОтбора");
	
	Если Форма.РежимВыбора И ЕстьОтборПоВладельцу И НЕ РольДоступна("Администратор") Тогда
		Форма.ЭлементыФормы.Список.НастройкаОтбора.Владелец.Доступность=Ложь;
		СтрокаОтбора=ЗначенияОтбора.Добавить();
		СтрокаОтбора.ЗначениеОтбора=ТекВладелец;
	Иначе
		Вид=Метаданные.НайтиПоТипу(ТипЗнч(Форма.Список)).Имя;
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Владелец КАК ЗначениеОтбора,
		|	Владелец.Наименование КАК ВладелецНаименование
		|ИЗ
		|	Справочник."+Вид+" КАК Справочник
		|УПОРЯДОЧИТЬ ПО	ВладелецНаименование";
		
		ЗначенияОтбора=Запрос.Выполнить().Выгрузить();		
	КонецЕсли; 
	
	Для Каждого Строка Из ЗначенияОтбора Цикл	
		Если ЗначенияОтбора.Индекс(Строка)=0 Тогда
			Страница=Панель.Страницы.Начальная;			
		Иначе			
			Страница=Панель.Страницы.Добавить("Владелец__"+ЗначенияОтбора.Индекс(Строка));		
		КонецЕсли;
		
		Страница.Заголовок	=""+Строка.ЗначениеОтбора;
		Страница.Значение	=Строка.ЗначениеОтбора;
		
		Если ТекВладелец=Строка.ЗначениеОтбора Тогда
			ТекущаяСтраница=Страница;
		КонецЕсли;
	КонецЦикла;
	
	Если ТекущаяСтраница<>Неопределено Тогда
		Панель.ТекущаяСтраница=ТекущаяСтраница;
		УстановитьОтборПоВладельцу(Форма);		
	КонецЕсли;	
	                          
	//Если Форма.ЭлементыФормы.Список.ТекущаяСтрока <> Неопределено Тогда
	Форма.ЭлементыФормы.Список.ИерархическийПросмотр = Ложь;
	Форма.ЭлементыФормы.Список.ИерархическийПросмотр = Истина;
	//КонецЕсли;
	
КонецПроцедуры


// ОТБОРЫ В ЖУРНАЛАХ
Процедура УстановитьОтборЖурнала(Форма, ЭлементыОтбора = Неопределено, ПоляМножественногоОтбора = Неопределено, ПоляГрупповогоОтбора = Неопределено) Экспорт
	
	ЭлементыМножественногоОтбора = Новый СписокЗначений;
	
	Если ЭлементыОтбора <> Неопределено Тогда // Шворобей ВЮ 02.04.2024 ++ Добавил условие
		Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
			
			ИмяЭлементаОтбора=ЭлементОтбора.Ключ;
			
			ТекЗначение = ЭлементОтбора.Значение;
			
			Если НЕ ЗначениеЗаполнено(ТекЗначение) Тогда
				ТекЗначение = Форма.ЭлементыФормы[ИмяЭлементаОтбора].Значение;
			КонецЕсли;
			
			Если ИмяЭлементаОтбора = "ВидДокумента" И НЕ ЗначениеНеЗаполнено(ТекЗначение) Тогда
				ТекЗначение = Метаданные.Документы[ТекЗначение];		
			КонецЕсли; 
			
			Если ПоляМножественногоОтбора <> Неопределено И ПоляМножественногоОтбора.Свойство(ИмяЭлементаОтбора) Тогда
				Если НЕ ЗначениеНеЗаполнено(ТекЗначение)  Тогда
					ЭлементыМножественногоОтбора.Добавить(ТекЗначение);
				КонецЕсли;			
			Иначе
				ЭлементОтбора=Форма.Список.Отбор[ИмяЭлементаОтбора];
				
				Если ЗначениеНеЗаполнено(ТекЗначение) Тогда
					ЭлементОтбора.Использование=Ложь;
				Иначе			
					ЭлементОтбора.ВидСравнения	=ВидСравнения.Равно;
					
					Если ТипОбъекта(ТекЗначение)="Справочник" И ТекЗначение.ЭтоГруппа И ПоляГрупповогоОтбора<>Неопределено И ПоляГрупповогоОтбора.Свойство(ИмяЭлементаОтбора) Тогда
						ЭлементОтбора.ВидСравнения	=ВидСравнения.ВИерархии;				
					КонецЕсли; 
					
					Если ТипЗнч(ЭлементОтбора.Значение)=Тип("Булево") И ТипЗнч(ТекЗначение)=Тип("Число") Тогда
						Если ТекЗначение=0 Тогда
							ЭлементОтбора.Установить(Ложь,Истина);
						ИначеЕсли ТекЗначение=1 Тогда
							ЭлементОтбора.Установить(Истина,Истина);
						Иначе
							ЭлементОтбора.Установить(Ложь,Ложь);						
						КонецЕсли;				
					Иначе
						// Кухарь А.Ю.  07.05.2026 начало
						// HELP-9700  
						//ЭлементОтбора.Значение		= ТекЗначение;									
						//ЭлементОтбора.Использование	= Истина;						
						Если Форма.КлючУникальности = "ЛистыПереукладки" тогда
							если ТипЗнч(ТекЗначение)<>Тип("ДокументСсылка.РасходнаяНакладная") Тогда
								ЭлементОтбора.Значение		= Документы.РасходнаяНакладная.ПустаяСсылка();									
								ЭлементОтбора.Использование	= Истина;	
								ЭлементОтбораДата = Форма.Список.Отбор["Дата"];
								ЭлементОтбораДата.Значение 	= ТекущаяДата();
								ЭлементОтбораДата.Использование = Истина;  
							иначе               
								ЭлементОтбора.Значение		= ТекЗначение;									
								ЭлементОтбора.Использование	= Истина;	
								ЭлементОтбораДата = Форма.Список.Отбор["Дата"];
								ЭлементОтбораДата.Использование = ложь;  							
							КонецЕсли;		
						иначе
							ЭлементОтбора.Значение		= ТекЗначение;									
							ЭлементОтбора.Использование	= Истина;
						КонецЕсли;	
						// Кухарь А.Ю.  07.05.2026 конец	
							
					КонецЕсли;				
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Шворобей ВЮ 02.04.2024 ++  Переделал, было не работоспособно
	ИмяЭлементаОтбора = Неопределено;
	Если ПоляМножественногоОтбора <> Неопределено Тогда
		
		Для Каждого ПолеМО ИЗ ПоляМножественногоОтбора Цикл
			ИмяЭлементаОтбора = ПолеМО.Ключ;
			ИмяПоляМножественногоОтбора = ПолеМО.Значение;
			Прервать;
		КонецЦикла;
		
		Если ИмяЭлементаОтбора = Неопределено Тогда Возврат КонецЕсли;
		
		Если ПустаяСтрока(ИмяПоляМножественногоОтбора) Тогда
			ИмяПоляМножественногоОтбора = "Список" + ИмяЭлементаОтбора;
		КонецЕсли;
			
		ЗначениеМножественногоОтбора = Форма.ЭлементыФормы[ИмяПоляМножественногоОтбора].Значение;
			
		Для Каждого ТекЭлементОтбора ИЗ ЗначениеМножественногоОтбора Цикл
			Если ЗначениеЗаполнено(ТекЭлементОтбора.Значение) И ЭлементыМножественногоОтбора.НайтиПоЗначению(ТекЭлементОтбора.Значение) = Неопределено Тогда
				ЭлементыМножественногоОтбора.Добавить(ТекЭлементОтбора.Значение);
			КонецЕсли;
		КонецЦикла;
		
		ЭлементОтбора = Форма.Список.Отбор[ИмяЭлементаОтбора];
		
		Если ЭлементыМножественногоОтбора.Количество() = 0 Тогда
			ЭлементОтбора.Использование = Ложь;			
		Иначе
			ЭлементОтбора.ВидСравнения	= ВидСравнения.ВСписке;
			ЭлементОтбора.Значение		= ЭлементыМножественногоОтбора;		
			ЭлементОтбора.Использование	= Истина;
		КонецЕсли;
	КонецЕсли;
	// Шворобей ВЮ 02.04.2024 ++
	
	//кухарь 31.03.15 начало
	Если ПоляГрупповогоОтбора <> Неопределено тогда
		Для каждого ПолеГО из ПоляГрупповогоОтбора Цикл
			Попытка
				ИмяЭлементаОтбора = ПолеГО.ключ;
				Если ИмяЭлементаОтбора = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				ЭлементОтбора = Форма.Список.Отбор[ИмяЭлементаОтбора];	
				Если ЭлементОтбора.ВидСравнения = ВидСравнения.ВСписке Тогда
					ЭлементОтбора.ВидСравнения = ВидСравнения.ВСпискеПоИерархии;
				ИначеЕсли ЭлементОтбора.ВидСравнения = ВидСравнения.Равно Тогда
					ЭлементОтбора.ВидСравнения = ВидСравнения.ВИерархии;
				КонецЕсли;		
			Исключение
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	//кухарь 31.03.15 конец
	
КонецПроцедуры

Функция ПолучитьУстановкиОтбора(Форма,ЭлементыОтбора) Экспорт
	УстановкиОтбора=Новый Соответствие;
	
	Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
		ЗначениеОтбора=Форма[ЭлементОтбора.Ключ];
		
		Если НЕ ЗначениеНеЗаполнено(ЗначениеОтбора) Тогда
			УстановкиОтбора.Вставить(ЭлементОтбора.Ключ,ЗначениеОтбора);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат УстановкиОтбора;
КонецФункции // ПолучитьУстакновкиОтбора()

Функция ПолучитьРеквизитДокумента(ДокСсылка,ИмяЭлементаОтбора) Экспорт
	ВидДокумента=ДокСсылка.Метаданные().Имя;
	
	Если ИмяЭлементаОтбора="ВидДокумента" Тогда
		Возврат ВидДокумента;	
	ИначеЕсли ИмяЭлементаОтбора="Получатель" Тогда
		Если ВидДокумента="Перемещение" Тогда		
			Возврат ДокСсылка.СкладПолучатель;
		Иначе
			Возврат ДокСсылка.Контрагент;
		КонецЕсли; 
	Иначе
		Если ДокСсылка.Метаданные().Реквизиты.Найти(ИмяЭлементаОтбора)<>Неопределено Тогда
			Возврат ДокСсылка[ИмяЭлементаОтбора];
		Иначе
			Возврат Неопределено;
		КонецЕсли; 		
	КонецЕсли;
КонецФункции // ПолучитьЗначениеЭлементаОтбораДокумента()

Процедура УстановитьЭлементыОтбораПоДокументу(Форма,ЭлементыОтбора,ДокСсылка,ПоляМножественногоОтбора=Неопределено) Экспорт
	ПереустановитьОтбор=Ложь;
	ЭлементыМножественногоОтбора=Новый СписокЗначений;
	
	УстановкиОтбора	=ПолучитьУстановкиОтбора(Форма,ЭлементыОтбора);
	МетаДок			=ДокСсылка.Метаданные();	
	
	Для Каждого ЭлементОтбора Из УстановкиОтбора Цикл		
		ИмяЭлементаОтбора	=ЭлементОтбора.Ключ;
		ЗначениеОтбора		=ЭлементОтбора.Значение;
		
		Если ЗначениеНеЗаполнено(ЗначениеОтбора) Тогда Продолжить КонецЕсли; 
		
		Если ПоляМножественногоОтбора<>Неопределено И ПоляМножественногоОтбора.Свойство(ИмяЭлементаОтбора) Тогда
			Если Не ЗначениеНеЗаполнено(ЗначениеОтбора) Тогда				
				ЭлементыМножественногоОтбора.Добавить(ЗначениеОтбора,ИмяЭлементаОтбора);			
			КонецЕсли;		
		Иначе
			Если ЗначениеНеЗаполнено(ЗначениеОтбора) Тогда Продолжить КонецЕсли; 
			//Если НЕ ЕстьРеквизитДокумента(ИмяЭлементаОтбора,МетаДок) Тогда Продолжить КонецЕсли; 
			
			РеквизитДокумента=ПолучитьРеквизитДокумента(ДокСсылка,ИмяЭлементаОтбора);
			Если РеквизитДокумента<>ЗначениеОтбора Тогда
				Форма[ИмяЭлементаОтбора]=РеквизитДокумента;				
				ПереустановитьОтбор=Истина;
			КонецЕсли;			
		КонецЕсли;
	КонецЦикла;
	
	Если ПоляМножественногоОтбора<>Неопределено Тогда
		Для Каждого ПолеМО ИЗ ПоляМножественногоОтбора Цикл
			ИмяЭлементаОтбора=ПолеМО.Ключ;			
			Прервать;
		КонецЦикла;
		
		РеквизитДокумента=ПолучитьРеквизитДокумента(ДокСсылка,ИмяЭлементаОтбора);
		Если ЭлементыМножественногоОтбора.НайтиПоЗначению(РеквизитДокумента)=Неопределено Тогда
			Если НЕ ЗначениеНеЗаполнено(Форма[ИмяЭлементаОтбора]) Тогда
				Форма[ИмяЭлементаОтбора]=РеквизитДокумента;						
				ПереустановитьОтбор=Истина;			
			КонецЕсли;			
		КонецЕсли;	
	КонецЕсли; 
	
	Если ПереустановитьОтбор Тогда
		УстановитьОтборЖурнала(Форма,ЭлементыОтбора,ПоляМножественногоОтбора);	
	КонецЕсли; 
КонецПроцедуры  

//ЖУРНАЛИЗАЦИЯ
Функция ПолучитьСсылкуСписка(Список,ПустаяСсылка=Неопределено) Экспорт
	ТекДанные=Список.ТекущиеДанные;
	Если ТекДанные=Неопределено Тогда
		Возврат ПустаяСсылка;
	Иначе
		Возврат ТекДанные.Ссылка;	
	КонецЕсли; 
КонецФункции // ПолучитьСсылкуСписка()

Процедура ОткрытьЖурналРегистрации(Ссылка) Экспорт
	Если Константы.ИспользоватьВнешниеЛоги.Получить() Тогда
		ИмяФайла=Константы.КаталогВнешнихОтчетов.Получить()+"ПросмотрЖурналаРегистрации.epf";
		
		Файл=Новый Файл(ИмяФайла);
		Если Файл.Существует() Тогда
			Обработка=ВнешниеОбработки.Создать(ИмяФайла);
			
			Обработка.СсылкаНаОбъект=Ссылка;
			Обработка.ПолучитьФорму().Открыть();			
		ИначеЕсли Метаданные.Обработки.Найти("ПросмотрЖурналаРегистрации")<>Неопределено Тогда
			Обработка=Обработки.ПросмотрЖурналаРегистрации.Создать();
			
			Обработка.СсылкаНаОбъект=Ссылка;
			Обработка.ПолучитьФорму().Открыть();	
		КонецЕсли;	
	Иначе
		Форма=РегистрыСведений.ЖурналРегистрации.ПолучитьФормуСписка();
		Форма.СсылкаНаОбъект=Ссылка;
		Форма.Открыть();	
	КонецЕсли;	
КонецПроцедуры

Процедура ОткрытьЖурналРассогласований(Ссылка) Экспорт
	Форма=РегистрыСведений.РассогласованияОбъектов.ПолучитьФормуСписка();
	Форма.СсылкаНаОбъект=Ссылка;
	Форма.Открыть();
КонецПроцедуры

// Кухарь А.Ю.  02.05.2023 конец
//Процедура ПолучитьОстатки(СписокНоменклатуры,Склад,Накладная,КэшОстатков, ФлагФизСклад = Ложь) Экспорт 
Процедура ПолучитьОстатки(СписокНоменклатуры,Склад,МасивНакладных,КэшОстатков, ФлагФизСклад = Ложь,МассивДополнительныхСкладов=Неопределено) Экспорт
// Кухарь А.Ю.  02.05.2023 конец

	
	Если СписокНоменклатуры.ВГраница()<0 Тогда Возврат КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Склад) Тогда Возврат КонецЕсли;
	
	МассивСкладов = Новый Массив();
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Сводный.Номенклатура.Код77 КАК Код77,
	|	Сводный.Номенклатура КАК Номенклатура,
	|	СУММА(Сводный.Остаток) КАК Остаток,
	|	СУММА(Сводный.Резерв) КАК Резерв,
	|	СУММА(Сводный.ВиртуальныйРезерв) КАК ВиртуальныйРезерв
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Остатки.Номенклатура, Резервы.Номенклатура) КАК Номенклатура,
	|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	|		0 КАК ВиртуальныйРезерв
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В (&СписокНоменклатуры)) КАК Остатки
	|			ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В (&СписокНоменклатуры)) КАК Резервы
	|			ПО Остатки.Номенклатура = Резервы.Номенклатура
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ОстаткиТМЦ.Номенклатура,
	|		ОстаткиТМЦ.Количество,
	|		0,
	|		0
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|	ГДЕ
	|		ОстаткиТМЦ.Регистратор в (&Регистратор)
	|		И ОстаткиТМЦ.Склад В(&МассивСкладов)
	|		И ОстаткиТМЦ.ВидДвижения = &Расход
	|		И ОстаткиТМЦ.Номенклатура В(&СписокНоменклатуры)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыТМЦ.Номенклатура,
	|		0,
	|		-РезервыТМЦ.Количество,
	|		0
	|	ИЗ
	|		РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|	ГДЕ
	|		РезервыТМЦ.Регистратор В (&Регистратор)
	|		И РезервыТМЦ.Склад В(&МассивСкладов)
	|		И РезервыТМЦ.Номенклатура В(&СписокНоменклатуры)) КАК Сводный
	|
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Номенклатура,
	|	Сводный.Номенклатура.Код77
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сводный.Номенклатура";
	
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);	
	Запрос.УстановитьПараметр("Регистратор",МасивНакладных);
	Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
	
	//Кухарь 02.03.18 начало
	Если НЕ Склад.ФизическийСклад.Пустая() И ПараметрыСеанса.ТипУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение и склад.ВидСклада<>Перечисления.ВидСклада.ВиртуальныйДляСклада Тогда
		//Кухарь 02.03.18 конец
		МассивСкладов.Добавить(Склад.ФизическийСклад);				
	Иначе
		МассивСкладов.Добавить(Склад);				
	КонецЕсли;
	
	// Кухарь А.Ю.  02.05.2023 начало
	если МассивДополнительныхСкладов<>Неопределено тогда
		для каждого СтрМасс из МассивДополнительныхСкладов цикл
			МассивСкладов.Добавить(СтрМасс);
		КонецЦикла;
	КонецЕсли;
	// Кухарь А.Ю.  02.05.2023 конец
	
	
	
	Если ФлагФизСклад И НЕ Склад.ФизическийСклад.Пустая() Тогда
		МассивСкладов.Добавить(Склад.ФизическийСклад);
	КонецЕсли;
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл	
		КэшОстатков.Вставить(Выборка.Номенклатура,Новый Структура("Остаток,Резерв,СвободныйОстаток,Код77",Выборка.Остаток,Выборка.Резерв,Макс(0,Выборка.Остаток-Выборка.Резерв-Выборка.ВиртуальныйРезерв),Выборка.Код77));	
	КонецЦикла;
	
КонецПроцедуры 
//крохин начало

