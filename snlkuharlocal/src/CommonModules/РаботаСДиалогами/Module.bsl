Процедура НастроитьПодменюПечати1(Форма, ТипОбъекта=Неопределено, ВидОбъекта=Неопределено, Контрагент=неопределено) Экспорт 
	Тип=?(ТипОбъекта=Неопределено,ТипОбъекта(Форма.Ссылка),ТипОбъекта);
	Вид=?(ВидОбъекта=Неопределено,Форма.Метаданные().Имя,ВидОбъекта);
	ПодменюПечати	=Форма.ЭлементыФормы.ДействияФормы.Кнопки.ПодменюПечати;	
	ПодменюПечати.Кнопки.Очистить();
	ИмяПечатнойФормы=ВосстановитьЗначение(Тип+"."+Вид+"ИмяПечатнойФормы");	
	ИдКнопкиПоУмолчанию=Неопределено;
	СтрокаТПФПоУмолчанию=Неопределено;
	ТПФ		= ПолучитьТаблицуПечатныхФорм(Тип+"."+Вид);
	Для Каждого СтрокаТПФ Из ТПФ Цикл
		Кнопка=ПодменюПечати.Кнопки.Добавить(СтрокаТПФ.ИДКнопки,ТипКнопкиКоманднойПанели.Действие,СтрокаТПФ.Наименование,Новый Действие("ПечатьВнеш"));
		Кнопка.Пояснение=СтрокаТПФ.ИДКнопки;
		Кнопка.Доступность = Истина;
		Если СтрокаТПФ.Наименование=ИмяПечатнойФормы Тогда
			СтрокаТПФПоУмолчанию=СтрокаТПФ;			
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры

Процедура ВнешняяПечать1(Форма, Ссылка, Элемент, ДопПараметры=Неопределено) Экспорт
	КодВОО = Сред(СокрЛП(Элемент.Пояснение), 2);
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ВнешниеОтчеты.Код КАК Код,
	|	ВнешниеОтчеты.Наименование КАК Наименование,
	|	ВнешниеОтчеты.Ссылка КАК Ссылка,
	|	ВнешниеОтчеты.ИмяФайла КАК ИмяФайла
	|ИЗ
	|	Справочник.ВнешниеОтчеты КАК ВнешниеОтчеты
	|ГДЕ
	|	ВнешниеОтчеты.Код = &КодВОО";
	
	Запрос.УстановитьПараметр("КодВОО",		Число(КодВОО));
	Выборка=Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
		ОбработкаПечати = Неопределено;
		ИмяОбработки = СокрЛП(Выборка.ИмяФайла);
		Если Лев(ИмяОбработки,3)="ВН_" Тогда
			ИмяОбработки=Сред(ИмяОбработки,4);	
		КонецЕсли;
		ДопКаталог="PrnForms\";
		ПолноеИмяФайлаОб	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить() + ИмяОбработки + ".epf");
		ПолноеИмяФайлаОтч	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить() + ИмяОбработки + ".erf");
		
		ПолноеИмяФайлаОб1	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить() + ДопКаталог + ИмяОбработки + ".epf");
		ПолноеИмяФайлаОтч1	=СокрЛП(Константы.КаталогВнешнихОтчетов.Получить() + ДопКаталог + ИмяОбработки + ".erf");
		
		ФайлОтчетаОб		= Новый Файл(ПолноеИмяФайлаОб);
		ФайлОтчетаОтч		= Новый Файл(ПолноеИмяФайлаОтч); 
		
		ФайлОтчетаОб1		= Новый Файл(ПолноеИмяФайлаОб1);
		ФайлОтчетаОтч1		= Новый Файл(ПолноеИмяФайлаОтч1);
		
		Если ФайлОтчетаОб.Существует() Тогда
			ОбработкаПечати = ВнешниеОбработки.Создать(ПолноеИмяФайлаОб);
		ИначеЕсли ФайлОтчетаОтч.Существует() Тогда
			ОбработкаПечати = ВнешниеОтчеты.Создать(ПолноеИмяФайлаОтч); 
		ИначеЕсли ФайлОтчетаОб1.Существует() Тогда
			ОбработкаПечати = ВнешниеОбработки.Создать(ПолноеИмяФайлаОб1);
		ИначеЕсли ФайлОтчетаОтч1.Существует() Тогда
			ОбработкаПечати = ВнешниеОтчеты.Создать(ПолноеИмяФайлаОтч1);
		Иначе
			Попытка
				ОбработкаПечати = Обработки[ИмяОбработки].Создать();
			Исключение 
				Попытка
					ОбработкаПечати = Отчеты[ИмяОбработки].Создать();
				Исключение
				КонецПопытки;
			КонецПопытки;	
		КонецЕсли;
		Если НЕ ОбработкаПечати = Неопределено Тогда
			ФормаО	= ОбработкаПечати.ПолучитьФорму();
			Попытка         
				//Если ОбработкаПечати.Свойство("ПечатьСразу") Тогда
				//	ОбработкаПечати.ПечатьСразу = Истина;
				//КонецЕсли;	   
				//Для Каждого КлЗ Из ОбработкаПечати.Реквизиты Цикл
				//	Если КлЗ.Ключ = "ПечатьСразу" Тогда
				//		КлЗ.Значение = Истина;
				//	ИначеЕсли ТипЗнч(КлЗ.Ключ) = ТипЗнч(Ссылка) Тогда
				//		КлЗ.Значение = Ссылка;
				//	КонецЕсли;	
				//КонецЦикла;	
				//Сообщить(Ссылка.МетаДанные().ПолноеИмя());
				Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.ЗоныХранения") Тогда
					ОбработкаПечати.ПечатьСразу = Истина;
					ОбработкаПечати.ЗонаХранения = Ссылка;
				КонецЕсли;
				ФормаО.Открыть();
				//КонецЕсли;
			Исключение
				
				Сообщить("Ошибка открытия внешней формы " + ОписаниеОшибки());
				ФормаО.Открыть();
			КонецПопытки;
		КонецЕсли;	
		
	КонецЕсли;
		
КонецПроцедуры //-SNL-91 20260120 Михайловский

