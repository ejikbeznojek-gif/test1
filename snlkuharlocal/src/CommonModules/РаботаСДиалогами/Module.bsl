Процедура УстановитьНомерДокументаСтарая(ДокументОбъект) экспорт 
	// Если  нет реквизита "Организация" или для нее не задан префикс, то 
	// используем пустой префикс,
	// иначе используем префикс организации.
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	
	ДопБуква="";
	Если МетаданныеДокумента.Имя="РасходнаяНакладная" Тогда
		//крохин начало 17.01.2020
		//ДопБуква=?(ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН,"б","а");
		Если ДокументОбъект.Дата >= '20200101' Тогда
			ДопБуква="б";
		Иначе
			ДопБуква=?(ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН,"б","а");
		КонецЕсли;
		//крохин конец 17.01.2020
	ИначеЕсли МетаданныеДокумента.Имя="ОтчетКассовойСмены" Тогда
		ДопБуква=?(ДокументОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН,"кб","кн");	
	КонецЕсли; 
	
	Вид=МетаданныеДокумента.Имя;
	//кухарь 15.08.14 начало
	//Если Вид="ЛистНабора" Тогда
	Если Вид="ЛистНабора" или Вид="ЛистПереукладки" Тогда
		//кухарь 15.08.14 конец
		
		//ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ДокументОбъект.ДокОснование.Номер)+"/");
		// Нечаева    +++++ 02,07,13 // новый префикс для листов набора на инвентаризацию
		ИмяДокумента=СокрЛП(ДокументОбъект.ДокОснование.Номер);
		ТипДокОсн= ДокументОбъект.ДокОснование.Метаданные().Имя;
		Если ТипДокОсн="Инвентаризация" Тогда
			
			ИмяДокумента=""+ИмяДокумента+"i";
			// и убираем один ноль;
			ИмяДокумента=Лев(ИмяДокумента,4)+Сред(ИмяДокумента,6,СтрДлина(ИмяДокумента))+"/";
			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ИмяДокумента));
		Иначе
			ДокументОбъект.УстановитьНовыйНомер(СокрЛП(ДокументОбъект.ДокОснование.Номер)+"/");
		КонецЕсли;
		//// нечаева  ------ 02,07,13
		
		//нечаева 23,08,16+++	
	ИначеЕсли  Вид="КорректировочныйСчетФактура" Тогда
		//крохин начало 01.08.2019
		
		//попытка
		//	
		//	Если ДокументОбъект.ДокОснование.метаданные.имя="РНК" Тогда
		//		возврат;
		//	КонецЕсли;	
		//исключение
		//конецПопытки;
		//крохин конец 01.08.2019
		
		//номер РНК
		попытка
			
			ДокРНк=ДокументОбъект.накладные[0].накладная.докоснование.ссылка; 
			
		исключение
			сообщить("Сначала сохраните документ!");
		конецПопытки;
		
		
		
		//нечаева 06,02,17------
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			Префикс=ПараметрыСеанса.ЭтотУзел.Код;
			//крохин начало
			ПрефиксСклада	=СокрЛП(ДокументОбъект.Склад.Префикс);
			Префикс = Префикс + ПрефиксСклада;
			//крохин конец
			//крохин начало 24.09.2013
			//в филиалах появились отгрузки от ГТ
			Если ДокументОбъект.Организация <> Справочники.Организации.НайтиПоКоду("SS-001") И не ПустаяСтрока(ДокументОбъект.Организация.Префикс) Тогда
				Префикс = Лев(ДокументОбъект.Организация.Префикс,1)+ Прав(Префикс,СтрДлина(Префикс)-1);	
			КонецЕсли;
			//крохин конец 24.09.2013
		Иначе
			ПрефиксКонтрагента="";
			
			Если ДокументОбъект.Накладные.Количество()>0 Тогда
				Накладная=ДокументОбъект.Накладные[0].Накладная;
				Если ЕстьРеквизитДокумента("ПунктДоставки",Накладная.Метаданные()) И ЗначениеЗаполнено(Накладная.ПунктДоставки.ПрефиксСФ) Тогда
					ПрефиксКонтрагента=СокрЛП(Накладная.ПунктДоставки.ПрефиксСФ);
