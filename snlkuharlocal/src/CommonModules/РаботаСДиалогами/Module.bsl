Функция УдалитьНули(СтрокаСНулями) Экспорт
	
	СтрокаБезНулей = СтрокаСНулями;
	
	Если Лев(СтрокаСНулями,1) = "0" ТОгда
		СтрокаБезНулей = Прав(СтрокаСНулями,СтрДлина(СтрокаСнулями)-1);
		Возврат УдалитьНули(СтрокаБезНулей);
	КонецЕсли;	
	
	Возврат СтрокаБезНулей;
	
КонецФункции
