Процедура ПодборСкладаПоФрагментам(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,ТолькоПервые=Истина) Экспорт
	СписокВыбора=Новый СписокЗначений;
	
	ТекСтрока=СокрЛП(Текст);	
	Пока Найти(ТекСтрока,"  ")<>0 Цикл
		ТекСтрока=СтрЗаменить(ТекСтрока,"  "," ");			
	КонецЦикла;
	
	Если ПустаяСтрока(ТекСтрока) Тогда Возврат КонецЕсли; 
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка
	|ИЗ
	|	Справочник.Склады
	|ГДЕ
	|	Наименование ПОДОБНО &ШаблонПоиска И НЕ ЭтоГруппа";	
	
	//ТекПользователь=ПараметрыСеанса.Пользователь;
	//Если ТекПользователь.ДоступныеСклады.Количество()>0 Тогда
	//	Запрос.Текст=Запрос.Текст+" И Ссылка В (
	//		|ВЫБРАТЬ Склад
	//		|ИЗ Справочник.Пользователи.ДоступныеСклады КАК ДоступныеСклады
	//		|ГДЕ ДоступныеСклады.Ссылка = &Пользователь)";
	//	
	//	Запрос.УстановитьПараметр("Пользователь",ТекПользователь);
	//КонецЕсли; 
	
	Запрос.Текст=Запрос.Текст+"	
	|Упорядочить ПО Наименование"
	;
	
	Запрос.УстановитьПараметр("ШаблонПоиска",?(ТолькоПервые,"","%")+СтрЗаменить(ТекСтрока," ","%")+"%");	
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СписокВыбора.Добавить(Выборка.Ссылка);		
	КонецЦикла;
	
	СтандартнаяОбработка=Ложь;
	Если СписокВыбора.Количество()=0 Тогда				
	ИначеЕсли СписокВыбора.Количество()=1 Тогда		
		Значение			=СписокВыбора.Получить(0).Значение;		
	Иначе
		Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
		Если Выбор<>Неопределено Тогда
			Значение=Выбор.Значение;
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры


// Процедура устанавливает отбор по основной организации в указанно форме
//
Процедура УстановитьОтборПоОрганизации(Форма, УчетПоВсемОрганизациям, ОсновнаяОрганизация, ИмяРеквизитаСписка, СкрыватьКолонку = Истина, ИмяОтбора = "Организация") Экспорт
	
	// В том случае если учте ведется по одной организации необходимо установить мягкий отбор.
	// т.е. отбор, с возможностью его изменения.
	
	Если НЕ УчетПоВсемОрганизациям Тогда // Установлен режим учета по одной организации
		
		Если НЕ (ТипЗнч(Форма[ИмяРеквизитаСписка]) = Тип("ТаблицаЗначений")) Тогда // Элемент - табличное поле
			
			// Проверим - Если это связанный регитср сведений тогда не нужно устанавливать отбор - 
			// он уже установлен системой автоматически
			
			Если ИмяРеквизитаСписка = "РегистрСведенийСписок" Тогда
				
				// Возвможно это переход по кнопке ПЕрейти
				Если ТипЗнч(Форма.ПараметрОтборПоИзмерению) = Тип("Структура") Тогда
					Если НЕ ЗначениеНеЗаполнено(Форма.ПараметрОтборПоИзмерению) Тогда
						Возврат; // Это переход по кнопке Перейти - не нужно устанавливать отбор
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			Форма[ИмяРеквизитаСписка].Отбор[ИмяОтбора].ВидСравнения  = ВидСравнения.Равно;
			Форма[ИмяРеквизитаСписка].Отбор[ИмяОтбора].Использование = Истина;
			Форма[ИмяРеквизитаСписка].Отбор[ИмяОтбора].Значение      = ОсновнаяОрганизация;
			
			Форма.ЭлементыФормы[ИмяРеквизитаСписка].НастройкаОтбора[ИмяОтбора].Доступность = Ложь;
			
		КонецЕсли;
		
		Если СкрыватьКолонку Тогда
			
			Если НЕ Форма.ЭлементыФормы[ИмяРеквизитаСписка].Колонки.Найти(ИмяОтбора) = Неопределено Тогда
				
				Форма.ЭлементыФормы[ИмяРеквизитаСписка].Колонки[ИмяОтбора].Видимость         = Ложь;
				Форма.ЭлементыФормы[ИмяРеквизитаСписка].Колонки[ИмяОтбора].ИзменятьВидимость = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры // УстановитьОтборПоОрганизации()


Процедура УстановитьЗаголовокФормы(Форма,Объект) Экспорт
	Форма.Заголовок		=Объект.Метаданные().Синоним+" "+Объект.Номер+" "+Формат(Объект.Дата,"ДФ=dd.MM.yy")+" / "+СокрЛП(Объект.Автор)+?(Объект.Ссылка.Пустая()," / Новый","");
	Форма.АвтоЗаголовок	=Ложь;
КонецПроцедуры

// Шворобей ВЮ 01.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-1748
///ТИПЫ ЦЕНЫ И ВАЛЮТЫ В ФОРМАХ
Процедура УстановитьЗаголовокКнопкиЦеныВалюта(Форма, МассивТекстаНадписи = Неопределено) Экспорт
	
	ДокОбъект	=Форма.ЭтотОбъект;
	МетаДок		=ДокОбъект.Метаданные();
	Надпись		=Форма.ЭлементыФормы.тЦеныВалюта;	
	
	ТекстНадписи="";
	Если ЕстьРеквизитДокумента("Валюта",МетаДок) Тогда
		ТекстНадписи ="Валюта: "+ДокОбъект.Валюта+", курс: "+Формат(ДокОбъект.Курс,"ЧДЦ=4");
	КонецЕсли;
	Если МассивТекстаНадписи <> Неопределено И МассивТекстаНадписи.Количество() > 1 Тогда
		ТекстНадписи = ТекстНадписи + Символы.ПС + МассивТекстаНадписи[0];
	КонецЕсли;
	Если ЕстьРеквизитДокумента("ТипЦен",МетаДок) Тогда
		ТекстНадписи = ТекстНадписи + Символы.ПС+"Тип цен: "+ДокОбъект.ТипЦен; 
	КонецЕсли; 
	Если ЕстьРеквизитДокумента("ТипСкидок",МетаДок) Тогда
		ТекстНадписи = ТекстНадписи + Символы.ПС+"Тип скидок: "+ДокОбъект.ТипСкидок;
	КонецЕсли;
	Если ЕстьРеквизитТабЧастиДокумента("ВсегоБезСкидки",МетаДок,"Товары") И ЕстьРеквизитТабЧастиДокумента("Всего",МетаДок,"Товары") Тогда
		ТекстНадписи = ТекстНадписи + Символы.ПС+"Скидка по накладной: "+Формат(ДокОбъект.Товары.Итог("ВсегоБезСкидки")-ДокОбъект.Товары.Итог("Всего"),"ЧДЦ=2; ЧРГ=' '; ЧГ=3,0");
	КонецЕсли;
	
	Если МассивТекстаНадписи <> Неопределено И МассивТекстаНадписи.Количество() > 2 Тогда
		ТекстНадписи = ТекстНадписи + Символы.ПС + МассивТекстаНадписи[1];
	КонецЕсли;
	
	Надпись.Значение = ТекстНадписи;
	
КонецПроцедуры 
// Шворобей ВЮ 01.11.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-1748

Процедура УстановитьТипЦенВалюту(Форма) Экспорт
	
	ФормаИзмененияЦен	=ПолучитьОбщуюФорму("ЦеныИВалюта",Форма);	
	ДокОбъект			=Форма.ЭтотОбъект;
	
	Результат			=ФормаИзмененияЦен.ОткрытьМодально();
	
	Если Результат=Неопределено Тогда Возврат КонецЕсли;
	
	НовыйТипЦен		=Результат["ТипЦен"];
	НовыйТипСкидок	=Результат["ТипСкидок"];
	НоваяВалюта		=Результат["Валюта"];
	НовыйКурс		=Результат["Курс"];
	
	Если НовыйТипЦен<>Неопределено ИЛИ НовыйТипСкидок<>Неопределено Тогда
		Ответ=Вопрос("Пересчитать цены в документе в соответствии с выбранным типом цен и скидок ?",РежимДиалогаВопрос.ДаНетОтмена);
		Если Ответ=КодВозвратаДиалога.Отмена Тогда
			Возврат;
		КонецЕсли;
		
		Если НовыйТипЦен<>Неопределено Тогда
			ДокОбъект.ТипЦен=НовыйТипЦен;			
		КонецЕсли; 
		Если НовыйТипСкидок<>Неопределено Тогда
			ДокОбъект.ТипСкидок=НовыйТипСкидок;			
		КонецЕсли;			
		
		Если Ответ=КодВозвратаДиалога.Да Тогда			
			ПересчетТЧ(ДокОбъект,"Товары",?(НоваяВалюта=Неопределено,ДокОбъект.Валюта,НоваяВалюта),ДокОбъект.Валюта,?(НовыйКурс=Неопределено,ДокОбъект.Курс,НовыйКурс),ДокОбъект.Курс,Истина);
		Иначе
			ПересчетТЧ(ДокОбъект,"Товары",?(НоваяВалюта=Неопределено,ДокОбъект.Валюта,НоваяВалюта),ДокОбъект.Валюта,?(НовыйКурс=Неопределено,ДокОбъект.Курс,НовыйКурс),ДокОбъект.Курс);
		КонецЕсли;
	ИначеЕсли НоваяВалюта<>Неопределено И НоваяВалюта<>ДокОбъект.Валюта Тогда
		ПересчетТЧ(ДокОбъект,"Товары",НоваяВалюта,ДокОбъект.Валюта,?(НовыйКурс=Неопределено,ДокОбъект.Курс,НовыйКурс),ДокОбъект.Курс);			
	КонецЕсли; 
	
	Если НоваяВалюта<>Неопределено Тогда
		ДокОбъект.Валюта=НоваяВалюта;
	КонецЕсли; 
	Если НовыйКурс<>Неопределено Тогда
		ДокОбъект.Курс=НовыйКурс;		
	КонецЕсли;
	
	УстановитьЗаголовокКнопкиЦеныВалюта(Форма);
	
КонецПроцедуры

