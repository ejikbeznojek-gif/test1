			конецЕсли;
		иначе
			Если Форма.ЭтотОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда 			
				СписокВыбора.Добавить(Перечисления.СостоянияНакладной.Отгружена);
			конецЕсли;
		конецЕсли;
		//нечаева 07,04,14 ---
		
		
	ИначеЕсли ВидДокумента="ОприходованиеТМЦ" Тогда
		Если Форма.ЭтоНовый() Тогда
			СписокВыбора.Добавить(Перечисления.СостоянияНакладной.ВРаботе);		
