Процедура ВыборФайла(Элемент,Расширение="dbf",ПроверятьСуществование=Ложь,ПолныйПуть=Истина) Экспорт
	
	ДиалогФыбораФайла								=	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	ДиалогФыбораФайла.Фильтр						=	"Файл данных (*."+Расширение+")|*."+Расширение+"";
	ДиалогФыбораФайла.Заголовок						=	"Выберите файл";
	ДиалогФыбораФайла.ПредварительныйПросмотр		=	Ложь;
	ДиалогФыбораФайла.Расширение					=	Расширение;
	ДиалогФыбораФайла.ИндексФильтра					=	0;
	ДиалогФыбораФайла.ПолноеИмяФайла				=	Элемент.Значение;
	ДиалогФыбораФайла.ПроверятьСуществованиеФайла	=	ПроверятьСуществование;
	
	Если ДиалогФыбораФайла.Выбрать() Тогда
		Файл	= Новый Файл(ДиалогФыбораФайла.ПолноеИмяФайла);
		Элемент.Значение = ?(ПолныйПуть,Файл.ПолноеИмя,Файл.Имя);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыборКаталога(Элемент,ПроверятьСуществование=Ложь) Экспорт
	
	ДиалогФыбораФайла								=	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	
	ДиалогФыбораФайла.Заголовок						=	"Выберите каталог";		
	//ДиалогФыбораФайла.ПолноеИмяФайла				=	Элемент.Значение;
	ДиалогФыбораФайла.ПроверятьСуществованиеФайла	=	ПроверятьСуществование;
	ДиалогФыбораФайла.Каталог						=	Элемент.Значение;
	
	Если ДиалогФыбораФайла.Выбрать() Тогда
		Элемент.Значение = ДиалогФыбораФайла.Каталог+"\";
	КонецЕсли;
	
КонецПроцедуры

//ПОДБОРЫ
Процедура ПодборНоменклатурыПоШК(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,ТипШК=Неопределено) Экспорт
	СписокВыбора=Новый СписокЗначений;
	
	ТекСтрока=СокрЛП(Текст);	
	Если НЕ ПустаяСтрока(ТекСтрока) Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.Владелец.Родитель.Родитель) КАК Брэнд,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.Владелец.Родитель) КАК Модель,
		|	ПРЕДСТАВЛЕНИЕ(ШтрихКоды.Владелец) КАК НоменклатураПредставление,
		|	ШтрихКоды.Владелец КАК Номенклатура,		
		|	ШтрихКоды.Наименование КАК ШтрихКод
		|ИЗ
		|	Справочник.ШтрихКоды КАК ШтрихКоды
		|ГДЕ
		|	ШтрихКоды.Наименование ПОДОБНО &ШаблонПоиска
		|	И ШтрихКоды.ТипШК=&ТипШК";
		
		Запрос.УстановитьПараметр("ТипШК",?(ТипШК=Неопределено,Перечисления.ТипыШтрихКодов.Штука,ТипШК));
		Запрос.УстановитьПараметр("ШаблонПоиска",СтрЗаменить(ТекСтрока," ","%"));	
		
		
		
		Выборка=Запрос.Выполнить().Выбрать();
		Если Выборка.Количество()>50 Тогда
			Предупреждение("Найдено более 50 записей соответствующих шаблону поиска !!!");	
		Иначе
			Пока Выборка.Следующий() Цикл
				СписокВыбора.Добавить(Выборка.Номенклатура,""+Выборка.ШтрихКод+" "+Выборка.Брэнд+" "+Выборка.НоменклатураПредставление+" ");		
			КонецЦикла;
			СписокВыбора.СортироватьПоПредставлению();		
		КонецЕсли;
	КонецЕсли;
	
	СтандартнаяОбработка=Ложь;
	Если СписокВыбора.Количество()=0 Тогда		
		Значение=Неопределено;
	ИначеЕсли СписокВыбора.Количество()=1 Тогда
		Значение=СписокВыбора.Получить(0).Значение;		
	Иначе
		Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
		Если Выбор<>Неопределено Тогда			
			Значение=Выбор.Значение;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПодборНоменклатурыПоКоду(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,ТолькоПервые=Ложь) Экспорт
	ОбъектМетаданных=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
	СписокВыбора=Новый СписокЗначений;
	
	Если ОбъектМетаданных<>Неопределено И Метаданные.Справочники.Индекс(ОбъектМетаданных)>0 И ОбъектМетаданных.ДлинаНаименования>0 Тогда
		ТекСтрока=СокрЛП(Текст);	
		Пока Найти(ТекСтрока,"  ")<>0 Цикл
			ТекСтрока=СтрЗаменить(ТекСтрока,"  "," ");			
		КонецЦикла;
		
		Если ПустаяСтрока(ТекСтрока) Тогда Возврат КонецЕсли; 
		
		МетаСправочник=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Ссылка,
		|	Наименование,Код";
		
		//Если МетаСправочник.Имя="Номенклатура" Тогда		
		//	Запрос.Текст=Запрос.Текст+",ШтрихКод";			
		//КонецЕсли;
		
		Запрос.Текст=Запрос.Текст+"
		|ИЗ
		|	Справочник."+МетаСправочник.Имя+"
		|ГДЕ
		|	Код ПОДОБНО &ШаблонПоиска";
		
		Если МетаСправочник.Иерархический Тогда			
			Если Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Группы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И ЭтоГруппа";
			ИначеЕсли Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Элементы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И НЕ ЭтоГруппа";		
			КонецЕсли; 
		КонецЕсли; 
		
		Если МетаСправочник.Владельцы.Содержит(Метаданные.Справочники["ИБ"]) И Форма.ЭлементыФормы.Найти("ИБ")<>Неопределено Тогда
			ТекИБ=Форма.ЭлементыФормы.ИБ.Значение;
			
			Если ТекИБ<>Неопределено И НЕ ТекИБ.Пустая() Тогда
				Запрос.Текст=Запрос.Текст+" И Владелец=&ИБ";			
				Запрос.УстановитьПараметр("ИБ",ТекИБ);			
			КонецЕсли;			
		КонецЕсли;
		
		Запрос.Текст=Запрос.Текст+"
		|Упорядочить ПО Код";
		
		Запрос.УстановитьПараметр("ШаблонПоиска","%"+Формат(Число(Текст), "ЧЦ=6; ЧВН="));	
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл			
			СписокВыбора.Добавить(Выборка.Ссылка,""+Выборка.Код+" "+Выборка.Наименование);					
		КонецЦикла;	
		
		СтандартнаяОбработка=Ложь;
		Если СписокВыбора.Количество()=0 Тогда		
		ИначеЕсли СписокВыбора.Количество()=1 Тогда
			Значение=СписокВыбора.Получить(0).Значение;		
		Иначе
			Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
			Если Выбор<>Неопределено Тогда			
				Значение=Выбор.Значение;
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

Процедура ПодборПоФрагментам(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,ТолькоПервые=Истина,Организация=Неопределено) Экспорт
	
	ОбъектМетаданных=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
	СписокВыбора=Новый СписокЗначений;
	
	Если ОбъектМетаданных<>Неопределено И Метаданные.Справочники.Индекс(ОбъектМетаданных)>0 И ОбъектМетаданных.ДлинаНаименования>0 Тогда
		ТекСтрока=СокрЛП(Текст);	
		Пока Найти(ТекСтрока,"  ")<>0 Цикл
			ТекСтрока=СтрЗаменить(ТекСтрока,"  "," ");			
		КонецЦикла;
		
		Если ПустаяСтрока(ТекСтрока) Тогда Возврат КонецЕсли; 
		
		МетаСправочник=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Ссылка,
		|	Наименование,
		|	Код";		
		
		Если МетаСправочник.Имя="Контрагенты" Тогда		
			Запрос.Текст=Запрос.Текст+",ИНН,КПП";			
		КонецЕсли;
		
		Запрос.Текст=Запрос.Текст+"
		|ИЗ
		|	Справочник."+МетаСправочник.Имя+"
		|ГДЕ
		|	(Наименование ПОДОБНО &ШаблонПоиска ИЛИ Код ПОДОБНО &ШаблонПоиска"+?(МетаСправочник.Имя="Контрагенты"," ИЛИ ИНН ПОДОБНО &ШаблонПоиска","")+")";
		Если МетаСправочник.Имя="Контрагенты" Тогда		
			Запрос.Текст=Запрос.Текст+" И НЕ ПОДСТРОКА(Наименование,1,2)=""__""";
			//крохин начало
			Запрос.Текст=Запрос.Текст+"
			|	И НЕ ПометкаУдаления";
			//крохин конец
			
		КонецЕсли;
		
		Если МетаСправочник.Иерархический Тогда
			Если Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Группы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И ЭтоГруппа";
			ИначеЕсли Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Элементы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И НЕ ЭтоГруппа";		
			КонецЕсли; 
		КонецЕсли; 
		
		Если Организация<>Неопределено Тогда
			Запрос.Текст=Запрос.Текст+"
			|	И Организация=&Организация";					
			Запрос.УстановитьПараметр("Организация",Организация);
		КонецЕсли; 
		
		Если МетаСправочник.Владельцы.Содержит(Метаданные.Справочники["ИБ"]) Тогда
			Если (Элемент.ВыборПоВладельцу=Неопределено ИЛИ Элемент.ВыборПоВладельцу.Пустая()) И Форма.ЭлементыФормы.Найти("ИБ")<>Неопределено Тогда
				ТекИБ=Форма.ЭлементыФормы.ИБ.Значение;
			Иначе
				ТекИБ=Элемент.ВыборПоВладельцу;
			КонецЕсли;
			
			Если ТекИБ<>Неопределено И НЕ ТекИБ.Пустая() Тогда
				Запрос.Текст=Запрос.Текст+" И Владелец=&ИБ";			
				Запрос.УстановитьПараметр("ИБ",ТекИБ);			
			КонецЕсли;
		ИначеЕсли МетаСправочник.Владельцы.Количество()>0 И Элемент.ВыборПоВладельцу<>Неопределено Тогда
			Запрос.Текст=Запрос.Текст+" И Владелец=&Владелец";			
			Запрос.УстановитьПараметр("Владелец",Элемент.ВыборПоВладельцу);			
		КонецЕсли;
		
		Запрос.Текст=Запрос.Текст+"
		|Упорядочить ПО Наименование";
		
		Запрос.УстановитьПараметр("ШаблонПоиска",?(ТолькоПервые,"","%")+СтрЗаменить(ТекСтрока," ","%")+"%");	
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл			
			СписокВыбора.Добавить(Выборка.Ссылка,""+Выборка.Наименование+" ("+Выборка.Код+")"+?(МетаСправочник.Имя="Контрагенты"," ИНН\КПП: "+СокрЛП(Выборка.ИНН)+"\"+СокрЛП(Выборка.КПП),""));					
		КонецЦикла;	
		
		СтандартнаяОбработка=Ложь;
		Если СписокВыбора.Количество()=0 Тогда		
		ИначеЕсли СписокВыбора.Количество()=1 Тогда
			Значение=СписокВыбора.Получить(0).Значение;		
		Иначе
			Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
			Если Выбор<>Неопределено Тогда			
				Значение=Выбор.Значение;
			КонецЕсли;
		КонецЕсли;
		
		Если Значение=Неопределено И ТипЗнч(Элемент.Значение)<>Тип("Неопределено") Тогда
			Значение=ПустоеЗначениеТипа(ТипЗнч(Элемент.Значение));	
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

