		Если Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Группы Тогда
			Запрос.Текст=Запрос.Текст+" И ЭтоГруппа";
		ИначеЕсли Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Элементы Тогда			
			Запрос.Текст=Запрос.Текст+" И НЕ ЭтоГруппа";		
		КонецЕсли; 
	КонецЕсли;		
	
	Запрос.Текст=Запрос.Текст+"
	|Упорядочить ПО Наименование";
	
	Запрос.УстановитьПараметр("ШаблонПоиска",		"%"+СтрЗаменить(ТекСтрока," ","%")+"%");	
	Запрос.УстановитьПараметр("ШаблонПоискаКода",	"SSP-%"+СокрЛП(ТекСтрока));	
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл			
		СписокВыбора.Добавить(Выборка.Ссылка,""+Выборка.Наименование+" ("+Выборка.Код+")");					
	КонецЦикла;	
	
	СтандартнаяОбработка=Ложь;
	Если СписокВыбора.Количество()=0 Тогда		
	ИначеЕсли СписокВыбора.Количество()=1 Тогда
		Значение=СписокВыбора.Получить(0).Значение;		
	Иначе
		Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
		Если Выбор<>Неопределено Тогда			
			Значение=Выбор.Значение;
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

Процедура ПодборДоговораПоФрагментам(Форма,Элемент, Текст, Значение, СтандартнаяОбработка,Контрагент,Организация=Неопределено) Экспорт	
	ОбъектМетаданных=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
	СписокВыбора=Новый СписокЗначений;
	
	Если ОбъектМетаданных<>Неопределено И Метаданные.Справочники.Индекс(ОбъектМетаданных)>0 И ОбъектМетаданных.ДлинаНаименования>0 Тогда
		ТекСтрока=СокрЛП(Текст);	
		Пока Найти(ТекСтрока,"  ")<>0 Цикл
			ТекСтрока=СтрЗаменить(ТекСтрока,"  "," ");			
		КонецЦикла;
		
		Если ПустаяСтрока(ТекСтрока) Тогда Возврат КонецЕсли; 
		
		МетаСправочник=Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Значение));
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Ссылка,
		|	Наименование,Код
		|ИЗ
		|	Справочник."+МетаСправочник.Имя+"
		|ГДЕ
		|	КодЦБ=&КодЦБ И (Наименование ПОДОБНО &ШаблонПоиска ИЛИ Код ПОДОБНО &ШаблонПоиска)
		|	И НЕ НеИспользовать";
		
		Если МетаСправочник.Иерархический Тогда
			Если Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Группы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И ЭтоГруппа";
			ИначеЕсли Элемент.ВыборГруппИЭлементов=ИспользованиеГруппИЭлементов.Элементы Тогда
				Запрос.Текст=Запрос.Текст+"
				|	И НЕ ЭтоГруппа"; 				
			КонецЕсли;
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Организация) Тогда		
			Запрос.Текст=Запрос.Текст+"
			|	И Организация=&Организация";
		КонецЕсли; 
		
		Запрос.Текст=Запрос.Текст+"
		|Упорядочить ПО Наименование";
		
		Запрос.УстановитьПараметр("ШаблонПоиска",СтрЗаменить(ТекСтрока," ","%")+"%");	
		Запрос.УстановитьПараметр("КодЦБ",?(ЗначениеЗаполнено(Контрагент.КодЦБ),Контрагент.КодЦБ,Контрагент.Код));
		Запрос.УстановитьПараметр("Организация",Организация);	
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл			
			СписокВыбора.Добавить(Выборка.Ссылка,""+Выборка.Наименование+" ("+Выборка.Код+")");					
		КонецЦикла;	
		
		СтандартнаяОбработка=Ложь;
		Если СписокВыбора.Количество()=0 Тогда		
		ИначеЕсли СписокВыбора.Количество()=1 Тогда
			Значение=СписокВыбора.Получить(0).Значение;		
		Иначе
			Выбор=Форма.ВыбратьИзСписка(СписокВыбора,Элемент);
			Если Выбор<>Неопределено Тогда			
				Значение=Выбор.Значение;
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;	
КонецПроцедуры

// ВНЕШНИЕ ПЕЧАТНЫЕ ФОРМЫ
Функция СтрокуВСписок(Строка)
	Список=Новый СписокЗначений;
	
	Пока Не(ПустаяСтрока(Строка)) Цикл
		Поз=Найти(Строка,",");
		Если Поз<>0 Тогда
			Список.Добавить(Лев(Строка,Поз-1));	
			Строка=Сред(Строка,Поз+1);
		Иначе
			Список.Добавить(Строка);	
			Строка="";			
		КонецЕсли; 	    
	КонецЦикла;
	Возврат Список;
КонецФункции


