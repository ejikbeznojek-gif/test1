Функция КоличествоПД(Контрагент) Экспорт
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	Владелец = &Владелец";
		
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;		
	КонецЕсли;
	
	Возврат 0;
КонецФункции //КоличествоПД(Контрагент)

Процедура ПриВыбореСчетаВТабличномПоле(Счет,ДанныеСтроки,ЭлементСписок,ЭлементДиалогаСчет = НЕОПРЕДЕЛЕНО, ТолькоПросмотр = ЛОЖЬ) Экспорт
	//ПриВыбореСчетаВТабличномПоле(Элемент.Значение,ТекущиеДанные,ЭлементыФормы.Услуги);
	
	ЭлементыСубконто = Новый Структура;
	
	Для Сч=1 По 3 Цикл
		ЭлементыСубконто.Вставить("Субконто"				+Сч,ДанныеСтроки["Субконто"+Сч]);		
		ЭлементыСубконто.Вставить("ЭлементДиалогаСубконто"	+Сч,ЭлементСписок.Колонки["Субконто"+Сч]);
	КонецЦикла; 
	
	ЧислоАктивныхСубконто = Счет.ВидыСубконто.Количество();
	
	Для Сч = 1 По ЧислоАктивныхСубконто Цикл
		ТипСубк = Счет.ВидыСубконто[Сч - 1].ВидСубконто.ТипЗначения;
		
		ЭлементыСубконто["ЭлементДиалогаСубконто" + Сч].ТолькоПросмотр = ТолькоПросмотр;
		
		Если ТипЗнч(ЭлементыСубконто["ЭлементДиалогаСубконто" + Сч]) = Тип("ПолеВвода") Тогда
			ЭлементыСубконто["ЭлементДиалогаСубконто" + Сч].ВыбиратьТип = (ТипСубк.Типы().Количество() > 1);
		Иначе
			ЭлементыСубконто["ЭлементДиалогаСубконто" + Сч].ЭлементУправления.ВыбиратьТип = (ТипСубк.Типы().Количество() > 1);
		КонецЕсли; 
		
		// Чтобы не устанавливался флаг модифицированности при открытии формы
		Если ТипСубк.ПривестиЗначение(ЭлементыСубконто["Субконто" + Сч]) <> ЭлементыСубконто["Субконто" + Сч] Тогда
			ЭлементыСубконто["Субконто" + Сч] = ТипСубк.ПривестиЗначение(ЭлементыСубконто["Субконто" + Сч]);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Сч = (ЧислоАктивныхСубконто + 1) По 3 Цикл
		
		Если Не ЭлементыСубконто["Субконто" + Сч] = Неопределено Тогда
			ЭлементыСубконто["Субконто" + Сч] = Неопределено;
		КонецЕсли;
		
		ЭлементыСубконто["ЭлементДиалогаСубконто" + Сч].ТолькоПросмотр = Истина;
		
	КонецЦикла;
	
	Если ЭлементДиалогаСчет <> Неопределено Тогда
		ЭлементДиалогаСчет.ТолькоПросмотр = ТолькоПросмотр;
	КонецЕсли;
	
	Для Сч=1 По 3 Цикл
		Если ДанныеСтроки["Субконто"+Сч]<>ЭлементыСубконто["Субконто"+Сч] Тогда
			ДанныеСтроки["Субконто"+Сч]=ЭлементыСубконто["Субконто"+Сч]
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры


Функция СтрокаПериода(Дата,Периодичность,СНачалаГода=Ложь) Экспорт
	Если Периодичность=Перечисления.ПериодичностьОтчетов.День Тогда
		Возврат ПредставлениеПериода(?(СНачалаГода,НачалоГода(Дата),НачалоДня(Дата)),КонецДня(Дата),"ФП = Истина");		
	ИначеЕсли Периодичность=Перечисления.ПериодичностьОтчетов.Месяц Тогда
		Возврат ПредставлениеПериода(?(СНачалаГода,НачалоГода(Дата),НачалоМесяца(Дата)),КонецМесяца(Дата),"ФП = Истина");	
	ИначеЕсли Периодичность=Перечисления.ПериодичностьОтчетов.Квартал Тогда
		Возврат ПредставлениеПериода(?(СНачалаГода,НачалоГода(Дата),НачалоКвартала(Дата)),КонецКвартала(Дата),"ФП = Истина");		
	ИначеЕсли Периодичность=Перечисления.ПериодичностьОтчетов.Год Тогда
		Возврат ПредставлениеПериода(НачалоГода(Дата),КонецГода(Дата),"ФП = Истина");				
	КонецЕсли;
КонецФункции // СтрокаПериода()

