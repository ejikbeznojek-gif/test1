			конецЕсли;
		иначе
			Если Форма.ЭтотОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда //	И ДокОбъект.Проведен 			
				СписокВыбора.Добавить(Перечисления.СостоянияНакладной.Принята);
