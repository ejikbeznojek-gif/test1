Функция ПолучитьСвойство(СсылкаНаОбъект,ВидСвойства,Кэш=Неопределено) Экспорт
	ЗначениеСвойства= Неопределено;
	
	Если Кэш=Неопределено Тогда
		СтрокаСвойств=Кэш.Найти(СсылкаНаОбъект,"СсылкаНаОбъект");
	Иначе
		СтрокаСвойств=Неопределено;	
	КонецЕсли;	
	
	Если СтрокаСвойств=Неопределено Тогда
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Значение
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	Объект = &СсылкаНаОбъект
		|	И Свойство = &ВидСвойства";
		
		Запрос.УстановитьПараметр("СсылкаНаОбъект",	СсылкаНаОбъект);
		Запрос.УстановитьПараметр("ВидСвойства",	ВидСвойства);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ЗначениеСвойства  = Выборка.Значение;		
		КонецЕсли;	
		
		Если Кэш<>Неопределено Тогда
			СтрокаКэша=Кэш.Добавить();				
			СтрокаКэша.СсылкаНаОбъект	= СсылкаНаОбъект;		
			СтрокаКэша.ЗначениеСвойства	= ЗначениеСвойства;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат ЗначениеСвойства;
КонецФункции

Процедура ПриИзмененииСвойстваВСписке(ЭУ,Список,ВидСвойства,Кэш=Неопределено) Экспорт	
	ВыбЗначение		= ЭУ.Значение;
	СсылкаНаОбъект	= Список.ТекущиеДанные.Ссылка;
	
	Если СсылкаНаОбъект=Неопределено ИЛИ СсылкаНаОбъект.Пустая() Тогда Возврат КонецЕсли; 
	
	ЗаписьСвойств=РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьМенеджерЗаписи();	
	ЗаписьСвойств.Объект	=СсылкаНаОбъект;
	ЗаписьСвойств.Свойство  =ВидСвойства;
	ЗаписьСвойств.Значение	=ВыбЗначение;
	
	Если ВыбЗначение=Неопределено ИЛИ НЕ ЗначениеЗаполнено(ВыбЗначение) Тогда		
		ЗаписьСвойств.Удалить();
	Иначе
		ЗаписьСвойств.Записать();
	КонецЕсли;
	
	СтрокаСвойств=Кэш.Найти(СсылкаНаОбъект,"СсылкаНаОбъект");
	Если СтрокаСвойств<>Неопределено Тогда
		СтрокаСвойств.ЗначениеСвойства=ВыбЗначение;
	КонецЕсли;
	
	Список.ОбновитьСтроки();
КонецПроцедуры


Функция ДобавитьОбязательнуюКолонкуСписка(Список,ИмяКолонки) Экспорт
	Колонка=Список.Колонки.Найти(ИмяКолонки);
	Если Колонка=Неопределено Тогда
		Колонка=Список.Колонки.Добавить(ИмяКолонки,Ложь);
	Иначе
		Колонка.АвтоУдаление=Ложь;
	КонецЕсли; 	
КонецФункции

