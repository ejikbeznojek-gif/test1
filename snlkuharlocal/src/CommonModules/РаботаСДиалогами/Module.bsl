		//нечаева 07,04,14 +++
		//только для узлов склада.
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если СокрЛП(Форма.ЭтотОбъект.Склад.КодФизическогоУзла)="" или Форма.ЭтотОбъект.Склад.КодФизическогоУзла = ПараметрыСеанса.ЭтотУзел.Подразделение.КодФизическогоУзла77  Тогда
				СписокВыбора.Добавить(Перечисления.СостоянияНакладной.Принята);
