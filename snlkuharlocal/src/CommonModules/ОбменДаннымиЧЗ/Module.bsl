Функция РаспределитьПоЧастям(Элементы, КолЧастей) Экспорт	
	Результат = Новый Массив;
	
	КРаспределению 		= Элементы.Количество(); 
	ВсегоРаспределено 	= 0;
	ВсегоРаспределеноФ 	= 0;
	Дельта				= 0;

	Инд = 0;

	Для Сч = 1 По КолЧастей Цикл		
		Если ВсегоРаспределено < КРаспределению Тогда
			текРезультат 		= Цел(КРаспределению/КолЧастей);				
			ВсегоРаспределено 	= ВсегоРаспределено 	+ текРезультат;			
			ВсегоРаспределеноФ 	= ВсегоРаспределеноФ 	+ КРаспределению/КолЧастей;
			
			Дельта = ВсегоРаспределеноФ - ВсегоРаспределено;		
			
			Если Дельта <= -1 Тогда		
				Корр = Цел(Дельта);			
				Дельта = Дельта - Корр;
			ИначеЕсли Дельта >= 1 Тогда
				Корр = Цел(Дельта);
			Иначе
				Корр = 0;			
			КонецЕсли;		
			
			текРезультат 		= текРезультат		+ Корр;
			ВсегоРаспределено 	= ВсегоРаспределено + Корр;			
			
			Пачка = Новый Массив;
			Для к = 1 по текРезультат Цикл
				Пачка.Добавить(Элементы[Инд]);				
				Инд = Инд + 1;
			КонецЦикла;
			
			Если Пачка.Количество() > 0 Тогда			
				Результат.Добавить(Пачка);
			КонецЕсли;
		Иначе
			Прервать;
		КонецЕсли;	
	КонецЦикла;

	Возврат Результат;	
КонецФункции //РаспределитьПоЧастям(Элементы, КолЧастей) Экспорт

Функция ЗагрузитьДанные_Регистра(ИмяТаблицы, ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	фПерезаписывать = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "фПерезаписывать", Ложь);
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");	
	
	Записи 			= Неопределено;
	ОтборыИзмерений = Неопределено;
	УдаленныеЗаписи	= Неопределено;
	Регистраторы	= Неопределено;
	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ, "Записи_") Тогда			
			Записи			= КиЗ.Значение;
		ИначеЕсли СтрНачинаетсяС(КиЗ.Ключ, "ОтборыИзмерений_") Тогда
			ОтборыИзмерений	= КиЗ.Значение;                         
		ИначеЕсли СтрНачинаетсяС(КиЗ.Ключ, "Регистраторы_") Тогда
			Регистраторы	= КиЗ.Значение;
		ИначеЕсли СтрНачинаетсяС(КиЗ.Ключ, "УдаленныеЗаписи_") Тогда
			УдаленныеЗаписи	= КиЗ.Значение;
		КонецЕсли;		
	КонецЦикла;
	
	Если Записи = Неопределено Тогда
		Результат.Ошибки.Добавить("Не обнаружено таблицы с данными записей регистра !");
		Возврат Результат;	
	КонецЕсли;         
	
	МетаРС = Метаданные.НайтиПоПолномуИмени(ИмяТаблицы);	
	
	Если МетаРС.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
		Если Регистраторы = Неопределено Тогда
			Результат = ЗагрузитьЗаписиРС_ПоРегистратору(МетаРС, Записи, Отправитель);
		Иначе                                                                                       
			Результат = ЗагрузитьЗаписиРС_ПоРегистратору_СОчисткой(МетаРС, Записи, Регистраторы, Отправитель);		
		КонецЕсли;		
	Иначе //Независимый		
		ВедущиеИзмерения = ПолучитьВедущиеИзмерения(МетаРС);
		Если ВедущиеИзмерения.Количество() > 0 И ТипЗнч(ОтборыИзмерений) = Тип("ТаблицаЗначений") Тогда
			Результат = ЗагрузитьЗаписиРС_ПоВедущимИзмерениям(МетаРС, Записи, ОтборыИзмерений, Отправитель, ВедущиеИзмерения);
		Иначе
			Результат = ЗагрузитьЗаписиРС_ПоЗаписям(МетаРС, Записи, УдаленныеЗаписи, Отправитель);					
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //Функция ЗагрузитьДанные_Регистра(ИмяТаблицы, ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт

Функция ЗагрузитьЗаписиРС_ПоРегистратору(МетаРС, Записи, Отправитель)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Вид = МетаРС.Имя;
	
	Запрос	= Новый Запрос;	
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Записи ИЗ &Записи КАК Записи
	|;
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	ВТ_Записи
	|ИТОГИ ПО
	|	Регистратор
	|";
	
	Запрос.УстановитьПараметр("Записи", Записи);
	
	рЗапроса			= Запрос.Выполнить();
	Выборка_Регистратор = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Регистратор");
	
	ВсегоСтрок	= Выборка_Регистратор.Количество();
	Сч			= 0;
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	СовсемНачало= Начало;
	
	ЗагрузкаИзСтаройБазы = (ЗначениеЗаполнено(Отправитель) И ТипЗнч(Отправитель) = Тип("ПланОбменаСсылка.Свертка"));
	
	ОшибокЗаписи = 0;
	
	ОшибкиЗаписи = СоздатьТаблицуОшибокЗаписи();	
	
	Пока Выборка_Регистратор.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Регистратор = Выборка_Регистратор.Регистратор;
		Если ЗначениеЗаполнено(Регистратор) Тогда
			НЗ = РегистрыСведений[Вид].СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(Регистратор);
			
			Выборка = Выборка_Регистратор.Выбрать();
			Пока Выборка.Следующий() Цикл
				Запись = НЗ.Добавить();
				ЗаполнитьЗначенияСвойств(Запись, Выборка);			
			КонецЦикла; 
			
			УстановитьОбменДаннымиИОтправителя(НЗ, Отправитель); 
			
			Попытка
				Если Вид = "СтатусыКМ_Факт" Тогда
					ЗаписатьДвижения_СтатусыКМ_Факт(НЗ, Регистратор, ЗагрузкаИзСтаройБазы);
				Иначе
					НЗ.Записать();
				КонецЕсли;
			Исключение
				СтрокаО = ОшибкиЗаписи.Добавить();
				
				СтрокаО.Основание	= Регистратор;
				СтрокаО.ТекстОшибки	= ОписаниеОшибки();
				СтрокаО.Дата		= ТекущаяДата();
				
				ОшибокЗаписи = ОшибокЗаписи + 1;					
			КонецПопытки;			
		КонецЕсли;
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка РС: '%1'. Загружено: %2 из %3 записей.", Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = Сч;	
	Результат.Вставить("ПрочитаноОбъектов", Сч); 
	Результат.Вставить("ОшибокЗаписи", 		ОшибокЗаписи);
	Результат.Вставить("ОшибкиЗаписи", 		ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - СовсемНачало)/1000;
	
	Если ПараметрыСеанса.Отладка Тогда
		ПланОбмена = ?(ЗначениеЗаполнено(Отправитель), "" + Отправитель.Метаданные(), "Н/У");	
		ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1 ('%2'), записано: %3, ошибок записи: %4.",  
			Результат.ПрочитаноОбъектов, МетаРС.ПолноеИмя(), Результат.ОбработаноОбъектов, ОшибокЗаписи);	
		ЗаписатьВЛог(ИмяЛогаОбмена(ПланОбмена), ТекстСообщения, "Информация", , , Результат.ВремяВыполнения);	
	КонецЕсли;	
	
	Возврат Результат;	
КонецФункции //ЗагрузитьЗаписиРС_ПоРегистратору()

Функция ЗагрузитьЗаписиРС_ПоРегистратору_СОчисткой(МетаРС, Записи, Регистраторы, Отправитель)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Вид = МетаРС.Имя;
	Менеджер = РегистрыСведений[Вид];
	Записи.Индексы.Добавить("Регистратор");	
	
	ВсегоСтрок		= Записи.Количество() + Регистраторы.Количество();
	ЗаписаноСтрок	= 0;
	Сч				= 0;
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	СовсемНачало= Начало;
	
	ЗагрузкаИзСтаройБазы = (ЗначениеЗаполнено(Отправитель) И ТипЗнч(Отправитель) = Тип("ПланОбменаСсылка.Свертка"));
	
	ОшибокЗаписи = 0;
	
	ОшибкиЗаписи = СоздатьТаблицуОшибокЗаписи();
	
	Для каждого СтрокаР Из Регистраторы Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Регистратор = СтрокаР.Регистратор;		
		
		Если ЗначениеЗаполнено(Регистратор) Тогда
			НЗ = Менеджер.СоздатьНаборЗаписей();
			НЗ.Отбор.Регистратор.Установить(Регистратор);
			
			Для каждого ДанныеЗаписи Из Записи.НайтиСтроки(Новый Структура("Регистратор", Регистратор)) Цикл			
				Запись = НЗ.Добавить();
				ЗаполнитьЗначенияСвойств(Запись, ДанныеЗаписи);			
			КонецЦикла; 
			
			ЗаписаноСтрок = ЗаписаноСтрок + НЗ.Количество() + 1;
			
			УстановитьОбменДаннымиИОтправителя(НЗ, Отправитель);
			
			Попытка
				Если Вид = "СтатусыКМ_Факт" Тогда
					ЗаписатьДвижения_СтатусыКМ_Факт(НЗ, Регистратор, ЗагрузкаИзСтаройБазы);					
				Иначе
					НЗ.Записать();
				КонецЕсли;				
			Исключение
				СтрокаО = ОшибкиЗаписи.Добавить();
				
				СтрокаО.Основание	= Регистратор;
				СтрокаО.ТекстОшибки	= ОписаниеОшибки();
				СтрокаО.Дата		= ТекущаяДата();
				
				ОшибокЗаписи = ОшибокЗаписи + 1;					
			КонецПопытки;			
		КонецЕсли;
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка РС: '%1'. Загружено: %2 из %3 записей.", ЗаписаноСтрок, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*ЗаписаноСтрок/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = Сч;	
	Результат.Вставить("ПрочитаноОбъектов", Сч); 
	Результат.Вставить("ОшибокЗаписи", 		ОшибокЗаписи);
	Результат.Вставить("ОшибкиЗаписи", 		ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - СовсемНачало)/1000;
	
	Если ПараметрыСеанса.Отладка Тогда
		ПланОбмена = ?(ЗначениеЗаполнено(Отправитель), "" + Отправитель.Метаданные(), "Н/У");	
		ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1 ('%2'), записано: %3, ошибок записи: %4.",  
			Результат.ПрочитаноОбъектов, МетаРС.ПолноеИмя(), Результат.ОбработаноОбъектов, ОшибокЗаписи);	
		ЗаписатьВЛог(ИмяЛогаОбмена(ПланОбмена), ТекстСообщения, "Информация", , , Результат.ВремяВыполнения);	
	КонецЕсли;	
	
	Возврат Результат;	
КонецФункции //ЗагрузитьЗаписиРС_ПоРегистратору()

Функция ЗагрузитьЗаписиРС_ПоВедущимИзмерениям(МетаРС, Записи, ОтборыИзмерений, Отправитель, ВедущиеИзмерения)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Вид			= МетаРС.Имя;
	Менеджер	= РегистрыСведений[Вид];
	
	ИмяЛога = ИмяЛогаОбмена(Метаданные.НайтиПоТипу(ТипЗнч(Отправитель)).Имя);
	
	ИндексируемыеИзмерения = Новый Массив;
	Для каждого Измерение Из МетаРС.Измерения Цикл
		Если МожноИндексироватьКолонку(Записи.Колонки[Измерение.Имя].ТипЗначения) Тогда
			ИндексируемыеИзмерения.Добавить(Измерение.Имя);
		КонецЕсли;	
	КонецЦикла;
	
	Запрос	= Новый Запрос;	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Записи ИЗ &Записи КАК Записи
	|" + ?(ИндексируемыеИзмерения.Количество() > 0, " ИНДЕКСИРОВАТЬ ПО " + СтрСоединить(ИндексируемыеИзмерения, ","),"") + "
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ * ПОМЕСТИТЬ ВТ_ОтборыИзмерений ИЗ &ОтборыИзмерений КАК ОтборыИзмерений
	|;
	|ВЫБРАТЬ * ИЗ ВТ_ОтборыИзмерений
	|";
	
	Запрос.УстановитьПараметр("Записи", 			Записи);
	Запрос.УстановитьПараметр("ОтборыИзмерений",	ОтборыИзмерений);
	
	Попытка
		рЗапроса	= Запрос.Выполнить();
	Исключение         
		ТекстСообщения = СтрШаблон("Ошибка загрузки записей: '%1', %2 !", МетаРС.ПолноеИмя(), ОписаниеОшибки());
		ЗаписатьВЛог(ИмяЛога, ТекстСообщения, "Ошибка");
		
		Результат.Ошибки.Добавить(ТекстСообщения);
		Результат.Успешно = Ложь;
		
		Возврат Результат;		
	КонецПопытки;
	Выборка_ВИ	= рЗапроса.Выбрать();
	
	ВсегоСтрок		= Записи.Количество() + ОтборыИзмерений.Количество();
	ЗаписаноСтрок   = 0;
	Сч				= 0;
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	СовсемНачало= Начало;
	
	ОшибокЗаписи = 0;
	
	ОшибкиЗаписи = СоздатьТаблицуОшибокЗаписи();
	
	Условия = Новый Массив;
	Для каждого ВедущееИзмерение Из ВедущиеИзмерения Цикл
		Условия.Добавить(СтрШаблон("%1 = &%1", ВедущееИзмерение));	
	КонецЦикла;
	
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	ВТ_Записи
	|ГДЕ
	|	" + СтрСоединить(Условия, Символы.ПС + Символы.Таб + "И ") + "
	|";
	
	Пока Выборка_ВИ.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		НЗ = Менеджер.СоздатьНаборЗаписей();		
		
		Для каждого ВедущееИзмерение Из ВедущиеИзмерения Цикл
			ЗначениеОтбора = Выборка_ВИ[ВедущееИзмерение];
			Запрос.УстановитьПараметр(ВедущееИзмерение, ЗначениеОтбора);
			
			НЗ.Отбор[ВедущееИзмерение].Установить(ЗначениеОтбора, Истина);
		КонецЦикла;	
		
		Выборка = Запрос.Выполнить().Выбрать();
		ЗаписаноСтрок = Выборка.Количество() + 1;
		
		Пока Выборка.Следующий() Цикл
			Запись = НЗ.Добавить();
			ЗаполнитьЗначенияСвойств(Запись, Выборка);			
		КонецЦикла; 
		
		Попытка
			НЗ.ОбменДанными.Загрузка = Истина;
			Попытка
				НЗ.Отправитель = Отправитель;					
			Исключение					
			КонецПопытки;				
			
			НЗ.Записать();				
		Исключение
			СтрокаО = ОшибкиЗаписи.Добавить();
			
			СтрокаО.Основание	= Выборка_ВИ[ВедущиеИзмерения[0]];
			СтрокаО.ТекстОшибки	= ОписаниеОшибки();
			СтрокаО.Дата		= ТекущаяДата();
			
			ОшибокЗаписи = ОшибокЗаписи + 1;					
		КонецПопытки;
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка РС '%1'. Загружено: %2 из %3 записей.", Вид, Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*ЗаписаноСтрок/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = Сч;	
	Результат.Вставить("ПрочитаноОбъектов", Сч); 
	Результат.Вставить("ОшибокЗаписи", 		ОшибокЗаписи);
	Результат.Вставить("ОшибкиЗаписи", ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	
	Если ПараметрыСеанса.Отладка Тогда
		ПланОбмена = ?(ЗначениеЗаполнено(Отправитель), "" + Отправитель.Метаданные(), "Н/У");	
		ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1 ('%2'), записано: %3, ошибок записи: %4.",  
			Результат.ПрочитаноОбъектов, МетаРС.ПолноеИмя(), Результат.ОбработаноОбъектов, ОшибокЗаписи);	
		ЗаписатьВЛог(ИмяЛогаОбмена(ПланОбмена), ТекстСообщения, "Информация", , , Результат.ВремяВыполнения);
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ЗагрузитьЗаписиРС_ПоВедущимИзмерениям(МетаРС, Записи, ОтборыИзмерений, Отправитель, ВедущиеИзмерения)

Функция ЗагрузитьЗаписиРС_ПоЗаписям(МетаРС, Записи, УдаленныеЗаписи, Отправитель)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Вид 		= МетаРС.Имя;
	Менеджер	= РегистрыСведений[Вид];	
	
	ПервоеИзмерение = Неопределено;
	Для каждого МетаИзмерение Из МетаРС.Измерения Цикл
		ПервоеИзмерение = МетаИзмерение.Имя;
		Прервать;
	КонецЦикла;	
	
	ВсегоСтрок	= Записи.Количество() + УдаленныеЗаписи.Количество();
	Сч			= 0;
	
	ОшибокЗаписи = 0;	
	ОшибкиЗаписи = СоздатьТаблицуОшибокЗаписи();
	
	Для каждого ДанныеЗаписи Из Записи Цикл	
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		НЗ = Менеджер.СоздатьНаборЗаписей();
		
		Для каждого МетаИзмерение Из МетаРС.Измерения Цикл
			Измерение = МетаИзмерение.Имя;			
			ЗначениеОтбора = ДанныеЗаписи[Измерение];			
			
			НЗ.Отбор[Измерение].Установить(ЗначениеОтбора, Истина);
		КонецЦикла;
		
		Запись = НЗ.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, ДанныеЗаписи);
		
		УстановитьОбменДаннымиИОтправителя(НЗ, Отправитель);
		
		Попытка			
			НЗ.Записать();				
		Исключение
			СтрокаО = ОшибкиЗаписи.Добавить();
			
			СтрокаО.Основание	= ДанныеЗаписи[ПервоеИзмерение];
			СтрокаО.ТекстОшибки	= ОписаниеОшибки();
			СтрокаО.Дата		= ТекущаяДата();
			
			ОшибокЗаписи = ОшибокЗаписи + 1;					
		КонецПопытки;
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка РС: '%1'. Загружено: %2 из %3 записей.", Вид, Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;
	
	Если ТипЗнч(УдаленныеЗаписи) = Тип("ТаблицаЗначений") Тогда	
		
		Для каждого ДанныеЗаписи Из УдаленныеЗаписи Цикл	
			#ЕСЛИ КЛИЕНТ ТОГДА
				ОбработкаПрерыванияПользователя();
			#КОНЕЦЕСЛИ
			
			НЗ = Менеджер.СоздатьНаборЗаписей();
			
			Для каждого МетаИзмерение Из МетаРС.Измерения Цикл
				Измерение = МетаИзмерение.Имя;			
				ЗначениеОтбора = ДанныеЗаписи[Измерение];			
				
				НЗ.Отбор[Измерение].Установить(ЗначениеОтбора, Истина);
			КонецЦикла;		
			
			УстановитьОбменДаннымиИОтправителя(НЗ, Отправитель);
			
			Попытка
				НЗ.Записать();				
			Исключение
				СтрокаО = ОшибкиЗаписи.Добавить();
				
				СтрокаО.Основание	= ДанныеЗаписи[ПервоеИзмерение];
				СтрокаО.ТекстОшибки	= ОписаниеОшибки();
				СтрокаО.Дата		= ТекущаяДата();
				
				ОшибокЗаписи = ОшибокЗаписи + 1;					
			КонецПопытки;
			
			Сч = Сч + 1;
			Если Сч % 100 = 0 Тогда
				ТекстСообщения = СтрШаблон("Загрузка РС: '%1'. Загружено: %2 из %3 записей.", Вид, Сч, ВсегоСтрок);
				инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
			КонецЕсли;		
		КонецЦикла;
		
	КонецЕсли;

	Результат.ОбработаноОбъектов = Сч;	
	Результат.Вставить("ПрочитаноОбъектов", Сч); 
	Результат.Вставить("ОшибокЗаписи", 		ОшибокЗаписи);
	Результат.Вставить("ОшибкиЗаписи", 		ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	
	Если ПараметрыСеанса.Отладка Тогда
		ПланОбмена = ?(ЗначениеЗаполнено(Отправитель), "" + Отправитель.Метаданные(), "Н/У");	
		ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1 ('%2'), записано: %3, ошибок записи: %4.",  
			Результат.ПрочитаноОбъектов, МетаРС.ПолноеИмя(), Результат.ОбработаноОбъектов, ОшибокЗаписи);	
		ЗаписатьВЛог(ИмяЛогаОбмена(ПланОбмена), ТекстСообщения, "Информация", , , Результат.ВремяВыполнения);
	КонецЕсли;	
	
	Возврат Результат;	
КонецФункции //ЗагрузитьЗаписиРС_ПоЗаписям(МетаРС, Записи, УдаленныеЗаписи, Отправитель)

Функция УстановитьОбменДаннымиИОтправителя(Объект, Отправитель)
	Объект.ОбменДанными.Загрузка = Истина;
	Попытка
		Объект.Отправитель = Отправитель;					
	Исключение					
	КонецПопытки;
КонецФункции //УстановитьОбменДаннымиИОтправителя(Объект, Отправитель)

Функция ЗаписатьДвижения_СтатусыКМ_Факт(НЗ, Регистратор, ЗагрузкаИзСтаройБазы)
	Если НЕ ЗагрузкаИзСтаройБазы И Метаданные.РегистрыСведений.ОтложенныеДвиженияДокументов.Измерения.ДокСсылка.Тип.СодержитТип(ТипЗнч(Регистратор)) Тогда //По новому
		рСохранения = ЗаписатьВОтложенныеДвижения(Регистратор, НЗ);	
		Если НЕ рСохранения.Успешно Тогда
			ТекстОшибки = СтрСоединить(рСохранения.Ошибки, Символы.ПС);
			ЗаписатьВЛог("ОбменДаннымиЧЗ", ТекстОшибки, "Ошибка");		
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;                                                                                 
	Иначе
		НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);					
		Попытка
			РегистрыСведений.СтатусыКМ_Факт.УстановитьБлокировкуПоНаборуЗаписей(НЗ);
			НЗ.Записать();					
			
			ЗафиксироватьТранзакцию();						
		Исключение
			ТекстОшибки = СтрШаблон("Ошибка записи статусов док-та: '%1'. %2", Регистратор, ОписаниеОшибки());
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();						
			КонецЕсли;               
			
			ЗаписатьВЛог("ОбменДаннымиЧЗ", ТекстОшибки, "Ошибка");
			ВызватьИсключение ТекстОшибки;
		КонецПопытки;					
	КонецЕсли;	
КонецФункции //ЗаписатьДвижения_СтатусыКМ_Факт(НЗ, Регистратор, ЗагрузкаИзСтаройБазы)

Функция МожноИндексироватьКолонку(ОписаниеТипов)
	ЕстьСсылки 			= Ложь;
	ЕстьХЗ 				= Ложь;
	ЕстьСтроки 			= Ложь;
	ЕстьЧисла			= Ложь;
	ЕстьДлинныеСтроки 	= Ложь;
	
	Для каждого Тип Из ОписаниеТипов.Типы() Цикл
		Если Метаданные.НайтиПоТипу(Тип) <> Неопределено Тогда
			ЕстьСсылки = Истина;
		ИначеЕсли Тип = Тип("Строка") Тогда
			ЕстьСтроки = Истина;		
			Если ОписаниеТипов.КвалификаторыСтроки.Длина = 0 Тогда
				ЕстьДлинныеСтроки = Истина;			
			КонецЕсли;
		ИначеЕсли Тип = Тип("Число") Тогда
			ЕстьЧисла = Истина;
		ИначеЕсли Тип = Тип("ХранилищеЗначения") Тогда
			ЕстьХЗ = Истина;
		КонецЕсли;			
	КонецЦикла;
	
	Результат = Ложь;
	
	Если ЕстьСсылки Тогда
		Если НЕ (ЕстьСтроки ИЛИ ЕстьЧисла ИЛИ ЕстьХЗ) Тогда
			Результат = Истина;
		КонецЕсли;		
	ИначеЕсли ЕстьСтроки Тогда
		Если НЕ ЕстьДлинныеСтроки Тогда
			Результат = Истина;
		КонецЕсли;		
	ИначеЕсли ЕстьЧисла Тогда
		Результат = Истина;						
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //МожноИндексироватьИзмерение(МетаИзмерение)

Функция ЗагрузитьДанные_Справочник(ИмяТаблицы, ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт	
	Результат	= МаркировкаКС.СтруктураРезультата();
	
	МетаОбъект 	= Метаданные.НайтиПоПолномуИмени(ИмяТаблицы);
	Менеджер 	= Справочники[МетаОбъект.Имя];
	
	фПерезаписывать = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "фПерезаписывать", Ложь);
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");
	
	Шапка 		= Неопределено;
	ДанныеТЧ 	= Новый Соответствие;
	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ,"ТЧ_") Тогда
			КиЗ.Значение.Индексы.Добавить("Ссылка");
			ДанныеТЧ[Сред(КиЗ.Ключ, 4)] = КиЗ.Значение;
		ИначеЕсли КиЗ.Ключ = "Шапка" Тогда
			Шапка = КиЗ.Значение;			
		КонецЕсли;		
	КонецЦикла;
	
	ЕстьКолонкаГруппы = (Шапка.Колонки.Найти("ЭтоГруппа") <> Неопределено) И (МетаОбъект.ВидИерархии = Метаданные.СвойстваОбъектов.ВидИерархии.ИерархияГруппИЭлементов);
	
	ПоляТолькоДляГрупп 		= Новый Массив;
	ПоляТолькоДляЭлементов	= Новый Массив;
	
	Для каждого МетаРеквизит Из МетаОбъект.Реквизиты Цикл		
		Если МетаРеквизит.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляГруппы Тогда
			ПоляТолькоДляГрупп.Добавить(МетаРеквизит.Имя);
		ИначеЕсли МетаРеквизит.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляЭлемента Тогда
			ПоляТолькоДляЭлементов.Добавить(МетаРеквизит.Имя);			
		КонецЕсли;	
	КонецЦикла;
	
	ТЧТолькоДляГрупп		= Новый Соответствие;
	ТЧТолькоДляЭлементов	= Новый Соответствие;
	
	Для каждого МетаТЧ Из МетаОбъект.ТабличныеЧасти Цикл
		Если МетаТЧ.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляГруппы Тогда
			ТЧТолькоДляГрупп[МетаТЧ.Имя] = Истина;
		ИначеЕсли МетаТЧ.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляЭлемента Тогда
			ТЧТолькоДляЭлементов[МетаТЧ.Имя] = Истина;			
		КонецЕсли;	
	КонецЦикла;
	
	ПоляТолькоДляГрупп 		= СтрСоединить(ПоляТолькоДляГрупп, ",");
	ПоляТолькоДляЭлементов	= СтрСоединить(ПоляТолькоДляЭлементов, ",");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Шапка ИЗ &Шапка КАК Шапка
	|;
	|ВЫБРАТЬ
	|	IsNULL(Ссылка.ВерсияДанных,"""") КАК ВерсияДанных,
	|	*
	|ИЗ
	|	ВТ_Шапка
	|ГДЕ
	|	Ссылка.ВерсияДанных ЕСТЬ NULL	
	|	ИЛИ &фПерезаписывать
	|";  
	
	Запрос.УстановитьПараметр("Шапка", 				Шапка);
	Запрос.УстановитьПараметр("фПерезаписывать",	фПерезаписывать);
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок		= Выборка.Количество();
	Сч				= 0;	
	ОшибкиЗаписи 	= ОбменДаннымиЧЗ.СоздатьТаблицуОшибокЗаписи();
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ		
		
		ЭтоГруппа 			= ?(ЕстьКолонкаГруппы, Выборка.ЭтоГруппа, Ложь);
		
		ПропускаемыеПоля	= "Ссылка";
		Если ЕстьКолонкаГруппы Тогда
			Если ЭтоГруппа Тогда			
				ПропускаемыеПоля = ПропускаемыеПоля + ?(ПустаяСтрока(ПоляТолькоДляЭлементов), "", ",") + ПоляТолькоДляЭлементов;
			Иначе 
				ПропускаемыеПоля = ПропускаемыеПоля + ?(ПустаяСтрока(ПоляТолькоДляГрупп), "", ",") + ПоляТолькоДляГрупп;
			КонецЕсли;		
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Выборка.ВерсияДанных) Тогда
			СпрОбъект = Выборка.Ссылка.ПолучитьОбъект();			
		Иначе			
			Если ЭтоГруппа Тогда			
				СпрОбъект = Менеджер.СоздатьГруппу();				
			Иначе
				СпрОбъект = Менеджер.СоздатьЭлемент();										
			КонецЕсли;			
			
			СпрОбъект.УстановитьСсылкуНового(Выборка.Ссылка);
		КонецЕсли;		
		
		ЗаполнитьЗначенияСвойств(СпрОбъект, Выборка, , ПропускаемыеПоля);
		
		Для Каждого КиЗ Из ДанныеТЧ Цикл
			ИмяТЧ = КиЗ.Ключ;
			
			СтрокиТЧ = КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка));
			
			Если ЭтоГруппа И ТЧТолькоДляЭлементов.Получить(ИмяТЧ) <> Неопределено Тогда
				Продолжить;
			ИначеЕсли НЕ ЭтоГруппа И ТЧТолькоДляГрупп.Получить(ИмяТЧ) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ТЧ_Объекта = СпрОбъект[КиЗ.Ключ];
			
			ТЧ_Объекта.Очистить();
			Для Каждого СтрокаТЧ_Ист Из КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка)) Цикл
				СтрокаТЧ_Тек = ТЧ_Объекта.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ_Тек, СтрокаТЧ_Ист);
			КонецЦикла;
		КонецЦикла;
		
		СпрОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи", Истина);
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		СпрОбъект.ОбменДанными.Отправитель = Отправитель;
		
		Попытка
			СпрОбъект.Записать();		
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		Исключение
			СтрокаО = ОшибкиЗаписи.Добавить();
				
			СтрокаО.Основание	= Выборка.Ссылка;
			СтрокаО.ТекстОшибки	= ОписаниеОшибки();
			СтрокаО.Дата		= ТекущаяДата();				
		КонецПопытки;		
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка %1. Загружено: %2 из %3 элементов.", ИмяТаблицы, Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = Шапка.Количество();
	Результат.Вставить("ПрочитаноОбъектов", Шапка.Количество()); 
	Результат.Вставить("ОшибокЗаписи", 	ОшибкиЗаписи.Количество());
	Результат.Вставить("ОшибкиЗаписи", 	ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;	
	
	Возврат Результат;	
КонецФункции // ()

Функция ЗагрузитьДанные_Документ(ИмяТаблицы, ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт
	Результат	= МаркировкаКС.СтруктураРезультата();
	
	МетаОбъект 	= Метаданные.НайтиПоПолномуИмени(ИмяТаблицы);
	Менеджер 	= Документы[МетаОбъект.Имя];
	
	фПерезаписывать = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "фПерезаписывать", Ложь);
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");
	
	Шапка 		= Неопределено;
	ДанныеТЧ 	= Новый Соответствие;
	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ,"ТЧ_") Тогда
			КиЗ.Значение.Индексы.Добавить("Ссылка");
			ДанныеТЧ[Сред(КиЗ.Ключ, 4)] = КиЗ.Значение;
		ИначеЕсли КиЗ.Ключ = "Шапка" Тогда
			Шапка = КиЗ.Значение;			
		КонецЕсли;		
	КонецЦикла;	  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Шапка ИЗ &Шапка КАК Шапка
	|;
	|ВЫБРАТЬ
	|	IsNULL(Ссылка.ВерсияДанных,"""") КАК ВерсияДанных,
	|	*
	|ИЗ
	|	ВТ_Шапка
	|ГДЕ
	|	Ссылка.ВерсияДанных ЕСТЬ NULL	
	|	ИЛИ &фПерезаписывать
	|";  
	
	Запрос.УстановитьПараметр("Шапка", 				Шапка);
	Запрос.УстановитьПараметр("фПерезаписывать",	фПерезаписывать);
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок		= Выборка.Количество();
	Сч				= 0;
	ОшибкиЗаписи 	= ОбменДаннымиЧЗ.СоздатьТаблицуОшибокЗаписи();
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Если ЗначениеЗаполнено(Выборка.ВерсияДанных) Тогда
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();			
		Иначе			
			ДокОбъект = Менеджер.СоздатьДокумент();		
			ДокОбъект.УстановитьСсылкуНового(Выборка.Ссылка);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ДокОбъект, Выборка, , "Ссылка");		
		
		Для Каждого КиЗ Из ДанныеТЧ Цикл
			СтрокиТЧ = КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка));		
			
			ТЧ_Объекта = ДокОбъект[КиЗ.Ключ];
			
			ТЧ_Объекта.Очистить();			
			Для Каждого СтрокаТЧ_Ист Из КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка)) Цикл
				СтрокаТЧ_Тек = ТЧ_Объекта.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ_Тек, СтрокаТЧ_Ист);			
			КонецЦикла; 
		КонецЦикла;
		
		ДокОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи", Истина);
		ДокОбъект.ОбменДанными.Загрузка 	= Истина;
		ДокОбъект.ОбменДанными.Отправитель	= Отправитель;
		
		Попытка
			ДокОбъект.Записать();		
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		Исключение
			СтрокаО = ОшибкиЗаписи.Добавить();
				
			СтрокаО.Основание	= Выборка.Ссылка;
			СтрокаО.ТекстОшибки	= ОписаниеОшибки();
			СтрокаО.Дата		= ТекущаяДата();
		КонецПопытки;
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка док-та: '%1'. Загружено: %2 из %3 документов.", МетаОбъект.Имя, Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;		
	КонецЦикла;	
	
	Результат.Вставить("ПрочитаноОбъектов", Шапка.Количество()); 
	Результат.Вставить("ОшибокЗаписи", 		ОшибкиЗаписи.Количество());
	Результат.Вставить("ОшибкиЗаписи", 		ОшибкиЗаписи);
	
	Результат.ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;	
	
	Возврат Результат;	
КонецФункции //ЗагрузитьДанные_Документ(ИмяТаблицы, ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт

Функция ЗаписатьВОтложенныеДвижения(Регистратор, НЗ)					
	СтрокаДанных = Новый Структура;
	СтрокаДанных.Вставить("ДокСсылка", 			Регистратор);
	СтрокаДанных.Вставить("ИмяРегистра",    	НЗ.Метаданные().ПолноеИмя());
	СтрокаДанных.Вставить("Движения",			Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Выгрузить()), Новый СжатиеДанных(5)));
	СтрокаДанных.Вставить("КоличествоЗаписей", 	НЗ.Количество());
	
	ДанныеДвижений = Новый Массив;
	ДанныеДвижений.Добавить(СтрокаДанных);
	
	Возврат РегистрыСведений.ОтложенныеДвиженияДокументов.СохранитьДвижения(Регистратор, ДанныеДвижений);
КонецФункции //ЗаписатьВОтложенныеДвижения(Регистратор, НЗ)

Функция СоздатьТаблицуОшибокЗаписи() Экспорт
	ОшибкиЗаписи = Новый ТаблицаЗначений;
	ОшибкиЗаписи.Колонки.Добавить("Основание");
	ОшибкиЗаписи.Колонки.Добавить("ТекстОшибки");
	ОшибкиЗаписи.Колонки.Добавить("Дата");
	
	Возврат ОшибкиЗаписи;
КонецФункции // ()
 
Функция ПолучитьПравилоВыгрузкиРегистра_ПоРегистратору(ОперИмпорта, Знач ОперИмпорта_Представление = "", ДопПараметры = Неопределено) Экспорт
	Если ПустаяСтрока(ОперИмпорта_Представление) Тогда
		ОперИмпорта_Представление = ОперИмпорта;	
	КонецЕсли;	
	
	ИмяТаблицыИст	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ИмяТаблицыИст", ОперИмпорта);
	ИмяТаблицыТек	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ИмяТаблицыТек", ИмяТаблицыТек);	
	
	ЗапросыИст = ОбменДаннымиЧЗ.СоздатьТаблицуИменЗапросов();	
	
	#Область ВТ_Ссылки
	
	ТекстЗапросаИзменений = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Регистратор КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Регистраторы
	|ИЗ	
	|	" + ИмяТаблицыИст + ".Изменения
	|ГДЕ
	|	Узел = &УзелПолучатель	
	|;
	|ВЫБРАТЬ
	|	ВТ_Регистраторы.Ссылка 	КАК Ссылка,
	|	СУММА(
	|		ВЫБОР 
	|			КОГДА Записи.Регистратор ЕСТЬ NULL ТОГДА 0 
	|			ИНАЧЕ 1 
	|		КОНЕЦ
	|	) 						КАК КолЗаписей
	|ИЗ
	|	ВТ_Регистраторы
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	" + ИмяТаблицыИст + " КАК Записи
	|ПО
	|	ВТ_Регистраторы.Ссылка = Записи.Регистратор
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Регистраторы.Ссылка
	|";	
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Регистратор	
	|ПОМЕСТИТЬ ВТ_Ссылки
	|ИЗ		
	|	&Регистраторы КАК Регистраторы
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|";	
	
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ВТ_Ссылки", ТекстЗапроса, Ложь);
	
	#КонецОбласти
	
	#Область Записи
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	Регистратор	
	|ИЗ		
	|	ВТ_Ссылки	
	|";
	
    ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "Регистраторы_" + ИмяТаблицыИст, ТекстЗапроса, Истина, Истина);
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	Записи.*
	|ИЗ	
	|	" + ИмяТаблицыИст + " КАК Записи
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки 
	|ПО 
	|	ВТ_Ссылки.Регистратор = Записи.Регистратор
	|";
	
    ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "Записи_" + ИмяТаблицыИст, ТекстЗапроса, Истина, Истина);
	
	#КонецОбласти
	
	Возврат Новый Структура("ИмяТаблицыИст,РазмерПорции,ТекстЗапросаИзменений,ЗапросыИст,ОперИмпорта,ОперИмпорта_Представление", 
		ИмяТаблицыИст, 5000, ТекстЗапросаИзменений, ЗапросыИст, ОперИмпорта, ОперИмпорта_Представление);
КонецФункции //ПолучитьПравилоВыгрузки() Экспорт

Функция УстановитьПолучателей(Узлы, Данные) Экспорт
	Если МаркировкаС.ВерсияПлатформыПоРежимуСовместимости() >= "8.003.019" Тогда
		ПланыОбмена.ЗарегистрироватьИзменения(Узлы, Данные);
	Иначе        
		Если ТипЗнч(Данные) = Тип("Массив") Тогда
			ВсегоСтрок  = Данные.Количество();
			Сч			= 0;
			Для каждого Ссылка Из Данные Цикл                          
				ПланыОбмена.ЗарегистрироватьИзменения(Узлы, Ссылка);		
				
				Сч = Сч + 1;
				Если Сч % 100 = 0 Тогда			
					ТекстСообщения = СтрШаблон("Регистрация данных к  обмену. Обработано: %1 из %2.", Сч, ВсегоСтрок);
					инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);
				КонецЕсли;
			КонецЦикла;		
		Иначе
			ПланыОбмена.ЗарегистрироватьИзменения(Узлы, Данные);
		КонецЕсли;		
	КонецЕсли;	
КонецФункции //УстановитьПолучателей(мСсылки, мПолучатели)

Функция ДобавитьУзелВПолучателей(СписокПолучателей, УзелПолучатель, УзелОтправитель, Загрузка) Экспорт
	Результат = Ложь;
	Если ЗначениеЗаполнено(УзелПолучатель) Тогда		
		ИмяПО = УзелПолучатель.Метаданные().Имя;
		Если УзелПолучатель <> Маркировка_ПИ.ЭтотУзел(ИмяПО) Тогда 
			Если Загрузка И УзелПолучатель = УзелОтправитель Тогда //туда-сюда гонять не будем		
			Иначе	
				СписокПолучателей.Добавить(УзелПолучатель);
				Результат = Истина;
			КонецЕсли;			
		КонецЕсли;
	КонецЕсли;	
	Возврат Результат;	
КонецФункции //ДобавитьУзелВПолучателей(СписокПолучателей, УзелПолучатель, УзелОтправитель, Загрузка) Экспорт

Функция ЕстьЗапущенныеЗаданияОбмена() Экспорт
	Результат = Ложь;
	
	ТекущееФЗ = ПолучитьТекущийСеансИнформационнойБазы().ПолучитьФоновоеЗадание();
	
	ИмяМетода = Метаданные.РегламентныеЗадания.ОбменДаннымиЧЗ.ИмяМетода;
	
	Для Каждого ФЗ Из ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("ИмяМетода,Состояние", ИмяМетода, СостояниеФоновогоЗадания.Активно)) Цикл
		Если ТипЗнч(ТекущееФЗ) = Тип("ФоновоеЗадание") И ФЗ.УникальныйИдентификатор = ТекущееФЗ.УникальныйИдентификатор Тогда
		ИначеЕсли ФЗ.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			Результат = Истина;		
			Прервать;
		КонецЕсли;
	КонецЦикла;
		
	Возврат Результат;
КонецФункции //ЕстьЗапущенныеЗаданиеОбмена() Экспорт