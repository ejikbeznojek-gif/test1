Функция СохранитьНужныйДокумент() Экспорт  
	
	//на будущее пока не будем использовать
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Перемещение.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Перемещение.Изменения КАК Перемещение
	|ГДЕ
	|	Перемещение.Узел = &Узел";
	//Параметры запроса       
	
	МойУзел =ПланыОбмена.ОбменНАХ.НайтиПоКоду("000000002");
	ОснСклад=Справочники.Склады.НайтиПоКоду("STA-48");
	
	Запрос.УстановитьПараметр("Узел",МойУзел);// Обмен НАХ
	Результат = Запрос.Выполнить().Выбрать();   
	
	ТЗ=Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Количество");
	ТЗ.Колонки.Добавить("ВидДвижения");
	
	Пока Результат.Следующий() Цикл
		
		НаборЗаписей = РегистрыНакопления.ОстаткиТМЦ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Результат.Ссылка); 
		НаборЗаписей.Прочитать();     
		
		Для каждого стрЗап из НаборЗаписей Цикл  
			
			Если стрЗап.Склад =ОснСклад Тогда				
				НовСТр = ТЗ.Добавить();
				НовСтр.Номенклатура    =   СтрЗап.Номенклатура.Наименование; 
				НовСтр.Количество      =   СтрЗап.Количество;
				Если СтрЗап.ВидДвижения=   ВидДвиженияНакопления.Расход Тогда
					НовСтр.ВидДвижения =   Ложь;
				Иначе  
					НовСтр.ВидДвижения =   Истина;
				КонецЕсли;				
			КонецЕсли;    		
		КонецЦикла;
		
	КонецЦикла;   
	
	Возврат ТЗ;
	
КонецФункции      

