функция ВернутьПроксиНАХ() Экспорт  
	
	//Тимофеев Ю.А. 03.02.2026
	//возвращает прокси подключения
	//к база Наше Адресное Хранение
	
	МойАдрес       =  Справочники.КлючиБезопасногоХранилищаДанных.НайтиПоКоду("000000023");
	ДанныеДоступа  =  РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(МойАдрес);
    
	ЛогинВебСервиса  = ДанныеДоступа.Логин;
	ПарольВебСервиса = ДанныеДоступа.Пароль;  
	АдресВебСервиса  = ДанныеДоступа.Хост; 
	
	Попытка		
		Определения = Новый WSОпределения(АдресВебСервиса,ЛогинВебСервиса,ПарольВебСервиса);
	Исключение
		
		Возврат Неопределено;		
	КонецПопытки;	
	Срвс = Определения.Сервисы.Получить(0);
	Прокси = Новый WSПрокси(Определения, Срвс.URIПространстваИмен, Срвс.Имя, Срвс.Имя + "Soap");
	Прокси.Пользователь	= ЛогинВебСервиса;
	Прокси.Пароль		= ПарольВебСервиса;
		
	Возврат Прокси;
	
КонецФункции   


