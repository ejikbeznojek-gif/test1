Функция Раскодировать64ВАдресе(НачСтр)
	
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=СокрЛП(НачСтр);
	
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		Символ=Сред(Стр,Сч,1);
		Десятичное=Найти(База,Символ)-1;		
		СтрокаБит=СтрокаБит+Сред(Бинарное(Десятичное),3);		
	КонецЦикла;
	              
	СтрокаИсходная="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение=Лев(СтрокаБит,8);
		
		СтрокаИсходная	=СтрокаИсходная+СимволпоБайтовомуКоду(Десятичное(БитовоеЗначение));			    
		СтрокаБит		=Сред(СтрокаБит,9);
	КонецЦикла;                      
	
	Возврат СтрокаИсходная;	    
КонецФункции            


Функция Бинарное(НачЗн)
	Зн=НачЗн;	
	Стр="";	
	Для Сч=1 по 8 Цикл
		Бит=Зн%2;
		
		Стр=""+Бит+Стр;   
		Зн=(Зн-Бит)/2;		
	КонецЦикла;     
	
	Возврат Стр;
КонецФункции //

Функция Десятичное(НачЗн)
	Зн=0;
	База=128;
	
	ТекДлинна=Мин(СтрДлина(НачЗн),8);
	
	Для Сч=1 по ТекДлинна Цикл
		Зн=Зн+База*Число(Сред(НачЗн,Сч,1));					    
		База=База/2;
	КонецЦикла;
	
	Возврат Зн;
КонецФункции //Десятичное 

Функция СимволПоБайтовомуКоду(Код)
	Возврат Символ(Код);
КонецФункции 
 
 Функция РазложитьСтрокуВАдресе(Знач Стр, Разделитель = ",") 
	
	МассивСтрок = Новый Массив();
	
	Если Разделитель = " " Тогда
		
		Стр = СокрЛП(Стр);
		
		Пока 1 = 1 Цикл
			
			Поз = Найти(Стр,Разделитель);
			
			Если Поз = 0 Тогда
				
				МассивСтрок.Добавить(Стр);
				Возврат МассивСтрок;
				
			КонецЕсли;
			
			МассивСтрок.Добавить(Лев(Стр,Поз-1));
			Стр = СокрЛ(Сред(Стр,Поз));
			
		КонецЦикла;
		
	Иначе
		
		ДлинаРазделителя = СтрДлина(Разделитель);
		
		Пока 1 = 1 Цикл
			
			Поз = Найти(Стр,Разделитель);
			Если Поз = 0 Тогда
				
				МассивСтрок.Добавить(Стр);
				Возврат МассивСтрок;
				
			КонецЕсли;
			
			МассивСтрок.Добавить(Лев(Стр,Поз-1));
			
			Стр = Сред(Стр,Поз + ДлинаРазделителя);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецФункции // глРазложить

/////////////Формирования QR кода для документов АДРЕССА/////////////////

//передаем ссылку на любой документ в ответ получаем картинку со штрихкодом  
//в QR код кодируем ГУИД документа

 Функция ВернутьQRкодКартинкой(ТекДок)  Экспорт
	
 РезультатПодключения = ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодов", "BarcodeSymbolicName", , ТипПодключенияВнешнейКомпоненты.Изолированно);
 Генератор = Новый("AddIn.BarcodeSymbolicName.Barcode");
 
 
 ГУИДССЫЛКИ	= ТекДок.Ссылка.УникальныйИдентификатор();
    
 Генератор.АвтоТип            = Ложь; // если Истина, то ТипКода можно не указывать  
 Генератор.ТипКода            = 16;  //QR Код
 Генератор.ЗначениеКода       = Строка(ГУИДССЫЛКИ); // Строка или Base64Строка
 
 Генератор.ПрозрачныйФон      = Истина; 
 Генератор.ТипВходныхДанных   = 0; // 0 - строка, 1 - base64Строка
 Генератор.УбратьЛишнийФон    = Истина; 
 Генератор.УровеньКоррекцииQR = 1;
 
 ДДШтрихкод = Генератор.ПолучитьШтрихкод();
 
 Если ДДШтрихкод<>Неопределено Тогда
	 Возврат Новый Картинка(ДДШтрихкод);
 иначе
	 Возврат Неопределено;
 КонецЕсли;

КонецФункции


Функция ВернутьДокументПоГУИД(ГУИД) Экспорт 
	
	//передаем ГУИД документа  и получаем ссылку на документ
	
	Если ТипЗнч(ГУИД) = Тип("Строка") Тогда
		GUID= новый УникальныйИдентификатор(ГУИД);
	Иначе
		GUID = ГУИД;
	КонецЕсли;       
	
	//первоначально будет использовать шк для листов набора
	Ссылка = Документы.ЛистНабора.ПолучитьСсылку(GUID);

	Если Найти(СокрЛП(Ссылка), "<Объект не найден>") = 0 Тогда
		Возврат Ссылка;	
	КонецЕсли;  	
	//первоначально будет использовать шк для листов набора
	
	МойДок= Неопределено;
	Для Каждого Мета из Метаданные.Документы Цикл
		Ссылка = Документы[Мета.Имя].ПолучитьСсылку(GUID);
		Если Найти(СокрЛП(Ссылка), "<Объект не найден>") > 0 Тогда
			Продолжить;
		Иначе  
			МойДок=Ссылка; 		
			Прервать;
		КонецЕсли;
	КонецЦикла;    
	
	Возврат МойДок;	
	
КонецФункции


