Функция ВернутьОстатокНоменклатурыВАдресномХранении(ТаблицаИсх, ДокСсылка) Экспорт
	
	//Т.Ю.А, 04.02.26
	ТаблицаКодов = ТаблицаИсх.Скопировать();
		 
	Если ТаблицаКодов.Количество()>0 Тогда
		
		//проверим на дубли
		ТаблицаКодов.Свернуть("Код");
		
		Прокси	= Неопределено;	  
		
		ПроксиАдрес = ВернутьПроксиНАХ();  
		
		Если ПроксиАдрес = Неопределено Тогда   
			Возврат Неопределено;	
		КонецЕсли;       
		
		МассивТЗ=Новый Массив;  		
		
		СтрДокумента = Новый Структура;
		СтрДокумента.Вставить("ГУИДРНК", Строка(ДокСсылка.УникальныйИдентификатор()));
		СтрДокумента.Вставить("НадпРНК", Строка(ДокСсылка));   
		
			
		//ТЮА  Строка(ДокСсылка.Накладная)
		
		МассивТЗ.Добавить(СтрДокумента);
		МассивТЗ.Добавить(ТаблицаКодов); 	
		
		ДанныеИзАдрес = ПроксиАдрес.ОстаткиТовараДляЗНБ(ЗначениеВХранилище(МассивТЗ));               //
		Если ДанныеИзАдрес = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		МассивИзАдрес = ЗначениеИзХранилища(ДанныеИзАдрес); 
		ТЗТовараКод = МассивИзАдрес[0];		
				
		Если ТЗТовараКод.Количество()=0 Тогда
			
			Возврат Неопределено; 
			
		Иначе
			
			ТЗНоменклатура = ПреобразоватьТЗКодыВНоменклатуру(ТЗТовараКод); 		
			Возврат ТЗНоменклатура;                                         
			
		КонецЕсли;
				
	Иначе
		Возврат Неопределено;
	КонецЕсли;


КонецФункции   


Функция ПреобразоватьТЗКодыВНоменклатуру(ТЗКоды) Экспорт
	
	Запрос = Новый Запрос;   
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ТЗКОДЫ.Код КАК Код,
	|	ТЗКОДЫ.Количество КАК Количество
	|ПОМЕСТИТЬ ЗаруженыКоды
	|ИЗ
	|	&ТЗКОДЫ КАК ТЗКОДЫ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаруженыКоды.Код КАК Код,
	|	СУММА(ЗаруженыКоды.Количество) КАК Количество
	|ПОМЕСТИТЬ НужныйКоды
	|ИЗ
	|	ЗаруженыКоды КАК ЗаруженыКоды
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаруженыКоды.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВыбТовар
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Код В
	|			(ВЫБРАТЬ
	|				НужныйКоды.Код КАК Код
	|			ИЗ
	|				НужныйКоды КАК НужныйКоды)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""000000002"" КАК Сектор,
	|	ВыбТовар.Ссылка КАК Номенклатура,
	|	НужныйКоды.Количество КАК КоличествоВСекторе
	|ИЗ
	|	НужныйКоды КАК НужныйКоды
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВыбТовар КАК ВыбТовар
	|		ПО (ВыбТовар.Ссылка.Код = НужныйКоды.Код)
	|";
	Запрос.УстановитьПараметр("ТЗКоды",ТЗКоды);
	
	ТЗРезультат= Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗРезультат;
	
КонецФункции          




Функция ПечатьЗНБ(Объект,ДопПараметры=Неопределено)  Экспорт
	Прокси	= Неопределено;	  
	
	ПроксиАдрес = ВернутьПроксиНАХ();  
	
	Если ПроксиАдрес = Неопределено Тогда   
		Возврат Неопределено;	
	КонецЕсли;       
	
	МассивТЗ=Новый Массив;  		
				
	МассивТЗ.Добавить(Строка(Объект.Ссылка.УникальныйИдентификатор()));
 	МассивТЗ.Добавить(ДопПараметры);
	
	ДанныеИзАдрес = ПроксиАдрес.ПечатьЗНБ(ЗначениеВХранилище(МассивТЗ));               //
	Если ДанныеИзАдрес = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли; 
	
	Возврат ЗначениеИзХранилища(ДанныеИзАдрес);
	
КонецФункции        





