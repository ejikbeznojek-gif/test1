Функция ПолучитьСледующийНомерЧасти(ПН)  Экспорт
	
	//возварщает СЛЕДУЮЩИЙ номер части для документа плана набора
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(ПланНаборатБрэндов.НомерЧасти)+1 КАК НомерЧасти
	|ИЗ
	|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
	|ГДЕ
	|	ПланНаборатБрэндов.Ссылка = &ПланНабора";
	//Параметры запроса
	Запрос.УстановитьПараметр("ПланНабора",ПН);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Номерчасти;
	Иначе   	
		Возврат 1;
	КонецЕсли;

