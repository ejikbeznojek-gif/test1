Процедура СотрудникВыборИзмена(Элемент,СтандартнаяОбработка) Экспорт 
	
	//при выборе или изменении реквизита физ.лицо в документах

	Если НуженКонтрольЗанятостиСотрудника() Тогда
		
		ОтветСТр = ADRESS.ПроверитьСтатусСотрудника(Элемент.Значение);
		
		Если ОтветСТр.Результат Тогда
			#Если Клиент Тогда
			Предупреждение(ОтветСТр.Ответ,7,"Выбранный сотрудник - занят");
			Элемент.Значение     = Справочники.ФизическиеЛица.ПустаяСсылка();
			СтандартнаяОбработка = ложь;
			#КонецЕсли
		КонецЕсли; 
		
	КонецЕсли;

КонецПроцедуры

Функция ПроверимРеквизитыФизическиеЛица(ОбъектДокумент)  Экспорт
	
	Ссылка = ОбъектДокумент.Ссылка;
	ИмяДокумента = ОбъектДокумент.Метаданные().Имя;
	
	Док = Метаданные.Документы[ИмяДокумента];  
	
	ТЗФизЛиц = Неопределено;	
	
	ТЗНезатятыхСотрудников = Новый ТаблицаЗначений;
	ТЗНезатятыхСотрудников.Колонки.Добавить("Сотрудник");
	
	ФизЛица = Тип("СправочникСсылка.ФизическиеЛица");
	
	Для Каждого Реквизит Из Док.Реквизиты Цикл   
		РаботникЗанят = Ложь; 	
		Если Реквизит.Тип.СодержитТип(ФизЛица) Тогда
			//если нужный и заполнен            
			ЗначРеквизита = Ссылка[Строка(Реквизит.Имя)];
			
			Если ЗначениеЗаполнено(ЗначРеквизита) Тогда 
				//проверка на повторение реквизита
				Если ТЗФизЛиц = Неопределено Тогда
					
					//проверим по регистру СтатусРаботыСотрудника
					ПроверкаФЛ = СтатусРаботыСотрудника(ЗначРеквизита,Ссылка);
					
					Если ПроверкаФЛ.Ответ Тогда  					
						
						ТЗФизЛиц = ПроверкаФЛ.ТЗ;			   
						
						КрайСтрока = ТЗФизЛиц.Получить(ТЗФизЛиц.Количество()-1);
						
						РаботникЗанят = Истина; 
					Иначе
						НовНез = ТЗНезатятыхСотрудников.Добавить();
						НовНез.Сотрудник=ЗначРеквизита;
						
					КонецЕсли; 
					
				Иначе   
					
					КрайСтрока = ТЗФизЛиц.Найти(ЗначРеквизита,"Сотрудник");
					
					Если КрайСтрока=Неопределено Тогда
						
						ПроверкаФЛ = СтатусРаботыСотрудника(ЗначРеквизита,Ссылка);
						
						Если ПроверкаФЛ.Ответ Тогда  					
							
							Для Каждого Стр из ПроверкаФЛ.ТЗ Цикл
								НовСтр = ТЗФИЗЛиц.Добавить();
								ЗаполнитьЗначенияСвойств(НовСтр,Стр);								
							КонецЦикла;  							
							
							КрайСтрока = ТЗФизЛиц.Получить(ТЗФизЛиц.Количество()-1);
							
							РаботникЗанят = Истина;		
							
						Иначе
							
							НовНез = ТЗНезатятыхСотрудников.Добавить();
							НовНез.Сотрудник=ЗначРеквизита;
	
						КонецЕсли; 		
						
					Иначе  
						
						КрайСтрока=Неопределено;	
						РаботникЗанят = Истина;						
						
					КонецЕсли;
				КонецЕсли;	       				 
			КонецЕсли;  
			
			Если РаботникЗанят Тогда      
				
				Если КрайСтрока<>Неопределено Тогда 
					#Если Клиент Тогда
						Предупреждение("Информация на "+ФОрмат(ТекущаяДата(),"ДФ=; ДЛФ=DDT")+"Сотрудник "+Строка(КрайСтрока.Сотрудник)+Символы.ПС+"Занят с "+Строка(КрайСтрока.ДатаНачала)
						+Символы.ПС+"Документ: "+Строка(КрайСтрока.ДокументОснования),,"Сотрудник занят");
					#КонецЕсли
					
				КонецЕсли;    
				
				ОбъектДокумент[Строка(Реквизит.Имя)] = Справочники.ФизическиеЛица.ПустаяСсылка();
				
			Иначе   
				
				ТЗНезатятыхСотрудников.Свернуть("Сотрудник");
				
				Для каждого незанят из ТЗНезатятыхСотрудников Цикл
					
					ИзменитьСтатусСотрудника(незанят.Сотрудник,ОбъектДокумент);
					
				КОнецЦикла;
				
			КОнецЕсли;  
			
		КонецЕсли;       
		
	КонецЦикла;   
	
	Возврат РаботникЗанят;
	
КонецФункции   

