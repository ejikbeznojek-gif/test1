 Функция НуженКонтрольЗанятостиСотрудника()
	
	//Если есть запись КонтрольБиржиЗанятости со значением ИСТИНА
	//функции работают
	 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита";
	//Параметры запроса
	Запрос.УстановитьПараметр("ИмяРеквизита","КонтрольБиржиЗанятости");// Строка
	Результат = Запрос.Выполнить().Выбрать();

	Если Результат.Следующий() Тогда
		Возврат Результат.ЗначениеРеквизита;
	Иначе
		Возврат Ложь;
	КонецЕсли;

