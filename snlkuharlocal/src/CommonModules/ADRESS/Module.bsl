Функция ПроверитьСтатусСотрудника(СсылкаСотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СтатусРаботыСотрудникаСрезПоследних.ДокументОснования КАК ДокументОснования,
	|	СтатусРаботыСотрудникаСрезПоследних.ДатаНачала КАК ДатаНачала,
	|	СтатусРаботыСотрудникаСрезПоследних.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.СтатусРаботыСотрудника.СрезПоследних(
	|			,
	|			Сотрудник = &Сотрудник
	|				И ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)) КАК СтатусРаботыСотрудникаСрезПоследних";
	
	Запрос.УстановитьПараметр("Сотрудник",  СсылкаСотрудник);// Физические лица
	Результат = Запрос.Выполнить().Выбрать(); 
	
	Если Результат.Следующий() Тогда
		СтрОтвета = Новый Структура;
		СтрОтвета.Вставить("Результат",Истина);
		СтрОтвета.Вставить("Ответ","Информация на: "+Формат(ТекущаяДата(),"ДЛФ=DT")+Символы.ПС+"Сотрудник: -< "+Строка(СсылкаСотрудник)+" >- занят."+Символы.ПС+"Основание:"+Строка(Результат.ДокументОснования)); 
		Возврат СтрОтвета;	
	Иначе
		СтрОтвета = Новый Структура;
		СтрОтвета.Вставить("Результат",Ложь);
		Возврат СтрОтвета;	
	КонецЕсли;
	
КонецФункции      

Процедура ЛокальноСнятьЗанятостьСотрудника(СсылкаСотрудник,ДокОснование=Неопределено,Комментарий="") Экспорт  
	
	Если СсылкаСотрудник<>Неопределено Тогда 
				
		Запрос = Новый Запрос; 
		
		Если ДокОснование=Неопределено Тогда
			
			ДатаОтбора = НачалоДня(ТекущаяДата()-86400*3);
			УсловиеПоДокументу=" И СтатусРаботыСотрудника.Период МЕЖДУ &НачПериода И &КонПериода И СтатусРаботыСотрудника.ДатаОкончания = &ДатаОкончания";
			Запрос.УстановитьПараметр("ДатаОкончания",Дата(1,1,1));// Дата
			Запрос.УстановитьПараметр("НачПериода",ДатаОтбора);// Дата 
			
		Иначе
			
			УсловиеПоДокументу=" И СтатусРаботыСотрудника.ДокументОснования = &ДокументОснования"; 
			Запрос.УстановитьПараметр("ДокументОснования",ДокОснование);// Дата 
			
		КонецЕсли;
		
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	СтатусРаботыСотрудника.Период КАК Период,
		               |	СтатусРаботыСотрудника.Сотрудник КАК Сотрудник,
		               |	СтатусРаботыСотрудника.ВидРаботы КАК ВидРаботы,
		               |	СтатусРаботыСотрудника.ДокументОснования КАК ДокументОснования,
		               |	СтатусРаботыСотрудника.ДатаНачала КАК ДатаНачала,
		               |	&КонПериода КАК ДатаОкончания,
		               |	&Комментарий КАК Комментарий
		               |ИЗ
		               |	РегистрСведений.СтатусРаботыСотрудника КАК СтатусРаботыСотрудника
		               |ГДЕ
		               |	СтатусРаботыСотрудника.Сотрудник = &Сотрудник"+УсловиеПоДокументу;
		//Параметры запроса
		Запрос.УстановитьПараметр("Сотрудник",  СсылкаСотрудник);// Физические лица  
		Запрос.УстановитьПараметр("КонПериода",ТекущаяДата());// Дата
		Запрос.УстановитьПараметр("Комментарий",Комментарий);// Дата

		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();    
		
		Пока Выборка.Следующий() Цикл     
			
			МенеджерЗаписи = РегистрыСведений.СтатусРаботыСотрудника.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
			МенеджерЗаписи.Записать(Истина);

		КонецЦикла;
        		
	КонецЕсли;
	 
 КонецПроцедуры



Процедура ДобавитьЗанятостьСотрудника(СсылкаСотрудник,ДокОснование) Экспорт     
	
	 МенеджерЗаписи = РегистрыСведений.СтатусРаботыСотрудника.СоздатьМенеджерЗаписи(); 
	 МенеджерЗаписи.Период             = ТекущаяДата();
	 МенеджерЗаписи.Сотрудник          = СсылкаСотрудник;
