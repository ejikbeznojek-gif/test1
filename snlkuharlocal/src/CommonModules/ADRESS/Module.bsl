	 МенеджерЗаписи.ДатаНачала         = ДокОснование.Дата;
	 МенеджерЗаписи.Записать(Истина); 
	 
 КонецПроцедуры   
  
Процедура СнятьЗанятостьСотрудника(СтрокиПланНабора,ДокОснование=Неопределено,Комментарий="") Экспорт   
	 
	//по строкам ПЛАНА НАБОРА
	 
	Если СтрокиПланНабора<>Неопределено Тогда 
		
		//все колонки табличной части документа ПЛАН НАБОРА	 
		БудемПроверятьРеквизиты=Метаданные.Документы.ПЛанНабора.ТабличныеЧасти.тБрэндов.Реквизиты;
		ФизЛица                = Тип("СправочникСсылка.ФизическиеЛица");   
		
		//создаем временную таблицу для хранеия сотрудника
		ТЗСотр = Новый ТаблицаЗначений;
		ТЗСотр.Колонки.Добавить("Сотрудник",Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
		
		Для Каждого СтрокаТЧ Из СтрокиПланНабора Цикл 
			
			Для каждого стрРекв из БудемПроверятьРеквизиты Цикл 		  
				
				Если стрРекв.Тип.СодержитТип(ФизЛица) Тогда
					//если нужный и заполнен            
					СсылкаСотрудник = СтрокаТЧ[Строка(стрРекв.Имя)];
					
					Если ЗначениеЗаполнено(СсылкаСотрудник) Тогда		
						
						НовСОтр= ТЗСотр.Добавить();
						НовСотр.Сотрудник = СсылкаСотрудник;	
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;   
			
		КонецЦикла;    
		
		
		//свернем  пример РНК вместо 1640 записей остается только 5
		ТЗСотр.Свернуть("Сотрудник");
		
		Для каждого ЕстьСотр из ТЗСотр Цикл
			ЛокальноСнятьЗанятостьСотрудника(ЕстьСотр.Сотрудник,ДокОснование,Комментарий);
		КонецЦикла;
		
	КонецЕсли;    
	 
 КонецПроцедуры     
 
