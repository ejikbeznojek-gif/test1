//ЗАГРУЗКА ИЗ XML
Функция ТипУзла(Чтение)
	Если Чтение.КоличествоАтрибутов()>0 Тогда
		Возврат Чтение.ПолучитьАтрибут(0);			
	КонецЕсли;
	Возврат Неопределено;
КонецФункции // ТипУзла()


Функция СоздатьКолонкиТЗ(Чтение,Объект)
	Пока Чтение.Прочитать() И Чтение.Имя="Кол" И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Цикл		
		Чтение.Прочитать();
		Объект.Колонки.Добавить(Чтение.Значение);		
		Чтение.Прочитать(); //Конец элемента Кол
	КонецЦикла;		
	Чтение.Прочитать(); //Конец элемента Колонки	
КонецФункции // создатьКолонкиТЗ()

Процедура ЗаполнитьСтрокуТЗ(Чтение,СтрокаТЗ)	
	Пока Чтение.Прочитать() И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Цикл
		ИмяКолонки=Чтение.Имя;
		НомерКолонки=Число(СтрЗаменить(ИмяКолонки,"Кол",""));
		
		СтрокаТЗ[НомерКолонки-1]=ЗагрузитьОбъект(Чтение);
	КонецЦикла;
КонецПроцедуры 


Функция ЗагрузитьОбъект(Чтение)
	ТипОбъекта	=ТипУзла(Чтение);	
	ИмяУзла		=Чтение.Имя;
	
	Если ПустаяСтрока(ТипОбъекта) Тогда
		Чтение.Прочитать();		
		ТипОбъекта=ТипУзла(Чтение);	
	КонецЕсли;	
	
	Если ТипОбъекта="СписокЗначений" Тогда
		СЗ=Новый СписокЗначений;
		
		Пока Чтение.Прочитать() И Чтение.Имя="СтрокаСписка" И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Цикл			
			Значение		=ЗагрузитьОбъект(Чтение);			
			Представление   =ЗагрузитьОбъект(Чтение);			
			Пометка			=ЗагрузитьОбъект(Чтение);
			
			Чтение.Прочитать();//конец элемента "СтрокаСписка"
			
			Если НЕ ТипЗнч(Пометка)=Тип("Булево") Тогда
				Пометка=Ложь;			
			КонецЕсли; 
			
			СЗ.Добавить(Значение,Представление,Пометка);			
		КонецЦикла;			
		
		Если СЗ.Количество()=0 Тогда Возврат СЗ	КонецЕсли; //из-за пустого списка возникают какие-то глюки
		
		Значение=СЗ;		
	ИначеЕсли ТипОбъекта="ТаблицаЗначений" Тогда
		ТЗ=Новый ТаблицаЗначений;
		
		ИмяУзла=Чтение.Имя;
		
		Если Чтение.Прочитать() И Чтение.Имя="Колонки" И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда				
			СоздатьКолонкиТЗ(Чтение,ТЗ);				
		КонецЕсли;			
			
		Если Чтение.Имя="Строки" И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Тогда
			Пока Чтение.Прочитать() И Чтение.Имя="СтрокаТЗ" И Чтение.ТипУзла=ТипУзлаXML.НачалоЭлемента Цикл
				СтрокаТЗ=ТЗ.Добавить();
				ЗаполнитьСтрокуТЗ(Чтение,СтрокаТЗ);				
			КонецЦикла;				
			
			Чтение.Прочитать(); //Конец узла "Строки"
		КонецЕсли;		
		Значение=ТЗ;
	ИначеЕсли ТипОбъекта="Число" Тогда		
		Чтение.Прочитать();		
		Значение=Число(Чтение.Значение);
	ИначеЕсли ТипОбъекта="Строка" Тогда
		Чтение.Прочитать();
		Значение=СокрЛП(""+Чтение.Значение);		
	ИначеЕсли ТипОбъекта="Дата" Тогда		
		Чтение.Прочитать();		
		
		ТекЗн=Чтение.Значение;
		Значение=?(ПустаяСтрока(ТекЗн),'00010101000000',Дата(Чтение.Значение));
	ИначеЕсли ТипОбъекта="Булево" Тогда
		Чтение.Прочитать();		
		Значение=?(Чтение.Значение="0",Ложь,Истина);		
	Иначе		
		Значение=Неопределено;
	КонецЕсли;
	
	Если Чтение.ТипУзла<>ТипУзлаXML.КонецЭлемента Тогда
		Чтение.Прочитать(); //конец элемента	
	КонецЕсли;
	
	Возврат Значение;
КонецФункции

Функция ЗагрузитьЗначениеИзФайлаXML(ИмяФайлаЗагрузки) Экспорт
	Объект=Неопределено;
	
	Чтение=Новый ЧтениеXML;
	Чтение.ОткрытьФайл(ИмяФайлаЗагрузки);
	Если Чтение.Прочитать() Тогда
		#Если Клиент Тогда
		ОбработкаПрерыванияПользователя();
		#КонецЕсли
				
		Объект=ЗагрузитьОбъект(Чтение);		
	Иначе
		Сообщить("Ошибка чтения файла !",СтатусСообщения.Важное);
	КонецЕсли; 
	
	Возврат Объект;
КонецФункции


