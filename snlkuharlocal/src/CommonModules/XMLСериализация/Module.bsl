//ВЫГРУЗКА В XML
Процедура ВыгрузитьОбъект(Запись,Объект,ИмяНовогоУзла="")
	//Запись=Новый ЗаписьXML;	
	ТипОбъекта=ТипОбъекта(Объект);
	
	Запись.ЗаписатьНачалоЭлемента(ИмяНовогоУзла);		
	Если ТипОбъекта="Неопределено" Тогда
		ТипУзла="Строка";		
	ИначеЕсли ТипОбъекта="Соответствие" Тогда
		ТипУзла="СписокЗначений";
	Иначе		
		ТипУзла=ТипОбъекта;	
	КонецЕсли; 
	
	Запись.ЗаписатьАтрибут("Тип",ТипУзла);	
	
	Если ТипОбъекта="Соответствие" Тогда
		
		Для Каждого Элемент Из Объект Цикл
			Запись.ЗаписатьНачалоЭлемента("СтрокаСписка");		
			
			ВыгрузитьОбъект(Запись,Элемент.Значение,"Значение");
			ВыгрузитьОбъект(Запись,Элемент.Ключ,"Представление");		
			ВыгрузитьОбъект(Запись,Ложь,"Пометка");		
			
			Запись.ЗаписатьКонецЭлемента();
		КонецЦикла;
	ИначеЕсли ТипОбъекта="СписокЗначений" Тогда
		Для Каждого Элемент Из Объект Цикл
			Запись.ЗаписатьНачалоЭлемента("СтрокаСписка");		
			
			ВыгрузитьОбъект(Запись,Элемент.Значение,"Значение");
			ВыгрузитьОбъект(Запись,Элемент.Представление,"Представление");		
			ВыгрузитьОбъект(Запись,Элемент.Пометка,"Пометка");		
			
			Запись.ЗаписатьКонецЭлемента();
		КонецЦикла;		
	ИначеЕсли ТипОбъекта="ТаблицаЗначений" Тогда		
		Запись.ЗаписатьНачалоЭлемента("Колонки");
		Для Каждого Колонка Из Объект.Колонки Цикл
			Запись.ЗаписатьНачалоЭлемента("Кол");			
			Запись.ЗаписатьТекст(Колонка.Имя);
			Запись.ЗаписатьКонецЭлемента();
		КонецЦикла; 
		Запись.ЗаписатьКонецЭлемента();
		
		КоличествоКолонок=Объект.Колонки.Количество();
		
		Запись.ЗаписатьНачалоЭлемента("Строки");
		Для Каждого Строка Из Объект Цикл
			Запись.ЗаписатьНачалоЭлемента("СтрокаТЗ");
			
			Для Сч=0 По КоличествоКолонок-1 Цикл
				ВыгрузитьОбъект(Запись,Строка[Сч],"Кол"+(Сч+1));			
			КонецЦикла; 
			
			Запись.ЗаписатьКонецЭлемента();		
		КонецЦикла; 
		Запись.ЗаписатьКонецЭлемента();
		
	ИначеЕсли ТипОбъекта="Строка" Тогда	
		Запись.ЗаписатьТекст(" "+Объект);	
	ИначеЕсли ТипОбъекта="Число" Тогда
		Запись.ЗаписатьТекст(Формат(Объект,"ЧРД=.;ЧН=0; ЧГ="));		
	ИначеЕсли ТипОбъекта="Дата" Тогда
		Запись.ЗаписатьТекст(Формат(Объект,"ДФ=yyyyMMdd"));		
	ИначеЕсли ТипОбъекта="Булево" Тогда
		Запись.ЗаписатьТекст(""+?(Объект,1,0));		
	Иначе
		Запись.ЗаписатьТекст(""+Объект);				
	КонецЕсли; 
	
	Запись.ЗаписатьКонецЭлемента();
КонецПроцедуры
 
Процедура ВыгрузитьЗначениеВФайлXML(Объект,ИмяФайлаВыгрузки) Экспорт
	Запись=Новый ЗаписьXML;
	Запись.ОткрытьФайл(ИмяФайлаВыгрузки);
	
	Запись.ЗаписатьНачалоЭлемента("Данные");
	
	ВыгрузитьОбъект(Запись,Объект,"СписокДокументов");
	
	Запись.ЗаписатьКонецЭлемента();
	
	Запись.Закрыть();
КонецПроцедуры



Функция ПреобразоватьСписокВСоответствие(Список) Экспорт	
	Соответствие=Новый Соответствие;
	
	Для Каждого Элемент Из Список Цикл
		Соответствие.Вставить(Элемент.Представление,Элемент.Значение);	
	КонецЦикла; 
	
	Возврат Соответствие;
КонецФункции // ПреобразоватьсписокВСоответствие()

Функция ПреобразоватьСоотвествиеВСписок(Соответствие) Экспорт
	Список=Новый СписокЗначений;
	Для Каждого Элемент Из Соответствие Цикл
		Список.Добавить(Элемент.Значение,Элемент.Ключ);		
	КонецЦикла;
	
	Возврат Список;
КонецФункции // ПреобразоватьСоотвествиеВСписок()

#Область ЗаменаНедопустимыхСимволов

// Заменяет недопустимые символы в XML-строке на заданные символы.
//
// Параметры:
//   Текст - Строка - строка, в которой требуется выполнить замену недопустимых символов.
//   СимволЗамены - Строка - строка, на которую требуется выполнить замену недопустимого символа в XML-строке.
// 
// Возвращаемое значение:
//    Строка - строка, полученная заменой недопустимых символов в XML-строке.
//
Функция ЗаменитьНедопустимыеСимволыXML(Знач Текст, СимволЗамены = " ") Экспорт
	
#Если Не ВебКлиент Тогда
	ПозицияНачала = 1;
	Позиция = НайтиНедопустимыеСимволыXML(Текст, ПозицияНачала);
	Пока Позиция > 0 Цикл
		НедопустимыйСимвол = Сред(Текст, Позиция, 1);
		Текст = СтрЗаменить(Текст, НедопустимыйСимвол, СимволЗамены);
		ПозицияНачала = Позиция + СтрДлина(СимволЗамены);
		Если ПозицияНачала > СтрДлина(Текст) Тогда
			Прервать;
		КонецЕсли;
		Позиция = НайтиНедопустимыеСимволыXML(Текст, ПозицияНачала);
	КонецЦикла;
	
	Возврат Текст;
#Иначе
	// Коды символов от 0 до 2^16-1, которые метод НайтиНедопустимыеСимволыXML
	// считает недопустимыми: 0-8, 11-12, 14-31, 55296-57343.
	Итог = "";
	ДлинаСтроки = СтрДлина(Текст);
	
	Для НомерСимвола = 1 По ДлинаСтроки Цикл
		Символ = Сред(Текст, НомерСимвола, 1);
		КодСимвола = КодСимвола(Символ);
		
		Если КодСимвола < 9
		 Или КодСимвола > 10    И КодСимвола < 13
		 Или КодСимвола > 13    И КодСимвола < 32
		 Или КодСимвола > 55295 И КодСимвола < 57344 Тогда
			
			Символ = СимволЗамены;
		КонецЕсли;
		Итог = Итог + Символ;
	КонецЦикла;
	
	Возврат Итог;
#КонецЕсли
	
КонецФункции

// Заменяет недопустимые символы в имени файла.
//
// Параметры:
//  ИмяФайла     - Строка - исходное имя файла.
//  НаЧтоМенять  - Строка - строка, на которую необходимо заменить недопустимые символы.
//
// Возвращаемое значение:
//   Строка - преобразованное имя файла.
//
Функция ЗаменитьНедопустимыеСимволыВИмениФайла(Знач ИмяФайла, НаЧтоМенять = " ") Экспорт

	Результат = ИмяФайла;
	МассивНайденныхНедопустимыхСимволов = НайтиНедопустимыеСимволыВИмениФайла(Результат);
	Для Каждого НедопустимыйСимвол Из МассивНайденныхНедопустимыхСимволов Цикл
		Результат = СтрЗаменить(Результат, НедопустимыйСимвол, НаЧтоМенять);
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

// Проверяет наличие недопустимых символов в имени файла.
//
// Параметры:
//  ИмяФайла  - Строка - имя файла.
//
// Возвращаемое значение:
//   Массив   - массив обнаруженных в имени файла недопустимых символов.
//              Если недопустимых символов не обнаружено - возвращается пустой массив.
Функция НайтиНедопустимыеСимволыВИмениФайла(ИмяФайла) Экспорт

	НедопустимыеСимволы = ПолучитьНедопустимыеСимволыВИмениФайла();
	
	МассивНайденныхНедопустимыхСимволов = Новый Массив;
	
	Для ПозицияСимвола = 1 По СтрДлина(НедопустимыеСимволы) Цикл
		ПроверяемыйСимвол = Сред(НедопустимыеСимволы,ПозицияСимвола,1);
		Если СтрНайти(ИмяФайла,ПроверяемыйСимвол) <> 0 Тогда
			МассивНайденныхНедопустимыхСимволов.Добавить(ПроверяемыйСимвол);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивНайденныхНедопустимыхСимволов;

КонецФункции

// Возвращает строку недопустимых символов.
// Согласно http://en.wikipedia.org/wiki/Filename - в разделе "Reserved characters and words".
// Возвращаемое значение:
//   Строка - строка недопустимых символов.
Функция ПолучитьНедопустимыеСимволыВИмениФайла() Экспорт

	НедопустимыеСимволы = """/\[]:;|=?*<>";
	НедопустимыеСимволы = НедопустимыеСимволы + Символы.Таб;
	Возврат НедопустимыеСимволы;

КонецФункции

#КонецОбласти

