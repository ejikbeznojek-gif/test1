//РАБОТА С РЕГИСТРОМ НАСТРОЕК
Функция ПрочитатьНастройку(ТипОбъекта,ИмяОбъекта,ИмяНастройки,Знач Пользователь=Неопределено) Экспорт
	Пользователь=?(Пользователь=Неопределено,ПараметрыСеанса.Пользователь,Пользователь);
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ЗначениеНастройки
	|ИЗ
	|	РегистрСведений.НастройкиОбъектов КАК НастройкиОбъектов
	|ГДЕ
	|	ТипОбъекта		= &ТипОбъекта
	|	И ИмяОбъекта	= &ИмяОбъекта
	|	И ИмяНастройки	= &ИмяНастройки
	|	И Пользователь	= &Пользователь";
	
	Запрос.УстановитьПараметр("ТипОбъекта",ТипОбъекта);
	Запрос.УстановитьПараметр("ИмяОбъекта",ИмяОбъекта);
	Запрос.УстановитьПараметр("ИмяНастройки",ИмяНастройки);
	Запрос.УстановитьПараметр("Пользователь",Пользователь);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		попытка
			Возврат Выборка.ЗначениеНастройки.Получить();	
		исключение
			прервать;
		Конецпопытки;
	КонецЦикла; 	
	Возврат Неопределено;	
КонецФункции // ПолучитьНастройку()

Функция ЗаписатьНастройку(Настройка,ТипОбъекта,ИмяОбъекта,ИмяНастройки,Знач Пользователь=Неопределено) Экспорт
	Пользователь=?(Пользователь=Неопределено,ПараметрыСеанса.Пользователь,Пользователь);
	
	Запись=РегистрыСведений.НастройкиОбъектов.СоздатьМенеджерЗаписи();
	Запись.ТипОбъекта		=ТипОбъекта;
	Запись.ИмяОбъекта		=ИмяОбъекта;
	Запись.ИмяНастройки		=ИмяНастройки;
	Запись.Пользователь		=Пользователь;
	
	Запись.ЗначениеНастройки=Новый ХранилищеЗначения(Настройка);
	
	Запись.ДатаМодификации	=ТекущаяДата();
	
	Запись.Записать();	
КонецФункции // ЗаписатьНастройку()

