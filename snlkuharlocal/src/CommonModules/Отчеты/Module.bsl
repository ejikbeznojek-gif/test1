// СОХРАНЕНИЕ ВОССТАНОВЛЕНИЕ ПОЛНЫХ НАСТРОЕК ОТЧЕТА
Функция АктивноеДеревоНастроек(Форма) Экспорт
	СписокДеревьев=Новый Структура("ДеревоОбщихНастроек,ДеревоНастроекПользователя");
	
	Для Каждого Дерево Из СписокДеревьев Цикл
		Если Форма.ЭлементыФормы[Дерево.Ключ].ВыделенныеСтроки.Количество()<>0 Тогда
			Возврат Дерево.Ключ;			
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Неопределено;
КонецФункции // АктивноеДеревоНастроек()

//сохраняет в дереве настроек текущую настройку отчета
Процедура СохранитьНастройку(Форма)	Экспорт
	ИмяАктивногоДереваНастроек	=АктивноеДеревоНастроек(Форма);
	ДеревоНастроек				=Форма.ЭлементыФормы[ИмяАктивногоДереваНастроек];
	
	ТекСтрока					=ДеревоНастроек.ТекущаяСтрока;		
	Если ТекСтрока<>Неопределено Тогда		
		Если ИмяАктивногоДереваНастроек="ДеревоНастроекПользователя" Тогда						
			ТекСтрока.Значение=Форма.ПолучитьНастройкуОтчета();
			СохранитьНастройкиОтчета(Форма,"НастройкиПользователя");
		ИначеЕсли ИмяАктивногоДереваНастроек="ДеревоОбщихНастроек" Тогда
			Если ПолучитьПолномочиеПользователя("СохранятьНастройкиОтчетов") Тогда
				ТекСтрока.Значение=Форма.ПолучитьНастройкуОтчета();
				СохранитьНастройкиОтчета(Форма,"ОбщиеНастройки");				
			Иначе
				Предупреждение("Недостаточно прав для сохранения общих настроек !");
			КонецЕсли;		
		КонецЕсли;		
	Иначе
		Предупреждение("Не выбрана строка дерева настроек !!!");
	КонецЕсли;	
КонецПроцедуры

//сохраняет деревья настроек, позиции даты и т.д.
Процедура СохранитьНастройкиОтчета(Форма,Вид=Неопределено) Экспорт
	ОтчетОбъект=Форма.ЭтотОбъект;
	ИмяОтчета=Форма.Метаданные().Имя;
	
	Если Форма.Метаданные().Реквизиты.Найти("ВидОтчета")<>Неопределено Тогда
		ИмяОтчета=ИмяОтчета+"_"+Форма.ВидОтчета.Код;
	КонецЕсли;
	
	Если Вид="НастройкиПользователя" ИЛИ Вид="Все" Тогда
		Настрока=Новый Структура("Дерево",ОтчетОбъект.ДеревоНастроекПользователя);
		ЗаписатьНастройку(Настрока,"Отчет",ИмяОтчета,"НастрокиПользователя");
	ИначеЕсли Вид="ОбщиеНастройки" ИЛИ Вид="Все" Тогда
		Настрока=Новый Структура("Дерево",ОтчетОбъект.ДеревоОбщихНастроек);
		ЗаписатьНастройку(Настрока,"Отчет",ИмяОтчета,"ОбщиеНастройки",Справочники.Пользователи.НастройкиПоУмолчанию);				
	КонецЕсли;
		
	НастройкиФормы=Новый Структура("ИндексСтрокиДереваНастроекПользователя,
									|ИндексСтрокиДереваОбщихНастроек,
									|ИмяАктивногоДереваНастроек,									
									|Дата1,Дата2",
									ПолучитьИндексТекущейСтрокиДерева(Форма.ЭлементыФормы.ДеревоНастроекПользователя),
									ПолучитьИндексТекущейСтрокиДерева(Форма.ЭлементыФормы.ДеревоОбщихНастроек),
									АктивноеДеревоНастроек(Форма),
									Форма.Дата1,Форма.Дата2);
	//крохин начало 18.04.2017								
	Попытка	
		ДопНастройки=Форма.ПолучитьДопНастройкиОтчета();
		НастройкиФормы.Вставить("ДопНастройки",ДопНастройки);	
	Исключение	
	КонецПопытки;
	//крохин конец 18.04.2017								
	ЗаписатьНастройку(НастройкиФормы,"Отчет",ИмяОтчета,"НастройкиФормы");	
КонецПроцедуры

//восстанавливает деревья настроек, позиции даты и т.д.
Процедура ВосстановитьНастройкиОтчета(Форма) Экспорт
	ИмяОтчета=Форма.Метаданные().Имя;
	
	Если Форма.Метаданные().Реквизиты.Найти("ВидОтчета")<>Неопределено Тогда
		ИмяОтчета=ИмяОтчета+"_"+Форма.ВидОтчета.Код;
	КонецЕсли; 
	
	НастрокиФормы=ПрочитатьНастройку("Отчет",ИмяОтчета,"НастройкиФормы");	
	Если НастрокиФормы<>Неопределено Тогда
		ИндексСтрокиДереваНастроекПользователя	=НастрокиФормы["ИндексСтрокиДереваНастроекПользователя"];
		ИндексСтрокиДереваОбщихНастроек			=НастрокиФормы["ИндексСтрокиДереваОбщихНастроек"];
		
		АктивноеДерево							=НастрокиФормы["ИмяАктивногоДереваНастроек"];
		
		Форма.Дата1								=НастрокиФормы["Дата1"]; 
		Форма.Дата2								=НастрокиФормы["Дата2"]; 		
		//крохин начало 18.04.2017
		ДопНастройки=Неопределено;
		Если НастрокиФормы.Свойство("ДопНастройки",ДопНастройки) Тогда
			Для Каждого Элемент Из ДопНастройки Цикл
				Форма[Элемент.Ключ]=Элемент.Значение;							
			КонецЦикла;		
		КонецЕсли;
		//крохин конец 18.04.2017
	Иначе		
		ИндексСтрокиДереваНастроекПользователя	="";
		ИндексСтрокиДереваОбщихНастроек			="";
		
		АктивноеДерево							="ДеревоНастроекПользователя";
		
		Форма.Дата1								=НачалоМесяца(ТекущаяДата()); 
		Форма.Дата2								=КонецМесяца(Форма.Дата1);	
	КонецЕсли; 
	
	Если АктивноеДерево="ДеревоНастроекПользователя" ИЛИ АктивноеДерево="ДеревоОбщихНастроек" Тогда
	Иначе
		АктивноеДерево="ДеревоОбщихНастроек";			
	КонецЕсли; 
		
	Настрока=ПрочитатьНастройку("Отчет",ИмяОтчета,"НастрокиПользователя");	
	Если Настрока<>Неопределено Тогда
		Форма.ДеревоНастроекПользователя=Настрока["Дерево"];		
	Иначе
		СоздатьКолонкиДереваНастроек(Форма,"ДеревоНастроекПользователя");
	КонецЕсли;	
	
	Настрока=ПрочитатьНастройку("Отчет",ИмяОтчета,"ОбщиеНастройки",Справочники.Пользователи.НастройкиПоУмолчанию);	
	Если Настрока<>Неопределено Тогда
		Форма.ДеревоОбщихНастроек=Настрока["Дерево"];
	Иначе
		СоздатьКолонкиДереваНастроек(Форма,"ДеревоОбщихНастроек");		
	КонецЕсли;
	
	ОтформатироватьДеревоНастроек(Форма,"ДеревоОбщихНастроек");
	ОтформатироватьДеревоНастроек(Форма,"ДеревоНастроекПользователя");
	
	ВосстановитьПозициюДерева(Форма.ЭлементыФормы.ДеревоОбщихНастроек,			ИндексСтрокиДереваОбщихНастроек);		
	ВосстановитьПозициюДерева(Форма.ЭлементыФормы.ДеревоНастроекПользователя,	ИндексСтрокиДереваНастроекПользователя);	
	
	Форма.ТекущийЭлемент=Форма.ЭлементыФормы[АктивноеДерево];
	АктивизацияСтрокиДереваНастроек(Форма,Форма.ТекущийЭлемент);	
	
		Если ЗначениеЗаполнено(ПараметрыСеанса.ДатаЗапретаВидимости) Тогда
			//крохин начало
			//по просьбе Филиппова
			Дата1 = НачалоМесяца(ТекущаяДата());
			Дата2 = ТекущаяДата();
		//	Дата1=ПараметрыСеанса.ДатаЗапретаВидимости;
		//	Дата2=КонецМесяца(ПараметрыСеанса.ДатаЗапретаВидимости);
		//крохин конец
		КонецЕсли;

КонецПроцедуры


Процедура ЗаписатьФормированиеОтчета(Форма, ДопИнфо = Неопределено, НастройкиОтчета = Неопределено, ВремяВыполнения = Неопределено) Экспорт
	ИмяЛога = ?(ВремяВыполнения = Неопределено ИЛИ ВремяВыполнения = 0.01, "ЗапускОтчетов", "ВремяВыполненияОтчетов");  
	
	//+++Чирков 12.05.2025
	Части = Новый Массив;
	Части.Добавить(Форма.Метаданные().Имя);	
	Если НЕ СтрНачинаетсяС(СокрЛП(ДопИнфо), "(") Тогда
		Части.Добавить(СокрЛП(ДопИнфо));						
	КонецЕсли;
	
	ЗаписатьВЛог(ИмяЛога, СтрСоединить(Части, "."), "Информация", , НастройкиОтчета,ВремяВыполнения);
	//---Чирков 12.05.2025
КонецПроцедуры

//крохин начало
Процедура ЗаписатьФормированиеОбработки(Форма,ДопИнфо=Неопределено) Экспорт	
	ЗаписатьВЛог("ЗапускОбработки",""+Форма.Метаданные().Имя+". "+ДопИнфо,"Информация");
КонецПроцедуры
//крохин конец


Функция ВычислитьСуммуВыделенныхЯчеекТабличногоДокумента(ПолеТабличногоДокумента) Экспорт	
	Сумма = 0;
	Для Каждого Область Из ПолеТабличногоДокумента.ВыделенныеОбласти Цикл
		Если ТипЗнч(Область) = Тип("ОбластьЯчеекТабличногоДокумента") Тогда
			Для ИндексСтрока = Область.Верх По Область.Низ Цикл
				Для ИндексКолонка = Область.Лево По Область.Право Цикл
					Попытка
						Сумма = Сумма + Число(СтрЗаменить(ПолеТабличногоДокумента.Область("R" + Формат(ИндексСтрока, "ЧГ=0") + "C" + Формат(ИндексКолонка, "ЧГ=0")) .Текст, " ", ""));
					Исключение
					КонецПопытки;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Сумма;	
КонецФункции

Процедура ОтобразитьСуммуЯчеек(Форма,Элемент) Экспорт
	ЭФ	= Форма.ЭлементыФормы;	
	ЭФ.ПолеСумма.Значение = ВычислитьСуммуВыделенныхЯчеекТабличногоДокумента(Элемент);
КонецПроцедуры