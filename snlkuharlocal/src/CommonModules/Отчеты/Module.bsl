// ПОЛУЧЕНИЕ УСТАНОВКА ТЕКУЩЕЙ СТРОКИ ДЕРЕВА НАСТРОЕК
Функция  ПолучитьИндексТекущейСтрокиДерева(Дерево) Экспорт	
	СтрокаИндекса="";
	
	ТекСтрока=Дерево.ТекущаяСтрока;	
	Если ТекСтрока<>Неопределено Тогда
		Пока ТекСтрока.Родитель<>Неопределено Цикл
			СтрокаИндекса=""+ТекСтрока.Родитель.Строки.Индекс(ТекСтрока)+?(ПустаяСтрока(СтрокаИндекса),"",",")+СтрокаИндекса;		
			ТекСтрока=ТекСтрока.Родитель;
		КонецЦикла;	
		СтрокаИндекса=""+Дерево.Значение.Строки.Индекс(ТекСтрока)+?(ПустаяСтрока(СтрокаИндекса),"",",")+СтрокаИндекса;		
	КонецЕсли;
	
	Возврат СтрокаИндекса;
КонецФункции

Процедура ВосстановитьПозициюДерева(ДеревоЭУ,Индекс)
	Дерево=ДеревоЭУ.Значение;
	
	ТекСтрокаДерева=Дерево;	
	ТекСтрока=Индекс;		
	Если ТекСтрокаДерева.Строки.Количество()>0 Тогда
		Попытка
			Поз=Найти(ТекСтрока,",");
			Пока Поз<>0 Цикл		
				ТекСтрокаДерева=ТекСтрокаДерева.Строки.Получить(Число(Лев(ТекСтрока,Поз-1)));
				
				ТекСтрока=Сред(ТекСтрока,Поз+1);		
				Поз=Найти(ТекСтрока,",");
			КонецЦикла;
			Если СтрДлина(ТекСтрока)>0 Тогда
				ТекСтрокаДерева=ТекСтрокаДерева.Строки.Получить(Число(ТекСтрока));
				
				ДеревоЭУ.ТекущаяСтрока=ТекСтрокаДерева;				
			КонецЕсли; 			
		Исключение
			Сообщить("Ошибка установки текущей строки ! "+ОписаниеОшибки());
		КонецПопытки;	
	КонецЕсли;	
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////////////
//ВЫДЕЛЕНИЕ СТРОК ДЕРЕВА НАСТРОЕК
Процедура СнятьВыделениеТекущейСтрокиТП(ТП)
	Если ТП.ТекущаяСтрока<>Неопределено Тогда
		ТП.ВыделенныеСтроки.Удалить(ТП.ТекущаяСтрока);
	КонецЕсли; 
КонецПроцедуры

Процедура УстановитьВыделениеТекущейСтрокиТП(ТП)
	Если ТП.ТекущаяСтрока<>Неопределено Тогда
		ТП.ВыделенныеСтроки.Добавить(ТП.ТекущаяСтрока);
	КонецЕсли;
КонецПроцедуры 

///////////////////////////////////////////////////////////////////////////////////
//ОБРАБОТКА СОБЫТИЙ ДЕРЕВА НАСТРОЕК
Процедура АктивизацияСтрокиДереваНастроек(Форма,Элемент) Экспорт
	
	ИмяАктивногоДереваНастроек=Элемент.Имя;	
	
	Если ИмяАктивногоДереваНастроек="ДеревоНастроекПользователя" Тогда	
		СнятьВыделениеТекущейСтрокиТП(Форма.ЭлементыФормы.ДеревоОбщихНастроек);	
		ВыборСтрокиДереваНастроек(Форма,Элемент.ТекущаяСтрока);		
		УстановитьВыделениеТекущейСтрокиТП(Форма.ЭлементыФормы.ДеревоНастроекПользователя);
	ИначеЕсли ИмяАктивногоДереваНастроек="ДеревоОбщихНастроек" Тогда 
		СнятьВыделениеТекущейСтрокиТП(Форма.ЭлементыФормы.ДеревоНастроекПользователя);						
		ВыборСтрокиДереваНастроек(Форма,Элемент.ТекущаяСтрока);
		УстановитьВыделениеТекущейСтрокиТП(Форма.ЭлементыФормы.ДеревоОбщихНастроек);	
	КонецЕсли;	
КонецПроцедуры

Процедура ВыборСтрокиДереваНастроек(Форма,ВыбраннаяСтрока)	Экспорт
	Если ВыбраннаяСтрока<>Неопределено И ВыбраннаяСтрока.Значение<>Неопределено Тогда
		Форма.ВосстановитьНастройкуОтчета(ВыбраннаяСтрока.Значение);		
	Иначе
		Форма.ВосстановитьНастройкуОтчета();		
	КонецЕсли;    
КонецПроцедуры 

