//СОЗАНИЕ ФОРМАТИРОВАНИЕ ДЕРЕВЬЕВ НАСТРОЕК
Функция СоздатьКолонкиДереваНастроек(Форма,ИмяДерева)	
	Дерево=Форма[ИмяДерева];
	
	Если Дерево.Колонки.Найти("Имя")=Неопределено Тогда			
		Дерево.Колонки.Добавить("Имя",Новый ОписаниеТипов("Строка"));				
	КонецЕсли; 
	Если Дерево.Колонки.Найти("Значение")=Неопределено Тогда	
		Дерево.Колонки.Добавить("Значение");				
	КонецЕсли;
	Если Дерево.Колонки.Найти("Заголовок")=Неопределено Тогда	
		Дерево.Колонки.Добавить("Заголовок");				
	КонецЕсли;
	Если Дерево.Колонки.Найти("ИспользоватьКакРасшифровку")=Неопределено Тогда	
		Дерево.Колонки.Добавить("ИспользоватьКакРасшифровку",Новый ОписаниеТипов("Булево"));				
	КонецЕсли;
	
	Если Дерево.Строки.Количество()=0 Тогда
		СтрокаДерева=Дерево.Строки.Добавить();
		СтрокаДерева.Имя="Основная";
	КонецЕсли;
КонецФункции // СоздатьКолонкиДереваНастроек()

Процедура ОтформатироватьДеревоНастроек(Форма,ИмяДерева)
	Форма.ЭлементыФормы[ИмяДерева].СоздатьКолонки();
	Форма.ЭлементыФормы[ИмяДерева].Колонки["Имя"].Ширина 		= 10;
	Форма.ЭлементыФормы[ИмяДерева].Колонки["Значение"].Видимость= Ложь;	
	Форма.ЭлементыФормы[ИмяДерева].Колонки["Заголовок"].Ширина	= 4;
КонецПроцедуры 

