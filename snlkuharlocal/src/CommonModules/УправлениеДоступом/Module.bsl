//ЭУ		- Элемент управления
//СтрокаТД	- строка таблицы доступа
Процедура УстановитьПараметрыДоступаЭУ(Форма,ЭУ,СтрокаТД)	
	Если ЭУ.Доступность И СтрокаТД.Доступность<>Неопределено Тогда
		ЭУ.Доступность=СтрокаТД.Доступность;					
	КонецЕсли;				
	Если СтрокаТД.ТолькоПросмотр<>Неопределено Тогда
		Попытка
			ЭУ.ТолькоПросмотр	=СтрокаТД.ТолькоПросмотр;					
		Исключение			
			ЭУ.Доступность		=?(СтрокаТД.ТолькоПросмотр,Ложь,Истина);			
		КонецПопытки;		
	КонецЕсли;				
	Если СтрокаТД.Видимость<>Неопределено Тогда
		Если ТипЗнч(ЭУ)=Тип("Надпись") Тогда
			ЭУ.Видимость=СтрокаТД.Видимость;
		Иначе
			//скрытые элементы не отображаем чтобы не портить картину
			//закрытые выключаем
			Если НЕ СтрокаТД.Видимость И ЭУ.Видимость Тогда
				ЭУ.Видимость=СтрокаТД.Видимость;		
				Попытка
					ЭУ.ИзменятьВидимость=Ложь;
				Исключение
				КонецПопытки;			
			КонецЕсли;		
		КонецЕсли;		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаТД.ВозможныеЗначения) Тогда				
		НачЗнач	=ЭУ.Значение;
		НачМод	=Форма.Модифицированность;
		
		ЭУ.СписокВыбора=ЗначениеИзСтрокиВнутр(СтрокаТД.ВозможныеЗначения);		
		ЭУ.РежимВыбораИзСписка=Истина;	
		ЭУ.КнопкаВыбора=Ложь;
		
		ЭУ.Значение=НачЗнач;
		
		Форма.Модифицированность=НачМод;
	КонецЕсли; 
КонецПроцедуры

