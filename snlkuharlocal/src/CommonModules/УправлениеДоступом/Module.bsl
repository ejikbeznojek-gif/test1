Функция МожноИзменятьДокумент(ДокОбъект,Отказ=Ложь,ВыводитьСообщения=Ложь) Экспорт
	Если Отказ Тогда Возврат Ложь КонецЕсли; //И так все плохо
	
	Вид=ДокОбъект.Метаданные().Имя;	
	
	ЭтотУзел=ПланыОбмена.Основной.ЭтотУзел();
	//Можно=Истина;
		
	Если Вид="РасходнаяНакладная" Тогда		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда
				Если ДокОбъект.Ссылка.Отгружен=Перечисления.Отгружен.Отгружен И НЕ ПустаяСтрока(ДокОбъект.Склад.КодФизическогоУзла) Тогда
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
				КонецЕсли;
			Иначе		
				Отказ=Истина;
			КонецЕсли;
			//крохин начало 16.02.2012
			//запретим редактировать филиальные РНК в офисе
			Если ДокОбъект.Склад.ТипСклада = Перечисления.ТипСклада.Филиал Тогда
				Если НЕ РольДоступна("Администратор") Тогда
			Отказ = Истина;	
			КонецЕсли;	
			КонецЕсли;
			//крохин конец 16.02.2012
		Иначе			
			Если РольДоступна("Администратор") Тогда
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорСклад") Тогда		
				Если ДокОбъект.Ссылка.Отгружен=Перечисления.Отгружен.Отгружен Тогда
					Если ДокОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
						Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
					Иначе
						Отказ=Истина; //На других узлах вообще нечего трогать чужие документы
					КонецЕсли;					
				КонецЕсли;			
			Иначе		
				Отказ=Истина;
			КонецЕсли;
			//крохин начало 16.02.2012
			//запретим редактировать офисные РНК в филиале
			//крохин начало 25.05.2012
			//Вэймарт
			//Если ДокОбъект.Склад.ТипСклада <> Перечисления.ТипСклада.Филиал И  ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			//Катаев+ 10/06/14 Для филиала проверку по досупу к скадам делаем по коду узла
			Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			//Если (ДокОбъект.Склад.ТипСклада <> Перечисления.ТипСклада.Филиал И ДокОбъект.Склад.ТипСклада <> Перечисления.ТипСклада.ОптовыйТЦ) И  ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
			////крохин конец 25.05.2012	
			//	
			////крохин начало 22.05.2012
			////Отказ = Истина;
			//Если ДокОбъект.Склад.Пустая() Тогда
			//	Отказ = Ложь;
			//Иначе
			//Если НЕ РольДоступна("Администратор") Тогда
			//Отказ = Истина;	
			//КонецЕсли;
				Если ДокОбъект.Склад.Пустая() Тогда
					Отказ = Ложь;
				ИначеЕсли ПланыОбмена.Основной.ЭтотУзел().Код <> ДокОбъект.Склад.КодФизическогоУзла Тогда
					Если НЕ РольДоступна("Администратор") Тогда
						Отказ = Истина;	
					КонецЕсли;
				
				КонецЕсли;
				//Катаев- 10/06/14
			//крохин конец 22.05.2012
			КонецЕсли;
			//крохин конец 16.02.2012

		КонецЕсли;		
	ИначеЕсли Вид="Перемещение" Тогда
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если ДокОбъект.Склад.ФизическийСклад=ДокОбъект.СкладПолучатель ИЛИ ДокОбъект.Склад=ДокОбъект.СкладПолучатель.ФизическийСклад Тогда //виртуальные перемещения на КБ
				Возврат НЕ Отказ;
			КонецЕсли;
			
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда					
				ЕстьВиртуальныеСклады=Ложь;
				Если ДокОбъект.Склад.ВидСклада=Перечисления.ВидСклада.Виртуальный ИЛИ ДокОбъект.СкладПолучатель.ВидСклада=Перечисления.ВидСклада.Виртуальный Тогда
					ЕстьВиртуальныеСклады=Истина;				
				КонецЕсли; 
				Если
						(НЕ ПустаяСтрока(ДокОбъект.Склад.КодФизическогоУзла) 			И ДокОбъект.Ссылка.Отгружен=Перечисления.Отгружен.Отгружен) //накладная реально отгружена складом
					ИЛИ (НЕ ПустаяСтрока(ДокОбъект.СкладПолучатель.КодФизическогоУзла)	И ДокОбъект.Ссылка.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.Принята) //накладная реально принята складом
					Тогда
					Если ЕстьВиртуальныеСклады Тогда
						Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженыхПеремещенийНаВирутальныеСклады");
					Иначе
						Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");					
					КонецЕсли;					
				КонецЕсли;
			Иначе		
				Отказ=Истина;
			КонецЕсли;			
		Иначе
			Если РольДоступна("Администратор") Тогда
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорСклад") Тогда		
				Если 
						ДокОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код И ДокОбъект.Ссылка.Отгружен=Перечисления.Отгружен.Отгружен //накладная реально отгружена складом						
					ИЛИ ДокОбъект.СкладПолучатель.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код И ДокОбъект.Ссылка.СостояниеНакладнойУПолучателя=Перечисления.СостоянияНакладной.Принята //накладная реально принята складом
					Тогда
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
										//крохин начало 29.03.2013
				//в филиалах можно по другой галке редактировать перемещения между своими складами
				Если ДокОбъект.Склад.КодФизическогоУзла=ДокОбъект.СкладПолучатель.КодФизическогоУзла Тогда
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженыхПеремещенийНаВирутальныеСклады");
				КонецЕсли;
				//крохин конец 29.03.2013
				КонецЕсли;			
			Иначе		
				Отказ=Истина;
			КонецЕсли;	
		КонецЕсли;		
	ИначеЕсли Вид="ПриходнаяНакладная" Тогда		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда				
				Если ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Принята И НЕ ПустаяСтрока(ДокОбъект.Склад.КодФизическогоУзла) Тогда				
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеПринятыхНакладных");					
				КонецЕсли;
			Иначе		
				Отказ=Истина;
			КонецЕсли;			
		Иначе
			Если РольДоступна("Администратор") Тогда					
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорСклад") Тогда		
				Если ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Принята Тогда
					Если ДокОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
						Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеПринятыхНакладных");
					Иначе
						Отказ=Истина;
					КонецЕсли;					
				КонецЕсли;			
			Иначе		
				Отказ=Истина;
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли Вид="СписаниеТМЦ" Тогда		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда				
				Если ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена И НЕ ПустаяСтрока(ДокОбъект.Склад.КодФизическогоУзла) Тогда				
					Отказ=НЕ ПолучитьПолномочиеПользователя("ИспользованиеИнвентаризаций");
				КонецЕсли;
			Иначе		
				Отказ=Истина;
			КонецЕсли;			
		Иначе
			Если РольДоступна("Администратор") Тогда					
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорСклад") Тогда		
				Если ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Отгружена Тогда
					Отказ=НЕ ПолучитьПолномочиеПользователя("ИспользованиеИнвентаризаций");
				КонецЕсли;			
			Иначе		
				Отказ=Истина;
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли Вид="ПродажаИМ" Тогда		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда
				
				Если ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Доставлена И НЕ ПустаяСтрока(ДокОбъект.Склад.КодФизическогоУзла) Тогда
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
				КонецЕсли;
				
				
			Иначе		
				Отказ=Истина;
			КонецЕсли;			
		Иначе			
			Если РольДоступна("Администратор") Тогда
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорСклад") Тогда		
				
				Если  ДокОбъект.Ссылка.СостояниеНакладной=Перечисления.СостоянияНакладной.Доставлена И ДокОбъект.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
					Отказ=Истина;  //НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
					
				Иначе 
					Отказ=НЕ ПолучитьПолномочиеПользователя("РедактированиеОтгруженныхНакладных");
					
				КонецЕсли;			
							
			Иначе		
				Отказ=Истина;
			КонецЕсли;	
		КонецЕсли;
		
	
	КонецЕсли;	
	
	Если Отказ И ВыводитьСообщения Тогда
		Сообщить("Недостаточно полномочий для модификации документа !",СтатусСообщения.Важное);	
	КонецЕсли;	
	Возврат НЕ Отказ;
КонецФункции // МожноИзменятьДокумент()

//крохин начало 14.06.2012
Функция МожноИзменятьКассовыйДокумент(ДокОбъект) Экспорт
	//проверим наличие непустых листов с датой больше или равной документу
	 //крохин начало 15.06.2012
	//Вэймарт может изменять кассу текущей датой
	//крохин начало 05.07.2012
	//теперь и Семеновский тоже
	//Если ПараметрыСеанса.ЭтотУзел.Подразделение.код = "SSP-0009" Тогда
	Если ПараметрыСеанса.ЭтотУзел.Подразделение.код = "SSP-0009" ИЛИ ПараметрыСеанса.ЭтотУзел.Подразделение.код = "SSP-0004" Тогда
	//крохин конец 05.07.2012	
	ДатаЛиста = НачалоДня(ДокОбъект.Дата)+24*60*60;
Иначе
	ДатаЛиста = НачалоДня(ДокОбъект.Дата);
	КонецЕсли;
	//крохин конец 15.06.2012
	
	//крохин начало 18.06.2012
	//временно разрешим в офисе
	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
	возврат Истина;
	КонецЕсли;
	//крохин конец 18.06.2012

		Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистКассовойКнигиПКО.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ЛистКассовойКниги.ПКО КАК ЛистКассовойКнигиПКО
	               |ГДЕ
	               |	ЛистКассовойКнигиПКО.Ссылка.Дата >= &ДатаЛиста
	               |	И ЛистКассовойКнигиПКО.Ссылка.Подразделение = &Подразделение
	               |	И ЛистКассовойКнигиПКО.Ссылка.Проведен
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ЛистКассовойКнигиПКО.Ссылка.Дата
	               |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("ДатаЛиста",ДатаЛиста);
	Запрос.УстановитьПараметр("Подразделение",ДокОбъект.Подразделение);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Сообщить("Существует заполненный лист кассовой книги за " + Формат(ДатаЛиста,"ДЛФ=D")+". Редактирование невозможно");
		Возврат Ложь;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистКассовойКнигиРКО.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ЛистКассовойКниги.РКО КАК ЛистКассовойКнигиРКО
	               |ГДЕ
	               |	ЛистКассовойКнигиРКО.Ссылка.Дата >= &ДатаЛиста
	               |	И ЛистКассовойКнигиРКО.Ссылка.Подразделение = &Подразделение
	               |	И ЛистКассовойКнигиРКО.Ссылка.Проведен
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ЛистКассовойКнигиРКО.Ссылка.Дата
	               |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("ДатаЛиста",ДатаЛиста);
	Запрос.УстановитьПараметр("Подразделение",ДокОбъект.Подразделение);
		
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Сообщить("Существует заполненный лист кассовой книги за " + Формат(ДатаЛиста,"ДЛФ=D")+". Редактирование невозможно");
		Возврат Ложь;
	КонецЕсли;
	
    Возврат Истина;
	
КонецФункции
