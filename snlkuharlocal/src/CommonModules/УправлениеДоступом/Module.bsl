//Вернул старую процедуру на место. Буду её использовать для документов с которыми работают напрямую (без ЛН и других подчинённых)
Функция ПроверитьБлокировкуНоменклатуры(ТЧ_Товары, Склад) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборНоменклатура.Номенклатура,
	|	БлокировкаВыдачиВНаборСклады.Склад
	|ИЗ
	|	Документ.БлокировкаВыдачиВНабор.Номенклатура КАК БлокировкаВыдачиВНаборНоменклатура
	|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.Склады КАК БлокировкаВыдачиВНаборСклады
	|		ПО БлокировкаВыдачиВНаборНоменклатура.Ссылка = БлокировкаВыдачиВНаборСклады.Ссылка
	|ГДЕ
	|	БлокировкаВыдачиВНаборСклады.Склад = &Склад
	|	И БлокировкаВыдачиВНаборНоменклатура.Ссылка.Активен";
	Запрос.УстановитьПараметр("Склад", Склад);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 0 Тогда
		Возврат Ложь;
	Иначе
		сз = Новый СписокЗначений;
		Пока Выборка.Следующий() Цикл
			сз.Добавить(Выборка.Номенклатура);
		КонецЦИкла;
		сз1 = Новый СписокЗначений;
		Для Каждого стр из ТЧ_Товары Цикл
			сз1.Добавить(стр.Номенклатура);
		КонецЦикла;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В ИЕРАРХИИ(&сзЗаблокированныхНоменклатур)
		|	И Номенклатура.Ссылка В ИЕРАРХИИ(&сзПереданныхНоменклатур)";
		Запрос.УстановитьПараметр("сзЗаблокированныхНоменклатур", сз);
		Запрос.УстановитьПараметр("сзПереданныхНоменклатур", сз1);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Количество() = 0 Тогда
			Возврат Ложь;
		Иначе
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
КонецФункции
