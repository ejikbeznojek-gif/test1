Функция ЕстьБлокировкаНоменклатуры(Накладная,ИмяТЧ="Товары") Экспорт
	Если НЕ ЗначениеЗаполнено(Накладная) Тогда Возврат Ложь КонецЕсли;
	//++Данилова Е.В. 28.01.2026  SNL-109
	
	ИмяОбъекта = Накладная.Метаданные().Имя; 
	ВидыОбъектовИсключения = Новый Массив;
	ВидыОбъектовИсключения.Добавить("Комплектация"); 
	ВидыОбъектовИсключения.Добавить("ПланНабора");
	ВидыОбъектовИсключения.Добавить("РасходнаяНакладная");
	ВидыОбъектовИсключения.Добавить("Перемещение");
	
	Если ВидыОбъектовИсключения.Найти(ИмяОбъекта) <> Неопределено Тогда
	
		Возврат Ложь; 	
	
	КонецЕсли;
	//--Данилова Е.В. 28.01.2026
	 
	Запрос 			= Новый Запрос;
	//++Данилова Е.В. 28.01.2026
	//Запрос.Текст 	= "
	//|ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|	Номенклатура	
	//|ПОМЕСТИТЬ СписокЗаблокированнойНоменклатуры
	//|ИЗ
	//|	Документ.БлокировкаВыдачиВНабор.Номенклатура КАК БлокировкаВыдачиВНаборНоменклатура
	//|ПОЛНОЕ СОЕДИНЕНИЕ 
	//|	Документ.БлокировкаВыдачиВНабор.Склады КАК БлокировкаВыдачиВНаборСклады
	//|ПО 
	//|	БлокировкаВыдачиВНаборНоменклатура.Ссылка = БлокировкаВыдачиВНаборСклады.Ссылка
	//|ГДЕ
	//|	БлокировкаВыдачиВНаборСклады.Склад = &Склад
	//|	И БлокировкаВыдачиВНаборНоменклатура.Ссылка.Активен
	//|ИНДЕКСИРОВАТЬ ПО 
	//|	Номенклатура
	//|;
	//|ВЫБРАТЬ
	//|	Номенклатура
	//|ИЗ
	//|	Документ."+Накладная.Метаданные().Имя+"."+ИмяТЧ+"
	//|ГДЕ
	//|	Ссылка=&Ссылка
	//|	И Количество>0
	//|	И Номенклатура В ИЕРАРХИИ (ВЫБРАТЬ Номенклатура ИЗ СписокЗаблокированнойНоменклатуры)
	//|";
	
	Запрос.Текст 	= 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ СписокЗаблокированнойНоменклатуры
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&ТекущаяДата, Склад = &Склад ИЛИ Склад = &СкладФизСклад) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ."+Накладная.Метаданные().Имя+"."+ИмяТЧ+" КАК РасходнаяНакладнаяТовары
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
	|	И РасходнаяНакладнаяТовары.Количество > 0
	|	И РасходнаяНакладнаяТовары.Номенклатура В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				СписокЗаблокированнойНоменклатуры.Номенклатура
	|			ИЗ
	|				СписокЗаблокированнойНоменклатуры)";

	
	
	Запрос.УстановитьПараметр("Склад",	ПолучитьРеквизитыШапки(Накладная,Новый Структура("Склад")).Склад);
	запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	Запрос.УстановитьПараметр("СкладФизСклад",	ПолучитьРеквизитыШапки(Накладная,Новый Структура("Склад")).Склад.ФизическийСклад);
	//--Данилова Е.В. 28.01.2026
	Запрос.УстановитьПараметр("Ссылка",	Накладная);
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Возврат (Выборка.Количество() > 0);	
КонецФункции
