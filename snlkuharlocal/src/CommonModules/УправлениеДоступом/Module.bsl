Функция УстановитьОграниченияРеквизитовВМодулеОбъекта(Объект, СтруктураПроверки) Экспорт
	
	ПараметрыПроверки = Новый Соответствие;
	
	СтруктураВозврата = Новый Структура;
	
	Для Каждого Элемент ИЗ СтруктураПроверки Цикл
		
		Если Найти(Элемент.Ключ, "Полномочие") > 0 Тогда
			
			Если ТипЗнч(Элемент.Значение) = Тип("Строка") Тогда
				
				Успешно = ОбщегоНазначения_ПИ.СуществуетПолномочие(Элемент.Значение);
				
				Если НЕ Успешно Тогда
					Возврат СтруктураВозврата;
				КонецЕсли;
				
				Полномочие = ПланыВидовХарактеристик.ПолномочияПользователей[Элемент.Значение];
				
				Если Полномочие.Пустая() Тогда
					Возврат СтруктураВозврата;
				КонецЕсли;
				
				СтруктураПроверки.Вставить(Элемент.Ключ, Полномочие);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураДоступностиПолей = ПолучитьТаблицуДоступностиПолей(Неопределено, Объект);
	ТД = СтруктураДоступностиПолей.ТД;
	Ограничение = СтруктураДоступностиПолей.Ограничение;
	
	Если Ограничение <> Неопределено Тогда
		СтруктураВозврата.Вставить("Ограничение", Ограничение);	
	КонецЕсли;
	
	// ПО УМОЛЧАНИЮ, ОТКАЗ = ИСТИНА
	Если ТД.Количество() = 0 Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Для Каждого Элемент ИЗ СтруктураПроверки Цикл
		
		НайденнаяСтрока = ТД.Найти(Элемент.Значение);
		Если НайденнаяСтрока <> Неопределено Тогда
			ПараметрыПроверки.Вставить(Элемент.Значение, Ложь);
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураВозврата.Вставить("ПараметрыПроверки", ПараметрыПроверки);
	
	Возврат СтруктураВозврата; // Отказ = Истина;
	
КонецФункции

// Проверяет наличие реквизита или свойства у произвольного объекта без обращения к метаданным.
//
// Параметры:
//  Объект       - Произвольный - объект, у которого нужно проверить наличие реквизита или свойства;
//  ИмяРеквизита - Строка       - имя реквизита или свойства.
//
// Возвращаемое значение:
//  Булево - Истина, если есть.
//
Функция ЕстьРеквизитИлиСвойствоОбъекта(Объект, ИмяРеквизита) Экспорт
	
	КлючУникальности   = Новый УникальныйИдентификатор;
	СтруктураРеквизита = Новый Структура(ИмяРеквизита, КлючУникальности);
	ЗаполнитьЗначенияСвойств(СтруктураРеквизита, Объект);
	
	Возврат СтруктураРеквизита[ИмяРеквизита] <> КлючУникальности;
	
КонецФункции

