Функция ПолучитьТаблицуДоступностиПолей(Форма = Неопределено, Объект = Неопределено, ТипФормы = "")
	
	СтруктураДоступности = Новый Структура("Ограничение, ТД");
	
	Если Форма <> Неопределено Тогда
		
		Если ЕстьРеквизитИлиСвойствоОбъекта(Форма, "Объект") Тогда
			ЭтоФормаОбъекта = Истина;
			Объект = ДанныеФормыВЗначение(Форма.Объект, Тип(ТипФормы));
		ИначеЕсли ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ЭтотОбъект") Тогда
			ЭтоФормаОбъекта = Истина;
			Объект = Форма.ЭтотОбъект;
		Иначе
			ЭтоФормаОбъекта = Ложь;
		КонецЕсли;
		
		Если НЕ ЭтоФормаОбъекта Тогда
			
			Если Форма.ЭлементыФормы.Найти("Список") <> Неопределено Тогда
				ЭтоФормаСписка = Истина;
				ИмяСписка = "Список";
			ИначеЕсли Форма.ЭлементыФормы.Найти("СправочникСписок") <> Неопределено Тогда
				ЭтоФормаСписка = Истина;
				ИмяСписка = "СправочникСписок";
			Иначе
				ЭтоФормаСписка = Ложь;
			КонецЕсли;
			
			Если ЭтоФормаСписка Тогда
				ТекДанные = Форма.ЭлементыФормы[ИмяСписка].ТекущиеДанные;
				Если ТекДанные <> Неопределено Тогда
					Объект = ТекДанные.Ссылка;
				Иначе
					СтруктураВозврата = ПолучитьИмяОбъектаМетаданныхПоИмениСписка(Форма[ИмяСписка]);
					Запрос = Новый Запрос;
					Запрос.Текст =
					"ВЫБРАТЬ ПЕРВЫЕ 1
					|	ОбъектСсылка.Ссылка КАК Ссылка
					|ИЗ
					|" + СтруктураВозврата.ИмяОбъектаСтрокой + " КАК ОбъектСсылка
					|ГДЕ
					|	НЕ ОбъектСсылка.ПометкаУдаления
					|"+ ?(СтруктураВозврата.ЭтоСправочник = Истина, "И НЕ ОбъектСсылка.ЭтоГруппа", "") + "
					|";
					
					УстановитьПривилегированныйРежим(Истина);
					Выборка = Запрос.Выполнить().Выбрать();
					УстановитьПривилегированныйРежим(Ложь);
					
					Если Выборка.Следующий() Тогда
						Объект = Выборка.Ссылка;	
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	НеПроверять = ?(Форма = Неопределено, Истина, Ложь);
	
	Ограничение = ПолучитьОграниченияДоступа(Объект);
			
	Если Ограничение <> Неопределено Тогда
		СообщениеОтладки("Ограничение доступа: "+Ограничение.ИД_СтрокиУсловий);
		СтруктураДоступности.Вставить("Ограничение", Ограничение);
		СтруктураДоступности.Вставить("ТД", ЗаполнитьТаблицуДоступностиПоОграничению(Ограничение,НеПроверять));
	Иначе
		СтруктураДоступности.Вставить("Ограничение", Неопределено);
		СтруктураДоступности.Вставить("ТД", ПолучитьТаблицуДоступностиПолей_Старая(Объект));
	КонецЕсли;
	
	Возврат СтруктураДоступности;
	
КонецФункции

