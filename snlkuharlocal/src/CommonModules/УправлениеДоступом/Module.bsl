Функция УстановитьДоступностьРеквизитов(Форма, ТипФормы = "") Экспорт
	
	СтруктураДоступности = ПолучитьТаблицуДоступностиПолей(Форма, Неопределено, ТипФормы);
	ТД = СтруктураДоступности.ТД;
	
	Если ТД.Количество()=0 Тогда
		#ЕСЛИ КЛИЕНТ ТОГДА
		Сообщить("Невозможно определить права доступа объекта !");
		#КОНЕЦЕСЛИ
		Форма.ТолькоПросмотр=Истина;
		Возврат СтруктураДоступности;
	КонецЕсли;
	
	Если ЕстьРеквизитИлиСвойствоОбъекта(Форма, "Объект") Тогда
		Объект = ДанныеФормыВЗначение(Форма.Объект, Тип(ТипФормы));
		МетаОбъект	= Объект.Метаданные();
		ТипОбъекта	= ТипОбъекта(Объект);
		ЭлементыФормы = Форма.Элементы;
	ИначеЕсли ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ЭтотОбъект") Тогда
		Объект		= Форма.ЭтотОбъект;
		МетаОбъект	= Объект.Метаданные();
		ТипОбъекта	= ТипОбъекта(Объект);
		ЭлементыФормы = Форма.ЭлементыФормы;
	Иначе
		Возврат СтруктураДоступности;
	КонецЕсли;
	
	Для Каждого СтрокаТД Из ТД Цикл	
		Если СтрокаТД.ТипРаздела="Шапка" Тогда
			
			Если СтрокаТД.ИмяРеквизита="*.*" Тогда //Все				
				Для Каждого ЭУ Из ЭлементыФормы Цикл
					
					Если ТипЗнч(ЭУ) = Тип("ГруппаФормы") ИЛИ ТипЗнч(ЭУ) = Тип("ДекорацияФормы")
						ИЛИ ТипЗнч(ЭУ) = Тип("КнопкаФормы") Тогда
						Продолжить;
					КонецЕсли;
					
					// ЭУ.Данные, УФ - ЭУ.Имя
					Попытка
						Данные = ЭУ.Данные;
					Исключение
						Данные = ЭУ.Имя;
					КонецПопытки;
					
					ЭтоРеквизитОбъекта = Ложь;
					Если (НЕ ПустаяСтрока(Данные) И Найти("Номер,Дата,Код,Наименование,Родитель,Владелец",Данные)<>0) ИЛИ 
						МетаОбъект.Реквизиты.Найти(Данные) <> Неопределено  Тогда
						ЭтоРеквизитОбъекта = Истина;					
					//ИначеЕсли ЭУ.ИзменяетДанные Тогда
					//	ЭтоРеквизитОбъекта=Ложь;	
					Иначе //не реквизит и данных не меняет на фиг сдался
						Продолжить;
					КонецЕсли; 
					
					Если СтрокаТД.ИмяРаздела="Реквизиты" И НЕ ЭтоРеквизитОбъекта Тогда Продолжить КонецЕсли; 
					Если СтрокаТД.ИмяРаздела="ЭУ" И ЭтоРеквизитОбъекта Тогда Продолжить КонецЕсли; 
					
					УстановитьПараметрыДоступаЭУ(Форма,ЭУ,СтрокаТД);					
				КонецЦикла; 
				ЭлементУправления=Неопределено;
			Иначе
				ЭлементУправления=ЭлементыФормы.Найти(СтрокаТД.ИмяРеквизита);
			КонецЕсли;			
		ИначеЕсли СтрокаТД.ТипРаздела="ТЧ" Тогда
			Если ТипОбъекта="Справочник" И Объект.Метаданные().Имя <> "Номенклатура" Тогда
				Если МетаОбъект.ТабличныеЧасти.ВидыДопОбработок.Использование=Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляГруппы И НЕ Объект.ЭтоГруппа Тогда
					Возврат СтруктураДоступности;
				ИначеЕсли МетаОбъект.ТабличныеЧасти.ВидыДопОбработок.Использование=Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляЭлемента И Объект.ЭтоГруппа Тогда
					Возврат СтруктураДоступности;				
				КонецЕсли;			
			КонецЕсли; 
			
			Если СтрокаТД.ИмяРеквизита="*.*" Тогда //Все
				Для Каждого КолонкаТЧ Из ЭлементыФормы[СтрокаТД.ИмяРаздела].Колонки Цикл
					УстановитьПараметрыДоступаЭУ(Форма,КолонкаТЧ,СтрокаТД);							
				КонецЦикла;		
				ЭлементУправления=Неопределено;				
				
				ИмяКП="кп"+СтрокаТД.ИмяРаздела;
				
				ЭУ=ЭлементыФормы.Найти(СтрокаТД.ИмяРаздела);
				Если ЭУ <> Неопределено Тогда
					ЭУ.ИзменятьСоставСтрок = СтрокаТД.ИзменятьСоставСтрок;				
				КонецЕсли;				
				
				кпТЧ = ЭлементыФормы.Найти(ИмяКП);
				Если кпТЧ <> Неопределено Тогда					
					Если кпТЧ.Кнопки.Найти("ПодборПоУмолчанию")<>Неопределено Тогда
						кпТЧ.Кнопки.ПодборПоУмолчанию.Доступность		=СтрокаТД.ИзменятьСоставСтрок;				
						Для Каждого Кнопка Из кпТЧ.Кнопки.ПодменюПодбор.Кнопки Цикл
							Кнопка.Доступность							=СтрокаТД.ИзменятьСоставСтрок;				
						КонецЦикла;
					КонецЕсли; 
					
					Если кпТЧ.Кнопки.Найти("ЗаполнитьПоУмолчанию")<>Неопределено Тогда
						кпТЧ.Кнопки.ЗаполнитьПоУмолчанию.Доступность	=СтрокаТД.ИзменятьСоставСтрок;				
						
						Для Каждого Кнопка Из кпТЧ.Кнопки.ПодменюЗаполнить.Кнопки Цикл
							Кнопка.Доступность							=СтрокаТД.ИзменятьСоставСтрок;				
						КонецЦикла;				
					КонецЕсли;			
				КонецЕсли;				
			Иначе				
				ЭлементУправления = ЭлементыФормы[СтрокаТД.ИмяРаздела].Колонки[СтрокаТД.ИмяРеквизита];
			КонецЕсли;
		КонецЕсли;	
		
		Если ЭлементУправления <> Неопределено Тогда
			УстановитьПараметрыДоступаЭУ(Форма,ЭлементУправления,СтрокаТД);
		КонецЕсли;		
	КонецЦикла;
	
	Возврат СтруктураДоступности;
	
КонецФункции 


Функция ПроверитьУсловие(НастройкаПрав,СтрокаОтбора,ДляНовых,Объект)
	// условие используется только для новых объектов если объект существует значит флай-вей
	Если ДляНовых Тогда
		Возврат Объект.Ссылка.Пустая()	
	КонецЕсли; 
	
	Постр=Новый ПостроительОтчета;
	
	НастройкаПравОбъект=НастройкаПрав.ПолучитьОбъект();
	НастройкаПравОбъект.НастроитьПостроитель(Постр,СтрокаОтбора);
	
	Постр.ВыбранныеПоля.Очистить();
	Постр.ВыбранныеПоля.Добавить("Ссылка");
	
	Постр.Параметры.Вставить("Ссылка",Объект.Ссылка);	
	Постр.Выполнить();	
	
	Если Постр.Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;	
	КонецЕсли;	
КонецФункции // ПроверитьУсловие()
 
Функция ПолучитьОграниченияДоступа(Объект, НеПроверятьТипУзла = Ложь)
	
	Тип		= ТипОбъекта(Объект);
	Вид		= Объект.Метаданные().Имя;
	
	ТипУзла	= ПланыОбмена.Основной.ЭтотУзел().ТипУзла;
	
	Запрос=Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УсловияОбъекта.ТипУзла КАК ТипУзла,
	|	УсловияОбъекта.Ссылка КАК НастройкаПрав,
	|	УсловияОбъекта.Ссылка.Тип КАК Тип,
	|	УсловияОбъекта.Ссылка.Вид КАК Вид,
	|	УсловияОбъекта.ДляНовых КАК ДляНовых,
	|	УсловияОбъекта.СтрокаОтбора КАК СтрокаОтбора,
	|	УсловияОбъекта.ПредставлениеОтбора КАК ПредставлениеОтбора,
	|	УсловияОбъекта.ИД_Строки КАК ИД_СтрокиУсловий,
	|	УсловияОбъекта.Приоритет КАК Приоритет,
	|	УсловияОбъекта.ПроизвольноеУсловие КАК ПроизвольноеУсловие
	|ИЗ
	|	Справочник.НастройкиДоступа.УсловияОбъекта КАК УсловияОбъекта
	|ГДЕ
	|	УсловияОбъекта.Ссылка.Тип = &Тип
	|	И УсловияОбъекта.Ссылка.Вид = &Вид
	|	И НЕ УсловияОбъекта.Ссылка.ПометкаУдаления
	|	" + ?(НеПроверятьТипУзла, "", "И УсловияОбъекта.ТипУзла = &ТипУзла") + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	УсловияОбъекта.Приоритет УБЫВ";
	 
	 Запрос.УстановитьПараметр("Тип",Тип);
	 Запрос.УстановитьПараметр("Вид",Вид);
	 Запрос.УстановитьПараметр("ТипУзла",ТипУзла);
	 
	 Выборка = Запрос.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл		 
		 Если ПроверитьУсловие(Выборка.НастройкаПрав,Выборка.СтрокаОтбора,Выборка.ДляНовых,Объект) Тогда
			 Возврат Новый Структура("СсылкаНаПравило,ИД_СтрокиУсловий,ТипУзла,ПроизвольноеУсловие",
			 	Выборка.НастройкаПрав,Выборка.ИД_СтрокиУсловий,Выборка.ТипУзла,Выборка.ПроизвольноеУсловие);		 
		 КонецЕсли; 
	 КонецЦикла;
	 
	 Возврат Неопределено;
КонецФункции // ПолучитьОграниченияДоступа()

Функция ЗаполнитьТаблицуДоступностиПоОграничению(Ограничение, НеПроверятьСтрокиУсловий = Ложь)
	ТД=Новый ТаблицаЗначений;
	
	ТД.Колонки.Добавить("ТипРаздела");
	ТД.Колонки.Добавить("ИмяРаздела");
	ТД.Колонки.Добавить("ИмяРеквизита");
	ТД.Колонки.Добавить("Полномочие");
	ТД.Колонки.Добавить("Доступность");
	ТД.Колонки.Добавить("Видимость");
	ТД.Колонки.Добавить("ВозможныеЗначения");
	ТД.Колонки.Добавить("ТолькоПросмотр");
	ТД.Колонки.Добавить("ИзменятьСоставСтрок");
	
	Запрос=Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПраваДоступа.Роль КАК Роль,
	|	ПраваДоступа.Полномочие КАК Полномочие,
	|	ПраваДоступа.Доступность КАК Доступность,
	|	ПраваДоступа.Видимость КАК Видимость,
	|	НЕ ПраваДоступа.Редактирование КАК ТолькоПросмотр,
	|	НЕ ПраваДоступа.НеИзменятьСоставСтрок КАК ИзменятьСоставСтрок,
	|	ПраваДоступа.ЗагрузкаПриОбмене КАК ЗагрузкаПриОбмене,
	|	ПраваДоступа.ВозможныеЗначения КАК ВозможныеЗначения,
	|	Реквизиты.ТипРаздела КАК ТипРаздела,
	|	Реквизиты.ИмяРаздела КАК ИмяРаздела,
	|	Реквизиты.ИмяРеквизита КАК ИмяРеквизита
	|ИЗ
	|	Справочник.НастройкиДоступа.ПраваДоступа КАК ПраваДоступа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			НастройкиДоступаРеквизиты.ТипРаздела КАК ТипРаздела,
	|			НастройкиДоступаРеквизиты.ИмяРаздела КАК ИмяРаздела,
	|			НастройкиДоступаРеквизиты.ИмяРеквизита КАК ИмяРеквизита,
	|			НастройкиДоступаРеквизиты.ИД_Строки КАК ИД_Строки
	|		ИЗ
	|			Справочник.НастройкиДоступа.Реквизиты КАК НастройкиДоступаРеквизиты
	|		ГДЕ
	|			НастройкиДоступаРеквизиты.Ссылка = &СсылкаНаПравило) КАК Реквизиты
	|		ПО ПраваДоступа.ИД_СтрокиРеквизитов = Реквизиты.ИД_Строки
	|ГДЕ
	|	ПраваДоступа.Ссылка = &СсылкаНаПравило
	|	И (ПраваДоступа.Роль = ""*.*""
	|			ИЛИ ПраваДоступа.Роль В (&ДоступныеРоли))
	|	" + ?(НеПроверятьСтрокиУсловий, "", "И ПраваДоступа.ИД_СтрокиУсловий = &ИД_СтрокиУсловий") + "
	|УПОРЯДОЧИТЬ ПО ПраваДоступа.НомерСтроки";
	
	ДоступныеРоли=Новый Массив;
	Для Каждого Роль Из Метаданные.Роли Цикл
		Если РольДоступна(Роль.Имя) Тогда
			ДоступныеРоли.Добавить(Роль.Имя);			
		КонецЕсли;			
	КонецЦикла;	
	
	Запрос.УстановитьПараметр("СсылкаНаПравило",	Ограничение.СсылкаНаПравило);
	Запрос.УстановитьПараметр("ИД_СтрокиУсловий",	Ограничение.ИД_СтрокиУсловий);
	
	Запрос.УстановитьПараметр("ДоступныеРоли",		ДоступныеРоли);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		//контроль полномочий
		Если НЕ Выборка.Полномочие.Пустая() И НЕ ПолучитьПолномочиеПользователя(Выборка.Полномочие) Тогда Продолжить КонецЕсли;			
		
		СтрокаТД=ТД.Добавить();		
		ЗаполнитьЗначенияСвойств(СтрокаТД,Выборка);			
	КонецЦикла;
	
	Если ТД.Количество()=0 Тогда
		ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"*.*"				,,,Истина);	
	КонецЕсли; 
	
	Возврат ТД;	
КонецФункции //ЗаполнитьтаблицуДоступностиПоОграничению(Ограничение)
 
