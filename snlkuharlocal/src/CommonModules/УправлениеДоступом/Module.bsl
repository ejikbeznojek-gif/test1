Функция ПолучитьТаблицуДоступностиПолей_Старая(Объект = Неопределено)
	
	Если ТипЗнч(Объект) = Тип("Форма") Тогда
		ДокОбъект = Объект.ЭтотОбъект;
	Иначе
		ДокОбъект = Объект;
	КонецЕсли;
	
	Вид=ДокОбъект.Метаданные().Имя;	
	ЭтотУзел=ПланыОбмена.Основной.ЭтотУзел();
	
	ТД=Новый ТаблицаЗначений;
	ТД.Колонки.Добавить("ТипРаздела");
	ТД.Колонки.Добавить("ИмяРаздела");
	ТД.Колонки.Добавить("ИмяРеквизита");
	ТД.Колонки.Добавить("Полномочие", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ПолномочияПользователей"));
	ТД.Колонки.Добавить("Доступность");
	ТД.Колонки.Добавить("Видимость");
	ТД.Колонки.Добавить("ТолькоПросмотр");
	ТД.Колонки.Добавить("ИзменятьСоставСтрок",Новый ОписаниеТипов("Булево"));
	ТД.Колонки.Добавить("ВозможныеЗначения");
		
	Если Вид="РасходнаяНакладная" ИЛИ Вид="Перемещение" Тогда		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ИнтегральнаяИБ Тогда			
		ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда						
				Если ДокОбъект.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе Тогда
						
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"*.*"				,,,Истина);					
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"Контрагент"		,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"ЛевыйКонтрагент"	,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"Договор"			,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"ПунктДоставки"		,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"СкладПолучатель"	,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"Реквизиты",	"Комментарий"		,,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Шапка"	,	"ЭУ",			"тЦеныВалюта"		,,,Ложь);
					
					ДобавитьВТаблицуДоступности(ТД,"ТЧ"		,	"Товары",		"*.*"				,,Истина);					
					ДобавитьВТаблицуДоступности(ТД,"ТЧ"		,	"Товары",		"Цена"				,,,Ложь);
				КонецЕсли;
			Иначе
			КонецЕсли;			
		ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.Склад Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") Тогда				
			ИначеЕсли РольДоступна("ОператорОфис") Тогда						
			ИначеЕсли РольДоступна("ОператорСклад") Тогда
				//шапка
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"*.*"				,,,Истина);
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"Комментарий"		,,,Ложь);
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"Отгружен"			,,,Ложь);
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"СостояниеНакладной",,,Ложь);
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"Дата"				,,,Ложь);
				ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"ДатаОтгрузки"		,,,Ложь);
				
				//ТЧ Товары				
				ДобавитьВТаблицуДоступности(ТД,"ТЧ"			,	"Товары"	,	"*.*"				,,Истина,,Ложь);				
				ДобавитьВТаблицуДоступности(ТД,"ТЧ"			,	"Товары"	,	"Количество"		,,Ложь);				
			Иначе                                                           
			КонецЕсли;	
		КонецЕсли;		
	ИначеЕсли Вид="ПриходнаяНакладная" Тогда
		//ДобавитьВТаблицуДоступности(ТД,ИмяРеквизита,ИмяТЧ="",Доступность=Неопределено,ТолькоПросмотр=Неопределено,Видимость=Неопределено,ИзменятьСоставСтрок=Неопределено)
		
		Если ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.ИнтегральнаяИБ Тогда			
		ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			Если РольДоступна("Администратор") Тогда
			ИначеЕсли РольДоступна("Менеджер") ИЛИ РольДоступна("ОператорОфис") Тогда						
				Если ДокОбъект.СостояниеНакладной<>Перечисления.СостоянияНакладной.ВРаботе Тогда
					ДобавитьВТаблицуДоступности(ТД,"__Все",,,Истина);					
					ДобавитьВТаблицуДоступности(ТД,"Контрагент",,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"ЛевыйКонтрагент",,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Договор",,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"ПунктДоставки",,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"Комментарий",,,Ложь);
					ДобавитьВТаблицуДоступности(ТД,"тЦеныВалюта",,,Ложь);
					
					ДобавитьВТаблицуДоступности(ТД,"__Все","Товары",,Истина);					
					ДобавитьВТаблицуДоступности(ТД,"Цена","Товары",,Ложь,);
				КонецЕсли;
			Иначе
			КонецЕсли;			
		ИначеЕсли ЭтотУзел.ТипУзла=Перечисления.ТипУзлаИБ.Склад Тогда
			Если РольДоступна("Администратор") Тогда		
			ИначеЕсли РольДоступна("Менеджер") Тогда				
			ИначеЕсли РольДоступна("ОператорОфис") Тогда						
			ИначеЕсли РольДоступна("ОператорСклад") Тогда
				//ТЧ Товары				
				ДобавитьВТаблицуДоступности(ТД,"__Все","Товары",,Истина,);
				ДобавитьВТаблицуДоступности(ТД,"__ИзменятьСоставСтрок","Товары",,,,Ложь);
				ДобавитьВТаблицуДоступности(ТД,"Количество","Товары",,Ложь,);								
				
				//шапка
				ДобавитьВТаблицуДоступности(ТД,"__Все",,,Истина,);
				ДобавитьВТаблицуДоступности(ТД,"Комментарий",,,Ложь,);
				ДобавитьВТаблицуДоступности(ТД,"Отгружен",,,Ложь,);
				ДобавитьВТаблицуДоступности(ТД,"СостояниеНакладной",,,Ложь,);
				ДобавитьВТаблицуДоступности(ТД,"Дата",,,Ложь,);
				ДобавитьВТаблицуДоступности(ТД,"ДатаОтгрузки",,,Ложь,);				
			Иначе
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;

	
	Если ТД.Количество()=0 Тогда
		ДобавитьВТаблицуДоступности(ТД,"Шапка"		,	"Реквизиты"	,	"*.*"				,,,Истина);	
	КонецЕсли; 
	
	Возврат ТД;
КонецФункции // ПолучитьНедоступныеПоля()

 
Функция ПроверкаДоступаККассовомуДокументу(Форма) Экспорт
	Отказ			= Ложь;
	ТолькоПросмотр	= Форма.ТолькоПросмотр;
	Описание		= "";
	
	ДокОбъект		= Форма.ЭтотОбъект;
	
	Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		ВидДокумента=ДокОбъект.Метаданные().Имя;
		
		Если ВидДокумента="ДвиженияДенежныхСредств" Тогда
			ИмяРеквизитаКассы="БанковскийСчет";
		ИначеЕсли ВидДокумента="ПереводСредств" Тогда
			ИмяРеквизитаКассы="Источник_Касса";
		Иначе
			ИмяРеквизитаКассы="Касса";			
		КонецЕсли;		
		
		Касса	= ДокОбъект[ИмяРеквизитаКассы];
		Если Касса=Неопределено Тогда Возврат НЕ Отказ КонецЕсли; 
		
		Если Касса.ПраваДоступа.Количество()>0 Тогда			
			СтрокаДК=Касса.ПраваДоступа.Найти(ПараметрыСеанса.Пользователь,"Пользователь");
			Если СтрокаДК=Неопределено ИЛИ СтрокаДК.ПросмотрДокументов=Ложь Тогда
				Отказ	=Истина;
				Описание="Недостаточно прав доступа на просмотр документов по данной кассе !";
			Иначе			
				Если НЕ СтрокаДК.РедактированиеДокументов Тогда
					ТолькоПросмотр	=Истина;
					Описание		="Недостаточно прав доступа для изменения документов по данной кассе !";			
				КонецЕсли; 
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ДокОбъект.Автор<>ПараметрыСеанса.Пользователь И НЕ ПолучитьПолномочиеПользователя("РедактированиеЧужихВыписок") И НЕ Отказ И НЕ ТолькоПросмотр Тогда		
		ТолькоПросмотр	= Истина;	
		Описание		= Описание+?(ЗначениеЗаполнено(Описание),Символы.ПС,"")+"Недостаточно прав для изменения документов созданных другим пользователем !";			
	КонецЕсли;
	
	Форма.ТолькоПросмотр=ТолькоПросмотр;
	
	Если ЗначениеЗаполнено(Описание) Тогда
		#ЕСЛИ КЛИЕНТ ТОГДА
		Предупреждение(Описание);
		#КОНЕЦЕСЛИ
	КонецЕсли;
	
	Возврат НЕ Отказ;
КонецФункции//ПроверкаДоступаККассовомуДокументу(ДокОбъект,Отказ)

