Функция ПолучитьИмяОбъектаМетаданныхПоИмениСписка(Знач ИмяСписка) Экспорт
	
	СтруктураВозврата = Новый Структура("ИмяОбъектаСтрокой, ЭтоСправочник, ЭтоДокумент", "", Ложь, Ложь);
	
	ИмяСпискаСтрокой = СокрЛП(ИмяСписка);
	
	ЭтоСправочник = Ложь; ЭтоДокумент = Ложь;
	
	Если Найти(ИмяСпискаСтрокой, "Справочник") > 0  Тогда
		ИмяОбъектаСтрокой = "Справочник.";
		СтруктураВозврата.Вставить("ЭтоСправочник", Истина);
	ИначеЕсли Найти(ИмяСпискаСтрокой, "Документ") Тогда
		ИмяОбъектаСтрокой = "Документ.";
		СтруктураВозврата.Вставить("ЭтоДокумент", Истина);
	КонецЕсли;
	
	ПозицияТочки = Найти(ИмяСпискаСтрокой, ".");
	ИмяОбъекта = Прав(ИмяСпискаСтрокой, СтрДлина(ИмяСпискаСтрокой) - ПозицияТочки);
	
	ИмяОбъектаСтрокой = ИмяОбъектаСтрокой + ИмяОбъекта;
	СтруктураВозврата.Вставить("ИмяОбъектаСтрокой", ИмяОбъектаСтрокой);
	
	Возврат СтруктураВозврата;
	
КонецФункции