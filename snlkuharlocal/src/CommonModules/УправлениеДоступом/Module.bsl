Функция ПроверитьБлокировкуВыдачейВНабор (ДокОбъект) Экспорт 
		//ДокОбъект=Документы.РасходнаяНакладная.НайтиПоНомеру().ПолучитьОбъект();
	
	Запрос=новый запрос;
	Запрос.Текст=	
 	"ВЫБРАТЬ РАЗЛИЧНЫЕ
 	|	БлокировкаВыдачиВНаборНоменклатура.Номенклатура,
 	|	БлокировкаВыдачиВНаборСклады.Склад,
 	|	БлокировкаВыдачиВНаборСостоянияЗапрета.Состояние КАК СостояниеБлокировки,
 	|	БлокировкаВыдачиВНаборСостоянияРезервирования.Состояние КАК СостояниеРезервирования
 	|ИЗ
 	|	Документ.БлокировкаВыдачиВНабор.Номенклатура КАК БлокировкаВыдачиВНаборНоменклатура
 	|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.Склады КАК БлокировкаВыдачиВНаборСклады
 	|		ПО БлокировкаВыдачиВНаборНоменклатура.Ссылка = БлокировкаВыдачиВНаборСклады.Ссылка
 	|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.СостоянияЗапрета КАК БлокировкаВыдачиВНаборСостоянияЗапрета
 	|		ПО БлокировкаВыдачиВНаборНоменклатура.Ссылка = БлокировкаВыдачиВНаборСостоянияЗапрета.Ссылка
 	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.СостоянияРезервирования КАК БлокировкаВыдачиВНаборСостоянияРезервирования
 	|		ПО БлокировкаВыдачиВНаборНоменклатура.Ссылка = БлокировкаВыдачиВНаборСостоянияРезервирования.Ссылка
 	|ГДЕ
 	|	БлокировкаВыдачиВНаборСклады.Склад = &Склад
 	|	И БлокировкаВыдачиВНаборНоменклатура.Ссылка.Активен
 	|	И БлокировкаВыдачиВНаборНоменклатура.Номенклатура В(&Номенклатура)";
	Запрос.УстановитьПараметр("Склад", ДокОбъект.Склад);
	Запрос.УстановитьПараметр("Номенклатура", ДокОбъект.Товары.ВыгрузитьКолонку("Номенклатура"));
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()>0 тогда
		Список=результат.Скопировать();
		Список.Свернуть("СостояниеРезервирования");
		Возврат Список;		
	иначе
		 возврат Неопределено
	КонецЕсли;


 КонецФункции
