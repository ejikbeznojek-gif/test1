Функция УправляемыйРежим() Экспорт
    Если НЕ ТранзакцияАктивна() Тогда
        Возврат Ложь;
	КонецЕсли;    
	
	Если Метаданные.РежимУправленияБлокировкойДанных = Метаданные.СвойстваОбъектов.РежимУправленияБлокировкойДанныхПоУмолчанию.Управляемый Тогда
		Возврат Истина;       
	ИначеЕсли Метаданные.РежимУправленияБлокировкойДанных = Метаданные.СвойстваОбъектов.РежимУправленияБлокировкойДанныхПоУмолчанию.Автоматический Тогда	
		Возврат Ложь;
	КонецЕсли;	
	
	Попытка
        НачатьТранзакцию(РежимУправленияБлокировкойДанных.Автоматический);
        ЗафиксироватьТранзакцию();
    Исключение
        Возврат Истина;
    КонецПопытки; 
    Возврат Ложь;	
КонецФункции
Функция БлокировкаПоОбъекту(Ссылка,Отказ=Ложь) Экспорт  
	Если Ссылка = Неопределено Тогда 
		Отказ = Истина;
		Возврат Ложь;
	КонецЕсли;             
	ВидОбъекта = Ссылка.Метаданные().Имя;    
	Если ПроведениеС.УправляемыйРежим() Тогда
		Блокировка = Новый БлокировкаДанных; 
		
		Если ВидОбъекта = "АвансовыйОтчет" Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	Док.Сотрудник КАК Контрагент,
			                      |	Док.Договор КАК Договор,
			                      |	ДокТч.Подразделение КАК Подразделение,
			                      |	ДокТч.СтатьяЗатрат КАК СтатьяЗатрат
			                      |ИЗ
			                      |	Документ.АвансовыйОтчет КАК Док
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АвансовыйОтчет.Затраты КАК ДокТч
			                      |		ПО (ДокТч.Ссылка = Док.Ссылка)
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Затраты");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Подразделение", "Подразделение");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СтатьяЗатрат", "СтатьяЗатрат");
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Взаиморасчеты");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Контрагент", "Контрагент");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Договор", "Договор");
		ИначеЕсли ВидОбъекта = "АктПриемки" Тогда  //не закончен
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	Док.Номенклатура КАК Номенклатура
			                      |ИЗ
			                      |	Документ.АктПриемки.Товары КАК Док
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка
			                      |	И НЕ Док.Отправлено = Док.Принято");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РасхожденияПоАкту");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
		ИначеЕсли ВидОбъекта = "Взаимозачет" Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	Док.Контрагент_Дебитор КАК Контрагент,
			                      |	Док.Договор_Дебитор КАК Договор
			                      |ИЗ
			                      |	Документ.Взаимозачет КАК Док
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка
			                      |
			                      |ОБЪЕДИНИТЬ
			                      |
			                      |ВЫБРАТЬ
			                      |	Док.Контрагент_Кредитор,
			                      |	Док.Договор_Кредитор
			                      |ИЗ
			                      |	Документ.Взаимозачет КАК Док
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка
			                      |
			                      |ОБЪЕДИНИТЬ
			                      |
			                      |ВЫБРАТЬ
			                      |	Док.Контрагент_Дебитор,
			                      |	Док.Договор_Дебитор
			                      |ИЗ
			                      |	Документ.Взаимозачет.Взаимозачеты КАК Док
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка
			                      |
			                      |ОБЪЕДИНИТЬ
			                      |
			                      |ВЫБРАТЬ
			                      |	Док.Контрагент_Кредитор,
			                      |	Док.Договор_Кредитор
			                      |ИЗ
			                      |	Документ.Взаимозачет.Взаимозачеты КАК Док
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Взаиморасчеты");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Контрагент", "Контрагент");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Договор", "Договор");
		ИначеЕсли ВидОбъекта = "ВозвратОборудования"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Номенклатура КАК Номенклатура,
			                      |	Док.Сотрудник КАК Сотрудник
			                      |ИЗ
			                      |	Документ.ВозвратОборудования.Товары КАК ДокТЧ
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратОборудования КАК Док
			                      |		ПО (Док.Ссылка = ДокТЧ.Ссылка)
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Оборудование");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Сотрудник", "Сотрудник");
		ИначеЕсли ВидОбъекта = "ВыдачаОборудования"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Номенклатура КАК Номенклатура,
			                      |	Док.Сотрудник КАК Сотрудник
			                      |ИЗ
			                      |	Документ.ВыдачаОборудования.Товары КАК ДокТЧ
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыдачаОборудования КАК Док
			                      |		ПО (Док.Ссылка = ДокТЧ.Ссылка)
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Оборудование");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Сотрудник", "Сотрудник");
		ИначеЕсли ВидОбъекта = "ДвижениеТовараВнешнегоКонтрагента"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Номенклатура КАК Номенклатура,
			                      |	Док.Контрагент КАК Контрагент
			                      |ИЗ
			                      |	Документ.ДвижениеТовараВнешнегоКонтрагента.Товары КАК ДокТЧ
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ДвижениеТовараВнешнегоКонтрагента КАК Док
			                      |		ПО (Док.Ссылка = ДокТЧ.Ссылка)
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ОстаткиТМЦВнешние");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
			//ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Контрагент", "Контрагент");
		ИначеЕсли ВидОбъекта = "ДвиженияДенежныхСредств"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Контрагент КАК Контрагент,
			                      |	ДокТЧ.Договор КАК Договор,
			                      |	ДокТЧ.Подразделение КАК Подразделение,
			                      |	ДокТЧ.СтатьяДДС КАК СтатьяЗатрат,
			                      |	ДокТЧ.Подразделение.Сейф КАК БанковскийСчет
			                      |ИЗ
			                      |	Документ.ДвиженияДенежныхСредств.Платежи КАК ДокТЧ
			                      |ГДЕ
			                      |	ДокТЧ.Ссылка = &Ссылка
			                      |
			                      |ОБЪЕДИНИТЬ
			                      |
			                      |ВЫБРАТЬ
			                      |	ДокТЧ.ФизЛицо,
			                      |	ДокТЧ.Договор,
			                      |	ДокТЧ.Подразделение,
			                      |	ДокТЧ.СтатьяДДС,
			                      |	ДокТЧ.Подразделение.Сейф
			                      |ИЗ
			                      |	Документ.ДвиженияДенежныхСредств.Платежи КАК ДокТЧ
			                      |ГДЕ
			                      |	ДокТЧ.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();            
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Затраты");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			//ЭлементБлокировки.ИсточникДанных = ТБлок;
			//ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Подразделение", "Подразделение");
			//ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СтатьяЗатрат", "СтатьяЗатрат");   
			
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Взаиморасчеты");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Контрагент", "Контрагент");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Договор", "Договор");

			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ДенежныеСредства");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			//ЭлементБлокировки.ИсточникДанных = ТБлок;
			//ЭлементБлокировки.ИспользоватьИзИсточникаДанных("БанковскийСчет", "БанковскийСчет");
		ИначеЕсли ВидОбъекта = "ДоставкаСобственнымТранспортом"  Тогда  
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РаспределениеУСОпоНакладным");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ИначеЕсли ВидОбъекта = "ЗаданиеНабора"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Номенклатура КАК Номенклатура,
			                      |	Док.Склад КАК Склад
			                      |ИЗ
			                      |	Документ.Заказ.Товары КАК ДокТЧ
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заказ КАК Док
			                      |		ПО (Док.Ссылка = ДокТЧ.Ссылка)
			                      |ГДЕ
			                      |	ДокТЧ.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РезервыТМЦ");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Склад", "Склад");     
			
		ИначеЕсли ВидОбъекта = "ЗаданиеНаМаркировку"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	Док.ШтрихкодУпаковки КАК ШтрихКодУпаковки,
			                      |	ЕСТЬNULL(СпрНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Номенклатура
			                      |ИЗ
			                      |	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК Док
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК
			                      |		ПО (СпрШК.Ссылка = Док.ШтрихкодУпаковки)
			                      |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
			                      |		ПО (СпрНоменклатура.Ссылка = СпрШК.Владелец)
			                      |			И (СпрШК.ТипКода В (ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)))
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СтатусыКМ_Факт");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ШтрихКодУпаковки", "ШтрихКодУпаковки");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");     
			
		ИначеЕсли ВидОбъекта = "ЗаданиеНаСборкуКомплектовЧЗ"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	Док.ШтрихкодУпаковки КАК ШтрихКодУпаковки,
			                      |	ЕСТЬNULL(СпрНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Номенклатура
			                      |ИЗ
			                      |	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК Док
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК
			                      |		ПО (СпрШК.Ссылка = Док.ШтрихкодУпаковки)
			                      |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
			                      |		ПО (СпрНоменклатура.Ссылка = Док.ШтрихкодУпаковки.Владелец)
			                      |			И (СпрШК.ТипКода В (ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)))
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка
			                      |
			                      |ОБЪЕДИНИТЬ
			                      |
			                      |ВЫБРАТЬ
			                      |	Док.ШтрихкодКоробки,
			                      |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
			                      |ИЗ
			                      |	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК Док
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК
			                      |		ПО Док.ШтрихкодКоробки = СпрШК.Ссылка
			                      |ГДЕ
			                      |	Док.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка",Ссылка);
			ТБлок = Запрос.Выполнить().Выгрузить();
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СтатусыКМ_Факт");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.ИсточникДанных = ТБлок;
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ШтрихКодУпаковки", "ШтрихКодУпаковки");
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");     
			
		ИначеЕсли ВидОбъекта = "Заказ"  Тогда  
			Запрос = Новый Запрос("ВЫБРАТЬ
			                      |	ДокТЧ.Номенклатура КАК Номенклатура,
			                      |	Док.Склад КАК Склад
			                      |ИЗ
			                      |	Документ.Заказ.Товары КАК ДокТЧ
			                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заказ КАК Док
			                      |		ПО (Док.Ссылка = ДокТЧ.Ссылка)
