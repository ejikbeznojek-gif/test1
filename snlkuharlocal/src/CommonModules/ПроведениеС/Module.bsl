Функция ОписаниеБлокировкиДанных(Блокировка)
	Данные = Новый Массив;     
	Для каждого ЭлементБлокировки из Блокировка Цикл   
		ЗаписьДанныхБлокировки = Новый Структура;  
		
		ЗаписьДанныхБлокировки.Вставить("ОбластьБлокировок",ЭлементБлокировки.Область);	    
		
		ПоляБлокировки = Новый ТаблицаЗначений();  
		ПоляБлокировки.Колонки.Добавить("Поле");
		ПоляБлокировки.Колонки.Добавить("КолонкаИсточникаДанных");
		ПоляБлокировки.Колонки.Добавить("Значение");
		Для Каждого ПолеБлокировки Из ЭлементБлокировки.Поля Цикл    
			Поле = ПоляБлокировки.Добавить();
			ЗаполнитьЗначенияСвойств(Поле,ПолеБлокировки);
		КонецЦикла;	
		ЗаписьДанныхБлокировки.Вставить("ПоляБлокировок",ПоляБлокировки);	    
		
		Если ТипЗнч(ЭлементБлокировки.ИсточникДанных) = Тип("ТаблицаЗначений") Тогда  
			ЗаписьДанныхБлокировки.Вставить("ИсточникДанных",ЭлементБлокировки.ИсточникДанных.Скопировать());	
		//Валетов + 12,05,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-9601	
		//Иначе
		//	Сообщить("Ой");	 
		//Валетов -
		КонецЕсли;
		Данные.Добавить(ЗаписьДанныхБлокировки);
	КонецЦикла;	
	Возврат Данные;
КонецФункции	
Процедура ЗаписатьНачалоБлокировки(Источник,ОбъектыБлокировки) Экспорт
    Если НЕ ТранзакцияАктивна() Тогда
        Возврат;
	КонецЕсли;    
	Если Не ОбщегоНазначения_ПИ.ИспользоватьЗамерыТранзакций() Тогда 
	    Возврат;
	КонецЕсли;    
		
	ИдТранзакции = Новый УникальныйИдентификатор(); 
	
	Блокировка = Новый БлокировкаДанных; 
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ДанныеБлокировок");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Ид", ИдТранзакции);
	Блокировка.Заблокировать();      
	
	МЗ = РегистрыСведений.ДанныеБлокировок.СоздатьМенеджерЗаписи();
	МЗ.Ид = ИдТранзакции;
	МЗ.ВремяНачала = ТекущаяДата();  
	МЗ.Источник = Источник;  
	МЗ.Записать(Ложь);      
	
	ПараметрыФЗ = Новый Массив;
	ПараметрыФЗ.Добавить(ИдТранзакции);
	
	ФоновыеЗадания.Выполнить("ПроведениеС.ЗаписатьЗавершениеБлокировки",ПараметрыФЗ);        
КонецПроцедуры
Процедура ЗаписатьЗавершениеБлокировки(ИдБлокировки) Экспорт
	
	Блокировка = Новый БлокировкаДанных; 
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ДанныеБлокировок");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Ид", ИдБлокировки);
	Успешно = Ложь;
	пока не Успешно Цикл
		НачатьТранзакцию();
		Попытка
			Блокировка.Заблокировать();  
			МЗ = РегистрыСведений.ДанныеБлокировок.СоздатьМенеджерЗаписи();      
			МЗ.Ид = ИдБлокировки;
			МЗ.Прочитать();         
			Если НЕ МЗ.Ид = ИдБлокировки Тогда
				Возврат;
			КонецЕсли;	
			МЗ.ВремяЗавершения = ТекущаяДата();
			МЗ.Записать(Истина);    
			Успешно = Истина;    
			ЗафиксироватьТранзакцию();
		Исключение      
			ОтменитьТранзакцию();
		КонецПопытки;
		Попытка   
			ВызватьПаузу(1000);
		Исключение      
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры 
Процедура ОбработатьДанныеБлокировок(ТаблицаПараметров=Неопределено) Экспорт  
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1000
	                      |	ДанныеБлокировок.Ид КАК Ид
