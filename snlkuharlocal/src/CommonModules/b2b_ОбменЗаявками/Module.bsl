Функция HTTPСоединение(ЗащищенноеСоединение = Истина) Экспорт

	НастройкиСоединения = ПолучитьПараметрыСоединения(); 	
	
	Ssl = Новый ЗащищенноеСоединениеOpenSSL();
	Прокси = Новый ИнтернетПрокси(Ложь); 
	//
	Если НастройкиСоединения.Порт = 80 Тогда 		
		ЗащищенноеСоединение = Ложь; 
	КонецЕсли;
	
	Попытка
		Если ЗащищенноеСоединение Тогда
			
			СоединениеHTTP = Новый HTTPСоединение(НастройкиСоединения.Сервер, НастройкиСоединения.Порт, НастройкиСоединения.Логин, НастройкиСоединения.Пароль,Прокси,,ssl);
		Иначе 
			
			СоединениеHTTP = Новый HTTPСоединение(НастройкиСоединения.Сервер, НастройкиСоединения.Порт, НастройкиСоединения.Логин, НастройкиСоединения.Пароль,Прокси);
		КонецЕсли;
		
		
		Возврат СоединениеHTTP; 
		
	Исключение
		Сообщить(ОписаниеОшибки()); 
		Возврат неопределено;
	КонецПопытки;
	
КонецФункции // СоединениеССервером()

