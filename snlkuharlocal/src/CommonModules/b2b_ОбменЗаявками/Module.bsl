					ЕстьИзменения = Истина; 	
				
				КонецЕсли;
			КонецЕсли;
			
			Если ЕстьИзменения Тогда
				
				РезультатЗаписи = ЗаписатьВРегистрУстановкаСкидок(СодержаниеТ);
				Если  Не РезультатЗаписи Тогда
					
					СтруктураОтвета.Вставить("result","ERROR");
					СтруктураОтвета.Вставить("message","Не удалось записать данные по скидкам для отработки");
					
					ЗаписьJSON = ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
					Возврат записьJSON; 
					
				КонецЕсли;	
				
			КонецЕсли;
			
			

		иначе
			
			ЗаписатьВЛог("b2b skidki","Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки(),,,);
			
