 //
 Функция ЗапросНаЗакрытиеФормы(Знач Заказ) Экспорт
	 
	 НаборЗаписей = РегистрыСведений.b2b_РегистрацияБлокировок.СоздатьНаборЗаписей(); 
	 НаборЗаписей.Отбор.Заказ.Установить(Заказ);
	 НаборЗаписей.Прочитать();
	 
	 Возврат НаборЗаписей.Количество() > 0; 
	 
 КонецФункции // ЗапросНаЗакрытиеФормы()
 
