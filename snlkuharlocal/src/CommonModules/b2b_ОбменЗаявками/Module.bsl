//
Процедура ЗаписатьВРегистрРегистрацияБлокировок(Заказ)
	
	МенеджерЗаписи = РегистрыСведений.b2b_РегистрацияБлокировок.СоздатьМенеджерЗаписи(); 
	МенеджерЗаписи.Заказ = Заказ;
	Попытка
		
		МенеджерЗаписи.Записать();
		
	Исключение
		
	КонецПопытки;
	
	
КонецПроцедуры // ЗаписатьВРегистрРегистрацияБлокировок()
  
