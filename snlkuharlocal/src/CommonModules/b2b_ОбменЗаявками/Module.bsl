Функция ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика(ВходныеПараметры)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапроса(Истина); 
	
	Если ВходныеПараметры.Свойство("НомерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.НомерЗаявки) Тогда
		
		СтруктураЗапроса.Data.accountNumber = ВходныеПараметры.НомерЗаявки; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("IDЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.IDЗаявки)
		 И НЕ ВходныеПараметры.Свойство("НомерЗаявки") Тогда
		
		СтруктураЗапроса.Data.bxId = ВходныеПараметры.IDЗаявки; 	
		
	КонецЕсли;

	
	Если ВходныеПараметры.Свойство("СтатусЗаказа")
		И ЗначениеЗаполнено(ВходныеПараметры.СтатусЗаказа) Тогда
		
		СтруктураЗапроса.Data.order.StatusId = ВходныеПараметры.СтатусЗаказа; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Товары")
		И ВходныеПараметры.Товары.Количество() > 0  Тогда
		
		МассивДанных = Новый Массив; 
		
		Для каждого ЭлементМассива Из  ВходныеПараметры.Товары Цикл
			
			СтруктураТовара = СтруктураТовара();
			ЗаполнитьЗначенияСвойств(СтруктураТовара,ЭлементМассива);
			
			СтруктураТовара.XmlId  = ЭлементМассива.IDТовара; 
			СтруктураТовара.quantity = ЭлементМассива.Количество; 
			
			//Если ВходныеПараметры.ФиксированнаяЦена Тогда
			
			СтруктураТовара.price    = ЭлементМассива.Цена;	
			
			//КонецЕсли;
			
			
			МассивДанных.Добавить(СтруктураТовара); 

			
		КонецЦикла;
		
		СтруктураЗапроса.Data.order.confirmedProducts = МассивДанных; 
		
	КонецЕсли;
	                
	Если ВходныеПараметры.Свойство("Дозаказ") 
		И ЗначениеЗаполнено(ВходныеПараметры.Дозаказ) Тогда
		
		СтруктураЗапроса.Data.Вставить("additionalOrder");	
		
	КонецЕсли;  	
	 
	
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()

Функция ЗаполнитьСтруктуруДляСозданияДозаказа(ВходныеПараметры)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапроса(Ложь,Истина); 
	
	Если ВходныеПараметры.Свойство("НомерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.НомерЗаявки) Тогда
		
		СтруктураЗапроса.Data.accountNumber = ВходныеПараметры.НомерЗаявки; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("IDЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.IDЗаявки)
		И НЕ ВходныеПараметры.Свойство("НомерЗаявки") Тогда
		
		СтруктураЗапроса.Data.bxId = ВходныеПараметры.IDЗаявки; 	
		
	КонецЕсли;

	
	Если ВходныеПараметры.Свойство("ЖелаемаяДатаОтгрузки")
		И ЗначениеЗаполнено(ВходныеПараметры.ЖелаемаяДатаОтгрузки) Тогда
		
		СтруктураЗапроса.Data.additionalOrder.orderedShipmentDate = ПреобразоватьДатуДляПередачиНаПортал(ВходныеПараметры.ЖелаемаяДатаОтгрузки); 	
		
	КонецЕсли;

	
	Если ВходныеПараметры.Свойство("Комментарий")
		И ЗначениеЗаполнено(ВходныеПараметры.Комментарий) Тогда
		
		СтруктураЗапроса.Data.additionalOrder.comment = ВходныеПараметры.Комментарий; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ИНН")
		И ЗначениеЗаполнено(ВходныеПараметры.ИНН) Тогда
		
		СтруктураЗапроса.Data.additionalOrder.inn = ВходныеПараметры.ИНН; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Контрагент")
		И ЗначениеЗаполнено(ВходныеПараметры.Контрагент) Тогда
		
		СтруктураЗапроса.Data.additionalOrder.inn = ВходныеПараметры.Контрагент.ИНН; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ПунктДоставки")
		И ЗначениеЗаполнено(ВходныеПараметры.ПунктДоставки) Тогда
		
		СтруктураЗапроса.Data.additionalOrder.deliveryAddress 	= ВходныеПараметры.ПунктДоставки.Код; 		
		
	КонецЕсли;


	
	Если ВходныеПараметры.Свойство("Товары")
		И ВходныеПараметры.Товары.Количество() > 0  Тогда
		
		МассивДанных = Новый Массив; 
		
		Для каждого ЭлементМассива Из  ВходныеПараметры.Товары Цикл
			
			СтруктураТовара = СтруктураТовара(истина);
			ЗаполнитьЗначенияСвойств(СтруктураТовара,ЭлементМассива);
			
			СтруктураТовара.XmlId  = ЭлементМассива.IDТовара; 
			СтруктураТовара.quantity = ЭлементМассива.Количество; 
						
			МассивДанных.Добавить(СтруктураТовара); 

			
		КонецЦикла;
		
		СтруктураЗапроса.Data.additionalOrder.orderedProducts = МассивДанных; 
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ТоварыВНаличии")
		И ВходныеПараметры.ТоварыВНаличии.Количество() > 0  Тогда
		
		МассивДанных = Новый Массив; 
		
		Для каждого ЭлементМассива Из  ВходныеПараметры.ТоварыВНаличии Цикл
			
			СтруктураТовара = СтруктураТовара();
			ЗаполнитьЗначенияСвойств(СтруктураТовара,ЭлементМассива);
			
			СтруктураТовара.XmlId  		= ЭлементМассива.IDТовара; 
			СтруктураТовара.quantity 	= ЭлементМассива.Количество;
			СтруктураТовара.price 		= ЭлементМассива.Цена;
						
			МассивДанных.Добавить(СтруктураТовара); 

			
		КонецЦикла;
		
		СтруктураЗапроса.Data.order.confirmedProducts = МассивДанных; 
		
	КонецЕсли;
	
	Возврат СтруктураЗапроса; 


КонецФункции // ()

Функция ЗаполнитьСтруктуруДляОтправкиСтатусаЗаказа(ВходныеПараметры,ДобавитьТовары = Ложь)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапросаИзменениеСтатуса(ВходныеПараметры.ОтменаЗаказа,ДобавитьТовары);  
	
	Если ВходныеПараметры.Свойство("НомерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.НомерЗаявки) Тогда
		
		СтруктураЗапроса.Data.accountNumber = ВходныеПараметры.НомерЗаявки; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("IDЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.IDЗаявки)
		И НЕ ВходныеПараметры.Свойство("НомерЗаявки") Тогда
		
		СтруктураЗапроса.Data.bxId = ВходныеПараметры.IDЗаявки; 	
		
	КонецЕсли;

	
	Если ВходныеПараметры.Свойство("СтатусЗаказа")
		И ЗначениеЗаполнено(ВходныеПараметры.СтатусЗаказа) Тогда
		
		СтруктураЗапроса.Data.order.StatusId = ВходныеПараметры.СтатусЗаказа; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("КомментарийОтмены")
		И ЗначениеЗаполнено(ВходныеПараметры.КомментарийОтмены) Тогда
		
		СтруктураЗапроса.Data.order.cancelReasonText = ВходныеПараметры.КомментарийОтмены; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Товары")
		И ВходныеПараметры.Товары.Количество() > 0 
		И СтруктураЗапроса.Data.order.Свойство("confirmedProducts") Тогда
		
		МассивДанных = Новый Массив; 
		
		Для каждого ЭлементМассива Из  ВходныеПараметры.Товары Цикл
			
			СтруктураТовара = СтруктураТовара();
			ЗаполнитьЗначенияСвойств(СтруктураТовара,ЭлементМассива);
			
			СтруктураТовара.XmlId  		= ЭлементМассива.IDТовара; 
			СтруктураТовара.quantity 	= ЭлементМассива.Количество;
			СтруктураТовара.price 		= ЭлементМассива.Цена;
			
			МассивДанных.Добавить(СтруктураТовара); 
			
			
		КонецЦикла;
		
		СтруктураЗапроса.Data.order.confirmedProducts = МассивДанных; 
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ТоварыДозаказа")
		И ВходныеПараметры.ТоварыДозаказа.Количество() > 0  Тогда
		
		МассивДанных = Новый Массив; 
		
		Для каждого ЭлементМассива Из  ВходныеПараметры.ТоварыДозаказа Цикл
			
			СтруктураТовара = СтруктураТовара();
			ЗаполнитьЗначенияСвойств(СтруктураТовара,ЭлементМассива);
			
			СтруктураТовара.XmlId  = ЭлементМассива.IDТовара; 
			СтруктураТовара.quantity = ЭлементМассива.Количество; 
			
			//СтруктураТовара.price    = ЭлементМассива.Цена;	
				
			
			МассивДанных.Добавить(СтруктураТовара); 
			
			
		КонецЦикла;
		
		СтруктураЗапроса.Data.Вставить("additionalOrder",Новый Структура); 
		СтруктураЗапроса.Data.additionalOrder.Вставить("confirmedProducts",Новый Массив); 
		СтруктураЗапроса.Data.additionalOrder.confirmedProducts = МассивДанных; 
		
	КонецЕсли;



		
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()

