			СтруктураОтвета.Вставить("message","В 1с не найден документ скидок.");
			
						
			#Если клиент  тогда
				сообщить("Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки());
			#КонецЕсли 
			
			записьJSON = ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
			Возврат записьJSON;
		КонецЕсли;	
		
		//КонецЕсли;  	
		
		Если НЕ ЕстьИзменения и  контрагентНайден ТОгда
			СтруктураОтвета.Вставить("result","OK");
			СтруктураОтвета.Вставить("message","В 1с скидка по этому контрагенту уже установлена");
			
		КонецЕсли;	
		//
		Если НЕ ЕстьИзменения и НЕ контрагентНайден Тогда
			
			ЗаписатьВЛог("b2b skidki","Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки(),,,);
			
			#Если клиент  тогда
				сообщить("Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки());
			#КонецЕсли     
			
			СтруктураОтвета.Вставить("result","ERROR");
