Функция ПолучитьСтавкуНДС_(Номенклатура) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ВЫБОР
	             |		КОГДА Номенклатура.СтавкаНДС <> &ПустаяСтавка
	             |			ТОГДА Номенклатура.СтавкаНДС
	             |		КОГДА Номенклатура.Родитель.СтавкаНДС <> &ПустаяСтавка
	             |			ТОГДА Номенклатура.Родитель.СтавкаНДС
	             |		КОГДА Номенклатура.Родитель.Родитель.СтавкаНДС <> &ПустаяСтавка
	             |			ТОГДА Номенклатура.Родитель.Родитель.СтавкаНДС
	             |		КОГДА Номенклатура.Родитель.Родитель.Родитель.СтавкаНДС <> &ПустаяСтавка
	             |			ТОГДА Номенклатура.Родитель.Родитель.Родитель.СтавкаНДС
	             |		КОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.СтавкаНДС <> &ПустаяСтавка
	             |			ТОГДА Номенклатура.Родитель.Родитель.Родитель.Родитель.СтавкаНДС
	             |		ИНАЧЕ &ПустаяСтавка
	             |	КОНЕЦ КАК СтавкаНДС
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	Номенклатура.Ссылка = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("ПустаяСтавка",Перечисления.СтавкиНДС.ПустаяСсылка());
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СтавкаНДС		
	Иначе
		Возврат Перечисления.СтавкиНДС.ПустаяСсылка();		
	КонецЕсли;
КонецФункции


