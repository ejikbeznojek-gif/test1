		//ВыборкаДетальныеЗаписи.Следующий(); 
		
		//Если ПараметрыДляЗаписи.Свойство("ОсновнойЗаказ") Тогда
		//	
		//	ОсновнойЗаказ = ПараметрыДляЗаписи.ОсновнойЗаказ;
		//	//ТаблицаДанных = РегистрыСведений.b2b_ЗаявкиКлиентов.СрезПоследних(,Новый Структура("Заказ",ОсновнойЗаказ));
		//	ВыборкаДанныхПоЗаказу = РегистрыСведений.b2b_ЗаявкиКлиентов.Выбрать(Новый Структура("Заказ",ОсновнойЗаказ));
		//	//ОтборПоЗаказу = ОсновнойЗаказ; 
		//Иначе
		//	ВыборкаДанныхПоЗаказу = РегистрыСведений.b2b_ЗаявкиКлиентов.Выбрать(Новый Структура("Заказ",Заказ));
		//	//ОтборПоЗаказу = ОсновнойЗаказ;
		//КонецЕсли;
		
		Если ПараметрыДляЗаписи.Свойство("СоответствиеТоварКоличествоРезерв") Тогда
			
			СоответствиеТоварКоличествоРезерв = ПараметрыДляЗаписи.СоответствиеТоварКоличествоРезерв; 	
		Иначе 
			СоответствиеТоварКоличествоРезерв= Новый Соответствие; 
