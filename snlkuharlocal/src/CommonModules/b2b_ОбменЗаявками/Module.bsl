Процедура ОтработатьОтгрузкуРНК(Знач РНК) Экспорт
	//заказ подтвержд. заявка 
	//РНК отгружен 
	//++Данилова Е.В. 10.10.2025 HELP-7411 
	Если НЕ(ТипЗнч(РНК) = Тип("ДокументСсылка.РасходнаяНакладная")
		ИЛИ  ТипЗнч(РНК) = Тип("ДокументОбъект.РасходнаяНакладная")) Тогда
		
	      
		Возврат; 	
	
	КонецЕсли;
	//--Данилова Е.В. 10.10.2025
	
	ЗаказКлиента = РНК.ДокОснование;
	
	Если ЗаказКлиента.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ 
		И РНК.Отгружен = Перечисления.Отгружен.Отгружен Тогда 		
		
		ЗаказОбъект = ЗаказКлиента.ПолучитьОбъект();
		Если ЗаказОбъект <> Неопределено 
			И НЕ ЗаказОбъект.ПометкаУдаления Тогда
			
			//Попытка
			//	ЗаказОбъект.Заблокировать();
			//Исключение
			//	Сообщить("Не удалось перевести состояние заказа в ""Выполнен"", объект заблокирован"); 
			//	Возврат;
			//КонецПопытки;
			ЗаказДозаказ = НайтиДоЗаказпоОсновному(ЗаказКлиента.ссылка);
			ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(ЗаказКлиента.ссылка); 
			РНКСущ = неопределено;
			
			МассивРНКЗаказа = СвязанныеРНКЗаказ(ЗаказКлиента);
			Если ЗаказДозаказ <> ЗаказКлиента.ссылка
				И ЗначениеЗаполнено(ЗаказДозаказ) Тогда 				 
			   РезультатСвязи = ПроверитьСвязьСРНК(ЗаказДозаказ,РНКСущ);
			   МассивРНК = СвязанныеРНКЗаказ(ЗаказДозаказ);
			   Для каждого ЭлементМассива  Из МассивРНК Цикл
				   
				   МассивРНКЗаказа.Добавить(ЭлементМассива); 
				   
			   КонецЦикла;
			ИначеЕсли ОсновнойЗаказ <> ЗаказКлиента.ссылка
				И ЗначениеЗаполнено(ОсновнойЗаказ) Тогда	
			    РезультатСвязи = ПроверитьСвязьСРНК(ОсновнойЗаказ,РНКСущ);
				МассивРНК = СвязанныеРНКЗаказ(ОсновнойЗаказ);
				Для каждого ЭлементМассива  Из МассивРНК Цикл
					
					МассивРНКЗаказа.Добавить(ЭлементМассива); 
					
				КонецЦикла;
			КонецЕсли;
			СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен; 
			//Если ЗначениеЗаполнено(РНКСущ)
			//	И РНКСущ.Отгружен <> Перечисления.Отгружен.Отгружен Тогда
			//
			//	СостояниеНакладной  = Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично; 
			//
			//КонецЕсли;
			Если МассивРНКЗаказа.Количество() > 0  Тогда
				ВыполненПолностью = Истина; 
				
				Для каждого РНКИзМассива Из  МассивРНКЗаказа Цикл
					
					Если РНКИзМассива.Отгружен <> Перечисления.Отгружен.Отгружен Тогда
						
						ВыполненПолностью = Ложь; 
						
					КонецЕсли;
					
				КонецЦикла;
				Если НЕ ВыполненПолностью Тогда
				
					СостояниеНакладной  = Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично;	
				
				КонецЕсли;
				
				
			КонецЕсли;
			
			ЗаказДляРедактирования = неопределено; 
			Если СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен
				И ЗначениеЗаполнено(ЗаказДозаказ) 
				И (ЗаказДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично
				ИЛИ РНКСущ = РНК) Тогда
			
				ЗаказДляРедактирования = ЗаказДозаказ.ПолучитьОбъект();
				ЗаказДляРедактирования.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен; 
			ИначеЕсли СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен
				И ЗначениеЗаполнено(ОсновнойЗаказ) 
				И (ОсновнойЗаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично
				ИЛИ РНКСущ = РНК) Тогда
				ЗаказДляРедактирования = ОсновнойЗаказ.ПолучитьОбъект();
				ЗаказДляРедактирования.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен;
			КонецЕсли;
			ЗаказОбъект.СостояниеНакладной = СостояниеНакладной; 
			
			УстановитьПривилегированныйРежим(Истина);
			Попытка
				ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
				//ЗаказОбъект.Разблокировать();
				
				Если ЗаказДляРедактирования <> неопределено Тогда
				
					ЗаказДляРедактирования.Записать(РежимЗаписиДокумента.Проведение); 	
				
				КонецЕсли;
			Исключение
				Сообщить("Не удалось перевести состояние заказа в ""Выполнен"", объект заблокирован ошибка записи"); 
				Сообщить(ОписаниеОшибки()); 
			КонецПопытки;
			УстановитьПривилегированныйРежим(Ложь);  			
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	
	
КонецПроцедуры // ОтработатьОтгрузкуРНК()
