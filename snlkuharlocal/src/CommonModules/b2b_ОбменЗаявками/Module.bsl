Процедура ЗаписатьДанныеВРСПриСозданииНовогоЗаказа(Знач ДатаОбновления, Знач ЗаказКлиентаНовый, Знач МетодДоставки, Знач СтатусЗаказа_b2b)
	
	Перем ПараметрыДлязаписи;
	
	ПараметрыДлязаписи = Новый Структура; 
	ПараметрыДлязаписи.Вставить("СтатусЗаказа_b2b",СтатусЗаказа_b2b);
	ПараметрыДлязаписи.Вставить("МетодДоставки",МетодДоставки);
	ПараметрыДлязаписи.Вставить("ДатаОбновления",ДатаОбновления);
	ПараметрыДлязаписи.Вставить("ПлановаяДатаОтгрузки",ЗаказКлиентаНовый.ДатаОтгрузки);
	
	ЗаписатьДополнительныеДанныеВРегистрЗаказов(ЗаказКлиентаНовый.Ссылка,ПараметрыДлязаписи); 
	
	ЗаписатьВРегистрОбновленныеЗаказы(ЗаказКлиентаНовый.Ссылка,ТекущаяДатаСеанса());

КонецПроцедуры // СоздатьЗаказКлиента()

