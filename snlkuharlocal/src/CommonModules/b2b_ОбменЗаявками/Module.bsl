//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(ИдентификаторЗапроса,Результат,Комментарий, ЭтоОшибка = Ложь,ХранитьПодробностиЛогирования = Ложь)

	Наборзаписей = РегистрыСведений.b2b_ЗапросыНаПолучениеЗаказовИстория.СоздатьНаборЗаписей(); 
	Наборзаписей.Отбор.ИдентификаторЗапроса.Установить(ИдентификаторЗапроса);
	Наборзаписей.Прочитать();
	
	Для каждого ЗаписьНабора Из Наборзаписей Цикл
	
		ЗаписьНабора.Комментарий = Комментарий;
		ЗаписьНабора.ТекстОшибки = ?(ЭтоОшибка,Комментарий,"");
		ЗаписьНабора.ИдентификаторКлиента = ?(Результат = Неопределено,"",Результат.ИдентификаторКлиента);		
		ЗаписьНабора.Документ = ?(Результат = Неопределено,"",Результат.Документ);
		Если ХранитьПодробностиЛогирования Тогда
			
			ЗаписьНабора.Результат = ?(Результат = Неопределено,"",Новый ХранилищеЗначения(Результат.РезультатJson,Новый СжатиеДанных(9)));	
			
		КонецЕсли;
	    
		
	КонецЦикла;
	
	Попытка
	
		Наборзаписей.Записать(); 
	
	Исключение
		
		ЗаписьЖурналаРегистрации("ОшибкаЗапросаОбменЕЭ_GET",УровеньЖурналаРегистрации.Ошибка,,,,);
	
	КонецПопытки;
	
КонецПроцедуры // ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат()


