Функция ПолучитьТекстJSON(Форма) Экспорт

	ЗаписьСервер  = Форма.РеквизитФормыВЗначение("Запись"); 
	ДанныеJSON 	  = ЗаписьСервер.Запрос.Получить(); 
	
	Возврат ДанныеJSON; 

КонецФункции // ПолучитьТекстJSON()

Функция ПолучитьТекстJSONРезультат(Форма,ИмяРесурса = "Результат") Экспорт

	ЗаписьСервер  = Форма.РеквизитФормыВЗначение("Запись"); 
	Структураjson 	  = ЗаписьСервер[ИмяРесурса].Получить(); 
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(Структураjson);
	
	Возврат СтрокаJSON; 

КонецФункции //

