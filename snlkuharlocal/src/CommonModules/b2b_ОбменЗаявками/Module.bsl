		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.b2b_ЗаявкиКлиентов.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Заказ.Установить(Заказ); 
		НаборЗаписей.Записать(); 
		
		Для каждого ТоварЗаказа Из Заказ.Товары  Цикл
			
			МенеджерЗаписи = РегистрыСведений.b2b_ЗаявкиКлиентов.СоздатьМенеджерЗаписи();
			
			//Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
			
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ВыборкаДетальныеЗаписи); 
			
			//КонецЕсли;
			
			МенеджерЗаписи.Заказ = Заказ;
			МенеджерЗаписи.Количество = ТоварЗаказа.Количество;
			
			КоличествоРезерв = СоответствиеТоварКоличествоРезерв.Получить( ТоварЗаказа.Номенклатура); 
			Если КоличествоРезерв = неопределено Тогда
				
				МенеджерЗаписи.КоличествоРезерв = ТоварЗаказа.Количество;	
			Иначе 
				МенеджерЗаписи.КоличествоРезерв = КоличествоРезерв;
			КонецЕсли;
			
			ЦенаСкидкаСтруктура = СоответствиеТоварЦенаСкидка.Получить(ТоварЗаказа.Номенклатура); 
			Если ЦенаСкидкаСтруктура = неопределено Тогда
				
				МенеджерЗаписи.Цена = ТоварЗаказа.Цена;
				МенеджерЗаписи.ЦенаБезСкидки = ТоварЗаказа.ЦенаБезСкидки;
				МенеджерЗаписи.Скидка = ТоварЗаказа.Скидка;
				МенеджерЗаписи.СкидкаНаНакладную = Заказ.Скидка;
				МенеджерЗаписи.ДопСкидкаНаНакладную = Заказ.ДопСкидкаНаНакладную;
			Иначе 
				МенеджерЗаписи.Цена = ЦенаСкидкаСтруктура.Цена;
				МенеджерЗаписи.ЦенаБезСкидки = ЦенаСкидкаСтруктура.ЦенаБезСкидки;
				МенеджерЗаписи.Скидка = ЦенаСкидкаСтруктура.Скидка;
				МенеджерЗаписи.СкидкаНаНакладную = ЦенаСкидкаСтруктура.СкидкаНаНакладную;
				МенеджерЗаписи.ДопСкидкаНаНакладную = ЦенаСкидкаСтруктура.ДопСкидкаНаНакладную;

			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("МетодДоставки")
				И ЗначениеЗаполнено(ПараметрыДляЗаписи.МетодДоставки) Тогда
				
				МенеджерЗаписи.МетодДоставки = ПараметрыДляЗаписи.МетодДоставки; 
				
			КонецЕсли;                                                               
			//
			Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыЗаявки") Тогда
				
				МенеджерЗаписи.ПричинаОтменыЗаявки = ПараметрыДляЗаписи.ПричинаОтменыЗаявки;
				
			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиЗаказа") Тогда
				
				МенеджерЗаписи.ПричинаОтменыОтгрузкиЗаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиЗаказа;
				
			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиДозаказа") Тогда
				
				МенеджерЗаписи.ПричинаОтменыОтгрузкиДозаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиДозаказа;
				
			КонецЕсли;
			
			
			Если ПараметрыДляЗаписи.Свойство("ПлановаяДатаОтгрузки") Тогда
				
				МенеджерЗаписи.ПлановаяДатаОтгрузки = ПараметрыДляЗаписи.ПлановаяДатаОтгрузки; 
				
			КонецЕсли;
			
			Если 
				ПараметрыДляЗаписи.Свойство("СтатусЗаказа_b2b")
				И ЗначениеЗаполнено(ПараметрыДляЗаписи.СтатусЗаказа_b2b) Тогда
				МенеджерЗаписи.СтатусЗаказа_b2b = ПараметрыДляЗаписи.СтатусЗаказа_b2b;
			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("ДатаОбновления")
				И ЗначениеЗаполнено(ПараметрыДляЗаписи.ДатаОбновления) Тогда
				МенеджерЗаписи.ДатаОбновления = ПараметрыДляЗаписи.ДатаОбновления;
			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("ДатаОбновленияДозаказа")
				И ЗначениеЗаполнено(ПараметрыДляЗаписи.ДатаОбновленияДозаказа) Тогда
				МенеджерЗаписи.ДатаОбновленияДозаказа = ПараметрыДляЗаписи.ДатаОбновленияДозаказа;
			КонецЕсли;
			
			Если ПараметрыДляЗаписи.Свойство("Отгружен")
				И ЗначениеЗаполнено(ПараметрыДляЗаписи.Отгружен) Тогда
				МенеджерЗаписи.Отгружен = ПараметрыДляЗаписи.Отгружен;
			КонецЕсли;

			
			МенеджерЗаписи.Номенклатура = ТоварЗаказа.Номенклатура; 
			
			Попытка
				
				МенеджерЗаписи.Записать(); 
				
			Исключение
				Сообщить(ОписаниеОшибки()); 
			КонецПопытки;
			
			
		КонецЦикла;
		
	Конецесли; 
	
	Если Заказ.Товары.Количество() = 0 Тогда //все в дозаказе
		
		МенеджерЗаписи = РегистрыСведений.b2b_ЗаявкиКлиентов.СоздатьМенеджерЗаписи();
		
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ВыборкаДетальныеЗаписи); 
		МенеджерЗаписи.Заказ = Заказ;
		
		Если ПараметрыДляЗаписи.Свойство("МетодДоставки")
			И ЗначениеЗаполнено(ПараметрыДляЗаписи.МетодДоставки) Тогда
			
			МенеджерЗаписи.МетодДоставки = ПараметрыДляЗаписи.МетодДоставки; 
			
		КонецЕсли;
		//
		Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыЗаявки") Тогда
			
			МенеджерЗаписи.ПричинаОтменыЗаявки = ПараметрыДляЗаписи.ПричинаОтменыЗаявки;
			
		КонецЕсли;
		
		Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиЗаказа") Тогда
			
			МенеджерЗаписи.ПричинаОтменыОтгрузкиЗаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиЗаказа;
			
		КонецЕсли;
		
		Если ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиДозаказа") Тогда
			
			МенеджерЗаписи.ПричинаОтменыОтгрузкиДозаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиДозаказа;
			
		КонецЕсли;
		
		
		Если ПараметрыДляЗаписи.Свойство("ПлановаяДатаОтгрузки") Тогда
			
			МенеджерЗаписи.ПлановаяДатаОтгрузки = ПараметрыДляЗаписи.ПлановаяДатаОтгрузки; 
			
		КонецЕсли;
		
		Если 
			ПараметрыДляЗаписи.Свойство("СтатусЗаказа_b2b")
			И ЗначениеЗаполнено(ПараметрыДляЗаписи.СтатусЗаказа_b2b) Тогда
			МенеджерЗаписи.СтатусЗаказа_b2b = ПараметрыДляЗаписи.СтатусЗаказа_b2b;
		КонецЕсли;
		
		Если ПараметрыДляЗаписи.Свойство("ДатаОбновления")
			И ЗначениеЗаполнено(ПараметрыДляЗаписи.ДатаОбновления) Тогда
			МенеджерЗаписи.ДатаОбновления = ПараметрыДляЗаписи.ДатаОбновления;
		КонецЕсли;
		
		Если ПараметрыДляЗаписи.Свойство("ДатаОбновленияДозаказа")
			И ЗначениеЗаполнено(ПараметрыДляЗаписи.ДатаОбновленияДозаказа) Тогда
			МенеджерЗаписи.ДатаОбновленияДозаказа = ПараметрыДляЗаписи.ДатаОбновленияДозаказа;
		КонецЕсли;
		
		Попытка
			
			МенеджерЗаписи.Записать(); 
			
		Исключение
			Сообщить(ОписаниеОшибки()); 
		КонецПопытки;
		
		
		
	КонецЕсли;
	
	ЗаписьСтатуса = ПараметрыДляЗаписи.Свойство("СтатусЗаказа_b2b")
	И ЗначениеЗаполнено(ПараметрыДляЗаписи.СтатусЗаказа_b2b);
	
	ЗаписьМетодаДоставки = ПараметрыДляЗаписи.Свойство("МетодДоставки")
	И ЗначениеЗаполнено(ПараметрыДляЗаписи.МетодДоставки);
	
	ЗаписьПричинаОтменыЗаявки = ПараметрыДляЗаписи.Свойство("ПричинаОтменыЗаявки")
	И ЗначениеЗаполнено(ПараметрыДляЗаписи.ПричинаОтменыЗаявки);
	
	ЗаписьПричинаОтменыОтгрузкиЗаказа = ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиЗаказа")
	И ЗначениеЗаполнено(ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиЗаказа);
	
	
	ЗаписьПричинаОтменыОтгрузкиДозаказа = ПараметрыДляЗаписи.Свойство("ПричинаОтменыОтгрузкиДозаказа")
	И ЗначениеЗаполнено(ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиДозаказа);
	
	
	Если  ЗаписьСтатуса 
		ИЛИ ЗаписьМетодаДоставки 
		ИЛИ ЗаписьПричинаОтменыЗаявки 
		ИЛИ ЗаписьПричинаОтменыОтгрузкиЗаказа 
		ИЛИ ЗаписьПричинаОтменыОтгрузкиДозаказа Тогда
		
		
		Дозаказ = НайтиДоЗаказпоОсновному(Заказ); 
		
		Если ЗначениеЗаполнено(Дозаказ)  Тогда
			
			НаборЗаписей = РегистрыСведений.b2b_ЗаявкиКлиентов.СоздатьНаборЗаписей(); 
			НаборЗаписей.Отбор.Заказ.Установить(Дозаказ);
			НаборЗаписей.Прочитать();
			Для каждого Записьнабора Из НаборЗаписей Цикл
				Если ЗаписьСтатуса Тогда
					
					Записьнабора.СтатусЗаказа_b2b = ПараметрыДляЗаписи.СтатусЗаказа_b2b;	
					
				КонецЕсли;
				
				Если  ЗаписьМетодаДоставки Тогда
					
					Записьнабора.МетодДоставки = ПараметрыДляЗаписи.МетодДоставки;	
					
				КонецЕсли;
				
				Если  ЗаписьПричинаОтменыЗаявки Тогда
					
					Записьнабора.ПричинаОтменыЗаявки = ПараметрыДляЗаписи.ПричинаОтменыЗаявки;	
					
				КонецЕсли;
				
				Если  ЗаписьПричинаОтменыОтгрузкиЗаказа Тогда
					
					Записьнабора.ПричинаОтменыОтгрузкиЗаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиЗаказа;	
					
				КонецЕсли;
				
				
				Если  ЗаписьПричинаОтменыОтгрузкиДозаказа Тогда
					
					Записьнабора.ПричинаОтменыОтгрузкиДозаказа = ПараметрыДляЗаписи.ПричинаОтменыОтгрузкиДозаказа;	
					
				КонецЕсли;
				
				
				
				
			КонецЦикла;
			
			НаборЗаписей.Записать(); 
			
		КонецЕсли;
	КонецЕсли;
	
	
	
	
КонецПроцедуры // ()

Процедура ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(Заказ,ПараметрыДляЗаписи,ОтправленЗапрос) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	b2b_Дозаказы.Комментарий КАК Комментарий,
	|	b2b_Дозаказы.ПРМ КАК ПРМ,
	|	b2b_Дозаказы.СрокПодтвержденияПоДозаказу КАК СрокПодтвержденияПоДозаказу,
	|	b2b_Дозаказы.СтатусДоЗаказа_b2b КАК СтатусДоЗаказа_b2b,
	|	b2b_Дозаказы.ЖелаемаяДатаОтгрузки КАК ЖелаемаяДатаОтгрузки,
	|	b2b_Дозаказы.Заказ КАК Заказ,
	|	b2b_Дозаказы.ЗаказОсновной КАК ЗаказОсновной,
	|	b2b_Дозаказы.ПунктДоставки КАК ПунктДоставки,
	|	b2b_Дозаказы.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
	|ГДЕ
	|	b2b_Дозаказы.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ПараметрыДляЗаписи.Свойство("Товары") Тогда //при записи заказа, первично, без отправки на сайт 
		
		ВыборкаДетальныеЗаписи.Следующий(); 
		Для каждого ДанныеПоТовару Из ПараметрыДляЗаписи.Товары Цикл
		
			МенеджерЗаписи = РегистрыСведений.b2b_Дозаказы.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ВыборкаДетальныеЗаписи); 
			
			МенеджерЗаписи.Заказ = Заказ;
			МенеджерЗаписи.Номенклатура = ДанныеПоТовару.Номенклатура;
			МенеджерЗаписи.Количество = ДанныеПоТовару.Количество;
			//МенеджерЗаписи.ЖелаемаяДатаОтгрузки = ДанныеПоТовару.ЖелаемаяДатаОтгрузки;
			//МенеджерЗаписи.Комментарий = ДанныеПоТовару.Комментарий; 			
			
			Если ПараметрыДляЗаписи.Свойство("ОсновнойЗаказ") Тогда
				
				МенеджерЗаписи.ЗаказОсновной = ПараметрыДляЗаписи.ОсновнойЗаказ;	
				
			КонецЕсли;
			
			Если  ПараметрыДляЗаписи.Свойство("Комментарий") Тогда
				
				МенеджерЗаписи.Комментарий = ПараметрыДляЗаписи.Комментарий;	
				
			КонецЕсли;
			
			Если  ПараметрыДляЗаписи.Свойство("ПунктДоставки") Тогда
				
				МенеджерЗаписи.ПунктДоставки = ПараметрыДляЗаписи.ПунктДоставки;	
				
			КонецЕсли;
			
			Если  ПараметрыДляЗаписи.Свойство("Контрагент") Тогда
				
				МенеджерЗаписи.Контрагент = ПараметрыДляЗаписи.Контрагент;	
				
			КонецЕсли;

			
			МенеджерЗаписи.Записать(); 
		КонецЦикла;
	Иначе  
		
		
		НаборЗаписей = РегистрыСведений.b2b_Дозаказы.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Заказ.Установить(Заказ); 
		НаборЗаписей.Записать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
			
			Для каждого ДанныеПоТовару Из Заказ.Товары Цикл
				
				МенеджерЗаписи = РегистрыСведений.b2b_Дозаказы.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ДанныеПоТовару); 
				
				ЗаполнитьЗначенияСвойств(МенеджерЗаписи,ВыборкаДетальныеЗаписи);	
				
				Если  ПараметрыДляЗаписи.Свойство("СрокПодтвержденияПоДозаказу") Тогда
					
					МенеджерЗаписи.СрокПодтвержденияПоДозаказу = ПараметрыДляЗаписи.СрокПодтвержденияПоДозаказу;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("СтатусДоЗаказа_b2b") Тогда
					
					МенеджерЗаписи.СтатусДоЗаказа_b2b = ПараметрыДляЗаписи.СтатусДоЗаказа_b2b;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("ПРМ") Тогда
					
					МенеджерЗаписи.ПРМ = ПараметрыДляЗаписи.ПРМ;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("Комментарий") Тогда
					
					МенеджерЗаписи.Комментарий = ПараметрыДляЗаписи.Комментарий;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("ЖелаемаяДатаОтгрузки") Тогда
					
					МенеджерЗаписи.ЖелаемаяДатаОтгрузки = ПараметрыДляЗаписи.ЖелаемаяДатаОтгрузки;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("ПунктДоставки") Тогда
					
					МенеджерЗаписи.ПунктДоставки = ПараметрыДляЗаписи.ПунктДоставки;	
					
				КонецЕсли;
				
				Если  ПараметрыДляЗаписи.Свойство("Контрагент") Тогда
					
					МенеджерЗаписи.Контрагент = ПараметрыДляЗаписи.Контрагент;	
					
				КонецЕсли;
				
				
				Попытка
					
					МенеджерЗаписи.Записать(); 
					
				Исключение
					
				КонецПопытки;
				
			КонецЦикла;
			
			
		КонецЕсли;
	КонецЕсли;
	
	
		 
	 

КонецПроцедуры // ()


// <Описание функции>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
Процедура ОбновитьЗаказКлиента(ДанныеАпи,ЗаказКлиента,
	ОбновленныеЗаказы,
	НеДобавлятьВРСОбновленные = Ложь,
	ВернутьИсходноеСостояние = Ложь,
	ИдентификаторЗапроса = неопределено)
	
	ЗаказКлиентаОбъект = ЗаказКлиента.ПолучитьОбъект();
	////////////////////////////////////////////////
	//блокировка
	//если вызов идет из формы открытой , то блокировку не проверяем 
	ПроверкаБлокировки = Истина; 
	ЗаблокироватьОбъектДляИзменений(ИдентификаторЗапроса, ЗаказКлиентаОбъект,НеДобавлятьВРСОбновленные,ПроверкаБлокировки);
	Если НЕ ПроверкаБлокировки Тогда
		
		Возврат; 	
		
	КонецЕсли;
	
	///////////////////////////////////////////////
	ДатаОбновления = ПреобразоватьДату(ДанныеАпи.order.dateUpdate);
	СрокПодтвержденияПоДозаказу  = ПреобразоватьДату(ДанныеАпи.order.cancellationTimeout2);
	 
	СтатусЗаказа =  ДанныеАпи.order.statusId;
	
	ПризнакКорректировки = ?(ДанныеАпи.order.Свойство("subStatusId"),ДанныеАпи.order.subStatusId = "ZCC",Ложь);  
	
	МетодДоставки = неопределено; 
	
	ПричинаОтменыЗаявки = Неопределено;      
	
	ДатаОбновленияДозаказа = неопределено; 
	
	Если ДанныеАпи.Свойство("additionalOrder") Тогда
		
		СтатусДоЗаказа_b2b = ПолучитьИзСоответствияСтатусДоЗаказа(ДанныеАпи.additionalOrder.statusId);
		НомерДоЗаказа = ДанныеАпи.additionalOrder.accountNumber;
		
		Если ДанныеАпи.additionalOrder.Свойство("confirmedProducts") Тогда
			ТоварыВДоЗаказе = ДанныеАпи.additionalOrder.confirmedProducts;
		Иначе 
			ТоварыВДоЗаказе = ДанныеАпи.additionalOrder.orderedProducts;
			
		КонецЕсли;
		
		ДатаОбновленияДозаказа = ПреобразоватьДату(ДанныеАпи.additionalOrder.dateUpdate);
		
	Иначе 
		СтатусДоЗаказа_b2b = Неопределено; 
		НомерДоЗаказа = Неопределено; 
		ТоварыВДоЗаказе = неопределено; 
	КонецЕсли;      
	
	ЗаказИзменен = Ложь;
	
	ВернутьИсходноеСостояниеПодтвержден = Ложь; 
	
	СостояниеНакладнойДо = ЗаказКлиентаОбъект.СостояниеНакладной; 
	СостояниеСогласованияДо = ЗаказКлиентаОбъект.СостояниеСогласования; 
	СтатусЗаявкиДо = СтатусЗаявкиПоЗаказу(ЗаказКлиентаОбъект.ссылка); 
	
	Если СтатусЗаказа = "ZN"
		ИЛИ СтатусЗаказа = "ZC" Тогда
		//ждет подтверждения дистрибьютором
		
		ВернутьИсходноеСостояниеПодтвержден = ВернутьИсходноеСостояние; 
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором;	   
		
		ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
		ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО;
		//++Данилова Е.В. 21.07.2025 без задачи , изменения на портале	
		Если ДанныеАпи.order.Свойство("confirmedProducts")
			 И НЕ ВернутьИсходноеСостояниеПодтвержден Тогда
			//--Данилова Е.В. 21.07.2025
			
			ТоварыВОсновномЗаказе =  ДанныеАпи.order.confirmedProducts; 
		Иначе 
			
			ТоварыВОсновномЗаказе =  ДанныеАпи.order.orderedProducts ;
		КонецЕсли;
		
		Если СтатусЗаказа = "ZN"
			И НЕ ДанныеАпи.order.Свойство("confirmedProducts") Тогда 
			
			ТоварыВОсновномЗаказе = неопределено;
			
			Если ЗаказКлиентаОбъект.Товары.Количество() > 0  Тогда
			
				ЗаказИзменен = Истина; 
			
			КонецЕсли;
			
		Иначе 
			МассивТоваровССайта = Новый Массив; 
			Для каждого ДанныеПоТовару Из ТоварыВОсновномЗаказе Цикл
				
				Номенклатура = НайтиТоварПоКодуТовара(ДанныеПоТовару.xmlId);
				
				Если  НЕ ЗначениеЗаполнено(Номенклатура) Тогда
					
					Продолжить; 
					
				КонецЕсли;
				
				МассивТоваровССайта.Добавить(Номенклатура); 
				
				Отбор = Новый Структура("Номенклатура",Номенклатура);
				СтрокиТовара = ЗаказКлиентаОбъект.Товары.НайтиСтроки(Отбор);
				
				Дозаказ = НайтиДоЗаказпоОсновному(ЗаказКлиентаОбъект.ссылка);
				
				СтатусДозаказаДо = СтатусДозаказаПоЗаказу(Дозаказ);
				
				ИзменитьТоварВЗаказе = Истина; 
				Если ЗначениеЗаполнено(Дозаказ) 
					И НЕ ЗначениеЗаполнено(СтатусДозаказаДо) Тогда
					Если НЕ ВернутьИсходноеСостояние Тогда
						
						СтрокиДозаказа = Дозаказ.Товары.НайтиСтроки(Отбор); 
						Если СтрокиДозаказа.Количество() > 0  Тогда
							
							ИзменитьТоварВЗаказе = Ложь; 
							
						КонецЕсли;	
					КонецЕсли; 	
					
				КонецЕсли;
					
				Если СтрокиТовара.Количество() > 0  Тогда
					
					НовыйТовар =  СтрокиТовара[0];
					
					Если ВернутьИсходноеСостояние Тогда 						
						
						НовыйТовар.Номенклатура 	= Номенклатура;
						НовыйТовар.ПодтвержденнаяЗаявка =  ДанныеПоТовару.quantity;
						НовыйТовар.Цена = ДанныеПоТовару.price;
						НовыйТовар.ЦенаИсточник = ДанныеПоТовару.price;
						НовыйТовар.ЦенаБезСкидки = ДанныеПоТовару.price;
						НовыйТовар.Единица 		= НайтиЕдиницуТовараПоБазовой(НовыйТовар.Номенклатура.БазоваяЕдиница,Номенклатура);			    
						НовыйТовар.СтавкаНДС       = ПолучитьСтавкуНДС_(Номенклатура); //.Родитель.СтавкаНДС; //Перечисления.СтавкиНДС.НДС20;
						НовыйТовар.Заявка 		= ДанныеПоТовару.quantity;
						НовыйТовар.Количество 		= ДанныеПоТовару.quantity;
						
						ЗаполнитьЦенуНоменклатурыТабЧасти_(НовыйТовар,ЗаказКлиентаОбъект); 
						
						РассчитатьСуммуТабЧасти_(НовыйТовар,ЗаказКлиентаОбъект);
						
						ЗаказИзменен = Истина;
						
						
					ИначеЕсли НовыйТовар.ПодтвержденнаяЗаявка <>  Число(ДанныеПоТовару.quantity)
						И ИзменитьТоварВЗаказе Тогда
						
						НовыйТовар.Номенклатура 	= Номенклатура;
						НовыйТовар.ПодтвержденнаяЗаявка =  ДанныеПоТовару.quantity;  						
						
						ЗаказИзменен = Истина;	
						
					КонецЕсли;
					
					
				Иначе 
					//если есть дозаказ и он еще не отправлен на портал , то 
					//необходимо проверить сумму по кол-ву и прибавить только разницу 
					//а если была уже отправка дозаказа, то хоть и статус не заполнен, но товара этого или не будет 
					
					
					
					Если ИзменитьТоварВЗаказе Тогда 
						
						НовыйТовар = ЗаказКлиентаОбъект.Товары.Добавить();
						НовыйТовар.Цена = ДанныеПоТовару.price;
						НовыйТовар.ЦенаИсточник = ДанныеПоТовару.price;
						НовыйТовар.ЦенаБезСкидки = ДанныеПоТовару.price;
						НовыйТовар.Единица 		= НайтиЕдиницуТовараПоБазовой(НовыйТовар.Номенклатура.БазоваяЕдиница,Номенклатура);			    
						НовыйТовар.СтавкаНДС       = ПолучитьСтавкуНДС_(Номенклатура); //Номенклатура.Родитель.СтавкаНДС; //Перечисления.СтавкиНДС.НДС20;
						НовыйТовар.Заявка 		= ДанныеПоТовару.quantity;
						НовыйТовар.Количество 		= ДанныеПоТовару.quantity;
						//НовыйТовар.Сумма 		    = НовыйТовар.Количество * НовыйТовар.Цена;
						//НовыйТовар.ВсегоБезСкидки    = НовыйТовар.Количество * НовыйТовар.ЦенаБезСкидки;
						//НовыйТовар.Всего 		    = НовыйТовар.Количество * НовыйТовар.Цена;
						//
						ЗаполнитьЦенуНоменклатурыТабЧасти_(НовыйТовар,ЗаказКлиентаОбъект);
						
						РассчитатьСуммуТабЧасти_(НовыйТовар,ЗаказКлиентаОбъект); 
						
						НовыйТовар.Номенклатура 	= Номенклатура;
						НовыйТовар.ПодтвержденнаяЗаявка =  ДанныеПоТовару.quantity;
						
						ЗаказИзменен = Истина;	
					КонецЕсли;
					
					
				КонецЕсли;
				
				
				
				
			КонецЦикла;
			//также может быть так, что товар скорректирован и убран из заказа
			СтрокиДляУдаления = Новый Массив; 
			Для каждого ТоварЗаказа Из   ЗаказКлиентаОбъект.Товары  Цикл
				Если  МассивТоваровССайта.Найти(ТоварЗаказа.Номенклатура)  = неопределено Тогда
					
				СтрокиДляУдаления.Добавить(ТоварЗаказа); 	
					
				КонецЕсли;
				
			КонецЦикла;
			
			Для каждого СтрокаДляУдаления Из СтрокиДляУдаления Цикл
			
				ЗаказКлиентаОбъект.Товары.Удалить(СтрокаДляУдаления); 	
			
			КонецЦикла;
				
				
		КонецЕсли; 
	ИначеЕсли СтатусЗаказа = "ZF" Тогда
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Выполнена;
		
		Если ЗаказКлиентаОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
			
			ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен;
			ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.Выполнен;	
			
			
		КонецЕсли;
		
		
		
	ИначеЕсли СтатусЗаказа = "ZO" Тогда
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЧастичноВыполнена;
		
		Если ЗаказКлиентаОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
			РНКСущ = неопределено; 
			РезультатСвязиРНК = ПроверитьСвязьСРНК(ЗаказКлиентаОбъект.ссылка,РНКСущ);
			Если РезультатСвязиРНК И ЗначениеЗаполнено(РНКСущ)
				И РНКСущ.Отгружен = Перечисления.Отгружен.Отгружен Тогда
				
				ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично;	
				
			КонецЕсли;
			
			ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
		КонецЕсли;
		
	ИначеЕсли СтатусЗаказа = "ZP" Тогда
		//согласована , меняем статус
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Согласована;
		
		Если НЕ ДанныеАпи.order.Свойство("confirmedProducts") 
			 ИЛИ (ДанныеАпи.order.Свойство("distrShipmentStatus") И ДанныеАпи.order.distrShipmentStatus = "C") Тогда  		   
			
			ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
			
			Если СостояниеСогласованияДо <> Перечисления.СостоянияСогласования.ОтмененЦО Тогда
			
				ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененКонтрагент;	
			   
			КонецЕсли;
			
			
		Иначе 
			
			Если ЗаказКлиентаОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ 
				 И ЗаказКлиентаОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично
				  И ЗаказКлиентаОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.Выполнен Тогда
			
				ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;	
			
			КонецЕсли;
			
			ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
			
			Для каждого СтрокаПоТовару Из ЗаказКлиентаОбъект.товары Цикл
				
				СтрокаПоТовару.ПодтвержденнаяЗаявка = СтрокаПоТовару.Количество; 
				
			КонецЦикла;
			
			МетодДоставки  =  ДанныеАпи.order.shipmentMethod;
			
		КонецЕсли;    
		
		
	ИначеЕсли СтатусЗаказа = "ZD" Тогда
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Отменена;
		ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
		
		Если СостояниеСогласованияДо <> Перечисления.СостоянияСогласования.ОтмененЦО Тогда
			ЗаказКлиентаОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененКонтрагент;
			
			 ПричинаОтменыЗаявки =  ДанныеАпи.order.cancelReasonText + ?(ЗначениеЗаполнено(ДанныеАпи.order.cancelComment)," " + ДанныеАпи.order.cancelComment,""); 
			
		КонецЕсли;
	ИначеЕсли СтатусЗаказа = "ZA" Тогда 
		
		СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом;
		
	Иначе 
		Возврат; 
	КонецЕсли;
	
	Попытка
		
		Попытка
			ЗаказКлиентаОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Если ЗаказКлиентаОбъект.Проведен Тогда 
				ЗаказКлиентаОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Иначе 
				ЗаказКлиентаОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
		КонецПопытки; 
		ПараметрыДлязаписи = Новый Структура; 
		ПараметрыДлязаписи.Вставить("СтатусЗаказа_b2b",СтатусЗаказа_b2b);
		ПараметрыДлязаписи.Вставить("ДатаОбновления",ДатаОбновления);
		Если ЗначениеЗаполнено(ДатаОбновленияДозаказа) Тогда
			
			ПараметрыДлязаписи.Вставить("ДатаОбновленияДозаказа",ДатаОбновленияДозаказа);	
			
		КонецЕсли;
		Если ЗначениеЗаполнено(МетодДоставки) Тогда
			
			ПараметрыДлязаписи.Вставить("МетодДоставки",МетодДоставки);	
			
		КонецЕсли;
		ЗаписатьДополнительныеДанныеВРегистрЗаказов(ЗаказКлиентаОбъект.Ссылка,ПараметрыДлязаписи);
		
		Если ЗначениеЗаполнено(ПричинаОтменыЗаявки) Тогда
		
			ЗаписатьВДополнительныеРеквизитыПричинуОтмены(ЗаказКлиентаОбъект.ссылка,ПричинаОтменыЗаявки); 	
		
		КонецЕсли;
		
		Если СтатусЗаявкиДо <> ?(СтатусЗаказа_b2b = Неопределено,Перечисления.b2b_СтатусыЗаказов.ПустаяСсылка(),СтатусЗаказа_b2b)
			 ИЛИ СостояниеНакладнойДо <> ЗаказКлиентаОбъект.СостояниеНакладной
			  ИЛИ СостояниеСогласованияДо <> ЗаказКлиентаОбъект.СостояниеСогласования Тогда
		
			ЗаказИзменен = Истина; 
		
		КонецЕсли;
		
		Если ЗаказИзменен Тогда
		
			ЗаписатьВРегистрОбновленныеЗаказы(ЗаказКлиентаОбъект.ссылка,ТекущаяДатаСеанса()); 	
		
		КонецЕсли;
		
		Дозаказ = НайтиДоЗаказпоОсновному(ЗаказКлиентаОбъект.ссылка);
		
		СтатусДозаказаДо = СтатусДозаказаПоЗаказу(Дозаказ); 
		СостояниеНакладнойДозаказаДо =  Дозаказ.СостояниеНакладной; 
		СостояниеСогласованияДозаказаДо = Дозаказ.СостояниеСогласования; 
		
		ЗаказИзменен = Ложь;
		Если (СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Согласована 
			ИЛИ СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЧастичноВыполнена
			ИЛИ СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором
			ИЛИ ПризнакКорректировки
			ИЛИ ВернутьИсходноеСостояниеПодтвержден
			ИЛИ СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Отменена)
			И ЗначениеЗаполнено(Дозаказ) 
			И НЕ ЗначениеЗаполнено(СтатусДоЗаказа_b2b)Тогда
			
			ОбъектДозаказ = Дозаказ.ПолучитьОбъект();
			////////////////////////////////////////////////
			//блокировка
			ПроверкаБлокировки = Истина; 
			ЗаблокироватьОбъектДляИзменений(ИдентификаторЗапроса, ОбъектДозаказ,НеДобавлятьВРСОбновленные,ПроверкаБлокировки);
			Если НЕ ПроверкаБлокировки Тогда
			
				Возврат; 	
			
			КонецЕсли;
			///////////////////////////////////////////////
			ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
			Если СостояниеСогласованияДозаказаДо <> Перечисления.СостоянияСогласования.ОтмененЦО Тогда
				ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененКонтрагент;
			КонецЕсли;
			ОбъектДозаказ.Комментарий =   ОбъектДозаказ.Комментарий + "#Отменен"; 
			
			СтатусДоЗаказа_b2b = Перечисления.b2b_СтатусыДоЗаказов.Отменен;
			
			ПараметрыДлязаписи = Новый Структура; 
			ПараметрыДлязаписи.Вставить("СтатусДоЗаказа_b2b",СтатусДоЗаказа_b2b);
			ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(ОбъектДозаказ.Ссылка,ПараметрыДлязаписи,ЛОЖЬ);
			
			ОбъектДозаказ.Записать(); 
			
			Если ПризнакКорректировки
				 ИЛИ ВернутьИсходноеСостояниеПодтвержден Тогда //отвяжем дозаказ
				
				ДозаказыНР = РегистрыСведений.b2b_Дозаказы.СоздатьНаборЗаписей(); 	
				ДозаказыНР.Отбор.Заказ.Установить(ОбъектДозаказ.ссылка); 
				ДозаказыНР.Записать(); 
				
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтатусДоЗаказа_b2b) 
			И ЗначениеЗаполнено(Дозаказ) Тогда
			
			ОбъектДозаказ = Дозаказ.ПолучитьОбъект();
			
			////////////////////////////////////////////////
			//блокировка
			ПроверкаБлокировки = Истина; 
			ЗаблокироватьОбъектДляИзменений(ИдентификаторЗапроса, ОбъектДозаказ,НеДобавлятьВРСОбновленные,ПроверкаБлокировки);
			Если НЕ ПроверкаБлокировки Тогда
			
				Возврат; 	
			
			КонецЕсли;
			///////////////////////////////////////////////
						
			Если СтатусДоЗаказа_b2b = Перечисления.b2b_СтатусыДоЗаказов.Отменен Тогда
				
				ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
				Если СостояниеСогласованияДозаказаДо <> Перечисления.СостоянияСогласования.ОтмененЦО Тогда 
					ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененКонтрагент;
				КонецЕсли;
			ИначеЕсли СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором Тогда 
				
				ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
				ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО; 
				
			ИначеЕсли СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Выполнена Тогда 
				
				ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен;
				ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.Выполнен;
				
			ИначеЕсли СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЧастичноВыполнена Тогда 
				РНКСущ = неопределено; 
				РезультатСвязиРНК = ПроверитьСвязьСРНК(ОбъектДозаказ.ссылка,РНКСущ);
				Если НЕ РезультатСвязиРНК И ЗначениеЗаполнено(РНКСущ)
					И РНКСущ.Отгружен = Перечисления.Отгружен.Отгружен Тогда
					ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Выполнен;
				КонецЕсли;
				Если ЗаказКлиентаОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
				
					ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.Выполнен;
				Иначе
					ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
				КонецЕсли;
				
				
			ИначеЕсли  СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Согласована Тогда
				Если ОбъектДозаказ.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ
					И ОбъектДозаказ.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично 
					И ОбъектДозаказ.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.Выполнен
					Тогда
					
					ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;	
					
				КонецЕсли;
				
				ОбъектДозаказ.СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
				
			ИначеЕсли  СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.Отменена Тогда 
				
				ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
				
				Если СостояниеСогласованияДозаказаДо <> Перечисления.СостоянияСогласования.ОтмененЦО Тогда
					ОбъектДозаказ.СостояниеСогласования = ЗаказКлиентаОбъект.СостояниеСогласования; 
				КонецЕсли;
			ИначеЕсли  СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом Тогда 
				
				ОбъектДозаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
				ОбъектДозаказ.СостояниеСогласования =  Перечисления.СостоянияСогласования.НаСогласованииКонтрагент; 
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТоварыВДоЗаказе) Тогда
				
				МассивТоваровССайта = Новый Массив; 
				Для каждого ДанныеПоТовару Из ТоварыВДоЗаказе Цикл
					
					Номенклатура = НайтиТоварПоКодуТовара(ДанныеПоТовару.xmlId);
					
					Если  НЕ ЗначениеЗаполнено(Номенклатура) Тогда
						
						Продолжить; 
						
					КонецЕсли;
					
					МассивТоваровССайта.Добавить(Номенклатура); 
					
					Отбор = Новый Структура("Номенклатура",Номенклатура);
					СтрокиТовара = ОбъектДозаказ.Товары.НайтиСтроки(Отбор);
					Если СтрокиТовара.Количество() > 0  Тогда
						
						Если СтрокиТовара[0].Количество <> Число(ДанныеПоТовару.quantity) тогда 
							 ЗаказИзменен = Истина; 
						КонецЕсли; 
						
						НовыйТовар =  СтрокиТовара[0]; 
						НовыйТовар.Номенклатура 	= Номенклатура; 
						НовыйТовар.ПодтвержденнаяЗаявка 		= ДанныеПоТовару.quantity; 
						НовыйТовар.Количество 					= ДанныеПоТовару.quantity;
						//НовыйТовар.Сумма 		    = НовыйТовар.Количество * НовыйТовар.Цена;
						//НовыйТовар.ВсегоБезСкидки  = НовыйТовар.Количество * НовыйТовар.ЦенаБезСкидки;
						//НовыйТовар.Всего 		    = НовыйТовар.Количество * НовыйТовар.Цена;
						РассчитатьСуммуТабЧасти_(НовыйТовар,ОбъектДозаказ);
					КонецЕсли;
					
					
					
				КонецЦикла;
				
				СтрокиДляУдаления = Новый Массив; 
				Для каждого ТоварЗаказа Из   ОбъектДозаказ.Товары  Цикл
					Если  МассивТоваровССайта.Найти(ТоварЗаказа.Номенклатура)  = неопределено Тогда
						
						СтрокиДляУдаления.Добавить(ТоварЗаказа); 	
						
					КонецЕсли;
					
				КонецЦикла;
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаления Цикл
					
					ОбъектДозаказ.Товары.Удалить(СтрокаДляУдаления); 	
					
				КонецЦикла;
				
				
			КонецЕсли;
			
			ОбъектДозаказ.Записать();
			
			ПараметрыДлязаписи = Новый Структура; 
			ПараметрыДлязаписи.Вставить("СтатусДоЗаказа_b2b",СтатусДоЗаказа_b2b);
			ПараметрыДлязаписи.Вставить("СрокПодтвержденияПоДозаказу",СрокПодтвержденияПоДозаказу);
			
			ПРМ =  НайтиПеремещениеТоваровПоНомеру(НомерДоЗаказа); 
			
			Если ЗначениеЗаполнено(ПРМ) Тогда 	
				ПараметрыДлязаписи.Вставить("ПРМ",ПРМ);
			КонецЕсли;	
			
			ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(ОбъектДозаказ.Ссылка,ПараметрыДлязаписи,ЛОЖЬ);
			Если СтатусДозаказаДо <> СтатусДоЗаказа_b2b 
				 ИЛИ СостояниеНакладнойДозаказаДо <> ОбъектДозаказ.СостояниеНакладной 
				  ИЛИ СостояниеСогласованияДозаказаДо <> ОбъектДозаказ.СостояниеСогласования Тогда
			
				  ЗаказИзменен = Истина; 
			
			  КонецЕсли;
			  
			  Если ЗаказИзменен 
				  И НЕ НеДобавлятьВРСОбновленные Тогда
				  
				  ЗаписатьВРегистрОбновленныеЗаказы(ОбъектДозаказ.ссылка,ТекущаяДатаСеанса()); 	
				  
			  КонецЕсли;
		КонецЕсли; 			 
		
		
		Если СтатусЗаказа = "ZC" Тогда
			
			ОбновленныеЗаказы.Добавить(ЗаказКлиентаОбъект.ссылка); 
			
		КонецЕсли;
		
	Исключение
		
		Сообщить(ОписаниеОшибки()); 
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаблокироватьОбъектДляИзменений(Знач ИдентификаторЗапроса, Знач ЗаказОбъект, ИзЗаказа = Ложь, ПроверкаБлокировки)
	
	Если ИзЗаказа Тогда
		
		ПроверкаБлокировки = Истина; 
		
		Возврат; 
		
		
	КонецЕсли;
	//Если ЗаказОбъект.Заблокирован() Тогда
	//	
	//	ЗаписатьОшибкуВЖурнал(ИдентификаторЗапроса,"Не удалось заблокировать документ заказа для обновления " + Строка(ЗаказОбъект.ссылка)); 
	//	
	//	ПроверкаБлокировки = Ложь; 
	//	
	//	Возврат; 
	//	
	//КонецЕсли;
	
	Попытка
		
		ЗаказОбъект.Заблокировать();
		
	Исключение
		
		ЗаписатьВРегистрРегистрацияБлокировок(ЗаказОбъект.ссылка); 
				
		ВремяОкончания = ТекущаяДата() + 1;
		Пока ТекущаяДата() <= ВремяОкончания Цикл	
		КонецЦикла;
		
		Попытка
			
			ЗаказОбъект.Заблокировать();
			
			ОчиститьРегистрРегистрацииБлокировокПоЗаказу(ЗаказОбъект.ссылка); 
			
		Исключение
			ПроверкаБлокировки = Ложь;
			
			ОчиститьРегистрРегистрацииБлокировокПоЗаказу(ЗаказОбъект.ссылка);
			
			ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Не удалось заблокировать документ заказа для обновления " + Строка(ЗаказОбъект.ссылка));
		КонецПопытки;
		
	КонецПопытки;
	

КонецПроцедуры // ОбновитьЗаказКлиента()

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
