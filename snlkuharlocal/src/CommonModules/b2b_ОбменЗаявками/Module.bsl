//методы Update 

Процедура ОтправкаНаСогласованиеТолькоОтгрузкиОтПоставщика(ВходныеПараметры,РезультатОтправки,ИдентификаторЗапроса = неопределено)Экспорт

	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
	
	//записать ошибку в журнал 
	    ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменЕЭ_POST",УровеньЖурналаРегистрации.Ошибка,,,,);
		
		Возврат; 
	
	КонецЕсли; 
	Если ВходныеПараметры.Свойство("Подразделение") Тогда
		
		Подразделение = ВходныеПараметры.Подразделение; 	
	Иначе 
		Подразделение = неопределено; 
	КонецЕсли;
	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаВыгрузки(Подразделение); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисВыгрузки);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика(ВходныеПараметры);
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор; 
	
	ХранитьПодробностиЛогирования = ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
	
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
		//в журнал запишем что отправили и когда, и потом уже ответ 
		ЗаписатьВЖурналЗапросыНаОбновлениеЗаказов(Строка(ИдентификаторЗапроса),СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
	Исключение
		
		//записать ошибку в журнал
		Комментарий = "Не удалось отправить запрос на согласование заказа. Ошибка!";
		РезультатДанные = СтруктураРезультат();
		ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);
		
		Возврат; //не подключился 
		
	КонецПопытки;
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;

	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
		//запись в журнал 
		 //записать состояние заказа  , оно изменяется на подтверждение от клиента 
		 Если Структура_JSON_Ответ.Свойство("data") Тогда
		 
		 	ОтработатьЗапросНаОбновление(Структура_JSON_Ответ,ВходныеПараметры.Заказ); 	
			
			РезультатДанные = СтруктураРезультат();
			
			РезультатДанные.ИдентификаторКлиента = Структура_JSON_Ответ.requestId;
			РезультатДанные.Документ = ВходныеПараметры.Заказ;
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			
			ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"",,ХранитьПодробностиЛогирования);
			
			РезультатОтправки = Истина; 
		 КонецЕсли;
	Иначе 
		//запись в журнал
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400
			ИЛИ КодОшибки = 403 Тогда   		
			
			ИнформацияОбОшибке = Структура_JSON_Ответ.Message;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = СтруктураРезультат(); 
		РезультатДанные.РезультатJson = ТелоСообщения;
		РезультатДанные.Документ = ВходныеПараметры.Заказ;
		
		ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);

	КонецЕсли; 


КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ОтработатьЗапросНаОбновление(ДанныеОтвет,Знач Заказ)
	
	//ЗаказОбъект = Заказ.ПолучитьОбъект(); 
	
	
	Если ДанныеОтвет.data.orders.Количество() > 0  Тогда
		
		СтатусЗаказа_b2b = ПолучитьИзСоответствияСтатусЗаказа(ДанныеОтвет.data.orders[0].order.statusId); 
		ДатаОбновления = ПреобразоватьДату(ДанныеОтвет.data.orders[0].order.dateUpdate);
		Если ДанныеОтвет.data.orders[0].Свойство("additionalOrder") Тогда 
			СтатусДоЗаказа_b2b = ПолучитьИзСоответствияСтатусДоЗаказа(ДанныеОтвет.data.orders[0].additionalOrder.statusId);
		Иначе 
			СтатусДоЗаказа_b2b = неопределено; 
		Конецесли; 
		СрокПодтвержденияДоЗаказа  = ПреобразоватьДату(ДанныеОтвет.data.orders[0].order.cancellationTimeout2);
		
		ПараметрыДлязаписи = Новый Структура; 
		ПараметрыДлязаписи.Вставить("СтатусЗаказа_b2b",СтатусЗаказа_b2b);
		ПараметрыДлязаписи.Вставить("ДатаОбновления",ДатаОбновления);
		
		ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыДлязаписи);
		
		Если ЗначениеЗаполнено(СтатусДоЗаказа_b2b) Тогда 
			ПараметрыДлязаписи = Новый Структура; 
			ПараметрыДлязаписи.Вставить("СтатусДоЗаказа_b2b",СтатусДоЗаказа_b2b);
			ПараметрыДлязаписи.Вставить("СрокПодтвержденияДоЗаказа",СрокПодтвержденияДоЗаказа);
			
