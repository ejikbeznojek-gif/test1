Процедура ЗагрузитьДанныеПоПунктамДоставки() Экспорт
	
		
	ДанныеДляОтправкиЗапроса = ПолучитьПараметрыМетодаЗагрузкиПунктовДоставки();
	Если НЕ ЗначениеЗаполнено(ДанныеДляОтправкиЗапроса.IDПользователяНаСайте) Тогда
		
		ЗаписатьОшибкуВЖурнал("","Не задан логин пользователя для отправки запроса на сайт ""Загрузить данные по пунктам доставки (b2b)"" "); 
		Возврат; 
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура("IDПользователя",ДанныеДляОтправкиЗапроса.IDПользователяНаСайте);
	
	ПолучениеДанныхПоПунктамДоставки(ВходныеПараметры); 

КонецПроцедуры // ()

