#Область КомандыДляОтправкиНаСайт
//здесь у нас будет запрос  с параметрами для загрузки : 
 
	// <Описание процедуры>
	//
	// Параметры:
	//  <Параметр1>  - <Тип.Вид> - <описание параметра>
	//                 <продолжение описания параметра>
	//  <Параметр2>  - <Тип.Вид> - <описание параметра>
	//                 <продолжение описания параметра>
	// в том числе новых, в том числе отработка ответа от клиента и от поставщика 
	
//ВходныеПараметры: СтатусыЗаказов,ДатаСозданияНачало,ДатаСозданияОкончание,
//ДатаОбновленияНачало,ДатаОбновленияОкончание,Пользователь ID клиента,номерЗаявки,ИД заявки 
Процедура ПолучениеДанныхПоЗаказам(Знач ВходныеПараметры,ОбновленныеЗаказы) Экспорт
	
	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
	
		ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменЕЭ_GET",УровеньЖурналаРегистрации.Ошибка,,,,); 
	
		Возврат; 
	
	КонецЕсли;
	Если ВходныеПараметры.Свойство("Подразделение") Тогда
		
		Подразделение = ВходныеПараметры.Подразделение; 	
	Иначе 
		Подразделение = Справочники.Подразделения.НайтиПоКоду("SSP-0001"); 
	КонецЕсли;	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаЗагрузки(Подразделение); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисЗагрузки);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляЗагрузкиЗаказов(ВходныеПараметры);
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор;
	
	ХранитьПодробностиЛогирования =  ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
	
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
		//в журнал запишем что отправили и когда, и потом уже ответ		 
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказов(Строка(ИдентификаторЗапроса),СтрокаJSON,ХранитьПодробностиЛогирования); 
		
	Исключение
		
		//записать ошибку в журнал
		Комментарий = "Не удалось отправить get запрос. Ошибка!";
		РезультатДанные = СтруктураРезультат();
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);
		
		Возврат; //не подключился 
		
	КонецПопытки; 
	
	//отработка ответа, пока непонятно как отрабатывать, в какой документ загружать данные 
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ);                                                                                           
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;

	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	ДатаНачалаРаботыВ1С = ДанныеДляОтправкиGetЗапроса.ДатаНачалаРаботыВ1С; 
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
		//запись в журнал 
		//записать можно id запроса, зарегистрированного на портале в журнал
		Если Структура_JSON_Ответ <> неопределено 
			И Структура_JSON_Ответ.Свойство("data")
			И ТипЗнч(Структура_JSON_Ответ.data) = Тип("Структура")
			И Структура_JSON_Ответ.data.Свойство("orders") 
			И Структура_JSON_Ответ.data.orders.Количество() > 0 Тогда
			
			///КонтрагентПокупатель = ВходныеПараметры.Контрагент;
			ЗаписатьБезЗаказа = Истина; 
			Для каждого СтруктураЗаказа Из Структура_JSON_Ответ.data.orders Цикл
				
				//сначала по ИД заказа , затем доделать и от вида поиска 
				
				ЗаказКлиента = НайтиЗаказКлиента(СтруктураЗаказа);
				ДатаСозданияЗаказа = НачалоДня(ПреобразоватьДату((СтруктураЗаказа.order.dateCreate)));
				
				
				СтатусЗаказа =  СтруктураЗаказа.order.statusId; 
				
				Если Не ЗначениеЗаполнено(ЗаказКлиента) Тогда
					Если ДатаНачалаРаботыВ1С > ДатаСозданияЗаказа
						И СтатусЗаказа <> "ZC" Тогда
												
						Продолжить; 	
					
					КонецЕсли;
					Если НЕ СтруктураЗаказа.order.Свойство("orderedProducts") Тогда
					
						Продолжить; 	
					
					КонецЕсли;
					ЗаказКлиента = СоздатьЗаказКлиента(СтруктураЗаказа);
					Если НЕ ЗначениеЗаполнено(ЗаказКлиента) Тогда
					
						ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Не создан заказ по контрагенту " + СтруктураЗаказа.order.user);
						
						Продолжить; 	
					
					КонецЕсли;
					ОбновленныеЗаказы.Добавить(ЗаказКлиента.ссылка);
					ЗаписатьБезЗаказа = Ложь; 
				Иначе 
					 ДатаОбновления = ПреобразоватьДату(СтруктураЗаказа.order.dateUpdate);
					 
					 ДатаОбновленияДозаказа = неопределено; 
					 
					 Если СтруктураЗаказа.Свойство("additionalOrder") Тогда
					 
					 	ДатаОбновленияДозаказа = ПреобразоватьДату(СтруктураЗаказа.additionalOrder.dateUpdate); 
					 
					 КонецЕсли; 			 
					 
					 
					 ДатаОбновленияВ1С = ДатаОбновленияПоЗаказу(ЗаказКлиента);
					 ДатаОбновленияДозаказаВ1С = ДатаОбновленияПоДоЗаказу(ЗаказКлиента);
					 
					 ВернутьИсходноеСостояние = Ложь; 
					 Если ВходныеПараметры.Свойство("ВернутьИсходноеСостояние")
						 И ВходныеПараметры.ВернутьИсходноеСостояние Тогда
						 
						 ВернутьИсходноеСостояние = Истина;  	
						 
					 КонецЕсли;
					 Если ДатаОбновления > ДатаОбновленияВ1С
						  ИЛИ ?(ДатаОбновленияДозаказа = неопределено,Дата(1,1,1),ДатаОбновленияДозаказа) > ДатаОбновленияДозаказаВ1С 
						  ИЛИ ВернутьИсходноеСостояние Тогда
						  
						 НеДобавлятьВРСОбновленные = Ложь; 
						 Если ВходныеПараметры.Свойство("ИзЗаказа")
							 И ВходныеПараметры.ИзЗаказа Тогда
							 
							 НеДобавлятьВРСОбновленные = Истина;  	
							 
						 КонецЕсли;		 
						 ЗаписатьБезЗаказа = Ложь;
						 
						 ОбновитьЗаказКлиента(СтруктураЗаказа,ЗаказКлиента,ОбновленныеЗаказы,НеДобавлятьВРСОбновленные,ВернутьИсходноеСостояние,ИдентификаторЗапроса); 	
						 
					 КонецЕсли;
				 КонецЕсли;
				 
				  
				
				//и еще проверять дату последнего обновления при загрузке, если она совпадает, то не грузить 
				//а вот если есть,то меняем статус дозаказа и заказа   
				РезультатДанные = СтруктураРезультат();
				
				РезультатДанные.ИдентификаторКлиента = Структура_JSON_Ответ.requestId;
				РезультатДанные.Документ = ЗаказКлиента.ссылка;
				РезультатДанные.РезультатJson = Структура_JSON_Ответ;
				
			    ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"",,ХранитьПодробностиЛогирования);
			КонецЦикла;
			
			Если ЗаписатьБезЗаказа Тогда
				
				РезультатДанные = СтруктураРезультат();
				
				РезультатДанные.ИдентификаторКлиента = Структура_JSON_Ответ.requestId;
				РезультатДанные.Документ = неопределено;
				РезультатДанные.РезультатJson = Структура_JSON_Ответ;
				
				ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"",,ХранитьПодробностиЛогирования);	
				
			КонецЕсли;
			//Отправить запрос на обновление статуса
			Для каждого ЗаказОбновить Из ОбновленныеЗаказы  Цикл
				
				ПараметрыДляОтправки = ФормированиеСтруктурыОтветОбновленныеЗаказы(ЗаказОбновить,Подразделение); 
				
				b2b_ОбменЗаявками.ОтправкаСтатусаЗаказа(ПараметрыДляОтправки,ЛОЖЬ,Истина); 	
				
			КонецЦикла;
		Иначе
			РезультатДанные = СтруктураРезультат(); 
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"Не найдены заказы по запросу",,ХранитьПодробностиЛогирования);
		КонецЕсли;
	Иначе
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400 Тогда   		
			
			ИнформацияОбОшибке = Структура_JSON_Ответ.Message;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = СтруктураРезультат(); 
		РезультатДанные.РезультатJson = ТелоСообщения; 
		
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);
		
	КонецЕсли; 
	
	
	
КонецПроцедуры

Функция ФормированиеСтруктурыОтветОбновленныеЗаказы(Знач ЗаказОбновить,Подразделение)
	
	//Перем МассивДанных, ПараметрыДляОтправки, СтруктураТовара, ТоварЗаказа;
	
	ПараметрыДляОтправки = Новый Структура; 
	ПараметрыДляОтправки.Вставить("НомерЗаявки",ЗаказОбновить.НомерЗаказа);
	ПараметрыДляОтправки.Вставить("IDЗаявки",ЗаказОбновить.ИдЗаказа);
	ПараметрыДляОтправки.Вставить("СтатусЗаказа","ZN");
	ПараметрыДляОтправки.Вставить("Заказ",ЗаказОбновить.ссылка);
	ПараметрыДляОтправки.Вставить("ТипЗапроса","ОтправкаСтатусаНаПортал");
	ПараметрыДляОтправки.Вставить("Подразделение",Подразделение);
	
	МассивДанных = Новый Массив; 
	Для каждого ТоварЗаказа  Из ЗаказОбновить.Товары Цикл
		
		СтруктураТовара = Новый Структура; 
		СтруктураТовара.Вставить("IDТовара",ПолучитьКодТовараДляПортала(ТоварЗаказа.Номенклатура));
		СтруктураТовара.Вставить("Количество",ТоварЗаказа.Количество);
		СтруктураТовара.Вставить("Цена",ТоварЗаказа.Цена);
		
		МассивДанных.Добавить(СтруктураТовара);	
		
	КонецЦикла;
	ПараметрыДляОтправки.Вставить("Товары",МассивДанных);
	Возврат ПараметрыДляОтправки;

