//
Функция ТекстОшибкиПоИдентификаторуЗапроса(ИдентификаторЗапроса)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.ТекстОшибки КАК ТекстОшибки
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, ИдентификаторЗапроса = &ИдентификаторЗапроса) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних";
	
	Запрос.УстановитьПараметр("ИдентификаторЗапроса", Строка(ИдентификаторЗапроса));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.ТекстОшибки; 	
	
	КонецЕсли;
	
	Возврат ""; 


КонецФункции // ТекстОшибкиПоИдентификаторуЗапрроса()


