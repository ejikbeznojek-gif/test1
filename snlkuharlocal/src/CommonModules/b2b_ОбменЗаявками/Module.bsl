//
Функция Этоb2bЗаказКлиента(Знач Заказ) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗаявкиКлиентов.Заказ КАК Заказ
		|ИЗ
		|	РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентов
		|ГДЕ
		|	b2b_ЗаявкиКлиентов.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой(); 

КонецФункции // Этоb2bЗаказКлиента()

