	|			ТОГДА 0
	|		ИНАЧЕ СУММА(ЕСТЬNULL(ВложенныйЗапрос.КолКонФакт, 0))
	|	КОНЕЦ КАК Остаток,
	//--Данилова Е.В. 18.02.2025
	|	ШтрихКодыНоменклатуры.Наименование КАК ШтрихКод
	|ПОМЕСТИТЬ ВТОстатки
	|ИЗ
	|	Справочник.Номенклатура КАК Ном
	//++Данилова Е.В. 24.11.2025 HELP-7957
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	//--Данилова Е.В. 24.11.2025 
	|			СУММА(Остатки.КоличествоКонечныйОстаток) КАК КолКонБух,
	|			ВЫБОР
	|				КОГДА СУММА(Остатки.КоличествоКонечныйОстаток) = 0
	|					ТОГДА NULL
	|				ИНАЧЕ СУММА(Остатки.СуммаКонечныйОстаток) / СУММА(Остатки.КоличествоКонечныйОстаток)
	|			КОНЕЦ КАК ЦенаСеб,
