Функция ПолучитьКодТовараДляПортала(Знач Номенклатура) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Код КАК ОсновнойКод,
		|	Номенклатура1.Код КАК КодРодителя
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура1
		|		ПО Номенклатура.Родитель = Номенклатура1.Ссылка
		|ГДЕ
		|	Номенклатура.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.КодРодителя + "#"+ ВыборкаДетальныеЗаписи.ОсновнойКод; 	
	
	КонецЕсли;
	
	Возврат Номенклатура.Код; 

	

КонецФункции // ПолучитьКодТовараДляДозаказа()


