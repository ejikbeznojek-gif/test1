Функция ЗаполнитьСтруктуруДляЗагрузкиЗаказов(Знач ВходныеПараметры)
	                                                                  	
	СтруктураЗапроса = СформироватьСтруктуруGetЗапроса(); 
	
	СтруктураЗапроса.data.filter.orderType = "OT_REQUEST"; 
	
	ДатаЗапретаРедактирования = Константы.ДатаЗапретаРедактирования.Получить(); 
	
	ЕстьФильтр = Ложь; 
	Если ВходныеПараметры.Свойство("СтатусыЗаказов") 
		И ТипЗнч(ВходныеПараметры.СтатусыЗаказов) = Тип("Массив")
		И ВходныеПараметры.СтатусыЗаказов.Количество() > 0 Тогда
		
		Для каждого ЭлементМассива Из ВходныеПараметры.СтатусыЗаказов Цикл
			statusId = ПолучитьИзСоответствияСтатусЗаказаДляОтправкиНаПортал(ЭлементМассива); 
			СтруктураЗапроса.data.filter.Вставить("statusId",Новый Массив); 
			СтруктураЗапроса.data.filter.statusId.Добавить(statusId); 
			
		КонецЦикла;		
		
		ЕстьФильтр = Истина;
		
	КонецЕсли;
	Если ВходныеПараметры.Свойство("ДатаСозданияНачало")
		И ВходныеПараметры.Свойство("ДатаСозданияОкончание")
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаСозданияНачало)
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаСозданияОкончание) Тогда
		
		Если ЗначениеЗаполнено(ДатаЗапретаРедактирования) Тогда
		
			ДатаСозданияНачало = Макс(ДатаЗапретаРедактирования,ВходныеПараметры.ДатаСозданияНачало); 
			ДатаСозданияОкончание = Макс(ДатаЗапретаРедактирования,ВходныеПараметры.ДатаСозданияОкончание);
		Иначе 
			ДатаСозданияНачало = ВходныеПараметры.ДатаСозданияНачало;
			ДатаСозданияОкончание = ВходныеПараметры.ДатаСозданияОкончание;
		КонецЕсли;
		
		СтруктураЗапроса.data.filter.Вставить("dateCreateFrom");
		СтруктураЗапроса.data.filter.Вставить("dateCreateTo");
		СтруктураЗапроса.data.filter.dateCreateFrom = ПреобразоватьДатуДляПередачиНаПортал(ДатаСозданияНачало); 
		СтруктураЗапроса.data.filter.dateCreateTo = ПреобразоватьДатуДляПередачиНаПортал(ДатаСозданияОкончание);
		
		ЕстьФильтр = Истина;
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ДатаОбновленияНачало")
		И ВходныеПараметры.Свойство("ДатаОбновленияОкончание")
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаОбновленияНачало)
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаОбновленияОкончание) Тогда
		
		СтруктураЗапроса.data.filter.Вставить("dateUpdateFrom");
		СтруктураЗапроса.data.filter.Вставить("dateUpdateTo");
		
		Если ЗначениеЗаполнено(ДатаЗапретаРедактирования) Тогда
			
			ДатаОбновленияНачало = Макс(ДатаЗапретаРедактирования,ВходныеПараметры.ДатаОбновленияНачало); 
			ДатаОбновленияОкончание = Макс(ДатаЗапретаРедактирования,ВходныеПараметры.ДатаОбновленияОкончание);
		Иначе 
			ДатаОбновленияНачало = ВходныеПараметры.ДатаОбновленияНачало;
			ДатаОбновленияОкончание = ВходныеПараметры.ДатаОбновленияОкончание;
		КонецЕсли;

		
		СтруктураЗапроса.data.filter.dateUpdateFrom = ПреобразоватьДатуДляПередачиНаПортал(ДатаОбновленияНачало); 
		СтруктураЗапроса.data.filter.dateUpdateTo = ПреобразоватьДатуДляПередачиНаПортал(ДатаОбновленияОкончание);
		
		ЕстьФильтр = Истина;
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Пользователь")
		И ЗначениеЗаполнено(ВходныеПараметры.Пользователь) Тогда
		
		СтруктураЗапроса.data.filter.Вставить("user");
		СтруктураЗапроса.data.filter.user = ВходныеПараметры.Пользователь; 	
		
		ЕстьФильтр = Истина;
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("номерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.номерЗаявки) Тогда
		
		СтруктураЗапроса.data.filter.Вставить("accountNumber");
		СтруктураЗапроса.data.filter.accountNumber = ВходныеПараметры.номерЗаявки; 	
		
		ЕстьФильтр = Истина;
	КонецЕсли;
	
	Если НЕ ЕстьФильтр Тогда
		
		СтруктураЗапроса.data.filter.Вставить("dateUpdateFrom");
		СтруктураЗапроса.data.filter.Вставить("dateUpdateTo");
		
		Если ЗначениеЗаполнено(ДатаЗапретаРедактирования) Тогда
			//долго стало отрабатывать из-за закрытия формы (пауза), ограничение в 3 дня 
			ДатаОбновленияНачало = НачалоДня(КонецДня(ТекущаяДатаСеанса()) - 24*3600*3); // ДатаЗапретаРедактирования;  //Макс(ДатаЗапретаРедактирования,НачалоМесяца(ТекущаяДатаСеанса())); 
			ДатаОбновленияОкончание = КонецДня(ТекущаяДатаСеанса()); //Макс(ДатаЗапретаРедактирования,КонецМесяца(ТекущаяДатаСеанса()));

		Иначе 
			ДатаОбновленияНачало = НачалоДня(КонецДня(ТекущаяДатаСеанса()) - 24*3600*3); //НачалоМесяца(ТекущаяДатаСеанса());
			ДатаОбновленияОкончание = КонецМесяца(ТекущаяДатаСеанса());
		КонецЕсли;


		
		СтруктураЗапроса.data.filter.dateUpdateFrom = ПреобразоватьДатуДляПередачиНаПортал(ДатаОбновленияНачало); 
		СтруктураЗапроса.data.filter.dateUpdateTo = ПреобразоватьДатуДляПередачиНаПортал(ДатаОбновленияОкончание);	
		
	КонецЕсли;
	
	Возврат СтруктураЗапроса; 
	
КонецФункции // ПолучениеСпискаЗаказов()

