Функция СвязанныеРНКЗаказ(Знач Заказ) Экспорт
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	ЗаказРасходныеНакладные.Документ КАК РНК
	 |ИЗ
	 |	Документ.Заказ.РасходныеНакладные КАК ЗаказРасходныеНакладные
	 |ГДЕ
	 |	ЗаказРасходныеНакладные.Ссылка = &Заказ
	 |	И ЗаказРасходныеНакладные.Документ.Проведен";  
	 
	 Запрос.УстановитьПараметр("Заказ", Заказ);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 
	 Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("РНК"); 
	
КонецФункции

