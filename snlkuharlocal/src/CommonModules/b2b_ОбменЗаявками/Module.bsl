Процедура ЗаписатьВОчередьНаОтправку(Знач Заказ, ТипЗапроса,ПараметрыНаОтправку,МассивСообщений,МассивОшибок = неопределено) Экспорт 

	МенеджерЗаписи = РегистрыСведений.b2b_ЗапросыНаОбновление.СоздатьМенеджерЗаписи(); 
	МенеджерЗаписи.Документ = Заказ; 
	МенеджерЗаписи.ТипЗапроса = ТипЗапроса; 
	МенеджерЗаписи.ВходящиеПараметры = Новый ХранилищеЗначения(ПараметрыНаОтправку,Новый СжатиеДанных(9)); 
	МенеджерЗаписи.ДатаЗаписи = ТекущаяДатаСеанса(); 
	МенеджерЗаписи.ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор); 
	Попытка
		
		МенеджерЗаписи.Записать(); 
		
	
	Исключение
	
	КонецПопытки;
	
	Сообщить("Записан в очередь на отправка запрос с типом " + ТипЗапроса);
	МассивСообщений.Добавить("Записан в очередь на отправка запрос с типом " + ТипЗапроса); 
	
	// сразу пока выполнение пока
	ТекстСообщения = ""; 
	ОтработатьЗапросыВОчереди(ТекстСообщения,МассивОшибок);
	
	МассивСообщений.Добавить(ТекстСообщения); 

КонецПроцедуры // ЗаписатьВОчередьНаОтправку()

