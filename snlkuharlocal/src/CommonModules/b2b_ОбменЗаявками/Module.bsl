Функция НайтиЕдиницуТовараПоБазовой(БазоваяЕдиница,Номенклатура)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Единицы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Единицы КАК Единицы
		|ГДЕ
		|	Единицы.Владелец = &Владелец
		|	И НЕ Единицы.ПометкаУдаления
		|	И Единицы.ОКЕИ = &ОКЕИ";
	
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	Запрос.УстановитьПараметр("ОКЕИ", БазоваяЕдиница);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ссылка; 
	КонецЕсли;

	Возврат Справочники.Единицы.ПустаяСсылка(); 
	
