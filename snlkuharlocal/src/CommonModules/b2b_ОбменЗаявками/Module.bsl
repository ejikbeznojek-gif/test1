Процедура ЗаписатьПунктыДоставки(ТаблицаДанных,ИдентификаторЗапроса)

	 Для каждого СтрокаТаблицы Из ТаблицаДанных Цикл
	 
	 	ПунктДоставки = Справочники.ПунктыДоставки.НайтиПоКоду(СтрокаТаблицы.Код);
		Если Не ЗначениеЗаполнено(ПунктДоставки) Тогда
			
			ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Пункт доставки по коду " + СтрокаТаблицы.Код + " не найден",,СтрокаТаблицы.Структураданных);
			
		КонецЕсли;
		ЮридическоеЛицо = Справочники.Контрагенты.НайтиПоКоду(СтрокаТаблицы.КодЮридическогоЛица);
		
		Если Не ЗначениеЗаполнено(ЮридическоеЛицо) Тогда
		
			ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Юридическое лицо по коду " + СтрокаТаблицы.КодЮридическогоЛица + " не найден",,СтрокаТаблицы.СтруктураДанныхПолная);
		
		КонецЕсли;
				
		Если ЗначениеЗаполнено(ПунктДоставки)
			И ЗначениеЗаполнено(ЮридическоеЛицо) Тогда
		
			ЗаписатьВРегистрПунктыДоставки(СтрокаТаблицы,ИдентификаторЗапроса,ПунктДоставки,ЮридическоеЛицо); 	
		 
		КонецЕсли;
	 
	 КонецЦикла;

 КонецПроцедуры // ЗаписатьПунктыДоставки()
 
