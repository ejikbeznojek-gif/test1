		МенеджерЗаписи.Запрос = Новый ХранилищеЗначения(Запрос,Новый СжатиеДанных(9));	
		
	КонецЕсли;
	 
	
	ПопыткаЗаписиВЖурнал( МенеджерЗаписи,"b2b_ЗапросыНаПолучениеЗаказовИстория",ИдентификаторЗапроса); 

