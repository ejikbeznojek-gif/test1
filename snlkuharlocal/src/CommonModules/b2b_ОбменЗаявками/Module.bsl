	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ДатаОтгрузкиДозаказа")
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаОтгрузкиДозаказа) Тогда
		
		СтруктураЗапроса.Data.order.eeeShipmentDate = ПреобразоватьДатуДляПередачиНаПортал(ВходныеПараметры.ДатаОтгрузкиДозаказа); 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("МетодДоставки")
		И ЗначениеЗаполнено(ВходныеПараметры.МетодДоставки) Тогда
		
		СтруктураЗапроса.Data.order.shipmentMethod = ВходныеПараметры.МетодДоставки; 	
		
	КонецЕсли;


		
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()

Функция ЗаполнитьСтруктуруДляОтправкиОтменыОтгрузки(ВходныеПараметры)

