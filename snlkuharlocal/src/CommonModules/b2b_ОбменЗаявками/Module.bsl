Процедура ПометитьНаУдалениеРНК(Знач Заказ, РезультатУдаления) Экспорт 
	
	РезультатУдаления = Ложь; 
	РНКСуществующее = неопределено; 
	СвязьПустая = ПроверитьСвязьСРНК(Заказ,РНКСуществующее);
	Если СвязьПустая Тогда
		
		Сообщить("РНК по заказу " + Строка(Заказ) + " не найден"); 
		Возврат; 	
		
	КонецЕсли;
	
	 РНКОбъект = РНКСуществующее.ПолучитьОбъект(); 
	 РНКОбъект.ПометкаУдаления = истина; 
	 
	 
	 Попытка
		 Если РНКОбъект.Проведен Тогда
			 
			 РНКОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);	
			 
		 КонецЕсли;
		 РНКОбъект.Записать(); 
		  
		 //
		 РезультатУдаления = Истина;
		 
		 //попробуем отправить пустую дату отгрузки 
		 
		 ПометитьНаУдалениеРНКОтправкаЗапросаНаПортал(Заказ);

		 
	 Исключение
		 Сообщить(ОписаниеОшибки()); 
	 КонецПопытки;  
	 

КонецПроцедуры

