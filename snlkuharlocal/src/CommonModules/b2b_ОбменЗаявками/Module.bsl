	 СтруктураЗапросаData = Новый Структура; 
	 СтруктураЗапросаData.Вставить("accountNumber");
	 СтруктураЗапросаData.Вставить("bxId") ; 
	 
	 СтруктураЗапросаData.Вставить("order"); 
	 
	 СтруктураЗапросаOrder = Новый Структура;
	 Если ДатаОтгрузкиЗаказа  Тогда
	 
	 	СтруктураЗапросаOrder.Вставить("distrShipmentDate");	
	 
	 КонецЕсли;
	 
	 
	 Если ДатаОтгрузкиДоЗаказа Тогда
	 
	 	СтруктураЗапросаOrder.Вставить("eeeShipmentDate");	
	 
	КонецЕсли;
	
	Если ДобавитьМетодДоставки Тогда
	
		СтруктураЗапросаOrder.Вставить("shipmentMethod");	
	
	КонецЕсли;  
	 
	 
	 
	 СтруктураЗапросаData.order = СтруктураЗапросаOrder;    
	 
