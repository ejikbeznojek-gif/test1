Функция СформироватьСтруктуруGetЗапроса() Экспорт

	  СтруктураЗапроса = Новый Структура; 
	  СтруктураЗапроса.Вставить("data"); 
	  
	  СтруктураЗапросаData = Новый Структура; 
	  СтруктураЗапросаData.Вставить("filter");
	  СтруктураЗапросаData.Вставить("params",Новый Структура);
	  
	  CтруктураЗапросаFilter = Новый Структура;
	  CтруктураЗапросаFilter.Вставить("orderType");
	  
	  //CтруктураЗапросаFilter.Вставить("statusId", Новый Массив);
	  //CтруктураЗапросаFilter.Вставить("dateCreateFrom");
	  //CтруктураЗапросаFilter.Вставить("dateCreateTo");
	  //CтруктураЗапросаFilter.Вставить("dateUpdateFrom");
	  //CтруктураЗапросаFilter.Вставить("dateUpdateTo");
	  //CтруктураЗапросаFilter.Вставить("dateUpdateBxFrom");
	  //CтруктураЗапросаFilter.Вставить("dateUpdateBxTo");
	  //CтруктураЗапросаFilter.Вставить("user");
	  //CтруктураЗапросаFilter.Вставить("accountNumber");
	  //CтруктураЗапросаFilter.Вставить("bxId");
	  //CтруктураЗапросаFilter.Вставить("bxId");
	  
	  СтруктураЗапросаData.filter = CтруктураЗапросаFilter; 
	  СтруктураЗапросаData.params.Вставить("skipProducts",true); 
	  
	  СтруктураЗапроса.Data = СтруктураЗапросаData; 
	  
	  Возврат СтруктураЗапроса; 
	  

КонецФункции // СформироватьСтруктуруGetЗапроса()

Функция СформироватьСтруктуруPostЗапроса(ОтгрузкаСНаличия = Истина,	СозданиеДоЗаказа = Ложь	) Экспорт

	  СтруктураЗапроса = Новый Структура; 
	  СтруктураЗапроса.Вставить("data"); 
	  
	  СтруктураЗапросаData = Новый Структура; 
	  СтруктураЗапросаData.Вставить("accountNumber");
	  СтруктураЗапросаData.Вставить("bxId") ; 
	  
	  Если ОтгрузкаСНаличия Тогда
		  
		  СтруктураЗапросаData.Вставить("order"); 
		  
		  СтруктураЗапросаOrder = Новый Структура; 
		  СтруктураЗапросаOrder.Вставить("statusId");
		  
		  
		  СтруктураЗапросаOrder.Вставить("confirmedProducts",Новый Массив);
		  СтруктураЗапросаData.order = СтруктураЗапросаOrder;
		  
	  КонецЕсли;
	  
	  Если СозданиеДоЗаказа Тогда
		  
		  СтруктураЗапросаData.Вставить("additionalOrder");
		  
		  СтруктураЗапросаadditionalOrder = Новый Структура; 
		  СтруктураЗапросаadditionalOrder.Вставить("orderedShipmentDate");//желаемая дата отгрузки 
		  СтруктураЗапросаadditionalOrder.Вставить("comment");
		  СтруктураЗапросаadditionalOrder.Вставить("inn");
		  СтруктураЗапросаadditionalOrder.Вставить("orderedProducts", Новый Массив);
		  СтруктураЗапросаadditionalOrder.Вставить("deliveryAddress","");
		  
		  СтруктураЗапросаData.additionalOrder = СтруктураЗапросаadditionalOrder;
		  
		  СтруктураЗапросаData.Вставить("order");
		  
		  СтруктураЗапросаOrder = Новый Структура;
		  СтруктураЗапросаOrder.Вставить("statusId","ZN");  //пока сразу 
		  СтруктураЗапросаOrder.Вставить("confirmedProducts",Новый Массив);
		  СтруктураЗапросаData.order = СтруктураЗапросаOrder;
		  
	  КонецЕсли;   
	  
	  
	  СтруктураЗапроса.Data = СтруктураЗапросаData; 
	  
	 	  
	  Возврат СтруктураЗапроса; 
	  

  КонецФункции // СформироватьСтруктуруPostЗапроса()
  
  //здесь и отмена заказа и отмена дозаказа, приходит разный статус
  //отправка на согласование заявки полностью, но без комментария отмены
 Функция СформироватьСтруктуруPostЗапросаИзменениеСтатуса(ОтменаЗаказа = истина,ДобавитьТовары = Ложь) Экспорт

	 СтруктураЗапроса = Новый Структура; 
	 СтруктураЗапроса.Вставить("data"); 
	 
	 СтруктураЗапросаData = Новый Структура; 
	 СтруктураЗапросаData.Вставить("accountNumber");
	 СтруктураЗапросаData.Вставить("bxId") ; 
	 
	 СтруктураЗапросаData.Вставить("order"); 
	 
	 СтруктураЗапросаOrder = Новый Структура; 
	 СтруктураЗапросаOrder.Вставить("statusId");
	 
	 Если ОтменаЗаказа Тогда
	 
	 	СтруктураЗапросаOrder.Вставить("cancelReasonText");	
	 
	КонецЕсли;
	
	Если ДобавитьТовары Тогда
		
		СтруктураЗапросаOrder.Вставить("confirmedProducts",Новый Массив);	
		
	КонецЕсли;
	 
	 
	 СтруктураЗапросаData.order = СтруктураЗапросаOrder;    
	 
	 СтруктураЗапроса.Data = СтруктураЗапросаData; 
	 
	 
	 Возврат СтруктураЗапроса; 
	  

  КонецФункции // СформироватьСтруктуруPostЗапроса()
  
