Функция ДополнительныйРеквизитЗаказа(Знач Заказ,ИмяРеквизита) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗаявкиКлиентовСрезПоследних.%ИмяРеквизита% КАК %ИмяРеквизита%
		|ИЗ
		|	РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентовСрезПоследних
		|ГДЕ
		|	b2b_ЗаявкиКлиентовСрезПоследних.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяРеквизита%",ИмяРеквизита); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи[ИмяРеквизита]; 	
	
	КонецЕсли;
	
	Возврат неопределено; 


КонецФункции

