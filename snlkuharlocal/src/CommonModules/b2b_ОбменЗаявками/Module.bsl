Функция ЗаполнитьСтруктуруДляОтправкиДатыОтгрузки(ВходныеПараметры)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапросаДатыОтгрузок(ВходныеПараметры.Свойство("ДатаОтгрузкиДозаказа"),ВходныеПараметры.Свойство("МетодДоставки"),ВходныеПараметры.Свойство("ДатаОтгрузкиЗаказа"));  
	
	Если ВходныеПараметры.Свойство("НомерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.НомерЗаявки) Тогда
		
		СтруктураЗапроса.Data.accountNumber = ВходныеПараметры.НомерЗаявки; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("IDЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.IDЗаявки)
		И НЕ ВходныеПараметры.Свойство("НомерЗаявки") Тогда
		
		СтруктураЗапроса.Data.bxId = ВходныеПараметры.IDЗаявки; 	
		
	КонецЕсли;

	
	Если ВходныеПараметры.Свойство("ДатаОтгрузкиЗаказа")
		И ЗначениеЗаполнено(ВходныеПараметры.ДатаОтгрузкиЗаказа) Тогда
		
