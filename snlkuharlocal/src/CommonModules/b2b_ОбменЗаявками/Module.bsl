	СтруктураОтвета.Вставить("data",СтрДата);
	
	Если не ЗначениеЗаполнено(Тело) тогда      
		
		ЗаписатьВЛог("b2b skidki","Ошибка загрузка скидок. Не заполнено тело запроса"+Тело,,,);
		
		СтруктураОтвета.Вставить("result","ERROR");
		СтруктураОтвета.Вставить("message","Ошибка чтения данных с сайта");
		
		ОшибкаОбработки = Истина;
		
		записьJSON = ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета); 
				
		возврат  записьJSON;   
		
		
	иначе  		
		
		ОшибкаОбработки = ложь;
		ЕстьИзменения = ложь;
		контрагентнайден = ложь; 	
				
		ЧтениеJSON0 = Новый ЧтениеJSON;
		ЧтениеJSON0.УстановитьСтроку(Тело);
		СодержаниеТ = ПрочитатьJSON(ЧтениеJSON0);
		
		СкидкаНомерДок = СтрЗаменить(СодержаниеТ.data.sale,"sk_","");
