	|								ТОГДА ""Нет""
	|							ИНАЧЕ ВЫБОР
	|									КОГДА Ном.Ссылка.Родитель.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
	|										ТОГДА ""Да""
	|									КОГДА Ном.Ссылка.Родитель.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.НЕт)
	|										ТОГДА ""Нет""
	|									ИНАЧЕ ""Нет""
	|								КОНЕЦ
	|						КОНЕЦ
	|				КОНЕЦ
	|		КОНЕЦ = ""Да""
	|	И Ном.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(перечисление.ЖизненныйЦиклНоменклатуры.Активна)
	|	И ВЫБОР КОГДА &ОстаткиЦО Тогда ИСТИНА ИНАЧЕ Ном.Родитель.ВидНоменклатуры = &ВидНоменклатуры КОНЕЦ 
