 КонецПроцедуры // ОчиститьРегистрРегистрацииБлокировокПоЗаказу()
 
 


   // <Описание функции>
   //
   // Параметры:
   //  <Параметр1>  - <Тип.Вид> - <описание параметра>
   //                 <продолжение описания параметра>
   //  <Параметр2>  - <Тип.Вид> - <описание параметра>
   //                 <продолжение описания параметра>
   //
   // Возвращаемое значение:
   //   <Тип.Вид>   - <описание возвращаемого значения>
   //
   Функция НайтиПеремещениеТоваровПоНомеру(НомерВторКонтрагента)
	   
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Перемещение.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Перемещение КАК Перемещение
		|ГДЕ
		|	Перемещение.Проведен
		|	И Перемещение.НомерЗаказаВторичногоКонтрагента = &НомерЗаказаВторичногоКонтрагента";
	
	Запрос.УстановитьПараметр("НомерЗаказаВторичногоКонтрагента", НомерВторКонтрагента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.ссылка; 	
	
	КонецЕсли;
	
	Возврат неопределено; 

	   
   КонецФункции // НайтиПеремещениеТоваровПоНомеру()
   
   
   // <Описание функции>
   //
   // Параметры:
   //  <Параметр1>  - <Тип.Вид> - <описание параметра>
   //                 <продолжение описания параметра>
   //  <Параметр2>  - <Тип.Вид> - <описание параметра>
   //                 <продолжение описания параметра>
   //
   // Возвращаемое значение:
   //   <Тип.Вид>   - <описание возвращаемого значения>
   //
Функция ПолучитьИзСоответствияСтатусДоЗаказа(СтатусДоЗаказа)
	
	СоответствиеСтатусыДоЗаказы = Новый Соответствие; 
	СоответствиеСтатусыДоЗаказы.Вставить("N",Перечисления.b2b_СтатусыДоЗаказов.ВОбработке);
	СоответствиеСтатусыДоЗаказы.Вставить("A",Перечисления.b2b_СтатусыДоЗаказов.ТребуетПодтверждения);
	СоответствиеСтатусыДоЗаказы.Вставить("PP",Перечисления.b2b_СтатусыДоЗаказов.ПредварительноПодтвержден);
	СоответствиеСтатусыДоЗаказы.Вставить("P",Перечисления.b2b_СтатусыДоЗаказов.Оформлен);
	СоответствиеСтатусыДоЗаказы.Вставить("CO",Перечисления.b2b_СтатусыДоЗаказов.ЧастичноВыполнен);
	СоответствиеСтатусыДоЗаказы.Вставить("F",Перечисления.b2b_СтатусыДоЗаказов.Выполнен);
	СоответствиеСтатусыДоЗаказы.Вставить("D",Перечисления.b2b_СтатусыДоЗаказов.Отменен);
	
    Возврат СоответствиеСтатусыДоЗаказы.Получить(СтатусДоЗаказа); 
   
КонецФункции // ПолучитьИзСоответствияСтатусДоЗаказа()

Функция ПолучитьИзСоответствияСтатусЗаказа(СтатусДоЗаказа)
	
	СоответствиеСтатусыДоЗаказы = Новый Соответствие; 
	СоответствиеСтатусыДоЗаказы.Вставить("ZC",Перечисления.b2b_СтатусыЗаказов.ЖдетОбработки);
	СоответствиеСтатусыДоЗаказы.Вставить("ZN",Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором);
	СоответствиеСтатусыДоЗаказы.Вставить("ZA",Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом);
	СоответствиеСтатусыДоЗаказы.Вставить("ZP",Перечисления.b2b_СтатусыЗаказов.Согласована);
	СоответствиеСтатусыДоЗаказы.Вставить("ZO",Перечисления.b2b_СтатусыЗаказов.ЧастичноВыполнена);
	СоответствиеСтатусыДоЗаказы.Вставить("ZF",Перечисления.b2b_СтатусыЗаказов.Выполнена);
	СоответствиеСтатусыДоЗаказы.Вставить("ZD",Перечисления.b2b_СтатусыЗаказов.Отменена);
	
    Возврат СоответствиеСтатусыДоЗаказы.Получить(СтатусДоЗаказа); 
   
КонецФункции // ПолучитьИзСоответствияСтатус

Функция ПолучитьИзСоответствияСтатусЗаказаДляОтправкиНаПортал(СтатусДоЗаказа)
	
	СоответствиеСтатусыДоЗаказы = Новый Соответствие; 
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.ЖдетОбработки,"ZC");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором,"ZN");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом,"ZA");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.Согласована,"ZP");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.ЧастичноВыполнена,"ZO");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.Выполнена,"ZF");
	СоответствиеСтатусыДоЗаказы.Вставить(Перечисления.b2b_СтатусыЗаказов.Отменена,"ZD");
	
    Возврат СоответствиеСтатусыДоЗаказы.Получить(СтатусДоЗаказа); 
   
КонецФункции

