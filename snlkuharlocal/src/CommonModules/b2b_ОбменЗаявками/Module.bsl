Процедура ЗаписатьВЖурналЗапросыНаОбновлениеЗаказов(ИдентификаторЗапроса,Запрос,ВходныеПараметры,ХранитьПодробностиЛогирования = Ложь)

	МенеджерЗаписи = РегистрыСведений.b2b_ЗапросыНаОбновлениеИстория.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДатаСеанса(); 
	МенеджерЗаписи.ИдентификаторЗапроса = ИдентификаторЗапроса;
	
	Если ХранитьПодробностиЛогирования Тогда
		
		МенеджерЗаписи.Запрос = Новый ХранилищеЗначения(Запрос,Новый СжатиеДанных(9));	
		
	КонецЕсли;
	
	
	Если ВходныеПараметры.Свойство("ИдентификаторОчереди") Тогда
	
		МенеджерЗаписи.ИдентификаторОчереди = ВходныеПараметры.ИдентификаторОчереди; 	
	
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Заказ") Тогда
	
		МенеджерЗаписи.Документ = ВходныеПараметры.Заказ; 	
	
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ТипЗапроса") Тогда
	
		МенеджерЗаписи.ТипЗапроса = ВходныеПараметры.ТипЗапроса; 	
	
	КонецЕсли;

	
	ПопыткаЗаписиВЖурнал( МенеджерЗаписи,"b2b_ЗапросыНаОбновлениеИстория",ИдентификаторЗапроса); 

КонецПроцедуры //	

Процедура ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(ИдентификаторЗапроса,ИдентификаторКлиента,Запрос,ВходныеПараметры,ХранитьПодробностиЛогирования = Ложь) Экспорт

	МенеджерЗаписи = РегистрыСведений.b2b_ЗапросыНаОбновлениеВОчереди.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДатаСеанса(); 
	МенеджерЗаписи.ИдентификаторЗапроса = ИдентификаторЗапроса; 
	МенеджерЗаписи.ИдентификаторКлиента = ИдентификаторКлиента;
	Если ХранитьПодробностиЛогирования Тогда
	
		МенеджерЗаписи.Запрос = Новый ХранилищеЗначения(Запрос,Новый СжатиеДанных(9));	
	
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Данные") Тогда
		
		СериализованныйМассивКонтрагентов = ЗначениеВСтрокуВнутр(ВходныеПараметры.Данные);
		МенеджерЗаписи.МассивДанных = Новый ХранилищеЗначения(СериализованныйМассивКонтрагентов, Новый СжатиеДанных(9));
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("ИдентификаторОчереди") Тогда
	
		МенеджерЗаписи.ИдентификаторОчереди = ВходныеПараметры.ИдентификаторОчереди; 	
	
	КонецЕсли;       
		
	Если ВходныеПараметры.Свойство("ТипЗапроса") Тогда
	
		МенеджерЗаписи.ТипЗапроса = ВходныеПараметры.ТипЗапроса; 	
	
	КонецЕсли;

	
	ПопыткаЗаписиВЖурнал( МенеджерЗаписи,"b2b_ЗапросыНаОбновлениеИстория",ИдентификаторЗапроса); 

КонецПроцедуры //	

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(ИдентификаторЗапроса,Результат,Комментарий, ЭтоОшибка = Ложь,ХранитьПодробностиЛогирования = Ложь)

	Наборзаписей = РегистрыСведений.b2b_ЗапросыНаОбновлениеИстория.СоздатьНаборЗаписей(); 
	Наборзаписей.Отбор.ИдентификаторЗапроса.Установить(ИдентификаторЗапроса);
	Наборзаписей.Прочитать();
	
	Для каждого ЗаписьНабора Из Наборзаписей Цикл
	
		ЗаписьНабора.Комментарий = Комментарий;
		ЗаписьНабора.ТекстОшибки = ?(ЭтоОшибка,Комментарий,"");
		ЗаписьНабора.ИдентификаторКлиента = ?(Результат = Неопределено,"",Результат.ИдентификаторКлиента);		
		ЗаписьНабора.Документ = ?(Результат = Неопределено,"",Результат.Документ);
		
		Если ХранитьПодробностиЛогирования Тогда
	    	ЗаписьНабора.Результат = ?(Результат = Неопределено,"",Новый ХранилищеЗначения(Результат.РезультатJson,Новый СжатиеДанных(9)));
		КонецЕсли;
	КонецЦикла;
	
	Попытка
	
		Наборзаписей.Записать(); 
	
	Исключение
		
		ЗаписьЖурналаРегистрации("ОшибкаЗапросаОбменЕЭ_GET",УровеньЖурналаРегистрации.Ошибка,,,,);
	
	КонецПопытки;
	
КонецПроцедуры // ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат()

Процедура ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
		ИдентификаторЗапроса,
		ИдентификаторКлиента,
		Результат,
		Комментарий, 
		ЭтоОшибка = Ложь,
		Отработано = Ложь,
		ХранитьПодробностиЛогирования = Ложь
	) Экспорт

	Наборзаписей = РегистрыСведений.b2b_ЗапросыНаОбновлениеВОчереди.СоздатьНаборЗаписей(); 
	Наборзаписей.Отбор.ИдентификаторЗапроса.Установить(ИдентификаторЗапроса);
	Наборзаписей.Отбор.ИдентификаторКлиента.Установить(ИдентификаторКлиента);
	Наборзаписей.Прочитать();
	
	Для каждого ЗаписьНабора Из Наборзаписей Цикл
	
		ЗаписьНабора.Комментарий = Комментарий;
		ЗаписьНабора.ТекстОшибки = ?(ЭтоОшибка,Комментарий,"");
			
		//ЗаписьНабора.ИдентификаторОчереди = ?(Результат = Неопределено,"",Результат.ИдентификаторОчереди);
		Если Результат <> Неопределено  Тогда
			
			Если ХранитьПодробностиЛогирования тогда 
				ЗаписьНабора.Результат =Новый ХранилищеЗначения(Результат.РезультатJson,Новый СжатиеДанных(9));
			КонецЕсли; 
			
	    	ЗаписьНабора.ИдентификаторОчереди = Результат.ИдентификаторОчереди;
			
			//это нужно хранить всегда 
			Если Результат.Свойство("МассивДанных") Тогда
			
				ЗаписьНабора.МассивДанных = Новый ХранилищеЗначения(Результат.МассивДанных,Новый СжатиеДанных(9));  	
			
			КонецЕсли;
			
		КонецЕсли;
		//ЗаписьНабора.Результат = ?(Результат = Неопределено,"",Новый ХранилищеЗначения(Результат.РезультатJson));
		ЗаписьНабора.Отработано = Отработано;
		
		
	КонецЦикла;
	
	Попытка
	
		Наборзаписей.Записать(); 
	
	Исключение
		
		ЗаписьЖурналаРегистрации("ОшибкаЗапросаОбменЕЭ_ОстаткиЦО",УровеньЖурналаРегистрации.Ошибка,,,,);
	
	КонецПопытки;
	
КонецПроцедуры // ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат()


