	|				КОГДА СУММА(Остатки.КоличествоКонечныйОстаток - ЕСТЬNULL(Резервы.КоличествоКонечныйОстаток, 0) - ЕСТЬNULL(МинимальныеОстаткиНаСкладахСрезПоследних.Количество, 0)) < 0
	|					ТОГДА 0
	|				ИНАЧЕ СУММА(Остатки.КоличествоКонечныйОстаток - ЕСТЬNULL(Резервы.КоличествоКонечныйОстаток, 0) - ЕСТЬNULL(МинимальныеОстаткиНаСкладахСрезПоследних.Количество, 0))
	|			КОНЕЦ КАК КолКонФакт,
	|			СУММА(ЕСТЬNULL(Резервы.КоличествоКонечныйОстаток, 0)) КАК Резерв,
	|			Остатки.Номенклатура.Ссылка КАК НоменклатураСсылка,
	|			Остатки.Склад КАК Склад
