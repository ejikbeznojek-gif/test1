			Запрос.УстановитьПараметр("Ссылка",Док);
			Запрос.УстановитьПараметр("Код",СкидкаКодКонтрагента);
			
			ВыборкаКонтрагенты=запрос.Выполнить().Выбрать();
			
			Если ВыборкаКонтрагенты.Следующий() Тогда 				
