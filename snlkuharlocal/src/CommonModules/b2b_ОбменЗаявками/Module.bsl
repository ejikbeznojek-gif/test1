Процедура b2b_ОбновитьЗаказы(ТаблицаПараметров = Неопределено) Экспорт 
	СоответствиеПараметров = Новый Соответствие; 
	Если ТаблицаПараметров <> Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			СоответствиеПараметров.Вставить(СтрокаТП.Имя,СтрокаТП.Значение); 
		КонецЦикла;
	КонецЕсли;
	
	ОбновленныеЗаказы = Новый Массив; 
	ПараметрыПолучения = Новый Структура;
		
	Если СоответствиеПараметров.Получить("Подразделение") <> неопределено Тогда
		
		ПараметрыПолучения.Вставить("Подразделение",СоответствиеПараметров.Получить("Подразделение")); 	
		
	КонецЕсли;

	b2b_ОбменЗаявками.ПолучениеДанныхПоЗаказам(ПараметрыПолучения,ОбновленныеЗаказы);
КонецПроцедуры

Процедура b2b_ОтработатьОтгруженныеЗаказы(ТаблицаПараметров = Неопределено) Экспорт
	СоответствиеПараметров = Новый Соответствие; 
	Если ТаблицаПараметров <> Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			СоответствиеПараметров.Вставить(СтрокаТП.Имя,СтрокаТП.Значение); 
		КонецЦикла;
	КонецЕсли;
	
	ПараметрыПолучения = Новый Структура;
	Если СоответствиеПараметров.Получить("Подразделение") <> неопределено Тогда
		
		ПараметрыПолучения.Вставить("Подразделение",СоответствиеПараметров.Получить("Подразделение")); 	
		
	КонецЕсли;
	ОтработатьОтгруженныеЗаказы(ПараметрыПолучения); 
КонецПроцедуры

