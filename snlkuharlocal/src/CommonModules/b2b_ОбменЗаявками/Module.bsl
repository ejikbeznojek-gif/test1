//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
Функция ВернутьЗаказВРаботу(Знач РНК)  Экспорт 
	//
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	b2b_СоответствиеРНКЗаказы.Заказ КАК Заказ
	|ИЗ
	|	РегистрСведений.b2b_СоответствиеРНКЗаказы КАК b2b_СоответствиеРНКЗаказы
	|ГДЕ
	|	b2b_СоответствиеРНКЗаказы.РНК = &РНК";
	
	Запрос.УстановитьПараметр("РНК", РНК);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РезультатСвязи =  РезультатЗапроса.Пустой(); 
	
	Если НЕ РезультатСвязи Тогда
		
		Выборка = РезультатЗапроса.Выбрать(); 
		
		Пока Выборка.Следующий() Цикл 
			
			Заказ = Выборка.Заказ;
			
			ЗаказОбъект = Заказ.ПолучитьОбъект(); 
			
			Если ЗаказОбъект.СостояниеНакладной <> Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
				
				ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;	
				
			КонецЕсли;
			 
			СтрокаРНК = ЗаказОбъект.РасходныеНакладные.Найти(РНК.ссылка,"Документ"); 
			Если СтрокаРНК <> неопределено Тогда
			
				ЗаказОбъект.РасходныеНакладные.Удалить(СтрокаРНК); 
			
			КонецЕсли;
			
			Попытка
				
				ЗаказОбъект.Записать(); 
			
				НаборЗаписей = РегистрыСведений.b2b_СоответствиеРНКЗаказы.СоздатьНаборЗаписей(); 
			    НаборЗаписей.Отбор.Заказ.Установить(ЗаказОбъект.ссылка); 
				НаборЗаписей.Записать(); 
				
			Исключение
			     Сообщить(ОписаниеОшибки()); 
			КонецПопытки;
			
		КонецЦикла;
		
		
	КонецЕсли;
	
	 


КонецФункции // ВернутьЗаказВРаботу()

