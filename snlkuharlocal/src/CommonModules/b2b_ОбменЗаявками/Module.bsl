 //
 Процедура ОчиститьРегистрРегистрацииБлокировокПоЗаказу(Знач Заказ)
	 
	 НаборЗаписей = РегистрыСведений.b2b_РегистрацияБлокировок.СоздатьНаборЗаписей(); 
	 НаборЗаписей.Отбор.Заказ.Установить(Заказ);
