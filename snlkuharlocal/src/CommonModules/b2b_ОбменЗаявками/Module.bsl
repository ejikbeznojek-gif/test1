			Возврат записьJSON;
			
		конецЕсли;	
		
		
		//**************************************************************************
				
		ЗаписатьВЛог("b2b skidki","1Загрузка скидок конец. Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок+" "+ТекущаяДата(),,,);
		
			
		записьJSON = ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
		Возврат записьJSON;
		
	КонецЕсли;
	
	ЗаписатьВЛог("b2b skidki","2Загрузка скидок конец. Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок+" "+ТекущаяДата(),,,);
	
	
	
КонецФункции

Функция ЗаписатьВРегистрУстановкаСкидок(СтруктураЗапроса)

	МенеджерЗаписи = РегистрыСведений.b2b_УстановкаСкидокЗапросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
	МенеджерЗаписи.Период = ТекущаяДатаСеанса(); 
	МенеджерЗаписи.Данные = Новый ХранилищеЗначения(СтруктураЗапроса,Новый СжатиеДанных(9));
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
		Возврат ложь; 
	КонецПопытки;
	
	Возврат истина; 
КонецФункции // ЗаписатьВРегистрУстановкаСкидок()

Функция ЗаписатьВРегистрУстановкаСкидокРезультатОтработки(ИдентификаторЗапроса,Отработан = ложь, ТекстОшибки = "")

	НаборЗаписей = РегистрыСведений.b2b_УстановкаСкидокЗапросы.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ИдентификаторЗапроса.Установить(ИдентификаторЗапроса);
	НаборЗаписей.Прочитать();
	
	Для каждого  ЗаписьНабора Из НаборЗаписей Цикл
		
		ЗаписьНабора.Отработан = Отработан;
		ЗаписьНабора.ТекстОшибки = ТекстОшибки; 	
		
	КонецЦикла;

	Попытка
		НаборЗаписей.Записать();
	Исключение
		Возврат ложь; 
	КонецПопытки;
	
	Возврат истина; 
КонецФункции

Функция ОтработатьЗагруженныеДанныеПоУстановкеСкидокКонтрагентов()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_УстановкаСкидокЗапросыСрезПоследних.Данные КАК Данные,
		|	b2b_УстановкаСкидокЗапросыСрезПоследних.ИдентификаторЗапроса КАК ИдентификаторЗапроса
		|ИЗ
		|	РегистрСведений.b2b_УстановкаСкидокЗапросы.СрезПоследних(, ) КАК b2b_УстановкаСкидокЗапросыСрезПоследних
		|ГДЕ
		|	НЕ b2b_УстановкаСкидокЗапросыСрезПоследних.Отработан";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтруктураОтвета = ВыборкаДетальныеЗаписи.Данные.Получить(); 
		
		Если ТипЗнч(СтруктураОтвета) = Тип("Структура") Тогда
			
			ОтработатьСогласованПоУстановкеСкидок(СтруктураОтвета,ВыборкаДетальныеЗаписи.ИдентификаторЗапроса); 
		Иначе 
			ЗаписатьВРегистрУстановкаСкидокРезультатОтработки(ВыборкаДетальныеЗаписи.ИдентификаторЗапроса,ЛОЖЬ,"Неверная структура ответа!!!!");
		КонецЕсли;
	КонецЦикла;
	
	


КонецФункции // ОтработатьДанныеПоСкидкам() 

Функция ОтработатьСогласованПоУстановкеСкидок(СтруктураОтвета,ИдентификаторЗапроса) 		
	
	СкидкаНомерДок 			= СтрЗаменить(СтруктураОтвета.data.sale,"sk_","");
	СкидкаКодКонтрагента 	= СтруктураОтвета.data.user;  // интегральный код
	//
	Док = документы.УстановкаСкидокПоКонтрагентам.НайтиПоНомеру(СкидкаНомерДок,НачалоГода(ТекущаяДата()));
	
	Если Не ЗначениеЗаполнено(Док) Тогда
		
		ЗаписатьВРегистрУстановкаСкидокРезультатОтработки(ИдентификаторЗапроса,ЛОЖЬ,"Не найден документ по номеру документа" + СкидкаНомерДок); 
		
		Возврат ЛОЖЬ; 	
	
	КонецЕсли;
	
	ДокОб = Док.ПолучитьОбъект();
	
	ЕстьИзменения 		= ложь;
	Контрагентнайден 	= ложь;
	
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	УстановкаСкидокПоКонтрагентамКонтрагенты.Контрагент КАК Контрагент,
	|	УстановкаСкидокПоКонтрагентамКонтрагенты.НомерСтроки КАК НомерСтроки,
	|	УстановкаСкидокПоКонтрагентамКонтрагенты.Контрагент.Наименование КАК КонтрагентНаименование
	|ИЗ
	|	Документ.УстановкаСкидокПоКонтрагентам.Контрагенты КАК УстановкаСкидокПоКонтрагентамКонтрагенты
	|ГДЕ
	|	УстановкаСкидокПоКонтрагентамКонтрагенты.Контрагент.Ведущий.Код = &Код
	|	И УстановкаСкидокПоКонтрагентамКонтрагенты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка",Док);
	Запрос.УстановитьПараметр("Код",СкидкаКодКонтрагента);
	
	ВыборкаКонтрагенты=запрос.Выполнить().Выбрать();
	Пока ВыборкаКонтрагенты.Следующий() Цикл
		
		КонтрагентНайден = истина;
		
		ТекСтрока = ДокОб.Контрагенты.Получить(ВыборкаКонтрагенты.НомерСтроки-1);
		
		Если не ТекСтрока.Согласован Тогда
			ТекСтрока.Согласован = Истина;
		КонецЕсли;
		
		
		ТекСтрока.Согласован = Истина;
		ЕстьИзменения = истина;
		
		//ЗаписатьВЛог("b2b skidki","Загрузка скидок. Контрагент - "+ВыборкаКонтрагенты.КонтрагентНаименование+" Ведущий -"+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок,,,);
					
	КонецЦикла;	
	
	ОшибкаОбработки = Ложь; 
	
	Если ЕстьИзменения Тогда
		попытка
			
			если ДокОб.модифицированность() тогда 
				
				Если  ДокОб.Проведен тогда
					ДокОб.Записать(РежимЗаписиДокумента.Проведение);
				иначе
					ДокОб.Записать(РежимЗаписиДокумента.запись);
				конецЕсли;
				
			КонецЕсли; 
			
			ЗаписатьВРегистрУстановкаСкидокРезультатОтработки(ИдентификаторЗапроса,Истина); 
			
		исключение 
			
			
			ЗаписатьВРегистрУстановкаСкидокРезультатОтработки(ИдентификаторЗапроса,Ложь,"Ошибка загрузка скидок.  Контрагент - "+СкидкаКодКонтрагента+" скидка -"+СкидкаНомерДок +ОписаниеОшибки());
							
			
			ОшибкаОбработки = Истина;
		конецпопытки;
		
		
	КонецЕсли;
	
	Возврат НЕ ОшибкаОбработки; 
	
	
КонецФункции // ()

Процедура b2b_ОтработатьДанныеПоУчастиюВСкидках(Ключ) Экспорт
	ОтработатьЗагруженныеДанныеПоУстановкеСкидокКонтрагентов(); 
КонецПроцедуры



