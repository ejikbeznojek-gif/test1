Процедура ЗаполнитьКоличествоКомплектующихПоСтроке_(СтрокаТЧ) экспорт
	Родитель = СтрокаТЧ.Номенклатура.Родитель; 
	
	КратностьКомплектующих =  Родитель.ШтукВКомплекте; 
	ВидНоменклатуры = Родитель.ВидНоменклатуры; 
	
	
	Если ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар тогда
		Если КратностьКомплектующих=0 
			ИЛИ СтрокаТЧ.Номенклатура.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект тогда 
			КратностьКомплектующих=1;
		КонецЕсли;
		СтрокаТЧ.КоличествоКомплектующих = СтрокаТЧ.Количество* КратностьКомплектующих;
	иначе
		СтрокаТЧ.КоличествоКомплектующих = 0;
	КонецЕсли;
КонецПроцедуры	
Функция СоздатьРНКНаСервере(Знач Заказ,
	ЭтоДозаказ, Сообщения, ПоОстаткам = Ложь) Экспорт
	
	//НовыйДокумент = Документы.РасходнаяНакладная.СоздатьДокумент();
	//НовыйДокумент.Договор = НовыйДокумент.Контрагент.ОсновнойДоговор; 
	//НовыйДокумент.Заполнить(Заказ);
	
	
	НовыйДокумент = ЗаполнитьНовыйДокументРНК(Заказ, Заказ.Товары,Сообщения,ПоОстаткам);


	
	Попытка
	
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		
		ЗаказОбъект = Заказ.ПолучитьОбъект(); 
		ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ;
		
		СтрокаСНакладной = ЗаказОбъект.РасходныеНакладные.Найти(НовыйДокумент.Ссылка,"Документ");
		Если  СтрокаСНакладной = Неопределено Тогда
			НоваяСтрокаРНК = ЗаказОбъект.РасходныеНакладные.Добавить();
			НоваяСтрокаРНК.Документ = НовыйДокумент.Ссылка; 
		КонецЕсли;
		ЗаказОбъект.Записать();  
		
		b2b_ОбменЗаявками.ЗаписатьСоответствиеРНКЗаказ(Заказ,НовыйДокумент.Ссылка);
		
		МетодДоставки = b2b_ОбменЗаявками.МетодДоставкиПоЗаказу(Заказ);
		
		ПараметрыНаОтправку = Новый Структура;
		ПараметрыНаОтправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
		//ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",Заказ.ДатаОтгрузки);
		
		Если МетодДоставки = "F"  и НЕ ЭтоДозаказ Тогда
		
			ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",Заказ.ДатаОтгрузки);
		
		КонецЕсли;
		
		Если МетодДоставки = "F"  и ЭтоДозаказ Тогда
		
			ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
			
			ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(Заказ); 
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ОсновнойЗаказ.ДатаОтгрузки);
		
		КонецЕсли;
		
		Если МетодДоставки = "P"  Тогда
		
			ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
			
			Если ЭтоДозаказ  Тогда
			
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",Заказ.ДатаОтгрузки);
				
			Иначе 
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",Заказ.ДатаОтгрузки);
				
			КонецЕсли;
		
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(МетодДоставки) Тогда
		
			//подтвержден был или заказ или дозаказ 
			//или заявка без дозаказа 
			
			Если ЭтоДозаказ Тогда
			
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",Заказ.ДатаОтгрузки);	
			Иначе 
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",Заказ.ДатаОтгрузки);
			КонецЕсли;
		
		КонецЕсли;
		
		 
		
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Заказ,ТипЗапроса,ПараметрыНаОтправку,Сообщения); 
		
		
		
		Возврат НовыйДокумент.Ссылка; 
		
	Исключение
		
		Сообщить(ОписаниеОшибки());
		
		Сообщения.Добавить(ОписаниеОшибки()); 
		
	КонецПопытки;
	
КонецФункции

Функция ЗаполнитьНовыйДокументРНК(Знач Заказ, Товары,Сообщения,ПоОстаткам = Ложь)
	
	ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, Отгружен, Склад, Дата",
	Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, Заказ.Склад,ТекущаяДата());
	
	НовыйДокОбъект = Документы.РасходнаяНакладная.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(НовыйДокОбъект, Заказ,,"Номер,Дата,ДокОснование,ДатаОформления");
	
	НовыйДокОбъект.Дата = ТекущаяДатаСеанса();
	НовыйДокОбъект.ДатаОформления = ТекущаяДатаСеанса();
	КодИБ = ПараметрыСеанса.ЭтотУзел.Код + "б";
	НовыйДокОбъект.УстановитьНовыйНомер(КодИБ + "-");
	НовыйДокОбъект.ДокОснование = Заказ.ссылка; 
	НовыйДокОбъект.НомерЗаказаВторичногоКонтрагента = Заказ.НомерЗаказа; 
	
	ЗаполнитьШапкуДокументаРНК(НовыйДокОбъект,ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац); 
	
	Если ТипЗнч(ДополнительныеРеквизиты) = Тип("Структура") Тогда
		Для Каждого Элемент из ДополнительныеРеквизиты Цикл
			
			НовыйДокОбъект[Элемент.Ключ] = Элемент.Значение;  
			
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(НовыйДокОбъект.ТипЦен) Тогда
		НовыйДокОбъект.ТипЦен = НовыйДокОбъект.Контрагент.ТипЦен;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(НовыйДокОбъект.ТипЦенРаспродажа) Тогда
		НовыйДокОбъект.ТипЦенРаспродажа = НовыйДокОбъект.Контрагент.ТипЦенРаспродажа;
	КонецЕсли;
	
	КэшОстатки = Новый Соответствие;
	
	Если ПоОстаткам Тогда
	
		МассивТоваровОстатки = Товары.Выгрузить().ВыгрузитьКолонку("Номенклатура"); 
		Склад = Заказ.Склад; 
		
		b2b_ОбменЗаявками.ПолучитьОстаткиПоЗаявкам(МассивТоваровОстатки,Склад,Заказ,КэшОстатки);	
	
	КонецЕсли;
	
	Для Каждого СтрокаТоваров ИЗ Товары Цикл
		
		НоваяСтрока = НовыйДокОбъект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТоваров);
		
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.СтавкаНДС) Тогда
			Родитель = НоваяСтрока.Номенклатура.Родитель; 
			НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНДС_(НоваяСтрока.Номенклатура);// Родитель.СтавкаНДС; 
		КонецЕсли;
		
		НоваяСтрока.Коэффициент = 1;
		НоваяСтрока.Единица = НоваяСтрока.Номенклатура.ОсновнаяЕдиница;
		НоваяСтрока.Заявка = НоваяСтрока.Количество;
		
		НоваяСтрока.Цена = СтрокаТоваров.Цена; 
		Если ПоОстаткам Тогда
			Если КэшОстатки.Получить(НоваяСтрока.Номенклатура) <> неопределено Тогда
			    СвободныйОстаток = КэшОстатки.Получить(НоваяСтрока.Номенклатура).СвободныйОстаток;
			Иначе
				СвободныйОстаток = 0;
			КонецЕсли;
			КоличествоПроставить =  Мин(СвободныйОстаток,НоваяСтрока.Количество);	
			Если КоличествоПроставить <> НоваяСтрока.Количество Тогда
			
				Сообщения.Добавить("По строке №" + Строка(НоваяСтрока.НомерСтроки) + " было проставлено кол-во, отличное от заявки"); 
			
			КонецЕсли;
			НоваяСтрока.Количество =  КоличествоПроставить; 
		КонецЕсли;
		НоваяСтрока.ПодтвержденнаяЗаявка = НоваяСтрока.Количество;
		
		НоваяСтрока.Всего = НоваяСтрока.Количество * НоваяСтрока.Цена;
		
		ЗаполнитьКоличествоКомплектующихПоСтроке_(НоваяСтрока); 
		РассчитатьСуммуТабЧасти_(НоваяСтрока, НовыйДокОбъект);
		
	КонецЦикла;
	
	
	ЗаполнитьУпаковку = Ложь;
	
	
	УстановитьПунктДоставкиСервер_(НовыйДокОбъект);
	Если НовыйДокОбъект.ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
		Для Каждого СтрокаТЧ Из НовыйДокОбъект.Контрагент.ВидыДопОбработок Цикл
			СтрокаДО = НовыйДокОбъект.ДопОбработки.Добавить();	
			СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
			Если СтрокаДО.ВидДопОбработки.РассчитыватьУпаковку Тогда
				ЗаполнитьУпаковку = Истина;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого СтрокаТЧ Из НовыйДокОбъект.ПунктДоставки.ВидыДопОбработок Цикл
			СтрокаДО = НовыйДокОбъект.ДопОбработки.Добавить();	
			СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
			Если СтрокаДО.ВидДопОбработки.РассчитыватьУпаковку Тогда
				ЗаполнитьУпаковку = Истина;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	
	НовыйДокОбъект.Упаковка.Очистить();
	
	Если ЗаполнитьУпаковку Тогда
		ТЗУпаковки = ПолучитьТЗУпаковки_(НовыйДокОбъект.Товары.Выгрузить(,"Номенклатура,Количество"), НовыйДокОбъект.Контрагент);
		
		Для Каждого СтрокаТЗ ИЗ ТЗУпаковки Цикл
			Если СтрокаТЗ.ДопОбработка <> Справочники.ВидыДопОбработки.ПустаяСсылка() Тогда
				Если НовыйДокОбъект.ДопОбработки.Найти(СтрокаТЗ.ДопОбработка)=Неопределено тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Если СтрокаТЗ.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = НовыйДокОбъект.Упаковка.Добавить();
			НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
			НоваяСтрока.Количество = СтрокаТЗ.Количество;
			НоваяСтрока.ПодтвержденнаяЗаявка = СтрокаТЗ.Количество;		
		КонецЦикла;
	КонецЕсли;
	
	Возврат НовыйДокОбъект; 

КонецФункции // 
Процедура УстановитьПунктДоставкиСервер_(ДокументОбъект) Экспорт
	
	Контрагент = ДокументОбъект.Контрагент;
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект.ПунктДоставки = Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПДСервер_(Контрагент) = 1 Тогда		
			Выборка = Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект.ПунктДоставки = Выборка.Ссылка;			
			КонецЦикла;
		Иначе
			ДокументОбъект.ПунктДоставки=Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект.ПунктДоставки =Неопределено;		
	КонецЕсли;	
КонецПроцедуры

Функция КоличествоПДСервер_(Контрагент) Экспорт
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	Владелец = &Владелец";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;		
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ПолучитьТЗУпаковки_(ТЧ,Контрагент=Неопределено)   Экспорт	 
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Родитель");
	ТЗ.Колонки.Добавить("Количество");
	ТЗ.Колонки.Добавить("Номенклатура2");
	ТЗ.Колонки.Добавить("ДопОбработка");
	
	Для Каждого СтрокаТЧ ИЗ ТЧ Цикл
		ВыборкаУпаковки = Справочники.Упаковка.Выбрать(,СтрокаТЧ.Номенклатура);
		Пока ВыборкаУпаковки.Следующий() Цикл  
			
			Если ВыборкаУпаковки.НезаполнятьВНакладных тогда
				Продолжить;
			КонецЕсли;
			
			
			Для Каждого СтрокаУпаковки Из ВыборкаУпаковки.ЭлементыУпаковки Цикл
				
				Если  ЗначениеЗаполнено(СтрокаУпаковки.Контрагент) и СтрокаУпаковки.Контрагент<>Контрагент тогда 
					Продолжить;
				КонецЕсли; 			
				
				
				СтрокаТЗ = ТЗ.Добавить();
				СтрокаТЗ.ДопОбработка=СтрокаУпаковки.ВидДопОбработки;
				
				СтрокаТЗ.Номенклатура = СтрокаУпаковки.Номенклатура;
				СтрокаТЗ.Номенклатура2 = СтрокаТЧ.Номенклатура.родитель;
				СтрокаТЗ.Родитель = СтрокаТЧ.Номенклатура.Родитель.Родитель;
				СтрокаТЗ.Количество = СтрокаУпаковки.Количество*СтрокаТЧ.Количество;
							
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	ТЗ.Свернуть("Номенклатура,ДопОбработка","Количество");
	
	Возврат ТЗ;
КонецФункции



Процедура УстановитьНезаполненныйРеквизитШапкиРНК(Объект, ИмяРеквизита,ЗначениеРеквизита) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Объект[ИмяРеквизита]) Тогда
		Объект[ИмяРеквизита]=ЗначениеРеквизита;
	КонецЕсли;
КонецПроцедуры 

Процедура ЗаполнитьШапкуДокументаРНК(ДокументОбъект, ТекПользователь, ВалютаРегламентированногоУчета = Неопределено) Экспорт
	
	
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	ВидДокумента		= МетаданныеДокумента.Имя;
	
	ОсновнойСклад		= ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнойСклад");	
			
	Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
		ТекИБ=Справочники.ИБ.НайтиПоКоду("SSP");
	Иначе			
		Если ЗначениеЗаполнено(ОсновнойСклад) И ЗначениеЗаполнено(ОсновнойСклад.ПрефиксИБ) Тогда
			ТекИБ=Справочники.ИБ.НайтиПоКоду(ОсновнойСклад.ПрефиксИБ);
		Иначе			
			ТекИБ=ПолучитьИБПоУмолчанию();			
		КонецЕсли;		
	КонецЕсли;
	
	ДокументОбъект.ИБ = ТекИБ; 
	
	
	
	ДокументОбъект.Автор   = ПараметрыСеанса.Пользователь;
	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Организация",ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнаяОрганизация")); 
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Отгружен",Перечисления.Отгружен.Резерв);
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"СостояниеНакладной",Перечисления.СостоянияНакладной.ВРаботе);
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"ВидОплаты",ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнойВидОплаты"));
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Подразделение",	ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновноеПодразделение"));	
	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Склад",				ОсновнойСклад);
	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"СостояниеДокументов",	Перечисления.СостояниеДокументов.НеВыписаны);
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"БанковскийСчет",		ДокументОбъект.Организация.ОсновнойБанковскийСчет);	
		
	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Валюта",		ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнаяВалютаПродажи"));	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Контрагент",	ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнойПокупатель"));		
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"ТипЦен",		ПолучитьЗначениеПоУмолчаниюПользователь_("ОсновнойТипЦенПродажи"));
	//УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Отгружен",		Перечисления.Отгружен.Резерв 						,	МетаданныеДокумента);
	
	если ЗначениеЗаполнено(ДокументОбъект.Контрагент) и  ТипЗнч(ДокументОбъект.Контрагент) = Тип("СправочникСсылка.Контрагенты") тогда
		УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Договор",	ДокументОбъект.Контрагент.ОсновнойДоговор); 
	КонецЕсли;
		
	
	УстановитьНезаполненныйРеквизитШапкиРНК(ДокументОбъект,"Валюта",			ПараметрыСеанса.ВалютаНац);
	 	 
	
	Если (НЕ ЗначениеЗаполнено(ДокументОбъект.Курс)) Тогда
		Доллары=Справочники.Валюты.НайтиПоКоду("840");
		
		ТекВалюта=?(ДокументОбъект.Валюта=ПараметрыСеанса.ВалютаНац,Доллары,ДокументОбъект.Валюта);//по исторически сложившейся традиции для рублей указывается курс доллара
		
		СтруктураКурсаДокумента      = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", ТекВалюта));
		
		ДокументОбъект.Курс			 = СтруктураКурсаДокумента.Курс;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ДокументОбъект.Склад)  Тогда		
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.Организация)  Тогда
			ДокументОбъект.Организация=ДокументОбъект.Склад.Организация;		
		КонецЕсли;		
	КонецЕсли;	
	
		//крохин
КонецПроцедуры

Функция ПолучитьЗначениеПоУмолчаниюПользователь_(Настройка,Знач Пользователь=Неопределено,Рекурсивно=Истина) Экспорт

	Пользователь=?(Пользователь=Неопределено,ПараметрыСеанса.Пользователь,Пользователь); 
	
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Настройка"   , ПланыВидовХарактеристик.НастройкиПользователей[Настройка]);

	Запрос.Текст = "
		|ВЫБРАТЬ
		|	Значение
		|ИЗ
		|	РегистрСведений.НастройкиПользователей КАК РегистрЗначениеПрав
		|
		|ГДЕ
		|	Пользователь = &Пользователь
		| И Настройка    = &Настройка
		|";

	Выборка = Запрос.Выполнить().Выбрать();

	ПустоеЗначение = ПланыВидовХарактеристик.НастройкиПользователей[Настройка].ТипЗначения.ПривестиЗначение();
	
	Если Выборка.Следующий() И НЕ ЗначениеНеЗаполнено(Выборка.Значение) Тогда
		Возврат Выборка.Значение;	
	ИначеЕсли Пользователь<>Справочники.Пользователи.НастройкиПоУмолчанию И Рекурсивно Тогда
		Возврат ПолучитьЗначениеПоУмолчанию(Настройка,Справочники.Пользователи.НастройкиПоУмолчанию);
	Иначе
		Возврат ПустоеЗначение;		
	КонецЕсли;
КонецФункции
