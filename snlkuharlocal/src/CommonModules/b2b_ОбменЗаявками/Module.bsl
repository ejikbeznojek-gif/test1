Функция СоздатьРНКПоНесколькимЗаказам(МассивЗаказов,Сообщения) Экспорт

	//по заказу и дозаказу РНК 
	НовыйДокумент = Документы.РасходнаяНакладная.СоздатьДокумент();
	ТЧТовары = НовыйДокумент.Товары.Выгрузить().Скопировать(); 
	//НовыйДокумент.Заполнить(МассивЗаказов[0]);
	//НовыйДокумент.ДатаОтгрузки = МассивЗаказов[0].ДатаОтгрузки;  
	//
	////НомерЗаказа = 1; 
	//
	
	Для НомерЗаказа  = 0 по МассивЗаказов.Количество() - 1 Цикл 
		
		Для каждого СтрокаТовара Из МассивЗаказов[НомерЗаказа].Товары Цикл
			
			СтрокаТЧ = ТЧТовары.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТовара); 	
			
		КонецЦикла;
	КонецЦикла;
	
	НовыйДокумент = ЗаполнитьНовыйДокументРНК(МассивЗаказов[0], ТЧТовары,Сообщения);
	
	Попытка
	
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение); 
		
		//метод доставки в этом случае вместе 
		
		Для каждого ЗаказИзМассива Из МассивЗаказов Цикл
			
			ЗаказОбъект = ЗаказИзМассива.ПолучитьОбъект(); 
			ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ;
			
			СтрокаСНакладной = ЗаказОбъект.РасходныеНакладные.Найти(НовыйДокумент.Ссылка,"Документ");
			Если  СтрокаСНакладной = Неопределено Тогда
				НоваяСтрокаРНК = ЗаказОбъект.РасходныеНакладные.Добавить();
				НоваяСтрокаРНК.Документ = НовыйДокумент.Ссылка; 
			КонецЕсли;
			ЗаказОбъект.Записать();
			
		
			b2b_ОбменЗаявками.ЗаписатьСоответствиеРНКЗаказ(ЗаказИзМассива,НовыйДокумент.Ссылка);	
			
			
			МетодДоставки = b2b_ОбменЗаявками.МетодДоставкиПоЗаказу(ЗаказИзМассива);
			
			ПараметрыНаОтправку = Новый Структура;
			ПараметрыНаОтправку.Вставить("НомерЗаявки",ЗаказИзМассива.НомерЗаказа);
			
			ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ЗаказИзМассива.ДатаОтгрузки);
			
			Если МетодДоставки = "F" Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ЗаказИзМассива.ДатаОтгрузки);
				
			КонецЕсли;
			
			ЭтоДозаказ = Ложь;
			ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(ЗаказИзМассива); 
			Если ЗначениеЗаполнено(ОсновнойЗаказ) Тогда
				ЭтоДозаказ = Истина; 
			КонецЕсли;
			
			Если МетодДоставки = "F"  и ЭтоДозаказ Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
				
				//ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(Заказ); 
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ОсновнойЗаказ.ДатаОтгрузки);
				
			КонецЕсли;
			
			
			
			Если МетодДоставки = "P"  Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";				 
				
				Если ЭтоДозаказ  Тогда
					
					ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",ЗаказИзМассива.ДатаОтгрузки);
					
				Иначе 
					
					ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ЗаказИзМассива.ДатаОтгрузки);
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(МетодДоставки) Тогда
				
				//подтвержден был или заказ или дозаказ 
				//или заявка без дозаказа 
				
				Если ЭтоДозаказ Тогда
					
					ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",ЗаказИзМассива.ДатаОтгрузки);	
					
				КонецЕсли;
				
			КонецЕсли; 	
			
			ПараметрыНаОтправку.Вставить("МетодДоставки",МетодДоставки); 
			
			b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(ЗаказИзМассива,ТипЗапроса,ПараметрыНаОтправку,Сообщения);
		КонецЦикла; 
		
		
		Возврат НовыйДокумент.Ссылка; 			
		
	Исключение
		
		Сообщить(ОписаниеОшибки());
		
		Сообщения.Добавить(ОписаниеОшибки()); 
		
	КонецПопытки;


КонецФункции // СоздатьРНКПоНесколькимЗаказам()

