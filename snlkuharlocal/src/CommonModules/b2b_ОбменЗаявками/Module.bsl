Процедура ЗаписатьОшибкуВЖурнал(ИдентификаторТранзакций, Ошибка,ИдентификаторКлиента = "", Результат = неопределено)  Экспорт
	
	МенеджерЗаписи = РегистрыСведений.b2b_ЖурналОшибок.СоздатьМенеджерЗаписи(); 
	МенеджерЗаписи.Период 					= ТекущаяДата(); 
	МенеджерЗаписи.ИдентификаторЗапроса 	= ИдентификаторТранзакций;  
	МенеджерЗаписи.ИдентификаторКлиента 	= ИдентификаторКлиента;
	Если ЗначениеЗаполнено(Результат) Тогда
	
		МенеджерЗаписи.Результат 	= Новый ХранилищеЗначения(Результат,Новый СжатиеДанных(9));	
	
	КонецЕсли;
	 
	МенеджерЗаписи.ИнформацияОбОшибке	= Ошибка; 
	
	Попытка
		
		МенеджерЗаписи.Записать(); 
		
	Исключение
		ЗаписьЖурналаРегистрации("ОшибкаЗаписиВЖурналОшибок",УровеньЖурналаРегистрации.Ошибка,Метаданные.РегистрыСведений.b2b_ЖурналОшибок,,,); 
	 КонецПопытки;
	
КонецПроцедуры 

