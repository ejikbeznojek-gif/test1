Функция НайтиОсновнойЗаказпоДозаказу(Знач Заказ) ЭКспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	b2b_ДозаказыСрезПоследних.ЗаказОсновной КАК ЗаказОсновной
	|ИЗ
	|	РегистрСведений.b2b_Дозаказы КАК b2b_ДозаказыСрезПоследних
	|ГДЕ
	|	b2b_ДозаказыСрезПоследних.Заказ = &Заказ
	|	И НЕ b2b_ДозаказыСрезПоследних.ЗаказОсновной.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		Возврат ВыборкаДетальныеЗаписи.ЗаказОсновной; 	
		
	КонецЕсли;
	
	Возврат Документы.Заказ.ПустаяСсылка(); 

КонецФункции // НайтиОсновнойЗаказпоДозаказу()

