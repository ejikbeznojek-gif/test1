	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомСправочник.Наименование";
	
	Если НЕ ОстаткиЦО Тогда  
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%РегистрПереданныеОстатки%",
		"		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ПереданныеОстатки КАК b2b_ПереданныеОстатки
		|		ПО ВтОстатки.Номенклатура = b2b_ПереданныеОстатки.Номенклатура
		|			И (b2b_ПереданныеОстатки.IDПользователяНаСайте = &IDПользователяНаСайте)"); 
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%РегистрПереданныеОстатки%",
		"ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ПереданныеОстаткиЦО КАК b2b_ПереданныеОстатки
		|		ПО ВтОстатки.Номенклатура = b2b_ПереданныеОстатки.Номенклатура ") ;  				
	КонецЕсли;
	
	Склады = новый Массив;
	
	Если НЕ ОстаткиЦО Тогда
		
		НастройкиОтправкиОстатков = ПолучитьПараметрыМетодаВыгрузкиОстатковДистрибьютора(); 
		
		Если ТипЗнч(НастройкиОтправкиОстатков.СкладыОстатков)= тип("Массив") 
			И НастройкиОтправкиОстатков.СкладыОстатков.Количество() > 0 Тогда
			
			Для каждого СкладОстатков Из НастройкиОтправкиОстатков.СкладыОстатков Цикл
				
				Склады.Добавить(СкладОстатков); 
				
			КонецЦикла;		
			
		КонецЕсли;
		
		Запрос.УстановитьПараметр("IDПользователяНаСайте", НастройкиОтправкиОстатков.IDПользователяНаСайте);
		
	Иначе
		
		НастройкиОтправкиОстатков = ПолучитьПараметрыМетодаВыгрузкиОстатковОсновного(); 
		
		Если ТипЗнч(НастройкиОтправкиОстатков.СкладыОстатковЦО)= тип("Массив") 
			И НастройкиОтправкиОстатков.СкладыОстатковЦО.Количество() > 0 Тогда
			
			Для каждого СкладОстатков Из НастройкиОтправкиОстатков.СкладыОстатковЦО Цикл
				
				Склады.Добавить(СкладОстатков); 
				
			КонецЦикла;		
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТипОстатков",Перечисления.ТипыМинимальныхОстатков.РасчетОстатковb2b); 
	Запрос.УстановитьПараметр("склады", Склады);
	Запрос.УстановитьПараметр("Дата2",ТекущаяДата());
	Запрос.УстановитьПараметр("Дата1",ТекущаяДата()); 	
	Запрос.УстановитьПараметр("ТолькоИзменения",ТолькоИзменения); 
	Запрос.УстановитьПараметр("ОстаткиЦО",ОстаткиЦО);
	Запрос.УстановитьПараметр("ВидНоменклатуры", перечисления.ВидыНоменклаутры.Товар);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПотокМассивовТоваров = Новый Массив; 
	МассивТоваров = Новый Массив;
	
	Счетчик = 0;
	
	РазмерПакета = 1000;
	//
	//Если ОстаткиЦО  Тогда
	//	
	//	РазмерПакета = 1000; 	
	//Иначе 
	//	РазмерПакета = 1000; 
	//КонецЕсли;
	
	Пока Выборка.Следующий() Цикл 		
		
		Если Счетчик = РазмерПакета Тогда
			ПотокМассивовТоваров.Добавить(МассивТоваров); 
			МассивТоваров = Новый Массив;
			Счетчик = 0; 
		КонецЕсли;
		
		
		СтруктураДанных = Новый Структура("Номенклатура,Остаток,ШтрихКод"); 	
		ЗаполнитьЗначенияСвойств(СтруктураДанных,выборка); 
		
		МассивТоваров.Добавить(СтруктураДанных);
		
		Счетчик = Счетчик + 1; 
	КонецЦикла;
	
	Если Счетчик > 0 Тогда
		
		ПотокМассивовТоваров.Добавить(МассивТоваров);	
		
	КонецЕсли;
	
	Возврат ПотокМассивовТоваров; 
	
КонецФункции // ОстаткиДляОтправкиНаСайт()

Процедура ЗаписатьВДополнительныеРеквизитыПричинуОтмены(Знач Документ, ЗначениеРеквизита)

	МенеджерЗаписи = РегистрыСведений.РеквизитыДокументов.СоздатьМенеджерЗаписи(); 
