		//|	ВТЗаказыДляОтработки.НомерЗаявки КАК НомерЗаявки,
		//|	ВтМетодыДоставки.МетодДоставки КАК МетодДоставки,
		//|	ВЫБОР
		//|		КОГДА ВТЗаказыСДозаказами.Заказ ЕСТЬ NULL
		//|			ТОГДА ЛОЖЬ
		//|		ИНАЧЕ ИСТИНА
		//|	КОНЕЦ КАК ЕстьДозаказ,
		//|	ВЫБОР
		//|		КОГДА ВТДозаказы.Заказ ЕСТЬ NULL
		//|			ТОГДА ЛОЖЬ
		//|		ИНАЧЕ ИСТИНА
		//|	КОНЕЦ КАК ЭтоДозаказ,
		//|	ЕСТЬNULL(ВТЗаказыСДозаказамиОсн.Заказ, ЗНАЧЕНИЕ(Документ.Заказ.ПустаяСсылка)) КАК Дозаказ,
		//|	ЕСТЬNULL(ВТЗаказыСДозаказами.ЗаказОсновной, ЗНАЧЕНИЕ(Документ.Заказ.ПустаяСсылка)) КАК ЗаказОсновной,
		//|	ВТЗаказыДляОтработки.СтатусЗаказа_b2b КАК СтатусЗаказа_b2b
		//|ИЗ
		//|	ВТЗаказыДляОтработки КАК ВТЗаказыДляОтработки
		//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтМетодыДоставки КАК ВтМетодыДоставки
		//|		ПО ВТЗаказыДляОтработки.Заказ = ВтМетодыДоставки.Заказ
		//|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗаказыСДозаказами КАК ВТЗаказыСДозаказами
		//|		ПО ВТЗаказыДляОтработки.Заказ = ВТЗаказыСДозаказами.Заказ
		//|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗаказыСДозаказами КАК ВТЗаказыСДозаказамиОсн
		//|		ПО ВТЗаказыДляОтработки.Заказ = ВТЗаказыСДозаказамиОсн.ЗаказОсновной
		//|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДозаказы КАК ВТДозаказы
		//|		ПО ВТЗаказыДляОтработки.Заказ = ВТДозаказы.Заказ";
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	b2b_СоответствиеРНКЗаказы.Ссылка КАК Заказ,
		|	b2b_СоответствиеРНКЗаказы.Документ КАК РНК
		|ПОМЕСТИТЬ ВтРНКНеОтгруженные
		|ИЗ
		|	Документ.Заказ.РасходныеНакладные КАК b2b_СоответствиеРНКЗаказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентов
		|		ПО b2b_СоответствиеРНКЗаказы.Ссылка = b2b_ЗаявкиКлиентов.Заказ
		|			И (b2b_СоответствиеРНКЗаказы.Документ.Проведен)
		|			И (b2b_СоответствиеРНКЗаказы.Документ.СостояниеНакладной <> &Отгружен)
		|ГДЕ
		|	НЕ b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b В (&Выполнен)
		|	И НЕ b2b_ЗаявкиКлиентов.Отгружен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	b2b_СоответствиеРНКЗаказы.Ссылка КАК Заказ,
		|	b2b_СоответствиеРНКЗаказы.Документ.ДатаОтгрузки КАК ДатаОтгрузки,
		|	b2b_СоответствиеРНКЗаказы.Ссылка.НомерЗаказа КАК НомерЗаявки,
		|	b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b КАК СтатусЗаказа_b2b
		|ПОМЕСТИТЬ ВТЗаказыДляОтработки
		|ИЗ
		|	Документ.Заказ.РасходныеНакладные КАК b2b_СоответствиеРНКЗаказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентов
		|		ПО b2b_СоответствиеРНКЗаказы.Ссылка = b2b_ЗаявкиКлиентов.Заказ
		|			И (b2b_СоответствиеРНКЗаказы.Документ.Проведен)
		|			И (b2b_СоответствиеРНКЗаказы.Документ.СостояниеНакладной = &Отгружен)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВтРНКНеОтгруженные КАК ВтРНКНеОтгруженные
		|		ПО b2b_СоответствиеРНКЗаказы.Документ = ВтРНКНеОтгруженные.РНК
		|			И b2b_СоответствиеРНКЗаказы.Ссылка = ВтРНКНеОтгруженные.Заказ
		|ГДЕ
		|	НЕ b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b В (&Выполнен)
		|	И НЕ b2b_ЗаявкиКлиентов.Отгружен
		|	И ВтРНКНеОтгруженные.РНК ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	b2b_ЗаявкиКлиентов.МетодДоставки КАК МетодДоставки,
		|	ВТЗаказыДляОтработки.Заказ КАК Заказ
		|ПОМЕСТИТЬ ВтМетодыДоставки
		|ИЗ
		|	ВТЗаказыДляОтработки КАК ВТЗаказыДляОтработки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентов
		|		ПО ВТЗаказыДляОтработки.Заказ = b2b_ЗаявкиКлиентов.Заказ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТЗаказыДляОтработки.Заказ КАК Заказ,
		|	b2b_Дозаказы.ЗаказОсновной КАК ЗаказОсновной
		|ПОМЕСТИТЬ ВТЗаказыСДозаказами
		|ИЗ
		|	ВТЗаказыДляОтработки КАК ВТЗаказыДляОтработки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
		|		ПО (b2b_Дозаказы.Заказ = ВТЗаказыДляОтработки.Заказ
		|				ИЛИ b2b_Дозаказы.ЗаказОсновной = ВТЗаказыДляОтработки.Заказ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТЗаказыСДозаказами.Заказ КАК Заказ
		|ПОМЕСТИТЬ ВТДозаказы
		|ИЗ
		|	ВТЗаказыСДозаказами КАК ВТЗаказыСДозаказами
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
		|		ПО (b2b_Дозаказы.Заказ = ВТЗаказыСДозаказами.Заказ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЗаказыДляОтработки.Заказ КАК Заказ,
		|	ВТЗаказыДляОтработки.ДатаОтгрузки КАК ДатаОтгрузки,
		|	ВТЗаказыДляОтработки.НомерЗаявки КАК НомерЗаявки,
		|	ВтМетодыДоставки.МетодДоставки КАК МетодДоставки,
		|	ВЫБОР
		|		КОГДА ВТЗаказыСДозаказами.Заказ ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЕстьДозаказ,
		|	ВЫБОР
		|		КОГДА ВТДозаказы.Заказ ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЭтоДозаказ,
		|	ЕСТЬNULL(ВТЗаказыСДозаказамиОсн.Заказ, ЗНАЧЕНИЕ(Документ.Заказ.ПустаяСсылка)) КАК Дозаказ,
		|	ЕСТЬNULL(ВТЗаказыСДозаказами.ЗаказОсновной, ЗНАЧЕНИЕ(Документ.Заказ.ПустаяСсылка)) КАК ЗаказОсновной,
		|	ВТЗаказыДляОтработки.СтатусЗаказа_b2b КАК СтатусЗаказа_b2b
		|ИЗ
		|	ВТЗаказыДляОтработки КАК ВТЗаказыДляОтработки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтМетодыДоставки КАК ВтМетодыДоставки
		|		ПО ВТЗаказыДляОтработки.Заказ = ВтМетодыДоставки.Заказ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗаказыСДозаказами КАК ВТЗаказыСДозаказами
		|		ПО ВТЗаказыДляОтработки.Заказ = ВТЗаказыСДозаказами.Заказ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗаказыСДозаказами КАК ВТЗаказыСДозаказамиОсн
		|		ПО ВТЗаказыДляОтработки.Заказ = ВТЗаказыСДозаказамиОсн.ЗаказОсновной
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДозаказы КАК ВТДозаказы
		|		ПО ВТЗаказыДляОтработки.Заказ = ВТДозаказы.Заказ";

	
	
	Выполненные = Новый Массив; 
	Выполненные.Добавить(Перечисления.b2b_СтатусыЗаказов.Выполнена); 
	Выполненные.Добавить(Перечисления.b2b_СтатусыЗаказов.Отменена);
	
	Запрос.УстановитьПараметр("Выполнен", Выполненные); //Перечисления.b2b_СтатусыЗаказов.Выполнена);
	Запрос.УстановитьПараметр("Отгружен", Перечисления.СостоянияНакладной.Отгружена);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ОтправленныеЗапросыПоЗаказам = Новый Массив;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ОтправленныеЗапросыПоЗаказам.Найти(ВыборкаДетальныеЗаписи.Заказ) <> неопределено  Тогда
			
			Продолжить; 	
			
		КонецЕсли;   
		
		ПараметрыНаОтправку = Новый Структура;
		ПараметрыНаОтправку.Вставить("НомерЗаявки",ВыборкаДетальныеЗаписи.НомерЗаявки);
		Если ПараметрыПолучения.Свойство("Подразделение") Тогда
		
			ПараметрыНаОтправку.Вставить("Подразделение",ПараметрыПолучения.Подразделение); 	
		Иначе 
			ПараметрыНаОтправку.Вставить("Подразделение",Справочники.Подразделения.НайтиПоКоду("SSP-0001"));
		КонецЕсли;
		ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
		ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
		
		Если ВыборкаДетальныеЗаписи.МетодДоставки = "F"  Тогда
			
			Если ВыборкаДетальныеЗаписи.ЭтоДозаказ
				И ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЗаказОсновной) Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
				
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Заказ);
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.ЗаказОсновной);
				
			ИначеЕсли ВыборкаДетальныеЗаписи.ЭтоДозаказ
				И НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЗаказОсновной) тогда 
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
				
				ПараметрыНаОтправку = Новый Структура;
				ПараметрыНаОтправку.Вставить("НомерЗаявки",ВыборкаДетальныеЗаписи.НомерЗаявки);
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
				ПараметрыНаОтправку.Вставить("МетодДоставки","P");
				
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Заказ);
				
			ИначеЕсли 	НЕ ВыборкаДетальныеЗаписи.ЭтоДозаказ
				И   ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Дозаказ) Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
				
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Заказ);
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Дозаказ); 
				
			ИначеЕсли 	НЕ ВыборкаДетальныеЗаписи.ЭтоДозаказ
				И   НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Дозаказ) Тогда
				
				ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
				
				ПараметрыНаОтправку = Новый Структура;
				ПараметрыНаОтправку.Вставить("НомерЗаявки",ВыборкаДетальныеЗаписи.НомерЗаявки);
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
				ПараметрыНаОтправку.Вставить("МетодДоставки","P");
				
				ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Заказ);
				
			КонецЕсли;
			
			
			
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.МетодДоставки = "P"  Тогда
			
			ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
			
			ПараметрыНаОтправку = Новый Структура;
			ПараметрыНаОтправку.Вставить("НомерЗаявки",ВыборкаДетальныеЗаписи.НомерЗаявки);
		
			Если ВыборкаДетальныеЗаписи.ЭтоДозаказ   Тогда
				
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки);
				
			Иначе
				ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",ВыборкаДетальныеЗаписи.ДатаОтгрузки); 			 
			
			КонецЕсли;
			
			ОтправленныеЗапросыПоЗаказам.Добавить(ВыборкаДетальныеЗаписи.Заказ);

			
		КонецЕсли; 
			
		МассивСообщений = Новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(ВыборкаДетальныеЗаписи.Заказ,ТипЗапроса,ПараметрыНаОтправку,МассивСообщений);
		
		
	КонецЦикла;
	
	

КонецПроцедуры // ОтгработатьОтгруженныеЗаказы()

