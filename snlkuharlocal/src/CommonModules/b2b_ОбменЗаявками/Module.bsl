Функция ЗагрузитьУчастиеВСкидкахb2bПоКонтрагенту(Тело)  Экспорт 
	
	ЗаписатьВЛог("b2b skidki","Загрузка скидок. начало "+ТекущаяДата(),,,);
	
	
	ИмяФайла = ""+Год(ТекущаяДата())+"_"+месяц(ТекущаяДата())+"_"+День(ТекущаяДата())+"_"+Час(ТекущаяДата())+"_"+минута(ТекущаяДата());
	ИмяФайлаОбмена =  "\\srvfiles\b2b_files\sale-new_b2b\"+ИмяФайла+".txt";
	
	Дописывать    = Истина;
	ЗаписьТекста = Новый ЗаписьТекста(ИмяФайлаОбмена, КодировкаТекста.UTF8, , Дописывать);
	ТекстСообщений     = ""+Тело;
	ЗаписьТекста.ЗаписатьСтроку(ТекстСообщений);
	ЗаписьТекста.Закрыть();
	
	//--------------------------------------------------------
	СтрДата = Новый Структура;	
	
