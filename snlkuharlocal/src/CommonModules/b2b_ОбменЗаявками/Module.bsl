Функция ДатаОбновленияПоЗаказу(Знач Заказ)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗаявкиКлиентовСрезПоследних.ДатаОбновления КАК ДатаОбновления
		|ИЗ
		|	РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентовСрезПоследних
		|ГДЕ
		|	b2b_ЗаявкиКлиентовСрезПоследних.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.ДатаОбновления; 	
	
	КонецЕсли;
	
	Возврат Заказ.Дата; 


КонецФункции // ДатаОбновленияПоЗаказу()

