#Область ОбщиеПроцедурыФункциияРаботыСЗаявками

Процедура ПолучитьОстаткиПоЗаявкам(СписокНоменклатуры,Склад,МассивНакладных,КэшОстатков) Экспорт
	Если СписокНоменклатуры.ВГраница()<0 Тогда 
		Возврат 
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Возврат 
	КонецЕсли;
	
	МассивСкладов = Новый Массив();
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Сводный.Номенклатура.Код77 КАК Код77,
	|	Сводный.Номенклатура КАК Номенклатура,
	|	СУММА(Сводный.Остаток) КАК Остаток,
	|	СУММА(Сводный.Резерв) КАК Резерв,
	|	СУММА(Сводный.ВиртуальныйРезерв) КАК ВиртуальныйРезерв
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(Остатки.Номенклатура, Резервы.Номенклатура) КАК Номенклатура,
	|		ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|		ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	|		0 КАК ВиртуальныйРезерв
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В (&СписокНоменклатуры)) КАК Остатки
	|			ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В (&СписокНоменклатуры)) КАК Резервы
	|			ПО Остатки.Номенклатура = Резервы.Номенклатура
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ОстаткиТМЦ.Номенклатура,
	|		ОстаткиТМЦ.Количество,
	|		0,
	|		0
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|	ГДЕ
	|		ОстаткиТМЦ.Регистратор в (&Регистратор)
	|		И ОстаткиТМЦ.Склад В(&МассивСкладов)
	|		И ОстаткиТМЦ.ВидДвижения = &Расход
	|		И ОстаткиТМЦ.Номенклатура В(&СписокНоменклатуры)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыТМЦ.Номенклатура,
	|		0,
	|		-РезервыТМЦ.Количество,
	|		0
	|	ИЗ
	|		РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|	ГДЕ
	|		РезервыТМЦ.Регистратор В (&Регистратор)
	|		И РезервыТМЦ.Склад В(&МассивСкладов)
	|		И РезервыТМЦ.Номенклатура В(&СписокНоменклатуры)) КАК Сводный
	|
	|СГРУППИРОВАТЬ ПО
	|	Сводный.Номенклатура,
	|	Сводный.Номенклатура.Код77
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сводный.Номенклатура";
	
	Запрос.УстановитьПараметр("Расход",ВидДвиженияНакопления.Расход);	
	Запрос.УстановитьПараметр("Регистратор",МассивНакладных);
	Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
	
	МассивСкладов.Добавить(Склад);
	
	Если ТипЗнч(МассивНакладных) = Тип("Массив")  Тогда
	
		Для каждого НакладнаяЗаказ Из  МассивНакладных Цикл
			
			Если ТипЗнч(НакладнаяЗаказ) = Тип("ДокументСсылка.Заказ") Тогда
				
				Для каждого СкладСтрока Из НакладнаяЗаказ.ДополнительныеСклады Цикл
					
					МассивСкладов.Добавить(СкладСтрока.Склад);	
					
				КонецЦикла;	
				
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли  ТипЗнч(МассивНакладных) = Тип("ДокументСсылка.Заказ") Тогда
		
		Для каждого СкладСтрока Из МассивНакладных.ДополнительныеСклады Цикл
			
			МассивСкладов.Добавить(СкладСтрока.Склад);	
			
		КонецЦикла;
	КонецЕсли;
	
		
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл	
		КэшОстатков.Вставить(Выборка.Номенклатура,Новый Структура("Остаток,Резерв,СвободныйОстаток,Код77",Выборка.Остаток,Выборка.Резерв,Макс(0,Выборка.Остаток-Выборка.Резерв-Выборка.ВиртуальныйРезерв),Выборка.Код77));	
	КонецЦикла;
	
КонецПроцедуры 

Процедура ОтправитьЗапросДоЗаказНаСервере(ЗаказыНаДоЗаказ,РезультатОтработки,ИдентификаторОчереди,ИдентификаторЗапроса = Неопределено)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕЭ_ДозаказыСрезПоследних.Заказ КАК Заказ,
		|	ЕЭ_ДозаказыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЕЭ_ДозаказыСрезПоследних.Количество КАК Количество,
		|	ЗаказДок.НомерЗаказа КАК НомерЗаявки,
		|	ЗаказДок.ИдЗаказа КАК IDЗаявки,
		|	ЕЭ_ДозаказыСрезПоследних.Комментарий КАК Комментарий,
		|	ЕЭ_ДозаказыСрезПоследних.ЖелаемаяДатаОтгрузки КАК ЖелаемаяДатаОтгрузки,
		|	ЕЭ_ДозаказыСрезПоследних.Номенклатура.Код КАК Код,
		|	ЕЭ_ДозаказыСрезПоследних.ЗаказОсновной КАК ЗаказОсновной,
		|	ЕЭ_ДозаказыСрезПоследних.ПунктДоставки КАК ПунктДоставки,
		|	ЕЭ_ДозаказыСрезПоследних.Контрагент КАК Контрагент
		|ИЗ
		|	РегистрСведений.b2b_Дозаказы КАК ЕЭ_ДозаказыСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заказ КАК ЗаказДок
		|		ПО ЕЭ_ДозаказыСрезПоследних.Заказ = ЗаказДок.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ЕЭ_ДозаказыСрезПоследних.Номенклатура = НоменклатураСпр.Ссылка
		|ГДЕ
		|	ЕЭ_ДозаказыСрезПоследних.Заказ В(&МассивЗаказов)
		|ИТОГИ
		|	МАКСИМУМ(НомерЗаявки),
		|	МАКСИМУМ(IDЗаявки),
		|	МАКСИМУМ(ЖелаемаяДатаОтгрузки),
		|	МАКСИМУМ(ЗаказОсновной),
		|	МАКСИМУМ(ПунктДоставки),
		|	МАКСИМУМ(Контрагент)
		|ПО
		|	Заказ";
	
	Запрос.УстановитьПараметр("МассивЗаказов", ЗаказыНаДоЗаказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаЗаказ = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОтправленныеУспешно = Новый Массив;
	
	Пока ВыборкаЗаказ.Следующий() Цикл
		
		ВходныеПараметры = СтруктураДоЗаказа(); 
		ЗаполнитьЗначенияСвойств(ВходныеПараметры,ВыборкаЗаказ); 
		ВходныеПараметры.Вставить("ТипЗапроса","СоздатьДозаказ"); 
		
		ВыборкаДетальныеЗаписи = ВыборкаЗаказ.Выбрать();
		
		//Комментарии = Новый Массив;
		Комментарий = ""; 
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			// Вставить обработку выборки ВыборкаДетальныеЗаписи
			//Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Комментарий) Тогда
			
			//Комментарии.Добавить(ВыборкаДетальныеЗаписи.Комментарий); 	
			Комментарий = ВыборкаДетальныеЗаписи.Комментарий; 
			//КонецЕсли;
			
			СтруктураТовара = Новый Структура("IDТовара,Количество"); 
			
			СтруктураТовара.IDТовара  = ПолучитьКодТовараДляПортала(ВыборкаДетальныеЗаписи.Номенклатура); 
			СтруктураТовара.Количество = ВыборкаДетальныеЗаписи.Количество;
			
			ВходныеПараметры.Товары.Добавить(СтруктураТовара); 
		КонецЦикла;
		
		ВходныеПараметры.Комментарий = Комментарий; //СтрСоединить(Комментарии,";"); 
		
		ЗаказОсновной = ВыборкаЗаказ.ЗаказОсновной;
		Количество0 = ЗаказОсновной = ВыборкаЗаказ.Заказ; 
		
		Для каждого ТоварЗаказа Из ЗаказОсновной.Товары Цикл
			
			СтруктураТовара = Новый Структура("IDТовара,Количество,Цена"); 
			
			СтруктураТовара.IDТовара  = ПолучитьКодТовараДляПортала(ТоварЗаказа.Номенклатура); 
			СтруктураТовара.Количество = ?(Количество0,0,ТоварЗаказа.Количество);
			СтруктураТовара.Цена = ТоварЗаказа.Цена; 
			
			ВходныеПараметры.ТоварыВНаличии.Добавить(СтруктураТовара);	
			
		КонецЦикла;
		
		ВходныеПараметры.Вставить("ИдентификаторОчереди",ИдентификаторОчереди); 
		 
		b2b_ОбменЗаявками.ОтправкаНаСозданиеДоЗаказа(ВходныеПараметры,ОтправленныеУспешно,ИдентификаторЗапроса); 
	КонецЦикла;
	
	РезультатОтработки = ОтправленныеУспешно.Количество() > 0 ; 
	
	//Для каждого ОтправленУспешно Из ОтправленныеУспешно Цикл
	//	
	//	//ПараметрыДляЗаписи = Новый Структура;  
	//	//b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(ОтправленУспешно,ПараметрыДляЗаписи,Истина); 	
	//	УдалитьИзОчередиНаОтправку(); 
	//	
	//КонецЦикла;
	
		
КонецПроцедуры // ОтправитьЗапросДоЗаказНаСервере()

// <Описание функции>
//
// Параметры:
