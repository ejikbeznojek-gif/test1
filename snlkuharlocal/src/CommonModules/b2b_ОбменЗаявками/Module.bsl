#Область ФоновыеЗаданияЗаказ

Процедура ОтправитьНаСогласованиеКлиентуВФоне(Знач Заказ, Знач ВерсияСтарая) Экспорт 
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Заказ);
	МассивПараметров.Добавить(ВерсияСтарая); 
	
	ИдентификаторФЗ = Новый УникальныйИдентификатор; 
	ФЗ = ФоновыеЗадания.Выполнить("b2b_ОбменЗаявками.ОтправитьНаСогласованиеКлиентуВФонеПослеПроверки",МассивПараметров,ИдентификаторФЗ,"ОтправитьНаСогласованиеКлиентуВФонеПослеПроверки"); 
	
КонецПроцедуры 

Процедура ОтправитьНаСогласованиеКлиентуВФонеПослеПроверки(Знач Заказ, Знач ВерсияСтарая) Экспорт 
   	
	ДокЗаписан = Ложь; 
	b2b_ОбменДаннымиПоAPI.ПроверкаВерсииДокументаПриЗаписи(ВерсияСтарая,Заказ,ДокЗаписан);
	
	Если НЕ ДокЗаписан Тогда
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Ошибка выполнения в фоне отправки по апи b2b согласования с клиентом заявки"), 
		УровеньЖурналаРегистрации.Ошибка, 
		, 
		, 
		НСтр("ru = 'Ошибка в ""ОтправитьНаСогласованиеКлиентуВФоне"".'"));
		
		Возврат; 	
	КонецЕсли;
	
	
	МассивТоваров = ДобавитьВМассивТоварыЗаказа(Заказ);
	
	Если МассивТоваров.Количество() = 0  Тогда
	
		ЗаписатьВЛог("b2b","Не найдены товары для отправки на согласование клиенту" + Строка(Заказ),"Информация"); 
		
		Возврат; 
	
	КонецЕсли; 	
	
	ПараметрыДляОтправки = Новый Структура; 
	ПараметрыДляОтправки.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
	ПараметрыДляОтправки.Вставить("IDЗаявки",Заказ.ИдЗаказа);
	ПараметрыДляОтправки.Вставить("СтатусЗаказа","ZA");	
	ПараметрыДляОтправки.Вставить("Товары",МассивТоваров); 
	ПараметрыДляОтправки.Вставить("Дозаказ",Документы.Заказ.ПустаяСсылка()); 
	ПараметрыДляОтправки.Вставить("Подразделение",Справочники.Подразделения.НайтиПоКоду("SSP-0118"));
	ПараметрыДляОтправки.Вставить("ИзФормыЗаказа",истина); 
	
	МассивСообщений = Новый Массив; 
		
	МассивПараметров = Новый Массив; 
	МассивПараметров.Добавить(Заказ);
	МассивПараметров.Добавить("ОтправитьклиентуТолькоВНаличии"); 
	МассивПараметров.Добавить(ПараметрыДляОтправки); 
	МассивПараметров.Добавить(МассивСообщений); 
	
	ИдентификаторФЗ = Новый УникальныйИдентификатор; 
	ФЗ = ФоновыеЗадания.Выполнить("b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку",МассивПараметров,ИдентификаторФЗ,"ЗаписатьВОчередьНаОтправкуОтправитьНАСогласованиеКлиенту"); 

КонецПроцедуры

Функция ДобавитьВМассивТоварыЗаказа(Знач Заказ)
	МассивДанных = Новый Массив; 
	Для каждого СтрокаДанных Из Заказ.Товары Цикл
		
		СтруктураТовара = Новый Структура; 
		СтруктураТовара.Вставить("IDТовара",ПолучитьКодТовараДляПортала(СтрокаДанных.Номенклатура));
		СтруктураТовара.Вставить("Количество",СтрокаДанных.Количество);
		СтруктураТовара.Вставить("Цена",СтрокаДанных.Цена);
		
		МассивДанных.Добавить(СтруктураТовара); 
		
	КонецЦикла;
	
	Возврат МассивДанных; 

КонецФункции

