			записьJSON = ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
			
			Возврат записьJSON; 
			
		конецЕсли;
		
				//
		СкидкаКодКонтрагента = СодержаниеТ.data.user;  // интегральный код
		//
		//++Данилова Е.В. 15.09.2025 HELP-7034 
		//Док = документы.УстановкаСкидокПоКонтрагентам.НайтиПоНомеру(СкидкаНомерДок,НачалоГода(ТекущаяДата()));
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	УстановкаСкидокПоКонтрагентам.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.УстановкаСкидокПоКонтрагентам КАК УстановкаСкидокПоКонтрагентам
		|ГДЕ
		|	УстановкаСкидокПоКонтрагентам.Номер = &Номер
		|	И УстановкаСкидокПоКонтрагентам.Проведен
		|	//И УстановкаСкидокПоКонтрагентам.Дата >= &Дата";
		
		Запрос.УстановитьПараметр("Номер", СкидкаНомерДок);
		//Запрос.УстановитьПараметр("Дата", НачалоГода(ТекущаяДата()));
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
