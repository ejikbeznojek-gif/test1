		СтруктураЗапроса.Data.order.eeeShipmentCancelText = ВходныеПараметры.КомментарийОтменаДоЗаказа;
		СтруктураЗапроса.Data.order.eeeShipmentCancelComment = ВходныеПараметры.ПричинаОтменаДоЗаказа;	
		
