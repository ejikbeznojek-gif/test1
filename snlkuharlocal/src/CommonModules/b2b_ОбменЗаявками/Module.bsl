//
Процедура ОтправитьЗапросПодтвердитьДозаказНаСервере(Документ,ВхПараметры,РезультатОтправки,ИдентификаторЗапроса = неопределено)

	РезультатОтправки = Ложь; 
	
	b2b_ОбменЗаявками.ОтправкаПодтвержденияОтменыДоЗаказа(ВхПараметры,РезультатОтправки,ИдентификаторЗапроса);

КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ОтработатьЗапросОтменитьОтгрузку(Документ,ВхПараметры,РезультатОтправки,ИдентификаторЗапроса = неопределено)

	РезультатОтправки = Ложь; 
	b2b_ОбменЗаявками.ОтправкаОтменыОтгрузкиЗаказа(ВхПараметры,РезультатОтправки,ИдентификаторЗапроса);
	
	Если РезультатОтправки Тогда
		
		ЗаказОбъект = Документ.ПолучитьОбъект(); 
		ЗаказОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененЦО;
		ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен; 
		Попытка
			
			ЗаказОбъект.Записать(); 
			
		Исключение
			
		КонецПопытки;
		
		Если ВхПараметры.Свойство("ЕдинаяОтгрузка") 
			И ВхПараметры.ЕдинаяОтгрузка Тогда
		
			Дозаказ = НайтиДоЗаказпоОсновному(ЗаказОбъект.ссылка);
			Если ЗначениеЗаполнено(Дозаказ)  Тогда
			
				ЗаказОбъект = Дозаказ.ПолучитьОбъект(); 
				ЗаказОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.ОтмененЦО;
				ЗаказОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.Отменен; 
				Попытка
					
					ЗаказОбъект.Записать(); 
					
