// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ОтработатьЗапросыВОчереди(ТекстСообщения = "",МассивОшибок = неопределено) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗапросыНаОбновление.Документ КАК Документ,
		|	b2b_ЗапросыНаОбновление.ТипЗапроса КАК ТипЗапроса,
		|	b2b_ЗапросыНаОбновление.ВходящиеПараметры КАК ВходящиеПараметры,
		|	b2b_ЗапросыНаОбновление.ДатаЗаписи КАК ДатаЗаписи,
		|	b2b_ЗапросыНаОбновление.ИдентификаторЗапроса КАК ИдентификаторЗапроса
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновление КАК b2b_ЗапросыНаОбновление
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаЗаписи";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ТипЗапроса  = ВыборкаДетальныеЗаписи.ТипЗапроса;
		ИдентификаторОчереди = ВыборкаДетальныеЗаписи.ИдентификаторЗапроса; 
		ОтработатьОтправкуОтТипаЗапроса(ТипЗапроса,ВыборкаДетальныеЗаписи.Документ,ВыборкаДетальныеЗаписи.ВходящиеПараметры,ИдентификаторОчереди,ТекстСообщения,МассивОшибок); 
		
	КонецЦикла;
	


КонецПроцедуры // ОтработатьЗапросыВОчереди()

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ОтработатьОтправкуОтТипаЗапроса(ТипЗапроса,Документ,ВхПараметры,ИдентификаторОчереди,ТекстСообщения = "",МассивОшибок = неопределено)
	
	ПараметрыПередачи = ВхПараметры.Получить(); 
	ПараметрыПередачи.Вставить("ИдентификаторОчереди",ИдентификаторОчереди); 
	ПараметрыПередачи.Вставить("Заказ",Документ);
	ПараметрыПередачи.Вставить("ТипЗапроса",ТипЗапроса);
	
	РезультаОтработки = Ложь;
	ИдентификаторЗапроса = ""; //для вывода ошибки пользователю 
	
	Если ТипЗапроса = "СоздатьДозаказ" Тогда
		
		ЗаказыНаОтправку = новый Массив; 
		ЗаказыНаОтправку.Добавить(Документ);
		
		ОтправитьЗапросДоЗаказНаСервере(ЗаказыНаОтправку,РезультаОтработки,ИдентификаторОчереди,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ПодтвердитьДозаказ" Тогда  		
		
		ОтправитьЗапросПодтвердитьДозаказНаСервере(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса); 		
		
		
	ИначеЕсли ТипЗапроса = "ОтправитьклиентуТолькоВНаличии" Тогда
		//Заказы переходят в состояния
		
		ОтработатьЗапросОтправитьТолькоВНаличии(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтправитьклиентуТолькоДозаказ" Тогда 
		
		ОтработатьЗапросОтправитьТолькоДозаказ(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса); 
		
	ИначеЕсли ТипЗапроса = "ОтменитьЗаявку" Тогда 
		
		ПараметрыПередачи.Вставить("ОтменаЗаказа",истина); 
		ПараметрыПередачи.Вставить("Заказ",Документ);
		
		ОтработатьОтменуЗавки(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса); 
		
	ИначеЕсли ТипЗапроса = "ОтправитьКлиентуПолностью" Тогда
		
		ОтработатьЗапросОтправитьПолностью(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса); 
		
	ИначеЕсли ТипЗапроса = "ИзменитьМетодДоставки" Тогда
		
		ОтработатьЗапросИзмененияМетодаДоставки(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтправитьДатуОтгрузкиВместе" Тогда
		
		ОтработатьЗапросОтправкиДатыОтгрузки(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно" Тогда
		
		ОтработатьЗапросОтправкиДатыОтгрузки(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтменитьотгрузкуВналичии"  Тогда 
		
		ОтработатьЗапросОтменитьОтгрузку(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтменитьОтгрузкуДозаказа" Тогда
		
		ОтработатьЗапросОтменитьОтгрузку(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли ТипЗапроса = "ОтменитьОтгрузкуЕдиную"  Тогда 
		ПараметрыПередачи.Вставить("ЕдинаяОтгрузка",Истина); 		
		ОтработатьЗапросОтменитьОтгрузку(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
	ИначеЕсли СтрНайти(ТипЗапроса,"ВыгрузкаОстатковЦО") > 0 Тогда
		
		ОтправкаДанныхПоОстаткамЦО(ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса,МассивОшибок);
		
		РезультаОтработки = Истина;  //чтобы не зависали
		
	ИначеЕсли  СтрНайти(ТипЗапроса,"ВыгрузкаОстатков") > 0 Тогда 
		
		ОтправкаДанныхПоОстаткам(ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);
		
		РезультаОтработки = Истина;
	
	ИначеЕсли ТипЗапроса = "ПодтвердитьЗаКлиентаПолностью"  Тогда
		
		ОтработатьЗапросПодтвердитьЗаКлиентаПолностью(Документ,ПараметрыПередачи,РезультаОтработки,ИдентификаторЗапроса);

	КонецЕсли;
	
	Если РезультаОтработки Тогда
		
		НаборНаОбновление = РегистрыСведений.b2b_ЗапросыНаОбновление.СоздатьНаборЗаписей(); 
		НаборНаОбновление.Отбор.ТипЗапроса.Установить(ТипЗапроса); 
		НаборНаОбновление.Отбор.Документ.Установить(Документ); 
		НаборНаОбновление.Записать();
		
		Сообщить("Успешно отработан запрос с типом " + ТипЗапроса);
		//ТекстСообщения = "Успешно отработан запрос с типом " + ТипЗапроса;
		
		ТекстСообщения = "Успешно отработан запрос"; 
		
		
		
		Если ТипЗапроса = "ОтправитьДатуОтгрузкиВместе" Тогда
			
			
			ЭтоДозаказ = Ложь;
			ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(Документ); 
			
			Если ЗначениеЗаполнено(ОсновнойЗаказ) Тогда
				
				ЭтоДозаказ = Истина;
				ДокументДозаказа = Документ; 
				
			КонецЕсли;
			
			Если Не ЭтоДозаказ Тогда
				
				ОсновнойЗаказ = Документ; 
				ДокументДозаказа = НайтиДоЗаказпоОсновному(Документ); 
				
			КонецЕсли;
			
			ПараметрыДлязаписи = Новый Структура; 
			ПараметрыДлязаписи.Вставить("Отгружен",Истина);
			
			РНКСуществующее = неопределено; 
			
			//РезультатПроверкиСвязи =  ПроверитьСвязьСРНК(ОсновнойЗаказ,РНКСуществующее);
			МассивРНК = СвязанныеРНКЗаказ(ОсновнойЗаказ); 
			//Если ЗначениеЗаполнено(РНКСуществующее)
			//	И РНКСуществующее.Отгружен = Перечисления.Отгружен.Отгружен Тогда
			//	
			//	ЗаписатьДополнительныеДанныеВРегистрЗаказов(ОсновнойЗаказ,ПараметрыДлязаписи);	
			//	
			//КонецЕсли; 
			Если МассивРНК.Количество() > 0  Тогда
				ОтгруженПолностью = истина; 
				Для каждого РНК Из МассивРНК  Цикл
					
					Если РНК.Отгружен <> Перечисления.Отгружен.Отгружен Тогда
						
						ОтгруженПолностью = Ложь; 
						
					КонецЕсли;	
					
				КонецЦикла;
				
				Если ОтгруженПолностью Тогда
				
					ЗаписатьДополнительныеДанныеВРегистрЗаказов(ОсновнойЗаказ,ПараметрыДлязаписи);	
				
				КонецЕсли;
			
			КонецЕсли;
			
			
			Если ЗначениеЗаполнено(ДокументДозаказа) Тогда
				
				РНКСуществующее = неопределено; 
				
				//РезультатПроверкиСвязи =  ПроверитьСвязьСРНК(ДокументДозаказа,РНКСуществующее);
				//Если ЗначениеЗаполнено(РНКСуществующее)
				//	И РНКСуществующее.Отгружен = Перечисления.Отгружен.Отгружен Тогда
				//	
				//	ЗаписатьДополнительныеДанныеВРегистрЗаказов(ДокументДозаказа,ПараметрыДлязаписи);	
				//	
				//КонецЕсли;
				МассивРНК = СвязанныеРНКЗаказ(ДокументДозаказа);
				Если МассивРНК.Количество() > 0  Тогда
					ОтгруженПолностью = истина; 
					Для каждого РНК Из МассивРНК  Цикл
						
						Если РНК.Отгружен <> Перечисления.Отгружен.Отгружен Тогда
							
							ОтгруженПолностью = Ложь; 
							
						КонецЕсли;	
						
					КонецЦикла;
					
					Если ОтгруженПолностью Тогда
						
						ЗаписатьДополнительныеДанныеВРегистрЗаказов(ДокументДозаказа,ПараметрыДлязаписи);	
						
					КонецЕсли;
					
				КонецЕсли;

				
			КонецЕсли;
			
		ИначеЕсли   ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно" тогда 
			
			ПараметрыДлязаписи = Новый Структура; 
			ПараметрыДлязаписи.Вставить("Отгружен",Истина);
			
			РНКСуществующее = неопределено; 
			
			//РезультатПроверкиСвязи =  ПроверитьСвязьСРНК(Документ,РНКСуществующее);
			//Если ЗначениеЗаполнено(РНКСуществующее)
			//	И РНКСуществующее.Отгружен = Перечисления.Отгружен.Отгружен Тогда
			//	
			//	ЗаписатьДополнительныеДанныеВРегистрЗаказов(Документ,ПараметрыДлязаписи);	
			//	
			//КонецЕсли; 
			МассивРНК = СвязанныеРНКЗаказ(Документ);
			
			Если МассивРНК.Количество() > 0  Тогда
				ОтгруженПолностью = истина; 
				Для каждого РНК Из МассивРНК  Цикл
					
					Если РНК.Отгружен <> Перечисления.Отгружен.Отгружен Тогда
						
						ОтгруженПолностью = Ложь; 
						
					КонецЕсли;	
					
				КонецЦикла;
				
				Если ОтгруженПолностью Тогда
					
					ЗаписатьДополнительныеДанныеВРегистрЗаказов(Документ,ПараметрыДлязаписи);	
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе 
		//тоже очишаем 
		
		НаборНаОбновление = РегистрыСведений.b2b_ЗапросыНаОбновление.СоздатьНаборЗаписей(); 
		НаборНаОбновление.Отбор.ТипЗапроса.Установить(ТипЗапроса); 
		НаборНаОбновление.Отбор.Документ.Установить(Документ); 
		НаборНаОбновление.Записать();
 
		Сообщить("Ошибка!!! отработки запроса с типом " + ТипЗапроса);
		
		ТекстСообщения = "Ошибка!!! отработки запроса с типом " + ТипЗапроса;
		
		Если ЗначениеЗаполнено(ИдентификаторЗапроса)  Тогда
			
			ОшибкаТекст = ТекстОшибкиПоИдентификаторуЗапроса(ИдентификаторЗапроса);
			
			ТекстСообщения = ТекстСообщения + Символы.ПС + ОшибкаТекст; 
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры // ()

