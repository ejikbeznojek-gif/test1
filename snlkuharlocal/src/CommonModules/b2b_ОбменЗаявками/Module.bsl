КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()


Процедура ОтправкаДанныхПоОстаткам(ВходныеПараметры,РезультатОтправки,ИдентификаторЗапроса = неопределено) Экспорт

	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
	
	//записать ошибку в журнал 
	    ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменОстатков_POST",УровеньЖурналаРегистрации.Ошибка,,,,);
		Возврат; 
	
	КонецЕсли;
	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаВыгрузки(); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисВыгрузкиОстатков);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляОтправкиОстатков(ВходныеПараметры);
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор;	
	
	ХранитьПодробностиЛогирования = ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
	
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
		//в журнал запишем что отправили и когда, и потом уже ответ 
		ЗаписатьВЖурналЗапросыНаОбновлениеЗаказов(Строка(ИдентификаторЗапроса),СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
	Исключение
		
		//записать ошибку в журнал
		//записать ошибку в журнал
		Комментарий = "Не удалось отправить запрос на обновление остатков. Ошибка!";
		РезультатДанные = СтруктураРезультат();
		ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);

		
		Возврат; //не подключился 
		
	КонецПопытки;
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;

	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
		//запись в журнал 
		 
		 Если Структура_JSON_Ответ.Свойство("data") Тогда   
			  	
			 
			 РезультатДанные = СтруктураРезультат();
			 
			 РезультатДанные.ИдентификаторКлиента = Структура_JSON_Ответ.requestId;
			 РезультатДанные.Документ = "";
			 РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			 
			 ТекстОшибкиЗагрузки = ""; 
			 
			 Если Структура_JSON_Ответ.Свойство("result")
				 И Структура_JSON_Ответ.result = "warning" Тогда
			 
			 	ТекстОшибкиЗагрузки =  Структура_JSON_Ответ.message; 
				
			КонецЕсли;
			
			ЭтоОшибка = ?(ЗначениеЗаполнено(ТекстОшибкиЗагрузки),Истина,Ложь); 
			
			ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,ТекстОшибкиЗагрузки,ЭтоОшибка,ХранитьПодробностиЛогирования);
			
			РезультатОтправки = Истина;
			
			Если ЭтоОшибка Тогда
			
				ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),ТекстОшибкиЗагрузки,Структура_JSON_Ответ.requestId);	
			
			КонецЕсли;
			
			МассивНеПереданные = Новый Массив;  			
			
			Если ТипЗнч(Структура_JSON_Ответ.data) = Тип("Структура") 
				И Структура_JSON_Ответ.data.Свойство("notFound")
				И Структура_JSON_Ответ.data.notFound.Свойство("xmlId") Тогда
				
				Для каждого ЭлементМассива Из Структура_JSON_Ответ.data.notFound.xmlId Цикл
					
					Номенклатура = НайтиТоварПоКодуТовара(ЭлементМассива);
					
					Если  НЕ ЗначениеЗаполнено(Номенклатура) Тогда
						
						Продолжить; 
						
					КонецЕсли;
					
					МассивНеПереданные.Добавить(Номенклатура); 
					
				КонецЦикла; 				
				
			КонецЕсли;
			
			ЗаписатьДанныеВРегистрПереданныеОстатки(ВходныеПараметры,ИдентификаторЗапроса,МассивНеПереданные); 
		 
		 КонецЕсли;
	Иначе 
		//запись в журнал
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400
			ИЛИ КодОшибки = 403 Тогда   		
			
			ИнформацияОбОшибке = Структура_JSON_Ответ.Message;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = СтруктураРезультат(); 
		РезультатДанные.РезультатJson = ТелоСообщения; 
		
		ЗаписатьВЖурналЗапросыНаОбновлениеРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);

	КонецЕсли; 


КонецПроцедуры // ОтправкаПодтвержденияДоЗаказа()

Процедура ОтправкаДанныхПоОстаткамЦО(ВходныеПараметры,РезультатОтправки,ИдентификаторЗапроса = неопределено,МассивОшибок) Экспорт
	
	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
		
		//записать ошибку в журнал 
		ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменОстатков_POST",УровеньЖурналаРегистрации.Ошибка,,,,);
		Возврат; 
		
	КонецЕсли;
	Если ТипЗнч(МассивОшибок) <> Тип("Массив") Тогда
	
		МассивОшибок = Новый Массив;	
	
	КонецЕсли;
	 
	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаВыгрузки(); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисВыгрузкиОстатковОсновной);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляОтправкиОстатковЦО(ВходныеПараметры,ТекущаяДатаСеанса());
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Строка(ВходныеПараметры.ИдентификаторЗапроса);  
	
	ХранитьПодробностиЛогирования = ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
		
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
		 
		
	Исключение
		
		//записать ошибку в журнал
		//записать ошибку в журнал
		Комментарий = "Не удалось отправить запрос на обновление остатков ЦО. Ошибка!";
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди");
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),"",СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),"",РезультатДанные,Комментарий,истина,,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);
		
		//ТемаПисьма = "Ошибка отправки остатков на портал из SNL"; 
		//ТекстПисьма = "Не удалось отправить запрос на обновление остатков ЦО. Ошибка подключения по http. Проверьте подключение! "; 
		//СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,"Ошибка отправки остатков на портал из SNL");  
		
		МассивОшибок.Добавить("Не удалось отправить запрос на обновление остатков ЦО из SNL. Ошибка подключения по http. Проверьте подключение!"); 
		
		Возврат; //не подключился 
		
	КонецПопытки;
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;
	
	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
				
		Если Структура_JSON_Ответ.Свойство("result") Тогда 
				
			
			ТекстОшибкиЗагрузки = ""; 
			
			Если Структура_JSON_Ответ.Свойство("result")
				И Структура_JSON_Ответ.result = "error" Тогда
				
				ТекстОшибкиЗагрузки =  Структура_JSON_Ответ.message; 
				
			КонецЕсли;
			
			ЭтоОшибка = ?(ЗначениеЗаполнено(ТекстОшибкиЗагрузки),Истина,Ложь);
			
			РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди,МассивДанных",,""); 
			
			ИдентификаторКлиента = Структура_JSON_Ответ.requestId;			
			
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			РезультатДанные.МассивДанных = ВходныеПараметры.Товары; 
			
			Если НЕ ЭтоОшибка  Тогда
				
				//РезультатДанные.ИдентификаторОчереди = Структура_JSON_Ответ.data.jobId;
				
			КонецЕсли;
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),ИдентификаторКлиента,СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),ИдентификаторКлиента,РезультатДанные,ТекстОшибкиЗагрузки,ЭтоОшибка,,ХранитьПодробностиЛогирования);
			
						
			Если ЭтоОшибка Тогда
				
				ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),ТекстОшибкиЗагрузки,Структура_JSON_Ответ.requestId);	
				
				//ТемаПисьма = "Ошибка отработки очереди по остаткам на портале"; 
				//ТекстПисьма = "Получена ошибка об обработке очереди на портале. Идентификатор клиента:" + ИдентификаторКлиента ; 
				//
				//СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,"Ошибка отработки очереди по остаткам на портале");
				
				МассивОшибок.Добавить("Получена ошибка при отправке пакета по остаткам из SNL. Идентификатор клиента:" + ИдентификаторКлиента);
				
			КонецЕсли;
		Иначе 
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),"",СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
			
			РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 			
					
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),"",РезультатДанные,"Ответ по структуре не соответствует ожидаемой",Истина,,ХранитьПодробностиЛогирования);
		КонецЕсли;
		
		РезультатОтправки = Истина;
	Иначе 
		//запись в журнал
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),"",СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400
			ИЛИ КодОшибки = 403 Тогда   		
			
			ИнформацияОбОшибке = Структура_JSON_Ответ.Message;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 
		РезультатДанные.РезультатJson = ТелоСообщения; 
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),"",РезультатДанные,Комментарий,истина,,ХранитьПодробностиЛогирования);
		
		//ТемаПисьма = "Ошибка отправки остатков на портал из SNL"; 
		//ТекстПисьма = "Не удалось отправить запрос на обновление остатков ЦО.  Код ошибки " + Комментарий ; 
		//
		//СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,"Ошибка отправки остатков на портал из SNL"); 
		МассивОшибок.Добавить("Не удалось отправить запрос на обновление остатков ЦО из SNL.  Код ошибки " + Комментарий);
	КонецЕсли; 
	
	
КонецПроцедуры // ОтправкаПодтвержденияДоЗаказа()

Процедура ОтработкаОтправленныхДанныхПоОстаткамЦО(ВходныеПараметры,РезультатОтправки,МассивОшибок) Экспорт
	
	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
		
		//записать ошибку в журнал 
		ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменОстатков_POST",УровеньЖурналаРегистрации.Ошибка,,,,);
		Возврат; 
		
	КонецЕсли;
	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаВыгрузки(); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисПолученияДанныхОчередиОстатки);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляПолученияДанныхОчереди(ВходныеПараметры);
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор;
	
	ХранитьПодробностиЛогирования = ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
	
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
				
	Исключение
		
		Комментарий = "Не удалось отправить запрос на получение данных по очереди (Остатки). Ошибка!";
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),"",СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),"",РезультатДанные,Комментарий,истина,,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);
		
		ТекстОшибки = "Не удалось отправить запрос на отработку очереди по остаткам ЦО из SNL. Ошибка подключения по http. Проверьте подключение! ";
		МассивОшибок.Добавить(ТекстОшибки); 
		
		Возврат; //не подключился 
		
	КонецПопытки;
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;
	
	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
				
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 
		
		ИдентификаторКлиента = Структура_JSON_Ответ.requestId;			
		
		РезультатДанные.РезультатJson = Структура_JSON_Ответ;
		РезультатДанные.ИдентификаторОчереди =  ВходныеПараметры.ИдентификаторКлиента; 
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),ИдентификаторКлиента,СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);

		Если Структура_JSON_Ответ.Свойство("data") Тогда 
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),ИдентификаторКлиента,РезультатДанные,,,);
			//++Данилова Е.В. 20.05.2026 без задачи сбоорй в обмене 
			Если  Структура_JSON_Ответ.data.Свойство("result") Тогда  
				//--Данилова Е.В. 20.05.2026 
				Если Структура_JSON_Ответ.data.result = "queued" Тогда     //пока не отработано  
					
					РезультатДанныеОчереди = неопределено;  //не перезаписываем
					ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(ВходныеПараметры.ИдентификаторЗапроса,ВходныеПараметры.ИдентификаторКлиента,РезультатДанныеОчереди,"В обработке",,,ХранитьПодробностиЛогирования); 
					
				ИначеЕсли 	Структура_JSON_Ответ.data.result = "success" 
					ИЛИ Структура_JSON_Ответ.data.result = "warning" Тогда			 			
					
					
					РезультатДанныеОчереди = Неопределено; 
					ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(ВходныеПараметры.ИдентификаторЗапроса,ВходныеПараметры.ИдентификаторКлиента,РезультатДанныеОчереди,"",ЛОЖЬ,Истина,ХранитьПодробностиЛогирования);
					
					МассивНеПереданные = Новый Массив;
					
					Если Структура_JSON_Ответ.data.Свойство("data")
						И Структура_JSON_Ответ.data.data.Свойство("notFound")
						И Структура_JSON_Ответ.data.data.notFound.Свойство("xmlId") Тогда
						
						Для каждого ЭлементМассива Из Структура_JSON_Ответ.data.data.notFound.xmlId Цикл
							
							Номенклатура = НайтиТоварПоКодуТовара(ЭлементМассива);
							
							Если  НЕ ЗначениеЗаполнено(Номенклатура) Тогда
								
								Продолжить; 
								
							КонецЕсли;
							
							МассивНеПереданные.Добавить(Номенклатура); 
							
						КонецЦикла; 				
						
						ЭтоОшибка = МассивНеПереданные.Количество() > 0; 
						
						ТекстОшибкиЗагрузки = "Не найдены товары:"  + СтрСоединить(Структура_JSON_Ответ.data.data.notFound.xmlId,","); 
						Если ЭтоОшибка Тогда
							
							ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),ТекстОшибкиЗагрузки,ВходныеПараметры.ИдентификаторКлиента);							
							
							ТекстОшибки = "При отправке данных по остаткам на портал возникли ошибки." + ТекстОшибкиЗагрузки;
							МассивОшибок.Добавить(ТекстОшибки);
							
						КонецЕсли;
						
						
					КонецЕсли;
					
					
					ЗаписатьДанныеВРегистрПереданныеОстаткиЦО(ВходныеПараметры,ВходныеПараметры.ИдентификаторЗапроса,МассивНеПереданные);
					
				ИначеЕсли 	Структура_JSON_Ответ.data.result = "error"  Тогда
					
					ТекстОшибкиЗагрузки =  Структура_JSON_Ответ.data.message;
					
					РезультатДанныеОчереди = неопределено; 
					
					ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(ВходныеПараметры.ИдентификаторЗапроса,ВходныеПараметры.ИдентификаторКлиента,РезультатДанныеОчереди,"Ошибка отработки очереди " + ТекстОшибкиЗагрузки,истина,,ХранитьПодробностиЛогирования);
					
					ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Ошибка отработки очереди",Структура_JSON_Ответ.requestId);
				Иначе 
					
					РезультатДанныеОчереди = неопределено; 
					
					ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(ВходныеПараметры.ИдентификаторЗапроса,ВходныеПараметры.ИдентификаторКлиента,РезультатДанныеОчереди,"Нераспознанный результат",истина,,ХранитьПодробностиЛогирования);
					
					ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Ошибка отработки очереди",Структура_JSON_Ответ.requestId);
					
					
				КонецЕсли;
				//++Данилова Е.В. 20.05.2026 без задачи сборй в обмене 
			Иначе 
				РезультатДанныеОчереди = неопределено; 
				
				ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(ВходныеПараметры.ИдентификаторЗапроса,ВходныеПараметры.ИдентификаторКлиента,РезультатДанныеОчереди,"Нераспознанный результат",истина,,ХранитьПодробностиЛогирования);
				
				ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),"Ошибка отработки очереди",Структура_JSON_Ответ.requestId);
				
			КонецЕсли; 
			//--Данилова Е.В. 20.05.2026 
		Иначе 
						
			РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 			
					
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			
			ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),ИдентификаторКлиента,РезультатДанные,"Ответ по структуре не соответствует ожидаемой",Истина,,ХранитьПодробностиЛогирования);

		КонецЕсли;
		
		РезультатОтправки = Истина;
	Иначе 
		//запись в журнал
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(Строка(ИдентификаторЗапроса),"",СтрокаJSON,ВходныеПараметры,ХранитьПодробностиЛогирования);
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400
			ИЛИ КодОшибки = 403 Тогда   		
			
			ИнформацияОбОшибке = СтрокаJSONОтвета;
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = Новый Структура("РезультатJson,ИдентификаторОчереди",,""); 
		РезультатДанные.РезультатJson = ТелоСообщения; 
		
		ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(Строка(ИдентификаторЗапроса),"",РезультатДанные,Комментарий,истина,,ХранитьПодробностиЛогирования);
		
		
		ТекстОшибки = "Не удалось отправить запрос на отработку очереди по остаткам ЦО из SNL." + ИнформацияОбОшибке;
		МассивОшибок.Добавить(ТекстОшибки);
		
	КонецЕсли; 
	
	
КонецПроцедуры // ОтправкаПодтвержденияДоЗаказа()

Функция ЗаполнитьСтруктуруДляОтправкиОстатков(ВходныеПараметры)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапросаОстаткиТоваров();   
	
	
	Если ВходныеПараметры.Свойство("IDПользователя")
		И ЗначениеЗаполнено(ВходныеПараметры.IDПользователя) Тогда 		
		
		СтруктураЗапроса.Data.user = ВходныеПараметры.IDПользователя; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.Свойство("Товары")
		И ВходныеПараметры.Товары.Количество() > 0 Тогда 		
		МассивТоваров = Новый Массив; 
		Для каждого ЭлементМассива Из ВходныеПараметры.Товары Цикл
			Если ВходныеПараметры.ЗаписыватьШтрихкод Тогда
				
				СтруктураДляПередачи = Новый Структура("barCode,stock");
				СтруктураДляПередачи.barCode = ЭлементМассива.ШтрихКод; 
				СтруктураДляПередачи.stock = ЭлементМассива.остаток;
				
			Иначе 
				СтруктураДляПередачи = Новый Структура("xmlId,stock");
				СтруктураДляПередачи.xmlId = ПолучитьКодТовараДляПортала(ЭлементМассива.Номенклатура); 
				СтруктураДляПередачи.stock = ЭлементМассива.остаток; 
			КонецЕсли; 
			
			МассивТоваров.Добавить(СтруктураДляПередачи); 
		КонецЦикла; 	
		СтруктураЗапроса.Data.products = МассивТоваров; 
	КонецЕсли;
	
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()

Функция ЗаполнитьСтруктуруДляОтправкиОстатковЦО(ВходныеПараметры,ДатаФормирования)

	СтруктураЗапроса =  СформироватьСтруктуруPostЗапросаОстаткиТоваровЦО();   
	
	
	СтруктураЗапроса.Data.time = ПреобразоватьДатуДляПередачиНаПортал(ДатаФормирования);  	
	
	
	Если ВходныеПараметры.Свойство("Товары")
		И ВходныеПараметры.Товары.Количество() > 0 Тогда 		
		МассивТоваров = Новый Массив; 
		Для каждого ЭлементМассива Из ВходныеПараметры.Товары Цикл
			СтруктураДляПередачи = Новый Структура("xmlId,stock");
			СтруктураДляПередачи.xmlId = ПолучитьКодТовараДляПортала(ЭлементМассива.Номенклатура); 
			СтруктураДляПередачи.stock = ЭлементМассива.остаток; 
			
			
			МассивТоваров.Добавить(СтруктураДляПередачи); 
		КонецЦикла; 	
		СтруктураЗапроса.Data.offers = МассивТоваров; 
	КонецЕсли;
	
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()

Функция ЗаполнитьСтруктуруДляПолученияДанныхОчереди(ВходныеПараметры) Экспорт

	СтруктураЗапроса =  СформироватьСтруктуруGetЗапросаДанныхПоОчереди();   
	
	
	СтруктураЗапроса.Data.requestId = ВходныеПараметры.ИдентификаторКлиента;  	
	
	Возврат СтруктураЗапроса; 


КонецФункции // ЗаполнитьСтруктуруДляОтправкиПодтвержденияТолькоОтгрузкиПоставщика()



Процедура ПолучениеДанныхПоПунктамДоставки(Знач ВходныеПараметры) Экспорт
	
	HTTPСоединение = HTTPСоединение(); 
	Если HTTPСоединение = неопределено Тогда
	
		ЗаписьЖурналаРегистрации("ОшибкаСоединенияОбменЕЭ_GET",УровеньЖурналаРегистрации.Ошибка,,,,); 
	
		Возврат; 
	
	КонецЕсли;
	
	ДанныеДляОтправкиGetЗапроса = ПолучитьПараметрыМетодаЗагрузкиПунктовДоставки(); 
	
	Запрос_АПИ_POST 	= Новый HTTPЗапрос(ДанныеДляОтправкиGetЗапроса.СервисЗагрузкиПунктовДоставки);
	Запрос_АПИ_POST.Заголовки.Вставить("Authorization", ДанныеДляОтправкиGetЗапроса.КлючАвторизации);
	
	СтруктураЗапроса = ЗаполнитьСтруктуруДляЗагрузкиПунктовДоставки(ВходныеПараметры);
	
	СтрокаJSON 	= ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураЗапроса);
	Запрос_АПИ_POST.УстановитьТелоИзСтроки(СтрокаJSON);
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор;
	ХранитьПодробностиЛогирования = ДанныеДляОтправкиGetЗапроса.ХранитьПодробностиЛогирования; 
	
	Попытка
		
		Ответ_АПИ = HTTPСоединение.ОтправитьДляОбработки(Запрос_АПИ_POST);
		//в журнал запишем что отправили и когда, и потом уже ответ		 
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказов(Строка(ИдентификаторЗапроса),СтрокаJSON,ХранитьПодробностиЛогирования); 
		
	Исключение
		
		//записать ошибку в журнал
		Комментарий = "Не удалось отправить get запрос. Ошибка!";
		РезультатДанные = СтруктураРезультат();
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);  
		ЗаписатьОшибкуВЖурнал(Строка(ИдентификаторЗапроса),Комментарий);
		
		Возврат; //не подключился 
		
	КонецПопытки; 
	
	//отработка ответа, пока непонятно как отрабатывать, в какой документ загружать данные 
	
	РезультатЧтенияJSON = СтруктураJSONЗапроса(Ответ_АПИ);                                                                                           
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;

	ТелоСообщения 	= Ответ_АПИ.ПолучитьТелоКакСтроку(); 
	СтрокаОтвета  	= Строка(Ответ_АПИ.КодСостояния) + " " + ТелоСообщения;
	СтрокаJSONОтвета= ТелоСообщения;
	
	
	Если Ответ_АПИ.КодСостояния = 200 Тогда
		//запись в журнал 
		//записать можно id запроса, зарегистрированного на портале в журнал
		Если Структура_JSON_Ответ <> неопределено 
			И Структура_JSON_Ответ.Свойство("data")
			И Структура_JSON_Ответ.data.Свойство("profiles")
			И ТипЗнч(Структура_JSON_Ответ.data.profiles) = Тип("Массив") Тогда 
			
			
			//таблица, так как возможно сохранение больших даных, сейчас только код ПД
			ТаблицаПунктыДоставки = Новый ТаблицаЗначений; 
			ТаблицаПунктыДоставки.Колонки.Добавить("КодЮридическогоЛица");
			ТаблицаПунктыДоставки.Колонки.Добавить("Код");
			ТаблицаПунктыДоставки.Колонки.Добавить("СтруктураДанных");
			ТаблицаПунктыДоставки.Колонки.Добавить("СтруктураДанныхПолная");
						
			Для каждого СтрокаПрофиля Из Структура_JSON_Ответ.data.profiles Цикл
				
				КодЮридическогоЛица =  СтрокаПрофиля.code; 
				
				Если СтрокаПрофиля.Свойство("addresses") Тогда
					
					Для каждого СтрокаАдреса Из СтрокаПрофиля.addresses Цикл
						
						СтрокаТаблицы = ТаблицаПунктыДоставки.Добавить(); 
						СтрокаТаблицы.Код = СтрокаАдреса.code ;
						СтрокаТаблицы.СтруктураДанных = СтрокаПрофиля;
						СтрокаТаблицы.СтруктураДанныхПолная = Структура_JSON_Ответ;
						СтрокаТаблицы.КодЮридическогоЛица = КодЮридическогоЛица ;						
					КонецЦикла;
					
				КонецЕсли;	
				
			КонецЦикла;
			
			ЗаписатьПунктыДоставки(ТаблицаПунктыДоставки,ИдентификаторЗапроса); 
			
			//Записать данные в РС по пунктам доставки 
			
			РезультатДанные = СтруктураРезультат();
			
			РезультатДанные.ИдентификаторКлиента = Структура_JSON_Ответ.requestId; //???? есть или нет 
			РезультатДанные.Документ = неопределено;
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			
			ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"",,ХранитьПодробностиЛогирования);
		Иначе
			РезультатДанные = СтруктураРезультат(); 
			РезультатДанные.РезультатJson = Структура_JSON_Ответ;
			ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,"Не найдены пункты доставки по запросу",,ХранитьПодробностиЛогирования);
		КонецЕсли;
	Иначе
		
		КодОшибки = Ответ_АПИ.КодСостояния;
		
		Если КодОшибки = 400 Тогда   		
			
			ИнформацияОбОшибке = Структура_JSON_Ответ.Message;  //должно быть 
			
		ИначеЕсли КодОшибки = 401 Тогда
			
			ИнформацияОбОшибке = "Авторизация не пройдена"; 
		Иначе 
			
			ИнформацияОбОшибке = "Ошибка сервера";
		КонецЕсли;
		
		Комментарий = Строка(КодОшибки) + ":" + ИнформацияОбОшибке; 
		
		РезультатДанные = СтруктураРезультат(); 
		РезультатДанные.РезультатJson = ТелоСообщения; 
		
		ЗаписатьВЖурналЗапросыНаПолучениеЗаказовРезультат(Строка(ИдентификаторЗапроса),РезультатДанные,Комментарий,истина,ХранитьПодробностиЛогирования);
		
	КонецЕсли; 
	
	
	
КонецПроцедуры

Функция ЗаполнитьСтруктуруДляЗагрузкиПунктовДоставки(Знач ВходныеПараметры)
	                                                                  	
	СтруктураЗапроса = СформироватьСтруктуруPostЗапросаПунктовДоставки(); 
	
	Если ВходныеПараметры.Свойство("IDПользователя")
		И ЗначениеЗаполнено(ВходныеПараметры.IDПользователя) Тогда 		
		
		СтруктураЗапроса.Data.login = ВходныеПараметры.IDПользователя; 	
		
	КонецЕсли;
		
	Возврат СтруктураЗапроса; 
	
КонецФункции // ПолучениеСпискаЗаказов()

Функция ЗаполнитьСтруктуруДляПодтвержденияЗаКлиента(ВходныеПараметры)

	СтруктураЗапроса =  СформироватьСтруктуруЗапросаПодтверждЗаКлиента(ВходныеПараметры.ТипЗапроса);
	
	Если ВходныеПараметры.Свойство("НомерЗаявки")
		И ЗначениеЗаполнено(ВходныеПараметры.НомерЗаявки) Тогда
		
		СтруктураЗапроса.Data.accountNumber = ВходныеПараметры.НомерЗаявки; 	
		
	КонецЕсли;
	
	Если ВходныеПараметры.ТипЗапроса = "ПодтвердитьЗаКлиентаПолностью" Тогда  		
		
		СтруктураЗапроса.Data.order.shipmentMethod = ВходныеПараметры.МетодДоставки; 
	
	КонецЕсли;
	
	Возврат СтруктураЗапроса;

