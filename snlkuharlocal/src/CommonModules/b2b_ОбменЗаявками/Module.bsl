 Процедура ПересчетЦены(Знач ДокументОбъект, Скидка) Экспорт
	 
	ДокументОбъект.Скидка = Скидка; 
 	ИмяРеквизитаЦены = "ЦенаБезСкидки";
	Контрагент = ДокументОбъект.Контрагент;
	
	Если ДокументОбъект.Договор.НеИспользоватьМатрицу  Тогда
		НеИспользоватьМатрицуПоДоговору=Истина;
	иначе
		НеИспользоватьМатрицуПоДоговору=ложь;
	КонецЕсли;	
	
	
	ИспользоватьНоменклатурнуюМатрицу = Ложь; 
	Если контрагент.ИспользоватьНоменклатурнуюМатрицу и не НеИспользоватьМатрицуПоДоговору Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Матрица.Ссылка КАК Ссылка1
		|ИЗ
		|	Документ.Матрица КАК Матрица
		|ГДЕ
		|	Матрица.Контрагент = &Контрагент
		|	И Матрица.Дата <= &Дата1
		|	И Матрица.ДатаОкончания >= &Дата2
		|	И Матрица.Договор = &Договор
		|	И Матрица.Проведен
		|АВТОУПОРЯДОЧИВАНИЕ";
		
		
		Запрос.УстановитьПараметр("Дата2",НачалоДня(ДокументОбъект.дата));
		Запрос.УстановитьПараметр("Дата1",КонецДня(ДокументОбъект.дата));
		Запрос.УстановитьПараметр("Контрагент",Контрагент);  
		Запрос.УстановитьПараметр("Договор",ДокументОбъект.Договор);
		РезультатЗапроса = Запрос.Выполнить(); 
		
		ИспользоватьНоменклатурнуюМатрицу = Истина; 
	КонецЕсли; 
	
	Для Каждого СтрокаТЧ Из ДокументОбъект.Товары Цикл  		
		
		Если ИспользоватьНоменклатурнуюМатрицу И НЕ РезультатЗапроса.Пустой() Тогда
			ЗаполнитьЦенуНоменклатурыТабЧастиПоМатрице_(СтрокаТЧ,ДокументОбъект);
		иначеЕсли ИспользоватьНоменклатурнуюМатрицу И РезультатЗапроса.Пустой() Тогда
			Сообщить("!!! Не найдена матрица по договору документа, цены заполнены без учета договора!");
			ЗаполнитьЦенуНоменклатурыТабЧастиПоМатрицеБезУчетаДоговора_(СтрокаТЧ,ДокументОбъект);
		Иначе //не меняем 
			ЗаполнитьЦенуНоменклатурыТабЧасти_(СтрокаТЧ,ДокументОбъект);  
		КонецЕсли;

		РассчитатьСуммуТабЧасти_(СтрокаТЧ,ДокументОбъект); 

	КонецЦикла;
	
КонецПроцедуры // ПересчетЦены()

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Процедура ЗаполнитьЦенуНоменклатурыТабЧасти_(СтрокаТЧ,ДокументОбъект)
	Распродажа = ложь; 
	
	ТекТипЦен			= ДокументОбъект.ТипЦен;
	Если ЗначениеЗаполнено(ДокументОбъект.ТипЦенРаспродажа) Тогда
		
		Цена = ПолучитьЦенуНоменклатуры_(СтрокаТЧ,ДокументОбъект,ДокументОбъект.ТипЦенРаспродажа);			
		Если ЗначениеЗаполнено(Цена) Тогда
			ТекТипЦен							= ДокументОбъект.ТипЦенРаспродажа;				
			
			СтрокаТЧ.ЦенаБезСкидки	= Цена;				
			Распродажа							= Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Контрагент = ДокументОбъект.Контрагент;
	
	Если Распродажа Тогда
		СтрокаТЧ.Скидка			= -1;
	Иначе 
		
		Если  ЗначениеЗаполнено(Контрагент) И ПроверитьНаличиеСкидокУКонтрагента_(Контрагент) Тогда //Контрагент.Скидки.Количество()>0 Тогда
			СтрокаТЧ.Скидка = ПолучитьСкидкуНоменклатуры_(СтрокаТЧ.Номенклатура,Контрагент,ДокументОбъект.Дата,ТекТипЦен);	
		//Иначе
			
			Наценка = ПолучитьНаценкуНоменклатуры_(СтрокаТЧ.Номенклатура,Контрагент,ДокументОбъект.Дата,ТекТипЦен); // нечаева 29,05,15++
			Если Наценка <> Неопределено И Наценка <> 0 Тогда
				Скидка = СтрокаТЧ.Скидка;
				СтрокаТЧ.Скидка = Скидка -Наценка + Скидка*Наценка/100;
			КонецЕсли;
			Если НЕ ДокументОбъект.ТипСкидок.пустая() Тогда
				
				ДопСкидкаОпт = ПолучитьСкидкуНоменклатуры_(СтрокаТЧ.Номенклатура,ДокументОбъект.ТипСкидок,ДокументОбъект.Дата,); 
				Если ДопСкидкаОпт = Неопределено Тогда ДопСкидкаОпт = 0; КонецЕсли;
				
				СтрокаТЧ.Скидка = СтрокаТЧ.Скидка+ДопСкидкаОпт;
				
			КонецЕсли;
		Иначе 
			
			СтрокаТЧ.Скидка=ПолучитьСкидкуНоменклатуры_(СтрокаТЧ.Номенклатура,ДокументОбъект.ТипСкидок,ДокументОбъект.Дата);
			Если ЗначениеЗаполнено(ДокументОбъект.Договор) И ДокументОбъект.Договор.ДопСкидка<>0 Тогда
				СтрокаТЧ.Скидка = СтрокаТЧ.Скидка + ДокументОбъект.Договор.ДопСкидка;
				Если СтрокаТЧ.Скидка=-1 Тогда				
					СтрокаТЧ.Скидка=0;									
				КонецЕсли;	
			КонецЕсли;
		Конецесли; 
	КонецЕсли;
	
	СтрокаТЧ.ЦенаБезСкидки = ПолучитьЦенуНоменклатуры_(СтрокаТЧ,ДокументОбъект,ТекТипЦен); //ДокументОбъект.ТипЦен);
	СтрокаТЧ.ТипЦен = ТекТипЦен;
	

КонецПроцедуры // ЗаполнитьЦенуНоменклатурыТабЧасти_()

Функция ПроверитьНаличиеСкидокУКонтрагента_(Знач Контрагент)  экспорт
	
	//
	Ведущий = Контрагент.Ведущий; 
	если ЗначениеЗаполнено(Ведущий) тогда
		Контрагент=Ведущий;
	КонецЕсли;
	
	
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ первые 1
	|	СкидкиКонтрагентов.Скидка КАК Скидка
	|ИЗ
	|	РегистрСведений.СкидкиКонтрагентов КАК СкидкиКонтрагентов
	|ГДЕ
	|	СкидкиКонтрагентов.Контрагент = &Контрагент";
	запрос.УстановитьПараметр("Контрагент",Контрагент);
	выборка=запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		Возврат Истина
