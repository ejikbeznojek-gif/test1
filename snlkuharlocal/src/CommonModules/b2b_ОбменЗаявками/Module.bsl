		Запрос.УстановитьПараметр("Дата1",КонецДня(ДатаРасчетаЦены));
		Запрос.УстановитьПараметр("Контрагент",Контрагент);
		Запрос.УстановитьПараметр("Договор",Договор);
		
		Запрос.УстановитьПараметр("ТекПункДоставки",ДокументОбъект.пунктДоставки);
		// цена по акции
		ТЗ1 = Запрос.Выполнить().Выгрузить();
		
		//цена по основному способу расчета, без учета акции		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	МатрицаТовары.Номенклатура,
		|	МатрицаТовары.Цена,
		|	МатрицаПунктыДоставки.Ссылка
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары
		|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
		|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
		|ГДЕ
		|	МатрицаТовары.Ссылка.Дата <= &Дата1
		|	И МатрицаТовары.Ссылка.Проведен
		|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
		|	И МатрицаТовары.Ссылка.Договор = &Договор
		|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
		|	И МатрицаТовары.Номенклатура = &ТекНом
		|	И МатрицаПунктыДоставки.ПунктДоставки.Ссылка = &текПункт
		|   И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция				
		|	УПОРЯДОЧИТЬ ПО
		|	МатрицаТовары.Ссылка.Дата УБЫВ
		|АВТОУПОРЯДОЧИВАНИЕ";
		
		
		Запрос.УстановитьПараметр("ТекНом",ТекТовар);
		Запрос.УстановитьПараметр("Дата2",НачалоДня(ДатаРасчетаЦены));
		Запрос.УстановитьПараметр("Дата1",КонецДня(ДатаРасчетаЦены));
		Запрос.УстановитьПараметр("Контрагент",Контрагент);
		Запрос.УстановитьПараметр("Договор",Договор);
		
		Запрос.УстановитьПараметр("ТекПункт",ДокументОбъект.пунктДоставки);
		ТЗ2 = Запрос.Выполнить().Выгрузить();
		
		Отбор = новый Структура;
		Отбор.Вставить("Номенклатура",ТекТовар);
		СтрокиМатриц = ТЗ1.НайтиСтроки(Отбор); 
		СтрокиМатриц2 = ТЗ2.НайтиСтроки(Отбор); 
		ТекЦена=0;
		Если СтрокиМатриц.Количество() = 0 Тогда
			// смотрим по основной базе
			Если СтрокиМатриц2.Количество() = 0 Тогда
				ТекЦена=0;
			Иначе
				Для Каждого СтрокаМатриц Из СтрокиМатриц2 Цикл
					ТекЦена=СтрокаМатриц.Цена;
					
				КонецЦикла;
			КонецЕсли;
			
		Иначе
			
			Для Каждого СтрокаМатриц Из СтрокиМатриц Цикл
				ТекЦена=СтрокаМатриц.Цена;					
			КонецЦикла;
			
		КонецЕсли;
		
		
	иначе 
		// берем по матрицам без заполненных факт адресов.
		
		Контрагент=ДокументОбъект.Контрагент;
		ТекТовар = СтрокаТЧ.номенклатура;
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	МатрицаТовары.Номенклатура,
		|	МатрицаТовары.Цена,
		|	МатрицаТовары.Ссылка
		|ИЗ
