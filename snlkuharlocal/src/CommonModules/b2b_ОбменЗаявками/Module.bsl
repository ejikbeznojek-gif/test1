#Область Маркировка 

Функция ПолучитьСоответствиеТоварТребМаркировка(Знач Заказ, Товары)	Экспорт
	
	СтруктураДанныхНакладной = Новый  Структура("Номенклатура,ПунктДоставки,Договор,Дата,Контрагент,ПостояннаяАкция,Товары"); 
	ЗаполнитьЗначенияСвойств(СтруктураДанныхНакладной,Заказ); 
	СтруктураДанныхНакладной.ПостояннаяАкция 	= Ложь; 
	СтруктураДанныхНакладной.Номенклатура 		= Товары.ВыгрузитьКолонку("Номенклатура");
	СтруктураДанныхНакладной.Товары = Товары; 
	
	ДатаПроверки = ?(ЗначениеЗаполнено(Заказ.ДатаОтгрузки),Заказ.ДатаОтгрузки,Заказ.Дата);
	
	ТаблицаПереопределяемыхДат = МаркировкаКС.ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(СтруктураДанныхНакладной,"Товары");
	
	Если ТаблицаПереопределяемыхДат <> Неопределено 
		И  ТаблицаПереопределяемыхДат.количество()>0 тогда
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТЗ.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ТЗ.ДатаНачалаРаботыСМаркировкой КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ВремТЗ
		|ИЗ
		|	&ТаблицаПереопределяемыхДат КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗ.Номенклатура КАК Ссылка,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ТЗ.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
		|				И ЕСТЬNULL(ТЗ.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) < &ДатаПроверки
		|			ТОГДА ИСТИНА
		|		КОГДА ТЗ.Номенклатура.ОтгрузкаТолькоЧерезЧЗ
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ТребуетсяМаркировка
		|ИЗ
		|	ВремТЗ КАК ТЗ";
		запрос.УстановитьПараметр("ДатаПроверки",ДатаПроверки);
		запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат",ТаблицаПереопределяемыхДат); 
		
		
	иначе
		
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
		|				И ЕСТЬNULL(Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) < &ДатаПроверки
		|			ТОГДА ИСТИНА
		|		КОГДА Номенклатура.ОтгрузкаТолькоЧерезЧЗ
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ТребуетсяМаркировка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&СписокНоменклатуры)";
		запрос.УстановитьПараметр("ДатаПроверки",ДатаПроверки);
		Запрос.УстановитьПараметр("СписокНоменклатуры",СтруктураДанныхНакладной.Номенклатура);
		
	КонецЕсли; 
	
	КэшПризнакаМаркировки = Новый Соответствие; 
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КэшПризнакаМаркировки.Вставить(Выборка.Ссылка,Выборка.ТребуетсяМаркировка);	
	КонецЦикла;
	
	Возврат КэшПризнакаМаркировки; 
КонецФункции


	
