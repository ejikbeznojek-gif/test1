Функция ОстаткиДляОтправкиНаСайт(ТолькоИзменения = Истина,ОстаткиЦО = Ложь) Экспорт 
	
	Запрос=Новый Запрос;     
	
	запрос.Текст = "ВЫБРАТЬ
	|	Ном.Ссылка КАК Номенклатура,
	//++Данилова Е.В. 18.02.2025
	//|	ВЫБОР
	//|		КОГДА СУММА(ЕСТЬNULL(ВложенныйЗапрос.КолКонФакт, 0)) > 1000
	//|			ТОГДА 1000
	//|		КОГДА СУММА(ЕСТЬNULL(ВложенныйЗапрос.КолКонФакт, 0)) < 0
	//|			ТОГДА 0
	//|		ИНАЧЕ СУММА(ЕСТЬNULL(ВложенныйЗапрос.КолКонФакт, 0))
	//|	КОНЕЦ КАК Остаток,
	//|	ВЫБОР
