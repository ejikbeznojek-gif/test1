Функция ПреобразоватьКодТовара(КодТовара)

	НомерПозиции = СтрНайти(КодТовара,"#");
	Если НомерПозиции > 0  Тогда
	
		Возврат Сред(КодТовара,НомерПозиции +1,СтрДлина(КодТовара) - НомерПозиции); 	
	
	КонецЕсли;
	
	Возврат КодТовара; 

