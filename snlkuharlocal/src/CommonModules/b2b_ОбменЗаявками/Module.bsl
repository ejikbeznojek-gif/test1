Функция ПолучитьЗначениеРеквизитаПоДокументу(Знач Документ, ИмяРеквизита)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеквизитыДокументов.ЗначениеРеквизита КАК ЗначениеРеквизита
		|ИЗ
		|	РегистрСведений.РеквизитыДокументов КАК РеквизитыДокументов
		|ГДЕ
		|	РеквизитыДокументов.Документ = &Документ
		|	И РеквизитыДокументов.ИмяРеквизита = &ИмяРеквизита";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.ЗначениеРеквизита; 	
	
	КонецЕсли;
	
	Возврат ""; 

КонецФункции // ПолучитьЗначениеРеквзитаПоДокументу()

