Функция ВывестиТекстОшибкиПоследний(Знач Заказ) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Период) КАК Период
		|ПОМЕСТИТЬ ВТМаксимальныйПериод
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, Документ = &Заказ) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.ТекстОшибки КАК ТекстОшибки
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, Документ = &Заказ) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМаксимальныйПериод КАК ВТМаксимальныйПериод
		|		ПО b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Период = ВТМаксимальныйПериод.Период";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Возврат ВыборкаДетальныеЗаписи.ТекстОшибки; 
	
	КонецЕсли;
	
	Возврат ""; 

КонецФункции // ВывестиТекстОшибкиПоследний()


Функция ПолучитьДатуОплаты_b2b(ДатаОтгрузки,ОтсрочкаПлатежа)  Экспорт
	Если   НЕ ЗначениеЗаполнено(ДатаОтгрузки) Тогда
		Возврат   Дата(1,1,1); 
	Иначе
		Если  ОтсрочкаПлатежа.ВидОтсрочки = Перечисления.ВидыОтсрочки.БанковскиеДни Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	КалендарьДни.Дата КАК Дата
			|ИЗ
			|	Справочник.Календарь.Дни КАК КалендарьДни
			|ГДЕ
			|	КалендарьДни.Дата >= &ДатаОтгрузки
			|	И КалендарьДни.Часы <> 0
			|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Дата
			|АВТОУПОРЯДОЧИВАНИЕ";
			Запрос.УстановитьПараметр("ДатаОтгрузки",ДатаОтгрузки);
			Выборка = Запрос.Выполнить().Выбрать();
			НПП = 0;
			Пока Выборка.Следующий() Цикл
				
				Если НПП = ОтсрочкаПлатежа.Отсрочка Тогда
					Возврат Выборка.Дата;	
				Конецесли;
				НПП = НПП + 1;
			КонецЦикла;
			
			Возврат ДатаОтгрузки+ОтсрочкаПлатежа.Отсрочка*24*60*60;		
		Иначе		
			Возврат ДатаОтгрузки+ОтсрочкаПлатежа.Отсрочка*24*60*60;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

Процедура ПометитьНаУдалениеРНКОтправкаЗапросаНаПортал(Знач Заказ)
	
	//Перем МетодДоставки, ОсновнойЗаказ, ПараметрыНаОтправку, Сообщения, ТипЗапроса, ЭтоДозаказ;
	
	МетодДоставки = b2b_ОбменЗаявками.МетодДоставкиПоЗаказу(Заказ);
	
	ЭтоДозаказ = Ложь;
	ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(Заказ); 
	Если ЗначениеЗаполнено(ОсновнойЗаказ) Тогда
		ЭтоДозаказ = Истина; 
	КонецЕсли;
	
	
	ПараметрыНаОтправку = Новый Структура;
	ПараметрыНаОтправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
	
	Если МетодДоставки = "F"  и НЕ ЭтоДозаказ Тогда
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
		
		ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",Заказ.ДатаОтгрузки);
		
	КонецЕсли;
	
	Если МетодДоставки = "F"  и ЭтоДозаказ Тогда
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
		
		ОсновнойЗаказ = НайтиОсновнойЗаказпоДозаказу(Заказ); 
		
		ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа","");
		
	КонецЕсли;
	
	Если МетодДоставки = "P"  Тогда
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
		
		Если ЭтоДозаказ  Тогда
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа","");
			
		Иначе 
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа","");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Сообщения = Новый Массив; 
	b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Заказ,ТипЗапроса,ПараметрыНаОтправку,Сообщения);

КонецПроцедуры // ПометитьНаУдалениеРНК()

Процедура СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,Основание)  Экспорт

	СписокПолучателей = Новый СписокЗначений; 	
