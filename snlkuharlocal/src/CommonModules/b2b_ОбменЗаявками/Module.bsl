Процедура ОбновитьОсновныеОстаткиb2b(ТолькоИзменения = Ложь) Экспорт

	 ПараметрыДляВыгрузкиОстатков = Новый Структура;
	 
	 НастройкиДляВыгрузкиОстатков = ПолучитьПараметрыМетодаВыгрузкиОстатковОсновного(); 
	 
	 ПотокМассивовТоваров = ОстаткиДляОтправкиНаСайт(ТолькоИзменения,истина); 
	 Сч = 1;
	 ИдентификаторЗапроса = Новый УникальныйИдентификатор;
	 
	 ПараметрыДляВыгрузкиОстатков.Вставить("ИдентификаторЗапроса",Строка(ИдентификаторЗапроса)); 
	 
	 МассивСообщений = Новый Массив; 
	 МассивОшибок = Новый Массив; 
	 Для каждого  МассивТоваров Из ПотокМассивовТоваров Цикл
		 
		 ПараметрыДляВыгрузкиОстатков.Вставить("Товары",МассивТоваров);  	 
		 
		 b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку("ОстаткиЦО","ВыгрузкаОстатковЦО" + Формат(Сч,"ЧГ=0"),ПараметрыДляВыгрузкиОстатков,МассивСообщений,МассивОшибок);	
		 Сч = Сч + 1; 
	 КонецЦикла;
	 
	 Если МассивОшибок.Количество() > 0 Тогда
		 //только одну выведем
		 ТемаПисьма = "Ошибка отправки остатков на портал из SNL."; 
		 ТекстПисьма = МассивОшибок[0] + Символы.ПС + ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы())); 
		 СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,"Ошибка отправки остатков на портал из SNL");	
		 
	 КонецЕсли;
	 
	 
	
КонецПроцедуры // ()

Процедура b2b_ОбновитьОсновныеОстаткиПолная(Ключ) Экспорт
