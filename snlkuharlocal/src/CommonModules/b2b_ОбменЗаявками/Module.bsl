//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
Функция ПреобразоватьДату(ДатаССайта)
	
	Если Не ЗначениеЗаполнено(ДатаССайта) Тогда
	
		Возврат Дата(1,1,1); 
	
	КонецЕсли;
	
	ДатаССайта = СтрЗаменить(ДатаССайта,".",""); 
	ДатаССайта = СтрЗаменить(ДатаССайта,",","");
	ДатаССайта = СтрЗаменить(ДатаССайта," ","");
	ДатаССайта = СтрЗаменить(ДатаССайта,":","");
	
	Год = Сред(ДатаССайта,5,4); 
	Число = Лев(ДатаССайта,2); 
	Месяц = Сред(ДатаССайта,3,2);
	
	Время = Сред(ДатаССайта,9,6); 
	
	
	Возврат Дата(Год + Месяц + Число + Время); 

КонецФункции // ПробразоватьДату()


Функция НайтиЗаказКлиента(Знач СтруктураЗаказа)
	
	ИДЗаказа 	= СтруктураЗаказа.order.bxId; 
	НомерЗаказа =  СтруктураЗаказа.order.accountNumber;
	ДатаЗаказа =  СтруктураЗаказа.order.dateCreate;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	НЕ Заказ.ПометкаУдаления
	|	И (Заказ.НомерЗаказа = &Номер
	|				И НАЧАЛОПЕРИОДА(Заказ.ДатаЗаказа, ДЕНЬ) = &ДатаСоздания
	|			ИЛИ Заказ.ИдЗаказа = &ИдЗаказа)
	|	И НЕ Заказ.b2b_Дозаказ"; 
		
	Запрос.УстановитьПараметр("ДатаСоздания", НачалоДня(ПреобразоватьДату((ДатаЗаказа))));
	Запрос.УстановитьПараметр("ИдЗаказа", ИдЗаказа);
	Запрос.УстановитьПараметр("Номер", НомерЗаказа);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ссылка; 
	Иначе
		Возврат Неопределено; 
	КонецЕсли;

КонецФункции

