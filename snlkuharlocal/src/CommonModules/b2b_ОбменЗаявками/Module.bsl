Процедура РассчитатьСуммуТабЧасти_(СтрокаТЧ,ДокументОбъект)  Экспорт

	Скидка = ДокументОбъект.Скидка; 
	
	СкидкаТЧ = СтрокаТЧ.Скидка;
	Если СкидкаТЧ = 0 Тогда
		Скидка = ДокументОбъект.Скидка;
	Иначе
		Если СкидкаТЧ > 0 Тогда				
			Скидка = СкидкаТЧ;
			Если ДокументОбъект.ДопСкидкаНаНакладную Тогда
				Скидка = Скидка + ДокументОбъект.Скидка;
			КонецЕсли; 
		Иначе
			//крохин начало 23.04.2012
			//для Беларуси, скидки могут быть отрицательными
			//	Скидка=0;
			Если СкидкаТЧ = -1 Тогда
				Скидка = 0;
			Иначе
				Скидка = СкидкаТЧ;
				Если ДокументОбъект.ДопСкидкаНаНакладную Тогда
					Скидка = Скидка + ДокументОбъект.Скидка;
				КонецЕсли;
			КонецЕсли;
			//крохин конец 23.04.2012
		КонецЕсли;
	КонецЕсли;

	СтрокаТЧ.ВсегоБезСкидки	= СтрокаТЧ.ЦенаБезСкидки*СтрокаТЧ.Количество;
	
	СтрокаТЧ.Цена	= СтрокаТЧ.ЦенаБезСкидки*(1-Скидка/100); //округление под разрядность реквизита "Цена" документа
	Цена			= СтрокаТЧ.Цена;
		
	СтрокаТЧ.Сумма 		= Цена * СтрокаТЧ.Количество;
	
	
	СтавкаНДС=ПроцентНДСпоСтавке(СтрокаТЧ.СтавкаНДС);
	
	
	НДС_Сверху = ДокументОбъект.Контрагент.НДС_Сверху;
	
	контрагентТ = ДокументОбъект.контрагент;
	
	Если НДС_Сверху Тогда
		
		
		ВсегоДоИзменения  =  СтрокаТЧ.ЦенаИсх * СтрокаТЧ.Количество;
		СуммаДоИзменения  =  Окр(ВсегоДоИзменения/(1+СтавкаНДС),2);
		НДСДоИзменения    =  ВсегоДоИзменения - СуммаДоИзменения;
		
		
		ЦенаПослеИзменения = СтрокаТЧ.ЦенаФакт;
		ЦенаПослеИзменения = Окр(ЦенаПослеИзменения/(1+СтавкаНДС),4);
		СуммаПослеИзменения= Окр(ЦенаПослеИзменения * СтрокаТЧ.Количество,4);
		НДСПослеИзменения	= Окр(СуммаПослеИзменения*СтавкаНДС,4);
		ВсегоПослеИзменения	= Окр(СуммаПослеИзменения + НДСПослеИзменения,4);
		
		СтрокаТЧ.Сумма	= СуммаДоИзменения - СуммаПослеИзменения;
		СтрокаТЧ.НДС	= НДСДоИзменения - НДСПослеИзменения;
		СтрокаТЧ.Всего	= ВсегоДоИзменения - ВсегоПослеИзменения;
		СтрокаТЧ.ВсегоБезСкидки	= 100*СтрокаТЧ.Всего/(1 - Скидка);//СтрокаТЧ.ВсегоБезСкидки*(1-Скидка/100);
		Если Скидка=0 тогда
			СтрокаТЧ.ВсегоБезСкидки	= СтрокаТЧ.Всего;
		Конецесли;	
			
		
	Иначе
		
		Цена = Окр(Цена/(1+СтавкаНДС),2);
		СтрокаТЧ.Сумма	= Цена * СтрокаТЧ.Количество;
		СтрокаТЧ.НДС	= СтрокаТЧ.Сумма*СтавкаНДС;
		СтрокаТЧ.Всего	= СтрокаТЧ.Сумма + СтрокаТЧ.НДС;
		ЦенаБезСкидки = Окр(СтрокаТЧ.ЦенаБезСкидки/(1+СтавкаНДС),2);
		СтрокаТЧ.ВсегоБезСкидки	= ЦенаБезСкидки*СтрокаТЧ.Количество*(1+СтавкаНДС);
		
	КонецЕсли;  	



КонецПроцедуры

