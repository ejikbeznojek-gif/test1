Процедура ПолучитьРезультатОбработкиОчередиНаСайте()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторЗапроса КАК ИдентификаторЗапроса,
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторКлиента КАК ИдентификаторКлиента,
		|	b2b_ЗапросыНаОбновлениеВОчереди.МассивДанных КАК МассивДанных
		|ИЗ
		|	РегистрСведений.b2b_ЗапросыНаОбновлениеВОчереди КАК b2b_ЗапросыНаОбновлениеВОчереди
		|ГДЕ
		|	b2b_ЗапросыНаОбновлениеВОчереди.ИдентификаторКлиента <> """"
		|	И НЕ b2b_ЗапросыНаОбновлениеВОчереди.Отработано
		|	И (ВЫРАЗИТЬ(b2b_ЗапросыНаОбновлениеВОчереди.ТекстОшибки КАК СТРОКА(500))) = """"
		|	И b2b_ЗапросыНаОбновлениеВОчереди.ТипЗапроса ПОДОБНО ""ВыгрузкаОстатковЦО%""
		|
		|УПОРЯДОЧИТЬ ПО
		|	b2b_ЗапросыНаОбновлениеВОчереди.Период";
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	РезультатОтправки = Ложь; 
	
	МассивОшибок = Новый массив; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПараметрыДляОтправкиЗапроса = Новый Структура; 
		ПараметрыДляОтправкиЗапроса.Вставить("ИдентификаторКлиента",ВыборкаДетальныеЗаписи.ИдентификаторКлиента);
		ПараметрыДляОтправкиЗапроса.Вставить("ИдентификаторЗапроса",ВыборкаДетальныеЗаписи.ИдентификаторЗапроса);
		ПараметрыДляОтправкиЗапроса.Вставить("Товары",ВыборкаДетальныеЗаписи.МассивДанных.Получить()); 
		ПараметрыДляОтправкиЗапроса.Вставить("ТипЗапроса","Отработка очереди по остаткам ЦО"); 
		
		ОтработкаОтправленныхДанныхПоОстаткамЦО(ПараметрыДляОтправкиЗапроса,РезультатОтправки,МассивОшибок); 
		
	КонецЦикла;
	
	Если МассивОшибок.Количество() > 0 Тогда
		//вывв=едем в письме только одну
		ТемаПисьма = "Ошибка отработки очереди  по остаткам  из SNL на портале."; 
		ТекстПисьма = МассивОшибок[0] + Символы.ПС + ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));  
		СформироватьВнутреннееУведомлениеОбОшибке(ТекстПисьма,ТемаПисьма,"Ошибка отправки остатков на портал из SNL");	
		
	КонецЕсли;
	
	


КонецПроцедуры // ()



