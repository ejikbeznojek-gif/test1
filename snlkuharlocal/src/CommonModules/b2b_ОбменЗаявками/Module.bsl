Функция СоздатьЗаказКлиента(ДанныеАпи)
	
	ЗаказКлиентаНовый = Документы.Заказ.СоздатьДокумент(); 
	ЗаказКлиентаНовый.Дата =  ТекущаяДатаСеанса();
	ЗаказКлиентаНовый.ИдЗаказа =  ДанныеАпи.order.bxId;
	ЗаказКлиентаНовый.НомерЗаказа =  ДанныеАпи.order.accountNumber;
	ЗаказКлиентаНовый.ДатаЗаказа =  ПреобразоватьДату(ДанныеАпи.order.dateCreate);
	ЗаказКлиентаНовый.ДатаОформления =  ТекущаяДатаСеанса();
	ЗаказКлиентаНовый.ИсточникЗаказа =  Перечисления.ИсточникЗаказа.Сайт; 
	 
	
	СтатусЗаказа_b2b = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором; //новый заказ формируется как ЖдетПодтвержденияДистрибьютором 
	//если  новый заказ, а его статус другой.. как ошибку возможно записать 
	МетодДоставки  =  ДанныеАпи.order.shipmentMethod;
	ДатаОбновления =  ПреобразоватьДату(ДанныеАпи.order.dateUpdate);
	
	ЗаказКлиентаНовый.Автор = ПараметрыСеанса.Пользователь; 
	 
	Контрагент = НайтиКонтрагентаПоСивольномуКоду(ДанныеАпи.order.user); 
	Если Не ЗначениеЗаполнено(Контрагент) Тогда
		
		ЗаписатьОшибкуВЖурнал(Строка(Новый УникальныйИдентификатор),"Не найден контрагент " + ДанныеАпи.order.user);
		Возврат неопределено; 	
	
	КонецЕсли;
	ЗаказКлиентаНовый.Контрагент = ?(ЗначениеЗаполнено(Контрагент),Контрагент,Справочники.Контрагенты.ПустаяСсылка());
	
	ЗаказКлиентаНовый.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
	ЗаказКлиентаНовый.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО; 	 
	
	ЗаказКлиентаНовый.ИБ=Справочники.ИБ.НайтиПоКоду("SMN");
	
	ЗаказКлиентаНовый.ВидОплаты=перечисления.ВидыОплаты.БН; //++-++
	ЗаказКлиентаНовый.КодОперации=перечисления.КодыОперацийОстатки.Реализация;
	// Смирнов М.Ю. 17.07.2025 начало
	ИмяИБ = НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref"); 
	Если ИмяИБ = "ekf" Тогда
		//++Данилова Е.В. 14.08.2025 HELP-6540
		//ЗаказКлиентаНовый.Склад = Справочники.Склады.НайтиПоКоду("STЕ-18");
		ЗаказКлиентаНовый.Склад = Справочники.Склады.НайтиПоКоду("STD-99");
		//--Данилова Е.В. 14.08.2025
	Иначе
		//ЗаказКлиентаНовый.Склад = Справочники.Склады.НайтиПоКоду("SSW-53"); //ЗаказКлиентаНовый.Контрагент.ОсновнойСкладОтгрузки; // 
		ЗаказКлиентаНовый.Склад = Справочники.Склады.НайтиПоКоду("STC-60");
	КонецЕсли;
	// Смирнов М.Ю. 17.07.2025 конец 
	
	//++Данилова Е.В. 09.10.2025  HELP-7391 
	Если ЗаказКлиентаНовый.Контрагент.РаботаСМаркированнымТоваромПодтверждена Тогда
		
