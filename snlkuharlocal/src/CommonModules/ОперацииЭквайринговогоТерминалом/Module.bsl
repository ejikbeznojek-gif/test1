					//Сообщить("Попытка повторного возврата списания баллов в этом чеке, начисление не выполнено");
					Возврат Истина
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		AuthRq = PCX.CreateRefundRequest();
		AuthResp = PCX.CreateRefundResponse();
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "cheque_msg_req";
		Extension.Critical = 1; 
		Extension.AddParam("msg_req","y"); 
		AuthRq.Extensions.AddItem(Extension); 
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "PURCHASE_EXT_PARAMS"; 
