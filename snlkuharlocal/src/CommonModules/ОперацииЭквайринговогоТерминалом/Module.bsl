Функция УзнатьХэш() экспорт
	попытка
		ВыхПараметры=новый СписокЗначений;
		ОбъектДрайвера = Новый COMОбъект("SBRFSRV.Server");
		очистить=ОбъектДрайвера.clear();	
		ответ=ОбъектДрайвера.NFun (5002);
		если ответ = 0 тогда
			Хэш=ОбъектДрайвера.GParamString("hash");
			ЭтоСбер=ОбъектДрайвера.GParamString("OWNCArd");
			Пан=ОбъектДрайвера.GParamString("ClientCard");
			Пан="************"+сред(пан,13);
			если ЭтоСбер<>"1" тогда
				ВыхПараметры.Добавить("ЭтожНеСбер");
				ВыхПараметры.Добавить(пан);
				Возврат ВыхПараметры;
			КонецЕсли;
			ОбъектДрайвера.clear();
			ВыхПараметры.Добавить(Хэш);
			ВыхПараметры.Добавить(пан);
			Возврат ВыхПараметры;
		иначе 
			Сообщить("Карта не прочитана, ошибка чтения карты");
			возврат Неопределено;
		КонецЕсли;
	Исключение
		Сообщить("Карта не прочитана, ошибка соединения с терминалом");
		возврат Неопределено;
	КонецПопытки;
КонецФункции


Функция ПроверитьБалансБаллов (хэш,пан) экспорт
	если хэш="ЭтожНеСбер" тогда возврат 0
	КонецЕсли;
	//кухарь 28.02.14 начало
	если СтрДлина(хэш)< 4 тогда
		возврат 0;
	КонецЕсли;
	//кухарь 28.02.14 конец

	попытка	
		pcx=ЭквайринговыйТерминал;
		
		//request = PCX.CreateAuthRequest(); 
		//Response=PCX.CreateAuthResponse(); 
		request = PCX.CreateinfoRequest(); 
		Response=PCX.CreateAuthResponse(); 
		
		//InfoRequest=PCX.CreateInfoRequest();
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "cheque_msg_req";
		Extension.Critical = 1; 
		Extension.AddParam("msg_req","y"); 
		request.Extensions.AddItem(Extension); 
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "PURCHASE_EXT_PARAMS"; 
		Extension.Critical = 1; 
		Extension.AddParam("PAN4", пан);
		//Extension.AddParam("RECEIPT", чек.УникальныйИдентификатор();//Передача маскированного ПАНа 
		request.Extensions.AddItem(Extension); 
		
		
		//InfoRequest=PCX.CreateAuthRequest();
		
		
		
		ClientID=Хэш;
		request.ClientID=ClientID;
		request.ClientIDType =6;
		
		retcode=PCX.GetInfo_V1(request,Response);
		Ограничена=ложь;
		если retcode= 0 тогда
			
			
			для сч=0 по Response.CardInfo.GetCount()-1 цикл
				item=Response.CardInfo.GetItem(сч);
				//кухарь 15.04.14 начало
				//Если item.Name="AB" тогда
				Если item.Name="BNS" тогда	
				//кухарь 15.04.14 конец
					баллов=item.Value;	
					//Сообщить("баллов на карте" +" : " + item.Value);	
				КонецЕсли;	
				Если item.Name="CS" и item.value="R" тогда
					Сообщить("карта ограниченна");
					Ограничена=Истина;	
					//Сообщить("баллов на карте" +" : " + item.Value);	
				КонецЕсли;	
			КонецЦикла;
			
			ChequeMessage = Response.ChequeMessage;
			Сообщить(ChequeMessage);	
			
		иначе
			Сообщить(PCX.GetErrorMessage(RetCode));
		КонецЕсли;
		//PCX.Finalize(); 
		
		если баллов = "" или баллов = Неопределено или Ограничена тогда
			баллов=0;
		КонецЕсли;
		Возврат баллов;
	Исключение
		Сообщить("ошибка получения баланса карты");
		возврат "";
	КонецПопытки;
КонецФункции


Функция ОплатитьБаллами (Хэш,СуммаОплаты,чек,форма,пан) Экспорт 
	//попытка
	
	pcx=ЭквайринговыйТерминал;
	
	отбор=новый Структура;
	отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
	отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
	отбор.Вставить("Отменена",ложь);
	ТрОплаты=форма.ТранзакцииБН.найтистроки(отбор);
	если ТрОплаты<> Неопределено тогда
