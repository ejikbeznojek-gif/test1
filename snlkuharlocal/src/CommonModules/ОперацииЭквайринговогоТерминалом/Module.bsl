		//сумма оплаты баллами (в копейках)
		//BonusAmount = СуммаОплаты*100;
		//сумма оплаты баллами (в копейках)
		
		altBonusAmount=РасчетЧастичногоВозвратаОплатыБаллами(чек);
		//Сообщить("расчётная сумма " + строка(altBonusAmount));
		BonusAmount=Окр(altBonusAmount*100,0);
