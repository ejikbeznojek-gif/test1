Функция ВозвратНачисленияБаллов(Хэш,СуммаОплатыБН,СуммаОплатыБаллами,чек,форма,пан)
	если Хэш="ЭтожНеСбер" тогда
		Возврат Истина
	КонецЕсли;
	
	
	попытка
		
		pcx=ЭквайринговыйТерминал;
		если ТипЗнч(Чек)<>Тип("ДокументОбъект.ПриходнаяНакладная") тогда
			отбор=новый Структура;
			отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.ВозвратНачисления);
			отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
			отбор.Вставить("Отменена",ложь);
			ТрОплаты=форма.ТранзакцииБН.найтистроки(отбор);
			если ТрОплаты<> Неопределено тогда
				если ТрОплаты.количество()>0 тогда
					//Сообщить("Попытка повторного возврата начисления баллов в этом чеке, списание не выполнено");
					Возврат Истина
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		
		AuthRq = PCX.CreateRefundRequest();
		AuthResp = PCX.CreateRefundResponse();
		
		//сумма оплаты баллами (в копейках)
		//BonusAmount = СуммаОплатыБаллами*100;
		//
		altBonusAmount=РасчетЧастичногоВозвратаОплатыБаллами(чек);
		//Сообщить("расчётная сумма " + строка(Окр(altBonusAmount,2)));
		BonusAmount=Окр(altBonusAmount*100,0);
		
		
		
		
		если ТипЗнч(Чек)<>Тип("ДокументОбъект.ПриходнаяНакладная") тогда
			PSAmount =чек.СуммаОплатыСертификатами*100;
			BNAmount = СуммаОплатыБН*100;
		Иначе 
			BNAmount = чек.товары.итог("Всего")*100-BonusAmount;
			PSAmount=0;
		КонецЕсли;
		если чек.докоснование.видоплаты=Перечисления.ВидыОплаты.НАЛ Тогда 
			BNAmount=0;
		КонецЕсли;
		
		//сумма оплаты баллами (в копейках)
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "cheque_msg_req";
		Extension.Critical = 1; 
		Extension.AddParam("msg_req","y"); 
		AuthRq.Extensions.AddItem(Extension); 
		
		
		Extension = PCX.CreateExtension(); 
		Extension.Type = "PURCHASE_EXT_PARAMS"; 
		Extension.Critical = 1; 
		Extension.AddParam("PAN4", пан); //Передача маскированного ПАНа
		Extension.AddParam("RECEIPT", Строка(чек.ссылка.УникальныйИдентификатор()));	
		//Extension.AddParam("RECEIPT", строка(текущаяДата())+строка(параметрысеанса.этотузел.код));	
		AuthRq.Extensions.AddItem(Extension); 
		
		
		//заполняем входные параметры
		AuthRq.Amount = (строка(формат(BonusAmount+BNAmount+PSAmount, "ЧГ =20")));
		//AuthRq.Amount = "110";
		AuthRq.Currency = "643"; //код валюты 810 - рубли
		AuthRq.ClientID = Хэш; //значение хэша карты
		AuthRq.ClientIDType = 6;  //тут мы говорим что используем именно хэш
		//заполняем входный параметры
		если чек.докоснование.транзакциибн.количество()>0 тогда
			//дЧек=Документы.Чек.НайтиПоНомеру().ТранзакцииБН.Найти("Начисление","Вид").ID;
			отбор=новый Структура;
			отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Начисление);
			отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
			отбор.Вставить("Отменена",ложь);
			AuthRq.OrigID = чек.докоснование.транзакцииБН.найтистроки(отбор).получить(0).ID; // Id транзакции начисления, по которой выполняем возврат 
			AuthRq.OrigTerminal = ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал.Terminal;
			AuthRq.OrigLocation = ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал.Location; 
			AuthRq.OrigPartnerID = ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал.PartnerID;
		иначе
			Возврат Истина;
		КонецЕсли;
		//заполняем оплату  баллами
		если BonusAmount <> 0 тогда
			item = PCX.CreatePaymentItem();   //баллами
			item.PayMeans = "N";   //что платим  баллами
			item.Amount = (строка(формат(BonusAmount, "ЧГ =20"))); 
			//item.Amount="50";
			retCode = AuthRq.Payment.AddItem(item);//добавляем во входные параметры контейнер с этим платежом
		КонецЕсли;
		//заполняем оплату  сертификатами 		
		если PSAmount<>0 тогда 
			item = PCX.CreatePaymentItem();   //сертификаты
			item.PayMeans = "T";   //что платим  сертификатами
			item.Amount = (строка(формат(PSAmount, "ЧГ =20"))); 
			retCode = AuthRq.Payment.AddItem(item);	
		КонецЕсли;		
		//заполняем оплату  Рублями БН 
		item = PCX.CreatePaymentItem();   //Рублями БН
		item.PayMeans = "I";   //что платим  Рублями БН
		item.Amount = (строка(формат(BNAmount, "ЧГ =20"))); 
		//item.Amount="60";
		retCode = AuthRq.Payment.AddItem(item);//добавляем во входные параметры контейнер с этим платежом
		//заполняем оплату  баллами 	
		
		для каждого товар из чек.товары цикл
			// добавляем информацию по позициям чека в запрос
			КешШтрихКодов=Неопределено;
			СписокТовара=новый Массив;
			СписокТовара.Добавить(товар.номенклатура);
			ChequeItem = PCX.CreateChequeItem(); 
			ТекТ=ПолучитьШКНоменклатуры(СписокТовара,КешШтрихКодов);
			ТекТ=КешШтрихКодов.получить(0).ШтрихКод_Штука_Значение;
			если ТекТ = Неопределено или ТекТ="" тогда
				//Сообщить("ID товара для ПЦ Сбербанка не задан  "+ товар.номенклатура.наименование);
				ТекТ="00";
			КонецЕсли;
			ChequeItem.Product = ТекТ;
			
			ChequeItem.Quantity = товар.количество; 
			ChequeItem.Amount = (строка(формат(товар.всего*100, "ЧГ =20")));  
			AuthRq.Cheque.AddItem(ChequeItem); // добавляем позицию чека
			
		КонецЦикла;
		
		
		
		retCode = PCX.Refund(AuthRq, AuthResp);   //снимаем баллы
		payTrans = AuthResp.Transaction;
		ChequeMessage = AuthResp.ChequeMessage;
		//кухарь 15.04.14 начало
		//BNS_C = PCX.FindCardInfoItem(AuthResp.CardInfo, "AB", "C", "N");
		BNS_C = PCX.FindCardInfoItem(AuthResp.CardInfo, "BNS", "C", "N");
		//кухарь 15.04.14 конец
		//Сообщить(BNS_C.Value/100);
		//КонецЦикла;
		
		
		
		//PCX.Finalize(); 
		если retcode=0 или retcode=1  тогда
			//Сообщить("Возврат начисления баллов успешно прошёл");
			если ТипЗнч(Чек)<>Тип("ДокументОбъект.ПриходнаяНакладная") тогда
				чекоб=форма;
				Транзакция=чекоб.транзакцииБН.добавить();
				транзакция.ID=payTrans.id;
				Транзакция.дата=payTrans.DateTime;
				транзакция.вид=Перечисления.ВидТранзакцииБН.ВозвратНачисления;
				Транзакция.видОплаты=Перечисления.ВалютаТранзакцииБН.Баллы;
				Транзакция.СуммаТранзакции=Окр(ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал.БазовыйПроцентНачисленийББ*(BNAmount)/10000,2);
				если retcode<>1 тогда    
					//кухарь 15.04.14 начало
					//Транзакция.СуммаТранзакцииИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "AB", "C", "N").value/100;
					Транзакция.СуммаТранзакцииИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "BNS", "C", "N").value/100;
					//кухарь 15.04.14 конец
				КонецЕсли;
				форма.слипспасибо=форма.слипспасибо+ChequeMessage+Символы.ПС;
				
			Иначе 
				если ТипЗнч(Чек)=Тип("ДокументОбъект.ПриходнаяНакладная") тогда
					если BNS_C<>Неопределено тогда
						форма.СуммаБалловКСписаниюСКартыИзБанка=-1*BNS_C.Value/100;
					КонецЕсли; 
					форма.СуммаБалловКСписаниюСКарты=ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал.БазовыйПроцентНачисленийББ*(BNAmount)/10000;
				КонецЕсли;
				
			КонецЕсли;
			//Сообщить("начисленно "+BNS_C.Value/100+" баллов");
			//Сообщить(ChequeMessage);
			возврат Истина;
		Иначе
			Сообщить(PCX.GetErrorMessage(RetCode));
			Возврат ложь;
		КонецЕсли;
		
	Исключение
		//Сообщить("ошибка возврата начисления баллов на карту");
		возврат Ложь;
	КонецПопытки;
	
