				//Кухарь 21.03.16 начало

			Исключение
			КонецПопытки;
		КонецЕсли;

		//кухарь 03.07.14 конец

		
		AuthRq.Amount = BonusAmount;
		AuthRq.Currency = "643"; //код валюты 810 - рубли
		AuthRq.ClientID = Хэш; //значение хэша карты
		AuthRq.ClientIDType = 6;  //тут мы говорим что используем именно хэш
		//заполняем входный параметры
		
		если чек.докоснование.оплачиваемБаллами тогда
			отбор=новый Структура;
			отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
