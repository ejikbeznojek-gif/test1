функция РасчетЧастичногоВозвратаОплатыБаллами(чек) экспорт
	//крохин начало 31.01.2017
	//появился возврат сертификатов без чека-основания
	Если чек.докоснование = Неопределено Тогда
	Возврат 0;	
	КонецЕсли;
	//крохин конец 31.01.2017
	РасчСумма=0;
	для каждого товар из чек.ДокОснование.Товары цикл
		ном=товар.Номенклатура;
		Ном1=чек.Товары.Найти(ном,"Номенклатура");
		если Ном1=Неопределено тогда
			Продолжить;
		КонецЕсли;
		
		РасчСумма=РасчСумма+ном1.количество*(чек.ДокОснование.СуммаОплатыБаллами*товар.Всего)/(чек.ДокОснование.СуммаДокумента*товар.Количество);
		
	КонецЦикла;
	Возврат РасчСумма;	
КонецФункции


