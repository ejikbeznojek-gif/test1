
Функция ВыполнитьЭквайринговуюОперацию (Команда,РезультатЭквайринговойОперации,Чек,КассаККМ,форма)    экспорт
	
	РезультатЭквайринговойОперации=Ложь;
	Попытка
		ОбъектДрайвера = Новый COMОбъект("SBRFSRV.Server");
	Исключение
		Сообщить("Не установлены библиотека sbrf.dll");
		Возврат ложь;
	КонецПопытки;
	
	
	ВходныеПараметры  = Новый Массив();
	ВыходныеПараметры = Неопределено;
	если Команда<>"Settlement" и команда <>"КонтрольнаяЛента" и Команда<>"AuthorizeVoid" тогда
		
		если ТипЗнч(Чек)=Тип("ДокументОбъект.ПриходнаяНакладная") тогда	
			СуммаДокумент=форма.товары.итог("всего");

			//кухарь инфернальный косяк 18.11.13 начало
			ВернутьБонусов=РасчетЧастичногоВозвратаОплатыБаллами(чек);
			//кухарь 13.12.14 начало
			//исправлен косяк с отсутствием округлений при не полных возвратах
			ВернутьБонусов=Окр(ВернутьБонусов,2);
			//кухарь 13.12.14 конец
			
			СуммаДокумент=СуммаДокумент-ВернутьБонусов;
			//кухарь инфернальный косяк 18.11.13 конец
			
			
		иначе
			СуммаДокумент=чек.СуммаОплаты;
			//номерчека=чек.номер;
			//работа с баллами кухарь 10.06.13 начало
			//ОплачиваемБаллами=чек.ОплачиваемБаллами;
			//СуммаОплатыБаллами=чек.СуммаОплатыБаллами;	
			//работа с баллами кухарь 10.06.13 конец
			
		КонецЕсли;
		//СуммаДокумента=СуммаДокумента*100;
		ВходныеПараметры.Добавить(СуммаДокумент);
		//ВходныеПараметры.Добавить("");
		//ВходныеПараметры.Вставить(2,Чек);
		////работа с баллами кухарь 10.06.13 начало
		//ВходныеПараметры.Добавить(ОплачиваемБаллами);
		//ВходныеПараметры.Добавить(СуммаОплатыБаллами);
		//работа с баллами кухарь 10.06.13 конец
	КонецЕсли;
	параметры = новый структура;
	параметры.Вставить("ШиринаСлипЧека",32);
	параметры.Вставить("КодСимволаЧастичногоОтреза",22);
	
	ВремяНачалаПечатиЧека=ТекущаяДата();
	
	РезультатЭТ=ВыполнитьКоманду(Команда,ВходныеПараметры,ВыходныеПараметры,ОбъектДрайвера,параметры,Чек,форма);
	
	Если ТекущаяДата() - ВремяНачалаПечатиЧека > 0 и  Команда<>"Settlement" и команда <>"КонтрольнаяЛента" и Команда<>"AuthorizeVoid"  Тогда
		если ТипЗнч(Чек)<>Тип("ДокументОбъект.ПриходнаяНакладная") тогда
			ЗаписатьВЛог("БезнальнаяОперация","Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера()+" Чек: "+ чек.номер+" Время: "+(ТекущаяДата() - ВремяНачалаПечатиЧека)+ " сек.","Информация",,,ТекущаяДата() - ВремяНачалаПечатиЧека);
			форма.ВремяБНоперации=Число(ТекущаяДата() - ВремяНачалаПечатиЧека);	
		иначе
			ЗаписатьВЛог("БезнальнаяОперация","Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера()+" ПНК: "+ чек.номер+" Время: "+(ТекущаяДата() - ВремяНачалаПечатиЧека)+ " сек.","Информация",,,ТекущаяДата() - ВремяНачалаПечатиЧека);
		КонецЕсли;
	КонецЕсли;
	
	Если Не РезультатЭТ Тогда
		Сообщить("Платёж по карте не прошёл");
		РезультатЭквайринговойОперации=Ложь;
	Иначе
		СтрокаСлипЧека		= ВыходныеПараметры[0][1];
		
		Если Не ПустаяСтрока(СтрокаСлипЧека) Тогда									
			СтрокаФР  	= глТорговоеОборудование.млФР.Найти(КассаККМ, "КассаККМ");
			если СтрокаФР = неопределено тогда   
				строкаФР=КассаККМ;
			КонецЕсли;
			Параметры.Вставить("ТекстЧека",СтрокаСлипЧека);
			если   СтрокаСлипЧека<>"ПечатьСверкиБН" тогда
				глТорговоеОборудование.ПечататьТекстНаЧеке(СтрокаФР, Параметры, "");
				если Команда<>"Settlement" и команда <>"КонтрольнаяЛента"  тогда
					глТорговоеОборудование.ПечататьТекстНаЧеке(СтрокаФР, Параметры, "");
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		РезультатЭквайринговойОперации=истина;
	КонецЕсли;
	
// кухарь сообщение о сумме возврата налом 25.11.13 начало	
Попытка	
	если ТипЗнч(Чек)=Тип("ДокументОбъект.ПриходнаяНакладная") и чек.ДокОснование.метаданные().имя="Чек" тогда
		если чек.ДокОснование.ВидОплаты=Перечисления.ВидыОплаты.НАЛ тогда
			Сообщить("Покупателю нужно вернуть "+Строка(СуммаДокумент)+" рублей наличными. Остальная сумма покупки была оплачена и возвращена баллами." );
			Предупреждение("Покупателю нужно вернуть "+Строка(СуммаДокумент)+" рублей наличными. Остальная сумма покупки была оплачена и возвращена баллами." );
		КонецЕсли;		
	КонецЕсли;
Исключение
КонецПопытки;	
// кухарь сообщение о сумме возврата налом 25.11.13 конец

	ОбъектДрайвера=Неопределено;
	возврат РезультатЭквайринговойОперации;
КонецФункции

Функция ВыполнитьКоманду(Команда, ВходныеПараметры = Неопределено, ВыходныеПараметры = Неопределено,
	ОбъектДрайвера, Параметры,чек,форма) Экспорт
	
	Результат = ложь;
	
	ВыходныеПараметры = Новый Массив();
	
	// Оплата платежной картой
	Если Команда = "AuthorizeSales" Тогда
		Сумма      = ВходныеПараметры[0];
		//НомерКарты = ВходныеПараметры[1];
		
		
		Результат = ОплатитьПлатежнойКартой(ОбъектДрайвера, Параметры,
		Сумма, ВыходныеПараметры,чек,форма);
		
		
		
		
		
		
		
		
		
		// Возрат платежа
	ИначеЕсли Команда = "AuthorizeRefund" Тогда
		Сумма      = ВходныеПараметры[0];
		//НомерКарты = ВходныеПараметры[1];
		
		Результат = ВернутьПлатежПоПлатежнойКарте(ОбъектДрайвера, Параметры,
		Сумма, ВыходныеПараметры,чек,форма);
		
		// Отмена платежа
	ИначеЕсли Команда = "AuthorizeVoid" Тогда
		//Сумма          = ВходныеПараметры[0];
		//СсылочныйНомер = ВходныеПараметры[1];
		СсылочныйНомер = "";
		
		Результат = ОтменитьПлатежПоПлатежнойКарте(ОбъектДрайвера, Параметры, ВыходныеПараметры);
		
		// Аварийная отмена платежа
	ИначеЕсли Команда = "EmergencyVoid" Тогда
		Сумма          = ВходныеПараметры[0];
		СсылочныйНомер = ВходныеПараметры[1];
		
		
		Результат = АварийнаяОтменаОперации(ОбъектДрайвера, Параметры,
		Сумма, СсылочныйНомер, ВыходныеПараметры);
		
		// Сверка итогов по картам
	ИначеЕсли Команда = "Settlement" Тогда
		Результат = ИтогиДняПоКартам(ОбъектДрайвера, Параметры, ВыходныеПараметры);
	ИначеЕсли Команда = "КонтрольнаяЛента" тогда
		результат= КонтрольнаяЛента(ОбъектДрайвера, Параметры, ВыходныеПараметры);
	ИначеЕсли  Команда = "Повтор" тогда 
		Результат = Повтор(ОбъектДрайвера, Параметры, ВыходныеПараметры);
		
		// Указанная команда не поддерживается данным драйвером
	Иначе
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(НСтр("ru='Команда ""%Команда%"" не поддерживается данным драйвером.'"));
		ВыходныеПараметры[1] = СтрЗаменить(ВыходныеПараметры[1], "%Команда%", Команда);
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОплатитьПлатежнойКартой(ОбъектДрайвера, Параметры,
	Сумма, ВыходныеПараметры,чек,форма) Экспорт
	Результат 			= ложь;
	
	
	
	ЗаплатилиБаллами=чек.СуммаОплатыБаллами;	
	СуммаВременная		= Неопределено;
	
	КодКарты    	    = Неопределено;
	СсылочныйНомер		= Неопределено;
	НомерЧека     		= Неопределено;
	
	//ОбъектДрайвера.ТипКарты = 0;//.ПоследнийТипКарты;?????????????????
	СуммаВременная = Сумма*100;
	
	очистить=ОбъектДрайвера.clear();	
	ОбъектДрайвера.SParam ("Amount", СуммаВременная);
	ответ=ОбъектДрайвера.NFun (4000);
	
	если ответ<>0 тогда возврат Ложь;
	иначе Результат=Истина;	
	КонецЕсли;
	
	
	
	
	НомерТерминала       = ОбъектДрайвера.GParamString("TermNum");
	MyClientCard       = ОбъектДрайвера.GParamString("ClientCard") ;
	MyClientExpiryDate = ОбъектДрайвера.GParamString("ClientExpiryDate") ;
	MyAuthCode         = ОбъектДрайвера.GParamString("AuthCode");
	MyCardName         = ОбъектДрайвера.GParamString("CardName");
	СлипЧек           = ОбъектДрайвера.GParamString("Cheque");
	MerchantTSN       =ОбъектДрайвера.GParamString("MerchantTSN");
	если чек.хэш="" или чек.хэш=Неопределено тогда
		если ОбъектДрайвера.GParamString("OWNCArd")="0" тогда
			Хэш="ЭтожНеСбер";
			Пан="";
		иначе
			Хэш			  		=ОбъектДрайвера.GParamString("Hash");
			Пан=ОбъектДрайвера.GParamString("ClientCard");
			Пан="************"+сред(пан,13);
			форма.хэш=хэш;
			форма.пан=пан;
			
			
		КонецЕсли;
	Иначе 
		Хэш=чек.хэш;
		Пан=чек.пан;
	КонецЕсли;
	
	
	
	чекоб=форма;
	Транзакция=чекоб.транзакцииБН.добавить();
	транзакция.ID=MerchantTSN;
	транзакция.вид=Перечисления.ВидТранзакцииБН.Списание;
	Транзакция.видОплаты=Перечисления.ВалютаТранзакцииБН.Рубли;
	Транзакция.СуммаТранзакции=Сумма;
	Транзакция.СуммаТранзакцииИзБанка=Сумма;
	
	
	
	
	
	
	
	
	если  ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал<>Справочники.ЭквайринговыеТерминалы.ПустаяСсылка()  и хэш<>"ЭтожНеСбер" Тогда 
		если ЗаплатилиБаллами <> 0 тогда
			РезультатОБ=ОплатитьБаллами(хэш,ЗаплатилиБаллами,чек,форма,пан);
		иначе 
			РезультатОБ=Истина
		КонецЕсли; 
		если (РезультатОБ или ЗаплатилиБаллами=0) тогда
		Иначе 
			Сообщить("не прошли операции с баллами");
			ответ=ОбъектДрайвера.NFun (4003);

			//кухарь 24.02.2014 начало
			//иногда могут не вставить карту при отмене
				////кухарь 28.10.2013 начало
				//Транзакция.отменена=Истина;
				////кухарь 28.10.2013 конец 			
				Если ответ=0 тогда
					Транзакция.отменена=Истина;
					//кухарь 17.03.14 начало
					//обнулим хэш на случай если в чеке используется несколько различных банковских карт
					форма.Хэш="";
					форма.Пан="";
					//кухарь 17.03.14 конец
				КонецЕсли;
			//кухарь 24.02.2014 конец
			
			
			возврат Ложь
		КонецЕсли;	
	КонецЕсли;
	
	
	
	
	
	
	СлипЧек=Сред(СлипЧек,1,Найти(СлипЧек,"================================")+32);	
	СлипЧек="ПечатьСверкиБН"+СлипЧек;
	
	ВыходныеПараметры.Добавить(Новый Массив());
	ВыходныеПараметры[0].Добавить("СлипЧек");
	ВыходныеПараметры[0].Добавить(СлипЧек);
	ВыходныеПараметры.добавить(Новый Массив());
	ВыходныеПараметры[1].добавить("КодАвторизации");
	ВыходныеПараметры[1].добавить(MyAuthCode);
	//ВыходныеПараметры.добавить(Хэш);
	
	
	ОбъектДрайвера.Clear();
	ОбъектДрайвера=Неопределено;
	
	Возврат Результат;
	
КонецФункции

// Функция осуществляет возврат платежа по карте.
// (API v2.0)
//
// Параметры: 
//  Объект              - <*>
//                      - Объект драйвера ЭС.
//
//  Сумма               – <Число>
//                      - Сумма к оплате по карте
//
//  КодRRN              - <Строка>
//                      - Уникальный код RRN транзакции
//
//  КодАвторизации      - <Строка>
//                      - Возвращается код авторизации транзакции
//
//  КодОперации         - <Строка>
//                      - Последовательный код операции
//
//  МассивСтрокСлипЧека - <Структура>
//                      - Массив строк слип-чека, сформированного
//                        после успешного выполнения операции
//
//  ШиринаЧека          - <Число>
//                      - Ширина слип-чека, установленная в параметрах настройки
//
//  КоличествоКопий     - <Число>
//                      - Количество печатаемых копий слип-чека
// 
// Возвращаемое значение: 
//     <ПеречислениеСсылка.ОшибкиПриРаботеСТорговымОборудованием>
//                 - Результат работы функции.
//
Функция ВернутьПлатежПоПлатежнойКарте(ОбъектДрайвера, Параметры,
	Сумма, ВыходныеПараметры,чек,форма) Экспорт
	
	результат=ложь;
	//крохин начало 31.01.2017
	//бывают ПНК на возврат сертификатов, без докоснования
	//если чек.докоснование.видоплаты=Перечисления.ВидыОплаты.БН тогда
	если чек.докоснование = Неопределено ИЛИ чек.докоснование.видоплаты=Перечисления.ВидыОплаты.БН тогда
	//крохин конец 31.01.2017	
	иначе
		сумма=0;
	КонецЕсли;
	
	
	если ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал<>Справочники.ЭквайринговыеТерминалы.ПустаяСсылка() тогда						
		ЗаплатилиБаллами=0;
		//крохин начало 31.01.2017
		//бывают ПНК на возврат сертификатов, без докоснования
		//ОплачиваемБаллами=чек.докоснование.ОплачиваемБаллами;
		//ЗаплатилиБаллами=чек.докоснование.СуммаОплатыБаллами;
		Если чек.докоснование <> Неопределено Тогда
		ОплачиваемБаллами=чек.докоснование.ОплачиваемБаллами;
		ЗаплатилиБаллами=чек.докоснование.СуммаОплатыБаллами;
	Иначе
		ОплачиваемБаллами = 0;
		ЗаплатилиБаллами = 0;
        КонецЕсли;
		//крохин конец 31.01.2017
		
		
		ХэШиПан=УзнатьХэш();
		если ХэШиПан= Неопределено тогда Возврат ложь
		КонецЕсли;
		
		хэш=ХэШиПан.получить(0).значение;
		Пан=ХэШиПан.получить(1).значение;
		форма.хэш=хэш;
		форма.пан=пан;
		
	КонецЕсли;						
	
	если Сумма>0 тогда
		
		Результат = ложь;
		СуммаВременная = Неопределено;
		
		КодКарты       = Неопределено;
		СсылочныйНомер = Неопределено;
		НомерЧека      = Неопределено;
		
		
		СуммаВременная = Сумма*100;
		
		ОбъектДрайвера.clear();	
		ОбъектДрайвера.SParam ("Amount", СуммаВременная);
		ответРубли=ОбъектДрайвера.NFun (4002);
		если ответРубли<>0 тогда возврат ложь
		иначе Результат=Истина;	
		КонецЕсли;
		
		
		
		НомерТерминала     = ОбъектДрайвера.GParamString("TermNum");
		MyClientCard       = ОбъектДрайвера.GParamString("ClientCard") ;
		MyClientExpiryDate = ОбъектДрайвера.GParamString("ClientExpiryDate") ;
		MyAuthCode         = ОбъектДрайвера.GParamString("AuthCode");
		MyCardName         = ОбъектДрайвера.GParamString("CardName");
		СлипЧек            = ОбъектДрайвера.GParamString("Cheque");
		MerchantTSN       =ОбъектДрайвера.GParamString("MerchantTSN");
		
		
		
		
		если ТипЗнч(Чек)<>Тип("ДокументОбъект.ПриходнаяНакладная") тогда
			чекоб=форма;
			Транзакция=чекоб.транзакцииБН.добавить();
			транзакция.ID=MerchantTSN;
			транзакция.вид=Перечисления.ВидТранзакцииБН.ВозвратСписания;
			Транзакция.видОплаты=Перечисления.ВалютаТранзакцииБН.Рубли;
			Транзакция.СуммаТранзакции=Окр(Сумма,2);
			Транзакция.СуммаТранзакцииИзБанка=Сумма;
			
		КонецЕсли;
		
	КонецЕсли;
	//попытка
	если ПараметрыСеанса.КассаККМ.ЭквайринговыйТерминал<>Справочники.ЭквайринговыеТерминалы.ПустаяСсылка() и хэш<>"ЭтожНеСбер"  Тогда 
		Если  форма.ДокОснование <> Неопределено Тогда
				//крохин начало 31.01.2017
		//возврат сертификатов, без докоснования
		//отбор=новый Структура;
		//отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Начисление);
