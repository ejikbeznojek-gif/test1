				Транзакция.дата=payTrans.DateTime;
				транзакция.вид=Перечисления.ВидТранзакцииБН.ВозвратСписания;
				Транзакция.видОплаты=Перечисления.ВалютаТранзакцииБН.Баллы;
				Транзакция.СуммаТранзакции=Окр(altBonusAmount,2);
				если retcode<>1 тогда
					//кухарь 15.04.14 начало
					//Транзакция.СуммаТранзакцииИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "AB", "C", "N").value/100;
					Транзакция.СуммаТранзакцииИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "BNS", "C", "N").value/100;
					//кухарь 15.04.14 конец
				КонецЕсли;
				//Сообщить(ChequeMessage);
				форма.слипспасибо=форма.слипспасибо+ChequeMessage+Символы.ПС;
				
			Иначе 
				//кухарь 15.04.14 начало
				//форма.СуммаБалловКВозвратуНаКартуИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "AB", "C", "N").value/100;
				форма.СуммаБалловКВозвратуНаКартуИзБанка=(-1)*PCX.FindCardInfoItem(AuthResp.CardInfo, "BNS", "C", "N").value/100;
				//кухарь 15.04.14 конец
				форма.СуммаБалловКВозвратуНаКарту=altBonusAmount;
			КонецЕсли;
			
			
			возврат Истина;
		Иначе
			Сообщить(PCX.GetErrorMessage(RetCode));
			Возврат ложь;
		КонецЕсли;
		
	Исключение
		//Сообщить("ошибка возврата оплаты баллами");
		возврат Ложь;
	КонецПопытки;
	
	
	
	
	
КонецФункции

функция ОтменаСписанияБаллов (форма,хэш) экспорт
	// нечаева ++ поставила - попытка исключение
	попытка	
		pcx=ЭквайринговыйТерминал;
		//если ТекущаяТранзакция<>Неопределено тогда
		//RetCode = PCX.Reverse(ТекущаяТранзакция);
		//ТекущаяТранзакция=Неопределено;
		//иначе
		Transaction = pcx.CreateTransaction();	
		отбор=новый Структура;
		отбор.Вставить("Вид",Перечисления.ВидТранзакцииБН.Списание);
		отбор.Вставить("ВидОплаты",Перечисления.ВалютаТранзакцииБН.Баллы);
		отбор.Вставить("Отменена",ложь);
		Transaction.ID = форма.транзакцииБН.найтистроки(отбор).получить(0).ID; // Id транзакции начисления, по которой выполняем возврат 
		Transaction.DateTime =форма.транзакцииБН.найтистроки(отбор).получить(0).дата;
		Transaction.Terminal = ЭквайринговыйТерминал.Terminal;
		Transaction.Location = ЭквайринговыйТерминал.Location; 
		Transaction.PartnerID = ЭквайринговыйТерминал.PartnerID;
		Transaction.ClientID=хэш;
		Transaction.ClientIDType=6;
		RetCode = PCX.Reverse(Transaction);
		//КонецЕсли;
		если RetCode=0 или RetCode=1 тогда
			форма.транзакцииБН.найтистроки(отбор).получить(0).отменена=истина;
			Сообщить("Произошла отмена списания баллов");
		Иначе
			Сообщить(PCX.GetErrorMessage(RetCode));
			
		КонецЕсли;
	исключение
		//сообщить("Возникла ошибка списания баллов.");
	конецПопытки;
	
	
	
КонецФункции


