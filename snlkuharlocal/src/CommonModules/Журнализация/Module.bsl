//ЖУРНАЛИЗАЦИЯ

Процедура ЗаписатьПроОтправкуНаСклад(Ссылка,Получатель) Экспорт
	
	///////// ОТКРЫВАЕМ УПРАВЛЯЕМУЮ ТРАНЗАКЦИЮ /////////////////////////////
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
	///////// ОТКРЫВАЕМ УПРАВЛЯЕМУЮ ТРАНЗАКЦИЮ /////////////////////////////
	
	НаборЗаписей=РегистрыСведений.ЖурналРегистрации.СоздатьНаборЗаписей();
	
	Запись=НаборЗаписей.Добавить();
	
	//Запись.СсылкаНаОбъект		=Ссылка;
	Запись.ТекстСсылки			=Ссылка.УникальныйИдентификатор();
	Запись.КлючЗаписи			=Новый УникальныйИдентификатор;
	
	Запись.Тип					=ТипОбъекта(Ссылка);
	Запись.Вид					=Ссылка.Метаданные().Имя;
	
	Запись.СостояниеПроведения	="Отправка на склад";
	Запись.СостояниеОбъекта		="Получатель: "+Получатель.Код;	
	
	Запись.Пользователь			=ПараметрыСеанса.Пользователь;
	Запись.Дата					=ТекущаяДата();
	//+++Чирков 16.01.13
	Если Метаданные.РегистрыСведений.ЖурналРегистрации.Измерения.Найти("День")<>Неопределено Тогда	
		Запись.День				=Запись.Дата;	
	КонецЕсли;
	//---Чирков 16.01.13
	
	НаборЗаписей.Записать(Ложь);
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

//считывает начальный образ объекта
Функция ПолучитьНачальныйОбраз(Ссылка) Экспорт
	Образ = Новый Соответствие;
	
	ОбъектМД = Метаданные.НайтипоТипу(ТипЗнч(Ссылка));
	
	Если Метаданные.Справочники.Индекс(ОбъектМД)>0 Тогда
		Образ.Вставить("Код",			Ссылка.Код);				
		Образ.Вставить("Наименование",	Ссылка.Наименование);		
	ИначеЕсли Метаданные.Документы.Индекс(ОбъектМД)>0 Тогда
		Образ.Вставить("Номер",	Ссылка.Номер);				
		Образ.Вставить("Дата",	Ссылка.Дата);		
	Иначе
		Возврат Образ;	
	КонецЕсли;	
	
	Для Каждого Реквизит Из Ссылка.Метаданные().Реквизиты Цикл
		Образ.Вставить(Реквизит.Имя, Ссылка[Реквизит.Имя]);
	КонецЦикла; 	
	
	Возврат Образ;
КонецФункции // ПолучитьНачальныйОбраз()

//ЛОГИ
Функция ЗаписатьВЛог(ИмяЛога,Сообщение,ТипСообщения,ВыводитьСообщения=Ложь,НастройкиОтчета=Неопределено,ВремяВыполнения=Неопределено) Экспорт
	ПараметрыСеанса.НомерЗаписиЛога=ПараметрыСеанса.НомерЗаписиЛога+1;
	
	Запись=РегистрыСведений.Логи.СоздатьМенеджерЗаписи();
	
	Запись.Дата=ТекущаяДата();
	Если Метаданные.РегистрыСведений.Логи.Измерения.Найти("День")<>Неопределено Тогда
		Запись.День=Запись.Дата;
	КонецЕсли;		
	
	Запись.НомерЗаписи	=ПараметрыСеанса.НомерЗаписиЛога;
	Запись.ИмяЛога		=ИмяЛога;
	Запись.Автор		=ПараметрыСеанса.Пользователь;
	Запись.Сообщение	=Сообщение;
	Запись.ТипСообщения	=ТипСообщения;
	
	Запись.ДопИнфо			= Новый ХранилищеЗначения(НастройкиОтчета,Новый СжатиеДанных(9));
	Запись.ВремяВыполненния = ВремяВыполнения;
	
	//крохин начало 17.09.2021
	//ошибка записи сообщения об ошибке не должна вешать обмен
	Попытка
		//+++Чирков 02.04.2025 чтобы не было ненужных удалений
		//Запись.Записать();
		Запись.Записать(Ложь);
		//---Чирков 02.04.2025
		#ЕСЛИ КЛИЕНТ ТОГДА
			Если ВыводитьСообщения Тогда
				Сообщить(Сообщение);	
			КонецЕсли; 
		#КОНЕЦЕСЛИ
	Исключение
		// Кухарь А.Ю. 01.12.2021 начало
		//Если логи висят, то бесконечная рекурсия
		// ЗаписатьВЛог("Ошибка записи в лог",ОписаниеОшибки(),"Информация"); 
		// Кухарь А.Ю. 01.12.2021 конец
		
		
	КонецПопытки;
	//крохин конец 17.09.2021
КонецФункции // ЗаписатьВЛог()


Функция ЗаписатьПоказательПроизводительности(ИмяПоказателя,ЗначениеПоказателя) Экспорт
	Запись=РегистрыСведений.ПоказателиПроизводительности.СоздатьМенеджерЗаписи();	
	
	Запись.Подразделение=ПараметрыСеанса.ЭтотУзел.Подразделение;
	Запись.Показатель	=ИмяПоказателя;
	Запись.ДатаИзмерения=ТекущаяДата();
	Запись.Значение		=ЗначениеПоказателя;
	
	Запись.Пользователь	=ПараметрыСеанса.Пользователь;
	Запись.ИмяКомпьютера=ИмяКомпьютера();
	
	Запись.Записать();
КонецФункции //ЗаписатьПоказательПроизводительности()
 