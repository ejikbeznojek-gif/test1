Функция СравнитьТЗ(ТЗНач,ТЗКон,ЭтоНовый = Ложь)
	ТЗДельт=Новый ТаблицаЗначений;
	
	КлючевыеПоля=Новый Структура;
	ПоляДанных	=Новый Структура;
	
	Для Каждого Колонка Из ТЗнач.Колонки Цикл
		Поз=Найти(Колонка.Имя,"___");
		
		ИмяПоля=Лев(Колонка.Имя,Поз-1);
		ВидПоля=Сред(Колонка.Имя,Поз+3);
				
		Если ВидПоля="Ключ" Тогда
			КлючевыеПоля.Вставить(Колонка.Имя,ИмяПоля);
		ИначеЕсли ВидПоля="Параметр" Тогда		
			ПоляДанных.Вставить(Колонка.Имя,ИмяПоля);			
		КонецЕсли; 		
	КонецЦикла;
	
	Если КлючевыеПоля.Количество()=0 ИЛИ ПоляДанных.Количество()=0 Тогда
		Возврат Новый ТаблицаЗначений;			
	КонецЕсли; 
	
	//Феданченков М.С. 27.06.2026 начало
	//проблема 0000000154 
	Если ЭтоНовый ИЛИ ТЗНач.Количество() = 0 Тогда
		// Добавляем колонки в ТЗДельт для первичной записи
		Для Каждого ПолеКлюча Из КлючевыеПоля Цикл
			ТЗДельт.Колонки.Добавить(ПолеКлюча.Значение);	
		КонецЦикла;
		
		Для Каждого ПолеДанных Из ПоляДанных Цикл
			ТЗДельт.Колонки.Добавить(ПолеДанных.Значение+"__1");
			ТЗДельт.Колонки.Добавить(ПолеДанных.Значение+"__2");
		КонецЦикла;
		
		Для Каждого СтрокаТек Из ТЗКон Цикл
			НоваяСтрока = ТЗДельт.Добавить();
			
			Для Каждого ПолеКлюча Из КлючевыеПоля Цикл
				НоваяСтрока[ПолеКлюча.Значение] = СтрокаТек[ПолеКлюча.Ключ];
			КонецЦикла;
			
			Для Каждого ПолеДанных Из ПоляДанных Цикл
				НоваяСтрока[ПолеДанных.Значение+"__1"] = Неопределено;
				НоваяСтрока[ПолеДанных.Значение+"__2"] = СтрокаТек[ПолеДанных.Ключ];
			КонецЦикла;
		КонецЦикла;
		
		Возврат ТЗДельт;
	КонецЕсли;
	//Феданченков М.С. 27.06.2026 конец
	
	СтрокаСоединений="";	
	СтрокаУсловий	="";
	СтрокаКлючей	="";
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ * ПОМЕСТИТЬ НачТЧ ИЗ &НачТЧ КАК НачТЧ;
	|ВЫБРАТЬ * ПОМЕСТИТЬ КонТЧ ИЗ &КонТЧ КАК КонТЧ;
	|
	|ВЫБРАТЬ 
	|	";
	
	Для Каждого ПолеКлюча Из КлючевыеПоля Цикл
		ТЗДельт.Колонки.Добавить(ПолеКлюча.Значение);	
		
	СтрокаКлючей=СтрокаКлючей+?(ПустаяСтрока(СтрокаКлючей),"",",")+"
	|	IsNULL(НачТЧ."+ПолеКлюча.Ключ+",КонТЧ."+ПолеКлюча.Ключ+") КАК "+ПолеКлюча.Значение;
	
	СтрокаСоединений=СтрокаСоединений+"
	|	"+?(ПустаяСтрока(СтрокаСоединений),"","И ")+"НачТЧ."+ПолеКлюча.Ключ+"=КонТЧ."+ПолеКлюча.Ключ;	
	КонецЦикла;

	Запрос.Текст=Запрос.Текст+СтрокаКлючей;
	
	Для Каждого ПолеДанных Из ПоляДанных Цикл
		Запрос.Текст=Запрос.Текст+",
		|	НачТЧ."+ПолеДанных.Ключ+" КАК "+ПолеДанных.Значение+"__1,
		|	КонТЧ."+ПолеДанных.Ключ+" КАК "+ПолеДанных.Значение+"__2";
		
		СтрокаУсловий=СтрокаУсловий+"
		|	"+?(ПустаяСтрока(СтрокаУсловий),"","ИЛИ ")+"IsNull(НачТЧ."+ПолеДанных.Ключ+",1) <> IsNull(КонТЧ."+ПолеДанных.Ключ+",2)";
		
		ТЗДельт.Колонки.Добавить(ПолеДанных.Значение+"__1");
		ТЗДельт.Колонки.Добавить(ПолеДанных.Значение+"__2");
	КонецЦикла;	
	
	Запрос.Текст=Запрос.Текст+"	
	|ИЗ
	|	НачТЧ
	|ПОЛНОЕ СОЕДИНЕНИЕ 
	|	КонТЧ 
	|ПО "+СтрокаСоединений+"
	|ГДЕ
	|"+СтрокаУсловий;
	
	Запрос.УстановитьПараметр("НачТЧ",ТЗНач);
	Запрос.УстановитьПараметр("КонТЧ",ТЗКон);
	
	ТЗДельт=Запрос.Выполнить().Выгрузить();
	
	//Для Каждого СтрокаТЗНач Из ТЗНач Цикл
	//	СтруктураОтбора=Новый Структура;
	//	Для Каждого КлючевоеПоле Из КлючевыеПоля Цикл
	//		СтруктураОтбора.Вставить(КлючевоеПоле.Ключ,СтрокаТЗНач[КлючевоеПоле.Ключ]);					
	//	КонецЦикла; 
	//	
	//	СтрокиТЗКон=ТЗКон.НайтиСтроки(СтруктураОтбора);
	//	Для Каждого СтрокаТЗКон Из СтрокиТЗКон Цикл
	//		ЕстьРазница=Ложь;
	//		
	//		СтрокаДельт=ТЗДельт.Добавить();
	//		
	//		Для Каждого ПолеДанных Из ПоляДанных Цикл				
	//			СтрокаДельт[ПолеДанных.Значение+"__1"]=СтрокаТЗНач[ПолеДанных.Ключ];
	//			СтрокаДельт[ПолеДанных.Значение+"__2"]=СтрокаТЗКон[ПолеДанных.Ключ];
	//			
	//			Если СтрокаТЗНач[ПолеДанных.Ключ]<>СтрокаТЗКон[ПолеДанных.Ключ] Тогда
	//				ЕстьРазница=Истина;				
	//			КонецЕсли;			
	//			
	//			СтрокаТЗНач[ПолеДанных.Ключ]=Неопределено; //если один раз сравнили значит есть лишние строки и больше сравнивать не надо
	//		КонецЦикла; 			
	//		
	//		Если НЕ ЕстьРазница Тогда
	//			ТЗДельт.Удалить(СтрокаДельт);		
	//		Иначе
	//			Для Каждого ПолеКлюча Из КлючевыеПоля Цикл
	//				СтрокаДельт[ПолеКлюча.Значение]=СтрокаТЗКон[ПолеКлюча.Ключ];			
	//			КонецЦикла; 
	//		КонецЕсли;			
	//		
	//		ТЗКон.Удалить(СтрокаТЗКон);
	//	КонецЦикла;
	//	
	//	Если СтрокиТЗКон.ВГраница()<0 Тогда //Если в конечной таблице не удалось найти соотвествующую строку - значит ее удалили			
	//		СтрокаДельт=ТЗДельт.Добавить();
	//		Для Каждого ПолеДанных Из ПоляДанных Цикл				
	//			СтрокаДельт[ПолеДанных.Значение+"__1"]=СтрокаТЗНач[ПолеДанных.Ключ];
	//		КонецЦикла; 	
	//		Для Каждого ПолеКлюча Из КлючевыеПоля Цикл
	//			СтрокаДельт[ПолеКлюча.Значение]=СтрокаТЗНач[ПолеКлюча.Ключ];			
	//		КонецЦикла;
	//	КонецЕсли; 
	//КонецЦикла; 
