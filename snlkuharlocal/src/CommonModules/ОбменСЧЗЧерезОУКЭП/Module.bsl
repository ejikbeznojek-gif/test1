Функция ЕстьДокументВОтложенныхДвижениях(ДокОМ)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОтложенныеДвиженияДокументов.ДокСсылка КАК ДокСсылка
	|ИЗ
	|	РегистрСведений.ОтложенныеДвиженияДокументов КАК ОтложенныеДвиженияДокументов
	|ГДЕ
	|	ОтложенныеДвиженияДокументов.ДокСсылка = &ДокОМ
	|	И НЕ ОтложенныеДвиженияДокументов.ОшибкаОбработки";
	Запрос.УстановитьПараметр("ДокОМ",ДокОМ);
	Результат = запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

