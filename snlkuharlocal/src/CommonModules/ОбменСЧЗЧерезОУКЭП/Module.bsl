//Валетов + 29,01,25 Обмен с ЧЗ С использованием ОУКЭП
//ПараметрыРегламентногоЗадания 	По имени 	ВидОбработки 
// 1 - Отправка документов в ЧЗ  2- получение ответа по отправленным документам.
Процедура ОтправитьДокуметыНаОбработкуВЧЗ(ТаблицаПараметров = Неопределено) Экспорт
	
	ВидЗапускаОбработки = 1; //ПО умолчанию 1
	
	Если ТаблицаПараметров <> Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			Если СтрокаТП.Имя = "ВидОбработки" Тогда				
				//Если СтрокаТП.Представление = "ВидОбработки" Тогда
				ВидЗапускаОбработки = СтрокаТП.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	
	Если ВидЗапускаОбработки = 3 Тогда
		АвтоматическаяОбработкаАгрегаций();
		
		Если инт_ДлительныеОперации.ЭтоФоновоеЗадание() Тогда
			ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();			
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	СписокПолучателей = Новый СписокЗначений;
	Сертификаты = ПолучитьСписокСертификатовСИНН();
	
	ЗаписатьВЛог("Обмен с ЧЗ (ОУКЭП)", "Получено сертификатов ЭЦП: " + Сертификаты.Количество(), "Информация");

	ДокументыОтправлены = Новый  Массив;
	ЕстьОшибки = Ложь;
	ТекстПисьма = "";
	ДокОшибки = Неопределено;
	
	Для Каждого Серт Из Сертификаты Цикл
		ОбработкаАПИ = Обработки.АпиЧЗ.Создать();
		
		СУЗ = ПолучитьСУЗПоОрганизации(Серт.Представление);
		ОрганизацияСуз = Суз.Владелец;
		
		ВидыОпераций = Новый Массив;
		ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа);
		ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.ФормированиеНабора);
		//Валетов+ 18,06,2025 Добавил отправку Расформирваний Упаковки, для обработки Расформированных Паллет
		//https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5282
		ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки);  
		//Валетов + 14,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3493
		Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.ТрансформацияУпаковки_Добавление);
		КонецЕсли;
		//Валтов -
		Если ВидЗапускаОбработки = 2 Тогда
			ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.Агрегация);
			//ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки);
		КонецЕсли;
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркировкаТоваровИСМП.Ссылка КАК Ссылка,
		|	МаркировкаТоваровИСМП.ВидОперации КАК ВидОперации,
		|	МаркировкаТоваровИСМП.ВидОперацииИСМП КАК ВидОперацииИСМП,
		|	МаркировкаТоваровИСМП.Организация КАК Организация,
		|	МаркировкаТоваровИСМП.Статус КАК Статус
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|ГДЕ
		|	МаркировкаТоваровИСМП.ВидОперацииИСМП В(&ВидОперации)
		|	И МаркировкаТоваровИСМП.Проведен
		|	И МаркировкаТоваровИСМП.Статус = &Статус
		|	И МаркировкаТоваровИСМП.Организация = &Организация
		|	И МаркировкаТоваровИСМП.Дата МЕЖДУ &ДатаНач И &ДатаОкон
		|
		|УПОРЯДОЧИТЬ ПО
		|	МаркировкаТоваровИСМП.Дата";
		
		Запрос.УстановитьПараметр("ВидОперации", ВидыОпераций);
		Запрос.УстановитьПараметр("ДатаНач", НачалоДня(ТекущаяДата()-86400*11));
		Запрос.УстановитьПараметр("ДатаОкон", ТекущаяДата());
		Запрос.УстановитьПараметр("Организация", ОрганизацияСуз);
		Запрос.УстановитьПараметр("Статус", ?(ВидЗапускаОбработки = 1,Перечисления.СтатусыДокументовМаркировки.КОбработке,Перечисления.СтатусыДокументовМаркировки.Обрабатывается));
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
				
		ТекстСообщения = СтрШаблон("Оправка док-ов. Организация: %1, отпечаток ЭЦП: %2, кол-во док-ов: %3.", ОрганизацияСуз, Серт.Значение, Выборка.Количество());
		ЗаписатьВЛог("Обмен с ЧЗ (ОУКЭП)", ТекстСообщения, "Информация");	
		
	//	пОбработки = Новый Структура("СУЗ,ОтпечатокСертификатаЭЦП", СУЗ, Серт.Значение);
		
		Если Выборка.Количество() > 0 Тогда
			//+++Чирков 16.06.2025 
			//Токен =  ОбработкаАПИ.ПолучитьТокен_СУЗ(Суз,Серт.Значение);
			//ТокенТруАпи= ОбработкаАПИ.ПолучитьТокен_TrueApi(Серт.Значение,ОрганизацияСуз);			
			
			//ОбработкаАПИ.Токен_СУЗ = Токен;
			//ОбработкаАПИ.Токен_TrueApi = ТокенТруАпи;
			//ОбработкаАПИ.Организация = ОрганизацияСуз;
			
			//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "Токен_СУЗ", Токен);
			//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТокенТруАпи", ТокенТруАпи);
			//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ОтпечатокСертификатаЭЦП",Серт.Значение);
			//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТекущаяСУЗ",Суз);			
			
			пОбработки = Новый Структура("СУЗ,ОтпечатокСертификатаЭЦП", СУЗ, Серт.Значение);
			
			//--Чирков 16.06.2025
			
			Пока Выборка.Следующий() Цикл
				Если ВидЗапускаОбработки = 1 Тогда
					//++Данилова Е.В. 18.08.2025 MARK-1756 
					РезультатПроверки = Документы.МаркировкаТоваровИСМП.РезультатПроверкиОбработкиРасформированияНабораГНпоЗСБ(Выборка.ссылка);
					Если НЕ РезультатПроверки.Успешно Тогда
					
						Продолжить; 	
					
					КонецЕсли;
					//--Данилова Е.В. 18.08.2025
                    //Валетов + 28,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#OUT-187 
					Если ЕстьДокументВОтложенныхДвижениях(Выборка.Ссылка) Тогда
						Продолжить;
					Иначе
						РезультатОбработки = ОбработкаАПИ.ОтправитьНаОбработку_ОперМаркировки(Выборка.Ссылка, пОбработки);
					КонецЕсли;
				   //Валетов -
				ИначеЕсли ВидЗапускаОбработки = 2 Тогда
					//+++Чирков 16.06.2025
					//РезультатОбработки = ОбработкаАПИ.ПолучитьРезультаты_ОперМаркировки(Выборка.Ссылка, ХранилищеОбщихНастроек);
					РезультатОбработки = ОбработкаАПИ.ПолучитьРезультаты_ОперМаркировки(Выборка.Ссылка, пОбработки);
					//---Чирков 16.06.2025
				КонецЕсли;
				
				Попытка
					СтрокаЗапроса = "ping -n 1 -w "+Формат(1000 * 1, "ЧДЦ=0; ЧГ=") + " 127.255.255.255"; 
					WshShell = Новый COMОбъект("WScript.Shell"); 
					WshShell.Run(СтрокаЗапроса, 0, -1);
				Исключение
				КонецПопытки;
				
				Если НЕ РезультатОбработки.Успешно Тогда
					//+++ Чирков 16.08.2025 
					//ЕстьОшибки = Истина;
					ЕстьОшибки = РезультатОбработки.Ошибки.Количество()>0 И НЕ МаркировкаКС.ЕстьОшибка404(РезультатОбработки); 
					Если ЕстьОшибки Тогда						
					//--- Чирков 16.08.2025
						ДокОшибки = Выборка.Ссылка;
						Если ТранзакцияАктивна() Тогда
							ОтменитьТранзакцию(); 
						КонецЕсли; 
						ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
						Если НЕ ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки Тогда						
							ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки;						
							
							Если РезультатОбработки.Ошибки.Количество() > 0 Тогда
								ДокОбъект.ТекстОшибки = СтрСоединить(РезультатОбработки.Ошибки, " ");
							КонецЕсли;
							Попытка	
								//+++Чирков 2025.04.28 - зачем перепроводить документ с ошибкой ?
								ДокОбъект.Записать();
								//+++Чирков 2025.04.28
							Исключение
								ДокОбъект.ОбменДанными.Загрузка = Истина;
								ДокОбъект.Записать();
							КонецПопытки;
						КонецЕсли;     
						//Валетов + 03,12,2025 ПУСТАЯ ЗАДАЧА
						//БЫЛО
						//ТекстПисьма = ТекстПисьма + " Ошибка обработки документа: № " + Выборка.Ссылка.Номер + " от "+ Выборка.Ссылка.Дата +"  Описание Ошибки: " +РезультатОбработки.Ошибки[0]  + Символы.ПС; 
						ТекстПисьма = " Ошибка обработки документа: № " + Выборка.Ссылка.Номер + " от "+ Выборка.Ссылка.Дата +"  Описание Ошибки: " +РезультатОбработки.Ошибки[0]  + Символы.ПС;
						//Валетов + 12,11,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3187
						ТемаПисьма = "Ошибки регламентного задания при обработке документов для ЧЗ в базе  " + Маркировка_ПИ.ЭтотУзел_Код();
						ОповеститьОбОшибке(ТекстПисьма,ТемаПисьма,СписокПолучателей,ДокОшибки);
					КонецЕсли;
				Иначе
					ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
					Если ВидЗапускаОбработки = 2 И НЕ ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
						ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан;
						Попытка	
							ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
						Исключение
							ДокОбъект.ОбменДанными.Загрузка = Истина;
							ДокОбъект.Записать();
						КонецПопытки;
					КонецЕсли;
				КонецЕсли;                                                          			
			КонецЦикла;
		КонецЕсли;			
	КонецЦикла;
	
	//Валетов + 12,11,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3187 Перенес выше, чтоб отправлять 1 ошибка = 1 письмо
	//Если ЕстьОшибки Тогда
	//	ТемаПисьма = "Ошибки регламентного задания при обработке документов для ЧЗ в базе  " + Маркировка_ПИ.ЭтотУзел_Код();
	//	ОповеститьОбОшибке(ТекстПисьма,ТемаПисьма,СписокПолучателей,ДокОшибки);
	//КонецЕсли; 
	
	Если инт_ДлительныеОперации.ЭтоФоновоеЗадание() Тогда
		ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();			
	КонецЕсли;	
КонецПроцедуры

Процедура АвтоматическаяОбработкаАгрегаций()  		
	
	ОбработкаАПИ = Обработки.АпиЧЗ.Создать();
	Сертификаты = ПолучитьСписокСертификатовСИНН();
	
	ДокументыОтправлены = Новый  Массив;
	ЕстьОшибки = истина;
	ДокОшибки = Неопределено;
	ТекстПисьма = "";
	СписокПолучателей = Новый СписокЗначений;
	
	Для Каждого Серт Из Сертификаты Цикл
		//	ОрганизацияСуз = Справочники.Организации.НайтиПоРеквизиту("ИНН",СокрЛП(Серт.Представление));
		
		СУЗ = ПолучитьСУЗПоОрганизации(Серт.Представление);
		ОрганизацияСуз = Суз.Владелец;
		
		//+++ Чирков 16.06.2025
		//Токен =  ОбработкаАПИ.ПолучитьТокен_СУЗ(Суз,Серт.Значение);
		//ТокенТруАпи= ОбработкаАПИ.ПолучитьТокен_TrueApi(Серт.Значение,ОрганизацияСуз);
		//
		//ОбработкаАПИ.Токен_СУЗ = Токен;
		//ОбработкаАПИ.Токен_TrueApi = ТокенТруАпи;
		//ОбработкаАПИ.Организация = ОрганизацияСуз;
		//
		//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "Токен_СУЗ", Токен);
		//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТокенТруАпи", ТокенТруАпи);
		//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ОтпечатокСертификатаЭЦП",Серт.Значение);
		//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТекущаяСУЗ",Суз);		
		
		пОбработки = Новый Структура("СУЗ,ОтпечатокСертификатаЭЦП", СУЗ, Серт.Значение);
		
		//--- Чирков 16.06.2025
		
		ЗапросРНК = Новый Запрос;
		ЗапросРНК.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладная.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусГотовностиКОтгрузкеЧЗ КАК СтатусГотовностиКОтгрузкеЧЗ
		|		ПО (СтатусГотовностиКОтгрузкеЧЗ.Документ = РасходнаяНакладная.Ссылка)
		|ГДЕ
		|	РасходнаяНакладная.Проведен
		|	И (РасходнаяНакладная.СостояниеНакладной = ЗНАЧЕНИЕ(перечисление.СостоянияНакладной.ГотоваКОтгрузке) 
		//Валетов + 17,09,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404
		|			ИЛИ РасходнаяНакладная.СостояниеНакладной = ЗНАЧЕНИЕ(перечисление.СостоянияНакладной.ОжиданиеОбработкиЧЗ)) 
		//Валетов -
		|	И (РасходнаяНакладная.ПравилаАгрегацииЧестногоЗнака <> ЗНАЧЕНИЕ(Справочник.ПравилаАгрегацииЧестногоЗнака.пустаяСсылка)
		|			ИЛИ РасходнаяНакладная.ПравилаАгрегацииЧестногоЗнака.Наименование <> ""Не требуется"")
		|	И РасходнаяНакладная.Организация = &Орг
		|	И ЕСТЬNULL(СтатусГотовностиКОтгрузкеЧЗ.СтатусЧЗ, ЗНАЧЕНИЕ(перечисление.СтатусыГотовностиКОтгрузкеЧЗ.ОжиданиеОбработкиЧЗ)) <> ЗНАЧЕНИЕ(перечисление.СтатусыГотовностиКОтгрузкеЧЗ.Обработано)
		|	И РасходнаяНакладная.ТребуетсяМаркировка = ИСТИНА
		|	И РасходнаяНакладная.ДатаОтгрузки >= &Дата" ;
		ЗапросРНК.УстановитьПараметр("Орг", ОрганизацияСуз);
		ЗапросРНК.УстановитьПараметр("Дата", НачалоДня(ТекущаяДата()-86400*11));
		РезПоРНК = ЗапросРНК.Выполнить().Выбрать();
		
		//берем все РНК и проверяем
		Пока РезПоРНК.Следующий() Цикл
			//По Десткому миру Агрегации не отправлять. Петров запретил.
			Если СокрЛП(РезПоРНК.Ссылка.Контрагент.Код) = "SST-0259" Тогда 
				//Валетов + 30,04,2025
				//Добавил Запись в регистр обработанных документов, чтоб потом он не лез в выборку.
				НаборЗаписей = РегистрыСведений.СтатусГотовностиКОтгрузкеЧЗ.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Документ.Установить(РезПоРНК.Ссылка);
				НаборЗаписей.Прочитать();
				Если НаборЗаписей.Количество() = 0 Тогда
					НоваяЗапись = НаборЗаписей.Добавить();
					НоваяЗапись.Документ = РезПоРНК.Ссылка;
				Иначе
					НоваяЗапись = НаборЗаписей[0];
				КонецЕсли;
				
				НоваяЗапись.СтатусЧЗ = Перечисления.СтатусыГотовностиКОтгрузкеЧЗ.Обработано;
				НаборЗаписей.Записать();
				//Валетов -
				Продолжить;
			КонецЕсли;
			
			ЕстьОшибки = Ложь;
			
			ВидыОпераций = Новый Массив;
			ВидыОпераций.Добавить(Перечисления.ВидыОперацийИСМП.Агрегация);
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка КАК Ссылка,
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки) КАК КоличествоШтрихкодовУпаковки,
