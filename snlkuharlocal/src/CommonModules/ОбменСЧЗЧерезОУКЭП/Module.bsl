Функция СделатьРазагрегацию(ДокСсылка,ЕстьОшибки,ТекстПисьма)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|ГДЕ
	|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ДокументОснование = &Док
	|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.Проведен
	|	И МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.РасформированиеУпаковки)
	|
	|СГРУППИРОВАТЬ ПО
	|	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка";
	
	Запрос.УстановитьПараметр("Док", ДокСсылка.ДокументОснование);
	
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Документы.МаркировкаТоваровИСМП.ПустаяСсылка();
		
	Иначе
		
		рПолучения = Документы.МаркировкаТоваровИСМП.ПолучитьДанныеРазАгрегации(ДокСсылка.ДокументОснование);
		Если рПолучения.Успешно Тогда
			
			Если рПолучения.Данные.Количество() = 0 Тогда
				Возврат Документы.МаркировкаТоваровИСМП.ПустаяСсылка();			
			КонецЕсли;
			
			ДокМаркировкиОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
			
			ДокМаркировкиОбъект.Дата	= ДокСсылка.дата - 2;			
			
			ДокМаркировкиОбъект.Организация	= ПолучитьРеквизитШапки(ДокСсылка, "Организация");
			ДокМаркировкиОбъект.Заполнить(ДокСсылка.ДокументОснование);
			ДокМаркировкиОбъект.ДокументОснование = ДокСсылка.ДокументОснование;
			ДокМаркировкиОбъект.ПодразделениеНанесения = ДокСсылка.ДокументОснование.Склад.Подразделение;
			ДокМаркировкиОбъект.ДополнительныеСвойства.Вставить("ЗаполнятьТолькоШапку", Истина);
			
			ДокМаркировкиОбъект.ВидОперации		= Перечисления.ВидыОперацийМаркировки.РасформированиеУпаковки;
			ДокМаркировкиОбъект.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.РасформированиеУпаковки;
			ДокМаркировкиОбъект.Статус			= Перечисления.СтатусыДокументовМаркировки.КОбработке;
			
			Для Каждого ШтрихкодУпаковки Из рПолучения.Данные Цикл
				СтрокаТЧ = ДокМаркировкиОбъект.ШтрихкодыУпаковок.Добавить();
				СтрокаТЧ.ШтрихкодУпаковки = ШтрихкодУпаковки;				
			КонецЦикла;
			
			Попытка
				ДокМаркировкиОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ДокМаркировкиОбъект.ОбменДанными.Загрузка = Истина;
				ДокМаркировкиОбъект.Записать();
				ЕстьОшибки = истина;
				ТекстПисьма = ТекстПисьма + " Ошибка проведения документа разагрегации: " + ДокМаркировкиОбъект.Ссылка +" Описание ошибки: " +ОписаниеОшибки() + Символы.ПС;
			КонецПопытки;
			Возврат ДокМаркировкиОбъект.Ссылка; 
		Иначе
			ЕстьОшибки = истина;
			ТекстПисьма = ТекстПисьма + " Ошибка разагрегации документа: " + ДокСсылка.ДокументОснование +" " + Символы.ПС;
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

Процедура ОповеститьОбОшибке(ТекстПисьма,ТемаПисьма,СписокПолучателей,ДокОшибкиСсылка)
