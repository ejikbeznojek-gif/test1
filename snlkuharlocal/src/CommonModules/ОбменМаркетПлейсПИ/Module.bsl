// Получить количество заказов в накладной.
// Кухарь А.Ю. 22.05.2022
// 
// Параметры:
//  Накладная - ДокументСсылка.РасходнаяНакладная - Документ накладная
// 
// Возвращаемое значение:
//  Число - Получить количество заказов в накладной
Функция ПолучитьКоличествоЗаказовВНакладной(Накладная) Экспорт
	  
	  Запрос = новый запрос;
	  запрос.Текст="ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказКлиентаFBSТовары.НомерЗаказа) КАК КоличествоЗаказов
	               |ИЗ
	               |	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	               |ГДЕ
	               |	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование = &Накладная
	               |	И ЗаказКлиентаFBSТовары.Ссылка.Дата > &Дата
	               |	И не ЗаказКлиентаFBSТовары.Отменен";
	 запрос.УстановитьПараметр("Накладная",Накладная);
	 запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());	 
	 Результат=запрос.Выполнить().Выбрать();
	 пока результат.Следующий() цикл
		 если результат.НомерЗаказа<>null тогда
			 возврат результат.КоличествоЗаказов;
		 КонецЕсли;
	 КонецЦикла;
	 возврат 0;
	 
КонецФункции // ПолучитьКоличествоЗаказовВНакладной()

// Получить количество заказов ВЛН.
// Кухарь А.Ю. 22.05.2022
// 
// Параметры:
//  ЛистНабора - ДокументСсылка.ЛистНабора -  Лист набора
// 
// Возвращаемое значение:
//  Число - Получить количество заказов ВЛН
Функция ПолучитьКоличествоЗаказовВЛН(ЛистНабора) Экспорт
	Запрос = новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.НомерЗаказа) КАК КоличествоЗаказов
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.Дата >= &Дата
	|	И ЛистПереукладки.ЛистНабора = &ЛистНабора";
	 запрос.УстановитьПараметр("ЛистНабора",ЛистНабора);
	 запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());	 
	 Результат=запрос.Выполнить().Выбрать();
	 пока результат.Следующий() цикл
		 если результат.НомерЗаказа<>null тогда
			 возврат результат.КоличествоЗаказов;
		 КонецЕсли;
	 КонецЦикла;
	 возврат 0;
	
 КонецФункции // ПолучитьКоличествоЗаказовВЛН()
 
