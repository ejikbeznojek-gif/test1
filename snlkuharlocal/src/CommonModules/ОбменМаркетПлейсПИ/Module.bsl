// Функция - Получить интернет магазин
// 
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты - Ссылка на контрагент, по которому вернется ссылка на интернет магазин
// 
// Возвращаемое значение:
//  СправочникСсылка.ИнетМагазины - Ссылка на сущность маркетплейса
Функция ПолучитьИнтернетМагазин(Контрагент) Экспорт
	
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИнетМагазины.Ссылка КАК ИМ
	|ИЗ
	|	Справочник.ИнетМагазины КАК ИнетМагазины
	|ГДЕ
	|	ИнетМагазины.Контрагент = &Контрагент
	|	И НЕ ИнетМагазины.ПометкаУдаления";
	запрос.УстановитьПараметр("Контрагент",Контрагент);
	Выборка = запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		возврат Выборка.ИМ;
	КонецЦикла;
	
	Возврат Справочники.ИнетМагазины.ПустаяСсылка();
	
КонецФункции // ПолучитьИнтернетМагазин()

