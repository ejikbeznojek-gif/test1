	НанесениеКодовНеОбязательно=ложь; 
	если СтруктураДанныхДокОснования.свойство("НанесениеКодовНеОбязательно") тогда
		НанесениеКодовНеОбязательно=СтруктураДанныхДокОснования.НанесениеКодовНеОбязательно;
	КонецЕсли;
	// Кухарь А.Ю.  13.02.2025 конец
	
	
	
	// Кухарь А.Ю.  20.01.2025 начало
	ОтгрузкаТолькоЧерезЧЗ=ПолучитьРеквизитШапки(Номенклатура,"ОтгрузкаТолькоЧерезЧЗ","Справочник");
	// Кухарь А.Ю.  20.01.2025 конец
	// Кухарь А.Ю.  28.02.2025 начало
	
	если ОтгрузкаТолькоЧерезЧЗ=Неопределено тогда
		ОтгрузкаТолькоЧерезЧЗ=ложь;
	КонецЕсли;
	// Кухарь А.Ю.  28.02.2025 конец
	
	
	
	СтруктураВозврата=новый Структура("МожноСканироватьКодыЧЗ,НужноСканироватьКодыЧЗ",Ложь,Ложь);
	
	ДатыТНВЭД=ПолучитьРеквизитыШапки(Номенклатура,"Родитель.ТНВЭД.ДатаНачалаРаботыСМаркировкой,Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой","Справочник");
	ДатаНачалаРаботыСМаркировкой=ДатыТНВЭД.Родитель_ТНВЭД_ДатаНачалаОбязательнойРаботыСМаркировкой;
	ДатаНачалаОбязательнойРаботыСМаркировкой=ДатыТНВЭД.Родитель_ТНВЭД_ДатаНачалаОбязательнойРаботыСМаркировкой;
	
	// Кухарь А.Ю. 18.11.2024 начало
	ИмяДокумента=ОбщегоНазначения_ПИ.ПолучитьИмяДокумента(ДокОснование);
	если ИмяДокумента="РасходнаяНакладная" или ИмяДокумента="Перемещение" тогда
		Контрагент=ПолучитьРеквизитШапки(ДокОснование,"Контрагент","Документ");
		ДанныеКонтрагента=ОбщегоНазначения_ПИ.ПолучитьДанныеКонтрагента(Контрагент);
		ТаблицаДопДанных=МаркировкаКС.ПодготовитьПереопределяемыеДатыНачалаРаботыСМаркировкойПоСтроке(ДокОснование,Контрагент,ДанныеКонтрагента,Номенклатура);
		если ТаблицаДопДанных<>Неопределено и ТаблицаДопДанных.количество()>0 тогда
			ДатаНачалаРаботыСМаркировкой=ТаблицаДопДанных[0].ДатаНачалаРаботыСМаркировкой;
			ДатаНачалаОбязательнойРаботыСМаркировкой=ТаблицаДопДанных[0].ДатаНачалаРаботыСМаркировкой;
		КонецЕсли;
	КонецЕсли;
	// Кухарь А.Ю. 18.11.2024 конец
	
	
	если не ЗначениеЗаполнено(ДатаНачалаОбязательнойРаботыСМаркировкой) тогда
		ДатаНачалаОбязательнойРаботыСМаркировкой='20800101';
	КонецЕсли;
	если не ЗначениеЗаполнено(ДатаНачалаРаботыСМаркировкой) тогда
		ДатаНачалаРаботыСМаркировкой='20800101';
	КонецЕсли;
	
	//Валетов + 01,08,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-2664
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") 
		И (ПолучитьРеквизитШапки(ДокОснование,"КодОперации","Документ") = Перечисления.КодыОперацийОстатки.ЗакупкаР
			ИЛИ ПолучитьРеквизитШапки(ДокОснование,"КодОперации","Документ") = Перечисления.КодыОперацийОстатки.Закупка) Тогда
			СтруктураВозврата.НужноСканироватьКодыЧЗ = Истина;
	КонецЕсли;
	//Валетов -
		
	Если  ДатаНачалаРаботыСМаркировкой <= ДатаОтгрузки и ТребуетсяМаркировка тогда
		СтруктураВозврата.МожноСканироватьКодыЧЗ = Истина;
		СтруктураВозврата.МожноСканироватьКодыЧЗ=Истина;
	КонецЕсли;
	
	
	// Кухарь А.Ю.  13.02.2025 начало
	// // FBO со спайками ЧЗ 
	Если  ДатаНачалаОбязательнойРаботыСМаркировкой <= ДатаОтгрузки или ОтгрузкаТолькоЧерезЧЗ тогда
		// Кухарь А.Ю.  13.02.2025 конец
		
		СтруктураВозврата.МожноСканироватьКодыЧЗ=Истина;
		
		// Кухарь А.Ю.  19.01.2025 начало
		//СтруктураВозврата.НужноСканироватьКодыЧЗ=Истина;
		// Кухарь А.Ю.  13.02.2025 начало
		// // FBO со спайками ЧЗ 
		//если не НаборыЧЗбезОклейкиКомплектующих и не ОтгрузкаТолькоЧерезЧЗ  тогда
		если не НанесениеКодовНеОбязательно тогда		
			// Кухарь А.Ю.  13.02.2025 конец	
			СтруктураВозврата.НужноСканироватьКодыЧЗ=Истина;
		КонецЕсли;
		// Кухарь А.Ю.  19.01.2025 конец
		
	КонецЕсли;
	
	//++Данилова Е.В. 01.12.2025  HELP-5962 
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") 
		И ПолучитьРеквизитШапки(ДокОснование,"ТребуетсяМаркировкаПриоритет","Документ") = Истина Тогда 
		СтруктураВозврата.НужноСканироватьКодыЧЗ=Истина;
		СтруктураВозврата.МожноСканироватьКодыЧЗ=Истина;
	КонецЕсли;
	//--Данилова Е.В. 01.12.2025
	
	//Кухарь А.Ю.  30.09.2024 начало
	если  ОтключитьКонтрольСканирования тогда
		если ТипЗнч(ДокОснование)= Тип("ДокументСсылка.Перемещение") тогда
			СтруктураВозврата.НужноСканироватьКодыЧЗ=Ложь;				
		ИначеЕсли ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") и ПолучитьРеквизитШапки(ДокОснование,"КодОперации","Документ")<>Перечисления.КодыОперацийОстатки.ЗакупкаР тогда
			СтруктураВозврата.НужноСканироватьКодыЧЗ=ложь;	
		КонецЕсли;
	КонецЕсли;
// Кухарь А.Ю.  30.09.2024 конец

	

	возврат СтруктураВозврата;
	
КонецФункции

// Кухарь А.Ю.  15.12.2024 конец



// Кухарь А.Ю.  19.01.2025 начало
//
Функция ПолучитьСвободныйКодДляПечати (ПараметрыПоиска) экспорт
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	//СтруктураВозврата=новый Структура("КодЧЗ,Успех,Ошибки",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(),Истина,"");	
		//20,01,2025 Ратманов исправление ошибки по HELP-2593 
	СтруктураВозврата=новый Структура("КодЧЗ,ЗначениеКМ,Успех,Ошибки,Цвет,Размер,Артикул,Статус",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(),"",Истина,"");	
	запрос=новый запрос;
	//++Ратманов
	//запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	//             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки КАК КодЧЗ,
	//             |	СтатусыКМ_ФактСрезПоследних.Статус КАК Статус,
	//             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки.ЗначениеШтрихкода КАК ЗначениеКМ,
	//             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки.Владелец.Цвет КАК Цвет,
	//             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки.Владелец.Размер КАК Размер,
	//             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки.Владелец.Родитель.КодПроизводителя КАК Артикул
	//             |ИЗ
	//             |	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(
	//             |			,
	//             |			Номенклатура = &Номенклатура
	//             |				И ТипШК = &ТипШК
	//             |				И НЕ ШтрихКодУпаковки В (&МассивИсключаемыхКодов)
	//             |				И &УсловиеПоКодамЗСБ
	//             |				И ШтрихКодУпаковки.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков)) КАК СтатусыКМ_ФактСрезПоследних
	//             |ГДЕ
	//             |	СтатусыКМ_ФактСрезПоследних.Статус В(&Статус)
	//             |	И СтатусыКМ_ФактСрезПоследних.Местонахождение В(&СписокМестонахождений)";
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	             |	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки КАК КодЧЗ,
	             |	СтатусыКМ_ФактСрезПоследних.Статус КАК Статус,
	             |	СпрШтрихКод.ЗначениеШтрихкода КАК ЗначениеКМ,
	             |	СпрШтрихКод_Владелец.Цвет КАК Цвет,
	             |	СпрШтрихКод_Владелец.Размер КАК Размер,
	             |	СпрШтрихКод_ВладелецРодитель.КодПроизводителя КАК Артикул
	             |ИЗ
	             |	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(
	             |			,
	             |			Номенклатура = &Номенклатура
	             |				И ТипШК = &ТипШК
	             |				И НЕ ШтрихКодУпаковки В (&МассивИсключаемыхКодов)
	             |				И &УсловиеПоКодамЗСБ
				 // Кухарь А.Ю.  20.03.2025 начало
				 //Потеряло актуальность
				 // |				И (
				 //|					ШтрихКодУпаковки.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков)
				 //|					ИЛИ ШтрихКодУпаковки.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Перемаркировка)				
				 //|				)				  
				 // Кухарь А.Ю.  20.03.2025 конец
				 
				|		) КАК СтатусыКМ_ФактСрезПоследних
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК СпрШтрихКод
	             |		ПО (СпрШтрихКод.Ссылка = СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки)
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрШтрихКод_Владелец
	             |		ПО (СпрШтрихКод_Владелец.Ссылка = СпрШтрихКод.Владелец)
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрШтрихКод_ВладелецРодитель
	             |		ПО (СпрШтрихКод_ВладелецРодитель.Ссылка = СпрШтрихКод_Владелец.Родитель)
	             |ГДЕ
	             |	СтатусыКМ_ФактСрезПоследних.Статус В(&Статус)
	             |	И СтатусыКМ_ФактСрезПоследних.Местонахождение В(&СписокМестонахождений)";
  	//--Ратманов	
	МассивМестоНахождений=новый Массив;
	если ОбщегоНазначения_ПИ.ЭтоУзел_ODN_или_OD7() тогда
		МассивМестоНахождений.Добавить(Неопределено);
		МассивМестоНахождений.Добавить(Справочники.Подразделения.ПустаяСсылка());
	КонецЕсли;
	МассивМестоНахождений.Добавить(ПараметрыПоиска.Подразделение);
	
	
	// Кухарь А.Ю.  19.01.2025 начало
	// Иногда коды бронируют, тогда брать нужно только из забронированных
	ОграничитьКодамиЗСБ=ложь;
	если ПараметрыПоиска.Свойство("СписокКодовИзРанееСозданныхЗСБ") и ПараметрыПоиска.Свойство("Накладная")  тогда
		Если ПараметрыПоиска.СписокКодовИзРанееСозданныхЗСБ тогда
			ОграничитьКодамиЗСБ=Истина;
			
			ЗапросЗСБ=новый запрос;
			ЗапросЗСБ.Текст="ВЫБРАТЬ различные
			|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки
			|ИЗ
			|	Документ.ЗаданиеНаСборкуКомплектовЧЗ.ШтрихкодыУпаковок КАК ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок
			|ГДЕ
			|	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
			|	И ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &Накладная
			|	И ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.ЗабронированПодСборку";
			ЗапросЗСБ.УстановитьПараметр("Накладная",ПараметрыПоиска.Накладная);
			МассивДоступныхКодов=ЗапросЗСБ.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
			
		КонецЕсли;
	КонецЕсли;
	если ОграничитьКодамиЗСБ тогда
		запрос.Текст=СтрЗаменить(запрос.Текст,"И &УсловиеПоКодамЗСБ","И ШтрихКодУпаковки В (&МассивДоступныхКодов)");
		запрос.УстановитьПараметр("МассивДоступныхКодов",МассивДоступныхКодов);
	иначе
		запрос.УстановитьПараметр("УсловиеПоКодамЗСБ",Истина);
	КонецЕсли;
	// Кухарь А.Ю.  19.01.2025 конец
	
	
	запрос.УстановитьПараметр("СписокМестонахождений",МассивМестоНахождений);
	запрос.УстановитьПараметр("МассивИсключаемыхКодов",ПараметрыПоиска.МассивИсключаемыхКодов);
	запрос.УстановитьПараметр("Номенклатура",ПараметрыПоиска.Номенклатура);
	запрос.УстановитьПараметр("ТипШК",ПараметрыПоиска.ТипШК);

	
	
	если ПараметрыПоиска.свойство("ОжидаемыйСтатусКода") тогда
		//Кухарь А.Ю.  23.02.2025 начало
		// Временно на переходный период. 
		//При следующем обновлении вернуть как было 
		//запрос.УстановитьПараметр("Статус",ПараметрыПоиска.ОжидаемыйСтатусКода); 
		СписокСтатусов = новый СписокЗначений;
		СписокСтатусов.Добавить(ПараметрыПоиска.ОжидаемыйСтатусКода);
		СписокСтатусов.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.НанесенВиртуально);	
		запрос.УстановитьПараметр("Статус",СписокСтатусов); 
		СтатусСтрокой=Строка(ПараметрыПоиска.ОжидаемыйСтатусКода);
		
		//Кухарь А.Ю.  23.02.2025 конец			
	иначе
		запрос.УстановитьПараметр("Статус",Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати); 	
		СтатусСтрокой=Строка("Готов к печати");

	КонецЕсли;
	

	// Кухарь А.Ю.  19.02.2025 конец
	
	
	Выборка=запрос.Выполнить().Выбрать();
	если Выборка.Количество()=0 тогда
		СтруктураВозврата.Успех=ложь;
		
		// Кухарь А.Ю.  25.02.2025 начало
		// Пустая задача
		//СтруктураВозврата.Ошибки=СтрШаблон("Не найдено ни одного кода ЧЗ в статусе %1, по номенклатуре %2",СтатусСтрокой,ПараметрыПоиска.Номенклатура);
		СтруктураВозврата.Ошибки=СтрШаблон("Не найдено ни одного кода ЧЗ в статусе %1, по номенклатуре %2, (%3)",
		СтатусСтрокой,ПараметрыПоиска.Номенклатура,ПолучитьРеквизитШапки(ПараметрыПоиска.Номенклатура,"Код","Справочник"));
		// Кухарь А.Ю.  25.02.2025 конец
		
	КонецЕсли;
	
	пока выборка.Следующий() цикл
		СтруктураВозврата.КодЧЗ=Выборка.КодЧЗ;
		//20,01,2025 Ратманов исправление ошибки по HELP-2593
		ЗаполнитьЗначенияСвойств(СтруктураВозврата,Выборка);
		//СтруктураВозврата.ЗначениеКМ=Выборка.ЗначениеКМ;
	КонецЦикла;
	
	ТекстСообщения = "МаркировкаКС.ПолучитьСвободныйКодДляПечати";
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало)/1000);
	
	Возврат СтруктураВозврата;
КонецФункции

// Кухарь А.Ю.  19.01.2025 начало
//
Функция ПолучитьСтруктуруКодаДляПечати (КодЧЗ) экспорт
	Запрос=новый запрос;
	СтруктураВозврата=новый Структура("Успех,Ошибки,КодЧЗ,ЗначениеКМ,Цвет,Размер,Артикул");
	СтруктураВозврата.Успех=ложь;
	СтруктураВозврата.Ошибки=новый Массив;
	запрос.Текст="ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК КодЧЗ,
	|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода КАК ЗначениеКМ,
	|	ШтрихкодыУпаковокТоваров.Владелец.Цвет КАК Цвет,
	|	ШтрихкодыУпаковокТоваров.Владелец.Размер КАК Размер,
	|	ШтрихкодыУпаковокТоваров.Владелец.Родитель.КодПроизводителя КАК Артикул
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Ссылка = &КодЧЗ";
	запрос.УстановитьПараметр("КодЧЗ",КодЧЗ);
	Выборка=запрос.Выполнить().Выбрать();
	пока Выборка.Следующий() цикл
		ЗаполнитьЗначенияСвойств(СтруктураВозврата,Выборка);
		СтруктураВозврата.Успех=Истина;
	КонецЦикла;
	если не СтруктураВозврата.Успех тогда
		СтруктураВозврата.Ошибки.Добавить("Не найден код ЧЗ");
	КонецЕсли;
	
	возврат СтруктураВозврата;
	
КонецФункции



Функция ПолучитьПоляКМДляПечати(КМ) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Владелец							КАК Номенклатура,
	|	Владелец.Родитель.КодПроизводителя	КАК Артикул,
	|	Владелец.Цвет						КАК Цвет,
	|	Владелец.Размер						КАК Размер,
	|	Ссылка								КАК ШтрихкодУпаковки,	
	|	ЗначениеШтрихкода					КАК ЗначениеКМ
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	Ссылка = &КМ
	|";
	
	Запрос.УстановитьПараметр("КМ", КМ);
	рЗапроса = Запрос.Выполнить();
	
	Результат = Новый Структура;
	Для Каждого Кол Из рЗапроса.Колонки Цикл
		Результат.Вставить(Кол.Имя, Неопределено);	
	КонецЦикла; 
	Выборка = рЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьПоляКМДляПечати(КМ)

Функция ДобавитьСообщения(Результат1, Результат2) Экспорт	
	Если ТипЗнч(Результат2)= Тип("Массив") Тогда
		ДанныеИст = Результат2;
	Иначе
		ДанныеИст = Результат2.Сообщения;
	КонецЕсли; 
	
	Если ТипЗнч(Результат1) = Тип("Массив") Тогда
		ДанныеПол = Результат1;
	Иначе
		ДанныеПол = Результат1.Сообщения;
	КонецЕсли; 
	
	Для Каждого Строка Из ДанныеИст Цикл
		ДанныеПол.Добавить(Строка);
	КонецЦикла;
КонецФункции //ДобавитьСообщения(Результат1, Результат2)	


