		|ИЗ
		|	Товары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСДатами КАК ТаблицаСДатами
		|		ПО Товары.Номенклатура = ТаблицаСДатами.Номенклатура
		|ГДЕ
		|	Товары.Количество > 0
		//|	И ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <= &ДатаПроверки
		//|	И ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)";
		|	И ВЫБОР
		|		КОГДА Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ	ТОГДА ИСТИНА
		|		ИНАЧЕ ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <= &ДатаПроверки
		|	КОНЕЦ
		|	И ВЫБОР
		|		КОГДА Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ	ТОГДА ИСТИНА
		|		ИНАЧЕ ЕСТЬNULL(ТаблицаСДатами.ДатаНачалаРаботыСМаркировкой, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ ";
		запрос.УстановитьПараметр("ТаблицаПереопределяемыхДат",ТаблицаПереопределяемыхДат);	

	иначе	
		запрос.Текст="ВЫБРАТЬ
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.Количество КАК Количество
		|ПОМЕСТИТЬ Товары
		|ИЗ
		|	&Товары КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Товары.Номенклатура КАК Номенклатура
		|ИЗ
		|	Товары КАК Товары
		|ГДЕ
		|	Товары.Количество > 0
		//|	И естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаРаботыСМаркировкой,ДатаВремя(1,1,1)) <> ДатаВремя(1,1,1)
		//|	И естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаРаботыСМаркировкой,ДатаВремя(1,1,1)) <= &ДатаПроверки"; 
		|	И ВЫБОР
		|		КОГДА Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ	ТОГДА ИСТИНА
		|		ИНАЧЕ естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,ДатаВремя(1,1,1)) <> ДатаВремя(1,1,1)
		|	КОНЕЦ
		|	И ВЫБОР  
		//++Данилова Е.В. 01.12.2025 HELP-5962
		|		КОГДА Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ	ИЛИ &ТребуетсяМаркировкаПриоритетПНК ТОГДА ИСТИНА
		//|		КОГДА Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ	ТОГДА ИСТИНА 
		//--Данилова Е.В. 01.12.2025 
		|		ИНАЧЕ естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,ДатаВремя(1,1,1)) <= &ДатаПроверки
		|	КОНЕЦ";
	КонецЕсли; 
	
	// Кухарь А.Ю.  23.12.2024 начало
