Функция ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой (ДокОбъект,ИмяТоварнойТЧ,ТЧИзЛН = неопределено) экспорт
	//Дата маркировки переопределяется либо из Матрица.Товары.ДатаНачалаРаботыСМаркировкой, либо из Контрагент.ДатаНачалаРаботыСМаркировкой
	//Берётся минимальная не пустая дата. Между датой из ТНВЭД и датой полученной из дополнительных источников
	
	//Тимофеев Ю.А. Начало   06-02-2025
	//ID-16215
	//для процедур маркетплейсов -там еще нет документов РНК , а нужно разделение
	
	Если ТипЗнч(ДокОбъект)=Тип("Структура") Тогда
		
		Товары=ДокОбъект[ИмяТоварнойТЧ];
		СтруктураДанныхНакладной=ДокОбъект;
		
	Иначе   
		
		//Тимофеев Ю.А. Конец    06-02-2025
		
		СтруктураДанныхНакладной=новый Структура("Номенклатура,ПунктДоставки,Договор,Дата,Контрагент,ПостояннаяАкция"); 
		ЗаполнитьЗначенияСвойств(СтруктураДанныхНакладной,ДокОбъект);
		Товары=ДокОбъект[ИмяТоварнойТЧ].выгрузить();
		СтруктураДанныхНакладной.Номенклатура=Товары.ВыгрузитьКолонку("Номенклатура");
		
	КонецЕсли;

	
	Контрагент=СтруктураДанныхНакладной.Контрагент;	
	// Кухарь А.Ю. 10.03.2025 начало
	// Пустая задача
	если Контрагент=Справочники.Контрагенты.ПустаяСсылка() тогда
		РеквизитыКонтрагента=новый Структура("ДатаНачалаРаботыСМаркировкой,ВыполнятьПоискДатыНачалаМаркировкиВМатрице",'20260101',ложь);
	Иначе 
		// Кухарь А.Ю. 10.03.2025 конец
		
		РеквизитыКонтрагента=ПолучитьРеквизитыШапки(Контрагент,"ДатаНачалаРаботыСМаркировкой,ВыполнятьПоискДатыНачалаМаркировкиВМатрице","Справочник");	
		// Кухарь А.Ю. 10.03.2025 начало
		// Пустая задача
	КонецЕсли;	
	// Кухарь А.Ю. 10.03.2025 конец
	
	ДатаНачалаМаркировкиИзКонтрагента=РеквизитыКонтрагента.ДатаНачалаРаботыСМаркировкой;	
	// Кухарь А.Ю. 06.03.2025 начало
	// Пустая задача
	ОтгрузкаСоСкладаМаркировки = ложь;
	//++Данилова Е.В. 20.08.2025 HELP-6434 
	ТребуетсяМаркировкаПриоритет = Ложь; 
	//--Данилова Е.В. 20.08.2025
	ТипДокумента=ТипЗнч(ДокОбъект);
	если ТипДокумента=Тип("ДокументСсылка.Перемещение") тогда
		РеквизитыСкладов=ПолучитьРеквизитыШапки(ДокОбъект,"Склад.ЭтоСкладМаркированногоТовара,СкладПолучатель.ЭтоСкладМаркированногоТовара","Документ");
		Если РеквизитыСкладов.Склад_ЭтоСкладМаркированногоТовара = Истина или РеквизитыСкладов.СкладПолучатель_ЭтоСкладМаркированногоТовара = Истина тогда
			ОтгрузкаСоСкладаМаркировки = Истина;
		КонецЕсли;
	ИначеЕсли ТипДокумента=Тип("ДокументОбъект.Перемещение") тогда
		Если ПолучитьРеквизитШапки(ДокОбъект.Склад,"ЭтоСкладМаркированногоТовара","Справочник") = Истина  
			//++Данилова Е.В. 17.11.2025  HELP-7070 
			//или ПолучитьРеквизитШапки(ДокОбъект.СкладПолучатель,"ЭтоСкладМаркированногоТовара","Справочник") тогда
			или ПолучитьРеквизитШапки(ДокОбъект.СкладПолучатель,"ЭтоСкладМаркированногоТовара","Справочник") = Истина тогда
			//--Данилова Е.В. 17.11.2025
			ОтгрузкаСоСкладаМаркировки = Истина;		
		КонецЕсли;	
	ИначеЕсли ТипДокумента=Тип("ДокументОбъект.РасходнаяНакладная") тогда
		Если ПолучитьРеквизитШапки(ДокОбъект.Склад,"ЭтоСкладМаркированногоТовара","Справочник") = Истина  тогда
			ОтгрузкаСоСкладаМаркировки = Истина;		
		КонецЕсли;
		//++Данилова Е.В. 20.08.2025  HELP-6434
		Если ДокОбъект.ТребуетсяМаркировкаПриоритет  тогда
			ТребуетсяМаркировкаПриоритет = Истина;		
		КонецЕсли;
		//--Данилова Е.В. 20.08.2025
	ИначеЕсли ТипДокумента=Тип("ДокументСсылка.РасходнаяНакладная") тогда
		Если ПолучитьРеквизитШапки(ДокОбъект,"Склад.ЭтоСкладМаркированногоТовара","Документ") = Истина  тогда
			ОтгрузкаСоСкладаМаркировки = Истина;			
		КонецЕсли;
		//++Данилова Е.В. 20.08.2025  HELP-6434
		Если ДокОбъект.ТребуетсяМаркировкаПриоритет  тогда
			ТребуетсяМаркировкаПриоритет = Истина;		
		КонецЕсли;
		//--Данилова Е.В. 20.08.2025
	КонецЕсли;
	
	
	РаботаПоМатрицам=РеквизитыКонтрагента.ВыполнятьПоискДатыНачалаМаркировкиВМатрице;
	//++Данилова Е.В. 20.08.2025 HELP-6434 
	//если ОтгрузкаСоСкладаМаркировки тогда
	если ОтгрузкаСоСкладаМаркировки 
		ИЛИ ТребуетсяМаркировкаПриоритет тогда
		//--Данилова Е.В. 20.08.2025
		РаботаПоМатрицам=ложь;
		ДатаНачалаМаркировкиИзКонтрагента=ТекущаяДата()-60*86400;		
	КонецЕсли;
	// Кухарь А.Ю. 06.03.2025 конец
	
	

	если РаботаПоМатрицам тогда
		ТаблицаМатриц=ПолучитьТаблицуМатрицСрезПоследних(СтруктураДанныхНакладной);
		ТаблицаМатриц.Свернуть("Номенклатура,ДатаНачалаРаботыСМаркировкой");
	КонецЕсли;
	
	Запрос=новый запрос;	

	
	
	если не РаботаПоМатрицам тогда
		если ДатаНачалаМаркировкиИзКонтрагента='00010101' тогда
			//Кухарь А.Ю.  10.03.2025 начало
			// Пустая задача
			ДатаНачалаМаркировкиИзКонтрагента='20260101'; 
			//Кухарь А.Ю.  10.03.2025 конец
			
		КонецЕсли;
		
		//Валетов + 25,09,2025 ПустаяЗадача Добавил ТЧизЛистовНабора, для получения дат по всем товарам если что-то есть в ЛН, но нет в ДокОсновании
		Если не ТЧИзЛН = неопределено Тогда 
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТЧ.Номенклатура КАК Номенклатура,
			|	ТЧ.Количество КАК Количество
			|ПОМЕСТИТЬ ВТ_Осн
			|ИЗ
			|	&Товары КАК ТЧ
			|ГДЕ
			|	ТЧ.Количество > 0
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаварыИзЛН.Номенклатура КАК Номенклатура,
			|	ТаварыИзЛН.Количество КАК Количество
			|ПОМЕСТИТЬ ВТ_ЛН
			|ИЗ
			|	&ТаварыЛН КАК ТаварыИзЛН
			|ГДЕ
			|	ТаварыИзЛН.Количество > 0
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЕСТЬNULL(ВТ_Осн.Номенклатура, ВТ_ЛН.Номенклатура) КАК Номенклатура
			|ПОМЕСТИТЬ Товары
			|ИЗ
			|	ВТ_Осн КАК ВТ_Осн
			|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ЛН КАК ВТ_ЛН
			|		ПО ВТ_Осн.Номенклатура = ВТ_ЛН.Номенклатура
			|;
			|";
			Запрос.УстановитьПараметр("ТаварыЛН",ТЧИзЛН);						   
		Иначе
			
			запрос.Текст="ВЫБРАТЬ
			|	ТЧ.Номенклатура КАК Номенклатура
			|ПОМЕСТИТЬ Товары
			|ИЗ
			|	&Товары как ТЧ
			|ГДЕ
			|	ТЧ.Количество > 0
			|
			|;
			|";
		КонецЕсли; 
	    запрос.Текст= запрос.Текст+"
		//Валетов -
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(ВЫБОР 
		|	Когда естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,ДатаВремя(1,1,1)) = ДатаВремя(1,1,1) тогда &ДалекоеБудущее 
		// Кухарь А.Ю.  03.06.2025 начало
		|			Когда Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ тогда ДатаВремя(2024,1,1) 	 
		// Кухарь А.Ю.  03.06.2025 конец
		
		|			КОГДА 
		|				естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее) <= &ДатаНачалаМаркировкиИзКонтрагента или  &ДатаНачалаМаркировкиИзКонтрагента = ДатаВремя (1,1,1)	ТОГДА 
		|				естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее)
		|			ИНАЧЕ 
		|				&ДатаНачалаМаркировкиИзКонтрагента
		|		КОНЕЦ) КАК ДатаНачалаРаботыСМаркировкой
		|ИЗ
		|	Товары КАК Товары
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура";	
	иначе	
		запрос.Текст="ВЫБРАТЬ
		|	ТЗМатриц.Номенклатура КАК номенклатура,
		|	ВЫБОР
		|		КОГДА ТЗМатриц.ДатаНачалаРаботыСМаркировкой = ДатаВремя(1,1,1)
		|			ТОГДА &ДалекоеБудущее
		|		ИНАЧЕ ТЗМатриц.ДатаНачалаРаботыСМаркировкой
		|	КОНЕЦ КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ВТМатриц
		|ИЗ
		|	&ТЗ КАК ТЗМатриц	
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.Количество КАК Количество
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	&Товары как ТЧ
		|ГДЕ
		|	ТЧ.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЕСТЬNULL(ТЗМатриц.ДатаНачалаРаботыСМаркировкой, &ДалекоеБудущее) < естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,ДатаВремя(1,1,1))
		|				ТОГДА ЕСТЬNULL(ТЗМатриц.ДатаНачалаРаботыСМаркировкой, &ДалекоеБудущее)
		// Кухарь А.Ю.  03.06.2025 начало
		|			Когда Товары.Номенклатура.ОтгрузкаТолькоЧерезЧЗ тогда ДатаВремя(2024,1,1) 	 
		// Кухарь А.Ю.  03.06.2025 конец
		
		|			ИНАЧЕ естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее)
		|		КОНЕЦ) КАК ДатаНачалаРаботыСМаркировкой
