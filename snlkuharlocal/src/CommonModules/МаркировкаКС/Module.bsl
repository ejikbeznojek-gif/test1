Функция ПодготовитьПереопределяемыеДатыНачалаРаботыСМаркировкойПоСтроке (Знач Накладная,Контрагент,РеквизитыКонтрагента,Номенклатура) экспорт
	ДатаНачалаМаркировкиИзКонтрагента=РеквизитыКонтрагента.ДатаНачалаРаботыСМаркировкой;	
	РаботаПоМатрицам=РеквизитыКонтрагента.ВыполнятьПоискДатыНачалаМаркировкиВМатрице;
	
	// Кухарь А.Ю. 06.03.2025 начало
	// Пустая задача
	ОтгрузкаСоСкладаМаркировки = ложь;
	//++Данилова Е.В. 20.08.2025 HELP-6434 
	ТребуетсяМаркировкаПриоритет = Ложь; 
	//--Данилова Е.В. 20.08.2025
	ТипДокумента=ТипЗнч(Накладная);
	если ТипДокумента=Тип("ДокументСсылка.Перемещение") тогда
		РеквизитыСкладов=ПолучитьРеквизитыШапки(Накладная,"Склад.ЭтоСкладМаркированногоТовара,СкладПолучатель.ЭтоСкладМаркированногоТовара","Документ");
		Если РеквизитыСкладов.Склад_ЭтоСкладМаркированногоТовара = Истина или РеквизитыСкладов.СкладПолучатель_ЭтоСкладМаркированногоТовара = Истина тогда
			ОтгрузкаСоСкладаМаркировки = Истина;
		КонецЕсли;
	ИначеЕсли ТипДокумента=Тип("ДокументСсылка.РасходнаяНакладная") тогда
		Если ПолучитьРеквизитШапки(Накладная,"Склад.ЭтоСкладМаркированногоТовара","Документ") = Истина  тогда
			ОтгрузкаСоСкладаМаркировки = Истина;			
		КонецЕсли;
		//++Данилова Е.В. 20.08.2025  HELP-6434
		Если Накладная.ТребуетсяМаркировкаПриоритет  тогда
			ТребуетсяМаркировкаПриоритет = Истина;		
		КонецЕсли;
		//--Данилова Е.В. 20.08.2025

	КонецЕсли;
	
	
	//++Данилова Е.В. 20.08.2025 HELP-6434 
