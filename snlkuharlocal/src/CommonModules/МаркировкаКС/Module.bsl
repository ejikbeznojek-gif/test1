		|					ИЛИ &ДатаНачалаМаркировкиИзКонтрагента = ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА естьnull(Товары.Ссылка.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее)
		|			ИНАЧЕ &ДатаНачалаМаркировкиИзКонтрагента
		|		КОНЕЦ) КАК ДатаНачалаРаботыСМаркировкой
		|ИЗ
		|	Справочник.Номенклатура КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Ссылка";	
	иначе	
		запрос.Текст="ВЫБРАТЬ
		|	ТЗМатриц.Номенклатура КАК номенклатура,
		|	ВЫБОР
		|		КОГДА ТЗМатриц.ДатаНачалаРаботыСМаркировкой = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА &ДалекоеБудущее
		|		ИНАЧЕ ТЗМатриц.ДатаНачалаРаботыСМаркировкой
		|	КОНЕЦ КАК ДатаНачалаРаботыСМаркировкой
		|ПОМЕСТИТЬ ВТМатриц
		|ИЗ
		|	&ТЗ КАК ТЗМатриц
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Спр.Ссылка КАК Номенклатура
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	Справочник.Номенклатура КАК Спр
		|ГДЕ
		|	Спр.Ссылка = &Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(ВЫБОР	
		// Кухарь А.Ю.  06.06.2025 начало
		|			КОГДА естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,ДатаВремя(1,1,1))  = ДатаВремя(1,1,1) тогда &ДалекоеБудущее		
		// Кухарь А.Ю.  06.06.2025 конец		
		|			КОГДА ЕСТЬNULL(ТЗМатриц.ДатаНачалаРаботыСМаркировкой, &ДалекоеБудущее) < естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее)
		|				ТОГДА ЕСТЬNULL(ТЗМатриц.ДатаНачалаРаботыСМаркировкой, &ДалекоеБудущее)
		|			ИНАЧЕ естьnull(Товары.Номенклатура.Родитель.ТНВЭД.ДатаНачалаОбязательнойРаботыСМаркировкой,&ДалекоеБудущее)
		|		КОНЕЦ) КАК ДатаНачалаРаботыСМаркировкой
		|ИЗ
		|	ВтТовары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМатриц КАК ТЗМатриц
		|		ПО Товары.Номенклатура = ТЗМатриц.номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура";
		запрос.УстановитьПараметр("ДалекоеБудущее",'20990101'); 			
		запрос.УстановитьПараметр("ТЗ",ТаблицаМатриц); 		

	КонецЕсли;
	запрос.УстановитьПараметр("ДатаНачалаМаркировкиИзКонтрагента",ДатаНачалаМаркировкиИзКонтрагента); 		
	запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	// Кухарь А.Ю.  10.02.2025 начало
	// HELP-2808
	запрос.УстановитьПараметр("ДалекоеБудущее",'20990101'); 	
	// Кухарь А.Ю.  10.02.2025 конец
	
	
	// Кухарь А.Ю.  22.01.2025 начало
