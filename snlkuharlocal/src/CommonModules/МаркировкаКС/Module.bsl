 Процедура ВернутьВРаботуЛН(Знач ЛНОбъект, ФормаЛН) Экспорт 
	 //++Данилова Е.В. 29.05.2026 
	 Если НЕ ПроверитьВозможностьВозвратаВработу(ЛНОбъект) Тогда
	    Сообщить("По документам маркировки по РНК выполняются операции агрегации"); 
	 	Возврат; 	
	 
	 КонецЕсли; 
	 //--Данилова Е.В. 29.05.2026 
	 ЛНОбъект.Завершен = Ложь;
	 
	 Если ТипЗнч(ЛНОбъект) = Тип("ДокументОбъект.ЛистНабора") Тогда 
		 
		 ЛНОбъект.ОкончаниеСканирования = Дата(1,1,1); 
		 ЛНОбъект.ВремяОкончанияСканирования = Дата(1,1,1);
		 
	 ИначеЕсли ТипЗнч(ЛНОбъект) = Тип("ДокументОбъект.ЛистПереукладки") Тогда
		 
		 ЛНОбъект.ДатаОкончанияСканирования = Дата(1,1,1); 
		 
