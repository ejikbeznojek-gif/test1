	если ОтгрузкаСоСкладаМаркировки 
		ИЛИ ТребуетсяМаркировкаПриоритет тогда
		//--Данилова Е.В. 20.08.2025
		РаботаПоМатрицам=ложь;
		ДатаНачалаМаркировкиИзКонтрагента=ТекущаяДата()-30*86400;		
	КонецЕсли;
	
	// Кухарь А.Ю. 06.03.2025 конец
	
	//Валетов + 13,03,2025  https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-3356
	Если РаботаПоМатрицам = Неопределено Тогда
		РаботаПоМатрицам = Ложь;
		Если ДатаНачалаМаркировкиИзКонтрагента = Неопределено Тогда
			ДатаНачалаМаркировкиИзКонтрагента = '00010101';
		КонецЕсли;
	КонецЕсли;
	//Валетов -
	
	если РаботаПоМатрицам тогда
		ТаблицаМатриц=ПолучитьТаблицуМатрицСрезПоследних(Накладная,,Номенклатура);
		ТаблицаМатриц.Свернуть("Номенклатура,ДатаНачалаРаботыСМаркировкой");
	КонецЕсли;
	
	Запрос=новый запрос;	
	
	
	если не РаботаПоМатрицам тогда	
		если ДатаНачалаМаркировкиИзКонтрагента='00010101' тогда
			//Кухарь А.Ю.  10.03.2025 начало
			// Пустая задача
			ДатаНачалаМаркировкиИзКонтрагента='20260101'; 
			//Кухарь А.Ю.  10.03.2025 конец

		КонецЕсли;
		запрос.Текст="ВЫБРАТЬ
		|	Товары.Ссылка КАК Номенклатура,
		|	МАКСИМУМ(ВЫБОР		
		// Кухарь А.Ю.  06.06.2025 начало
