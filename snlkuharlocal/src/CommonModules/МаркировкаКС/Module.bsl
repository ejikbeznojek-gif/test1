Функция ВывестиСообщения(рОбработки) Экспорт
	Сообщения		= МаркировкаКС.ПолучитьЗначениеПараметра(рОбработки, "Сообщения", Новый Массив);
	ТекстСообщения	= "";
	
	Если Сообщения.Количество() > 0 Тогда	
		ТекстСообщения = СтрСоединить(Сообщения, Символы.ПС);
		Сообщить(ТекстСообщения, СтатусСообщения.Важное);
	КонецЕсли;
	
	Возврат ТекстСообщения;
КонецФункции //ВывестиСообщения(рОбработки) Экспорт

Функция СохранитьОтложенныеДвижения(ДокОбъект, Отказ) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ДокСсылка = ДокОбъект.Ссылка;
	
	ДанныеДвижений	= МаркировкаКС.ПолучитьДвиженияДокумента(ДокОбъект);	
	рСохранения		= РегистрыСведений.ОтложенныеДвиженияДокументов.СохранитьДвижения(ДокСсылка, ДанныеДвижений);
	Если рСохранения.Успешно Тогда                                               
		Для каждого Элемент Из ДанныеДвижений Цикл          
			ИмяТаблицы = Элемент.ИмяРегистра;			
			Если ИмяТаблицы = "РегистрСведений.ИспользованныеКодыАгрегаций" Тогда Продолжить КонецЕсли;
			
			ДвиженияПоРегистру = ДокОбъект.Движения[СтрРазделить(ИмяТаблицы, ".")[1]];			
			Если МаркировкаКС.ЕстьДвиженияПоРегистру(ИмяТаблицы, ДокСсылка) Тогда				
				//ДвиженияПоРегистру.Записывать = Истина;			
			КонецЕсли;
			//ДвиженияПоРегистру.Очистить();
			ДвиженияПоРегистру.Записывать = Ложь;
		КонецЦикла;		
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рСохранения);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Если НЕ Результат.Успешно Тогда
		Отказ = Истина;	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗаписатьОтложенныеДвижения(ДокОбъект) Экспорт

Функция ПолучитьДвиженияДокумента(ДокОбъект) Экспорт  
	ДанныеДвижений = Новый Массив;
	Для Каждого НЗ Из ДокОбъект.Движения Цикл	          
		СтрокаДанных = Новый Структура;
		СтрокаДанных.Вставить("ДокСсылка", 			ДокОбъект.Ссылка);
		СтрокаДанных.Вставить("ИмяРегистра",    	НЗ.Метаданные().ПолноеИмя());
		СтрокаДанных.Вставить("Движения",			Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Выгрузить()), Новый СжатиеДанных(5)));
		СтрокаДанных.Вставить("КоличествоЗаписей", 	НЗ.Количество());
		
		ДанныеДвижений.Добавить(СтрокаДанных);	
	КонецЦикла;	
	
	Возврат  ДанныеДвижений;	
КонецФункции //ПолучитьДвижения(ДокОбъект) Экспорт

Функция ЕстьДвиженияПоРегистру(ИмяТаблицы, Регистратор) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1 
	|	Регистратор
	|ИЗ
	|	" + ИмяТаблицы + "
	|ГДЕ
	|	Регистратор = &Регистратор
	|";
	
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат  (Выборка.Следующий() И Выборка.Регистратор = Регистратор);
КонецФункции //ЕстьДвиженияПоРегистру(ИмяТаблицы, Регистратор) Экспорт

Функция МожноЗапускатьФЗ(ИмяМетода) Экспорт
	Результат = СтруктураРезультата();
	
	ТекущееФЗ = ПолучитьТекущийСеансИнформационнойБазы().ПолучитьФоновоеЗадание();
	
	Если ТекущееФЗ <> Неопределено Тогда
		ОтборФЗ		= Новый Структура("ИмяМетода,Состояние", ИмяМетода, СостояниеФоновогоЗадания.Активно);
		АктивныеФЗ	= ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);	
		
		Для Каждого АктивноеФЗ Из АктивныеФЗ Цикл		
			Если АктивноеФЗ.УникальныйИдентификатор <> ТекущееФЗ.УникальныйИдентификатор Тогда
				ФЗ = АктивныеФЗ[0];
				ТекстОшибки = СтрШаблон("Обнаружено работающее ФЗ с методом '%1' ! Запущено: %2, ид.: %3 !.", ИмяМетода, ФЗ.Начало, ФЗ.УникальныйИдентификатор);
				Результат.Ошибки.Добавить(ТекстОшибки);
				
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПроверитьВозможностьЗапускаФЗ(ИмяМетода) Экспорт

