Процедура ЗаполнитьТабличныеЧастиПризнакомМаркировки(НакладнаяОбъект) экспорт 
	ТипНакладной=ТипЗнч(НакладнаяОбъект);
	ТаблицаТоваров=Неопределено;
	ЗаполнитьКомплектующиеПоТоварамРНК=ложь;
	если ТипНакладной=Тип("ДокументОбъект.РасходнаяНакладная") тогда
		ТаблицаТоваров=ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(НакладнаяОбъект,"Товары");
		если НакладнаяОбъект.ОтгрузкаКомплектов тогда
			ЗаполнитьКомплектующиеПоТоварамРНК = Истина;
		КонецЕсли;
	ИначеЕсли ТипНакладной=Тип("ДокументОбъект.Перемещение") тогда
		ТаблицаТоваров=ПодготовитьТаблицуСПереопределяемойДатойНачалаРаботыСМаркировкой(НакладнаяОбъект,"Товары");		
	КонецЕсли;


	
	если ТаблицаТоваров<>Неопределено тогда
		Для каждого СтрТЧ из НакладнаяОбъект.товары цикл
			СтрокаТЗ=ТаблицаТоваров.найти(СтрТЧ.Номенклатура,"Номенклатура");
			если СтрокаТЗ=Неопределено тогда      
				СтрТЧ.ТребуетсяМаркировка=ложь;
			иначе
				Если СтрокаТЗ.ДатаНачалаРаботыСМаркировкой<=НакладнаяОбъект.Дата тогда
					СтрТЧ.ТребуетсяМаркировка=Истина;
				иначе
					СтрТЧ.ТребуетсяМаркировка=ложь;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	если ЗаполнитьКомплектующиеПоТоварамРНК тогда
		Для каждого СтрТЧ из НакладнаяОбъект.Комплектующие цикл
			ВидНоменклатуры= ОбщегоНазначения_ПИ.ПолучитьРеквизитШапкиПИ(СтрТЧ.Номенклатура,"Родитель.ВидНоменклатуры","Справочник");
			если ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Товар  тогда
				СтрокаТоваров=НакладнаяОбъект.Товары.Найти(СтрТЧ.Продукция,"Номенклатура");
				Если СтрокаТоваров=Неопределено тогда
					СтрТЧ.ТребуетсяМаркировка = ложь;
				Иначе
					СтрТЧ.ТребуетсяМаркировка =СтрокаТоваров.ТребуетсяМаркировка;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	
КонецПроцедуры

