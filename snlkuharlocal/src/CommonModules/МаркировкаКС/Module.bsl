	КонецЕсли;
	// Кухарь А.Ю.  23.12.2024 конец 
	//++Данилова Е.В. 01.12.2025 HELP-5962 
	запрос.УстановитьПараметр("ТребуетсяМаркировкаПриоритетПНК",ТребуетсяМаркировкаПриоритетПНК);
	//--Данилова Е.В. 01.12.2025 
	
	запрос.УстановитьПараметр("Товары",ДокОбъект[ИмяТоварнойТЧ].выгрузить());
	результат=запрос.Выполнить().Выбрать();

	если  ВозможнаРаботаСМаркировкой и результат.Количество()>0 тогда
		ТребуетсяМаркировка=Истина;
