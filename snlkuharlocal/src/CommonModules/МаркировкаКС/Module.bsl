				Если КнопкаПанели.Имя = "ЭтикеткаОнлайн" Тогда
				
					КнопкаПанели.Доступность = истина; 	
				
				КонецЕсли;
				//--Данилова Е.В. 15.06.2026 
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	//КонецЕсли;
	 
КонецПроцедуры

