Функция ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной (Знач Накладная) экспорт
	СтруктураВозврата=новый Структура("УстановленыПравилаРаботыСАгрегацией,РазворачиватьАгрегациюДоШтук,ТребуетсяАгрегацияБлочков,ТребуетсяАгрегацияКоробок,ТребуетсяАгрегацияПаллет,ПриАгрегацииСворачиватьПоНаименованиюКонтрагента",
	ложь,ложь,ложь,ложь,ложь,Ложь); 
	//++Данилова Е.В. 14.01.2026 ASU-2089 
	СтруктураВозврата.Вставить("ФормироватьНаборКодовАгрегацииНаПаллету",Ложь); 
	//--Данилова Е.В. 14.01.2026 
	//++Данилова Е.В. 09.02.2026 SNL-131
	если ТипЗнч(Накладная)<>тип("ДокументСсылка.РасходнаяНакладная")
		ИЛИ Не ЗначениеЗаполнено(Накладная) тогда  
	//--Данилова Е.В. 09.02.2026 
		возврат СтруктураВозврата;
	ИначеЕсли не ПолучитьРеквизитШапки(Накладная,"ТребуетсяМаркировка") тогда
		возврат СтруктураВозврата;
	КонецЕсли;
	
	
	Правила=ПолучитьРеквизитШапки(Накладная,"ПравилаАгрегацииЧестногоЗнака","Документ");
	если Правила=Справочники.ПравилаАгрегацииЧестногоЗнака.ПустаяСсылка() тогда
		возврат СтруктураВозврата;
	Иначе
		СтруктураВозврата.УстановленыПравилаРаботыСАгрегацией=Истина;
	КонецЕсли;
	//++Данилова Е.В. 14.01.2026 ASU-2089
	//РеквизитыПравил=ПолучитьРеквизитыШапки(Правила,"РазворачиватьАгрегациюДоШтук,ТребуетсяАгрегацияБлочков,ТребуетсяАгрегацияКоробок,ТребуетсяАгрегацияПаллет,ПриАгрегацииСворачиватьПоНаименованиюКонтрагента","Справочник");	
	СтрокаРеквизитов = "РазворачиватьАгрегациюДоШтук,ТребуетсяАгрегацияБлочков,ТребуетсяАгрегацияКоробок,ТребуетсяАгрегацияПаллет,
	|ПриАгрегацииСворачиватьПоНаименованиюКонтрагента,ФормироватьНаборКодовАгрегацииНаПаллету"; 
	РеквизитыПравил=ПолучитьРеквизитыШапки(Правила,СтрокаРеквизитов,"Справочник");	
	//--Данилова Е.В. 14.01.2026 
	ЗаполнитьЗначенияСвойств(СтруктураВозврата,РеквизитыПравил);
	возврат СтруктураВозврата;
	
КонецФункции

