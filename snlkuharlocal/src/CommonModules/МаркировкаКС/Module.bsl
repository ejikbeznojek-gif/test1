Функция СохранитьНастройкиФормыЛНДляВосстановления(ЭтаФорма) Экспорт

	МассивПанелей = Новый массив;
	
	СоответствиеИмяДоступность = Новый Соответствие; 
	
	МассивПанелей.Добавить("ДействияФормы");
	МассивПанелей.Добавить("КоманднаяПанель1");
	МассивПанелей.Добавить("КоманднаяПанель2");
	МассивПанелей.Добавить("КоманднаяПанель3");
	МассивПанелей.Добавить("кпБрэнды");
	МассивПанелей.Добавить("кпТовары");
	
	
	
	Для каждого ЭлементФормы Из ЭтаФорма.ЭлементыФормы Цикл 
		
		Если ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") 
			ИЛИ ТипЗнч(ЭлементФормы) = Тип("КнопкаКоманднойПанели") 
			ИЛИ ТипЗнч(ЭлементФормы) = Тип("Кнопка") 
			Тогда  
			 
			СоответствиеИмяДоступность.Вставить(ЭлементФормы.Имя,ЭлементФормы.Доступность);
			
		КонецЕсли;	
		
		если ТипЗнч(ЭлементФормы) = Тип("ТабличноеПоле") тогда    
			СоответствиеИмяДоступность.Вставить(ЭлементФормы.Имя,ЭлементФормы.ТолькоПросмотр);
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеВвода") или ТипЗнч(ЭлементФормы) = Тип("Флажок") тогда
			СоответствиеИмяДоступность.Вставить(ЭлементФормы.Имя,ЭлементФормы.Доступность);
		КонецЕсли;
		
		
	КонецЦикла;
	
	Для каждого ЭлементПанель Из МассивПанелей  Цикл
		
		Для каждого КнопкаПанели Из ЭтаФорма.ЭлементыФормы[ЭлементПанель].Кнопки Цикл
			
			Если ТипЗнч(КнопкаПанели) = Тип("КнопкаФормы") 
				ИЛИ ТипЗнч(КнопкаПанели) = Тип("КнопкаКоманднойПанели")
				ИЛИ ТипЗнч(КнопкаПанели) = Тип("Кнопка") Тогда
				
					
				СоответствиеИмяДоступность.Вставить(ЭлементФормы.Имя,ЭлементФормы.Доступность);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат СоответствиеИмяДоступность; 

КонецФункции // СохранитьНастройкиФормыДляВосстановления()

