Функция МожноСканироватьНоменклатуруОбычнымШКилиЧЗ(Номенклатура, ОтсканировалиМарку, СтруктураДанныхДокОснования, ПараметрыСканированияМарок, ТочноМожноСканироватьОбычныеШК = Ложь) Экспорт	
// Кельманов А.В. - ИЗМ-0000000061 - 2026.06.17 }
	
	ДокОснование = СтруктураДанныхДокОснования.ДокОснование;

	Результат = Новый Структура("Успешно, Ошибки, ПечататьКодЧЗ", Истина, Новый Массив, Ложь);	

	// Кухарь А.Ю.  19.12.2024 начало
	//ДанныеНоменклатурыЧЗ=ПроверкаНеобходимостиСканированияКодаЧЗ (Номенклатура,СтруктураДанныхДокОснования.ДатаОтгрузки,СтруктураДанныхДокОснования.ТребуетсяМаркировка,ДокОснование);
	Если ПараметрыСканированияМарок.Свойство("ОтключитьКонтрольСканирования") Тогда
		ОтключитьКонтрольСканирования = ПараметрыСканированияМарок.ОтключитьКонтрольСканирования;
	Иначе
		ОтключитьКонтрольСканирования = Ложь;
	КонецЕсли;
	
	ДанныеНоменклатурыЧЗ=ПроверкаНеобходимостиСканированияКодаЧЗ (Номенклатура,СтруктураДанныхДокОснования,ОтключитьКонтрольСканирования);	 
	// Кухарь А.Ю.  19.12.2024 конец

	ЕстьКарточкаВЧЗ = ДанныеНоменклатурыЧЗ.МожноСканироватьКодыЧЗ;
	НужноСканироватьКодЧЗ = ДанныеНоменклатурыЧЗ.НужноСканироватьКодыЧЗ;

	// Кельманов А.В. - ИЗМ-0000000061 - 2026.06.17 {
	Если ТочноМожноСканироватьОбычныеШК Тогда
		НужноСканироватьКодЧЗ = Ложь;
	КонецЕсли;
	// Кельманов А.В. - ИЗМ-0000000061 - 2026.06.17 }

	// Кухарь А.Ю.  13.02.2025 начало
	// // FBO со спайками ЧЗ 
	//НаборыЧЗбезОклейкиКомплектующих=ложь; 
	//если СтруктураДанныхДокОснования.свойство("НаборыЧЗбезОклейкиКомплектующих") тогда
	//	НаборыЧЗбезОклейкиКомплектующих=СтруктураДанныхДокОснования.НаборыЧЗбезОклейкиКомплектующих;
	//КонецЕсли;
	
	НанесениеКодовНеОбязательно = Ложь; 
	Если СтруктураДанныхДокОснования.свойство("НанесениеКодовНеОбязательно") Тогда
		НанесениеКодовНеОбязательно = СтруктураДанныхДокОснования.НанесениеКодовНеОбязательно;
	КонецЕсли;
	// Кухарь А.Ю.  13.02.2025 конец

	Если ОтсканировалиМарку Тогда //Щёлкнули марку. 
		Если ЕстьКарточкаВЧЗ Тогда
			Если НЕ (ПараметрыСканированияМарок.НужноСканироватьМарки Или ПараметрыСканированияМарок.СканироватьМаркиДляВнутреннихДокументов) Тогда
				ТекстСообщения = "В эту накладную маркировку сканировать не нужно, требуется отгрузить такой же товар, но без нанесённых кодов ЧЗ." 				
				+ ПараметрыСканированияМарок.Сообщение; 
				Результат.Ошибки.Добавить(ТекстСообщения);
			КонецЕсли;			
		Иначе			
			Результат.Ошибки.Добавить(СтрШаблон("Карточка номенклатуры: '%1'  отсканируйте обычный ШК товара.", Номенклатура));
		КонецЕсли;		
	Иначе //Щёлкнули обычный ШК, нужно проверить, возможно обычными ШК уже нельзя грузить.
		// Кухарь А.Ю.  21.05.2024 начало
		//
		Если Не НужноСканироватьКодЧЗ Тогда 
			// Кухарь А.Ю.  19.01.2025 начало
			// Если ЕстьКарточкаВЧЗ И (ПараметрыСканированияМарок.НужноСканироватьМарки или ПараметрыСканированияМарок.СканироватьМаркиДляВнутреннихДокументов)  тогда
			// Кухарь А.Ю.  13.02.2025 начало
			// // FBO со спайками ЧЗ 		
			//Если не НаборыЧЗбезОклейкиКомплектующих 
			Если Не НанесениеКодовНеОбязательно  
				// Кухарь А.Ю.  13.02.2025 конец
				
				// Кельманов А.В. - ИЗМ-0000000061 - 2026.06.17 {
				И Не ТочноМожноСканироватьОбычныеШК 
				// Кельманов А.В. - ИЗМ-0000000061 - 2026.06.17 }
				
				И ЕстьКарточкаВЧЗ 
				И (ПараметрыСканированияМарок.НужноСканироватьМарки Или ПараметрыСканированияМарок.СканироватьМаркиДляВнутреннихДокументов) 
				Тогда				
				// Кухарь А.Ю.  19.01.2025 конец
				
				ТекстСообщения	= СтрШаблон("Номенклатура %1 подлежит маркировке, обычным ШК её сканировать нельзя.
				|Отсканируйте код ЧЗ, если его нет на товаре, требуется нанесение этого кода на товар.", Номенклатура );
				
				Результат.Ошибки.Добавить(ТекстСообщения);
				Результат.ПечататьКодЧЗ = Истина;
			КонецЕсли;
		Иначе
			ТекстСообщения	= СтрШаблон("Номенклатура %1 подлежит обязательной маркировке, обычным ШК её сканировать нельзя.
			|Отсканируйте код ЧЗ, если его нет на товаре, требуется нанесение этого кода на товар.", Номенклатура );		
			Результат.Ошибки.Добавить(ТекстСообщения);
			Результат.ПечататьКодЧЗ = Истина;			
		КонецЕсли; 
		// Кухарь А.Ю.  21.05.2024 конец
		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);		
	
	Возврат Результат;
	
КонецФункции //МожноСканироватьНоменклатуруОбычнымШКилиЧЗ(Накладная, Номенклатура, ОтсканировалиМарку = Ложь) Экспорт	

Функция ПроверкаНеобходимостиСканированияКодаЧЗ (Номенклатура,СтруктураДанныхДокОснования,ОтключитьКонтрольСканирования=ложь) экспорт
	// Кухарь А.Ю.  19.01.2025 начало
	// Переделал на входящую структуру
	ДатаОтгрузки=СтруктураДанныхДокОснования.ДатаОтгрузки;
