Функция ОтработатьСканированиеКоробаЛНЛП(Знач ЛНЛПОбъект,
	Знач ДанныеМаркиЧЗ,Знач ФормироватьНовуюЭтикеткуДляКороба, ТипШК,ЗаписатьЛНЛП = ложь,ИспользоватьЛНТолькоДляНабора = Ложь) Экспорт 
	
	СтруктураРезультата = Новый Структура("Успех,КоличествоИзШК,НовыйКод,РаспечататьНовыйКод",истина,0,Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(),ложь); 
	//Данилова Е.В. 03.04.2026 MARK-3539	
	РезультатПроверкиСканКороба = ПроверитьОтсканированныйКоробЧЗ(ЛНЛПОбъект,ДанныеМаркиЧЗ.МаркаЧЗ,ФормироватьНовуюЭтикеткуДляКороба,ТипШК,ИспользоватьЛНТолькоДляНабора);
	//++Данилова Е.В. 02.04.2026  MARK-3539
	Если ИспользоватьЛНТолькоДляНабора  Тогда
	
		РезультатПроверкиСканКороба.ЕстьЛПЛН = Ложь; 	
	   	РезультатПроверкиСканКороба.АгрегацияПроверена  = Истина; 
	КонецЕсли;
	//--Данилова Е.В. 02.04.2026 
	Если РезультатПроверкиСканКороба.ЕстьЛПЛН Тогда
		
		СтруктураРезультата.Успех = Ложь; 	
		Возврат СтруктураРезультата; 	
		
	КонецЕсли;				
	Если НЕ РезультатПроверкиСканКороба.ВложенияПроверены Тогда
		
		Сообщить("Во вложениях короба найден ЧЗ отгруженный или списанный!!! Отсканируйте другой короб! ");					
		СтруктураРезультата.Успех = Ложь;
		Возврат СтруктураРезультата; 
	КонецЕсли;
	
	Если НЕ РезультатПроверкиСканКороба.АгрегацияПроверена Тогда
		
		Сообщить("Отсканированный короб расформирован!!! Будет сформирован новый код коробки, распечатайте и отсканируйте его!");
		
		//Если ЭтоНовый() Тогда
		Если ЗаписатьЛНЛП Тогда 	
			
			ЛНЛПОбъект.Записать(); 	
			
		КонецЕсли;
		
		НовыйАгрегационныйКод = СформироватьНовыйАгрегационныйКодКоробаДляСканирования(ЛНЛПОбъект.ссылка,ЛНЛПОбъект.ДокОснование,ДанныеМаркиЧЗ.МаркаЧЗ);
		
		СтруктураРезультата.НовыйКод = НовыйАгрегационныйКод;
		СтруктураРезультата.РаспечататьНовыйКод = ЗначениеЗаполнено(НовыйАгрегационныйКод); 
		
		Возврат СтруктураРезультата; 			 
		
	КонецЕсли;
	
	Если РезультатПроверкиСканКороба.КоличествоЧЗ > 0  Тогда
		
		ДанныеМаркиЧЗ.Количество = РезультатПроверкиСканКороба.КоличествоЧЗ; 	
		
		КоличествоИзШК =  ДанныеМаркиЧЗ.Количество;
		
		СтруктураРезультата.КоличествоИзШК = КоличествоИзШК; 
	КонецЕсли; 
	
	Возврат СтруктураРезультата; 

КонецФункции 

//Данилова Е.В. 03.04.2026 MARK-3539
Функция ПроверитьОтсканированныйКоробЧЗ(ЛНЛПОбъект, Знач МаркаЧЗ,Знач ФормироватьНовуюЭтикеткуДляКороба, ТипШК,ИспользоватьЛНТолькоДляНабора = Ложь)  Экспорт
	СтруктураПроверки = Новый Структура("АгрегацияПроверена,ВложенияПроверены,ЕстьЛПЛН,КоличествоЧЗ",истина, истина,ЛОЖЬ,0); 
	Если ТипШК <> Перечисления.ТипыШтрихКодов.Коробка Тогда
		
		Возврат СтруктураПроверки; 		
		
	КонецЕсли;
	ДокОснование = ЛНЛПОбъект.ДокОснование; 
	ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ДокОснование);		
	Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистНабора") Тогда 
		ВидОбъекта = "ЛистНабора"; 
	ИначеЕсли ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистПереукладки") Тогда
		ВидОбъекта = "ЛистПереукладки";
	КонецЕсли;
	//++Данилова Е.В. 30.03.2026 SNL-153 
	//Если НЕ ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков 
	//	И ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок  Тогда
	Если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок  Тогда
		//--Данилова Е.В. 30.03.2026 
		
		Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистНабора")
			И ЕстьЛПСАгрегацией(ДокОснование) тогда
			Сообщить("Агрегация начата в листах переукладки");
			СтруктураПроверки.ЕстьЛПЛН = Истина; 
			возврат СтруктураПроверки;
		КонецЕсли;
		
		Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистПереукладки")
			И ОбщегоНазначения_ПИ.ЕстьЛНСКодамиАгрегации(ДокОснование,ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок,ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков) тогда
			Сообщить("Агрегация начата в листах набора");
			СтруктураПроверки.ЕстьЛПЛН = Истина; 
			возврат СтруктураПроверки;
		КонецЕсли;
		
		МассивВложенныхШК = МаркаЧЗ.ВложенныеШтрихкоды.ВыгрузитьКолонку("Штрихкод");
		Если МассивВложенныхШК.Количество() = 0 И НЕ ФормироватьНовуюЭтикеткуДляКороба Тогда
			
			ВложенияПроверены = истина;	
			
		Иначе 
			СтруктураВложенияТары = ПолучитьСтруктуруВложенныхКодов(ТипШК, МаркаЧЗ.Наименование, ВидОбъекта);
			
			Если Не СтруктураВложенияТары.Успех Тогда
				
				ВложенияПроверены = Ложь;
				СтруктураПроверки.ВложенияПроверены = Ложь;
				Сообщить(СтрСоединить(СтруктураВложенияТары.Ошибки, Символы.ПС));
				Возврат СтруктураПроверки;  
			Иначе 
				ВложенияПроверены = истина; 		
			КонецЕсли; 
		КонецЕсли;
		КМНаПереклейку = НЕ КодАгрегатаБезПереклейки(МаркаЧЗ,ДокОснование) И ФормироватьНовуюЭтикеткуДляКороба;
			
		Если НЕ КМНаПереклейку 
			//++Данилова Е.В. 03.04.2026 MARK-3539
			И НЕ ИспользоватьЛНТолькоДляНабора Тогда 
			//--Данилова Е.В. 03.04.2026 
			
			ДобавитьВТЧДляДальнейшейАгрегации(ЛНЛПОбъект,МаркаЧЗ,МаркаЧЗ);
			
		КонецЕсли;
			
		КоличествоПоКоробкеИзЧЗ = КоличествоВложенныхШтукПоМарке(МаркаЧЗ); //МассивВложенныхШК.Количество(); 
		
		Если НЕ ЗначениеЗаполнено(МаркаЧЗ.Владелец) Тогда
			
			КоличествоПоКоробкеИзЧЗ = 0; 	
			
		КонецЕсли;
		
		Возврат  Новый Структура("АгрегацияПроверена,ВложенияПроверены,ЕстьЛПЛН,КоличествоЧЗ",НЕ КМНаПереклейку, ВложенияПроверены,ЛОЖЬ,КоличествоПоКоробкеИзЧЗ);
	Иначе 
		Возврат СтруктураПроверки;  
	КонецЕсли; 
	
КонецФункции // ОтработатьСканированиеКоробаЧЗ() 

Процедура ДобавитьВТЧДляДальнейшейАгрегации(ЛНЛПОбъект, Знач НовыйКодКоробки, Знач ИсходныйКодКоробки) Экспорт
	
	Если НовыйКодКоробки = ИсходныйКодКоробки Тогда		
		
		Если  ЛНЛПОбъект.ШтрихкодыКоробокДляАгрегации.Найти(ИсходныйКодКоробки,"НовыйКодКоробки") <> неопределено Тогда
			Возврат; 
		Конецесли; 
		
	КонецЕсли;
	
	НоваяСтрокаДляАгрегации 					= ЛНЛПОбъект.ШтрихкодыКоробокДляАгрегации.Добавить(); 
	НоваяСтрокаДляАгрегации.НовыйКодКоробки 	= НовыйКодКоробки; 
	НоваяСтрокаДляАгрегации.ИсходныйКодКоробки 	= ИсходныйКодКоробки;
	
КонецПроцедуры 

Функция СформироватьНовыйАгрегационныйКодКоробаДляСканирования(Знач Ссылка,Знач Докоснование, Знач МаркаЧЗ) Экспорт
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();                  
	рБронирования= Документы.МаркировкаТоваровИСМП.ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста(Ссылка,ДокОснование, Перечисления.ТипыШтрихКодов.Коробка);
	ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", "Документы.МаркировкаТоваровИСМП.ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста (ЛН)", , , , ВремяВыполнения);    
	ПолучаемыйКодАгрегации = Неопределено;
	если не рБронирования.Успешно тогда            
		Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();      
		рБронирования = Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляЛН(Ссылка, Перечисления.ТипыШтрихКодов.Коробка,МаркаЧЗ.ТипУпаковки);
	иначе
		ПолучаемыйКодАгрегации = рБронирования.Данные[0];
	КонецЕсли;
	
	ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", "Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляЛН (ЛН)", , , , ВремяВыполнения);
	
	Если ТипЗнч(ссылка) = Тип("ДокументСсылка.ЛистНабора") Тогда 
		ВидОбъекта = " Документ.ЛистНабора "; 
	ИначеЕсли ТипЗнч(ссылка) = Тип("ДокументСсылка.ЛистПереукладки") Тогда
		ВидОбъекта = " Документ.ЛистПереукладки ";
	КонецЕсли;
	
	Если рБронирования.Успешно тогда	
		
		если ПолучаемыйКодАгрегации = Неопределено тогда
			ПолучаемыйКодАгрегации = рБронирования.Данные;
		КонецЕсли;
				
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЛистНабораПереукладки.КодАгрегации КАК КодАгрегации,
		|	ЛистНабораПереукладки.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабораПереукладки
		|ГДЕ
		|	ЛистНабораПереукладки.Проведен
		|	И ЛистНабораПереукладки.КодАгрегации = &КодАгрегации
		|	И ЛистНабораПереукладки.Ссылка <> &Ссылка";
		запрос.УстановитьПараметр("КодАгрегации",ПолучаемыйКодАгрегации);
		запрос.УстановитьПараметр("Ссылка",Ссылка);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора",ВидОбъекта); 
		Выборка=запрос.Выполнить().Выбрать();
		пока выборка.Следующий() Цикл 
			Сообщить(СтрШаблон("Обнаружен дубль кода %1 в %2",ПолучаемыйКодАгрегации,выборка.ссылка));
			Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();	
		КонецЦикла;
		//
		//КодОтсканирован = РаспечататьНовыйАгрегационныйКод(ПолучаемыйКодАгрегации,МаркаЧЗ);
		//
		//Если Не КодОтсканирован Тогда
		//	
		//	Сообщить("Код не отсканирован!!!"); 	
		//	
		//КонецЕсли;
		
		Возврат  ПолучаемыйКодАгрегации; 
		
	Иначе
		МаркировкаКС.ВывестиОшибки(рБронирования);	
		Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();;
	КонецЕсли;
	
	
КонецФункции 

Функция РаспечататьНовыйАгрегационныйКод(Знач КодАгрегацииНовый,Знач МаркаЧЗ,Знач Докоснование, Знач ссылка)  Экспорт	
	
	ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(ДокОснование); 
	
	ПечатьНовойКомпонентой=ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(ДопПараметрыНакладной.Получатель,"НоваяПечатьКоробов",Ложь);
	Если НЕ ПечатьНовойКомпонентой Тогда 
		
		НомерКоробки="";
		
		ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать(); 
		ИмяМакета="Этикетка_40_58_Остатки";  
		Макет = ОбработкаПечати.ПолучитьМакет(ИмяМакета);
		
		ТД = Новый ТабличныйДокумент;
		ТД.ОтображатьСетку		= Ложь;
		ТД.ОтображатьЗаголовки	= Ложь;	
		ТД.ИмяПараметровПечати	= "ПараметрыПечати_КМ_"+ИмяМакета;	
		
		ДанныеДляПечати	= Неопределено;
		
		ШтукЧЗВКоробке = КоличествоВложенныхШтукПоМарке(МаркаЧЗ); //МаркаЧЗ.ВложенныеШтрихкоды.Количество();
		
		ДопПараметры = Новый Структура("Артикул", "");
		
		ДопПараметры.Вставить("ОтображатьТекст",ложь);				  
		Строкадата = строка(Докоснование.Дата);  		
		СтрокаРнк  = Строка(Докоснование);     	
		сТРОКАРНК = СтрЗаменить(СтрокаРнк,"от","");
		сТРОКАРНК = СтрЗаменить(СтрокаРнк,Строкадата,"");	
		ДопПараметры.Вставить("Рнк",сТРОКАРНК);	   
		ДопПараметры.Вставить("ГруппаТовара",	Докоснование.ГруппыТоваров);
		ДопПараметры.Вставить("Комментарий",Докоснование.Комментарий);
		ДопПараметры.Вставить("контрагент",Докоснование.контрагент);
		//ПечататьCode128ДляАгрегаций = ПолучитьЗначРеквСпр(ДокОснование.Контрагент,"ПечататьCode128ДляАгрегаций");
		ТипШКАгрегации = ПолучитьРеквизитШапки(ДокОснование.Контрагент,"ТипШКАгрегации","Справочник");
		ПечататьCode128ДляАгрегаций = ТипШКАгрегации = Перечисления.ТипыКодировокШК.Code128;	
		АгрегацияВCode128 = Ложь;
		Если ПечататьCode128ДляАгрегаций <> Неопределено Тогда
			АгрегацияВCode128 = ПечататьCode128ДляАгрегаций;	
		КонецЕсли;
		
		Если АгрегацияВCode128 Тогда 
			ДопПараметры.Вставить("АгрегацииВCode128",АгрегацияВCode128);
		иначе
			ДопПараметры.Вставить("ДобавлятьСкобочкиВТекст",Истина); 
		КонецЕсли;
		
		Область = ОбработкаПечати.СформироватьКА(Макет, ПолучитьРеквизитШапки(КодАгрегацииНовый,"Наименование","справочник"), НомерКоробки, ШтукЧЗВКоробке, ДопПараметры);
		ТД.Вывести(Область); 
		//++Данилова Е.В. 03.03.2026 SNL-153
		Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда 
			тд.Показать();
		Иначе
			ТД.Напечатать(); 
		КонецЕсли;
		//--Данилова Е.В. 03.03.2026 
	Иначе 
			
		КолКоробок= "";
		МожноВыводитьОбщееКоличествоМест = ЛОЖЬ;
		
		СтрокаРеквизитовСсылка = "Сканировщик,ГруппыТоваров"; 
		Реквизитыссылки			=	ПолучитьРеквизитыШапки(ссылка,СтрокаРеквизитовСсылка,"Документ");
		Сканировщик = Реквизитыссылки.Сканировщик; 
		ГруппыТоваров = Реквизитыссылки.ГруппыТоваров; 
		
		СтрокаРеквизитовДокОснования	=	"Контрагент,Контрагент.Код,Контрагент.Наименование,Контрагент.Родитель.Код,
		|СостояниеНакладной,КоличествоКоробок,Номер,
		|ПунктДоставки,ПунктДоставки.Регион,ПунктДоставки.Наименование,ПунктДоставки.НомерМагазина,ПунктДоставки.АдресПолучателя,ПунктДоставки.Телефоны,
		|РайонДоставки.Сектор.Наименование,РайонДоставки.Сектор,НомерЗаказа,
		|Организация.Наименование,Организация.Телефоны,Организация.ЮридическийАдрес";
		РеквизитыДокОснования			=	ПолучитьРеквизитыШапки(ДокОснование,СтрокаРеквизитовДокОснования,"Документ");	     	
		КодКонтрагента					=	РеквизитыДокОснования.Контрагент_Код; 
		КодКонтрагентаРодителя			=	РеквизитыДокОснования.Контрагент_Родитель_Код;  
		СостояниеНакладной				=	РеквизитыДокОснования.СостояниеНакладной;        
		КоличествоКоробок				=	РеквизитыДокОснования.КоличествоКоробок; 	
		ТабДок	= Новый ТабличныйДокумент;
		Макет=Обработки.НаклейкиНаКоробки.ПолучитьМакет("ШКНоваяКомпонента");
		
		НаборПолей = Новый Структура;
		сектор = Лев(РеквизитыДокОснования.РайонДоставки_Сектор_Наименование,2);
		НаборПолей.Вставить("сектор",РеквизитыДокОснования.РайонДоставки_Сектор);	
		НаборПолей.Вставить("Отправитель",РеквизитыДокОснования.Организация_Наименование);
		НаборПолей.Вставить("Телефон",РеквизитыДокОснования.Организация_Телефоны);	
		НаборПолей.Вставить("ЮрАД",РеквизитыДокОснования.Организация_ЮридическийАдрес);		 
		
		Регион=Неопределено; 
		АдресДляЭтикеткиИзРег ="";
		Получатель	=РеквизитыДокОснования.Контрагент_наименование;
		Регион= РеквизитыДокОснования.ПунктДоставки_Регион;	
		Грузополучатель=РеквизитыДокОснования.Контрагент;		
		АдресДляЭтикеткиИзРег=ПрочитатьЗначениеРеквизитаПНКПРМРНК("АдресДляЭтикетки",ДокОснование);		
		НаборПолей.Вставить("ад", РеквизитыДокОснования.ПунктДоставки_АдресПолучателя+ " тел.: "+РеквизитыДокОснования.ПунктДоставки_Телефоны);
		если ЗначениеЗаполнено(АдресДляЭтикеткиИзРег) тогда
			НаборПолей.ад=АдресДляЭтикеткиИзРег;
		КонецЕсли;     
		
		НаборПолей.Вставить("Пользователь",Строка(Сканировщик)+?(ПараметрыСеанса.Пользователь.ФизЛицо=Сканировщик,"","\"+Строка(ПараметрыСеанса.Пользователь.ФизЛицо)));	
		НаборПолей.Вставить("Номер", РеквизитыДокОснования.Номер);	
		НаборПолей.Вставить("Получатель",Получатель);
		НаборПолей.Вставить("Регион",Регион);   
		 
		
		НужноОбрезать=Ложь; 	
		
		
		// Кухарь А.Ю. 01.05.2025 начало
		ДопПараметрыПечати=новый Структура("КодКонтрагента,КодКонтрагентаРодителя,КолКоробок,МожноВыводитьОбщееКоличествоМест,НаборПолей,НужноОбрезать,ТабДок",
		КодКонтрагента,КодКонтрагентаРодителя,КолКоробок,МожноВыводитьОбщееКоличествоМест,НаборПолей,НужноОбрезать,ТабДок);        
		
		НомерКоробки = ""; 
		ДопПараметрыПечати.Вставить("ТребуетсяАгрегацияКоробок",истина);     
		ДопПараметрыПечати.Вставить("НомерКоробки",НомерКоробки);    
		
		ДопПараметрыПечати.Вставить("ОбработкаПечати", Обработки.ПечатьЭтикетокЧЗ.Создать());     
		
		если ЗначениеЗаполнено(КодАгрегацииНовый) тогда
			ТипШКАгрегации = ПолучитьРеквизитШапки(РеквизитыДокОснования.Контрагент,"ТипШКАгрегации","Справочник"); 
			если ТипШКАгрегации = Перечисления.ТипыКодировокШК.Code128 тогда   
				ДопПараметрыПечати.Вставить("ПечататьCode128ДляАгрегаций",Истина);
			иначе
				ДопПараметрыПечати.Вставить("ПечататьCode128ДляАгрегаций",ложь);
			КонецЕсли;
		КонецЕсли;	
		
		ШтукЧЗВКоробке = КоличествоВложенныхШтукПоМарке(МаркаЧЗ); //МаркаЧЗ.ВложенныеШтрихкоды.Количество();
		ПечатьЭтикеткиОнлайнНаСтрокуКороба(ДопПараметрыПечати,ШтукЧЗВКоробке,ГруппыТоваров,ссылка,КодАгрегацииНовый, Докоснование);
		
		ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_НовыйАгрегационныйКод_НаклейкиНаКоробки";
				
		ТабДок.ОтображатьСетку 		= Ложь;	
		ТабДок.ОтображатьЗаголовки 	= Ложь;	
		ТабДок.ПолеСверху=0; ТабДок.ПолеСнизу=0; ТабДок.ПолеСлева=3; ТабДок.ПолеСправа=0;
		
		//++Данилова Е.В. 03.03.2026 SNL-153
		Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда 
			ТабДок.Показать("Наклейки "+ РеквизитыДокОснования.Номер);
		Иначе
			ТабДок.Напечатать(); 
		КонецЕсли; 	
		//ТабДок.Показать("Наклейки "+ РеквизитыДокОснования.Номер);
		//--Данилова Е.В. 03.03.2026
	КонецЕсли; 
	
	//ОжидаемыйКодОтсканированный = КодАгрегацииНовый;
	//РаспакованныйШК = МаркаЧЗ; 
	
	Возврат Истина; 
	
	
КонецФункции 

Процедура ПечатьЭтикеткиОнлайнНаСтрокуКороба(ДопПараметрыПечати,КоличествоЧЗШтук,ГруппыТоваров,ссылка, КодАгрегацииНовый, ДокОснование) 
	
	КодКонтрагента 						=	ДопПараметрыПечати.КодКонтрагента; 
	КодКонтрагентаРодителя 				=	ДопПараметрыПечати.КодКонтрагентаРодителя;
	КолКоробок 							= 	ДопПараметрыПечати.КолКоробок;
	МожноВыводитьОбщееКоличествоМест 	= 	ДопПараметрыПечати.МожноВыводитьОбщееКоличествоМест;
	НаборПолей							= 	ДопПараметрыПечати.НаборПолей;
	НужноОбрезать 						= 	ДопПараметрыПечати.НужноОбрезать;
	ТабДок 								= 	ДопПараметрыПечати.ТабДок;
	ТребуетсяАгрегацияКоробок 			=	ДопПараметрыПечати.ТребуетсяАгрегацияКоробок;              
	НомерКоробки						=	ДопПараметрыПечати.НомерКоробки;	
	ОбработкаПечати						= 	ДопПараметрыПечати.ОбработкаПечати; 
	Номенклатура						= 	"Номенклатура: Сборная ("+ ГруппыТоваров+")"; 
	ШтукВКоробе							=	КоличествоЧЗШтук; 
	
	Лист=Ссылка;
	Макет=Обработки.НаклейкиНаКоробки.ПолучитьМакет("ШКНоваяКомпонента");
	
	ОбработкаФормированияКартинки=Обработки.СформироватьКартинкуКодаШКQR.Создать();
	СтруктураДанныхКомпонентыПечати=ОбработкаФормированияКартинки.ПолучитьКомпонентуФормированияDataMatrixКода();	
	если не СтруктураДанныхКомпонентыПечати.Успех тогда 
		Сообщить(СтруктураДанныхКомпонентыПечати.Ошибки);
		возврат;
	КонецЕсли;	
	
	ОблЭтикетка=Макет.ПолучитьОбласть("Строка|Этикетка"); 
	ПечататьCode128ДляАгрегаций 		= 	ДопПараметрыПечати.ПечататьCode128ДляАгрегаций;  
	
	
	ИмяОбластиНоменклатура =  "ОбластьНоменклатура";
	ИмяОбластиКороба =  "ОбластьКороба";
	
	попытка
		Рисунок=ОблЭтикетка.Рисунки.ШтрихКод;     
	Исключение  
		СообщитьИзМодуля("В области макета не обнаружено рисунка с именем ШтрихКод");
		возврат;
	КонецПопытки;    
	
	
	//если ШтукВКоробе>0 тогда
	//	НаборПолей.Вставить("ШтукВЛН"," - "+ШтукВКоробе+"шт.");	
	//КонецЕсли;
	
	
	
	ДопПараметры = новый Структура;
	
	//КодАгрегации=ПолучитьРеквизитШапки(Лист,"КодАгрегации","Документ");
	Если ПечататьCode128ДляАгрегаций Тогда 
		ДопПараметры.Вставить("АгрегацииВCode128",ПечататьCode128ДляАгрегаций);
	иначе
		ДопПараметры.Вставить("ДобавлятьСкобочкиВТекст",Истина); 
	КонецЕсли;		 
	ДопПараметры.Вставить("НужнаТолькоКартинка",Истина);   
	ДопПараметры.Вставить("ОтображатьТекст",ложь); 
	ДопПараметры.Вставить("ВысотаРисунка",Рисунок.Высота);
	ДопПараметры.Вставить("ШиринаРисунка",Рисунок.Ширина);		 
	Рисунок.Картинка = ОбработкаПечати.СформироватьКА(Макет, ПолучитьРеквизитШапки(КодАгрегацииНовый,"Наименование","справочник"), 0, 0, ДопПараметры);  
	
	ПрефиксКодаАгрегации="";	
	если  ДопПараметры.Свойство("ДобавлятьСкобочкиВТекст") тогда
		если ДопПараметры.ДобавлятьСкобочкиВТекст=Истина тогда
			ПрефиксКодаАгрегации="(00)";		
		КонецЕсли;
	КонецЕсли;
	НаборПолей.вставить("ШтрихКод",ПрефиксКодаАгрегации+КодАгрегацииНовый);	
	
	ОблЭтикетка.Параметры.Заполнить(НаборПолей);	 	    	
	ОблЭтикетка.Параметры.номенклатура=номенклатура;  	
	
	попытка
		если СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>48 и НужноОбрезать тогда
			ОблЭтикетка.Параметры.Номенклатура=СтрЗаменить(ОблЭтикетка.Параметры.Номенклатура,"АРТ:","");
		КонецЕсли;
	Исключение
	КонецПопытки; 
	ОблЭтикетка.Параметры.ВсегоКоробов=КолКоробок;
	
	ОбластьНоменклатура=ОблЭтикетка.Области.Найти(ИмяОбластиНоменклатура); 
	если ОбластьНоменклатура<>Неопределено тогда
		если СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>70 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,5);
		иначеесли СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>50 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,6);
		иначеесли СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>40 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,7);
		КонецЕсли;
	КонецЕсли;         
	
	ОблЭтикетка.Параметры.НомерКороба=НомерКоробки;			
	
	ОбластьКороба=ОблЭтикетка.Области.Найти(ИмяОбластиКороба); 
	
	если МожноВыводитьОбщееКоличествоМест и облЭтикетка.Параметры.НомерКороба=КолКоробок  тогда			
		ОблЭтикетка.Параметры.ВсегоКоробов=КолКоробок;
	иначе       
		если ОбластьКороба<>Неопределено тогда
			ОбластьКороба.Текст=СтрЗаменить(ОбластьКороба.Текст,"из","");         
		КонецЕсли;
	КонецЕсли;
	
	
	Если КодКонтрагента = "EKF-0301" или КодКонтрагента = "SSR-1593" или КодКонтрагентаРодителя="SSR-7156" тогда	
		АдресИзРегистра=ПрочитатьЗначениеРеквизитаПНКПРМРНК("АдресДляЭтикетки",ДокОснование);
		если ЗначениеЗаполнено(АдресИзРегистра) тогда
			ОблЭтикетка.Параметры.АД=АдресИзРегистра;
		КонецЕсли;
		ОблЭтикетка.Параметры.НомерЗаказаЭтикетка=ДокОснование.НомерЗаказа;
		ОблЭтикетка.Параметры.Регион="";
		ОблЭтикетка.Область("ГородЗаголовок").Текст="Заказ №";
	КонецЕсли;   
	
	ТабДок.Вывести(ОблЭтикетка);
	
КонецПроцедуры

Функция КоличествоВложенныхШтукПоМарке(Знач МаркаЧЗ) Экспорт

	 ТЗВложенные =  ПолучитьВложенныеШК(МаркаЧЗ);
	 
	 Возврат ТЗВложенные.ВыгрузитьКолонку("Штрихкод").Количество(); 

КонецФункции // КоличествоВложенныхШтукПоМарке()

Функция ПроверитьОтсканированныйБлочокЧЗ(ЛНЛПОбъект, Знач МаркаЧЗ,ТипШК)  Экспорт
	СтруктураПроверки = Новый Структура("ВложенияПроверены,ЕстьЛПЛН,КоличествоЧЗ",истина,ЛОЖЬ,0); 
	Если ТипШК <> Перечисления.ТипыШтрихКодов.Блочок Тогда
		
		Возврат СтруктураПроверки; 		
		
	КонецЕсли;
	ДокОснование = ЛНЛПОбъект.ДокОснование; 
	ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(ДокОснование);		
	Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистНабора") Тогда 
		ВидОбъекта = "ЛистНабора"; 
	ИначеЕсли ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистПереукладки") Тогда
		ВидОбъекта = "ЛистПереукладки";
	КонецЕсли;
	Если ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков  Тогда		
		
		Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистНабора")
			И ЕстьЛПСАгрегацией(ДокОснование) тогда
			Сообщить("Агрегация начата в листах переукладки");
			СтруктураПроверки.ЕстьЛПЛН = Истина; 
			возврат СтруктураПроверки;
		КонецЕсли;
		
		Если ТипЗнч(ЛНЛПОбъект) = Тип("ДокументОбъект.ЛистПереукладки")
			И ОбщегоНазначения_ПИ.ЕстьЛНСКодамиАгрегации(ДокОснование,ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок,ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков) тогда
			Сообщить("Агрегация начата в листах набора");
			СтруктураПроверки.ЕстьЛПЛН = Истина; 
			возврат СтруктураПроверки;
		КонецЕсли;
		
		МассивВложенныхШК = МаркаЧЗ.ВложенныеШтрихкоды.ВыгрузитьКолонку("Штрихкод");
		Если МассивВложенныхШК.Количество() = 0 Тогда
			
			Сообщить("Вложения по коду ЧЗ не найдены"); 
			СтруктураПроверки.ВложенияПроверены = Ложь;
			
			Возврат СтруктураПроверки;
		Иначе 
			СтруктураВложенияТары = ПолучитьСтруктуруВложенныхКодов(ТипШК, МаркаЧЗ.Наименование, ВидОбъекта);
			
			Если Не СтруктураВложенияТары.Успех Тогда
				
				ВложенияПроверены = Ложь;
				СтруктураПроверки.ВложенияПроверены = Ложь;
				Сообщить(СтрСоединить(СтруктураВложенияТары.Ошибки, Символы.ПС));
				Возврат СтруктураПроверки;  
			Иначе 
				ВложенияПроверены = истина; 		
			КонецЕсли; 
		КонецЕсли;
					
		КоличествоПоКоробкеИзЧЗ = КоличествоВложенныхШтукПоМарке(МаркаЧЗ); //МассивВложенныхШК.Количество(); 
		
		Если НЕ ЗначениеЗаполнено(МаркаЧЗ.Владелец) Тогда
			
			КоличествоПоКоробкеИзЧЗ = 0; 	
			
		КонецЕсли;
		СтруктураПроверки.ВложенияПроверены = ВложенияПроверены;
		СтруктураПроверки.КоличествоЧЗ = КоличествоПоКоробкеИзЧЗ; 
		
		Возврат  СтруктураПроверки; 
	Иначе 
		Возврат СтруктураПроверки;  
	КонецЕсли; 
	
КонецФункции // ОтработатьСканированиеКоробаЧЗ() 

Функция ОтработатьСканированиеБлочкаЛНЛП(Знач ЛНЛПОбъект, Знач ДанныеМаркиЧЗ,ТипШК,ЗаписатьЛНЛП = ложь) Экспорт 
	
	СтруктураРезультата = Новый Структура("Успех,КоличествоИзШК",истина,0); 
	Если НЕ ДанныеМаркиЧЗ.СканировалиКодЧЗ Тогда
	
		Возврат СтруктураРезультата; 	
	
	КонецЕсли;
	РезультатПроверкиСканКороба = ПроверитьОтсканированныйБлочокЧЗ(ЛНЛПОбъект,ДанныеМаркиЧЗ.МаркаЧЗ,ТипШК);
	
	Если РезультатПроверкиСканКороба.ЕстьЛПЛН Тогда
		
		СтруктураРезультата.Успех = Ложь; 	
		Возврат СтруктураРезультата; 	
		
	КонецЕсли;				
	Если НЕ РезультатПроверкиСканКороба.ВложенияПроверены Тогда
		
		Сообщить("Во вложениях короба найден ЧЗ отгруженный или списанный!!! Отсканируйте другой короб! ");					
		СтруктураРезультата.Успех = Ложь;
		Возврат СтруктураРезультата; 
	КонецЕсли;	
		
	Если РезультатПроверкиСканКороба.КоличествоЧЗ > 0  Тогда
		
		ДанныеМаркиЧЗ.Количество = РезультатПроверкиСканКороба.КоличествоЧЗ; 	
		
		КоличествоИзШК =  ДанныеМаркиЧЗ.Количество;
		
		СтруктураРезультата.КоличествоИзШК = КоличествоИзШК; 
	КонецЕсли; 
	
	Возврат СтруктураРезультата; 

КонецФункции 

