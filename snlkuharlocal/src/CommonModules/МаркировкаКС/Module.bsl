Функция ПроверитьВозможностьВозвратаВработу(Знач ЛНОбъект) Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	МаркировкаТоваровИСМП.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|ГДЕ
		|	МаркировкаТоваровИСМП.Проведен
		|	И МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
		|	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
		|	И МаркировкаТоваровИСМП.Статус В(&Статусы)";
	
	Статусы = Новый Массив; 
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.Обрабатывается);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.Обработан);
	
	Запрос.УстановитьПараметр("ДокументОснование", ЛНОбъект.ДокОснование);
	Запрос.УстановитьПараметр("Статусы", Статусы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Пустой(); 	

КонецФункции // ПроверитьВозможностьВозвратаВработу()

