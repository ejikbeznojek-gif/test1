		ОшибкиИст = Результат2;
	Иначе
		ОшибкиИст = Результат2.Ошибки;
	КонецЕсли; 
	
	Если ТипЗнч(Результат1) = Тип("Массив") Тогда
		ОшибкиПол = Результат1;
	Иначе
		ОшибкиПол = Результат1.Ошибки;
	КонецЕсли; 
	
	Для Каждого Ошибка Из ОшибкиИст Цикл
		ОшибкиПол.Добавить(Ошибка);
	КонецЦикла;
КонецФункции //ДобавитьОшибки(Результат1, Результат2)	

