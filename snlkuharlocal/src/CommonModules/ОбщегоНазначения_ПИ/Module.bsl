// Кухарь А.Ю. 24.08.2021 начало
Функция ПолучитьМассивДопОбработок (Документ,ФильтрПоДО=Неопределено) экспорт
	если ТипЗнч(Документ) = Тип("ДокументСсылка.РасходнаяНакладная") тогда
		Ссылка=Документ;	
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаданиеНабора") тогда
		Ссылка=Документ.Накладная;
	Иначе
		Ссылка=Документ.ДокОснование;
	КонецЕсли;
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ различные
	|	РасходнаяНакладнаяДопОбработки.ВидДопОбработки КАК ВидДопОбработки
	|ИЗ
	|	Документ.РасходнаяНакладная.ДопОбработки КАК РасходнаяНакладнаяДопОбработки
	|ГДЕ
	|	РасходнаяНакладнаяДопОбработки.Ссылка = &Ссылка";
	// Кухарь А.Ю. 24.08.2021 начало
	//
	если ФильтрПоДО<>Неопределено тогда
		Запрос.Текст=СтрЗаменить(запрос.Текст,
		"РасходнаяНакладнаяДопОбработки.Ссылка = &Ссылка",
		"РасходнаяНакладнаяДопОбработки.Ссылка = &Ссылка и РасходнаяНакладнаяДопОбработки.ВидДопОбработки В (&ФильтрПоДО)");
		Запрос.УстановитьПараметр("ФильтрПоДО",ФильтрПоДО);
	КонецЕсли;
	// Кухарь А.Ю. 24.08.2021 конец
	
	запрос.УстановитьПараметр("Ссылка",Ссылка);
	Возврат запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВидДопОбработки");
КонецФункции
