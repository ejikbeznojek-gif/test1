// SNL-73
Функция ПолучитьПрефиксПоДатеИУзлу (Знач ДатаПрефикса, Знач Узел) экспорт 
	
	КодУзла = ПолучитьРеквизитШапки(Узел,"Код","ПланОбмена");
	ПоследнийСимволКодаУзла = Прав(КодУзла,1);   
	СтрокаСимволов="ABCDEFGHIJKLMNOPQRSTUVWXYZ";    
	СтрокаЧисел="0123456789";   
	если СтрНайти(СтрокаЧисел,ПоследнийСимволКодаУзла) > 0 тогда
		СимволЭтоЧисло = Истина;
	Иначе
		СимволЭтоЧисло = ложь;
	КонецЕсли;           
	
	если СимволЭтоЧисло тогда     
		СтрокаПоиска = СтрокаЧисел;
		КоличествоВозможныхСимволов = 10;
	иначе
		СтрокаПоиска = СтрокаСимволов;
		КоличествоВозможныхСимволов = 26;
	КонецЕсли;          
	
	ТекМесто = СтрНайти(СтрокаПоиска,ПоследнийСимволКодаУзла); 		
	
	СтартовыйГод = 2025;
	ТекущийГод = Год(ДатаПрефикса); 
	если ТекущийГод = СтартовыйГод тогда  //После 2025 можно удалять
		если КодУзла = "SNL" тогда 
			Возврат "SSP";
		иначе
			возврат КодУзла; 
		КонецЕсли;
	КонецЕсли;
	ДельтаЛет = ТекущийГод - СтартовыйГод; 
	СимволОтНачалаСроки = ТекМесто + ДельтаЛет;
	КоличествоПроходов = Цел((СимволОтНачалаСроки-1)/КоличествоВозможныхСимволов);  
	СимволОтНачалаСроки = СимволОтНачалаСроки - КоличествоПроходов*КоличествоВозможныхСимволов;
	ПоследняяНоваяБуква = Сред(СтрокаПоиска,СимволОтНачалаСроки,1);    
	
	
	возврат Лев(КодУзла,СтрДлина(КодУзла)-1)+ПоследняяНоваяБуква;     
	
КонецФункции  

