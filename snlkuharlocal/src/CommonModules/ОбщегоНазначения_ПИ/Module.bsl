//Тимофеев Ю.А. Изменение 0000000098 ВГХ Номенклатуры
Функция ВГХНоменклатуры (ВыбТовар) Экспорт
	
	НужныйРодитель = ВыбТовар.Родитель;
	
	Если Ложь Тогда
		НужныйРодитель=Справочники.Номенклатура.СоздатьГруппу();
	КонецЕсли;
	
	//Если это не товар
	Если НужныйРодитель.ВидНоменклатуры<>Перечисления.ВидыНоменклаутры.Товар Тогда
		Возврат Ложь;
	КонецЕсли;
	
	//получим данные из регистра
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВГХ.ВидВГХ КАК ВидВГХ,
		|	ВГХ.ЗначениеВГХ КАК ЗначениеВГХ,
		|	ВГХ.Регистратор.ШтукВКоробке КАК ШтукВКоробке,
		|	ВГХ.Регистратор.ШтукВКоробочке КАК ШтукВКоробочке
		|ИЗ
		|	РегистрСведений.ВГХ КАК ВГХ
		|ГДЕ
		|	ВГХ.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", ВыбТовар);
	
	РезультатЗапроса = Запрос.Выполнить();              
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Истина;
	КонецЕсли;
	
	
	
	ТЗВГХ = РезультатЗапроса.Выгрузить(); 
	
	ШтукВКоробке   = ТЗВГХ[0].ШтукВКоробке;
	ШтукВКоробочке = ТЗВГХ[0].ШтукВКоробочке;
	
	//если есть данные по коробке нужно заполнить
	Если ШтукВКоробке > 0 Тогда
		
		НовСтр = ТЗВГХ.Добавить(); 	
		НовСтр.ВидВГХ       = "ВысотаКоробки";
		НовСтр.ЗначениеВГХ  = 0;   
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ШиринаКоробки";
		НовСтр.ЗначениеВГХ  = 0;   
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ДлинаКоробки";
		НовСтр.ЗначениеВГХ  = 0;   
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ВесБруттоКоробки";
		НовСтр.ЗначениеВГХ  = 0;

		
	КонецЕсли;
		
	//если есть данные по блочку нужно заполнить    
	Если ШтукВКоробочке > 0 Тогда     	
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ВысотаБлочка";
		НовСтр.ЗначениеВГХ  = 0;
		
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ШиринаБлочка";
		НовСтр.ЗначениеВГХ  = 0;    
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ДлинаБлочка";
		НовСтр.ЗначениеВГХ  = 0; 
		
		НовСтр = ТЗВГХ.Добавить(); 
		НовСтр.ВидВГХ       = "ВесБруттоБлочка";
		НовСтр.ЗначениеВГХ  = 0;

		
	КонецЕсли;


	
	НовСтр = ТЗВГХ.Добавить(); 
	НовСтр.ВидВГХ       = "ШиринаШтуки";
	НовСтр.ЗначениеВГХ  = 0;
	
	НовСтр = ТЗВГХ.Добавить(); 
	НовСтр.ВидВГХ       = "ВысотаШтуки";
	НовСтр.ЗначениеВГХ  = 0;   
		
	НовСтр = ТЗВГХ.Добавить(); 
	НовСтр.ВидВГХ       = "ДлинаШтуки";
	НовСтр.ЗначениеВГХ  = 0;   
	
	
	
	
		
	НовСтр = ТЗВГХ.Добавить(); 
	НовСтр.ВидВГХ       = "ВесБруттоШтуки";
	НовСтр.ЗначениеВГХ  = 0;                
	
	
	
	ТЗВГХ.Свернуть("ВидВГХ","ЗначениеВГХ");
	
	Для Каждого СтрВГХ из ТЗВГХ Цикл
		Если СтрВГХ.ЗначениеВГХ  = 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
		
	Возврат Ложь;
   
КонецФункции      

