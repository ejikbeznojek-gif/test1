Функция ПолучитьИмяИсходящейОчередиДокФлоуПоИмениОбъекта (ИмяОбъекта) Экспорт
	
	СтруктураВозврата = МаркировкаКС.СтруктураРезультата(Истина);
	
	ЭтоЖиваяБаза = ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза();
	Постфикс = "";
	Если Не ЭтоЖиваяБаза Тогда  
		Постфикс = "Тест";
	КонецЕсли;
	
	Если ИмяОбъекта = "ЗаявкаНаОплату" Тогда 
		ИмяПредопределенныхДанныхКлючаХранилища = "ДанныеDocFlowRabbitЗНОИсходящийПоток";
	Иначе
		ИмяПредопределенныхДанныхКлючаХранилища = "ДанныеDocFlowRabbit" + ИмяОбъекта+"ИсходящийПоток";
	КонецЕсли;	                                                                                      
	ИмяПредопределенныхДанныхКлючаХранилища =  ИмяПредопределенныхДанныхКлючаХранилища +  Постфикс;
	
	Попытка	
		КлючХранилища = Справочники.КлючиБезопасногоХранилищаДанных[ИмяПредопределенныхДанныхКлючаХранилища];
	Исключение 
		СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не найден ключ безопасного хранилища данных  %1", ИмяПредопределенныхДанныхКлючаХранилища)); 
		КлючХранилища = Неопределено;
	КонецПопытки;         
	
	Если КлючХранилища = Неопределено тогда     
		СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Отсутствует ключ безопасного хранения исходящей очереди %1", ИмяОбъекта));  
	Иначе
		ДанныеКлюча = РаботаСБезопаснымХранилищемСервер.ПрочитатьДанныеАвторизацииПоКлючу(КлючХранилища); 
		Если ТипЗнч(ДанныеКлюча) = Тип("Структура") и ДанныеКлюча.Свойство("Ресурс") и ЗначениеЗаполнено(ДанныеКлюча.Ресурс) Тогда   
			СтруктураВозврата.Данные = ДанныеКлюча.Ресурс;
		Иначе 
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не заполнено имя исходящей очереди  %1", ИмяОбъекта)); 	
		КонецЕсли; 	
	КонецЕсли;     
	
	Если СтруктураВозврата.Ошибки.Количество () > 0 Тогда     
		СтруктураВозврата.Успешно = Ложь;   
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции      


Функция ПолучитьМассивИменВходящихОчередейДокФлоу () Экспорт 
	
	СтруктураВозврата = МаркировкаКС.СтруктураРезультата(Истина);

	ЭтоЖиваяБаза = ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза();
	Постфикс = "";
	Если Не ЭтоЖиваяБаза Тогда  
		Постфикс = "Тест";
	КонецЕсли;
	
	МассивОчередей = новый Массив;   
	ДополнитьМассивИменОчередейДокФлоуПоКлючу(МассивОчередей, "ДанныеDocFlowRabbitЗНОВходящийПоток" + Постфикс, СтруктураВозврата.Ошибки);
	ДополнитьМассивИменОчередейДокФлоуПоКлючу(МассивОчередей, "ДанныеDocFlowRabbitКонтрагентыВходящийПоток" + Постфикс, СтруктураВозврата.Ошибки);
	ДополнитьМассивИменОчередейДокФлоуПоКлючу(МассивОчередей, "ДанныеDocFlowRabbitДоговорыВходящийПоток" + Постфикс, СтруктураВозврата.Ошибки);
	ДополнитьМассивИменОчередейДокФлоуПоКлючу(МассивОчередей, "ДанныеDocFlowRabbitБанковскиеСчетаВходящийПоток" + Постфикс, СтруктураВозврата.Ошибки);
	
	Если СтруктураВозврата.Ошибки.Количество () > 0 Тогда     
		СтруктураВозврата.Успешно = Ложь;   
	КонецЕсли;               
	
    СтруктураВозврата.Данные = МассивОчередей;
	
	Возврат СтруктураВозврата;
			
КонецФункции           

  
