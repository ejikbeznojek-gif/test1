Функция ПолучитьДопПараметрыНакладной (Док) экспорт
	// Кухарь А.Ю. 20.10.2025 начало 
	//Пока непонятно откуда вызывается, добавлю вызов исключения, чтобы по стеку потом понять откуда вызов.
	//HELP-7521
	если Док = Неопределено тогда
		ВызватьИсключение "Не выбран документ для получения доп. параметров";
	КонецЕсли;
	// Кухарь А.Ю. 20.10.2025 конец
	
	ДопПараметры=новый Структура("Имя,ЗаполнятьПереклейку,ОтгрузкаКомплектов","",Истина,ложь);
	ДопПараметры.Вставить("ОтгрузкаFBS",Ложь); 
	ДопПараметры.Вставить("ВыводитьДополнительныеСведения",Ложь); 
	ДопПараметры.Вставить("МассивДО",новый Массив); 
	ДопПараметры.Вставить("Получатель",Справочники.Контрагенты.ПустаяСсылка()); 
	ДопПараметры.Вставить("НеКонтролироватьКоличествоЕдиниц",ложь); 
	ДопПараметры.Вставить("НаборТовараПоЕдинойСхеме",ложь); 
	ВидНакладной=док.метаданные().имя; 
	ДопПараметры.Вставить("РазбиватьСпецификацииПоПродукции",ложь); 	
	ДопПараметры.Вставить("ОтгрузкаДСП",ложь);
	ДопПараметры.Вставить("ТребуетсяМаркировка",ложь);	 
	ДопПараметры.Вставить("НаборыЧЗбезОклейкиКомплектующих",ложь);	 
	ДопПараметры.Вставить("НанесениеКодовНеОбязательно",ложь);	
	
	// Ихсанов Д. А. Начало 23.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8242
	ДопПараметры.Вставить("Озон_МаркировкаПоВсемЗаказам", Ложь);
	// Ихсанов Д. А. Конец 23.12.2025
	
	// Кухарь А.Ю.  16.04.2025 начало
	ДопПараметры.Вставить("ПроверятьСодержимоеТарыЧЗ",ложь);
	// Кухарь А.Ю.  16.04.2025 конец                           

	// Кухарь А.Ю.  24.10.2025 начало
	// HELP-7562
	ДопПараметры.Вставить("ПроверятьВложениеЭкспозитораЧЗ",ложь); 
	// Кухарь А.Ю.  24.10.2025 конец

	
	
	РазрешеныСпайкиБезОклейкиКомплектующихЧЗ = ложь;	
	
	Запрос=новый запрос;		
	если ВидНакладной="ЗаданиеНабора" тогда 
		запрос.Текст=     "ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ЗаданиеНабора.Получатель ССЫЛКА Справочник.Контрагенты
		|			ТОГДА ВЫРАЗИТЬ(ЗаданиеНабора.Получатель КАК Справочник.Контрагенты).Код
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК КодКонтрагента,
		|	ВЫБОР
		|		КОГДА ЗаданиеНабора.Получатель ССЫЛКА Справочник.Контрагенты
		|			ТОГДА ВЫРАЗИТЬ(ЗаданиеНабора.Получатель КАК Справочник.Контрагенты).НаборТовараПоЕдинойСхеме
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК НаборТовараПоЕдинойСхеме,
		|	ЗаданиеНабора.Склад.Код КАК КодСклада,
		|	ВЫБОР
		|		КОГДА ЗаданиеНабора.Накладная ССЫЛКА Документ.РасходнаяНакладная
		|			ТОГДА ВЫРАЗИТЬ(ЗаданиеНабора.Накладная КАК Документ.РасходнаяНакладная).ОтгрузкаКомплектов
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ОтгрузкаКомплектов,
		|	ЗаданиеНабора.Получатель КАК Получатель,
		|	ВЫБОР
		|		КОГДА ЗаданиеНабора.Накладная ССЫЛКА Документ.РасходнаяНакладная
		|			ТОГДА НЕ ВЫРАЗИТЬ(ЗаданиеНабора.Накладная КАК Документ.РасходнаяНакладная).ПунктДоставки.ПереклейкаНеНужна
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЗаполнятьПереклейку,
		|	ИнетМагазины.Ссылка КАК ИнетМагазин,
		|	ЗаданиеНабора.ТребуетсяМаркировка КАК ТребуетсяМаркировка,
		|	ВЫБОР
