Функция ДляНакладнойТребуютсяПроводкиПоОстаткамПланов (Знач Ссылка, Знач Контрагент) Экспорт
	
	Результат = Ложь;  
	
	Если ОбщегоНазначения_ПИ.ЭтоУзел_ЦО() Тогда	
		Если Контрагент = ПолучитьКонтрагентаНеИзменяемыйОстаток() Тогда
			Запрос = Новый Запрос;        
			Запрос.УстановитьПараметр("Накладная",Ссылка);
			Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	РС.Накладная КАК Накладная
			|ИЗ
			|	РегистрСведений.РаспределениеПлановПродажПоНакладным КАК РС
			|ГДЕ
			|	РС.Накладная = &Накладная";
			Выборка = Запрос.Выполнить();
			Если Не Выборка.Пустой() Тогда    
				Результат = Истина;
			КонецЕсли;
		КонецЕсли;    
	КонецЕсли;	    
	
	Возврат Результат;
	
КонецФункции

