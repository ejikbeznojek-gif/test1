Процедура ДополнитьМассивИменОчередейДокФлоуПоКлючу(МассивОчередей, ИмяКлюча, МассивОшибок)    
	
	КлючХранилища = Справочники.КлючиБезопасногоХранилищаДанных[ИмяКлюча];	
	Если КлючХранилища = Неопределено тогда     
		МассивОшибок.Добавить(СтрШаблон("Отсутствует ключ безопасного хранения  очереди %1", ИмяКлюча));  
	Иначе
		ДанныеКлюча = РаботаСБезопаснымХранилищемСервер.ПрочитатьДанныеАвторизацииПоКлючу(КлючХранилища); 
		Если ТипЗнч(ДанныеКлюча) = Тип("Структура") и ДанныеКлюча.Свойство("Ресурс") и ЗначениеЗаполнено(ДанныеКлюча.Ресурс) Тогда   
			МассивОчередей.Добавить(ДанныеКлюча.Ресурс);
		Иначе 
			МассивОшибок.Добавить(СтрШаблон("Не заполнено адрес очереди  %1", ИмяКлюча)); 	
		КонецЕсли; 	
	КонецЕсли;    
		
Конецпроцедуры    

