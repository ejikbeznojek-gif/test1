Функция ЭтоКопия()
	РабочиеСервера = Новый Массив;
	РабочиеСервера.Добавить("srvbase-sk:1741");
	РабочиеСервера.Добавить("srv-data");
	РабочиеСервера.Добавить("srv1c-ekf");
	
	РабочиеБазы = Новый Массив;
	РабочиеБазы.Добавить("OD7");  
	РабочиеБазы.Добавить("snl");  
	РабочиеБазы.Добавить("ekf");  
	
	Данные = СтруктураИБ();  
	
	Если Данные.Файловая Тогда
		Возврат Истина;
	КонецЕсли;
	Если РабочиеСервера.Найти(Данные.ИмяСервера) = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	Если РабочиеБазы.Найти(Данные.ИмяБазы) = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;   
	Возврат Ложь;
КонецФункции	
