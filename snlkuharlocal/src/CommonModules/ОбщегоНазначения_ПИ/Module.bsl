			ДопПараметры.ЗаполнятьПереклейку=ложь; 
			ДопПараметры.НеКонтролироватьКоличествоЕдиниц=Истина;	 
		ИначеЕсли результат.КодКонтрагента="SSP-4991"  тогда
			ДопПараметры.ВыводитьДополнительныеСведения=Истина; 
			ДопПараметры.МассивДО=ПолучитьМассивДопОбработок(Док,Справочники.ВидыДопОбработки.УпаковкаВКосметичку); 
			
