Функция ПечататьКоробныеЭтикеткиНовойКомпонентой (Знач Накладная) экспорт  
	//По старому печатаем только для 1го случая  - Это РНК где есть агрегациии коробок и на контрагента не установлен признак НоваяПечатьКоробов
	Результат = Ложь;       
	
	//Кухарь 31.07.2025 начало
	если Маркировка_ПИ.ТипТекущегоУзла() <> Перечисления.ТипУзлаИБ.Склад тогда
		возврат Результат;
	КонецЕсли;
	//Кухарь 31.07.2025 конец
	
	если ТипЗнч(Накладная) = Тип("ДокументСсылка.ЗаданиеНабора") тогда  //С ТСД ЛН вначале записывается с док основанием = Задание набора. Надо переопределять
		Накладная = ПолучитьРеквизитШапки(Накладная,"ДокументОснование","Документ"); 
	КонецЕсли;     
	
	если ТипЗнч(Накладная) <> Тип("ДокументСсылка.РасходнаяНакладная") тогда  //Это РНК
		Результат = Истина;  
	КонецЕсли;     
	
	если не Результат тогда 
		Контрагент = ПолучитьРеквизитШапки(Накладная,"Контрагент","Документ");	
		Если ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(Контрагент,"НоваяПечатьКоробов",Ложь) тогда // признак НоваяПечатьКоробов
			Результат = Истина;
		КонецЕсли; 
	КонецЕсли;
	
	если не Результат тогда
		ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(Накладная);  	       	
		если не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок тогда  //есть агрегациии коробок
			Результат = Истина;
		КонецЕсли;  
	КонецЕсли;
	
	возврат Результат;
	

КонецФункции
