Функция ЭтоУзел_СкладФилиала() Экспорт
	
	//определяем что это склад в филиале 
	//по условию тип = магазин и есть у подразделения Выделенный склад
	
	//текущий узел
	ТекущийУзел = ПараметрыСеанса.ЭтотУзел;
	
	ЭтоСкладФилиала=Ложь;
	
	Если ТекущийУзел.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение Тогда
		//если тип склада = магазина
		ПодразделениеУзла = ТекущийУзел.Подразделение;
		
		Если ЗначениеЗаполнено(ПодразделениеУзла) Тогда
			//наличие выделенного склада
			Возврат ПодразделениеУзла.ЕстьВыделенныйСклад;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЭтоСкладФилиала;
	
КонецФункции //ЭтоУзел_СкладФилиала()

