//Тимофеев Ю.А. Изменение 0000000099 ВГХ Номенклатуры
Процедура ИзменитьВГХтовара(Номенклатура,ЭтоПросмотр=Ложь) Экспорт
			
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВГХ.Ссылка КАК Ссылка,
	|	ВГХ.НачалоРабот КАК НачалоРабот
	|ИЗ
	|	Документ.ВГХ КАК ВГХ
	|ГДЕ
	|	ВГХ.Номенклатура = &Номенклатура
	|	И НЕ ВГХ.ПометкаУдаления
	|	И ВГХ.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВГХ.Дата УБЫВ";
	
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	//значит никто не заполняет
	Если РезультатЗапроса.Пустой() Тогда				
		
		ДокВГХ                  = Документы.ВГХ.СоздатьДокумент();
		ДокВГХ.Дата             = ТекущаяДата();
		ДокВГХ.Автор            = ПараметрыСеанса.Пользователь;
		ДокВГХ.Номенклатура     = Номенклатура;    
		ДокВГХ.ШтукВКоробке     = Номенклатура.Родитель.ШтукВКоробке;
		ДокВГХ.ШтукВКоробочке   = Номенклатура.Родитель.ШтукВКоробочке;     
		ДокВГХ.НачалоРабот      = ТекущаяДата();
		ДокВГХ.Записать();
		
		ФормаВГХ                = ДокВГХ.ПолучитьФорму("ФормаЗаписи");
		ФормаВГХ.Номенклатура   = Номенклатура; 
		ФормаВГХ.ШтукВКоробке   = Номенклатура.Родитель.ШтукВКоробке;
		ФормаВГХ.ШтукВКоробочке = Номенклатура.Родитель.ШтукВКоробочке;
		ФормаВГХ.ДокументОбъект = ДокВГХ; 
		ФормаВГХ.ЭтоПросмотр    = ЭтоПросмотр ;
		ФормаВГХ.ОткрытьМодально();    
		
	Иначе
		
		Выборка = РезультатЗапроса.Выбрать(); 
		
		Если Выборка.Следующий() Тогда
			
			ДокументКопия               = Выборка.Ссылка.Скопировать();
			
			ДокументКопия.Дата           = ТекущаяДата();	 
			ДокументКопия.НачалоРабот    = ТекущаяДата();
			ДокументКопия.ОкончаниеРабот = Дата(1,1,1);
			ДокументКопия.Автор          = ПараметрыСеанса.Пользователь;
			
			ФормаВГХ                      = ДокументКопия.ПолучитьФорму("ФормаЗаписи");
			ФормаВГХ.ДокументОбъект       = ДокументКопия;  
			ФормаВГХ.ЭтоПросмотр          = ЭтоПросмотр ;
			ФормаВГХ.ОткрытьМодально();  
			
		КОнецЕсли;      					
		
	КОнецЕсли;

КонецПроцедуры
