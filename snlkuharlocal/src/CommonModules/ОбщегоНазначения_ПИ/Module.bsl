Функция ЭтоНеКопияАЖиваяБаза () Экспорт
	СтрокаТекущегоСоединения = СокрЛП(ВРег(СтрокаСоединенияИнформационнойБазы()));     
	СтрокаСоединения	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));     
	
	// Кухарь А.Ю.  31.03.2026 начало
	// Заплатка. Отключить после того как придумаем что делать.	
	СтрокаСоединения2 ="SRVR=""SRV01-SK:1741"";REF=""OD7"";"; 
	СтрокаСоединения3 ="SRVR=""SRV02-SK:1741"";REF=""OD7"";";    
	возврат СтрокаСоединения = СтрокаТекущегоСоединения 
	или СтрокаСоединения2 = СтрокаТекущегоСоединения 
	или СтрокаСоединения3 = СтрокаТекущегоСоединения; 
	// Кухарь А.Ю.  31.03.2026 конец
	
	Возврат СтрокаТекущегоСоединения = СтрокаСоединения;
	
		
