// Кухарь А.Ю.  13.05.2025 начало  
//Функция ПолучитьЗначениеРСРеквизитыСправочников(Ссылка, ИмяРеквизита = "") Экспорт 
//Результат = Неопределено;
Функция ПолучитьЗначениеРСРеквизитыСправочников(Ссылка, ИмяРеквизита = "",ПустоеЗначение = Неопределено) Экспорт  
	Результат = ПустоеЗначение;	
	// Кухарь А.Ю.  13.05.2025 конец	
	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ИмяРеквизита", ИмяРеквизита);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита
	|	И РеквизитыСправочников.Справочник = &Ссылка";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.ЗначениеРеквизита;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
