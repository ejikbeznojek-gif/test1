
Процедура ФР_ГП_Товары_ПриЗаписиПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Попытка
		Если ЗначениеЗаполнено(Источник.Регистратор) Тогда
			ДатаГП 					= Константы.ГП_Партии.Получить();
			МоментВремениДокумента 	= Источник.Регистратор.МоментВремени();	
			
			Если МоментВремениДокумента.Сравнить(Новый МоментВремени(ДатаГП))<0 ИЛИ НЕ ЗначениеЗаполнено(ДатаГП) Тогда
				Константы.ГП_Партии.Установить(МоментВремениДокумента.Дата);
			КонецЕсли;	
		КонецЕсли;
	Исключение
		ЗаписатьВЛог("Отладка","Ошибка фиксации изменения ГП партии. "+ОписаниеОшибки(),"Ошибка");		
	КонецПопытки;	
	
КонецПроцедуры
