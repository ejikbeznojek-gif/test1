Процедура ВывестиПротокол(ТабПротокола=Неопределено,УзелКорреспондент,Результат,ВидОперации="Загрузка")				
	ЭтотУзел=ПараметрыСеанса.ЭтотУзел;
	
	ТДПротокол=Новый ТабличныйДокумент;
	
	Макет=ПолучитьОбщийМакет("ПротоколОбмена");
	
	ОблЗаголовок=Макет.ПолучитьОбласть("Заголовок");
	
	Если ВидОперации="Загрузка" Тогда
		ОблЗаголовок.Параметры.УзелОтправитель	=УзелКорреспондент.Код;
		ОблЗаголовок.Параметры.УзелПолучатель	=ЭтотУзел.Код;
		
		
		ОблЗаголовок.Параметры.ВидОперации=" загрузки";
		
		Если Результат.Результат Тогда
			ОблЗаголовок.Параметры.НомерСообщения	=УзелКорреспондент.НомерПринятого;	
			ИмяФайлаПротокола="Prot_"+УзелКорреспондент.Код+"_"+ЭтотУзел.Код+"_"+Формат(УзелКорреспондент.НомерПринятого,"ЧГ=")+".mxl";
		Иначе			
			ОблЗаголовок.Параметры.НомерСообщения	="?????";	
			ИмяФайлаПротокола="Prot_"+УзелКорреспондент.Код+"_"+ЭтотУзел.Код+"_"+СокрЛП(СтрЗаменить(Результат.Описание,"!",""))+"_"+Формат(ТекущаяДата(),"ДФ=yyyyMMddHHmmss") +".mxl";		
		КонецЕсли;		
	ИначеЕсли ВидОперации="Выгрузка" Тогда
		ОблЗаголовок.Параметры.УзелОтправитель	=ЭтотУзел.Код;
		ОблЗаголовок.Параметры.УзелПолучатель	=УзелКорреспондент.Код;
		
		ОблЗаголовок.Параметры.ВидОперации=" выгрузки";
		
		Если Результат.Результат Тогда
			ОблЗаголовок.Параметры.НомерСообщения	=УзелКорреспондент.НомерОтправленного;					
			ИмяФайлаПротокола="Prot_"+ЭтотУзел.Код+"_"+УзелКорреспондент.Код+"_"+Формат(УзелКорреспондент.НомерОтправленного,"ЧГ=")+".mxl";		
		Иначе
			ОблЗаголовок.Параметры.НомерСообщения	="?????";
			ИмяФайлаПротокола="Prot_"+ЭтотУзел.Код+"_"+УзелКорреспондент.Код+"_"+СокрЛП(СтрЗаменить(Результат.Описание,"!",""))+"_"+Формат(ТекущаяДата(),"ДФ=yyyyMMddHHmmss")+".mxl";
		КонецЕсли;		
	КонецЕсли;
	
	ОблЗаголовок.Параметры.ДатаЗагрузки		=ТекущаяДата();	
	ТДПротокол.Вывести(ОблЗаголовок);
	
	Если НЕ Результат.Результат Тогда
		ОблОшибка=Макет.ПолучитьОбласть("ОшибкаОбмена");
		ОблОшибка.Параметры.Описание=Результат.Описание;
		
		ТДПротокол.Вывести(ОблОшибка);
	КонецЕсли;
	
	Если ТипЗнч(ТабПротокола)=Тип("ТаблицаЗначений") Тогда
		
		
		ТабПротокола.Сортировать("Склад,Вид,Номер");
		
		БылСклад=Неопределено;
		
		
		Для Каждого СтрокаТЗ Из ТабПротокола Цикл
			Если БылСклад<>СтрокаТЗ.Склад Тогда
				ОблСклад	=Макет.ПолучитьОбласть("Склад");
				ОблСклад.Параметры.Заполнить(СтрокаТЗ);	
				
				ТДПротокол.Вывести(ОблСклад);
				
				ОблШапка	=Макет.ПолучитьОбласть("Шапка");
				ТДПротокол.Вывести(ОблШапка);	
				
				БылСклад=СтрокаТЗ.Склад;
			КонецЕсли;		
			
			ОблСтрока=Макет.ПолучитьОбласть("Строка");
			ОблСтрока.Параметры.Заполнить(СтрокаТЗ);		
			
			ТДПротокол.Вывести(ОблСтрока);		
		КонецЦикла; 	
	КонецЕсли; 
	
	//ТДПротокол.Записать(Константы.КаталогВнешнихОтчетов.Получить()+"Протоколы обмена\"+ИмяФайлаПротокола,ТипФайлаТабличногоДокумента.MXL);	
КонецПроцедуры

Процедура ВыполнитьОбменСУзлом(КодУзла)
	УзелОбмена=ПланыОбмена.Основной.НайтиПоКоду(КодУзла);				
	Если УзелОбмена.Пустая() Тогда
		Ошибки="Не найден узел обмена с кодом: """+КодУзла+""" !";								
		ЗаписатьВЛог("Регламент",Ошибки,"Ошибка");
	Иначе
		УзелОбъект=УзелОбмена.ПолучитьОбъект();
		
		Протокол=Неопределено;
		
		Результат=УзелОбъект.ПрочитатьСообщениеСИзменениями(,Протокол);
		ВывестиПротокол(Протокол,УзелОбъект,Результат,"Загрузка");				
		
		Протокол=Неопределено;
		
		Результат=УзелОбъект.ЗаписатьСообщениеСИзменениями(Протокол);
		ВывестиПротокол(Протокол,УзелОбъект,Результат,"Выгрузка");
		
		Результат=Истина;
	КонецЕсли;
КонецПроцедуры

Функция СтрокуВСписок(ИсхСтр)
	Стр=ИсхСтр;
	Массив=Новый Массив;
	
	Поз=Найти(Стр,",");
	Пока Поз<>0 И СтрДлина(Стр)>0 Цикл
		Массив.Добавить(СокрЛП(Лев(Стр,Поз-1)));
		Стр=Сред(Стр,Поз+1);	
		Поз=Найти(Стр,",");
	КонецЦикла;
	Если СтрДлина(Стр)>0 Тогда	
		Массив.Добавить(СокрЛП(Стр));
	КонецЕсли;
	
	Возврат Массив;
КонецФункции // СтрокуВСписок()

Процедура ОбменДанными(ТаблицаПараметров=Неопределено) Экспорт
	СтрокаСоединенияСразрешеннымОбменом	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения					=ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю.  31.03.2026 начало
	//Рефакторинг. Приведение к 1й функции
	//Если ТекСтрокаСоединения <> СтрокаСоединенияСразрешеннымОбменом Тогда
	если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда	
		//Кухарь А.Ю.  31.03.2026 конец	
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Обмен данными. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");		
		Возврат;
	КонецЕсли;
	
	ЗаписатьВЛог("Регламент","Начало выполнения. "+ТипЗнч(ТаблицаПараметров),"Информация");
	Если ТаблицаПараметров<>Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			ЗаписатьВЛог("Регламент","Параметр: "+СтрокаТП.Имя+" - "+СтрокаТП.Значение,"Информация");
			Если СтрокаТП.Имя="КодыУзлов" Тогда
				КодыУзлов=СтрокуВСписок(СтрокаТП.Значение);
				Для Каждого КодУзла Из КодыУзлов Цикл				
					ЗаписатьВЛог("Автопроцедуры","Начало обмена с узлом: "+КодУзла,"Инфо");
					ВыполнитьОбменСУзлом(КодУзла);			
				КонецЦикла;			
			КонецЕсли; 
		КонецЦикла;			
	Иначе
		ЗаписатьВЛог("Регламент","Ошибка выполнения ! Не заданы параметры задачи !","Ошибка");
	КонецЕсли; 
	
	//крохин начало 24.03.2017
	//в ЦО проверяем отсутствие проводок и перепроводим
	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		ПроверитьДокументы();
		//Кухарь 14.01.20 начало
		//У склада будем проверять наличие ЗНБ без проводок.
	ИначеЕсли ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.Склад Тогда
		ПроверитьДокументыСклад();	
		//Кухарь 14.01.20 конец		
	КонецЕсли;
	//крохин конец 24.03.2017	
	
	ЗаписатьВЛог("Регламент","Завершение выполнения.","Информация");	
	
	Если инт_ДлительныеОперации.ЭтоФоновоеЗадание() Тогда
		ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();			
	КонецЕсли;
КонецПроцедуры

Процедура ЗагрузкаКурсов(ТаблицаПараметров=Неопределено) Экспорт
	Обработка=Обработки.КурсыВалютРБК.Создать();
	Обработка.НачДата=ТекущаяДата()-14*24*60*60;
	Обработка.КонДата=ТекущаяДата()+24*60*60;
	
	Обработка.СписокВалют.Очистить();
	Выборка=Справочники.Валюты.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Ссылка=ПараметрыСеанса.ВалютаНац Тогда Продолжить КонецЕсли; 
		Если Выборка.ПометкаУдаления Тогда Продолжить КонецЕсли; 
		
		СтрокаТЧ=Обработка.СписокВалют.Добавить();	
		СтрокаТЧ.Валюта=Выборка.Ссылка;	
	КонецЦикла; 
	
	Обработка.ЗагрузитьКурсыСРБК();
КонецПроцедуры

