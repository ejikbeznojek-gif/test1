Процедура ОчисткаСкладаСмешанныеСпайки(ТаблицаПараметров = Неопределено) Экспорт
	
	Если ТаблицаПараметров = Неопределено Тогда
		СкладСмешанныеСпайки = Документы.ЗаказСмешанныхСпаекFBO.ПолучитьЗначениеРеквизитыСправочников(, "СкладСмешанныеСпайки", Истина);
	Иначе
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			Если СтрокаТП.Имя = "СкладСмешанныеСпайки" Тогда			
				СкладСмешанныеСпайки = СтрокаТП.Значение;
			КонецЕсли;
		КонецЦикла;  
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СкладСмешанныеСпайки", СкладСмешанныеСпайки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) - ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК СвободныйОстаток
	|ПОМЕСТИТЬ вр_Остатки
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад = &СкладСмешанныеСпайки) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Период, Склад = &СкладСмешанныеСпайки) КАК Резервы
	|		ПО Остатки.Склад = Резервы.Склад
	|			И Остатки.Номенклатура = Резервы.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 0)) КАК КоличествоРНК
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка.Склад = &СкладСмешанныеСпайки
	|	И Комплектующие.Ссылка.Проведен
	|	И Комплектующие.Ссылка.Дата <= КОНЕЦПЕРИОДА(&Период, ДЕНЬ)
	|	И Комплектующие.Ссылка.СостояниеНакладной В (ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ПолученоСкладом), ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеНабора))
	|
	|СГРУППИРОВАТЬ ПО
	|	Комплектующие.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура) КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(вр_Остатки.СвободныйОстаток, 0) - ЕСТЬNULL(вр_Товары.КоличествоРНК, 0)) КАК ФактическийОстаток
	|ПОМЕСТИТЬ вр_Сводная
	|ИЗ
	|	вр_Остатки КАК вр_Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
	|		ПО вр_Остатки.Номенклатура = вр_Товары.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Сводная.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(вр_Сводная.ФактическийОстаток) КАК ФактическийОстаток,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|					И ОстаткиТМЦ.Склад <> &СкладСмешанныеСпайки
	|				ТОГДА ОстаткиТМЦ.Период
	|			ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|		КОНЕЦ) КАК Период
	|ПОМЕСТИТЬ вр_ПериодыПоследниеПриходы
	|ИЗ
	|	вр_Сводная КАК вр_Сводная
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ПО вр_Сводная.Номенклатура = ОстаткиТМЦ.Номенклатура
	|ГДЕ
	|	ОстаткиТМЦ.Период <= &Период
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Сводная.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_ПериодыПоследниеПриходы.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(вр_ПериодыПоследниеПриходы.ФактическийОстаток) КАК Количество,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА ОстаткиТМЦ.Склад
	|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|		КОНЕЦ) КАК Склад
	|ИЗ
	|	вр_ПериодыПоследниеПриходы КАК вр_ПериодыПоследниеПриходы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ПО вр_ПериодыПоследниеПриходы.Номенклатура = ОстаткиТМЦ.Номенклатура
	|			И вр_ПериодыПоследниеПриходы.Период = ОстаткиТМЦ.Период
	|			И (ВЫБОР
	|				КОГДА ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|					ТОГДА ОстаткиТМЦ.Склад
	|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|			КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))
	|ГДЕ
	|	вр_ПериодыПоследниеПриходы.ФактическийОстаток > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_ПериодыПоследниеПриходы.Номенклатура";
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) - ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК СвободныйОстаток,
	|	Остатки.Склад КАК Склад
	|ПОМЕСТИТЬ вр_Остатки
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад = &СкладСмешанныеСпайки) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки КАК Резервы
	|		ПО Остатки.Склад = Резервы.Склад
	|			И Остатки.Номенклатура = Резервы.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 0)) КАК КоличествоРНК
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка.Склад = &СкладСмешанныеСпайки
	|	И Комплектующие.Ссылка.Проведен
	|	И Комплектующие.Ссылка.Дата <= КОНЕЦПЕРИОДА(&Период, ДЕНЬ)
	|	И Комплектующие.Ссылка.СостояниеНакладной В (ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ПолученоСкладом), ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеНабора))
	|
	|СГРУППИРОВАТЬ ПО
	|	Комплектующие.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура) КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(вр_Остатки.СвободныйОстаток, 0) - ЕСТЬNULL(вр_Товары.КоличествоРНК, 0)) КАК ФактическийОстаток,
	|	вр_Остатки.Склад КАК Склад
	|ПОМЕСТИТЬ вр_Сводная
	|ИЗ
	|	вр_Остатки КАК вр_Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
	|		ПО вр_Остатки.Номенклатура = вр_Товары.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура),
	|	вр_Остатки.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиТМЦ.Период КАК Период,
	|	ОстаткиТМЦ.Регистратор КАК Регистратор,
	|	ОстаткиТМЦ.Регистратор.Склад КАК Склад,
	|	ЕСТЬNULL(ОстаткиТМЦ.Регистратор.СкладПолучатель, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)) КАК СкладПолучатель,
	|	ОстаткиТМЦ.Номенклатура КАК Номенклатура,
	|	вр_Сводная.ФактическийОстаток КАК ФактическийОстаток
	|ПОМЕСТИТЬ вр_ПериодыПоследниеПриходы
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ КАК ОстаткиТМЦ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Сводная КАК вр_Сводная
	|		ПО ОстаткиТМЦ.Номенклатура = вр_Сводная.Номенклатура
	|ГДЕ
	|	ОстаткиТМЦ.Склад = &СкладСмешанныеСпайки
	|	И ОстаткиТМЦ.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И ОстаткиТМЦ.Период <= &Период
	|	И ЕСТЬNULL(ОстаткиТМЦ.Регистратор.СкладПолучатель, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вр_ПериодыПоследниеПриходы.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(вр_ПериодыПоследниеПриходы.Период) КАК Период,
	|	МАКСИМУМ(вр_ПериодыПоследниеПриходы.Склад) КАК Склад,
	|	МАКСИМУМ(вр_ПериодыПоследниеПриходы.ФактическийОстаток) КАК Количество
	|ИЗ
	|	вр_ПериодыПоследниеПриходы КАК вр_ПериодыПоследниеПриходы
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_ПериодыПоследниеПриходы.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	Период УБЫВ";
	
	УстановитьПривилегированныйРежим(Истина);
	тзПриходы = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если тзПриходы.Количество() = 0 Тогда Возврат; КонецЕсли;
	
	ДополнительныеРеквизитыПРМ = Новый Структура;
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладной", Перечисления.СостоянияНакладной.Отгружена);
	ДополнительныеРеквизитыПРМ.Вставить("Отгружен", Перечисления.Отгружен.Отгружен);
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладнойУПолучателя", Перечисления.СостоянияНакладной.Принята);
	ДополнительныеРеквизитыПРМ.Вставить("Дата", ТекущаяДатаСеанса());
	
	МассивСкладов = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(тзПриходы.ВыгрузитьКолонку("Склад"));
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// НАДО ЛИ ОБРАБАТЫВАТЬ СИТУАЦИЮ - СКЛАД ??? ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	
	Для Каждого СтрСклад ИЗ МассивСкладов Цикл
		
		ТаблицаЗагрузки = тзПриходы.Скопировать(Новый Структура("Склад", СтрСклад));
		
		Если ТаблицаЗагрузки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПРМ = ЗаполнениеДокументов.СоздатьПеремещение(, ТаблицаЗагрузки, СкладСмешанныеСпайки,
			СтрСклад, "Очистка склада Смешанные спайки", ДополнительныеРеквизитыПРМ, Истина, Истина);
		
	КонецЦикла;
	
КонецПроцедуры
// Шворобей ВЮ 25.08.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6656

// Шворобей ВЮ 02.09.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-6873
Процедура АвтоматическоеЗакрытиеМинусовСВычеркамиВРНК(ТаблицаПараметров = Неопределено) Экспорт
	
	МассивОфисныхСкладов = Новый Массив;
	МассивОтветственныхЛиц = Новый Массив;
	
	Если ТаблицаПараметров = Неопределено Тогда
		МассивОфисныхСкладов.Добавить(Справочники.Склады.НайтиПоКоду("STA-48"));
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// МассивСкладовДляПРМ = Новый Массив;
		// А. Склад Часцы (Основной), Б. Склад Часцы (ДОП), В. Склад Часцы (Франчайзинг), Г. Склад Часцы (FBS), Д. Склад Часцы (ДСП), Е. Склад Часцы (ДСП резерв)
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	Иначе
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "Склад" Тогда			
				МассивОфисныхСкладов.Добавить(СтрокаТП.Значение);
			КонецЕсли;
			Если СтрокаТП.Имя = "ОтветственноеЛицо" Тогда			
				МассивОтветственныхЛиц.Добавить(СтрокаТП.Значение);
			КонецЕсли;
			
		КонецЦикла;  
	КонецЕсли;
	
	МассивОфисныхВиртуальныхСкладов = ПолучитьМассивВиртуальныхСкладов(МассивОфисныхСкладов);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОфисныхВиртуальныхСкладов", МассивОфисныхВиртуальныхСкладов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Склад КАК Склад,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) - ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК СвободныйОстаток
	|ПОМЕСТИТЬ вр_Остатки
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Период, Склад В (&МассивОфисныхВиртуальныхСкладов)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&Период, Склад В (&МассивОфисныхВиртуальныхСкладов)) КАК Резервы
	|		ПО Остатки.Склад = Резервы.Склад
	|			И Остатки.Номенклатура = Резервы.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комплектующие.Ссылка.Склад КАК Склад,
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(Комплектующие.Количество, 0)) КАК КоличествоРНК
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка.Склад В(&МассивОфисныхВиртуальныхСкладов)
	|	И Комплектующие.Ссылка.Проведен
	|	И Комплектующие.Ссылка.Дата <= КОНЕЦПЕРИОДА(&Период, ДЕНЬ)
	|	И Комплектующие.Ссылка.СостояниеНакладной В (ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ПолученоСкладом), ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеНабора))
	|
	|СГРУППИРОВАТЬ ПО
	|	Комплектующие.Ссылка.Склад,
	|	Комплектующие.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(вр_Товары.Склад, вр_Остатки.Склад) КАК Склад,
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура) КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(вр_Остатки.СвободныйОстаток, 0) - ЕСТЬNULL(вр_Товары.КоличествоРНК, 0)) КАК Количество
	|ИЗ
	|	вр_Остатки КАК вр_Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Товары КАК вр_Товары
	|		ПО вр_Остатки.Номенклатура = вр_Товары.Номенклатура
	|			И вр_Остатки.Склад = вр_Товары.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(вр_Товары.Склад, вр_Остатки.Склад),
	|	ЕСТЬNULL(вр_Товары.Номенклатура, вр_Остатки.Номенклатура)
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(вр_Остатки.СвободныйОстаток, 0) - ЕСТЬNULL(вр_Товары.КоличествоРНК, 0)) < 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Склад";
	
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	УстановитьПривилегированныйРежим(Истина);
	тзМинуса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если тзМинуса.Количество() = 0 Тогда Возврат; КонецЕсли;
	
	МассивСкладовДляПРМ = ЗаполнениеДокументов.УдалитьПовторяющиесяЭлементыМассива(тзМинуса.ВыгрузитьКолонку("Склад"));
	
	ДополнительныеРеквизитыПРМ = Новый Структура;
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладной", Перечисления.СостоянияНакладной.Отгружена);
	ДополнительныеРеквизитыПРМ.Вставить("Отгружен", Перечисления.Отгружен.Отгружен);
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладнойУПолучателя", Перечисления.СостоянияНакладной.Принята);
	ДополнительныеРеквизитыПРМ.Вставить("Дата", ТекущаяДатаСеанса());
	
	Для Каждого СкладПриемник ИЗ МассивСкладовДляПРМ Цикл
		
		ТаблицаЗагрузки = тзМинуса.Скопировать(Новый Структура("Склад", СкладПриемник));
		
		Если ТаблицаЗагрузки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Стр ИЗ ТаблицаЗагрузки Цикл
			Стр.Количество = Модуль(Стр.Количество);	
		КонецЦикла;
		
		МассивПРМ = СоздатьПРМ(ТаблицаЗагрузки, МассивОфисныхСкладов, СкладПриемник); 
		
	КонецЦикла;
	
	// Если минус не закрыт, то уменьшается количество в РНК/ПРМ в состоянии «в работе», с сортировкой по дате по убыванию, без сортировки по контрагентам.
	// При этом менеджеру контрагента (или ответственному лицу департамента) приходит письмо о вычерке.
	
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	УстановитьПривилегированныйРежим(Истина);
	тзМинуса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если тзМинуса.Количество() = 0 Тогда Возврат; КонецЕсли;
	
	Запрос.УстановитьПараметр("тзМинуса", тзМинуса);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Минуса.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Минуса.Склад КАК Справочник.Склады) КАК Склад,
	|	-(ВЫРАЗИТЬ(Минуса.Количество КАК ЧИСЛО)) КАК Количество
	|ПОМЕСТИТЬ вр_Минуса
	|ИЗ
	|	&тзМинуса КАК Минуса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыРНК.Ссылка КАК Ссылка,
	|	ТоварыРНК.Ссылка.Дата КАК Дата,
	|	ТоварыРНК.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ТоварыРНК.Количество, 0) КАК КоличествоБыло,
	|	ЕСТЬNULL(ТоварыРНК.Количество, 0) - ЕСТЬNULL(вр_Минуса.Количество, 0) КАК Количество
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК ТоварыРНК
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Минуса КАК вр_Минуса
	|		ПО ТоварыРНК.Номенклатура = вр_Минуса.Номенклатура
	|			И ТоварыРНК.Ссылка.Склад = вр_Минуса.Склад
	|ГДЕ
	|	ТоварыРНК.Ссылка.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ВРаботе)
	|	И ЕСТЬNULL(ТоварыРНК.Количество, 0) - ЕСТЬNULL(вр_Минуса.Количество, 0) > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТоварыПРМ.Ссылка,
	|	ТоварыПРМ.Ссылка.Дата,
	|	ТоварыПРМ.Номенклатура,
	|	ЕСТЬNULL(ТоварыПРМ.Количество, 0),
	|	ЕСТЬNULL(ТоварыПРМ.Количество, 0) - ЕСТЬNULL(вр_Минуса.Количество, 0)
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Минуса КАК вр_Минуса
	|		ПО ТоварыПРМ.Номенклатура = вр_Минуса.Номенклатура
	|			И ТоварыПРМ.Ссылка.СкладПолучатель = вр_Минуса.Склад
	|ГДЕ
	|	ТоварыПРМ.Ссылка.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ВРаботе)
	|	И ЕСТЬNULL(ТоварыПРМ.Количество, 0) - ЕСТЬNULL(вр_Минуса.Количество, 0) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|ИТОГИ ПО
	|	Ссылка";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка_Ссылка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Ссылка");
	УстановитьПривилегированныйРежим(Ложь);
	
	МассивУжеУменьшили = Новый Массив;
	
	Пока Выборка_Ссылка.Следующий() Цикл
		
		ДокОбъект = Выборка_Ссылка.Ссылка.ПолучитьОбъект();
		
		Если ДокОбъект <> Неопределено Тогда
			
			Выборка = Выборка_Ссылка.Выбрать();
			
			ДокументПерезаписывать = Ложь;
			
			МассивВычерков = Новый Массив;
			
			Пока Выборка.Следующий() Цикл
				
				Если МассивУжеУменьшили.Найти(Выборка.Номенклатура) = Неопределено Тогда
					
					НайденныеСтрокиДок = ДокОбъект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Выборка.Номенклатура));
					
					Для Каждого НСтр ИЗ НайденныеСтрокиДок Цикл
						
						НСтр.Количество = Выборка.Количество;
						Если ЕстьРеквизитТабЧастиДокумента("ПодтвержденнаяЗаявка", ДокОбъект.Метаданные(), "Товары") Тогда
							НСтр.ПодтвержденнаяЗаявка = Выборка.Количество;
						КонецЕсли;
						РассчитатьСуммуТабЧасти(НСтр, ДокОбъект);
						
						МассивУжеУменьшили.Добавить(Выборка.Номенклатура);
						ДокументПерезаписывать = Истина;
						
						МассивВычерков.Добавить(Строка(Выборка.Номенклатура) + " уменьшили Количество до " + Строка(Выборка.Количество));
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ДокументПерезаписывать Тогда	
				Попытка
					ДокОбъект.ЗаписатьБезОбработки(РежимЗаписиДокумента.Проведение);
					// При этом менеджеру контрагента (или ответственному лицу департамента) приходит письмо о вычерке.
					Если ЗначениеЗаполнено(ДокОбъект.Контрагент.Менеджер) Тогда
						
						СписокПолучателей = Новый СписокЗначений;
						Если ЗначениеЗаполнено(ДокОбъект.Контрагент.Менеджер.ЕМэйл) Тогда
							СписокПолучателей.Добавить(СокрЛП(ДокОбъект.Контрагент.Менеджер.ЕМэйл));
						КонецЕсли;
						
						Для Каждого ФизЛицо ИЗ МассивОтветственныхЛиц Цикл
							Если ЗначениеЗаполнено(ФизЛицо.ЕМэйл) Тогда
								СписокПолучателей.Добавить(ФизЛицо.ЕМэйл);	
							КонецЕсли;
						КонецЦикла;
						
						ТемаПисьма = "Рассылка о наличии вычерков в документе " + Строка(ДокОбъект.Ссылка);
						ТелоПисьма = "";
						Для Каждого ТекстВычерка ИЗ МассивВычерков Цикл
							ТелоПисьма = ТелоПисьма + ТекстВычерка + ?(МассивВычерков.Количество() > 1, Символы.ПС, "");	
						КонецЦикла;
						
						Если НЕ ПустаяСтрока(ТелоПисьма) И СписокПолучателей.Количество() > 0 Тогда
							Ответ = СформироватьВнутреннееУведомление(СписокПолучателей, ТелоПисьма, ТемаПисьма, ДокОбъект.Ссылка,,,"robot@collant.ru");
						КонецЕсли;
						
					КонецЕсли;
				Исключение
			        ЗаписатьВЛог("РегЗадание.ЗакрытиеМинусов", "Не могу записать документ " + Строка(ДокОбъект), "Информация");
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьМассивВиртуальныхСкладов(МассивФизическихСкладов)
	
	МассивВиртуальныхСкладов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивФизическихСкладов", МассивФизическихСкладов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.ФизическийСклад В (&МассивФизическихСкладов)
	|	И Склады.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Виртуальный)
	|	И НЕ Склады.НеИспользовать
	|	И НЕ Склады.ПометкаУдаления
	|	И НЕ Склады.ЭтоГруппа";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивВиртуальныхСкладов.Добавить(Выборка.Склад);	
	КонецЦикла; 
	
	Возврат МассивВиртуальныхСкладов;
	
КонецФункции //
