Процедура ОповещениеОбИзмененияхПоТипуРассылки(ТаблицаПараметров = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	
	ТекстОбъекты = "";
	
	ТемаПисьма = "Письмо об изменениях по Типу рассылки";
	
	ТипРассылки = Справочники.ТипыРассылок.ОповещенияОбИзмененииШтрихкодов;
	ФлагРассылки = "РассылкиЭлПочта";   // "ФизЛицаРазрешениеОтгрузки"
	
	Если ТаблицаПараметров <> Неопределено Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
		
			Если СтрокаТП.Имя = "ТемаПисьма" Тогда
				ТемаПисьма = ?(ЗначениеЗаполнено(СтрокаТП.Значение), СокрЛП(СтрокаТП.Значение), ТемаПисьма);
