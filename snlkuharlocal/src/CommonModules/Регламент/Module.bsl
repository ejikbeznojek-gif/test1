//Валетов+ 20,10,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404
Процедура ПереводНакладныхИзОжиданияОбработкиЧЗвРГ(ТаблицаПараметров=Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РасходнаяНакладная.Ссылка КАК Ссылка,
	               |	РасходнаяНакладная.ТребуетсяМаркировка КАК ТребуетсяМаркировка,
	               |	РасходнаяНакладная.ОтгрузкаКомплектов КАК ОтгрузкаКомплектов
	               |ИЗ
	               |	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	               |ГДЕ
	               |	РасходнаяНакладная.Проведен
	               |	И РасходнаяНакладная.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеОбработкиЧЗ)";
	
	Результат = Запрос.Выполнить().Выбрать(); 
	Пока Результат.Следующий() Цикл 
		ПоменятьСтатус = Истина;
		ТекстСообщения = "";
		ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(Результат.Ссылка);		
		Если ПравилаРаботыСАгрегациейЧЗ.УстановленыПравилаРаботыСАгрегацией Тогда  
			
			НужныПаллеты = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет;
			НужныБлочки = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков;
			НужныКороба = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок;
			ЕстьПаллеты = Ложь;
			ЕстьБлочки = Ложь;
			ЕстьКороба = Ложь;
			
			ЗапросОМ = Новый Запрос;
			ЗапросОМ.Текст =  "ВЫБРАТЬ
			                  |	МаркировкаТоваровИСМП.ТипШК КАК ТипШК,
			                  |	МаркировкаТоваровИСМП.Статус КАК Статус
			                  |ИЗ
			                  |	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
			                  |ГДЕ
			                  |	МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
			                  |	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)";
			ЗапросОМ.УстановитьПараметр("ДокументОснование",Результат.Ссылка);
			Рез = ЗапросОМ.Выполнить().Выбрать();
			Пока Рез.Следующий() Цикл 
				
				Если Рез.ТипШК = Перечисления.ТипыШтрихКодов.Блочок И Рез.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда 
					ЕстьБлочки = Истина;
				ИначеЕсли Рез.ТипШК = Перечисления.ТипыШтрихКодов.Коробка И Рез.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
					ЕстьКороба = Истина;
				ИначеЕсли Рез.ТипШК = Перечисления.ТипыШтрихКодов.Палета И Рез.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан тогда
					ЕстьПаллеты = Истина;	
				КонецЕсли;	
								
			КонецЦикла;  
			Если НужныБлочки И НЕ Естьблочки Тогда
				ПоменятьСтатус = Ложь; 
				ТекстСообщения = ТекстСообщения +  " Не обработаны Блочки. ";
			КонецЕсли; 
			Если НужныКороба И НЕ ЕстьКороба Тогда
				ПоменятьСтатус = Ложь; 
				ТекстСообщения = ТекстСообщения +  " Не обработаны Короба. ";
			КонецЕсли;
			Если НужныПаллеты И НЕ ЕстьПаллеты Тогда
				ПоменятьСтатус = Ложь;
				ТекстСообщения = ТекстСообщения +  " Не обработаны Паллеты. ";
			КонецЕсли;
		КонецЕсли; 
		
		Если Результат.ТребуетсяМаркировка И Результат.ОтгрузкаКомплектов И ПоменятьСтатус Тогда
			ПоменятьСтатус = Ложь;
			ЗапросОМпоЗСб = Новый Запрос;
			ЗапросОМпоЗСб.Текст =  "ВЫБРАТЬ
			                        |	МаркировкаТоваровИСМП.ТипШК КАК ТипШК,
			                        |	МаркировкаТоваровИСМП.Статус КАК Статус
			                        |ИЗ
			                        |	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
			                        |ГДЕ
			                        |	ВЫРАЗИТЬ(МаркировкаТоваровИСМП.ДокументОснование КАК Документ.ЗаданиеНаСборкуКомплектовЧЗ).ДокОснование = &ДокументОснование
			                        |	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ФормированиеНабора)";
			ЗапросОМпоЗСб.УстановитьПараметр("ДокументОснование",Результат.Ссылка);
			РезНаборы = ЗапросОМпоЗСб.Выполнить().Выбрать();
			Пока РезНаборы.Следующий() Цикл 
				Если РезНаборы.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
					ПоменятьСтатус = Истина;   
				КонецЕсли; 
			КонецЦикла; 
			Если не ПоменятьСтатус Тогда
				ТекстСообщения = ТекстСообщения +  " Не обработаны Формирования наборов. ";
			КонецЕсли;
			
		КонецЕсли;
		
		Если ПоменятьСтатус Тогда
		   ПеревестиВГотоваКОтгрузке(Результат.Ссылка);
        КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Процедура ПеревестиВГотоваКОтгрузке(Док)
	ЕстьОшибки = Ложь; 
	СписокПолучателей = Новый СписокЗначений;
	РнкОбъект = Док.ПолучитьОбъект();  
	НовоеСостояние = Перечисления.СостоянияНакладной.ГотоваКОтгрузке;
	РнкОбъект.СостояниеНакладной = НовоеСостояние;
	Попытка 
		РнкОбъект.Записать(); 
		//Валетов + 09,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-5404
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПланНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПланНабора КАК ПланНабора
		|ГДЕ
		|	НЕ ПланНабора.ПометкаУдаления
		|	И ПланНабора.ДокОснование = &Накладная";
		Запрос.УстановитьПараметр("Накладная",Док); 
		Результат = Запрос.Выполнить().Выгрузить();
		ПланНабора = Результат[0].Ссылка.ПолучитьОбъект();		
		Для Каждого СтрБрендов Из ПланНабора.тБрэндов Цикл
			СтрБрендов.Состояние=НовоеСостояние;
		КонецЦикла;				
		ПланНабора.ЗаписатьБезОбработки(РежимЗаписиДокумента.Запись);
		ОбновитьСостоянияЗНБ (НовоеСостояние,Док);
		//Валетов -
		
		НаборЗаписей = РегистрыСведений.СтатусГотовностиКОтгрузкеЧЗ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Документ.Установить(Док);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Документ = Док;
		Иначе
			НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;
		
		НоваяЗапись.СтатусЧЗ = Перечисления.СтатусыГотовностиКОтгрузкеЧЗ.Обработано;
		НаборЗаписей.Записать();
	Исключение  
		ЕстьОшибки = Истина;
		ТекстПисьма = ТекстПисьма + " Ошибка перевода в РГ Накладной: № "+ РнкОбъект.Номер + " от "+ РнкОбъект.Дата  + Символы.ПС + ОписаниеОшибки();
	КонецПопытки;
	
	Если ЕстьОшибки Тогда
		ТемаПисьма = "Ошибки регламентного задания перевода накладных из статуса `Ожидание Обработки ЧЗ` в `Готова к отгрузке`, в базе  " + Маркировка_ПИ.ЭтотУзел_Код();
		ОповеститьОбОшибке(ТекстПисьма,ТемаПисьма,СписокПолучателей,Док);
	КонецЕсли;

КонецПроцедуры  


Процедура ОповеститьОбОшибке(ТекстПисьма,ТемаПисьма,СписокПолучателей,ДокОшибкиСсылка)
	//Не шлем письма в течении 10 часов с последней записи с Документом Ошибки
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	ПисьмаНаОтправку.ДатаСозданияПисьма КАК ДатаСозданияПисьма,
	                |	ПисьмаНаОтправку.Основание КАК Основание
	                |ИЗ
	                |	РегистрСведений.ПисьмаНаОтправку КАК ПисьмаНаОтправку
	                |ГДЕ
	                |	ПисьмаНаОтправку.Основание = &ДокОсн
	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	ПисьмаНаОтправку.ДатаСозданияПисьма УБЫВ";
	Запрос.УстановитьПараметр("ДокОсн",ДокОшибкиСсылка);
	Рез = запрос.Выполнить().Выбрать();
	Пока Рез.Следующий() Цикл
		Если ТекущаяДата() - 3600 * 10 <= Рез.ДатаСозданияПисьма	Тогда
			Возврат;  //10 часов на обработку ошибки не прошло, пока не спамим...
		КонецЕсли;
	КонецЦикла;
	
	СписокПолучателей.Добавить("mark@collant.ru");
	//Феданченков М.С. 10.06.2026 начало
	//наряд 0000001265
	СписокПолучателей.Добавить("tp@collant.ru");
	//Феданченков М.С. 10.06.2026 конец
	
	//СписокПолучателей.Добавить("valetov@collant.ru"); 
	
	СформироватьВнутреннееУведомление(СписокПолучателей,ТекстПисьма,ТемаПисьма,ДокОшибкиСсылка);
	
КонецПроцедуры


