					КонецЕсли;
					
					СформироватьВнутреннееУведомление(СписокПолучателей, ТекстПисьма, ТемаПисьма, НайденныйОтчет,
						, ИмяФайла, "robot@collant.ru"); 
					
				КонецЕсли;
				
			КонецЕсли;
