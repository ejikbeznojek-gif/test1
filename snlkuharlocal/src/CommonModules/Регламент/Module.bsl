Функция СоздатьПРМ(тзСпайки, МассивСкладов, СкладПриемник)
	
	МассивПРМ = Новый Массив;
	
	ДатаПРМ = ТекущаяДатаСеанса();
	
	ДополнительныеРеквизитыПРМ = Новый Структура;
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладной", Перечисления.СостоянияНакладной.Отгружена);
	ДополнительныеРеквизитыПРМ.Вставить("Отгружен", Перечисления.Отгружен.Отгружен);
	ДополнительныеРеквизитыПРМ.Вставить("СостояниеНакладнойУПолучателя", Перечисления.СостоянияНакладной.Принята);
	ДополнительныеРеквизитыПРМ.Вставить("Дата", ДатаПРМ);
	ДополнительныеРеквизитыПРМ.Вставить("ДатаПриемки", ДатаПРМ);
	ДополнительныеРеквизитыПРМ.Вставить("ДатаОтгрузки", ДатаПРМ);
	
	Для Каждого СтрСклад ИЗ МассивСкладов Цикл  // Обходим Склады
		
		Если СтрСклад = СкладПриемник Тогда
			Продолжить;
		КонецЕсли;
		
		тзСпайкиПРМ = Новый ТаблицаЗначений;
		тзСпайкиПРМ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		тзСпайкиПРМ.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
		
		Для Каждого СтрокаТЗ ИЗ тзСпайки Цикл
			
			Количество = СтрокаТЗ.Количество;
			
			Если Количество <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ОстатокНаСкладе = Документы.ЗаказСмешанныхСпаекFBO.РассчитатьОстаткиПоОдномуСкладу(СтрокаТЗ.Номенклатура, СтрСклад);
			
			Если ОстатокНаСкладе <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если Количество >= ОстатокНаСкладе Тогда
				
				НоваяСтрока = тзСпайкиПРМ.Добавить();
				НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
				НоваяСтрока.Количество = ОстатокНаСкладе;
				
				СтрокаТЗ.Количество = Количество - ОстатокНаСкладе;
				
			ИначеЕсли ОстатокНаСкладе > Количество Тогда
				
				НоваяСтрока = тзСпайкиПРМ.Добавить();
				НоваяСтрока.Номенклатура = СтрокаТЗ.Номенклатура;
				НоваяСтрока.Количество = Количество;
				
				СтрокаТЗ.Количество = 0;	
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если тзСпайкиПРМ.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДополнительныеРеквизитыПРМ.Вставить("Склад", СтрСклад);
		
		ПРМ = ЗаполнениеДокументов.СоздатьПеремещение(Неопределено, тзСпайкиПРМ, СтрСклад,
			СкладПриемник, "Закрытие минусов", ДополнительныеРеквизитыПРМ, Истина, Истина);
			
		Если ПРМ <> Неопределено Тогда
			МассивПРМ.Добавить(ПРМ);		
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивПРМ;
	
КонецФункции

#КонецОбласти

