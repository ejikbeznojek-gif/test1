Процедура ВнешнееЗадание(ТаблицаПараметров) Экспорт
	//++Данилова Е.В. 19.09.2024
	ДоступРазрешенДляТестов = ДоступРазрешенДляТестирования(ТаблицаПараметров); 
	//--Данилова Е.В. 19.09.2024
	//Мессерле 18.06.12
	СтрокаСоединенияСразрешеннымОбменом	=ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения					=ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом 
	Если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() 
		//Кухарь А.Ю. 31.03.2026 конец
		
		И НЕ ДоступРазрешенДляТестов Тогда	
		//крохин начало 11.08.2013
		//ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Обмен данными. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Внешнее задание. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");		
		//крохин конец 11.08.2013
		Возврат;
	КонецЕсли;
	//Мессерле 18.06.12
	
	
	Если ТаблицаПараметров<>Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл

			//++Ратманов 07.02.2026 			
			Если СтрокаТП.Имя = "Обработка" Тогда
				
				МожноВыполнятьВнешние = ОбщегоНазначения_ПИ.ПолучитьЗначениеКонстанты("РазрешитьВнешниеОбработкиВРегламенте");
				
				Обработка = Неопределено;                                                  
				
				Если ТипЗнч(СтрокаТП.Значение) = Тип("Строка") И СтрНачинаетсяС(СтрокаТП.Значение, Маркировка_ПИ.КаталогВнешнихОтчетов()) Тогда                                                                     
					
					Файл = Новый Файл(СтрокаТП.Значение);
					Если Файл.Существует() Тогда                                          
						ОЗОД = Новый ОписаниеЗащитыОтОпасныхДействий;
						ОЗОД.ПредупреждатьОбОпасныхДействиях = Ложь;
						Обработка = ВнешниеОбработки.Создать(СтрокаТП.Значение, Ложь, ОЗОД);
					Иначе
						ЗаписатьВЛог("Регламент", "Запрещено использование внешних обработок в регламентных заданиях !", "Ошибка");
					КонецЕсли;                                                      
				Иначе
					Обработка = Обработки[СтрокаТП.Значение].Создать();
				КонецЕсли;
				Если Обработка = Неопределено Тогда                                                                
					ТекстОшибки = СтрШаблон("Не удалось создать обработку выполнения рег. задания ! Обработка: '%1'", СтрокаТП.Значение);
					ЗаписатьВЛог("Регламент", ТекстОшибки, "Ошибка");
					Возврат;
				КонецЕсли;
				
				ЗаписатьВЛог("ЗапускОтчетов", "" + Обработка.Метаданные().Имя + ". ", "Информация");
				
				Обработка.Сформировать(ТаблицаПараметров);                                                      
			КонецЕсли;
			//--Ратманов 07.02.2026 			
			
			// Шворобей ВЮ 30.01.2024 ++
			Если СтрокаТП.Имя = "ОК" ИЛИ СтрокаТП.Имя = "OK" Тогда
				
				//////////////////////////////////////////////////////////////////////////////////////
				// ОТЧЕТ ОК МОЖНО ИСКАТЬ ПО КОДУ И ПО НАИМЕНОВАНИЮ
				//////////////////////////////////////////////////////////////////////////////////////
				
				НайденныйОтчет = Справочники.ВнешниеОтчеты.НайтиПоКоду(СтрокаТП.Значение);
				
				Если НайденныйОтчет = Справочники.ВнешниеОтчеты.ПустаяСсылка() Тогда
					НайденныйОтчет = Справочники.ВнешниеОтчеты.НайтиПоНаименованию(СтрокаТП.Значение);
				КонецЕсли;
				
				Если НайденныйОтчет <> Справочники.ВнешниеОтчеты.ПустаяСсылка() Тогда
					
					Отчет = Отчеты.ОбщийОтчетНаКомпоновке.Создать();
					Отчет.ВидОтчета = НайденныйОтчет;
					
					ТекСхемаКомпоновки = Отчет.ВидОтчета.СхемаКомпоновки.Получить();
					Если Тип(ТекСхемаКомпоновки) = Тип("СхемаКомпоновкиДанных") Тогда	
						Отчет.СхемаКомпоновкиДанных = ТекСхемаКомпоновки;
					Иначе
						ЗаписатьВЛог("ЗапускОтчетов","Не могу найти Схему компоновки " + Отчет.Метаданные().Имя + ". ","Информация");
						Возврат;
					КонецЕсли;
					
					КомпоновщикНастроек = Отчет.КомпоновщикНастроек;
					КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Отчет.СхемаКомпоновкиДанных));
					
					///////////////////////////////////////////////////////////////////////////////////
					// Надо завести Настройки отчета
					///////////////////////////////////////////////////////////////////////////////////
					
					НайденнаяСтрока = ТаблицаПараметров.Найти("Дата1", "Имя");
					Если НайденнаяСтрока <> Неопределено Тогда
						Отчет.Дата1 = НачалоДня(НайденнаяСтрока.Значение);
					Иначе
						Отчет.Дата1 = НачалоДня(ТекущаяДатаСеанса());
					КонецЕсли;
					ЗаполнениеДокументов.УстановитьПараметрСКД(КомпоновщикНастроек, "Дата1", Отчет.Дата1);
					
					НайденнаяСтрока = ТаблицаПараметров.Найти("Дата2", "Имя");
					Если НайденнаяСтрока <> Неопределено Тогда
						Отчет.Дата2 = КонецДня(НайденнаяСтрока.Значение);
					Иначе
						Отчет.Дата2 = КонецДня(ТекущаяДатаСеанса());
					КонецЕсли;
					ЗаполнениеДокументов.УстановитьПараметрСКД(КомпоновщикНастроек, "Дата2", Отчет.Дата2);
					
					////////////////////////////////////////////////////////////////////////////////////
					// Установим остальные Параметры СКД, будем искать по Комментарию "ПараметрСКД"
					////////////////////////////////////////////////////////////////////////////////////
					
					НайденныеСтроки = ТаблицаПараметров.НайтиСтроки(Новый Структура("Комментарий", "ПараметрСКД"));
					Если НайденныеСтроки.Количество() > 0 Тогда
						Для Каждого НайденнаяСтрока ИЗ НайденныеСтроки Цикл
							ЗаполнениеДокументов.УстановитьПараметрСКД(КомпоновщикНастроек, СокрЛП(НайденнаяСтрока.Имя), НайденнаяСтрока.Значение);
						КонецЦикла;
					КонецЕсли;
					
					////////////////////////////////////////////////////////////////////////////////////
					// Установим Отборы СКД, будем искать по Комментарию "ОтборСКД"
					////////////////////////////////////////////////////////////////////////////////////
					
					НайденныеСтроки = ТаблицаПараметров.НайтиСтроки(Новый Структура("Комментарий", "ОтборСКД"));
					Если НайденныеСтроки.Количество() > 0 Тогда
						Для Каждого НайденнаяСтрока ИЗ НайденныеСтроки Цикл
							
							ВидСравненияСКД = ВидСравненияКомпоновкиДанных.Равно;
							
							Если ТипЗнч(НайденнаяСтрока.Значение) = Тип("СписокЗначений") ИЛИ
								ТипЗнч(НайденнаяСтрока.Значение) = Тип("Массив") ИЛИ
								ТипЗнч(НайденнаяСтрока.Значение) = Тип("ФиксированныйМассив") Тогда
									ВидСравненияСКД = ВидСравненияКомпоновкиДанных.ВСписке;
							КонецЕсли;
								
							Если ТипЗнч(НайденнаяСтрока.Значение) = Тип("Строка") Тогда
								ВидСравненияСКД = ВидСравненияКомпоновкиДанных.Содержит;
							КонецЕсли;
							
							ЭтоСправочник = Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(НайденнаяСтрока.Значение));
							Если ЭтоСправочник Тогда
								МетаданныеОбъекта = НайденнаяСтрока.Значение.Метаданные();
								// Проверить Справочник на Группу
								Если МетаданныеОбъекта.Иерархический Тогда
									Если НайденнаяСтрока.Значение.ЭтоГруппа Тогда
										ВидСравненияСКД = ВидСравненияКомпоновкиДанных.ВИерархии;	
									Иначе
										ВидСравненияСКД = ВидСравненияКомпоновкиДанных.Равно;
									КонецЕсли;
								КонецЕсли;
							КонецЕсли;
							
							ЗаполнениеДокументов.УстановитьОтборСКД(КомпоновщикНастроек, СокрЛП(НайденнаяСтрока.Имя), НайденнаяСтрока.Значение, ВидСравненияСКД);
							
						КонецЦикла;
					КонецЕсли;
					
					////////////////////////////////////////////////////////////////////////////////////
					
					Результат = Новый ТабличныйДокумент;
