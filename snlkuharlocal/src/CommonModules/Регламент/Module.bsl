				ЗаполнитьШапкуДокумента(ДокОбъект,ПараметрыСеанса.Пользователь);
			Иначе		
				ДокОбъект=Док.ПолучитьОбъект();			
			КонецЕсли; 
			
			ДокОбъект.ВидЗаявки	=ВидЗаявки;
