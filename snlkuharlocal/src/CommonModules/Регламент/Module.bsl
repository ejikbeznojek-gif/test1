//Валетов+ 24,06,2025 Регламент записи регистра СтатусыЗаказаМарокДляДокументов
Процедура ЗаписатьДокументыВРегЗаказМарок(ТаблицаПараметров=Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасходнаяНакладная.Ссылка КАК Документ
	|ПОМЕСТИТЬ ВТДок
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Дата >= &НачДата
	|	И РасходнаяНакладная.Проведен
	|	И РасходнаяНакладная.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ЗаказКМЧЗ)
	|	И РасходнаяНакладная.ТребуетсяМаркировка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Перемещение.Ссылка
	|ИЗ
	|	Документ.Перемещение КАК Перемещение
	|ГДЕ
	|	Перемещение.Проведен
	|	И Перемещение.Дата >= &НачДата
	|	И Перемещение.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ЗаказКМЧЗ)
	|	И Перемещение.ТребуетсяМаркировка
	// Кельманов А.В. - SNL-239 - 2026.05.27 {
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Комплектация.Ссылка
	|ИЗ
	|	Документ.Комплектация КАК Комплектация
	|ГДЕ
	|	Комплектация.Проведен
	|	И Комплектация.Дата >= &НачДата
	|	И Комплектация.СостояниеНакладной = ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ЗаказКМЧЗ)
	// Кельманов А.В. - SNL-239 - 2026.05.27 }
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДок.Документ КАК Документ
	|ИЗ
	|	ВТДок КАК ВТДок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|		ПО ВТДок.Документ = СтатусыЗаказаМарокДляДокументов.Накладная
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.Накладная ЕСТЬ NULL"; 
	//Валетов + 03,12,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3340
	//Поменял 1 день назад на 3. Появились ПРМ которым статус для заказа меняют только через 2 дня.
	Запрос.УстановитьПараметр("НачДата",ТекущаяДата()-86400*3);
	
	Результат = Запрос.Выполнить().Выбрать(); 
	Пока Результат.Следующий() Цикл 
		Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			НаборЗаписей = РегистрыСведений.СтатусыЗаказаМарокДляДокументов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Накладная.Установить(Результат.Документ);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() = 0 Тогда
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.Накладная = Результат.Документ;
				НоваяЗапись.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.ТребуетсяЗаказМарок;
				НаборЗаписей.Записать();
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры
