Процедура ПрописатьТекущиеСуммыПоДК(ТаблицаПараметров=Неопределено) Экспорт
	
	//Нечаева 16,01,2014
	// сумма по сертификатам проданным по ДК
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ОтчетКассовойСменыТовары.ДК КАК ДК,
	|	СУММА(ВЫБОР
	|			КОГДА ОтчетКассовойСменыТовары.Ссылка.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя)
	|				ТОГДА -1
	|			ИНАЧЕ 1
	|		КОНЕЦ * ОтчетКассовойСменыТовары.Всего) КАК РасчетнаяСумма
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары КАК ОтчетКассовойСменыТовары
	|ГДЕ
	|	ОтчетКассовойСменыТовары.Ссылка.Дата > &Дата2
	|	И ОтчетКассовойСменыТовары.ДК <> ЗНАЧЕНИЕ(Справочник.ДисконтныеКарты.ПустаяСсылка)
	|	И (НЕ ОтчетКассовойСменыТовары.ДК.Ликвидирована)
	|	И ОтчетКассовойСменыТовары.Ссылка.Проведен
	|	И ОтчетКассовойСменыТовары.Номенклатура.ВидНоменклатуры =(&ПодарСерт)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтчетКассовойСменыТовары.ДК
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриходнаяНакладнаяТовары.Ссылка.ДК,
	|	СУММА(-ПриходнаяНакладнаяТовары.Всего)
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	ПриходнаяНакладнаяТовары.Ссылка.Дата > &Дата2
	|	И ПриходнаяНакладнаяТовары.Ссылка.Проведен
	|	И ПриходнаяНакладнаяТовары.Ссылка.ДК <> ЗНАЧЕНИЕ(Справочник.ДисконтныеКарты.ПустаяСсылка)
	|	И (НЕ ПриходнаяНакладнаяТовары.Ссылка.ДК.Ликвидирована)
	|	И ПриходнаяНакладнаяТовары.Номенклатура.ВидНоменклатуры =(&ПодарСерт)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриходнаяНакладнаяТовары.Ссылка.ДК";
	
	
	Запрос.УстановитьПараметр("Дата2",КонецДня('20140131'));   // 20140131  //с 1 февраля
	Запрос.УстановитьПараметр("ПодарСерт",Перечисления.ВидыНоменклаутры.ПодарочныйСертификат);
	ВыборкаСертификатов=Запрос.Выполнить().Выгрузить();	
	// нечаева 16,01,2014 ---
	
	
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	ДК,
	|	ДК.ОбщаяСуммаДо2013		КАК СуммаВДК,
	|	СУММА(РасчетнаяСумма)	КАК РасчетнаяСумма	
	|ИЗ
	|(	
	|ВЫБРАТЬ
	|	ДК,
	|	СУММА(ВЫБОР КОГДА Ссылка.КодОперации=ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя) ТОГДА -1 ИНАЧЕ 1 КОНЕЦ*Всего) КАК РасчетнаяСумма
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары
	|ГДЕ
	|	Ссылка.Дата>&Дата2
	|	И ДК<>ЗНАЧЕНИЕ(Справочник.ДисконтныеКарты.ПустаяСсылка)
	//крохин начало 23.05.2013
	|	И НЕ ДК.Ликвидирована
	//крохин конец 23.05.2013
	|	И Ссылка.Проведен	
	|СГРУППИРОВАТЬ ПО ДК
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ	
	|	Ссылка.ДК,
	|	СУММА(-Всего)
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|ГДЕ
	|	Ссылка.Дата>&Дата2
	|	И Ссылка.Проведен 
	|	И Ссылка.ДК <> ЗНАЧЕНИЕ(Справочник.ДисконтныеКарты.ПустаяСсылка)
	//крохин начало 23.05.2013
	|	И НЕ Ссылка.ДК.Ликвидирована
	//крохин конец 23.05.2013
	|СГРУППИРОВАТЬ ПО Ссылка.ДК	
	|) КАК СВОДНЫЙ
	|СГРУППИРОВАТЬ ПО ДК
	|ИМЕЮЩИЕ 
	//крохин начало 27.05.2013
	//накопления не уменьшаются
	//|	ДК.ОбщаяСумма<>ДК.ОбщаяСуммаДо2013+СУММА(РасчетнаяСумма)";
	|	ДК.ОбщаяСумма<ДК.ОбщаяСуммаДо2013+СУММА(РасчетнаяСумма)";
	//крохин конец 27.05.2013
	
	Запрос.УстановитьПараметр("Дата2",КонецДня('20121231'));
	
	Выборка=Запрос.Выполнить().Выбрать();	
	
	Пока Выборка.Следующий() Цикл
		ДК_Объект=Выборка.ДК.ПолучитьОбъект();
		// Нечаева 16,01,2014 вычитаем подар. сертификаты с 1 февраля 2014  +++
		ПодСерт=выборкаСертификатов.Найти(Выборка.Дк);
		Сумма=Выборка.РасчетнаяСумма;
		Если ПодСерт<>Неопределено Тогда
			Сумма=Выборка.РасчетнаяСумма-ПодСерт.РасчетнаяСумма;
			//Сообщить(""+Выборка.Дк+"  "+Выборка.РасчетнаяСумма+" -- "+Сумма);
		КонецЕсли;	
		
		//нечаева 23,09,2014 +++
		//ДК_Объект.ОбщаяСумма=ДК_Объект.ОбщаяСуммаДо2013+Сумма;
		//// Нечаева 16,01,2014 вычитаем подар. сертификаты с 1 февраля 2014  ---
		//ДК_Объект.Записать();	
		
		НОбщаяСумма=ДК_Объект.ОбщаяСуммаДо2013+Сумма;
		// Нечаева 16,01,2014 вычитаем подар. сертификаты с 1 февраля 2014  ---
		Если Выборка.ДК.ОбщаяСумма<>НОбщаясумма Тогда
			ДК_Объект.ОбщаяСумма=НОбщаяСумма;
			ДК_Объект.Записать();
		КонецЕсли;	
		//нечаева 23,09,2014 ---
		
	КонецЦикла;	
КонецПроцедуры
