			Обработка=Обработки.ЗаполнениеТЧ.Создать();
			Обработка.ДокОбъект=ДокОбъект;
			
			Обработка.ЗаполнитьЗаявкуНаОтгрузку();			
			
			Если ДокОбъект.ПометкаУдаления Тогда
				ДокОбъект.ПометкаУдаления=Ложь;				
			КонецЕсли;
			
			//крохин начало
			//формируем ЗОГ по всем складам, даже если не было накладных
			//Если ДокОбъект.Накладные.Количество()>0 Тогда
			//	ДокОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад;				
			//	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);				
			//Иначе
			//	ЗаписатьВЛог("Регламент","На "+ДатаОтгрузки+" не обнаружено накладных !","Информация");					
			//КонецЕсли;
			ДокОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.КОтправкеНаСклад;	
			//крохин начало 27.02.2013
			//не записываем пустые документы
			//ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Если ДокОбъект.Накладные.Количество() > 0 Тогда
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			КонецЕсли;
			//крохин конец 27.02.2013
			//крохин конец
			
		КонецЦикла;	
		
		// Кухарь А.Ю. 04.02.2021 начало
		// Дополнение накладными вспомогательных ЗОГ
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ЗаявкаНаОтгрузку.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаОтгрузку КАК ЗаявкаНаОтгрузку
		|ГДЕ
		|	ЗаявкаНаОтгрузку.Дата >= &Дата
		|	И ЗаявкаНаОтгрузку.Проведен
		|	И ЗаявкаНаОтгрузку.ВидЗаявки = &Вспомогательный
		|	И ЗаявкаНаОтгрузку.ДатаОтгрузки > &ТекущаяДата";
		запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
		запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
		запрос.УстановитьПараметр("Вспомогательный",Перечисления.ВидыЗавокНаОтргузку.Вспомогательная);
		результат=запрос.Выполнить().Выбрать();
		пока результат.Следующий() цикл
			ДокОбъект=результат.ссылка.ПолучитьОбъект();
			Обработка=Обработки.ЗаполнениеТЧ.Создать();
			Обработка.ДокОбъект=ДокОбъект;		
			Обработка.ЗаполнитьЗаявкуНаОтгрузку();		
			Если ДокОбъект.Накладные.Количество() > 0 Тогда
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			КонецЕсли;
			
		КонецЦикла;
		// Кухарь А.Ю. 04.02.2021 конец
		
		
		
	Иначе
		ЗаписатьВЛог("Регламент","Формирование ЗОГ ! Ошибка выполнения ! Не заданы параметры задачи !","Ошибка");
	КонецЕсли; 
	ЗаписатьВЛог("Регламент","Завершение выполнения.","Информация");
КонецПроцедуры
