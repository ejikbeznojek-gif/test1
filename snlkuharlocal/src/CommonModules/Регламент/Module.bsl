Процедура ОповещениеОбОтрицательныхОстаткахЗаказыПоставщикам(ТаблицаПараметров = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Остатки.Заказ КАК Заказ,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	Остатки.КоличествоОстаток КАК Остаток
	|ПОМЕСТИТЬ втОтрицательныеОстатки
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам.Остатки(&Период, ТИПЗНАЧЕНИЯ(Заказ) = ТИП(Документ.КонтрактСПроизводителем)) КАК Остатки
	|ГДЕ
	|	Остатки.КоличествоОстаток < 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втОтрицательныеОстатки.Заказ КАК Заказ
	|ИЗ
	|	втОтрицательныеОстатки КАК втОтрицательныеОстатки
	|
	|УПОРЯДОЧИТЬ ПО
	|	втОтрицательныеОстатки.Заказ.Дата";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Количество() = 0 Тогда Возврат; КонецЕсли;
	
	ТемаПисьма = "Письмо об отрицательных остатках по регистру <Заказы поставщикам>";
	
	ТипРассылки = Справочники.ТипыРассылок.ОповещениеОбОтрицательныхОстаткахЗаказыПоставщикам;
	ФлагРассылки = "РассылкиЭлПочта";
	
	Если ТаблицаПараметров <> Неопределено Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
		
			Если СтрокаТП.Имя = "ТемаПисьма" Тогда
				ТемаПисьма = ?(ЗначениеЗаполнено(СтрокаТП.Значение), СокрЛП(СтрокаТП.Значение), ТемаПисьма);
			КонецЕсли;
			
			Если СтрокаТП.Имя = "ТипРассылки" Тогда
				ТипРассылки = ?(ЗначениеЗаполнено(СтрокаТП.Значение), СтрокаТП.Значение, ТипРассылки);
			КонецЕсли;
			
			Если СтрокаТП.Имя = "ФлагРассылки" Тогда
				ФлагРассылки = ?(ЗначениеЗаполнено(СтрокаТП.Значение), СокрЛП(СтрокаТП.Значение), ФлагРассылки);
			КонецЕсли;
		
		КонецЦикла;
		                      
	КонецЕсли;
	
	ТелоПисьма = "";
	Пока Выборка.Следующий() Цикл
		ТелоПисьма = ТелоПисьма + СокрЛП(Выборка.Заказ) + Символы.ПС;	
	КонецЦикла;
	
	СписокПолучателей = СформСписокПолучат(ТипРассылки, , ФлагРассылки);
	
	Если НЕ ПустаяСтрока(ТелоПисьма) И СписокПолучателей.Количество() > 0 Тогда
		Ответ = СформироватьВнутреннееУведомление(СписокПолучателей, ТелоПисьма, ТемаПисьма,,,,"robot@collant.ru");
	КонецЕсли;
	
КонецПроцедуры

