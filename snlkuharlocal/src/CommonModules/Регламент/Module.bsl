Процедура КорректировкаШККМ(ТаблицаПараметров=Неопределено) Экспорт
	НаборЗап = РегистрыСведений.КорректировкаЗначениеКМ.СоздатьНаборЗаписей();
	НаборЗап.Отбор.Обработано.Установить(Ложь);
	НаборЗап.Прочитать();  
	Прод = Ложь;
	Если НаборЗап.Количество() Тогда 
		Прод = Истина;
		МасЗап = Новый Массив;
		Для Каждого ТЗап Из НаборЗап Цикл
			МасЗап.Добавить(Новый Структура("RefBC, ValBC, ValBC1", XMLСтрока(ТЗап.ШтрихКодУпаковки), XMLСтрока(ТЗап.ЗначениеШтрихкода), XMLСтрока(ТЗап.ЗначениеШтрихкода1)));
		КонецЦикла;
		
	КонецЕсли;
	Если Прод И МасЗап.Количество() Тогда
		ЗаписьJSON = Новый ЗаписьJSON();
		ЗаписьJSON.УстановитьСтроку();
		СтрукКМ = Новый Структура;
	
		СтрукКМ.Вставить("ObjectsBC", МасЗап);
		ЗаписатьJSON(ЗаписьJSON, СтрукКМ);
		СтрокаJSON = ЗаписьJSON.Закрыть();
		СтрПар = ПолучитьПараметрыHTTP();
		СоединениеHTTP = Новый HTTPСоединение(СтрПар.Хост, , СтрПар.Логин, СтрПар.Пароль);
		HTTP_Запрос = Новый HTTPзапрос();
		HTTP_Запрос.УстановитьТелоИзСтроки(СтрокаJSON);
		HTTP_Запрос.АдресРесурса = СтрПар.Ресурс;
		ОтветHTTP = СоединениеHTTP.ОтправитьДляОбработки(HTTP_Запрос);
		СтрВозврат = ОтветHTTP.ПолучитьТелоКакСтроку();
		Если ОтветHTTP.КодСостояния = 200 Тогда
			Ответ = СтрВозврат;
		Иначе
			Ответ = НСтр("ru='Ошибка при обработке запроса '")+СтрВозврат;
		КонецЕсли;
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрВозврат);
		Сода = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		МасОбр = Сода["ResultArray"];
		НаборЗап1 = РегистрыСведений.КорректировкаЗначениеКМ.СоздатьНаборЗаписей();
		НаборЗап1.Прочитать();
		
		Для Каждого ТЗап Из НаборЗап1 Цикл
			Если НЕ (МасОбр.Найти(XMLСтрока(ТЗап.ШтрихКодУпаковки)) = Неопределено) Тогда
				ТЗап.Обработано = Истина;
				//с обменом не возвращается так лучше
				ОбновитьЗначШККМ(XMLСтрока(ТЗап.ШтрихКодУпаковки), ТЗап.ЗначениеШтрихкода, ТЗап.ЗначениеШтрихкода1);
			КонецЕсли;	
		КонецЦикла;	
		НаборЗап1.Записать();
	КонецЕсли;	
КонецПроцедуры

Процедура ОбновитьЗначШККМ(УИДСпр, ЗнШК, ЗнШК1)
	Попытка
		СпрШК = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСсылку(Новый УникальныйИдентификатор(УИДСпр)); 
		Если ЗначениеЗаполнено(СпрШК) И НЕ (СпрШК.ЗначениеШтрихкода = ЗнШК1) Тогда
			СпрШКОб = СпрШК.ПолучитьОбъект();
			Если НЕ СпрШКОб = Неопределено Тогда
				СпрШКОб.ЗначениеШтрихкода = ЗнШК1;
				СпрШКОб.Записать(); 
			КонецЕсли; 
		КонецЕсли;	
	Исключение
		Сообщение = Сообщение + " Ошибка: " + ОписаниеОшибки();
	КонецПопытки;
КонецПроцедуры	

Функция ПолучитьПараметрыHTTP()
	Возврат РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
			Справочники.КлючиБезопасногоХранилищаДанных.ДанныеHTTPПубликацииSNL);
КонецФункции //-MARK-704 20251126 Михайловский

//Стырил у Андрея из Паллет 
Процедура ОбновитьСостоянияЗНБ (НовоеСостояние,Накладная)
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Накладная = &Накладная
	|	И ЗаданиеНабора.Проведен
	|	И ЗаданиеНабора.СостояниеНакладной <> &СостояниеНакладной";
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.УстановитьПараметр("СостояниеНакладной",НовоеСостояние);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		ЗНБ=результат.ссылка.получитьобъект();
		ЗНБ.СостояниеНакладной=НовоеСостояние;
		ЗНБ.ОбменДанными.Загрузка=Истина;
		знб.Записать();
	КонецЦикла;
КонецПроцедуры   

