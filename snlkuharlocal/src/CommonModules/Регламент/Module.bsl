			КонецЕсли;
		
		КонецЦикла;
		                      
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Данные.Период КАК Период,
	|	Данные.Объект КАК Объект,
	|	Данные.ТипРассылки КАК ТипРассылки,
	|	Данные.ОписаниеИзменений КАК ОписаниеИзменений
	|ИЗ
	|	РегистрСведений.ДанныеДляОтправкиПочтовымУведомлением КАК Данные
	|ГДЕ
	|	Данные.ДатаФормированияУведомления = ДАТАВРЕМЯ(1, 1, 1)
	|	И Данные.ТипРассылки = &ТипРассылки
	|	" + ТекстОбъекты + "
	|";
	
	Запрос.УстановитьПараметр("ТипРассылки", ТипРассылки);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТелоПисьма = "";
	Пока Выборка.Следующий() Цикл
		ТелоПисьма = ТелоПисьма + СокрЛП(Выборка.ОписаниеИзменений) + Символы.ПС;	
	КонецЦикла;
	
	СписокПолучателей = СформСписокПолучат(ТипРассылки, , ФлагРассылки);
	
	Если НЕ ПустаяСтрока(ТелоПисьма) И СписокПолучателей.Количество() > 0 Тогда
		Ответ = СформироватьВнутреннееУведомление(СписокПолучателей, ТелоПисьма, ТемаПисьма,,,,"robot@collant.ru");
		Если ПустаяСтрока(Ответ) Тогда
			Выборка.Сбросить();
			Пока Выборка.Следующий() Цикл
				СтруктураЗаписи = Новый Структура("Период, Объект, ТипРассылки, ОписаниеИзменений");
				ЗаполнитьЗначенияСвойств(СтруктураЗаписи, Выборка);
				ДополнительныеРеквизиты = Новый Структура("ДатаФормированияУведомления", ТекущаяДата());
				РегистрыСведений.ДанныеДляОтправкиПочтовымУведомлением.СоздатьЗаписьДляОтправкиПочтовымСообщением(СтруктураЗаписи, ДополнительныеРеквизиты);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
