Процедура ДозагрузкаОшибокОбмена(ТаблицаПараметров=Неопределено) Экспорт
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	СсылкаНаОбъект,
	|	КодУзла1,
	|	КодУзла2,
	|	НомерСообщения	
	|ИЗ
	|	РегистрСведений.РассогласованияОбъектов
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗаписи";
	//крохин начало 09.10.2013
	ЕстьошибкиПриЗагрузке = Ложь;
	//крохин конец 09.10.2013
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Запись=РегистрыСведений.РассогласованияОбъектов.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись,Выборка,"СсылкаНаОбъект,КодУзла1,КодУзла2");	
		
		Запись.Прочитать();
		Если ЗначениеЗаполнено(Запись.КодУзла1) Тогда
			Если ПараметрыСеанса.ЭтотУзел.Код=Запись.КодУзла1 Тогда
				СостояниеВУдаленномУзле	=Запись.СостояниеВУзле2.Получить();
				Отправитель				=ПланыОбмена.Основной.НайтиПоКоду(Запись.КодУзла2);
			Иначе			
				СостояниеВУдаленномУзле	=Запись.СостояниеВУзле1.Получить();		
				Отправитель				=ПланыОбмена.Основной.НайтиПоКоду(Запись.КодУзла1);
			КонецЕсли;
			
			//+++Чирков 29.04.13 обход ошибки с загрузкой чужих данных
			//крохин начало 09.10.2013
			//Если ПустаяСтрока(СостояниеВУдаленномУзле) Тогда Продолжить КонецЕсли;
			Если ПустаяСтрока(СостояниеВУдаленномУзле) Тогда 
				ЕстьошибкиПриЗагрузке = Истина;
				Продолжить 
			КонецЕсли;
			//крохин конец 09.10.2013
			//---Чирков
			
			Чтение=Новый ЧтениеXML;
			Чтение.УстановитьСтроку(СостояниеВУдаленномУзле);
			//крохин начало 22.08.2013
			//обход ошибки с отсутствующими объектами или изменениями в конфигурации
			//Данные=ПрочитатьXML(Чтение);
			Попытка
				Данные=ПрочитатьXML(Чтение);
			Исключение
				//крохин начало 09.10.2013
				//удалим записи после окончания обработки
				//		ЗаписатьВЛог("Ошибка дозагрузки обмена","Ошибка: "+ОписаниеОшибки()+". Запись: "+Чтение,"Информация");
				//крохин начало 06.12.2013
				//может быть ошибка при записи в лог сообщения об ошибке.
				//ЗаписатьВЛог("Ошибка дозагрузки обмена","Ошибка: "+ОписаниеОшибки()+". Запись удалена: Тип: "+Выборка.Тип+" .Вид: "+Выборка.Вид+ " .Код Узла1: "+Выборка.Кодузла1+" .КодУзла2: "+Выборка.КодУзла2+ ". Ссылка:"+Выборка.СсылкаНаОбъект+ " .Номер сообщения: "+Выборка.НомерСообщения,"Информация");
				попытка
					ЗаписатьВЛог("Ошибка дозагрузки обмена","Ошибка: "+ОписаниеОшибки()+". Запись удалена: Тип: "+Выборка.Тип+" .Вид: "+Выборка.Вид+ " .Код Узла1: "+Выборка.Кодузла1+" .КодУзла2: "+Выборка.КодУзла2+ ". Ссылка:"+Выборка.СсылкаНаОбъект+ " .Номер сообщения: "+Выборка.НомерСообщения,"Информация");
				Исключение
					ЗаписатьВЛог("Ошибка дозагрузки обмена","Ошибка: "+ОписаниеОшибки()+". Запись удалена","Информация");
				КонецПопытки;
				//крохин кенец 06.12.2013
				ЕстьошибкиПриЗагрузке = Истина;		
				//крохин конец 09.10.2013
				Продолжить;
			КонецПопытки;
			//крохин конец 22.08.2013
			
			
			Данные.ОбменДанными.Загрузка	=Истина;
			Данные.ОбменДанными.Отправитель	=Отправитель;
			
			Данные.ДополнительныеСвойства.Вставить("ПараметрыЗагрузки",Новый Структура("Отправитель,НомерСообщения",Отправитель,Выборка.НомерСообщения));
			
			УзелОбъект=ПланыОбмена.Основной.ЭтотУзел().ПолучитьОбъект();
			//ПолучитьВариантЗагрузки(Данные,ТипДанных,Отправитель,Описание) Экспорт
			Описание		="";
			
			ПараметрыСеанса.НомерСообщения=Выборка.НомерСообщения;
			
			ВариантЗагрузки	=УзелОбъект.ПолучитьВариантЗагрузки(Данные,Запись.Тип,Отправитель,Описание);
			НовыйОбъект			= Ложь;
			ОтправитьОбратно	= Ложь;
			ЕстьРассогласования = Ложь;
			ОбъектЗагружен		= Ложь;
			
			Если ВариантЗагрузки="Полная" Тогда
				ОбъектЗагружен	=УзелОбъект.ЗаписатьПолныеДанныеВБазу(Данные,Запись.Тип,Отправитель,Описание,НовыйОбъект);						
			ИначеЕсли ВариантЗагрузки="Частичная" Тогда
				ОбъектЗагружен	=УзелОбъект.ЗаписатьВозможныеДанныеВБазу(Данные,Запись.Тип,Отправитель,Описание,НовыйОбъект,ЕстьРассогласования,ОтправитьОбратно);
			КонецЕсли;			
			
			ПараметрыСеанса.НомерСообщения=0;
			УзелОбъект.УдалитьИзЖурналаРассогласований(Данные.Ссылка,Отправитель);
		КонецЕсли; 
	КонецЦикла;	
	//крохин начало 09.10.2013
	//удаляем косячные записи
	Если ЕстьошибкиПриЗагрузке Тогда
		ЗаписатьВЛог("Ошибка дозагрузки обмена","Очистка регистра","Информация");
		наборЗаписей = РегистрыСведений.РассогласованияОбъектов.СоздатьНаборЗаписей();
		наборЗаписей.Записать();
		
	КонецЕсли;
	//крохин конец 09.10.2013
КонецПроцедуры

