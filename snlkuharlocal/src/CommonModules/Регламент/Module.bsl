Процедура ОповещениеОбИзмененииШтрихкодов(ТаблицаПараметров=Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	
	ТекстОбъекты = ""; ТекстТипРассылки = "";
	
	ТемаПисьма = "Оповещения об изменении штрих-кодов";
	
	Если ТаблицаПараметров <> Неопределено Тогда
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
		
			Если СтрокаТП.Имя = "ТемаПисьма" Тогда
				ТемаПисьма = ?(ЗначениеЗаполнено(СтрокаТП.Значение), СокрЛП(СтрокаТП.Значение), "Оповещения об изменении штрих-кодов");
			КонецЕсли;
			
			Если СтрокаТП.Имя = "Объекты" Тогда
				Если ЗначениеЗаполнено(СтрокаТП.Значение) Тогда
					Запрос.УстановитьПараметр("Объекты", СтрокаТП.Значение);
					ТекстОбъекты = "И Данные.Объект В(&Объекты)";
				КонецЕсли;
			КонецЕсли;
			
			Если СтрокаТП.Имя = "ТипРассылки" Тогда
				Если ЗначениеЗаполнено(СтрокаТП.Значение) Тогда
					Запрос.УстановитьПараметр("ТипРассылки", СтрокаТП.Значение);
					ТекстТипРассылки = "И Данные.ТипРассылки = &ТипРассылки";
				КонецЕсли;	
			КонецЕсли;
		
		КонецЦикла;
		                      
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Данные.Период КАК Период,
	|	Данные.Объект КАК Объект,
	|	Данные.ТипРассылки КАК ТипРассылки,
	|	Данные.ОписаниеИзменений КАК ОписаниеИзменений
	|ИЗ
	|	РегистрСведений.ДанныеДляОтправкиПочтовымУведомлением КАК Данные
	|ГДЕ
	|	Данные.ДатаФормированияУведомления = ДАТАВРЕМЯ(1, 1, 1)
	|	" + ТекстОбъекты + "
	|	" + ТекстТипРассылки + "
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	ТелоПисьма = "";
	Пока Выборка.Следующий() Цикл
		ТелоПисьма = ТелоПисьма + СокрЛП(Выборка.ОписаниеИзменений) + Символы.ПС;	
	КонецЦикла;
	
	СписокПолучателей = СформСписокПолучат(Справочники.ТипыРассылок.ОповещенияОбИзмененииШтрихкодов);
	
	Если НЕ ПустаяСтрока(ТелоПисьма) И СписокПолучателей.Количество() > 0 Тогда
		Ответ = СформироватьВнутреннееУведомление(СписокПолучателей, ТелоПисьма, ТемаПисьма,,,,"robot@collant.ru");
		Если ПустаяСтрока(Ответ) Тогда
			Выборка.Сбросить();
			Пока Выборка.Следующий() Цикл
				СтруктураЗаписи = Новый Структура("Период, Объект, ТипРассылки, ОписаниеИзменений");
				ЗаполнитьЗначенияСвойств(СтруктураЗаписи, Выборка);
				ДополнительныеРеквизиты = Новый Структура("ДатаФормированияУведомления", ТекущаяДата());
				РегистрыСведений.ДанныеДляОтправкиПочтовымУведомлением.СоздатьЗаписьДляОтправкиПочтовымСообщением(СтруктураЗаписи, ДополнительныеРеквизиты);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

