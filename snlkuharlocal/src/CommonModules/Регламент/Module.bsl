//
Функция ПолучитьДатуОтгрузкиСУчетомВыходныхКалендаря(Знач ДатаОтгрузки) Экспорт 

	Если ТипЗнч(ДатаОтгрузки) = Тип("Строка") Тогда
	
		ДатаОтгрузки = Дата(ДатаОтгрузки); 	
	
	КонецЕсли;
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	КалендарьДни.Дата КАК Дата
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	КалендарьДни.Часы <> 0
	|	И НАЧАЛОПЕРИОДА(КалендарьДни.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Дата0, ДЕНЬ)
	|	И НЕ КалендарьДни.Ссылка.ПометкаУдаления";
	Запрос.УстановитьПараметр("Дата0",ДатаОтгрузки); 
	РезультатЗапроса = Запрос.Выполнить(); 
	Если РезультатЗапроса.Пустой()  Тогда
		
		Возврат ПолучитьСледующуюДатуОтгрузки(КонецДня(ДатаОтгрузки)); 	
	Иначе 
		Возврат ДатаОтгрузки; 
	КонецЕсли; 


КонецФункции // ПолучитьДатуОтгрузкиПоЗаказуb2b()

