Процедура РассылкаОНаличииНезакрытыхКоллективныхРабот(ТаблицаПараметров = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаЗапретаРедактирование", ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());	
	Запрос.УстановитьПараметр("ДатаНачалаРабот", ТекущаяДатаСеанса() - 86400*1);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КоллективныеРаботы.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КоллективныеРаботы КАК КоллективныеРаботы
	|ГДЕ
	|	КоллективныеРаботы.ДатаНачалаРабот <= &ДатаНачалаРабот
	|	И КоллективныеРаботы.Проведен
	|	И НЕ КоллективныеРаботы.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Отгружена), ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Принята))
	|	И КоллективныеРаботы.Дата > &ДатаЗапретаРедактирование
	|	И КоллективныеРаботы.ДатаОкончанияРабот = ДАТАВРЕМЯ(1, 1, 1)";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Количество() = 0 Тогда Возврат; КонецЕсли;
	
	ТемаПисьма = "Рассылка о наличии незакрытых Коллективных работ";
	ТипРассылки = Справочники.ТипыРассылок.НаличиеНезакрытыхКоллективныхРабот;
	ФлагРассылки = "РассылкиЭлПочта";
	
	ТелоПисьма = "";
	Пока Выборка.Следующий() Цикл
		ТелоПисьма = ТелоПисьма + СокрЛП(Выборка.Ссылка) + Символы.ПС;	
	КонецЦикла;
	
	СписокПолучателей = СформСписокПолучат(ТипРассылки, , ФлагРассылки);
	
	Если НЕ ПустаяСтрока(ТелоПисьма) И СписокПолучателей.Количество() > 0 Тогда
		Ответ = СформироватьВнутреннееУведомление(СписокПолучателей, ТелоПисьма, ТемаПисьма,,,,"robot@collant.ru");
	КонецЕсли;
	
КонецПроцедуры
