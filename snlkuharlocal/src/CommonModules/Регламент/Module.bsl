Функция ПолучитьСледующуюДатуОтгрузкиСУчетомВыходных()  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Дата	
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	(КалендарьДни.Часы <> 0 ИЛИ КалендарьДни.ОтгрузкаВВыходной)
	|	И КалендарьДни.Дата > &Дата0
	|	И НЕ Ссылка.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО Дата";
	
	Запрос.УстановитьПараметр("Дата0",КонецДня(ТекущаяДата()));
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Дата;
	Иначе	
		ЗаписатьВЛог("Регламент","Не заполнен календарь на !","Ошибка");
		
		Возврат КонецДня(ТекущаяДата())+1;		 		
	КонецЕсли;
	
КонецФункции 


Процедура ОбновлениеДанныхЗОГ(ТаблицаПараметров=Неопределено) Экспорт
	ЗаписатьВЛог("Регламент","Обновление данных ЗОГ. Начало выполнения.","Информация");
	//крохин начало 11.05.2011
	//если есть параметр, обновляем данные ЗОГ за прошлый день
	//Выборка=Документы.ЗаявкаНаОтгрузку.Выбрать(КонецДня(ТекущаяДата())+1,КонецДня(ТекущаяДата())+7*24*60*60);
	// Кухарь А.Ю. 18.03.2022 начало
	// Отбор по складу
	Склад=Неопределено; 
	// Кухарь А.Ю. 18.03.2022 конец
	
	ОбновлятьПрошлыйДень = Ложь;    
	
	ОбновлятьПаллеты     = Ложь;
	
	Если ТаблицаПараметров<>Неопределено Тогда
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			Если СтрокаТП.Имя="ОбновлятьПрошлыйДень" Тогда
				ОбновлятьПрошлыйДень=СтрокаТП.Значение;
			КонецЕсли; 
			
			//Тимофеев Ю.А. 18.08.2023 Начало 
			Если СтрокаТП.Имя="ОбновлятьПаллеты" Тогда
				ОбновлятьПаллеты=СтрокаТП.Значение;
			КонецЕсли; 
			//Тимофеев Ю.А. 18.08.2023 Конец 
			
			// Кухарь А.Ю. 18.03.2022 начало
			//Прервать;
			Если СтрокаТП.Имя="Склад" Тогда
				Склад=СтрокаТП.Значение;
			КонецЕсли;
			// Кухарь А.Ю. 18.03.2022 конец
			
		КонецЦикла;
	КонецЕсли;
	Если ОбновлятьПрошлыйДень Тогда
		Выборка=Документы.ЗаявкаНаОтгрузку.Выбрать(НачалоДня(ТекущаяДата()),КонецДня(ТекущаяДата())+7*24*60*60);	
	Иначе
		Выборка=Документы.ЗаявкаНаОтгрузку.Выбрать(КонецДня(ТекущаяДата())+1,КонецДня(ТекущаяДата())+7*24*60*60);
	КонецЕсли;
	//крохин конец  11.05.2011
	
	Пока Выборка.Следующий() Цикл
		//крохин начало 10.06.2013
		//по ошибке могут создать лишние
		Если НЕ Выборка.Проведен Тогда Продолжить КонецЕсли;
		//крохин конец 10.06.2013
		
		// Кухарь А.Ю. 18.03.2022 начало
		// Отбор по складу
		если Склад<>Неопределено и Выборка.Склад<>Склад тогда
			Продолжить;
		КонецЕсли;
		// Кухарь А.Ю. 18.03.2022 конец
		
		
		ВремДок=Выборка.ПолучитьОбъект();					
		ВремДок.ОбновитьСостоянияНакладных();
		//Тимофеев Ю.А. 18.08.2023 Начало   
		Если ОбновлятьПаллеты Тогда
			ВремДок.ОбновитьСостояниеПаллет();
		КонецЕсли;
		//Тимофеев Ю.А. 18.08.2023 Конец
		ВремДок.Записать();
		
		ЗаписатьВЛог("Регламент","Обновление данных ЗОГ. Обработан: "+ВремДок.Ссылка,"Информация");
	КонецЦикла;		
	
	ЗаписатьВЛог("Регламент","Обновление данных ЗОГ. Завершение выполнения.","Информация");
КонецПроцедуры

