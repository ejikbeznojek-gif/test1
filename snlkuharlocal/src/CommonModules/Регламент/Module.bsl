Функция ТаблицаПараметровВСоответствие(тПараметры) Экспорт
	Результат = Новый Соответствие;
	Для каждого СтрокаП Из тПараметры Цикл		
		ТекЗнач = СтрокаП.Значение;
		
		БылоЗначение = Результат[СтрокаП.Имя];
		Если БылоЗначение <> Неопределено Тогда			
			Если ТипЗнч(БылоЗначение) <> Тип("Массив") Тогда				
				ВремЗначение = БылоЗначение;
				
				БылоЗначение = Новый Массив;
				БылоЗначение.Добавить(ВремЗначение);
			КонецЕсли;						
			БылоЗначение.Добавить(ТекЗнач);
			
			ТекЗнач = БылоЗначение;
		КонецЕсли;			
		Результат[СтрокаП.Имя] = ТекЗнач;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ТаблицаПараметровВСоответствие()

// Шворобей ВЮ 17.04.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-4200
Функция ПолучитьСледующуюДатуОтгрузки(Знач ДатаОтсчета = Неопределено, ДокументСсылка = Неопределено, Рекурсия = 0) Экспорт
	
	ФлагЭтоСкладFBS = Ложь;
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		
		текПунктДоставки = ЗначениеРеквизитаОбъекта(ДокументСсылка, "ПунктДоставки");
		
		Если ЗначениеЗаполнено(текПунктДоставки) Тогда
			
			ФлагОтгружать = ПолучитьЗначениеКатегорииОбъекта(текПунктДоставки, "Отгружать 24/7");
			
			Если ФлагОтгружать Тогда
				Возврат КонецДня(ТекущаяДата()) + 1;	
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументСсылка.Склад) И ДокументСсылка.Склад.ЭтоСкладFBS Тогда
			ФлагЭтоСкладFBS = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	//++Данилова Е.В. 25.10.2024
	Если ЗначениеЗаполнено(ДатаОтсчета) Тогда
		Дата0 = КонецДня(ДатаОтсчета);
	ИначеЕсли ЗначениеЗаполнено(ДокументСсылка) Тогда
		Дата0 = КонецДня(ДокументСсылка.Дата);
	Иначе
		Дата0 = КонецДня(ТекущаяДата());	
	КонецЕсли;
	Запрос.УстановитьПараметр("Дата0", Дата0);
	//--Данилова Е.В. 25.10.2024
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КалендарьДни.Дата КАК Дата
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	КалендарьДни.Часы <> 0
	|	И КалендарьДни.Дата > &Дата0
	|	И НЕ КалендарьДни.Ссылка.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	КалендарьДни.Дата";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		СледующаяДатаОтгрузки = Выборка.Дата;
		Если Рекурсия > 0 Тогда
			Возврат СледующаяДатаОтгрузки;	
		КонецЕсли;
	Иначе	
		ЗаписатьВЛог("Регламент","Не заполнен календарь на !","Ошибка");
		//++Данилова Е.В. 25.10.2024
		Возврат Дата0 + 1;
		//--Данилова Е.В. 25.10.2024
	КонецЕсли;
	
	Если НЕ ФлагЭтоСкладFBS Тогда
		СледующаяДатаОтгрузки = ПолучитьСледующуюДатуОтгрузки(СледующаяДатаОтгрузки,, Рекурсия + 1);
	КонецЕсли;
	
	Возврат СледующаяДатаОтгрузки;
	
КонецФункции
//крохин конец 01.11.2018

Процедура ФормированиеЗаявокНаОтгрузку(ТаблицаПараметров=Неопределено) Экспорт
	ЗаписатьВЛог("Регламент","Начало выполнения. "+ТипЗнч(ТаблицаПараметров),"Информация");
	Если ТаблицаПараметров<>Неопределено Тогда
		Параметры=Новый Соответствие;
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			ЗаписатьВЛог("Регламент","Параметр: "+СтрокаТП.Имя+" - "+СтрокаТП.Значение,"Информация");		
			Параметры.Вставить(СтрокаТП.Имя,СтрокаТП.Значение);
		КонецЦикла;	
		
		
		ДатаОтгрузки=Параметры.Получить("ДатаОтгрузки");
		Если ДатаОтгрузки=Неопределено Тогда
				 
			//Кухарь А.Ю.  28.05.2025 начало              
			//ДатаОтгрузки=ПолучитьСледующуюДатуОтгрузки();	
			ДатаОтгрузки=ПолучитьСледующуюДатуОтгрузки(,,1);	 
			//Кухарь А.Ю.  28.05.2025 конец
			
		КонецЕсли;
		
		//крохин начало 01.11.2018
		//по выходным формируем дополнительный ЗОГ отдельным заданием со служебным параметром.
		ОтгрузкаПоВыходным = Параметры.Получить("ОтгрузкаПоВыходным");
		Если ОтгрузкаПоВыходным <> Неопределено И ОтгрузкаПоВыходным Тогда
			ДатаОтгрузкиПоВыходным = ПолучитьСледующуюДатуОтгрузкиСУчетомВыходных();
			Если ДатаОтгрузкиПоВыходным = ДатаОтгрузки Тогда
				ЗаписатьВЛог("Регламент","ЗОГ по выходным. Отмена выполнения","Информация");	
				Возврат;
			Иначе
				ДатаОтгрузки = ДатаОтгрузкиПоВыходным;
				ЗаписатьВЛог("Регламент","ЗОГ по выходным. Запуск выполнения на "+ Формат(ДатаОтгрузки,"ДФ=dd.MM.yyyy"),"Информация");
			КонецЕсли;
		КонецЕсли;
		
		//крохин конец 01.11.2018
		
		ВидЗаявки=Параметры.Получить("ВидЗаявки");
		Если ВидЗаявки=Неопределено Тогда			
			ЗаписатьВЛог("Регламент","В параметрах не задан вид заявки !","Ошибка");
			Возврат;
		КонецЕсли; 
		
		Склады=ТаблицаПараметров.НайтиСтроки(Новый Структура("Имя","Склад"));
		Для Каждого СтрокаСклада Из Склады Цикл
			Склад=СтрокаСклада.Значение;
			ЗаписатьВЛог("Регламент","Формирование ЗОГ по складу: "+Склад+", вид: "+ВидЗаявки,"Информация");	
			
			Док=Неопределено;
			Выборка=Документы.ЗаявкаНаОтгрузку.Выбрать(НачалоДня(ДатаОтгрузки),КонецДня(ДатаОтгрузки),Новый Структура("Склад",Склад));
			Пока Выборка.Следующий() Цикл				
				Если Док=Неопределено Тогда
					Док=Выборка.Ссылка;			
				Иначе					
					ВремДок=Выборка.ПолучитьОбъект();					
					ВремДок.УстановитьПометкуУдаления(Истина);					
				КонецЕсли;				
