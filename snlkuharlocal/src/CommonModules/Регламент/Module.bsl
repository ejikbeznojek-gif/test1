Процедура АвтоматизацияРаботыСЗаказамиКМ_ОУКЭП(ТаблицаПараметров) Экспорт
	Если ТаблицаПараметров<>Неопределено Тогда
		СоответствиеПараметры = Новый Соответствие; 
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			СоответствиеПараметры.Вставить(СтрокаТП.Имя,СтрокаТП.Значение); 			
		КонецЦикла;
		
		ОшибкаПараметров = ложь; 
		
		Если СоответствиеПараметры.Получить("Организация") = неопределено Тогда
		
			ЗаписатьВЛог("Регламент_ЗаказыКМ_ОУКЭП","Не задан параметр ""Организация"" ","Ошибка!!!",истина);
			
			ОшибкаПараметров = истина; 
		
		КонецЕсли;
		Если СоответствиеПараметры.Получить("Подразделение") = неопределено Тогда
		
			ЗаписатьВЛог("Регламент_ЗаказыКМ_ОУКЭП","Не задан параметр ""Подразделение"" ","Ошибка!!!",истина);	
			
			ОшибкаПараметров = истина;
		КонецЕсли;
		
		Если СоответствиеПараметры.Получить("Этап") = неопределено Тогда
		
			ЗаписатьВЛог("Регламент_ЗаказыКМ_ОУКЭП","Не задан параметр ""Этап"" ","Ошибка!!!",истина);	
			
			ОшибкаПараметров = истина;
		КонецЕсли;
		
		Если ОшибкаПараметров Тогда
		
			Возврат; 	
		
		КонецЕсли;
		
		
		
		ОбработкаЗаказовКМ = Обработки.ФормированиеИОбработкаЗаказовКМ.Создать();
		ОбработкаЗаказовКМ.Организация = СоответствиеПараметры.Получить("Организация"); 
		
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			Если СтрокаТП.Имя = "Подразделение" Тогда
				
				ОбработкаЗаказовКМ.Подразделение.Добавить(СтрокаТП.Значение); 
				
			КонецЕсли; 		
		КонецЦикла; 	
		
		//в дальнейшем их останется 3 
		Этап = СоответствиеПараметры.Получить("Этап");		
		
		ПараметрыОбработки = Новый Структура; 
		ПараметрыОбработки.Вставить("Организация",ОбработкаЗаказовКМ.Организация);
		ПараметрыОбработки.Вставить("Подразделение",ОбработкаЗаказовКМ.Подразделение.ВыгрузитьЗначения());
		
		ПроцедураОбработки = "ОбработкаЗаказовКМ.Этап"+Строка(Этап) + "(ПараметрыОбработки)"; 
		Попытка
		
			Выполнить ПроцедураОбработки;	
		
		Исключение
		    ЗаписатьВЛог("Регламент_ЗаказыКМ_ОУКЭП","Не найдена процедура обработки для выполнения или ошибка выполнения!!","Ошибка",истина);
		КонецПопытки; 		

	Иначе 
		 
	КонецЕсли;
КонецПроцедуры
