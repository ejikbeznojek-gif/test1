		Пока Выборка.Следующий() Цикл			
			Возврат  Выборка.Скидка;
		КонецЦикла;
		
		
		
	Иначе
		Запрос=Новый Запрос;
		//Запрос.Текст="
		//|ВЫБРАТЬ ПЕРВЫЕ 1		
		//|	Скидка,ТипЦен,
		//|	ВЫБОР 
