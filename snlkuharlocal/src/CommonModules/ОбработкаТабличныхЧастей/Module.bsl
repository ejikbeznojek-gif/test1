КонецФункции

//Мессерле Для группового получения свойств номенклатуры (Номенклатура- первый параметр:можно задавать как элемент, так и группу (модель))
Функция ПолучитьСвойстваНоменклатуры(Номенклатура,МассивНоменклатуры=НЕОПРЕДЕЛЕНО,ВремТз=Неопределено)  Экспорт
	
	Свойства=Новый Структура;
	
	Если НЕ(ВремТз="" или ВремТз=НЕОПРЕДЕЛЕНО) тогда
		
		Стр=ВремТз.найти(номенклатура,"Номенклатура");
		Если Стр<>Неопределено тогда
			Если  стр.свойства<>Неопределено тогда
				Возврат(стр.свойства);
			Конецесли;
		Конецесли;
		
		Стр=ВремТз.найти(номенклатура,"Модель");
		Если Стр<>Неопределено тогда
			Если  стр.свойства<>Неопределено тогда  
				Возврат(стр.свойства);
			Конецесли;
		Конецесли;
		
		
		Если Стр=Неопределено тогда
			Возврат(свойства);
		Конецесли;
		
	Конецесли;
	
	
	если МассивНоменклатуры<>Неопределено тогда //Передали что-то
		
		Если ВремТз="" тогда
			
			
			Запрос=Новый Запрос;
			
			Запрос.Текст="ВЫБРАТЬ
			|	аа.Свойство,
			|	аа.Значение,
			|	аа.Уровень КАК Уровень,
			|	аа.номенклатура,
			|	аа.Модель
			|ИЗ
			|	(ВЫБРАТЬ
			|		ЗначенияСвойствОбъектов.Свойство КАК Свойство,
			|		ЗначенияСвойствОбъектов.Значение КАК Значение,
			|		0 КАК Уровень,
			|		Номенклатура.Ссылка КАК номенклатура,
			|		Номенклатура.Родитель КАК Модель
			|	ИЗ
			|		Справочник.Номенклатура КАК Номенклатура
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
			|			ПО Номенклатура.Ссылка = ЗначенияСвойствОбъектов.Объект
			|	ГДЕ
			|		Номенклатура.Ссылка В(&СписокНоменклатуры)
			|		И Номенклатура.ЭтоГруппа = ЛОЖЬ
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		ЗначенияСвойствОбъектов.Свойство,
			|		ЗначенияСвойствОбъектов.Значение,
			|		1,
			|		Номенклатура.Ссылка,
			|		Номенклатура.Родитель
			|	ИЗ
			|		Справочник.Номенклатура КАК Номенклатура
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
			|			ПО Номенклатура.Родитель = ЗначенияСвойствОбъектов.Объект
			|	ГДЕ
			|		Номенклатура.Ссылка В(&СписокНоменклатуры)
			|		И Номенклатура.ЭтоГруппа = ЛОЖЬ
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		ЗначенияСвойствОбъектов.Свойство,
			|		ЗначенияСвойствОбъектов.Значение,
			|		2,
			|		Номенклатура.Ссылка,
			|		Номенклатура.Родитель
			|	ИЗ
			|		Справочник.Номенклатура КАК Номенклатура
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
			|			ПО Номенклатура.Родитель.Родитель = ЗначенияСвойствОбъектов.Объект
			|	ГДЕ
			|		Номенклатура.Ссылка В(&СписокНоменклатуры)
			|		И Номенклатура.ЭтоГруппа = ЛОЖЬ) КАК аа
			|ГДЕ
			|	(НЕ аа.Значение ЕСТЬ NULL )
			|
			|УПОРЯДОЧИТЬ ПО
			|	номенклатура,Уровень";	
			
			Свойства=Новый Структура;
			
			Запрос.УстановитьПараметр("СписокНоменклатуры",МассивНоменклатуры);
			
			ВремТз=Запрос.Выполнить().Выгрузить();
			ВремТз.Колонки.Добавить("Свойства");
			ВремТз.Индексы.Добавить("Номенклатура");
			ВремТз.Индексы.Добавить("Модель");
			
			старном="";
			Для каждого стр из ВремТз цикл
				Попытка
					Если старНом<>Стр.номенклатура тогда
						Свойства=Новый Структура;
					Конецесли;
					СтарНом=Стр.номенклатура;
					КодСвойства=СтрЗаменить(стр.Свойство,"""","");	
					КодСвойства=СтрЗаменить(стр.Свойство," ","");
					
					//крохин начало 01.03.2012
					//Свойства.Вставить(КодСвойства,стр.Значение);
					Если стр.Свойство <> Null Тогда
						Свойства.Вставить(КодСвойства,стр.Значение);
					КонецЕсли;
					//крохин конец 01.03.2012
					стр.свойства=Свойства;
					
				Исключение
					//Сообщить("Ошибочное свойство: "+стр.Свойство);
				КонецПопытки;		
			КонецЦикла;	
			
			Стр=ВремТз.найти(номенклатура,"Номенклатура");
			Если Стр=Неопределено тогда
				
				Стр=ВремТз.найти(номенклатура,"Модель");
				Если Стр<>Неопределено тогда
					Возврат(стр.Свойства);
				Конецесли;
				
				Возврат(Свойства);
				
			иначе
				Возврат(стр.Свойство);
			Конецесли;
			
		Конецесли; //ВремТз пустая
		
		//мессерле
		
	иначе
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ЗначенияСвойствОбъектов.Объект = &Брэнд
		|			ТОГДА 1
		|		КОГДА ЗначенияСвойствОбъектов.Объект = &Модель
		|			ТОГДА 2
		|		КОГДА ЗначенияСвойствОбъектов.Объект = &Номенклатура
		|			ТОГДА 3
		|		ИНАЧЕ 4
		|	КОНЕЦ КАК Уровень,
		|	ЗначенияСвойствОбъектов.Свойство,
		|	ЗначенияСвойствОбъектов.Значение
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	(ЗначенияСвойствОбъектов.Объект = &Модель
		|			ИЛИ ЗначенияСвойствОбъектов.Объект = &Брэнд
		|			ИЛИ ЗначенияСвойствОбъектов.Объект = &Номенклатура)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Уровень,
		|	ЗначенияСвойствОбъектов.Объект";	
		
		Свойства=Новый Структура;
		
		Запрос.УстановитьПараметр("Модель",Номенклатура.Родитель);
		Запрос.УстановитьПараметр("Брэнд",Номенклатура.Родитель.родитель);
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		
		Выборка=Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Попытка
				КодСвойства=СтрЗаменить(Выборка.Свойство,"""","");	
				КодСвойства=СтрЗаменить(Выборка.Свойство," ","");
				
				Свойства.Вставить(КодСвойства,Выборка.Значение);		
			Исключение
				//крохин начало 26.02.2013
				//мешает сообщение
				//Сообщить("Ошибочное свойство: "+Выборка.Свойство);
				//крохин конец 26.02.2013
			КонецПопытки;		
		КонецЦикла;	
		
		Возврат Свойства;
	Конецесли;
КонецФункции //ПолучитьСвойстваНоменклатуры(Номенклатура) 


// <Описание функции>
//
// Параметры
//  <Параметр1>  – <Тип.Вид> – <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  – <Тип.Вид> – <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   – <описание возвращаемого значения>
//
Функция ПолучитьЦенуНоменклатуры_Старая(Номенклатура,Единица=Неопределено,ТипЦен,ВалютаДокумента,КурсДокумента,ДатаРасчета=Неопределено) Экспорт
	Запрос=Новый Запрос;
	
	Если ДатаРасчета=Неопределено Тогда
		#Если Клиент Тогда		
			ТекДатаРасчета=КонецДня(РабочаяДата);
		#Иначе
			ТекДатаРасчета=КонецДня(ТекущаяДата());		
		#КонецЕсли		
	Иначе
		ТекДатаРасчета=КонецДня(ДатаРасчета);	
	КонецЕсли;
	
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1		
	|	Прайс.Цена,	
	|	ВЫБОР 
	|		КОГДА СпрНом.Ссылка 							= Прайс.Номенклатура ТОГДА 1 
	|		КОГДА СпрНом.Ссылка.Родитель					= Прайс.Номенклатура ТОГДА 2 
	//|		КОГДА СпрНом.Ссылка.Родитель.Родитель			= Прайс.Номенклатура ТОГДА 3 
	//|		КОГДА СпрНом.Ссылка.Родитель.Родитель.Родитель	= Прайс.Номенклатура ТОГДА 4
	|	ИНАЧЕ NULL
	|	КОНЕЦ*10000000000+РАЗНОСТЬДАТ(Прайс.Ссылка.Дата,&Дата2,Секунда) КАК Уровень
	|ИЗ
	|	Документ.ПрайсЛист.Товары КАК Прайс
	|ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|ПО (
	|	СпрНом.Ссылка 								= Прайс.Номенклатура ИЛИ 
	|	СпрНом.Ссылка.Родитель						= Прайс.Номенклатура 
	//ИЛИ
	//|	СпрНом.Ссылка.Родитель.Родитель				= Прайс.Номенклатура ИЛИ
	//|	СпрНом.Ссылка.Родитель.Родитель.Родитель	= Прайс.Номенклатура 
	|	)
	|ГДЕ 
	|	Прайс.Ссылка.Проведен
	|	И Прайс.Ссылка.ТипЦен	= &ТипЦен
	|	И НАЧАЛОПЕРИОДА(Прайс.Ссылка.Дата,День)<= &Дата2
	|	И КОНЕЦПЕРИОДА(Прайс.Ссылка.Дата2,День)>= &Дата2
	|	И СпрНом.Ссылка 	= &Номенклатура";
	
	Если НЕ Номенклатура.ЭтоГруппа Тогда
		Запрос.Текст=Запрос.Текст+"						
		|	И СпрНом.ЭтоГруппа 	= Ложь";	
	КонецЕсли; 
	
	Запрос.Текст=Запрос.Текст+"
	|УПОРЯДОЧИТЬ ПО Уровень";
	
	Запрос.УстановитьПараметр("Дата2",			ТекДатаРасчета);
	Запрос.УстановитьПараметр("ТипЦен",			ТипЦен);
	Запрос.УстановитьПараметр("Номенклатура",	Номенклатура);
	
	Результат=Запрос.Выполнить();
	
	//крохин начало 22.09.2011
	//единицу не используем больше
	//Коэффициент=?(Единица=Неопределено,1,Единица.Коэффициент);
	Коэффициент = 1;
	//крохин конец 22.09.2011;
	
	
	Выборка=Результат.Выбрать();
	Пока Выборка.Следующий() Цикл			
		Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);
	КонецЦикла;
	
	Возврат Неопределено;
КонецФункции // ПолучитьЦенуНоменклатуры()

