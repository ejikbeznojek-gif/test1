	Если МетаданныеДокумента.Имя = "КонтрактСПроизводителем" и СтрокаТЧ.Цена>0 и ТипЗнч(ДопПараметры) = Тип("Структура")  Тогда
		если ДопПараметры.Свойство("ВыделятьЦенуУпаковки") и ДопПараметры.Свойство("ТипЦеныУпаковки") тогда
			ЦенаУпаковки=ПолучитьЦенуНоменклатуры(СтрокаТЧ.Номенклатура,СтрокаТЧ.Единица,ДопПараметры.ТипЦеныУпаковки,ДокументОбъект.Валюта,ДокументОбъект.Курс,ДокументОбъект.Дата);
			если ЦенаУпаковки >= СтрокаТЧ.Цена тогда  
				СтрокаТЧ.ЦенаБезУпаковки = СтрокаТЧ.Цена;  
				СтрокаТЧ.ЦенаУпаковки = 0;    
				СообщитьИзМодуля(СтрШаблон("Цена упаковки по %1 - больше или равна общей цене, это некорректно. Цена упаковки обнулена.",СтрокаТЧ.Номенклатура));
			иначе
				СтрокаТЧ.ЦенаБезУпаковки = СтрокаТЧ.Цена - ЦенаУпаковки;
				СтрокаТЧ.ЦенаУпаковки = ЦенаУпаковки;				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	// Кухарь А.Ю. 27.10.2025 конец
	
КонецПроцедуры // РассчитатьСуммуТабЧасти()

