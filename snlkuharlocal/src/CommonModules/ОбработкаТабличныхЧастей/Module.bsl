Функция КонтрольДублейСтрокБезСертификатов(ДокОбъект) Экспорт	
	СтрокиДублей		= Новый Соответствие;
	УдаляемыеСтроки     = Новый Массив;
	МетаДок				= ДокОбъект.Метаданные();
	
	//+++Чирков - 16.01.13 надоели ошибки в логах
	Если НЕ ЕстьТабЧастьДокумента("Товары",МетаДок) Тогда	
		Возврат Истина;		
	КонецЕсли;
	//---Чирков
	
	СуммируемыеКолонки	= Новый Массив;
	Если ЕстьРеквизитТабЧастиДокумента("Заявка",МетаДок,"Товары") Тогда
		СуммируемыеКолонки.Добавить("Заявка");
	КонецЕсли; 
	Если ЕстьРеквизитТабЧастиДокумента("ПодтвержденнаяЗаявка",МетаДок,"Товары") Тогда
		СуммируемыеКолонки.Добавить("ПодтвержденнаяЗаявка");
	КонецЕсли;
	Если ЕстьРеквизитТабЧастиДокумента("КоличествоРасч",МетаДок,"Товары") Тогда
		СуммируемыеКолонки.Добавить("КоличествоРасч");
	КонецЕсли;
	Если ЕстьРеквизитТабЧастиДокумента("КоличествоФакт",МетаДок,"Товары") Тогда
		СуммируемыеКолонки.Добавить("КоличествоФакт");
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из ДокОбъект.Товары Цикл	
		Если СтрокаТЧ.Номенклатура.ВидНоменклатуры=Перечисления.ВидыНоменклаутры.ПодарочныйСертификат Тогда
			Продолжить;
		КонецЕсли;
		//крохин начало 27.07.2021
		//сворачиваем только строки без акции
		Если СтрокаТЧ.АвтопроверяемаяАкция.ПродажаБлочкамиПоФиксированнымЦенам Тогда
			Продолжить;	
		КонецЕсли;
		//крохин конец 27.07.2021
		СтрокаДубля=СтрокиДублей.Получить(СтрокаТЧ.Номенклатура);
		Если СтрокаДубля=Неопределено Тогда
			СтрокиДублей.Вставить(СтрокаТЧ.Номенклатура,СтрокаТЧ);	
		Иначе			
			СтрокаДубля.Количество	=СтрокаДубля.Количество	+СтрокаТЧ.Количество;
			Если ЕстьРеквизитТабЧастиДокумента("Всего",МетаДок,"Товары") Тогда
				СтрокаДубля.Всего		=СтрокаДубля.Всего		+СтрокаТЧ.Всего;
			Конецесли;
			Для Каждого Колонка Из СуммируемыеКолонки Цикл
				СтрокаДубля[Колонка]=СтрокаДубля[Колонка]+СтрокаТЧ[Колонка];			
			КонецЦикла;			
			
			РассчитатьСуммуТабЧасти(СтрокаДубля,ДокОбъект,"ОтВсего");			
			
			УдаляемыеСтроки.Добавить(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла; 	
	
	Для Каждого СтрокаТЧ ИЗ УдаляемыеСтроки Цикл
		ДокОбъект.Товары.Удалить(СтрокаТЧ);		
	КонецЦикла;
	
	ПроверитьСоответствиеЗаявке(ДокОбъект);
	
