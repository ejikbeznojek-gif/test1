Процедура ОткрытьПодборМарок(Форма) Экспорт
	СтрокаТЧ=Форма.ЭлементыФормы.Товары.ТекущаяСтрока;
	
	ФормаПодбора=ПолучитьОбщуюФорму("ПодборПартий",Форма);	
	ФормаПодбора.Документ		=Форма.Ссылка;
	
	Если Форма.Ссылка.Метаданные().ТабличныеЧасти.Товары.Реквизиты.Найти("Склад")<>Неопределено Тогда
		ФормаПодбора.Склад			=СтрокаТЧ.Склад;
	ИначеЕсли Форма.Ссылка.Метаданные().Реквизиты.Найти("Склад")<>Неопределено Тогда
		ФормаПодбора.Склад			=Форма.Склад;		
	ИначеЕсли Форма.Ссылка.Метаданные().Реквизиты.Найти("СкладОтправитель")<>Неопределено Тогда
		ФормаПодбора.Склад			=Форма.СкладОтправитель;
	Иначе
		Сообщить("Ошибка определения склада источника !",СтатусСообщения.Важное);
	КонецЕсли; 	
	
	ФормаПодбора.Номенклатура	=СтрокаТЧ.Номенклатура;
	
	Попытка
		ФормаПодбора.Количество		=СтрокаТЧ.Заказ;
	Исключение
		ФормаПодбора.Количество		=СтрокаТЧ.Количество;		
	Конецпопытки;
	
	ФормаПодбора.Открыть();
КонецПроцедуры

Процедура ОткрытьПодборКредДокументов(Форма,Элемент,Контрагент,Договор) Экспорт	
	
	ФормаПодбора=ПолучитьОбщуюФорму("ПодборКредДокументов",Элемент);	
	ФормаПодбора.Документ	=Форма.Ссылка;
	
	ФормаПодбора.Контрагент	=Контрагент;
	ФормаПодбора.Договор	=Договор;
	
	ФормаПодбора.Открыть();
КонецПроцедуры

