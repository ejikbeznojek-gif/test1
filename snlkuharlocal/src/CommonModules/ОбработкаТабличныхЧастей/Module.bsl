// Функция ПолучитьТЗУпаковки(ТЧ)   Экспорт
Функция ПолучитьТЗУпаковки(ТЧ,Контрагент=Неопределено)   Экспорт	 
	// Кухарь А.Ю. 08.09.2021 конец
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Родитель");
	ТЗ.Колонки.Добавить("Количество");
	ТЗ.Колонки.Добавить("Номенклатура2");
	
	//Кухарь 09.02.17 начало
	//Часть упаковки будет использоваться только при определённой доп обработки.
	ТЗ.Колонки.Добавить("ДопОбработка");
	//Кухарь 09.02.17 конец
	
	//крохин начало 18.05.2015
	//не используется
	//ТЗ.Колонки.Добавить("Заказ");
	//крохин конец 18.05.2015
	Для Каждого СтрокаТЧ ИЗ ТЧ Цикл
		ВыборкаУпаковки = Справочники.Упаковка.Выбрать(,СтрокаТЧ.Номенклатура);
		Пока ВыборкаУпаковки.Следующий() Цикл  
			//Кухарь 22.10.18 начало
			//фиктивная упаковка для носков и колготок
			если ВыборкаУпаковки.НезаполнятьВНакладных тогда
				Продолжить;
			КонецЕсли;
			//Кухарь 22.10.18 конец
			
			Для Каждого СтрокаУпаковки Из ВыборкаУпаковки.ЭлементыУпаковки Цикл
				// Кухарь А.Ю. 08.09.2021 начало
				// Упаковка для разных клиентов
				если  ЗначениеЗаполнено(СтрокаУпаковки.Контрагент) и СтрокаУпаковки.Контрагент<>Контрагент тогда Продолжить;КонецЕсли; 
				// Кухарь А.Ю. 08.09.2021 конец
				
				
				СтрокаТЗ = ТЗ.Добавить();
				//Кухарь 09.02.17 начало
				//Часть упаковки будет использоваться только при определённой доп обработки.
				СтрокаТЗ.ДопОбработка=СтрокаУпаковки.ВидДопОбработки;
