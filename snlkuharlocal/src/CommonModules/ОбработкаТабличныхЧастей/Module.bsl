//Кухарь 06.12.18 начало
Функция ПроверитьЗаполнитьЦеныПРМПоСебестоимостиФранч (ДокОбъект) экспорт
	// Кухарь А.Ю.  02.08.2022 начало
	// Для ЦО проверка не нужна
	если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
		возврат Истина;
	КонецЕсли;
	// Кухарь А.Ю.  02.08.2022 конец
	
	
	если ложь тогда ДокОбъект=Документы.Перемещение.ПустаяСсылка().ПолучитьОбъект();КонецЕсли;
	если ДокОбъект.Ссылка=Документы.Перемещение.ПустаяСсылка() тогда
		СообщитьИзМодуля("Сначала запишите ПРМ");
		возврат ложь;
	КонецЕсли;
	
	Граница=Последовательности.Товары.ПолучитьГраницу();   
	//Кухарь 12.12.18 начало
	//Конфигураторная ошибка	
	//если Граница.Дата<ДокОбъект.Ссылка.дата тогда	
	если Граница.Ссылка.Дата<ДокОбъект.Ссылка.дата тогда
		//Кухарь 12.12.18 конец		
		СообщитьИзМодуля("Перед отгрузкой проведите базу");
		возврат ложь;
	КонецЕсли;
	
	Товары=ДокОбъект.Товары;
	ЕстьСебестоимость=Истина;
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПеремещениеТовары.Номенклатура
	|ПОМЕСТИТЬ т1
	|ИЗ
	|	Документ.Перемещение.Товары КАК ПеремещениеТовары
	|ГДЕ
	|	ПеремещениеТовары.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СРЕДНЕЕ(ВЫБОР
	|			КОГДА ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) = 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(ОстаткиТМЦОстатки.СуммаОстаток, 0) / ОстаткиТМЦОстатки.КоличествоОстаток
	|		КОНЕЦ) КАК Себестоимость,
	|	т1.Номенклатура
	|ИЗ
	|	т1 КАК т1
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад = &Склад) КАК ОстаткиТМЦОстатки
	|		ПО т1.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	т1.Номенклатура";
	запрос.УстановитьПараметр("Ссылка",ДокОбъект.Ссылка);
	//Кухарь 12.12.18 начало
	//Конфигураторная ошибка
	запрос.УстановитьПараметр("Дата2",ДокОбъект.Дата);
	запрос.УстановитьПараметр("Склад",ДокОбъект.склад);
	//Кухарь 12.12.18 конец	
	Результат=запрос.Выполнить().Выгрузить();		
	Для каждого СтрТЧ из Товары цикл
		СтрТЗ=Результат.Найти(СтрТЧ.Номенклатура);
		если СтрТЗ=Неопределено   тогда 	
			СтрТЧ.Цена=0;
			Продолжить;
		КонецЕсли;	
		Себестоимость=СтрТЗ.Себестоимость;
		СтрТЧ.Цена=Себестоимость;
		СтрТЧ.ЦенаБезСкидки=Себестоимость;		
		СтрТЧ.Себестоимость=Себестоимость*СтрТЧ.Количество;	
	КонецЦикла;
	
	Отбор=новый Структура("Цена",0);
	МассСтрокТЧ=Товары.НайтиСтроки(Отбор);
	Для каждого СтрТЧ из МассСтрокТЧ цикл
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПеремещениеТовары.Себестоимость КАК Себестоимость,
		|	ПеремещениеТовары.Цена КАК Цена,
		|	ПеремещениеТовары.Количество КАК Количество
		|ИЗ
		|	Документ.Перемещение.Товары КАК ПеремещениеТовары
		|ГДЕ
		|	ПеремещениеТовары.Номенклатура = &Номенклатура
		|	И ПеремещениеТовары.Ссылка.Проведен
		|	И ПеремещениеТовары.Ссылка.СкладПолучатель = &СкладПолучатель
		|	И ПеремещениеТовары.Количество > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПеремещениеТовары.Ссылка.Дата";
		запрос.УстановитьПараметр("Номенклатура",СтрТЧ.Номенклатура);
		запрос.УстановитьПараметр("СкладПолучатель",ДокОбъект.Склад);
		Результат=запрос.Выполнить().Выбрать();
		пока Результат.Следующий() цикл
			Себестоимость=?(Результат.Себестоимость=0,Результат.Цена,Результат.Себестоимость/Результат.Количество);
			СтрТЧ.Цена=Себестоимость;
			СтрТЧ.ЦенаБезСкидки=Себестоимость;		
			СтрТЧ.Себестоимость=Себестоимость*СтрТЧ.Количество;
			//Кухарь 13.12.18 начало
			//Иногда цены всё ещё пустые
			ЗаполнитьЦенуНоменклатурыТабЧасти(СтрТЧ, ДокОбъект);
			//Кухарь 13.12.18 конец
		КонецЦикла;
	КонецЦикла;
	
	МассСтрокТЧ=Товары.НайтиСтроки(Отбор);
	Для каждого СтрТЧ из МассСтрокТЧ цикл
		СообщитьИзМодуля("Нулевая цена на "+СтрТЧ.номенклатура.наименование);
		ЕстьСебестоимость=Ложь;
	КонецЦикла;
	
	Возврат ЕстьСебестоимость;
КонецФункции

