Функция ПолучитьПериодическийРеквизит1(Объект,ИмяРеквизита,Знач Дата2=Неопределено,КодИБ=Неопределено,ДатаРеквизита="") Экспорт
	Дата2=?(Дата2=Неопределено,ТекущаяДата(),Дата2);
	
	Запрос=Новый Запрос;
	Если КодИБ=Неопределено Тогда
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Значение,Период
		|ИЗ
		|	РегистрСведений.История.СрезПоследних(&Дата2,Объект = &Объект И Реквизит = &Реквизит)
		|УПОРЯДОЧИТЬ ПО	Период УБЫВ";		
	Иначе
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Значение,Период
		|ИЗ
		|	РегистрСведений.История
		|ГДЕ 
		|	Объект = &Объект И Реквизит = &Реквизит И Период<=&Дата2 И Значение.Владелец.Код=&КодИБ	
		|УПОРЯДОЧИТЬ ПО	Период УБЫВ";			
		
		Запрос.УстановитьПараметр("КодИБ",КодИБ);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Дата2",КонецДня(Дата2));
	Запрос.УстановитьПараметр("Объект",Объект);
	Запрос.УстановитьПараметр("Реквизит",ИмяРеквизита);
	
	Выборка=Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		ДатаРеквизита=Выборка.Период;
		Возврат Выборка.Значение;
	КонецЦикла; 
	
	Возврат Неопределено;
КонецФункции // ПолучитьпериодическийРеквизит()

Функция ПолучитьГрупповойПериодическийРеквизит1(Ссылка,ИмяРеквизита,Знач Дата2=Неопределено)	Экспорт
	Значение=Неопределено;
	
	Если Ссылка<>Неопределено И НЕ Ссылка.Пустая() Тогда		
		Значение=ПолучитьПериодическийРеквизит(Ссылка,ИмяРеквизита,Дата2);
		Если Значение=Неопределено И Ссылка.Уровень()<>0 Тогда
			Значение=ПолучитьГрупповойПериодическийРеквизит1(Ссылка.Родитель,ИмяРеквизита,Дата2);	
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Значение;
КонецФункции // ПолучитьГрупповойПериодическийРЕквизит()

