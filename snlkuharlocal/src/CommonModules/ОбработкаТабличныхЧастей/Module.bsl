//нечаева 26,06,17++
Функция ПолучитьЦенуЧЛДляАртураСписок(СписокШК) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Модель,
	|	ЦеныНоменклатурыСрезПоследних.ТипЦен КАК ТипЦен,
	|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ДатаПрайса,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ШтрихКоды.Наименование,
	|	ШтрихКоды.Владелец,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Код КАК Код
	|ПОМЕСТИТЬ Цены
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			{(&Дата2)},
	|			Прайс.Проведен
	|				И Прайс.Дата2 >= &Дата2
	|				И ТипЦен = &ТипЦен) КАК ЦеныНоменклатурыСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихКоды КАК ШтрихКоды
	|		ПО ЦеныНоменклатурыСрезПоследних.Номенклатура = ШтрихКоды.Владелец.Родитель
	|ГДЕ
	|	ШтрихКоды.ТипШК = &ТипШк
	|	И ШтрихКоды.ВидШК = &видШк
	|	И ШтрихКоды.Наименование В ИЕРАРХИИ(&СпШК)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Модель,
	|	ТипЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Цены.ДатаПрайса) КАК ДатаПрайса,
	|	Цены.Модель,
	|	Цены.ТипЦен
	|ПОМЕСТИТЬ Прайсы
	|ИЗ
	|	Цены КАК Цены
	|
	|СГРУППИРОВАТЬ ПО
	|	Цены.ТипЦен,
	|	Цены.Модель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""Цены"" КАК Раздел,
	|	Прайсы.Модель,
	|	Прайсы.ТипЦен,
	|	Цены.Цена,
	|	Цены.Код,
	|	Цены.Наименование
	|ИЗ
	|	Прайсы КАК Прайсы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены
	|		ПО (Цены.Модель = Прайсы.Модель)
	|			И (Цены.ТипЦен = Прайсы.ТипЦен)
	|			И (Цены.ДатаПрайса = Прайсы.ДатаПрайса)";
	
	Запрос.УстановитьПараметр("Дата2",НачалоДня(ТекущаяДата()));			   
	Запрос.УстановитьПараметр("СпШк",СписокШК);	
	Запрос.УстановитьПараметр("ТипЦен",справочники.ТипыЦен.НайтиПоКоду("SSP-0301")); // частное лицо
	Запрос.УстановитьПараметр("ТипШк",перечисления.ТипыШтрихКодов.Штука);
	Запрос.УстановитьПараметр("ВидШк",перечисления.ВидыШК.Основной);
	
	//нечаева 22,08,18++	
	Рез = Запрос.Выполнить().Выбрать();
	Цена = 0;
