				иначе 
					// тогда берем цену по базовому прайс-листу. сделано для франчей - сброс цен
					прервать;
				КонецЕсли;
				//нечаева 08,09,2014 ----
			КонецЦикла;	
			
			
			// смотрим базовый тип цен
			Запрос.Текст="
			|ВЫБРАТЬ ПЕРВЫЕ 1	
			|	Цена,
			|	ВЫБОР 
			|		КОГДА ТипЦен = &ТипЦен ТОГДА 0		
			|	ИНАЧЕ 100 КОНЕЦ КАК Уровень
			|ИЗ
			|РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата2,
			|	(ТипЦен=&ТипЦен_Базовый)
			|	И Номенклатура = &Номенклатура0
			|	И Прайс.Проведен
			|	И КОНЕЦПЕРИОДА(Прайс.Дата2,День) >= &Дата2	И Прайс.Дата < &Дата2
			|	) КАК ЦеныНоменклатурыСрезПоследних
			|ГДЕ Номенклатура.ЭтоГруппа
			|УПОРЯДОЧИТЬ ПО Уровень,Прайс.Дата Убыв";
			
			Запрос.УстановитьПараметр("Дата2",				ТекДатаРасчета);
			Запрос.УстановитьПараметр("ТипЦен",				ТипЦен);	
			Запрос.УстановитьПараметр("ТипЦен_Базовый",		ТипЦен.Базовый);		
			
			Запрос.УстановитьПараметр("Номенклатура0",	?(Номенклатура.ЭтоГруппа,Номенклатура,Номенклатура.Родитель));
			
			Результат=Запрос.Выполнить();
			//крохин начало 22.09.2011
			//единицу не используем больше
			//Коэффициент=?(Единица=Неопределено,1,Единица.Коэффициент);
			Коэффициент = 1;
			//крохин конец 22.09.2011;
			Выборка=Результат.Выбрать();
			Пока Выборка.Следующий() Цикл			
				Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);
			КонецЦикла;	
			
			
			
			//Нечаева 14,08,13 ------
		КонецЕсли;
	//////////////////////////////////////////////////////////////////////////////////////////	
		Возврат 0;
	Иначе
		Возврат 0;
	Конецесли;
