				|	
				|	ОБЪЕДИНИТЬ ВСЕ
				|	
				|	ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка,
				|		4,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата
				|	ИЗ
				|		РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|				КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|				ТипСкидок = &ТипСкидок
				|					И Номенклатура В (&СписокПозиций4)
				|					И Документ.Проведен
				|					И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|					И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних) КАК а1
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				|			МИНИМУМ(а2.уровень) КАК уровень,
				|			а2.Номенклатура КАК Номенклатура
				|		ИЗ
				|			(ВЫБРАТЬ
				|				ЦеныНоменклатурыСрезПоследних.Скидка КАК Скидка,
				|				0 КАК уровень,
				|				ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура
				|			ИЗ
				|				РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|						КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|						ТипСкидок = &ТипСкидок
				|							И Номенклатура В (&СписокПозиций)
				|							И Документ.Проведен
				|							И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|							И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|			
				|			ОБЪЕДИНИТЬ ВСЕ
				|			
				|			ВЫБРАТЬ
				|				ЦеныНоменклатурыСрезПоследних.Скидка,
				|				1,
				|				ЦеныНоменклатурыСрезПоследних.Номенклатура
				|			ИЗ
				|				РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|						КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|						ТипСкидок = &ТипСкидок
				|							И Номенклатура В (&СписокПозиций1)
				|							И Документ.Проведен
				|							И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|							И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|			
				|			ОБЪЕДИНИТЬ ВСЕ
				|			
				|			ВЫБРАТЬ
				|				ЦеныНоменклатурыСрезПоследних.Скидка,
				|				2,
				|				ЦеныНоменклатурыСрезПоследних.Номенклатура
				|			ИЗ
				|				РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|						КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|						ТипСкидок = &ТипСкидок
				|							И Номенклатура В (&СписокПозиций2)
				|							И Документ.Проведен
				|							И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|							И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|			
				|			ОБЪЕДИНИТЬ ВСЕ
				|			
				|			ВЫБРАТЬ
				|				ЦеныНоменклатурыСрезПоследних.Скидка,
				|				3,
				|				ЦеныНоменклатурыСрезПоследних.Номенклатура
				|			ИЗ
				|				РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|						КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|						ТипСкидок = &ТипСкидок
				|							И Номенклатура В (&СписокПозиций3)
				|							И Документ.Проведен
				|							И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|							И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|			
				|			ОБЪЕДИНИТЬ ВСЕ
				|			
				|			ВЫБРАТЬ
				|				ЦеныНоменклатурыСрезПоследних.Скидка,
				|				4,
				|				ЦеныНоменклатурыСрезПоследних.Номенклатура
				|			ИЗ
				|				РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|						КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|						ТипСкидок = &ТипСкидок
				|							И Номенклатура В (&СписокПозиций4)
				|							И Документ.Проведен
				|							И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|							И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних) КАК а2
				|		
				|		СГРУППИРОВАТЬ ПО
				|			а2.Номенклатура,
				|			а2.Скидка) КАК а2
				|		ПО а1.уровень = а2.уровень
				|			И а1.Номенклатура = а2.Номенклатура
				|
				|УПОРЯДОЧИТЬ ПО
				|	а1.ДокументДата УБЫВ";
				
				
				
				Запрос.УстановитьПараметр("Дата2",			ТекДатаРасчета);
				Запрос.УстановитьПараметр("ТипСкидок",		ТипСкидок_Контрагент);
				//Запрос.УстановитьПараметр("ТипСкидок_Базовый",ТипСкидок_Контрагент.Базовый);
				Запрос.УстановитьПараметр("СписокПозиций",	МассивНоменклатуры); 
				Запрос.УстановитьПараметр("СписокПозиций1",СписокПозиций1);
				Запрос.УстановитьПараметр("СписокПозиций2",СписокПозиций2);
				Запрос.УстановитьПараметр("СписокПозиций3",СписокПозиций3);
				Запрос.УстановитьПараметр("СписокПозиций4",СписокПозиций4);
				
				// 12.09.2014 +++ нечаева
				ВремТз=запрос.Выполнить().выгрузить();
				ВремТз.Индексы.Добавить("Номенклатура");
				
				МоделиТЗ= ВремТз.Скопировать();
				МоделиТЗ.Свернуть("Номенклатура");
				
				/// удаляем списанные скидки =-1.
				Для каждого Стр из МоделиТЗ цикл
					
					
					ТекНом=Стр.Номенклатура;
					
					Отбор = Новый Структура();
					Отбор.Вставить("Номенклатура",ТекНом);
					
					СтрПоиск=ВремТз.найтиСтроки(Отбор);
					
					Если СтрПоиск.Количество()>0 и СтрПоиск[0].Скидка=-1 Тогда
						
						Для каждого СТРН из СтрПоиск цикл
							
							ВремТз.Удалить(СтрН);
							
						конецЦикла;
						
					конецесли;
					
				КонецЦикла;
				
				ВремТз.Сортировать("ДокументДата Убыв");
				// 12.09.2014  нечаева   -------
				
				
				
				// запрос 2
				
				запрос2=новый запрос;
				запрос2.Текст="ВЫБРАТЬ
				|	а1.Скидка,
				|	а1.уровень,
				|	а1.Номенклатура,
				|	а1.ДокументДата
				|ИЗ
				|	(ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка КАК Скидка,
				|		0 КАК уровень,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата КАК ДокументДата
				|	ИЗ
				|		РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|				КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|				ТипСкидок = &ТипСкидок_Базовый
				|					И Номенклатура В (&СписокПозиций)
				|					И Документ.Проведен
				|					И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|					И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|	
				|	ОБЪЕДИНИТЬ ВСЕ
				|	
				|	ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка,
				|		1,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата
				|	ИЗ
				|		РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|				КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|				ТипСкидок = &ТипСкидок_Базовый
				|					И Номенклатура В (&СписокПозиций1)
				|					И Документ.Проведен
				|					И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|					И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|	
				|	ОБЪЕДИНИТЬ ВСЕ
				|	
				|	ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка,
				|		2,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата
				|	ИЗ
