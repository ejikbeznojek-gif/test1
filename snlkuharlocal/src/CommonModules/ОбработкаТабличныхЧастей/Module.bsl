//Мессерле Для группового получения цен номенклатуры (если не заданы 2 посл. параметр, то работает по прежнему алгоритма)
Функция ПолучитьЦенуНоменклатуры(Номенклатура,Единица=Неопределено,ТипЦен,ВалютаДокумента,КурсДокумента,ДатаРасчета=Неопределено,МассивНоменклатуры=НЕОПРЕДЕЛЕНО,ВремТз=НЕОПРЕДЕЛЕНО) Экспорт
	Если ТипЦен<>Неопределено И НЕ ТипЦен.Пустая() Тогда		
		Запрос=Новый Запрос;
		
		Если ДатаРасчета=Неопределено Тогда
			#Если Клиент Тогда		
				// нечаева 06,08,13 +++ было везде на конец дня
				//ТекДатаРасчета=КонецДня(РабочаяДата);
				ТекДатаРасчета=Текущаядата();  //РабочаяДата;
				
			#Иначе
				ТекДатаРасчета=КонецДня(ТекущаяДата());		
			#КонецЕсли		
		Иначе
			//ТекДатаРасчета=КонецДня(ДатаРасчета);	
			ТекДатаРасчета=ДатаРасчета;
		КонецЕсли;
		
		Если НЕ(ВремТз="" или ВремТз=НЕОПРЕДЕЛЕНО) тогда
			Стр=ВремТз.найти(номенклатура,"Номенклатура");
			Если Стр=Неопределено тогда    
				Стр=ВремТз.найти(номенклатура.родитель,"Номенклатура");
				Если Стр=Неопределено тогда
					Стр=ВремТз.найти(номенклатура.родитель.родитель,"Номенклатура");
					Если Стр=Неопределено тогда
						Возврат(0);
					иначе
						Возврат(стр.Цена);
					Конецесли;	  
					
					Возврат(0);
				иначе
					Возврат(стр.Цена);
				Конецесли;
				возврат(0);
			иначе
				Возврат(стр.Цена);
			Конецесли;
			
		Конецесли;
		
		Если МассивНоменклатуры<>Неопределено тогда //Передали что-то   
			колвмасс=МассивНоменклатуры.количество();
			для ном5=0 по КолВмасс-1 цикл                                                                     
				МассивНоменклатуры.Добавить(МассивНоменклатуры.получить(ном5).значение.родитель);  
			Конеццикла;	
			//нечаева 09,01,13 ++++ разбила на 2 запроса
			Если ВремТз="" тогда
				
				//по основному типу цен считаем
				запрос=новый запрос;
				Запрос.Текст="ВЫБРАТЬ
				|	ЦеныНоменклатурыСрезПоследних.Цена,
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ПрайсДата
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				|			КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|			ТипЦен = &ТипЦен
				|				И Номенклатура В (&СписокНоменклатуры)
				|				И Прайс.Проведен
				|				И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2
				|				И Прайс.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
				|			МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Прайс.Дата) КАК Дата
				|		ИЗ
				|			РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				|					КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|					ТипЦен = &ТипЦен
				|						И Номенклатура В (&СписокНоменклатуры)
				|						И Прайс.Проведен
				|						И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2
				|						И Прайс.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|		ГДЕ
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
				|		
				|		СГРУППИРОВАТЬ ПО
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура) КАК Даты
				|		ПО ЦеныНоменклатурыСрезПоследних.Прайс.Дата = Даты.Дата
				|			И ЦеныНоменклатурыСрезПоследних.Номенклатура = Даты.Номенклатура
				|ГДЕ
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
				//  |	И ЦеныНоменклатурыСрезПоследних.Цена <> -1
				|
				|УПОРЯДОЧИТЬ ПО
				|	ПрайсДата УБЫВ";
				
				// по базовому типу цен считаем
				запрос2=новый запрос;
				Запрос2.Текст="ВЫБРАТЬ
				|	ЦеныНоменклатурыСрезПоследних.Цена,
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ПрайсДата
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				|			КонецПериода(&Дата2,День),
				|			( ТипЦен = &ТипЦен_Базовый)
				|				И Номенклатура В (&СписокНоменклатуры)
				|				И Прайс.Проведен
				|				И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2 И Прайс.Дата < &Дата2 ) КАК ЦеныНоменклатурыСрезПоследних
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
				|			МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Прайс.Дата) КАК Дата
				|		ИЗ
				|			РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				|					КонецПериода(&Дата2,День),
				|					( ТипЦен = &ТипЦен_Базовый)
				|						И Номенклатура В (&СписокНоменклатуры)
				|						И Прайс.Проведен
				|						И КОНЕЦПЕРИОДА(Прайс.Дата2, ДЕНЬ) >= &Дата2 И Прайс.Дата < &Дата2 ) КАК ЦеныНоменклатурыСрезПоследних
				|		ГДЕ
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
				|		
				|		СГРУППИРОВАТЬ ПО
				|			ЦеныНоменклатурыСрезПоследних.Номенклатура) КАК Даты
				|		ПО ЦеныНоменклатурыСрезПоследних.Прайс.Дата = Даты.Дата
				|			И ЦеныНоменклатурыСрезПоследних.Номенклатура = Даты.Номенклатура
				|ГДЕ
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа
				|
				|УПОРЯДОЧИТЬ ПО
				|	ПрайсДата УБЫВ";
				
				
				
				СписокНоменклатуры=новый СписокЗначений;
				
				для ном=0  по массивноменклатуры.количество()-1 цикл
					СписокНоменклатуры.Добавить(?(массивноменклатуры[ном].значение.ЭтоГруппа,массивноменклатуры[ном].значение,массивноменклатуры[ном].значение.Родитель));
				Конеццикла;
				// цены по текущему типу цен
				Запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
