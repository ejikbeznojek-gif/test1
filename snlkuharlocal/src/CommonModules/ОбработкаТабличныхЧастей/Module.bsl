//крохин начало 24.09.2013
//заполнение импортера и ГТД в комплектах
Процедура ЗаполнитьИмпортераКМПЛРНК(Документ)  Экспорт
	
	ТЗ = Документ.Комплектующие.Выгрузить(,"Продукция,Номенклатура");
	ТЗНовыхГТД = Новый ТаблицаЗначений;
	ТЗНовыхГТД.Колонки.Добавить("Номенклатура");
	ТЗНовыхГТД.Колонки.Добавить("ГТД");
	
	ДатаДокумента=ПолучитьРеквизитШапки(Документ,"Дата","Документ");
	запрос=новый запрос;
					// | &ТЗ как ТЗ
 //|	Документ.РасходнаяНакладная.Комплектующие КАК ТЗ

	запрос.Текст="ВЫБРАТЬ
	             |	ТЗ.Номенклатура КАК Номенклатура,
	             |	ТЗ.Продукция КАК Продукция
	             |ПОМЕСТИТЬ ВремТЗ
	             |ИЗ
	             | &ТЗ как ТЗ
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ИсторияСрезПоследних.Значение КАК ГТД,
	             |	ИсторияСрезПоследних.Объект КАК Продукция,
	             |	ИсторияСрезПоследних.Период КАК Период
	             |ПОМЕСТИТЬ ГТДПродукции
	             |ИЗ
	             |	РегистрСведений.История.СрезПоследних(
	             |			&Дата2,
	             |			Объект В
	             |					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |						ВремТЗ.Продукция.Родитель
	             |					ИЗ
	             |						ВремТЗ КАК ВремТЗ
	             |					ГДЕ
	             |						ВремТЗ.Продукция.Родитель.ВидКомплекта В (&СписокВидовКомлекта))
	             |				И Реквизит = ""НомерГТД"") КАК ИсторияСрезПоследних
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ИсторияСрезПоследних.Объект,
	             |	ИсторияСрезПоследних.Значение,
	             |	ИсторияСрезПоследних.Период
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ИсторияСрезПоследних.Значение КАК ГТД,
	             |	ИсторияСрезПоследних.Объект КАК Номенклатура,
	             |	ИсторияСрезПоследних.Период КАК Период
	             |ПОМЕСТИТЬ ГТДНоменклатуры
	             |ИЗ
	             |	РегистрСведений.История.СрезПоследних(
	             |			&Дата1,
	             |			Объект В
	             |					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |						ВремТЗ.Номенклатура.Родитель
	             |					ИЗ
	             |						ВремТЗ КАК ВремТЗ
	             |					ГДЕ
	             |						ВремТЗ.Продукция.Родитель.ВидКомплекта В (&СписокВидовКомлекта))
	             |				И Реквизит = ""НомерГТД"") КАК ИсторияСрезПоследних
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ГТДПродукции.Продукция КАК Продукция,
	             |	МАКСИМУМ(ГТДПродукции.Период) КАК Период
	             |ПОМЕСТИТЬ ГТДПродМакс
	             |ИЗ
	             |	ГТДПродукции КАК ГТДПродукции
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ГТДПродукции.Продукция
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ГТДНоменклатуры.Номенклатура КАК Номенклатура,
	             |	МАКСИМУМ(ГТДНоменклатуры.Период) КАК Период
	             |ПОМЕСТИТЬ ГТДНомМакс
	             |ИЗ
	             |	ГТДНоменклатуры КАК ГТДНоменклатуры
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ГТДНоменклатуры.Номенклатура
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	МАКСИМУМ(ГТДПродукции.ГТД) КАК ГТД,
	             |	ГТДПродМакс.Продукция КАК Продукция
	             |ПОМЕСТИТЬ ГТДПродФин
	             |ИЗ
	             |	ГТДПродМакс КАК ГТДПродМакс
	             |		ЛЕВОЕ СОЕДИНЕНИЕ ГТДПродукции КАК ГТДПродукции
	             |		ПО ГТДПродМакс.Продукция = ГТДПродукции.Продукция
	             |			И ГТДПродМакс.Период = ГТДПродукции.Период
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ГТДПродМакс.Продукция
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ГТДНомМакс.Номенклатура КАК Номенклатура,
	             |	МАКСИМУМ(ГТДНоменклатуры.ГТД) КАК ГТД
	             |ПОМЕСТИТЬ ГТДНомФин
	             |ИЗ
	             |	ГТДНомМакс КАК ГТДНомМакс
	             |		ЛЕВОЕ СОЕДИНЕНИЕ ГТДНоменклатуры КАК ГТДНоменклатуры
	             |		ПО ГТДНомМакс.Номенклатура = ГТДНоменклатуры.Номенклатура
	             |			И ГТДНомМакс.Период = ГТДНоменклатуры.Период
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ГТДНомМакс.Номенклатура
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ВремТЗ.Номенклатура.Родитель КАК Номенклатура,
	             |	ВремТЗ.Продукция.Родитель КАК Продукция,
	             |	ГТДПродукции.ГТД КАК ГТДСтарый,
	             |	ГТДНоменклатуры.ГТД КАК ГТД
	             |ПОМЕСТИТЬ ГотовыеДанные
	             |ИЗ
	             |	ВремТЗ КАК ВремТЗ
	             |		ЛЕВОЕ СОЕДИНЕНИЕ ГТДПродФин КАК ГТДПродукции
	             |		ПО ВремТЗ.Продукция.Родитель = ГТДПродукции.Продукция
	             |		ЛЕВОЕ СОЕДИНЕНИЕ ГТДНомФин КАК ГТДНоменклатуры
	             |		ПО ВремТЗ.Номенклатура.Родитель = ГТДНоменклатуры.Номенклатура
	             |ГДЕ
	             |	ВремТЗ.Продукция.Родитель.ВидКомплекта В(&СписокВидовКомлекта)
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ГотовыеДанные.Номенклатура КАК Номенклатура,
	             |	ГотовыеДанные.Продукция КАК Продукция,
	             |	ВЫБОР
	             |		КОГДА ГотовыеДанные.ГТД ССЫЛКА Справочник.ГТД
	             |			ТОГДА ВЫРАЗИТЬ(ГотовыеДанные.ГТД КАК Справочник.ГТД).Наименование
	             |	КОНЕЦ КАК НаименованиеГТД,
	             |	ВЫБОР
	             |		КОГДА ГотовыеДанные.ГТДСтарый ССЫЛКА Справочник.ГТД
	             |			ТОГДА ВЫРАЗИТЬ(ГотовыеДанные.ГТДСтарый КАК Справочник.ГТД).Наименование
	             |	КОНЕЦ КАК НаименованиеГТДСтарый,
	             |	ГотовыеДанные.ГТДСтарый КАК ГТДСтарый,
	             |	ГотовыеДанные.ГТД КАК ГТД
	             |ИЗ
	             |	ГотовыеДанные КАК ГотовыеДанные
	             |ГДЕ
	             |	НЕ ГотовыеДанные.ГТД ЕСТЬ NULL";
	запрос.УстановитьПараметр("ТЗ",ТЗ);	
	запрос.УстановитьПараметр("Дата2",ДатаДокумента);
	запрос.УстановитьПараметр("Дата1",ДатаДокумента-1);
	запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	СписокВидовКомлекта=новый СписокЗначений;
	СписокВидовКомлекта.Добавить(Перечисления.ВидыКомплектов.Ассортито);
	СписокВидовКомлекта.Добавить(Перечисления.ВидыКомплектов.Комплект);
	запрос.УстановитьПараметр("СписокВидовКомлекта",СписокВидовКомлекта);
	
	
	ТЗ=запрос.Выполнить().Выгрузить();
	СписокПродукции = Новый СписокЗначений;
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		Если СписокПродукции.НайтиПоЗначению(СтрокаТЗ.Продукция) <> Неопределено Тогда Продолжить КонецЕсли;
		ГТД=СтрокаТЗ.ГТД;
		НаименованиеГТД=СтрокаТЗ.НаименованиеГТД;
		ГТДСтарый=СтрокаТЗ.ГТДСтарый;
		НаименованиеСтарогоГТД=СтрокаТЗ.НаименованиеГТДСтарый;
		если ГТД=ГТДСтарый тогда Продолжить;КонецЕсли;
		
		если ЗначениеЗаполнено(ГТД) тогда
			ДатаНовогоГТД=сред(НаименованиеГТД,Найти(НаименованиеГТД,"/")+1,6);
			попытка
				ДатаНовогоГТД=Дата("20"+Прав(ДатаНовогоГТД,2)+Сред(ДатаНовогоГТД,3,2)+Лев(ДатаНовогоГТД,2));
			Исключение
				ДатаНовогоГТД=ПустаяДата();
			КонецПопытки;
		иначе
			ДатаНовогоГТД=ПустаяДата();
		КонецЕсли;	
		
		если ЗначениеЗаполнено(ГТДСтарый) тогда
			ДатаСтарогоГТД=сред(НаименованиеСтарогоГТД,Найти(НаименованиеСтарогоГТД,"/")+1,6);
			
			попытка
				ДатаСтарогоГТД=Дата("20"+Прав(ДатаСтарогоГТД,2)+Сред(ДатаСтарогоГТД,3,2)+Лев(ДатаСтарогоГТД,2));
			Исключение
				ДатаСтарогоГТД=ПустаяДата();
			КонецПопытки;
		иначе
			ДатаСтарогоГТД=ПустаяДата();
		КонецЕсли;
		
		Если ГТД <> Неопределено и (ДатаНовогоГТД> ДатаСтарогоГТД или (ДатаНовогоГТД=ПустаяДата() и ДатаСтарогоГТД=ПустаяДата())) Тогда
			СтрокаТЗНовыхГТД = ТЗНовыхГТД.Добавить();
			СтрокаТЗНовыхГТД.Номенклатура = СтрокаТЗ.Продукция;
			СтрокаТЗНовыхГТД.ГТД = ГТД;
			СписокПродукции.Добавить(СтрокаТЗ.продукция);
		КонецЕсли;
		

	КонецЦикла;	
	
	
	
	
	
	Если ТЗНовыхГТД.Количество() > 0 Тогда
		НЗ=РегистрыСведений.История.СоздатьНаборЗаписей();
		//крохин начало
		//ГТД записываем датой из ГТД, а не из документа 
		НЗ.Отбор.Период.Установить(Документ.Дата,Истина);
		
		//крохин конец
		//НЗ.Отбор.Реквизит.Установить("НомерГТД",Истина);
		НЗ.Отбор.Документ.Установить(Документ.Ссылка,Истина);
		
		Для Каждого СтрокаГТД Из ТЗНовыхГТД Цикл
			Если НЕ СтрокаГТД.ГТД.Пустая() И НЕ СтрокаГТД.Номенклатура.Пустая() Тогда
				Запись=НЗ.Добавить();
				//крохин начало
				//ГТД записываем датой из ГТД, а не из документа 
				//	Запись.Период		=Дата;
				Запись.Период		=Документ.Дата;
				//крохин конец
				Запись.Объект		=СтрокаГТД.Номенклатура;
				Запись.Реквизит		="НомерГТД";
				Запись.Документ		=Документ.Ссылка;		
				
				Запись.Значение		=СтрокаГТД.ГТД;			
				
				Запись.Регистратор	=Документ.Ссылка;			
			КонецЕсли;	
		КонецЦикла;
		НЗ.Записать();
	КонецЕсли;
	
КонецПроцедуры

