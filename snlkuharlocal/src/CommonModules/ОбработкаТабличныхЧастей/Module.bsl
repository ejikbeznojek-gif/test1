Функция ПолучитьСкидкуНоменклатурыЧисло(Номенклатура,ТипСкидок_Контрагент,ДатаРасчета=Неопределено,ТипЦенСкидок=Неопределено) Экспорт
	
	Если ТипЗнч(ТипСкидок_Контрагент)=Тип("СправочникСсылка.ТипыСкидок") Тогда		//по типу скидок
		Если ДатаРасчета=Неопределено Тогда
			#Если Клиент Тогда		
				ТекДатаРасчета=РабочаяДата;
			#Иначе
				ТекДатаРасчета=ТекущаяДата();		
			#КонецЕсли		
		Иначе
			ТекДатаРасчета=ДатаРасчета;	
		КонецЕсли;
		
		Запрос=Новый Запрос;
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1		
		|	Скидка,
		|	ВЫБОР 
		|		КОГДА Номенклатура	=&Номенклатура0 ТОГДА 0
		|		КОГДА Номенклатура	=&Номенклатура1 ТОГДА 1
		|		КОГДА Номенклатура	=&Номенклатура2 ТОГДА 2
		|		КОГДА Номенклатура	=&Номенклатура3 ТОГДА 3
		|		КОГДА Номенклатура	=&Номенклатура3 ТОГДА 4
			// Кухарь А.Ю. 13.10.2022 начало
			//+1 уровень иерархии
			 |		КОГДА Номенклатура	=&Номенклатура5 ТОГДА 5
			// Кухарь А.Ю. 13.10.2022 конец
		
		|	ИНАЧЕ 100 
		|	КОНЕЦ КАК Уровень
		|ИЗ
		|РегистрСведений.СкидкиНоменклатуры.СрезПоследних(КонецПериода(&Дата2,День),
		|	(ТипСкидок = &ТипСкидок)
		|	И Номенклатура В (&СписокПозиций)
		|	И Документ.Проведен
		|	И КОНЕЦПЕРИОДА(Документ.Дата2,День) >= &Дата2 и документ.Дата < &Дата2		
		|	) КАК ЦеныНоменклатурыСрезПоследних		
		|УПОРЯДОЧИТЬ ПО Документ.Дата Убыв,Уровень";
		
		
		Запрос.УстановитьПараметр("Дата2",			ТекДатаРасчета);
		Запрос.УстановитьПараметр("ТипСкидок",		ТипСкидок_Контрагент.базовый);   //!!!!!!!!!!!!
		
		СписокПозиций=Новый Массив;
		
		Уровень=0;		
		ТекРодитель=Номенклатура;
		// Кухарь А.Ю. 13.10.2022 начало
		//+1 уровень иерархии
		//Пока Уровень<5 Цикл
		Пока Уровень<6 Цикл
			// Кухарь А.Ю. 13.10.2022 конец
			СписокПозиций.Добавить(ТекРодитель);		
			Запрос.УстановитьПараметр("Номенклатура"+Уровень,ТекРодитель);
			
			Уровень=Уровень+1;
			ТекРодитель=ТекРодитель.Родитель;	
		КонецЦикла;
		
		Запрос.УстановитьПараметр("СписокПозиций",	СписокПозиций);
		
		Результат=Запрос.Выполнить();
		
		Выборка=Результат.Выбрать();
		Пока Выборка.Следующий() Цикл			
			Возврат  Выборка.Скидка;
		КонецЦикла;
		
		
		//второй запрос по другому типу скидок. если по базовому нет.
		Запрос=Новый Запрос;
