//Аналогично работают функции  ПолучитьЦенуНоменклатуры  и ПолучитьСвойстваНоменклатуры.
//Пример использования - обработка "ПечатьЭтикеток"

// нечаева ст. вариант до оптимизации запроса
Функция ПолучитьСкидкуНоменклатурыCт(Номенклатура,ТипСкидок_Контрагент,ДатаРасчета=Неопределено,ТипЦенСкидок=Неопределено,МассивНоменклатуры=НЕОПРЕДЕЛЕНО,ВремТз=НЕОПРЕДЕЛЕНО) Экспорт
	
	Если ТипЗнч(ТипСкидок_Контрагент)=Тип("СправочникСсылка.ТипыСкидок") Тогда		//по типу скидок
		Если ДатаРасчета=Неопределено Тогда
			#Если Клиент Тогда
				// нечаева 06,08,13 +++ было везде на конец дня
				//ТекДатаРасчета=КонецДня(РабочаяДата);
				ТекДатаРасчета=ТекущаяДата(); //РабочаяДата;
			#Иначе
				ТекДатаРасчета=ТекущаяДата();		
			#КонецЕсли		
		Иначе
			ТекДатаРасчета=ДатаРасчета;	
		КонецЕсли;
		
		Если НЕ(ВремТз="" или ВремТз=НЕОПРЕДЕЛЕНО) И ЗначениеЗаполнено(Номенклатура) тогда
			Стр=ВремТз.найти(номенклатура,"Номенклатура");
			Если Стр=Неопределено тогда    
				Стр=ВремТз.найти(номенклатура.родитель,"Номенклатура");
				Если Стр=Неопределено тогда
					Стр=ВремТз.найти(номенклатура.родитель.родитель,"Номенклатура");
					Если Стр=Неопределено тогда
						Возврат(0);
					иначе
						Возврат(стр.скидка);
					Конецесли;	  
					
					Возврат(0);
				иначе
					Возврат(стр.скидка);
				Конецесли;
