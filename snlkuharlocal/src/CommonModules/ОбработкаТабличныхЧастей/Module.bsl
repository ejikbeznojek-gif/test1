//Катаев+ 05/06/14
Процедура РассчитатьТоварыПоДаннымКлиента(СтрокаТЧ, НайденнаяСтрока, ДокументОбъект) Экспорт
	Если НайденнаяСтрока.Количество = 0 Тогда
		строкаТЧ.Всего = 0;
	Иначе
		строкаТЧ.Всего = НайденнаяСтрока.Всего*НайденнаяСтрока.КоличествоФакт/НайденнаяСтрока.Количество;
	КонецЕсли;
	
	ИмяТабличнойЧасти 			= ПолучитьИмяТабличнойЧастиПоСсылкеНаСтроку(СтрокаТЧ);
	МетаданныеДокумента 		= ДокументОбъект.Метаданные();
	СкидкаТЧ=?(ЕстьРеквизитТабЧастиДокумента("Скидка",МетаданныеДокумента,ИмяТабличнойЧасти),СтрокаТЧ.Скидка,0);
	Если СкидкаТЧ=0 Тогда
		Скидка=?(ЕстьРеквизитДокумента("Скидка",МетаданныеДокумента),ДокументОбъект.Скидка,0);
	Иначе
		Если СкидкаТЧ>0 Тогда				
			Скидка=СкидкаТЧ;
			Если ЕстьРеквизитДокумента("ДопСкидкаНаНакладную",МетаданныеДокумента) И ДокументОбъект.ДопСкидкаНаНакладную Тогда
				Скидка=Скидка+ДокументОбъект.Скидка;
			КонецЕсли; 
		Иначе
			//крохин начало 23.04.2012
			//для Беларуси, скидки могут быть отрицательными
			//	Скидка=0;
			Если СкидкаТЧ = -1 Тогда
				Скидка=0;
			Иначе
				Скидка=СкидкаТЧ;
				Если ЕстьРеквизитДокумента("ДопСкидкаНаНакладную",МетаданныеДокумента) И ДокументОбъект.ДопСкидкаНаНакладную Тогда
					Скидка=Скидка+ДокументОбъект.Скидка;
				КонецЕсли;
			КонецЕсли;
			//крохин конец 23.04.2012
		КонецЕсли;		
	КонецЕсли;	
	
	//нечаева 03,06,15+++
	// для оптовых клиентов увеличиваем тип скидок
	Если ЕстьРеквизитДокумента("ТипСкидок",МетаданныеДокумента) Тогда
		Если  НЕ ДокументОбъект.ТипСкидок.пустая() Тогда
			
			ДопСкидкаОпт = ПолучитьСкидкуНоменклатуры(СтрокаТЧ.Номенклатура,ДокументОбъект.ТипСкидок,ДокументОбъект.Дата,);	 
			Если ДопСкидкаОпт = Неопределено Тогда
				ДопСкидкаОпт = 0;
			КонецЕсли;	
			Скидка = Скидка+ДопСкидкаОпт;
			
		КонецЕсли;	
	КонецЕсли;
	//нечаева 03,06,15---
	
	
	Если ЕстьРеквизитТабЧастиДокумента("СтавкаНДС",ДокументОбъект.Метаданные(),ИмяТабличнойЧасти) Тогда
		СтавкаНДС=ПроцентНДСпоСтавке(СтрокаТЧ.СтавкаНДС);
		
		СтрокаТЧ.НДС	=СтрокаТЧ.Всего*СтавкаНДС/(1+СтавкаНДС);			
		СтрокаТЧ.Сумма  =СтрокаТЧ.Всего-СтрокаТЧ.НДС;
	КонецЕсли;
	
	Если ЕстьРеквизитТабЧастиДокумента("ЦенаБезСкидки",МетаданныеДокумента,ИмяТабличнойЧасти) Тогда
		Если НайденнаяСтрока.Количество = 0 Тогда
			ЦенаБезСкидки = 0;
		Иначе
			ЦенаБезСкидки	=НайденнаяСтрока.Всего/НайденнаяСтрока.Количество/(1-Скидка/100);
		КонецЕсли;
		СтрокаТЧ.ЦенаБезСкидки = ЦенаБезСкидки;
		СтрокаТЧ.ВсегоБезСкидки =ЦенаБезСкидки*СтрокаТЧ.Количество;
	КонецЕсли;		
Конецпроцедуры
