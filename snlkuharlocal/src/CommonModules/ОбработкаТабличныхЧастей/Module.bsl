//Функция ПолучитьСкидкуНоменклатуры(Номенклатура,ТипСкидок_Контрагент,ДатаРасчета=Неопределено,ТипЦенСкидок=Неопределено,МассивНоменклатуры=НЕОПРЕДЕЛЕНО,ВремТз=НЕОПРЕДЕЛЕНО) Экспорт
Функция ПолучитьСкидкуНоменклатуры(Номенклатура,ТипСкидок_Контрагент,ДатаРасчета=Неопределено,ТипЦенСкидок=Неопределено,МассивНоменклатуры=НЕОПРЕДЕЛЕНО,ВремТз=НЕОПРЕДЕЛЕНО,ФиксироватьАкцию=Ложь) Экспорт
	//крохин конец 12.01.2021	
	
	Если ТипЗнч(ТипСкидок_Контрагент)=Тип("СправочникСсылка.ТипыСкидок") Тогда		//по типу скидок
		Если ДатаРасчета=Неопределено Тогда
			#Если Клиент Тогда
				// нечаева 06,08,13 +++ было везде на конец дня
				//ТекДатаРасчета=КонецДня(РабочаяДата);
				ТекДатаРасчета=ТекущаяДата(); //РабочаяДата;
			#Иначе
				ТекДатаРасчета=ТекущаяДата();		
			#КонецЕсли		
		Иначе
			ТекДатаРасчета=ДатаРасчета;	
		КонецЕсли;
		
		Если НЕ(ВремТз="" или ВремТз=НЕОПРЕДЕЛЕНО) И ЗначениеЗаполнено(Номенклатура) тогда
			Стр=ВремТз.найти(номенклатура,"Номенклатура");
			Если Стр=Неопределено тогда    
				Стр=ВремТз.найти(номенклатура.родитель,"Номенклатура");
				Если Стр=Неопределено тогда
					Стр=ВремТз.найти(номенклатура.родитель.родитель,"Номенклатура");
					Если Стр=Неопределено тогда
						Возврат(0);
					иначе
						Возврат(стр.скидка);
					Конецесли;	  
					
					Возврат(0);
				иначе
					Возврат(стр.скидка);
				Конецесли;
				возврат(0);
			иначе
				Возврат(стр.скидка);
			Конецесли;
			
		Конецесли;
		
		если МассивНоменклатуры<>Неопределено тогда //Передали что-то
			Если ВремТз="" тогда
				//нечева 18,06,14--- оптимизация запроса						
				// 1 уровень	
				Запр=Новый Запрос;
				Запр.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	Номенклатура.Ссылка.Родитель
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|ГДЕ
				|	Номенклатура.Ссылка В(&СписокПозиций)";
				Запр.УстановитьПараметр("СписокПозиций",	МассивНоменклатуры);  
				СписокПозиций1=запр.Выполнить().Выгрузить();
				//второй уровень
				Запр=Новый Запрос;
				Запр.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	Номенклатура.Ссылка.Родитель
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|ГДЕ
				|	Номенклатура.Ссылка В(&СписокПозиций)";
				Запр.УстановитьПараметр("СписокПозиций",	СписокПозиций1);  
				СписокПозиций2=запр.Выполнить().Выгрузить();
				// 3
				Запр=Новый Запрос;
				Запр.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	Номенклатура.Ссылка.Родитель
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|ГДЕ
				|	Номенклатура.Ссылка В(&СписокПозиций)";
				Запр.УстановитьПараметр("СписокПозиций",	СписокПозиций2);  
				СписокПозиций3=запр.Выполнить().Выгрузить();
				// 4
				Запр=Новый Запрос;
				Запр.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	Номенклатура.Ссылка.Родитель
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|ГДЕ
				|	Номенклатура.Ссылка В(&СписокПозиций)";
				Запр.УстановитьПараметр("СписокПозиций",	СписокПозиций3);  
				СписокПозиций4=запр.Выполнить().Выгрузить();
				
				
				
				
				//нечаева 02,06,14 разделила на два запроса  ++++
				
				запрос=новый запрос;
				
				запрос.Текст="ВЫБРАТЬ
				|	а1.Скидка,
				|	а1.уровень,
				|	а1.Номенклатура,
				|	а1.ДокументДата
				|ИЗ
				|	(ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка КАК Скидка,
				|		0 КАК уровень,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата КАК ДокументДата
				|	ИЗ
				|		РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|				КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|				ТипСкидок = &ТипСкидок
				|					И Номенклатура В (&СписокПозиций)
				|					И Документ.Проведен
				|					И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|					И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
				|	
				|	ОБЪЕДИНИТЬ ВСЕ
				|	
				|	ВЫБРАТЬ
				|		ЦеныНоменклатурыСрезПоследних.Скидка,
				|		1,
				|		ЦеныНоменклатурыСрезПоследних.Номенклатура,
				|		ЦеныНоменклатурыСрезПоследних.Документ.Дата
				|	ИЗ
				|		РегистрСведений.СкидкиНоменклатуры.СрезПоследних(
				|				КОНЕЦПЕРИОДА(&Дата2, ДЕНЬ),
				|				ТипСкидок = &ТипСкидок
				|					И Номенклатура В (&СписокПозиций1)
				|					И Документ.Проведен
				|					И КОНЕЦПЕРИОДА(Документ.Дата2, ДЕНЬ) >= &Дата2
				|					И документ.Дата < &Дата2) КАК ЦеныНоменклатурыСрезПоследних
