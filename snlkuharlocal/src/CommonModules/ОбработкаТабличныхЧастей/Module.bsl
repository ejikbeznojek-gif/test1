Функция ПолучитьСтавкуНДС(Номенклатура) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ВЫБОР 
	|		КОГДА СтавкаНДС<>&ПустаяСтавка ТОГДА СтавкаНДС
	|		КОГДА Родитель.СтавкаНДС<>&ПустаяСтавка ТОГДА Родитель.СтавкаНДС
	|		КОГДА Родитель.Родитель.СтавкаНДС<>&ПустаяСтавка ТОГДА Родитель.Родитель.СтавкаНДС
	|		КОГДА Родитель.Родитель.Родитель.СтавкаНДС<>&ПустаяСтавка ТОГДА Родитель.Родитель.Родитель.СтавкаНДС
	//крохин начало
	|		КОГДА Родитель.Родитель.Родитель.Родитель.СтавкаНДС<>&ПустаяСтавка ТОГДА Родитель.Родитель.Родитель.Родитель.СтавкаНДС
	//|		КОГДА Родитель.Родитель.Родитель.Родитель.СтавкаНДС<>&ПустаяСтавка ТОГДА Родитель.Родитель.Родитель.СтавкаНДС
	//крохин конец
	|	ИНАЧЕ 
	| 		&ПустаяСтавка
	|	КОНЕЦ КАК СтавкаНДС
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("ПустаяСтавка",Перечисления.СтавкиНДС.ПустаяСсылка());
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СтавкаНДС		
	Иначе
		Возврат Перечисления.СтавкиНДС.ПустаяСсылка();		
	КонецЕсли;
КонецФункции // ПолучитьСтавкуНДС()


// Процедура заполняет ставку НДС в строке табличной части документа
//
// Параметры:
//  СтрокаТабличнойЧасти     - строка табличной части документа,
//  ДокументОбъект           - объект редактируемого документа.
//
Процедура ЗаполнитьСтавкуНДСТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект) Экспорт
	
	ИмяТабличнойЧасти = ПолучитьИмяТабличнойЧастиПоСсылкеНаСтроку(СтрокаТабличнойЧасти);
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	
	//Заполнить СтавкаНДС
	Если ЕстьРеквизитТабЧастиДокумента("СтавкаНДС", МетаданныеДокумента, ИмяТабличнойЧасти) Тогда
		//крохин начало 29.03.2011
		//для отгрузки белорусским клиентам- ставка 0%
		//СтрокаТабличнойЧасти.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.Номенклатура);
		Если ЕстьРеквизитДокумента("НулеваяСтавкаНДС",МетаданныеДокумента) И ДокументОбъект.НулеваяСтавкаНДС Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.НДС0;			
		Иначе
			//Катаев+ 02/06/14
			//СтрокаТабличнойЧасти.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.Номенклатура);
			
			//Если МетаданныеДокумента.Имя = "ПриходнаяНакладная" и ИмяТабличнойЧасти = "Заказ" Тогда
			Если ЕстьРеквизитДокумента("ПоставщикПоАгентскойСхеме", МетаданныеДокумента) Тогда
				Если (ЕстьРеквизитДокумента("КодОперации", МетаданныеДокумента) И ДокументОбъект.КодОперации = Перечисления.КодыОперацийОстатки.АгентскийДоговор) И
					// Шворобей 09.01.2024 ++ https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-2458
					(ЗначениеЗаполнено(ДокументОбъект.ПоставщикПоАгентскойСхеме) И ДокументОбъект.ПоставщикПоАгентскойСхеме.СтавкаНДСКонтрагента = Перечисления.СтавкиНДС.БезНДС) Тогда
						СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
				//крохин начало 16.01.2024
				//ошибка
				//ИначеЕсли ДокументОбъект.Контрагент.КонтрагентБезНДС Тогда
				//	СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
				//крохин конец 16.01.2024
				Иначе
					СтрокаТабличнойЧасти.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.Номенклатура);
				КонецЕсли;
			Иначе
				СтрокаТабличнойЧасти.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.Номенклатура);
			КонецЕсли;
			//Катаев- 02/06/14
		КонецЕсли;
		// Шворобей 09.01.2024 ++
		//крохин конец 29.03.2011
		
		//крохин начало 21.01.2019
		//для франчайзи без НДС
		//крохин начало 14.02.2019
		//ставка НДС для франчайзи нулевая во всех документах
		//Если ПараметрыСеанса.ЭтотУзел.Подразделение.НулеваяСтавкаНДСвЧеке И ДокументОбъект.метаданные().Имя = "Чек" Тогда
		Если ПараметрыСеанса.ЭтотУзел.Подразделение.НулеваяСтавкаНДСвЧеке Тогда
			//крохин конец 14.02.2019	
			СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		КонецЕсли;
		//крохин конец 21.01.2019
	КонецЕсли;
	
КонецПроцедуры // ЗаполнитьСтавкуНДСТабЧасти()

// Процедура заполняет единицу в строке табличной части документа
//
// Параметры:
//  СтрокаТабличнойЧасти     - строка табличной части документа,
//  ДокументОбъект           - объект редактируемого документа.
//
Процедура ЗаполнитьЕдиницуТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект) Экспорт
	
	// берем из самого реквизита Номенклатура
	СтрокаТабличнойЧасти.Единица	 = СтрокаТабличнойЧасти.Номенклатура.ОсновнаяЕдиница;
	СтрокаТабличнойЧасти.Коэффициент = СтрокаТабличнойЧасти.ЕдиницаИзмерения.Коэффициент;
	
	РассчитатьКоличествоТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект);
	
КонецПроцедуры // ЗаполнитьЕдиницуТабЧасти()




