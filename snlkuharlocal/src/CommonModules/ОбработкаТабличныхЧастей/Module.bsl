Функция ПроверкаШКGS1НаИспользование(ШтрихКод) Экспорт
	
	Используется = ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ШтрихКоды.Владелец КАК Владелец,
	|	ШтрихКоды.Наименование КАК Наименование,
	|	ШтрихКоды.ТипШК КАК ТипШК,
	|	ШтрихКоды.ВидШК КАК ВидШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Наименование = &текшк";
	//|	И ШтрихКоды.ВидШК = &Доп";
	Запрос.УстановитьПараметр("ТекШК",Строка(ШтрихКод));
	//Запрос.УстановитьПараметр("Доп",перечисления.ВидыШК.Дополнительный);
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() ТОгда
		#если клиент тогда
			сообщить(" Штрикод - "+ШтрихКод+" уже загружен, номенклатура - "+рез.владелец+" код - "+рез.владелец.код);
		#конецесли
		
		Используется = истина;
		возврат используется;
	КонецЕсли;
	
	
	попытка
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	РезервированиеШКGS1.ДокументРегистрации КАК ДокументРегистрации,
		|	РезервированиеШКGS1.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.РезервированиеШКGS1 КАК РезервированиеШКGS1
		|ГДЕ
		|	РезервированиеШКGS1.GS1 = &ТекШк";
		Запрос.УстановитьПараметр("ТекШК",(ШтрихКод));
		//Запрос.УстановитьПараметр("Доп",перечисления.ВидыШК.Дополнительный);
		Рез = Запрос.Выполнить().Выбрать();
		Если Рез.Следующий() ТОгда
			#если клиент тогда
				
				сообщить(" Штрикод - "+ШтрихКод+" уже загружен в регистр. ");
			#конецесли
			
			Используется = истина;
			возврат используется;
			
		КонецЕсли;
	исключение
		#если клиент тогда
			
			сообщить(" Штрикод - "+ШтрихКод+" не загружен в регистр. ");
		#конецесли
		
		Используется = истина;
		возврат используется;
		
	конецпопытки;
	
	
	
	Возврат ложь;
	
КонецФункции
