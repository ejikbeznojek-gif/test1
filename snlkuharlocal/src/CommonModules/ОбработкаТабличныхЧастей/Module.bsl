			Если СтрокаТЧ.ЦенаКомпенсации>0 Тогда
				СтрокаТЧ.ЦенаСКомпенсацией=СтрокаТЧ.Цена;
				СтрокаТЧ.ВсегоСКомпенсацией=СтрокаТЧ.Всего;
				СтрокаТЧ.Компенсация=Окр(СтрокаТЧ.ЦенаКомпенсации*СтрокаТЧ.Количество,2);
			Иначе
				СтрокаТЧ.ВсегоСКомпенсацией=СтрокаТЧ.Всего;	
				СтрокаТЧ.Компенсация=0;	
				СтрокаТЧ.ЦенаСКомпенсацией=СтрокаТЧ.цена;
			КонецЕсли;		
			СтрокаТЧ.Цена= СтрокаТЧ.Цена-СтрокаТЧ.ЦенаКомпенсации;
			СтрокаТЧ.Всего= СтрокаТЧ.Цена*СтрокаТЧ.Количество;	

		Иначе
			СтрокаТЧ.ВсегоСКомпенсацией=0;	
			СтрокаТЧ.Компенсация=0;	
			СтрокаТЧ.ЦенаСКомпенсацией=0;
			СтрокаТЧ.ЦенаКомпенсации=0;	
		КонецЕсли;
	КонецЕсли;
	
    //// Крохин  16.12.2024 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1637
	//заполнение компенсации в СПП, если поменяли Количество или ЦенаКомпенсаци
	Если МетаданныеДокумента.Имя = "СписаниеТМЦСпути" Тогда
		Если ЗначениеЗаполнено(ДокументОбъект.КонтрагентКомпенсация) И ЗначениеЗаполнено(ДокументОбъект.ДоговорКомпенсация) И 
			ЗначениеЗаполнено(ДокументОбъект.ТипЦенКомпенсация) Тогда			
