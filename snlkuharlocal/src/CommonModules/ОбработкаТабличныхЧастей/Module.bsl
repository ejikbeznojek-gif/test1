// Кухарь А.Ю.  24.03.2026 начало
Функция СтавкаНДСПоПроценту (Процент) Экспорт
	
	если ТипЗнч(Процент) = Тип("Число") и Процент>0 и Процент<1 тогда    
		Процент = 100*Процент; 
	ИначеЕсли ТипЗнч(Процент) = Тип("Строка") тогда  
		Процент = ВРег(Процент);
		Процент = СтрЗаменить(Процент," ","");
		Процент = СтрЗаменить(Процент,"%","");
		
		если СтрНайти(Процент,"БЕЗ") > 0 и СтрНайти(Процент,"НДС")> 0 тогда 
			возврат Перечисления.СтавкиНДС.БезНДС;  
		иначе       
			попытка
				Процент = Число(Процент);
			исключение
				возврат Неопределено;
			КонецПопытки;
		КонецЕсли;   		
	КонецЕсли;   
	
	 
	 
	
	Если Процент = 0 Тогда
		Возврат Перечисления.СтавкиНДС.НДС0;
	ИначеЕсли Процент = 10 Тогда
		Возврат Перечисления.СтавкиНДС.НДС10;

	ИначеЕсли Процент = 18 Тогда
		Возврат Перечисления.СтавкиНДС.НДС18;  
			ИначеЕсли Процент = 20 Тогда
		Возврат Перечисления.СтавкиНДС.НДС20;   
	ИначеЕсли Процент = 22 Тогда
		Возврат Перечисления.СтавкиНДС.НДС22;   
	ИначеЕсли Процент = 5 Тогда
		Возврат Перечисления.СтавкиНДС.НДС5;   
	ИначеЕсли Процент = 7 Тогда
		Возврат Перечисления.СтавкиНДС.НДС7;  
	иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции        
