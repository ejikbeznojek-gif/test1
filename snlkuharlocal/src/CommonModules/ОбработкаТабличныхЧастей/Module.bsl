								Возврат(стр.Цена);
							Конецесли;	
							
						иначе
							// цена по локальному прайсу
							//Возврат(стр.Цена);
							полученнаяцена=стр.Цена;
							
						Конецесли;	  
						// нечаева 09,01,13 ---
						Возврат(0);
					иначе
						полученнаяцена=стр.Цена;
						
					Конецесли;
					возврат(0);
				иначе
					полученнаяцена=стр.Цена;
				Конецесли;
			Конецесли;
			Если ПолученнаяЦена=-1 Тогда
				Возврат(0);
			иначе
				Возврат(ПолученнаяЦена);
			КонецЕсли;	
			Возврат(0);
			
			// 12.09.2014 нечаева  -------
			
			
			//мессерле
		иначе
			//Нечаева 14,08,13++++
			
			// считаем по текущему типу цен
			//Запрос.Текст="
			//|ВЫБРАТЬ ПЕРВЫЕ 1	
			//|	Цена,
			//|	ВЫБОР 
			//|		КОГДА ТипЦен = &ТипЦен ТОГДА 0		
			//|	ИНАЧЕ 100 КОНЕЦ КАК Уровень
			//|ИЗ
			//|РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата2,
			//|	(ТипЦен = &ТипЦен)
			//|	И Номенклатура = &Номенклатура0
			//|	И Прайс.Проведен
			//|	И КОНЕЦПЕРИОДА(Прайс.Дата2,День) >= &Дата2	
			//|	) КАК ЦеныНоменклатурыСрезПоследних
			//|ГДЕ Номенклатура.ЭтоГруппа
			//|УПОРЯДОЧИТЬ ПО Уровень,Прайс.Дата Убыв";
			
			
			// сначала считаем цену по приоритетному типу цен - локальному , если нет то берем базовый.
			Запрос.Текст="
			|ВЫБРАТЬ ПЕРВЫЕ 1	
			|	Цена,
			|	ВЫБОР 
			|		КОГДА ТипЦен = &ТипЦен ТОГДА 0		
			|	ИНАЧЕ 100 КОНЕЦ КАК Уровень
			|ИЗ
			|РегистрСведений.ЦеныНоменклатуры.СрезПоследних(КонецПериода(&Дата2,День),
			|	(ТипЦен = &ТипЦен)
			|	И Номенклатура = &Номенклатура0
			|	И Прайс.Проведен
			|	И КОНЕЦПЕРИОДА(Прайс.Дата2,День) >= &Дата2 И Прайс.Дата < &Дата2
			|	) КАК ЦеныНоменклатурыСрезПоследних
			|ГДЕ Номенклатура.ЭтоГруппа
			|УПОРЯДОЧИТЬ ПО Уровень,Прайс.Дата Убыв";
			
			
			
			
			Запрос.УстановитьПараметр("Дата2",				ТекДатаРасчета);
			Запрос.УстановитьПараметр("ТипЦен",				ТипЦен);	
			Запрос.УстановитьПараметр("ТипЦен_Базовый",		ТипЦен.Базовый);		
			
			// Кухарь А.Ю.  06.03.2026 начало
			//Запрос.УстановитьПараметр("Номенклатура0",	?(Номенклатура.ЭтоГруппа,Номенклатура,Номенклатура.Родитель));      
			РеквизитыНоменклатуры = ПолучитьРеквизитыШапки(Номенклатура,"ЭтоГруппа,Родитель","Справочник");
			Запрос.УстановитьПараметр("Номенклатура0",	?(РеквизитыНоменклатуры.ЭтоГруппа,Номенклатура,РеквизитыНоменклатуры.Родитель));
			// Кухарь А.Ю.  06.03.2026 конец
			
						
			Результат=Запрос.Выполнить();
			//крохин начало 22.09.2011
			//единицу не используем больше
			//Коэффициент=?(Единица=Неопределено,1,Единица.Коэффициент);
			Коэффициент = 1;
			//крохин конец 22.09.2011;
			Выборка=Результат.Выбрать();
			
			
			
			Пока Выборка.Следующий() Цикл			
				//нечаева 08,09,2014 +++
				Если Выборка.цена<>-1 Тогда
