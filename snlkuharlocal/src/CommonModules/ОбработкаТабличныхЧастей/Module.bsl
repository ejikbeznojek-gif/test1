// нечаева 14,12,16++
Функция ПолучитьЦенуДляАртура(КодНом) Экспорт
	
	//чернышев
	Контрагент = Справочники.Контрагенты.НайтиПоКоду("SSR-6515");
	
	ТекТипЦен			= контрагент.ТипЦен;
	Цена				= 0;
	Распродажа			= Ложь;
	валюта = справочники.Валюты.НайтиПоКоду("810");
	
	Номенклатура = справочники.Номенклатура.НайтиПоКоду(КодНом);
	Модель = Номенклатура.родитель;
	//распродажа
	Цена=ПолучитьЦенуНоменклатуры(Номенклатура,,Контрагент.ТипЦенРаспродажа,Валюта,1,ТекущаяДата());			
	Если ЗначениеЗаполнено(Цена) Тогда
		
		Распродажа							= Истина;
		Возврат Цена;
		
	КонецЕсли; 
	
	Цена = ПолучитьЦенуКонтрагента(ТекущаяДата(),Контрагент,Модель);
	//СкидкаТек = ПолучитьСкидкуКонтрагента(ТекущаяДата(),Контрагент,Модель);
	
	Если ЗначениеЗаполнено(Цена) Тогда
		Возврат Цена;
	иначе
		возврат 0;
	КонецЕсли;
	
	
КонецФункции // ПриИзмененииНоменклатурыТабЧасти()
