Процедура ОбнулитьЦеныВТабЧасти(ТабличнаяЧасть,ДокОбъект) экспорт
	для каждого СтрокаТЧ из ТабличнаяЧасть цикл
		СтрокаТЧ.Цена=0;
		СтрокаТЧ.ЦенаБезСкидки=0;
		СтрокаТЧ.Сумма=0;
		СтрокаТЧ.НДС=0;
		СтрокаТЧ.Всего=0;
		СтрокаТЧ.ВсегоБезСкидки=0;
		Если ДокОбъект.Метаданные().имя="РасходнаяНакладная" тогда
			СтрокаТЧ.ЦенаБезБонуса=0;
			СтрокаТЧ.ВсегоБезБонуса=0;			
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
