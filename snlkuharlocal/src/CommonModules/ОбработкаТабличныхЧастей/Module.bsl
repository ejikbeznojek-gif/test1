					Конецесли;	
					
				КонецЦикла;
				//нечаева 09,01,13 ----
				// 12.09.2014 --- нечаева
				
				
			Конецесли;
			
			
			// 12.09.2014 +++ нечаева
			ПолученнаяЦена= 0;
