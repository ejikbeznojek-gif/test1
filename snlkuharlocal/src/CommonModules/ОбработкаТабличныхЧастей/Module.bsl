Функция ЦенаКонтрагентаО(Дата2,Номенклатура,ТипЦен) Экспорт
	
	ТекТипЦен			= ТипЦен;
	Распродажа			= Ложь;
	
	
	Валюта=ТипЦен.Валюта;
	Курс=ПолучитьКурсВалюты_ПоРусски(Валюта, Дата2);
	Цена=ПолучитьЦенуНоменклатуры(Номенклатура,,ТипЦен,Валюта,Курс,Дата2);
	
	//определение - ПолучитьЦенуНоменклатуры(Номенклатура,Единица=Неопределено,ТипЦен,ВалютаДокумента,КурсДокумента,ДатаРасчета=Неопределено) Экспорт
	
	Возврат Цена;
	
КонецФункции

Функция ПолучитьЦенуКонтрагента(Дата,Контрагент,Модель) Экспорт 
	
	ТипЦенРаспродажа=ПолучитьРеквизитРодителя(Контрагент,"ТипЦенРаспродажа");
	ТипЦен_SALE=Контрагент.ТипЦенРаспродажа;
	ТипЦен=Справочники.ТипыЦен.ПустаяСсылка();
	
	Скидка=0;
	ЦенаРаспродажа=0;
	Цена=0;
	ИтЦена=0;
	
	
	СкидкаВЫб=СкидкаКонтрагентаО(дата,Модель,Контрагент);
	
	Если  СкидкаВыб=Неопределено Тогда
		СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
		Если СкидкаКонтрагента>0 Тогда
			Скидка=СкидкаКонтрагента;
			//крохин начало 29.06.2012
			//Тип цен может быть задан в контрагенте, а не родителе
			//ТипЦен=ПолучитьРеквизитРодителя(Контрагент,"ТипЦен");
			ТипЦен = Контрагент.ТипЦен;
			Если ТипЦен.Пустая() Тогда
				
			КонецЕсли;
			//крохин конец 29.06.2012
			
		КонецЕсли; 
		
	Иначе
		Скидка=СкидкаВыб.Скидка;
		ТипЦен=СкидкаВыб.ТипЦен;
		//Сообщить("  "+Модель+" "+Скидка+"  "+ТипЦен);
	КонецЕсли; 
	
	Цена=ЦенаКонтрагентаО(Дата,Модель,ТипЦен);
	//-----------------------------------------------------
	Если ТипЦен_SALE.Пустая() Тогда
		ТипЦен_SALE=Контрагент.ТипЦенРаспродажа;
	КонецЕсли; 
	
	ЦенаРаспродажа=ЦенаКонтрагентаО(Дата,Модель,ТипЦен_SALE);
	Если НЕ ЦенаРаспродажа=Неопределено Тогда
		Цена=ЦенаРаспродажа;
		ТипЦен=ТипЦен_SALE;
	КонецЕсли; 
	
	//*****************************************************************
	Если ТипЦен=ТипЦен_SALE Тогда
		
		ИтЦена=Цена;
		ИтСкидка="-";
		
	Иначе
		
		Если НЕ Скидка=Неопределено и НЕ Цена=Неопределено Тогда
			Если Скидка=-1 Тогда
				ИтЦена=Цена;
			Иначе
				ИтЦена=Цена-(Цена/100*Скидка);
			КонецЕсли; 
		Иначе
			ИтЦена=Цена;
		КонецЕсли; 
		
		//ИтЦена=Цена;
		ИтСкидка=Число(Скидка);
		
	КонецЕсли;		
	//*****************************************************************
	
	
	Возврат ИтЦена;
	
	
КонецФункции

Функция ПолучитьСкидкуКонтрагента(Дата,Контрагент,Модель) Экспорт 
	
	
	ТипЦенРаспродажа=ПолучитьРеквизитРодителя(Контрагент,"ТипЦенРаспродажа");
	ТипЦен_SALE=Контрагент.ТипЦенРаспродажа;
	ТипЦен=Справочники.ТипыЦен.ПустаяСсылка();
	
	Скидка=0;
	
	СкидкаВЫб=СкидкаКонтрагентаО(дата,Модель,Контрагент);
	
	Если  СкидкаВыб=Неопределено Тогда
		СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
		Если СкидкаКонтрагента>0 Тогда
			Скидка=СкидкаКонтрагента;
			ТипЦен=ПолучитьРеквизитРодителя(Контрагент,"ТипЦен");
		КонецЕсли; 
		
	Иначе
		Скидка=СкидкаВыб.Скидка;
		ТипЦен=СкидкаВыб.ТипЦен;
		//Сообщить("  "+Модель+" "+Скидка+"  "+ТипЦен);
	КонецЕсли; 
	
	Цена=ЦенаКонтрагентаО(Дата,Модель,ТипЦен);
	ЦенаРаспродажа=ЦенаКонтрагентаО(Дата,Модель,ТипЦен_SALE);
	Если НЕ ЦенаРаспродажа=Неопределено Тогда
		Цена=ЦенаРаспродажа;
		ТипЦен=ТипЦен_SALE;
	КонецЕсли; 
	
	//-----------------------------------------------------
	Если ТипЦен_SALE.Пустая() Тогда
		ТипЦен_SALE=Контрагент.ТипЦенРаспродажа;
	КонецЕсли; 
	
	ЦенаРаспродажа=ЦенаКонтрагентаО(Дата,Модель,ТипЦен_SALE);
	Если НЕ ЦенаРаспродажа=Неопределено Тогда
		Цена=ЦенаРаспродажа;
		ТипЦен=ТипЦен_SALE;
	КонецЕсли; 
	
	//*****************************************************************
	Если ТипЦен=ТипЦен_SALE Тогда
		
		ИтСкидка="-";
		
	Иначе
		
