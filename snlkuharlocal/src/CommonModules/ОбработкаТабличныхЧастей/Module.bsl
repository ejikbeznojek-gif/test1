					Если Стр=Неопределено тогда
						Стр=ВремТз.найти(номенклатура.родитель.родитель,"Номенклатура");
						// нечаева 09,01,13 +++  добавила тз2
						Если Стр=Неопределено тогда
							
							Стр=ВремТз2.найти(номенклатура.родитель.родитель,"Номенклатура");
							Если Стр=Неопределено тогда
