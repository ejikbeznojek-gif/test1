Функция ПолучитьСуммыТандерЭкспозиторы(ДокОбъект,Экспозитор)
	
	ТН=Новый ТаблицаЗначений;
	
	ТН.Колонки.Добавить("Номенклатура");	
	ТН.Колонки.Добавить("Количество");
	ТН.Колонки.Добавить("НДС");
	ТН.Колонки.Добавить("Сумма");
	ТН.Колонки.Добавить("СтавкаНДС");
	ТН.Колонки.Добавить("Всего");
	ТН.Колонки.Добавить("Цена");
	
	ИсходнаяТЧ=ДокОбъект.Товары.Выгрузить();
	ИсходнаяТЧ = Новый ТаблицаЗначений;
	ИсходнаяТЧ.Колонки.Добавить("Номенклатура");	
	ИсходнаяТЧ.Колонки.Добавить("Количество");
	ИсходнаяТЧ.Колонки.Добавить("НДС");
	ИсходнаяТЧ.Колонки.Добавить("Сумма");
	ИсходнаяТЧ.Колонки.Добавить("Всего");
	ИсходнаяТЧ.Колонки.Добавить("Цена");
	
	
	// заменияем на колво экспозиторов. Цену берем из матрицы.
	
	ОбщКолво = ДокОбъект.товары.Итог("Количество");
	КолвВ1Эксп = Экспозитор.Коплектующие.Итог("Количество");
	Если КолвВ1Эксп = 0 Тогда
		ВсегоЭксп  = Окр(ОбщКолво);
	Иначе
		ВсегоЭксп  = Окр(ОбщКолво/КолвВ1Эксп);
	КонецЕсли;
	
	
	//------------------------------------------------------------------------
	//------------------------------------------------------------------------
	НовСтр = ТН.Добавить();
	НовСТр.Номенклатура = Экспозитор;
	НовСТр.Количество = ВсегоЭксп;
	//ЗаполнитьЦенуНоменклатурыТабЧастиПоМатрице(НовСТр, ДокОбъект) ;
	//ПриИзмененииНоменклатурыТабЧасти(НовСтр, ТекОб);
	
	
	
	//получим цену номенклатуры
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	МатрицаТовары.Номенклатура,
	|	МатрицаТовары.Цена,
	|	МатрицаПунктыДоставки.Ссылка
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|		ПОЛНОЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	|		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	|ГДЕ
	|	МатрицаТовары.Ссылка.Дата <= &Дата1
	|	И МатрицаТовары.Ссылка.Проведен
	|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	//	|	И МатрицаТовары.Ссылка.Акция = ИСТИНА
	|	И МатрицаТовары.Номенклатура = &ТекНом
	//	|	И МатрицаПунктыДоставки.ПунктДоставки.Ссылка = &текПункДоставки
	|	УПОРЯДОЧИТЬ ПО
	|	МатрицаТовары.Ссылка.Дата УБЫВ
	|АВТОУПОРЯДОЧИВАНИЕ";
	//нечаева 18,07,17---
	Запрос.УстановитьПараметр("ТекНом",Экспозитор);			   
	Запрос.УстановитьПараметр("Дата2",НачалоДня(ДокОбъект.дата));
	Запрос.УстановитьПараметр("Дата1",КонецДня(ДокОбъект.дата));
	Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
	Запрос.УстановитьПараметр("Договор",ДокОбъект.Договор);
	
	Запрос.УстановитьПараметр("ТекПункДоставки",ДокОбъект.пунктДоставки);
	// цена по акции
	ТЗ1 = Запрос.Выполнить().Выгрузить();
	Если ТЗ1.Количество()>0 Тогда
		Цена = ТЗ1[0].Цена;
	Иначе	
		Цена = 0;
	КонецЕсли;	
	//------------------------------------------------------------------------------------------
	
	НовСтр.Цена = Цена;
	
	НовСТр.Сумма 	= НовСТр.Цена * НовСТр.Количество;
	НовСТр.СтавкаНДС=ПолучитьСтавкуНДС(Экспозитор);
	СтавкаНДС=ПроцентНДСпоСтавке(НовСтр.СтавкаНДС);
	НовСтр.НДС	= Окр(НовСтр.Сумма*СтавкаНДС/(1+СтавкаНДС),2);			
	НовСтр.Всего	= НовСтр.Сумма;
	НовСтр.Сумма  = НовСтр.Всего - НовСтр.НДС;
	//------------------------------------------------------------------------
		
	// нечаева 11,10,23+++
	Ндссверху = ложь;

	Если ДокОбъект.Контрагент.НДС_СВерху = истина Тогда
		Ндссверху = истина;
	КонецЕсли;
		
	Если НдсСверху  Тогда
		Цена = Окр(Цена/(1+СтавкаНДС),2);
		НовСТр.Сумма	= Цена * НовСТр.Количество;
		НовСТр.НДС	= Окр(НовСТр.Сумма*СтавкаНДС,2);
		НовСТр.Всего	=  НовСТр.Сумма + НовСТр.НДС;
	КонецЕсли;
	// нечаева 11,10,23---
	
	//------------------------------------------------------------------------
	
	Для Каждого СтрокаТН Из ТН Цикл
		Номенклатура=СтрокаТН.Номенклатура;
		Модель		=СтрокаТН.Номенклатура.Родитель;
		// было
		//СтрокаТН.Цена		=?(СтрокаТН.Количество=0,0,СтрокаТН.Сумма/СтрокаТН.Количество);
		//Если СтрокаТН.Сумма=0 Тогда
		//	СтрокаТН.СтавкаНДС=100*ПроцентНДСпоСтавке(ПолучитьРеквизитРодителя(СтрокаТН.Номенклатура,"СтавкаНДС"));
		//Иначе			
		//	СтрокаТН.СтавкаНДС	=Окр(100*(СтрокаТН.НДС/СтрокаТН.Сумма),0,1);
		//КонецЕсли;			
		
		// нечаева11,10,23++
		ПрСтНДС = ПроцентНДСпоСтавке(ПолучитьРеквизитРодителя(СтрокаТН.Номенклатура,"СтавкаНДС"));
		
		Если СтрокаТН.Сумма=0 Тогда
			СтрокаТН.СтавкаНДС=100*ПрСтНДС ;
		Иначе			
			СтрокаТН.СтавкаНДС	=Окр(100*(СтрокаТН.НДС/СтрокаТН.Сумма),0,1);
		КонецЕсли;			
				
		Если НдсСверху  Тогда
			СтрокаТН.Цена =  ?(СтрокаТН.Количество=0,0,Окр(СтрокаТН.Цена/(1+ПрСтНДС),2))
			//цена = Окр(Цена/(1+СтавкаНДС),2);
		иначе
			СтрокаТН.Цена		=?(СтрокаТН.Количество=0,0,СтрокаТН.Сумма/СтрокаТН.Количество);
		КонецЕсли;
		// нечаева 11,10,23---

	КонецЦикла; 
	
	
	Возврат ТН;
КонецФункции // ПолучитьТаблицуНакладной()

Функция ПоправкаСуммТандер(ДокументОбъект,ТТТ)
	
	//ОбработкаПрерыванияПользователя();
	
	ПоправкаВсего = ТТТ.итог("Всего") - ДокументОбъект.Товары.Итог("Всего");
	ПоправкаНДС = ТТТ.итог("НДС") - ДокументОбъект.Товары.Итог("НДС");
	ШагПоправкиНДС =0 ;
	ШагПоправкиВсего = 0 ;
	
	//нечаева 08,11,19 +++    
	// увеличила сумму со 100 на 300 нечаева 25,10,23+++
	Если ПоправкаВсего<-300 или ПоправкаВсего>300 
		или ПоправкаНДС<-300 или ПоправкаНДС>300
		Тогда
		
		#если клиент тогда
			сообщить("Проверьте количество товаров в накладной, оно должно быть кратно экспозиторам!");
			сообщить("Итоговые суммы не пересчитаны! Разница больше 300 руб.");

		#конецесли	
		возврат ложь;
		
	КонецЕсли;	
	//нечаева 08,11,19 ---
	
	
	
	Если (ПоправкаВсего>1 ) или (ПоправкаВсего<-1) Тогда 
		ШагПоправкиВсего = Окр(ПоправкаВсего/ДокументОбъект.Товары.количество(),2);
	ИначеЕсли ПоправкаВсего<>0 Тогда
		ШагПоправкиВсего = 0.01;
	КонецЕсли;	
	
	Если ПоправкаНДС>1 или ПоправкаНДС<-1 Тогда 
		ШагПоправкиНДС = Окр(ПоправкаНДС/ДокументОбъект.Товары.количество(),2);
	иначеЕсли ПоправкаНДС<>0 Тогда
		ШагПоправкиНДС = 0.01;
	КонецЕсли;	
	
	Если ШагПоправкиНДС<0 Тогда ШагПоправкиНДС = -ШагПоправкиНДС; КонецЕсли;
	Если ШагПоправкиВсего<0 Тогда ШагПоправкиВсего = -ШагПоправкиВсего; КонецЕсли;
	
	Если  ПоправкаВсего<>0 или ПоправкаНДС<>0 Тогда
