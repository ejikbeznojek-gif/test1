функция ГТДДляЕкодаГТД(Номенклатура) Экспорт
	
	
	ГТД=ПолучитьГрупповойПериодическийРеквизит(Номенклатура.Родитель,"НомерГТД",ТекущаяДата());
	
	Страна	="RU";
	НомерГТД="";
	Если ГТД<>Неопределено И Врег(""+ГТД.СтранаПроисхождения)<>"РОССИЯ" И НЕ ПустаяСтрока(""+ГТД.СтранаПроисхождения) Тогда
		Страна		=""+ГТД.СтранаПроисхождения;
		НомерГТД	=СокрЛП(""+ГТД.Наименование);
	КонецЕсли;
	
	
	Если НомерГТД="" Тогда
		Сообщить("Для номенклатуры - "+Номенклатура+" - не определен номер ГТД! ");
		Ошибка=1;
	КонецЕсли;	
	
	//--------------------------------------------------------------------------------
	// ищем номер страны для гтд
	//--------------------------------------------------------------------------------
	Макет=ПолучитьОбщийМакет("КлассификаторСтранМира");
	Искомое2 = СокрЛП(Страна);  //значение в макете есть, не находит
	Искомое = Макет.НайтиТекст(Искомое2); //,, ОбластьПоиска);
	Если Искомое<>Неопределено ТОгда
		Строка=Искомое.Низ;
		Колонка=Искомое.Лево+1; // для кода
	КонецЕсли;
	// получаем код
	
	Страна=Макет.Область(Строка,Колонка).Текст;
	
	Возврат Гтд;
	
КонецФункции


