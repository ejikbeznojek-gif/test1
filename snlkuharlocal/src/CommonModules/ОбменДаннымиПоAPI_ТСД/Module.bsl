	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.Ликвидирован,4);
	
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.ВПути,5); 
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.Таможня,6);
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.Получен,7);
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.ВПроизводстве,8);
	
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.Произведен,9);
	Соответствие.Вставить(Перечисления.СостояниеЗаказаПоставщику.Закрыт,10);
