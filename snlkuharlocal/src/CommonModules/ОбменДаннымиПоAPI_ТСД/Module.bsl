Функция ОтветlistFactoriesGET(Знач Запрос) Экспорт 
	
	Ответ = Новый HTTPСервисОтвет(200); 	
	//Заголовки 
	ЗаголовкиСоответствие 	= Запрос.заголовки;  
	ПараметрыЗапроса 		= Запрос.ПараметрыЗапроса; //после знака ? 
	
	Лимит 				= неопределено; 
	НомерСтраницы 		= неопределено; 
	
	Если ПараметрыЗапроса.Получить("limit") <> неопределено Тогда
		
		Лимит = Число(ПараметрыЗапроса.Получить("limit"));  	
		
	КонецЕсли;
	
	Если ПараметрыЗапроса.Получить("page") <> неопределено Тогда
		
		номерСтраницы = Число(ПараметрыЗапроса.Получить("page"));  	
		
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура; 	
	ПараметрыОтбора.Вставить("Лимит",Лимит);
	ПараметрыОтбора.Вставить("номерСтраницы",номерСтраницы);
	ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
	
	ЗаписатьВходящиеДанныеЗапросаИсторияЗапросовФабрики(ИдентификаторЗапроса,ПараметрыЗапроса,Новый Структура); 
	
	СтруктураОтвета = ПолучитьДанныеПоФабрикам(ИдентификаторЗапроса,ПараметрыОтбора); 	
	
	СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
	
	Ответ  = СформироватьОтветApplicationFactory(200,СтрокаJSON,""); 
	
	ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,СтруктураОтвета,200); 
	
	Возврат Ответ;

	
КонецФункции // ОтветlistFactoriesGET()

Функция ОтветlistOrdersPOST(Знач Запрос) Экспорт 

	Ответ = Новый HTTPСервисОтвет(200);
	
	ЗаголовкиСоответствие 	= Запрос.заголовки;  
	ПараметрыЗапроса 		= Запрос.ПараметрыЗапроса; //после знака ? 
	ТекстТела 				= Запрос.ПолучитьТелоКакСтроку();
	Если ЗначениеЗаполнено(ТекстТела) Тогда 	
		СтруктураJSONЗапроса = ПрочитатьТелоЗапросаВСтруктуру(ТекстТела); 
	Иначе 
		СтруктураJSONЗапроса = Новый Структура; 
	КонецЕсли;	
	ОтборПоКонтрагенту 	= неопределено;
	Лимит 				= неопределено; 
	НомерСтраницы 		= неопределено;
	ТипДокумента 		= неопределено;
	//++Данилова Е.В. 13.03.2026 MARK-3512 
	ТипЗаказа 			= Неопределено; 
	//--Данилова Е.В. 13.03.2026 
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("factoryId") Тогда
		
		ГУИД = Новый УникальныйИдентификатор(СтруктураJSONЗапроса.factoryId);
		
		УстановитьПривилегированныйРежим(Истина);
		ОтборПоКонтрагенту = Справочники.Контрагенты.ПолучитьСсылку(ГУИД); 
		
		Если ОтборПоКонтрагенту.ПолучитьОбъект() = неопределено Тогда
		
			ОтборПоКонтрагенту = неопределено; 	
		
		КонецЕсли;
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("limit") Тогда
		
		Лимит = СтруктураJSONЗапроса.limit;  	
		
	КонецЕсли;
	
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("page") Тогда
		
		номерСтраницы = СтруктураJSONЗапроса.page;  	
		
	КонецЕсли;
	
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("typedoc") Тогда
		
		ТипДокумента = СтруктураJSONЗапроса.typedoc;  	
		
	КонецЕсли;
	
	//++Данилова Е.В. 13.03.2026 MARK-3512
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("type_order") Тогда
		
		ТипЗаказа = СтруктураJSONЗапроса.type_order;  	
		
	КонецЕсли;
	//--Данилова Е.В. 13.03.2026 
	
	ПараметрыОтбора = Новый Структура; 
	ПараметрыОтбора.Вставить("ОтборПоКонтрагенту",ОтборПоКонтрагенту);
	ПараметрыОтбора.Вставить("Лимит",Лимит);
	ПараметрыОтбора.Вставить("номерСтраницы",номерСтраницы);
	ПараметрыОтбора.Вставить("ТипДокумента",ТипДокумента);
	//++Данилова Е.В. 13.03.2026 MARK-3512
	ПараметрыОтбора.Вставить("ТипЗаказа",ТипЗаказа);
	//--Данилова Е.В. 13.03.2026 
	//////////здесь проверка параметров , которые пришли 
	
	ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
	
	ЗаписатьВходящиеДанныеЗапросаИсторияЗапросовФабрики(ИдентификаторЗапроса,ПараметрыЗапроса,СтруктураJSONЗапроса);
	
	СтруктураОтвета = ПолучитьСписокЗПС(ИдентификаторЗапроса,ПараметрыОтбора); 
	
	СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
	
	Ответ  = СформироватьОтветApplicationFactory(200,СтрокаJSON,""); 
	
	ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,СтруктураОтвета,200);
			
	Возврат Ответ;
	

КонецФункции // ОтветlistOrdersPOST()

Функция ОтветlistProductsPOST(Знач Запрос) Экспорт 

	Ответ = Новый HTTPСервисОтвет(200);
	
	ЗаголовкиСоответствие 	= Запрос.заголовки;  
	ПараметрыЗапроса 		= Запрос.ПараметрыЗапроса; //после знака ? 
	ТекстТела 				= Запрос.ПолучитьТелоКакСтроку();
	
	
	СтруктураJSONЗапроса = ПрочитатьТелоЗапросаВСтруктуру(ТекстТела);
	  
	
	ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
	ЗаписатьВходящиеДанныеЗапросаИсторияЗапросовФабрики(ИдентификаторЗапроса,ПараметрыЗапроса,СтруктураJSONЗапроса);
	
	РезультатОбработки = ОбработатьСтруктуруЗапросаПоIDЗПС(СтруктураJSONЗапроса,ИдентификаторЗапроса); 
	
	Если ТипЗнч(РезультатОбработки) = Тип("HTTPСервисОтвет") Тогда
		
		Возврат РезультатОбработки; 
		
	ИначеЕсли ТипЗнч(РезультатОбработки) = Тип("Массив") тогда 
		
		МассивЗПС = РезультатОбработки; 
		
	Иначе
		ОтветОшибка = Новый Структура; 
		ОтветОшибка.Вставить("error","Неизвестная ошибка обработки запроса!!!"); 
		
		ОтветОшибкаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(ОтветОшибка);
		
		Возврат СформироватьОтветApplicationFactory(400,ОтветОшибкаJSON,"Unknown error!!!"); 
		
	КонецЕсли;
	
	 
	СтруктураОтвета = ПолучитьСписокТоваровПоЗПС(ИдентификаторЗапроса,МассивЗПС);
	
	СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(СтруктураОтвета);
	
	Ответ  = СформироватьОтветApplicationFactory(200,СтрокаJSON,""); 
	
	ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,СтруктураОтвета,200);
	
	///ПроставитьОтправкуМарокПоЗПСВФоне(МассивЗПС);  в какой момент непонятно... 
	
	Возврат Ответ;
	

КонецФункции // listProductsPOST()

