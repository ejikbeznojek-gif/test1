Функция ПолучитьСписокТоваровПоЗПС1(Знач Идентификатор, МассивЗПС) Экспорт
	
	УстановитьПривилегированныйРежим(истина);
	
	ДанныеОтвета 	= СтруктураДанныеСписокТоваровЗПС(Идентификатор); 
	ДанныеОтвета.id = Идентификатор; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	МаркировкаТоваровИСМП.ДокументОснование КАК ЗПС
	|ПОМЕСТИТЬ ВТКоробки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
	|ГДЕ
	|	МаркировкаТоваровИСМП.ДокументОснование В(&МассивЗПС)
	|	И МаркировкаТоваровИСМП.ВидОперации = &Агрегация
	|	И МаркировкаТоваровИСМП.Проведен
	|	И МаркировкаТоваровИСМП.ТипШК = &Коробка
	|	И МаркировкаТоваровИСМП.Статус = &Обработан
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТКоробки.ШтрихкодУпаковки) КАК Количество,
	|	ВТКоробки.ЗПС КАК ЗПС
	|ПОМЕСТИТЬ ВТКоличествоКоробок
	|ИЗ
	|	ВТКоробки КАК ВТКоробки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТКоробки.ЗПС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПоставщику.Ссылка КАК ЗПС,
	|	ЗаказПоставщику.Номер КАК Номер,
	|	ЗаказПоставщику.Контрагент КАК Контрагент,
	|	ЗаказПоставщику.Контрагент.Наименование КАК КонтрагентНаименование,
	|	ЗаказПоставщику.Дата КАК Дата,
	|	ЗаказПоставщику.СостояниеЗаказа КАК СтатусЗПС,
	|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	|	ЗаказПоставщикуТовары.Номенклатура.Наименование КАК НоменклатураНаименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер.Наименование КАК НоменклатураРазмер,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет.Наименование КАК НоменклатураЦвет,
	|	"""" КАК Картинка,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(ВТКоличествоКоробок.Количество, 0) КАК КоличествоКоробок
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|		ПО (ЗаказПоставщикуТовары.Ссылка = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКоличествоКоробок КАК ВТКоличествоКоробок
	|		ПО (ВТКоличествоКоробок.ЗПС = ЗаказПоставщику.Ссылка)
	|ГДЕ
	|	ЗаказПоставщику.Ссылка В(&МассивЗПС)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПоставщику.Ссылка,
	|	ЗаказПоставщику.Номер,
	|	ЗаказПоставщику.Контрагент,
	|	ЗаказПоставщику.Контрагент.Наименование,
	|	ЗаказПоставщику.Дата,
	|	ЗаказПоставщику.СостояниеЗаказа,
	|	ЗаказПоставщикуТовары.Номенклатура,
	|	ЗаказПоставщикуТовары.Номенклатура.Наименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер.Наименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет.Наименование,
	|	"""",
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Количество, 0),
	|	ЕСТЬNULL(ВТКоличествоКоробок.Количество, 0)
	|ИЗ
	|	Документ.КонтрактСПроизводителем КАК ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КонтрактСПроизводителем.Товары КАК ЗаказПоставщикуТовары
	|		ПО (ЗаказПоставщикуТовары.Ссылка = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКоличествоКоробок КАК ВТКоличествоКоробок
	|		ПО (ВТКоличествоКоробок.ЗПС = ЗаказПоставщику.Ссылка)
	|ГДЕ
	|	ЗаказПоставщику.Ссылка В(&МассивЗПС)
	|ИТОГИ
	|	СУММА(Количество),
	|	МАКСИМУМ(КоличествоКоробок)
	|ПО
	|	ЗПС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТКоробки.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ВТКоробки.ЗПС КАК ЗПС
	|ИЗ
	|	ВТКоробки КАК ВТКоробки
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки)
	|ПО
	|	ЗПС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование КАК ЗПС,
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК КМ,
	|	ШтрихкодыУпаковокТоваров.Наименование КАК Наименование,
	|	ШтрихкодыУпаковокТоваров.ТипКода КАК ТипКода
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ШтрихкодыУпаковокТоваров.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|ГДЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование В(&МассивЗПС)
	|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	КМ";
	
	Запрос.УстановитьПараметр("МассивЗПС", МассивЗПС);
	Запрос.УстановитьПараметр("Агрегация", перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов);
	Запрос.УстановитьПараметр("Коробка", Перечисления.ТипыШтрихКодов.Коробка);
	Запрос.УстановитьПараметр("Обработан", Перечисления.СтатусыДокументовМаркировки.Обработан);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ВыборкаИтогиТовары = ПакетЗапросов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВыборкаЗПСПоКоробкам = ПакетЗапросов[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВыборкаЗПСПоЭмиссиям = ПакетЗапросов[4].Выбрать(); 
	
	СоответствиеКодСтатус = СоответствиеСтатусКодСтатусаЗПС();
	Пока ВыборкаИтогиТовары.Следующий() Цикл
		
		ЗПС = ВыборкаИтогиТовары.ЗПС; 
		
		СтруктураЗПС = ДанныеМассиваЗПССТоварами(); 
		СтруктураЗПС.id   			= XMLСтрока(ЗПС.ссылка.УникальныйИдентификатор());
		СтруктураЗПС.code  		= ЗПС.Номер; 
		СтруктураЗПС.factory       = XMLСтрока(ЗПС.Контрагент.Наименование); 
		СтруктураЗПС.dateCreate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		//СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		Если ЗначениеЗаполнено(ЗПС.ДатаИзменения) Тогда		
			СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.ДатаИзменения);	
		Иначе 
			СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		КонецЕсли;
		//--Данилова Е.В. 13.03.2026 
		СтруктураЗПС.statusName    = XMLСтрока(ЗПС.СостояниеЗаказа); 
		СтруктураЗПС.factoryId     = XMLСтрока(ЗПС.Контрагент.УникальныйИдентификатор()); 
		СтруктураЗПС.statusCode    = XMLСтрока(СоответствиеКодСтатус.Получить(ЗПС.СостояниеЗаказа));
		СтруктураЗПС.boxTotal      = ВыборкаИтогиТовары.КоличествоКоробок; 
		СтруктураЗПС.productTotal  = ВыборкаИтогиТовары.Количество;
		
		
		ВыборкаТовары = ВыборкаИтогиТовары.Выбрать(); 
		
		Пока ВыборкаТовары.Следующий() Цикл
			
			СтруктураТовара =  ДанныеМассиваТоварыЗПС(); 
			СтруктураТовара.id 			= XMLСтрока(ВыборкаТовары.Номенклатура.УникальныйИдентификатор());
			СтруктураТовара.name 		= ВыборкаТовары.Номенклатура.Родитель.Наименование; 
			СтруктураТовара.size 		= XMLСтрока(ВыборкаТовары.НоменклатураРазмер); 
			СтруктураТовара.color 		= XMLСтрока(ВыборкаТовары.НоменклатураЦвет);
			СтруктураТовара.multibox	= ВыборкаТовары.Номенклатура.Родитель.ШтукВКоробке; 
			СтруктураТовара.GTIN 		= ВыборкаТовары.Номенклатура.ГТИН;
			СтруктураТовара.count 		= ВыборкаТовары.Количество;
			 
			СтруктураЗПС.productList.Добавить(СтруктураТовара); 
		КонецЦикла;
		
		
		ОтборПоЗПС = Новый Структура("ЗПС",ЗПС); 
		Пока ВыборкаЗПСПоКоробкам.НайтиСледующий(ОтборПоЗПС) Цикл 			
			
			ВыборкаИтогиКоробки = ВыборкаЗПСПоКоробкам.ВЫбрать(); 
			
			Пока ВыборкаИтогиКоробки.Следующий() Цикл   
				
				СтруктураКоробки = ДанныеМассиваКоробкиЗПС(); 
				
				СтруктураКоробки.code = XMLСтрока(ВыборкаИтогиКоробки.ШтрихкодУпаковки.Наименование); 
				//СтруктураКоробки.productTotal =  ВыборкаИтогиКоробки.ШтрихкодУпаковки; 
				
				//ВыборкаТоварыКоробки = ВыборкаИтогиКоробки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
				
				//Пока ВыборкаТоварыКоробки.Следующий() Цикл
				//	
				//	СтруктураТоварыКоробки = Новый Структура("id,total");  
				//	СтруктураТоварыКоробки.id 		=  XMLСтрока(ВыборкаТоварыКоробки.Номенклатура.УникальныйИдентификатор()); 
				//	СтруктураТоварыКоробки.total 	=  ВыборкаТоварыКоробки.ШтрихкодУпаковки; 
				//	
				//	СтруктураКоробки.productList.Добавить(СтруктураТоварыКоробки); 	 
				//	
				//КонецЦикла;	 
				
				
				СтруктураЗПС.boxList.Добавить(СтруктураКоробки); 
			КонецЦикла;		 
		КонецЦикла;
		
		ВыборкаЗПСПоКоробкам.Сбросить();
		
		Пока ВыборкаЗПСПоЭмиссиям.НайтиСледующий(ОтборПоЗПС) Цикл
			
			СтруктураЭлМассиваКМ 		= Новый Структура("id,value,type"); 	
			СтруктураЭлМассиваКМ.id 	= XMLСтрока(ВыборкаЗПСПоЭмиссиям.КМ.УникальныйИдентификатор());
			СтруктураЭлМассиваКМ.value 	= ВыборкаЗПСПоЭмиссиям.Наименование; 
			СтруктураЭлМассиваКМ.type	= XMLСтрока(ВыборкаЗПСПоЭмиссиям.ТипКода);
			
			СтруктураЗПС.Markes.Добавить(СтруктураЭлМассиваКМ);
			
		КонецЦикла; 
		ВыборкаЗПСПоЭмиссиям.Сбросить();
		
		ДанныеОтвета.data.Добавить(СтруктураЗПС); 
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДанныеОтвета; 
	
 КонецФункции 

Функция ПолучитьСписокТоваровПоЗПС(Знач Идентификатор, МассивЗПС) Экспорт
	
	УстановитьПривилегированныйРежим(истина);
	
	ДанныеОтвета 	= СтруктураДанныеСписокТоваровЗПС(Идентификатор); 
	ДанныеОтвета.id = Идентификатор; 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование КАК ЗПС,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваров.Ссылка) КАК КМВсего
	|ПОМЕСТИТЬ ВТМаркиВсего
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ШтрихкодыУпаковокТоваров.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование В (&МассивЗПС))
	|			И (НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЗПС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки) КАК ВсегоКоробок,
	|	МаркировкаТоваровИСМП.ДокументОснование КАК ЗПС
	|ПОМЕСТИТЬ ВТВсегоКоробок
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
	|			И (МаркировкаТоваровИСМП.ДокументОснование В (&МассивЗПС))
	|			И (МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(перечисление.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов))
	|			И (МаркировкаТоваровИСМП.Проведен)
	|			И (МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
	|			И (МаркировкаТоваровИСМП.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(МаркировкаТоваровИСМП.ДокументОснование) = ТИП(Документ.ЗаказПоставщику)
	|
	|СГРУППИРОВАТЬ ПО
	|	МаркировкаТоваровИСМП.ДокументОснование
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки),
	|	МаркировкаТоваровИСМП.ДокументОснование
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
	|			И (МаркировкаТоваровИСМП.ДокументОснование В (&МассивЗПС))
	|			И (МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(перечисление.ВидыОперацийМаркировки.Агрегация))
	|			И (МаркировкаТоваровИСМП.Проведен)
	|			И (МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
	//|			И (МаркировкаТоваровИСМП.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(МаркировкаТоваровИСМП.ДокументОснование) = ТИП(Документ.КонтрактСПроизводителем)
	|
	|СГРУППИРОВАТЬ ПО
	|	МаркировкаТоваровИСМП.ДокументОснование
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЗПС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПоставщику.Ссылка КАК ЗПС,
	|	ЗаказПоставщику.Номер КАК Номер,
	|	ЗаказПоставщику.Контрагент КАК Контрагент,
	|	ЗаказПоставщику.Контрагент.Наименование КАК КонтрагентНаименование,
	|	ЗаказПоставщику.Дата КАК Дата,
	|	ЗаказПоставщику.СостояниеЗаказа КАК СтатусЗПС,
	|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	|	ЗаказПоставщикуТовары.Номенклатура.Наименование КАК НоменклатураНаименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер.Наименование КАК НоменклатураРазмер,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет.Наименование КАК НоменклатураЦвет,
	|	"""" КАК Картинка,
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Количество, 0) КАК Количество,
	|	ЕСТЬNULL(ВТМаркиВсего.КМВсего, 0) КАК КМВсего,
	|	ЕСТЬNULL(ВТВсегоКоробок.ВсегоКоробок, 0) КАК КоробокВсего
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|		ПО (ЗаказПоставщикуТовары.Ссылка = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМаркиВсего КАК ВТМаркиВсего
	|		ПО (ВТМаркиВсего.ЗПС = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВсегоКоробок КАК ВТВсегоКоробок
	|		ПО (ВТВсегоКоробок.ЗПС = ЗаказПоставщику.Ссылка)
	|ГДЕ
	|	ЗаказПоставщику.Ссылка В(&МассивЗПС)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПоставщику.Ссылка,
	|	ЗаказПоставщику.Номер,
	|	ЗаказПоставщику.Контрагент,
	|	ЗаказПоставщику.Контрагент.Наименование,
	|	ЗаказПоставщику.Дата,
	|	ЗаказПоставщику.СостояниеЗаказа,
	|	ЗаказПоставщикуТовары.Номенклатура,
	|	ЗаказПоставщикуТовары.Номенклатура.Наименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер.Наименование,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет.Наименование,
	|	"""",
	|	ЕСТЬNULL(ЗаказПоставщикуТовары.Количество, 0),
	|	ЕСТЬNULL(ВТМаркиВсего.КМВсего, 0),
	|	ЕСТЬNULL(ВТВсегоКоробок.ВсегоКоробок, 0)
	|ИЗ
	|	Документ.КонтрактСПроизводителем КАК ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КонтрактСПроизводителем.Товары КАК ЗаказПоставщикуТовары
	|		ПО (ЗаказПоставщикуТовары.Ссылка = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМаркиВсего КАК ВТМаркиВсего
	|		ПО (ВТМаркиВсего.ЗПС = ЗаказПоставщику.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВсегоКоробок КАК ВТВсегоКоробок
	|		ПО (ВТВсегоКоробок.ЗПС = ЗаказПоставщику.Ссылка)
	|ГДЕ
	|	ЗаказПоставщику.Ссылка В(&МассивЗПС)
	|ИТОГИ
	|	СУММА(Количество),
	|	МАКСИМУМ(КМВсего),
	|	МАКСИМУМ(КоробокВсего)
	|ПО
	|	ЗПС";
	
	Запрос.УстановитьПараметр("МассивЗПС", МассивЗПС);
	
	ВыборкаИтогиТовары = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 	
	
	СоответствиеКодСтатус = СоответствиеСтатусКодСтатусаЗПС();
	Пока ВыборкаИтогиТовары.Следующий() Цикл
		
		ЗПС = ВыборкаИтогиТовары.ЗПС; 
		
		СтруктураЗПС = ДанныеМассиваЗПССТоварами(); 
		СтруктураЗПС.id   			= XMLСтрока(ЗПС.ссылка.УникальныйИдентификатор());
		СтруктураЗПС.code  		= ЗПС.Номер; 
		СтруктураЗПС.factory       = XMLСтрока(ЗПС.Контрагент.Наименование); 
		СтруктураЗПС.dateCreate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		//++Данилова Е.В. 16.03.2026  MARK-3512 
		//СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		Если ЗначениеЗаполнено(ЗПС.ДатаИзменения) Тогда		
			СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.ДатаИзменения);	
		Иначе 
			СтруктураЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ЗПС.Дата);
		КонецЕсли;
		//--Данилова Е.В. 16.03.2026 
		СтруктураЗПС.statusName    = XMLСтрока(ЗПС.СостояниеЗаказа); 
		СтруктураЗПС.factoryId     = XMLСтрока(ЗПС.Контрагент.УникальныйИдентификатор()); 
		СтруктураЗПС.statusCode    = XMLСтрока(СоответствиеКодСтатус.Получить(ЗПС.СостояниеЗаказа));
		//++Данилова Е.В. 26.05.2026 без задачи		
		Если ТипЗнч(ЗПС) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			
			ОтложенноеЗаполнениеТСД = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ЗПС,"ОтложенноеЗаполнениеТСД");
			СтруктураЗПС.type_doc = "order";
			СтруктураЗПС.Invoice = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ЗПС,"НомерПоставщика");
			СтруктураЗПС.type_order = ?(ОтложенноеЗаполнениеТСД,"null","full");
			
		ИначеЕсли ТипЗнч(ЗПС) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
			
			СтруктураЗПС.type_doc = "contract";
			
			СтруктураЗПС.number_order = ОбщегоНазначенияС.ПолучитьРеквизитШапкиСервер(ЗПС,"НомерЗаказа");
			СтруктураЗПС.type_order = "full"; 
		КонецЕсли; 
		 
		//--Данилова Е.В. 26.05.2026  

		СтруктураЗПС.boxTotal      = ВыборкаИтогиТовары.КоробокВсего;
		СтруктураЗПС.markesTotal   = ВыборкаИтогиТовары.КМВсего;
		СтруктураЗПС.productTotal  = ВыборкаИтогиТовары.Количество;
		
		
		ВыборкаТовары = ВыборкаИтогиТовары.Выбрать(); 
		//++Данилова Е.В. 16.03.2026 MARK-3512 
		Если ВыборкаИтогиТовары.Количество = 0 Тогда
			
			ДанныеОтвета.data.Добавить(СтруктураЗПС);
			
			Продолжить; 	
		
		КонецЕсли;
		//--Данилова Е.В. 16.03.2026 
		Пока ВыборкаТовары.Следующий() Цикл
			
			СтруктураТовара =  ДанныеМассиваТоварыЗПС(); 
			СтруктураТовара.id 			= XMLСтрока(ВыборкаТовары.Номенклатура.УникальныйИдентификатор());
			СтруктураТовара.name 		= ВыборкаТовары.Номенклатура.Родитель.Наименование; 
			СтруктураТовара.size 		= XMLСтрока(ВыборкаТовары.НоменклатураРазмер); 
			СтруктураТовара.color 		= XMLСтрока(ВыборкаТовары.НоменклатураЦвет);
			СтруктураТовара.multibox	= ВыборкаТовары.Номенклатура.Родитель.ШтукВКоробке; 
			СтруктураТовара.GTIN 		= ВыборкаТовары.Номенклатура.ГТИН;
			СтруктураТовара.count 		= ВыборкаТовары.Количество;
			//++Данилова Е.В. 09.03.2026 MARK-3512
			СтруктураТовара.id_parent 	= XMLСтрока(ВыборкаТовары.Номенклатура.родитель.УникальныйИдентификатор());
			//--Данилова Е.В. 09.03.2026 
			//++Данилова Е.В. 26.05.2026 без задачи
			СтруктураТовара.code 		= ВыборкаТовары.Номенклатура.Код;
			СтруктураТовара.code_parent = ВыборкаТовары.Номенклатура.Родитель.Код;
			СтруктураТовара.code_maker 	= ВыборкаТовары.Номенклатура.Родитель.КодПроизводителя;			
			//--Данилова Е.В. 26.05.2026 
			СтруктураЗПС.productList.Добавить(СтруктураТовара); 
		КонецЦикла;
		
		ДанныеОтвета.data.Добавить(СтруктураЗПС); 
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДанныеОтвета; 
	
 КонецФункции 
 
 Функция ПолучитьСписокМарокПоЗПС(Знач Идентификатор, ПараметрыОтбора) Экспорт
	
	УстановитьПривилегированныйРежим(истина);
	
	МассивЗПС 		= ПараметрыОтбора.МассивЗПС; 
	Лимит 			= ПараметрыОтбора.Лимит;
	НомерСтраницы 	= ПараметрыОтбора.НомерСтраницы; 
	
	ДанныеОтвета 	= СтруктураДанныеСписокТоваровЗПС(Идентификатор); 
	ДанныеОтвета.id = Идентификатор; 
	
	Запрос = Новый Запрос;
	
	ТекстЗапросаСписокМарокБезПагинации(Запрос); 
	
	Если ЗначениеЗаполнено(Лимит) И 
		НЕ ЗначениеЗаполнено(НомерСтраницы) Тогда
	
		ТекстЗапросаСписокМарокСпагинациейПоЛимиту(Запрос,Лимит); 	
	ИначеЕсли ЗначениеЗаполнено(Лимит) И 
		 ЗначениеЗаполнено(НомерСтраницы) Тогда
		 
		ТекстЗапросаСписокМарокСпагинацией(Запрос,Лимит,НомерСтраницы);
		
	КонецЕсли;

	
	Запрос.УстановитьПараметр("МассивЗПС", МассивЗПС); 
	ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	Пока ВыборкаИтоги.Следующий() Цикл
		
		ЗПС = ВыборкаИтоги.ЗПС; 
		
		СтруктураЗПС = ДанныеМассиваЗПССМарками(); 
		СтруктураЗПС.id   			= XMLСтрока(ЗПС.ссылка.УникальныйИдентификатор());
		СтруктураЗПС.code  			= ЗПС.Номер; 
		СтруктураЗПС.MarkesCount  = ВыборкаИтоги.КМ;
		СтруктураЗПС.MarkesTotal  = ВыборкаИтоги.КМВсего;
		
		ВыборкаМарки = ВыборкаИтоги.Выбрать(); 
		
		Пока ВыборкаМарки.Следующий() Цикл
			
			СтруктураЭлМассиваКМ 		= Новый Структура("id,value,type"); 	
			СтруктураЭлМассиваКМ.id 	= XMLСтрока(ВыборкаМарки.КМ.УникальныйИдентификатор());
			СтруктураЭлМассиваКМ.value 	= ВыборкаМарки.Наименование; 
			СтруктураЭлМассиваКМ.type	= XMLСтрока(ВыборкаМарки.ТипКода);
			
			СтруктураЗПС.Markes.Добавить(СтруктураЭлМассиваКМ); 			
			 
		КонецЦикла;	
				
		ДанныеОтвета.data.Добавить(СтруктураЗПС); 
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДанныеОтвета; 
	
КонецФункции

Процедура ТекстЗапросаСписокМарокБезПагинации(Запрос)
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование КАК ЗПС,
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК КМ,
	|	ШтрихкодыУпаковокТоваров.Наименование КАК Наименование,
	|	ШтрихкодыУпаковокТоваров.ТипКода КАК ТипКода,
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК КМВсего
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ШтрихкодыУпаковокТоваров.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование В (&МассивЗПС))
	|			И (НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления)
	|
	|УПОРЯДОЧИТЬ ПО
	|	КМ
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КМ),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КМВсего)
	|ПО
	|	ЗПС";

КонецПроцедуры

Процедура ТекстЗапросаСписокМарокСпагинациейПоЛимиту(Запрос,Лимит)
	            
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование КАК ЗПС,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваров.Ссылка) КАК КМВсего
	|ПОМЕСТИТЬ ВТМаркиВсего
	|ИЗ
