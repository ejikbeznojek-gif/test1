Процедура ЗаписатьВходящиеДанныеЗапросаИсторияЗапросовФабрики(Знач ИдентификаторЗапроса, ПараметрыЗапроса, СтруктураЗапроса) Экспорт
	
	УстановитьПривилегированныйРежим(истина);
	
	МенеджерЗаписи = Регистрысведений.ИсторияЗапросовПриложенияФабрик.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИД = ИдентификаторЗапроса; 
	МенеджерЗаписи.Запрос = Новый ХранилищеЗначения(СтруктураЗапроса,Новый СжатиеДанных(9));
	МенеджерЗаписи.ПараметрыЗапроса = ЗначениеВСтрокуВнутр(ПараметрыЗапроса); 
	МенеджерЗаписи.ДатаЗапроса = ТекущаяДатаСеанса(); 
	Если СтруктураЗапроса.Свойство("requestId") Тогда
		
		МенеджерЗаписи.ИДКлиента = СтруктураЗапроса.requestId; 	
		
	КонецЕсли;
	Попытка
		
		МенеджерЗаписи.Записать(); 
		
	Исключение 
		
		ЗаписьЖурналаРегистрации("ИсторияЗапросовПриложенияФабрик",УровеньЖурналаРегистрации.Ошибка,Метаданные.РегистрыСведений.ИсторияЗапросовПриложенияФабрик,,"Ошибка записи",); 
		
	КонецПопытки; 
	
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

Процедура ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(Знач ИдентификаторЗапроса,СтруктураОтвета, КодОтвета) Экспорт
	
	УстановитьПривилегированныйРежим(истина);
	
	Наборзаписей = РегистрыСведений.ИсторияЗапросовПриложенияФабрик.СоздатьНаборЗаписей(); 
	Наборзаписей.Отбор.ИД.Установить(ИдентификаторЗапроса);
	Наборзаписей.Прочитать();
	
	Если Наборзаписей.Количество() > 0  Тогда
		
		Для каждого ЗаписьНабора  Из Наборзаписей Цикл
			
			ЗаписьНабора.Ответ = Новый ХранилищеЗначения(СтруктураОтвета,Новый СжатиеДанных(9)); 
			ЗаписьНабора.КодОтвета = КодОтвета;
			
		КонецЦикла;	
		
	КонецЕсли;
	Попытка
	
		Наборзаписей.Записать(); 
	
	Исключение
		
		ЗаписьЖурналаРегистрации("ИсторияЗапросовПриложенияФабрик",УровеньЖурналаРегистрации.Ошибка,Метаданные.РегистрыСведений.ИсторияЗапросовПриложенияФабрик,,"Ошибка записи",);

	КонецПопытки;
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

