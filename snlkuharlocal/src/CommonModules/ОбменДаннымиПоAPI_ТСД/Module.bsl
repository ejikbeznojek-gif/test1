Функция ОбработатьСтруктуруЗапросаПоIDЗПС(СтруктураJSONЗапроса,ИдентификаторЗапроса)

	МассивЗПС = Новый Массив;
	МассивОшибок = Новый Массив; 
	
	Если ТипЗнч(СтруктураJSONЗапроса) = Тип("Структура") 
		И СтруктураJSONЗапроса.Свойство("orderId") Тогда
		
		Если ТипЗнч(СтруктураJSONЗапроса.orderId) = Тип("Строка") Тогда
			
			ГУИД = Новый УникальныйИдентификатор(СтруктураJSONЗапроса.orderId);
			УстановитьПривилегированныйРежим(Истина); 	
			ЗаказПоставщику = Документы.ЗаказПоставщику.ПолучитьСсылку(ГУИД);		
			Если  ЗаказПоставщику.ПолучитьОбъект() = неопределено Тогда
				ЗаказПоставщику = Документы.КонтрактСПроизводителем.ПолучитьСсылку(ГУИД); 
				Если  ЗаказПоставщику.ПолучитьОбъект() = неопределено Тогда
					УстановитьПривилегированныйРежим(Ложь);
					ОтветОшибка = Новый Структура; 
					ОтветОшибка.Вставить("error","Не найден ЗПС по orderId (ID ЗПС)" + СтруктураJSONЗапроса.orderId);
					
					СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(ОтветОшибка);
					
					Ответ400 =  СформироватьОтветApplicationFactory(400,СтрокаJSON,"No order found for orderId (ID order)" + СтруктураJSONЗапроса.orderId);					 
					
					ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,ОтветОшибка,400);
					
					Возврат Ответ400;
				Иначе 
					МассивЗПС.Добавить(ЗаказПоставщику); 
					
					УстановитьПривилегированныйРежим(Ложь);
				КонецЕсли; 
			Иначе 
				
				МассивЗПС.Добавить(ЗаказПоставщику); 
				
				УстановитьПривилегированныйРежим(Ложь);

			КонецЕсли;
		ИначеЕсли ТипЗнч(СтруктураJSONЗапроса.orderId) = Тип("Массив") Тогда
			
			Для каждого ЭлементМассиваorderId Из СтруктураJSONЗапроса.orderId Цикл
				
				ГУИД = Новый УникальныйИдентификатор(ЭлементМассиваorderId);
				УстановитьПривилегированныйРежим(Истина);
				ЗаказПоставщику = Документы.ЗаказПоставщику.ПолучитьСсылку(ГУИД);	
				Если   ЗаказПоставщику.ПолучитьОбъект() = неопределено Тогда
					ЗаказПоставщику = Документы.КонтрактСПроизводителем.ПолучитьСсылку(ГУИД); 
					Если ЗаказПоставщику.ПолучитьОбъект() = неопределено Тогда
						МассивОшибок.Добавить("No order found for orderId orderId (ID order)" + СтруктураJSONЗапроса.orderId);
					Иначе 
						МассивЗПС.Добавить(ЗаказПоставщику);
					КонецЕсли;
				Иначе 
					МассивЗПС.Добавить(ЗаказПоставщику);
				КонецЕсли; 
				
				УстановитьПривилегированныйРежим(Ложь);
				
			КонецЦикла;
			
		Иначе
			
			ОтветОшибка = Новый Структура; 
			ОтветОшибка.Вставить("error","Неверные параметры запроса, неизвестного типа orderId (ID ЗПС)");
			
			СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(ОтветОшибка);
			
			Ответ400 =  СформироватьОтветApplicationFactory(400,СтрокаJSON,"Invalid request parameter orderId (ID order)");			 
			
			ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,ОтветОшибка,400);
			
			Возврат Ответ400;
		КонецЕсли;
		
	Иначе 
		
		ОтветОшибка = Новый Структура; 
		ОтветОшибка.Вставить("error","Неверные параметры запроса, не найден orderId (ID ЗПС)");
		
		СтрокаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(ОтветОшибка);
		
		Ответ400 =  СформироватьОтветApplicationFactory(400,СтрокаJSON,"Invalid request parameters, not found orderId (ID order)");		 
		
		ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,ОтветОшибка,400);
		
		Возврат Ответ400; 
	КонецЕсли;
	
	Если МассивЗПС.Количество() = 0  Тогда
		
		ОтветОшибка = Новый Структура; 
		ОтветОшибка.Вставить("error",СтрСоединить(МассивОшибок,",")); 	
		
		ОтветОшибкаJSON = b2b_ОбменЗаявками.ОтработатьЗаполненнуюСтруктуруОтвета(ОтветОшибка);
		
		Ответ400 =  СформироватьОтветApplicationFactory(400,ОтветОшибкаJSON,"Not found orders");
		
		ЗаписатьИсходящиеДанныеИсторияЗапросаФабрики(ИдентификаторЗапроса,ОтветОшибка,400);
		
		Возврат Ответ400; 
		
	КонецЕсли;
	
   Возврат МассивЗПС; 

КонецФункции // ОбработатьСтруктуруЗапросаПоIDЗПС()


#КонецОбласти

 #Область ОбменСПриложениемФабрики
 
Функция ПолучитьДанныеПоФабрикам(Знач Идентификатор,ПараметрыОтбора)  Экспорт
    УстановитьПривилегированныйРежим(Истина); 
	
	ДанныеОтвета =  СтруктураДанныеФабрик(Идентификатор); 
	ДанныеОтвета.id = Идентификатор; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК ссылка,
		|	Контрагенты.Код КАК Код,
		|	Контрагенты.Наименование КАК Наименование,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) КАК КоличествоЗПС, 
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрактСПроизводителем.Ссылка) КАК КоличествоКП
		//--Данилова Е.В. 13.03.2026 
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ПО (ЗаказПоставщику.Контрагент = Контрагенты.Ссылка)
		|			И (ЗаказПоставщику.Проведен)
		|			И (ЗаказПоставщику.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки)
		//++Данилова Е.В. 21.04.2026 правка по письму 
		|				ИЛИ ЗаказПоставщику.ОтложенноеЗаполнениеТСД)
		//--Данилова Е.В. 21.04.2026 
		//++Данилова Е.В. 13.03.2026 MARK-3512
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КонтрактСПроизводителем КАК КонтрактСПроизводителем
		|		ПО (КонтрактСПроизводителем.Контрагент = Контрагенты.Ссылка)
		|			И (КонтрактСПроизводителем.Проведен)
		|			И (КонтрактСПроизводителем.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки)) 
	    //--Данилова Е.В. 13.03.2026 
		|ГДЕ
		|	Контрагенты.ВыгружатьМаркиЗПСДляТСД
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Ссылка,
		|	Контрагенты.Код,
		|	Контрагенты.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
	
	Если ЗначениеЗаполнено(ПараметрыОтбора.Лимит)
		И НЕ ЗначениеЗаполнено(ПараметрыОтбора.номерСтраницы) Тогда
		              
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ %Лимит%
		|	Контрагенты.Ссылка КАК ссылка,
		|	Контрагенты.Код КАК Код,
		|	Контрагенты.Наименование КАК Наименование,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) КАК КоличествоЗПС,
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрактСПроизводителем.Ссылка) КАК КоличествоКП
		//--Данилова Е.В. 13.03.2026
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ПО (ЗаказПоставщику.Контрагент = Контрагенты.Ссылка)
		|			И (ЗаказПоставщику.Проведен)
		|			И (ЗаказПоставщику.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки))
		//++Данилова Е.В. 13.03.2026 MARK-3512
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КонтрактСПроизводителем КАК КонтрактСПроизводителем
		|		ПО (КонтрактСПроизводителем.Контрагент = Контрагенты.Ссылка)
		|			И (КонтрактСПроизводителем.Проведен)
		|			И (КонтрактСПроизводителем.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки)) 
	    //--Данилова Е.В. 13.03.2026 

		|ГДЕ
		|	Контрагенты.ВыгружатьМаркиЗПСДляТСД
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Ссылка,
		|	Контрагенты.Код,
		|	Контрагенты.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование"; 		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Лимит%",ПараметрыОтбора.Лимит);	
		
	ИначеЕсли ЗначениеЗаполнено(ПараметрыОтбора.Лимит)
		И  ЗначениеЗаполнено(ПараметрыОтбора.номерСтраницы) Тогда         
		                    
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ %НеВключать%
		|	Контрагенты.Ссылка КАК ссылка,
		|	Контрагенты.Наименование КАК Наименование
		|ПОМЕСТИТЬ ВТИсключения
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ВыгружатьМаркиЗПСДляТСД
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Ссылка,
		|	Контрагенты.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ %Лимит%
		|	Контрагенты.Ссылка КАК ссылка,
		|	Контрагенты.Код КАК Код,
		|	Контрагенты.Наименование КАК Наименование,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) КАК КоличествоЗПС,
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрактСПроизводителем.Ссылка) КАК КоличествоКП
		//--Данилова Е.В. 13.03.2026
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ПО (ЗаказПоставщику.Контрагент = Контрагенты.Ссылка)
		|			И (ЗаказПоставщику.Проведен)
		|			И (ЗаказПоставщику.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки)) 
		//++Данилова Е.В. 13.03.2026 MARK-3512
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КонтрактСПроизводителем КАК КонтрактСПроизводителем
		|		ПО (КонтрактСПроизводителем.Контрагент = Контрагенты.Ссылка)
		|			И (КонтрактСПроизводителем.Проведен)
		|			И (КонтрактСПроизводителем.СостояниеПроверкиМарокНаТСД = ЗНАЧЕНИЕ(Перечисление.СостоянияПроверкиМарокНаТСД.ТребуетсяОтправитьМарки)) 
	    //--Данилова Е.В. 13.03.2026 

		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсключения КАК ВТИсключения
		|		ПО (ВТИсключения.ссылка = Контрагенты.Ссылка)
		|ГДЕ
		|	Контрагенты.ВыгружатьМаркиЗПСДляТСД
		|	И ВТИсключения.ссылка ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Ссылка,
		|	Контрагенты.Код,
		|	Контрагенты.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Лимит%",ПараметрыОтбора.Лимит);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%НеВключать%",ПараметрыОтбора.Лимит * (ПараметрыОтбора.НомерСтраницы - 1));

	КонецЕсли; 
	
	
	МассивСостояний = Новый Массив; 
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Закрыт); 
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Ликвидирован);
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Получен);
	
	Запрос.УстановитьПараметр("МассивСостояний", МассивСостояний);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтруктураЭлементаМассива = ДанныеМассиваФабрик();
		
		СтруктураЭлементаМассива.factoryId 		= XMLСтрока(ВыборкаДетальныеЗаписи.ссылка.УникальныйИдентификатор()); 
		СтруктураЭлементаМассива.factorycode	= ВыборкаДетальныеЗаписи.Код; 
		СтруктураЭлементаМассива.factoryName    = ВыборкаДетальныеЗаписи.Наименование; 
		СтруктураЭлементаМассива.ordersTotal    = ВыборкаДетальныеЗаписи.КоличествоЗПС;
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		СтруктураЭлементаМассива.contractTotal	= ВыборкаДетальныеЗаписи.КоличествоКП;
		//--Данилова Е.В. 13.03.2026 
		
		ДанныеОтвета.data.Добавить(СтруктураЭлементаМассива); 
	КонецЦикла; 
	
	 УстановитьПривилегированныйРежим(Ложь);
	 
	Возврат ДанныеОтвета; 

КонецФункции // ПолучитьДанныеПоФабрикам()

Функция СтруктураДанныеФабрик(Знач Идентификатор)
	
	Основная = Новый Структура; 
	Основная.Вставить("data", Новый Массив);
	Основная.Вставить("id",Идентификатор); 
	
	Возврат Основная; 
	
КонецФункции // СтруктураДанныеФабрик()

Функция ДанныеМассиваФабрик()
	
	ДанныеМас = Новый Структура(); 
	ДанныеМас.Вставить("factoryId","");
	ДанныеМас.Вставить("factorycode","");
	ДанныеМас.Вставить("factoryName","");  
	ДанныеМас.Вставить("ordersTotal",0);
	//++Данилова Е.В. 13.03.2026 MARK-3512 
	ДанныеМас.Вставить("contractTotal",0);
	//--Данилова Е.В. 13.03.2026 
	Возврат ДанныеМас; 
	
КонецФункции // ДанныеМассиваФабрик()

Функция СформироватьОтветApplicationFactory(КодВозврата,ТелоОтвета,Причина) Экспорт 

	Ответ = Новый HTTPСервисОтвет(КодВозврата);
	Ответ.Причина = Причина;
	Ответ.Заголовки.Вставить("Content-type", "application/json");
	Ответ.Заголовки.Вставить("Charset", "utf-8"); 
	Если ЗначениеЗаполнено(ТелоОтвета) Тогда   
		
		Ответ.УстановитьТелоИзСтроки(ТелоОтвета); 
		
	КонецЕсли;
	
	
	Возврат Ответ; 
	
КонецФункции // СформироватьОтвет() 

Функция ПолучитьСписокЗПС(Знач Идентификатор,ПараметрыОтбора) Экспорт
	
	УстановитьПривилегированныйРежим(истина); 
	
	ДанныеОтвета = СтруктураДанныеСписокЗПС(Идентификатор); 
	ДанныеОтвета.id = Идентификатор;
	
	Запрос = Новый Запрос;
	
	ТекстЗапросаПоЗПСБезПагинации(Запрос); 	
	
	МассивСостояний = Новый Массив; 
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Закрыт); 
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Ликвидирован);
	МассивСостояний.Добавить(Перечисления.СостояниеЗаказаПоставщику.Получен);
	
	Запрос.УстановитьПараметр("МассивСостояний", МассивСостояний); 
	
	Запрос.УстановитьПараметр("ОтборПоКонтрагенту", ЛОЖЬ);   
	Запрос.УстановитьПараметр("Контрагент", неопределено);	
	
	Если ЗначениеЗаполнено(ПараметрыОтбора.ОтборПоКонтрагенту) Тогда
		
		Запрос.УстановитьПараметр("ОтборПоКонтрагенту", Истина);
		Запрос.УстановитьПараметр("Контрагент", ПараметрыОтбора.ОтборПоКонтрагенту);
		
	КонецЕсли; 
	//++Данилова Е.В. 09.03.2026 MARK-3512 
	//убираем это условие, будут передаваться и КП и ЗПС
	//Запрос.УстановитьПараметр("ОтборПоТипуДокумента", Истина);
	//Запрос.УстановитьПараметр("ТипДокумента", "order"); 
	Запрос.УстановитьПараметр("ОтборПоТипуДокумента", Ложь);
	Запрос.УстановитьПараметр("ОтборПоТипуЗаказа", Ложь);
	Запрос.УстановитьПараметр("ТипДокумента", "");
	Запрос.УстановитьПараметр("ТипЗаказа", "");
	//--Данилова Е.В. 09.03.2026 
	Если ЗначениеЗаполнено(ПараметрыОтбора.ТипДокумента)  Тогда 
		
	    Запрос.УстановитьПараметр("ОтборПоТипуДокумента", Истина);
		Запрос.УстановитьПараметр("ТипДокумента", ПараметрыОтбора.ТипДокумента);	
	
	КонецЕсли; 
	//++Данилова Е.В. 13.03.2026 MARK-3512
	Если ЗначениеЗаполнено(ПараметрыОтбора.ТипЗаказа)  Тогда 
		
	    Запрос.УстановитьПараметр("ОтборПоТипуЗаказа", Истина);
		Запрос.УстановитьПараметр("ТипЗаказа", ПараметрыОтбора.ТипЗаказа);	
	
	КонецЕсли;
	//--Данилова Е.В. 13.03.2026 
	
	Если ЗначениеЗаполнено(ПараметрыОтбора.Лимит)
		И НЕ ЗначениеЗаполнено(ПараметрыОтбора.номерСтраницы) Тогда
		          
		ТекстЗапросаПоЗПССПагинациейПоЛимиту(Запрос,ПараметрыОтбора.Лимит);
		
		
	ИначеЕсли ЗначениеЗаполнено(ПараметрыОтбора.Лимит)
		И  ЗначениеЗаполнено(ПараметрыОтбора.номерСтраницы) Тогда 
		                 
		ТекстЗапросаПоЗПССПагинацией(Запрос,ПараметрыОтбора.Лимит,ПараметрыОтбора.НомерСтраницы); 
		
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СоответствиеКодСтатус = СоответствиеСтатусКодСтатусаЗПС(); 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		
		ЭлементМассиваЗПС = ДанныеМассиваЗПС(); 
		
		ЭлементМассиваЗПС.id 			= XMLСтрока(ВыборкаДетальныеЗаписи.СсылкаЗПС.УникальныйИдентификатор());  
		ЭлементМассиваЗПС.code      	= ВыборкаДетальныеЗаписи.НомерЗПС; 
		ЭлементМассиваЗПС.factory   	= ВыборкаДетальныеЗаписи.Контрагент.Наименование;
		ЭлементМассиваЗПС.factoryId  	= XMLСтрока(ВыборкаДетальныеЗаписи.Контрагент.УникальныйИдентификатор());
		ЭлементМассиваЗПС.dateCreate    = ПреобразоватьДатуДляПередачиНаПортал(ВыборкаДетальныеЗаписи.ДатаЗПС); 
		//++Данилова Е.В. 16.03.2026 MARK-3512 
		//ЭлементМассиваЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ВыборкаДетальныеЗаписи.ДатаЗПС);
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.СсылкаЗПС.ДатаИзменения) Тогда		
			ЭлементМассиваЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ВыборкаДетальныеЗаписи.СсылкаЗПС.ДатаИзменения);	
		Иначе 
			ЭлементМассиваЗПС.dateUpdate    = ПреобразоватьДатуДляПередачиНаПортал(ВыборкаДетальныеЗаписи.ДатаЗПС);
		КонецЕсли;
		//--Данилова Е.В. 16.03.2026 
		ЭлементМассиваЗПС.statusName    = XMLСтрока(ВыборкаДетальныеЗаписи.СтатусЗПС); 
		ЭлементМассиваЗПС.statusCode    = XMLСтрока(СоответствиеКодСтатус.Получить(ВыборкаДетальныеЗаписи.СтатусЗПС));
				
		Если ТипЗнч(ВыборкаДетальныеЗаписи.СсылкаЗПС) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			
			ЭлементМассиваЗПС.type_doc = "order";
			ЭлементМассиваЗПС.Invoice = ВыборкаДетальныеЗаписи.СсылкаЗПС.НомерПоставщика;
			
		ИначеЕсли ТипЗнч(ВыборкаДетальныеЗаписи.СсылкаЗПС) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
			
			ЭлементМассиваЗПС.type_doc = "contract";
			//++Данилова Е.В. 16.03.2026 MARK-3512
			ЭлементМассиваЗПС.number_order = ВыборкаДетальныеЗаписи.СсылкаЗПС.НомерЗаказа;
			//--Данилова Е.В. 16.03.2026 
		КонецЕсли;
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		ЭлементМассиваЗПС.type_order = ?(ВыборкаДетальныеЗаписи.ОтложенноеЗаполнениеТСД,"null","full"); 
		//--Данилова Е.В. 13.03.2026 
		
		ДанныеОтвета.data.Добавить(ЭлементМассиваЗПС);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДанныеОтвета; 
	
КонецФункции

Процедура ТекстЗапросаПоЗПСБезПагинации(Запрос)
			
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.Код КАК КодКонтрагента,
