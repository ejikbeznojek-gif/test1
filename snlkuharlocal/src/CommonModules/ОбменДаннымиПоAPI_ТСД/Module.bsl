Функция ПолучитьСписокКоробокПоЗПС(Знач Идентификатор, ПараметрыОтбора) Экспорт
	
	УстановитьПривилегированныйРежим(истина); 
	
	МассивЗПС 		= ПараметрыОтбора.МассивЗПС; 
	Лимит 			= ПараметрыОтбора.Лимит;
	НомерСтраницы 	= ПараметрыОтбора.НомерСтраницы;
	
	ДанныеОтвета 	= СтруктураДанныеСписокТоваровЗПС(Идентификатор); 
	ДанныеОтвета.id = Идентификатор; 
	
	Запрос = Новый Запрос;
	
	ТекстЗапросаСписокКоробокБезПагинации(Запрос);
	
	Если ЗначениеЗаполнено(Лимит) И 
		НЕ ЗначениеЗаполнено(НомерСтраницы) Тогда
		
		ТекстЗапросаСписокКоробокСПагинациейПоЛимиту(Запрос,Лимит); 
		
	ИначеЕсли ЗначениеЗаполнено(Лимит) И 
		ЗначениеЗаполнено(НомерСтраницы) Тогда
		
		ТекстЗапросаСписокКоробокСПагинацией(Запрос,Лимит,НомерСтраницы);
		
	КонецЕсли;

	
	Запрос.УстановитьПараметр("МассивЗПС", МассивЗПС);
		
	ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаИтоги.Следующий() Цикл
		
		ЗПС = ВыборкаИтоги.ЗПС; 
		
		СтруктураЗПС = ДанныеМассиваЗПССКоробками(); 
		СтруктураЗПС.id   		= XMLСтрока(ЗПС.ссылка.УникальныйИдентификатор());
		СтруктураЗПС.code  		= ЗПС.Номер;
		//++Данилова Е.В. 13.03.2026 MARK-3512 
		//СтруктураЗПС.boxTotal   = ВыборкаИтоги.ШтрихкодУпаковкиВсего;
		//СтруктураЗПС.boxcount   = ВыборкаИтоги.ШтрихкодУпаковки; 
		СтруктураЗПС.boxTotal   = ВыборкаИтоги.ШтрихкодКоробкиВсего;
		СтруктураЗПС.boxcount   = ВыборкаИтоги.ШтрихкодКоробкиКоличество;
		//--Данилова Е.В. 13.03.2026 
		
		ВыборкаКоробки = ВыборкаИтоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		
		Пока ВыборкаКоробки.Следующий() Цикл
			
			//++Данилова Е.В. 13.03.2026 MARK-3512
			//СтруктураКоробки.code = XMLСтрока(ВыборкаКоробки.ШтрихкодУпаковки.Наименование);
			Если ТипЗнч(ЗПС) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда 			
				СтруктураКоробки = ДанныеМассиваКоробкиЗПС(истина);
				
				ВыборкаКоды = ВыборкаКоробки.Выбрать();
				МассивКодов = Новый Массив; 
				Пока ВыборкаКоды.Следующий() Цикл
					
					МассивКодов.Добавить(ВыборкаКоды.ШтрихкодУпаковки.Наименование);  				
					
				КонецЦикла;
				СтруктураКоробки.Markes = МассивКодов;
				СтруктураКоробки.MarkesTotal 	= ВыборкаКоробки.ШтрихкодУпаковки;
			Иначе 
				СтруктураКоробки = ДанныеМассиваКоробкиЗПС();
			КонецЕсли;
			СтруктураКоробки.code 			= XMLСтрока(ВыборкаКоробки.ШтрихкодКоробки.Наименование); 		 
			//--Данилова Е.В. 13.03.2026
			СтруктураЗПС.boxList.Добавить(СтруктураКоробки);
			
		КонецЦикла; 	
		
		ДанныеОтвета.data.Добавить(СтруктураЗПС); 
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДанныеОтвета; 
	
 КонецФункции
 
