		 |				И (МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(перечисление.ВидыОперацийМаркировки.Агрегация))
		 |				И (МаркировкаТоваровИСМП.Проведен)
		 |				И (МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
		// |				И (МаркировкаТоваровИСМП.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
		 |			ЛЕВОЕ СОЕДИНЕНИЕ ВтИсключения КАК ВтИсключения
		 |			ПО (ВтИсключения.ШтрихкодКоробки = МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки)
		 |				И (ВтИсключения.ЗПС = МаркировкаТоваровИСМП.ДокументОснование)
		 |				И (ВтИсключения.ОМ = МаркировкаТоваровИСМП.Ссылка)
		 |	ГДЕ
		 |		ВтИсключения.ШтрихкодКоробки ЕСТЬ NULL) КАК ВложенныйЗапрос
		 |
		 |УПОРЯДОЧИТЬ ПО
		 |	ВложенныйЗапрос.ДатаДок,
		 |	ВложенныйЗапрос.ЗПС,
		 |	ВложенныйЗапрос.НаименованиеКоробки
		 |
		 |ИНДЕКСИРОВАТЬ ПО
		 |	ВложенныйЗапрос.ШтрихкодКоробки,
		 |	ВложенныйЗапрос.ЗПС,
		 |	ВложенныйЗапрос.ОМ
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	ВтКоробки.ШтрихкодКоробки КАК ШтрихкодКоробки,
		 |	ВтКоробки.ШтрихкодКоробки КАК ШтрихкодКоробкиКоличество,
		 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		 |	ВтКоробки.ЗПС КАК ЗПС,
		 |	ВтКоробки.ДатаДок КАК ДатаДок,
		 |	ВтКоробки.ШтрихкодКоробкиВсего КАК ШтрихкодКоробкиВсего,
		 |	ВтКоробки.НаименованиеКоробки КАК НаименованиеКоробки
		 |ИЗ
		 |	ВТКоробки КАК ВтКоробки
		 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		 |		ПО ВтКоробки.ОМ = МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка
		 |			И ВтКоробки.ШтрихкодКоробки = МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки
		 |ГДЕ
		 |	ТИПЗНАЧЕНИЯ(ВтКоробки.ЗПС) = ТИП(Документ.заказПоставщику)
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	ВтКоробки.ШтрихкодКоробки,
		 |	ВтКоробки.ШтрихкодКоробки,
		 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки,
		 |	ВтКоробки.ЗПС,
		 |	ВтКоробки.ДатаДок,
		 |	ВтКоробки.ШтрихкодКоробкиВсего,
		 |	ВтКоробки.НаименованиеКоробки
		 |ИЗ
		 |	ВТКоробки КАК ВтКоробки
		 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		 |		ПО ВтКоробки.ОМ = МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка
		 |			И ВтКоробки.ШтрихкодКоробки = МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки
		 |ГДЕ
		 |	ТИПЗНАЧЕНИЯ(ВтКоробки.ЗПС) = ТИП(Документ.КонтрактСПроизводителем)
		 |
		 |УПОРЯДОЧИТЬ ПО
		 |	ВтКоробки.ДатаДок,
		 |	ЗПС,
		 |	НаименованиеКоробки
		 |ИТОГИ
		 |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодКоробкиКоличество),
		 |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки),
		 |	МАКСИМУМ(ШтрихкодКоробкиВсего)
		 |ПО
		 |	ЗПС,
		 |	ШтрихкодКоробки"; 
	  
	//--Данилова Е.В. 13.03.2026  
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Лимит%",Лимит);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%НеВключать%",Лимит * (НомерСтраницы - 1));

