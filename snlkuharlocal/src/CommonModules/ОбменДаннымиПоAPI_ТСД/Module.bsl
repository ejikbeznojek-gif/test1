Процедура ПроставитьОтправкуМарокПоЗПСВФоне(Знач МассивЗПС)

	Если МассивЗПС.Количество() > 0  Тогда
		
		ПараметрыФонЗадания = Новый Массив; 
		ПараметрыФонЗадания.Добавить(МассивЗПС); 
		
		ИдентификаторФЗ = Новый УникальныйИдентификатор; 
		ФЗадание = ФоновыеЗадания.Выполнить("ОбменДаннымиПоAPI_ТСД.ПроставитьОтправкуМарокПоЗПС",ПараметрыФонЗадания,ИдентификаторФЗ,"ПроставитьОтправкуМарокПоЗПС");  	
		
	КонецЕсли;

КонецПроцедуры

Процедура ПроставитьОтправкуМарокПоЗПС(Знач МассивЗПС) Экспорт
	УстановитьПривилегированныйРежим(истина); 
	МассивДляЗаписи = Новый Массив; 
	Для каждого ЗначениеЗПС Из МассивЗПС Цикл
		Если ЗначениеЗПС.СостояниеПроверкиМарокНаТСД <> Перечисления.СостоянияПроверкиМарокНаТСД.МаркиОтправлены Тогда
			
			ОбъектЗПС = ЗначениеЗПС.ПолучитьОбъект(); 	
			ОбъектЗПС.СостояниеПроверкиМарокНаТСД = Перечисления.СостоянияПроверкиМарокНаТСД.МаркиОтправлены;
			
			МассивДляЗаписи.Добавить(ОбъектЗПС); 
			
		КонецЕсли;
		
	КонецЦикла;
	
	НачатьТранзакцию(); 
	Для каждого ОбЗПС Из МассивДляЗаписи Цикл
		
		
		Попытка
			
			ОбЗПС.Записать(); 
			
		Исключение
			ЗаписатьВЛог("СостоянияПроверкиМарокНаТСД","Не удалось поменять состояние проверки марок на ТСД на ""Марки отправлены""" + Строка(ОбЗПС.ссылка),"Ошибка"); 
			Если ТранзакцияАктивна() Тогда
				
				ОтменитьТранзакцию();
				
				УстановитьПривилегированныйРежим(Ложь);
				
				Прервать; 
			КонецЕсли;
		КонецПопытки; 	
		
		
	КонецЦикла;
	Если ТранзакцияАктивна() Тогда
		
		ЗафиксироватьТранзакцию();	
		
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

 	
