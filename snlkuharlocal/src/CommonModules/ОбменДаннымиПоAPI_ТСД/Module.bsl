 Функция ПолучитьСостояниеПроверкиМарокНаТСД(Знач Контрагент,СостояниеПроверкиМарокНаТСД) Экспорт
	 
	 //Кухарь А.Ю.  06.04.2026 начало
	 //Иногда КП создают с пустым контрагентом
	 если не ЗначениеЗаполнено(Контрагент) тогда    
		  СостояниеПроверкиМарокНаТСД = Перечисления.СостоянияПроверкиМарокНаТСД.НеТребуетсяОтправлять;   
		  Возврат Неопределено;
	 КонецЕсли;
	 //Кухарь А.Ю.  06.04.2026 конец
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	Контрагенты.ВыгружатьМаркиЗПСДляТСД КАК ВыгружатьМаркиЗПСДляТСД
	 |ИЗ
	 |	Справочник.Контрагенты КАК Контрагенты
	 |ГДЕ
	 |	Контрагенты.Ссылка = &Ссылка";
	 
	 Запрос.УстановитьПараметр("Ссылка", Контрагент);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 
	 ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(); 
	 ВыборкаДетальныеЗаписи.Следующий(); 
	 
	 Если ВыборкаДетальныеЗаписи.ВыгружатьМаркиЗПСДляТСД 
		 И СостояниеПроверкиМарокНаТСД = перечисления.СостоянияПроверкиМарокНаТСД.ПустаяСсылка() Тогда
		 
		 СостояниеПроверкиМарокНаТСД = Перечисления.СостоянияПроверкиМарокНаТСД.НеТребуетсяОтправлять; 
		 
	 КонецЕсли;
	 
	 Если НЕ ВыборкаДетальныеЗаписи.ВыгружатьМаркиЗПСДляТСД 
		 И СостояниеПроверкиМарокНаТСД = перечисления.СостоянияПроверкиМарокНаТСД.НеТребуетсяОтправлять Тогда
		 
		 СостояниеПроверкиМарокНаТСД = Перечисления.СостоянияПроверкиМарокНаТСД.ПустаяСсылка(); 
		 
	 КонецЕсли;
	 
	// Возврат СостояниеПроверкиМарокНаТСД; 
	 
