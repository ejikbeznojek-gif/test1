#Область ЗаписьДанныхВ1С

// Записывает данные сообщения из RabbitMQ в регистр сведений.
//
// Параметры:
//   ПараметрыЗаписи - Структура - данные для записи в регистр, содержащие свойства сообщения.
//                   Если не содержит свойство "ИдентификаторЗаписи", будет создан новый идентификатор.
//
// Возвращаемое значение:
//   Структура:
//     * Данные - УникальныйИдентификатор - идентификатор записи в регистре
//     * Ошибки - Массив из Строка - список текстовых описаний ошибок
//     * Успех - Булево - результат выполнения операции
Функция ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписи) Экспорт
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	Если Не ПараметрыЗаписи.Свойство("ИдентификаторЗаписи") Тогда
		ИдентификаторЗаписи = Новый УникальныйИдентификатор;
	Иначе
		ИдентификаторЗаписи = ПараметрыЗаписи.ИдентификаторЗаписи;
	КонецЕсли;
	
	СтруктураВозврата.Данные = ИдентификаторЗаписи;
	
	МенеджерЗаписи = РегистрыСведений.ДокФлоу_СообщенияОбмена.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПараметрыЗаписи);
	МенеджерЗаписи.ДатаЗаписи = ТекущаяДатаСеанса();
	
	МенеджерЗаписи.ИдентификаторЗаписи = ИдентификаторЗаписи;
	
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
		СтруктураВозврата.ошибки.добавить(СтрШаблон(
		"Не удалось записать данные в РС ДокФлоу_СообщенияОбмена по причине %1", ОписаниеОшибки()));
	КонецПопытки;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;	
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаписатьПолученныеДанныеВ1С(СтруктураДанных)   
	
	ТипДокумента = СтруктураДанных.ТипДокумента;
	
	Если ТипДокумента = "ЗаявкаНаОплату" Тогда   
		Возврат ЗаписатьЗаявкуНаОплатуИзДанныхДокФлоу(СтруктураДанных);
	ИначеЕсли ТипДокумента = "Контрагенты" Тогда  
		Возврат ЗаписатьКонтрагентаИзДанныхДокФлоу(СтруктураДанных);  
	ИначеЕсли ТипДокумента = "Договоры" Тогда  
		Возврат ЗаписатьДоговорИзДанныхДокФлоу(СтруктураДанных);  
	ИначеЕсли ТипДокумента = "БанковскиеСчета" Тогда  
		Возврат ЗаписатьБанковскийСчетИзДанныхДокФлоу(СтруктураДанных);  
	
	Иначе
		СтруктураВозврата = ПолучитьСтруктуруВозврата();
		СтруктураВозврата.Успех = Ложь;
		СтруктураВозврата.Ошибки.Добавить("Не предусмотрена запись указанного типа объекта - " + ТипДокумента);  
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции          

Функция ЗаписатьДоговорИзДанныхДокФлоу (СтруктураДанных)        
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки	 = Ложь;
	ВходящийКод = "";
	
	Если  Не СтруктураДанных.Свойство("ВходящийКод") Тогда
		СтруктураВозврата.Ошибки.Добавить("Не удалось записать договор. Отсутствует входящий код");
		ЕстьОшибки = Истина;
	Иначе
		ВходящийКод = СтруктураДанных.ВходящийКод;
	КонецЕсли;            
	
	СправочникОбъект = Неопределено;
	
	Если Не ЕстьОшибки Тогда
		Попытка              
			Если ЗначениеЗаполнено(СтруктураДанных.Код) Тогда 
				СправочникСсылка = Справочники.Договоры.НайтиПоКоду(СтруктураДанных.Код);
				Если Не ЗначениеЗаполнено(СправочникСсылка) Тогда  
					СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не найден договор по коду %1", СтруктураДанных.Код));   
				Иначе
					СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
				КонецЕсли;
			Иначе 
				СправочникОбъект = Справочники.Договоры.СоздатьЭлемент();   
			КонецЕсли;     
			
			Если СправочникОбъект <> Неопределено Тогда 
				ЗаполнитьЗначенияСвойств(СправочникОбъект, СтруктураДанных);	
				
				СправочникОбъект.Наименование = "Дог. № " 
				+ СокрЛП(СправочникОбъект.Номер) + " от " + Формат(СправочникОбъект.Дата, "ДФ = dd.MM.yyyy");
				
				КодЦБКонтрагента = ПолучитьРеквизитШапки(СправочникОбъект.Владелец, "Ведущий.Код","Справочник");
				Если ЗначениеЗаполнено(КодЦБКонтрагента) Тогда   
					СправочникОбъект.КодЦБ = КодЦБКонтрагента;	
				КонецЕсли;
				
				СправочникОбъект.ВходящийКод	 = ВходящийКод;    
				
				Если Не ЗначениеЗаполнено(СправочникОбъект.Владелец) Тогда 
					СтруктураВозврата.Ошибки.Добавить("Не найден владелец загружаемого договора"); 
				КонецЕсли;    
				
				Если Не  ЗначениеЗаполнено(СправочникОбъект.ВалютаКредита) Тогда  
					СправочникОбъект.ВалютаКредита = ОбщегоНазначения_ПИ.ПолучитьЗначениеКонстанты("ВалютаУпрУчета");	
				КонецЕсли;     
				
				Если Не  ЗначениеЗаполнено(СправочникОбъект.Организация) Тогда  
					СправочникОбъект.Организация = Маркировка_ПИ.ОрганизацияЕЕЭ();	
				КонецЕсли;
				
				Если СтруктураВозврата.Ошибки.Количество() = 0 Тогда
					СправочникОбъект.Записать();   
				КонецЕсли; 
			КонецЕсли;    
			
		Исключение       		
			ИнформацияОбОшибке = ИнформацияОбОшибке();       
			ОшибкаКратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);			
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По ID объекта %1 Не удалось записать объект по причине %2",
			ВходящийКод, ОшибкаКратко));
			ЕстьОшибки = Истина;
		КонецПопытки;
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	Иначе
		СтруктураВозврата.Данные = СправочникОбъект.Ссылка;
	КонецЕсли;        
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаписатьБанковскийСчетИзДанныхДокФлоу (СтруктураДанных)        
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки	 = Ложь;
	ВходящийКод = "";
	
	Если  Не СтруктураДанных.Свойство("ВходящийКод") Тогда
		СтруктураВозврата.Ошибки.Добавить("Не удалось записать банковский счет. Отсутствует входящий код");
		ЕстьОшибки = Истина;
	Иначе
		ВходящийКод = СтруктураДанных.ВходящийКод;
	КонецЕсли;            
	
	Банк = НайтиБанкПоБИКиКоррСчету(СтруктураДанных.БикБанка, СтруктураДанных.КоррСчетБанка); 
	
	Если Банк = Неопределено Тогда    
		СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не найден банк по БИК %1 И Корр счету %2",
		СтруктураДанных.БикБанка, СтруктураДанных.КоррСчетБанка));
	Иначе
		СтруктураДанных.Вставить("Банк", Банк);
	КонецЕсли;
	
	СправочникОбъект = Неопределено;
	
	Если Не ЕстьОшибки Тогда
		Попытка              
			Если ЗначениеЗаполнено(СтруктураДанных.Код) Тогда 
				СправочникСсылка = Справочники.БанковскиеСчета.НайтиПоКоду(СтруктураДанных.Код);
				Если Не ЗначениеЗаполнено(СправочникСсылка) Тогда  
					СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не найден банковский счет по коду %1",
					СтруктураДанных.Код));   
				Иначе
					СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
				КонецЕсли;
			Иначе 
				СправочникОбъект = Справочники.БанковскиеСчета.СоздатьЭлемент();   
			КонецЕсли;     
			
			Если СправочникОбъект <> Неопределено Тогда 
				ЗаполнитьЗначенияСвойств(СправочникОбъект, СтруктураДанных);					
				СправочникОбъект.ВходящийКод	 = ВходящийКод;    
				
				Если Не ЗначениеЗаполнено(СправочникОбъект.Владелец) Тогда 
					СтруктураВозврата.Ошибки.Добавить("Не найден владелец загружаемого банковского счета"); 
				КонецЕсли;    
				
				Если Не  ЗначениеЗаполнено(СправочникОбъект.ВалютаДенежныхСредств) Тогда  
					СправочникОбъект.ВалютаДенежныхСредств = ОбщегоНазначения_ПИ.ПолучитьЗначениеКонстанты("ВалютаУпрУчета");	
				КонецЕсли;     
				
				СправочникОбъект.ЗаполнитьТекстКорреспондента();
				
				Если СтруктураВозврата.Ошибки.Количество() = 0 Тогда
					СправочникОбъект.Записать();   
				КонецЕсли; 
			КонецЕсли;    
			
		Исключение       		
			ИнформацияОбОшибке = ИнформацияОбОшибке();       
			ОшибкаКратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);			
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По ID объекта %1 Не удалось записать объект по причине %2",
			ВходящийКод, ОшибкаКратко));
			ЕстьОшибки = Истина;
		КонецПопытки;
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	Иначе
		СтруктураВозврата.Данные = СправочникОбъект.Ссылка;
	КонецЕсли;        
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция НайтиБанкПоБИКиКоррСчету (БИК, КоррСчет)    
	
	Банк = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Банки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Банки КАК Банки
	|ГДЕ
	|	НЕ Банки.ПометкаУдаления
	|	И НЕ Банки.ЭтоГруппа
	|	И Банки.КоррСчет = &КоррСчет
	|	И Банки.Код = &Код";
	Запрос.УстановитьПараметр("Код", БИК);
	Запрос.УстановитьПараметр("КоррСчет", КоррСчет);  
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Банк = Выборка.Ссылка;
	КонецЦикла;
	
	Возврат Банк;
	
КонецФункции

Функция ЗаписатьКонтрагентаИзДанныхДокФлоу (СтруктураДанных)        
	
	СтруктураВозврата	= ПолучитьСтруктуруВозврата();
	ЕстьОшибки	 		= Ложь;
	ВходящийКод 		= "";
	
	Если  Не СтруктураДанных.Свойство("ВходящийКод") Тогда
		СтруктураВозврата.Ошибки.Добавить("Не удалось записать контрагента. Отсутствует входящий код");
		ЕстьОшибки = Истина;
	Иначе
		ВходящийКод = СтруктураДанных.ВходящийКод;
	КонецЕсли;            

	
	СправочникОбъект = Неопределено;
	
	НачатьТранзакцию();
	
	Если Не ЕстьОшибки Тогда   
		
		Попытка              
			Если ЗначениеЗаполнено(СтруктураДанных.Код) Тогда 
				СправочникСсылка = Справочники.Контрагенты.НайтиПоКоду(СтруктураДанных.Код);
				Если Не ЗначениеЗаполнено(СправочникСсылка) Тогда  
					СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не найден контрагент по коду %1", СтруктураДанных.Код));   
				Иначе
					СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
				КонецЕсли;
			Иначе 
				СправочникОбъект				 = Справочники.Контрагенты.СоздатьЭлемент(); 
				СправочникОбъект.Родитель		 = ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ПапкаЗагрузкиКонтрагентовИзДокФлоу",Справочники.Контрагенты.ПустаяСсылка());  
				Если  СправочникОбъект.Родитель	 = Справочники.Контрагенты.ПустаяСсылка() Тогда
					СтруктураВозврата.Ошибки.Добавить("Не указана папка, для загрузки контрагентов Из док. флоу");  
				КонецЕсли;	         
				СправочникОбъект.Владелец		 = ОбщегоНазначения_ПИ.ПолучитьОсновнуюИБ();		
			КонецЕсли;     
			
			Если СправочникОбъект <> Неопределено Тогда 
				ЗаполнитьЗначенияСвойств(СправочникОбъект, СтруктураДанных);	     
		
				СправочникОбъект.ВходящийКод	 = ВходящийКод;     
				
				Если ЗначениеЗаполнено(СправочникОбъект.Ведущий) Тогда
					Если ПолучитьРеквизитШапки(СправочникОбъект.Ведущий, "Владелец", "Справочник") = ОбщегоНазначения_ПИ.ПолучитьОсновнуюИБ() Тогда     
						СтруктураВозврата.Ошибки.Добавить("Владелец ведущего должен быть интегральным контрагентом");	
					КонецЕсли;  
					СправочникОбъект.КодЦБ = ПолучитьРеквизитШапки(СправочникОбъект.Ведущий, "Код", "Справочник");   
					// Кухарь А.Ю.  13.07.2026 начало
					// Пустая задача
				Иначе
					ВедущийОбъект = Справочники.Контрагенты.СоздатьЭлемент();
					ЗаполнитьЗначенияСвойств(ВедущийОбъект, СправочникОбъект,"КаналСбыта1, СтранаРегистрации");
					ВедущийОбъект.Владелец = ОбщегоНазначения_ПИ.ПолучитьИнтегральнуюИБ();  
					Если СтруктураДанных.Свойство("НаименованиеВедущего") И ЗначениеЗаполнено(СтруктураДанных.НаименованиеВедущего) Тогда
						ВедущийОбъект.Наименование = СтруктураДанных.НаименованиеВедущего;
					Иначе  
						ВедущийОбъект.Наименование = СправочникОбъект.Наименование;
					КонецЕсли;                    
					ВедущийОбъект.Родитель		 = ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ПапкаЗагрузкиИнтегральныхКонтрагентовИзДокФлоу",Справочники.Контрагенты.ПустаяСсылка());  
					Если  ВедущийОбъект.Родитель	 = Справочники.Контрагенты.ПустаяСсылка() Тогда
						СтруктураВозврата.Ошибки.Добавить("Не указана папка, для загрузки интегральных контрагентов Из док. флоу");  
					КонецЕсли;	        
					ВедущийОбъект.Записать(); 
					СправочникОбъект.КодЦБ = ВедущийОбъект.Код;
					СправочникОбъект.Ведущий =  ВедущийОбъект.Ссылка			
					// Кухарь А.Ю.  13.07.2026 конец
					
				КонецЕсли;        
				
				Запрос = Новый  Запрос;    
				Запрос.УстановитьПараметр("Ссылка",СправочникОбъект.Ссылка);
				Запрос.УстановитьПараметр("Владелец",СправочникОбъект.Владелец);
				Запрос.УстановитьПараметр("ИНН",СправочникОбъект.ИНН);
				
				Запрос.Текст = "ВЫБРАТЬ
				|	Контрагенты.Ссылка КАК Ссылка,
				|	Контрагенты.Код КАК Код
				|ИЗ
				|	Справочник.Контрагенты КАК Контрагенты
				|ГДЕ
				|	Контрагенты.Ссылка <> &Ссылка
				|	И Контрагенты.Владелец = &Владелец
				|	И Контрагенты.ИНН = &ИНН
				|	И НЕ Контрагенты.ПометкаУдаления";
				Выборка = Запрос.Выполнить().Выбрать();
				Пока Выборка.Следующий() Цикл    
					СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Обнаружен другой контрагент с таким же ИНН %1,
					| имеющий код %2", СправочникОбъект.ИНН, Выборка.Код));	
				КонецЦикла;
				
				Если СтруктураВозврата.Ошибки.Количество() = 0 Тогда
					СправочникОбъект.Записать();   
				КонецЕсли; 
			КонецЕсли;    
			
		Исключение       		
			ИнформацияОбОшибке = ИнформацияОбОшибке();       
			ОшибкаКратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);			
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По ID объекта %1 Не удалось записать объект по причине %2",
			ВходящийКод, ОшибкаКратко));
			ЕстьОшибки = Истина;
		КонецПопытки;
	КонецЕсли;  
	
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда   
		ОтменитьТранзакцию();
		СтруктураВозврата.Успех = Ложь;
	Иначе             
		ЗафиксироватьТранзакцию();
		СтруктураВозврата.Данные = СправочникОбъект.Ссылка;
	КонецЕсли;        
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаписатьЗаявкуНаОплатуИзДанныхДокФлоу (СтруктураДанных)        
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки	 = Ложь;
	ТипДокумента = СтруктураДанных.ТипДокумента;
	ВходящийНомер = "";
	
	Если Не СтруктураДанных.Свойство("ВходящийНомер") Тогда
		СтруктураВозврата.Ошибки.Добавить("Не удалось записать документ. Отсутствует входящий номер");
		ЕстьОшибки = Истина;
	Иначе
		ВходящийНомер = СтруктураДанных.ВходящийНомер;
	КонецЕсли;
	
	Если Не ЕстьОшибки Тогда
		Запрос = Новый запрос;
		запрос.Текст = СтрШаблон("ВЫБРАТЬ первые 1
		|	Док.Номер КАК Номер
		|ИЗ
		|	Документ.%1 КАК Док
		|ГДЕ
		|Док.ВходящийНомер = &ВходящийНомер
		| И Не Док.ПометкаУдаления", ТипДокумента);
		Запрос.УстановитьПараметр("ВходящийНомер", СтруктураДанных.ВходящийНомер);
		Выборка = запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По ID документа %1 уже существует %2 с номером %3",
			ВходящийНомер, ТипДокумента, Выборка.Номер));
			ЕстьОшибки = Истина;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЕстьОшибки Тогда
		Попытка
			ЗНООбъект = Документы.ЗаявкаНаОплату.СоздатьДокумент();
			ЗНООбъект.Дата = ТекущаяДатаСеанса();       			
			
			ЗаполнитьШапкуДокумента(ЗНООбъект, ЗНООбъект.Автор, ПараметрыСеанса.ВалютаНац, "Продажа");
			УстановитьНомерДокументаКлиентСервер(ЗНООбъект);
			Если Не СтруктураДанных.Свойство("РасшифровкиЗатрат") Тогда
				СтруктураДанных.Вставить("РасшифровкиЗатрат",Новый Массив());
			КонецЕсли;
			
			ЗаполнитьЗначенияСвойств(ЗНООбъект, СтруктураДанных, , "РасшифровкиЗатрат");   			
			
			Если СтруктураДанных.Свойство("РасшифровкиЗатрат") И ТипЗнч(СтруктураДанных.РасшифровкиЗатрат) = Тип(
				"Массив") Тогда
				Для Каждого СтрМасс Из СтруктураДанных.РасшифровкиЗатрат Цикл
					СтрТЧ = ЗНООбъект.РасшифровкиЗатрат.Добавить();
					ЗаполнитьЗначенияСвойств(СтрТЧ, СтрМасс);
				КонецЦикла;
			КонецЕсли;  
			
			ЗНООбъект.НачальноеЗаполнениеПриВыбореОрганизации();
			ЗНООбъект.Состояние=Перечисления.СостоянияЗаявокНаОплату.ВРаботе;
			РеквизитыКонтрагента = ПолучитьРеквизитыШапки(ЗНООбъект.Контрагент,
			"ОсновнойДоговор,ОсновнойДоговор.НеИспользовать", "Справочник");
			Если Не ЗначениеЗаполнено(ЗНООбъект.Договор) Или ПолучитьРеквизитШапки(ЗНООбъект.Договор, "НеИспользовать",
				"Справочник") = Истина Тогда
				Если РеквизитыКонтрагента.ОсновнойДоговор_НеИспользовать = Ложь Тогда
					ЗНООбъект.Договор =  РеквизитыКонтрагента.ОсновнойДоговор;
				Иначе
					ЗНООбъект.Договор = Неопределено;
				КонецЕсли;
			КонецЕсли;  
			
			ЗНООбъект.ВидОперации=Перечисления.ВидыОперацийППИсходящее.ОплатаПоставщику;
			ЗНООбъект.ОчередностьПлатежа = 5;
			
			Если Не ЗначениеЗаполнено(ЗНООбъект.Договор) Тогда
				ЗНООбъект.Договор = Справочники.Контрагенты.ПолучитьЕдинственныйДоговорКонтрагента(ЗНООбъект.Контрагент);
			КонецЕсли;                
			
			Если Не ЗначениеЗаполнено(ЗНООбъект.РСКонтрагента) Тогда
				ЗНООбъект.РСКонтрагента = Справочники.Контрагенты.ПолучитьЕдинственныйБанковскийСчетКонтрагента(ЗНООбъект.Контрагент);
			КонецЕсли;     
			
			Если ТипЗнч(ЗНООбъект.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда    
				МенеджерКонтрагента = ПолучитьРеквизитШапки(ЗНООбъект.Контрагент,"Менеджер","Справочник");   
				Если ЗначениеЗаполнено(МенеджерКонтрагента) Тогда  
					ЗНООбъект.ОтветственноеФизЛицо = МенеджерКонтрагента;
				КонецЕсли;         
				
				ЗНООбъект.УстановитьРеквизитыПлательщика();
				ЗНООбъект.УстановитьРеквизитыПолучателя();
				
			КонецЕсли;
			
			ЗНООбъект.Состояние = Перечисления.СостоянияЗаявокНаОплату.КОплате;
			
			Если ЗНООбъект.РасшифровкиЗатрат.Количество() = 1 Тогда       
				СтрокаТЧ = ЗНООбъект.РасшифровкиЗатрат[0];
				ЗаполнитьЗначенияСвойств(ЗНООбъект, СтрокаТЧ, "Подразделение, СтатьяЗатрат, ПериодРасходов, СубЗатрата, Затраты, Проект");
			Иначе
				ЗНООбъект.Подразделение = Справочники.Подразделения.ПустаяСсылка();     
				ЗНООбъект.СтатьяЗатрат = Справочники.СтатьиЗатрат.ПустаяСсылка();
				ЗНООбъект.ПериодРасходов = ПустаяДата();
				ЗНООбъект.СубЗатрата = Справочники.СубЗатраты.ПустаяСсылка();
				ЗНООбъект.Затраты = Ложь;   
				МассСтрок = ЗНООбъект.РасшифровкиЗатрат.НайтиСтроки(Новый Структура("Затраты", Ложь));
				Если МассСтрок.Количество() = 0 Тогда
					ЗНООбъект.Затраты = Истина;
				КонецЕсли;		   					  
			КонецЕсли;  		
			ЗНООбъект.Записать();
		Исключение       
			ИнформацияОбОшибке = ИнформацияОбОшибке();       
			ОшибкаКратко = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);			
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон("По ID документа %1 Не удалось записать документ по причине %2",
			ВходящийНомер, ОшибкаКратко));
			ЕстьОшибки = Истина;
		КонецПопытки;
	КонецЕсли;

	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	Иначе
		СтруктураВозврата.Данные = ЗНООбъект.Ссылка;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Запускает обмен документами через DocFlow с использованием RabbitMQ.
//
// Параметры:
//   ТаблицаПараметров - ТаблицаЗначений - дополнительная настройка параметров обмена
//                     - Неопределено - параметры не заданы
Процедура ОбменДокФлоу(ТаблицаПараметров = Неопределено) Экспорт
	  
	ДопПараметры=Новый Структура;                 
	ПаузаМеждуПовторами = 30;
	Если ТипЗнч(ТаблицаПараметров) = Тип("ТаблицаЗначений") Тогда
			
		Для Каждого СтрокаПараметров Из ТаблицаПараметров Цикл           
			ИмяПараметра = ВРег(СтрЗаменить(СтрокаПараметров.Имя," ",""));
			Если ИмяПараметра = "" Тогда 
				Продолжить; 
			КонецЕсли;       
			
			Если ИмяПараметра = "ПАУЗАМЕЖДУПОВТОРАМИ" Тогда   
				ПаузаМеждуПовторами = СтрокаПараметров.Значение;    
			КонецЕсли;               
			
			Если Не ДопПараметры.Свойство(ИмяПараметра) Тогда
				ДопПараметры.Вставить(ИмяПараметра,СтрокаПараметров.Значение);
			КонецЕсли;  
			
		КонецЦикла;
	КонецЕсли;
	
	ЗапуститьБесконечныйЦиклПриемкиСообщенийЧерезRabbitMQ(ПаузаМеждуПовторами,ДопПараметры);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти