		КонецЕсли; 
		// Кухарь А.Ю.  26.06.2026 конец
		
	КонецЦикла;         
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции      

Функция ИнициализироватьКомпонентуНаПрием (СтруктураАвторизации,СкидыватьКеш = Ложь)    
	
	Если СкидыватьКеш Тогда 
		ОбновитьПовторноИспользуемыеЗначения();
	КонецЕсли;
	
	КомпонентаОбмена = Неопределено;
		
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки = Ложь;
	
	Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка"); 
	
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;
	

	Если КомпонентаОбмена = Неопределено Тогда
		ОбновитьПовторноИспользуемыеЗначения();
		Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка");
	КонецЕсли;     
	
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;  	
	
	Попытка
		КомпонентаОбмена.УстановитьСоединение(СтруктураАвторизации.Хост, СтруктураАвторизации.Логин,
		СтруктураАвторизации.Пароль);
	Исключение
		ЕстьОшибки = Истина;
		СтруктураВозврата.Ошибки.Добавить(ОписаниеОшибки());
	КонецПопытки;     
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда 
		СтруктураВозврата.Успех = Ложь;  
	Иначе
		СтруктураВозврата.Данные = КомпонентаОбмена;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ПрочитатьТекущееСообщениеRabbitMQ(СтруктураПараметров)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки = Ложь;
	СтруктураВозврата.Данные = Ложь;
	
	КомпонентаОбмена = СтруктураПараметров.КомпонентаОбмена;
	
	НомерДоставки	= 0;
	Сообщение		= КомпонентаОбмена.ПрочитатьСообщение(НомерДоставки);
	Если НомерДоставки < 0 Тогда       
		
		СтруктураВозврата.Ошибки.Добавить(КомпонентаОбмена.ПолучитьОшибку());   
		
	ИначеЕсли Сообщение = Ложь Тогда  
		
		СтруктураВозврата.Данные = Истина;
		Возврат СтруктураВозврата;  
		
	ИначеЕсли НомерДоставки >= 0 Тогда
		
		СообщениеСтрокой	= ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
		
		ПараметрыЗаписиРС = Новый Структура;
		ПараметрыЗаписиРС.Вставить("ДанныеЗаписаныВ1С", Ложь);
		ПараметрыЗаписиРС.Вставить("ОтправленоПодтверждениеОЗаписи", Ложь);
		ПараметрыЗаписиРС.Вставить("ВходящийТекст", СообщениеСтрокой);
		ПараметрыЗаписиРС.Вставить("ТекстСообщений", "");
		ПараметрыЗаписиРС.Вставить("ЕстьОшибки", Ложь);
		ПараметрыЗаписиРС.Вставить("ИдентификаторДокумента", "");
		ПараметрыЗаписиРС.Вставить("СтатусСообщения", Перечисления.СтатусыСообщенийИзRabbit.Прочитано);
		Результат = ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Если Не ЕстьОшибки Тогда  
			Попытка
				КомпонентаОбмена.ПодтвердитьЧтение(НомерДоставки);
			Исключение
				Результат.Ошибки.Добавить("Не удалось подтвердить чтение сообщения. " + описаниеОшибки());
			КонецПопытки;
		КонецЕсли;  
		
	КонецЕсли;        
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата; 
	
КонецФункции  

// Подключает внешнюю компоненту для работы с RabbitMQ в заданном направлении и возвращает результат подключения.
//
// Параметры:
//   Направление - Строка - направление обмена: "Прием" или "Отправка". По умолчанию "Прием"
//
// Возвращаемое значение:
//   Структура - см. ПолучитьСтруктуруВозврата:
//     * Успех - Булево - флаг успешности выполнения операции
//     * Данные - Произвольный - объект подключенной компоненты Неопределено, если подключение не удалось
//     * Ошибки - Массив из Строка - список текстов ошибок
Функция ПодключитьКомпонентуRabbitMQ(Направление = "Прием") Экспорт
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	Разрядность = РазрядностьПлатформы();
	ОбъектКомпоненты	= Неопределено;
	ИмяДляПодключения	= "AddIn" + Направление;
	Если ПодключитьВнешнююКомпоненту(ПоместитьВоВременноеХранилище(ПолучитьОбщийМакет("КомпонентаОбмена"
		+ Разрядность)), ИмяДляПодключения, ТипВнешнейКомпоненты.Native,
		ТипПодключенияВнешнейКомпоненты.НеИзолированно) Тогда
		Попытка
			ИмяОбъекта			= "AddIn." + ИмяДляПодключения + ".AMQPToNative";
			ОбъектКомпоненты	= Новый (ИмяОбъекта);
		Исключение
			СтруктураВозврата.Ошибки.Добавить("Ошибка создания объекта Из компоненты. " + ОписаниеОшибки());
		КонецПопытки;
	Иначе
		СтруктураВозврата.Ошибки.Добавить("Не удалось подключить компоненту обмена.");
	КонецЕсли;
	
	СтруктураВозврата.Данные =  ОбъектКомпоненты;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция РазрядностьПлатформы()
	
	СисИнфо	= Новый СистемнаяИнформация;
	Если СтрНайти(СисИнфо.ТипПлатформы, 64) <> 0 Тогда
		Результат	= 64;
	Иначе
		Результат	= 32;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДанныеАвторизацииRabbitMQ()   
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	СтруктураКлючей = Новый Структура("ЗНОВходящийПоток,ИсходящийПоток");   
	СтруктураКлючей.Вставить("ИсходящийПотокПлатежныхДанных");    
	
	СтруктураДанных = Новый Структура;
	Если ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() Тогда //Тут определяется с каким контуром будут получены данные для обмена с живым или тестовым 
		СтруктураКлючей.ЗНОВходящийПоток = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitЗНОВходящийПоток;
		СтруктураКлючей.ИсходящийПоток = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitЗНОИсходящийПоток;       
		СтруктураКлючей.ИсходящийПотокПлатежныхДанных = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitПлатежнаяИнформацияИсходящийПоток;  
	Иначе
		СтруктураКлючей.ЗНОВходящийПоток = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitЗНОВходящийПотокТест;
		СтруктураКлючей.ИсходящийПоток = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitЗНОИсходящийПотокТест;  
		СтруктураКлючей.ИсходящийПотокПлатежныхДанных = Справочники.КлючиБезопасногоХранилищаДанных.ДанныеDocFlowRabbitПлатежнаяИнформацияИсходящийПотокТест;  		
	КонецЕсли;
	
	ДанныеАвторизации = РаботаСБезопаснымХранилищем.ПрочитатьДанныеАвторизацииПоКлючу(СтруктураКлючей.ЗНОВходящийПоток);  //Основные параметры + имя очереди для получения входящих ЗНО
	Для Каждого ЭлементДанныхАвторизации Из ДанныеАвторизации Цикл
		Если ЭлементДанныхАвторизации.Ключ = "Логин" Тогда
			СтруктураДанных.Вставить("Логин", ЭлементДанныхАвторизации.Значение);
		ИначеЕсли ЭлементДанныхАвторизации.Ключ = "Пароль" Тогда
			СтруктураДанных.Вставить("Пароль", ЭлементДанныхАвторизации.Значение);
		ИначеЕсли ЭлементДанныхАвторизации.Ключ = "Хост" Тогда
			СтруктураДанных.Вставить("Хост", ЭлементДанныхАвторизации.Значение);
		КонецЕсли;
	КонецЦикла;     
	
	ДанныеАвторизации = РаботаСБезопаснымХранилищем.ПрочитатьДанныеАвторизацииПоКлючу(СтруктураКлючей.ИсходящийПоток); // имя очереди для отправки подтверждений о загрузке ЗНО
	Для Каждого ЭлементДанныхАвторизации Из ДанныеАвторизации Цикл
		Если ЭлементДанныхАвторизации.Ключ = "Ресурс" Тогда
			СтруктураДанных.Вставить("ИмяОчередиИсходящаяЗНО", ЭлементДанныхАвторизации.Значение);
		КонецЕсли;
	КонецЦикла;

	ДанныеАвторизации = РаботаСБезопаснымХранилищем.ПрочитатьДанныеАвторизацииПоКлючу(СтруктураКлючей.ИсходящийПотокПлатежныхДанных); // имя очереди для отправки изменений статуса на "оплачен" в ЗНО
	Для Каждого ЭлементДанныхАвторизации Из ДанныеАвторизации Цикл
		Если ЭлементДанныхАвторизации.Ключ = "Ресурс" Тогда
			СтруктураДанных.Вставить("ИмяОчередиИсходящаяПлатежныеДанные", ЭлементДанныхАвторизации.Значение);
		КонецЕсли;
	КонецЦикла;     

	МассивПолей = Новый Массив;
	МассивПолей.Добавить("ИмяОчередиИсходящаяЗНО");  
	МассивПолей.Добавить("ИмяОчередиИсходящаяПлатежныеДанные");
	МассивПолей.Добавить("Хост");
	МассивПолей.Добавить("Логин");
	МассивПолей.Добавить("Пароль");
	
	Результат = ПроверитьЗаполнениеСтруктурыДанных(СтруктураДанных, МассивПолей);
	Если Не Результат.Успех Тогда
		СтруктураВозврата.Ошибки.Добавить("В настройках доступа к RABBIT обнаружены ошибки:");
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
	КонецЕсли;
	
	СтруктураВозврата.Данные = СтруктураДанных;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	Возврат СтруктураВозврата;  
	
КонецФункции

Функция ПроверитьЗаполнениеСтруктурыДанных(СтруктураДанных, МассивИменПолей)        
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	Для Каждого СтрокаМассива Из МассивИменПолей Цикл
		Если СтруктураДанных.Свойство(СтрокаМассива) Тогда
			Если Не ЗначениеЗаполнено(СтруктураДанных[СтрокаМассива]) Тогда
				СтруктураВозврата.Ошибки.Добавить("Не заполнено поле " + СтрокаМассива);
			КонецЕсли;
		Иначе
			СтруктураВозврата.Ошибки.Добавить("Не заполнено поле " + СтрокаМассива);
		КонецЕсли;
	КонецЦикла;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	Возврат СтруктураВозврата;     
	
КонецФункции

// Отправляет накопленные сообщения из 1С:Предприятие в RabbitMQ.
//
// Параметры:
//   СтруктураАвторизации - Структура - параметры авторизации для подключения к RabbitMQ:
//     * Хост - Строка - адрес сервера RabbitMQ
//     * Логин - Строка - имя пользователя для подключения
//     * Пароль - Строка - пароль для подключения
//     * ИмяОчередиИсходящаяПлатежныеДанные - Строка - имя очереди для отправки сообщений
//
// Возвращаемое значение:
//   Структура - результат выполнения операции:
//     * Успех - Булево - Истина, если отправка прошла успешно
//     * Ошибки - Массив из Строка - список ошибок, возникших при отправке      
//     * Данные - Неопределено
Функция ОтправитьНакопленныеСообщенияИз1С(СтруктураАвторизации)   Экспорт       
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка"); 
	
	ЕстьОшибки = Ложь;
	
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;   
	КонецЕсли;    
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;
	
	Если КомпонентаОбмена = Неопределено Тогда
		ОбновитьПовторноИспользуемыеЗначения();
		Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка");
	КонецЕсли;
	
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;  
		
	Попытка
		КомпонентаОбмена.УстановитьСоединение(СтруктураАвторизации.Хост, СтруктураАвторизации.Логин,
		СтруктураАвторизации.Пароль);
	Исключение
		ЕстьОшибки = Истина;
		СтруктураВозврата.Ошибки.Добавить(ОписаниеОшибки());
	КонецПопытки;
	
	Запрос = Новый запрос;
	Запрос.УстановитьПараметр("КПередачеВRabbit", Перечисления.СтатусыСообщенийИзRabbit.КПередачеВRabbit);
	Запрос.Текст = "ВЫБРАТЬ
	|	ДокФлоу_СообщенияОбмена.ИдентификаторЗаписи КАК ИдентификаторЗаписи,
	|	ДокФлоу_СообщенияОбмена.ТекстСообщений КАК ТекстСообщений
	|ИЗ
	|	РегистрСведений.ДокФлоу_СообщенияОбмена КАК ДокФлоу_СообщенияОбмена
	|ГДЕ
	|	ДокФлоу_СообщенияОбмена.СтатусСообщения = &КПередачеВRabbit";
	
	Выборка = Запрос.Выполнить().Выбрать();  
	
	Пока Выборка.Следующий() Цикл
		
		Сообщение		= ПолучитьДвоичныеДанныеИзСтроки(Выборка.ТекстСообщений);
		
		ЕстьОшибкаКомпоненты = Ложь;
		Попытка     
			НомерДоставки	= КомпонентаОбмена.ОтправитьСообщение("", 
			СтруктураАвторизации.ИмяОчередиИсходящаяПлатежныеДанные,
			Сообщение);     
		Исключение
			ЕстьОшибкаКомпоненты = Истина;
			ОшибкаКомпоненты = ОписаниеОшибки();
		КонецПопытки;   
		
		Если ЕстьОшибкаКомпоненты Тогда
			ПолныйТекстСообщения = СтрШаблон("Не удалось отправить сообщение. Ошибка: %1", ОшибкаКомпоненты);  
			ЗаписатьВЛог("Ошибки", ПолныйТекстСообщения, "Информация");	
			ВызватьИсключение ПолныйТекстСообщения;
		КонецЕсли;
				
		Если НомерДоставки > 0 Тогда			
			ЕстьОшибкаКомпоненты = Ложь;
			попытка
				КомпонентаОбмена.ОтправитьБуферСообщений();	
			Исключение   
				ЕстьОшибкаКомпоненты = Истина;
				ОшибкаКомпоненты = ОписаниеОшибки();	
			КонецПопытки;               
			
			Если ЕстьОшибкаКомпоненты Тогда
				ПолныйТекстСообщения = СтрШаблон("Не удалось отправить сообщение. Ошибка: %1", ОшибкаКомпоненты);  
				ЗаписатьВЛог("Ошибки", ПолныйТекстСообщения, "Информация");	
				ВызватьИсключение ПолныйТекстСообщения;
			КонецЕсли;
			
			МенеджерЗаписи = РегистрыСведений.ДокФлоу_СообщенияОбмена.СоздатьМенеджерЗаписи(); 
			МенеджерЗаписи.ИдентификаторЗаписи = Выборка.ИдентификаторЗаписи;
			МенеджерЗаписи.Прочитать();
			МенеджерЗаписи.СтатусСообщения = Перечисления.СтатусыСообщенийИзRabbit.ПереданоПодтверждение;
			МенеджерЗаписи.Записать(Истина);

		КонецЕсли;    
	
	КонецЦикла;    		

	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

