				//Кухарь А.Ю. 13.07.2026 начало
					
				СтруктураСтроки.success = Истина;
				СтруктураСтроки.error = "";
			КонецЕсли;
		Иначе
			СтруктураСтроки.success = Ложь;
			СтруктураСтроки.error = "input text can not be read";
