#Область ПрограммныйИнтерфейс

// Принимает сообщение через RabbitMQ, обрабатывает JSON данные, записывает в 1С И отправляет подтверждение
// Параметры:
//  ДопПараметры - Неопределено, Структура - Дополнительные параметры
// Возвращаемое значение:
//  Структура - Результат выполнения:
// * Успех - Булево - Успешность выполнения
// * Ошибки - Массив Из Строка - Список ошибок
// * Данные - Неопределено - Данные результата
Функция ПринятьСообщениеЧерезRabbitMQ(ДопПараметры = Неопределено) Экспорт

	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	ЕстьОшибки = Ложь;

	Результат = ПолучитьДанныеАвторизацииRabbitMQ();
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	Иначе
		ДанныеАвторизации = Результат.Данные;
	КонецЕсли;
	
	Если Не ЕстьОшибки Тогда
		Результат = ПрочитатьСообщенияRabbitMQ(ДанныеАвторизации);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Результат = ОбработатьДанныеРСДокФлоу_СообщенияОбмена();
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Результат = ОтправитьОтветОбработкиСообщенийВRabbitMQ(ДанныеАвторизации);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;       
		
		Результат = ОтправитьНакопленныеСообщенияИз1С(ДанныеАвторизации);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;      		
		
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;   
		ЗаписатьВЛог("Ошибки", "Ошибка работы с док флоу " + СтрСоединить(СтруктураВозврата.Ошибки, ","),
		 "Информация");
	КонецЕсли;
	
	Возврат СтруктураВозврата;
		
КонецФункции

// Запускает бесконечный Цикл приема сообщений Из RabbitMQ.
//
// Параметры:
//   ПаузаМеждуПовторами - Число - время ожидания между итерациями в секундах
//   ДопПараметры - Неопределено - дополнительные параметры для приема сообщений
//
// Возвращаемое значение:
//   Булево - Истина, Если обмен уже запущен, Иначе управление Не возвращается (бесконечный Цикл)
Функция ЗапуститьБесконечныйЦиклПриемкиСообщенийЧерезRabbitMQ (ПаузаМеждуПовторами = 30, 
	ДопПараметры = Неопределено) Экспорт 
	
	ОбменУжеЗапущен = ЕстьЗапущенныеЗаданияОбменаRabbit();
	Если ОбменУжеЗапущен Тогда
		ЗаписатьВЛог("РаботаСДокФлоу", "Регламентное задание уже выполняется в другом потоке. Запуск отменён.",
		 "Информация");
		Возврат Истина;
	КонецЕсли;
	
	Пока Истина Цикл  
		ПринятьСообщениеЧерезRabbitMQ(ДопПараметры);    
		МаркировкаКС.Пауза(ПаузаМеждуПовторами);
	КонецЦикла;                                     
		
КонецФункции

// Обрабатывает входящие сообщения Из очереди RabbitMQ с прочитанным статусом.
//
// Возвращаемое значение:
//   Структура:
//     * Успех - Булево - Истина, Если все сообщения обработаны успешно
//     * Ошибки - Массив Из Строка - описания ошибок при обработке сообщений
//     * Данные - Неопределено - зарезервированное свойство для расширения
Функция ОбработатьДанныеРСДокФлоу_СообщенияОбмена() Экспорт      
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	СтруктураВозврата.Данные = Неопределено;
	
	Запрос = Новый запрос;
	Запрос.УстановитьПараметр("Прочитано", Перечисления.СтатусыСообщенийИзRabbit.Прочитано);
	Запрос.Текст = "ВЫБРАТЬ
	|	ДокФлоу_СообщенияОбмена.ВходящийТекст КАК ВходящийТекст,
	|	ДокФлоу_СообщенияОбмена.ИдентификаторЗаписи КАК ИдентификаторЗаписи,
	|	ДокФлоу_СообщенияОбмена.ИдентификаторДокумента КАК ИдентификаторДокумента,
	|	ДокФлоу_СообщенияОбмена.ЗначениеВ1С КАК ЗначениеВ1С
	|ИЗ
	|	РегистрСведений.ДокФлоу_СообщенияОбмена КАК ДокФлоу_СообщенияОбмена
	|ГДЕ
	|	ДокФлоу_СообщенияОбмена.СтатусСообщения = &Прочитано";
	
	Выборка = Запрос.Выполнить().Выбрать();   
	
	Пока Выборка.Следующий() Цикл
		
		ДопПараметры = Новый Структура("ИдентификаторЗаписи", Выборка.ИдентификаторЗаписи);
		Результат = ПрочитатьИОбработатьВходящийJSON(Выборка.ВходящийТекст, ДопПараметры);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		КонецЕсли;
		
	КонецЦикла;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;                  
	
	Возврат СтруктураВозврата;   
	
КонецФункции

// Читает входящий JSON, преобразует его в структуру И выполняет обработку данных.
// 
// Параметры:
//  Текст - Строка - Текст
//  ДопПараметры - Неопределено, Структура - Доп параметры
// 
// Возвращаемое значение:
//  Структура - Прочитать И обработать входящий JSON:
// * Успех - Булево - 
// * Ошибки - Массив Из Строка - 
// * Данные - Структура, Неопределено -  
Функция ПрочитатьИОбработатьВходящийJSON(Текст, ДопПараметры = Неопределено) Экспорт 
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки = Ложь;
	СтруктураДанных = Неопределено;
	СтруктураВозврата.Данные = Новый Структура("IDДокумента,Документ", "", Неопределено);
	ЗаписатьВЛог("РаботаСДокФлоу", СтрШаблон("Начало загрузки док флоу"), "Информация");
	
	ИдентификаторЗаписи = Неопределено;
	
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда
		Если ДопПараметры.Свойство("ИдентификаторЗаписи") Тогда
			ИдентификаторЗаписи = ДопПараметры.ИдентификаторЗаписи;
		КонецЕсли;
	КонецЕсли;
	
	Результат = СформироватьСтруктуруДанныхИзТекста(Текст);
	
	Если Не Результат.Успех Тогда
		СтруктураВозврата.Ошибки.Добавить("Не удалось прочитать файл");
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);	
		Результат = СформироватьСтруктуруДанныхИзТекстаПострочно(Текст);
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);		
		ЕстьОшибки = Истина;
	Иначе
		СтруктураДанных			= Результат.Данные;
	КонецЕсли;
	
	Если Не ТипЗнч(СтруктураДанных) = Тип("Структура") Тогда
		СтруктураВозврата.Ошибки.Добавить("В файле передана некорректная информация");
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если Не ЕстьОшибки Тогда
		Если СтруктураДанных.Свойство("documentID") Тогда
			СтруктураВозврата.Данные.IDДокумента = СтруктураДанных.documentID;
		Иначе
			СтруктураВозврата.Данные.IDДокумента = "";
		КонецЕсли;
		
		Результат = ПолучитьТипЗагружаемогоДокумента(СтруктураДанных);
		Если Результат.Успех Тогда
			ТипДокумента = Результат.Данные;
		Иначе
			СтруктураВозврата.Ошибки.Добавить("Не удалось определить тип загружаемого документа");
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		КонецЕсли;     
	КонецЕсли;
	
	Если Не ЕстьОшибки Тогда
		Результат = ВалидироватьСтруктуруДанных(СтруктураДанных, ТипДокумента);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;
		Иначе
			СтруктураДанных = Результат.Данные;
		КонецЕсли;
	КонецЕсли;   
	
	ЗаписанныйДокумент = Неопределено;
	
	Если Не ЕстьОшибки Тогда       	
		Результат = ЗаписатьПолученныеДанныеВ1С(СтруктураДанных);
		
		ПараметрыЗаписиРС = Новый Структура;
		ПараметрыЗаписиРС.Вставить("ИдентификаторДокумента", СтруктураВозврата.Данные.IDДокумента);
		ПараметрыЗаписиРС.Вставить("ВходящийТекст", Текст);
		Если ИдентификаторЗаписи <> Неопределено Тогда
			ПараметрыЗаписиРС.Вставить("ИдентификаторЗаписи", ИдентификаторЗаписи);
		КонецЕсли;
		ПараметрыЗаписиРС.Вставить("ОтправленоПодтверждениеОЗаписи", Ложь); 
		// Кухарь А.Ю.  26.06.2026 начало
		// Изменение 0000000204
		ПараметрыЗаписиРС.Вставить("ИмяОбъекта", ТипДокумента); 
		// Кухарь А.Ю.  26.06.2026 конец
		
		Если Не Результат.Успех Тогда                  		
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;		
			ПараметрыЗаписиРС.Вставить("ДанныеЗаписаныВ1С", Ложь);
			ПараметрыЗаписиРС.Вставить("СтатусСообщения", Перечисления.СтатусыСообщенийИзRabbit.ОшибкаЗаписи1С);
			ПараметрыЗаписиРС.Вставить("ЕстьОшибки", Истина);
			ПараметрыЗаписиРС.Вставить("ТекстСообщений", СтрСоединить(Результат.Ошибки, ", "));			
			
			Результат = ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);   			
		Иначе    		
			ЗаписанныйДокумент = Результат.Данные;
			ПараметрыЗаписиРС.Вставить("ДанныеЗаписаныВ1С", Истина);
			ПараметрыЗаписиРС.Вставить("СтатусСообщения", Перечисления.СтатусыСообщенийИзRabbit.ЗаписаноВ1С);
			ПараметрыЗаписиРС.Вставить("ЕстьОшибки", Ложь);         
			ПараметрыЗаписиРС.Вставить("ЗначениеВ1С", ЗаписанныйДокумент);    		 

			Результат = ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);
			СтруктураВозврата.Данные.Документ = ЗаписанныйДокумент;
		КонецЕсли;      
		
	Иначе		
		ПараметрыЗаписиРС = Новый Структура;
		ПараметрыЗаписиРС.Вставить("ИдентификаторДокумента", СтруктураВозврата.Данные.IDДокумента);
		ПараметрыЗаписиРС.Вставить("ВходящийТекст", Текст);
		Если ИдентификаторЗаписи <> Неопределено Тогда
			ПараметрыЗаписиРС.Вставить("ИдентификаторЗаписи", ИдентификаторЗаписи);
		КонецЕсли;
		ПараметрыЗаписиРС.Вставить("ОтправленоПодтверждениеОЗаписи", Ложь);
		ПараметрыЗаписиРС.Вставить("ДанныеЗаписаныВ1С", Ложь);
		ПараметрыЗаписиРС.Вставить("СтатусСообщения", Перечисления.СтатусыСообщенийИзRabbit.ОшибкаЗаписи1С);
		ПараметрыЗаписиРС.Вставить("ЕстьОшибки", Истина);
		ПараметрыЗаписиРС.Вставить("ТекстСообщений", СтрСоединить(СтруктураВозврата.Ошибки, ", "));
		// Кухарь А.Ю.  26.06.2026 начало
		// Изменение 0000000204
		ПараметрыЗаписиРС.Вставить("ИмяОбъекта", ТипДокумента); 
		// Кухарь А.Ю.  26.06.2026 конец
		
		Результат = ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);   	
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
		ЗаписатьВЛог("РаботаСДокФлоу", СтрШаблон("Неуспешное завершение загрузки док флоу. Ошибки: %1", 
		СтрСоединить(СтруктураВозврата.Ошибки, ", ")), "Информация");
	Иначе
		ЗаписатьВЛог("РаботаСДокФлоу", СтрШаблон("Успешное завершение загрузки док флоу. Записан объект: %1",
		ЗаписанныйДокумент), "Информация");
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОповещенияИЛогирования

// Проверяет наличие активных фоновых заданий обмена с RabbitMQ
//
// Возвращаемое значение:
//   Булево - Истина если есть активные фоновые задания обмена RabbitMQ, иначе Ложь
Функция ЕстьЗапущенныеЗаданияОбменаRabbit()  Экспорт   
	
	Результат = Ложь;
		
	ТекущееФЗ = ПолучитьТекущийСеансИнформационнойБазы().ПолучитьФоновоеЗадание();
	Наименование = "ДокФлоу_Сервер.ЗапуститьБесконечныйЦиклПриемкиСообщенийЧерезRabbitMQ";
	
	Для Каждого ФЗ Из ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Наименование,Состояние", Наименование, СостояниеФоновогоЗадания.Активно)) Цикл
		Если ТипЗнч(ТекущееФЗ) = Тип("ФоновоеЗадание") И ФЗ.УникальныйИдентификатор = ТекущееФЗ.УникальныйИдентификатор Тогда
		ИначеЕсли ФЗ.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			Результат = Истина;		
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Метод = "ДокФлоу_Сервер.ОбменДокФлоу";	
	
	Для Каждого ФЗ Из ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("ИмяМетода,Состояние",
	 Метод, СостояниеФоновогоЗадания.Активно)) Цикл
	 	
		Если ТипЗнч(ТекущееФЗ) = Тип("ФоновоеЗадание") 
		И ФЗ.УникальныйИдентификатор = ТекущееФЗ.УникальныйИдентификатор Тогда
			
			Продолжить;
			
		ИначеЕсли ФЗ.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			
			Результат = Истина;		
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;  
	
КонецФункции    

#КонецОбласти

#Область ОбработкаСтруктурыТекста

Функция ВалидироватьСтруктуруДанных(СтруктураДанныхИзФайла, ТипДокумента)   	
	
	СтруктураВозврата  = ПолучитьСтруктуруВозврата();
	
	ТаблицаЗаполняемыхПолей = ПолучитьТаблицуЗаполняемыхПолейШапки(ТипДокумента);
	СтруктураДокумента = Новый Структура("ТипДокумента", ТипДокумента);
	
	Для Каждого СтрокаТаблицыПолей Из ТаблицаЗаполняемыхПолей Цикл
		НайденноеЗначение = Неопределено;
		ЕстьОшибкиПоиска  = Ложь;
		
		Если Не СтруктураДанныхИзФайла.Свойство(СтрокаТаблицыПолей.ИмяТэгаВФайле) Тогда
			Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон("В тексте отсутствует обязательное поле %1",
				СтрокаТаблицыПолей.ИмяТэгаВФайле));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		ЗначениеПоляСтруктуры = СтруктураДанныхИзФайла[СтрокаТаблицыПолей.ИмяТэгаВФайле];
		
		ТипЗначФайлаОжидаемый		 = ТипЗнч(СтрокаТаблицыПолей.ПустоеЗначениеПоляФайла);
		ТипЗначФайлаФакт			 = ТипЗнч(ЗначениеПоляСтруктуры);
		ТипЗнач1СОжидаемый			 = ТипЗнч(СтрокаТаблицыПолей.ПустоеЗначениеПоля1С);
		
		Если ТипЗначФайлаФакт <> ТипЗначФайлаОжидаемый Тогда
			Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
				"В тэге %1 передано поле неправильного типа, переданный тип - %2, ожидаемый тип - %3",
				СтрокаТаблицыПолей.ИмяТэгаВФайле, ТипЗначФайлаФакт, ТипЗначФайлаОжидаемый));
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаТаблицыПолей.ЯвноУказатьАлгоритмПоиска Тогда
			//@skip-check query-in-loop
			Результат = ОбработатьЗаполнениеНеТиповогоПоля(СтрокаТаблицыПолей.ИмяТэгаВФайле, ЗначениеПоляСтруктуры,
			ТипДокумента);
			
			Если Не Результат.Успех Тогда
				Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
					МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
				КонецЕсли;
				ЕстьОшибкиПоиска = Истина;
				НайденноеЗначение  = Неопределено;			
			Иначе
				НайденноеЗначение = Результат.Данные;
			КонецЕсли;
		КонецЕсли;
		
		Если НайденноеЗначение = Неопределено И Не ЕстьОшибкиПоиска Тогда
			Результат = ВыполнитьПреобразованиеПростыхТипов(ТипЗначФайлаФакт, ТипЗнач1СОжидаемый, ЗначениеПоляСтруктуры,
			СтрокаТаблицыПолей.ИмяТэгаВФайле);
			Если Не Результат.Успех Тогда
				Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
					МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
					Продолжить;
				КонецЕсли;
			Иначе
				НайденноеЗначение = Результат.Данные;
			КонецЕсли;
		КонецЕсли;
		
		Если НайденноеЗначение <> Неопределено Тогда
			Если ТипЗнач1СОжидаемый = Тип("Строка") И ТипЗнч(НайденноеЗначение) = Тип("Строка") Тогда
				  
				// Кухарь А.Ю.  26.06.2026 начало
				// Изменение 0000000204
				Если ТипДокумента = "ЗаявкаНаОплату" Тогда 
					ДлиннаСтрокиРеквизитаДокумента = Метаданные.Документы[ТипДокумента].Реквизиты[СтрокаТаблицыПолей.НаименованиеРеквизита1С].Тип.КвалификаторыСтроки.Длина;      
				Иначе 
					Если СтрокаТаблицыПолей.НаименованиеРеквизита1С = "Код" или СтрокаТаблицыПолей.НаименованиеРеквизита1С = "Наименование" Тогда
						ДлиннаСтрокиРеквизитаДокумента = Метаданные.Справочники[ТипДокумента].СтандартныеРеквизиты[СтрокаТаблицыПолей.НаименованиеРеквизита1С].Тип.КвалификаторыСтроки.Длина; 	
					Иначе					 
						Если  ЕстьРеквизитДокумента(СтрокаТаблицыПолей.НаименованиеРеквизита1С,Метаданные.Справочники[ТипДокумента]) Тогда
							ДлиннаСтрокиРеквизитаДокумента = Метаданные.Справочники[ТипДокумента].Реквизиты[СтрокаТаблицыПолей.НаименованиеРеквизита1С].Тип.КвалификаторыСтроки.Длина;  
						Иначе       
							ДлиннаСтрокиРеквизитаДокумента = СтрДлина(НайденноеЗначение)
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				// Кухарь А.Ю.  26.06.2026 конец
				
				Если ДлиннаСтрокиРеквизитаДокумента > 0 И СтрДлина(НайденноеЗначение) > ДлиннаСтрокиРеквизитаДокумента Тогда
					Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
						СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
						"В тэге %1 передано слишком длинное значение %2, максимальная длина строка - %3",
						СтрокаТаблицыПолей.ИмяТэгаВФайле, НайденноеЗначение, ДлиннаСтрокиРеквизитаДокумента));
					КонецЕсли;
					НайденноеЗначение = Неопределено;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если НайденноеЗначение <> Неопределено Тогда
			СтруктураДокумента.Вставить(СтрокаТаблицыПолей.НаименованиеРеквизита1С, НайденноеЗначение);
		КонецЕсли;
		
	КонецЦикла;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	Иначе
		СтруктураВозврата.Данные = СтруктураДокумента;
	КонецЕсли;              
	
	Возврат СтруктураВозврата;  
	
КонецФункции

Функция ОбработатьЗаполнениеНеТиповогоПоля(ИмяТэгаВФайле, ЗначениеРеквизитаПоиска, ТипДокумента)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	Запрос = Новый запрос;
	Запрос.УстановитьПараметр("ЗначениеРеквизитаПоиска", ЗначениеРеквизитаПоиска);
	НужноВыполнитьЗапрос = Истина;
	НайденноеЗначение	 = Неопределено;
	
	Если ИмяТэгаВФайле = "innOrganization" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Организации КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.ИНН = &ЗначениеРеквизитаПоиска
		|	И Спр.ОрганизацияНашейКомпании"; 
	ИначеЕсли ИмяТэгаВФайле = "innSupplier" Тогда
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Контрагенты КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И Спр.ИНН = &ЗначениеРеквизитаПоиска
		|	И Спр.Владелец = &Владелец"; 
		запрос.УстановитьПараметр("Владелец",Справочники.ИБ.НайтиПоКоду("SSP")); //КолготкиМосква
	ИначеЕсли ИмяТэгаВФайле = "CounteragentPaymentAccountCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.БанковскиеСчета КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска
		|	И Спр.Код <> """""; 		
	ИначеЕсли ИмяТэгаВФайле = "authorCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Пользователи КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "organisationPaymentAccountCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.БанковскиеСчета КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "contractCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Договоры КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "departmentCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Подразделения КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "itemCostsCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.СтатьиЗатрат КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";    
	ИначеЕсли ИмяТэгаВФайле = "itemSubСostsCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.СубЗатраты КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "projectCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Проекты КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";   
		// Кухарь А.Ю.  26.06.2026 начало
		// Изменение 0000000204
	ИначеЕсли ИмяТэгаВФайле = "salesChannelCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.КаналСбыта КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	ИначеЕсли ИмяТэгаВФайле = "ownerCode" или 
		ИмяТэгаВФайле = "counteragentCode"  Тогда 
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Контрагенты КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска
		|	И НЕ Спр.ЭтоГруппа";	
	ИначеЕсли ИмяТэгаВФайле = "serviceType" Тогда 
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.ВидыДоговоров КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска
		|	И НЕ Спр.ЭтоГруппа";				
	ИначеЕсли ИмяТэгаВФайле = "bankCode" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.Банки КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Код = &ЗначениеРеквизитаПоиска";
	
	ИначеЕсли ИмяТэгаВФайле = "country" Тогда
		Запрос.Текст = "ВЫБРАТЬ первые 1
		|	Спр.Ссылка КАК НайденноеЗначение
		|ИЗ
		|	Справочник.КлассификаторСтранМира КАК Спр
		|ГДЕ
		|	не Спр.ПометкаУдаления
		|	И Спр.Наименование = &ЗначениеРеквизитаПоиска";    			
	ИначеЕсли ИмяТэгаВФайле = "VATRate" Тогда
		НужноВыполнитьЗапрос = Ложь;
		НайденноеЗначение = СтавкаНДСПоПроценту(ЗначениеРеквизитаПоиска);
		Если НайденноеЗначение <> Неопределено Тогда
			СтруктураВозврата.Данные = НайденноеЗначение;
		Иначе
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
			"В тэге %1 передано значение %2, по которому ничего Не нашлось в 1С. ", ИмяТэгаВФайле,
			ЗначениеРеквизитаПоиска));
		КонецЕсли;
	ИначеЕсли ИмяТэгаВФайле = "Expenses" Тогда
		НужноВыполнитьЗапрос = Ложь;		
		Результат = ЗаполнитьСтрокиТЧ(ИмяТэгаВФайле, ЗначениеРеквизитаПоиска, ТипДокумента);
		Если Не Результат.Успех Тогда
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			НайденноеЗначение = Неопределено;
		Иначе
			НайденноеЗначение = Результат.Данные;
			СтруктураВозврата.Данные =  Результат.Данные;
		КонецЕсли;
	КонецЕсли;
	
	Если НужноВыполнитьЗапрос Тогда
		Выборка = запрос.Выполнить().Выбрать();
		Если Выборка.Количество() = 0 Тогда
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
			"В тэге %1 передано значение %2, по которому ничего Не нашлось в 1С", ИмяТэгаВФайле,
			ЗначениеРеквизитаПоиска));
		КонецЕсли;
		
		Пока Выборка.Следующий() Цикл
			СтруктураВозврата.Данные = Выборка.НайденноеЗначение;
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции
 
Процедура ДобавитьСтрокуТаблицыЗаполняемыхПолей(ТаблицаПолей, ИмяТэгаВФайле, ПустоеЗначениеПоляФайла,
	ПустоеЗначениеПоля1С, НаименованиеРеквизита1С, ЯвноУказатьАлгоритмПоиска, ОбязательноеПоле)
	
	СтрокаТЗ = ТаблицаПолей.Добавить();
	СтрокаТЗ.ИмяТэгаВФайле = ИмяТэгаВФайле;
	СтрокаТЗ.ПустоеЗначениеПоляФайла = ПустоеЗначениеПоляФайла;
	СтрокаТЗ.ПустоеЗначениеПоля1С = ПустоеЗначениеПоля1С;
	СтрокаТЗ.НаименованиеРеквизита1С = НаименованиеРеквизита1С;
	СтрокаТЗ.ЯвноУказатьАлгоритмПоиска = ЯвноУказатьАлгоритмПоиска;
	СтрокаТЗ.ОбязательноеПоле = ОбязательноеПоле;
	
КонецПроцедуры

Функция ВыполнитьПреобразованиеПростыхТипов(ТипЗначФайлаФакт, ТипЗнач1СОжидаемый,
	 ЗначениеПоляСтруктуры, ИмяТэгаВФайле)
	
	СтруктураВозврата  = ПолучитьСтруктуруВозврата();
	Если ТипЗначФайлаФакт <> ТипЗнач1СОжидаемый Тогда
		Если ТипЗнач1СОжидаемый = Тип("Число") Тогда
			Попытка
				НайденноеЗначение = Число(ЗначениеПоляСтруктуры);
			Исключение
				НайденноеЗначение = Неопределено;
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
				"В тэге %1 передано значение %2, которое Не удалось преобразовать к число", ИмяТэгаВФайле,
				ЗначениеПоляСтруктуры));
			КонецПопытки;
		ИначеЕсли ТипЗнач1СОжидаемый = Тип("Строка") Тогда
			Попытка
				НайденноеЗначение = Строка(ЗначениеПоляСтруктуры);
			Исключение
				НайденноеЗначение = Неопределено;
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
				"В тэге %1 передано значение, которое Не удалось преобразовать к строке", ИмяТэгаВФайле));
			КонецПопытки;
		ИначеЕсли ТипЗнач1СОжидаемый = Тип("Дата") Тогда
			Попытка
				НайденноеЗначение = Дата(ЗначениеПоляСтруктуры);
			Исключение
				НайденноеЗначение = Неопределено;
				СтруктураВозврата.Ошибки.Добавить(СтрШаблон("В тэге %1 передано значение %2, 
				|которое Не удалось преобразовать к дате", ИмяТэгаВФайле,
				ЗначениеПоляСтруктуры));
			КонецПопытки;
			
		КонецЕсли;
	Иначе
		НайденноеЗначение =  ЗначениеПоляСтруктуры;
	КонецЕсли;
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
		СтруктураВозврата.Данные = Неопределено;
		
	Иначе
		СтруктураВозврата.Данные = НайденноеЗначение;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ЗаполнитьСтрокиТЧ(ИмяТэгаВФайле, ЗначениеРеквизитаПоиска, ТипДокумента)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ТаблицаПолейТЧ = ПолучитьТаблицуЗаполняемыхПолейТЧ(ТипДокумента, "РасшифровкиЗатрат");
	МассивСтруктур = Новый Массив;
	Счетчик = 0;
	Для Каждого СтрокаМассива Из ЗначениеРеквизитаПоиска Цикл
		Счетчик = Счетчик + 1;
		ВСтрокеЕстьОшибка = Ложь;
		НачалоОшибкиПоСтроке = СтрШаблон("Ошибка в массиве %1, строка %2. ", ИмяТэгаВФайле, Счетчик);
		МассивОшибокТекущейСтроки = Новый Массив;
		СтруктураТекущейСтроки = Новый Структура;
		
		Для Каждого СтрокаТаблицыПолей Из ТаблицаПолейТЧ Цикл
			НайденноеЗначение = Неопределено;
			
			Если Не СтрокаМассива.Свойство(СтрокаТаблицыПолей.ИмяТэгаВФайле) Тогда
				Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
					МассивОшибокТекущейСтроки.Добавить(СтрШаблон("В тексте отсутствует обязательное поле %1",
					СтрокаТаблицыПолей.ИмяТэгаВФайле));
					ВСтрокеЕстьОшибка = Истина;
				КонецЕсли;
			КонецЕсли;
			
			Если Не ВСтрокеЕстьОшибка Тогда
				ЗначениеПоляСтруктуры = СтрокаМассива[СтрокаТаблицыПолей.ИмяТэгаВФайле];
				ТипЗначФайлаОжидаемый		 = ТипЗнч(СтрокаТаблицыПолей.ПустоеЗначениеПоляФайла);
				ТипЗначФайлаФакт			 = ТипЗнч(ЗначениеПоляСтруктуры);
				ТипЗнач1СОжидаемый			 = ТипЗнч(СтрокаТаблицыПолей.ПустоеЗначениеПоля1С);
				
				Если ТипЗначФайлаФакт <> ТипЗначФайлаОжидаемый Тогда
					Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
						МассивОшибокТекущейСтроки.Добавить(СтрШаблон("В тэге %1 
						|передано поле неправильного типа, переданный тип - %2, ожидаемый тип - %3",
						СтрокаТаблицыПолей.ИмяТэгаВФайле, ТипЗначФайлаФакт, ТипЗначФайлаОжидаемый));
						ВСтрокеЕстьОшибка = Истина;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если Не ВСтрокеЕстьОшибка Тогда
				Если СтрокаТаблицыПолей.ЯвноУказатьАлгоритмПоиска Тогда
					//@skip-check query-in-loop
					Результат = ОбработатьЗаполнениеНеТиповогоПоля(СтрокаТаблицыПолей.ИмяТэгаВФайле,
					ЗначениеПоляСтруктуры, ТипДокумента);
					Если Не Результат.Успех Тогда
						Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
							МассивОшибокТекущейСтроки.Добавить(СтрСоединить(Результат.Ошибки, ", "));
							ВСтрокеЕстьОшибка = Истина;
						КонецЕсли;
					Иначе
						НайденноеЗначение = Результат.Данные;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если Не ВСтрокеЕстьОшибка И НайденноеЗначение = Неопределено Тогда
				Если НайденноеЗначение = Неопределено Тогда
					Результат = ВыполнитьПреобразованиеПростыхТипов(ТипЗначФайлаФакт, ТипЗнач1СОжидаемый,
					ЗначениеПоляСтруктуры, СтрокаТаблицыПолей.ИмяТэгаВФайле);
					Если Не Результат.Успех Тогда
						Если СтрокаТаблицыПолей.ОбязательноеПоле Тогда
							МассивОшибокТекущейСтроки.Добавить(СтрСоединить(Результат.Ошибки, ", "));
							ВСтрокеЕстьОшибка = Истина;
						КонецЕсли;
					Иначе
						НайденноеЗначение = Результат.Данные;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если Не ВСтрокеЕстьОшибка Тогда
				СтруктураТекущейСтроки.Вставить(СтрокаТаблицыПолей.НаименованиеРеквизита1С, НайденноеЗначение);
			Иначе
				СтруктураВозврата.Ошибки.добавить(НачалоОшибкиПоСтроке + 
				СтрСоединить(МассивОшибокТекущейСтроки, ", "));
			КонецЕсли;		
		КонецЦикла;
		
		Если Не ВСтрокеЕстьОшибка Тогда
			МассивСтруктур.Добавить(СтруктураТекущейСтроки);
		КонецЕсли;
	КонецЦикла;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех  = Ложь;
		СтруктураВозврата.Данные = Неопределено;
	Иначе
		СтруктураВозврата.Данные = МассивСтруктур;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ПолучитьТипЗагружаемогоДокумента(СтруктураДанных)
	
	ИмяСвойстваТипаДокумента = "documentType";
	СтруктураВозврата = ПолучитьСтруктуруВозврата();   
	      
	Если СтруктураДанных.Свойство(ИмяСвойстваТипаДокумента) Тогда
		ТипДокумента = СтруктураДанных.documentType;
		
		Если ОбщегоНазначения_ПИ.ДокументСуществует(ТипДокумента) 
		или ОбщегоНазначения_ПИ.СправочникСуществует(ТипДокумента) Тогда
			
			СтруктураВозврата.Данные = ТипДокумента;		
		Иначе		
			СтруктураВозврата.Ошибки.Добавить(СтрШаблон(
			"В свойстве %1 передан отсутствующий в конфигурации объект - %2", ИмяСвойстваТипаДокумента,
			ТипДокумента));
			
		КонецЕсли;	
	Иначе		
		СтруктураВозврата.Ошибки.Добавить(СтрШаблон("Не передано свойство %1", ИмяСвойстваТипаДокумента));		
	КонецЕсли;
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

