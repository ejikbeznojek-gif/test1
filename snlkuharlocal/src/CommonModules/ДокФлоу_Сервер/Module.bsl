Функция СформироватьСтруктуруДанныхИзТекста(Текст)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Текст);
	Попытка
		СтруктураВозврата.Данные = ПрочитатьJSON(ЧтениеJSON, Ложь);
	Исключение
		СтруктураВозврата.Ошибки.Добавить(ОписаниеОшибки());
	КонецПопытки;
	
	ЧтениеJSON.Закрыть();
	Возврат СтруктураВозврата
	
КонецФункции  

Функция СформироватьСтруктуруДанныхИзТекстаПострочно(Текст)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
