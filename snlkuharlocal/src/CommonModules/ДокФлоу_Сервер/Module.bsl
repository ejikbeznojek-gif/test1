		// Кухарь А.Ю.  26.06.2026 начало
		// Изменение 0000000204
		Результат = ОбщегоНазначения_ПИ.ПолучитьИмяИсходящейОчередиДокФлоуПоИмениОбъекта(Выборка.ИмяОбъекта);
		Если Не Результат.Успешно Тогда 
			МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
			ЕстьОшибки = Истина;	
		Иначе
			ИмяОчереди = Результат.Данные;
		КонецЕсли;		
		
		Если Не ЕстьОшибки Тогда 
			// Кухарь А.Ю.  26.06.2026 конец

			Попытка     
				ЕстьОшибкаКомпоненты = Ложь;
				// Кухарь А.Ю.  26.06.2026 начало
