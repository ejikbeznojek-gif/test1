Функция ПрочитатьСообщенияRabbitMQ(СтруктураАвторизации)   
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки = Ложь;

	// Кухарь А.Ю.  26.06.2026 начало
	// Изменение 0000000204
	Результат = ОбщегоНазначения_ПИ.ПолучитьМассивИменВходящихОчередейДокФлоу();  
	Если Результат.Успешно Тогда
		МассивОчередей = Результат.Данные;
	Иначе 
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;	
	// Кухарь А.Ю.  26.06.2026 конец
	
	Если Не ЕстьОшибки Тогда                
		// Кухарь А.Ю.  26.06.2026 начало
		// Изменение 0000000204
		Для Каждого ИмяОчереди Из МассивОчередей Цикл  
			// Кухарь А.Ю.  26.06.2026 конец
			Результат = ИнициализироватьКомпонентуНаПрием(СтруктураАвторизации,Истина);
			Если Не Результат.Успех Тогда   
				МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
				ЕстьОшибки = Истина;
			Иначе
				КомпонентаОбмена = Результат.Данные;
			КонецЕсли;
			
			Если ЕстьОшибки Тогда
				Продолжить;
			КонецЕсли;			
			
			Попытка     
				ЕстьОшибкаКомпоненты = Ложь;				
				КомпонентаОбмена.НачатьПриемСообщений(ИмяОчереди);  
			Исключение
				ЕстьОшибкаКомпоненты = Истина;
				ОшибкаКомпоненты = ОписаниеОшибки();
			КонецПопытки;   
			
			Если ЕстьОшибкаКомпоненты Тогда
				ПолныйТекстСообщения = СтрШаблон("Не удалось начать приём сообщений. Ошибка: %1",ОшибкаКомпоненты);  
				ЗаписатьВЛог("Ошибки", ПолныйТекстСообщения, "Информация");	   
				СтруктураВозврата.Ошибки.Добавить(ПолныйТекстСообщения);
				СтруктураВозврата.Успех = Ложь;
				Возврат СтруктураВозврата;
			КонецЕсли;	 				
			
			СтруктураПараметровЧтения = Новый Структура("КомпонентаОбмена", КомпонентаОбмена);
			
			Пока Истина Цикл	
				Результат = ПрочитатьТекущееСообщениеRabbitMQ(СтруктураПараметровЧтения);
				Если Результат.Успех Тогда
					ЧтениеСообщенийЗавершено = Результат.Данные;
				Иначе
					МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
					ЕстьОшибки = Истина;
					Прервать;
				КонецЕсли;
				
				Если ЧтениеСообщенийЗавершено Тогда
					Прервать;
				КонецЕсли;  		
			КонецЦикла;      
			
			// Кухарь А.Ю.  26.06.2026 начало
			// Изменение 0000000204
		КонецЦикла;
		// Кухарь А.Ю.  26.06.2026 конец
		
	КонецЕсли;	 
	
	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успех = Ложь;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ОтправитьОтветОбработкиСообщенийВRabbitMQ(СтруктураАвторизации)
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	ЕстьОшибки = Ложь;
	
	Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка"); 

	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;
	
	Если КомпонентаОбмена = Неопределено Тогда
		ОбновитьПовторноИспользуемыеЗначения();
		Результат = ОбщегоНазначения_ПИ.ПодключитьКомпонентуRabbitMQ_ПИ("Отправка");
	КонецЕсли;
	
	Если Не Результат.Успех Тогда
		МаркировкаКС.ДобавитьОшибки(СтруктураВозврата, Результат);
		ЕстьОшибки = Истина;
	КонецЕсли;
	
	Если ЕстьОшибки Тогда
		СтруктураВозврата.Успех = Ложь;
		Возврат СтруктураВозврата;
	Иначе
		КомпонентаОбмена = Результат.Данные;
	КонецЕсли;  
	
	Попытка
		КомпонентаОбмена.УстановитьСоединение(СтруктураАвторизации.Хост, СтруктураАвторизации.Логин,
		СтруктураАвторизации.Пароль);
	Исключение
		ЕстьОшибки = Истина;
		СтруктураВозврата.Ошибки.Добавить(ОписаниеОшибки());
	КонецПопытки;
		
	Запрос = Новый запрос;
	МассивСтатусовКОтправке = Новый Массив;
	МассивСтатусовКОтправке.Добавить(Перечисления.СтатусыСообщенийИзRabbit.ОшибкаЗаписи1С);
	МассивСтатусовКОтправке.Добавить(Перечисления.СтатусыСообщенийИзRabbit.ЗаписаноВ1С);
	
	Запрос.УстановитьПараметр("МассивСтатусовКОтправке", МассивСтатусовКОтправке);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДокФлоу_СообщенияОбмена.ВходящийТекст КАК ВходящийТекст,
	               |	ДокФлоу_СообщенияОбмена.ИдентификаторЗаписи КАК ИдентификаторЗаписи,
	               |	ДокФлоу_СообщенияОбмена.ИдентификаторДокумента КАК ИдентификаторДокумента,
	               |	ДокФлоу_СообщенияОбмена.СтатусСообщения КАК СтатусСообщения,
	               |	ДокФлоу_СообщенияОбмена.ТекстСообщений КАК ТекстСообщений,
	               |	ДокФлоу_СообщенияОбмена.ЗначениеВ1С КАК ЗначениеВ1С,
	               |	ДокФлоу_СообщенияОбмена.ИмяОбъекта КАК ИмяОбъекта
	               |ИЗ
	               |	РегистрСведений.ДокФлоу_СообщенияОбмена КАК ДокФлоу_СообщенияОбмена
	               |ГДЕ
	               |	ДокФлоу_СообщенияОбмена.СтатусСообщения В(&МассивСтатусовКОтправке)";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл     
		
		ЕстьОшибки = Ложь;
				
		СтруктураСтроки = Новый Структура("id, success, error", "", Ложь, "", "");
		СтруктураСтроки.Вставить("inputText", "");
		
		ДанныеЗаписаныВ1С = Ложь;
		Если ЗначениеЗаполнено(Выборка.ИдентификаторДокумента) Тогда
			Если Выборка.СтатусСообщения = Перечисления.СтатусыСообщенийИзRabbit.ОшибкаЗаписи1С Тогда
				СтруктураСтроки.id = Выборка.ИдентификаторДокумента;
				СтруктураСтроки.success = Ложь;
				СтруктураСтроки.error = Выборка.ТекстСообщений;
			Иначе
				ДанныеЗаписаныВ1С = Истина;
				СтруктураСтроки.id = Выборка.ИдентификаторДокумента;  
				//Кухарь А.Ю. 13.07.2026 начало                  
				//Если ЗначениеЗаполнено(Выборка.ЗначениеВ1С) И  ТипЗнч(Выборка.ЗначениеВ1С) = Тип("ДокументСсылка.ЗаявкаНаОплату") Тогда									
				Если ЗначениеЗаполнено(Выборка.ЗначениеВ1С) Тогда
					//Кухарь А.Ю. 13.07.2026 конец				
					Если ТипЗнч(Выборка.ЗначениеВ1С) = Тип("ДокументСсылка.ЗаявкаНаОплату") Тогда
						СтруктураСтроки.Вставить("code",ПолучитьРеквизитШапки(Выборка.ЗначениеВ1С, "Номер", "Документ"));  
					ИначеЕсли  ТипЗнч(Выборка.ЗначениеВ1С) = Тип("СправочникСсылка.Контрагенты") Тогда   
						РеквизитыШапки = ПолучитьРеквизитыШапки(Выборка.ЗначениеВ1С, "Код, Ведущий.Код", "Справочник"); 
                        СтруктураСтроки.Вставить("code", РеквизитыШапки.Код); 
                        СтруктураСтроки.Вставить("ownerCode", РеквизитыШапки.Ведущий_Код);						
				Иначе
						СтруктураСтроки.Вставить("code",ПолучитьРеквизитШапки(Выборка.ЗначениеВ1С, "Код", "Справочник")); 
					КонецЕсли;     
