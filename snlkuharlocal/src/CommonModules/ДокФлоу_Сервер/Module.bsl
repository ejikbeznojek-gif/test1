				ПараметрыЗаписиРС.Вставить("СтатусСообщения", Перечисления.СтатусыСообщенийИзRabbit.ПереданоПодтверждение);
				ПараметрыЗаписиРС.Вставить("ОтправленоПодтверждениеОЗаписи", Истина);
				ПараметрыЗаписиРС.Вставить("ИдентификаторЗаписи", Выборка.ИдентификаторЗаписи);
				ПараметрыЗаписиРС.Вставить("ВходящийТекст", Выборка.ВходящийТекст);
				ПараметрыЗаписиРС.Вставить("ЕстьОшибки", Не ДанныеЗаписаныВ1С);
				ПараметрыЗаписиРС.Вставить("ТекстСообщений", Выборка.ТекстСообщений);
				ПараметрыЗаписиРС.Вставить("ИдентификаторДокумента", Выборка.ИдентификаторДокумента); 
				ПараметрыЗаписиРС.Вставить("ЗначениеВ1С", Выборка.ЗначениеВ1С);    
				// Кухарь А.Ю.  26.06.2026 начало
				// Изменение 0000000204
				ПараметрыЗаписиРС.Вставить("ИмяОбъекта", Выборка.ИмяОбъекта);     
				// Кухарь А.Ю.  26.06.2026 конец
				
				Результат = ЗаписатьДанныеСообщенияИзRabbitВРегистр(ПараметрыЗаписиРС);
