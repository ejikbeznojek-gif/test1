//получение таблицы параметров регламентного задания по ключу
Функция ВернутьПараметрыРегламентногоЗадания(нужныйКлюч) Экспорт
	
	Отбор = Новый Структура;
	Отбор.Вставить("Ключ", нужныйКлюч);
				
	МоеРегЗадание=РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
    ТаблицаПараметров= МоеРегЗадание[0].Параметры[0];
	
	Возврат ТаблицаПараметров; 
	
КонецФункции
