Функция ПолучитьСтруктуруПериодическихРеквизитов(Вид) Экспорт
	ПериодическиеРеквизиты=Новый Структура;
	Для Каждого Реквизит Из Метаданные.Справочники[Вид].Реквизиты Цикл
		Если Найти(Реквизит.Комментарий,"(Периодический")<>0 Тогда
			ПериодическиеРеквизиты.Вставить(Реквизит.Имя);
		КонецЕсли;	
	КонецЦикла; 
	//крохин начало 12.03.2013
	//периодические ревизиты прописываем в коде, чтобы не плодить в справочнике
	Если Вид = "Номенклатура" тогда
	ПериодическиеРеквизиты.Вставить("Декларация");
    КонецЕсли;
    //крохин конец 12.03.2013

	Возврат ПериодическиеРеквизиты;
КонецФункции // ПолучитьПериодическиеРеквизиты()
//Данилова Е.В. 25.03.2025 добавлен параметр Дополнительные свойства
Процедура УстановитьРеквизитыОбъекта(СсылкаНаОбъект,Реквизиты,РежимЗаписи=Неопределено,РежимЗагрузки=Ложь,НеПроверятьДЗР=Ложь,ДополнительныеСвойстваОбъекта = неопределено) Экспорт
	Если РежимЗаписи=Неопределено Тогда
		РежимЗаписи=РежимЗаписиДокумента.Запись;	
	КонецЕсли;
	
	Объект=СсылкаНаОбъект.ПолучитьОбъект();	
	
	Если Объект=Неопределено Тогда Возврат КонецЕсли; 
	
	Попытка
	    Объект.мЗаписьБезКонтроля=Истина;		
	Исключение	
	КонецПопытки;
	Если НеПроверятьДЗР Тогда
		Объект.ДополнительныеСвойства.Вставить("НеПроверятьДЗР",Истина);		
	КонецЕсли; 
	
	Если РежимЗагрузки Тогда
		Объект.ОбменДанными.Загрузка=Истина;	
	КонецЕсли; 
	
	Для Каждого Элемент Из Реквизиты Цикл
		Если Объект[Элемент.Ключ]<>Элемент.Значение Тогда
			Объект[Элемент.Ключ]=Элемент.Значение;			
		КонецЕсли;		
	КонецЦикла;
	//++Данилова Е.В. 25.03.2025
	Если ДополнительныеСвойстваОбъекта <> неопределено
		И ТипЗнч(ДополнительныеСвойстваОбъекта) = Тип("Структура") Тогда
		
		Для каждого ДопСвойство  Из ДополнительныеСвойстваОбъекта Цикл
			
			Объект.ДополнительныеСвойства.Вставить(ДопСвойство.Ключ,ДопСвойство.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	//--Данилова Е.В. 25.03.2025
	
	Если Объект.Модифицированность() Тогда
		Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(СсылкаНаОбъект)) Тогда
			Объект.Записать(РежимЗаписи);
		Иначе
			Объект.Записать();		
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры


