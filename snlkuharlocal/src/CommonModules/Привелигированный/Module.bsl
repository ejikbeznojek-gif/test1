Функция УдалитьОбъектПоСсылке(Ссылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	Попытка	
		Ссылка.ПолучитьОбъект().Удалить();			
	Исключение	                            
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(ОписаниеОшибки());
	КонецПопытки;
	Возврат Результат;
КонецФункции //УдалитьОбъект(Ссылка) Экспорт
