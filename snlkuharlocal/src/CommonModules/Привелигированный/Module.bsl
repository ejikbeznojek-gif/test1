Процедура ЗаписатьДопИнфо (ВидИнфо,ЗначениеИнфо) Экспорт 
	ЗаписьВРег=РегистрыСведений.ДопИнфо.СоздатьНаборЗаписей();
	ЗаписьВРег.Отбор.ВидИнфо.Значение=ВидИнфо;
	ЗаписьВРег.Отбор.ВидИнфо.использование=истина;		
	ЗаписьВРег.Прочитать();
	ЗаписьВРег.Очистить();
	СтрЗаписей=ЗаписьВРег.Добавить();
	СтрЗаписей.ВидИнфо=ВидИнфо;
	СтрЗаписей.ЗначениеИнфо=ЗначениеИнфо;
	ЗаписьВРег.Записать();
	
	
КонецПроцедуры

Функция ПрочитатьДопИнфо (ВидИнфо) Экспорт
	ЗаписьВРег=РегистрыСведений.ДопИнфо.СоздатьНаборЗаписей();
	ЗаписьВРег.Отбор.ВидИнфо.Значение=ВидИнфо;
	ЗаписьВРег.Отбор.ВидИнфо.использование=истина;		
	ЗаписьВРег.Прочитать();
	для каждого СтрЗаписей из ЗаписьВРег цикл
		Возврат СтрЗаписей.ЗначениеИнфо;
	КонецЦикла;
	возврат "";
КонецФункции
