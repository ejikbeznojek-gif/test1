Функция УстановитьПериодическийРеквизит(Объект,ИмяРеквизита,Значение,Дата2,Документ=Неопределено) Экспорт
	Запись=РегистрыСведений.История.СоздатьМенеджерЗаписи();	
	
	Запись.Объект	=Объект;
	Запись.Реквизит	=ИмяРеквизита;
	Запись.Значение	=Значение;
	Запись.Период	=Дата2;
	Запись.Документ	=Документ;
	
	Запись.Записать();
КонецФункции // УстановитьПериодичесткийРеквизит()
 
Функция ПолучитьПериодическийРеквизит(Объект,ИмяРеквизита,Знач Дата2=Неопределено,КодИБ=Неопределено,ДатаРеквизита="",отбор=Неопределено) Экспорт
	Дата2=?(Дата2=Неопределено,ТекущаяДата(),Дата2);
	
	Запрос=Новый Запрос;
	Если КодИБ=Неопределено Тогда
		Запрос.Текст="
		|ВЫБРАТЬ
		|	Значение,Период
		|ИЗ
		|	РегистрСведений.История.СрезПоследних(&Дата2,Объект = &Объект И Реквизит = &Реквизит)
		|УПОРЯДОЧИТЬ ПО	Период УБЫВ";		
	Иначе
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Значение,Период
		|ИЗ
		|	РегистрСведений.История
		|ГДЕ 
		|	Объект = &Объект И Реквизит = &Реквизит И Период<=&Дата2 И Значение.Владелец.Код=&КодИБ	
		|УПОРЯДОЧИТЬ ПО	Период УБЫВ";			
		
		Запрос.УстановитьПараметр("КодИБ",КодИБ);
	КонецЕсли;
		
	Запрос.УстановитьПараметр("Дата2",КонецДня(Дата2));
	Запрос.УстановитьПараметр("Объект",Объект);
	Запрос.УстановитьПараметр("Реквизит",ИмяРеквизита);
	
	Выборка=Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		//Кухарь 18.11.16 начало
		//Для отбора
		//Функция ПолучитьГрупповойПериодическийРеквизит(Ссылка,ИмяРеквизита,Знач Дата2=Неопределено)	Экспорт
		если отбор<>Неопределено  тогда
			если Выборка.Значение.странапроисхождения<>Отбор.Страна тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		//Кухарь 18.11.16 конец
		
		ДатаРеквизита=Выборка.Период;
		Возврат Выборка.Значение;
	КонецЦикла; 
	
	Возврат Неопределено;
КонецФункции // ПолучитьпериодическийРеквизит()

