		ТекстОшибки = "Не найден ЗСБ по отгрузке комплектов %1 ";
		ТекстОшибки = СтрШаблон(ТекстОшибки,РНК); 
		Результат.ошибки.Добавить(ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

