Функция НайтиСправочник(Вид, СтруктураПоиска) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник."+Вид+"
	|ГДЕ
	|	Истина ";
	
	Для Каждого Элемент Из СтруктураПоиска Цикл
		Запрос.Текст=Запрос.Текст+"
		|	И "+Элемент.Ключ+"=&"+Элемент.Ключ;
		
		Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);
	КонецЦикла;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Возврат Выборка.Ссылка;			
	КонецЕсли;	
	
	Возврат Справочники[Вид].ПустаяСсылка();
КонецФункции //НайтиСправочник(Вид,СтруктураПоиска) Экспорт

Функция ДобавитьКоды(Объект, мНаименованияКодов) Экспорт
	мКоды = НайтиКоды(мНаименованияКодов);
	Для Каждого ШтрихкодУпаковки Из мКоды Цикл
		СтрокаТЧ = Объект.ШтрихкодыУпаковок.Добавить();							
		СтрокаТЧ.ШтрихкодУпаковки = ШтрихкодУпаковки;			
	КонецЦикла;
КонецФункции //ДобавитьКоды(Объект, Коды) Экспорт

Процедура УдалитьКоды(Объект, Коды) Экспорт
	Для Каждого ШтрихкодУпаковки Из Коды Цикл
		Строки = Объект.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодУпаковки", ШтрихкодУпаковки));
		Для Каждого Строка Из Строки Цикл
			Объект.ШтрихкодыУпаковок.Удалить(Строка);		
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Функция НайтиКоды(мКоды) Экспорт
	тКодов = Новый ТаблицаЗначений;
	тКодов.Колонки.Добавить("Наименование", ПолучитьОписаниеТиповСтроки(Метаданные.Справочники.ШтрихкодыУпаковокТоваров.ДлинаНаименования));
	Для каждого Наименование Из мКоды Цикл
		СтрокаТ = тКодов.Добавить();
		СтрокаТ.Наименование = Наименование;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Наименования ИЗ &тКодов КАК тКодов
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СпрКМ.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_Наименования
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК СпрКМ
	|ПО
	|	СпрКМ.Наименование = ВТ_Наименования.Наименование
	|";
	
	Запрос.УстановитьПараметр("тКодов", тКодов);	
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции //НайтиКоды(мКоды) Экспорт

Функция ЗаписатьФактСканирования(ШтрихКод, ДокументСканирования, ДопПараметры = Неопределено) Экспорт
	ТипШК 			= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТипШК", Перечисления.ТипыШтрихКодов.Штука);
	НазначениеШК	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "НазначениеШК");
	КодировкаШК		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "КодировкаШК", Перечисления.ТипыКодировокШК.EAN13);
	ДанныеПоШК	 	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДанныеПоШК");
	Накладная		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Накладная");
	ТекстОшибки		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТекстОшибки");
	Знак			= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Знак", 1);	
	
	Если НазначениеШК = Неопределено Тогда
		НазначениеШК = Маркировка_ПИ.ПолучитьНазначениеПоШК(ШтрихКод);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Накладная) Тогда
		Накладная = НакладнаяПоДокументуСканирования(ДокументСканирования);	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(НазначениеШК) Тогда
		НазначениеШК = ОпределитьНазначениеШКпоДанным(ДанныеПоШК);
	КонецЕсли;
	Если СтрДлина(ШтрихКод) >= 60 Тогда
		КодировкаШК = Перечисления.ТипыКодировокШК.DataMatrix;	
	КонецЕсли;
	
	РабочееМесто = ПараметрыСеанса.РабочееМестоКлиента;
	
	Запись = РегистрыСведений.РеестрСканирования.СоздатьМенеджерЗаписи();
	
	Запись.ИД_Записи 	= Новый УникальныйИдентификатор;
	
	Запись.Автор 		= ПараметрыСеанса.Пользователь;

	// Кельманов А.В. - Оптимизация работы - 2026.06.03 {
	//Запись.ФизЛицо = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ФизЛицо");
	ФизЛицо = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ФизЛицо");
	
	Если Не ЗначениеЗаполнено(ФизЛицо) И ЗначениеЗаполнено(Запись.Автор.ФизЛицо) Тогда
		
		ФизЛицо = Запись.Автор.ФизЛицо;
		
	КонецЕсли;
	
	Запись.ФизЛицо = ФизЛицо;
	// Кельманов А.В. - Оптимизация работы - 2026.06.03 }

	Запись.РабочееМесто = ПараметрыСеанса.РабочееМестоКлиента;
	Запись.Знак			= Знак;
	Запись.СостояниеСканера = ПараметрыСеанса.СостояниеСканераДляПланаНабора;
	Запись.ДокументСканирования = ДокументСканирования;
	Запись.Накладная	= Накладная;
	Запись.Дата			= ТекущаяДата();
	Запись.КодировкаШК	= КодировкаШК;
	Запись.ТипШК		= ТипШК;	
	Запись.НазначениеШК	= НазначениеШК;
	Запись.ДанныеПоШК	= ДанныеПоШК;
	Запись.ШтрихКод		= ШтрихКод;	
	Запись.ТекстОшибки	= ТекстОшибки; 
	
	//Тимофеев Ю.А. 15.04.2026 Задания в РС "реестр сканирования" без ТСД SNL-194   
	ЧтоЗаДокумент = ТипЗнч(ДокументСканирования); 	
	Если ЧтоЗаДокумент=Тип("ДокументСсылка.ЛистНабора") Тогда
		Запись.ДокументЗадание = ДокументСканирования.ЗаданиеНабора;
	ИначеЕсли  ЧтоЗаДокумент=Тип("ДокументСсылка.ЛистПереукладки") Тогда
		Запись.ДокументЗадание = ДокументСканирования.ЗаданиеНаАгрегацию;
	ИначеЕсли  ЧтоЗаДокумент=Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ") Тогда
		Запись.ДокументЗадание = ДокументСканирования.ДокОснование;
	КонецЕсли;	     
	//Тимофеев Ю.А. 15.04.2026 Задания в РС "реестр сканирования" без ТСД SNL-194
	
	Запись.Записать(Ложь);
КонецФункции //ЗаписатьФактСканирования(ШтрихКод, ДокументСканирования, ДопПараметры = Неопределено) Экспорт

Функция ЗаписатьФактыСканированияПачкой(тШтрихКоды, ДокументСканирования, ДопПараметры = Неопределено) Экспорт
	Накладная		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Накладная");	
	ФизЛицо			= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ФизЛицо");
	РабочееМесто	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "РабочееМесто", 		ПараметрыСеанса.РабочееМестоКлиента);
	СостояниеСканера= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "СостояниеСканера",	ПараметрыСеанса.СостояниеСканераДляПланаНабора);
		
	Если НЕ ЗначениеЗаполнено(Накладная) Тогда
		Накладная = НакладнаяПоДокументуСканирования(ДокументСканирования);	
	КонецЕсли;
	
	НЗ = РегистрыСведений.РеестрСканирования.СоздатьНаборЗаписей();
	НЗ.РасширенныеРежимыЗамещения = Истина;	
	
	Для каждого СтрокаШК Из тШтрихКоды Цикл
		Запись = НЗ.Добавить();
		
		ЗаполнитьЗначенияСвойств(Запись, СтрокаШК);		
		
		Запись.ИД_Записи 	= Новый УникальныйИдентификатор;
		
		Запись.Автор 				= ПараметрыСеанса.Пользователь;
		Запись.ДокументСканирования = ДокументСканирования;
		Запись.Накладная			= Накладная;   
		
		Если НЕ ЗначениеЗаполнено(Запись.НазначениеШК) Тогда
			Запись.НазначениеШК = Маркировка_ПИ.ПолучитьНазначениеПоШК(Запись.ШтрихКод);
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(Запись.НазначениеШК) Тогда
			Запись.НазначениеШК = ОпределитьНазначениеШКпоДанным(Запись.ДанныеПоШК);
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(Запись.КодировкаШК) Тогда
			Если СтрДлина(Запись.ШтрихКод) >= 60 Тогда
				Запись.КодировкаШК = Перечисления.ТипыКодировокШК.DataMatrix;	
				Запись.ШтрихКод = Лев(Запись.ШтрихКод, 31)
			КонецЕсли;		
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(Запись.ФизЛицо) Тогда
			Запись.ФизЛицо	= ФизЛицо;		
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Запись.РабочееМесто) Тогда
			Запись.РабочееМесто = РабочееМесто;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Запись.СостояниеСканера) Тогда		
			Запись.СостояниеСканера = СостояниеСканера;
		КонецЕсли;		
	КонецЦикла;
	
	НЗ.Записать(РежимЗамещения.Добавление);
КонецФункции //ЗаписатьФактыСканированияПачкой(тШтрихКоды, ДокументСканирования, ДопПараметры = Неопределено) Экспорт

Функция ОпределитьНазначениеШКпоДанным(Данные)
	Результат = Неопределено;                              
	ТипДанных = ТипЗнч(Данные);
	
	Если ТипДанных = Тип("СправочникСсылка.Номенклатура") Тогда
		Результат = Справочники.НазначенияШК.Товар;
	ИначеЕсли ТипДанных = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Результат = Справочники.НазначенияШК.ФизЛицо;
	ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипДанных) Тогда
		Результат = Справочники.НазначенияШК.Документ;
	КонецЕсли;                                       
	
	Возврат Результат;
КонецФункции // ()

Функция НакладнаяПоДокументуСканирования(ДокументСканирования) Экспорт
	Результат 	= Неопределено;
	ТипДока		= ТипЗнч(ДокументСканирования);
	
	Если ТипДока = Тип("ДокументСсылка.ЗаданиеНабора") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументСканирования, "Накладная");
	ИначеЕсли ТипДока = Тип("ДокументСсылка.ЗаданиеНаМаркировку") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументСканирования, "ДокОснование");
	ИначеЕсли ТипДока = Тип("ДокументСсылка.ЛистНабора") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументСканирования, "ДокОснование");		
	ИначеЕсли ТипДока = Тип("ДокументСсылка.ЛистПереукладки") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументСканирования, "ДокОснование");			
	ИначеЕсли ТипДока = Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ") Тогда
		Результат = ПолучитьРеквизитШапки(ДокументСканирования, "ДокОснование.ДокОснование");	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НакладнаяПоДокументуСканирования(ДокументСканирования)

Функция ЗафиксироватьОтвалЧЗ() Экспорт	
	Константы.ДатаОтвалаЧЗ.Установить(ТекущаяДата());
	ОбновитьПовторноИспользуемыеЗначения();	
	
	ЗаписатьВЛог("Работоспособность ЧЗ", "Не работает ЧЗ", "Ошибка");
КонецФункции //ЗафиксироватьРаботоспособностьЧЗ() Экспорт

Функция ВремяНеработоспособностиЧЗ() Экспорт
	Результат = 0;
	
	Если НЕ Маркировка_ПИ.ЧЗ_Живой() Тогда
		Результат = ТекущаяДата() - Маркировка_ПИ.ДатаОтвалаЧЗ();			
	КонецЕсли;	                                                 
	
	Возврат Результат;
КонецФункции //ВремяНеработоспособностиЧЗ()

Функция ПроверитьКМпоДокументу(ДокСсылка, ДопПараметры = Неопределено) Экспорт	
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Вставить("ОшибкаЧЗ", Ложь);	
	
	ОтложеннаяПроверка	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ОтложеннаяПроверка", Ложь);
	ВызовИзЗадачи		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ВызовИзЗадачи", Ложь);
	СоздаватьЗадачу		= ОтложеннаяПроверка;
	ОшибкаВыполнения	= Ложь;
	
	СостояниеЧЗДопускаетВыполнениеПроверки = Истина;	
	Если МаркировкаС.ВремяНеработоспособностиЧЗ() < 60 Тогда 
		//Может был разовый сбой и надо попробовать еще разок
	ИначеЕсли МаркировкаС.ВремяНеработоспособностиЧЗ() > Маркировка_ПИ.ИнтервалПовторногоЗапросаЧЗ() Тогда
		МаркировкаС.ЗафиксироватьОтвалЧЗ();	//Перенос еще на полчаса
	Иначе
		СостояниеЧЗДопускаетВыполнениеПроверки = Ложь;
	КонецЕсли;
	
	//+++ Чирков 15.05.2026 - перенос блока - для проверок при отвале ЧЗ
	ПорцииКМ = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ПорцииКМ");
	Если ПорцииКМ = Неопределено Тогда
		ПорцииКМ = ПолучитьПорцииКМДляПроверки(ДокСсылка);
	КонецЕсли;
	//--- Чирков 15.05.2026
	
	ЕстьКМДляПроверки = ЕстьКМДляПроверки(ПорцииКМ);	
	
	Если ЕстьКМДляПроверки Тогда	
		ОшибкаЧЗ = Ложь;	
		Если ОтложеннаяПроверка = Ложь Тогда		
			Если СостояниеЧЗДопускаетВыполнениеПроверки Тогда		
				пОбработки = Новый Структура("Основание,ПорцииКМ", ДокСсылка, ПорцииКМ);
				пОбработки.Вставить("ОтпечатокСертификатаЭЦП", ОбменСЧЗЧерезОУКЭПСервер.ПолучитьСертификатЭЦП_ОУКЭП());
				
				Обработка = Обработки.АпиЧЗ.Создать();
				
				Попытка
					РегистрыСведений.СтатусыПроверкиКМвЧЗ.УстановитьРезультатПроверкиДокументаПоЧЗ(ДокСсылка, Перечисления.СтатусПроверкиКМвЧЗ.Проверяется);
					
					Результат = Обработка.ПроверитьКМвЧЗ(пОбработки);
					
					Если Результат.Успешно Тогда
						рРазбора = Обработка.ПолучитьРезультатыПроверкиКМпоДокументу(ДокСсылка, Результат.Данные, ДопПараметры);			
						Если ТипЗнч(рРазбора.Данные) = Тип("ТаблицаЗначений") И рРазбора.Данные.Количество() > 0 Тогда
							Результат.Успешно	= Ложь;
							Результат.Данные	= рРазбора.Данные;			
							
							РегистрыСведений.ОшибкиПроверкиКМвЧЗ.ЗаписатьОшибкиКМ(ДокСсылка, рРазбора.Данные);
							
							ТекстОшибки = СтрШаблон("Обнаружено %1 ошибок в КМ !", рРазбора.Данные.Количество());					
							РегистрыСведений.СтатусыПроверкиКМвЧЗ.УстановитьРезультатПроверкиДокументаПоЧЗ(ДокСсылка, Перечисления.СтатусПроверкиКМвЧЗ.Ошибка, Новый Структура("ДопИнфо", ТекстОшибки));
						Иначе
							РегистрыСведений.ОшибкиПроверкиКМвЧЗ.ОчиститьОшибкиКМ(ДокСсылка);
							РегистрыСведений.СтатусыПроверкиКМвЧЗ.УстановитьРезультатПроверкиДокументаПоЧЗ(ДокСсылка, Перечисления.СтатусПроверкиКМвЧЗ.Успешно);
						КонецЕсли;
					Иначе                                                                                                                            
						ТекстОшибки = СтрСоединить(Результат.Ошибки, Символы.ПС);
						ЗаписатьВЛог("Проверка КМ ЧЗ", "Ошибка выполнения: 'Обработка.АпиЧЗ.ПроверитьКМвЧЗ'. Ошибка " + ТекстОшибки, "Ошибка");				
						
						РегистрыСведений.СтатусыПроверкиКМвЧЗ.УстановитьРезультатПроверкиДокументаПоЧЗ(ДокСсылка, Перечисления.СтатусПроверкиКМвЧЗ.Ошибка, Новый Структура("ДопИнфо", ТекстОшибки));
						
						СоздаватьЗадачу 	= Истина;
						ОшибкаЧЗ 			= Истина;
						ОшибкаВыполнения	= Истина;
					КонецЕсли;
					
				Исключение            
					ТекстОшибки = ОписаниеОшибки();
					Результат.Ошибки.Добавить(ТекстОшибки);
					Результат.Успешно = Ложь;
					ЗаписатьВЛог("Проверка КМ ЧЗ", "Ошибка выполнения: 'МаркировкаС.ПроверитьКМпоДокументу'. Ошибка " + ТекстОшибки, "Ошибка");
					
					СоздаватьЗадачу 	= Истина;				
					ОшибкаВыполнения	= Истина;
				КонецПопытки;		
			Иначе         
				СоздаватьЗадачу = Истина;    
				ОшибкаЧЗ 		= Истина;			
			КонецЕсли;
		КонецЕсли;
		
		Результат.Вставить("ОшибкаЧЗ", ОшибкаЧЗ);
	Иначе
		СоздаватьЗадачу = Ложь;
		
		ТекстОшибки = "Ошибка данных: 'Обработка.АпиЧЗ.ПроверитьКМвЧЗ'. Отсутствуют КМ для проверки.";
		ЗаписатьВЛог("Проверка КМ ЧЗ", ТекстОшибки + " " + ДокСсылка, "Ошибка");
						
		РегистрыСведений.СтатусыПроверкиКМвЧЗ.УстановитьРезультатПроверкиДокументаПоЧЗ(ДокСсылка, Перечисления.СтатусПроверкиКМвЧЗ.Ошибка, Новый Структура("ДопИнфо", ТекстОшибки));
	КонецЕсли;
	
	Если СоздаватьЗадачу Тогда			
		Если ВызовИзЗадачи Тогда	
			Результат.Успешно = Ложь;			
			Результат.Ошибки.Добавить("Ошибка проверки ЧЗ при вызове из задачи. ОшибкаЧЗ: " + ОшибкаЧЗ);			
		Иначе                                                                                           
			СоздатьЗадачуПроверкиКМпоДокументу(ДокСсылка, ПорцииКМ);		
		КонецЕсли;			
	Иначе
		Результат.Вставить("ОшибкаВыполнения", ОшибкаВыполнения);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПроверитьКМпоДокументу(ДокСсылка, ДопПараметры = Неопределено) Экспорт

Функция ЕстьКМДляПроверки(ПорцииКМ)
	Результат = Ложь;
	Если ТипЗнч(ПорцииКМ) = Тип("Массив") Тогда
		Для каждого ПорцияКМ Из ПорцииКМ Цикл
			Если ТипЗнч(ПорцияКМ) = Тип("Массив") И ПорцияКМ.Количество() > 0 Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	Возврат Результат;
КонецФункции //ЕстьКМДляПроверки(ПорцииКМ)

Функция ПолучитьПорцииКМДляПроверки(ДокСсылка) Экспорт
	Результат		= Новый Массив;
	ТипДокумента	= ТипЗнч(ДокСсылка);
	
	Если ТипДокумента = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда		
		//Результат = Документы.ХранилищеКодовМаркировки.ПолучитьКМДляПроверки(ДокОснование);
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ЛистНабора") Тогда		
		Результат = Документы.ЛистНабора.ПолучитьПорцииКМДляПроверки(ДокСсылка);
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ЛистПереукладки") Тогда		
		Результат = Документы.ЛистПереукладки.ПолучитьПорцииКМДляПроверки(ДокСсылка);
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ") Тогда		
		Результат = Документы.ЛистСборкиКомплектовЧЗ.ПолучитьПорцииКМДляПроверки(ДокСсылка);
	КонецЕсли;      
	
	Возврат Результат;
КонецФункции //ПолучитьПорцииКМДляПроверки(ДокСсылка)

Функция СоздатьЗадачуПроверкиКМпоДокументу(Основание, ПорцииКодов)
	Если ЗначениеЗаполнено(Основание) Тогда	
		пОбработки = Новый Структура("ПараметрыПорций, ПараллельноеВыполнение", ПорцииКодов, Истина);
		РегистрыСведений.ЗадачиОтложеннойОбработкиДокументов.СоздатьЗадачу(Основание, 
			Перечисления.ЗадачиОтложеннойОбработкиДокументов.ПроверитьКодыВЧЗ, Новый Структура("ПараметрыОбработки", пОбработки));
	КонецЕсли;	
КонецФункции //СоздатьЗадачуПроверкиКМпоДокументу(Основание, ПорцииКодов)

Функция МассивВТаблицу(МассивЗначений, ИмяКолонки, ИмяТипа = Неопределено) Экспорт
	ТЗ = Новый ТаблицаЗначений;
	Если МассивЗначений.Количество() > 0 Тогда
		МТ = Новый Массив;
		МТ.Добавить(ТипЗнч(МассивЗначений[0]));
		ТипКолонки = Новый ОписаниеТипов(МТ);
	Иначе		
		Если ЗначениеЗаполнено(ИмяТипа) Тогда
			ТипКолонки = Новый  ОписаниеТипов(ИмяТипа);
		Иначе
			ТипКолонки = Неопределено;		
		КонецЕсли;
	КонецЕсли;
	ТЗ.Колонки.Добавить(ИмяКолонки, ТипКолонки);
	
	Для Каждого ТекЗнач Из МассивЗначений Цикл
		Если ЗначениеЗаполнено(ТекЗнач) Тогда
			СтрокаТК = ТЗ.Добавить();	
			СтрокаТК[ИмяКолонки] = ТекЗнач;		
		КонецЕсли;	
	КонецЦикла; 
	
	Возврат ТЗ;
КонецФункции //МассивВТаблицу(МассивЗначений, ИмяКолонки) Экспорт

// Кухарь А.Ю. 30.08.2024 начало
//
Функция ПолучитьНовоеМестоположениеМаркировкиПоДокументу(знач ДокументСсылка) экспорт
	СтруктураВозврата=новый Структура("НовоеМестоположение,УзелПолучателя,Успешно,Ошибки",Неопределено,Неопределено,ложь,Неопределено);
	//Узел получателя = неопределено, значит движение будет без передачи между узлами
	//СкладМестоположения = неопределено, значит такое движение нельзя делать
	
	
	МассивОшибок=новый Массив;
	НуженТранзитныйСклад=ложь;
	СкладПереопределен=ложь;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
		РеквизитыХКМ=ПолучитьРеквизитыШапки(ДокументСсылка,"ДокОснование,Операция","Документ");
		ДокументСсылка=РеквизитыХКМ.ДокОснование;
		Операция=РеквизитыХКМ.Операция;
		если Операция = Перечисления.СкладскиеОперации.Отгрузка тогда
			НуженТранзитныйСклад=Истина;
		КонецЕсли;
		если не ЗначениеЗаполнено(ДокументСсылка) тогда
			МассивОшибок.Добавить("Обнаружен ХКМ без док. основания");
		КонецЕсли;
	КонецЕсли;	
	
	если МассивОшибок.Количество()=0 тогда
		ПараметрыТекущегоУзла=новый Структура("Узел,КодУзла,ТипУзла,Подразделение,ОсновнойСклад");
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	Основной.Ссылка КАК Узел,
		|	Основной.Код КАК КодУзла,
		|	Основной.ТипУзла КАК ТипУзла,
		|	Основной.Подразделение КАК Подразделение,
		|	Основной.Подразделение.ОсновнойСклад КАК ОсновнойСклад
		|ИЗ
		|	ПланОбмена.Основной КАК Основной
		|ГДЕ
		|	Основной.Ссылка = &Узел";
		запрос.УстановитьПараметр("Узел",ПараметрыСеанса.ЭтотУзел);
		выборка=запрос.Выполнить().Выбрать();
		если выборка.Количество()=0 тогда
			возврат Неопределено;
		КонецЕсли;
		Пока выборка.Следующий() цикл
			ЗаполнитьЗначенияСвойств(ПараметрыТекущегоУзла,выборка);
		КонецЦикла;
		
		//Тут живут данные часцов
		ПараметрыТранспортногоУзла=новый Структура("Узел,КодУзла,ТипУзла,Подразделение,ОсновнойСклад");
		запрос.УстановитьПараметр("Узел",Константы.УзелТранспортногоОтдела.Получить());
		выборка=запрос.Выполнить().Выбрать();
		если выборка.Количество()=0 тогда
			возврат Неопределено;
		КонецЕсли;
		Пока выборка.Следующий() цикл
			ЗаполнитьЗначенияСвойств(ПараметрыТранспортногоУзла,выборка);
		КонецЦикла;			
		
		
		Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказПоставщику")   
			или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.КонтрактСПроизводителем")
			или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Машина")
			Тогда  //Пока что всегда Склад часцы
			СтруктураВозврата.УзелПолучателя = ПараметрыТранспортногоУзла.Узел;
			СтруктураВозврата.НовоеМестоположение = ПараметрыТранспортногоУзла.ОсновнойСклад;
			
			
			НуженТранзитныйСклад=Истина;

		ИначеЕсли  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"КодОперации,Склад","Документ");
			если РеквизитыШапки.КодОперации=Перечисления.КодыОперацийОстатки.ЗакупкаР тогда  //Пока что всегда Склад часцы
				
				СтруктураВозврата.УзелПолучателя = ПараметрыТранспортногоУзла.Узел;
				СтруктураВозврата.НовоеМестоположение = ПараметрыТранспортногоУзла.ОсновнойСклад;
			иначе
				УзелПолучателя=ПолучитьУзелПоСкладу(РеквизитыШапки.Склад);
				
				СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.Склад;
				СтруктураВозврата.УзелПолучателя=УзелПолучателя;
			КонецЕсли;
		ИначеЕсли  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Перемещение") Тогда   
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"СкладПолучатель","Документ");
			УзелПолучателя=ПолучитьУзелПоСкладу(РеквизитыШапки.СкладПолучатель);
			
			СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.СкладПолучатель;
			СтруктураВозврата.УзелПолучателя=УзелПолучателя;
			
		ИначеЕсли  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"Контрагент","Документ");
			
			СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.Контрагент;
		ИначеЕсли  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.СписаниеТМЦ") или
			ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОприходованиеТМЦ")
			тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"Склад","Документ");
			УзелПолучателя=ПолучитьУзелПоСкладу(РеквизитыШапки.Склад);
			
			СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.Склад;
			СтруктураВозврата.УзелПолучателя=УзелПолучателя;		
		ИначеЕсли   ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетКассовойСмены") тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"Касса.ОсновнойПокупатель","Документ");
			
			СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.Касса_ОсновнойПокупатель;
		ИначеЕсли   ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"ДокументОснование","Документ");
			ДокОснование=РеквизитыШапки.ДокументОснование;
			если ТипЗнч(ДокОснование)  = Тип("ДокументСсылка.ЗаказПоставщику") тогда
				РеквизитыШапкиДокОснования=ПолучитьРеквизитыШапки(ДокОснование,"Контрагент","Документ");
				СтруктураВозврата.НовоеМестоположение=РеквизитыШапкиДокОснования.Контрагент;
			КонецЕсли;
		ИначеЕсли   ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") тогда
			РеквизитыШапки=ПолучитьРеквизитыШапки(ДокументСсылка,"ПодразделениеНанесения","Документ");
			СтруктураВозврата.НовоеМестоположение=РеквизитыШапки.ПодразделениеНанесения;			
		КонецЕсли;	
		
		если ТипЗнч(СтруктураВозврата.НовоеМестоположение)=Тип("СправочникСсылка.Склады") тогда
			РеквизитыСклада=ПолучитьРеквизитыШапки(СтруктураВозврата.НовоеМестоположение,"СкладБухгалтерии,КарантинЧЗ,СкладОтгрузкиТранзитом","Справочник");	
			если РеквизитыСклада.КарантинЧЗ <> Истина тогда //Карантин всегда оставляем как есть
				если ЗначениеЗаполнено(СтруктураВозврата.УзелПолучателя)тогда  //Сначала берём основной склад из узла, если там не пусто
					СкладПереопределяемый=ПолучитьСкладПоУзлу(СтруктураВозврата.УзелПолучателя);
					если ЗначениеЗаполнено(СкладПереопределяемый) и не СкладПереопределен тогда
						СкладПереопределен=Истина;
						СтруктураВозврата.НовоеМестоположение=СкладПереопределяемый;
					КонецЕсли;
					
					если ЗначениеЗаполнено(РеквизитыСклада.СкладБухгалтерии) и не СкладПереопределен тогда //Если не нашли, то пытаемся взять из реквизита склада
						СтруктураВозврата.НовоеМестоположение= РеквизитыСклада.СкладБухгалтерии;
					КонецЕсли;
				КонецЕсли;
				
				если НуженТранзитныйСклад и ЗначениеЗаполнено(РеквизитыСклада.СкладОтгрузкиТранзитом) тогда
					   СтруктураВозврата.НовоеМестоположение= РеквизитыСклада.СкладОтгрузкиТранзитом;
				КонецЕсли;

			КонецЕсли;
			
			
		КонецЕсли;
	КонецЕсли;	
	
	если не ЗначениеЗаполнено(СтруктураВозврата.НовоеМестоположение) тогда
		МассивОшибок.Добавить("Не удалось определить новое местоположение кода ЧЗ по документу");
	КонецЕсли;	
	если МассивОшибок.Количество()>0 Тогда
		СтруктураВозврата.Успешно=ложь;
	иначе
		СтруктураВозврата.Успешно=Истина;
	КонецЕсли;
	СтруктураВозврата.Ошибки=МассивОшибок;
	
	возврат СтруктураВозврата;	
КонецФункции

Функция ПолучитьУзелПоСкладу (Знач Склад)
	РеквизитыСклада=ПолучитьРеквизитыШапки(Склад,"КодФизическогоУзла,ТипСклада","Справочник");
	КодФизическогоУзла=РеквизитыСклада.КодФизическогоУзла;

	если не ЗначениеЗаполнено(КодФизическогоУзла) тогда 
		возврат Неопределено;
	КонецЕсли;
	
	если РеквизитыСклада.ТипСклада <> Перечисления.ТипСклада.РозничныйТЦ тогда		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ первые 1
		|	Основной.Ссылка КАК Ссылка
		|ИЗ
		|	ПланОбмена.Основной КАК Основной
		|ГДЕ
		|	Основной.Код = &КодФизическогоУзла
		|	И не Основной.ПометкаУдаления";
		запрос.УстановитьПараметр("КодФизическогоУзла",КодФизическогоУзла);
		выборка=запрос.Выполнить().Выбрать();
		пока выборка.следующий() цикл
			возврат выборка.ссылка;
		КонецЦикла;
	иначе
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ первые 1
		|	План.Ссылка КАК Ссылка
		|ИЗ
		|	ПланОбмена.ФР_ОбменСФРК КАК План
		|ГДЕ
		|	План.Код = &КодФизическогоУзла
		|	И не План.ПометкаУдаления";
		запрос.УстановитьПараметр("КодФизическогоУзла","CO_FR");
		выборка=запрос.Выполнить().Выбрать();
		пока выборка.следующий() цикл
			возврат выборка.ссылка;
		КонецЦикла;
		
	КонецЕсли;
	
	
	возврат Неопределено;
КонецФункции
Функция ПолучитьСкладПоУзлу (Знач Узел)
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	Основной.Подразделение.ОсновнойСклад КАК ОсновнойСклад
	|ИЗ
	|	ПланОбмена.Основной КАК Основной
	|ГДЕ
	|	Основной.Ссылка = &Узел";
	запрос.УстановитьПараметр("Узел",Узел);
	выборка=запрос.Выполнить().Выбрать();
	пока выборка.следующий() цикл
		возврат выборка.ОсновнойСклад;
	КонецЦикла;
	
	возврат Неопределено;
КонецФункции

