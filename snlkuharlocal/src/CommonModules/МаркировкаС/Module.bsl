Функция ТекущийСтатусКодаФакт(ШтрихКодУпаковки) Экспорт
	Результат = Перечисления.СтатусыКодовМаркировкиФакт.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Период,
	|	Статус
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт
	|ГДЕ
	|	ШтрихКодУпаковки = &ШтрихКодУпаковки	
	|	И Активность
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ
	|";
	
	Запрос.УстановитьПараметр("ШтрихКодУпаковки", ШтрихКодУпаковки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Статус) Тогда
		Результат = Выборка.Статус;	
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //ТекущийСтатусКодаФакт(ШтрихКодУпаковки) Экспорт

