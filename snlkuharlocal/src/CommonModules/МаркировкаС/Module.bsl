					Результат.ошибки.Добавить(ТекстОшибки);	
					
				КонецЕсли;
				
				Если Выборка.РасхождениеПродукции = Истина Тогда
					
					Результат.Успешно = Ложь;
					ТекстОшибки = "Количество продукции к сборке %1 в %2 не соответствуют количеству отсканированных КМ комплектов в ЛСК %3"; 
