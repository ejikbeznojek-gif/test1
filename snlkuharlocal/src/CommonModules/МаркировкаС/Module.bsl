Функция КонтрольЧЗПоРНКОжиданиеПаллетирования(Знач РНК) Экспорт
		
	Результат = МаркировкаКС.СтруктураРезультата(истина);
	 
	ИспользоватьПроверку = ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ИспользоватьПроверкуОжиданиеПаллетирования",неопределено);
	Если ИспользоватьПроверку <> истина Тогда
	    //всегда успешно
		Возврат Результат; 	
	
	КонецЕсли;	 
	
    КонтрольЧЗПоРНКОжиданиеПаллетированияПоПравиламЧЗ(Результат, РНК);

	//3. проверяем количество штук по ЛН и по ЛП + берем количество по отсканированным коробкам и блочкам
	
	КонтрольЧЗПоРНКОжиданиеПаллетированияПроверкаКоличестваШтук(Результат, РНК);

	
	КонтрольЧЗПоРНКОжиданиеПаллетированияПоЗСБ(Результат, РНК);

	//++Данилова Е.В. 20.03.2026
	КонтрольЧЗПоРНКОжиданиеОбработкиЧЗ(РНК,Результат); 
	//--Данилова Е.В. 20.03.2026 
	Возврат Результат; 
	
КонецФункции

Процедура КонтрольЧЗПоРНКОжиданиеПаллетированияПоЗСБ(Знач Результат, Знач РНК)	
	
	//ЗСБ
	ЗСБ = НайтиДокумент("ЗаданиеНаСборкуКомплектовЧЗ",новый Структура("ДокОснование,Проведен",РНК,Истина)); 
	//++Данилова Е.В. 27.03.2026 MARK-3552 
	Если ЗначениеЗаполнено(ЗСБ)
		И ЗСБ.Товары.Количество() > 0 Тогда
		//--Данилова Е.В. 27.03.2026 
		
		Запрос 		 = Новый Запрос; 
		Запрос.УстановитьПараметр("РНК",РНК);
		Запрос.УстановитьПараметр("ЗСБ",ЗСБ);
		Запрос.Текст = "ВЫБРАТЬ
		               |	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество,
		               |	СУММА(РасходнаяНакладнаяКомплектующие.КоличествоПродукции) КАК КоличествоПродукции
		               |ПОМЕСТИТЬ ВТКомплРНК
		               |ИЗ
		               |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		               |ГДЕ
		               |	РасходнаяНакладнаяКомплектующие.Ссылка = &РНК
		               |	И РасходнаяНакладнаяКомплектующие.Количество > 0
		               |	И РасходнаяНакладнаяКомплектующие.ТребуетсяМаркировка
		               |	И РасходнаяНакладнаяКомплектующие.Продукция <> РасходнаяНакладнаяКомплектующие.Номенклатура
		               |	И РасходнаяНакладнаяКомплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(перечисление.видыноменклаутры.товар)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодУпаковки) КАК Количество,
		               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.ШтрихкодКомплекта) КАК КоличествоПродукции
		               |ПОМЕСТИТЬ ВТКомплЛСК
		               |ИЗ
		               |	Документ.ЛистСборкиКомплектовЧЗ.ШтрихкодыУпаковок КАК ЛистСборкиКомплектовЧЗШтрихкодыУпаковок
		               |ГДЕ
		               |	ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.ДокОснование = &ЗСБ
		               |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Ссылка.Проведен
		               |	И ЛистСборкиКомплектовЧЗШтрихкодыУпаковок.Комплектующее.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(перечисление.видыноменклаутры.товар)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЕСТЬNULL(ВТКомплРНК.Количество, 0) <> ЕСТЬNULL(ВТКомплЛСК.Количество, 0) КАК РасхождениеКомпл,
		               |	ЕСТЬNULL(ВТКомплРНК.КоличествоПродукции, 0) <> ЕСТЬNULL(ВТКомплЛСК.КоличествоПродукции, 0) КАК РасхождениеПродукции,
		               |	ЕСТЬNULL(ВТКомплРНК.Количество, 0) КАК КоличествоВРНК,
		               |	ЕСТЬNULL(ВТКомплЛСК.Количество, 0) КАК КоличествовЛСК,
		               |	ЕСТЬNULL(ВТКомплРНК.КоличествоПродукции, 0) КАК КоличествоПродукцииВРНК,
		               |	ЕСТЬNULL(ВТКомплЛСК.КоличествоПродукции, 0) КАК КоличествоПродукцииВЛСК
		               |ИЗ
		               |	ВТКомплРНК КАК ВТКомплРНК
		               |		ПОЛНОЕ СОЕДИНЕНИЕ ВТКомплЛСК КАК ВТКомплЛСК
		               |		ПО (ИСТИНА)
		               |ГДЕ
		               |	(ЕСТЬNULL(ВТКомплРНК.Количество, 0) <> ЕСТЬNULL(ВТКомплЛСК.Количество, 0)
		               |			ИЛИ ЕСТЬNULL(ВТКомплРНК.КоличествоПродукции, 0) <> ЕСТЬNULL(ВТКомплЛСК.КоличествоПродукции, 0))";
		
		РезультатЗапроса = Запрос.Выполнить(); 
		
		Если НЕ РезультатЗапроса.Пустой() Тогда 
			Выборка = РезультатЗапроса.Выбрать(); 
			Если Выборка.Следующий() Тогда 
				Если Выборка.РасхождениеКомпл = Истина Тогда
					
					Результат.Успешно = Ложь; 
					
					ТекстОшибки = "Количество комплектующих к сборке %1 в %2 не соответствуют количеству отсканированных КМ штук в ЛСК %3"; 
					ТекстОшибки = СтрШаблон(ТекстОшибки,Выборка.КоличествоВРНК,РНК,Выборка.КоличествовЛСК); 
