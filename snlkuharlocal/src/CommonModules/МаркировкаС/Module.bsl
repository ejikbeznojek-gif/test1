Функция КонтрольЧЗПоРНКОжиданиеОбработкиЧЗ(Знач РНК,Результат) Экспорт
		
	//ИспользоватьПроверку = ОбщегоНазначения_ПИ.ПрочитатьРСРеквизитСправочника_ПИ("ИспользоватьПроверкуОжиданиеОбработкиЧЗ",неопределено);
	//Если ИспользоватьПроверку <> истина Тогда
	//	
	//	Возврат Результат; 	
	//	
	//КонецЕсли;  
	
	//++Данилова Е.В. 21.04.2026 MARK-3552 
	//ПроверятьКратностьБлочков = ПолучитьРеквизитШапки(РНК,"Контрагент.ПроверятьКратностьБлочков");
	//ПроверятьКратностьКоробок = ПолучитьРеквизитШапки(РНК,"Контрагент.ПроверятьКратностьКоробок"); 
	//--Данилова Е.В. 21.04.2026 
	//++Данилова Е.В. 01.04.2026 MARK-3552
	ЕстьЛП = ЕстьЛПСКодамиЧЗ(РНК); 
	//--Данилова Е.В. 01.04.2026 
	
	ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(РНК);
	//++Данилова Е.В. 21.04.2026 MARK-3552
	ПроверятьКратностьБлочков = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков; 
	ПроверятьКратностьКоробок = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок;	
	//--Данилова Е.В. 21.04.2026
	Если ПроверятьКратностьБлочков
		ИЛИ ПроверятьКратностьКоробок Тогда
		
		СтруктураДанныхНакладной=новый Структура("Номенклатура,ПунктДоставки,Договор,Дата,Контрагент,ПостояннаяАкция"); 
		ЗаполнитьЗначенияСвойств(СтруктураДанныхНакладной,РНК); 	
		
		СтруктураДанныхНакладной.Номенклатура = РНК.Товары.выгрузить().ВыгрузитьКолонку("Номенклатура");
		 		
		
		ТаблицаМатрицы = ПолучитьТаблицуМатрицСрезПоследних(СтруктураДанныхНакладной);
		 		
		Если ПроверятьКратностьБлочков Тогда 
			  
			КонтрольКоличестваБлочков(Результат,РНК,ТаблицаМатрицы,ПравилаРаботыСАгрегациейЧЗ,ПроверятьКратностьКоробок,ЕстьЛП); 
			
		ИначеЕсли ПроверятьКратностьКоробок Тогда 
			КонтрольКоличестваКоробов(Результат,РНК,ТаблицаМатрицы,ПравилаРаботыСАгрегациейЧЗ,ЕстьЛП);
		КонецЕсли; 
		
		
	КонецЕсли;  
	
	
	Результат.Успешно = Результат.Ошибки.Количество() = 0; 
	
	Возврат Результат; 
	
КонецФункции

Процедура КонтрольКоличестваБлочков(Результат, Знач РНК, ТаблицаМатрицы, ПравилаРаботыСАгрегациейЧЗ = Неопределено,ПроверятьКратностьКоробок = Ложь, ЕстьЛП = Неопределено) Экспорт
	//++Данилова Е.В. 21.04.2026 MARK-3552
	//ПроверятьКратностьБлочков = ПолучитьРеквизитШапки(РНК,"Контрагент.ПроверятьКратностьБлочков"); 
	//
	//Если НЕ ПроверятьКратностьБлочков Тогда
	//	
	//	Возврат; 	
	//	
	//КонецЕсли;  
	//--Данилова Е.В. 21.04.2026 
	Если ПравилаРаботыСАгрегациейЧЗ = Неопределено Тогда
		
		ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(РНК);  	
		
	КонецЕсли;
	
	Если НЕ ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков Тогда
		
		Возврат;  	
		
	КонецЕсли; 
	//++Данилова Е.В. 21.04.2026 MARK-3552 
	Если ТаблицаМатрицы.Количество() = 0
		ИЛИ ТаблицаМатрицы.Итог("КратностьБлочка") = 0 Тогда
	
		Возврат;	
	
	КонецЕсли;
	//--Данилова Е.В. 21.04.2026 
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	
	
	"ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|ГДЕ
	|	РасходнаяНакладная.Ссылка = &РНК
	|	И РасходнаяНакладнаяТовары.Количество > 0
	|	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|	И РасходнаяНакладнаяТовары.ТребуетсяМаркировка
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТМатрица.Номенклатура КАК Номенклатура,
