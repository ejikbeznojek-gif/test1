Функция КоличествоШКПоЗаранееСформированнымАгрегациям(Знач ДокументОснование) Экспорт
	 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(ВложенныйЗапрос.КоличествоПоКоробкам) + СУММА(ВложенныйЗапрос.КоличествоПоБлочкам) КАК Количество
		|ИЗ
		|	(ВЫБРАТЬ
		|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод) КАК КоличествоПоКоробкам,
		|		0 КАК КоличествоПоБлочкам
		|	ИЗ
		|		Документ.ЛистНабора КАК ЛистНабора
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка
		|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыКоробокДляАгрегации КАК ЛистНабораШтрихкодыКоробокДляАгрегации
		|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыКоробокДляАгрегации.Ссылка
		|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки)
		|				И (ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки = ЛистНабораШтрихкодыКоробокДляАгрегации.НовыйКодКоробки)
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		|			ПО (ЛистНабораШтрихкодыКоробокДляАгрегации.ИсходныйКодКоробки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка)
		|				И (ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука))
		|	ГДЕ
		|		ЛистНабора.Проведен
		|		И ЛистНабора.ДокОснование = &ДокОснование
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		0,
		|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод)
		|	ИЗ
		|		Документ.ЛистНабора КАК ЛистНабора
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
		|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка
		|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок))
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
		|			ПО (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки = ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка)
		|				И (ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука))
		|	ГДЕ
		|		ЛистНабора.Проведен
		|		И ЛистНабора.ДокОснование = &ДокОснование) КАК ВложенныйЗапрос";
	
	Запрос.УстановитьПараметр("ДокОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КоличествоВложенных = 0; 	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КоличествоВложенных = ВыборкаДетальныеЗаписи.Количество; 
	КонецЦикла;
	
	Возврат КоличествоВложенных; 

 
 КонецФункции // КоличествоШКПоЗаранееСформированнымАгрегациям()    

