Процедура КонтрольКоличестваКоробов(Результат, Знач РНК,ТаблицаМатрицы,ПравилаРаботыСАгрегациейЧЗ = неопределено,ЕстьЛП = Неопределено) Экспорт
	
	//++Данилова Е.В. 21.04.2026 MARK-3552
	//ПроверятьКратностьКоробок = ПолучитьРеквизитШапки(РНК,"Контрагент.ПроверятьКратностьКоробок"); 
	//
	//Если НЕ ПроверятьКратностьКоробок Тогда
	//	
	//	Возврат; 	
	//	
	//КонецЕсли;
	//--Данилова Е.В. 21.04.2026
	Если ПравилаРаботыСАгрегациейЧЗ = Неопределено Тогда
		
		ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(РНК);  	
		
	КонецЕсли;
	
	Если НЕ ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок Тогда
		
		Возврат;  	
		
	КонецЕсли;
	
	//++Данилова Е.В. 21.04.2026 MARK-3552 
	Если ТаблицаМатрицы.Количество() = 0
		ИЛИ ТаблицаМатрицы.Итог("КратностьКоробки") = 0 Тогда
	
		Возврат;	
	
	КонецЕсли;
	//--Данилова Е.В. 21.04.2026 
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	
	
	"ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|ГДЕ
	|	РасходнаяНакладная.Ссылка = &РНК
	|	И РасходнаяНакладнаяТовары.Количество > 0
	|	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|	И РасходнаяНакладнаяТовары.ТребуетсяМаркировка
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТМатрица.Номенклатура КАК Номенклатура,
	|	ВТМатрица.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТМатрица.КратностьКоробки КАК КратностьКоробки
	|ПОМЕСТИТЬ ВТМатрица
	|ИЗ
	|	&ТЧМатрица КАК ВТМатрица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.Количество КАК Количество,
	|	ВТМатрица.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ВТМатрица.КратностьКоробки КАК КратностьКоробки
	|ИЗ
	|	ВТТовары КАК ВТТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМатрица КАК ВТМатрица
	|		ПО ВТТовары.Номенклатура = ВТМатрица.Номенклатура"; 
	Запрос.УстановитьПараметр("РНК",РНК);
	Запрос.УстановитьПараметр("ТЧМатрица",ТаблицаМатрицы);
	ТаблицаМатрицыПоРНК = Запрос.Выполнить().Выгрузить(); 
	
	ТаблицаМатрицыПоРНКПолная =  ТаблицаМатрицыПоРНК.Скопировать(); 
	
	ТаблицаМатрицыПоРНК.Свернуть("АртикулКонтрагента,КратностьКоробки","Количество");
	
	ТЗСодержимоеКоробовТоваров =новый ТаблицаЗначений;
	ТЗСодержимоеКоробовТоваров.Колонки.Добавить("Номенклатура", новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗСодержимоеКоробовТоваров.Колонки.Добавить("Количество", новый ОписаниеТипов("Число"));
	ТЗСодержимоеКоробовТоваров.Колонки.Добавить("КоличествоКоробок", новый ОписаниеТипов("Число"));
	ТЗСодержимоеКоробовТоваров.Колонки.Добавить("КоличествоВРНК", новый ОписаниеТипов("Число"));
	
	ТЗСодержимоеКоробов =новый ТаблицаЗначений;
	ТЗСодержимоеКоробов.Колонки.Добавить("Номенклатура", новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗСодержимоеКоробов.Колонки.Добавить("Количество", новый ОписаниеТипов("Число"));
	ТЗСодержимоеКоробов.Колонки.Добавить("КоличествоКоробок", новый ОписаниеТипов("Число"));
	
	
	ВсегоКоличествоКоробок = 0; 
	для каждого СтрТЗСверн из ТаблицаМатрицыПоРНК цикл
		
		НомЛП = ТаблицаМатрицыПоРНКПолная.НайтиСтроки(новый Структура("АртикулКонтрагента",СтрТЗСверн.АртикулКонтрагента));
		КолКоробов = СтрТЗСверн.Количество/СтрТЗСверн.КратностьКоробки;
		
		ВсегоКоличествоКоробок = ВсегоКоличествоКоробок + КолКоробов; 
		если Цел(КолКоробов) <> КолКоробов тогда   
			КолКоробов = Цел(КолКоробов)+1;
		КонецЕсли;    
		
		для каждого СтрМасс из НомЛП цикл
			СтрТЗ 				= ТЗСодержимоеКоробовТоваров.Добавить();
			СтрТЗ.Номенклатура	= СтрМасс.Номенклатура;
			СтрТЗ.КоличествоКоробок	= СтрМасс.количество/СтрТЗСверн.КратностьКоробки;
			СтрТЗ.Количество	= СтрМасс.количество/СтрТЗ.КоличествоКоробок;  		
			СтрТз.КоличествоВРНК = СтрМасс.количество; 
		КонецЦикла;		
		
	КонецЦикла; 
	
	Если ТЗСодержимоеКоробовТоваров.Количество() = 0 Тогда 
		
		Сообщить("По матрице ничего не найдено"); 
		
		Возврат; 	
		
	КонецЕсли;
	
	
	ЭтоFBS = Ложь; 
	
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Вложенныйзапрос.Продукция КАК Продукция,
	|	Вложенныйзапрос.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(Вложенныйзапрос.Количество, 0)) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасходнаяНакладнаяТовары.Номенклатура КАК Продукция,
	|		РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|		СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
	|	ИЗ
	|		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|			ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
