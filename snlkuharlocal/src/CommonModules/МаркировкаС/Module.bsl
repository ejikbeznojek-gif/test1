		|	Документ.Матрица КАК МатрицаДок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.Товары КАК МатрицаТовары
		|		ПО МатрицаДок.Ссылка = МатрицаТовары.Ссылка
		|ГДЕ
		|	МатрицаДок.Контрагент = &Контрагент
		|	И МатрицаТовары.ШККонтрагента <> """"
		|	И МатрицаДок.Проведен
		|	И (МатрицаДок.ДатаОкончания > &ТекущаяДата
		|			ИЛИ МатрицаДок.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
		|	И МатрицаТовары.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Сообщить("По номенклатуре " + Строка(Номенклатура) + " не найдена действующая матрица"); 
		
		Возврат неопределено; 
		
	Иначе 
		
		Выборка = РезультатЗапроса.Выбрать(); 
		Выборка.Следующий() ; 
		
		Возврат Выборка.ШККонтрагентаКоробка;  
		
	КонецЕсли;
	
	  
КонецФункции // ПолучитьЕАНПоНоменклатуре()

