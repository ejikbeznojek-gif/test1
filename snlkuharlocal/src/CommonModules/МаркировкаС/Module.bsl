	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Сообщить("По контрагенту при проверке товаров " + Строка(Контрагент) + " не найдена действующая матрица"); 
		
		Возврат неопределено; 
		
	Иначе 
		
		МассивШК = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ШККонтрагентаБлочок");  		 
		
		Возврат МассивШК.Количество() = 1;  
		
