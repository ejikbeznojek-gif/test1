Функция ЗаписатьНовыйАгрегационныйКодКонтрагентаДМ(Знач ШКЧЗ, Знач Контрагент, Знач ТипШтрихКода, Знач ШКЧЗУпаковки)  Экспорт
	
	Если ТипШтрихКода = Перечисления.ТипыШтрихКодов.Блочок  Тогда
		
		//Наименование = 04 + ШКЧЗ.Наименование + 
		
		ЕАНБлочка =  ПолучитьЕАНБлочкаПоНоменклатуре(ШКЧЗ.Владелец,Контрагент);
		 
		Если ЕАНБлочка = неопределено Тогда
			
			Сообщить("Ошибка записи нового агрегационного кода",СтатусСообщения.Внимание); 
			
			Возврат  неопределено; 
			
		КонецЕсли;
		
		ПорядковыйНомер = ПолучитьПорядковыйНомерПоПрефиксу("02" + "0" + ЕАНБлочка + "21");
		ПорядковыйНомерСтрока = Формат(ПорядковыйНомер,"ЧЦ=6; ЧВН=; ЧГ=0"); 
		
		НаименованиеАгрегКода = "02" + "0" + ЕАНБлочка + "21" + ПорядковыйНомерСтрока; 
		НаименованиеАгрегКодаСоСкобками = "(02)" + "0" + ЕАНБлочка + "(21)" + ПорядковыйНомерСтрока;
		
		НовыйЭлемент = Справочники.АгрегационныеКодыКонтрагентов.СоздатьЭлемент(); 
		НовыйЭлемент.Наименование = НаименованиеАгрегКода; 
		НовыйЭлемент.ТипШК 		= ТипШтрихКода; 
		НовыйЭлемент.Контрагент = Контрагент; 
		НовыйЭлемент.ШКЧЗ 		= ШКЧЗУпаковки; 
		НовыйЭлемент.НаименованиеСоСкобками = НаименованиеАгрегКодаСоСкобками;
		//++Данилова Е.В. 23.04.2025 пока без задачи
		НовыйЭлемент.УстановитьНовыйКод();
		//--Данилова Е.В. 23.04.2025
		//++Данилова Е.В. 26.05.2025  ASU-2264
		НовыйЭлемент.Номенклатура = ШКЧЗ.Владелец; 
		//--Данилова Е.В. 26.05.2025 
		Попытка
			
			НовыйЭлемент.Записать();
			
			Возврат НовыйЭлемент.ссылка; 
			
		Исключение
			Возврат Неопределено; 
		КонецПопытки;
		
	ИначеЕсли ТипШтрихКода = Перечисления.ТипыШтрихКодов.Коробка  Тогда
		
		ЕАНКоробки =  ПолучитьЕАНКоробкиПоНоменклатуре(ШКЧЗ.Владелец,Контрагент);
		
		Если ЕАНКоробки = неопределено Тогда
			
			Сообщить("Ошибка записи нового агрегационного кода",СтатусСообщения.Внимание); 
			
			Возврат  неопределено; 
			
		КонецЕсли;
		
		ПорядковыйНомер = ПолучитьПорядковыйНомерПоПрефиксу("03" + "0" + ЕАНКоробки + "21");
		ПорядковыйНомерСтрока = Формат(ПорядковыйНомер,"ЧЦ=6; ЧВН=; ЧГ=0"); 
		
		НаименованиеАгрегКода = "03" + "0" + ЕАНКоробки + "21" + ПорядковыйНомерСтрока; 
		НаименованиеАгрегКодаСоСкобками = "(03)" + "0" + ЕАНКоробки + "(21)" + ПорядковыйНомерСтрока;
		
		НовыйЭлемент = Справочники.АгрегационныеКодыКонтрагентов.СоздатьЭлемент(); 
		НовыйЭлемент.Наименование = НаименованиеАгрегКода; 
		НовыйЭлемент.ТипШК 		= ТипШтрихКода; 
		НовыйЭлемент.Контрагент = Контрагент; 
		НовыйЭлемент.ШКЧЗ 		= ШКЧЗУпаковки; 
		НовыйЭлемент.НаименованиеСоСкобками = НаименованиеАгрегКодаСоСкобками;
		//++Данилова Е.В. 23.04.2025 пока без задачи
		НовыйЭлемент.УстановитьНовыйКод();
		//--Данилова Е.В. 23.04.2025
		//++Данилова Е.В. 26.05.2025  ASU-2264
		НовыйЭлемент.Номенклатура = ШКЧЗ.Владелец; 
		//--Данилова Е.В. 26.05.2025 
		Попытка
			
			НовыйЭлемент.Записать();
			
			Возврат НовыйЭлемент.ссылка; 
			
		Исключение
			Возврат Неопределено; 
