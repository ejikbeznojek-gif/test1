Функция ВерсияПлатформы() Экспорт
	СисИнфо = Новый СистемнаяИнформация;
	
	Возврат НомерИзЧастей(СтрРазделить(СисИнфо.ВерсияПриложения, "."));
КонецФункции //ВерсияПлатформы()

Функция ВерсияПлатформыПоРежимуСовместимости() Экспорт
	РежимСовместимости = ВРег(""+Метаданные.РежимСовместимости);
	
	Если РежимСовместимости = ВРег("НеИспользовать") Тогда
		Результат = ВерсияПлатформы();
	Иначе	                  		
		РежимСовместимости = СтрЗаменить(РежимСовместимости, "ВЕРСИЯ", "");	
		Результат = НомерИзЧастей(СтрРазделить(РежимСовместимости, "_"));				
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ВерсияПлатформыПоРежимуСовместимости() Экспорт

Функция НомерИзЧастей(Части)
	Результат = Части[0];
	Если Части.Количество() > 1 Тогда
		Результат = Результат + "." + Прав("000" + Части[1], 3);
	КонецЕсли;
	Если Части.Количество() > 2 Тогда
		Результат = Результат + "." + Прав("000" + Части[2], 3);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НомерИзЧастей(Части)

Функция ЗаписатьОтложенныеДвиженияДокументов(тПараметров = Неопределено) Экспорт
	Если ТипЗнч(тПараметров) = Тип("ТаблицаЗначений") Тогда
		пОбработки = Новый Соответствие;
		Для каждого СтрокаП Из тПараметров Цикл
			ТекЗнач = пОбработки[СтрокаП.Имя];	
			Если ТекЗнач = Неопределено Тогда
				ТекЗнач = СтрокаП.Значение;
			Иначе         
				ТекЗнач = ТекЗнач + "," + СтрокаП.Значение;
			КонецЕсли;                       
			пОбработки[СтрокаП.Имя] = ТекЗнач;
		КонецЦикла;
	Иначе
		пОбработки = тПараметров;	
	КонецЕсли;

	Возврат РегистрыСведений.ОтложенныеДвиженияДокументов.ЗаписатьОтложенныеДвиженияДокументов(пОбработки);	
КонецФункции //ЗаписатьОтложенныеДвиженияДокументов(тПараметров = Неопределено) Экспорт

