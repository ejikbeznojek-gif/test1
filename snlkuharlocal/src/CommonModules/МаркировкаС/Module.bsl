			НоваяСтрокаСодер.Количество = КоличествоВКоробке; 
			НоваяСтрокаСодер.КоличествоКоробок = КоличествоКоробок; 
			НоваяСтрокаСодер.Номенклатура = СтрокаТЧ.Номенклатура;	
			
		КонецЕсли;
		
