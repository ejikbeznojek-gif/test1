	|		РасходнаяНакладная.Ссылка = &Ссылка
	|		И РасходнаяНакладнаяТовары.Количество > 0
	|		И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|		И НЕ РасходнаяНакладная.ОтгрузкаКомплектов
	|		И РасходнаяНакладнаяТовары.ТребуетсяМаркировка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		СУММА(РасходнаяНакладнаяТовары.Количество)
	|	ИЗ
	|		Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|			ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|	ГДЕ
	|		РасходнаяНакладная.Ссылка = &Ссылка
	|		И РасходнаяНакладнаяТовары.Количество > 0
	|		И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|		И РасходнаяНакладная.ОтгрузкаКомплектов
	|		И РасходнаяНакладнаяТовары.ТребуетсяМаркировка) КАК Вложенныйзапрос";
	
	Запрос.УстановитьПараметр("Ссылка", РНК);
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КоличествоДокумента = РНК.КоличествоДокумента; 
	ВыборкаДетальныеЗаписи.Следующий(); 
	КоличествоДокумента = ВыборкаДетальныеЗаписи.Количество;
	Если КоличествоДокумента = NULL Тогда
		
		КоличествоДокумента = 0; 	
		
	КонецЕсли;
	
	Если КоличествоДокумента > (КоличествоШтук  + КолШКЗаранееАгрегированных) Тогда //или комплектующих?? 
		
		Результат.Успешно = Ложь;
		ТекстОшибки = "Количество товаров в документе %1 больше, чем товаров, остканированных в ЛН/ЛП %2, %3"; 
		ТекстОшибки = СтрШаблон(ТекстОшибки,КоличествоДокумента,КоличествоШтук  + КолШКЗаранееАгрегированных,РНК); 
		//ТекстОшибки = "Количество товаров в документе "  + Строка(КоличествоДокумента) +" больше, чем товаров, остканированных в ЛН/ЛП " + Строка(КоличествоШтук  + КолШКЗаранееАгрегированных); 
		Результат.ошибки.Добавить(ТекстОшибки);
		
	КонецЕсли;

КонецПроцедуры

Процедура КонтрольЧЗПоРНКОжиданиеПаллетированияПоПравиламЧЗ(Результат, Знач РНК)
	
	ПравилаРаботыСАгрегациейЧЗ=МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(РНК);
	
	ТребуетсяАгрегацияБлочков = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков;
	ТребуетсяАгрегацияКоробок = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок;
	ТребуетсяАгрегацияПаллет = ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияПаллет;
	//++Данилова Е.В. 01.04.2026
	//ЕстьЛП = ЕстьЛПСАгрегацией(РНК);
	ЕстьЛП = ЕстьЛПСКодамиЧЗ(РНК); 
	//--Данилова Е.В. 01.04.2026 
	
	Если ПравилаРаботыСАгрегациейЧЗ.УстановленыПравилаРаботыСАгрегацией Тогда 		
		
		//1. проверяем, что есть все агрегации 
		
		Запрос = Новый запрос;
		Запрос.УстановитьПараметр("ДокументОснование",РНК);
		запрос.Текст =
		"ВЫБРАТЬ
		|	МаркировкаТоваровИСМП.Ссылка КАК ДокМаркировки
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|ГДЕ
		|	МаркировкаТоваровИСМП.Проведен
		|	И МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
		|	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
		|	И МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаркировкаТоваровИСМП.Ссылка КАК ДокМаркировки
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|ГДЕ
		|	МаркировкаТоваровИСМП.Проведен
		|	И МаркировкаТоваровИСМП.ДокументОснование = &ДокументОснование
		|	И МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
		|	И МаркировкаТоваровИСМП.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок)";
		
		ПакетРезультатов = Запрос.ВыполнитьПакет(); 
		
		ТекстОшибки = ""; 
		
		Если ТребуетсяАгрегацияКоробок 
			И ПакетРезультатов[0].Пустой() Тогда
			
			Результат.Успешно = Ложь; 
			ТекстОшибки = "Не найдена ОМ (агрегация) по коробкам, " + Строка(РНК); 	
			Результат.ошибки.Добавить(ТекстОшибки); 
			
		КонецЕсли; 
		
		Если ТребуетсяАгрегацияБлочков 
			И ПакетРезультатов[1].Пустой() Тогда
			
			Результат.Успешно = Ложь; 
			ТекстОшибки = "Не найдена ОМ (агрегация) по блочкам, " + Строка(РНК); 	
			Результат.ошибки.Добавить(ТекстОшибки); 
			
		КонецЕсли;////
		  	
			
		//2. проверяем, что все агрегации заполнены по ЛП/ЛН 
		
		Если ТребуетсяАгрегацияКоробок Тогда
			
			
			Запрос = Новый Запрос;
			Если ЕстьЛП Тогда 
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ЛистПереукладки.Ссылка КАК ЛП
				|ИЗ
				|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
				|		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладки.Ссылка
				|ГДЕ
				|	ЛистПереукладки.ДокОснование = &ДокОснование
				|	И (ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
				|			ИЛИ ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок))
				|	И ЛистПереукладки.КодАгрегации = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяССылка)
				|	И ЛистПереукладки.Проведен";
			Иначе
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ЛистНабора.Ссылка КАК ЛП
				|ИЗ
				|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
				|		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка
				|ГДЕ
				|	ЛистНабора.ДокОснование = &ДокОснование
				|	И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
				|			ИЛИ ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Блочок))
				|	И ЛистНабора.КодАгрегации = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяССылка)
				|	И ЛистНабора.Проведен";
			КонецЕсли;
			
			Запрос.УстановитьПараметр("ДокОснование", РНК);		
			РезультатЗапроса = Запрос.Выполнить();
			
			Если  НЕ РезультатЗапроса.Пустой() Тогда 
				Результат.Успешно = Ложь;
				Выборка = РезультатЗапроса.Выбрать(); 
				
				Пока Выборка.Следующий() Цикл  		
					ИмяДок = ?(ЕстьЛП,"ЛП","ЛН"); 
					ТекстОшибки = "По " + ИмяДок + " не заполнен код агрегации короба " + Строка(Выборка.ЛП) + " " + Строка(РНК);	
					Результат.ошибки.Добавить(ТекстОшибки);
					
				КонецЦикла;			
				
			КонецЕсли; 		
			
		КонецЕсли;  	 
		
		Если ТребуетсяАгрегацияБлочков  Тогда 
			
			Запрос = Новый Запрос;
			Если ЕстьЛП Тогда 
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ЛистПереукладки.Ссылка КАК ЛП
				|ИЗ
				|	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладки
				|		ПО ЛистПереукладкиШтрихкодыУпаковок.Ссылка = ЛистПереукладки.Ссылка
				|ГДЕ
				|	ЛистПереукладки.ДокОснование = &ДокОснование
				|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
				|	И ЛистПереукладкиШтрихкодыУпаковок.ШтрихкодБлочка = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяССылка)
				|	И ЛистПереукладки.Проведен";
			Иначе
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ЛистНабора.Ссылка КАК ЛП
				|ИЗ
				|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора КАК ЛистНабора
				|		ПО ЛистНабораШтрихкодыУпаковок.Ссылка = ЛистНабора.Ссылка
				|ГДЕ
				|	ЛистНабора.ДокОснование = &ДокОснование
				|	И ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
				|	И ЛистНабораШтрихкодыУпаковок.ШтрихкодБлочка = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяССылка)
				|	И ЛистНабора.Проведен";
			КонецЕсли;
			
			Запрос.УстановитьПараметр("ДокОснование", РНК);		
			РезультатЗапроса = Запрос.Выполнить();
			
			Если  НЕ РезультатЗапроса.Пустой() Тогда 
				Результат.Успешно = Ложь;
				Выборка = РезультатЗапроса.Выбрать(); 
				
				Пока Выборка.Следующий() Цикл  		
					ИмяДок = ?(ЕстьЛП,"ЛП","ЛН");
					ТекстОшибки = "По "  + ИмяДок + " заполнены НЕ ВСЕ коды по блочкам " + Строка(Выборка.ЛП) + " " + Строка(РНК);	
					Результат.ошибки.Добавить(ТекстОшибки);
					
				КонецЦикла;			
				
			КонецЕсли; 	
			
		КонецЕсли; 
		
		
	КонецЕсли;
	
	
КонецПроцедуры
 

