#Область Перемаркировка
Процедура ЗапуститьВФонеСозданиеЗаказовКодовМаркировки(Знач ДокРегистрации, Знач ИдентификаторФЗ) Экспорт
	МассивПараметров = Новый Массив; 
	МассивПараметров.Добавить(ДокРегистрации);

	ФЗ = ФоновыеЗадания.Выполнить("МаркировкаС.ЗаписатьВФонеЗаказКодовМаркировки", МассивПараметров, ИдентификаторФЗ,
		"ЗаписатьВФонеЗаказКодовМаркировки"); 
	
КонецПроцедуры

Процедура ЗаписатьВФонеЗаказКодовМаркировки(Знач ДокументРегистрации) Экспорт
	
	Документы.Перемаркировка.СоздатьЗаказыКодовМаркировки(ДокументРегистрации);  
	
КонецПроцедуры  

Процедура ИзменитьСтатусПеремаркировкиВФоне(Знач ДокРегистрации,Знач ВерсияДанных, Знач ИдентификаторФЗ, Статус = неопределено) Экспорт 

	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(ДокРегистрации); 
	МассивПараметров.Добавить(Статус);
	МассивПараметров.Добавить(ВерсияДанных);

	ФЗ = ФоновыеЗадания.Выполнить("МаркировкаС.ИзменитьСтатусПеремаркировки", МассивПараметров, ИдентификаторФЗ,
		"ИзменитьСтатусПеремаркировки");	

КонецПроцедуры

Процедура ИзменитьСтатусПеремаркировки(Знач ДокументРегистрации, Статус = Неопределено,ВерсияДанных = неопределено)  Экспорт 
	
	Если Статус = Неопределено Тогда
		
		Статус = Перечисления.СтатусыПеремаркировки.ОбработаноЧЗ; 	
		
	КонецЕсли;
	
	Если ВерсияДанных = Неопределено Тогда 
		Документы.Перемаркировка.УстановитьСтатусПеремаркировки(ДокументРегистрации,Статус);
	Иначе
		ДокЗаписан = Ложь; 
		ПроверкаВерсииДокументаПриЗаписи(ВерсияДанных,Документрегистрации,ДокЗаписан);
		
		Если ДокЗаписан Тогда
			
			Документы.Перемаркировка.УстановитьСтатусПеремаркировки(ДокументРегистрации,Статус); 
		Иначе 
			
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Ошибка выполнения в фоне изменения статуса по перемаркировке'"), 
			УровеньЖурналаРегистрации.Ошибка, 
			, 
			, 
			НСтр("ru = 'Ошибка в ""ИзменитьСтатусПеремаркировкиВФоне"".'"));
			
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

 Процедура ПроверкаВерсииДокументаПриЗаписи(Знач ВерсияНовая,Знач ДокументРегистрации,ДокЗаписан,СекундПауза = 0) Экспорт 
	
	Если СекундПауза >= 100 Тогда 
		
		ДокЗаписан = Ложь;	
		
	ИначеЕсли ВерсияНовая <> ДокументРегистрации.ссылка.ВерсияДанных Тогда 
		
		МаркировкаКС.Пауза(2); 
		
		СекундПауза = СекундПауза + 2; 
		
		ПроверкаВерсииДокументаПриЗаписи(ВерсияНовая,ДокументРегистрации,ДокЗаписан,СекундПауза); 
	Иначе 
		ДокЗаписан = истина;  
	КонецЕсли;

КонецПроцедуры



