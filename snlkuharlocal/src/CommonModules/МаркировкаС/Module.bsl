Функция ЕстьЛПСКодамиЧЗ(Накладная) экспорт
	запрос=новый запрос;
	запрос.УстановитьПараметр("Накладная",Накладная);
	запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
	              |	ЛП.Ссылка КАК Ссылка
	              |ИЗ
	              |	Документ.ЛистПереукладки КАК ЛП
	              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛПШК
	              |		ПО ЛП.Ссылка = ЛПШК.Ссылка
	              |ГДЕ
	              |	ЛП.Проведен
	              |	И ЛП.ДокОснование = &Накладная"; 
	выборка=запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл
		возврат Истина;
	КонецЦикла;
	//++Данилова Е.В. 03.04.2026 MARK-3539 
	ИспользоватьЛНТолькоДляНабора = ИспользоватьЛНТолькоДляНабора(Накладная); 
	Возврат ИспользоватьЛНТолькоДляНабора;  
	//возврат Ложь;
	//--Данилова Е.В. 03.04.2026
КонецФункции
