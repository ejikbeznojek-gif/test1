		ПорядковыйНомер = Прав(Выборка.Наименование,СтрДлина(Выборка.Наименование) - СтрДлина(Префикс)); 
		
		Попытка
			
			 Возврат Число(ПорядковыйНомер) + 1; 
			
		Исключение
			
			Возврат 1; 
			
		КонецПопытки;
		
		//Данилова Е.В. 23.04.2025 вернула обратно
		
		//ПорядковыйНомер = Выборка.Количество + 1;
		
		//Возврат ПорядковыйНомер;
		// Кельманов А.В. - Исправление ошибки - 2025.04.17 }
		
	КонецЕсли;

