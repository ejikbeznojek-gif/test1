Функция ДобавитьУзелВПолучателей(СписокПолучателей, УзелПолучатель, УзелОтправитель, Загрузка) Экспорт
	Если Загрузка И УзелПолучатель = УзелОтправитель Тогда //туда-сюда гонять не будем		
	Иначе
		Если ЗначениеЗаполнено(УзелПолучатель) Тогда
			СписокПолучателей.Добавить(УзелПолучатель);
		КонецЕсли;
	КонецЕсли;	
КонецФункции // Добавить()

Функция ОбъектСуществует(Ссылка, Знач ИмяТаблицы = "") Экспорт
	Если Ссылка = Неопределено Тогда
		Возврат Ложь;
	ИначеЕсли Ссылка=Null Тогда
		Возврат Ложь;
	ИначеЕсли НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ложь;							
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяТаблицы) Тогда
		МетаОбъект = Метаданные.НайтиПоПолномуИмени(ИмяТаблицы);
	Иначе				
		МетаОбъект = Метаданные.НайтиПоТипу(ТипЗнч(Ссылка)); 
	КонецЕсли; 
	
	Если МетаОбъект = Неопределено Тогда
		Возврат Ложь;	
	КонецЕсли;	
	
	Запрос			= Новый Запрос;
	Запрос.Текст	= "ВЫБРАТЬ ВерсияДанных ИЗ " + МетаОбъект.ПолноеИмя() + " ГДЕ Ссылка=&Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();	
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ВерсияДанных));
КонецФункции //ОбъектСуществует(Ссылка, Знач ИмяТаблицы = "") Экспорт

