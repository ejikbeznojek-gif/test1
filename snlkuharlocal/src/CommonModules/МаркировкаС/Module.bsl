Функция ПолучитьПорядковыйНомерПоПрефиксу(Префикс)

	Запрос = Новый Запрос;
	//++Данилова Е.В. 23.04.2025 без задачи
	//Запрос.Текст = "ВЫБРАТЬ
	//// Кельманов А.В. - Исправление ошибки - 2025.04.17 {
	////|	АгрегационныеКодыКонтрагентов.Наименование КАК Наименование
	//|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АгрегационныеКодыКонтрагентов.Наименование) КАК Количество
	//// Кельманов А.В. - Исправление ошибки - 2025.04.17 }
	//|ИЗ
	//|	Справочник.АгрегационныеКодыКонтрагентов КАК АгрегационныеКодыКонтрагентов
	//|ГДЕ
	//|	НЕ АгрегационныеКодыКонтрагентов.ПометкаУдаления
	//|	И АгрегационныеКодыКонтрагентов.Наименование ПОДОБНО &Наименование"; 
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	АгрегационныеКодыКонтрагентов.Наименование КАК Наименование
	|ИЗ
	|	Справочник.АгрегационныеКодыКонтрагентов КАК АгрегационныеКодыКонтрагентов
	|ГДЕ
	|	НЕ АгрегационныеКодыКонтрагентов.ПометкаУдаления
	|	И АгрегационныеКодыКонтрагентов.Наименование ПОДОБНО &Наименование
	|
	|УПОРЯДОЧИТЬ ПО
	|	АгрегационныеКодыКонтрагентов.Наименование УБЫВ";

	//--Данилова Е.В. 23.04.2025
	
	Запрос.УстановитьПараметр("Наименование", Префикс + "%");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
