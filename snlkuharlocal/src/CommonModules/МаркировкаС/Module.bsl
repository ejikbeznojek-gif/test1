Функция ПолучитьЕАНКоробкиПоНоменклатуре(Номенклатура,Контрагент)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МатрицаТовары.Номенклатура КАК Номенклатура,
		|	МатрицаТовары.ШККонтрагентаКоробка КАК ШККонтрагентаКоробка
