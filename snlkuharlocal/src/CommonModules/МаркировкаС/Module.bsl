	//--Данилова Е.В. 01.04.2026
	Запрос.УстановитьПараметр("РНК", РНК);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	
	ВыборкаПоШтукам = ПакетЗапросов[6].Выбрать();
	ВыборкаПоКоробкам = ПакетЗапросов[7].Выбрать();
	ВыборкаПоКоробкамВсего = ПакетЗапросов[8].Выбрать();
	
	Пока ВыборкаПоШтукам.Следующий() Цикл
		
		ТекстОшибки = СтрШаблон("Количество отсканированных штук в коробки %1 по товару %2 не совпадает с запланированным %3",
		ВыборкаПоШтукам.КоличествоОтсканированное,ВыборкаПоШтукам.Номенклатура,ВыборкаПоШтукам.КоличествоПоПлану); 
		
		
		Результат.Ошибки.Добавить(ТекстОшибки); 		
		
	КонецЦикла;
	
	Пока ВыборкаПоКоробкам.Следующий() Цикл 		
		
		
		ТекстОшибки = СтрШаблон("Количество отсканированных коробов %1 по товару %2 не совпадает с запланированным %3",
		ВыборкаПоКоробкам.КоличествоОтсканированное,ВыборкаПоКоробкам.Номенклатура,ВыборкаПоКоробкам.КоличествоПоПлану); 
		
		
		Результат.Ошибки.Добавить(ТекстОшибки); 		
		
	КонецЦикла;
	
	Пока ВыборкаПоКоробкамВсего.Следующий() Цикл 		
		
		
		ТекстОшибки = СтрШаблон("Количество отсканированных коробов %1 ИТОГОВОЕ не совпадает с запланированным %2",
		ВыборкаПоКоробкамВсего.КоличествоОтсканированное,ВыборкаПоКоробкамВсего.КоличествоПоПлану); 
		
		
		Результат.Ошибки.Добавить(ТекстОшибки); 		
		
	КонецЦикла;
	
КонецПроцедуры 

Процедура РассчитатьКоличествоКоробокПоВведеннымДанным(СодержимоеБлочка,ВсегоБлочков,Коробки, РНК,ЭтоFBS)
    Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВтСодержимое.НомерБлочка КАК НомерБлочка,
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	ВтСодержимое.Количество КАК Количество,
		|	ВтСодержимое.НомерКоробки КАК НомерКоробки
		|ПОМЕСТИТЬ ВтСодержимое
		|ИЗ
		|	&СодержимоеБлочка КАК ВтСодержимое
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВсегоБлочков.НомерБлочка КАК НомерБлочка,
		|	ВТВсегоБлочков.КоличествоБлочков КАК Количество
		|ПОМЕСТИТЬ ВТВсегоБлочков
		|ИЗ
		|	&ВсегоБлочков КАК ВТВсегоБлочков
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	СУММА(ВтСодержимое.Количество * ВТВсегоБлочков.Количество) КАК Количество,
		|	ВтСодержимое.НомерКоробки КАК НомерКоробки
		|ПОМЕСТИТЬ ВТВПравилах
		|ИЗ
		|	ВТВсегоБлочков КАК ВТВсегоБлочков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтСодержимое КАК ВтСодержимое
		|		ПО ВТВсегоБлочков.НомерБлочка = ВтСодержимое.НомерБлочка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВтСодержимое.Номенклатура,
		|	ВтСодержимое.НомерКоробки,
		|	ВтСодержимое.НомерБлочка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
		|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
		|ГДЕ
		|	РасходнаяНакладнаяТовары.Ссылка = &ДокОснование
		|	И РасходнаяНакладнаяТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
		|	И РасходнаяНакладнаяТовары.ТребуетсяМаркировка
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходнаяНакладнаяТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
		|	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
		|ПОМЕСТИТЬ ВтКомплектующие
		|ИЗ
		|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		|ГДЕ
		|	РасходнаяНакладнаяКомплектующие.Ссылка = &ДокОснование
		|	И РасходнаяНакладнаяКомплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
		|	И РасходнаяНакладнаяКомплектующие.ТребуетсяМаркировка
		|	И НЕ &ЭтоFBS
		|	И &ОтгрузкаКомплектов
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходнаяНакладнаяКомплектующие.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТовары.Номенклатура КАК Номенклатура,
		|	ВтТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВтТоварыРНК
		|ИЗ
		|	ВтТовары КАК ВтТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКомплектующие КАК ВтКомплектующие
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ВтКомплектующие.Номенклатура ЕСТЬ NULL
		|	И ВтТовары.Количество > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВтКомплектующие.Номенклатура,
		|	ВтКомплектующие.Количество
		|ИЗ
		|	ВтКомплектующие КАК ВтКомплектующие
		|ГДЕ
		|	ВтКомплектующие.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТоварыРНК.Номенклатура КАК Номенклатура,
		|	ВтТоварыРНК.Количество КАК Количество
		|ИЗ
		|	ВтТоварыРНК КАК ВтТоварыРНК
		|ИТОГИ
		|	СУММА(Количество)
		|ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВПравилах.Номенклатура КАК Номенклатура,
		|	ВТВПравилах.Количество КАК Количество,
		|	ВТВПравилах.НомерКоробки КАК НомерКоробки
		|ИЗ
		|	ВТВПравилах КАК ВТВПравилах
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура,
		|	НомерКоробки";
	
	Запрос.УстановитьПараметр("СодержимоеБлочка",СодержимоеБлочка);
	Запрос.УстановитьПараметр("ВсегоБлочков",ВсегоБлочков);

	Запрос.УстановитьПараметр("ДокОснование", РНК.Ссылка);
	Запрос.УстановитьПараметр("ЭтоFBS", ЭтоFBS);
	Запрос.УстановитьПараметр("ОтгрузкаКомплектов", РНК.ОтгрузкаКомплектов);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ВыборкаТоварыИтоги = ПакетЗапросов[6].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	ТаблицаТоваровВПравилах = ПакетЗапросов[7].Выгрузить();
	
	ТаблицаТоваровВПравилахСвернутая = ТаблицаТоваровВПравилах.скопировать(); 
	
	ТаблицаТоваровВПравилахСвернутая.Свернуть("НомерКоробки","Количество"); 
	 
	ТаблицаТоваровВПравилахСвернутая.колонки.Добавить("КоличествоПроставленное",Новый ОписаниеТипов("Число"));
		 
	Пока ВыборкаТоварыИтоги.Следующий() Цикл
		
		КоличествоНеобходимое = ВыборкаТоварыИтоги.Количество;
		
		Пока КоличествоНеобходимое > 0  Цикл		
			
			ОтборПоТаблице = Новый Структура("Номенклатура",ВыборкаТоварыИтоги.Номенклатура); 
			СтрокиТЧ = ТаблицаТоваровВПравилах.НайтиСтроки(ОтборПоТаблице);  		
			КоличествоВСтрокеПравил = 0;  
			Для каждого СтрокаТЧ Из СтрокиТЧ Цикл 
				
				КоличествоВСтрокеПравил = СтрокаТЧ.Количество; 
				Если КоличествоНеобходимое = 0 Тогда 
					
					Прервать; 	
					
				КонецЕсли;
				
				Если КоличествоНеобходимое < СтрокаТЧ.Количество Тогда
					
					Продолжить; 	
					
				КонецЕсли;
				
				ОтборПоКоробам = Новый Структура("НомерКоробки",СтрокаТЧ.НомерКоробки);
				СтрокиПоКоробам =  ТаблицаТоваровВПравилахСвернутая.НайтиСтроки(ОтборПоКоробам);//должна быть одна
				Для каждого СтрокаПоКоробам Из СтрокиПоКоробам Цикл
					
					СтрокаПоКоробам.КоличествоПроставленное =  СтрокаПоКоробам.КоличествоПроставленное + СтрокаТЧ.Количество; 
				
				КонецЦикла;
				
				КоличествоНеобходимое = КоличествоНеобходимое - СтрокаТЧ.Количество;  
				
			КонецЦикла; 
			
			Если КоличествоНеобходимое < КоличествоВСтрокеПравил 
				ИЛИ КоличествоВСтрокеПравил = 0 Тогда
				КоличествоНеобходимое = 0; 
			Конецесли; 
		КонецЦикла;
	КонецЦикла; 	 
	
	Для каждого  СтрокаТЧ Из ТаблицаТоваровВПравилахСвернутая Цикл
	
		  СтрокаКороба = Коробки.Найти(СтрокаТЧ.НомерКоробки,"НомерКоробки");
		  Если СтрокаКороба <> Неопределено Тогда
			  
			  СтрокаКороба.Количество = Цел(СтрокаТЧ.КоличествоПроставленное/СтрокаТЧ.Количество);	
			  
		  КонецЕсли;
	
	КонецЦикла;
	 
 КонецПроцедуры

Функция КоличествоШКПоЗаранееСформированнымАгрегациямДоГотовоКОтгрузке(Знач ДокументОснование,ЕстьЛП = неопределено) Экспорт
	//++Данилова Е.В. 01.04.2026  MARK-3552 
	Если ЕстьЛП = Неопределено Тогда 
		ЕстьЛП = ЕстьЛПСКодамиЧЗ(ДокументОснование); 
	КонецЕсли;
	 
	Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	СУММА(ВложенныйЗапрос.КоличествоПоКоробкам) + СУММА(ВложенныйЗапрос.КоличествоПоБлочкам) КАК Количество
	//	|ИЗ
	//	|	(ВЫБРАТЬ
	//	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод) КАК КоличествоПоКоробкам,
	//	|		0 КАК КоличествоПоБлочкам
	//	|	ИЗ
	//	|		Документ.ЛистНабора КАК ЛистНабора
	//	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	//	|			ПО ЛистНабора.Ссылка = ЛистНабораШтрихкодыУпаковок.Ссылка
	//	|				И (ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка))
