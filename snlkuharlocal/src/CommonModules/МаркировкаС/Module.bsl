Функция ИмяКаталогаСРазделителем(ИмяКаталога) Экспорт
	мКаталог = СокрЛП(ИмяКаталога);
	РП = ПолучитьРазделительПутиСервера();
	Если НЕ СтрЗаканчиваетсяНа(мКаталог, РП) Тогда
		мКаталог = мКаталог + РП;	
	КонецЕсли;
	Возврат мКаталог;
КонецФункции //ИмяКаталогаСРазделителем(ИмяКаталога) Экспорт
	
Функция ПолноеИмяФайла(ИмяКаталога, ИмяФайла) Экспорт	
	Возврат ИмяКаталогаСРазделителем(ИмяКаталога) + ИмяФайла;
КонецФункции //ПолноеИмяФайла(ИмяКаталога, ИмяФайла)

Функция ПолучитьСвободныеКодыШтук(Номенклатура, Количество, ПодразделениеНанесения) Экспорт	
	//+++Чирков 20230330 - перерход на унифицированные методы получения свободных кодов
	Возврат Справочники.ШтрихкодыУпаковокТоваров.ПолучитьСвободныеКодыШтук(Номенклатура, Количество, Новый Структура("Местонахождение", ПодразделениеНанесения));
	//---Чирков 20230330 - перерход на унифицированные методы получения свободных кодов

	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если Количество = 0 Тогда
		Результат.Данные = Новый ТаблицаЗначений;
		Возврат Результат;
	КонецЕсли; 
		
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ " + МаркировкаКС.ЧислоБезДури(Количество) + "
	|	ШтрихКодУпаковки
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(,
	|		Номенклатура 							= &Номенклатура
	|		И ТипШК									= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)  
	//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522  Добавил Перемаркировку
	//|		И ШтрихКодУпаковки.СпособВводаВОборот	= ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков) 
	|		И ШтрихКодУпаковки.СпособВводаВОборот В (ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.МаркировкаОстатков), ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Перемаркировка))
	|		И ШтрихКодУпаковки.ТипУпаковки			= ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МаркированныйТовар)
	|		И (
	|			ШтрихКодУпаковки.ТипКода			= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар) ИЛИ		
	|			(
	|				ШтрихКодУпаковки.ТипКода			= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|				И ШтрихКодУпаковки.Владелец.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|			)
	|		)	
	|	)
	|ГДЕ
	|	Местонахождение = &ПодразделениеНанесения	
	|	И НЕ ВПути
	|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ГотовКПечати)	
	|ДЛЯ ИЗМЕНЕНИЯ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних
	//Чирков Д.С. 05.03.2025 +++ Оптимизация производительности - а порядок кракозябл - не сильно важен
	//|УПОРЯДОЧИТЬ ПО
	//|	ШтрихКодУпаковки.Наименование	
	//Чирков Д.С. 05.03.2025 ---
	|";	
	
	Запрос.УстановитьПараметр("ПодразделениеНанесения", ПодразделениеНанесения);
	Запрос.УстановитьПараметр("Номенклатура",			Номенклатура);	
	
	Результат.Данные = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихКодУпаковки");
		
	ПолученоКМ = Результат.Данные.Количество();
	Если ПолученоКМ <> Количество Тогда	
		ТекстОшибки = СтрШаблон("Найдено %1 свободных, из %2 требуемых кодов маркировки (%3), по подразделению: %4.",
			ПолученоКМ, Количество, Перечисления.ТипыШтрихКодов.Штука, ПодразделениеНанесения);		
		Результат.Ошибки.Добавить(ТекстОшибки);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПолучитьСвободныеКодыШтук(ВыбНоменклатура)

