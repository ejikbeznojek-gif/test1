Функция ВыполнитьВФоне(ИмяПроцедуры, пОбработки = Неопределено, КлючФЗ = "", Наименование = "") Экспорт	
	
	пМетода = Новый Массив;
	пМетода.Добавить(ИмяПроцедуры);
	пМетода.Добавить(пОбработки);
	
	ФЗ = ФоновыеЗадания.Выполнить("МаркировкаС.ФоноваяФункция", пМетода, КлючФЗ, Наименование);
	
	Возврат ФЗ.УникальныйИдентификатор;

КонецФункции

Функция ФоноваяФункция(ИмяПроцедуры, пОбработки) Экспорт
	Части = СтрРазделить(ИмяПроцедуры, ".");
	Если Части[0] = "Обработка" Тогда		
		Обработка = Обработки[Части[1]].Создать();
		Результат = Вычислить("Обработка."+Части[2]+"(пОбработки)");
		
		АдресРезультата = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "АдресРезультата");
		Если ЭтоАдресВременногоХранилища(АдресРезультата) Тогда
			ПоместитьВоВременноеХранилище(Результат, АдресРезультата);										
		КонецЕсли;		
	ИначеЕсли Части[0] = "ВнешняяОбработка" Тогда
		
		ИмяВФ = ПолучитьИмяВременногоФайла("epf");		
		пОбработки.ОбразОбработки.Записать(ИмяВФ);
		
		ОЗОД = Новый ОписаниеЗащитыОтОпасныхДействий;
		ОЗОД.ПредупреждатьОбОпасныхДействиях = Ложь;		
		
		Обработка = ВнешниеОбработки.Создать(ИмяВФ, Ложь, ОЗОД); 
		
		УдалитьФайлы(ИмяВФ,"*");
		
		Результат = Вычислить("Обработка."+Части[2]+"(пОбработки)");
		
		АдресРезультата = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "АдресРезультата");
		Если ЭтоАдресВременногоХранилища(АдресРезультата) Тогда
			ПоместитьВоВременноеХранилище(Результат, АдресРезультата);										
		КонецЕсли;		
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции //ФоноваяФункция(ИмяПроцедуры, пОбработки)
 

Процедура СообщитьПрогресс(Знач Процент = Неопределено, Знач Текст = Неопределено, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ПолучитьТекущийСеансИнформационнойБазы().ПолучитьФоновоеЗадание() = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Данные = Новый Структура("ТипСообщения,Прогресс", "Прогресс", ПрогрессДанные());
	Если Процент <> Неопределено Тогда
		Данные.Прогресс.Процент = Процент;
	КонецЕсли;	
	Если Текст <> Неопределено Тогда
		Данные.Прогресс.Текст	= Текст;
	КонецЕсли;
	
	Если ДопПараметры <> Неопределено Тогда
		Данные.Прогресс.Вставить("ДопПараметры", ДопПараметры);
	КонецЕсли;	
	
	МаркировкаКС.СообщитьПользователю(ЗначениеВСтрокуВнутр(Данные));
	
КонецПроцедуры

Функция ПрогрессДанные(Процент = 0, Текст = "")

	Возврат Новый Структура("Процент,Текст", Процент,Текст);

КонецФункции // ()
 

Функция ПрочитатьПрогрессИСообщения(Знач ИдентификаторЗадания, Знач Режим = "ПрогрессИСообщения") Экспорт
	
	Сообщения = Новый ФиксированныйМассив(Новый Массив);
	Результат = Новый Структура("Сообщения, Прогресс", Сообщения, Неопределено);
	
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);
	Если Задание = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивСообщений = Задание.ПолучитьСообщенияПользователю(Истина);
	Если МассивСообщений = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Количество		= МассивСообщений.Количество();
	Сообщения		= Новый Массив;
	
	ЧитатьСообщения = (Режим = "ПрогрессИСообщения" Или Режим = "Сообщения"); 
	ЧитатьПрогресс  = (Режим = "ПрогрессИСообщения" Или Режим = "Прогресс"); 
	
	Если ЧитатьСообщения И Не ЧитатьПрогресс Тогда
		Результат.Сообщения = Новый ФиксированныйМассив(МассивСообщений);
		Возврат Результат;
	КонецЕсли;
	
	Для Номер = 0 По Количество - 1 Цикл
		Сообщение = МассивСообщений[Номер];
		
		Если СтрНачинаетсяС(Сообщение.Текст, "{") Тогда
			Данные = ЗначениеИзСтрокиВнутр(Сообщение.Текст); 					
			ТипСообщения = МаркировкаКС.ПолучитьЗначениеПараметра(Данные, "ТипСообщения");
			Если ТипСообщения = "Прогресс" Тогда
				Если ЧитатьПрогресс Тогда				
					Результат.Прогресс 	= Данные.Прогресс;
				КонецЕсли; 				
			Иначе
				Если ЧитатьСообщения Тогда
					Сообщения.Добавить(Сообщение);				
				КонецЕсли; 				
			КонецЕсли; 					
		КонецЕсли;		
	КонецЦикла;
	
	Результат.Сообщения = Новый ФиксированныйМассив(Сообщения);
	
	Возврат Результат;	
КонецФункции //ПрочитатьПрогрессИСообщения(Знач ИдентификаторЗадания, Знач Режим = "ПрогрессИСообщения")

Функция УстановитьОтборДинСписка(ДинСписок, Отбор) Экспорт
	мОтбор		= ДинСписок.Отбор;
	мОтбор.Элементы.Очистить();		
	
	Для Каждого КиЗ Из Отбор Цикл
		ЭлементОтбора = мОтбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		
		ЭлементОтбора.ЛевоеЗначение		= Новый ПолеКомпоновкиДанных(КиЗ.Ключ);
		ЭлементОтбора.ВидСравнения		= ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение	= Киз.Значение;
		ЭлементОтбора.Использование		= Истина;
	КонецЦикла; 	
КонецФункции //УстановитьОтборДинСписка(ДинСписок, Отбор) Экспорт

Функция ПолучитьНоменклатуруДокумента(ДокСсылка, ИмяТЧ = "Товары") Экспорт
	
	Запрос			= Новый Запрос;
	Запрос.Текст	= " 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ					
	|	Номенклатура
	|ИЗ
	|	"+ДокСсылка.Метаданные().ПолноеИмя()+"."+ИмяТЧ+"
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
