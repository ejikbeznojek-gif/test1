Функция ПроверитьЕАНБлочкаПоМассивуТоваровИзБлочка(МассивТоваров,Контрагент) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МатрицаТовары.ШККонтрагентаБлочок КАК ШККонтрагентаБлочок
		|ИЗ
		|	Документ.Матрица КАК МатрицаДок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.Товары КАК МатрицаТовары
		|		ПО МатрицаДок.Ссылка = МатрицаТовары.Ссылка
		|ГДЕ
		|	МатрицаДок.Контрагент = &Контрагент
		|	И МатрицаТовары.ШККонтрагента <> """"
		|	И МатрицаДок.Проведен
		|	И (МатрицаДок.ДатаОкончания > &ТекущаяДата
		|			ИЛИ МатрицаДок.ДатаОкончания < ДАТАВРЕМЯ(2000, 1, 1))
		|	И МатрицаТовары.Номенклатура В(&МассивТоваров)";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("МассивТоваров", МассивТоваров);
