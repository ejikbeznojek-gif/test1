	|	ЛистНабора.Ссылка как ЛН,
	|	1 КАК  КоличествоКоробок, 
	|	ЛистНабора.ТипКороба  как ТипКороба
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистНабора
	|ГДЕ
	|	ЛистНабора.Проведен
	|	И ЛистНабора.ДокОснование = &ДокОснование";
	запрос.УстановитьПараметр("ДокОснование",Документ.ссылка);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()=0 тогда				
		Запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ
		|	ЛистНабора.Ссылка как ЛН,
		|	ЛистНабора.КоличествоКоробок как КоличествоКоробок,
		|	ЛистНабора.ТипКороба как ТипКороба
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабора
		|ГДЕ
		|	ЛистНабора.Проведен
		|	И ЛистНабора.ДокОснование = &ДокОснование";
		запрос.УстановитьПараметр("ДокОснование",Документ.ссылка);
