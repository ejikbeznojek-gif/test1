					//Переклейку обрабатываем отдельно
				иначе
					если СтрМасс.НормаРасхода*СтрРез.ЛН.переклейка.итог("Количество")>0 тогда
						СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
						СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода*СтрРез.ЛН.переклейка.итог("Количество");
						СтрокаТЗМатериалов.Номенклатура=СтрМасс.Номенклатура;
					КонецЕсли;
				КонецЕсли;
				//Кухарь 24.09.17 начало
				
				
			КонецЦикла;
			//ЛН с типом ШК - блочок и штука конец
			
			
			//Листы набора конец
			
			/////////////////////
		КонецЕсли;
		
		
	КонецЦикла;
	//КонецЕсли;
	возврат ТЗМатериалов;
КонецФункции

Функция ОбработатьПаллеты (Документ,ТЗМатериалов);
	
	
	запрос=новый запрос;
	//Кухарь 26.12.17 начало
	//Оптимизация
	
	//запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
	//|	ПаллетаЛистыНабора.Ссылка как Паллета
	//|ИЗ
	//|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	//|ГДЕ
	//|	ПаллетаЛистыНабора.Документ = &Документ
	//|	И ПаллетаЛистыНабора.Ссылка.Проведен
	//|	И ПаллетаЛистыНабора.Ссылка.Проведен
	//
	//|	И ПаллетаЛистыНабора.Ссылка.ОкончаниеПаллетирования <> &ПустаяДата";
	//запрос.УстановитьПараметр("Документ",Документ.ссылка);
	//запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	//результат=запрос.Выполнить().Выгрузить();
	//ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(результат.Получить(0).Паллета,Документ.ссылка);
	ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(Документы.Паллета.ПустаяСсылка(),Документ.ссылка);
	
	//Кухарь 26.12.17 конец
	
	если ТЗСтрокМатрицы=Неопределено тогда Возврат ТЗМатериалов;КонецЕсли;
	
	
	Для каждого СтрМасс из ТЗСтрокМатрицы цикл
		
		запрос.Текст="ВЫБРАТЬ
		|	ВидыНормРасходаМатериалов.Ссылка КАК ВидНормыСсылка,
		|	ВидыНормРасходаМатериалов.Наименование КАК ВидНормыНаименование,
		|	ВидыНормРасходаМатериалов.ИмяНормыРасхода КАК ИмяНормыРасхода,
		|	ВидыНормРасходаМатериалов.ЗначениеНормыРасхода КАК ЗначениеНормыРасхода,
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода КАК Владелец
		|ИЗ
		|	Справочник.ВидыНормРасходаМатериалов КАК ВидыНормРасходаМатериалов
		|ГДЕ
		|	ВидыНормРасходаМатериалов.ПометкаУдаления = ЛОЖЬ
		|	И ВидыНормРасходаМатериалов.ИмяНормыРасхода = &ИмяНормыРасхода";
		запрос.УстановитьПараметр("ИмяНормыРасхода",СтрМасс.ИмяНормыРасхода);
		НормаТекущейНоменклатуры=запрос.Выполнить().Выгрузить();
		
		
		СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
		СтрокаТЗМатериалов.Номенклатура=СтрМасс.Номенклатура;
		
		
		если СтрМасс.НормаРасхода = 0 тогда
			если НормаТекущейНоменклатуры.Количество()>=1 тогда
				СтрокаТЗМатериалов.Количество=НормаТекущейНоменклатуры.Получить(0).ЗначениеНормыРасхода;
			иначе
				СтрокаТЗМатериалов.Количество=0;
			КонецЕсли;
		иначе 
			СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода;
		КонецЕсли;
		
		СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествоПаллет;
		
		если СтрМасс.НесколькоПозиций и Документ.ссылка.метаданные().имя="РасходнаяНакладная" тогда
			Запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			|	РеквизитыСправочников.ЗначениеРеквизита
			|ИЗ
			|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
			|ГДЕ
			|	РеквизитыСправочников.Справочник = &Справочник
			|	И РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита";	
			запрос.УстановитьПараметр("Справочник",Документ[СтрМасс.ИсточникДругихПозиций]);
			запрос.УстановитьПараметр("ИмяРеквизита",СтрМасс.РеквизитИсточникаДругихПозиций);
			результат=запрос.Выполнить().Выбрать();
			пока результат.Следующий() цикл
				СтрокаТЗМатериалов.Номенклатура=результат.ЗначениеРеквизита;
			КонецЦикла;
			
			
		КонецЕсли;
		
		
	КонецЦикла;
	
	
	
	возврат ТЗМатериалов;
КонецФункции


Функция ОбработатьНакладную(Документ,ТЗМатериалов)
	ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(Документ);
	
	если ТЗСтрокМатрицы=Неопределено тогда Возврат ТЗМатериалов;КонецЕсли;
	
	
	Для каждого СтрМасс из ТЗСтрокМатрицы цикл
		СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
		СтрокаТЗМатериалов.количество=СтрМасс.НормаРасхода;
		СтрокаТЗМатериалов.номенклатура=СтрМасс.Номенклатура;
		если СтрМасс.НаКаждуюШтукуОтдельно тогда
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествоДокумента;
		ИначеЕсли СтрМасс.НаКаждуюКоробкуОтдельно тогда
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествокоробок;
		ИначеЕсли СтрМасс.НаКаждыйБлочокОтдельно тогда
			КоличествоБлочков=0;
			для каждого СтрТч из документ.товары цикл
				если СтрТч.номенклатура.родитель.ШтукВКоробочке=0 тогда Продолжить;КонецЕсли;
				КоличествоБлочков=КоличествоБлочков+СтрТч.количество/СтрТч.номенклатура.родитель.ШтукВКоробочке;
			КонецЦикла;
			КоличествоБлочков=Окр(КоличествоБлочков,0);
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*КоличествоБлочков;
			
		КонецЕсли;
	КонецЦикла;
	
	
	Возврат ТЗМатериалов;
КонецФункции