	ОбработкаАПи 		= Обработки.АпиЧЗ.Создать(); 
	//Данилова Е.В. 24.04.2026 HELP-9550 добавлен параметр
	РезультатОтработки  = ОбработкаАПи.ПолучитьДанныеИзЧЗПоКодамКМ(МассивКМ,АдресРезультата);
	
	Возврат РезультатОтработки; 

КонецФункции // ПроверитьМаркиЧЗНаСервере()

Функция ПолучитьСертификатЭЦП_ОУКЭП(Знач Организация = Неопределено) Экспорт
	Результат = "";
	Если Организация = Неопределено Тогда
		Организация = Маркировка_ПИ.ОрганизацияЕЕЭ();	
	КонецЕсли;
	
	ИНН = СокрЛП(ПолучитьРеквизитШапки(Организация, "ИНН"));
		
	ДанныеСертификатов = ПолучитьСписокСертификатовСИНН();
	
	Для Каждого Элемент Из ДанныеСертификатов Цикл                   
		Если СокрЛП(Элемент.Представление) = ИНН Тогда
			Результат = Элемент.Значение;		
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ПолучитьСертификатЭЦП_ОУКЭП(Знач Организация = Неопределено) Экспорт
