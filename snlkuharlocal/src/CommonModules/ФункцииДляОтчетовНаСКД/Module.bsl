Функция ПолучитьНаименованияЗначковПоУходу(Номенклатура,ЗначокУход)    Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТипыУпаковкиЗначки.Значок.Наименование КАК ЗначокНаименование
	               |ИЗ
	               |	Справочник.ТипыУпаковки.Значки КАК ТипыУпаковкиЗначки
	               |ГДЕ
	               |	ТипыУпаковкиЗначки.Значок В ИЕРАРХИИ(&ЗначокУход)
	               |	И ТипыУпаковкиЗначки.Ссылка = &ОсновнойТипУпаковки";
				   
				   Запрос.УстановитьПараметр("ОсновнойТипУпаковки",Номенклатура.Родитель.ОсновнойТипУпаковки);
				   Запрос.УстановитьПараметр("ЗначокУход",ЗначокУход);
				   
Выборка = запрос.Выполнить().Выбрать();
НаименованиеУхода = "";
Пока Выборка.Следующий() Цикл
НаименованиеУхода = НаименованиеУхода + Выборка.ЗначокНаименование + ",";	
КонецЦикла; 
Если не ПустаяСтрока(НаименованиеУхода) Тогда
	НаименованиеУхода = Лев(НаименованиеУхода,СтрДлина(НаименованиеУхода)-1);
КонецЕсли;
Возврат НаименованиеУхода;
КонецФункции

