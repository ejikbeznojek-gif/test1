Функция ЦенаПоследнегоПрихода(Номенклатура, Дата2) Экспорт 
	
	ЦПП = 0 ;
	
	ДатаРеквизита=Неопределено;
	//ЦПП		=ПолучитьПериодическийРеквизит(Номенклатура,"ЦенаПоследнегоПрихода",Дата,,ДатаРеквизита);
		Дата2=?(Дата2=Неопределено,ТекущаяДата(),Дата2);
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		             |	История.Значение,
		             |	История.Период КАК Период
		             |ИЗ
		             |	РегистрСведений.История КАК История
		             |ГДЕ
		             |	История.Объект В ИЕРАРХИИ(&Объект)
		             |	И История.Реквизит = &Реквизит
		             |	И История.Период <= &Дата2
		             |
		             |УПОРЯДОЧИТЬ ПО
		             |	Период УБЫВ";			
		
		
	Запрос.УстановитьПараметр("Дата2",КонецДня(Дата2));
	Запрос.УстановитьПараметр("Объект",Номенклатура);
	Запрос.УстановитьПараметр("Реквизит","ЦенаПоследнегоПрихода");
	
	Выборка=Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Значение;
	КонецЦикла; 
	
	
	
	Возврат 0;
			
КонецФункции
