////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
///// ПОЛУЧИТЬ ОБЪЕКТ ПО СТРОКЕ УИД (УНИВЕРСАЛЬНАЯ ФУНКЦИЯ)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
Функция НайтиОбъектПоУИД(УникальныйИдентификаторСтрокой, ТипМетаданных = "Справочник", ВидМетаданных = "") Экспорт
	
	УИД = Новый УникальныйИдентификатор(УникальныйИдентификаторСтрокой);
	
	Если ТипМетаданных = "Справочник" Тогда
		Ссылка = ПолучитьСсылкуПоМенеджеруОбъекта(Справочники[ВидМетаданных], УИД);
	ИначеЕсли ТипМетаданных = "Документ" Тогда
		Ссылка = ПолучитьСсылкуПоМенеджеруОбъекта(Документы[ВидМетаданных], УИД);
	КонецЕсли;
	
	Если Ссылка <> Неопределено Тогда
		Возврат Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьСсылкуПоМенеджеруОбъекта(ОбъектыМенеджер, УИД)
	
	СсылкаГуид = ОбъектыМенеджер.ПолучитьСсылку(УИД);
	Если СсылкаГуид.ПолучитьОбъект() <> Неопределено Тогда
		Возврат СсылкаГуид;
	КонецЕсли;
	
	Возврат Неопределено;	
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
///// ПОЛУЧИТЬ ИЗМЕНЕНИЯ ИЗ ХРАНИЛИЩА ЗНАЧЕНИЙ (УНИВЕРСАЛЬНАЯ ФУНКЦИЯ)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
Функция ПолучитьИзмененияЖурналаРегистрации(Изменения) Экспорт
	
	СтруктураВозврата = Новый Структура("ИзмененияРеквизитов", Неопределено);
	
	Если ТипЗнч(Изменения) = Тип("ХранилищеЗначения") Тогда
		ИзмененияОбъекта = ЗначениеИзСтрокиВнутр(Изменения.Получить());
	Иначе
		ИзмененияОбъекта = ЗначениеИзСтрокиВнутр(Изменения);
	КонецЕсли;
	
	Если ТипЗнч(ИзмененияОбъекта) = Тип("Структура") Тогда
		Если ИзмененияОбъекта.Свойство("Реквизиты") Тогда
			Если ТипЗнч(ИзмененияОбъекта.Реквизиты) = Тип("ТаблицаЗначений") И ИзмененияОбъекта.Реквизиты.Количество() > 0 Тогда
				СтруктураВозврата.Вставить("ИзмененияРеквизитов", ИзмененияОбъекта.Реквизиты);
			КонецЕсли;
		КонецЕсли;
		Если ИзмененияОбъекта.Свойство("ТЧ") Тогда
			Для Каждого Элемент ИЗ ИзмененияОбъекта.ТЧ Цикл
				Если ТипЗнч(Элемент.Значение) = Тип("ТаблицаЗначений") И Элемент.Значение.Количество() > 0 Тогда
					СтруктураВозврата.Вставить(Элемент.Ключ, Элемент.Значение);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
///// ПОИСК РЕКВИЗИТА ВНУТРИ ПОЛУЧЕННЫХ ИЗМЕНЕНИЙ С СОРТИРОВКОЙ ПО ДНЯМ И СОСТОЯНИЮ ОБЪЕКТА
///// НА ВЫХОДЕ - МАССИВ СТРУКТУР С ИСТОРИЕЙ ИЗМЕНЕНИЯ РЕКВИЗИТА ПОИСКА
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
Функция ПоискИзмененийРеквизитаВЖурналеРегистрации(Объект, РеквизитПоиска = "", РеквизитТЧПоиска = "", НомерЗаписи = "Первая") Экспорт
	
	МассивРеквизитовПоиска = Новый Массив;
	МассивРеквизитовТЧПоиска = Новый Массив;
	
	////////// ПРОВЕРИМ, ЕСТЬ ЛИ ТАКОЙ РЕКВИЗИТ ///////////////////////////////////////////////////////
	Если НЕ ПустаяСтрока(РеквизитПоиска) ИЛИ НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
		Представление = Объект.Метаданные().ПолноеИмя();
		
		Если Найти(Представление, "Документ") > 0 Тогда
			
			Если НЕ ПустаяСтрока(РеквизитПоиска) Тогда
				Если НЕ ЕстьРеквизитДокумента(РеквизитПоиска, Объект.Метаданные()) Тогда
					Возврат Новый Массив;
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
				ФлагПоиска = Ложь;
				Для Каждого СтрТЧ ИЗ Объект.Метаданные().ТабличныеЧасти Цикл
					Если ЕстьРеквизитТабЧастиДокумента(РеквизитТЧПоиска, Объект.Метаданные(), СтрТЧ.Имя) Тогда
						ФлагПоиска = Истина;
					КонецЕсли;
				КонецЦикла;
				Если НЕ ФлагПоиска Тогда
					Возврат Новый Массив;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли Найти(Представление, "Справочник") > 0 Тогда
			
			Если НЕ ПустаяСтрока(РеквизитПоиска) Тогда
				Если НЕ ЕстьРеквизитОтчета(РеквизитПоиска, Объект.Метаданные()) Тогда
					Возврат Новый Массив; 
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
				ФлагПоиска = Ложь;
				Для Каждого СтрТЧ ИЗ Объект.Метаданные().ТабличныеЧасти Цикл
					Если ЕстьРеквизитТабЧастиДокумента(РеквизитТЧПоиска, Объект.Метаданные(), СтрТЧ.Имя) Тогда
						ФлагПоиска = Истина;
					КонецЕсли;
				КонецЦикла;
				Если НЕ ФлагПоиска Тогда
					Возврат Новый Массив;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	/////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	Если НЕ ПустаяСтрока(РеквизитПоиска) И НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
		ТекстПоиска = "И (ЖурналРегистрации.ИзмененияШапки = ИСТИНА ИЛИ ЖурналРегистрации.ИзмененияТЧ = ИСТИНА)";
	ИначеЕсли НЕ ПустаяСтрока(РеквизитПоиска) И ПустаяСтрока(РеквизитТЧПоиска) Тогда
		ТекстПоиска = "И ЖурналРегистрации.ИзмененияШапки = ИСТИНА";
	ИначеЕсли ПустаяСтрока(РеквизитПоиска) И НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
		ТекстПоиска = "И ЖурналРегистрации.ИзмененияТЧ = ИСТИНА";
	Иначе
		ТекстПоиска = "";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("УИДОбъекта", XMLСтрока(Объект));
	Запрос.Текст =
	"ВЫБРАТЬ " + ?(НомерЗаписи = "Первая" ИЛИ НомерЗаписи = "Последняя", "ПЕРВЫЕ 1", "") + "
	|	ЖурналРегистрации.День КАК День,
	|	ЖурналРегистрации.Изменения КАК Изменения,
	|	ЖурналРегистрации.ИзмененияШапки КАК ИзмененияШапки,
	|	ЖурналРегистрации.ИзмененияТЧ КАК ИзмененияТЧ,
	|	ВЫБОР
	|		КОГДА ЖурналРегистрации.СостояниеОбъекта = ""Первичная запись""
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ЖурналРегистрации.СостояниеОбъекта = ""Перезапись""
	|					ТОГДА 1
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ЖурналРегистрации.СостояниеОбъекта = ""Пометка на удаление""
	|							ТОГДА 2
	|						ИНАЧЕ ВЫБОР
	|								КОГДА ЖурналРегистрации.СостояниеОбъекта = ""Снятие пометки на удаление""
	|									ТОГДА 3
	|								ИНАЧЕ ВЫБОР
	|										КОГДА ЖурналРегистрации.СостояниеОбъекта = ""Удаление""
	|											ТОГДА 4
	|										ИНАЧЕ 5
	|									КОНЕЦ
	|							КОНЕЦ
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК СостояниеОбъекта
	|ИЗ
	|	РегистрСведений.ЖурналРегистрации КАК ЖурналРегистрации
	|ГДЕ
	|	ЖурналРегистрации.ТекстСсылки = &УИДОбъекта
	|	" + ТекстПоиска + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	День " + ?(НомерЗаписи = "Последняя", "УБЫВ,", "ВОЗР,") + "
	|	СостояниеОбъекта";
	
	// СостояниеОбъекта - "Первичная запись", "Перезапись", "Пометка на удаление", "Снятие пометки на удаление", "Удаление"
	// " + ТекстПоиска + "
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	МассивИменРеквизитовТЧ = Новый Массив;
	МассивИменРеквизитовТЧ.Добавить("Номенклатура");
	МассивИменРеквизитовТЧ.Добавить("Контрагент");
	МассивИменРеквизитовТЧ.Добавить("Договор");
	
	Пока Выборка.Следующий() Цикл
		
		СтруктураВозврата = ПолучитьИзмененияЖурналаРегистрации(Выборка.Изменения);
		
		////////// ВНАЧАЛЕ СМОТРИМ ПО РЕКВИЗИТАМ ////////////////////////////////////////////////////////////
		Если НЕ ПустаяСтрока(РеквизитПоиска)
			И СтруктураВозврата.Свойство("ИзмененияРеквизитов") И СтруктураВозврата.ИзмененияРеквизитов <> Неопределено Тогда
			
			НайденныеСтроки = СтруктураВозврата.ИзмененияРеквизитов.НайтиСтроки(Новый Структура("Реквизит", РеквизитПоиска));
			
			Для Каждого НайденнаяСтрока ИЗ НайденныеСтроки Цикл
				СтруктураВывода = Новый Структура("День, Реквизит, НачЗнач, КонЗнач");
				ЗаполнитьЗначенияСвойств(СтруктураВывода, НайденнаяСтрока);
				СтруктураВывода.Вставить("День", Выборка.День);
				МассивРеквизитовПоиска.Добавить(СтруктураВывода);
			КонецЦикла;
		КонецЕсли;
		
		////////// ТЕПЕРЬ ПО ТАБЛИЧНЫМ ЧАСТЯМ ///////////////////////////////////////////////////////////////
		Если НЕ ПустаяСтрока(РеквизитТЧПоиска) Тогда
			Для Каждого СтрТЧ ИЗ Объект.Метаданные().ТабличныеЧасти Цикл
				
				Если СтруктураВозврата.Свойство(СтрТЧ.Имя) И СтруктураВозврата[СтрТЧ.Имя] <> Неопределено Тогда
					/////////////////// СМОТРИМ, ЕСЛИ ЛИ СТОЛБЦЫ С ТАКИМ ИМЕНЕМ ////////////////////
					ЕстьСтолбецРеквизитаТЧПоиска = Истина;
					нКолонка = СтруктураВозврата[СтрТЧ.Имя].Колонки.Найти(РеквизитТЧПоиска + "__1");
					Если нКолонка = Неопределено Тогда
    						ЕстьСтолбецРеквизитаТЧПоиска = Ложь;
					КонецЕсли;
					ИмяСтолбцаРеквизитаТЧ = "";
					Для Каждого ИмяРеквизитаТЧ ИЗ МассивИменРеквизитовТЧ Цикл
						нКолонка = СтруктураВозврата[СтрТЧ.Имя].Колонки.Найти(ИмяРеквизитаТЧ);
						Если НЕ нКолонка = Неопределено Тогда
							ИмяСтолбцаРеквизитаТЧ = ИмяРеквизитаТЧ;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					////////////////////////////////////////////////////////////////////////////////
					Если ЕстьСтолбецРеквизитаТЧПоиска И НЕ ПустаяСтрока(ИмяСтолбцаРеквизитаТЧ) Тогда
						Для Каждого СтрокаТЗ ИЗ СтруктураВозврата[СтрТЧ.Имя] Цикл
				              	СтруктураВывода = Новый Структура("День, Реквизит, НачЗнач, КонЗнач");
							СтруктураВывода.Вставить("Реквизит", СтрокаТЗ[ИмяСтолбцаРеквизитаТЧ]);
							СтруктураВывода.Вставить("НачЗнач", СтрокаТЗ[РеквизитТЧПоиска + "__1"]);
							СтруктураВывода.Вставить("КонЗнач", СтрокаТЗ[РеквизитТЧПоиска + "__2"]);
							СтруктураВывода.Вставить("День", Выборка.День);
							МассивРеквизитовТЧПоиска.Добавить(СтруктураВывода);
						КонецЦикла;
					КонецЕсли;
				КонецЕсли;
				
		       КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивРеквизитовПоиска.Количество() > 0 Тогда
		Возврат МассивРеквизитовПоиска;
	ИначеЕсли МассивРеквизитовТЧПоиска.Количество() > 0 Тогда
		Возврат МассивРеквизитовТЧПоиска;
	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	
КонецФункции
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

//// Первая, ПерваяНенулевая, Последняя, ПоследняяНенулевая
Функция ПолучитьЗначениеЗаписиЖРпоНомеру(Объект, РеквизитПоиска = "", РеквизитТЧПоиска = "", НомерЗаписи = "Первая") Экспорт
	
	МассивИзменений = ПоискИзмененийРеквизитаВЖурналеРегистрации(Объект, РеквизитПоиска, РеквизитТЧПоиска, НомерЗаписи);
	
	Если МассивИзменений.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// МОЖНО СДЕЛАТЬ РАСШИРЯЕМУЮ ФУНКЦИЮ (СДЕЛАН ТОЛЬКО ЧАСТНЫЙ СЛУЧАЙ)
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	ПреобразоватьВДату = Ложь;
	Если Найти(ВРЕГ(РеквизитПоиска), "ДАТА") > 0 ИЛИ Найти(ВРЕГ(РеквизитТЧПоиска), "ДАТА") > 0 Тогда
		ПреобразоватьВДату = Истина;
	КонецЕсли;
	
	Значение = Неопределено;
	Если НомерЗаписи = "Первая" Тогда
		Запись = МассивИзменений[0];
		Если ПреобразоватьВДату Тогда
			Попытка
				НачЗнач = Дата(Запись.НачЗнач);
			Исключение
				НачЗнач = Дата(1,1,1);
			КонецПопытки;
			Попытка
				КонЗнач = Дата(Запись.КонЗнач);
			Исключение
				КонЗнач = Дата(1,1,1);
			КонецПопытки;
		Иначе
			НачЗнач = ?(ЗначениеЗаполнено(Запись.НачЗнач) И ЭтоЧисло(Запись.НачЗнач), ПривестиСтрокуКЧислу(Запись.НачЗнач), Запись.НачЗнач);
			КонЗнач = ?(ЗначениеЗаполнено(Запись.КонЗнач) И ЭтоЧисло(Запись.КонЗнач), ПривестиСтрокуКЧислу(Запись.КонЗнач), Запись.КонЗнач);
		КонецЕсли;
		Значение = ?(ЗначениеЗаполнено(НачЗнач), НачЗнач, КонЗнач); 
	ИначеЕсли НомерЗаписи = "Последняя" Тогда
	    Запись = МассивИзменений[МассивИзменений.Количество() - 1];
		Если ПреобразоватьВДату Тогда
			Попытка
				НачЗнач = Дата(Запись.НачЗнач);
			Исключение
				НачЗнач = Дата(1,1,1);
			КонецПопытки;
			Попытка
				КонЗнач = Дата(Запись.КонЗнач);
			Исключение
				КонЗнач = Дата(1,1,1);
			КонецПопытки;
		Иначе
			НачЗнач = ?(ЗначениеЗаполнено(Запись.НачЗнач) И ЭтоЧисло(Запись.НачЗнач), ПривестиСтрокуКЧислу(Запись.НачЗнач), Запись.НачЗнач);
			КонЗнач = ?(ЗначениеЗаполнено(Запись.КонЗнач) И ЭтоЧисло(Запись.КонЗнач), ПривестиСтрокуКЧислу(Запись.КонЗнач), Запись.КонЗнач);
		КонецЕсли;
		Значение = ?(ЗначениеЗаполнено(КонЗнач), КонЗнач, НачЗнач);
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

