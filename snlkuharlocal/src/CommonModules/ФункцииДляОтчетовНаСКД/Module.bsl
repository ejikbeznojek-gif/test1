Функция ПолучитьМесяцДаты(Дата) Экспорт
	МесяцДаты = Сред(формат(Дата,"ДФ=dd.MM.yyyy"),4,2);
	Если МесяцДаты = "01" Тогда
		МесяцДаты = "Январь";
	ИначеЕсли МесяцДаты = "02" Тогда
		МесяцДаты = "Февраль";
	ИначеЕсли МесяцДаты = "03" Тогда
		МесяцДаты = "Март";
	ИначеЕсли МесяцДаты = "04" Тогда
		МесяцДаты = "Апрель";
    ИначеЕсли МесяцДаты = "05" Тогда
		МесяцДаты = "Май";
    ИначеЕсли МесяцДаты = "06" Тогда
		МесяцДаты = "Июнь";
    ИначеЕсли МесяцДаты = "07" Тогда
		МесяцДаты = "Июль";
    ИначеЕсли МесяцДаты = "08" Тогда
		МесяцДаты = "Август";
    ИначеЕсли МесяцДаты = "09" Тогда
		МесяцДаты = "Сентябрь";
    ИначеЕсли МесяцДаты = "10" Тогда
		МесяцДаты = "Октябрь";
    ИначеЕсли МесяцДаты = "11" Тогда
		МесяцДаты = "Ноябрь";
    ИначеЕсли МесяцДаты = "12" Тогда
		МесяцДаты = "Декабрь";
	КонецЕсли;
	Возврат МесяцДаты + " "+ПолучитьГодДаты(Дата); 
КонецФункции

Функция ПолучитьКварталДаты(Дата)    Экспорт
	Дата = НачалоКвартала(Дата);
	КварталДаты = Сред(формат(Дата,"ДФ=dd.MM.yyyy"),4,2);
	Если КварталДаты = "01" Тогда
		КварталДаты = "1 квартал";
	ИначеЕсли КварталДаты = "04" Тогда
		КварталДаты = "2 квартал";	
	ИначеЕсли КварталДаты = "07" Тогда
		КварталДаты = "3 квартал";
	ИначеЕсли КварталДаты = "10" Тогда
		КварталДаты = "4 квартал";	
	КонецЕсли;
	Возврат КварталДаты + " "+ПолучитьГодДаты(Дата); 
КонецФункции
