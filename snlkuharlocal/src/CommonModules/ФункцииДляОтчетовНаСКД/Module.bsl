	// Кухарь А.Ю.  01.02.2023 начало
	//функция ПолучитьЦенуНоменклатурыУпрощДляСКД(Номенклатура,ТипЦен,ДатаРасчета=Неопределено,Валюта = неопределено) Экспорт
функция ПолучитьЦенуНоменклатурыУпрощДляСКД(Номенклатура,ТипЦен,ДатаРасчета=Неопределено,Валюта = неопределено,НеПересчитыватьКурс=ложь) Экспорт	 
	// Кухарь А.Ю.  01.02.2023 конец
	
	//Нечаева 17,06,19++
	Если Валюта = Неопределено Тогда
		ВалютаДокумента=Справочники.Валюты.НайтиПоКоду("810");
	Иначе
	    ВалютаДокумента=Валюта;
	КонецЕсли;
	//Нечаева 17,06,19---

	
	
	ВалютаДокумента=Справочники.Валюты.НайтиПоКоду("810");
	КурсДокумента=1;
	
	Если ТипЦен<>Неопределено И НЕ ТипЦен.Пустая() Тогда		
		Запрос=Новый Запрос;
		
		Если ДатаРасчета=Неопределено Тогда
			#Если Клиент Тогда		
				// нечаева 06,08,13 +++ было везде на конец дня
				//ТекДатаРасчета=КонецДня(РабочаяДата);
				ТекДатаРасчета=Текущаядата();  //РабочаяДата;
				
			#Иначе
				ТекДатаРасчета=КонецДня(ТекущаяДата());		
			#КонецЕсли		
		Иначе
			//ТекДатаРасчета=КонецДня(ДатаРасчета);	
			ТекДатаРасчета=ДатаРасчета;
		КонецЕсли;
		
		
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1	
		|	Цена,
		|	ВЫБОР 
		|		КОГДА ТипЦен = &ТипЦен ТОГДА 0		
		|	ИНАЧЕ 100 КОНЕЦ КАК Уровень
		|ИЗ
		|РегистрСведений.ЦеныНоменклатуры.СрезПоследних(КонецПериода(&Дата2,День),
		|	(ТипЦен = &ТипЦен)
		|	И Номенклатура = &Номенклатура0
		|	И Прайс.Проведен
		|	И КОНЕЦПЕРИОДА(Прайс.Дата2,День) >= &Дата2 И Прайс.Дата < &Дата2
		|	) КАК ЦеныНоменклатурыСрезПоследних
		|ГДЕ Номенклатура.ЭтоГруппа
		|УПОРЯДОЧИТЬ ПО Уровень,Прайс.Дата Убыв";
		
		
		
		
		Запрос.УстановитьПараметр("Дата2",				ТекДатаРасчета);
		Запрос.УстановитьПараметр("ТипЦен",				ТипЦен);	
		Запрос.УстановитьПараметр("ТипЦен_Базовый",		ТипЦен.Базовый);		
		
		Запрос.УстановитьПараметр("Номенклатура0",	?(Номенклатура.ЭтоГруппа,Номенклатура,Номенклатура.Родитель));
		
		Результат=Запрос.Выполнить();
		//крохин начало 22.09.2011
		//единицу не используем больше
		//Коэффициент=?(Единица=Неопределено,1,Единица.Коэффициент);
		Коэффициент = 1;
		//крохин конец 22.09.2011;
		Выборка=Результат.Выбрать();
		
		
		
		Пока Выборка.Следующий() Цикл			
			//нечаева 08,09,2014 +++
			Если Выборка.цена<>-1 Тогда
				
				// Кухарь А.Ю.  01.02.2023 начало
				//		Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);
				если НеПересчитыватьКурс тогда
					Возврат  Выборка.Цена;
				иначе
					Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);			
				КонецЕсли;
				// Кухарь А.Ю.  01.02.2023 конец
				
				
			иначе 
				// тогда берем цену по базовому прайс-листу. сделано для франчей - сброс цен
				прервать;
			КонецЕсли;
			//нечаева 08,09,2014 ----
		КонецЦикла;	
		
		
		// смотрим базовый тип цен
		Запрос.Текст="
		|ВЫБРАТЬ ПЕРВЫЕ 1	
		|	Цена,
		|	ВЫБОР 
		|		КОГДА ТипЦен = &ТипЦен ТОГДА 0		
		|	ИНАЧЕ 100 КОНЕЦ КАК Уровень
		|ИЗ
		|РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата2,
		|	(ТипЦен=&ТипЦен_Базовый)
		|	И Номенклатура = &Номенклатура0
		|	И Прайс.Проведен
		|	И КОНЕЦПЕРИОДА(Прайс.Дата2,День) >= &Дата2	И Прайс.Дата < &Дата2
		|	) КАК ЦеныНоменклатурыСрезПоследних
		|ГДЕ Номенклатура.ЭтоГруппа
		|УПОРЯДОЧИТЬ ПО Уровень,Прайс.Дата Убыв";
		
		Запрос.УстановитьПараметр("Дата2",				ТекДатаРасчета);
		Запрос.УстановитьПараметр("ТипЦен",				ТипЦен);	
		Запрос.УстановитьПараметр("ТипЦен_Базовый",		ТипЦен.Базовый);		
		
		Запрос.УстановитьПараметр("Номенклатура0",	?(Номенклатура.ЭтоГруппа,Номенклатура,Номенклатура.Родитель));
		
		Результат=Запрос.Выполнить();
		//крохин начало 22.09.2011
		//единицу не используем больше
		//Коэффициент=?(Единица=Неопределено,1,Единица.Коэффициент);
		Коэффициент = 1;
		//крохин конец 22.09.2011;
		Выборка=Результат.Выбрать();
		Пока Выборка.Следующий() Цикл			
			
			// Кухарь А.Ю.  01.02.2023 начало
			//			Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);		
			если НеПересчитыватьКурс тогда
				Возврат  Выборка.Цена;
			иначе
				Возврат  глПересчет(Выборка.Цена*Коэффициент,ТипЦен.Валюта,ТекДатаРасчета,ВалютаДокумента,КурсДокумента);			
			КонецЕсли;
			// Кухарь А.Ю.  01.02.2023 конец
			
		КонецЦикла;	
		
		
		
		Возврат Неопределено;
	КонецЕсли;
	
