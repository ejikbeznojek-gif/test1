Функция получитьДекларацию(Модель,ТипРеквизита=неопределено) Экспорт
	
	
		декларация = ПолучитьГрупповойПериодическийРеквизит(Модель,"Декларация",ТекущаяДата());
		
				
		Если декларация <> Неопределено тогда
			НомерД = декларация.Наименование;
			Изготовитель = декларация.Изготовитель;
			Орган = декларация.Орган;
			ВидДокумента = декларация.ВидДокумента;	
			ДатаНачала = Формат(декларация.ДатаНачала,"ДФ=dd.MM.yy");
			ДатаОкончания = Формат(декларация.ДатаОкончания,"ДФ=dd.MM.yy");
			СтранаПроисхождения = Декларация.СтранаПроисхождения;
			попытка
				Филиал = Декларация.Филиал;
			исключение
				филиал="";
			конецПопытки;

		иначе
			НомерД = "";
			Изготовитель = "";
			Орган = "";
			ВидДокумента = "";	
			ДатаНачала = "";
			ДатаОкончания = "";
			СтранаПроисхождения="";
			Филиал="";
		КонецЕсли;
		
		Если ТипРеквизита = "Изготовитель"	 тогда
			
			возврат Изготовитель;
		иначеЕсли типРеквизита = "Филиал" ТОгда
			возврат филиал;
		иначеЕсли типРеквизита = "СтранаПроисхождения" ТОгда
			возврат СтранаПроисхождения;
	
		иначе
			возврат Изготовитель;
		КонецЕсли;	  
	

		
		
		
	  возврат СтранаПроисхождения;
	
	
КонецФункции

