// кол-во раб дней месяца
Функция КолРабДнейМесяца(Дата)
	
	ВсегоРДней=0;
	
	ЗапросПоДням=Новый Запрос;
	ЗапросПоДням.Текст="
	|ВЫБРАТЬ
	|	КалендарьДни.Дата КАК Дата
	|ИЗ
	|	Справочник.Календарь.Дни КАК КалендарьДни
	|ГДЕ
	|	КалендарьДни.Ссылка.Период = &Период
	|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
	|	И КалендарьДни.Часы > 0
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Дата)
	|ПО ОБЩИЕ";
	
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//|	КалендарьДни.Дата КАК Дата
	//|ИЗ
	//|	Справочник.Календарь.Дни КАК КалендарьДни
	//|ГДЕ
	//|	КалендарьДни.Дата >= &ДатаОтгрузки
	//|	И КалендарьДни.Часы <> 0
	//|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	Дата
	//|АВТОУПОРЯДОЧИВАНИЕ";
	
	
	
	ЗапросПоДням.УстановитьПараметр("Период",НачалоМесяца(Дата));
	РезультатПоДням	=ЗапросПоДням.Выполнить();
	
	ВсегоРДней=0;
	
	ВыборкаПоДням	=РезультатПоДням.Выбрать();
	Пока ВыборкаПоДням.Следующий() Цикл
		Если ВыборкаПоДням.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда
			ВсегоРДней=ВыборкаПоДням.Дата;			
		Иначе					
			Прервать;
		КонецЕсли;	
	КонецЦикла; 
	
	
	Если ВсегоРДней=0 Тогда
		Сообщить("Не заполнен календарь на: " +ПредставлениеПериода(НачалоМесяца(Дата),КонецМесяца(Дата)),СтатусСообщения.Важное);					
	КонецЕсли;
	
	
	Возврат ВсегоРДней;
	
КонецФункции

