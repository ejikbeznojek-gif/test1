// нечаева 26,11,13 поменяла наименование +++
// 
// Процедура вычисляет количество лет, месяцев и дней между двумя датами
// Параметры
//  Дата1    – дата, первая дата (более поздняя, часто текущая, стаж определяется по состоянию на эту дату)
//  Дата2    – дата, вторая дата (ранняя дата, с нее начинается "течение" стажа)
//  Лет        – Число, в этот параметр будет записано кол-во лет между двумя датами (Дата1-Дата2)
//  Месяцев    – Число, в этот параметр будет записано кол-во месяцев между двумя датами (Дата1-Дата2)
//  Дней    – Число, в этот параметр будет записано кол-во дней между двумя датами (Дата1-Дата2)
Процедура РазобРазностьДат(Дата11, Дата22, Лет = 0, Месяцев = 0, Дней = 0) Экспорт
	
	Лет        = 0;
	Месяцев    = 0;
	Дней    = 0;
	Если Дата11 > Дата22 Тогда
		
		ВременнаяДата = Дата11;
		Если День(ВременнаяДата) < День(Дата22) Тогда
			Дней = (ВременнаяДата - ДобавитьМесяц(ВременнаяДата,-1))/86400;
			ВременнаяДата = ДобавитьМесяц(ВременнаяДата,-1);
		КонецЕсли;
		Если Месяц(ВременнаяДата) < Месяц(Дата22) Тогда
			ВременнаяДата = ДобавитьМесяц(ВременнаяДата,-12);
			Месяцев = 12;
		КонецЕсли;
		Лет        = Макс(             Год(ВременнаяДата)        - Год(Дата22),    0);
		Месяцев    = Макс(Месяцев    + Месяц(ВременнаяДата)    - Месяц(Дата22),    0);
		Дней    = Макс(Дней        + День(ВременнаяДата)    - День(Дата22),    0);
		
		// скорректируем отображаемое значение, если "вмешалось" разное количество дней в месяцах
		
		Если Дата22 <> (ДобавитьМесяц(Дата11,-Лет*12-Месяцев)-Дней*86400) Тогда
			Дней = Дней + (День(КонецМесяца(Дата22)) - День(НачалоМесяца(Дата22))) - (День(КонецМесяца(ДобавитьМесяц(Дата11,-1))) - День(НачалоМесяца(ДобавитьМесяц(Дата11,-1))));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры    // РазобратьРазностьДат
