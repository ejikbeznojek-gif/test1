Функция ПолучитьСтатусАктаПриемки(СФ)  Экспорт
	
	Если СФ = Неопределено или СФ = Null Тогда
		
		возврат "Не обнаружен акт";
		
	КонецЕсли;
	Запрос = Новый Запрос;
	СтатусАкта = "";
	Запрос.Текст =
	"ВЫБРАТЬ
	|	АктПриемки.СостояниеДокумента,
	|	АктПриемки.РНК
	|ИЗ
	|	Документ.АктПриемки КАК АктПриемки
	|ГДЕ
	|	АктПриемки.РНК = &РНК";
	Для Каждого РНК из СФ.Накладные Цикл
		Запрос.УстановитьПараметр("РНК", РНК.Накладная);
		Выборка = Запрос.Выполнить().Выбрать();
		попытка
			Если Выборка.Следующий() Тогда
				Если Выборка.СостояниеДокумента = Перечисления.СостоянияНакладной.Принята Тогда
					Возврат "Товар получен покупателем, но имеются расхождения";
				КонецЕсли;
			Иначе
				Возврат "Не обнаружен акт";
			КонецЕсли;
		исключение
			Возврат "Не обнаружен акт";
		конецПопытки;
	КонецЦикла;
	попытка
		РНК = Выборка.РНК;
	исключение
		РНК = СФ.накладные[0].Накладная;
	конецПопытки;
	
	Возврат "Товар по получен покупателем";
	
