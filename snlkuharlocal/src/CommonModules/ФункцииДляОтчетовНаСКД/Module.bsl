Функция ДатаПоследнегоДвиженияРегистра(НаименованиеРегистра,НаименованиеИзмерения,ЗначениеИзмерения,ВидДвижения = Неопределено) Экспорт
Запрос = Новый Запрос;
Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
               |	НаименованиеРегистра.Период КАК Период
               |ИЗ
               |	РегистрНакопления."+НаименованиеРегистра + " КАК НаименованиеРегистра
               |ГДЕ
               |	НаименованиеРегистра."+ НаименованиеИзмерения +"= &ЗначениеИзмерения";
Если ВидДвижения <> Неопределено Тогда
	Запрос.Текст = Запрос.Текст + "
               |	И НаименованиеРегистра.ВидДвижения = &ВидДвижения";
		   КонецЕсли;
	Запрос.Текст = Запрос.Текст + "	   
               |
               |УПОРЯДОЧИТЬ ПО
               |	НаименованиеРегистра.Период УБЫВ";

Запрос.УстановитьПараметр("ЗначениеИзмерения",ЗначениеИзмерения);
Запрос.УстановитьПараметр("ВидДвижения",ВидДвижения);

Выборка = Запрос.Выполнить().Выбрать();
Если Выборка.Следующий() Тогда
	Возврат Выборка.Период;
Иначе
	Возврат ПустаяДата();
	КонецЕсли;
КонецФункции
