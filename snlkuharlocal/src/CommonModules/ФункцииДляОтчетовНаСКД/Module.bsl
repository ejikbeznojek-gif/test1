Функция ПроверитьНоменклатуруНаВхождениеНаименованийМоделиЦветаРазмера (НаименованиеМодели,НаименованиеЦвета,НаименованиеРазмера,НаименованиеЭлемента) Экспорт 
	НаименованиеМодели=СокрЛП(НаименованиеМодели);	
	НаименованиеЦвета=СокрЛП(НаименованиеЦвета);	
	НаименованиеРазмера=СокрЛП(НаименованиеРазмера);	
	НаименованиеЭлемента=СокрЛП(НаименованиеЭлемента);
	ТекстРасхождения="";
	МассивРасхождений=новый Массив;
	если СтрНайти(НаименованиеЭлемента,НаименованиеМодели)=0 тогда
		МассивРасхождений.Добавить("В наименовании элемента нет модели");
	КонецЕсли;
	если СтрНайти(НаименованиеЭлемента,НаименованиеЦвета)=0 тогда
		МассивРасхождений.Добавить("В наименовании элемента нет цвета");
	КонецЕсли;
	если СтрНайти(НаименованиеЭлемента,НаименованиеРазмера)=0 тогда
		МассивРасхождений.Добавить("В наименовании элемента нет размера");
	КонецЕсли;
	если МассивРасхождений.Количество()>0 тогда
		ТекстРасхождения=СтрСоединить(МассивРасхождений,", ");
	КонецЕсли;
	
	возврат ТекстРасхождения;
	
	
	
КонецФункции
