Функция ПолучитьОбъемКоробовИзРегистра(Докобъект) экспорт
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как ОбъемКоробов
	|ИЗ
	|	РегистрСведений.РеквизитыДокументов КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита
	|	И РеквизитыРНКПНКПРМ.Документ = &Документ";
	запрос.УстановитьПараметр("ИмяРеквизита","ОбъемКоробов");
	запрос.УстановитьПараметр("Документ",Докобъект.Ссылка);
	РезОбъемКоробов=запрос.Выполнить().Выгрузить();
	
	если РезОбъемКоробов.Количество()=0 тогда
		возврат Докобъект.ОбъемДокумента;
	иначе
		ТОбъём=РезОбъемКоробов.Получить(0).ОбъемКоробов;
		если ТОбъём=0 тогда
			возврат Докобъект.ОбъемДокумента;
		иначе Возврат ТОбъём;	
		КонецЕсли;
	КонецЕсли;
	
КонецФункции
