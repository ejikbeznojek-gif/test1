		НаименованиеРегистра, ФлагВидДвижения = "Приход", ФлагЗаписи = "Первая") Экспорт
	
	МассивКодовОпераций = Новый Массив;
	
	Если ФлагВидДвижения = "Приход" Тогда
		ВидДвижения = ВидДвиженияНакопления.Приход;
		МассивКодовОпераций.Добавить(Перечисления.КодыОперацийОстатки.ЗакупкаР);
	ИначеЕсли ФлагВидДвижения = "Расход" Тогда
		ВидДвижения = ВидДвиженияНакопления.Расход;
		МассивКодовОпераций.Добавить(Перечисления.КодыОперацийОстатки.Реализация);
	КонецЕсли;
	
	Если СокрЛП(НаименованиеИзмерения) = "" Тогда
		НаименованиеИзмерения = ЗначениеИзмерения.Метаданные().Имя;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвижения);
	Запрос.УстановитьПараметр("ЗначениеИзмерения", ЗначениеИзмерения);
	Запрос.УстановитьПараметр("МассивКодовОпераций", МассивКодовОпераций);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РегистрНакопления.Период КАК Период
	|ИЗ
	|	РегистрНакопления." + НаименованиеРегистра + " КАК РегистрНакопления
	|ГДЕ
	|	РегистрНакопления.ВидДвижения = &ВидДвижения
	|	И РегистрНакопления.Период МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаНачала, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаОкончания, ДЕНЬ)
	|	И РегистрНакопления." + НаименованиеИзмерения + " = &ЗначениеИзмерения
	|	И РегистрНакопления.КодОперации В (&МассивКодовОпераций)
	|
       |УПОРЯДОЧИТЬ ПО
       |	Период " + ?(ФлагЗаписи = "Последняя", "УБЫВ", "ВОЗР") + "
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Период;
	Иначе
		Возврат ПустаяДата();
	КонецЕсли;	
	
КонецФункции
