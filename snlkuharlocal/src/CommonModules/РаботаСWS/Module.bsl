Функция ПолучитьДанныеПоПапкамВерхнегоУровня () Экспорт
	СтруктураОбмена=Новый Структура();		
	МассивВыгрузки=новый Массив;	
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	Номенклатура.Ссылка КАК Ссылка,
	             |	Номенклатура.Наименование КАК Наименование,
	             |	Номенклатура.Код КАК Код,
	             |	Номенклатура.ПометкаУдаления КАК ПометкаУдаления
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	Номенклатура.ЭтоГруппа
	             |	И Номенклатура.Родитель = &Пустая
	             |	И Номенклатура.ВидНоменклатуры = &Товар";
	запрос.УстановитьПараметр("Товар",Перечисления.ВидыНоменклаутры.Товар);
	запрос.УстановитьПараметр("Пустая",Справочники.Номенклатура.ПустаяСсылка());
	
	ТЗ=запрос.Выполнить().выгрузить();
	Для каждого результат из ТЗ цикл
		ВремСтруктура = новый Структура("Наименование,Код,ПометкаУдаления,УИД",
		результат.Наименование,
		результат.Код,		
		результат.ПометкаУдаления,
		Строка(результат.ссылка.УникальныйИдентификатор()));
		МассивВыгрузки.Добавить(ВремСтруктура);			
	КонецЦикла;
	
	СтруктураОбмена.Вставить("МассивТоваров",МассивВыгрузки);	
	Возврат СтруктураОбмена;	
	
	
КонецФункции


