Функция ПолучитьДанныеТабеля(КодПодразделения,Дата) Экспорт
	СтруктураОбмена=Новый Структура();		
	МассивВыгрузки=новый Массив;	
	
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ТабельДанные.Сотрудник.ТабельныйНомер КАК СотрудникТабельныйНомер,
	|	ТабельДанные.Значение КАК Значение,
	|	ТабельДанные.Дата КАК Дата
	|ИЗ
	|	Документ.Табель.Данные КАК ТабельДанные
	|ГДЕ
	|	ТабельДанные.Ссылка.Подразделение = &Подразделение
	|	И ТабельДанные.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2";
	
	запрос.УстановитьПараметр("Подразделение",Справочники.Подразделения.НайтиПоКоду(КодПодразделения));
	запрос.УстановитьПараметр("Дата1",НачалоМесяца(Дата));
	запрос.УстановитьПараметр("Дата2",КонецМесяца(Дата));
	
	ТЗ=запрос.Выполнить().выгрузить();
	Для каждого результат из ТЗ цикл
		ВремСтруктура = новый Структура("СотрудникТабельныйНомер,Значение,Дата",
		результат.СотрудникТабельныйНомер,
		Строка(результат.Значение),		
		Строка(результат.Дата));
		МассивВыгрузки.Добавить(ВремСтруктура);			
	КонецЦикла;
	
	СтруктураОбмена.Вставить("МассивТоваров",МассивВыгрузки);	
	Возврат СтруктураОбмена;	
	

КонецФункции
