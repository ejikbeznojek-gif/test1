
Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	
	// Кухарь А.Ю.  05.06.2023 начало
	МассивДокументов=новый Массив;
	если ТипЗнч(ТаблицаПараметров) =Тип("ТаблицаЗначений") тогда
		для каждого СтрТЗ из ТаблицаПараметров цикл
			Если СтрТЗ.Имя="ОтборПоДокументу" тогда
				МассивДокументов.Добавить(СтрТЗ.Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	// Кухарь А.Ю.  05.06.2023 конец
	
	
    //Тимофеев Ю.А. начало 03.08.2023
	
	//Запрос=новый запрос;
	//Запрос.Текст="ВЫБРАТЬ
	//|	ПисьмаНаОтправку.Основание КАК Основание,
	//|	ПисьмаНаОтправку.СписокПолучателей КАК СписокПолучателей,
	//|	ПисьмаНаОтправку.ТекстПисьма КАК ТекстПисьма,
	//|	ПисьмаНаОтправку.ТемаПисьма КАК ТемаПисьма,
	//|	ПисьмаНаОтправку.ДатаСозданияПисьма КАК ДатаСозданияПисьма,
	//|	ПисьмаНаОтправку.ИмяФайлаВложения КАК ИмяФайлаВложения,
	//|	ПисьмаНаОтправку.Вложение КАК Вложение,
	//|	ВЫБОР
	//|		КОГДА ТИПЗНАЧЕНИЯ(ПисьмаНаОтправку.УчетнаяЗаписьОтправителя) = ТИП(Справочник.УчетныеЗаписиЭлектроннойПочты)
	//|			ТОГДА ПисьмаНаОтправку.УчетнаяЗаписьОтправителя.АдресЭлектроннойПочты
	//|		ИНАЧЕ ЕСТЬNULL(ПисьмаНаОтправку.УчетнаяЗаписьОтправителя, """")
	//|	КОНЕЦ КАК АдресОтправителя
	//|ИЗ
	//|	РегистрСведений.ПисьмаНаОтправку КАК ПисьмаНаОтправку
	//|ГДЕ
	//|	ПисьмаНаОтправку.ДатаСозданияПисьма >= &Дата1
	//|	И (ВЫРАЗИТЬ(ПисьмаНаОтправку.СписокПолучателей КАК СТРОКА(10))) <> """"
	//|	И (ВЫРАЗИТЬ(ПисьмаНаОтправку.ТекстПисьма КАК СТРОКА(10))) <> """"
	//|	И ПисьмаНаОтправку.ДатаОтправки = ДАТАВРЕМЯ(1, 1, 1)";  
	//
	
	
	
	//СписокПолучателейКопии
	
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ПисьмаНаОтправку.Основание КАК Основание,
	             |	ПисьмаНаОтправку.СписокПолучателей КАК СписокПолучателей,
	             |	ПисьмаНаОтправку.ТекстПисьма КАК ТекстПисьма,
	             |	ПисьмаНаОтправку.ТемаПисьма КАК ТемаПисьма,
	             |	ПисьмаНаОтправку.ДатаСозданияПисьма КАК ДатаСозданияПисьма,
	             |	ПисьмаНаОтправку.ИмяФайлаВложения КАК ИмяФайлаВложения,
	             |	ПисьмаНаОтправку.Вложение КАК Вложение,
	             |	ВЫБОР
	             |		КОГДА ТИПЗНАЧЕНИЯ(ПисьмаНаОтправку.УчетнаяЗаписьОтправителя) = ТИП(Справочник.УчетныеЗаписиЭлектроннойПочты)
	             |			ТОГДА ПисьмаНаОтправку.УчетнаяЗаписьОтправителя.АдресЭлектроннойПочты
	             |		ИНАЧЕ ЕСТЬNULL(ПисьмаНаОтправку.УчетнаяЗаписьОтправителя, """")
	             |	КОНЕЦ КАК АдресОтправителя,
	             |	ПисьмаНаОтправку.СписокПолучателейКопии КАК СписокПолучателейКопии
	             |ИЗ
	             |	РегистрСведений.ПисьмаНаОтправку КАК ПисьмаНаОтправку
	             |ГДЕ
	             |	ПисьмаНаОтправку.ДатаСозданияПисьма >= &Дата1
	             |	И (ВЫРАЗИТЬ(ПисьмаНаОтправку.СписокПолучателей КАК СТРОКА(10))) <> """"
	             |	И (ВЫРАЗИТЬ(ПисьмаНаОтправку.ТекстПисьма КАК СТРОКА(10))) <> """"
	             |	И ПисьмаНаОтправку.ДатаОтправки = ДАТАВРЕМЯ(1, 1, 1)"; 
	
	//Тимофеев Ю.А. конец 03.08.2023

	
	Запрос.УстановитьПараметр("Дата1",Константы.ДатаЗапретаРедактирования.Получить()-30*24*3600);
	
	// Кухарь А.Ю.  05.06.2023 начало
	//
	если МассивДокументов.Количество()>0 тогда
		запрос.Текст=запрос.Текст+" и ПисьмаНаОтправку.Основание в (&МассивДокументов)";
		запрос.УстановитьПараметр("МассивДокументов",МассивДокументов);
	КонецЕсли;
	// Кухарь А.Ю.  05.06.2023 конец
	
	
	Результат = Запрос.Выполнить().Выбрать();
	пока Результат.Следующий() цикл
		
		Основание = Результат.Основание;
		ПолучателиТекст=СтрЗаменить(Результат.СписокПолучателей,"##",Символы.ПС);
		КоличествоПолучателей=СтрЧислоСтрок(ПолучателиТекст);
		если КоличествоПолучателей= 0 тогда
			ЗаписатьВЛог("Регламент","В письме на основании "+Основание+" пустой получатель","Ошибка");
			Продолжить;
		КонецЕсли;
		СписокПолучателей=новый СписокЗначений;
		
		Для сч=1 по КоличествоПолучателей цикл
			ТекПолучатель=СтрПолучитьСтроку(ПолучателиТекст,сч);
			если Найти(ТекПолучатель,"@")=0 тогда
				ЗаписатьВЛог("Регламент","В письме на основании "+Основание+" некорректный получатель "+ТекПолучатель,"Ошибка");
				Продолжить;
			КонецЕсли;
			если СписокПолучателей.НайтиПоЗначению(ТекПолучатель)=Неопределено тогда
				СписокПолучателей.Добавить(СокрЛП(ТекПолучатель));	
			КонецЕсли;
		КонецЦикла; 
		
		//Тимофеев Ю.А. начало 03.08.2023   
		
		
		КопииТекст=СтрЗаменить(Результат.СписокПолучателейКопии,"##",Символы.ПС);
		// Смирнов М.Ю. 25.07.2025 HELP-6126 начало	
		//КоличествоАдресКопии=СтрЧислоСтрок(КопииТекст);
		КоличествоАдресКопии = ?(КопииТекст = "", 0, СтрЧислоСтрок(КопииТекст));
		// Смирнов М.Ю. 25.07.2025 HELP-6126 конец
		
		СписокКопии=новый СписокЗначений;
		
		Для сч=1 по КоличествоАдресКопии цикл
			ТекАдрКопии=СтрПолучитьСтроку(КопииТекст,сч);
			если Найти(ТекАдрКопии,"@")=0 тогда
				ЗаписатьВЛог("Регламент","В письме на основании "+Основание+" некорректный получатель копии "+ТекПолучатель,"Ошибка");
				Продолжить;
			КонецЕсли;
			если СписокКопии.НайтиПоЗначению(ТекАдрКопии)=Неопределено тогда
				СписокКопии.Добавить(СокрЛП(ТекАдрКопии));	
			КонецЕсли;
		КонецЦикла;       		
		
		//Тимофеев Ю.А. конец 03.08.2023
		
		Если СокрЛП(Результат.ИмяФайлаВложения) <> "" Тогда
			Вложение = Результат.Вложение.Получить();
		Иначе
			Вложение = Неопределено;
		КонецЕсли;
		
		// Смирнов М.Ю. 25.07.2025 HELP-6126 начало
		Если СписокПолучателей.Количество()>0 тогда
			КоличествоПопыток = 0;
			ПисьмоОтправлено = Ложь;
			Пока КоличествоПопыток < 3 Цикл
				Попытка  
					
					//Тимофеев Ю.А. начало 03.08.2023
					// Шворобей ВЮ 23.09.2022 ++
					//	ОтправитьПисьмо(Результат.ТекстПисьма,СписокПолучателей,Результат.ТемаПисьма, Вложение, СокрЛП(Результат.ИмяФайлаВложения), СокрЛП(Результат.АдресОтправителя));
					// Шворобей ВЮ 23.09.2022 ++ 
					
					//доп.параметр СписокКопии
					
					ОтправитьПисьмо(Результат.ТекстПисьма,СписокПолучателей,Результат.ТемаПисьма, Вложение, СокрЛП(Результат.ИмяФайлаВложения), СокрЛП(Результат.АдресОтправителя),СписокКопии);
					КоличествоПопыток = 3;
					ПисьмоОтправлено = Истина;
					//Тимофеев Ю.А. конец 03.08.2023
				Исключение
					
					КоличествоПопыток = КоличествоПопыток + 1;
					// обрабатываем ошибку
					ОписаниеОшибки = ОписаниеОшибки();
					ТекстСообщенияПользователю = "Возникла ошибка при отправки письма (на основании %1, получатель %2). Информацияпо ошибке: %3";
					ТекстОшибки = СтрШаблон(ТекстСообщенияПользователю, Основание, ТекПолучатель, ОписаниеОшибки);
					ЗаписатьВЛог("Регламент", ТекстОшибки, "Ошибка"); 
					// Смирнов М.Ю. 25.07.2025 HELP-6126 конец
				КонецПопытки;
			КонецЦикла;
			
			Если Не ПисьмоОтправлено Тогда
				// отправляем письмо ответственному менеджеру о том, что письмо не отправлено контрагенту
				Если ТипЗнч(Основание) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
					ТекстПисьмаОбошибке = "Письмо не отправлено получателю %1. 
						| Для повторной отправке зайдите в меню ""Операции"", выберите ""Обработки"", далее в списке обраоток выберите 
						| ""АвтоотправкаПечатныхФормКонтрагентам"". С помощью обработки отправьте письмо повторно";
					ТекстПисьмаОбОшибкеКОтправке = СтрШаблон(ТекстПисьмаОбошибке, ТекПолучатель);
					
					// получаем почту ответственного менеджера
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	ФизическиеЛица.ЕМэйл КАК ЕМэйл
					|ИЗ
					|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
					|		ПО РасходнаяНакладная.Контрагент = Контрагенты.Ссылка
					|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
					|		ПО РасходнаяНакладная.Менеджер = ФизическиеЛица.Ссылка
					|ГДЕ
					|	РасходнаяНакладная.Ссылка = &Ссылка";
					
					Запрос.УстановитьПараметр("Ссылка", Основание);
					РезультатЗапроса = Запрос.Выполнить();
					Если Не РезультатЗапроса.Пустой() Тогда
						
						Выборка = РезультатЗапроса.Выбрать();
						Выборка.Следующий(); 
						
						Если ЗначениеЗаполнено(Выборка.ЕМэйл) Тогда
							
							СписокПолучателей = Новый СписокЗначений;
							СписокПолучателей.Добавить(Выборка.ЕМэйл);
							ТемаПисьмаОбОшибке = СтрШаблон("Письмо не отправлено контрагенту %1", ТекПолучатель); 
							
							ЗаписьВРег = РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
							ЗаписьВРег.Основание = Основание;
							ЗаписьВРег.ДатаСозданияПисьма = ТекущаяДата();
							ЗаписьВРег.Период = ТекущаяДата();
							
							ЗаписьВРег.ТекстПисьма = ТекстПисьмаОбОшибкеКОтправке;
							ЗаписьВРег.ТемаПисьма = ТемаПисьмаОбОшибке;
							ЗаписьВРег.СписокПолучателей = СписокПолучателей;
							ЗаписьВРег.Записать(); 
							
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
				
			
			Попытка
				////Михайловский 20221109 вместо нз мз +++
				////вместо
				НаборЗаписей=РегистрыСведений.ПисьмаНаОтправку.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ДатаСозданияПисьма.использование=Истина;
				НаборЗаписей.Отбор.ДатаСозданияПисьма.значение=результат.ДатаСозданияПисьма;
				НаборЗаписей.Отбор.Основание.использование=Истина;
				НаборЗаписей.Отбор.Основание.значение=Основание;
				НаборЗаписей.Прочитать();
				для каждого запись из НаборЗаписей цикл
					запись.ДатаОтправки=ТекущаяДата();
				КонецЦикла;
				НаборЗаписей.Записать();	
				////это вместо
				//МенЗап=РегистрыСведений.ПисьмаНаОтправку.СоздатьМенеджерЗаписи();
				//МенЗап.ДатаСозданияПисьма=результат.ДатаСозданияПисьма;
				//МенЗап.Основание=Основание;
				////МенЗап.Прочитать();
				//МенЗап.ДатаОтправки=ТекущаяДата();
				//МенЗап.Записать();
				////Михайловский 20221109 вместо нз мз +++
			Исключение
				ОписаниеОшибки = ОписаниеОшибки();
				ЗаписатьВЛог("Регламент", ОписаниеОшибки, "Ошибка");	
			КонецПопытки;

		КонецЕсли;
		
	КонецЦикла;
	
	// Кухарь А.Ю.  05.06.2023 начало
	//
	 
	// Кухарь А.Ю.  05.06.2023 конец
	
	
КонецПроцедуры  

//Тимофеев Ю.А. начало 03.08.2023 

//Процедура ОтправитьПисьмо(Текст,СписокПолучателей,Тема = "", АдресВложения = Неопределено, ИмяФайла = "", АдресОтправителя = "") Экспорт


Процедура ОтправитьПисьмо(Текст,СписокПолучателей,Тема = "", АдресВложения = Неопределено, ИмяФайла = "", АдресОтправителя = "",СписокКопии="") Экспорт
//Тимофеев Ю.А. конец 03.08.2023
	ПочтовыйПрофиль = Новый ИнтернетПочтовыйПрофиль; 
	
	// Кухарь А.Ю.  08.09.2022 начало
	//ПочтовыйПрофиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//ПочтовыйПрофиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//ПочтовыйПрофиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(ПочтовыйПрофиль,ПараметрыПочты);	
	// Кухарь А.Ю.  08.09.2022 конец
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//ПочтовыйПрофиль.Пользователь       = "*%*%*%";
	//ПочтовыйПрофиль.Пароль             = "*$*$*$";        
	////Кухарь А.Ю.  20.09.2025 начало
	//ПочтовыйПрофиль.ПользовательSMTP	   = "*%*%*%";
	//ПочтовыйПрофиль.ПарольSMTP	 		   = "*$*$*$";
	////Кухарь А.Ю.  20.09.2025 конец
	ПочтовыйПрофиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Логин;
	ПочтовыйПрофиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Пароль;
	ПочтовыйПрофиль.ПользовательSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Логин;
	ПочтовыйПрофиль.ПарольSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	
	ПочтовыйПрофиль.ВремяОжидания      = 60; 
	
	Сообщение = Новый ИнтернетПочтовоеСообщение;
	
	Для каждого ТекПолучатель из СписокПолучателей цикл
		Сообщение.Получатели.Добавить(ТекПолучатель.значение);
	КонецЦикла;  
	
	//Тимофеев Ю.А. начало 03.08.2023
	Если СписокКопии<> "" Тогда
		//если заполнен значен , есть копии
		Для каждого ТекКопия из СписокКопии цикл
			Сообщение.Копии.Добавить(ТекКопия.значение);
		КонецЦикла;
	КонецЕсли;
    //Тимофеев Ю.А. конец 03.08.2023
	
	// Шворобей ВЮ 23.09.2022 ++
	Сообщение.Отправитель = ?(АдресОтправителя <> "", АдресОтправителя, "helpdesk@collant.ru");
	// Шворобей ВЮ 23.09.2022 ++ 
	//Валетов + 22,09,2025  https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7145
	Если СокрЛП(АдресОтправителя) = "robot@collant.ru" Тогда 
		// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
		//ПочтовыйПрофиль.Пользователь       = "*%*%*%";
		//ПочтовыйПрофиль.Пароль             = "*$*$*$"; 
		//ПочтовыйПрофиль.ПользовательSMTP	   = "*%*%*%";
		//ПочтовыйПрофиль.ПарольSMTP	 		   = "*$*$*$";
		ПочтовыйПрофиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
