Процедура Сформировать(ТаблицаПараметров = Неопределено)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Декларация.Ссылка КАК Документ
	               |ИЗ
	               |	Документ.Декларация КАК Декларация
	               |ГДЕ
	               |	Декларация.ДатаОкончания > &ДатаОкончания
	               |	И Декларация.Проведен
	               |	И Декларация.Дата >= &ДатаНачала
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Декларация.Дата УБЫВ
	               |АВТОУПОРЯДОЧИВАНИЕ";
				   
Запрос.УстановитьПараметр("ДатаОкончания",ТекущаяДата());
Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
Запрос.УстановитьПараметр("ДатаНачала",'20150101');
Иначе
Запрос.УстановитьПараметр("ДатаНачала",'20010101');
КонецЕсли;
Выборка = Запрос.Выполнить().Выбрать();
ТекстПисьма = "";
Пока Выборка.Следующий() Цикл
//	Состояние(Выборка.Документ);

//	ОбработкаПрерыванияПользователя(); 
Запрос = Новый Запрос;
Запрос.Текст = "ВЫБРАТЬ
               |	1 КАК Поле1
               |ИЗ
               |	РегистрСведений.История КАК История
               |ГДЕ
               |	История.Период = &Период
               |	И История.Документ = &Документ";
Запрос.УстановитьПараметр("Период",Выборка.Документ.Дата);
Запрос.УстановитьПараметр("Документ",Выборка.Документ);
Выборка2 = Запрос.Выполнить().Выбрать();
Если Выборка2.Количество() <> Выборка.Документ.Товары.Количество() Тогда
ТекстПисьма = ТекстПисьма + "косяк в декларации "+ Выборка.Документ+ ". "+Выборка.Документ.Изготовитель +Символы.ПС;
//Сообщить(ТекстПисьма);
//Сообщить(Выборка2.Количество());
//Сообщить(Выборка.Документ.Товары.Количество());
//Прервать;
КонецЕсли;
КонецЦикла;

Если ПустаяСтрока(ТекстПисьма) Тогда
ТекстПисьма = "Контроль деклараций: ошибок нет";	
КонецЕсли;


//крохин начало 17.05.2019
//контроль SSR
Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Взаиморасчеты.Регистратор,
				   //крохин начало 06.06.2019
				   |    Взаиморасчеты.Период
				   //крохин конец 06.06.2019
	               |ИЗ
	               |	РегистрНакопления.Взаиморасчеты КАК Взаиморасчеты
	               |ГДЕ
	               |	(Взаиморасчеты.Договор = &Договор
				   |     ИЛИ Взаиморасчеты.Договор = &Договор2)
				   |	И Взаиморасчеты.Контрагент = &Контрагент
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Взаиморасчеты.Период
	               |АВТОУПОРЯДОЧИВАНИЕ";
				   
Запрос.УстановитьПараметр("Договор",Справочники.Договоры.НайтиПоКоду("SNL-020844"));
Запрос.УстановитьПараметр("Договор2",Справочники.Договоры.НайтиПоКоду("SNL-000124"));
Запрос.УстановитьПараметр("Контрагент",Справочники.Контрагенты.НайтиПоКоду("SMN-0139"));
Выборка = Запрос.Выполнить().Выбрать();
Пока Выборка.Следующий() Цикл
	ТекстПисьма = ТекстПисьма + "ошибка во взаиморасчетах по документу: "+Выборка.Регистратор+Символы.ПС; 
КонецЦикла;;

//крохин начало 01.10.2019
//ещё один
Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Взаиморасчеты.Регистратор,
				   |    Взаиморасчеты.Период
	               |ИЗ
	               |	РегистрНакопления.Взаиморасчеты КАК Взаиморасчеты
	               |ГДЕ
	               |	Взаиморасчеты.Договор = &Договор
				   |	И Взаиморасчеты.Контрагент = &Контрагент
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Взаиморасчеты.Период
	               |АВТОУПОРЯДОЧИВАНИЕ";
				   
Запрос.УстановитьПараметр("Договор",Справочники.Договоры.НайтиПоКоду("SNL-000132"));
Запрос.УстановитьПараметр("Контрагент",Справочники.Контрагенты.НайтиПоКоду("SMN-0478"));
Выборка = Запрос.Выполнить().Выбрать();
Пока Выборка.Следующий() Цикл
	ТекстПисьма = ТекстПисьма + "ошибка во взаиморасчетах по документу: "+Выборка.Регистратор+Символы.ПС; 
КонецЦикла;;


//крохин конец 01.10.2019


Если ТекстПисьма = "Контроль деклараций: ошибок нет" Тогда
ТекстПисьма = ТекстПисьма + Символы.ПС + "Контроль взаиморасчетов: ошибок нет"+Символы.ПС;	
КонецЕсли;

ТекстПисьма = ПроверитьДС(ТекстПисьма);

//крохин конец 17.05.2019
ПослатьПисьмо(ТекстПисьма);	
КонецПроцедуры	



Процедура ПослатьПисьмо(Текст) Экспорт
	
	//возврат; //+++
	
	
	попытка
		ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
		ЗаписатьВЛог("Ватком","Отправление почты """+параметрыСеанса.Пользователь+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
	исключение
	конецпопытки;
	
	ПочтовыйПрофиль = Новый ИнтернетПочтовыйПрофиль; 
	
	// Кухарь А.Ю.  08.09.2022 начало
	//ПочтовыйПрофиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//ПочтовыйПрофиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//ПочтовыйПрофиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(ПочтовыйПрофиль,ПараметрыПочты);	
	// Кухарь А.Ю.  08.09.2022 конец
	
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//ПочтовыйПрофиль.Пользователь       = "*%*%*%";
	//ПочтовыйПрофиль.Пароль             = "*$*$*$";
	ПочтовыйПрофиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Логин;
	ПочтовыйПрофиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуХелпДеск).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	ПочтовыйПрофиль.ВремяОжидания      = 60; 
	
	Сообщение = Новый ИнтернетПочтовоеСообщение;
	
	Сообщение.Получатели.Добавить("krohin@collant.ru");
	Сообщение.Отправитель = "helpdesk@collant.ru";
	Сообщение.Тема = "Контроль корректности в базе " + ПараметрыСеанса.ЭтотУзел.Код;
	Сообщение.Тексты.Добавить(Текст);
	
	Почта = Новый ИнтернетПочта(); 
	Попытка 
		Почта.Подключиться(ПочтовыйПрофиль); 
	Исключение 
		Сообщить(ОписаниеОшибки()); 
		Возврат; 
	КонецПопытки; 
	
	Почта.Подключиться(ПочтовыйПрофиль);
	Почта.Послать(Сообщение);
	Почта.Отключиться();
	
	
КонецПроцедуры	


Функция ПроверитьДС(Текст)
	   СЗ = Новый СписокЗначений;
	   
//РКО	   
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РасходныйКассовыйОрдер.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.РасходныйКассовыйОрдер КАК РасходныйКассовыйОрдер
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДенежныеСредства.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
	|		ГДЕ
	|			ДенежныеСредства.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДенежныеСредства.Регистратор
    |) КАК КоличествоЗаписей
	|		ПО РасходныйКассовыйОрдер.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И РасходныйКассовыйОрдер.Дата МЕЖДУ &Дата1 И &Дата2
	|	И РасходныйКассовыйОрдер.Проведен
	|	И РасходныйКассовыйОрдер.Сумма > 0
	|	И РасходныйКассовыйОрдер.Подразделение.ВидПодразделения <> &ВидПодразделения
	|
	|УПОРЯДОЧИТЬ ПО
	|	РасходныйКассовыйОрдер.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
Запрос.УстановитьПараметр("ВидПодразделения",Перечисления.ВидыПодразделений.Франчайзинг);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	//	ЗаписатьВЛог("Исправление ошибки записи при обмене","Перепроведение "+Выборка.Ссылка,"Информация");
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	//ПКО   
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПриходныйКассовыйОрдер.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДенежныеСредства.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
	|		ГДЕ
	|			ДенежныеСредства.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДенежныеСредства.Регистратор
    |) КАК КоличествоЗаписей
	|		ПО ПриходныйКассовыйОрдер.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И ПриходныйКассовыйОрдер.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ПриходныйКассовыйОрдер.Проведен
	|	И ПриходныйКассовыйОрдер.Сумма > 0
	|	И ПриходныйКассовыйОрдер.Подразделение.ВидПодразделения <> &ВидПодразделения
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриходныйКассовыйОрдер.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
Запрос.УстановитьПараметр("ВидПодразделения",Перечисления.ВидыПодразделений.Франчайзинг);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	//	ЗаписатьВЛог("Исправление ошибки записи при обмене","Перепроведение "+Выборка.Ссылка,"Информация");
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;

	
	//ПС  
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПереводСредств.Ссылка,
	|	КоличествоЗаписей.Колво,
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) КАК Колво1
	|ИЗ
	|	Документ.ПереводСредств КАК ПереводСредств
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДенежныеСредства.Регистратор КАК Регистратор,
	|			СУММА(1) КАК Колво
	|		ИЗ
	|			РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
	|		ГДЕ
	|			ДенежныеСредства.Период МЕЖДУ &Дата1 И &Дата2
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДенежныеСредства.Регистратор
    |) КАК КоличествоЗаписей
	|		ПО ПереводСредств.Ссылка = КоличествоЗаписей.Регистратор
	|ГДЕ
	|	ЕСТЬNULL(КоличествоЗаписей.Колво, 0) = 0
	|	И ПереводСредств.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ПереводСредств.Проведен
	|	И ПереводСредств.Сумма > 0
	|	И ПереводСредств.Источник_Подразделение.ВидПодразделения <> &ВидПодразделения
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПереводСредств.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Дата1",КонецДня(Константы.ДатаЗапретаРедактирования.Получить())+1);
	Запрос.УстановитьПараметр("Дата2",КонецМесяца(ТекущаяДата()));
Запрос.УстановитьПараметр("ВидПодразделения",Перечисления.ВидыПодразделений.Франчайзинг);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	//	ЗаписатьВЛог("Исправление ошибки записи при обмене","Перепроведение "+Выборка.Ссылка,"Информация");
		СЗ.Добавить(Выборка.Ссылка);
	КонецЦикла;

	
		Если СЗ.Количество() > 0 Тогда
		Текст = Текст +"Ошибки регистра ДС: "+ Символы.ВК;
		
		Для Н = 1 По СЗ.Количество() Цикл
			Текст = Текст + СЗ.Получить(Н-1) + Символы.ВК;
		//	ДокОбъект = СЗ.Получить(Н-1).Значение.ПолучитьОбъект();
		//	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЦикла;
		//ПослатьПисьмоОПерепроведении(Текст);
	Иначе
		Текст = Текст +"Нет ошибок регистра ДС "+ Символы.ВК;

	КонецЕсли;

    Возврат Текст;
	
КонецФункции