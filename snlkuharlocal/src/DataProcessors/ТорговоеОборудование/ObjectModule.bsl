// Процедура осуществляет печать чека на ФР.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
//                    - Строка таблицы подключенных ФР (млФР), соответствующая ФР,
//                      на котором необходимо напечатать чек.
//
//  Параметры         - <Структура>
//                    - Структура параметров операции.
//                       Входные параметры:
//                        НомерСекции    - <Число>
//                                       - Номер секции, которой соответствуют
//                                         позиции данного чека.
//                        ПолученоБезНал - <Число>
//                                       - Сумма, полученная от покупателя (безналичная оплата).
//                        ПолученоНал    - <Число>
//                                       - Сумма, полученная от покупателя (наличная оплата).
//                        СписокТоваров  - <ТаблицаЗначений>
//                                       - Таблица товаров, которые необходимо
//                                         отразить в чеке.
//                                         Таблица имеет следующие колонки:
//                                           "Колво"   - <Число>
//                                                     - Количество продаваемого
//                                                       товара.
//                                           "Скидка"  - <Число>
//                                                     - Процент скидки для данной
//                                                       строки чека.
//                                           "Товар"   - <Строка>
//                                                     - Наименование товара,
//                                                       который должен быть отражён
//                                                       в чеке.
//                                           "Цена"    - <Число>
//                                                     - Цена за единицу товара.
//                        ЧекНаВозврат   - <Булево>
//                                       - Данный чек является чеком на возврат.
//                       Выходные параметры:
//                        НомерЧека      - <Число>
//                                       - Номер текущего чека.
//                        НомерСмены     - <Число>
//                                       - Номер текущей смены.
//
//  Ответ             - <Строка>
//                    - Описание произошедшей в ходе выполнения операции ошибки,
//                      или пустая строка в случае успешного завершения.
//
Процедура ПечататьЧек(ФР, Параметры, Ответ) Экспорт

	Ответ = "";

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Ответ = "Ошибка при попытке печати чека: фискальный регистратор не подключен.";
	ИначеЕсли ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Ответ = "Ошибка при печати строки чека на фискальном регистраторе """
		         + ФР.Модель.Наименование
		         + """: не задана обработка обслуживания.";
	ИначеЕсли ФР.ДляПриемаНаличныхОтЮрЛиц Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: фискальный регистратор предназначен для отражения наличных денежных расчетов.";
	Иначе
		Пароль = ПараметрыСеанса.ПарольКассираФискальногоРегистратора;		
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: в настройках пользователя не указан пароль фискального регистратора.";
		Иначе
			Форма     = ПолучитьФормуОбработки(ФР.Модель.ОбработкаОбслуживания);
			Параметры.Вставить("Объект",  ФР.Объект);
			Параметры.Вставить("НомерЛУ", ФР.НомерЛУ);
			Параметры.Вставить("Пароль",  Пароль);
			Форма.ВыполнитьОперацию("ПечататьЧек", Параметры, Ответ);
			Если Не ПустаяСтрока(Ответ) Тогда
				Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
				        + ФР.Модель.Наименование
				        + """: " + Ответ;
		    КонецЕсли;
		
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры // ПечататьЧек()

