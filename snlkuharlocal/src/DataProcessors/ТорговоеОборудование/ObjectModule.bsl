//// ПРОЦЕДУРЫ РАБОТЫ С ФИСКАЛЬНЫМ РЕГИСТРАТОРОМ

// Процедура осуществляет подключение ФР.
//
// Параметры
//  Модель                       - <СправочникСсылка.ТорговоеОборудование>
//                               - Модель подключаемого ФР.
//
//  НомерЛУ                      - <Число>
//                               - Номер логического устройства.
//
//  ДляПриемаНаличныхОтЮрЛиц     - <Булево>
//                               - Данный ФР подключен в режиме отражения
//                                 наличных расчетов с индивидуальными
//                                 покупателями.
//
//  КассаККМ                     - <СправочникСсылка.КассыККМ>
//                               - Касса, с которой связан данный ФР.
//
Функция ПодключитьФР(Модель, НомерЛУ, ДляПриемаНаличныхОтЮрЛиц, КассаККМ, ВсеПараметры) Экспорт

	Если Модель.ДрайверОборудования.Пустая() Тогда
		Объект    = Неопределено;
		Ответ     = "";	
		
		Параметры = Новый Структура();
		
		Параметры.Вставить("Модель",  		Модель);
		Параметры.Вставить("НомерЛУ", 		НомерЛУ);
		
		Если ТипЗнч(ВсеПараметры)=Тип("Структура") Тогда
			ДобавитьПараметры(Параметры,ВсеПараметры);		
		КонецЕсли;	
		
		Параметры.Вставить("Пароль",  ПолучитьЗначениеПоУмолчанию("ПарольАдминистратораФискальногоРегистратора"));

		Если ЗначениеНеЗаполнено(Модель.ОбработкаОбслуживания) Тогда
			Сообщить("Ошибка при подключении фискального регистратора """
			         + Модель.Наименование
			         + """: не задана обработка обслуживания.",
			         СтатусСообщения.Важное);
			Возврат Перечисления.ТООшибкиОбщие.ОшибкаНеизвестно;
		КонецЕсли;

		Форма = ПолучитьФормуОбработки(Модель.ОбработкаОбслуживания);
		Форма.ВыполнитьОперацию("Подключить", Параметры, Ответ);
		
		Если ПустаяСтрока(Ответ) Тогда
			Параметры.Свойство("Объект", Объект);
			
			ФР                          = млФР.Добавить();
			ФР.Объект                   = Объект;
			ФР.Модель                   = Модель;
			ФР.НомерЛУ                  = НомерЛУ;
			ФР.КассаККМ                 = КассаККМ;
			ФР.ДляПриемаНаличныхОтЮрЛиц = ДляПриемаНаличныхОтЮрЛиц;
			
		Иначе
			Сообщить("Ошибка при подключении фискального регистратора """
			         + Модель.Наименование
			         + """: "
			         + Ответ,
			         СтатусСообщения.Важное);
			Возврат Перечисления.ТООшибкиОбщие.ОшибкаПриПодключении;
		КонецЕсли;

		Возврат Перечисления.ТООшибкиОбщие.ПустаяСсылка();		
	Иначе //Подключение 2024 
		
		рПодключения = МенеджерОборудованияКлиент.ПроверитьПодключитьОборудование(Модель);		
		
		Если рПодключения.Успешно Тогда		
			ФР                          = млФР.Добавить();
			//ФР.Объект                   = Объект;
			ФР.Модель                   = Модель;
			//ФР.НомерЛУ                  = НомерЛУ;
			ФР.КассаККМ                 = рПодключения.КассаККМ;
			ФР.ДляПриемаНаличныхОтЮрЛиц = ДляПриемаНаличныхОтЮрЛиц;
			
			ПараметрыСеанса.КассаККМ	= ФР.КассаККМ;
			
			Возврат Перечисления.ТООшибкиОбщие.ПустаяСсылка();			
		Иначе
			Сообщить("Ошибка при подключении фискального регистратора """
			         + Модель.Наименование
			         + """: "
			         + рПодключения.Ошибки,
			         СтатусСообщения.Важное);
			Возврат Перечисления.ТООшибкиОбщие.ОшибкаПриПодключении;								
		КонецЕсли; 	
	КонецЕсли; 
	
	
КонецФункции // ПодключитьФР()

// Процедура осуществляет отключение ФР.
//
// Параметры
//  ФР - <СтрокаТаблицыЗначений>
//     - Строка таблицы подключенных ФР (млФР), соответствующая отключаемому ФР.
//
Процедура ОтключитьФР(ФР)

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Возврат;
	КонецЕсли;

	Если ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Сообщить("Ошибка при отключении фискального регистратора """
		         + ФР.Модель.Наименование
		         + """: не задана обработка обслуживания.",
		         СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;

	Ответ     = "";
	Форма     = ПолучитьФормуОбработки(ФР.Модель.ОбработкаОбслуживания);
	Параметры = Новый Структура();
	Параметры.Вставить("Объект",  ФР.Объект);
	Параметры.Вставить("НомерЛУ", ФР.НомерЛУ);

	Форма.ВыполнитьОперацию("Отключить", Параметры, Ответ);
	Если ПустаяСтрока(Ответ) Тогда
		млФР.Удалить(ФР);
	Иначе
		Сообщить("Ошибка при отключении фискального регистратора """
		         + ФР.Модель.Наименование
		         + """: "
		         + Ответ,
		         СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;

КонецПроцедуры // ОтключитьФР()

// Функция осуществляет аннулирование чека на ФР.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
//                    - Строка таблицы подключенных ФР (млФР), соответствующая ФР,
//                      открытый чек которого необходимо аннулировать.
//
//  Ответ             - <Строка>
//                    - Описание произошедшей в ходе выполнения операции ошибки,
//                      или пустая строка в случае успешного завершения.
//
//  ВыводитьСообщение - <Булево>
//                    - Необязательный параметр; указывает на необходимость
//                      выводить информацию об ошибке.
//
Процедура АннулироватьЧек(ФР, Ответ, ВыводитьСообщение = Истина) Экспорт

	Ответ = "";

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Ответ = "Ошибка при попытке аннулировать чек: фискальный регистратор не подключен.";
	ИначеЕсли ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Ответ = "Ошибка при попытке аннулирования чека на фискальном регистраторе """
		         + ФР.Модель.Наименование
		         + """: не задана обработка обслуживания.";
	//крохин начало 09.08.2019
	//аннулировать чеки для юр.лиц можно
	//ИначеЕсли ФР.ДляПриемаНаличныхОтЮрЛиц Тогда
	//	Ответ = "Ошибка при попытке аннулирования чека на фискальном регистраторе """
	//	        + ФР.Модель.Наименование
	//	        + """: фискальный регистратор предназначен для отражения наличных денежных расчетов.";
	//крохин конец 09.08.2019			
	Иначе
		Пароль = ПараметрыСеанса.ПарольКассираФискальногоРегистратора;		
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Ответ = "Ошибка при попытке аннулирования чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: в настройках пользователя не указан пароль фискального регистратора.";
		Иначе
			Форма     = ПолучитьФормуОбработки(ФР.Модель.ОбработкаОбслуживания);
			Параметры = Новый Структура();
			Параметры.Вставить("Объект",  ФР.Объект);
			Параметры.Вставить("НомерЛУ", ФР.НомерЛУ);
			Параметры.Вставить("Пароль",  Пароль);
			Форма.ВыполнитьОперацию("АннулироватьЧек", Параметры, Ответ);
			Если Не ПустаяСтрока(Ответ) Тогда
				Ответ = "Ошибка при попытке аннулирования чека на фискальном регистраторе """
				        + ФР.Модель.Наименование
				        + """: " + Ответ;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если Не ПустаяСтрока(Ответ) И ВыводитьСообщение Тогда
		Сообщить(Ответ, СтатусСообщения.Важное);
	КонецЕсли;

КонецПроцедуры // АннулироватьЧек()

// Процедура осуществляет печать строки чека ФР.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
//                    - Строка таблицы подключенных ФР (млФР), соответствующая ФР,
//                      строку чека которого необходимо напечатать.
//
//  Параметры         - <Структура>
//                    - Структура параметров операции.
//                       Входные параметры:
//                         Наименование    - <Строка>
//                                         - Наименование товара.
//                         Количество      - <Число>
//                                         - Количество товара.
//                         Цена            - <Число>
//                                         - Цена товара.
//                         Скидка          - <Число>
//                                         - Скидка в процентах.
//                         Секция,         - <Число>
//                                         - Номер секции.
//                         ПризнакВозврата - <Булево>
//                                         - Признак возврата товара.
//                        Выходные параметры:
//                         НомерЧека       - <Число>
//                                         - Номер текущего чека.
//                         НомерСмены      - <Число>
//                                         - Номер текущей смены.
//
//  Ответ             - <Строка>
//                    - Описание произошедшей в ходе выполнения операции ошибки,
//                      или пустая строка в случае успешного завершения.
//
Процедура ПечататьСтрокуЧека(ФР, Параметры, Ответ) Экспорт

	Ответ = "";

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Ответ = "Ошибка при попытке печати строки чека: фискальный регистратор не подключен.";
	ИначеЕсли ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		         + ФР.Модель.Наименование
		         + """: не задана обработка обслуживания.";
	ИначеЕсли ФР.ДляПриемаНаличныхОтЮрЛиц Тогда
		Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: фискальный регистратор предназначен для отражения наличных денежных расчетов.";
	ИначеЕсли ПустаяСтрока(Параметры.Наименование) Тогда
		Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: не задана номенклатура.";
	ИначеЕсли Параметры.Цена = 0 Тогда
		Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: не указана цена товара.";
	ИначеЕсли Параметры.Количество = 0 Тогда
		Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: не указано количество товара.";
	Иначе
		Пароль = ПолучитьЗначениеПоУмолчанию("ПарольКассираФискальногоРегистратора");
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Пароль = ПолучитьЗначениеПоУмолчанию("ПарольАдминистратораФискальногоРегистратора");
		КонецЕсли;
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: в настройках пользователя не указан пароль фискального регистратора.";
		Иначе
			Форма     = ПолучитьФормуОбработки(ФР.Модель.ОбработкаОбслуживания);
			Параметры.Вставить("Объект",  ФР.Объект);
			Параметры.Вставить("НомерЛУ", ФР.НомерЛУ);
			Параметры.Вставить("Пароль",  Пароль);
			Форма.ВыполнитьОперацию("ПечататьСтрокуЧека", Параметры, Ответ);
			Если Не ПустаяСтрока(Ответ) Тогда
				Ответ = "Ошибка при попытке печати строки чека на фискальном регистраторе """
				        + ФР.Модель.Наименование
				        + """: " + Ответ;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры // ПечататьСтрокуЧека()

// Процедура осуществляет закрытие чека ФР.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
//                    - Строка таблицы подключенных ФР (млФР), соответствующая ФР,
//                      открытый чек который необходимо закрыть.
//
//  Параметры         - <Структура>
//                    - Структура параметров операции.
//                       Входные параметры:
//                        СуммаНал    - <Число>
//                                    - Сумма, полученная от покупателя, наличными.
//                        СуммаБезНал - <Число>
//                                    - Сумма, полученная от покупателя, безналичными.
//                       Выходные параметры:
//                        НомерЧека   - <Число>
//                                    - Номер текущего чека.
//                        НомерСмены  - <Число>
//                                    - Номер текущей смены.
//
//  Ответ             - <Строка>
//                    - Описание произошедшей в ходе выполнения операции ошибки,
//                      или пустая строка в случае успешного завершения.
//
Процедура ЗакрытьЧек(ФР, Параметры, Ответ) Экспорт

	Ответ = "";

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Ответ = "Ошибка при попытке закрытия чека: фискальный регистратор не подключен.";
	ИначеЕсли ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Ответ = "Ошибка при попытке закрытия чека на фискальном регистраторе """
