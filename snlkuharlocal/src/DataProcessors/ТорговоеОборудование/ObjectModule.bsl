// Процедура осуществляет печать чека для ПКО/РКО на ФР.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
//                    - Строка таблицы подключенных ФР (млФР), соответствующая ФР,
//                      на котором необходимо напечатать чек.
//
//  Параметры         - <Структура>
//                    - Структура параметров операции.
//                       Входные параметры:
//                        Заголовок      - <Строка>
//                                       - Заголовок позиции чека. Например:
//                                         "Принято от Алхимов А.А."
//                        Сумма          - <Число>
//                                       - Сумма в валюте регламентированного учета.
//                                         Если сумма < 0, то печатается чек на
//                                         возврат (РКО).
//                        НДС            - <Число>
//                                       - Ставка НДС. Может принимать одно из
//                                         слежующих значений: 0%, 10%, 18%, 20%.
//                                         Для корректной работы необходимо, чтобы
//                                         для фискального регистратора были назначены
//                                         соответствующие налоговые ставки:
//                                           Ставка 1 - 18%, "НДС 18%"
//                                           Ставка 2 - 10%, "НДС 10%"
//                                           Ставка 3 - 20%, "НДС 20%"
//                                           Ставка 4 - 0%,  "Без НДС".
//                       Выходные параметры:
//                        НомерЧека      - <Число>
//                                       - Номер текущего чека.
//                        НомерСмены     - <Число>
//                                       - Номер текущей смены.
//
//  Ответ             - <Строка>
//                    - Описание произошедшей в ходе выполнения операции ошибки,
//                      или пустая строка в случае успешного завершения.
//
Процедура ПечататьЧекДляПКО(ФР, Параметры, Ответ) Экспорт

	Ответ = "";

	Если ЗначениеНеЗаполнено(ФР) Тогда
		Ответ = "Ошибка при попытке печати чека: фискальный регистратор не подключен.";
	ИначеЕсли ЗначениеНеЗаполнено(ФР.Модель.ОбработкаОбслуживания) Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		         + ФР.Модель.Наименование
		         + """: не задана обработка обслуживания.";
	ИначеЕсли Не ФР.ДляПриемаНаличныхОтЮрЛиц Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: фискальный регистратор не предназначен для отражения наличных денежных расчетов.";
	ИначеЕсли ПустаяСтрока(Параметры.Заголовок) Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: не указано основание.";
	ИначеЕсли Параметры.Сумма = 0 Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: сумма должна быть отлична от нуля.";
	ИначеЕсли (Параметры.НДС <> 0)
	          И (Параметры.НДС <> 10)
	          И (Параметры.НДС <> 18)
	          И (Параметры.НДС <> 20) Тогда
		Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: некорректное значение ставки НДС - """
		        + Формат(Параметры.НДС, "ЧН=0; ЧГ=0")
		        + """.";
	Иначе
		Пароль = ПолучитьЗначениеПоУмолчанию("ПарольКассираФискальногоРегистратора");
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Пароль = ПолучитьЗначениеПоУмолчанию("ПарольАдминистратораФискальногоРегистратора");
		КонецЕсли;
		Если ЗначениеНеЗаполнено(Пароль) Тогда
			Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
		        + ФР.Модель.Наименование
		        + """: в настройках пользователя не указан пароль фискального регистратора.";
		Иначе
			Врем    = Новый Структура();
			Форма   = ПолучитьФормуОбработки(ФР.Модель.ОбработкаОбслуживания);
			//крохин начало 09.08.2019
			
			ПризнакСпособаРасчета = Неопределено;
			Параметры.Свойство("ПризнакСпособаРасчета",ПризнакСпособаРасчета);
			
			Если ПризнакСпособаРасчета = Неопределено Тогда
			//крохин конец 09.08.2019

			Таблица = Новый ТаблицаЗначений();

			Таблица.Колонки.Добавить("Колво");
			Таблица.Колонки.Добавить("Скидка");
			Таблица.Колонки.Добавить("Товар");
			Таблица.Колонки.Добавить("Цена");
			//крохин начало 16.06.2017
			Таблица.Колонки.Добавить("Количество");
			Таблица.Колонки.Добавить("СуммаСкидки");
			Таблица.Колонки.Добавить("СтавкаНДС");
			Таблица.Колонки.Добавить("Номенклатура");
			Таблица.Колонки.Добавить("Секция");
			//крохин конец 16.06.2017
			
			
			Если Параметры.Сумма < 0 Тогда
				Сумма        = -Параметры.Сумма;
				ЧекНаВозврат = Истина;
			Иначе
				Сумма        = Параметры.Сумма;
				ЧекНаВозврат = Ложь;
			КонецЕсли;

			Строка        = Таблица.Добавить();
			Строка.Колво  = 1;
			//крохин начало 16.06.2017
			Строка.Количество  = 1;
			Строка.СуммаСкидки = 0;  
			//крохин начало 08.01.2019
			//Строка.СтавкаНДС = Перечисления.СтавкиНДС.НДС18;
			Строка.СтавкаНДС = Перечисления.СтавкиНДС.НДС20;
			//крохин конец 08.01.2019
			Строка.Номенклатура = Параметры.Заголовок;
			Строка.Секция = 1;
			//крохин конец 16.06.2017
			Строка.Скидка = 0;
			Строка.Товар  = Параметры.Заголовок;
			Строка.Цена   = Сумма;
			
			//крохин начало 09.08.2019	
			Врем.Вставить("ПризнакСпособаРасчета","ОплатаЗаОтгруженныйТовар");
		Иначе
			Параметры.Свойство("СписокТоваров",Таблица);
			
			Если Параметры.Сумма < 0 Тогда
				Сумма        = -Параметры.Сумма;
				ЧекНаВозврат = Истина;
			Иначе
				Сумма        = Параметры.Сумма;
				ЧекНаВозврат = Ложь;
			КонецЕсли;
			Если ПризнакСпособаРасчета = "Аванс" Тогда
				Врем.Вставить("ПризнакСпособаРасчета","Аванс");

		ИначеЕсли ПризнакСпособаРасчета = "ОплатаЗаОтгруженныйТовар" Тогда
			  	Врем.Вставить("ПризнакСпособаРасчета","ОплатаЗаОтгруженныйТовар");
							
			ИначеЕсли ПризнакСпособаРасчета = "ЗачетАванса" Тогда
				Врем.Вставить("ПризнакСпособаРасчета","ЗачетАванса");
			КонецЕсли;
			
			КонецЕсли;
			//крохин конец 09.08.2019

			Врем.Вставить("Объект",         ФР.Объект);
			Врем.Вставить("НомерЛУ",        ФР.НомерЛУ);
			Врем.Вставить("Пароль",         Пароль);
			Врем.Вставить("НомерСекции",    1);
			//крохин начало 16.06.2017
			Врем.Вставить("ПолученоБН", Параметры.ПолученоБН);
			Врем.Вставить("ПолученоНал",    Параметры.ПолученоНал);
			//крохин конец 16.06.2017
			Врем.Вставить("СписокТоваров",  Таблица);
			Врем.Вставить("ЧекНаВозврат",   ЧекНаВозврат);
			Врем.Вставить("НДС",            Параметры.НДС);
			
			//крохин начало 09.08.2019
			Врем.Вставить("КонтрагентНаименование",Параметры.КонтрагентНаименование);
			Врем.Вставить("КонтрагентИНН",Параметры.КонтрагентИНН);
			ВРем.Вставить("CustomerEmail",Параметры.CustomerEmail);
			//крохин конец 09.08.2019

			Форма.ВыполнитьОперацию("ПечататьЧек", Врем, Ответ);
			Если ПустаяСтрока(Ответ) Тогда
				Параметры.Вставить("НомерЧека",  Врем.НомерЧека);
				Параметры.Вставить("НомерСмены", Врем.НомерСмены);
			Иначе
				Ответ = "Ошибка при попытке печати чека на фискальном регистраторе """
				        + ФР.Модель.Наименование
				        + """: " + Ответ;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры // ПечататьЧекДляПКО()

// Процедура осуществляет снятие Z-отчёта на фискальном регистраторе.
//
// Параметры
//  ФР                - <СтрокаТаблицыЗначений>
