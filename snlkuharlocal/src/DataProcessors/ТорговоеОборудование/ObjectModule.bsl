Функция ПолучитьОбработкуОбслуживания(Модель) Экспорт
	ХЗ_Обработки=Модель.ОбработкаОбслуживания83.Обработка.Получить();
	Если ХЗ_Обработки=Неопределено Тогда Возврат Неопределено КонецЕсли;	
	
	ИмяВФ=ПолучитьИмяВременногоФайла("epf"); 
	ХЗ_Обработки.Записать(ИмяВФ);	
	Обработка=ВнешниеОбработки.Создать(ИмяВФ);
	
	//Обработка=ВнешниеОбработки.Создать("C:\Users\1c\Desktop\1\НастройкаФР.epf");
	
	Возврат Обработка;
КонецФункции // ()
 

