&НаКлиенте
Процедура ОпНеНайденКИЗ(ШК, Сооб)
	Если Найти(ШК, РазделительGS1()) > 0 Тогда  //Марка с GS
		
		Марка = СтрЗаменить(ШК, РазделительGS1(),"<GS>");
		Марка = ?(Лев(Марка, 4) = "<GS>", Сред(Марка, 5), Марка);	
		
	ИначеЕсли Найти(ШК, "<GS>") > 0 Тогда //сканируем с экрана
		Марка = ШК;
		Марка = ?(Лев(Марка, 4) = "<GS>", Сред(Марка, 5), Марка);
	//ИначеЕсли СтрДлина(СокрЛП(ШК)) > 30 и СтрНайти(Лев(СокрЛП(ШК),3),"01") > 0 Тогда
	//	Марка = СокрЛП(ШК);  
	Иначе
		Марка = СокрЛП(ШК);	
	КонецЕсли;
	ПоказатьПредупреждение(, Сооб + Марка, 30);
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСсылкуШКУпаковки(ШтрихКод) 
	Рез = Новый Структура;
	Если Найти(ШтрихКод, РазделительGS1()) > 0 Тогда  //Марка с GS
		//+HELP-3942 20250408 Михайловский
		//1-й символ chr(29) бывает
		//SGTIN = Лев(ШтрихКод, СтрНайти(Штрихкод,МаркировкаКлиентСервер.РазделительGS1())-1);
		//ШтрихКод = СтрЗаменить(ШтрихКод, МаркировкаКлиентСервер.РазделительGS1(),"<GS>");
		ШтрихКод = СтрЗаменить(ШтрихКод, РазделительGS1(),"<GS>");
		ШтрихКод = ?(Лев(ШтрихКод, 4) = "<GS>", Сред(ШтрихКод, 5), ШтрихКод);
		SGTIN = Лев(ШтрихКод, СтрНайти(ШтрихКод,"<GS>")-1);
		//-HELP-3942 20250408 Михайловский
	ИначеЕсли Найти(ШтрихКод, "<GS>") > 0 Тогда
		//+HELP-3942 20250408 Михайловский
		//1-й символ chr(29) бывает
		ШтрихКод = ?(Лев(ШтрихКод, 4) = "<GS>", Сред(ШтрихКод, 5), ШтрихКод);
		//-HELP-3942 20250408 Михайловский
		SGTIN = Лев(ШтрихКод, СтрНайти(ШтрихКод,"<GS>")-1);
	ИначеЕсли СтрДлина(СокрЛП(ШтрихКод)) > 30 и СтрНайти(Лев(СокрЛП(ШтрихКод),3),"01") > 0 Тогда //Отсканирована Марка но в формате ХЗ
		SGTIN = Лев(ШтрихКод, 31);
	КонецЕсли; 
	
	СсылкаШКУпаковок = ЗапросШКУпаковки(SGTIN);
	Рез.Вставить("SGTIN", SGTIN);
	Рез.Вставить("ШтрихКод", ШтрихКод);
	Рез.Вставить("СсылкаШКУпаковок", СсылкаШКУпаковок);
	Возврат Рез;
	//СсылкаШКУпаковок;		
КонецФункции

&НаСервереБезКонтекста
Функция ЗапросШКУпаковки(SGTIN)
	СсылкаШКУпаковки = Неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Наименование = &SGTIN" ;
	Запрос.УстановитьПараметр("SGTIN",SGTIN);
	Результат = запрос.Выполнить().Выбрать();
	
	
	Если Результат.Следующий() Тогда
		СсылкаШКУпаковки = Результат.Ссылка;
	КонецЕсли;
	Возврат СсылкаШКУпаковки;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапросСтатусШКУпаковки(СсылкаШКУпаковки)
	Рез = Новый Структура; 
	Рез.Вставить("НачСтатус", Неопределено);
	Рез.Вставить("Номенклатура", Неопределено);
	Рез.Вставить("ТекСтатус", Неопределено);
	Рез.Вставить("ХКМПриход", Неопределено);
	Рез.Вставить("Приход", Неопределено);
	Рез.Вставить("ХКМТек", Неопределено);
	Рез.Вставить("ТекДок", Неопределено); 
	Рез.Вставить("МожноВ", Ложь);
	Запрос = Новый Запрос;
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	СтатусыКМ_Факт.Статус КАК Статус,
	|	СтатусыКМ_Факт.Номенклатура КАК Номенклатура,
	|	СтатусыКМ_Факт.ТипШК КАК ТипШК,
	|	СтатусыКМ_Факт.Регистратор КАК Регистратор,
	|	СтатусыКМ_Факт.Местонахождение КАК Местонахождение
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт КАК СтатусыКМ_Факт
	|ГДЕ
	|	СтатусыКМ_Факт.ШтрихКодУпаковки = &ШтрихКодУпаковки
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыКМ_Факт.Период,
	|	СтатусыКМ_Факт.Регистратор.Дата";
	Запрос.УстановитьПараметр("ШтрихКодУпаковки",СсылкаШКУпаковки);
	Результат = запрос.Выполнить().Выбрать();
	к = 0;
	Пока Результат.Следующий() Цикл
		Если к = 0 Тогда
			Рез.НачСтатус = Результат.Статус;
			Рез.Номенклатура = Результат.Номенклатура; 
			Если ТипЗнч(Результат.Регистратор) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
				Рез.ХКМПриход = Результат.Регистратор; 
				Рез.Приход = Результат.Регистратор.ДокОснование;
			Иначе
				Рез.Приход = Результат.Регистратор;
			КонецЕсли;	
		КонецЕсли;
		Рез.ТекСтатус = Результат.Статус;
		
		Если ТипЗнч(Результат.Регистратор) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
			Рез.ХКМТек = Результат.Регистратор; 
			Рез.ТекДок = Результат.Регистратор.ДокОснование;
		Иначе
			Рез.ТекДок = Результат.Регистратор;
		КонецЕсли;
		
		к = к + 1;
	КонецЦикла; 
	Если (Рез.ТекСтатус = Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте ИЛИ Рез.ТекСтатус = Перечисления.СтатусыКодовМаркировкиФакт.Карантин) И ТипЗнч(Рез.Приход) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Рез.МожноВ = Истина;
	КонецЕсли;	
	Возврат Рез;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РазделительGS1() Экспорт;
	
	Возврат Символ(29); // Dec 29
	
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//Вставить содержимое обработчика  
	Объект.ПричинаРекламации = Справочники.ПричиныРекламаций.НайтиПоКоду("OD7-0006");
	Если Объект.ВозвратныйДокумент = 0 Тогда
		Объект.ТипРекламации = Перечисления.ВидыРекламаций.Вычерк;
	Иначе
		Объект.ТипРекламации = Перечисления.ВидыРекламаций.Возврат;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПроверитьИСоздатьДокументыНаСервере()
	// Вставить содержимое обработчика.
	ТЗВозвр = Объект.ВозвратБрака.Выгрузить();
	Запр = Новый Запрос; 
	Запр.Текст =
	"ВЫБРАТЬ
	|ТЗСтр.ШКУпаковки,         
	|ТЗСтр.Приход,         
	|ТЗСтр.ТекДок,
	|ТЗСтр.Номенклатура,
	|ТЗСтр.МожноВ 
	//|ТЗСтр.ОписН
	|ПОМЕСТИТЬ ВТ_ШК
	|ИЗ
	|	&ТЗ КАК ТЗСтр
	|; 
	|ВЫБРАТЬ
	|ВТ_ШК.ШКУпаковки,         
	|ВТ_ШК.Приход,         
	|ВТ_ШК.ТекДок,
	|ВТ_ШК.Номенклатура,
	|ВТ_ШК.МожноВ,
	|РекламационнаяНакладнаяШтрихкодыУпаковок.Ссылка КАК РКМ
	|
	|ИЗ
	|	ВТ_ШК КАК ВТ_ШК
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.РекламационнаяНакладная.ШтрихкодыУпаковок КАК РекламационнаяНакладнаяШтрихкодыУпаковок
	|	ПО РекламационнаяНакладнаяШтрихкодыУпаковок.ШтрихкодУпаковки = ВТ_ШК.ШКУпаковки
	
	//|ВЫБРАТЬ
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.Ссылка КАК Ссылка,
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.Товар КАК Товар
	//|ИЗ
	//|	Документ.РекламационнаяНакладная.ШтрихкодыУпаковок КАК РекламационнаяНакладнаяШтрихкодыУпаковок"
	
	|";   
	
	//|ВЫБРАТЬ
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.Ссылка КАК Ссылка,
	//|	РекламационнаяНакладнаяШтрихкодыУпаковок.Товар КАК Товар
	//|ИЗ
	//|	Документ.РекламационнаяНакладная.ШтрихкодыУпаковок КАК РекламационнаяНакладнаяШтрихкодыУпаковок"
	
	Запр.УстановитьПараметр("ТЗ", ТЗВозвр);  
	ТЗРез = Запр.Выполнить().Выгрузить();
	СоотДок = Новый Соответствие;
	ТЗСв = ТЗРез.Скопировать();
	ТЗСв.Свернуть("Приход, РКМ");
	Для Каждого ТекСтр Из ТЗСв Цикл
		Если ТипЗнч(ТекСтр.Приход) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			ТекРКМ = ТекСтр.РКМ;
			СоздДок = Ложь;
			Если НЕ ЗначениеЗаполнено(ТекРКМ) Тогда
				СоздДок = Истина;	
			Иначе
				ТДокРКМ = ТекРКМ.ПолучитьОбъект();
				
				Если ТДокРКМ = Неопределено Тогда
					СоздДок = Истина;	
				КонецЕсли;
				
			КонецЕсли;	
			Если СоздДок Тогда	
				ДокРКМ = Документы.РекламационнаяНакладная.СоздатьДокумент();
				ДокРКМ.ИБ = ПолучитьИБПоУмолчанию(); 
				//Найды = ТЗС1.НайтиСтроки(Новый Структура("РНК", НовСтр.РНК));
				//ТД = ТекущаяДатаСеанса();
				//Если Найды.Количество() Тогда 
				//	Если Месяц(Найды[0].ПНК.Дата) = Месяц(ТД) Тогда
				//		ДокРКМ.Дата = Найды[0].ПНК.Дата;
				//	Иначе
				//		ДокРКМ.Дата = ТекущаяДатаСеанса();
				//	КонецЕсли;
				//Иначе
				ДокРКМ.Дата = ТекущаяДатаСеанса();
				ДокРКМ.Автор = ПараметрыСеанса.Пользователь;
				//КонецЕсли;
				ДокРКМ.ДокОснование = ТекСтр.Приход;
				ДокРКМ.Валюта = ТекСтр.Приход.Валюта;
				РКМОбработкаЗаполнения(ТекСтр.Приход, ДокРКМ);
				ДокРКМ.ВидРекламации = Объект.ТипРекламации;
				ДокРКМ.ПричинаРекламации = Объект.ПричинаРекламации;
				ДокРКМ.ПроводитьПоОстаткам = ?(ДокРКМ.ВидРекламации = Перечисления.ВидыРекламаций.Вычерк, Истина, Ложь); 
				//ДокРКМ.ЗаявкаНаВозвратОтПокупателя = Объект.ДокОбъект.Ссылка;
				УстановитьНомерДокументаКлиентСервер(ДокРКМ); 
				ДокРКМ.Склад = Объект.Склад;
				ДокРКМ.Записать();
								
				ТекРКМ = ДокРКМ.Ссылка; 
				//НовСтр.НовыйРКМ = Истина;
			Иначе 
				Если НЕ ТекРКМ.ВидРекламации = Объект.ТипРекламации ИЛИ НЕ (ТекРКМ.ПроводитьПоОстаткам = ?(ТекРКМ.ВидРекламации = Перечисления.ВидыРекламаций.Вычерк, Истина, Ложь)) Тогда
					ТекДокРКМ = ТекРКМ.ПолучитьОбъект();
					ТекДокРКМ.ВидРекламации = Объект.ТипРекламации;
					ТекДокРКМ.ПроводитьПоОстаткам = ?(ТекДокРКМ.ВидРекламации = Перечисления.ВидыРекламаций.Вычерк, Истина, Ложь);
					Если НЕ ТекДокРКМ.Подразделение = ТекДокРКМ.ДокОснование.Подразделение Тогда
						ТекДокРКМ.Подразделение = ТекДокРКМ.ДокОснование.Подразделение;
					КонецЕсли;	
					ТекДокРКМ.Записать();
				КонецЕсли;	
			КонецЕсли;	
			СоотДок.Вставить(ТекСтр.Приход, ТекРКМ);
		КонецЕсли;	
	КонецЦикла; 
	
	
	ТЗНом = Новый ТаблицаЗначений;	
	ТЗНом.Колонки.Добавить("Кол",Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(7)));
	ТЗНом.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	Для Каждого КлЗ Из СоотДок Цикл
		ТПНК = КлЗ.Ключ;
		ТРКМ = КлЗ.Значение;  
		ДокРКМ = ТРКМ.ПолучитьОбъект();
		Если 1=2 Тогда
			ДокРКМ = Документы.РекламационнаяНакладная.СоздатьДокумент();
		КонецЕсли;
		Найды = Объект.ВозвратБрака.НайтиСтроки(Новый Структура("Приход", ТПНК)); 
		
		
		
		
		//Если Найды.Количество() Тогда
		//	Если НЕ ЗначениеЗаполнено(Найды[0].РКМ) И ЗначениеЗаполнено(Найды[0].ПНК) И НЕ ЗначениеЗаполнено(ДокРКМ.ДокументВозврата) Тогда
		//		ДокРКМ.ДокументВозврата = Найды[0].ПНК;
		//	КонецЕсли;	
		//КонецЕсли;
		ТЗНом.Очистить();
		
		Для Каждого Найд Из Найды Цикл
			Если НЕ ЗначениеЗаполнено(Найд.ВозвратныйДок) Тогда
				
				
				Найд.ВозвратныйДок = ТРКМ;
				//Найд.РКМ_ПНК = ДокРКМ.ДокументВозврата;
			КонецЕсли;
			
			Найды1 = ДокРКМ.ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодУпаковки", Найд.ШКУпаковки));
			Если Найды1.Количество() = 0 Тогда
				НовШК = ДокРКМ.ШтрихкодыУпаковок.Добавить();
				НовШК.Количество = 1;
				НовШК.СтатусУКонтрагента = Перечисления.СтатусыМарокУКонтаргента.Излишек; //???
				НовШК.ШтрихкодУпаковки = Найд.ШКУпаковки;
				НовШК.ШКМаркиКонтрагента = Найд.КодМаркировки; 
				НовШК.Товар = Найд.Номенклатура; 
				НовС = ТЗНом.Добавить();
				НовС.Кол = 1;
				НовС.Номенклатура = Найд.Номенклатура;
			КонецЕсли;	
			
		КонецЦикла;
		ТЗН = ТЗНом.Скопировать();
		ТЗН.Свернуть("Номенклатура", "Кол");  
		
		Для Каждого ТСтр Из ТЗН Цикл
			
			НовСТ = ДокРКМ.Товары.Добавить();
			НовСТ.Номенклатура = ТСтр.Номенклатура;
			НайдыНом = ТПНК.Товары.НайтиСтроки(Новый Структура("Номенклатура", ТСтр.Номенклатура));  
			КолвоПНК = 0;
			ОбПНК = 0;
			Для Каждого НайдНом Из НайдыНом Цикл
				КолвоПНК = КолвоПНК + НайдНом.Количество;
				ОбПНК = ОбПНК + НайдНом.Объем;
			КонецЦикла;	
			НовСТ.КоличествоИсх = КолвоПНК;
			НовСТ.КоличествоФакт = КолвоПНК - ТСтр.Кол;
			НовСТ.Количество = ТСтр.Кол;
			НовСТ.Единица = НайдыНом[0].Единица;
			НовСТ.Коэффициент = НайдыНом[0].Коэффициент;
			НовСТ.Цена = НайдыНом[0].Цена;
			НовСТ.ЦенаБезСкидки = НайдыНом[0].ЦенаБезСкидки;
			НовСТ.СтавкаНДС = НайдыНом[0].СтавкаНДС; 
			НовСТ.Объем = Окр(ОбПНК * НовСТ.Количество/КолвоПНК, 3);
			НовСТ.Всего = НовСТ.Цена * НовСТ.Количество;
			НовСТ.ВсегоБезСкидки = НовСТ.ЦенаБезСкидки * НовСТ.Количество;
			ПСтавкаНДС=ПроцентНДСпоСтавке(НовСТ.СтавкаНДС);
			НовСТ.НДС = Окр(НовСТ.Всего*ПСтавкаНДС/(1+ПСтавкаНДС),2);
			НовСТ.Сумма = НовСТ.Всего - НовСТ.НДС;
			
		КонецЦикла;	
		Попытка
			ДокРКМ.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ДокРКМ.Записать();
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьИСоздатьДокументы(Команда) 
	Если Объект.ВозвратБрака.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не заполнена таблица возвратов");
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.Склад) Тогда
		ПоказатьПредупреждение(, "Не выбран склад");
		Возврат;
	КонецЕсли;
	ПроверитьИСоздатьДокументыНаСервере();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура РКМОбработкаЗаполнения(Основание,РКМ) 	
	
	Если Основание=Неопределено ИЛИ Основание.Пустая() Тогда Возврат КонецЕсли;
	
	ВидОснования	= Основание.Метаданные().Имя;
	
	РКМ.ДокОснование	= Основание;
	
	
	// Катаев+ 19/03/13  Добавил заполнение на основании акта приемки
	
	РКМ.ПунктДоставки	= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"ПунктДоставки");			
	РКМ.Менеджер 		= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"Менеджер");			
	РКМ.Организация		= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"Организация");	
	РКМ.ТипЦен			= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"ТипЦен");
	РКМ.ТипСкидок		= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"ТипСкидок");
	
	РКМ.Менеджер			= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"Менеджер");
	//крохин конец 29.01.2013
	
	РКМ.Комментарий		= ""+РКМ.ДокОснование.Метаданные()+" № " + РКМ.ДокОснование.Номер + " от " + Формат(РКМ.ДокОснование.Дата,"ДФ=dd.MM.yy");		
	
	Если ВидОснования="ПриходнаяНакладная" ИЛИ ВидОснования="РасходнаяНакладная" Тогда
		РКМ.Корреспондент	= РКМ.ДокОснование.Контрагент;		
		РКМ.Склад			= РКМ.ДокОснование.Склад; 
		РКМ.Подразделение			= РКМ.ДокОснование.Подразделение;
		//крохин начало 06.03.2012
		РКМ.ВидОплаты = РКМ.ДокОснование.ВидОплаты;
		//крохин конец 06.03.2012
		//крохин начало 24.05.2012
		РКМ.ДатаОплаты = РКМ.Докоснование.ДатаОплаты;
		//крохин конец 24.05.2012
	ИначеЕсли ВидОснования="Перемещение" Тогда
		РКМ.Корреспондент	= РКМ.ДокОснование.СкладПолучатель;
		РКМ.Склад			= РКМ.ДокОснование.Склад;
		// Катаев+ 19/03/13 
	ИначеЕсли Видоснования="АктПриемки"	 Тогда
		РКМ.Корреспондент	= РКМ.ДокОснование.Контрагент;		
		РКМ.Склад			= РКМ.ДокОснование.Склад;
		РКМ.ДатаОплаты = РКМ.ДокОснование.РНК.ДатаОплаты;
		//Катаев- 19/03/13
	Иначе
		РКМ.Склад			= ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"Склад");		
	КонецЕсли;	
	
	РКМ.договор = ПолучитьРеквизитОбъекта(РКМ.ДокОснование,"Договор");
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ВозвратныйДокументПриИзменении(Элемент)
	// Вставить содержимое обработчика. 
	Если Объект.ВозвратныйДокумент = 0 Тогда
		Объект.ТипРекламации = Перечисления.ВидыРекламаций.Вычерк;
	Иначе
		Объект.ТипРекламации = Перечисления.ВидыРекламаций.Возврат;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПНКПриИзмененииНаСервере()
	// Вставить содержимое обработчика. 
	ТЗШК.Очистить();
	Запр = Новый Запрос;
	Запр.Текст  = 
	"ВЫБРАТЬ
	|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШКУпаковки,
	|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Владелец.Ссылка КАК Номенклатура,
	|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.ЗначениеШтрихкода КАК КодМаркировки
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
	|ГДЕ
	|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка.ДокОснование = &ПНК";
	Запр.УстановитьПараметр("ПНК", ПНК); 
	Выб = Запр.Выполнить().Выбрать();
	
	Пока Выб.Следующий() Цикл
		НовС = ТЗШК.Добавить();
		ЗаполнитьЗначенияСвойств(НовС, Выб);
	КонецЦикла;	
КонецПроцедуры

&НаКлиенте
Процедура ПНКПриИзменении(Элемент)
	ПНКПриИзмененииНаСервере();
КонецПроцедуры

