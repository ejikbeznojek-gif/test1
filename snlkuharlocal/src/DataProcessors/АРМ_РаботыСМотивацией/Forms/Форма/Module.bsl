#Область ОбработчикиСобытийФормы       

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)         
	
	Элемент = Начисления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Элемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Проведен");
	Элемент.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Элемент.Использование = Истина;
	Элемент.ПравоеЗначение = Истина;     
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура МесяцНачисленияПриИзменении(Элемент)      
	
	ИмяПоля = "МесяцНачисления";

	Если ЗначениеЗаполнено(МесяцНачисления) Тогда
		Элемент = Неопределено;
		Для Каждого ТекЭлемент Из Начисления.Отбор.Элементы Цикл
			Если ТекЭлемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля) Тогда
				Элемент = ТекЭлемент;
			КонецЕсли;
		КонецЦикла;
		Если Элемент = Неопределено Тогда
			Элемент = Начисления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			Элемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля);
			Элемент.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			Элемент.Использование = Истина;

		КонецЕсли;

		Элемент.ПравоеЗначение = МесяцНачисления;
	Иначе
		ЭлементДляУдаления = Начисления.Отбор.Элементы.Найти(
			Новый ПолеКомпоновкиДанных(ИмяПоля));
		Если ЭлементДляУдаления <> Неопределено Тогда
			Начисления.Отбор.Элементы.Удалить(ЭлементДляУдаления);
		КонецЕсли;
	КонецЕсли;   
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы    

&НаКлиенте
Процедура ОткрытьСформироватьОтчетПоПремиям(Команда)   
	
	РезультатПолученияОтчета = ПолучитьВнешнийОтчетПоПремиям();
	Если Не РезультатПолученияОтчета.Успешно Тогда
		МаркировкаКС.ВывестиОшибки(РезультатПолученияОтчета);
		Возврат;
	КонецЕсли;
	Данные = РезультатПолученияОтчета.Данные;

	НужнаяНастройкаКомпоновщика = Данные.Настройка;
	ВнешнийОтчет = Данные.Отчет;
	Настройки = Новый Структура("Дата1, Дата2, НастройкиКомпоновщика");
	Если ЗначениеЗаполнено(МесяцНачисления) Тогда
		Настройки.Дата1 = НачалоМесяца(МесяцНачисления);
		Настройки.Дата2 = КонецМесяца(МесяцНачисления);
	Иначе
		ТекущаяДатаСеанса = ПолучитьТекущуюДатаСеанса();
		Настройки.Дата1 = НачалоМесяца(ТекущаяДатаСеанса);
		Настройки.Дата2 = КонецМесяца(ТекущаяДатаСеанса);
	КонецЕсли; 
	
	ФормаОтчета = ПолучитьФорму("Отчет.ОбщийОтчетНаКомпоновке.Форма.ФормаОтчета");
	ФормаОтчета.ВидОтчета = ВнешнийОтчет;
	ФормаОтчета.НастройкиЗагружены = Истина;
	Настройки.НастройкиКомпоновщика = НужнаяНастройкаКомпоновщика;
	ФормаОтчета.Открыть();
	ФормаОтчета.Дата1 = Настройки.Дата1;
	ФормаОтчета.Дата2 = Настройки.Дата2;
	ФормаОтчета.ВосстановитьНастройкуОтчета(Настройки);
	ФормаОтчета.Сформировать(Неопределено);  
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНачисленияНаВыбранныйМесяц(Команда)
	
	Если Не ПроверитьМесяц() Тогда
		Возврат;
	КонецЕсли;

	СоздатьНачисленияНаВыбранныйМесяцНаСервере(МесяцНачисления);
	Элементы.Начисления.Обновить(); 
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбновитьНачисленияПланВыбранногоМесяца(Команда)   
	
	Если Не ПроверитьМесяц() Тогда
		Возврат;
	КонецЕсли;
	Попытка
		ОбновитьНачисленияВыбранногоМесяцаНаСервере(МесяцНачисления, "ПланРассчитан");
	Исключение
		ТекстСообщения = ОписаниеОшибки();
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = ТекстСообщения;
		Сообщение.Сообщить();
	КонецПопытки;
	Элементы.Начисления.Обновить();

КонецПроцедуры 

&НаКлиенте
Процедура ОбновитьНачисленияФактВыбранногоМесяца(Команда)        
	
	Если Не ПроверитьМесяц() Тогда
		Возврат;
	КонецЕсли;

	ОбновитьНачисленияВыбранногоМесяцаНаСервере(МесяцНачисления, "ФактРассчитан");
	Элементы.Начисления.Обновить();

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНачислениеПремииВыбранногоМесяца(Команда)    
	
	Если Не ПроверитьМесяц() Тогда
		Возврат;
	КонецЕсли;

	ОбновитьНачисленияВыбранногоМесяцаНаСервере(МесяцНачисления, "ПремияРассчитана");
	Элементы.Начисления.Обновить();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ПолучитьТекущуюДатаСеанса() 
	
	Возврат ТекущаяДатаСеанса();
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОбновитьНачисленияВыбранногоМесяцаНаСервере(Знач Месяц, Знач ИмяРеквизитаОбновления)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
				   |	НачислениеПремииЗаВыполнениеПлана.Ссылка КАК Ссылка
				   |ИЗ
				   |	Документ.НачислениеПремииЗаВыполнениеПлана КАК НачислениеПремииЗаВыполнениеПлана
				   |ГДЕ
				   |	НачислениеПремииЗаВыполнениеПлана.Проведен
				   |	И НачислениеПремииЗаВыполнениеПлана.МесяцНачисления = &МесяцНачисления";
	Запрос.УстановитьПараметр("МесяцНачисления", Месяц);
	Выборка = Запрос.Выполнить().Выбрать();
	НачатьТранзакцию();
	Попытка
		Пока Выборка.Следующий() Цикл
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ДокОбъект[ИмяРеквизитаОбновления] = Ложь;
			ДокОбъект.РассчитатьВсеДанные();
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	Документы.НачислениеПремииЗаВыполнениеПлана.РассчитатьМинимальнуюПремиюЗаМесяц(Месяц);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьНачисленияНаВыбранныйМесяцНаСервере(Знач Месяц)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
				   |	РаспределениеСотрудниковПоНаправлениямПродаж.Ссылка КАК ВидНачисления
				   |ИЗ
				   |	Справочник.РаспределениеСотрудниковПоНаправлениямПродаж КАК РаспределениеСотрудниковПоНаправлениямПродаж
				   |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НачислениеПремииЗаВыполнениеПлана КАК НачислениеПремииЗаВыполнениеПлана
				   |		ПО (НачислениеПремииЗаВыполнениеПлана.ВидНачисления = РаспределениеСотрудниковПоНаправлениямПродаж.Ссылка)
				   |			И (НачислениеПремииЗаВыполнениеПлана.МесяцНачисления = &Месяц)
				   |			И (НачислениеПремииЗаВыполнениеПлана.Проведен)
				   |ГДЕ
				   |	НЕ РаспределениеСотрудниковПоНаправлениямПродаж.ПометкаУдаления
				   |	И НачислениеПремииЗаВыполнениеПлана.Ссылка есть null";
	Запрос.УстановитьПараметр("Месяц", Месяц);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокОбъект = Документы.НачислениеПремииЗаВыполнениеПлана.СоздатьДокумент();
		ДокОбъект.ВидНачисления = Выборка.ВидНачисления;
		ДокОбъект.Дата = ТекущаяДатаСеанса();
		ДокОбъект.МесяцНачисления = Месяц;
		ДокОбъект.ЗаполнитьКритерииПоНаправлению();
		ДокОбъект.РассчитатьВсеДанные();
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;   
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВнешнийОтчетПоПремиям()

	СтруктураВозврата = МаркировкаКС.СтруктураРезультата(Истина);

	КодОтчета = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(
		Справочники.Пользователи.НастройкиПоУмолчанию, "ОтчетПоМотивацииДОП", "");
	ИмяНастройки = ОбщегоНазначения_ПИ.ПолучитьЗначениеРСРеквизитыСправочников(
		Справочники.Пользователи.НастройкиПоУмолчанию, "ИмяНастройкиОтчетПоМотивацииДОП", "");
	Если КодОтчета = "" Тогда
		СтруктураВозврата.Ошибки.Добавить("Не установлен код отчёта для отчёта по мотивации");
	КонецЕсли;

	Если ИмяНастройки = "" Тогда
		СтруктураВозврата.Ошибки.Добавить("Не установлено имя настройки по умолчанию для отчёта по мотивации");
	КонецЕсли;

	Если СтруктураВозврата.Ошибки.Количество() > 0 Тогда
		СтруктураВозврата.Успешно = Ложь;
		Возврат СтруктураВозврата;

	КонецЕсли;

	Отчет = Отчеты.ОбщийОтчетНаКомпоновке.Создать();
	Отчет.ВидОтчета = Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОтчета);
	Отчет.НастройкиЗагружены = Истина;

	ИмяОтчета = "ОбщийОтчетНаКомпоновке_" + КодОтчета;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
				   |	НастройкиОбъектов.ЗначениеНастройки КАК ЗначениеНастройки
				   |ИЗ
				   |	РегистрСведений.НастройкиОбъектов КАК НастройкиОбъектов
				   |ГДЕ
				   |	НастройкиОбъектов.ИмяОбъекта = &ИмяОтчета
				   |	И НастройкиОбъектов.Пользователь = &Пользователь";
	Запрос.УстановитьПараметр("Пользователь", Справочники.Пользователи.НастройкиПоУмолчанию);
	Запрос.УстановитьПараметр("ИмяОтчета", ИмяОтчета);

	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Количество() = 0 Тогда
		СтруктураВозврата.Ошибки.Добавить("Не найдены настройки отчёта для отчёта по мотивации");
		СтруктураВозврата.Успешно = Ложь;
		Возврат СтруктураВозврата;
	КонецЕсли;

	Пока Результат.Следующий() Цикл
		ОбщиеНастройки = Результат.ЗначениеНастройки.получить();
		НужнаяНастройка = ОбщиеНастройки.Дерево.Строки.Найти(ИмяНастройки);
		Если НужнаяНастройка <> Неопределено Тогда
			НужнаяНастройкаКомпоновщика =  НужнаяНастройка.Значение.НастройкиКомпоновщика;
		Иначе
			СтруктураВозврата.Ошибки.Добавить("Не найдены настройки отчёта для отчёта по мотивации");
			СтруктураВозврата.Успешно = Ложь;
			Возврат СтруктураВозврата;
		КонецЕсли;

	КонецЦикла;
	Если СтруктураВозврата.Ошибки.Количество() = 0 Тогда
		СтруктураВозврата.Данные = Новый Структура("Отчет,Настройка", Справочники.ВнешниеОтчеты.НайтиПоКоду(КодОтчета),
			НужнаяНастройкаКомпоновщика);
	Иначе
		СтруктураВозврата.Успешно = Ложь;
	КонецЕсли;

	Возврат СтруктураВозврата;   
	
КонецФункции

&НаКлиенте
Функция ПроверитьМесяц()   
	
	Если Не ЗначениеЗаполнено(МесяцНачисления) Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Укажите месяц начисления";
		Сообщение.Сообщить();
		Возврат Ложь;
	КонецЕсли;
	Возврат Истина; 
	
КонецФункции

#КонецОбласти