					Если ЗначениеНеЗаполнено(Дата) Тогда
						ТабДок.Область(НомерСтроки,16,НомерСтроки,16).Текст = "СФ "+СФ.Номер+ " от "+ФОрмат(ТекДок.Дата,"ДФ=dd.MM.yyyy")+" стр. "+Сч + " из "+ВсегоСтраниц+". Валюта: руб";
					Иначе
						ТабДок.Область(НомерСтроки,16,НомерСтроки,16).Текст = "СФ "+СФ.Номер+ " от "+ФОрмат(Дата,"ДФ=dd.MM.yyyy")+" стр. "+Сч + " из "+ВсегоСтраниц+". Валюта: руб";
					КонецЕсли;
					//крохин конец 14.02.2013
					ТабДок.Область(НомерСтроки,16,НомерСтроки,16).ГоризонтальноеПоложение = ГоризонтальноеПоложение.Право;
				КонецЕсли;
			Иначе
				
				Если ЗначениеНеЗаполнено(Дата) Тогда
					ТабДок.Область(НомерСтроки,14,НомерСтроки,14).Текст = "СФ "+СФ.Номер+ " от "+ФОрмат(ТекДок.Дата,"ДФ=dd.MM.yyyy")+" стр. "+Сч + " из "+ВсегоСтраниц+". Валюта: руб";
				Иначе
					ТабДок.Область(НомерСтроки,14,НомерСтроки,14).Текст = "СФ "+СФ.Номер+ " от "+ФОрмат(Дата,"ДФ=dd.MM.yyyy")+" стр. "+Сч + " из "+ВсегоСтраниц+". Валюта: руб";
				КонецЕсли;
				//крохин конец 14.02.2013
				ТабДок.Область(НомерСтроки,14,НомерСтроки,14).ГоризонтальноеПоложение = ГоризонтальноеПоложение.Право; 
				//крохин конец 23.01.2012
				
				//метро, другая MXL
				Если ИндивидуальнаяНастройкаПодКонтрагента = Справочники.НастройкиПечатиПодКонтрагента.Метро Тогда
