			КонецЕсли;
		КонецЕсли;
		//Лобан --- 090813
		
		//Лобан 120314 +++
		//Печать наименование номенклатуры для контрагента из матрицы
		//СтрокаТН.НоменклатураПредставление=СокрЛП(Модель.ТипТовара)+" "+СокрЛП(Модель.Родитель.Брэнд)+" "+СокрЛП(Модель.КодПроизводителя)+" "+Номенклатура.Наименование;
		//крохин начало 05.02.2019
		Если ДокОбъект.Контрагент.ИспользоватьНоменклатурнуюМатрицу Тогда
			//крохин конец 05.02.2019	
			Запрос = Новый запрос;
