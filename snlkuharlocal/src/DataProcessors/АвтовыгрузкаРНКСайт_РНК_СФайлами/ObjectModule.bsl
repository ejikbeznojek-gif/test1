Процедура ЗаписатьДокументЗаказ(ДокументПРоведения)

	РежимПроведения = ?(ПроводитьДокументыОперативно, РежимПроведенияДокумента.Оперативный, РежимПроведенияДокумента.Неоперативный);
	
	Если ДокументПРоведения = документы.Заказ.ПустаяСсылка() тогда
		возврат;
	КонецЕсли;	
	//++Данилова Е.В. 11.09.2024
	//Докк = ДокументПроведения.ПолучитьОбъект();
	Если ТипЗнч(ДокументПРоведения) = Тип("ДокументСсылка.Заказ") Тогда
	
		Докк = ДокументПроведения.ПолучитьОбъект();
		
	ИначеЕсли ТипЗнч(ДокументПРоведения) = Тип("ДокументОбъект.Заказ") Тогда
		
		Докк = ДокументПРоведения; 
		
	КонецЕсли;
	//--Данилова Е.В. 11.09.2024
	
	Если  НЕ  ДокументПРоведения.пометкаУдаления = истина ТОгда
	
		
		Попытка
			
			Докк.Записать(РежимЗаписиДокумента.Проведение, РежимПроведения);			
			
		Исключение
			ЗаписатьВЛог("b2b", "Ошибка при проведении документа: " + Строка(ДокументПРоведения) + Символы.ПС + ОписаниеОшибки(),"Информация"); 
			//++Данилова Е.В. 11.09.2024
			Если ТранзакцияАктивна() Тогда
			
				ОтменитьТранзакцию();
			
			КонецЕсли;
			//--Данилова Е.В. 11.09.2024
		конецПопытки;
	иначе
		Попытка
			Докк.Записать(РежимЗаписиДокумента.ОтменаПроведения);			
		Исключение
			ЗаписатьВЛог("b2b", "Ошибка при установке пометки на удаление документа: " + Строка(ДокументПроведения) + Символы.ПС + ОписаниеОшибки(),"Информация");                     
			СообщитьОбИсключительнойОшибке(Ложь, "Ошибка при установке пометки на удаление документа: " + Строка(ДокументПроведения) + Символы.ПС + ОписаниеОшибки());
			//++Данилова Е.В. 11.09.2024
			Если ТранзакцияАктивна() Тогда
			
				ОтменитьТранзакцию();
			
			КонецЕсли;
			//--Данилова Е.В. 11.09.2024
			Возврат;
		КонецПопытки;
	конецЕсли;
	
КонецПРоцедуры
