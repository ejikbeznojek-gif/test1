// нечаева 21,09,23++
Функция СформироватьНакладную(ДокОбъект,ДопПараметры=Неопределено) Экспорт 
	
	ТабДок	= Новый ТабличныйДокумент;
	
	МетаДок		= ДокОбъект.Метаданные();
	ВидДокумента= МетаДок.Имя;
	
	Если ВидДокумента="РасходнаяНакладная" Тогда
		ВидНакладной="Расходная накладная";
		Получатель	=ДокОбъект.Контрагент;
	ИначеЕсли ВидДокумента="ПриходнаяНакладная" Тогда
		ВидНакладной="Приходная накладная";				
		Получатель	=ДокОбъект.Склад;
	ИначеЕсли ВидДокумента="Перемещение" Тогда
		ВидНакладной="Перемещение";		
		Получатель	=ДокОбъект.СкладПолучатель;
	ИначеЕсли ВидДокумента="ОтчетКассовойСмены" Тогда
		ВидНакладной="ОКС";		
		Получатель	=ДокОбъект.Касса;				
	ИначеЕсли ВидДокумента="ПродажаИМ" Тогда
		ВидНакладной="Продажа интернет-магазина";		
		Получатель	=ДокОбъект.Контрагент;
		
	Иначе
		ВидНакладной="";		
	КонецЕсли; 
	
	Макет=ПолучитьМакет("Накладная");
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	//крохин начало 23.08.2011
	//в ЛН нет организации	
	//ОблЗаголовок.Параметры.Фирма		= ДокОбъект.Организация.НаименованиеПолное;
	МетаданныеДокумента = ДокОбъект.Метаданные();
	Если ЕстьРеквизитДокумента("Организация",МетаданныеДокумента) Тогда
		ОблЗаголовок.Параметры.Фирма		= ДокОбъект.Организация.НаименованиеПолное;
	Иначе
		ОблЗаголовок.Параметры.Фирма        = Справочники.Организации.НайтиПоКоду("SS-001").НаименованиеПолное; 
	КонецЕсли;
	//крохин конец 23.08.2011
	ОблЗаголовок.Параметры.Склад		= "Склад: "+ДокОбъект.Склад;
	ОблЗаголовок.Параметры.ВидНакладной = ВидНакладной;
	ОблЗаголовок.Параметры.Номер		= ДокОбъект.Номер;		
	ОблЗаголовок.Параметры.Дата			= Формат(ДокОбъект.Дата,"ДФ=dd.MM.yyyy");		
	ОблЗаголовок.Параметры.Получатель	= Получатель;
	Попытка
		ОблЗаголовок.Параметры.ДатаОтгрузки	= "Дата отгрузки: "+Формат(ДокОбъект.ДатаОтгрузки,"ДФ=dd.MM.yyyy");			
	Исключение
		
	КонецПопытки;
	
	Если ЕстьРеквизитДокумента("Комментарий",МетаДок) Тогда
		ОблЗаголовок.Параметры.Комментарий	= СокрЛП(ДокОбъект.Комментарий);	
	КонецЕсли; 
	
	ТабДок.Вывести(ОблЗаголовок);
	
	
	Если ВидДокумента="РасходнаяНакладная" И ДокОбъект.ДопОбработка>0 Тогда
		ТабДок.Вывести(Макет.ПолучитьОбласть("ЗаголовокДопОбработка"));
		Для Каждого СтрокаТЧ Из ДокОбъект.ДопОбработки Цикл
			Если СтрокаТЧ.ВидДопОбработки=Справочники.ВидыДопОбработки.БезОбработки Тогда Продолжить КонецЕсли; 
			
			ОблСтрока=Макет.ПолучитьОбласть("СтрокаДопОбработки");		
			ОблСтрока.Параметры.Заполнить(СтрокаТЧ);
			
			ОблСтрока.Параметры.ВидДопОбработки = ?(Пустаястрока(строкаТЧ.ВидДопОбработки.Описание) ,строкаТЧ.ВидДопОбработки,СтрокаТЧ.ВидДопОбработки.Описание);
			
			
			ТабДок.Вывести(ОблСтрока);			
		КонецЦикла;	
	КонецЕсли;
	
	ОблШапка	= Макет.ПолучитьОбласть("Шапка");
	
	ТабДок.Вывести(ОблШапка);
	
	ТШК=ПолучитьШтрихКоды(ДокОбъект.Товары);
	
	Сч=0;
	
	//нечаева 03,07,14 добавила кцн++
	//16,07,14 +++ нечаева
	ТекДокумент=ДокОбъект;
	ТК=ПолучитьТаблицуНакладной(ДокОбъект);               
	//16,07,14 --- нечаева
	//нечаева 03,07,14 добавила кцн--
	
	
	Для Каждого СтрокаТоваров Из ТК Цикл
		Если СтрокаТоваров.Количество=0 Тогда Продолжить КонецЕсли; 
		
		СтрокаТШК=ТШК.Найти(СтрокаТоваров.Номенклатура,"Номенклатура");
		Если СтрокаТШК=Неопределено Тогда
			СтрокаТШК=ТШК.Добавить();			
			СтрокаТШК.Номенклатура=СтрокаТоваров.Номенклатура;
		КонецЕсли; 
		
		Сч=Сч+1;
		
		ОблСтрока	= Макет.ПолучитьОбласть("Строка");
		
		ОблСтрока.Параметры.Сч=Сч;
		
		ОблСтрока.Параметры.Заполнить(СтрокаТоваров);					
		ОблСтрока.Параметры.Заполнить(СтрокаТоваров.Номенклатура);		
		ОблСтрока.Параметры.ШтрихКод=СтрокаТШК.ШтрихКод;
		
		ТабДок.Вывести(ОблСтрока);		
	КонецЦикла; 
	
	// нечаева ++
	Если ВидДокумента="ПродажаИМ" Тогда
		
		Для Каждого СтрокаТоваров Из ДокОбъект.Услуги Цикл
			//Если СтрокаТоваров.Количество=0 Тогда Продолжить КонецЕсли; 
			
			СтрокаТШК=ТШК.Найти(СтрокаТоваров.Номенклатура,"Номенклатура");
			Если СтрокаТШК=Неопределено Тогда
				СтрокаТШК=ТШК.Добавить();			
				СтрокаТШК.Номенклатура=СтрокаТоваров.Номенклатура;
			КонецЕсли; 
			
			Сч=Сч+1;
			
			ОблСтрока	= Макет.ПолучитьОбласть("Строка");
			
			ОблСтрока.Параметры.Сч=Сч;
			
			ОблСтрока.Параметры.Заполнить(СтрокаТоваров);					
			ОблСтрока.Параметры.Заполнить(СтрокаТоваров.Номенклатура);		
			ОблСтрока.Параметры.ШтрихКод=СтрокаТШК.ШтрихКод;
			ОблСтрока.Параметры.Количество=0;
			
			ТабДок.Вывести(ОблСтрока);		
		КонецЦикла; 
		
		ОблПодвал	= Макет.ПолучитьОбласть("ПодвалИМ");
		ОблПодвал.Параметры.Сч=Сч;
		ОблПодвал.Параметры.Количество	=ДокОбъект.Товары.Итог("Количество");
		
		ОблПодвал.Параметры.Всего		=ДокОбъект.Товары.Итог("Всего")+ДокОбъект.Услуги.Итог("Всего");
		
		//крохин начало 06.03.2012
		//есть ещё оплата сертификатом
		//ОблПодвал.Параметры.ВсегоКОплате=ДокОбъект.Товары.Итог("Всего")+ДокОбъект.Услуги.Итог("Всего")-ДокОбъект.СуммаБонуса;
		ОблПодвал.Параметры.СуммаОплатыСертификатом = ДокОбъект.СуммаОплатыСертификатом;
		ОблПодвал.Параметры.ВсегоКОплате=ДокОбъект.Товары.Итог("Всего")+ДокОбъект.Услуги.Итог("Всего")-ДокОбъект.СуммаБонуса-ДокОбъект.СуммаОплатыСертификатом;
		//крохин конец 06.03.2012
		ОблПодвал.Параметры.СуммаБонуса	=ДокОбъект.СуммаБонуса;
		
		
	Иначе
		
		
		ОблПодвал	= Макет.ПолучитьОбласть("Подвал");
		ОблПодвал.Параметры.Сч=Сч;
		ОблПодвал.Параметры.Количество	=ДокОбъект.Товары.Итог("Количество");
		
		ОблПодвал.Параметры.Всего		=ТК.Итог("Всего");
		
		
		
		
	КонецЕсли;
	
	// Нечаева ----
	
	
	ТабДок.Вывести(ОблПодвал);		
	
	ВывестиКонтрольнуюИнформациюВВыходнуюТаблицуН(ДокОбъект,ТабДок,ПолучитьМакет("Накладная"));
	
	
	ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_"+ДокОбъект.Метаданные().Имя+"_"+ВидДокумента;
	ТабДок.ОтображатьСетку 		= Ложь;	
	ТабДок.ОтображатьЗаголовки 	= Ложь;
	
	Возврат ТабДок;
	
	
	
КонецФункции // Печать()

//вывод контрольной информации в печ. форму для сравнения спецификаций
Процедура ВывестиКонтрольнуюИнформациюВВыходнуюТаблицуН(ДокОбъект,Таб,Макет) Экспорт	
	Если Константы.НеВыводитьКонтрольнуюИнформациюПриПечати.Получить() Тогда Возврат КонецЕсли;
	
	МетаДок=ДокОбъект.Метаданные();
	
	ПараметрыШапки=Новый Структура;
	
	Вид80=ДокОбъект.Метаданные().Имя;
	Если Вид80="РасходнаяНакладная" Тогда
		Вид77=?(ДокОбъект.ВидОплаты=Перечисления.ВидыОплаты.НАЛ,"РасходнаяНАЛ","РасходнаяБН");
	Иначе
		Вид77=Вид80;			
	КонецЕсли; 
	
	ПараметрыШапки.Вставить("Вид77",Вид77);
	ПараметрыШапки.Вставить("Номер",ДокОбъект.Номер);
	ПараметрыШапки.Вставить("Дата",	ДокОбъект.Дата);
	
	Если ЕстьРеквизитДокумента("ДатаОтгрузки",МетаДок) Тогда
		ПараметрыШапки.Вставить("ДатаОтгрузки",	ДокОбъект.ДатаОтгрузки);		
	КонецЕсли; 
	
	Если ЕстьРеквизитДокумента("Контрагент",МетаДок) Тогда
		ПараметрыШапки.Вставить("КонтрагентНаименование",	ДокОбъект.Контрагент.Наименование);	
		ПараметрыШапки.Вставить("КонтрагентКод",			ДокОбъект.Контрагент.Код);
	КонецЕсли;
	
	ПараметрыШапки.Вставить("СкладНаименование",		ДокОбъект.Склад.Наименование);
	ПараметрыШапки.Вставить("СкладКод",					ДокОбъект.Склад.Код);	
	Если ЕстьРеквизитДокумента("Организация",ДокОбъект.Метаданные()) Тогда
		попытка
			ПараметрыШапки.Вставить("ОрганизацияНаименование",	ДокОбъект.Организация.Наименование);
		исключение
			ПараметрыШапки.Вставить("ОрганизацияНаименование",	Справочники.Организации.НайтиПоКоду("SS-001"));
		КонецПопытки;
	КонецЕсли;	
	
	Обл_Шапка=Макет.ПолучитьОбласть("Контроль_Шапка");
	Обл_Шапка.Параметры.Заполнить(ПараметрыШапки);
	
	НачСтрока=Таб.ВысотаТаблицы+1;
	
	Таб.Вывести(Обл_Шапка);
	
	Для Каждого СтрокаТЧ Из ДокОбъект.Товары  Цикл
		ОблСтрока=Макет.ПолучитьОбласть("Контроль_Строка");
		
		ПараметрыСтроки=Новый Структура;
		
		ПараметрыСтроки.Вставить("Код77",		СтрокаТЧ.Номенклатура.Код77);
		ПараметрыСтроки.Вставить("Наименование",СтрокаТЧ.Номенклатура.Наименование);
		ПараметрыСтроки.Вставить("Количество",	СтрокаТЧ.Количество);
		
		Если Вид80<>"ЛистНабора" Тогда
			ПараметрыСтроки.Вставить("Цена",		СтрокаТЧ.Цена);
			ПараметрыСтроки.Вставить("НДС",			СтрокаТЧ.НДС);
			ПараметрыСтроки.Вставить("Всего",		СтрокаТЧ.Всего);		
		КонецЕсли; 
		
		ОблСтрока.Параметры.Заполнить(ПараметрыСтроки);		
		
