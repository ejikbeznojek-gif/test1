Функция СформироватьCMLСРанееЗагруженнымиЗаказами(СтрокаCML, МассивИзменений) 
	//
	ОтобразитьСостояние("Поиск открытых заказов, загруженных с " + HTTPОбменСервер + "...");
	
	ТаблицаДокументов = тСписокЗаказовНаОтправку; //ПроцедурыОбменаССайтом.ПолучитьЗаказыСОплатойИОтгрузкойПоКатегориямПоРегистру(МассивИзменений, мМассивЗагруженныхДокументов);
	
	Если ТаблицаДокументов.Количество() = 0 Тогда  
		Возврат ТаблицаДокументов;
	КонецЕсли;
	
	ОбъектCML = ПолучитьОбъектДляЗаписиXML("",ТекущаяДата());
	НачатьCML(ОбъектCML);
	
	// тут не будем табличную часть передавать.
	
	//++Данилова Е.В. 11.09.2024
	НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);//++Данилова Е.В. 29.04.2025 ASU-2239 
	//--Данилова Е.В. 11.09.2024
	Для Каждого СтрокаТД Из ТаблицаДокументов Цикл
		
		ТекЗаказ =  СтрокаТД.ЗаказСсылка;
		//нечаева 06,05,22+++
		ТекСтатус = ПолучитьСтатусЗаказа(ТекЗаказ);
		// поменяем статус у самого заказа.
		Если ТекСтатус = "CO" ТОгда
			ЗакОб  = текзаказ.ПолучитьОбъект();
			ЗакОб.СостояниеНакладной = перечисления.СостоянияЗаказаКонтрагента.ВыполненЧастично;
			//ЗакОб.записать();
			//++Данилова Е.В. 11.09.2024
			//ЗаписатьДокументЗаказ(текзаказ);
			ЗаписатьДокументЗаказ(ЗакОб);
			//--Данилова Е.В. 11.09.2024

		иначе
			попытка
				ЗакОб  = текзаказ.ПолучитьОбъект();
				ЗакОб.СостояниеНакладной = перечисления.СостоянияЗаказаКонтрагента.Выполнен;
				ЗакОб.СостояниеСогласования = перечисления.СостоянияСогласования.Выполнен;
				//ЗакОб.записать();
				//++Данилова Е.В. 11.09.2024
				//ЗаписатьДокументЗаказ(текзаказ);
				ЗаписатьДокументЗаказ(ЗакОб);
				//--Данилова Е.В. 11.09.2024

			исключение
					ЗаписатьВЛог("b2b", "Ошибка при проведении документа: " + Строка(ЗакОб) + Символы.ПС + ОписаниеОшибки(),"Информация");                     
			//СообщитьОбИсключительнойОшибке(Ложь, "Ошибка при проведении документа: " + Строка(ДокументПроведения) + Символы.ПС + ОписаниеОшибки());
			//Возврат Ложь;

			конецпопытки;
		конецЕсли;
		//нечаева 06,05,22--
		
		ОбъектCML.ЗаписатьНачалоЭлемента("Документ");
		
		ВыгрузитьЗаказВCML(ОбъектCML, СтрокаТД);
		
		ОбъектCML.ЗаписатьНачалоЭлемента("ЗначенияРеквизитов");
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Номер по 1С", СтрокаТД.Номер);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата по 1С", ФорматДатыДляCML(СтрокаТД.Дата));
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "ПометкаУдаления", СтрокаТД.ПометкаУдаления);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Проведен", СтрокаТД.Проведен);
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Финальный статус", "false");
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Платежный профиль", ТекЗаказ.контрагент.ведущий.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Код пользователя", ТекЗаказ.контрагент.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Адрес доставки", ТекЗаказ.пунктДоставки.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата доставки", ФорматДатыДляCML(ТекЗаказ.ДатаОтгрузки));

				
		// тут меняем статус заказа
		Если ТекСтатус = "CO" ТОгда
			
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа ИД", "CO");
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа", "[CO] Частично отгружено");
		иначе
					
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа ИД", "F");
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа", "[F] Выполнен");
		конецЕсли;
		
		
		// "[P] Оформлен"
		// [D] Отменен
		// [N] В обработке
		// [A] Требует подтверждения
		// [P] Оформлен
		// CO - частично отгружен
		// [F] Выполнен
		
		
		ОбъектCML.ЗаписатьКонецЭлемента();
		ОбъектCML.ЗаписатьКонецЭлемента();
		
	КонецЦикла;
	
	//ОбъектCML.ЗаписатьКонецЭлемента();
	
	СтрокаCML = ЗавершитьCML(ОбъектCML);
	
	//++Данилова Е.В. 11.09.2024
	Если ТранзакцияАктивна() Тогда
		
		ЗафиксироватьТранзакцию();
		
	КонецЕсли;
	//--Данилова Е.В. 11.09.2024
	
	Возврат ТаблицаДокументов;
	
КонецФункции
