	|	МатрицаТовары.Ссылка.Проведен = ИСТИНА
	|	И (НЕ (ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(20))) = """""""")
	|	И МатрицаТовары.Ссылка.Контрагент = &ТекКонтрагент
	//|	И МатрицаТовары.Ссылка.Договор = &Договор
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &датаДок2
	|	И МатрицаТовары.Ссылка.Дата <= &датаДок1
	|	И МатрицаТовары.Номенклатура = &ТекНом";
	
	//нечаева 18,07,17+++
	Попытка
		Если ДокОбъект.ПостояннаяАкция Тогда
			Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
			//крохин начало 28.07.2017
			//постоянные акции только под галку
		Иначе
			Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
			//крохин конец 28.07.2017
		КонецЕсли;
	Исключение
		
	КонецПопытки;
	
	Запрос.Текст = Запрос.Текст +"
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	//нечаева 18,07,17---
	
	Запрос.УстановитьПараметр("ТекКонтрагент",контрагент);
	Запрос.УстановитьПараметр("Договор",договор);
	Запрос.УстановитьПараметр("ТекНом",Номенклатура);
	Запрос.УстановитьПараметр("ДатаДок2",НачалоДня(ДокОбъект.дата));
