	КонецЕсли;	
	//------------------------------------------------------------------------------------------
	
	
	
	НовСтр.Цена = Цена;
	
	
	//Цена = ПолучитьЦенуНоменклатурыТабЧастиПоМатрице(НовСТр, ДокОбъект);
	//РассчитатьСуммуТабЧасти(НовСтр, ТекОб);
	
	НовСТр.Сумма 	= НовСТр.Цена * НовСТр.Количество;
	НовСТр.СтавкаНДС=ПолучитьСтавкуНДС(Экспозитор);
	СтавкаНДС=ПроцентНДСпоСтавке(НовСтр.СтавкаНДС);
	НовСтр.НДС	= НовСтр.Сумма*СтавкаНДС/(1+СтавкаНДС);			
	НовСтр.Всего	= НовСтр.Сумма;
	НовСтр.Сумма  = НовСтр.Всего - НовСтр.НДС;
	//------------------------------------------------------------------------
	//------------------------------------------------------------------------
	
	//нечаева 24,07,2018+++
	Если ДокОбъект.контрагент.НДС_Сверху Тогда
		
		НовСТр.СтавкаНДС=ПолучитьСтавкуНДС(Экспозитор);
		ЦенаБезНДС = Окр(НовСтр.Цена/(1+СтавкаНДС),2);	
		
		НовСТр.Сумма 	= ЦенаБезНДС * НовСТр.Количество;
		
		НовСтр.НДС	= Окр(НовСтр.Сумма*СтавкаНДС,2);			
		НовСтр.Всего	= НовСтр.Сумма+НовСтр.НДС;
		
		//----------------------------------------------
		
	КонецЕсли;
	//нечаева 24,07,18---
	
	
	
	
	ТН.Колонки.Добавить("ШтрихКод");
	//ТН.Колонки.Добавить("Цена");
	//ТН.Колонки.Добавить("СтавкаНДС");
	ТН.Колонки.Добавить("НоменклатураПредставление");
	ТН.Колонки.Добавить("Единица");	
	ТН.Колонки.Добавить("ОКЕИ");	
	ТН.Колонки.Добавить("Страна");
	ТН.Колонки.Добавить("СтранаКод");
	ТН.Колонки.Добавить("НомерГТД");
	ТН.Колонки.Добавить("КодКонтрагента");
	ТН.Колонки.Добавить("КоличествоКоробок");
	ТН.Колонки.Добавить("ШтукВКоробке");
	
	ТН.Колонки.Добавить("ШКТовара");
	
	//крохин начало 01.03.2019
	//для развернутых документов надо рассчитывать ГТД по моделям
	Если НЕ Кратко Тогда
		ТНГТД = ТН.Скопировать();
		
		Для Каждого СтрокаТНГТД ИЗ ТНГТД Цикл
			СтрокаТНГТД.Номенклатура =	СтрокаТНГТД.Номенклатура.Родитель;
		КонецЦикла;
		ТНГТД.Свернуть("Номенклатура");
		ТНГТД.Колонки.Добавить("ГТД");
		Для Каждого СтрокаТНГТД ИЗ ТНГТД Цикл
			СтрокаТНГТД.ГТД =	неопределено ; //ПолучитьГрупповойПериодическийРеквизит(СтрокаТНГТД.Номенклатура,"НомерГТД",ДокОбъект.Дата);
		КонецЦикла;
	КонецЕсли;	
	//крохин конец 01.03.2019
	
	
	Для Каждого СтрокаТН Из ТН Цикл
		Номенклатура=СтрокаТН.Номенклатура;
		Модель		=?(Кратко,СтрокаТН.Номенклатура,СтрокаТН.Номенклатура.Родитель);
		
		СтрокаТН.Цена		=?(СтрокаТН.Количество=0,0,СтрокаТН.Сумма/СтрокаТН.Количество);
		Если СтрокаТН.Сумма=0 Тогда
			СтрокаТН.СтавкаНДС=100*ПроцентНДСпоСтавке(ПолучитьРеквизитРодителя(СтрокаТН.Номенклатура,"СтавкаНДС"));
		Иначе			
			СтрокаТН.СтавкаНДС	=Окр(100*(СтрокаТН.НДС/СтрокаТН.Сумма),0,1);
		КонецЕсли;			
		
		СтрокаТН.Единица	="шт.";			
		СтрокаТН.ОКЕИ		="796";
		
		
		//Кухарь 28.11.16 начало
		//крохин начало 16.12.2016
		//пока отменяем
		//крохин начало 01.03.2019
		//для развернутых документов надо рассчитывать ГТД по моделям
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(Модель,"НомерГТД",ДокОбъект.Дата);					
		Если Кратко Тогда
			ГТД= неопределено; //  ПолучитьГрупповойПериодическийРеквизит(Модель,"НомерГТД",ДокОбъект.Дата);
		Иначе
			НайденнаяСтрокаГТД = ТНГТД.Найти(Модель, "Номенклатура");
			Если НайденнаяСтрокаГТД = Неопределено Тогда
				ГТД = Неопределено;
			Иначе
				ГТД = НайденнаяСтрокаГТД.ГТД;
			КонецЕсли;			
		КонецЕсли;
		//крохин конец 01.03.2019					
		Страна	="Россия";
		НомерГТД="--------";
		//крохин начало 23.01.2012
		//новая форма
		СтранаКод = "643";
		//крохин конец 23.01.2012
		
		Если ГТД<>Неопределено И Врег(""+ГТД.СтранаПроисхождения)<>"РОССИЯ" И НЕ ПустаяСтрока(""+ГТД.СтранаПроисхождения) Тогда
			Страна		=""+ГТД.СтранаПроисхождения;
			НомерГТД	=СокрЛП(""+ГТД.Наименование);
			СтранаКод = ГТД.СтранаПроисхождения.Код;
		КонецЕсли;
		
		Если Страна<>"Россия" И СтрДлина(НомерГТД)<25 Тогда			
			Если СтрДлина(НомерГТД)<23 Тогда
				//Сообщить("Кривой ГТД !!! Товар: """+СтрокаТН.Номенклатура+""", ГТД: """+НомерГТД+""" !");		
			Иначе
				//Сообщить("Отсутствует 4-ый сегмент ГТД !!! Товар: """+СтрокаТН.Номенклатура+""", ГТД: """+НомерГТД+""" !");
				
				НомерГТД=НомерГТД+"/3";
			КонецЕсли; 					
		КонецЕсли;
		Если Страна="Россия" Тогда
			Страна	="--------";
		КонецЕсли;
		СтрокаТН.Страна		= Страна;
		СтрокаТН.НомерГТД	= НомерГТД;
		СтрокаТН.СтранаКод = СтранаКод;
		
		
		//Лобан 120314 +++
		//Печать наименование номенклатуры для контрагента из матрицы
		//СтрокаТН.НоменклатураПредставление=СокрЛП(Модель.ТипТовара)+" "+СокрЛП(Модель.Родитель.Брэнд)+" "+СокрЛП(Модель.КодПроизводителя)+" "+Номенклатура.Наименование;
		Запрос = Новый запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	МатрицаТовары.Номенклатура,
		|	МатрицаТовары.НаименованиеКонтрагента КАК НаименованиеКонтрагента
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары
		|ГДЕ
		|	МатрицаТовары.Ссылка.Проведен
		|	И МатрицаТовары.Ссылка.Дата <= &Дата
		|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата
		|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент";
		
		//нечаева 18,07,17+++
		Попытка
			Если ДокОбъект.ПостояннаяАкция Тогда
				Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
				//крохин начало 28.07.2017
				//постоянные акции только под галку
			Иначе
				Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
				//крохин конец 28.07.2017
			КонецЕсли;
		Исключение
			
		КонецПопытки;
		//нечаева 18,07,17---
		
		Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
		Запрос.УстановитьПараметр("Дата",ДокОбъект.Дата);
		ТЗ = Запрос.Выполнить().Выгрузить();	
		Отбор = Новый Структура();
		Отбор.Вставить("Номенклатура",СтрокаТН.номенклатура.Ссылка);
		НайденныеСтроки = ТЗ.НайтиСтроки(Отбор);
		для Каждого Строчка из НайденныеСтроки Цикл 
			НаименованиеКонтрагента = Строчка.НаименованиеКонтрагента;
		КонецЦикла;
		если Не ПустаяСтрока(НаименованиеКонтрагента) тогда
			СтрокаТН.НоменклатураПредставление = НаименованиеКонтрагента 
		иначе		
			СтрокаТН.НоменклатураПредставление=СокрЛП(Модель.ТипТовара)+" "+СокрЛП(Модель.Родитель.Брэнд)+" "+СокрЛП(Модель.КодПроизводителя)+" "+Номенклатура.Наименование;		
		КонецЕсли;	
		//Лобан 120314 ---
		
		
		//Лобан +++ 260713
		//Новая форма е5
		СтрокаТН.ШКТовара=ПолучитьШтрихКодТовара(СтрокаТН.Номенклатура);
		//Лобан --- 260713
		
		Если ПечататьШтрихКоды Тогда
			Если ВидШтрихКода="Внутренний" Тогда
				СтрокаТН.ШтрихКод=?(Кратко,СокрЛП(СтрокаТН.Номенклатура.Код77),Прав(ПолучитьШтрихКодТовара(СтрокаТН.Номенклатура),6));			
			ИначеЕсли ВидШтрихКода="Контрагент" Тогда
				//Нечаева 29,10,2014 +++
				Если ДокОбъект.Контрагент.ИспользоватьНоменклатурнуюМатрицу Тогда
					СтрокаТН.ШтрихКод=ПолучитьАртикулКонтрагентаПоМатрице(ДокОбъект,СтрокаТН.Номенклатура);				
				Иначе
					СтрокаТН.ШтрихКод=ПолучитьАртикулКонтрагента(СтрокаТН.Номенклатура,ТипАртикула);				
				КонецЕсли;	
				//Нечаева 29,10,2014 ---
			ИначеЕсли ВидШтрихКода="ШтрихКод" Тогда
				СтрокаТН.ШтрихКод=ПолучитьШтрихКодТовара(СтрокаТН.Номенклатура);
			КонецЕсли;			
		КонецЕсли;				
		
		
	КонецЦикла; 
	
	
	
	Возврат ТН;
КонецФункции // ПолучитьТаблицуНакладной()


Функция ПолучитьТаблицуНакладной(ДокОбъект,Режим="Накладная",СФ=Неопределено)
	
		Кратко = ложь;    НеУчитыватьРекламации = ложь;  ТипАртикула = неопределено;
		ВидШтрихКода="Внутренний";  ВидШтрихКода="ШтрихКод";

		
	НакладнаяСсылка=ДокОбъект.ссылка;
	Контрагент=ДокОбъект.контрагент;
	
	ТН = новый ТаблицаЗначений;
	//
	////03,04,18+++ нечаева
	//для экспозиторов по Тандеру
	запрос=новый Запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как Экспозитор
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &Документ
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = ""Экспозитор"""; 
	запрос.УстановитьПараметр("Документ",НакладнаяСсылка);
	результат=запрос.Выполнить().Выбрать();
	если результат.Количество()>0 тогда
		Результат.Следующий();
		
		Возврат  ПолучитьТаблицуНакладнойТандерЭкспозиторы(ДокОбъект,Режим,СФ,Результат.Экспозитор);
	КонецЕсли;	
	//03,04,18--- нечаева
	
		
	фСводнаяСФ = ложь;
	
	Если Режим="СФ" И фСводнаяСФ Тогда		
		Если СФ=Неопределено ИЛИ СФ.Пустая() Тогда
			//Предупреждение("Невоможно определить сводную СФ для печати !");		
		Иначе
			Запрос=Новый Запрос;
			Запрос.Текст="ВЫБРАТЬ Накладная ИЗ Документ.СчетФактура.Накладные ГДЕ Ссылка=&СФ";
			Запрос.УстановитьПараметр("СФ",СФ);			
			СписокНакладных=Запрос.Выполнить().Выгрузить();
		КонецЕсли;	
	КонецЕсли;
	
	
	Запрос=новый запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	Т1.Номенклатура КАК Номенклатура,
	|	СУММА(Т1.Количество) КАК Количество,
	|	СУММА(Т1.НДС) КАК НДС,
	|	СУММА(Т1.Всего) КАК Всего,
	|	Т1.Модель КАК Модель,
	|	СУММА(Т1.НомерСтроки) КАК НомерСтроки,
	// Кухарь А.Ю. 21.07.2021 начало
	// Правильнее брать из товаров, а не из номенклатуры
	|	Т1.СтавкаНДС КАК СтавкаНДС				  
	// Кухарь А.Ю. 21.07.2021 конец
	|ПОМЕСТИТЬ ТЗТоваров
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|		РасходнаяНакладнаяТовары.Количество КАК Количество,
	|		РасходнаяНакладнаяТовары.НДС КАК НДС,
	|		РасходнаяНакладнаяТовары.Всего КАК Всего,
	|		РасходнаяНакладнаяТовары.Номенклатура.Родитель КАК Модель,
	|		РасходнаяНакладнаяТовары.НомерСтроки КАК НомерСтроки,
	// Кухарь А.Ю. 21.07.2021 начало
	//  // Правильнее брать из товаров, а не из номенклатуры
	|		РасходнаяНакладнаяТовары.СтавкаНДС КАК СтавкаНДС				  
	// Кухарь А.Ю. 21.07.2021 конец
	
	|	ИЗ
	|		Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|	ГДЕ
	|		РасходнаяНакладнаяТовары.Количество > 0
	|		И РасходнаяНакладнаяТовары.Ссылка В(&СписокНакладных)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РекламационнаяНакладнаяТовары.Номенклатура,
	|		-РекламационнаяНакладнаяТовары.Количество,
	|		-РекламационнаяНакладнаяТовары.НДС,
	|		-РекламационнаяНакладнаяТовары.Всего,
	|		РекламационнаяНакладнаяТовары.Номенклатура.Родитель,
	|		0,             
	// Кухарь А.Ю. 21.07.2021 начало
	//  // Правильнее брать из товаров, а не из номенклатуры
	|		РекламационнаяНакладнаяТовары.СтавкаНДС			  
	// Кухарь А.Ю. 21.07.2021 конец
	
	|	ИЗ
	|		Документ.РекламационнаяНакладная.Товары КАК РекламационнаяНакладнаяТовары
	|	ГДЕ
	|		РекламационнаяНакладнаяТовары.Ссылка.ДокОснование.Ссылка В(&СписокНакладных)
	|		И РекламационнаяНакладнаяТовары.Ссылка.Проведен
	|		И &УчитыватьВычерки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаЦенВНакладнойТовары.Номенклатура,
	|		0,
	|		-КорректировкаЦенВНакладнойТовары.НДС,
	|		-КорректировкаЦенВНакладнойТовары.Всего,
	|		КорректировкаЦенВНакладнойТовары.Номенклатура.Родитель,
	|		0,       
	// Кухарь А.Ю. 21.07.2021 начало
	//   Правильнее брать из товаров, а не из номенклатуры
	|		КорректировкаЦенВНакладнойТовары.СтавкаНДС			  
	// Кухарь А.Ю. 21.07.2021 конец
	
	|	ИЗ
	|		Документ.КорректировкаЦенВНакладной.Товары КАК КорректировкаЦенВНакладнойТовары
	|	ГДЕ
	|		КорректировкаЦенВНакладнойТовары.Ссылка.ДокОснование.Ссылка В(&СписокНакладных)
	|		И КорректировкаЦенВНакладнойТовары.Ссылка.Проведен
	|		И КорректировкаЦенВНакладнойТовары.Ссылка.ВидРекламации = &Вычерк
	|		И &УчитыватьВычерки) КАК Т1
	|
