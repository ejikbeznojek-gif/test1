Функция ВыгрузитьЗаказыВФайлДляОтгрузок(СтруктураИзменений, СтруктураПараметровСайта, КоличествоВыгруженныхЗаказов = 0)
	
	//возврат истина;
	Успешно = Истина;
	КоличествоВыгруженныхЗаказов = 0;
	
	МассивИзменений   = Новый Массив;
	
	Если ВыгружатьТолькоИзменения И НЕ мПринудительнаяПолнаяВыгрузка Тогда
		
		МассивИзменений = СтруктураИзменений.Заказы;
		
		// из этого массива нужно удалить все только что загруженные заказы
		Для Каждого Эл Из мМассивЗагруженныхДокументов Цикл
			
			ИндексЭлемента = МассивИзменений.Найти(Эл);
			Если ИндексЭлемента <> Неопределено Тогда
				МассивИзменений.Удалить(ИндексЭлемента);
			КонецЕсли;
			
		КонецЦикла;
		
		Если МассивИзменений.Количество() = 0 Тогда
			
			СообщитьПользователю("Изменения заказов не зарегистрированы. Выгрузка заказов не произведена.", Истина); 
			Возврат Истина;
			
		КонецЕсли;	
		
	КонецЕсли;
	
	ОбъектCMLСтрока   = "";
	ТаблицаДокументов = СформироватьCMLСРанееЗагруженнымиЗаказамиОтгрузки(ОбъектCMLСтрока, МассивИзменений);
	
	КоличествоВыгруженныхЗаказов = ТаблицаДокументов.Количество();
	
	Если КоличествоВыгруженныхЗаказов = 0 Тогда
		
		СообщитьПользователю("Не выгружен ни один заказ.", Истина);
		Возврат Успешно;
		
	КонецЕсли;
	
	ИмяФайлаОбмена 		 = "1cbitrix-" + Строка(Новый УникальныйИдентификатор) + ".xml";
	ПолноеИмяФайлаОбмена = мКаталогНаДиске + "\" + ИмяФайлаОбмена;
	//!!!!
	#если клиент    тогда
		Сообщить(ПолноеИмяФайлаОбмена);   // для тестов надо
	#конецесли
	ФайлCMLНаДиске = Новый ТекстовыйДокумент;
	ФайлCMLНаДиске.УстановитьТекст(ОбъектCMLСтрока);
	
	Попытка
		ФайлCMLНаДиске.Записать(ПолноеИмяФайлаОбмена, "UTF-8");
	Исключение
		СообщитьОбИсключительнойОшибке(Истина, "Не удалось записать CML файл на диск: " + ПолноеИмяФайлаОбмена + Символы.ПС + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	СообщитьПользователю("Выгружено заказов: " + ТаблицаДокументов.Количество(), Истина);	
	Возврат Истина;
	
КонецФункции

Функция СформироватьCMLСРанееЗагруженнымиЗаказамиОтгрузки(СтрокаCML, МассивИзменений) 
	//
	ОтобразитьСостояние("Поиск открытых заказов, загруженных с " + HTTPОбменСервер + "...");
	
	ТаблицаДокументов = тСписокЗаказовНаОтправкуОтгрузки; //ПроцедурыОбменаССайтом.ПолучитьЗаказыСОплатойИОтгрузкойПоКатегориямПоРегистру(МассивИзменений, мМассивЗагруженныхДокументов);
	
	Если ТаблицаДокументов.Количество() = 0 Тогда  
		Возврат ТаблицаДокументов;
	КонецЕсли;
		
	ОбъектCML = ПолучитьОбъектДляЗаписиXMLРНК("",ТекущаяДата());
	НачатьCML(ОбъектCML);
		
		
	Для Каждого СтрокаТД Из ТаблицаДокументов Цикл
		ОбъектCML.ЗаписатьНачалоЭлемента("Контейнер");

		ОбъектCML.ЗаписатьНачалоЭлемента("Документ");
		
		// первая часть, сам заказ, потом цикл по РНК
		ВыгрузитьЗаказВCML(ОбъектCML, СтрокаТД);  //--
			
		ОбъектCML.ЗаписатьНачалоЭлемента("ЗначенияРеквизитов");
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Номер по 1С", СтрокаТД.Номер);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата по 1С", ФорматДатыДляCML(СтрокаТД.Дата));
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "ПометкаУдаления", СтрокаТД.ПометкаУдаления);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Проведен", СтрокаТД.Проведен);
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Финальный статус", "false");
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Платежный профиль", СтрокаТД.ЗаказСсылка.контрагент.ведущий.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Код пользователя", СтрокаТД.ЗаказСсылка.контрагент.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Адрес доставки", СтрокаТД.ЗаказСсылка.пунктДоставки.код);
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата доставки", ФорматДатыДляCML(СтрокаТД.ЗаказСсылка.ДатаОтгрузки));
		
		
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа ИД", "O");
		ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа", "[O] Отгружен");
			
		ОбъектCML.ЗаписатьКонецЭлемента();
		ОбъектCML.ЗаписатьКонецЭлемента();
		
		// вторая часть цикл по РНК.
		ТаблицаДокументовРНК = новый ТаблицаЗначений;
		// здесь уже отбираем и новые, и уже отгруженныеранее  РНК по заказу.
		ТаблицаДокументовРНК = ПроцедурыОбменаССайтом.ПолучитьТаблицуДокументовРНК(МассивИзменений,ТаблицаДокументовРНК,СтрокаТД.ЗаказСсылка);
		
		Для Каждого СтрокаТД Из ТаблицаДокументовРНК Цикл
			
			ОбъектCML.ЗаписатьНачалоЭлемента("Документ");
			
			// первая часть, сам заказ, потом цикл по РНК
			ВыгрузитьЗаказВCMLРНК(ОбъектCML, СтрокаТД);  //--
			
			ОбъектCML.ЗаписатьНачалоЭлемента("ЗначенияРеквизитов");
			
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Номер по 1С", СтрокаТД.Номер);
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата по 1С", ФорматДатыДляCML(СтрокаТД.Дата));
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "ПометкаУдаления", СтрокаТД.ПометкаУдаления);
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Проведен", СтрокаТД.Проведен);
			
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Финальный статус", "false");
			
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Платежный профиль", СтрокаТД.ЗаказСсылка.контрагент.ведущий.код);
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Код пользователя", СтрокаТД.ЗаказСсылка.контрагент.код);
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Адрес доставки", СтрокаТД.ЗаказСсылка.пунктДоставки.код);
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Дата доставки", ФорматДатыДляCML(СтрокаТД.ЗаказСсылка.ДатаОтгрузки));
			
			
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа ИД", "O");
			ДобавитьНовоеЗначениеРеквизита(ОбъектCML, "Статуса заказа", "[O] Отгружен");
			
			ОбъектCML.ЗаписатьКонецЭлемента();
			ОбъектCML.ЗаписатьКонецЭлемента();
		КонецЦикла;	
				
		ОбъектCML.ЗаписатьКонецЭлемента();  // контейнер
	КонецЦикла;	
		
	СтрокаCML = ЗавершитьCML(ОбъектCML);
	
	Возврат ТаблицаДокументов;
	
КонецФункции

//это кусок для РНК-отгрузки, второй части контейнера
Процедура ВыгрузитьЗаказВCMLРНК(ОбъектCML, Док)
	
	номеррнк = Док.ЗаказСсылка.номер;
	НомерРНк = СтрЗаменить(НомерРНК,"б","");
	НомерРНк = СтрЗаменить(НомерРНК,"а","");
	
	ИдЗаказа = Док.ЗаказСсылка.докОснование.ИдЗаказа;
	Если ИдЗаказа ="" Тогда
		ИдЗаказа = номеррнк ;
	КонецЕсли;	
	

	
	ЗаписатьТекстовойУзел(ОбъектCML, "Ид"	,ИдЗаказа) ; //Строка(Док.ЗаказСсылка.УникальныйИдентификатор()));
	// тут под вопросом какой номер ???
	ЗаписатьТекстовойУзел(ОбъектCML, "Номер", номеррнк); //Док.НомерВходящегоДокументаЭлектронногоОбмена);
	ЗаписатьТекстовойУзел(ОбъектCML, "Дата" , ФорматДатыДляCML(Док.ДатаВходящегоДокументаЭлектронногоОбмена, Истина, Ложь));	
	ЗаписатьТекстовойУзел(ОбъектCML, "Номер1С", НомерРНк);  // Док.Номер
	ЗаписатьТекстовойУзел(ОбъектCML, "Дата1С" , ФорматДатыДляCML(Док.Дата, Истина, Ложь));	

	ЗаписатьТекстовойУзел(ОбъектCML, "ХозОперация", "Отпуск товара");
	
	ЗаписатьТекстовойУзел(ОбъектCML, "Роль"		  , "Продавец");
	ЗаписатьТекстовойУзел(ОбъектCML, "Валюта"	  , ФорматВалютыДляCML(Док.ВалютаДокумента));
	ЗаписатьТекстовойУзел(ОбъектCML, "Курс"	      , Док.КурсВзаиморасчетов);
	ЗаписатьТекстовойУзел(ОбъектCML, "Сумма"      , Док.СуммаДокумента); //ФорматЗначенияДляCML(Док.СуммаДокумента, ФорматСуммы));	
		
	ОбъектCML.ЗаписатьНачалоЭлемента("Контрагенты");
		
	ВыгрузитьКонтрагентаДок(ОбъектCML, Док.Контрагент,,,,Док.ЗаказСсылка.ПунктДоставки); 	
	//ВыгрузитьРеквизитыКонтрагентаВCML(ОбъектCML, Док.Контрагент);
	ОбъектCML.ЗаписатьКонецЭлемента();   //контрагенты
		
	ЗаписатьТекстовойУзел(ОбъектCML, "Время", ФорматДатыДляCML(Док.ДатаВходящегоДокументаЭлектронногоОбмена, Ложь, Истина));
	ЗаписатьТекстовойУзел(ОбъектCML, "СрокПлатежа", ФорматДатыДляCML(Док.ДатаОплаты, Истина, Ложь));
	
	ЗаписатьТекстовойУзел(ОбъектCML, "Комментарий", ФорматНаименованияДляCML(""+Док.Комментарий+" номер отгрузки - "+Док.ЗаказСсылка.Номер+" дата отгрузки - "+Док.ЗаказСсылка.ДатаОтгрузки));
	
		
	ВыгрузитьТоварыУслугиЗаказаВCML(ОбъектCML, Док);
	
	
	
КонецПроцедуры

Функция ПолучитьОбъектДляЗаписиXMLРНК(ИмяФайла, ДатаФормирования)
	
	ЗаписьXML = Новый ЗаписьXML;
	
	Если ПустаяСтрока(ИмяФайла) Тогда
		ЗаписьXML.УстановитьСтроку("UTF-8");
	Иначе
		ЗаписьXML.ОткрытьФайл(ИмяФайла, "UTF-8"); 
	КонецЕсли;   
	// пример
	//	<КоммерческаяИнформация xmlns="urn:1C.ru:commerceml_2" xmlns:xs="http://www.w3.org/2001/XMLSchema" 
	//   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" ВерсияСхемы="3.1" ДатаФормирования="2015-06-29T18:27:13" Ид="1">
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("КоммерческаяИнформация");
	ЗаписьXML.ЗаписатьАтрибут("ДатаФормирования", Формат(ДатаФормирования, "ДФ=yyyy-MM-dd'T'ЧЧ:мм:сс"));	
	ЗаписьXML.ЗаписатьАтрибут("ВерсияСхемы","3.1"); 
	ЗаписьXML.ЗаписатьАтрибут("xmlns","urn:1C.ru:commerceml_2");
	ЗаписьXML.ЗаписатьАтрибут("xmlns:xs","http://www.w3.org/2001/XMLSchema");
	ЗаписьXML.ЗаписатьАтрибут("xmlns:xsi","http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьАтрибут("Ид","1");
		
	Возврат ЗаписьXML;
	
КонецФункции



