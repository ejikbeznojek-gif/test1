					ТабДок.Область(НомерСтроки,16,НомерСтроки,16).ГоризонтальноеПоложение = ГоризонтальноеПоложение.Право;
				КонецЕсли;
				
				//ашан
				Если ИндивидуальнаяНастройкаПодКонтрагента = Справочники.НастройкиПечатиПодКонтрагента.Ашан Тогда
					ТабДок.Область(НомерСтроки,14,НомерСтроки,14).Очистить(); 
