	Если ТаблицаДокументов.Количество() = 0 Тогда  
		Возврат ТаблицаДокументов;
	КонецЕсли;
	
	ОбъектCML = ПолучитьОбъектДляЗаписиXML("",ТекущаяДата());
	НачатьCML(ОбъектCML);
	
	
	Для Каждого СтрокаТД Из ТаблицаДокументов Цикл
		
		ОбъектCML.ЗаписатьНачалоЭлемента("Документ");
		
		//ВыгрузитьЗаказВCML(ОбъектCML, СтрокаТД);
		СформироватьДопФайл(СтрокаТД.ЗаказСсылка,ОбъектCML);
		
		// "[P] Оформлен"
		// [D] Отменен
		// [N] В обработке
		// [A] Требует подтверждения
		// [P] Оформлен
		// [F] Выполнен
		
		
		ОбъектCML.ЗаписатьКонецЭлемента();  // здесь документ
		
	КонецЦикла;	
	//ОбъектCML.ЗаписатьКонецЭлемента();
	
	СтрокаCML = ЗавершитьCML(ОбъектCML);
	
	Возврат ТаблицаДокументов;
	
КонецФункции

