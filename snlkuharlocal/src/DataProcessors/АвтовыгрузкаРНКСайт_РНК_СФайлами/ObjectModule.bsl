						ТабДок.Область(НомерСтроки+1,16,НомерСтроки+1,16).Текст = "СФ "+СФ.Номер+ " от "+ФОрмат(Дата,"ДФ=dd.MM.yyyy")+" стр. "+Сч + " из "+ВсегоСтраниц+". Валюта: руб"; 
