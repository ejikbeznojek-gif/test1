			|	МатрицаТовары.Номенклатура,
			|	МатрицаТовары.НаименованиеКонтрагента КАК НаименованиеКонтрагента
			|ИЗ
			|	Документ.Матрица.Товары КАК МатрицаТовары
			|ГДЕ
			|	МатрицаТовары.Ссылка.Проведен
			|	И МатрицаТовары.Ссылка.Дата <= &Дата
			|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата
			|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент";
			
			//нечаева 18,07,17+++
			Попытка
				Если ДокОбъект.ПостояннаяАкция Тогда
					Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
					//крохин начало 28.07.2017
					//постоянные акции только под галку
				Иначе
					Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
					//крохин конец 28.07.2017
				КонецЕсли;
			Исключение
				
			КонецПопытки;
			//нечаева 18,07,17---
			
			Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
			Запрос.УстановитьПараметр("Дата",ДокОбъект.Дата);
			ТЗ = Запрос.Выполнить().Выгрузить();	
			Отбор = Новый Структура();
			Отбор.Вставить("Номенклатура",СтрокаТН.номенклатура.Ссылка);
			НайденныеСтроки = ТЗ.НайтиСтроки(Отбор);
			для Каждого Строчка из НайденныеСтроки Цикл 
				НаименованиеКонтрагента = Строчка.НаименованиеКонтрагента;
			КонецЦикла;
			//крохин начало 05.02.2019
		Иначе
			НаименованиеКонтрагента = "";
		КонецЕсли;
		//крохин конец 05.02.2019
		если Не ПустаяСтрока(НаименованиеКонтрагента) тогда
			СтрокаТН.НоменклатураПредставление = НаименованиеКонтрагента 
