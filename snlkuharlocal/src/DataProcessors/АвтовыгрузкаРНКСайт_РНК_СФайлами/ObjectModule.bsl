	Рез=Запрос.Выполнить().Выбрать();	
	
	Пока Рез.Следующий() Цикл
		Если Не ПустаяСтрока(Рез.Артикул) Тогда
			Возврат СокрЛП(Рез.Артикул);		
		КонецЕсли;		
	КонецЦикла;
	
	
	
	
	Возврат "";
	
	
