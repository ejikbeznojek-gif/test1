	//кухарь 05.03.15 конец	
	Контрагент = ДокОбъект.контрагент;
	//нечаева 26,04,18++
	Договор = ДокОбъект.Договор;
	
	Запрос=Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(20)) КАК артикул,
	|	МатрицаТовары.Ссылка,
	|	МатрицаТовары.Ссылка.Дата КАК Дата,
	|	МатрицаТовары.Ссылка.ДатаОкончания,
	|	МатрицаТовары.Номенклатура
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Проведен = ИСТИНА
	|	И (НЕ (ВЫРАЗИТЬ(МатрицаТовары.АртикулКонтрагента КАК СТРОКА(20))) = """""""")
	|	И МатрицаТовары.Ссылка.Контрагент = &ТекКонтрагент
