	ИначеЕсли ИмяЭлемента = "Документ.Товары.Товар.ЗначенияРеквизитов.ЗначениеРеквизита" Тогда
		
		ТекущаяСтрокаТоваровУслуг.Строки.Добавить();
		
	ИначеЕсли ИмяЭлемента = "Документ.Товары.Товар.Скидки.Скидка" Тогда
		
		ТекущаяСтрокаТоваровУслуг.Строки.Добавить();
		
	ИначеЕсли ИмяЭлемента = "Документ.ЗначенияРеквизитов.ЗначениеРеквизита" Тогда
		
		НовСтрокаДерева = ТекущаяСтрокаДерева.Строки.Добавить();
		
	КонецЕсли;
	
	Возврат Успешно;
	
КонецФункции                       

Функция КонтрагентПРиИзменении2(Док);
	
	Контрагент = Док.Контрагент;
	Док.дата = ТекущаяДата();
	
	Если Контрагент.НеИспользовать Тогда
		//Предупреждение("Данный контрагент запрещен к использованию в документах !");			
		Если НЕ РольДоступна("Администратор") Тогда
			Контрагент=Неопределено;		
		КонецЕсли;		
	КонецЕсли;
	
	
	Если НЕ Контрагент.Менеджер.Штатный Тогда
		//Предупреждение("Некорректный менеджер контрагента!");			
		Если НЕ РольДоступна("Администратор") Тогда
			Контрагент=Неопределено;		
		КонецЕсли;		
	КонецЕсли;
	
	
	ТипЦенКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"ТипЦен");
	Док.ТипЦен=ТипЦенКонтрагента;
	
	ТипЦенРаспродажаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"ТипЦенРаспродажа");
	Док.ТипЦенРаспродажа=ТипЦенРаспродажаКонтрагента;
	
	СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
	Док.Скидка=СкидкаКонтрагента;
	
	
	БылДоговор=Док.Договор;
	
	УстановитьДоговорСб2б(док);	
	Договор_ПриИзменении2(Док);			
	
	Если Ложь Тогда
		Если Контрагент.Менеджер.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение ИЛИ Контрагент.Менеджер.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение.Менеджер.Подразделение Тогда
			Док.Менеджер = Контрагент.Менеджер;
		ИначеЕсли Контрагент.МенеджерТЦ.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение ИЛИ Контрагент.МенеджерТЦ.Подразделение = ПараметрыСеанса.ЭтотУзел.Подразделение.Менеджер.Подразделение Тогда
			Док.Менеджер = Контрагент.МенеджерТЦ;
		Иначе
			Док.Менеджер = ПараметрыСеанса.ЭтотУзел.Подразделение.Менеджер;	
		Конецесли;
		
		
		Если Док.Менеджер <> Контрагент.Менеджер И Док.Менеджер <> Контрагент.МенеджерТЦ Тогда
		//	Сообщить("Не совпадают менеджеры контрагента и подразделения!");	
		КонецЕсли;		
	Иначе
		Док.Менеджер				= Контрагент.Менеджер;
	КонецЕсли;
	
	//Менеджер_ПриИзменении();
	
	Док.Регион					= Контрагент.Регион;
	Док.состояниенакладной = перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
	//УстановитьПунктДоставки(Док);
	Док.типСкидок = Контрагент.ТипСкидок;
	
	//ПунктДоставки_ПриИзменении();
	
	//Если ИзмененТипЦен Тогда
	//	ЗапросНаПересчетЦен();		
	//КонецЕсли; 
	//
	//Если СокрЛП(Контрагент.Код)=КодМетро И Лев(Номер,3)<>"SSP" Тогда
	//	УстановитьНомерДокумента(ЭтотОбъект);	
	//КонецЕсли;			
	
	//	Док.ЛевыйКонтрагент=Контрагент;
	
	Если Контрагент.Ведущий.ТолькоПредоплата Тогда
		Док.ОтсрочкаПлатежа = Справочники.ОтсрочкиПлатежа.НайтиПоКоду("1");
		Док.ОтсрочкаПлатежаПриИзменении();
	КонецЕсли;
	
	//УстановитьЗаголовокКнопкиЦеныВалюта(ЭтаФорма);
	
	
	
	
КонецФункции	


