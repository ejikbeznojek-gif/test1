Функция УстановитьОрганизацию(СтрокаТЧ)
	Если СтрокаТЧ.ИсточникОрганизации="Склад" Тогда
		Организация=ТекДок.Склад.Организация;
	ИначеЕсли СтрокаТЧ.ИсточникОрганизации="Документ" Тогда			
		Организация=ТекДок.Организация;					
	КонецЕсли; 
	Если Организация.Пустая() Тогда
		Организация=ПолучитьЗначениеПоУмолчанию("ОсновнаяОрганизация");	
	КонецЕсли;
КонецФункции // УстановитьОрганизацию()
 

