функция КопироватьФайл3(ИмяФайлаИсточника,ИмяФайлаПриемника,СоединениеFTP=Неопределено,НаFTP=Истина)
	Если СоединениеFTP=Неопределено тогда
	Копироватьфайл(ИмяФайлаИсточника,ИмяФайлаПриемника);
	иначе
	ИмяФайлаПриемника1=СтрЗаменить(ИмяФайлаПриемника,"\","/");
	ИмяФайлаИсточника1=СтрЗаменить(ИмяФайлаИсточника,"\","/");
	Если НаFTP тогда
	СоединениеFTP.Записать(ИмяФайлаИсточника1,ИмяФайлаПриемника1);
	иначе
	СоединениеFTP.Получить(ИмяФайлаИсточника1,ИмяФайлаПриемника1);
	Конецесли;
	Конецесли;
Конецфункции
