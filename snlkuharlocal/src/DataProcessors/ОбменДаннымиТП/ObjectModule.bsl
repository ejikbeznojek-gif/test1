				Конецесли;
				
				Если СтрокаТП.Имя="ВсеТовары" Тогда
					ВсеТовары=(СтрокаТП.Значение);
				Конецесли;
			КонецЦикла;			
		Конецесли;
	Конецесли;
	//сообщить1("Склад="+Склады[0].Склад);
