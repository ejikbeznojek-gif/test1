	#Если Клиент Тогда
		Сообщить(ТекущаяДата());
	#КонецЕсли
	Если НЕ ВыгружатьТовары тогда
		возврат;
	КонецЕсли;	
	
	ПРиКрОш=ложь;
	
	Если НЕ ЗначениеЗаполнено(ИмяФайлаВыгрузки) Тогда
		#Если Клиент Тогда
			Предупреждение("Не указано имя файла выгрузки !!!");
			
		#КонецЕсли
		
		
		Возврат;	
	КонецЕсли; 
	
