Функция СоздатьОбновитьГруппы(ПоловозрастнойПризнак,ВидНоменклатуры,родитель, кодтоваранасайте, тзактивности,КодСайта)
	
	Отказ = ложь;
	
	Запрос = новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	              |	ИерархияГруппИМ.Ссылка КАК Ссылка,
	              |	ИерархияГруппИМ.Активность КАК Активность
	              |ИЗ
	              |	Справочник.ИерархияГруппИМ КАК ИерархияГруппИМ
	              |ГДЕ
	              |	ИерархияГруппИМ.Владелец = &б2б
	              |	И ИерархияГруппИМ.Половозрастнойпризнак = &пол
	              |	И ИерархияГруппИМ.ГруппаТовара = &группа";
	Запрос.УстановитьПараметр("б2б",КодСайта);//справочники.ИнетМагазины.НайтиПоКоду("00007"));
	Запрос.УстановитьПараметр("пол",ПоловозрастнойПризнак);
	Запрос.УстановитьПараметр("группа",ВидНоменклатуры);
	Рез = Запрос.Выполнить().Выбрать();
	
	Если Рез.Следующий() Тогда
		
		ТекСтр = Рез;
		Если Текстр.Активность = ложь тогда
			  ТОб =Текстр.ссылка.получитьОБъект();
			  ТОб.активность = истина;
			  ТОБ.записать();
				
		КонецЕсли;	
		
	Иначе
		//создаем новый элемент
		НовЭл = справочники.ИерархияГруппИМ.СоздатьГруппу();
		новЭл.Владелец = КодСайта;//справочники.ИнетМагазины.НайтиПоКоду("00007");
		новЭл.Активность = истина;
		
		Если родитель<> неопределено тогда
			новЭл.Родитель = родитель;
		КонецЕсли;
		
		новэл.ГруппаТовара = ВидНоменклатуры;
		новЭл.Половозрастнойпризнак = ПоловозрастнойПризнак;
		новЭл.КодНаСайте = кодтоваранасайте;
		новэл.Наименование = ВидНоменклатуры.наименование;
		новЭл.Записать();
		
	КонецЕсли;	
	
	НовСтр = тзактивности.Добавить();
	НовСтр.ТипТовара = ВидНоменклатуры;
	НовСтр.ПоловозрастнойПризнак = ПоловозрастнойПризнак;
	НовСтр.КодНаСайте = кодтоваранасайте;
	Новстр.активность = 1;
	

	возврат НЕ Отказ;
	
конецФункции

