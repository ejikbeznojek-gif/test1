	МассивНом= Новый Массив();
	//МассивНом.Добавить(Группы);
	МассивНом=Группы;
	
	
	//+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
	//                  запись файла
	//++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
	#Если Клиент Тогда
		Состояние("Начало...");
	#КонецЕсли
	
	
