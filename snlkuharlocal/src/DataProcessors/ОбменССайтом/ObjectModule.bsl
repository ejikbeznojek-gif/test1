		Обновлять=Ложь;                                                 // имя колонки
		НайденнаяСтрока = ТаблицаПараметров.Найти("Статус заказа", "СвойствоНаименование");
		Значение=Неопределено;
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			Значение = НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		
		НеПерезаписывать=Док.РанееЗагруженныйДокументСсылка.БольшеНеПерезаписыватьДокумент;
		Если Значение<>Неопределено Тогда
			Если СтрЧислоВхождений(Значение, "[T]")>0 Или СтрЧислоВхождений(Значение, "[C]")>0 или СтрЧислоВхождений(Значение, "[K]")>0 Тогда
				Обновлять=Истина;
			КонецЕСли;
		КонецЕсли;
		
