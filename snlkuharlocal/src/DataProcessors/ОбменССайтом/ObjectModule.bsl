Функция НайтиАртикулПоМатрице(Контрагент, номенклатура) Экспорт
	
	
	Артикул = "";	
	// ищем по ШК
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	МатрицаТовары.Номенклатура КАК Номенклатура,
	|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
	|	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
	|	МатрицаТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	МатрицаТовары.Цена КАК Цена,
	|	МатрицаТовары.КодПроизводителяКонтрагента КАК КодПроизв
	|ИЗ
	|	Документ.Матрица.Товары КАК МатрицаТовары
	|ГДЕ
	|	МатрицаТовары.Ссылка.Контрагент = &Контрагент
	|	И МатрицаТовары.Ссылка.ДатаОкончания >= &ТекДата
	|	И МатрицаТовары.Ссылка.Проведен = ИСТИНА
	|	И МатрицаТовары.Номенклатура = &ТекНом";
	
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	Запрос.УстановитьПараметр("ТекНом",Номенклатура);
	Запрос.УстановитьПараметр("ТекДата",ТекущаяДата());
	
	Рез=Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда
		//нечаева 12,08,21
		Если контрагент.код = "SSR-9059"  или контрагент.код = "SSR-8987" Тогда
			//нечаева 12,08,21---	
			возврат Рез.КодПроизв;
			
		Иначе	
			Возврат Рез.АртикулКонтрагента;
		КонецЕсли;
		
	КонецЕсли;
	
	
	
	возврат Артикул;
	//----------------------------------------------------------------------------
КонецФункции // НайтиПОШК()
