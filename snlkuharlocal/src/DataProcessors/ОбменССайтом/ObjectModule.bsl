Функция ПолучитьЦену(Ном,ТипЦЕн)
	
	Цена=0;
	
	Запрос=новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Модель,
	|	ЦеныНоменклатурыСрезПоследних.ТипЦен КАК ТипЦен,
	|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ДатаПрайса,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ПОМЕСТИТЬ Цены
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			{(&Дата2)},
	|			Прайс.Проведен
	|				И Прайс.Дата2 >= &Дата2 {(ТипЦен).*}) КАК ЦеныНоменклатурыСрезПоследних
	|ГДЕ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура В Иерархии (&ТекНом)
	|	И ЦеныНоменклатурыСрезПоследних.ТипЦен = &Тектипцен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Модель,
	|	ТипЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Цены.ДатаПрайса) КАК ДатаПрайса,
	|	Цены.Модель,
	|	Цены.ТипЦен
	|ПОМЕСТИТЬ Прайсы
	|ИЗ
	|	Цены КАК Цены
	|
	|СГРУППИРОВАТЬ ПО
	|	Цены.ТипЦен,
	|	Цены.Модель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Прайсы.Модель,
	|	Прайсы.ТипЦен,
	|	Цены.Цена
	|ИЗ
	|	Прайсы КАК Прайсы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены
	|		ПО (Цены.Модель = Прайсы.Модель)
	|			И (Цены.ТипЦен = Прайсы.ТипЦен)
	|			И (Цены.ДатаПрайса = Прайсы.ДатаПрайса)  ";
	
	Запрос.УстановитьПараметр("ТекНом",Ном);
	Запрос.УстановитьПараметр("Тектипцен",ТипЦен);
	Запрос.УстановитьПараметр("Дата2",ТекущаяДата());
	
	Рез=Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда
		Цена=Рез.Цена;
	КонецЕсли;	
	
	Возврат Цена;
	
КонецФункции		
//выгружать или нет - на сайт коллант
Функция ПроверитьВыгрузку(ТекНоменклатура)
	
	Выгружать=Ложь;
	
	
	Если (ТекНоменклатура.ВыгружатьВИнтернетМагазин = Перечисления.ВыгружатьНаСайт.Да) тогда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;	
	
	Выгружать1 = (ПолучитьРеквизитРодителя(ТекНоменклатура,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать1=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;	
	
	Выгружать2 = (ПолучитьРеквизитРодителя(ТекНоменклатура.Родитель,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать2=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;
	
	Выгружать3 = (ПолучитьРеквизитРодителя(ТекНоменклатура.Родитель.Родитель,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать3=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Выгружать;
	
КонецФункции

Функция ПолучитьСвойстваМодели(Модель)
	Запрос=Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ	
	|	ВЫБОР
	|		КОГДА Объект=&Брэнд ТОГДА 1
	|		КОГДА Объект=&Модель ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК Уровень,
	|	Свойство,
	|	Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	Объект = &Модель ИЛИ Объект = &Брэнд
	|УПОРЯДОЧИТЬ ПО Уровень,Объект";	
	
	Свойства=Новый Структура;
	
	Запрос.УстановитьПараметр("Модель",Модель);
	Запрос.УстановитьПараметр("Брэнд",Модель.Родитель);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Попытка
			КодСвойства=СтрЗаменить(Выборка.Свойство,"""","");	
			КодСвойства=СтрЗаменить(Выборка.Свойство," ","");
			
			Свойства.Вставить(КодСвойства,Выборка.Значение);		
		Исключение
			Сообщить("Ошибочное свойство: "+Выборка.Свойство);
		КонецПопытки;		
	КонецЦикла;	
	
	Возврат Свойства;
КонецФункции //ПолучитьСвойстваНоменклатуры(Номенклатура) 

