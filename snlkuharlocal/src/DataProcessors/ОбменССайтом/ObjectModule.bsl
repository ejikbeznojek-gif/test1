	Для каждого ТекСтрока Из Док.Товары Цикл
		
		Если ТекСтрока.Номенклатура.Код="SNL-096562" Тогда
			ТекСтрока.Цена=500;
			ТекСтрока.ЦенаБезСкидки=500;
			ТекСтрока.Скидка=-1;
			РассчитатьСуммуТабЧасти(ТекСтрока, Док);	
		КонецЕсли;
		
		Если ТекСтрока.Номенклатура.Код="SNL-095774" Тогда
			ТекСтрока.Цена=1000;
