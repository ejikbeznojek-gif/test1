Функция ПроверитьАктивность(Ном)
	
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ПометкаУдаления = ЛОЖЬ
	|	И Номенклатура.ЭтоГруппа = ЛОЖЬ
	|	И Номенклатура.ЖизненныйЦиклНоменклатуры = &активна
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&Текном)";
	
	запрос.УстановитьПараметр("ТекНом",ном);
	запрос.УстановитьПараметр("активна",перечисления.ЖизненныйЦиклНоменклатуры.Активна);
	
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Количество()>0 Тогда
		
		возврат "true";
		
	иначе
		
		возврат "false";
		
	КонецЕсли;	
	
	возврат "true";
	
	
конецФункции

