
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Параметры.КлючНазначенияИспользования = "" Тогда
		ЭтаФорма.Закрыть();
		ПоказатьПредупреждение(,"Это служебная форма, открывается только по кнопочке!!!");
		Возврат;
	КонецЕсли;
	
	УправлениеВидимостью();

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ДокОбъект") Тогда
		
		Объект.ДокОбъект = Параметры.ДокОбъект;
		
		Если Объект.ДокОбъект <> Неопределено Тогда
			
			Параметры.КлючНазначенияИспользования = "ДокОбъектЗаполнен";
		
			тзВыборка = Обработки.СкорректироватьКомплектующие.РассчитатьКомплектующие(Объект.ДокОбъект);
			
			Если ТипЗнч(тзВыборка) = Тип("ТаблицаЗначений") Тогда
		
				Объект.Комплектующие.Загрузить(тзВыборка);
				
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостью()
	
	Элементы.ЗагрузитьФиктивныеДокументы.Доступность = ((Объект.Расхождения.Количество() = 0 ИЛИ ХватаетКомплектующих())
		И Объект.Комплектующие.Количество() > 0
		И Объект.КомплектующиеКП.Количество() > 0);
		
	Элементы.КнопкаОбновитьТовары.Доступность = ((Объект.Расхождения.Количество() = 0 ИЛИ ХватаетКомплектующих())
		И Объект.Комплектующие.Количество() > 0
		И Объект.КомплектующиеКП.Количество() > 0);
		
	Элементы.КнопкаПодогнатьКоличество.Доступность = ЗначениеЗаполнено(Объект.КП_фиктивный);
	
	Элементы.КнопкаВыровнятьПоКП.Доступность = ЗначениеЗаполнено(Объект.ЗАП_фиктивный) И Объект.КомплектующиеКП.Количество() > 0;
	
КонецПроцедуры

&НаКлиенте
Процедура РасхожденияПослеУдаления(Элемент)
	УправлениеВидимостью();
КонецПроцедуры

