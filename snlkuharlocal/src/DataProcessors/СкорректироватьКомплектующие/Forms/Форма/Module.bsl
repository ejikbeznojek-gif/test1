#Область ОтветыНаВопросы

&НаКлиенте
Процедура ОтветНаВопросОбновитьТовары(ОтветНаВопрос, ДополнительныеПараметры) Экспорт 

	Если ОтветНаВопрос = КодВозвратаДиалога.ОК Тогда
		
		Если Объект.ДокОбъект <> Неопределено Тогда
		
			тзВыборка = ВыгрузитьТЧ_НаСервере("Комплектующие");
			ЗагрузитьТЧ_ПоСсылке_НаСервере(Объект.ДокОбъект, "Товары", тзВыборка);
			Оповестить("ОбновилиКоличество");
		
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтветНаВопросЗагрузитьФиктивныеДокументы(ОтветНаВопрос, ДополнительныеПараметры) Экспорт
	
	Если ОтветНаВопрос = КодВозвратаДиалога.ОК Тогда
		
		Если ЗначениеЗаполнено(Объект.КП_фиктивный) Тогда
			тзТовары = ВыгрузитьТЧ_НаСервере("КомплектующиеКП");
			Если тзТовары.Количество() > 0 Тогда
				ЗагрузитьТЧ_ПоСсылке_НаСервере(Объект.КП_фиктивный, "Товары", тзТовары);
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ЗАП_фиктивный) Тогда
			тзТовары = ВыгрузитьТЧ_НаСервере("КомплектующиеЗАП");
			Если тзТовары.Количество() > 0 Тогда
				ЗагрузитьТЧ_ПоСсылке_НаСервере(Объект.ЗАП_фиктивный, "Товары", тзТовары);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
