&НаКлиенте
Процедура ПеречитатьКП(Команда)
	
	Если ЗначениеЗаполнено(Объект.КП_фиктивный) Тогда
		
		тзКП = Обработки.СкорректироватьКомплектующие.РассчитатьКомплектующие(Объект.КП_фиктивный);
		ЗагрузитьТЧ_НаСервере(тзКП, "КомплектующиеКП");
		ЗаполнитьРасхождения();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеречитатьЗАП(Команда)
	
	Если ЗначениеЗаполнено(Объект.ЗАП_фиктивный) Тогда
		
		тзКП = Обработки.СкорректироватьКомплектующие.РассчитатьКомплектующие(Объект.ЗАП_фиктивный);
		ЗагрузитьТЧ_НаСервере(тзКП, "КомплектующиеЗАП");
		
	КонецЕсли;
	
КонецПроцедуры

