#Область ОбработкаВыбора

&НаКлиенте
Процедура КП_фиктивныйОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		тзКП = Обработки.СкорректироватьКомплектующие.РассчитатьКомплектующие(ВыбранноеЗначение);
		ЗагрузитьТЧ_НаСервере(тзКП, "КомплектующиеКП");
		ЗаполнитьРасхождения();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомплектующиеКПКомплектующееОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.КомплектующиеКП.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) И ТекущиеДанные <> Неопределено Тогда
		ТекущиеДанные.Номенклатура = Обработки.СкорректироватьКомплектующие.ПодобратьНоменклатуруКП_ПоНоменклатуреЗАП(ВыбранноеЗначение, ВыгрузитьТЧ_НаСервере());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗАП_фиктивныйОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		тзКП = Обработки.СкорректироватьКомплектующие.РассчитатьКомплектующие(ВыбранноеЗначение);
		ЗагрузитьТЧ_НаСервере(тзКП, "КомплектующиеЗАП");
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
