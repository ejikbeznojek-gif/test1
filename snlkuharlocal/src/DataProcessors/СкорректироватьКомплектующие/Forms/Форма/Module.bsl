&НаСервере
Процедура ЗагрузитьТЧ_НаСервере(тзВыборка, ИмяТабличнойЧасти = "КомплектующиеКП")
	Объект[ИмяТабличнойЧасти].Загрузить(тзВыборка);	
КонецПроцедуры

&НаСервере
Функция ВыгрузитьТЧ_НаСервере(ИмяТабличнойЧасти = "Комплектующие")
	Возврат Объект[ИмяТабличнойЧасти].Выгрузить();
КонецФункции

&НаСервере
Процедура ЗаполнитьРасхождения()
	
	тзКомплектующие = Объект.Комплектующие.Выгрузить(, "Комплектующее, Количество");
	тзКомплектующиеКП = Объект.КомплектующиеКП.Выгрузить(, "Комплектующее, Количество");
	
	Для Каждого Стр ИЗ тзКомплектующие Цикл
		Стр.Количество = - Стр.Количество;
	КонецЦикла;
		
	тзРасхождения = ЗаполнениеДокументов.РазницаТаблицЗначений(тзКомплектующие, тзКомплектующиеКП,
		"Комплектующее,Количество");
	
	тзРасхождения.Свернуть("Комплектующее", "Количество");
	
	//МассивСтрок = тзРасхождения.НайтиСтроки(Новый Структура("Количество", 0));
	
	//Для Каждого ЭлементМассива Из МассивСтрок Цикл
	//	тзРасхождения.Удалить(ЭлементМассива);
	//КонецЦикла;
	
	тзРасхождения.Колонки.Добавить("Хватает", Новый ОписаниеТипов("Булево"));
	тзРасхождения.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	Для Каждого Стр ИЗ тзРасхождения Цикл
		Стр.Номенклатура = Стр.Комплектующее; 
		Если Стр.Количество >= 0 Тогда
			Стр.Хватает = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Объект.Расхождения.Загрузить(тзРасхождения);
	
	УправлениеВидимостью();

КонецПроцедуры

&НаСервере
Функция ХватаетКомплектующих()
	
	Для Каждого Стр ИЗ Объект.Расхождения Цикл
		Если Стр.Хватает = Ложь Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ЭтоСпайка(Номенклатура)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Комплектующие.Номенклатура КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Ссылка = &Номенклатура";
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если НЕ Результат.Пустой() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ПодогнатьКоличествоКП_Сервер()
	
	// Если в Фиктивном КП не хватает Количества - убираем из основного ЗАПа Количество, чтобы хватало на Спайку
	
	Для Каждого Стр ИЗ Объект.Расхождения Цикл
		
		Если Стр.Количество < 0 Тогда
			
			Если ЭтоСпайка(Стр.Номенклатура) Тогда
				НайденныеСтрокиЗАП = Объект.Расхождения.НайтиСтроки(Новый Структура("Комплектующее", Стр.Комплектующее));
				КоличествоКВычитанию = Модуль(Стр.Количество);
				
			
			
			Для Каждого НСтр ИЗ НайденныеСтрокиЗАП Цикл
				
				Если КоличествоКВычитанию > НСтр.Количество Тогда
					КоличествоКВычитанию = КоличествоКВычитанию - НСтр.Количество;
					НСтр.Количество = 0;
				ИначеЕсли КоличествоКВычитанию < НСтр.Количество Тогда
					НСтр.Количество = Нстр.Количество - КоличествоКВычитанию;
					Прервать;
				КонецЕсли;
				
				
			КонецЦикла;
			
				
			Иначе
				НайденныеСтрокиЗАП = Объект.Комплектующие.НайтиСтроки(Новый Структура("Номенклатура,Комплектующее", Стр.Номенклатура, Стр.Комплектующее));
				Для Каждого НСтр ИЗ НайденныеСтрокиЗАП Цикл
					НСтр.Количество = ?(НСтр.Количество - Модуль(Стр.Количество) < 0, 0, НСтр.Количество - Модуль(Стр.Количество));	
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьРасхождения();
	
	// теперь в Расхождениях должны остаться одни "+" (если в КП количество больше, чем в ЗАП)
	// Теперь отнимаем Количество, которое осталось в ЗАП из Количества в Фиктивном КП
	// Какие-то строки будут 0, какие то больше 0
	
	Для Каждого Стр ИЗ Объект.Расхождения Цикл
		
		НайденныеСтрокиКП = Объект.КомплектующиеКП.НайтиСтроки(Новый Структура("Номенклатура,Комплектующее", Стр.Номенклатура, Стр.Комплектующее));
		Для Каждого НСтр ИЗ НайденныеСтрокиКП Цикл
			НСтр.Количество = Модуль(Стр.Количество);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьТЧ_ПоСсылке_НаСервере(ДокСсылка, ИмяТабличнойЧасти = "Товары", тзВыборка)
	
	ДокОбъект = Неопределено;
	Если ЗаполнениеДокументов.ЭтоСсылка(ТипЗнч(ДокСсылка)) Тогда
		ДокОбъект = ДокСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	Если ДокОбъект <> Неопределено Тогда
		
		Для Каждого Стр ИЗ тзВыборка Цикл
			
			НайденныеСтроки = ДокОбъект[ИмяТабличнойЧасти].НайтиСтроки(Новый Структура("Номенклатура", Стр.Комплектующее));
			
			Для Каждого НСтр ИЗ НайденныеСтроки Цикл
				
				НСтр.Количество = Стр.Количество;
				
				Если ЕстьРеквизитТабЧастиДокумента("Заявка", ДокОбъект.Метаданные(), ИмяТабличнойЧасти) Тогда
					НСтр.Заявка = НСтр.Количество; 
				КонецЕсли;
				
				Если ЕстьРеквизитТабЧастиДокумента("ПодтвержденнаяЗаявка", ДокОбъект.Метаданные(), ИмяТабличнойЧасти) Тогда
					НСтр.ПодтвержденнаяЗаявка = НСтр.Количество; 
				КонецЕсли;
				
				РассчитатьСуммуТабЧасти(НСтр, ДокОбъект);
				
			КонецЦикла;
			
		КонецЦикла;
		
		Попытка
			ДокОбъект.Записать();
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = Строка(ДокОбъект) + " обновлен.";
			Сообщение.Сообщить();
		Исключение
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = Строка(ДокОбъект) + " Не могу обновить ТЧ " + ИмяТабличнойЧасти;
			Сообщение.Сообщить();
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

