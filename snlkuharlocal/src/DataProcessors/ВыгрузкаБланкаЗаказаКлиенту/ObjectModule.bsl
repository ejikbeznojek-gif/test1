	//КонецЕсли; 
	//
	//Если НЕ ТипЦен_SALE.Пустая() Тогда
	//	
	//	ЦенаРаспродажа=ПолучитьЦенуНоменклатуры(Номенклатура,,ТипЦен_SALE,ТипЦен_SALE.Валюта,ПолучитьКурсВалюты(ТипЦен_SALE.Валюта,Дата2).Курс,Дата2);
