Функция СкидкаКонтрагента1(Номенклатура,ТипСкидок_Контрагент)  Экспорт
	
	Запрос=Новый Запрос;
	//Запрос.Текст="
	//|ВЫБРАТЬ ПЕРВЫЕ 1		
	//|	Скидка,ТипЦен,
	//|	ВЫБОР 
	//|		КОГДА Номенклатура	=&Номенклатура0 ТОГДА 0
	//|		КОГДА Номенклатура	=&Номенклатура1 ТОГДА 1
	//|		КОГДА Номенклатура	=&Номенклатура2 ТОГДА 2
	//|		КОГДА Номенклатура	=&Номенклатура3 ТОГДА 3
	//|		КОГДА Номенклатура	=&Номенклатура4 ТОГДА 4
	//// Кухарь А.Ю. 13.10.2022 начало
	////+1 уровень иерархии
	//|		КОГДА Номенклатура	=&Номенклатура5 ТОГДА 5 
	//// Кухарь А.Ю. 13.10.2022 конец
	//
	//|	ИНАЧЕ 100 
	//|	КОНЕЦ КАК Уровень
	//|ИЗ
	//|	Справочник.Контрагенты.Скидки
	//|ГДЕ
	//|	Ссылка = &Контрагент		
	//|	И Номенклатура В (&СписокПозиций)
	//|УПОРЯДОЧИТЬ ПО Уровень";
	
	// Шворобей ВЮ 05.03.2024 ++
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СкидкиКонтрагентов.Скидка КАК Скидка,
	|	СкидкиКонтрагентов.ТипЦен КАК ТипЦен,
	|	ВЫБОР
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура0
	|			ТОГДА 0
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура1
	|			ТОГДА 1
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура2
	|			ТОГДА 2
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура3
	|			ТОГДА 3
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура4
	|			ТОГДА 4
	|		КОГДА СкидкиКонтрагентов.Номенклатура = &Номенклатура5
	|			ТОГДА 5
	|		ИНАЧЕ 100
	|	КОНЕЦ КАК Уровень
	|ИЗ
	|	РегистрСведений.СкидкиКонтрагентов КАК СкидкиКонтрагентов
	|ГДЕ
	|	СкидкиКонтрагентов.Номенклатура В(&СписокПозиций)
	|	И СкидкиКонтрагентов.Контрагент = &Контрагент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Уровень";
	// Шворобей ВЮ 05.03.2024 ++
	
	Запрос.УстановитьПараметр("Контрагент", ?(ЗначениеЗаполнено(ТипСкидок_Контрагент.Ведущий), ТипСкидок_Контрагент.Ведущий, ТипСкидок_Контрагент));		
	
	СписокПозиций=Новый Массив;
	
	Уровень=0;		
	ТекРодитель=Номенклатура;
	// Кухарь А.Ю. 13.10.2022 начало
	//+1 уровень иерархии
	//Пока Уровень<5 Цикл
	Пока Уровень<6 Цикл
		// Кухарь А.Ю. 13.10.2022 конец
		
		СписокПозиций.Добавить(ТекРодитель);		
		Запрос.УстановитьПараметр("Номенклатура"+Уровень,ТекРодитель);
		
		Уровень=Уровень+1;
		ТекРодитель=ТекРодитель.Родитель;			
	КонецЦикла;
	
	Запрос.УстановитьПараметр("СписокПозиций",	СписокПозиций);
	
	Результат=Запрос.Выполнить();
	
	Выборка=Результат.Выбрать();
	Пока Выборка.Следующий() Цикл			
		ТипЦенСкидок=Выборка.ТипЦен;
		Возврат  Выборка;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции 

Функция ЦенаКонтрагента1(Номенклатура,ТипЦен,контрагент = неопределено)  Экспорт
	
	Если Контрагент = неопределено Тогда
		контрагент = справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	
	ТекТипЦен			= ТипЦен;
	Распродажа			= Ложь;
	Скидка=0;
	//--------------------------------------------------------------
	//                   с учетом скидок 
	//--------------------------------------------------------------
	Если НЕ Контрагент.Пустая() Тогда
		
		СкидкаВЫб=СкидкаКонтрагента1(Номенклатура,Контрагент);
		Если  СкидкаВыб=Неопределено Тогда
			СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
