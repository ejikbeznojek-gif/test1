Функция ОтформатироватьПостроитель(Построитель)     Экспорт
	Шаблон=ПолучитьМакет("Отчет");	
	
	Макет=Построитель.Макет;
	Для СчС=1 По Макет.ВысотаТаблицы Цикл	
		Для СчК=1 По Макет.ШиринаТаблицы Цикл	
			ТекОбласть=Макет.Область("R"+СчС+"C"+СчК);
			Если ТекОбласть.Заполнение=ТипЗаполненияОбластиТабличногоДокумента.Параметр Тогда
				ОбластьШаблона=Шаблон.Области.Найти(ТекОбласть.Параметр);
				Если ОбластьШаблона<>Неопределено Тогда
					ТекОбласть.Формат				=ОбластьШаблона.Формат;				
					ТекОбласть.ШиринаКолонки		=ОбластьШаблона.ШиринаКолонки;
					ТекОбласть.ВыделятьОтрицательные=ОбластьШаблона.ВыделятьОтрицательные;
					ТекОбласть.АвтоОтступ=ОбластьШаблона.АвтоОтступ;
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла;
	КонецЦикла;
	
	Построитель.Макет=Макет;
	
	Если Построитель.Макет.Области.Найти("ШапкаТаблицы")<>Неопределено Тогда
		Построитель.Макет.Области.ШапкаТаблицы.РазмещениеТекста=ТипРазмещенияТекстаТабличногоДокумента.Переносить;	
	Иначе
		Для Каждого Колонка Из ПостроительОтчета.ИзмеренияКолонки Цикл
			Для Сч=1 По 3 Цикл
				ТекИмяОбласти=""+Колонка.Имя+"Уровень"+Сч;
				ТекОбласть=Построитель.Макет.Области.Найти(ТекИмяОбласти);
				Если ТекОбласть<>Неопределено Тогда
					ТекОбласть.РазмещениеТекста=ТипРазмещенияТекстаТабличногоДокумента.Переносить;			
				КонецЕсли;
			КонецЦикла;			
		КонецЦикла;  
	КонецЕсли;	
КонецФункции // ОтформатироватьПостроитель()

Процедура НастроитьПостроитель() экспорт 
	
	
	ПостроительОтчета.Текст="
	|ВЫБРАТЬ
	|	СпрНоменклатура.Родитель.Родитель.Родитель					КАК Брэнд,
	|	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.Родитель.Родитель.Родитель)	КАК БрэндПредставление,
	|	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.Родитель.Родитель)			КАК КоллекцияПредставление,
	|	СпрНоменклатура.Родитель КАК Модель,
	|	СпрНоменклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке,
	|	СпрНоменклатура.Родитель.ШтукВКоробочке КАК ШтукВБлочке,	
	|	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.Родитель) КАК МодельПредставление,	
	|	СпрНоменклатура.Родитель.КодПроизводителя КАК КодПроизводителя,	
	|	СпрНоменклатура.Цвет КАК Цвет,		
	|	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.Цвет) КАК ЦветПредставление,
	|	СпрНоменклатура.Родитель.Коллекция КАК Коллекция,
	
	|	СпрНоменклатура.Размер.Родитель КАК РазмерныйРяд,
	//крохин начало 17.03.2011
	//поменял упорядочивание размеров со ссылок на коды
	//|	СпрНоменклатура.Размер КАК Размер,
	|	СпрНоменклатура.Размер.Код КАК Размер,
	//крохин конец
	|	СпрСклады.Ссылка КАК Склад,
	|	(&Остаток*ЕстьNULL(Остатки.КоличествоОстаток,0)+&Резерв*ЕстьNULL(Резервы.КоличествоОстаток,0)) КАК КолКон,
	|	ЕстьNULL(Остатки.КоличествоОстаток,0)	КАК ОстКон	
	|ИЗ
	|	Справочник.Номенклатура КАК СпрНоменклатура 
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.Склады КАК СпрСклады
	|ПО 1=1
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2,{Номенклатура.*,Склад.*}) КАК Остатки				
	|ПО СпрНоменклатура.Ссылка=Остатки.Номенклатура И СпрСклады.Ссылка=Остатки.Склад
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	РегистрНакопления.РезервыТМЦ.Остатки(&Дата2,{Номенклатура.*,Склад.*}) КАК Резервы
	|ПО СпрНоменклатура.Ссылка=Резервы.Номенклатура И СпрСклады.Ссылка=Резервы.Склад	
	|ГДЕ НЕ СпрНоменклатура.ЭтоГруппа	
	|	И (&ВключатьНули ИЛИ (&Остаток<>0 И Остатки.КоличествоОстаток ЕСТЬ НЕ Null) ИЛИ (&Резерв<>0 И Резервы.КоличествоОстаток ЕСТЬ НЕ Null))
	|{
	|	ГДЕ 
	|	СпрНоменклатура.Ссылка.*			КАК Номенклатура,
	|	СпрНоменклатура.Родитель.Коллекция	КАК Коллекция,
	|	СпрСклады.Ссылка.*					КАК Склад
	|}
	|ИТОГИ 
	|	СУММА(КолКон)
	|ПО ОБЩИЕ	
	|{ИТОГИ ПО 	
	|	РазмерныйРяд,
	|	Брэнд,Модель,Цвет,Размер,Склад	
	|}	
	|АВТОУПОРЯДОЧИВАНИЕ"	
	;
	
	ПостроительОтчета.Параметры.Вставить("Длина",3);
	ПостроительОтчета.ЗаполнитьНастройки();
	ПостроительОтчета.ЗаполнениеРасшифровки = ВидЗаполненияРасшифровкиПостроителяОтчета.Расшифровка;
	ПостроительОтчета.ВыводитьДетальныеЗаписи=Ложь;
	
	ПостроительОтчета.ДобавлениеПредставлений=ТипДобавленияПредставлений.Добавлять;		
	
	ПостроительОтчета.ДоступныеПоля["КолКон"].Представление			="Кол. кон.";
	
	//ПостроительРасшифровки.Текст=ПостроительОтчета.Текст;	
КонецПроцедуры

Процедура НастроитьПостроительПоУмолчанию() Экспорт
	ПостроительОтчета.ВыбранныеПоля.Очистить();		
	
	ПостроительОтчета.ВыбранныеПоля.Добавить("КолКон");
	ПостроительОтчета.ВыбранныеПоля.Добавить("ШтукВКоробке");
	ПостроительОтчета.ВыбранныеПоля.Добавить("ШтукВБлочке");
	ПостроительОтчета.ВыбранныеПоля.Добавить("КодПроизводителя");
	ПостроительОтчета.ВыбранныеПоля.Добавить("Коллекция");
	ПостроительОтчета.ВыбранныеПоля.Добавить("КоллекцияПредставление");
	
	ПостроительОтчета.ИзмеренияСтроки.Очистить();
	
	ПостроительОтчета.ИзмеренияСтроки.Добавить("РазмерныйРяд",,ТипИзмеренияПостроителяОтчета.Элементы);	
	ПостроительОтчета.ИзмеренияСтроки.Добавить("Брэнд",,ТипИзмеренияПостроителяОтчета.Элементы);	
	ПостроительОтчета.ИзмеренияСтроки.Добавить("Модель",,ТипИзмеренияПостроителяОтчета.Элементы);	
	ПостроительОтчета.ИзмеренияСтроки.Добавить("Цвет",,ТипИзмеренияПостроителяОтчета.Элементы);	
	
	ПостроительОтчета.ИзмеренияКолонки.Очистить();
	ПостроительОтчета.ИзмеренияКолонки.Добавить("Склад",,ТипИзмеренияПостроителяОтчета.Элементы);
	ПостроительОтчета.ИзмеренияКолонки.Добавить("Размер",,ТипИзмеренияПостроителяОтчета.Элементы);
	
	
	ОтборКоличество=ПостроительОтчета.Отбор.Количество();
	Для Н = 1 По ОтборКоличество Цикл
		ПостроительОтчета.Отбор.Удалить(ОтборКоличество - Н);
	КонецЦикла;
	
	ПостроительОтчета.Отбор.Добавить("Склад");	
	ПостроительОтчета.Отбор.Добавить("Номенклатура");	
	ПостроительОтчета.Отбор["Номенклатура"].ВидСравнения=ВидСравнения.ВИерархии;
КонецПроцедуры

