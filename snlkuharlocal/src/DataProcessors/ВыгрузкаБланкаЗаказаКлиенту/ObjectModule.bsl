	Если Цена=Неопределено Тогда
		
		Цена=0;
		
	КонецЕсли; 
	
	
	Если Скидка+0>0 Тогда
		
		Цена=Формат(Цена-(Цена*Скидка/100),"ЧДЦ=2");
		
