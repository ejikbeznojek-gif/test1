Процедура ПрописатьКодыТоваров(ТД,Ексель,Книга,Лист) Экспорт
	Для Кол=1 по ТД.ШиринаТаблицы	Цикл
		Для Стр=1 по ТД.ВысотаТаблицы Цикл
			КодТовара=ТД.Область(Стр,Кол,Стр,Кол).Расшифровка;		    
			Если НЕ ПустаяСтрока(КодТовара) Тогда
				#Если Клиент Тогда
				Состояние("Установка кодов: "+КодТовара);
				#КонецЕсли
				Попытка               
					КодПозиции="R"+СтрЗаменить(КодТовара,"-","_____");
					Лист.Cells(Стр,Кол).Name=КодПозиции;
					Книга.Names(КодПозиции).Visible=0;
					Ексель.Evaluate(Книга.Names(КодПозиции).Value).Locked=0;					
				Исключение
					Сообщить("Кривой код: "+КодТовара+" "+ОписаниеОшибки());
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;  	    
	КонецЦикла;
КонецПроцедуры //ПрописатьКодыТоваров

