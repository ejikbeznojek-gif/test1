Функция ПолучитьКодТовара(Модель,Размер,Цвет) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка.Код КАК Код80,
	|	Ссылка.Код77 КАК Код77
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Родитель = &Модель
	|	И Размер = &Размер
	|	И Цвет = &Цвет";
	
	Запрос.УстановитьПараметр("Модель",Модель);
	//крохин начало18.03.2011
	//размер- код размера
	//	Запрос.УстановитьПараметр("Размер",Размер);
	Запрос.УстановитьПараметр("Размер",Справочники.Размеры.НайтиПоКоду(Размер));
	//крохин конец
	Запрос.УстановитьПараметр("Цвет",Цвет);	
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		//Возврат Выборка[фВидКодов];	
		//Возврат Выборка.Код77;
		//Мессерле
		Возврат Выборка.Код80;
		//Мессерле
		
	КонецЦикла; 
	
	Возврат "";
КонецФункции // НайтиТовар()

