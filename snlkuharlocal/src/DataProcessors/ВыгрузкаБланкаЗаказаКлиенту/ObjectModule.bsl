				Скидка=СкидкаКонтрагента;
				ТекТипЦен=ПолучитьРеквизитРодителя(Контрагент,"ТипЦен");
				
			КонецЕсли; 
		Иначе
			Скидка=СкидкаВыб.Скидка;
			ТекТипЦен=СкидкаВыб.ТипЦен;
		КонецЕсли; 
		
	КонецЕсли;
	
	
