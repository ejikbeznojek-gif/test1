Процедура ПрописатьФормулы(ТД,Лист,СтрокиТИ,ЧислоРазмеров) Экспорт
	Перем ФормулаВ,ФормулаГ;
	
	ШиринаСекцииНачало=Макет.ПолучитьОбласть("Заголовок|Начало").ШиринаТаблицы;
	ПозицияГорИтога=ШиринаСекцииНачало+ЧислоРазмеров+1;
	
	ФормулаГ="=SUM(RC[-"+ЧислоРазмеров+"]:RC[-1]";
	Для Каждого СтрокаТИ Из СтрокиТИ Цикл		
		СтрокиДанных=СтрокаТИ.Строки;                             
		Если СтрокиДанных.Количество()>0 Тогда
			ФормулаВ="";
			
			Для Каждого СтрокаДанных Из СтрокиДанных Цикл				
				ФормулаВ=ФормулаВ+?(ПустаяСтрока(ФормулаВ)=1,"","+")+"R"+СтрокаДанных.СтрокаИтога+"C";				
				Лист.Cells(СтрокаДанных.СтрокаИтога,ПозицияГорИтога).FormulaR1C1=ФормулаГ;
				//		Сообщить(ФормулаГ);
			КонецЦикла;						
			
			ФормулаВ="="+ФормулаВ;
			
			НачСмещение=ШиринаСекцииНачало+1;		
			Для Сч=НачСмещение по (НачСмещение+ЧислоРазмеров)-1 Цикл
				Лист.Cells(СтрокаТИ.СтрокаИтога,Сч).FormulaR1C1=ФормулаВ;
				//		Сообщить(ФормулаВ);
				Лист.Cells(СтрокаТИ.СтрокаИтога,ПозицияГорИтога).FormulaR1C1=ФормулаГ;
				//		Сообщить(ФормулаГ);
			КонецЦикла;                                                         
			
			Лист.Cells(СтрокаТИ.СтрокаИтога,ПозицияГорИтога+2).FormulaR1C1=ФормулаВ; //сумма
			//	сообщить(ФормулаВ);
			
			Если СтрокаТИ.ИмяИтога="Модель" Тогда	//сумма 		
				Лист.Cells(СтрокаТИ.СтрокаИтога,ПозицияГорИтога+2).FormulaR1C1="=RC[-2]*RC[-1]";
			КонецЕсли;
			
			ПрописатьФормулы(ТД,Лист,СтрокиДанных,ЧислоРазмеров);
		КонецЕсли;		                              
		
		// Группировка строк
		Если СтрокаТИ.ИмяИтога="Марка" Тогда			
			НачСтрока=СтрокаТИ.СтрокаИтога+1;
			КонСтрока=НачСтрока+СтрокаТИ.Строки.Количество()-1;			
			
			Лист.Rows(""+НачСтрока+":"+КонСтрока).Group();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры //ПрописатьФормулы


Функция РазвернутьПоРазмерам(Выборка,ИмяСекции,МаксЧислоРазмеров,ОблИтог,СтрокаТИ,ИтогПоСтроке=Ложь) Экспорт
	НачКол=ОблИтог.ШиринаТаблицы;		
	ТекЧислоРазмеров=0;
	
	Если ИмяСекции="Итого" Тогда
		ИмяГруппировкиРР=Неопределено;
	ИначеЕсли ИмяСекции="РазмерныйРяд" Тогда		
		ИмяГруппировкиРР="РазмерныйРяд";
	Иначе
		ИмяГруппировкиРР="РазмерныйРяд";			
	КонецЕсли;	
	
	ВыборкаРМ=Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Размер",ИмяГруппировкиРР);	
	
	Пока ВыборкаРМ.Следующий() И ТекЧислоРазмеров<МаксЧислоРазмеров Цикл		
		
		ОблСклад=Макет.ПолучитьОбласть(ИмяСекции+"|Размер");
		
		ТекЧислоРазмеров=ТекЧислоРазмеров+1;
		
		ОблСклад.Параметры.Заполнить(ВыборкаРМ);
		
		//крохин начало 17.03.2011
		//поменял упорядочивание размеров со ссылок на коды
		Если ИмяСекции="Шапка" Тогда
			попытка
				ОблСклад.Параметры.Размер = Справочники.Размеры.НайтиПоКоду(ВыборкаРМ.Размер);
			исключение
			конецпопытки;
		КонецЕсли;
		//крохин конец
		
		
		Если ИмяСекции="РазмерныйРяд" И НЕ ИтогПоСтроке Тогда	
		ИначеЕсли ИмяСекции="Модель" Тогда			
		ИначеЕсли ИмяСекции="Итого" Тогда			
		ИначеЕсли ИмяСекции="Цвет" Тогда
			ТекОбл=ОблСклад.Область();	
			КодТовара=ПолучитьКодТовара(ВыборкаРМ.Модель,ВыборкаРМ.Размер,ВыборкаРМ.Цвет);
			Если ПустаяСтрока(КодТовара) Тогда
				ТекОбл.ЦветФона		=Новый Цвет(128,128,128);
			Иначе
				КодТовара=ПолучитьКодТовара(ВыборкаРМ.Модель,ВыборкаРМ.Размер,ВыборкаРМ.Цвет);				
				Если ВыборкаРМ.КолКон<>Null И ВыборкаРМ.КолКон>0 Тогда
					ТекОбл.ЦветФона=Новый Цвет(255,255,153);			
					ОблСклад.Параметры.КодТовара=КодТовара;
					//Если фВыводитьКоличество Тогда
					//	ОблСклад.Параметры.Остаток = ВыборкаРМ.КолКон;
					//КонецЕсли;					
				Иначе
					ТекОбл.ЦветФона=Новый Цвет(192,192,192);
					Если фНеКонтролироватьОстатки Тогда
						ОблСклад.Параметры.КодТовара=КодТовара;					
					КонецЕсли; 
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли; 
		
		ОблИтог.Присоединить(ОблСклад);
	КонецЦикла; 
	
	ОблСклад=Макет.ПолучитьОбласть(ИмяСекции+"|Размер");
	Для Сч=ТекЧислоРазмеров+1 По МаксЧислоРазмеров Цикл
		ОблИтог.Присоединить(ОблСклад);
	КонецЦикла;
	
	Если ИмяСекции="Шапка" Тогда
		ОблСклад=ОблИтог.Область(1,НачКол+1,1,ОблИтог.ШиринаТаблицы);
		ОблСклад.Объединить();
		ОблСклад.Текст					=Выборка.РазмерныйРяд;
		ОблСклад.ВертикальноеПоложение	=ВертикальноеПоложение.Центр;
		ОблСклад.ГоризонтальноеПоложение=ГоризонтальноеПоложение.Центр;	
	КонецЕсли;		
	
	ОблИтого=Макет.ПолучитьОбласть(ИмяСекции+"|Конец");
	ОблИтого.Параметры.Заполнить(Выборка);
	Если ИмяСекции="Модель" Тогда
		ОблИтого.Параметры.Цена=ТекЦена;	
	КонецЕсли;
	
	ОблИтог.Присоединить(ОблИтого);	
КонецФункции // РазвернутьпоРазмерам()

Функция РазвернутьПоСкладам(Выборка,ИмяСекции,МаксЧислоРазмеров) Экспорт	
	ОблИтог=Новый ТабличныйДокумент;
	
	ОблНачало=Макет.ПолучитьОбласть(ИмяСекции+"|Начало");
	ОблНачало.Параметры.Заполнить(Выборка);
	//крохин начало 02.03.2012
	Если ИмяСекции="Цвет" Тогда
		Если Не ПустаяСтрока(Выборка.Цвет.РусскоеНаименование) Тогда
			ОблНачало.Параметры.ЦветРусскоеНаименование="("+Выборка.Цвет.РусскоеНаименование+")";
		КонецЕсли;
	КонецЕсли;
	//крохин конец 02.03.2012
	Если ИмяСекции="Модель" Тогда			
		Если НЕ ЗначениеЗаполнено(Выборка.Коллекция) Тогда
			ОблНачало.Параметры.Коллекция=Выборка.КоллекцияПредставление;					
		КонецЕсли;
		//Кухарь 19.04.18 начало
		////Под галку выводим ещё 1 поле и кое что меняем
		//если  ВыводитьНазваниеТовараДляСайта тогда
		//	ОблНачало.Параметры.МодельПредставление=Выборка.модель.названиетоварадлясайта;
		//	ОблНачало.Параметры.КодПроизводителя=Выборка.модель.РусскоеНаименование;
		//	ОблНачало.область(1,2,1,2).шрифт=новый Шрифт("Arial",10,Истина);
		//КонецЕсли;
		////Кухарь 19.04.18 конец
		
	КонецЕсли; 
	
	ОблИтог.Вывести(ОблНачало);
	
	Если фРазворачиватьПоСкладам Тогда
		ВыборкаСК	=Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Склад","Все");
		
		Пока ВыборкаСК.Следующий() Цикл			
			Если ВыборкаСК.Склад=Null Тогда Продолжить КонецЕсли;
			Если ИмяСекции="РазмерныйРяд" ИЛИ ИмяСекции="Итого" Тогда			
				СтрокаТИ=ТИ.Найти(ВыборкаСК.Склад,"Склад");			
				Если СтрокаТИ=Неопределено Тогда
					СтрокаТИ=ТИ.Добавить();			
					СтрокаТИ.Склад=ВыборкаСК.Склад;
				КонецЕсли; 
			Иначе
				СтрокаТИ=Неопределено;
			КонецЕсли; 
			
			РазвернутьПоРазмерам(ВыборкаСК,ИмяСекции,МаксЧислоРазмеров,ОблИтог,СтрокаТИ);		
			
		КонецЦикла;	
		
		Если КоличествоСкладов>1 Тогда
			Если ИмяСекции="Итого" Тогда
				СтрокаСвертки="";
				Для Сч=1 По МаксЧислоРазмеров Цикл
					СтрокаСвертки=СтрокаСвертки+"Р_"+Сч+",";			
				КонецЦикла; 
				СтрокаСвертки=Лев(СтрокаСвертки,СтрДлина(СтрокаСвертки)-1);
				
				ТИ.Добавить();
				ТИ.Колонки.Добавить("Свертка");
				ТИ.Свернуть("Свертка",СтрокаСвертки);			
				
				СтрокаТИ=ТИ[0];
			КонецЕсли;
			
			РазвернутьПоРазмерам(Выборка,ИмяСекции,МаксЧислоРазмеров,ОблИтог,СтрокаТИ,Истина);		
		КонецЕсли;
	Иначе
		РазвернутьПоРазмерам(Выборка,ИмяСекции,МаксЧислоРазмеров,ОблИтог,СтрокаТИ);
	КонецЕсли; 
	
	
	Возврат ОблИтог;
КонецФункции // РазвернутьПоСкладам()

