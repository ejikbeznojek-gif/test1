	////крохин конец 06.12.2017			
	//	Цена=Формат(Цена-(Цена*СкидкаИзФормы/100),"ЧДЦ=2");
	//	
	//КонецЕсли; 
	//крохин конец
	
	//-----------------------------------------------------
	
	//Если ТипЦен_SALE.Пустая() И НЕ Контрагент.Пустая() Тогда
