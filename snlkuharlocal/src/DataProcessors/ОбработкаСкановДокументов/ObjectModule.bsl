 Функция Раскодировать64Лок(НачСтр) Экспорт 
	 База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	 
	 Стр=СокрЛП(НачСтр);
	 
	 СтрокаБит="";
	 
	 Длина=СтрДлина(Стр);
	 
	 ПолнаяСтрока="";
	 Для Сч=1 По Длина Цикл
		 Символ=Сред(Стр,Сч,1);
		 Десятичное=Найти(База,Символ)-1;		
		 СтрокаБит=СтрокаБит+Сред(БинарноеЛок(Десятичное),3);		
	 КонецЦикла;
	 
	 СтрокаИсходная="";
	 Пока СтрДлина(СтрокаБит)>0 Цикл		
		 БитовоеЗначение=Лев(СтрокаБит,8);
		 
		 СтрокаИсходная	=СтрокаИсходная+СимволпоБайтовомуКоду(ДесятичноеЛок(БитовоеЗначение));			    
		 СтрокаБит		=Сред(СтрокаБит,9);
	 КонецЦикла;                      
	 
	 Возврат СтрокаИсходная;	    
 КонецФункции //Раскодировать
 
 
 Функция БинарноеЛок(НачЗн)
	 Зн=НачЗн;	
	 Стр="";	
	 Для Сч=1 по 8 Цикл
		 Бит=Зн%2;
		 
		 Стр=""+Бит+Стр;   
		 Зн=(Зн-Бит)/2;		
	 КонецЦикла;     
	 
	 Возврат Стр;
 КонецФункции //
 
