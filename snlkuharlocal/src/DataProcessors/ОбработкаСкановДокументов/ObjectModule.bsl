  Функция НайтиНомерСФПоРНК(НомерДокумента,Год) Экспорт 
	 попытка
	 Запрос = Новый Запрос;
	 запрос.Текст = "ВЫБРАТЬ
	                |	СчетФактураНакладные.Ссылка.Номер КАК Номер
	                |ИЗ
	                |	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
	                |ГДЕ
	                |	СчетФактураНакладные.Ссылка.Дата МЕЖДУ &НачПериода И &КонПериода
	                |	И СчетФактураНакладные.Накладная.Номер = &Номер";
	 Запрос.УстановитьПараметр("Номер",НомерДокумента);
	 Запрос.УстановитьПараметр("Начпериода",Дата(2000+Год,1,1));
	 Запрос.УстановитьПараметр("КонПериода",КонецГода(Дата(2000+Год,1,1)));
	 Выборка = Запрос.Выполнить().Выбрать();
	 Если Выборка.Следующий() Тогда
		 Возврат Выборка.Номер; 
	 Иначе
		 Возврат "";
	 КонецЕсли;
 Исключение
	 Возврат "";
	 КонецПопытки;
 КонецФункции
 

 