
Процедура ЗагрузитьОтветТранспортнойКомпании(ТаблицаПараметров=Неопределено) Экспорт
	
	ПочтовыйЯщик = Справочники.УчетныеЗаписиЭлектроннойПочты.УчетнаяЗаписьОбменаСТК;
		
	СтруктураВозврата = Документы.ЗаявкаНаДоставку.ПолучитьПочтовыйОтвет(ПочтовыйЯщик);
	
	Если СтруктураВозврата.КоличествоВложений <> 0 Тогда
		
		ЗаписатьВЛог("ОбработатьПочтовыйОтвет","Начало выполнения. Задача: Загрузка ответов транспортных компаний!","Информация");
		
		МассивКУдалению = Документы.ЗаявкаНаДоставку.ОбработатьПочтовыйОтвет();
		Документы.ЗаявкаНаДоставку.УдалитьОбработанныеФайлы(МассивКУдалению);
		
		ЗаписатьВЛог("ОбработатьПочтовыйОтвет","Окончание выполнения. Задача: Загрузка ответов транспортных компаний!","Информация");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	ЗагрузитьОтветТранспортнойКомпании();	
КонецПроцедуры
