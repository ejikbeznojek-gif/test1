#Область РазделениеТоваров

Функция РазделитьМаркированныеИНемаркированныеТовары(Накладная, МассивНоменклатурыЗНБ = Неопределено, ЗНБ = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Накладная", Накладная);
	Запрос.УстановитьПараметр("ЗНБ", ЗНБ);
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РеквизитыДокументов.Документ КАК Перемещение
	|ПОМЕСТИТЬ вр_Перемещения
	|ИЗ
	|	РегистрСведений.РеквизитыДокументов КАК РеквизитыДокументов
	|ГДЕ
	|	РеквизитыДокументов.ИмяРеквизита = ""Связь_РНК_ПРМ""
	|	И РеквизитыДокументов.ЗначениеРеквизита = &Накладная
	|	И ТИПЗНАЧЕНИЯ(РеквизитыДокументов.Документ) = ТИП(Документ.Перемещение)
	|	И ТИПЗНАЧЕНИЯ(РеквизитыДокументов.ЗначениеРеквизита) = ТИП(Документ.РасходнаяНакладная)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура) КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(ТоварыПРМ.Количество, 0)) КАК Количество
	|ПОМЕСТИТЬ вр_НемаркированныеТовары
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Комплектующие КАК КомплектующиеРНК
	|		ПО ТоварыПРМ.Номенклатура = КомплектующиеРНК.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|		ПО ТоварыПРМ.Ссылка = вр_Перемещения.Перемещение
	|ГДЕ
	|	НЕ ТоварыПРМ.Ссылка.Склад.ЭтоСкладМаркированногоТовара
	|	И КомплектующиеРНК.Ссылка = &Накладная
	|	" + ?(МассивНоменклатурыЗНБ = Неопределено, "", "И ТоварыПРМ.Номенклатура В(&МассивНоменклатурыЗНБ)") + "
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура) КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(ТоварыПРМ.Количество, 0)) КАК Количество
	|ПОМЕСТИТЬ вр_МаркированныеТовары
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Комплектующие КАК КомплектующиеРНК
	|		ПО ТоварыПРМ.Номенклатура = КомплектующиеРНК.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|		ПО ТоварыПРМ.Ссылка = вр_Перемещения.Перемещение
	|ГДЕ
	|	ТоварыПРМ.Ссылка.Склад.ЭтоСкладМаркированногоТовара
	|	И КомплектующиеРНК.Ссылка = &Накладная
	|	" + ?(МассивНоменклатурыЗНБ = Неопределено, "", "И ТоварыПРМ.Номенклатура В(&МассивНоменклатурыЗНБ)") + "
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура) КАК Номенклатура,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ЕСТЬNULL(КомплектующиеРНК.Количество, 0) - ЕСТЬNULL(ТоварыПРМ.Количество, 0) > 0
	|				ТОГДА ЕСТЬNULL(КомплектующиеРНК.Количество, 0) - ЕСТЬNULL(ТоварыПРМ.Количество, 0)
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Количество
	|ПОМЕСТИТЬ вр_ТоварыНеСовпадаетКоличество
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Комплектующие КАК КомплектующиеРНК
	|		ПО ТоварыПРМ.Номенклатура = КомплектующиеРНК.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|		ПО ТоварыПРМ.Ссылка = вр_Перемещения.Перемещение
	|ГДЕ
	|	КомплектующиеРНК.Ссылка = &Накладная
	|	И ЕСТЬNULL(КомплектующиеРНК.Количество, 0) - ЕСТЬNULL(ТоварыПРМ.Количество, 0) > 0
	|	" + ?(МассивНоменклатурыЗНБ = Неопределено, "", "И КомплектующиеРНК.Номенклатура В(&МассивНоменклатурыЗНБ)") + "
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, КомплектующиеРНК.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Комплектующие.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Комплектующие.Количество, 0) КАК Количество
	|ПОМЕСТИТЬ вр_ЕстьВРНК_НетВПРМ
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК Комплектующие
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Перемещение.Товары КАК ПеремещениеТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|			ПО ПеремещениеТовары.Ссылка = вр_Перемещения.Перемещение
	|		ПО Комплектующие.Номенклатура = ПеремещениеТовары.Номенклатура
	|ГДЕ
	|	Комплектующие.Ссылка = &Накладная
	|	И ПеремещениеТовары.Номенклатура ЕСТЬ NULL
	|	" + ?(МассивНоменклатурыЗНБ = Неопределено, "", "И Комплектующие.Номенклатура В(&МассивНоменклатурыЗНБ)") + "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_МаркированныеТовары.Номенклатура КАК Номенклатура,
	|	0 КАК Количество,
	|	вр_МаркированныеТовары.Количество КАК КоличествоЧЗ
	|ПОМЕСТИТЬ вр_Сводная
	|ИЗ
	|	вр_МаркированныеТовары КАК вр_МаркированныеТовары
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вр_ТоварыНеСовпадаетКоличество.Номенклатура,
	|	0,
	|	вр_ТоварыНеСовпадаетКоличество.Количество
	|ИЗ
	|	вр_ТоварыНеСовпадаетКоличество КАК вр_ТоварыНеСовпадаетКоличество
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вр_ЕстьВРНК_НетВПРМ.Номенклатура,
	|	0,
	|	вр_ЕстьВРНК_НетВПРМ.Количество
	|ИЗ
	|	вр_ЕстьВРНК_НетВПРМ КАК вр_ЕстьВРНК_НетВПРМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вр_НемаркированныеТовары.Номенклатура,
	|	вр_НемаркированныеТовары.Количество,
	|	0
	|ИЗ
	|	вр_НемаркированныеТовары КАК вр_НемаркированныеТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Сводная.Номенклатура КАК Номенклатура,
	|	СУММА(вр_Сводная.Количество) КАК Количество,
	|	СУММА(вр_Сводная.КоличествоЧЗ) КАК КоличествоЧЗ
	|ИЗ
	|	вр_Сводная КАК вр_Сводная
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Сводная.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РеквизитыДокументов.Документ КАК Перемещение
	|ПОМЕСТИТЬ вр_Перемещения
	|ИЗ
	|	РегистрСведений.РеквизитыДокументов КАК РеквизитыДокументов
	|ГДЕ  
	//++Данилова Е.В. 11.12.2025  HELP-8148 
	//|	РеквизитыДокументов.ИмяРеквизита = ""Связь_РНК_ПРМ""
	|	РеквизитыДокументов.ИмяРеквизита ПОДОБНО ""Связь_РНК_ПРМ%""
	//--Данилова Е.В. 11.12.2025
	|	И РеквизитыДокументов.ЗначениеРеквизита = &Накладная
	|	И ТИПЗНАЧЕНИЯ(РеквизитыДокументов.Документ) = ТИП(Документ.Перемещение)
	|	И ТИПЗНАЧЕНИЯ(РеквизитыДокументов.ЗначениеРеквизита) = ТИП(Документ.РасходнаяНакладная)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыЗНБ.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ТоварыЗНБ.Количество) КАК Количество,
	|	МАКСИМУМ(ТоварыЗНБ.ТребуетсяМаркировка) КАК ТребуетсяМаркировка
	|ПОМЕСТИТЬ вр_ЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ТоварыЗНБ
	|ГДЕ
	|	ТоварыЗНБ.Ссылка = &ЗНБ
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыЗНБ.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, вр_ЗНБ.Номенклатура) КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(вр_ЗНБ.Количество, 0)) КАК Количество
	|ПОМЕСТИТЬ вр_НемаркированныеТовары
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_ЗНБ КАК вр_ЗНБ
	|		ПО ТоварыПРМ.Номенклатура = вр_ЗНБ.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|		ПО ТоварыПРМ.Ссылка = вр_Перемещения.Перемещение
	|ГДЕ
	|	НЕ ТоварыПРМ.Ссылка.Склад.ЭтоСкладМаркированногоТовара
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, вр_ЗНБ.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, вр_ЗНБ.Номенклатура) КАК Номенклатура,
	|	МАКСИМУМ(ЕСТЬNULL(вр_ЗНБ.Количество, 0)) КАК Количество
	|ПОМЕСТИТЬ вр_МаркированныеТовары
	|ИЗ
	|	Документ.Перемещение.Товары КАК ТоварыПРМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_ЗНБ КАК вр_ЗНБ
	|		ПО ТоварыПРМ.Номенклатура = вр_ЗНБ.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_Перемещения КАК вр_Перемещения
	|		ПО ТоварыПРМ.Ссылка = вр_Перемещения.Перемещение
	|ГДЕ
	|	ТоварыПРМ.Ссылка.Склад.ЭтоСкладМаркированногоТовара
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ТоварыПРМ.Номенклатура, вр_ЗНБ.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_МаркированныеТовары.Номенклатура КАК Номенклатура,
	|	0 КАК Количество,
	|	вр_МаркированныеТовары.Количество КАК КоличествоЧЗ
	|ПОМЕСТИТЬ вр_Сводная
	|ИЗ
	|	вр_МаркированныеТовары КАК вр_МаркированныеТовары
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вр_НемаркированныеТовары.Номенклатура,
	|	вр_НемаркированныеТовары.Количество,
	|	0
	|ИЗ
	|	вр_НемаркированныеТовары КАК вр_НемаркированныеТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Сводная.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(вр_Сводная.Количество) КАК Количество,
	|	МАКСИМУМ(вр_Сводная.КоличествоЧЗ) КАК КоличествоЧЗ
	|ПОМЕСТИТЬ вр_Объединение
	|ИЗ
	|	вр_Сводная КАК вр_Сводная
	|
	|СГРУППИРОВАТЬ ПО
	|	вр_Сводная.Номенклатура
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 
	//++Данилова Е.В. 23.10.2025 без задачи 
	|ВЫБРАТЬ
	|	вр_ЗНБ.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(вр_Объединение.КоличествоЧЗ, 0) <> 0
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА вр_Объединение.Количество ЕСТЬ NULL
	|					ТОГДА ВЫБОР
	|							КОГДА вр_ЗНБ.ТребуетсяМаркировка
	|								ТОГДА 0
	|							ИНАЧЕ вр_ЗНБ.Количество
	|						КОНЕЦ
	|				ИНАЧЕ вр_Объединение.Количество
	|			КОНЕЦ
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР
	|		КОГДА вр_Объединение.КоличествоЧЗ ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|					КОГДА вр_ЗНБ.ТребуетсяМаркировка
	|						ТОГДА вр_ЗНБ.Количество
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		ИНАЧЕ вр_Объединение.КоличествоЧЗ
	|	КОНЕЦ КАК КоличествоЧЗ
	|ИЗ
	|	вр_ЗНБ КАК вр_ЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вр_Объединение КАК вр_Объединение
	|		ПО вр_ЗНБ.Номенклатура = вр_Объединение.Номенклатура 
	//--Данилова Е.В. 23.10.2025
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура";

	УстановитьПривилегированныйРежим(Истина);
	тзТовары = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат тзТовары;
	
КонецФункции
 
Функция ЭтоСкладСмешанныеСпайки(ДокОбъект) Экспорт
	
	Если ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.ЗаданиеНабора") Тогда
		Если ЗначениеЗаполнено(ДокОбъект.Накладная) И ЕстьРеквизитДокумента("Склад", ДокОбъект.Накладная.Метаданные()) Тогда
			Склад = ДокОбъект.Накладная.Склад;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.ПланНабора") Тогда
		Если ЗначениеЗаполнено(ДокОбъект.ДокОснование) И ЕстьРеквизитДокумента("Склад", ДокОбъект.ДокОснование.Метаданные()) Тогда
			Склад = ДокОбъект.ДокОснование.Склад;	
		Иначе
			Возврат Ложь;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Склад = ДокОбъект.Склад;	
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	СкладСмешанныеСпайки = Документы.ЗаказСмешанныхСпаекFBO.ПолучитьЗначениеРеквизитыСправочников(, "СкладСмешанныеСпайки", Истина);
	
	Возврат ?(Склад = СкладСмешанныеСпайки, Истина, Ложь);
	
КонецФункции

Функция ПолучитьТаблицуССекторамиИНаборщиками(ДокСсылка, тзТовары) Экспорт
	
	Запрос = Новый Запрос;
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ПланНабора") Тогда
		Запрос.УстановитьПараметр("ПланНабора", ДокСсылка);
	ИначеЕсли ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ЗаданиеНабора") Тогда
		Запрос.УстановитьПараметр("ПланНабора", ДокСсылка.ДокументОснование);
	КонецЕсли;
	Запрос.УстановитьПараметр("тзТовары", тзТовары);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(тзТовары.Количество КАК ЧИСЛО) КАК Количество
	|ПОМЕСТИТЬ вр_Товары
	|ИЗ
	|	&тзТовары КАК тзТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тБрэндов.Брэнд КАК Брэнд,
	|	тБрэндов.Коллекция КАК Коллекция,
	|	тБрэндов.Наборщик КАК Наборщик,
	|	тБрэндов.СекторХранения КАК СекторХранения
	|ПОМЕСТИТЬ вр_ПланНабора
	|ИЗ
	|	Документ.ПланНабора.тБрэндов КАК тБрэндов
	|ГДЕ
	|	тБрэндов.Ссылка = &ПланНабора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вр_Товары.Номенклатура КАК Номенклатура,
	|	вр_Товары.Количество КАК Количество,
	|	вр_ПланНабора.Брэнд КАК Брэнд,
	|	вр_ПланНабора.Коллекция КАК Коллекция,
	|	вр_ПланНабора.Наборщик КАК Наборщик,
	|	вр_ПланНабора.СекторХранения КАК СекторХранения
	|ИЗ
	|	вр_Товары КАК вр_Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вр_ПланНабора КАК вр_ПланНабора
	|		ПО вр_Товары.Номенклатура.Родитель.Родитель = вр_ПланНабора.Коллекция
	|			И вр_Товары.Номенклатура.Родитель.Родитель.Родитель = вр_ПланНабора.Брэнд
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наборщик,
	|	Брэнд,
	|	Коллекция";
	
	УстановитьПривилегированныйРежим(Истина);
	тзСводное = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат тзСводное;
	
КонецФункции

#КонецОбласти

#Область ПечатьСмешанныеСпайки

Функция ПечатьЗаданияНабораСмешанныеСпайки(ДокОбъект, Макет, ДопПараметрыНакладной) Экспорт
	
	МассивЗНБ = Новый Массив;
	
	Если ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.ПланНабора") Тогда
		
		Накладная = ДокОбъект.ДокОснование;
		ПланНабора = ДокОбъект.Ссылка;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ПланНабора", ПланНабора);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаданиеНабора.Ссылка КАК ЗНБ
		|ИЗ
		|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|ГДЕ
		|	ЗаданиеНабора.ДокументОснование = &ПланНабора
		|	И ЗаданиеНабора.Проведен";
		
		УстановитьПривилегированныйРежим(Истина);
		МассивЗНБ = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ЗНБ");
		УстановитьПривилегированныйРежим(Ложь);
		
	ИначеЕсли ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.ЗаданиеНабора") Тогда
		
		Накладная = ДокОбъект.Накладная;
		ПланНабора = ДокОбъект.ДокументОснование;
		
		МассивЗНБ.Добавить(ДокОбъект.Ссылка);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	//////////////// ДАННЫЕ ИЗ НАКЛАДНОЙ //////////////////////////////////////////////
	ОтгрузкаКомплектов= Накладная.ОтгрузкаКомплектов;
	
	ВидНакладной				= "РасходнаяНакладная";
	ВидНакладнойПредставление	= "РНК";	
	
	ТД = Новый ТабличныйДокумент;
	ТД.Очистить();
	ТД.ИмяПараметровПечати = "ПН_СмешанныеСпайки";
	ТД.ОтображатьСетку = Ложь;
	
	ОблЗаголовок	= Макет.ПолучитьОбласть("Заголовок");
	ОблШапка	    = Макет.ПолучитьОбласть("ШапкаЧЗ");
	ОблСтрока	    = Макет.ПолучитьОбласть("СтрокаЧЗ");
	ОблПодвал       = Макет.ПолучитьОбласть("ПодвалЧЗ");
	
	ОблТекст 	= Макет.ПолучитьОбласть("Текст");
	
	ОблЗаголовок.Параметры.Заголовок ="К накладной: "+ВидНакладнойПредставление+" "+Накладная.Номер+" от "+Формат(Накладная.Дата,"ДФ=dd.MM.yyyy");
	ОблЗаголовок.Параметры.Заполнить(Накладная);
	ОблЗаголовок.Параметры.ГруппыТоваров = "";        //ТЮА
	ОблЗаголовок.Параметры.ДатаОтгрузки  = Формат(Накладная.ДатаОтгрузки,"ДФ=dd.MM.yyyy");
	
	ДатаАвизации = ОблЗаголовок.Параметры.ДатаОтгрузки; 
	ВремяПриемки = ПолучитьВремяПриемки(Накладная); 	
	
	СтрокаДатыВремениДоставки = "";
	
	Если ЗначениеЗаполнено(ДатаАвизации) Тогда
		СтрокаДатыВремениДоставки=СтрокаДатыВремениДоставки+"отгрузка: "+ДатаАвизации;			 
		Если ЗначениеЗаполнено(ВремяПриемки) тогда
			СтрокаДатыВремениДоставки=СтрокаДатыВремениДоставки+" "+ВремяПриемки;
		КонецЕсли;		
	КонецЕсли;
	
	РайонДоставки=ПолучитьРеквизитШапки(Накладная,"ПунктДоставки.РайонДоставки","Документ");
	Если НЕ ЗначениеЗаполнено(РайонДоставки) Тогда
		РайонДоставки=ПолучитьРеквизитШапки(Накладная,"Контрагент.РайонДоставки","Документ");
	КонецЕсли;	
	
	ОблЗаголовок.Параметры.РайонДоставкиПечать = "Район доставки: "+РайонДоставки+".Сектор: "+РайонДоставки.Сектор;		
	ОблЗаголовок.Параметры.ДопОбработка        = ТекстДопОбработки(Накладная);
	//////////////// ДАННЫЕ ИЗ НАКЛАДНОЙ //////////////////////////////////////////////
	
	//////////////// ОБХОДИМ ЗНБ //////////////////////////////////////////////////////
	Для Каждого ЗНБ ИЗ МассивЗНБ Цикл
		
		тзТовары = РазделитьМаркированныеИНемаркированныеТовары(Накладная, Неопределено, ЗНБ);
		
		Если тзТовары.Количество() = 0 Тогда
			Продолжить;
		Конецесли;
		
		//==================================================================================================
		/////// НА ПЛАТФОРМЕ х64 РИСУНОК НЕ ВЫВОДИТСЯ /////////////////////////////////
		СистемнаяИнформация = Новый СистемнаяИнформация;
		Если СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86 Тогда
			Рисунок				  = ОблЗаголовок.Рисунки.ОбъектШК;
			ОбъектШК			  = Рисунок.Объект;	
			ОбъектШК.Сообщение	  = СформироватьШКДокаСервер(ЗНБ);
		КонецЕсли;
		//==================================================================================================
	
		СтрокаПН = ПолучитьДанныеПервойСтроки(Накладная);	
	
		ОблЗаголовок.Параметры.Склад				= ПолучитьРеквизитШапки(Накладная,"Склад","Документ");
		ОблЗаголовок.Параметры.Наборщик				= ПолучитьНаборщика(ЗНБ);	
		ОблЗаголовок.Параметры.Сканировщик			= СтрокаПН.Сканировщик;
		
		КоличествоОбщее = 0;
		Для Каждого СтрокаТЧ ИЗ тзТовары Цикл
			КоличествоОбщее = КоличествоОбщее + СтрокаТЧ.Количество + СтрокаТЧ.КоличествоЧЗ;	
		КонецЦикла;
		ОблЗаголовок.Параметры.КоличествоОбщее	= "Кол-во всего: " + КоличествоОбщее;
		
		ТД.Вывести(ОблЗаголовок);
		ТД.Вывести(ОблШапка);
		
		///////////////////////////////////////////////////////////////////////////////
		
		Сч = 0; ИтогоКоличество = 0; ИтогоКоличествоЧЗ = 0;
		
		ТД.Вывести(ОблТекст);
		Для Каждого СтрокаТЧ ИЗ тзТовары Цикл
			
			Если СтрокаТЧ.Количество = 0 И СтрокаТЧ.КоличествоЧЗ = 0 Тогда Продолжить КонецЕсли;
			
			Сч=Сч+1;
			
			ОблСтрока.Параметры.Товары 		= СтрокаТЧ.Номенклатура;
			ОблСтрока.Параметры.НПП 		= Сч;
			ОблСтрока.Параметры.ШК 			= ПолучитьШтрихКодТовара(СтрокаТЧ.Номенклатура,Перечисления.ТипыШтрихКодов.Штука,Перечисления.ВидыШК.Основной);
			ОблСтрока.Параметры.Количество	= СтрокаТЧ.Количество;
			ОблСтрока.Параметры.КоличествоЧЗ= СтрокаТЧ.КоличествоЧЗ;
			
			ИтогоКоличество	= ИтогоКоличество + СтрокаТЧ.Количество;
			ИтогоКоличествоЧЗ = ИтогоКоличествоЧЗ + СтрокаТЧ.КоличествоЧЗ;
			
			ТД.Вывести(ОблСтрока);			
		КонецЦикла;
		
		ОблПодвал.Параметры.КоличествоСтрок	= Сч;
		ОблПодвал.Параметры.Количество		= ИтогоКоличество;
		ОблПодвал.Параметры.КоличествоЧЗ	= ИтогоКоличествоЧЗ;
		ТД.Вывести(ОблПодвал);
		
		УстановитьКолонтитулыТД(ТД);
		
		ТД.ВывестиГоризонтальныйРазделительСтраниц();
		
	КонецЦикла;
	
	Возврат ТД;
	
КонецФункции

Процедура УстановитьКолонтитулыТД(ТД, ПопожениеКолонтитула="Верхний")
	
	Если ПопожениеКолонтитула="Верхний" Тогда
		Колонтитул=ТД.ВерхнийКолонтитул;
	Иначе
		Колонтитул=ТД.НижнийКолонтитул;	
	КонецЕсли; 
	
	Колонтитул.Выводить=Истина;
	Колонтитул.ВертикальноеПоложение=ВертикальноеПоложение.Верх;
	
	Колонтитул.ТекстСлева="Сформирован: "+СокрЛП(ПараметрыСеанса.Пользователь)+", "+ТекущаяДата();	
	Колонтитул.ТекстСлева=СтрЗаменить(Колонтитул.ТекстСлева," ",Символы.НПП);  
	
	Колонтитул.ТекстСправа="Стр. № [&НомерСтраницы]из [&СтраницВсего]";
	
КонецПроцедуры

Функция ПолучитьДанныеПервойСтроки(ДокОбъект)
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	*
	|ИЗ
	|	Документ.ПланНабора.тБрэндов
	|ГДЕ
	|	Ссылка.Проведен И Ссылка.Накладная=&РНК
	|";
	
	Запрос.УстановитьПараметр("РНК",ДокОбъект.Ссылка);
	
	РезультатЗапроса=Запрос.Выполнить().Выгрузить();
	Результат=Новый Структура;
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		Результат.Вставить(Колонка.Имя,Неопределено);	
		Если РезультатЗапроса.Количество()>0 Тогда
			Результат[Колонка.Имя]=РезультатЗапроса[0][Колонка.Имя];
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции

Функция ПолучитьНаборщика(ЗНБ_Объект)
	
	Результат=Справочники.ФизическиеЛица.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПланНаборатБрэндов.Наборщик КАК Наборщик
	|ИЗ
	|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
	|ГДЕ
	|	ПланНаборатБрэндов.Ссылка = &ПланНабора
	|	И ПланНаборатБрэндов.НомерЧасти = &НомерЧасти";
	
	Запрос.УстановитьПараметр("ПланНабора",ЗНБ_Объект.ДокументОснование);
	Запрос.УстановитьПараметр("НомерЧасти",ЗНБ_Объект.НомерЧасти);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Наборщик) Тогда
		Результат = Выборка.Наборщик;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 

Функция ТекстДопОбработки(Накладная)
	ДопОбработка = ?(ТребуетсяДопОбработка(Накладная),"Требуется доп. обработка !","Доп. обработка не требуется");
	Возврат ДопОбработка;
КонецФункции //ТребуетсяДопОбработка(ДокСсылка) 

#КонецОбласти

#Область КодировкаСлужебные

Функция СформироватьШКДокаСервер(Док) Экспорт
	Если Док.Пустая() Тогда Возврат "" КонецЕсли;
	КодИсх="*"+ИдПоВидуДокумента(Док.Метаданные().Имя)+"*"+Док.Номер+"*"+Прав(""+Год(Док.Дата),2)+"*";		
	Возврат Закодировать64Сервер(КодИсх);
КонецФункции //СформироватьШКДока

Функция Закодировать64Сервер(НачСтр) Экспорт
	База="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	
	Стр=НачСтр;
	
	Остаток=СтрДлина(Стр) % 3;
	НеХватает=?(Остаток=0,0,3-Остаток); 
	
	Для Сч=1 по НеХватает Цикл
		Стр=Стр+" ";	    
	КонецЦикла;	
	    
	СтрокаБит="";
	
	Длина=СтрДлина(Стр);
	
	ПолнаяСтрока="";
	Для Сч=1 По Длина Цикл
		СтрокаБит=СтрокаБит+Бинарное(БайтовыйКодСимволаСервер(Сред(Стр,Сч,1)));		
	КонецЦикла;
	
	СтрокаКода="";
	Пока СтрДлина(СтрокаБит)>0 Цикл		
		БитовоеЗначение="00"+Лев(СтрокаБит,6);
		
		СтрокаКода	=СтрокаКода+Сред(База,Десятичное(БитовоеЗначение)+1,1);			    
		СтрокаБит	=Сред(СтрокаБит,7);
	КонецЦикла;                                                      
	
	Возврат СтрокаКода;	
КонецФункции // 

Функция БайтовыйКодСимволаСервер(Символ) Экспорт
	Возврат ЗаполнитьКодировки().КодировкаПрямая[Символ];
КонецФункции // КодСимвола()

Функция СимволПоБайтовомуКоду(Код)
	Возврат ЗаполнитьКодировки().КодировкаОбратная[Код];
КонецФункции // ()
  
Функция Бинарное(НачЗн)
	Зн=НачЗн;	
	Стр="";	
	Для Сч=1 по 8 Цикл
		Бит=Зн%2;
		
		Стр=""+Бит+Стр;   
		Зн=(Зн-Бит)/2;		
	КонецЦикла;     
	
	Возврат Стр;
КонецФункции //

Функция Десятичное(НачЗн)
	Зн=0;
	База=128;
	
	ТекДлинна=Мин(СтрДлина(НачЗн),8);
	
	Для Сч=1 по ТекДлинна Цикл
		Зн=Зн+База*Число(Сред(НачЗн,Сч,1));					    
		База=База/2;
	КонецЦикла;
	
	Возврат Зн;
КонецФункции //Десятичное

Функция ИдПоВидуДокумента(Вид)
	Возврат Метаданные.Документы[Вид].Синоним;	
КонецФункции //ВнутреннийИдВидаДокумента
 
