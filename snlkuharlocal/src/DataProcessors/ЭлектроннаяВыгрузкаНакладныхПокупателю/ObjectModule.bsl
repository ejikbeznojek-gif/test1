		Элемент2.УстановитьАтрибут("MATKX",Строка(ТекСтрока.Номенклатура.Наименование));
		Элемент2.УстановитьАтрибут("Qty",Строка(ТекСтрока.Количество));
		Элемент2.УстановитьАтрибут("KWERT",Строка(Цена));  // цена без НДС
		Элемент2.УстановитьАтрибут("PRONU",Строка(НомерГТД));
		
		ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
		
	КонецЦикла;
	
	//---------------------------------------------------------------
	ЗаписьДом=Новый ЗаписьDom;
	ЗаписьДом.Записать(ДокументДом,ЗаписьХМЛ);
	ЗаписьХМЛ.Закрыть();	
	
	//Сообщить("Сформирован файл обмена. "+ИмяФайлаОбмена);
	
	//----------------------------------------
	//             отправить письмо
	//----------------------------------------
	Шапка="";
	СообщитьМенеджеруКаприз(ИмяФайлаОбмена);
	
	Если КрОшибки.Количество() Тогда
		
