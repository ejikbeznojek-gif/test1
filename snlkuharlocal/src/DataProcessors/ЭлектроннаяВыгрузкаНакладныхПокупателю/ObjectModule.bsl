Процедура Отправить()  Экспорт
	
	НомЗак=ДокОбъект.номерЗаказа;
	Если СокрЛП(НомЗак)="" Тогда
		
		ГСЧ = Новый ГенераторСлучайныхЧисел(255);
		НомЗак=ГСЧ.СлучайноеЧисло(0, 10000);
		
	КонецЕсли;	
	
	ИмяФайлаОбмена=""+константы.КаталогВнешнихОтчетов.Получить() +"temp\"+ НомЗак+".xml";
	
	//Сообщить(ИмяФайлаОбмена);
	Файл=Новый Файл(ИмяФайлаОбмена);
	
	
	ЗаписьХМЛ=Новый ЗаписьXML;
	ЗаписьХМЛ.ОткрытьФайл(ИмяФайлаОбмена);   //(Путь+Имя+".xml");
	ДокументДом=Новый ДокументDom("http://v8.1c./8.1/sample91_DOM","Document-Order");
	КорневойЭлемент=ДокументДом.ЭлементДокумента;
	//-------- Order-Header ------------------------------------------
	ЭлементДом=ДокументДом.СоздатьЭлемент("Order");
	ТекУзел1=КорневойЭлемент.ДобавитьДочерний(ЭлементДом);
	//----------------------------------------------------------------
	Элемент2=ДокументДом.СоздатьЭлемент("OrderNumber");
	ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
	текстДом=ДокументДом.СоздатьТекстовыйУзел(ДокОбъект.Номер);
	ТекУзел2.ДобавитьДочерний(ТекстДом);
	//------------------------------------------------------------
	Элемент2=ДокументДом.СоздатьЭлемент("OrderDate");
	ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
	текстДом=ДокументДом.СоздатьТекстовыйУзел(строка(ДокОбъект.Дата));
	ТекУзел2.ДобавитьДочерний(ТекстДом);
	//------------------------------------------------------------
	Элемент2=ДокументДом.СоздатьЭлемент("Buyer");
	ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
	текстДом=ДокументДом.СоздатьТекстовыйУзел(строка(ДокОбъект.Контрагент.ПолноеНаименование));
	ТекУзел2.ДобавитьДочерний(ТекстДом);
	//------------------------------------------------------------
	Элемент2=ДокументДом.СоздатьЭлемент("AdresDostavki");
	ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
	текстДом=ДокументДом.СоздатьТекстовыйУзел(строка(ДокОбъект.ПунктДоставки.ПочтовыйАдрес));
	ТекУзел2.ДобавитьДочерний(ТекстДом);
	
	
	//-------------------------
	//    заполнение строк
	//-------------------------
	ЭлементДом=ДокументДом.СоздатьЭлемент("Order-Lines");
	ТекУзел1=КорневойЭлемент.ДобавитьДочерний(ЭлементДом);
	
	РР=1;
	Для Каждого ТекСтрока из ДокОбъект.Товары цикл
		//ТекСтрока.Номенклатура.Вес
		Если ТекСтрока.Количество<=0 Тогда
			
			Продолжить;
			
		КонецЕсли; 
		Элемент=ДокументДом.СоздатьЭлемент("Line");
		ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент);
		//----------------------------------------------
		Элемент=ДокументДом.СоздатьЭлемент("LineNumber");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(рр));                 
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		// ищем штрихкод номенклатуры  -----------------------------
		
		ШКО="";
		//-------------------
		Попытка
			
			ТипШк = Перечисления.ТипыШтрихКодов.Штука;
			
			Запрос=Новый Запрос;
			Запрос.Текст="ВЫБРАТЬ
			|	ШтрихКоды.Владелец КАК Номенклатура,
			|	ШтрихКоды.Наименование как номер,
			|	ШтрихКоды.Код
			|ИЗ
			|	Справочник.ШтрихКоды КАК ШтрихКоды
			|ГДЕ
			|	ШтрихКоды.ТипШК = &ТипШК
			|	И ШтрихКоды.Владелец = &ТекНом";
			
			Запрос.УстановитьПараметр("ТекНом",текСтрока.Номенклатура); 
			Запрос.УстановитьПараметр("ТипШК",ТипШк);
			
			Выборка1 = запрос.Выполнить().Выбрать();
			
			Пока выборка1.Следующий() Цикл
				ШКО=выборка1.Номер; //ШКО+"@"
			КонецЦикла;	
			
		Исключение
		КонецПопытки;
		
		//---------------------------------------------------------
		Элемент=ДокументДом.СоздатьЭлемент("SK");  //штрихкод
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(ШКО);                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		//----------------------------------------------------------
		
		Элемент=ДокументДом.СоздатьЭлемент("Nomenklatura");  // наименование номенклатуры
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(ТекСтрока.Номенклатура.Наименование);                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("Kol");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.Количество));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		//
		//Элемент=ДокументДом.СоздатьЭлемент("EDU");
		//ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		//текстДом=ДокументДом.СоздатьТекстовыйУзел(ТекСтрока.Единица.Наименование);                      
		//ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		//  НДС
		Элемент=ДокументДом.СоздатьЭлемент("CENA");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.Цена-(Окр(ТекСтрока.НДС/ТекСтрока.Количество,2,0))));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		
		//  НДС
		Элемент=ДокументДом.СоздатьЭлемент("NDS");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(Окр(ТекСтрока.НДС/ТекСтрока.Количество,2,0)));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		// цена с НДС
		Элемент=ДокументДом.СоздатьЭлемент("CenaSNDS");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.Цена));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("StavkaNDS");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.СтавкаНДС));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("Summa");  //  сумма по строке
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.Сумма));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("SummaNDS");  //  сумма НДС
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.НДС));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("VsegoSummaS_NDS");  //Сумма с НДС
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекСтрока.Всего));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		
		РР=РР+1;
		
	КонецЦикла;
	
	//---------------------------------------------------------------
	ЗаписьДом=Новый ЗаписьDom;
	ЗаписьДом.Записать(ДокументДом,ЗаписьХМЛ);
	ЗаписьХМЛ.Закрыть();	
	
	
	//Сообщить("Сформирован файл обмена. "+ИмяФайлаОбмена);
	
	//----------------------------------------
	//             отправить письмо
	//----------------------------------------
	шапка="";
	
	СообщитьМенеджеру(ИмяФайлаОбмена);
	
	
	Если КритичОшибки.Количество() Тогда
		
		СообщитьКритОшибки();
		
	КонецЕсли;	
	
	
КонецПроцедуры

Процедура СообщитьМенеджеру(ПутьФайла) Экспорт
	
	Менеджер=ДокОбъект.контрагент.Менеджер;
	Профиль= Новый ИнтернетПочтовыйПрофиль;
	// Кухарь А.Ю.  08.09.2022 начало
	//Профиль.АдресСервераPOP3   = "87.236.190.180";
	//Профиль.АдресСервераSMTP   =  "87.236.190.180";
	//Профиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);	
	// Кухарь А.Ю.  08.09.2022 конец
	Профиль.ПортSMTP           = 25;
	
	//Профиль.АутентификацияSMTP = СпособSMTPАутентификации.ПоУмолчанию;
	Профиль.АутентификацияPOP3=СпособPOP3Аутентификации.Обычная;
	Профиль.АутентификацияSMTP=СпособSMTPАутентификации.Login;
	
	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	//Профиль.ПользовательSMTP="*%*%*%";
	//профиль.ПарольSMTP="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	Профиль.ПользовательSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.ПарольSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	
	//----------------------------------------------------------------
	Сообщение=новый интернетПочтовоеСообщение;
	
	
	Сообщение.Получатели.Добавить("ecode@collant.ru"); //+++
	//	Сообщение.Получатели.Добавить("nechaeva@collant.ru");
	Сообщение.Получатели.Добавить("konstantinova@collant.ru");
	
	// Кухарь А.Ю. 26.03.2021 начало
	// 	Если СокрЛП(ДокОбъект.контрагент.код)="SSP-3572" Тогда
		Если СокрЛП(КодКонтрагента)="SSP-3572" Тогда 
	// Кухарь А.Ю. 26.03.2021 конец
	
        //++++
		// ригла
		Сообщение.Получатели.Добавить("RNKL@rigla.ru");
		
		// Кухарь А.Ю. 26.03.2021 начало
		// 	ИначеЕсли (СокрЛП(ДокОбъект.контрагент.код)="SSP-2874") ИЛИ (СокрЛП(ДокОбъект.контрагент.код)="SSP-2507") Тогда
	ИначеЕсли (СокрЛП(КодКонтрагента)="SSP-2874") ИЛИ (СокрЛП(КодКонтрагента)="SSP-2507") Тогда		 
		// Кухарь А.Ю. 26.03.2021 конец
		

		// оз
		Сообщение.Получатели.Добавить("NKL@rigla.ru");
		
	КонецЕсли;	
	
	
	Сообщение.Отправитель="ecode@collant.ru";
	
	ПунктДоставки=ДокОбъект.ПунктДоставки;
	
	Если ПунктДоставки=Неопределено тогда
		ПунктДоставки="";
	Конецесли;	
	
	
	Сообщение.Тема="Подтверждение заказа № "+ДокОбъект.номерЗаказа+" - "+ДокОбъект.контрагент+" - "+ПунктДоставки;
	Строка=Символ(13)+Символ(13)+"       Добрый день!"+Символ(13)+Символ(13)+Строка("Подтверждение заказа № "+ДокОбъект.НомерЗаказа+" . "+ДокОбъект.Ссылка);
	
