	Строка=Строка+Символы.ПС+символы.ПС+"Фактический адрес, пунк доставки: "+ДокОбъект.ПунктДоставки;
	Строка=Строка+Символы.ПС;
	
	Строка=Строка+Символы.ПС+"________________________________________________________________";
	Строка=Строка+Символы.ПС+"ООО <<Единая Европа - Элит>>";
	
	Сообщение.Тексты.Добавить(Строка);
	
	//Сообщение.Вложения.Добавить(ПутьФайла);
	Попытка
		Сообщение.Вложения.Добавить(ПутьФайла);     //+++
	Исключение
		КритичОшибки.Добавить("Не возможно добавить файл выгрузки "+ДокОбъект.ссылка+". Контрагент - "+ДокОбъект.контрагент+".  "+ОписаниеОшибки() );
	КонецПопытки;
	
	Почта= Новый ИнтернетПочта;
	попытка
		Почта.Подключиться(Профиль);
	исключение
		КритичОшибки.Добавить("Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки() );
	конецПопытки;
	Попытка
		Почта.Послать(Сообщение);
	исключение
		КритичОшибки.Добавить("Не возможно отправить сообщение!   "+ОписаниеОшибки() );
	конецПопытки;
	Почта.Отключиться();
	
	Если критичОшибки.Количество()=0 Тогда
		// Сообщить("Файл отправлен покупателю. ");
	конецЕсли;   
	
	//----------------------------------------
	//           удаляем файл отправки
	//----------------------------------------
	
	УдалитьФайлы(ПутьФайла);     //+++
	
КонецПроцедуры

Процедура СообщитьКритОшибки() Экспорт
	
	Профиль= Новый ИнтернетПочтовыйПрофиль;
	
	// Кухарь А.Ю.  08.09.2022 начало
	//Профиль.АдресСервераPOP3   = "87.236.190.180";
	//Профиль.АдресСервераSMTP   =  "87.236.190.180";
	//Профиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);	
	// Кухарь А.Ю.  08.09.2022 конец
	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	//Профиль.ПользовательSMTP="*%*%*%";
	//профиль.ПарольSMTP="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	Профиль.ПользовательSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.ПарольSMTP = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	
	//------------------------------------------------
	// сообщение о критических ошибках
	//------------------------------------------------
	сообщениеКрит=новый интернетПочтовоеСообщение;
	СообщениеКрит.Получатели.Добавить("ecode@collant.ru"); //+++
	СообщениеКрит.Получатели.Добавить("nechaeva@collant.ru");
	
	сообщениеКрит.Отправитель="ecode@collant.ru";
	СообщениеКрит.Тема="Автообмен Ригла. Критические ошибки!";
	Строка="Добрый день!!!"+Символ(13);
	НомСтр=1;
	Если НЕ Ошибки=Неопределено и КритичОшибки.Количество()>0 Тогда
		Для рр=0 по КритичОшибки.Количество()-1 Цикл
			Строка=Строка+Символ(13)+НомСтр+". "+КритичОшибки[рр];
			Строка=Строка+Символ(13);
			НомСтр=НомСтр+1;
		КонецЦикла;
	КонецЕсли;
	
	Строка=Строка+Символ(13)+"________________________________________________________________";
	//-----------------------------------------
	СообщениеКрит.Тексты.Добавить(Строка);
	
	Почта= Новый ИнтернетПочта;
	Почта.Подключиться(Профиль);
	почта.Послать(СообщениеКрит);
	Почта.Отключиться();
	
КонецПроцедуры

