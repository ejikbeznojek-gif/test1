Процедура ОтправитьКаприз()  Экспорт
	
	КрОшибки.Очистить();
	НомЗак=ДокОбъект.номерЗаказа;
	Если СокрЛП(НомЗак)="" Тогда
		
		возврат;
		// не отправляем письмо и не выгружаем эти документы.
		
		//ГСЧ = Новый ГенераторСлучайныхЧисел(255);
		//НомЗак=ГСЧ.СлучайноеЧисло(0, 10000);
		
	КонецЕсли;	
	
	ИмяФайлаОбмена=""+константы.КаталогВнешнихОтчетов.Получить() +"temp\"+ НомЗак+"-"+ДокОбъект.Номер+".xml";
	
	//Сообщить(ИмяФайлаОбмена);
	Файл=Новый Файл(ИмяФайлаОбмена);
	
	Если СтрДлина(СокрЛП(ДокОбъект.ПунктДоставки.НомерМагазина))=0 Тогда
		
		КрОшибки.Добавить("В пункте доставки не проставлен номер магазина (закладка доп.инфо)! Накладная "+ДокОбъект.Номер+" номер заказа -  "+ДокОбъект.номерЗаказа);
		КрОшибки.Добавить("Номер магазина должен быть равен реквизиту ""Код получателя"" из файла заказа покупателя!");
		КрОшибки.Добавить("Выгрузка отменена! Проверьте данные и перезапишите документ для автоотправки.");
		ОтказСтолетов=Истина;
		Возврат;
		
	КонецЕсли;	
	
	
	ЗаписьХМЛ=Новый ЗаписьXML;
	ЗаписьХМЛ.ОткрытьФайл(ИмяФайлаОбмена);   
	ДокументДом=Новый ДокументDom("","ExchangePackage");     //    http://v8.1c./8.1/sample91_DOM
	КорневойЭлемент=ДокументДом.ЭлементДокумента;
	// Order-Header ------------------------------------------
	ЭлементДом=ДокументДом.СоздатьЭлемент("MaterialMovement");
	
	Дата=""+Формат(ДокОбъект.ДатаОтгрузки,"ДЛФ=Д");
	НомерМагазина=""+ДокОбъект.ПунктДоставки.НомерМагазина;
	
	Колво0=4-СтрДлина(НомерМагазина);
	Для ст=1 по колво0 Цикл
		НомерМагазина="0"+НомерМагазина;
	КонецЦикла;
	
	ЭлементДом.УстановитьАтрибут("MCOD1","Единая Европа Элит");
	ЭлементДом.УстановитьАтрибут("DateMove",Строка(Дата));
	ЭлементДом.УстановитьАтрибут("NumOrd",Строка(ДокОбъект.НомерЗаказа));
	ЭлементДом.УстановитьАтрибут("RecPlant",Строка(НомерМагазина));
	ЭлементДом.УстановитьАтрибут("DocNum",Строка(ДокОбъект.Номер));
	
	ТекУзел1=КорневойЭлемент.ДобавитьДочерний(ЭлементДом);
	
	//---------------------------------------------------------
	
	Для Каждого ТекСтрока из ДокОбъект.Товары цикл
		
		Элемент2=ДокументДом.СоздатьЭлемент("Row");
		Если ТекСтрока.Количество=0 ТОгда
			продолжить;
		КонецЕсли;	
		
		//---------------------------------------------
		НомерСтроки=""+ТекСтрока.НомерСтроки+"0";
		Колво0=5-СтрДлина(НомерСтроки);
		Для ст=1 по колво0 Цикл
			НомерСтроки="0"+НомерСтроки;
		КонецЦикла;
		//-------------------
		ШКО="";
		Попытка
			
			ТипШкН = Перечисления.ТипыШтрихКодов.Штука;
			
			Запрос=Новый Запрос;
