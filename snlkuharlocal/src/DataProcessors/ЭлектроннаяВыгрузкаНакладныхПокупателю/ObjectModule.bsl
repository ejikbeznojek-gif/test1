				НомерГТД=НомерГТД+"/3";
			КонецЕсли; 					
		КонецЕсли; 
		
		//СтрокаТН.Страна		= Страна;
		//СтрокаТН.НомерГТД	= НомерГТД;
		//------------------------------------------------	
		
		Элемент2.УстановитьАтрибут("PosNumOrd",Строка(ДокОбъект.НомерЗаказа));
