Функция НайтиШК(Ном)
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ШтрихКоды.Наименование КАК шк
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.ТипШК = &ТипШК
	|	И ШтрихКоды.Владелец = &номенклатура
	|	И ШтрихКоды.ВидШК = &ВидШК";
	
	Запрос.УстановитьПараметр("ТипШК",Перечисления.ТипыШтрихКодов.Штука);
	Запрос.УстановитьПараметр("ВидШК",Перечисления.ВидыШК.Основной);
	
	Запрос.УстановитьПараметр("номенклатура",Ном);
	выборка = запрос.Выполнить().Выбрать();
	Пока выборка.Следующий() Цикл
		
		возврат(выборка.шк);
		
	КонецЦикла; 
	
	
КонецФункции

Функция ПолучитьСвойстваМодели(Модель)
	Запрос=Новый Запрос;
	Запрос.Текст="     
	|ВЫБРАТЬ     
	|     ВЫБОР
	|          КОГДА Объект=&Брэнд ТОГДА 1
	|          КОГДА Объект=&Модель ТОГДА 2
	|          ИНАЧЕ 3
	|     КОНЕЦ КАК Уровень,
	|     Свойство,
	|     Значение
	|ИЗ
	|     РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|     Объект = &Модель ИЛИ Объект = &Брэнд
	|УПОРЯДОЧИТЬ ПО Уровень,Объект";     
	
	Свойства=Новый Структура;
	Свойства.Вставить("ОрганСертификации"," ");
	Свойства.Вставить("СертификатПолноеНаименование"," ");
	Свойства.Вставить("СрокСертификата"," ");
	
	
	Запрос.УстановитьПараметр("Модель",Модель);
	Запрос.УстановитьПараметр("Брэнд",Модель.Родитель);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Попытка
			КодСвойства=СтрЗаменить(Выборка.Свойство,"""","");     
			КодСвойства=СтрЗаменить(Выборка.Свойство," ","");
			
			Свойства.Вставить(КодСвойства,Выборка.Значение);          
		Исключение
			// Сообщить("Ошибочное свойство: "+Выборка.Свойство);
		КонецПопытки;          
	КонецЦикла;     
	
	Возврат Свойства;
	
	
конецФункции

// из ПечатиПакетаДокументов  (правильный расчет)
Функция ПолучитьТаблицуНакладнойНов(Режим="Накладная",СФ=Неопределено,ДокОбъект)
	
	
	ВидШтрихКода="Внутренний";	
	Кратко=0;
	ПечататьШтрихКоды=Истина;
	ТипАртикула=Справочники.АртикулыКонтрагентов.ПустаяСсылка();
	
	ТН=Новый ТаблицаЗначений;
	
	ТН.Колонки.Добавить("Номенклатура");	
	ТН.Колонки.Добавить("Цена");
	ТН.Колонки.Добавить("Количество");
	ТН.Колонки.Добавить("НДС");
	ТН.Колонки.Добавить("НДС1шт");
	ТН.Колонки.Добавить("НДС2шт");
	ТН.Колонки.Добавить("Сумма");
	ТН.Колонки.Добавить("Всего");
	
	
	ИсходнаяТЧ=ДокОбъект.Товары.Выгрузить();		
	
	
	// сначала сворачиваем, потом считаем  -----------------------------------------------
	//
	Если Кратко Тогда
		
		Для Каждого СтрокаТЧ Из ИсходнаяТЧ Цикл                             //*****
			Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли; 
			
			Номенклатура		=СтрокаТЧ.Номенклатура;
			Модель				=Номенклатура.Родитель;
			СтрокаТЧ.Номенклатура=?(Кратко=0,Номенклатура,Модель);
		КонецЦикла;
		
		ИсходнаяТЧ.Свернуть("Номенклатура,Цена","Количество,Сумма,НДС,Всего");
		
	КонецЕсли; 
	//-----------------------------------------------------------------------------------
	
	Для Каждого СтрокаТЧ Из ИсходнаяТЧ Цикл
		Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли; 
		
		Если СтрокаТЧ.Сумма=0 Тогда
			СтавкаНДС=100*ПроцентНДСпоСтавке(ПолучитьРеквизитРодителя(СтрокаТЧ.Номенклатура,"СтавкаНДС"));
		Иначе			
			СтавкаНДС	=Окр(100*(СтрокаТЧ.НДС/СтрокаТЧ.Сумма),0,1);
		КонецЕсли;	
		
		СтрокаТН=ТН.Добавить();		
		
		//Количество	=СтрокаТЧ.Количество;
		//Ндс1шт      =Окр(СтрокаТЧ.Цена*СтавкаНДС/(100+СтавкаНДС),2,0);
		//Цена      	=Окр((СтрокаТЧ.Цена-НДС1шт),2,0);      // уже без  ндс
		//Ндс21шт 	=Окр(Цена*СтавкаНДС/100,2,0);
		//СуммаБезНДс = Цена*Количество;
		//НДС         = Окр(СуммаБезНДс*СтавкаНДС/100,2);
		//Всего       =СуммаБезНДС+НДС;
		
		
		Количество	=СтрокаТЧ.Количество;
		Ндс1шт      =Окр(СтрокаТЧ.Цена*СтавкаНДС/(100+СтавкаНДС),2,0);
		Цена      	=Окр((СтрокаТЧ.Цена-НДС1шт),2,0);      // уже без  ндс
		ЦенаОбщ     =Ндс1шт+цена;
		
		Всего = ЦенаОбщ*Количество;
		Сумма = Цена*Количество;
		НДС   = Всего-Сумма;
		
		//Ндс21шт 	=Окр(Цена*СтавкаНДС/100,2,0);
		//СуммаБезНДс = Цена*Количество;
		//НДС         = Окр(СуммаБезНДс*СтавкаНДС/100,2);
		//Всего       =СуммаБезНДС+НДС;
		
		СтрокаТН.Цена      	=Цена;
		СтрокаТН.Сумма		=Сумма;
		СтрокаТН.НДС1шт		=Ндс1шт;  
		
		//СтрокаТН.Сумма		=Сумма   //БезНДс;
		
		СтрокаТН.НДС		=НДС;  
		СтрокаТН.Всего		=Всего;  
		СтрокаТН.Количество	=Количество;  
		
		Номенклатура		=СтрокаТЧ.Номенклатура;
		Модель				=Номенклатура.Родитель;
		
		СтрокаТН.Номенклатура=?(Кратко=0,СтрокаТЧ.Номенклатура,Модель);     //****
	КонецЦикла;
	//
	//Если Кратко Тогда
	//	ТН.Свернуть("Номенклатура,Цена","Количество,Сумма,НДС,Всего");        //*****
	//КонецЕсли; 
	
	ТН.Колонки.Добавить("НоменклатураПредставление");
	ТН.Колонки.Добавить("Единица");	
	ТН.Колонки.Добавить("ОКЕИ");	
	ТН.Колонки.Добавить("Страна");
	ТН.Колонки.Добавить("НомерГТД");
	ТН.Колонки.Добавить("ШтрихКод");
	ТН.Колонки.Добавить("КодКонтрагента");
	ТН.Колонки.Добавить("КоличествоКоробок");
	ТН.Колонки.Добавить("ШтукВКоробке");
	ТН.Колонки.Добавить("СтавкаНДС");
	//ТН.Колонки.Добавить("Цена");
	
	
	Для Каждого СтрокаТН Из ТН Цикл
		Номенклатура = СтрокаТН.Номенклатура;
		Модель		=?(Кратко,СтрокаТН.Номенклатура,СтрокаТН.Номенклатура.Родитель);
		//Модель		 = Номенклатура;
		//Модель		=?(Кратко,СтрокаТН.Номенклатура,СтрокаТН.Номенклатура.Родитель);       //*****
		
		Если СтрокаТН.Сумма=0 Тогда
			СтрокаТН.СтавкаНДС=100*ПроцентНДСпоСтавке(ПолучитьРеквизитРодителя(СтрокаТН.Номенклатура,"СтавкаНДС"));
		Иначе			
			СтрокаТН.СтавкаНДС	=Окр(100*(СтрокаТН.НДС/СтрокаТН.Сумма),0,1);
		КонецЕсли;			
		
		СтрокаТН.Единица	="шт.";			
		СтрокаТН.ОКЕИ		="796";
		
		//ГТД
		ГТД=ПолучитьГрупповойПериодическийРеквизит(Модель,"НомерГТД",ДокОбъект.Дата);
		
		Страна	="Россия";
		НомерГТД="--------";
		
		Если ГТД<>Неопределено И Врег(""+ГТД.СтранаПроисхождения)<>"РОССИЯ" И НЕ ПустаяСтрока(""+ГТД.СтранаПроисхождения) Тогда
			Страна		=""+ГТД.СтранаПроисхождения;
			НомерГТД	=СокрЛП(""+ГТД.Наименование);
		КонецЕсли;
		
		Если Страна<>"Россия" И СтрДлина(НомерГТД)<25 Тогда			
			Если СтрДлина(НомерГТД)<23 Тогда
				Сообщить("Кривой ГТД !!! Товар: """+СтрокаТН.Номенклатура+""", ГТД: """+НомерГТД+""" !");		
			Иначе
				Сообщить("Отсутствует 4-ый сегмент ГТД !!! Товар: """+СтрокаТН.Номенклатура+""", ГТД: """+НомерГТД+""" !");
				
				НомерГТД=НомерГТД+"/3";
			КонецЕсли; 					
		КонецЕсли; 
		
		СтрокаТН.Страна		= Страна;
		СтрокаТН.НомерГТД	= НомерГТД;
		
		Если ПечататьШтрихКоды Тогда
			Если ВидШтрихКода="Внутренний" Тогда
				СтрокаТН.ШтрихКод=?(Кратко,СокрЛП(СтрокаТН.Номенклатура.Код77),Прав(ПолучитьШтрихКодТовара(СтрокаТН.Номенклатура),6));			
			ИначеЕсли ВидШтрихКода="Контрагент" Тогда
				СтрокаТН.ШтрихКод=ПолучитьАртикулКонтрагента(СтрокаТН.Номенклатура,ТипАртикула);				
			ИначеЕсли ВидШтрихКода="ШтрихКод" Тогда
				СтрокаТН.ШтрихКод=ПолучитьШтрихКодТовара(СтрокаТН.Номенклатура);
			КонецЕсли;			
		КонецЕсли;				
		СтрокаТН.ШтукВКоробке=0;
		Если Номенклатура.ШтукВКоробке<>Null Тогда
			СтрокаТН.ШтукВКоробке=Номенклатура.ШтукВКоробке;  //Модель.ШтукВКоробке;
		конецЕсли;   
		Если СтрокаТН.ШтукВКоробке>0 Тогда
			СтрокаТН.КоличествоКоробок=СтрокаТН.Количество/СтрокаТН.ШтукВКоробке; 			
		КонецЕсли;	
		
		СтрокаТН.НоменклатураПредставление=СокрЛП(Модель.ТипТовара)+" "+СокрЛП(Модель.Родитель.Брэнд)+" "+СокрЛП(Модель.КодПроизводителя)+" "+Номенклатура.Наименование;		
	КонецЦикла; 
	
	Возврат ТН;
КонецФункции // ПолучитьТаблицуНакладнойНов()

Функция ПолучитьАртикулКонтрагента(Номенклатура,ВыбТипАртикула)
	Если ВыбТипАртикула=Неопределено ИЛИ ВыбТипАртикула.Пустая() Тогда Возврат "" КонецЕсли; 
	
	Выборка = Справочники.АртикулыКонтрагентов.Выбрать(,Номенклатура,Новый Структура("ТипАртикула",ВыбТипАртикула));
	Пока Выборка.Следующий() Цикл
		Если Не ПустаяСтрока(Выборка.Наименование) Тогда
			Возврат СокрЛП(Выборка.Наименование);		
		КонецЕсли;		
	КонецЦикла;
	
	Если НЕ Номенклатура.ЭтоГруппа Тогда
		Возврат ПолучитьАртикулКонтрагента(Номенклатура.Родитель,ВыбТипАртикула);	
	Иначе
		Возврат "";
	КонецЕсли;	
КонецФункции //ПолучитьАртикулКонтрагента(Номенклатура,ТипАртикула) 

Процедура ВыгрузитьНакНов(НаклРНК)
	
	Если СтрДлина(НаклРНК.ПунктДоставки.НомерМагазина)=0 ТОгда
		Сообщить("Для накладной "+НаклРНК+" - "+НаклРНК.ПунктДоставки+ " в пункте доставки не проставлен номер магазина. Выгрузка отменена!");
		КритичОшибкиСтолетов.Добавить("Для накладной "+НаклРНК+" - "+НаклРНК.ПунктДоставки+ " в пункте доставки не проставлен номер магазина. Выгрузка отменена!" );
		ОтказСтолетов=Истина;
		возврат;
	КонецЕсли;	
	
	ТабДокСуммы=ПолучитьТаблицуНакладнойНов("Накладная",Неопределено,НаклРНК);
	ДатаДок=НаклРНК.Дата;
	НомерДок=НаклРНК.Номер;
	НомерМагазина=НаклРНК.ПунктДоставки.НомерМагазина;
	НомерЗаказа=НаклРНК.НомерЗаказа;
	ДатаЗаказа=НаклРНК.ДатаЗаказа;
	
	
	//          НаклРНК.Дата;
	////-------------------------------------------------------
	//// подсчитываем общие итоги
	Таб = Новый ТаблицаЗначений;
	Таб=ТабДокСуммы.Скопировать();
	
	ИтСумм=Таб.Итог("Всего");
	ИтОбщНДС=Таб.Итог("НДС");
	ИтОбщ=Таб.Итог("Сумма");
	Таб.Свернуть("СтавкаНДС","НДС,Сумма");
	Для каждого Ст Из Таб Цикл
		
		Если Ст.ставкаНДС=18 Тогда
			Ит18=Ст.Сумма;
			Ит18Ндс=Ст.НДС;
		КонецЕсли;
		
		Если Ст.ставкаНДС=10 Тогда
			Ит10=Ст.Сумма;
			Ит10Ндс=Ст.НДС;
		КонецЕсли;
		
		Если Ст.ставкаНДС=0 Тогда
			Ит0=Ст.Сумма;
			Ит0Ндс=Ст.НДС;
		КонецЕсли; 
		
	КонецЦикла;
	
	////-------------------------------------------------------
	//// дата и номер счет фактуры
	
	СФ=Неопределено;
	СФДата=" ";	
	СФНомер="0";
	
	СФ=СчетФактураНакладной(НаклРНК.Ссылка,НаклРНК.Организация);
	
	Если СФ.Пустая() Тогда
		//Сообщить("Для документа не заведена счет-фактура, параметры не проставлены! ");
	Иначе
		СФДата=СФ.Дата;	
		СФНомер=СФ.Номер;
	КонецЕсли;	
	
	
	//-------------------------------------------------------
	
	БД=Новый XBase;
	
	БД.Кодировка=КодировкаXBase.OEM;
	
	БД.поля.Добавить("NDOC","C",20);       //Ном.Док
	БД.поля.Добавить("DATEDOC","D",8);     //Дата.Док
	БД.поля.Добавить("CODEPST","C",12);    //КодТовараПоставщика
	БД.поля.Добавить("EAN13","C",13);      //ЗаводскойБарКод
	БД.поля.Добавить("PRICE1","N",9,2);    //Цена Производ c НДС
	БД.поля.Добавить("PRICE1N","N",9,2);    //Цена Производ без НДС
	БД.поля.Добавить("SUMNDS1","N",9,2);    //Сумма НДС производителя
	
	БД.поля.Добавить("PRICE2","N",9,2);    //Цена прайся с ндс
	БД.поля.Добавить("PRICE2N","N",9,2);   //Цена прайса без ндс
	БД.поля.Добавить("SUMNDS2","N",9,2);   //Сумма НДС прайса 
	
	БД.поля.Добавить("QNT","N",9,2);         //Количество
	БД.поля.Добавить("SER","C",20);        //Серия
	БД.поля.Добавить("GDATE","D",8);       //Срок годности
	БД.поля.Добавить("DATEMADE","D",8);    //Дата изготовления
	БД.поля.Добавить("NAME","C",80);       //Наименование
	БД.поля.Добавить("CNTR","C",15);       //страна изг
	БД.поля.Добавить("FIRM","C",40);       //фирма изгот
	БД.поля.Добавить("QNTPACK","N",8);    //кол в упак
	БД.поля.Добавить("NDS","N",9.2);         //ставка ндс
	БД.поля.Добавить("NSP","N",9.2);         //ставка нсп
	БД.поля.Добавить("GNVLS","N",9);         //признак ЖНВЛС
	БД.поля.Добавить("REGPRC","N",9,2);      //цена гос регистрац
	БД.поля.Добавить("DATEPRC","D",8);         //дата рег цены
	БД.поля.Добавить("NUMGTD","C",30);     //Номер ГТД
	БД.поля.Добавить("SERTIF","C",80);     //сертиф Пример "РОСС.IN.ФМ01.Д91123"
	БД.поля.Добавить("SERTDATE","D",8);    //Срок действия сертификата
	БД.поля.Добавить("SERTORG","C",80);    //Орган Сертификации
	БД.поля.Добавить("SUMPAY","N",9,2);    //Сумма отпускная с ндс по строчке
	БД.поля.Добавить("SUMNDS10","N",9,2);  //сумма ндс 10%
	БД.поля.Добавить("SUMNDS20","N",9,2);  //сумма ндс 18%
	БД.поля.Добавить("SUM10","N",9,2);     //сумма без ндс 10%
	БД.поля.Добавить("SUM20","N",9,2);     //сумма без ндс 18%
	БД.поля.Добавить("SUM0","N",9,2);      //сумма без ндс 0%
	
	БД.поля.Добавить("EXCHCODE","N",1);      //код валюты 0-руб 1-$ 2-EU
	БД.поля.Добавить("ERATE","N",9,2);      //курс на данную накладную
