КонецФункции // МП_ПараметрыОбработки()

// Процедура - МП Заполнить параметры обработки
// Заполняет параметры стандартными стандартными значениями текущего объекта.
// 
// Параметры:
//  СтруктураПараметров - Структура - структура параметров обработки данных сервиса Яндекс Маркет
Процедура МП_ЗаполнитьПараметрыОбработки(СтруктураПараметров) Экспорт
	
	// Общие настройки для работы в модели сервиса
	СтруктураПараметров.ДополнительныеПараметры	   = КоннекторHTTP.НовыеПараметры();
	
	// Инициализируем параметры библиотеки
	СтруктураПараметров.ДополнительныеПараметры.Заголовки =
		ОбменМаркетПлейс.МП_Яндекс_ВернутьЗаголовкиHTTP(СтруктураПараметров.МаркетПлейс);
	СтруктураПараметров.ДополнительныеПараметры.ПараметрыПреобразованияJSON.ВариантЗаписиДатыJSON =
		ВариантЗаписиДатыJSON.ЛокальнаяДата;
	СтруктураПараметров.ДополнительныеПараметры.ПараметрыПреобразованияJSON.ПрочитатьВСоответствие = Ложь;
	СтруктураПараметров.ДополнительныеПараметры.ПараметрыПреобразованияJSON.ИменаСвойствСоЗначениямиДата =
		СтрРазделить("creationDate,shipmentDate", ",");
	
	// Ихсанов Д. А. Начало 25.06.2026 Изменение 0000000221 от 25.06.2026 13:13:13: e1cib/data/Документ.Изменение?ref=89690050568f680711f1707e79109a75
	СтруктураПараметров.ПолеСоответствияКодаТовара = "ШККонтрагента";
	// Ихсанов Д. А. Конец 25.06.2026
	
	// Инициализируем параметры заполнения данных по заказу
	СтруктураПараметров.ИменаСтруктурДанных.Вставить("ТелоЗаказа", "orders");
	СтруктураПараметров.ИменаСтруктурДанных.Вставить("Товары", "items");
	
	СтруктураПараметров.ИменаПолей.Вставить("ВнешнийИдентификатор", "orderId");
	СтруктураПараметров.ИменаПолей.Вставить("ДатаСоздания", "creationDate");
	СтруктураПараметров.ИменаПолей.Вставить("ДатаОтгрузки", "ДанныеЗаказа.delivery.shipment.shipmentDate");
	
	СтруктураПараметров.ИменаПолейТоваров.Вставить("Идентификатор", "id");
	СтруктураПараметров.ИменаПолейТоваров.Вставить("ШККонтрагента", "offerId");
	
	СтруктураПараметров.ПоляТовараИзДанныхЗаказа.Вставить("ВнешнийИдентификатор",
		СтруктураПараметров.ИменаПолей["ВнешнийИдентификатор"]);
	СтруктураПараметров.ПоляТовараИзДанныхЗаказа.Вставить("Статус", "status");
	СтруктураПараметров.ПоляТовараИзДанныхЗаказа.Вставить("ДополнительныйСтатус", "substatus");
	
	СтруктураПараметров.АгрегируемыеПоля.Вставить("Сумма", 0);
	СтруктураПараметров.АгрегируемыеПоля.Вставить("ЗаказПоЮрЛицу", Ложь);
	// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
	СтруктураПараметров.АгрегируемыеПоля.Вставить("Интервал", "");
	// Ихсанов Д. А. Конец 18.06.2026
	
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("НомерЗаказа");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("НомерОтгрузки");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("НомерПосылки");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("СостояниеУКлиента");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("ДополнительныйСтатус");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("ШтрихКод");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("Количество");
	СтруктураПараметров.АгрегируемыеПоляТовара.Вставить("Цена");
	
КонецПроцедуры // МП_ЗаполнитьПараметрыОбработки()

// Функция - МП Адрес запроса заказы
// 
// Параметры:
//  ИдентификаторКабинета - Строка - Идентификатор личного кабинета (BusinessId)
// 
// Возвращаемое значение:
//  Строка - Адрес запроса
Функция МП_АдресЗапроса_СписокЗаказов(ИдентификаторКабинета) Экспорт
	
	Возврат СтрШаблон("/v1/businesses/%1/orders", ИдентификаторКабинета);
	
КонецФункции // МП_АдресЗапроса_СписокЗаказов()

// Функция - МП Адрес запроса создать посылку
// 
// Параметры: РеквизитыМаркетПлейс - Структура - Структура с данными для составления адреса запроса
//  ИДКомпании - Строка - ИДКомпании
//  НомерЗаказа - Строка - Номер заказа
// 
// Возвращаемое значение:
//  Строка - Адрес запроса
Функция МП_АдресЗапроса_СоздатьПосылку(ИДКомпании, НомерЗаказа) Экспорт
	
	Возврат СтрШаблон("/v2/campaigns/%1/orders/%2/boxes", ИДКомпании, НомерЗаказа);
	
КонецФункции // МП_АдресЗапроса_СоздатьПосылку()

// Функция - МП Адрес запроса этикетки
// 
// Параметры: РеквизитыМаркетПлейс - Структура - Структура с данными для составления адреса запроса
//  ИДКомпании - Строка - ИДКомпании
//  НомерЗаказа - Строка - Номер заказа
//  НомерОтгрузки - Число - Номер отгрузки
//  НомерПосылки - Строка - Номер посылки
// 
// Возвращаемое значение:
//  Строка - Адрес запроса
Функция МП_АдресЗапроса_Этикетки(ИДКомпании, НомерЗаказа, НомерОтгрузки = 0, НомерПосылки) Экспорт
	
	Возврат СтрШаблон("/v2/campaigns/%1/orders/%2/delivery/shipments/%3/boxes/%4/label",
		ИДКомпании, НомерЗаказа, НомерОтгрузки, НомерПосылки);
	
КонецФункции // МП_АдресЗапроса_Этикетки()

// Функция - МП Адрес запроса подтверждение сборки
// 
// Параметры: РеквизитыМаркетПлейс - Структура - Структура с данными для составления адреса запроса
//  ИДКомпании - Строка - ИДКомпании
//  НомерЗаказа - Строка - Номер заказа
// 
// Возвращаемое значение:
//  Строка - Адрес запроса
Функция МП_АдресЗапроса_ИзменениеСтатусаОдногоЗаказа(ИДКомпании, НомерЗаказа) Экспорт
	
	Возврат СтрШаблон("/v2/campaigns/%1/orders/%2/status",
		ИДКомпании, НомерЗаказа);
	
КонецФункции // МП_АдресЗапроса_ПодтверждениеСборки()

// Функция - МП Восстановление значений полей JSON
// Вспомогательная функция, вызываемая при чтении JSON объекта. Необходима для коррекции
// типов данных и значений полей.
// 
// Параметры:
//  Свойство - Строка - Имя поля структуры JSON для обработки.
//  Значение - Строка, Число - Значения поля для обработки.
//  ДополнительныеПараметры - Структура - Перечень дополнительных параметров для обработки.
// 
// Возвращаемое значение:
//  Неопределено, Строка, Число - Строка, Число, Дата, Любая ссылка.
Функция МП_ВосстановлениеЗначенийПолейJSON(Свойство, Значение, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры.Свойство("ИменаПолейДляВосстановления") Тогда
		Если ТипЗнч(ДополнительныеПараметры.ИменаПолейДляВосстановления) = Тип("Строка") Тогда
			МассивПолейДляВосстановления = СтрРазделить(СтрЗаменить(
				ДополнительныеПараметры.ИменаПолейДляВосстановления, " ", ""), ",", Ложь);
		Иначе
			МассивПолейДляВосстановления = ДополнительныеПараметры.ИменаПолейДляВосстановления;
		КонецЕсли;

		Если МассивПолейДляВосстановления.Найти(Свойство) = Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
		
		Результат = Неопределено;
		УстановитьБезопасныйРежим(Истина);
		Выполнить(ДополнительныеПараметры.ОбработчикПолейВосстановления[Свойство]);
		УстановитьБезопасныйРежим(Ложь);
		Если Результат <> Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
	Иначе
		Результат = Неопределено;
		УстановитьБезопасныйРежим(Истина);
		Выполнить(ДополнительныеПараметры[Свойство]);
		УстановитьБезопасныйРежим(Ложь);
		Если Результат <> Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции // МП_ВосстановлениеЗначенийПолейJSON()

// Функция - МП Преобразование значений полей JSON
// Вспомогательная функция, вызываемая при записи JSON объекта. Необходима для коррекции
// типов данных и значений полей.
// 
// Параметры:
//  Свойство - Строка - Имя поля структуры JSON для обработки.
//  Значение - Строка, Число - Значения поля для обработки.
//  ДополнительныеПараметры - Структура - Перечень дополнительных параметров для обработки.
//  Отказ - Булево - 
// 
// Возвращаемое значение:
//  Строка, Число - Строка, Число, Дата, Любая ссылка.
Функция МП_ПреобразованиеЗначенийПолейJSON(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт
	
	Возврат Значение;
	
КонецФункции // МП_ПреобразованиеЗначенийПолейJSON()

// Функция - Получить посылки по номерам заказов
// 
// Параметры:
//  МассивЗаказов - Массив из Строка - Массив заказов для получения данных по посылкам
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Яндекс Маркет
// 
// Возвращаемое значение:
//  Соответствие Из Строка - Данные по посылкам, ключ - это номер заказа, в значении структура с данными посылки
Функция ПолучитьПосылкиПоНомерамЗаказов(МассивЗаказов, ПараметрыОбработки) Экспорт
	
	ХешКартаЗаказовИПосылок = Новый Соответствие;
	
	Для каждого ДанныеЗаказа из МассивЗаказов Цикл
		Если Не ДанныеЗаказа.delivery.Свойство("boxesLayout") Тогда
			Продолжить
		КонецЕсли;
		
		КоличествоТовара = 0;
		Для каждого ДанныеТовара из ДанныеЗаказа.items Цикл
			КоличествоТовара = КоличествоТовара + ДанныеТовара.count;
		КонецЦикла;
		
		Если КоличествоТовара <> ДанныеЗаказа.delivery.boxesLayout.Количество() Тогда
			Продолжить
		КонецЕсли;
		
		ДанныеПосылок = Новый Соответствие;
		лИндекс = ДанныеЗаказа.delivery.boxesLayout.ВГраница();
		Пока лИндекс >= 0 Цикл
			ДанныеПоЭкземпляруПосылки = ДанныеЗаказа.delivery.boxesLayout[лИндекс];
			лИндекс = лИндекс - 1;
			
			Если Не ДанныеПоЭкземпляруПосылки.Свойство("items") Тогда
				Продолжить;
			КонецЕсли;
			
			Для каждого ДанныеТовара из ДанныеПоЭкземпляруПосылки.items Цикл
				СтруктураПосылки = ДанныеПосылок[Формат(ДанныеТовара.id, "ЧГ=")];
				Если СтруктураПосылки = Неопределено Тогда
					СтруктураПосылки = Новый Соответствие;
					
					ДанныеПосылок.Вставить(Формат(ДанныеТовара.id, "ЧГ="), СтруктураПосылки);
				КонецЕсли;
				
				СтруктураТовара = Новый Структура("shipmentId");
				СтруктураТовара.Вставить("boxId",	ДанныеПоЭкземпляруПосылки.boxId);
				СтруктураТовара.Вставить("orderId", ДанныеЗаказа.orderId);
				СтруктураТовара.Вставить("barcode", ДанныеПоЭкземпляруПосылки.barcode);
				
				Если ДанныеЗаказа.delivery.shipment.Свойство("id") Тогда
					СтруктураТовара.Вставить("shipmentId", ДанныеЗаказа.delivery.shipment.id);
				КонецЕсли;
				
				СтруктураПосылки.Вставить(ДанныеПоЭкземпляруПосылки.boxId, СтруктураТовара);
			КонецЦикла;
		КонецЦикла;
		
		ХешКартаЗаказовИПосылок.Вставить(ДанныеЗаказа.orderId, ДанныеПосылок);
	КонецЦикла;
	
	Возврат ХешКартаЗаказовИПосылок;
	
КонецФункции // ПолучитьПосылкиПоНомерамЗаказов()

#КонецЕсли

#КонецОбласти
