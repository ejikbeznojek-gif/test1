
&НаКлиенте
Процедура ПолучитьСписокФайлов(Команда)
	ТекДанные = Элементы.BucketObjects.ТекущиеДанные;
	Если ТекДанные <> Неопределено И ТекДанные.IsFolder Тогда
		Префикс = СокрЛП(ТекДанные.key); 			
	Иначе
		Префикс = "";
	КонецЕсли; 
	
	ПолучитьСписокФайлов_НаСервере(Префикс);
КонецПроцедуры

&НаСервере
Процедура ПолучитьСписокФайлов_НаСервере(Префикс)
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	ОбработкаОбъект.ПолучитьСписокФайлов(Префикс);	
	
	Объект.BucketObjects.Загрузить(ОбработкаОбъект.BucketObjects.Выгрузить());	
КонецПроцедуры


