Функция ПроверитьДокументНаОтсутствиеБлокировок(Знач Документ)  Экспорт
	РезПроверки = Новый Структура("Успех,Ошибки,ДопТекстОшибки",истина, Новый Массив,""); 
	Запрос = Новый Запрос; 
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаданиеНабора") Тогда 
		//Данилова Е.В. 11.03.2026 SNL-159  изменение запроса с учетом проходных накладных
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
		|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
		|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
		|ПОМЕСТИТЬ ВТБлокировки
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
		|			&ТекущаяДата,
		|			Склад = &Склад
		|				ИЛИ Склад = &СкладФизСклад) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНабора.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТЗНБВНаборе
		|ИЗ
		|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
		|		ПО ЗаданиеНабора.ДокументОснование = ПланНабора.Ссылка
		|ГДЕ
		|	ПланНабора.ПроходнаяНакладная
		|	И ПланНабора.Ссылка = &ПланНабора
		|	И ЗаданиеНабора.Проведен
		|	И ЗаданиеНабора.СостояниеНакладной В(&СостоянияВНаборе)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНабора.Склад КАК Склад,
		|	ЗаданиеНабора.Ссылка КАК Ссылка,
		|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТНоменклатураЗНБОстальные
		|ИЗ
		|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
		|		ПО ЗаданиеНабора.ДокументОснование = ПланНабора.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|		ПО ЗаданиеНабора.Ссылка = ЗаданиеНабораТовары.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗНБВНаборе КАК ВТЗНБВНаборе
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ПланНабора.ПроходнаяНакладная
		|	И ПланНабора.Ссылка = &ПланНабора
		|	И ЗаданиеНабора.Проведен
		|	И ЗаданиеНабора.СостояниеНакладной В(&СостоянияДоОжиданияНабора)
		|	И ВТЗНБВНаборе.Ссылка ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНабора.Склад КАК Склад,
		|	ЗаданиеНабора.Ссылка КАК Ссылка,
		|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТоварыДокумента
		|ИЗ
		|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
		|		ПО (ЗаданиеНабора.ДокументОснование = ПланНабора.Ссылка)
		|ГДЕ
		|	ЗаданиеНабора.Ссылка = &Ссылка
		|	И НЕ ПланНабора.ПроходнаяНакладная
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТНоменклатураЗНБОстальные.Склад,
		|	ВТНоменклатураЗНБОстальные.Ссылка,
		|	ВТНоменклатураЗНБОстальные.Номенклатура
		|ИЗ
		|	ВТНоменклатураЗНБОстальные КАК ВТНоменклатураЗНБОстальные
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТоварыДокумента.Ссылка КАК Ссылка,
		|	ВТТоварыДокумента.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТТоварыДокумента КАК ВТТоварыДокумента
		|ГДЕ
		|	(ВТТоварыДокумента.Склад В
		|				(ВЫБРАТЬ
		|					ВТБлокировки.Склад
		|				ИЗ
		|					ВТБлокировки)
		|			ИЛИ ВТТоварыДокумента.Склад.ФизическийСклад В
		|				(ВЫБРАТЬ
		|					ВТБлокировки.Склад
		|				ИЗ
		|					ВТБлокировки))
		|	И ВТТоварыДокумента.Номенклатура В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТБлокировки.Номенклатура
		|			ИЗ
		|				ВТБлокировки)";
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("Склад", Документ.Склад);
		Запрос.УстановитьПараметр("СкладФизСклад", Документ.Склад.ФизическийСклад); 
		//++Данилова Е.В. 11.03.2026 SNL-159 
		Запрос.УстановитьПараметр("ПланНабора", Документ.ДокументОснование);
		
		СостоянияДоОжиданияНабора = Новый Массив;
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.ПолученоСкладом); 
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.СформированыЗаданияНабора);
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.ПроверенаПоОстаткам);
		
		Запрос.УстановитьПараметр("СостоянияДоОжиданияНабора", СостоянияДоОжиданияНабора);
		
		СостоянияВНаборе = Новый Массив;
		СостоянияВНаборе.Добавить(перечисления.СостоянияНакладной.ОжиданиеНабора); 
		СостоянияВНаборе.Добавить(перечисления.СостоянияНакладной.ВНаборе);
		Запрос.УстановитьПараметр("СостоянияВНаборе", СостоянияВНаборе);
		//--Данилова Е.В. 11.03.2026 
	Иначе
		Возврат РезПроверки; 
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	
	РезПроверки.Успех =  РезультатЗапроса.Пустой();
	//++Данилова Е.В. 11.03.2026 SNL-159
	ПроходнаяНакладная = ПолучитьРеквизитШапки(Документ.ДокументОснование,"ПроходнаяНакладная"); 
	Если  ПроходнаяНакладная
		И НЕ РезультатЗапроса.Пустой() Тогда
		МассивТоваровБлок = Новый Массив; 
		МассивЗНБ = Новый Массив; 
		Выборка = РезультатЗапроса.Выбрать(); 
		Пока Выборка.Следующий() Цикл
			Если МассивТоваровБлок.Найти(Выборка.Номенклатура) = Неопределено Тогда
				
				МассивТоваровБлок.Добавить(Выборка.Номенклатура);	
				
			КонецЕсли; 
			
			Если МассивЗНБ.Найти(Выборка.ссылка) = Неопределено Тогда
				
				МассивЗНБ.Добавить(Выборка.ссылка);	
				
			КонецЕсли; 
			
		КонецЦикла;
		РезПроверки.Ошибки = МассивТоваровБлок;
		РезПроверки.ДопТекстОшибки = "Проходная накладная!!! Заблокированные товары по ЗНБ:" + СтрСоединить(МассивЗНБ,",");
		
		Возврат РезПроверки;
	Иначе 
		
		
		МассивТоваровБлок = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура");  
		РезПроверки.Ошибки = МассивТоваровБлок; 
		
		Возврат РезПроверки;
	КонецЕсли;
	//--Данилова Е.В. 11.03.2026
КонецФункции // ПроверитьДокументНаНаличиеБлокировок()

Функция ПроверитьВозможностьЗаполненияИНВ(ДокОбъект,МассивТоваров,МассивСкладов) ЭКСПОРТ
	МассивОшибок  = Новый Массив; 
	ЗНБИсключения = новый Массив; 
	
	РезультатОтработки = новый Структура("Успех,Ошибки,Данные",Истина,Новый Массив, новый Массив); 
	Если ДокОбъект.Метаданные().Имя = "Инвентаризация" Тогда
		Если ДокОбъект.СостояниеНакладной <> Перечисления.СостоянияНакладной.ВРаботе Тогда
			
			МассивОшибок.Добавить("Заполнять остатки можно только в состоянии ""в работе"" "); 	
			РезультатОтработки.Успех = Ложь; 
			РезультатОтработки.ошибки = МассивОшибок; 
			Возврат РезультатОтработки; 
		КонецЕсли; 		
	КонецЕсли;   	 
	
	//ЕстьБлокировка = ЕстьблокировкаПоИНВ(МассивСкладов,МассивТоваров);
	//
	//Если НЕ ЕстьБлокировка Тогда
	//	
	//	МассивОшибок.Добавить("Для работы с инвентаризацией необходимо создать документ блокировки! Активной блокировки не найдено!"); 	
	//	РезультатОтработки.Успех = Ложь; 
	//	РезультатОтработки.ошибки = МассивОшибок;
	//	
	//	Возврат РезультатОтработки; 
	//	
	//КонецЕсли;
	//++Данилова Е.В. 12.02.2026 по письму 
	Индекс = МассивСкладов.Найти(Справочники.Склады.ПустаяСсылка()); 
	Если Индекс <> неопределено Тогда
	
		МассивСкладов.Удалить(Индекс); 	
	
	КонецЕсли;
	//--Данилова Е.В. 12.02.2026  
	
	//Данилова Е.В. 11.03.2026 SNL-159 
	//изменение запроса с учетом проходных накладных 
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В ИЕРАРХИИ (&Склады)
	|			ИЛИ Склады.ФизическийСклад В ИЕРАРХИИ (&Склады))
	|	И НЕ Склады.ПометкаУдаления
	|	И НЕ Склады.Ссылка = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&Номенклатура)
	|	И НЕ Номенклатура.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБПомежуточная
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланНабора.Ссылка КАК ПланНабора,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.СостояниеНакладной КАК СостояниеНакладной
	|ПОМЕСТИТЬ ВТЗаблокированныеТоварыПоПроходнаяНакладная
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
	|		ПО (ПланНабора.ПроходнаяНакладная)
	|			И (ЗаданиеНабора.ДокументОснование = ПланНабора.Ссылка)
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияПроверкиЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.Склад КАК Склад,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.Номенклатура КАК Номенклатура,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.ЗНБ КАК ЗНБПроходная
	|ПОМЕСТИТЬ ВТАктивныеЗНБ
	|ИЗ
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная КАК ВТЗаблокированныеТоварыПоПроходнаяНакладная
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабораДокумент
	|		ПО ВТЗаблокированныеТоварыПоПроходнаяНакладная.ПланНабора = ПланНабораДокумент.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|		ПО (ПланНабораДокумент.Ссылка = ЗаданиеНабора.ДокументОснование)
	|			И (ЗаданиеНабора.СостояниеНакладной В (&СостоянияПроверкиЗНБ))
	|			И (ЗаданиеНабора.Проведен)
	|			И (ЗаданиеНабора.Ссылка <> ВТЗаблокированныеТоварыПоПроходнаяНакладная.ЗНБ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТАктивныеЗНБПомежуточная КАК ВТАктивныеЗНБ
	|		ПО (ВТАктивныеЗНБ.ЗНБ = ЗаданиеНабора.Ссылка)
	|ГДЕ
	|	ВТАктивныеЗНБ.ЗНБ ЕСТЬ NULL
	|	И (ЗаданиеНабора.СостояниеНакладной В (&СостоянияЗНБ)
	|			ИЛИ ВТЗаблокированныеТоварыПоПроходнаяНакладная.СостояниеНакладной В (&СостоянияЗНБ))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТАктивныеЗНБ.ЗНБ,
	|	ВТАктивныеЗНБ.Склад,
	|	ВТАктивныеЗНБ.Номенклатура,
	|	ВТАктивныеЗНБ.ЗНБ
	|ИЗ
	|	ВТАктивныеЗНБПомежуточная КАК ВТАктивныеЗНБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад
	|ПОМЕСТИТЬ ВТБлокировкиВсе
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
	|			,
	|			Склад В
