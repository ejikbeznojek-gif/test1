  Функция ПроходнаяНакладнаяПроверкаРНК(Знач РНК) Экспорт
 
 	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПланНабора.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПланНабора КАК ПланНабора
		|ГДЕ
		|	ПланНабора.ПроходнаяНакладная
