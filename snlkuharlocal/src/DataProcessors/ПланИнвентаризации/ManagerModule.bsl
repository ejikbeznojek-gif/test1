Функция ЕстьблокировкаПоТоварамСклада(Склады,МассивТоваров,ПланНабораЗНБ = неопределено,ОтборПоСостояниямЗНБ = ложь) Экспорт
	Если ТипЗнч(Склады) = Тип("СправочникСсылка.Склады") Тогда 	
		МассивСкладов = Новый Массив; 	
		МассивСкладов.Добавить(Склады);
		Если ЗначениеЗаполнено(Склады.ФизическийСклад) Тогда
			
			МассивСкладов.Добавить(Склады.ФизическийСклад);	
			
		КонецЕсли;

	ИначеЕсли ТипЗнч(Склады) = Тип("Массив") Тогда 
		МассивСкладов = Склады; 
	КонецЕсли;
	//++Данилова Е.В. 11.03.2026 SNL-159 
	Если ПланНабораЗНБ <> неопределено Тогда
		Запрос = Новый Запрос;
		Если ОтборПоСостояниямЗНБ Тогда 
			
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЗаданиеНабора.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТЗНБВНаборе
			|ИЗ
			|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ВТПН
			|		ПО ЗаданиеНабора.ДокументОснование = ВТПН.Ссылка
			|			И (ВТПН.ПроходнаяНакладная)
			|			И (ВТПН.Ссылка = &ПланНабора)
			|ГДЕ
			|	ЗаданиеНабора.Проведен
			|	И ЗаданиеНабора.СостояниеНакладной В(&СостоянияВНаборе)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Спр.Ссылка КАК Номенклатура
			|ИЗ
			|	Справочник.Номенклатура КАК Спр
			|ГДЕ
			|	Спр.Ссылка В ИЕРАРХИИ(&МассивТоваров)
			|	И НЕ &ПроходнаяНакладная
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЗаданиеНабораТовары.Номенклатура
			|ИЗ
			|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ВТПН
			|		ПО ЗаданиеНабора.ДокументОснование = ВТПН.Ссылка
			|			И (ВТПН.ПроходнаяНакладная)
			|			И (ВТПН.Ссылка = &ПланНабора)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
			|		ПО ЗаданиеНабора.Ссылка = ЗаданиеНабораТовары.Ссылка
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗНБВНаборе КАК ВТЗНБВНаборе
			|		ПО (ИСТИНА)
			|ГДЕ
			|	ЗаданиеНабора.Проведен
			|	И ЗаданиеНабора.СостояниеНакладной В(&СостоянияДоОжиданияНабора)
			|	И ВТЗНБВНаборе.Ссылка ЕСТЬ NULL";
		Иначе
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Спр.Ссылка КАК Номенклатура
			|ИЗ
			|	Справочник.Номенклатура КАК Спр
			|ГДЕ
			|	Спр.Ссылка В ИЕРАРХИИ(&МассивТоваров)
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	РасходнаяНакладнаяТовары.Номенклатура
			|ИЗ
			|	Документ.%РасходнаяНакладная% КАК РасходнаяНакладная
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ВТПН
			|		ПО РасходнаяНакладная.ссылка = ВТПН.Накладная
			|			И (ВТПН.ПроходнаяНакладная)
			|			И (ВТПН.Ссылка = &ПланНабора)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.%РасходнаяНакладная%.%Товары% КАК РасходнаяНакладнаяТовары
			|		ПО РасходнаяНакладная.Ссылка = РасходнаяНакладнаяТовары.Ссылка
			|ГДЕ
			|	РасходнаяНакладная.Проведен"; 
			
			Накладная 		= ПланНабораЗНБ.Накладная; 
			ВидНакладной	= ОбщегоНазначения_ПИ.ПолучитьИмяДокумента(Накладная); 
 			ЭтоКомплектация = (ВидНакладной="РасходнаяНакладная" И ПолучитьРеквизитШапки(Накладная,"ОтгрузкаКомплектов","Документ")=Истина) или ВидНакладной="Комплектация"; 
			ИмяТЧНакладной=?(ЭтоКомплектация,"Комплектующие","Товары");
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"%РасходнаяНакладная%",ВидНакладной);
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Товары%",ИмяТЧНакладной);
			
		КонецЕсли;
		Запрос.УстановитьПараметр("ПланНабора", ПланНабораЗНБ);
		Запрос.УстановитьПараметр("МассивТоваров", МассивТоваров);
				
		СостоянияДоОжиданияНабора = Новый Массив;
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.ПолученоСкладом); 
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.СформированыЗаданияНабора);
		СостоянияДоОжиданияНабора.Добавить(перечисления.СостоянияНакладной.ПроверенаПоОстаткам);
		
		Запрос.УстановитьПараметр("СостоянияДоОжиданияНабора", СостоянияДоОжиданияНабора);	
		
		СостоянияВНаборе = Новый Массив;
		СостоянияВНаборе.Добавить(перечисления.СостоянияНакладной.ОжиданиеНабора); 
		СостоянияВНаборе.Добавить(перечисления.СостоянияНакладной.ВНаборе);
		
		Запрос.УстановитьПараметр("СостоянияВНаборе", СостоянияВНаборе);
		Запрос.УстановитьПараметр("ПроходнаяНакладная", ПланНабораЗНБ.ПроходнаяНакладная);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если Не РезультатЗапроса.Пустой()  Тогда
			
			МассивТоваров = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура"); 	
		Иначе 
			Возврат Ложь; 
		КонецЕсли;
		
		
	КонецЕсли;
	//--Данилова Е.В. 11.03.2026 
	Запрос = Новый Запрос;
	//++Данилова Е.В. 11.02.2026 HELP-8837 
	запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	//--Данилова Е.В. 11.02.2026 
	Запрос.Текст 	= 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В (&МассивСкладов)
	|			ИЛИ Склады.ФизическийСклад В (&МассивСкладов))
	|	И НЕ Склады.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТБлокировка
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
	|			&ТекущаяДата,
	|			Склад В
	|				(ВЫБРАТЬ
	|					ВТСклады.Ссылка
	|				ИЗ
	|					ВТСклады)) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Спр.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Спр
	|ГДЕ
	|	Спр.Ссылка В ИЕРАРХИИ(&МассивТоваров)
	|	И Спр.Ссылка В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				ВТБлокировка.Номенклатура
	|			ИЗ
	|				ВТБлокировка)
	|;
	| 
	//++Данилова Е.В. 11.02.2026  HELP-8837 
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТБлокировка.Регистратор КАК Блокировка
	|ИЗ
	|	ВТБлокировка КАК ВТБлокировка";
	//--Данилова Е.В. 11.02.2026 
	
	запрос.УстановитьПараметр("МассивСкладов",МассивСкладов); 
	запрос.УстановитьПараметр("МассивТоваров",МассивТоваров);
	запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	//++Данилова Е.В. 11.02.2026  HELP-8837
	//результатЗапроса = Запрос.Выполнить();
	//
	//Возврат НЕ результатЗапроса.Пустой(); 
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;
	РезультатТовары = ПакетЗапросов[2]; 
	РезультатБлокировки = ПакетЗапросов[3];
	МассивТоваровБлокировки =  РезультатТовары.Выгрузить().выгрузитьКолонку("Ссылка"); 
	
	ВыборкаБлокировки =  РезультатБлокировки.Выбрать(); 
	
	Пока ВыборкаБлокировки.Следующий() Цикл
		
		Запрос = Новый Запрос; 
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТБлокировка.номенклатура КАК номенклатура
		|ПОМЕСТИТЬ ВТТоварыБлокировки
		|ИЗ
		|	ВТБлокировка КАК ВТБлокировка
		|ГДЕ
		|	ВТБлокировка.Регистратор = &Блокировка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СпрНом.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК СпрНом
		|ГДЕ
		|	СпрНом.Ссылка В(&МассивТоваров)
		|	И СпрНом.Ссылка В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТТоварыБлокировки.номенклатура
		|			ИЗ
		|				ВТТоварыБлокировки)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокировки";
		
		Запрос.УстановитьПараметр("Блокировка", ВыборкаБлокировки.Блокировка);
		Запрос.УстановитьПараметр("МассивТоваров", МассивТоваровБлокировки);
		
		ТоварыКонкрБлокировки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ссылка"); 
		
		Если ТоварыКонкрБлокировки.Количество() > 0  Тогда
			
			ТекстСообщения = СтрШаблон("Заблокированы товары, блокировка %1, товары : %2",ВыборкаБлокировки.Блокировка,СтрСоединить(ТоварыКонкрБлокировки,Символы.ПС));  
			Сообщить(ТекстСообщения); 	
		
		КонецЕсли; 
		
		
	КонецЦикла;
	
	
	Возврат  НЕ РезультатТовары.Пустой(); 
	//--Данилова Е.В. 11.02.2026 	

КонецФункции // ЕстьблокировкаПоИНВ()

Функция ПроверитьЗНБОжиданиеНабора(Знач ЗНБ) Экспорт 
	
	РезПроверки = Новый Структура("Успех,Ошибки",истина, Новый Массив);
	Запрос  = новый Запрос; 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
		|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
		|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
		|ПОМЕСТИТЬ ВТБлокировки
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
		|			&ТекущаяДата,
		|			Склад = &Склад
		|				ИЛИ Склад = &СкладФизСклад) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНабора.Склад КАК Склад,
		|	ЗаданиеНабора.Ссылка КАК Ссылка,
		|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТоварыДокумента
		|ИЗ
		|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
		|ГДЕ
		|	ЗаданиеНабора.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора КАК ЗаданиеНабора
		|ПОМЕСТИТЬ ВТЗНБ
		|ИЗ
		|	Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировки КАК ВТБлокировки
		|		ПО БлокировкаВыдачиВНаборЗНБ.Ссылка = ВТБлокировки.Блокировка
		|ГДЕ
		|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТоварыДокумента.Ссылка КАК Ссылка,
		|	ВТТоварыДокумента.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТТоварыДокумента КАК ВТТоварыДокумента
		|ГДЕ
		|	(ВТТоварыДокумента.Склад В
		|				(ВЫБРАТЬ
		|					ВТБлокировки.Склад
		|				ИЗ
		|					ВТБлокировки)
		|			ИЛИ ВТТоварыДокумента.Склад.ФизическийСклад В
		|				(ВЫБРАТЬ
		|					ВТБлокировки.Склад
		|				ИЗ
		|					ВТБлокировки))
		|	И ВТТоварыДокумента.Номенклатура В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТБлокировки.Номенклатура
		|			ИЗ
		|				ВТБлокировки)
		|	И ВТТоварыДокумента.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТЗНБ.ЗаданиеНабора
		|			ИЗ
		|				ВТЗНБ)";
                                                      
        Запрос.УстановитьПараметр("Ссылка", ЗНБ);
		Запрос.УстановитьПараметр("Склад", ЗНБ.Склад);
		Запрос.УстановитьПараметр("СкладФизСклад", ЗНБ.Склад.ФизическийСклад);
		запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
		РезультатЗапроса = Запрос.Выполнить(); 
		
		РезПроверки.Успех =  РезультатЗапроса.Пустой();
		
		МассивТоваровБлок = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура");  
		РезПроверки.Ошибки = МассивТоваровБлок; 
		
		Возврат РезПроверки; 
 
		
КонецФункции // ПроверитьЗНБОжиданиеНабора()

 //++Данилова Е.В. 24.02.2026 HELP-8893 
 Функция РазделитьЗНБ(СоответствиеНомерЧастиТовары,РНК) Экспорт
    РезультатВыполнения = МаркировкаКС.СтруктураРезультата(Ложь); 

 	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПланНабора.Ссылка КАК Ссылка,
		|	ПланНаборатБрэндов.Коллекция.ЭтоГруппа КАК КоллекцияЭтоГруппа
		|ИЗ
		|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
		|		ПО ПланНаборатБрэндов.Ссылка = ПланНабора.Ссылка
		|ГДЕ
		|	ПланНабора.Проведен
		|	И ПланНабора.Накладная = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", РНК);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		ПланНабора = ВыборкаДетальныеЗаписи.ссылка; 
		
		ЗаполнениеПоБрендам = ВыборкаДетальныеЗаписи.КоллекцияЭтоГруппа; 
		НачатьТранзакцию(); 
		ПланНабораОбъект = ПланНабора.ПолучитьОбъект(); 
		
		ДопПараметрыНакладной=ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(РНК);
		РаспределятьРасходныеМатериалы = Ложь; 	
		если ДопПараметрыНакладной.НаборыЧЗбезОклейкиКомплектующих или ДопПараметрыНакладной.ОтгрузкаFBS тогда
			РаспределятьРасходныеМатериалы=Истина;
		КонецЕсли;
		
		ЗаблокированныеТовары  = Новый ТаблицаЗначений;
		ЗаблокированныеТовары.Колонки.Добавить("номенклатура", Новый ОписаниеТипов("СправочникСсылка.номенклатура"));
		ЗаблокированныеТовары.Колонки.Добавить("Коллекция",Новый ОписаниеТипов("СправочникСсылка.номенклатура"));
		
		
		Если ЗаполнениеПоБрендам  Тогда   		
			
			тБрэндов = ПланНабора.тБрэндов.Выгрузить(); 
			тБрэндов.Колонки.Добавить("Разделять"); 		 
			МассивЧастей = Новый Массив; 
			Для каждого СтрокаБрэнда Из тБрэндов Цикл
				
				ТоварыДляРазделения = СоответствиеНомерЧастиТовары.Получить(СтрокаБрэнда.номерЧасти);
				
				Если ТоварыДляРазделения <> Неопределено  Тогда
					МассивЧастей.Добавить(СтрокаБрэнда.номерЧасти);	
					СтрокаБрэнда.Разделять = истина;
					Для каждого ТовМассива Из ТоварыДляРазделения Цикл
						Если ТовМассива.Родитель.Родитель = СтрокаБрэнда.Коллекция Тогда 
							НоваяСтр = ЗаблокированныеТовары.Добавить(); 
							новаяСтр.Номенклатура =	ТовМассива; 
							новаяСтр.Коллекция = СтрокаБрэнда.Коллекция;
							//	
							//	СтрокаБрэнда.Разделять = истина;
							//Иначе 
							//	СтрокаБрэнда.Разделять = Ложь;
						КонецЕсли;
					КонецЦикла;	
					
				Иначе 
					СтрокаБрэнда.Разделять = Ложь;
				КонецЕсли;
			КонецЦикла; 
			
			ДанныеДляРазделения = Новый Структура("тБрэндов,ТоварыДляПереноса",тБрэндов,ЗаблокированныеТовары);
			ПланНабораОбъект.ЗаполнитьТаблицуБрэндов(РаспределятьРасходныеМатериалы,ДанныеДляРазделения);
			ПланНабораОбъект.Записать();
			
			ДанныеДляРазделения = Новый Структура("НомераЧастей,ТоварыДляПереноса",МассивЧастей,ЗаблокированныеТовары); 
			НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ = ложь; 
			РезультатСоздания = ПланНабораОбъект.СоздатьЗаданияНабораПоПлануНабора(РаспределятьРасходныеМатериалы,ДанныеДляРазделения,НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ);
			Если РезультатСоздания
				И НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ Тогда
				
				Если ТранзакцияАктивна() Тогда
					
					ЗафиксироватьТранзакцию();
					
				КонецЕсли;
				
				
				СоздатьЗНМ_И_ЛМ_ПоЗНБ_Набора(ПланНабораОбъект.ссылка,РНК); 	
			Иначе 
				
				Если ТранзакцияАктивна() Тогда
					
					ЗафиксироватьТранзакцию();
					
				КонецЕсли;
				
			КонецЕсли;
			РезультатВыполнения.Успешно =  РезультатСоздания;
			РезультатВыполнения.Данные = ПланНабораОбъект.ссылка;
			
			Если Не РезультатСоздания Тогда
				
				РезультатВыполнения.Ошибки.Добавить("Не удалось записать ЗНБ");	
				
			КонецЕсли;
		Иначе 	
			
			ЗаблокированныеТоварыМассив = Новый Массив;
			МассивЧастей = Новый Массив;
			Для каждого  ЭлементСоответствия Из СоответствиеНомерЧастиТовары  Цикл
				МассивЧастей.Добавить(ЭлементСоответствия.Ключ);
				Для каждого ТоварИзМассива Из ЭлементСоответствия.Значение  Цикл
					
					ЗаблокированныеТоварыМассив.Добавить(ТоварИзМассива); 					
					
					НоваяСтр = ЗаблокированныеТовары.Добавить(); 
					новаяСтр.Номенклатура =	ТоварИзМассива; 
					новаяСтр.Коллекция = ТоварИзМассива;
				КонецЦикла;  			
				
			КонецЦикла;
			
			тБрэндов = ПланНабора.тБрэндов.Выгрузить();
			тБрэндов.Колонки.Добавить("Разделять");  		
			
			Для каждого СтрокаБрэнда Из тБрэндов Цикл
				
				ТоварыДляРазделения = СоответствиеНомерЧастиТовары.Получить(СтрокаБрэнда.номерЧасти);
				
				Если ТоварыДляРазделения <> Неопределено  Тогда  
					
					СтрокаБрэнда.Разделять = истина; 
					
				Иначе 
					СтрокаБрэнда.Разделять = Ложь;
				КонецЕсли;
			КонецЦикла; 
			
			ДанныеДляРазделения = Новый Структура("тБрэндов,ТоварыДляПереноса",тБрэндов,ЗаблокированныеТоварыМассив); 			
			ПланНабораОбъект.ЗаполнитьТаблицуБрэндовШарапово(ДанныеДляРазделения);
			//ПланНабораОбъект.тБрэндов.Сортировать("ЭтоБлочки,Брэнд"); 
			ПланНабораОбъект.Записать();
			ДанныеДляРазделения = Новый Структура("НомераЧастей,ТоварыДляПереноса",МассивЧастей,ЗаблокированныеТовары);
			НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ = Ложь; 
			РезультатСоздания = ПланНабораОбъект.СоздатьЗаданияНабораПоПлануНабора(РаспределятьРасходныеМатериалы,ДанныеДляРазделения,НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ);
			
			Если РезультатСоздания
				И НужноСоздаватьЗНМ_И_ЛМ_ПоЗНБ Тогда
				
				Если ТранзакцияАктивна() Тогда
					
					ЗафиксироватьТранзакцию();
					
				КонецЕсли;
				
				СоздатьЗНМ_И_ЛМ_ПоЗНБ_Набора(ПланНабораОбъект.ссылка,РНК); 	
			Иначе 
				
				Если ТранзакцияАктивна() Тогда
					
					ЗафиксироватьТранзакцию();
					
				КонецЕсли;	
			КонецЕсли;
			РезультатВыполнения.Успешно =  РезультатСоздания;  
			РезультатВыполнения.Данные = ПланНабораОбъект.ссылка; 
			Если Не РезультатСоздания Тогда
				
				РезультатВыполнения.Ошибки.Добавить("Не удалось записать ЗНБ");	
				
			КонецЕсли;
		КонецЕсли;
		
		
		Возврат РезультатВыполнения;
	Иначе 
		
		//Сообщить("Не найден план набора по РНК"); 
		РезультатВыполнения.Ошибки.Добавить("Не найден план набора по РНК"); 
		Возврат РезультатВыполнения; 
	КонецЕсли;

 
КонецФункции

Процедура СоздатьЗНМ_И_ЛМ_ПоЗНБ_Набора(Знач ПланНабора, Знач Накладная)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданиеНабора.Ссылка КАК ЗНБ
	               |ИЗ
	               |	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	               |ГДЕ
	               |	ЗаданиеНабора.ДокументОснование = &ДокументОснование
	               |	И ЗаданиеНабора.Проведен
	               |	И ЗаданиеНабора.ТребуетсяМаркировка
	               |	И ЗаданиеНабора.Дата >= &Дата
	               |	И ЗаданиеНабора.ЗНМ = ЗНАЧЕНИЕ(Документ.ЗаданиеНаМаркировку.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ДокументОснование", ПланНабора);
	Запрос.УстановитьПараметр("Дата", Константы.ДатаЗапретаРедактирования.Получить());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Ошибки = Документы.ЗаданиеНабора.СоздатьЗНМ_И_ЛМ(Выборка.ЗНБ, Накладная);
		
		Если ЗначениеЗаполнено(Ошибки) Тогда
			
			Сообщить(Ошибки);
			
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры
 
