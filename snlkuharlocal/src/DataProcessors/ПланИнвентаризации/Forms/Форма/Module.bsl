&НаСервере
Процедура ЗавершитьБлокировкиНаСервере() 
	ДатаЗавершения = ТекущаяДата(); 
	АктБлокировкиДерево = РеквизитФормыВЗначение("АктивныеБлокировки",Тип("ДеревоЗначений"));
	
	Блокировки = Новый Массив; 
	Для каждого Уровень1  Из АктБлокировкиДерево.Строки Цикл
		Если НЕ Уровень1.Пометка Тогда
			
			Продолжить; 
			
		КонецЕсли;
		Для каждого Уровень2 Из Уровень1.Строки Цикл
			Если НЕ Уровень2.Пометка Тогда
				
				Продолжить; 
				
			КонецЕсли;
			//проверим после 
			//Если ЗначениеЗаполнено(Уровень2.ИНВ)
			//	И Уровень2.ИНВ.СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена Тогда
			//
			//	Продолжить; 	
			//
			//КонецЕсли;
			
			Если ЗначениеЗаполнено(Уровень2.Блокировка)
				 И Блокировки.Найти(Уровень2.Блокировка) = Неопределено Тогда
			
				 Блокировки.Добавить(Уровень2.Блокировка); 
			
			КонецЕсли;
			
		 КонецЦикла;
	
	 КонецЦикла;
	 НачатьТранзакцию(); 
	 Для каждого БлокировкаДок Из Блокировки Цикл
		 
		 РезультатПроверки = ЕстьНеЗавершИНВПоБлокировке(БлокировкаДок);
		 
		 Если  РезультатПроверки Тогда
			 
			 ТекстСооб = СтрШаблон("По блокировке %1 есть незавершенные ИНВ",БлокировкаДок.ссылка); 
		    Сообщить(ТекстСооб); 
		 	Продолжить; 	
		 
		 КонецЕсли;
		 
		 БлокировкаДокОбъект = БлокировкаДок.ПолучитьОбъект(); 
		 // СтрокиНеЗаверш = БлокировкаДокОбъект.ВремяДействия.НайтиСтроки(Новый Структура("ДатаОкончания",дата(1,1,1))); 
		 
		 //Для каждого СтрокаНеЗаверш  Из  СтрокиНеЗаверш Цикл
		 Если ДатаЗавершения <= БлокировкаДокОбъект.ДатаНачала Тогда
			 
			 БлокировкаДокОбъект.ДатаНачала = ДатаЗавершения - 1; 	
			 
		 КонецЕсли;
		 БлокировкаДокОбъект.ДатаОкончания = ДатаЗавершения; 
		 
		 //КонецЦикла;		 
		 
		 БлокировкаДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		 Сообщить("К закрытию блокировка " + Строка(БлокировкаДокОбъект.ссылка)); 
	 КонецЦикла;
	 Если  ТранзакцияАктивна() Тогда
		 
		 ЗафиксироватьТранзакцию();	
		 
	 КонецЕсли;
	 
	 
	
	
КонецПроцедуры

&НаСервере
Функция ЕстьНеЗавершИНВПоБлокировке(Знач ДокБлокировки)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
		|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
		|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
		|ПОМЕСТИТЬ ВТБлокировки
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(, ) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен
		|	И БлокировкаВыдачиВНаборСрезПоследних.Регистратор = &Регистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТБлокировки.Склад КАК Склад,
		|	ВТБлокировки.Номенклатура КАК Номенклатура,
		|	Инвентаризация.Ссылка КАК ИНВ
		|ПОМЕСТИТЬ ВТИнв
		|ИЗ
		|	Документ.Инвентаризация КАК Инвентаризация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Инвентаризация.Товары КАК ИнвентаризацияТовары
		|		ПО Инвентаризация.Ссылка = ИнвентаризацияТовары.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировки КАК ВТБлокировки
		|		ПО (Инвентаризация.Склад = ВЫБОР
		|				КОГДА ВТБлокировки.Склад.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Физический)
		|					ТОГДА ВТБлокировки.Склад
		|				ИНАЧЕ ВТБлокировки.Склад.ФизическийСклад
		|			КОНЕЦ)
		|ГДЕ
		|	Инвентаризация.Проведен
		|	И Инвентаризация.СостояниеНакладной <> &СостояниеНакладной
		|	И ИнвентаризацияТовары.Номенклатура В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТБлокировки.Номенклатура
		|			ИЗ
		|				ВТБлокировки)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТБлокировки.Блокировка КАК Блокировка
		|ИЗ
		|	ВТБлокировки КАК ВТБлокировки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТИнв КАК ВТИнв
		|		ПО ВТБлокировки.Склад = ВТИнв.Склад
		|			И ВТБлокировки.Номенклатура = ВТИнв.Номенклатура";
	
	Запрос.УстановитьПараметр("Регистратор", ДокБлокировки);
	Запрос.УстановитьПараметр("СостояниеНакладной", Перечисления.СостоянияНакладной.Отгружена);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой(); 

КонецФункции // ПроверитьНеЗавершенныеИНВПоБлокировке()

