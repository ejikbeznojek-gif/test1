&НаКлиенте
Процедура ПриИзмененииПометки(Знач ТекущиеДанные)   	
	
	Если ТекущиеДанные.ПолучитьРодителя() = неопределено Тогда
		
		Для каждого ТекЭлемент Из ТекущиеДанные.ПолучитьЭлементы() Цикл
			
			ТекЭлемент.Пометка = ТекущиеДанные.Пометка; 
			
		КонецЦикла;	
	Иначе 
		МеткаРодителя = ТекущиеДанные.Пометка; 
		РодительСтроки = ТекущиеДанные.ПолучитьРодителя();
		МеткаРодителяТек = РодительСтроки.Пометка;
		КоличествоЭл = РодительСтроки.ПолучитьЭлементы().Количество();
		Сч = 0; 
		Для каждого ЭлСтроки Из РодительСтроки.ПолучитьЭлементы() Цикл
			
			Если ЭлСтроки.Пометка = ТекущиеДанные.Пометка Тогда
				
				Сч = Сч + 1;  
				
			КонецЕсли;	
			
		КонецЦикла;
		Если КоличествоЭл = Сч Тогда
			
			РодительСтроки.Пометка = МеткаРодителя;	
			
		КонецЕсли;
		Если МеткаРодителя
			И КоличествоЭл <> Сч Тогда
			
			РодительСтроки.Пометка = истина; 
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

