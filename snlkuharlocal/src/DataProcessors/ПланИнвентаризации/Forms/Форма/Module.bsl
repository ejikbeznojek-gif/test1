				Запрос.УстановитьПараметр("Блокировка",ВыборкаБлокировки.Блокировка);
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					Если ВыборкаАКтЗНБ.ЗНБ <> Выборка.ЗНББлок Тогда
						
						НСтрока = ТЧАктивныеЗНБПроходныеРНК.Добавить(); 	
						НСтрока.ЗНБАктивное = ВыборкаАКтЗНБ.ЗНБ;
						НСтрока.ЗНББлок 	= Выборка.ЗНББлок;
						НСтрока.Блокировка1 = ВыборкаБлокировки.Блокировка;
						
					Иначе
						НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
						ЗаполнитьЗначенияСвойств(НСтрока,выборка);	
						НСтрока.ЗНБ = ВыборкаАКтЗНБ.ЗНБ; 
						НСтрока.Блокировка = ВыборкаБлокировки.Блокировка;
					КонецЕсли;
				КонецЦикла;
				
				 
				
			//КонецЕсли;
			
		КонецЦикла;
		
		//ВыборкаБлокировки.Сбросить(); 
		
		//Выборка = ВыборкаАКтЗНБ.выбрать(); 
