&НаКлиенте
Процедура СоздатьБлокировку(Команда)
	Если Номенклатура.Количество() = 0
		 ИЛИ Склады.Количество() = 0
		  ИЛИ Не ЗначениеЗаполнено(НаДату) Тогда
		  
		  ПоказатьПредупреждение(,"Необходимо заполнить все поля: склады, номенклатуру и дату!!!"); 
		  
		  Возврат; 	
	
	КонецЕсли;
	ДокБлокировки = СоздатьБлокировкуНаСервере();
	Если  ЗначениеЗаполнено(ДокБлокировки) Тогда
		СозданнаяБлокировка = ДокБлокировки; 
		ОткрытьЗначение(ДокБлокировки);	
		
	КонецЕсли;
	 
КонецПроцедуры 

