	Если ТипЗНЧ(ОтсканированныеЗНБСтр) = Тип("Структура") Тогда
	
		ДобавитьЗНБВБлокировкиНаСервере(ОтсканированныеЗНБСтр.ЗНБ,ОтсканированныеЗНБСтр.Все);
		ОбновитьНаСервере();
		РазвернутьДерево();
	
	КонецЕсли;
КонецПроцедуры  

