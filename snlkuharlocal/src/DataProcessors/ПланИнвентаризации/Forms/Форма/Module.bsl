		   	   СтрокаЗНБ.Пометка = истина; 
			   СтрокаЗНБ.Отсканировать = Ложь; 
			   
			   Для каждого СтрНом Из СтрокаЗНБ.ПолучитьЭлементы() Цикл
			   
			   	    СтрНом.Пометка = Истина;
					СтрНом.Отсканировать = Ложь;
			   
				КонецЦикла; 
				
				прервать; 
		   
		   КонецЕсли;
	  
	  КонецЦикла;
 
