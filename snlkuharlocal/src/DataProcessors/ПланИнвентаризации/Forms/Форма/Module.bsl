Функция СформироватьОтчет2НаСервере()
	
	ТЗ = СформироватьТЗНоменклатураПоСкладамБезблокировки();

	Об = РеквизитФормыВЗначение("Объект");
	ТабДок = Об.СформироватьТабДокНоменклатураПоСкладамБезБлокировки(ТЗ);
	
	Возврат ТабДок;
КонецФункции

&НаСервере
Функция СформироватьТЗНоменклатураПоСкладамБезблокировки()
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.УстановитьПараметр("НаДату",?(НЕ ЗначениеЗаполнено(ПериодОтчет2),ТекущаяДата(),ПериодОтчет2));
	Запрос.УстановитьПараметр("Склады",ОтборСклады.ВыгрузитьЗначения()); 
	Запрос.УстановитьПараметр("Физический",Перечисления.Видсклада.Физический); 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Склады.ВидСклада <> &Физический
	|			ТОГДА Склады.ФизическийСклад
	|		ИНАЧЕ Склады.Ссылка
	|	КОНЕЦ КАК Склад
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.Ссылка В ИЕРАРХИИ(&Склады)
	|	И НЕ Склады.ЭтоГруппа
	|	И ВЫБОР
	|			КОГДА Склады.ВидСклада <> &Физический
	|				ТОГДА Склады.ФизическийСклад
	|			ИНАЧЕ Склады.Ссылка
	|		КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяССылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
	|ПОМЕСТИТЬ ВТБлокировки
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
	|			&НаДату,
	|			Склад В
	|				(ВЫБРАТЬ
	|					ВТСклады.Склад
	|				ИЗ
	|					ВТСклады)) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТСклады.Склад КАК Склад
	|ИЗ
	|	ВТСклады КАК ВТСклады";
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	МенеджерВременныхТаблиц = запрос.МенеджерВременныхТаблиц; 
	
	ТЗ = Новый ТаблицаЗначений; 	
	ТЗ.Колонки.Добавить("Номенклатура",новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("Склад",новый ОписаниеТипов("СправочникСсылка.Склады"));
	
	Пока Выборка.Следующий() Цикл
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТБлокировки.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТоварыБлок
		|ИЗ
		|	ВТБлокировки КАК ВТБлокировки
		|ГДЕ
		|	ВТБлокировки.Склад = &Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура.Родитель КАК Номенклатура
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Ссылка В ИЕРАРХИИ(&ОтборНоменклатура)
		|	И НЕ Номенклатура.Ссылка В ИЕРАРХИИ
		|				(ВЫБРАТЬ
		|					ВТТоварыБлок.Номенклатура
		|				ИЗ
		|					ВТТоварыБлок)
		|	И НЕ Номенклатура.ЭтоГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлок";
		
		Запрос.УстановитьПараметр("ОтборНоменклатура", ОтборНоменклатура1.ВыгрузитьЗначения());
		Запрос.УстановитьПараметр("Склад", Выборка.Склад);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаТЗ = ТЗ.Добавить();
			СтрокаТЗ.Склад = Выборка.Склад; 
			СтрокаТЗ.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура; 
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТЗ; 

КонецФункции

&НаКлиенте
Процедура СформироватьОтчет2(Команда)
	Табдок = СформироватьОтчет2НаСервере();
	Отчет2.Очистить();
	Отчет2.Вывести(Табдок); 
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОтборыСоздБлокировки(Команда)
	Номенклатура.Очистить();
	Склады.Очистить(); 
	СозданнаяБлокировка = ПредопределенноеЗначение("Документ.БлокировкаВыдачиВНабор.ПустаяСсылка");
	НаДату = ТекущаяДата(); 
	ДатаНачалаБлокировкиFBS = НаДату  - 12*3600; 
КонецПроцедуры

&НаКлиенте
Процедура БезУчетаБлокировокПриИзменении(Элемент)
	Элементы.ОтборНоменклатура.Видимость = БезУчетаБлокировок; 
КонецПроцедуры
//++Данилова Е.В. 20.02.2026 HELP-8893 
&НаСервере
Процедура ДелениеЗНБПриИзмененииНаСервере()
	//++Данилова Е.В. 11.03.2026 SNL-159 
	Если РежимДеленияЗНБ = 0  Тогда
		
		ПроходнаяНакладнаяПН = Обработки.ПланИнвентаризации.ПроходнаяНакладнаяПроверкаРНК(РНК_ДелениеЗНБ);		
		
	Иначе
		
		ПроходнаяНакладнаяПН = Обработки.ПланИнвентаризации.ЗНБПоПроходнойНакладной(ЗНБ_ДелениеЗНБ); 		
		
	КонецЕсли;
	
	Если ПроходнаяНакладнаяПН Тогда
		
		Сообщить("Проходная накладная!! Деление ЗНБ недоступно!!"); 
		
		Возврат; 	
		
	КонецЕсли;
	
	//--Данилова Е.В. 11.03.2026 	

	ДЗ = ЗаполнитьЗНБДляДеления();
	ЗначениеВРеквизитФормы(ДЗ,"ЗНБДляДеления"); 
КонецПроцедуры

&НаКлиенте
Процедура РНК_ДелениеЗНБПриИзменении(Элемент)
	ДелениеЗНБПриИзмененииНаСервере();
КонецПроцедуры  

Функция ЗаполнитьЗНБДляДеления() 
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
	|ПОМЕСТИТЬ ВТБлокировки
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&ТекущаяДата, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Склад КАК Ссылка
	|ПОМЕСТИТЬ ВТСкладыБлок
	|ИЗ
	|	ВТБлокировки КАК Склады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок)
	|			ИЛИ Склады.ФизическийСклад В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок))
	|	И НЕ Склады.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				ВТБлокировки.Номенклатура
	|			ИЗ
	|				ВТБлокировки)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|	И ВЫБОР
	|			КОГДА &РежимСканированияРНК
	|				ТОГДА ЗаданиеНабора.Накладная = &Накладная
	|			ИНАЧЕ ЗаданиеНабора.Ссылка = &ЗНБ
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора КАК ЗНБ,
	|	БлокировкаВыдачиВНаборЗНБ.Ссылка КАК Блокировка
	|ПОМЕСТИТЬ ВТБлокировкиПоЗНБ
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&ТекущаяДата, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
	|		ПО БлокировкаВыдачиВНаборСрезПоследних.Регистратор = БлокировкаВыдачиВНаборЗНБ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ПО (ВТАктивныеЗНБ.ЗНБ = БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора)
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТБлокировкиПоЗНБ.Блокировка КАК Блокировка,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБВБлокировках
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	НЕ ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|ИТОГИ ПО
	|	ЗНБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБВБлокировках.ЗНБ КАК ЗНБ
	|ИЗ
	|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТБлокировки.Блокировка КАК Блокировка,
	|	ВТБлокировки.Склад КАК Склад
	|ИЗ
	|	ВТБлокировки КАК ВТБлокировки";
	
	СостоянияЗНБ = Новый Массив; 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.ОжиданиеНабора); 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.СформированыЗаданияНабора);
	Запрос.УстановитьПараметр("СостоянияЗНБ", СостоянияЗНБ);
	Запрос.УстановитьПараметр("Отгружена", Перечисления.СостоянияНакладной.Отгружена);
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	Запрос.УстановитьПараметр("РежимСканированияРНК",РежимДеленияЗНБ = 0); 
	Запрос.УстановитьПараметр("Накладная",РНК_ДелениеЗНБ);
	Запрос.УстановитьПараметр("ЗНБ",ЗНБ_ДелениеЗНБ);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	ВыборкаАКтЗНБ = ПакетЗапросов[7].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	ВыборкаИтоги = ПакетЗапросов[8].Выбрать();
	
	ТЗБлокировки =  ПакетЗапросов[9].Выгрузить();
	
	МенеджерВременнныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ТЧАктивныеЗНБ = новый ТаблицаЗначений; 
	ТЧАктивныеЗНБ.Колонки.Добавить("ЗНБ",новый ОписаниеТипов("ДокументСсылка.ЗаданиеНабора"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Номенклатура",новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Блокировка",новый ОписаниеТипов("ДокументСсылка.БлокировкаВыдачиВНабор"));
	ТЧАктивныеЗНБ.Колонки.Добавить("ДобавленВБлокировку",новый ОписаниеТипов("Булево"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Отсканировать",новый ОписаниеТипов("Булево"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Пометка",новый ОписаниеТипов("Булево"));
	
	Отсканировать = Истина;
	Если РежимДеленияЗНБ = 1 Тогда
	
		Отсканировать = Ложь; 	
	
	КонецЕсли;
	Пока ВыборкаАКтЗНБ.Следующий() Цикл  
		
		
		Для каждого ВыборкаБлокировки Из ТЗБлокировки Цикл
				Запрос = Новый запрос; 
				Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
				
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыЗНБ
				|ИЗ
				|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСклады
				|		ПО (СпрСклады.Ссылка = ВТАктивныеЗНБ.Склад)
				|ГДЕ
				|	ВТАктивныеЗНБ.ЗНБ = &ЗНБ
				|	И (СпрСклады.Ссылка = &Склад
				|			ИЛИ СпрСклады.ФизическийСклад = &Склад)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТБлокировки.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировки
				|ИЗ
				|	ВТБлокировки КАК ВТБлокировки
				|ГДЕ
				|	ВТБлокировки.Блокировка = &Блокировка
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	номенклатура.Ссылка КАК номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировкиЭлементы
				|ИЗ
				|	Справочник.Номенклатура КАК номенклатура
				|ГДЕ
				|	номенклатура.Ссылка В ИЕРАРХИИ
				|			(ВЫБРАТЬ
				|				ВТТоварыБлокировки.Номенклатура
				|			ИЗ
				|				ВТТоварыБлокировки)
				|	И НЕ номенклатура.ЭтоГруппа
				|	И НЕ номенклатура.ПометкаУдаления
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТТоварыЗНБ.Номенклатура КАК Номенклатура
				|ИЗ
				|	ВТТоварыЗНБ КАК ВТТоварыЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБлокировкиЭлементы КАК ВТТоварыБлокировкиЭлементы
				|		ПО ВТТоварыЗНБ.Номенклатура = ВТТоварыБлокировкиЭлементы.номенклатура
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыЗНБ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировки
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировкиЭлементы";
				Запрос.УстановитьПараметр("ЗНБ",ВыборкаАКтЗНБ.ЗНБ);
				Запрос.УстановитьПараметр("Склад",ВыборкаБлокировки.Склад);
				Запрос.УстановитьПараметр("Блокировка",ВыборкаБлокировки.Блокировка);
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					
					НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
					ЗаполнитьЗначенияСвойств(НСтрока,выборка);	
					НСтрока.ЗНБ = ВыборкаАКтЗНБ.ЗНБ; 
					НСтрока.Блокировка = ВыборкаБлокировки.Блокировка;
					НСтрока.Пометка = истина; 
					Если ВыборкаАКтЗНБ.ЗНБ.СостояниеНакладной = перечисления.СостоянияНакладной.ОжиданиеНабора Тогда
					
						НСтрока.Отсканировать 	= Отсканировать; 	
					    НСтрока.Пометка			 = НЕ Отсканировать;
						
					КонецЕсли;
					
				КонецЦикла;
			
			
		КонецЦикла;	 		
		
	КонецЦикла;
	
	Пока ВыборкаИтоги.Следующий() Цикл
		
		Запрос = Новый Запрос; 
		Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	ВТАктивныеЗНБВБлокировках.Блокировка КАК Блокировка
		|ПОМЕСТИТЬ ВТБлокировкиПОЗНБ1
		|ИЗ
		|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
		|ГДЕ
		|	ВТАктивныеЗНБВБлокировках.ЗНБ = &ЗНБ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыБлок.Номенклатура КАК Номенклатура,
		|	ВТБлокировкиПОЗНБ.Блокировка КАК Блокировка
		|ПОМЕСТИТЬ ВТТоварыБлокировки
		|ИЗ
		|	Документ.БлокировкаВыдачиВНабор.Номенклатура КАК ТоварыБлок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировкиПОЗНБ1 КАК ВТБлокировкиПОЗНБ
		|		ПО (ВТБлокировкиПОЗНБ.Блокировка = ТоварыБлок.Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
