		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокировки"; 
		
		Запрос.УстановитьПараметр("ЗНБ",ВыборкаИтоги.ЗНБ);
		МассивТоваровЗНБ =  Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("номенклатура");
		Для каждого ЭлМассива Из МассивТоваровЗНБ Цикл 		
			НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
			НСтрока.Номенклатура = ЭлМассива; 	
			НСтрока.ЗНБ = ВыборкаИтоги.ЗНБ;
		КонецЦикла;
		
	КонецЦикла;  
		
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
	Запрос.УстановитьПараметр("АктивныеЗНБ",ТЧАктивныеЗНБ);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(АктивныеЗНБ.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
