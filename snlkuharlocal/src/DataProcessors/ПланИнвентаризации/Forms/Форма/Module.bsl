Функция СформироватьОтчет1НаСервере() 
	Если БезУчетаБлокировок Тогда 
		ТЗ = СформитьТаблицуИсточникНетАктивныхЗНББезУчетаБлокировок();
		
		Об = РеквизитФормыВЗначение("Объект");
		ТабДок = Об.СформироватьТабДокНоменклатураБезАктивныхЗНББезУчетаБлокировок(ТЗ);
	Иначе 
		ТЗ = СформитьТаблицуИсточникНетАктивныхЗНБ();
		
		Об = РеквизитФормыВЗначение("Объект");
		ТабДок = Об.СформироватьТабДокНоменклатураБезАктивныхЗНБ(ТЗ);
	КонецЕсли;
	Возврат ТабДок;
КонецФункции

&НаСервере
Функция СформитьТаблицуИсточникНетАктивныхЗНБ()
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
	|ПОМЕСТИТЬ ВТБлокировки
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&НаДату, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Склад КАК Ссылка
	|ПОМЕСТИТЬ ВТСкладыБлок
	|ИЗ
	|	ВТБлокировки КАК Склады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок)
	|			ИЛИ Склады.ФизическийСклад В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок))
	|	И НЕ Склады.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				ВТБлокировки.Номенклатура
	|			ИЗ
	|				ВТБлокировки)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора КАК ЗНБ,
	|	БлокировкаВыдачиВНаборЗНБ.Ссылка КАК Блокировка
	|ПОМЕСТИТЬ ВТБлокировкиПоЗНБ
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&НаДату, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
	|		ПО БлокировкаВыдачиВНаборСрезПоследних.Регистратор = БлокировкаВыдачиВНаборЗНБ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ПО (ВТАктивныеЗНБ.ЗНБ = БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора)
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТАктивныеЗНБ.Склад КАК Склад,
	|	ВТБлокировкиПоЗНБ.Блокировка КАК Блокировка,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБВБлокировках
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	НЕ ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|ИТОГИ ПО
	|	ЗНБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБВБлокировках.ЗНБ КАК ЗНБ
	|ИЗ
	|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТБлокировки.Блокировка КАК Блокировка,
	|	ВТБлокировки.Склад КАК Склад
	|ИЗ
	|	ВТБлокировки КАК ВТБлокировки";
	
	СостоянияЗНБ = Новый Массив; 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.ОжиданиеНабора); 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.ВНаборе);
	Запрос.УстановитьПараметр("СостоянияЗНБ", СостоянияЗНБ);
	Запрос.УстановитьПараметр("Отгружена", Перечисления.СостоянияНакладной.Отгружена);
	запрос.УстановитьПараметр("НаДату",?(НЕ ЗначениеЗаполнено(ПериодОтчет1),ТекущаяДата(),ПериодОтчет1)); 
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	ВыборкаАКтЗНБ = ПакетЗапросов[7].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	ВыборкаИтоги = ПакетЗапросов[8].Выбрать();
	
	ТЗБлокировки =  ПакетЗапросов[9].Выгрузить();
	
	МенеджерВременнныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ТЧАктивныеЗНБ = новый ТаблицаЗначений; 
	ТЧАктивныеЗНБ.Колонки.Добавить("ЗНБ",новый ОписаниеТипов("ДокументСсылка.ЗаданиеНабора"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Номенклатура",новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Блокировка",новый ОписаниеТипов("ДокументСсылка.БлокировкаВыдачиВНабор"));
	
	Пока ВыборкаАКтЗНБ.Следующий() Цикл  
		
		
		Для каждого ВыборкаБлокировки Из ТЗБлокировки Цикл
			//	
			//Если ВыборкаБлокировки.Склад = ВыборкаАКтЗНБ.ЗНБ.Склад 
			//ИЛИ ВыборкаБлокировки.Склад = ВыборкаАКтЗНБ.ЗНБ.Склад.ФизическийСклад Тогда
			Запрос = Новый запрос; 
			Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
			
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
			|ПОМЕСТИТЬ ВТТоварыЗНБ
			|ИЗ
			|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСклады
			|		ПО (СпрСклады.Ссылка = ВТАктивныеЗНБ.Склад)
			|ГДЕ
			|	ВТАктивныеЗНБ.ЗНБ = &ЗНБ
			|	И (СпрСклады.Ссылка = &Склад
			|			ИЛИ СпрСклады.ФизическийСклад = &Склад)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТБлокировки.Номенклатура КАК Номенклатура
			|ПОМЕСТИТЬ ВТТоварыБлокировки
			|ИЗ
			|	ВТБлокировки КАК ВТБлокировки
			|ГДЕ
			|	ВТБлокировки.Блокировка = &Блокировка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	номенклатура.Ссылка КАК номенклатура
			|ПОМЕСТИТЬ ВТТоварыБлокировкиЭлементы
			|ИЗ
			|	Справочник.Номенклатура КАК номенклатура
			|ГДЕ
			|	номенклатура.Ссылка В ИЕРАРХИИ
			|			(ВЫБРАТЬ
			|				ВТТоварыБлокировки.Номенклатура
			|			ИЗ
			|				ВТТоварыБлокировки)
			|	И НЕ номенклатура.ЭтоГруппа
			|	И НЕ номенклатура.ПометкаУдаления
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТТоварыЗНБ.Номенклатура КАК Номенклатура
			|ИЗ
			|	ВТТоварыЗНБ КАК ВТТоварыЗНБ
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБлокировкиЭлементы КАК ВТТоварыБлокировкиЭлементы
			|		ПО ВТТоварыЗНБ.Номенклатура = ВТТоварыБлокировкиЭлементы.номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТТоварыЗНБ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТТоварыБлокировки
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТТоварыБлокировкиЭлементы";
			Запрос.УстановитьПараметр("ЗНБ",ВыборкаАКтЗНБ.ЗНБ); 
			Запрос.УстановитьПараметр("Склад",ВыборкаБлокировки.Склад); 
			Запрос.УстановитьПараметр("Блокировка",ВыборкаБлокировки.Блокировка);
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				
				НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
				ЗаполнитьЗначенияСвойств(НСтрока,выборка);	
				НСтрока.ЗНБ = ВыборкаАКтЗНБ.ЗНБ; 
				НСтрока.Блокировка = ВыборкаБлокировки.Блокировка;
				
			КонецЦикла;
			
			
			
			//КонецЕсли;
			
		КонецЦикла; 		
	КонецЦикла;
	
	Пока ВыборкаИтоги.Следующий() Цикл
		
		Запрос = Новый Запрос; 
		Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	ВТАктивныеЗНБВБлокировках.Блокировка КАК Блокировка
		|ПОМЕСТИТЬ ВТБлокировкиПОЗНБ1
		|ИЗ
		|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
		|ГДЕ
		|	ВТАктивныеЗНБВБлокировках.ЗНБ = &ЗНБ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыБлок.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТоварыБлокировки
		|ИЗ
		|	Документ.БлокировкаВыдачиВНабор.Номенклатура КАК ТоварыБлок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировкиПОЗНБ1 КАК ВТБлокировкиПОЗНБ
		|		ПО (ВТБлокировкиПОЗНБ.Блокировка = ТоварыБлок.Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТАктивныеЗНБВБлокировках.номенклатура КАК номенклатура
		|ИЗ
		|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
		|ГДЕ
		|	ВТАктивныеЗНБВБлокировках.ЗНБ = &ЗНБ
		|	И НЕ ВТАктивныеЗНБВБлокировках.номенклатура В ИЕРАРХИИ
		|				(ВЫБРАТЬ
		|					ВТТоварыБлокировки.Номенклатура
		|				ИЗ
		|					ВТТоварыБлокировки)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТБлокировкиПОЗНБ1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокировки"; 
		
		Запрос.УстановитьПараметр("ЗНБ",ВыборкаИтоги.ЗНБ);
		МассивТоваровЗНБ =  Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("номенклатура"); 
		
		Для каждого ВыборкаБлокировки Из ТЗБлокировки Цикл
			//	
			//Если ВыборкаБлокировки.Склад = ВыборкаИтоги.ЗНБ.Склад
				//ИЛИ ВыборкаБлокировки.Склад = ВыборкаИтоги.ЗНБ.Склад.ФизическийСклад Тогда
				
				Запрос = Новый запрос; 
				Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
				
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыЗНБ
				|ИЗ
				|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСклады
				|		ПО (СпрСклады.Ссылка = ВТАктивныеЗНБ.Склад)
				|ГДЕ
				|	ВТАктивныеЗНБ.ЗНБ = &ЗНБ
				|	И ВТАктивныеЗНБ.Номенклатура В(&МассивТоваров)
				|	И (СпрСклады.Ссылка = &Склад
				|			ИЛИ СпрСклады.ФизическийСклад = &Склад)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТБлокировки.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировки
				|ИЗ
				|	ВТБлокировки КАК ВТБлокировки
				|ГДЕ
				|	ВТБлокировки.Блокировка = &Блокировка
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	номенклатура.Ссылка КАК номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировкиЭлементы
				|ИЗ
				|	Справочник.Номенклатура КАК номенклатура
				|ГДЕ
				|	номенклатура.Ссылка В ИЕРАРХИИ
				|			(ВЫБРАТЬ
				|				ВТТоварыБлокировки.Номенклатура
				|			ИЗ
				|				ВТТоварыБлокировки)
				|	И НЕ номенклатура.ЭтоГруппа
				|	И НЕ номенклатура.ПометкаУдаления
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТТоварыЗНБ.Номенклатура КАК Номенклатура
				|ИЗ
				|	ВТТоварыЗНБ КАК ВТТоварыЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБлокировкиЭлементы КАК ВТТоварыБлокировкиЭлементы
				|		ПО ВТТоварыЗНБ.Номенклатура = ВТТоварыБлокировкиЭлементы.номенклатура
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыЗНБ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировки
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировкиЭлементы";
				Запрос.УстановитьПараметр("ЗНБ",ВыборкаИтоги.ЗНБ);
				Запрос.УстановитьПараметр("Склад",ВыборкаБлокировки.Склад);
				Запрос.УстановитьПараметр("Блокировка",ВыборкаБлокировки.Блокировка); 
				Запрос.УстановитьПараметр("МассивТоваров",МассивТоваровЗНБ);
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					
					НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
					ЗаполнитьЗначенияСвойств(НСтрока,выборка);	
					НСтрока.ЗНБ = ВыборкаИтоги.ЗНБ; 
					НСтрока.Блокировка = ВыборкаБлокировки.Блокировка;
					
				КонецЦикла;
				
				
			//КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ТЧНоменклатураБезАктивныхЗНБ = Новый ТаблицаЗначений; 	
	ТЧНоменклатураБезАктивныхЗНБ.Колонки.Добавить("Номенклатура",новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧНоменклатураБезАктивныхЗНБ.Колонки.Добавить("Склад",новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТЧНоменклатураБезАктивныхЗНБ.Колонки.Добавить("Блокировка",новый ОписаниеТипов("ДокументСсылка.БлокировкаВыдачиВНабор"));
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
	Запрос.УстановитьПараметр("АктивныеЗНБ",ТЧАктивныеЗНБ);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	АктивныеЗНБ.Блокировка КАК Блокировка,
	|	АктивныеЗНБ.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ АктивныеЗНБИтог
	|ИЗ
	|	&АктивныеЗНБ КАК АктивныеЗНБ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	МенеджерВременнныхТаблиц = запрос.МенеджерВременныхТаблиц; 
	//без отбора по складу 
	//если номенклатура есть в блокировке по ЗНБ, не важно, по какому складу, не попадает в отчет 
	ТЗБлокировки.Свернуть("Блокировка"); 
	Для каждого СтрокаТЧ Из ТЗБлокировки Цикл 
		
		Запрос = Новый Запрос;
		запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТБлокировки.номенклатура КАК номенклатура
		|ПОМЕСТИТЬ ВТТоварыБлокПоСкладу
		|ИЗ
		|	ВТБлокировки КАК ВТБлокировки
		|ГДЕ
		//|	ВТБлокировки.Склад = &Склад
		|	ВТБлокировки.Блокировка = &Блокировка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СпрНом.Ссылка КАК номенклатура
		|ПОМЕСТИТЬ ВТТоварыБлокПоСкладуРазвернуто
		|ИЗ
		|	Справочник.Номенклатура КАК СпрНом
		|ГДЕ
		|	СпрНом.Ссылка В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТТоварыБлокПоСкладу.номенклатура
		|			ИЗ
		|				ВТТоварыБлокПоСкладу)
		|	И НЕ СпрНом.ЭтоГруппа
		|	И НЕ СпрНом.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТТоварыБлокПоСкладуРазвернуто.номенклатура.Родитель КАК Номенклатура
		|ИЗ
		|	ВТТоварыБлокПоСкладуРазвернуто КАК ВТТоварыБлокПоСкладуРазвернуто
		|		ЛЕВОЕ СОЕДИНЕНИЕ АктивныеЗНБИтог КАК АктивныеЗНБИтог
		|		ПО (АктивныеЗНБИтог.Блокировка = &Блокировка)
		|			И (АктивныеЗНБИтог.Номенклатура.Родитель = ВТТоварыБлокПоСкладуРазвернуто.номенклатура.Родитель)
		|ГДЕ
		|	АктивныеЗНБИтог.номенклатура ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокПоСкладу
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокПоСкладуРазвернуто";
		
		Запрос.УстановитьПараметр("Блокировка", СтрокаТЧ.Блокировка);
		//Запрос.УстановитьПараметр("Склад", СтрокаТЧ.Склад);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтр = ТЧНоменклатураБезАктивныхЗНБ.Добавить(); 
			НоваяСтр.Блокировка = СтрокаТЧ.Блокировка; 
			//НоваяСтр.Склад = СтрокаТЧ.Склад;
			НоваяСтр.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
		КонецЦикла; 		
		
	КонецЦикла;
	
	//++Данилова Е.В. 09.03.2026 SNL-159
	
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ТЧНоменклатураБезАктивныхЗНБ",ТЧНоменклатураБезАктивныхЗНБ);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЧТовары.Блокировка КАК Блокировка,
	|	ТЧТовары.номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТТоварыСБлокировкой
	|ИЗ
	|	&ТЧНоменклатураБезАктивныхЗНБ КАК ТЧТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	ВТТоварыСБлокировкой КАК ВТТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СкладыСПр.Ссылка КАК Склад
	|ПОМЕСТИТЬ ВТСкладыПоОтбору
	|ИЗ
	|	Справочник.Склады КАК СкладыСПр
	|ГДЕ
	|	СкладыСПр.Ссылка В иерархии(&Склады)
	|	И СкладыСПр.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Виртуальный)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СкладыСПр1.Ссылка
	|ИЗ
	|	Справочник.Склады КАК СкладыСПр
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыСПр1
	|		ПО СкладыСПр.ФизическийСклад = СкладыСПр1.Ссылка
	|			И (СкладыСПр.ФизическийСклад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))
	|ГДЕ
	|	СкладыСПр.Ссылка В иерархии(&Склады)
	|	И СкладыСПр.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Виртуальный)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СкладыСПр.Ссылка
	|ИЗ
	|	Справочник.Склады КАК СкладыСПр
	|ГДЕ
	|	СкладыСПр.Ссылка В иерархии(&Склады)
	|	И СкладыСПр.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Физический)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СкладыСПр1.Ссылка
	|ИЗ
	|	Справочник.Склады КАК СкладыСПр
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыСПр1
	|		ПО (СкладыСПр1.ФизическийСклад = СкладыСПр.Ссылка)
	|			И (СкладыСПр1.ФизическийСклад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))
	|ГДЕ
	|	СкладыСПр.Ссылка В иерархии(&Склады)
	|	И СкладыСПр.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Физический)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество
	|ПОМЕСТИТЬ ВТОстаткиПоСкладам
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&НаДату,
	|			Склад В
	|					(ВЫБРАТЬ
	|						ВТСкладыПоОтбору.Склад
	|					ИЗ
	|						ВТСкладыПоОтбору)
	|				И Номенклатура В  иерархии
	|					(ВЫБРАТЬ
	|						ВТТовары.Номенклатура
	|					ИЗ
	|						ВТТовары КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				&НаДату,
	|				Склад В
	|						(ВЫБРАТЬ
	|							ВТСкладыПоОтбору.Склад
	|						ИЗ
	|							ВТСкладыПоОтбору)
	|					И Номенклатура В Иерархии
	|						(ВЫБРАТЬ
	|							ВТТовары.Номенклатура
	|						ИЗ
	|							ВТТовары КАК ВТТовары)) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.Номенклатура  КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ВТОстаткиПоСкладам.Количество, 0)) КАК Количество
	|ПОМЕСТИТЬ ВТОстаткиПоТоварам
	|ИЗ
	|	ВТТовары КАК ВТТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиПоСкладам КАК ВТОстаткиПоСкладам
	|		ПО (ВТОстаткиПоСкладам.Номенклатура.Родитель = ВТТовары.Номенклатура)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТТовары.Номенклатура
	|
	|ИМЕЮЩИЕ
	|	%ИсключитьНулевыеОстатки%
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТоварыСБлокировкой.Блокировка КАК Блокировка,
	|	ВТТоварыСБлокировкой.номенклатура КАК номенклатура,
	|	ВТОстаткиПоТоварам.Количество КАК Количество
	|ИЗ
	|	ВТТоварыСБлокировкой КАК ВТТоварыСБлокировкой
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОстаткиПоТоварам КАК ВТОстаткиПоТоварам
	|		ПО ВТТоварыСБлокировкой.номенклатура = ВТОстаткиПоТоварам.Номенклатура";
	запрос.УстановитьПараметр("НаДату",?(НЕ ЗначениеЗаполнено(ПериодОтчет1),ТекущаяДата(),ПериодОтчет1));
	МассивСклады = ОтборСклады1.ВыгрузитьЗначения();
	запрос.УстановитьПараметр("Склады",МассивСклады);
	Если ИсключитьНулевыеОстатки Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИсключитьНулевыеОстатки%", "СУММА(ЕСТЬNULL(ВТОстаткиПоСкладам.Количество, 0)) > 0"); 
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИсключитьНулевыеОстатки%", "Истина"); 
	КонецЕсли;
	
	
	РезультатЗапроса = Запрос.Выполнить();    
	Возврат РезультатЗапроса.Выгрузить();  
	//Возврат ТЧНоменклатураБезАктивныхЗНБ; 
    //--Данилова Е.В. 09.03.2026
КонецФункции

&НаСервере
Функция СформитьТаблицуИсточникНетАктивныхЗНББезУчетаБлокировок()
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
	|ПОМЕСТИТЬ ВТБлокировки
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&НаДату, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Склад КАК Ссылка
	|ПОМЕСТИТЬ ВТСкладыБлок
	|ИЗ
	|	ВТБлокировки КАК Склады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок)
	|			ИЛИ Склады.ФизическийСклад В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок))
	|	И НЕ Склады.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТТоварыПоОтбору
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&ОтборНоменклатура)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	//|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТоварыПоОтбору.Ссылка
	|			ИЗ
	|				ВТТоварыПоОтбору КАК ВТТоварыПоОтбору)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора КАК ЗНБ,
	|	БлокировкаВыдачиВНаборЗНБ.Ссылка КАК Блокировка
	|ПОМЕСТИТЬ ВТБлокировкиПоЗНБ
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&НаДату, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
	|		ПО БлокировкаВыдачиВНаборСрезПоследних.Регистратор = БлокировкаВыдачиВНаборЗНБ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
