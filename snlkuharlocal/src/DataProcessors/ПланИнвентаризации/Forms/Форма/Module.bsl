&НаКлиенте
 Процедура РазделитьЗНБ(Команда)
	 //сначала собрать по дереву ЗНБ, которые надо разделить 
	СоответствиеЗНБ = Новый Соответствие; 
	Для каждого СтрокаЗНБ Из  ЗНБДляДеления.ПолучитьЭлементы() Цикл
		
		Если НЕ СтрокаЗНБ.Пометка
			ИЛИ СтрокаЗНБ.ВсеТоварыЗаблокированы Тогда
			
			Продолжить; 	
			
		КонецЕсли; 	
		
		МассивТоваров = Новый Массив; 
		Для каждого СтрокаТовара Из СтрокаЗНБ.ПолучитьЭлементы() Цикл
			Если НЕ СтрокаТовара.Пометка Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			МассивТоваров.Добавить(СтрокаТовара.Номенклатура);
			
		КонецЦикла;
		
		
		СоответствиеЗНБ.Вставить(СтрокаЗНБ.ЗНБ,МассивТоваров); 
		
		
	КонецЦикла; 
	
	результатРазделения = РазделитьЗНБНаСервере(СоответствиеЗНБ); 
	
	Если результатРазделения.Успешно  Тогда
		
		ДелениеЗНБПриИзмененииНаСервере();
		ОткрытьЗначение(результатРазделения.Данные);
		
		 
	Иначе
		МаркировкаКС.ВывестиОшибки(результатРазделения); 
		
	КонецЕсли;
КонецПроцедуры 

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Функция РазделитьЗНБНаСервере(СоответствиеЗНБ)
	
	результатРазделения = МаркировкаКС.СтруктураРезультата(ложь); 
	Если СоответствиеЗНБ.Количество()  = 0  Тогда
		
		результатРазделения.Ошибки.Добавить("Не найдено ЗНБ для разделения"); 
		Возврат результатРазделения; 	
		
	КонецЕсли;

	Если РежимДеленияЗНБ = 0 Тогда
		
		РНК = РНК_ДелениеЗНБ; 
		
	Иначе
		
		Для каждого ЭлСоответствия Из СоответствиеЗНБ Цикл
			
			ЗНБ = ЭлСоответствия.Ключ;	
			РНК = ЗНБ.Накладная; 
			
			Прервать; 
			
		КонецЦикла;
		
		 
	КонецЕсли;
	
	//преобразовать по номеру части 
	СоответствиеНомерЧастиТовары = Новый Соответствие; 
	
	Для каждого СтрокаСоотвествия Из СоответствиеЗНБ Цикл
	
		СоответствиеНомерЧастиТовары.Вставить(СтрокаСоотвествия.Ключ.НомерЧасти,СтрокаСоотвествия.Значение); 	
	
	КонецЦикла;
	
	результатРазделения = Обработки.ПланИнвентаризации.РазделитьЗНБ(СоответствиеНомерЧастиТовары,РНК); 
	
	Возврат результатРазделения; 

КонецФункции // РазделитьЗНБНаСервере()

&НаКлиенте
Процедура ОбновитьДелениеЗНБ(Команда)
	ДелениеЗНБПриИзмененииНаСервере(); 
КонецПроцедуры

