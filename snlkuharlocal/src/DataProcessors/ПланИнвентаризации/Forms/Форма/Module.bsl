&НаКлиенте
Процедура ОткрытьДокумент(Команда) 
	//++Данилова Е.В. 20.02.2026 HELP-8893 
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаДелениеЗНБ Тогда 
		
		Если ТипЗнч(Элементы.ЗНБДляДеления.ТекущийЭлемент) = Тип("ПолеФормы")  Тогда
			Если Элементы.ЗНБДляДеления.ТекущийЭлемент.Имя = "ЗНБДляДеленияЗНБ" Тогда
				Если ЗначениеЗаполнено(Элементы.ЗНБДляДеления.ТекущиеДанные.ЗНБ) Тогда 
					ОткрытьЗначение(Элементы.ЗНБДляДеления.ТекущиеДанные.ЗНБ); 	
				КонецЕсли;
			КонецЕсли;
			
			Если Элементы.ЗНБДляДеления.ТекущийЭлемент.Имя = "ЗНБДляДеленияБлокировка" Тогда
				Если ЗначениеЗаполнено(Элементы.ЗНБДляДеления.ТекущиеДанные.Блокировка) Тогда 
					ОткрытьЗначение(Элементы.ЗНБДляДеления.ТекущиеДанные.Блокировка); 	
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	//--Данилова Е.В. 20.02.2026 	
	ИначеЕсли ТипЗнч(Элементы.АктивныеБлокировки.ТекущийЭлемент) = Тип("ПолеФормы")  Тогда
		
		Если Элементы.АктивныеБлокировки.ТекущийЭлемент.Имя = "АктивныеБлокировкиБлокировка" Тогда
			Если ЗначениеЗаполнено(Элементы.АктивныеБлокировки.ТекущиеДанные.Блокировка) Тогда 
				ОткрытьЗначение(Элементы.АктивныеБлокировки.ТекущиеДанные.Блокировка); 	
			КонецЕсли;
		КонецЕсли;
		
		Если Элементы.АктивныеБлокировки.ТекущийЭлемент.Имя = "АктивныеБлокировкиИНВ" Тогда
			Если ЗначениеЗаполнено(Элементы.АктивныеБлокировки.ТекущиеДанные.ИНВ) Тогда 
				ОткрытьЗначение(Элементы.АктивныеБлокировки.ТекущиеДанные.ИНВ); 	
			КонецЕсли;
		КонецЕсли;
		Если Элементы.АктивныеБлокировки.ТекущийЭлемент.Имя = "АктивныеБлокировкиЗНБ" Тогда
			Если ЗначениеЗаполнено(Элементы.АктивныеБлокировки.ТекущиеДанные.ЗНБ) Тогда 
				ОткрытьЗначение(Элементы.АктивныеБлокировки.ТекущиеДанные.ЗНБ); 	
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;
		
КонецПроцедуры

