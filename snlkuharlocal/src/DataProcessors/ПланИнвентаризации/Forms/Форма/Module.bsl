				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТБлокировки.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировки
				|ИЗ
				|	ВТБлокировки КАК ВТБлокировки
				|ГДЕ
				|	ВТБлокировки.Блокировка = &Блокировка
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	номенклатура.Ссылка КАК номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировкиЭлементы
				|ИЗ
				|	Справочник.Номенклатура КАК номенклатура
				|ГДЕ
				|	номенклатура.Ссылка В ИЕРАРХИИ
				|			(ВЫБРАТЬ
				|				ВТТоварыБлокировки.Номенклатура
				|			ИЗ
				|				ВТТоварыБлокировки)
				|	И НЕ номенклатура.ЭтоГруппа
				|	И НЕ номенклатура.ПометкаУдаления
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТТоварыЗНБ.Номенклатура КАК Номенклатура
				|ИЗ
				|	ВТТоварыЗНБ КАК ВТТоварыЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБлокировкиЭлементы КАК ВТТоварыБлокировкиЭлементы
				|		ПО ВТТоварыЗНБ.Номенклатура = ВТТоварыБлокировкиЭлементы.номенклатура
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыЗНБ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировки
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТТоварыБлокировкиЭлементы";
				Запрос.УстановитьПараметр("ЗНБ",ВыборкаИтоги.ЗНБ);
				Запрос.УстановитьПараметр("Склад",ВыборкаБлокировки.Склад);
				Запрос.УстановитьПараметр("Блокировка",ВыборкаБлокировки.Блокировка); 
				Запрос.УстановитьПараметр("МассивТоваров",МассивТоваровЗНБ);
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					
					НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
					ЗаполнитьЗначенияСвойств(НСтрока,выборка);	
					НСтрока.ЗНБ = ВыборкаИтоги.ЗНБ; 
					НСтрока.Блокировка = ВыборкаБлокировки.Блокировка;
					НСтрока.Пометка = истина; 
					Если ВыборкаИтоги.ЗНБ.СостояниеНакладной = перечисления.СостоянияНакладной.ОжиданиеНабора Тогда
						
						НСтрока.Отсканировать 	= Отсканировать; 	
					    НСтрока.Пометка			 = НЕ Отсканировать;
						
					КонецЕсли; 
				КонецЦикла;
				
				
			//КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧЗНБ.ЗНБ КАК ЗНБ,
		|	ТЧЗНБ.Номенклатура КАК Номенклатура,
		|	ТЧЗНБ.Блокировка КАК Блокировка,
		|	ТЧЗНБ.ДобавленВБлокировку КАК ДобавленВБлокировку,
		|	ТЧЗНБ.Отсканировать КАК Отсканировать,
		|	ТЧЗНБ.Пометка КАК Пометка
		|ПОМЕСТИТЬ ВТЗНБ
		|ИЗ
		|	&ТаблицаЗНБ КАК ТЧЗНБ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗНБТовары.Ссылка КАК ЗНБ,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗНБТовары.Номенклатура) КАК КоличествоТоваров
		|ПОМЕСТИТЬ ВТКолТоваровЗНБ
		|ИЗ
		|	Документ.ЗаданиеНабора.Товары КАК ЗНБТовары
		|ГДЕ
		|	ЗНБТовары.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТЗНБ.ЗНБ
		|			ИЗ
		|				ВТЗНБ)
		|	И ЗНБТовары.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗНБТовары.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЗНБ.ЗНБ КАК ЗНБ,
		|	ВТЗНБ.Номенклатура КАК Номенклатура,
		|	ВТЗНБ.Блокировка КАК Блокировка,
		|	ВТЗНБ.ДобавленВБлокировку КАК ДобавленВБлокировку,
		|	ВТЗНБ.Отсканировать КАК Отсканировать,
		|	ВТЗНБ.Пометка КАК Пометка,
		|	ВТКолТоваровЗНБ.КоличествоТоваров КАК КоличествоТоваров
		|ИЗ
		|	ВТЗНБ КАК ВТЗНБ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКолТоваровЗНБ КАК ВТКолТоваровЗНБ
		|		ПО (ВТКолТоваровЗНБ.ЗНБ = ВТЗНБ.ЗНБ)
		|ИТОГИ
		|	МАКСИМУМ(Отсканировать),
		|	МАКСИМУМ(Пометка),
		|	МАКСИМУМ(КоличествоТоваров)
		|ПО
		|	ЗНБ"; 
	
	Запрос.УстановитьПараметр("ТаблицаЗНБ",ТЧАктивныеЗНБ); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаЗНБ = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДЗ = РеквизитФормыВЗначение("ЗНБДляДеления",Тип("ДеревоЗначений"));
	ДЗ.Строки.Очистить(); 
	
	Пока ВыборкаЗНБ.Следующий() Цикл
		Уровень1 = ДЗ.Строки.Добавить(); 
		Уровень1.ЗНБ = ВыборкаЗНБ.ЗНБ;
		Уровень1.Пометка 		= ВыборкаЗНБ.Пометка;
		Уровень1.Отсканировать 	= ВыборкаЗНБ.Отсканировать;
	     
		ВыборкаДетальныеЗаписи = ВыборкаЗНБ.Выбрать();
	    КоличествоТоваровЗНБ = ВыборкаЗНБ.КоличествоТоваров;  
		 
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Уровень2 = Уровень1.Строки.Добавить(); 
			ЗаполнитьЗначенияСвойств(Уровень2,ВыборкаДетальныеЗаписи); 
			Уровень2.ЗНБ = Документы.ЗаданиеНабора.ПустаяСсылка(); 
		КонецЦикла;
		
		Если КоличествоТоваровЗНБ = Уровень1.Строки.Количество() Тогда
		
			Уровень1.ВсеТоварыЗаблокированы = Истина; 	
		
		КонецЕсли;
	КонецЦикла; 
	
	Возврат ДЗ; 


КонецФункции // ЗаполнитьЗНБДляДеления()

