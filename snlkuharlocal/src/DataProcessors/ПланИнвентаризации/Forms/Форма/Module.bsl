#Область СлужебныеПроцедурыФункции

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ДобавитьЗНБВБлокировкиНаСервере(МассивЗНБ,ВсеБлокировки = Ложь)
	
	 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивЗНБ",МассивЗНБ); 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
		|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
		|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
		|ПОМЕСТИТЬ ВТБлокировки
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(%НаДату%, ) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаданиеНабора.Ссылка КАК ЗНБ,
		|	ВТБлокировки.Блокировка КАК Блокировка
		|ИЗ
		|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировки КАК ВТБлокировки
		|		ПО (ЗаданиеНабора.Склад = ВТБлокировки.Склад
		|				ИЛИ ЗаданиеНабора.Склад.ФизическийСклад = ВТБлокировки.Склад)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
		|		ПО (ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка)
		|ГДЕ
		|	ЗаданиеНабора.Ссылка В(&МассивЗНБ)
		|	И ЗаданиеНабораТовары.Номенклатура В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТБлокировки.Номенклатура
		|			ИЗ
		|				ВТБлокировки)
		|ИТОГИ ПО
		|	Блокировка";
	
	Если ВсеБлокировки Тогда 
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%НаДату%",""); 
	
	Иначе 
		
	    Запрос.Текст = СтрЗаменить(Запрос.Текст,"%НаДату%","&НаДату");
		Запрос.УстановитьПараметр("НаДату",ТекущаяДата()); 
		
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИтоги = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	МассивДобавленныхЗНБ = Новый Массив; 
	Пока ВыборкаИтоги.Следующий() Цикл 
		
		ЕстьИзменения = Ложь;
		
		БлокировкаДок = ВыборкаИтоги.Блокировка;
		
		БлокировкаДокОб = БлокировкаДок.ПолучитьОбъект(); 
		
		ВыборкаЗНБ = ВыборкаИтоги.Выбрать();
		
		ТоварыБлок = БлокировкаДок.Номенклатура.Выгрузить(); 
		
		Пока ВыборкаЗНБ.Следующий() Цикл 
			
			ОтборЗНБ = Новый Структура("ЗаданиеНабора",ВыборкаЗНБ.ЗНБ);
			СтрокиЗНБ = БлокировкаДокОб.ЗНБ.НайтиСтроки(ОтборЗНБ);
			Если СтрокиЗНБ.Количество() > 0 Тогда
			
				Продолжить;	
			
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ТоварыБлок.Номенклатура КАК Номенклатура
			|ПОМЕСТИТЬ ВТТовары
			|ИЗ
			|	&ТоварыБлок КАК ТоварыБлок
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ЗаданиеНабораТовары.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
			|ГДЕ
			|	ЗаданиеНабораТовары.Ссылка = &Ссылка
			|	И ЗаданиеНабораТовары.Номенклатура В ИЕРАРХИИ
			|			(ВЫБРАТЬ
			|				ВТТовары.Номенклатура
			|			ИЗ
			|				ВТТовары)";
			
			Запрос.УстановитьПараметр("Ссылка", ВыборкаЗНБ.ЗНБ);
			Запрос.УстановитьПараметр("ТоварыБлок",ТоварыБлок);

			РезультатЗапроса1 = Запрос.Выполнить();
			
			Если Не РезультатЗапроса1.Пустой() Тогда
				
				НоваяСтрока =  БлокировкаДокОб.ЗНБ.Добавить(); 
				НоваяСтрока.ЗаданиеНабора = ВыборкаЗНБ.ЗНБ;
				
				МассивДобавленныхЗНБ.Добавить(ВыборкаЗНБ.ЗНБ); 
				
				ЕстьИзменения = истина; 
			КонецЕсли;
			
		    Если ЕстьИзменения Тогда
			
				БлокировкаДокОб.Записать(); 	
			
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если МассивДобавленныхЗНБ.Количество() > 0  Тогда
	
		Сообщить("Необходимо отложить следующие ЗНБ:"); 	
	    Сообщить(СтрСоединить(МассивДобавленныхЗНБ,Символы.ПС));  
	Иначе 
		Сообщить("Не найдены активные блокировки по отсканированным ЗНБ!"); 
	КонецЕсли;

КонецПроцедуры // ДобавитьЗНБВБлокировкиНаСервере()


&НаСервере
Процедура СоздатьИНВНаСервере()
	//создаем ИНВ по выделенным строкам 
	//если выделено несколько складов, то по складам 
	
	АктБлокировкиДерево = РеквизитФормыВЗначение("АктивныеБлокировки",Тип("ДеревоЗначений")); 
	
	СоответствиеСкладТовары = Новый Соответствие; 
	
	Для каждого Уровень1 Из АктБлокировкиДерево.Строки Цикл 
		
		Если НЕ Уровень1.Пометка Тогда
		
			Продолжить;	
		
		КонецЕсли;
		
		Если Уровень1.Склад.ВидСклада = Перечисления.ВидСклада.Физический Тогда
			
			Склад = Уровень1.Склад; 
		Иначе 
			Склад =  Уровень1.Склад.ФизическийСклад; 
			
		КонецЕсли;
		
		МассивТоваров = СоответствиеСкладТовары.Получить(Склад);   
		Если МассивТоваров = Неопределено Тогда
			
			МассивТоваров = Новый Массив; 	
			
		КонецЕсли;
		
		Для каждого Уровень2 Из Уровень1.Строки Цикл
			Если НЕ Уровень2.Пометка 
				ИЛИ ЗначениеЗаполнено(Уровень2.ИНВ) Тогда
				
				Продолжить;	
				
			КонецЕсли;
			
			МассивТоваров.Добавить(Уровень2.Номенклатура); 	
			
		КонецЦикла;
	    Если МассивТоваров.Количество() > 0  Тогда
		
			СоответствиеСкладТовары.Вставить(Склад,МассивТоваров);	
		
		КонецЕсли;	
		 
	КонецЦикла;
	МассивДокументов = Новый Массив; 
	Для каждого  ЭлСоответствия Из СоответствиеСкладТовары Цикл
	
		 НовыйДокумент = Документы.Инвентаризация.СоздатьДокумент(); 
		 НовыйДокумент.Дата = ТекущаяДата(); 
	     ЗаполнитьШапкуДокумента(НовыйДокумент, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац);
		 НовыйДокумент.ИБ			= ФР_ОбщегоНазначения_ПИ.ТекущаяИБ(); 
		 НовыйДокумент.СостояниеНакладной = Перечисления.СостоянияНакладной.ВРаботе; 
		 НовыйДокумент.Склад = ЭлСоответствия.Ключ;
		 НовыйДокумент.СкладВременногоХранения = ЭлСоответствия.Ключ;
		 НовыйДокумент.СтатьяЗатрат = Справочники.СтатьиЗатрат.НайтиПоКоду("223 240"); 
		 
		 МассивТоваров = ЭлСоответствия.Значение; 
		 Для каждого ТоварыМассива Из МассивТоваров Цикл
			 
			 СтрокаТоваров = НовыйДокумент.Товары.Добавить(); 
			 СтрокаТоваров.Номенклатура = ТоварыМассива; 	
			 
		 КонецЦикла;
		 
		 МассивДокументов.Добавить(НовыйДокумент);  
		 
	 КонецЦикла;
	 НачатьТранзакцию(); 
	 Для каждого ДокИнв Из МассивДокументов Цикл
		 Попытка
			 
			 ДокИнв.Записать(РежимЗаписиДокумента.Проведение);
			 
		 Исключение
			 Сообщить(ОписаниеОшибки()); 
		 КонецПопытки;
		 
		 
	 КонецЦикла; 
	 если ТранзакцияАктивна() Тогда 
		 ЗафиксироватьТранзакцию();
		 
		 Сообщить(СтрСоединить(МассивДокументов,Символы.ПС)); 
	 КонецЕсли;
 КонецПроцедуры

&НаСервере
Функция АктивныеЗНБНаСервере(СрезНаДату = неопределено)
	
	РезультатТЗ = СформитьТаблицуИсточникАктивныеЗНБ(СрезНаДату);
	
	Об = РеквизитФормыВЗначение("Объект");
	ТабДок = Об.СформироватьТабДокАктивныеЗНБ(РезультатТЗ);
	
	Возврат ТабДок; 
	
КонецФункции

&НаСервере
Функция СформитьТаблицуИсточникАктивныеЗНБ(СрезНаДату)
	//Данилова Е.В. 12.03.2026 SNL-159 
	//изменен запрос 
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
	|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
	|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
	|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
	|ПОМЕСТИТЬ ВТБлокировки
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&ТекущаяДата, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Склад КАК Ссылка
	|ПОМЕСТИТЬ ВТСкладыБлок
	|ИЗ
	|	ВТБлокировки КАК Склады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТСклады
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(Склады.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок)
	|			ИЛИ Склады.ФизическийСклад В
	|				(ВЫБРАТЬ
	|					ВТСкладыБлок.Ссылка
	|				ИЗ
	|					ВТСкладыБлок))
	|	И НЕ Склады.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				ВТБлокировки.Номенклатура
	|			ИЗ
	|				ВТБлокировки)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБПомежуточная
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланНабора.Ссылка КАК ПланНабора,
	|	ЗаданиеНабора.Склад КАК Склад,
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ЗаданиеНабора.СостояниеНакладной КАК СостояниеНакладной
	|ПОМЕСТИТЬ ВТЗаблокированныеТоварыПоПроходнаяНакладная
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
	|			ПО ЗаданиеНабора.Склад = ВТСклады.Ссылка
	|		ПО ЗаданиеНабораТовары.Ссылка = ЗаданиеНабора.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабора
	|		ПО (ПланНабора.ПроходнаяНакладная)
	|			И (ЗаданиеНабора.ДокументОснование = ПланНабора.Ссылка)
	|ГДЕ
	|	ЗаданиеНабора.СостояниеНакладной В(&СостоянияПроверкиЗНБ)
	|	И ЗаданиеНабораТовары.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТТовары.Ссылка
	|			ИЗ
	|				ВТТовары КАК ВТТовары)
	|	И ЗаданиеНабора.Накладная.СостояниеНакладной <> &Отгружена
	|	И ЗаданиеНабора.Накладная.Проведен
	|	И ЗаданиеНабора.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.Склад КАК Склад,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.Номенклатура КАК Номенклатура,
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная.ЗНБ КАК ЗНББлок
	|ПОМЕСТИТЬ ВТАктивныеЗНБ
	|ИЗ
	|	ВТЗаблокированныеТоварыПоПроходнаяНакладная КАК ВТЗаблокированныеТоварыПоПроходнаяНакладная
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланНабора КАК ПланНабораДокумент
	|		ПО ВТЗаблокированныеТоварыПоПроходнаяНакладная.ПланНабора = ПланНабораДокумент.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|		ПО (ПланНабораДокумент.Ссылка = ЗаданиеНабора.ДокументОснование)
	|			И (ЗаданиеНабора.СостояниеНакладной В (&СостоянияПроверкиЗНБ))
	|			И (ЗаданиеНабора.Проведен)
	|			И (ЗаданиеНабора.Ссылка <> ВТЗаблокированныеТоварыПоПроходнаяНакладная.ЗНБ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТАктивныеЗНБПомежуточная КАК ВТАктивныеЗНБ
	|		ПО (ВТАктивныеЗНБ.ЗНБ = ЗаданиеНабора.Ссылка)
	|ГДЕ
	|	ВТАктивныеЗНБ.ЗНБ ЕСТЬ NULL
	|	И (ЗаданиеНабора.СостояниеНакладной В (&СостоянияЗНБ)
	|			ИЛИ ВТЗаблокированныеТоварыПоПроходнаяНакладная.СостояниеНакладной В (&СостоянияЗНБ))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТАктивныеЗНБ.ЗНБ,
	|	ВТАктивныеЗНБ.Склад,
	|	ВТАктивныеЗНБ.Номенклатура,
	|	ВТАктивныеЗНБ.ЗНБ
	|ИЗ
	|	ВТАктивныеЗНБПомежуточная КАК ВТАктивныеЗНБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора КАК ЗНБ,
	|	БлокировкаВыдачиВНаборЗНБ.Ссылка КАК Блокировка
	|ПОМЕСТИТЬ ВТБлокировкиПоЗНБ
	|ИЗ
	|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(&ТекущаяДата, ) КАК БлокировкаВыдачиВНаборСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
	|		ПО БлокировкаВыдачиВНаборСрезПоследних.Регистратор = БлокировкаВыдачиВНаборЗНБ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ПО (ВТАктивныеЗНБ.ЗНБ = БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора)
	|ГДЕ
	|	БлокировкаВыдачиВНаборСрезПоследних.Активен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТБлокировкиПоЗНБ.Блокировка КАК Блокировка,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТАктивныеЗНБВБлокировках
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	НЕ ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБ.ЗНБ КАК ЗНБ,
	|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура,
	|	ВТАктивныеЗНБ.ЗНББлок КАК ЗНББлок
	|ИЗ
	|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБлокировкиПоЗНБ КАК ВТБлокировкиПоЗНБ
	|		ПО ВТАктивныеЗНБ.ЗНБ = ВТБлокировкиПоЗНБ.ЗНБ
	|ГДЕ
	|	ВТБлокировкиПоЗНБ.Блокировка ЕСТЬ NULL
	|ИТОГИ ПО
	|	ЗНБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТАктивныеЗНБВБлокировках.ЗНБ КАК ЗНБ
	|ИЗ
	|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТБлокировки.Блокировка КАК Блокировка,
	|	ВТБлокировки.Склад КАК Склад
	|ИЗ
	|	ВТБлокировки КАК ВТБлокировки";
	
	СостоянияЗНБ = Новый Массив; 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.ОжиданиеНабора); 
	СостоянияЗНБ.Добавить(Перечисления.СостоянияНакладной.ВНаборе);
	Запрос.УстановитьПараметр("СостоянияЗНБ", СостоянияЗНБ);
	
	СостоянияДоОжиданияНабора = Новый Массив; 
	СостоянияДоОжиданияНабора.Добавить(Перечисления.СостоянияНакладной.ПолученоСкладом); 
	СостоянияДоОжиданияНабора.Добавить(Перечисления.СостоянияНакладной.СформированыЗаданияНабора);
	СостоянияДоОжиданияНабора.Добавить(Перечисления.СостоянияНакладной.ПроверенаПоОстаткам);
	Запрос.УстановитьПараметр("СостоянияДоОжиданияНабора", СостоянияДоОжиданияНабора);
	
	СостоянияПроверкиЗНБ = Новый Массив; 
	СостоянияПроверкиЗНБ.Добавить(Перечисления.СостоянияНакладной.ОжиданиеНабора); 
	СостоянияПроверкиЗНБ.Добавить(Перечисления.СостоянияНакладной.ВНаборе);
	СостоянияПроверкиЗНБ.Добавить(Перечисления.СостоянияНакладной.ПолученоСкладом); 
	СостоянияПроверкиЗНБ.Добавить(Перечисления.СостоянияНакладной.СформированыЗаданияНабора);
	СостоянияПроверкиЗНБ.Добавить(Перечисления.СостоянияНакладной.ПроверенаПоОстаткам);
	Запрос.УстановитьПараметр("СостоянияПроверкиЗНБ", СостоянияПроверкиЗНБ);
	
	Запрос.УстановитьПараметр("Отгружена", Перечисления.СостоянияНакладной.Отгружена);
	Если НЕ ЗначениеЗаполнено(СрезНаДату) Тогда		
		Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	Иначе 
		Запрос.УстановитьПараметр("ТекущаяДата",СрезНаДату); 	
	КонецЕсли;
	 
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	ВыборкаАКтЗНБ = ПакетЗапросов[9].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	ВыборкаИтоги = ПакетЗапросов[10].Выбрать();
	
	ТЗБлокировки =  ПакетЗапросов[11].Выгрузить();
	
	МенеджерВременнныхТаблиц = Запрос.МенеджерВременныхТаблиц; 
	
	ТЧАктивныеЗНБ = новый ТаблицаЗначений; 
	ТЧАктивныеЗНБ.Колонки.Добавить("ЗНБ",новый ОписаниеТипов("ДокументСсылка.ЗаданиеНабора"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Номенклатура",новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧАктивныеЗНБ.Колонки.Добавить("Блокировка",новый ОписаниеТипов("ДокументСсылка.БлокировкаВыдачиВНабор"));
	
	ТЧАктивныеЗНБПроходныеРНК = новый ТаблицаЗначений; 
	ТЧАктивныеЗНБПроходныеРНК.Колонки.Добавить("ЗНББлок",новый ОписаниеТипов("ДокументСсылка.ЗаданиеНабора"));
	ТЧАктивныеЗНБПроходныеРНК.Колонки.Добавить("ЗНБАктивное",новый ОписаниеТипов("ДокументСсылка.ЗаданиеНабора"));
	ТЧАктивныеЗНБПроходныеРНК.Колонки.Добавить("Блокировка1",новый ОписаниеТипов("ДокументСсылка.БлокировкаВыдачиВНабор"));
	
	Пока ВыборкаАКтЗНБ.Следующий() Цикл  
		
		
		Для каждого ВыборкаБлокировки Из ТЗБлокировки Цикл
			//	
		//	Если ВыборкаБлокировки.Склад = ВыборкаАКтЗНБ.ЗНБ.Склад 
				//ИЛИ ВыборкаБлокировки.Склад = ВыборкаАКтЗНБ.ЗНБ.Склад.ФизическийСклад Тогда
				Запрос = Новый запрос; 
				Запрос.МенеджерВременныхТаблиц = МенеджерВременнныхТаблиц; 
				
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ВТАктивныеЗНБ.Номенклатура КАК Номенклатура,
				|	ВТАктивныеЗНБ.ЗНББлок КАК ЗНББлок
				|ПОМЕСТИТЬ ВТТоварыЗНБ
				|ИЗ
				|	ВТАктивныеЗНБ КАК ВТАктивныеЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСклады
				|		ПО (СпрСклады.Ссылка = ВТАктивныеЗНБ.Склад)
				|ГДЕ
				|	ВТАктивныеЗНБ.ЗНБ = &ЗНБ
				|	И (СпрСклады.Ссылка = &Склад
				|			ИЛИ СпрСклады.ФизическийСклад = &Склад)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТБлокировки.Номенклатура КАК Номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировки
				|ИЗ
				|	ВТБлокировки КАК ВТБлокировки
				|ГДЕ
				|	ВТБлокировки.Блокировка = &Блокировка
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	номенклатура.Ссылка КАК номенклатура
				|ПОМЕСТИТЬ ВТТоварыБлокировкиЭлементы
				|ИЗ
				|	Справочник.Номенклатура КАК номенклатура
				|ГДЕ
				|	номенклатура.Ссылка В ИЕРАРХИИ
				|			(ВЫБРАТЬ
				|				ВТТоварыБлокировки.Номенклатура
				|			ИЗ
				|				ВТТоварыБлокировки)
				|	И НЕ номенклатура.ЭтоГруппа
				|	И НЕ номенклатура.ПометкаУдаления
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТТоварыЗНБ.Номенклатура КАК Номенклатура,
				|	ВТТоварыЗНБ.ЗНББлок КАК ЗНББлок
				|ИЗ
				|	ВТТоварыЗНБ КАК ВТТоварыЗНБ
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТоварыБлокировкиЭлементы КАК ВТТоварыБлокировкиЭлементы
				|		ПО ВТТоварыЗНБ.Номенклатура = ВТТоварыБлокировкиЭлементы.номенклатура
