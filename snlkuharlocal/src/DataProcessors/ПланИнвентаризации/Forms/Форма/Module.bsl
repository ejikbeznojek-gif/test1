&НаСервере
Функция СоздатьБлокировкуНаСервере()
	
	РезультатПроверки = ПроверитьДействующиеБлокировкиНаДату();
	
	Если  НЕ РезультатПроверки.Успех Тогда
		
		Сообщить(СтрСоединить(РезультатПроверки.Ошибки,Символы.ПС)); 
		Возврат Неопределено; 
		
	КонецЕсли; 
	
	НовыйДокумент = Документы.БлокировкаВыдачиВНабор.СоздатьДокумент();
	НовыйДокумент.Дата = ТекущаяДата(); 
	НовыйДокумент.Автор = ПараметрыСеанса.Пользователь;
	Если ЗначениеЗаполнено(ДатаНачалаБлокировкиFBS) Тогда
	
		НовыйДокумент.ДатаНачалаБлокировкиFBS = ДатаНачалаБлокировкиFBS; 	
	
	КонецЕсли;
	Для каждого ЭлСписка Из Номенклатура Цикл
	
		НоваяСтрока = НовыйДокумент.Номенклатура.Добавить(); 
	    НоваяСтрока.Номенклатура = ЭлСписка.Значение; 
		
	КонецЦикла;
	
	Для каждого ЭлСписка Из Склады Цикл
	
		НоваяСтрока = НовыйДокумент.Склады.Добавить(); 
	    НоваяСтрока.Склад = ЭлСписка.Значение; 
		
	КонецЦикла;
	//НовыйДокумент.Номенклатура.ЗагрузитьКолонку(Номенклатура.ВыгрузитьЗначения(),"номенклатура");  
	//НовыйДокумент.Склады.ЗагрузитьКолонку(Склады.ВыгрузитьЗначения(),"Склад");
	
	//СтрТЧ = НовыйДокумент.ВремяДействия.Добавить();
	//СтрТЧ.ДатаНачала = НаДату;
	
	НовыйДокумент.ДатаНачала  = НаДату; 
	Попытка
		Если ЗначениеЗаполнено(ДатаНачалаБлокировкиFBS) Тогда 
			НовыйДокумент.ДополнительныеСвойства.Вставить("НеПерезаписыватьДатуFBS",истина); 
		КонецЕсли;
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
	     
	Исключение
	    Сообщить(ОписаниеОшибки()); 
	КонецПопытки;
	 
	Возврат НовыйДокумент.Ссылка; 
КонецФункции  

&НаСервере
Функция ПроверитьДействующиеБлокировкиНаДату()
    РезультатПроверки = Новый Структура("Успех,Ошибки",истина,новый Массив); 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(
		|			&НаДату,
		|			Склад В (&Склады)
		|				И Номенклатура В ИЕРАРХИИ (&Номенклатура)) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен";
	
	Запрос.УстановитьПараметр("НаДату", НаДату);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура.ВыгрузитьЗначения());
	Запрос.УстановитьПараметр("Склады", Склады.ВыгрузитьЗначения());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	МассивОшибок = Новый Массив; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТекстОш = СтрШаблон("Есть активные блокировки по выбранным ""склад + номенклатура"": %1 - %2",ВыборкаДетальныеЗаписи.Склад,ВыборкаДетальныеЗаписи.номенклатура); 
		МассивОшибок.Добавить(ТекстОш); 
	КонецЦикла;
	РезультатПроверки.Успех = МассивОшибок.Количество() = 0; 
	РезультатПроверки.Ошибки = МассивОшибок; 
	
	Возврат РезультатПроверки; 

КонецФункции // ПроверитьДействующиеБлокировкиНаДату()

