					КонецЕсли;
					
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ЗначениеЗаполнено(Уровень2.ИНВ) Тогда
				
				Уровень2.Пометка = Истина;
				
				Уровень1.Пометка = Истина; 
				
			КонецЕсли;

		КонецЦикла;
	
