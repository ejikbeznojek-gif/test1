		|ИЗ
		|	ВТАктивныеЗНБВБлокировках КАК ВТАктивныеЗНБВБлокировках
		|ГДЕ
		|	ВТАктивныеЗНБВБлокировках.ЗНБ = &ЗНБ
		|	И НЕ ВТАктивныеЗНБВБлокировках.номенклатура В ИЕРАРХИИ
		|				(ВЫБРАТЬ
		|					ВТТоварыБлокировки.Номенклатура
		|				ИЗ
		|					ВТТоварыБлокировки)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТБлокировкиПОЗНБ1.Блокировка КАК Блокировка
		|ИЗ
		|	ВТБлокировкиПОЗНБ1 КАК ВТБлокировкиПОЗНБ1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТБлокировкиПОЗНБ1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТоварыБлокировки"; 
		
		Запрос.УстановитьПараметр("ЗНБ",ВыборкаИтоги.ЗНБ);
		ПакетЗапросов = Запрос.ВыполнитьПакет(); 
		ВыборкаТоварыВБлокировке =  ПакетЗапросов[2].Выбрать();
		БлокировкиВыборка =  ПакетЗапросов[4].Выбрать();
		МассивТоваровЗНБ =  ПакетЗапросов[3].Выгрузить().ВыгрузитьКолонку("номенклатура"); 
		Пока БлокировкиВыборка.Следующий() Цикл
		
			Пока ВыборкаТоварыВБлокировке.Следующий()  Цикл
			
				
				НСтрока = ТЧАктивныеЗНБ.Добавить(); 	
				НСтрока.Номенклатура = ВыборкаТоварыВБлокировке.Номенклатура; 	
				НСтрока.ЗНБ = ВыборкаИтоги.ЗНБ; 
				НСтрока.Блокировка = БлокировкиВыборка.Блокировка;	
				НСтрока.ДобавленВБлокировку = Истина;	
				
				НСтрока.Пометка = истина; 
				Если ВыборкаИтоги.ЗНБ.СостояниеНакладной = перечисления.СостоянияНакладной.ОжиданиеНабора Тогда
					
					НСтрока.Отсканировать 	= Отсканировать; 	
