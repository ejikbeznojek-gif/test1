	КонецЦикла;
	
	ТЧАктивныеЗНБПроходныеРНК.Свернуть("Блокировка1,ЗНББлок,ЗНБАктивное"); 
	
	Результат = Новый Структура("ТЧАктивныеЗНБ,ТЧАктивныеЗНБПроходныеРНК",ТЧАктивныеЗНБ,ТЧАктивныеЗНБПроходныеРНК); 
	Возврат Результат; 

КонецФункции

&НаСервере
Процедура ОбновитьНаСервере()
	// все активные блокировки на тек. дату. 
	ТекущаяДатаОтбор = ТекущаяДата(); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаВыдачиВНаборСрезПоследних.Склад КАК Склад,
		|	БлокировкаВыдачиВНаборСрезПоследних.Номенклатура КАК Номенклатура,
		|	БлокировкаВыдачиВНаборСрезПоследних.Регистратор КАК Блокировка,
		|	БлокировкаВыдачиВНаборСрезПоследних.Период КАК Датаначала
		|ПОМЕСТИТЬ ВТБлокировки
		|ИЗ
		|	РегистрСведений.БлокировкаВыдачиВНабор.СрезПоследних(, ) КАК БлокировкаВыдачиВНаборСрезПоследних
		|ГДЕ
		|	БлокировкаВыдачиВНаборСрезПоследних.Активен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТБлокировки.Склад КАК Склад,
		|	ВТБлокировки.Номенклатура КАК Номенклатура,
		|	Инвентаризация.Ссылка КАК ИНВ,
		|	Инвентаризация.Дата КАК ДатаИНВ
		|ПОМЕСТИТЬ ВТИнвВсе
		|ИЗ
		|	Документ.Инвентаризация КАК Инвентаризация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Инвентаризация.Товары КАК ИнвентаризацияТовары
		|		ПО Инвентаризация.Ссылка = ИнвентаризацияТовары.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБлокировки КАК ВТБлокировки
		|		ПО (Инвентаризация.Склад = ВЫБОР
		|				КОГДА ВТБлокировки.Склад.ВидСклада = ЗНАЧЕНИЕ(Перечисление.ВидСклада.Физический)
		|					ТОГДА ВТБлокировки.Склад
		|				ИНАЧЕ ВТБлокировки.Склад.ФизическийСклад
		|			КОНЕЦ)
		|			И Инвентаризация.Дата >= ВТБлокировки.Блокировка.Дата
		|ГДЕ
		|	Инвентаризация.Проведен
		|	И ИнвентаризацияТовары.Номенклатура В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				ВТБлокировки.Номенклатура
		|			ИЗ
		|				ВТБлокировки)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИнвВсе.Склад КАК Склад,
		|	ВТИнвВсе.Номенклатура КАК Номенклатура,
		|	ВТИнвВсе.ИНВ КАК ИНВ
		|ПОМЕСТИТЬ ВТИнв
		|ИЗ
		|	ВТИнвВсе КАК ВТИнвВсе
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ВТИнвВсе.Склад КАК Склад,
		|			ВТИнвВсе.Номенклатура КАК Номенклатура,
		|			МАКСИМУМ(ВТИнвВсе.ДатаИНВ) КАК ДатаИНВ
		|		ИЗ
		|			ВТИнвВсе КАК ВТИнвВсе
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ВТИнвВсе.Склад,
		|			ВТИнвВсе.Номенклатура) КАК ВложенныйЗАпрос
		|		ПО ВТИнвВсе.Склад = ВложенныйЗАпрос.Склад
		|			И ВТИнвВсе.Номенклатура = ВложенныйЗАпрос.Номенклатура
		|			И ВТИнвВсе.ДатаИНВ = ВложенныйЗАпрос.ДатаИНВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТБлокировки.Склад КАК Склад,
		|	ВТБлокировки.Номенклатура КАК Номенклатура,
		|	ВТБлокировки.Блокировка КАК Блокировка,
		|	ВТБлокировки.Датаначала КАК Датаначала,
		|	ЕСТЬNULL(ВТИнв.ИНВ, ЗНАЧЕНИЕ(Документ.Инвентаризация.пустаяссылка)) КАК ИНВ,
		|	ЕСТЬNULL(БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора, ЗНАЧЕНИЕ(Документ.ЗаданиеНабора.пустаяссылка)) КАК ЗНБ
		|ИЗ
		|	ВТБлокировки КАК ВТБлокировки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИнвВсе КАК ВТИнв
		|		ПО ВТБлокировки.Склад = ВТИнв.Склад
		|			И ВТБлокировки.Номенклатура = ВТИнв.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.БлокировкаВыдачиВНабор.ЗНБ КАК БлокировкаВыдачиВНаборЗНБ
		|		ПО ВТБлокировки.Блокировка = БлокировкаВыдачиВНаборЗНБ.Ссылка
		|			И (БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора.Склад = ВТБлокировки.Склад
		|				ИЛИ БлокировкаВыдачиВНаборЗНБ.ЗаданиеНабора.Склад.ФизическийСклад = ВТБлокировки.Склад)
		|ИТОГИ
		|	МАКСИМУМ(Блокировка),
		|	МАКСИМУМ(Датаначала),
		|	МАКСИМУМ(ИНВ)
		|ПО
		|	Склад,
		|	Номенклатура";
	Запрос.УстановитьПараметр("СостояниеНакладной",Перечисления.СостоянияНакладной.Отгружена); 
	РезультатЗапроса = Запрос.Выполнить();
	
	ДеревоАктивныеБлокировки = РеквизитФормыВЗначение("АктивныеБлокировки",Тип("ДеревоЗначений")); 
	ДеревоАктивныеБлокировки.Строки.очистить(); 
	
	ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	Пока ВыборкаИтоги.Следующий() Цикл
	
		Уровень1 = ДеревоАктивныеБлокировки.Строки.Добавить(); 
		Уровень1.Склад  = ВыборкаИтоги.Склад; 
		
		ВыборкаИтоги2 = ВыборкаИтоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		
		Пока ВыборкаИтоги2.Следующий() Цикл
		
			Уровень2 = Уровень1.Строки.Добавить(); 
			Уровень2.Номенклатура = ВыборкаИтоги2.Номенклатура; 
			Уровень2.Блокировка = ВыборкаИтоги2.блокировка; 
			//Уровень2.ИНВ = ВыборкаИтоги2.ИНВ; 
			Уровень2.Датаначала = ВыборкаИтоги2.ДатаНачала;
			//Если ЗначениеЗаполнено(Уровень2.ИНВ) Тогда
			//
			//	Уровень2.Пометка = Истина;
			//	
			//	Уровень1.Пометка = Истина; 
			//
			//КонецЕсли;
			
			ВыборкаДетальные =  ВыборкаИтоги2.Выбрать(); 
			
			Пока ВыборкаДетальные.Следующий() Цикл
				
				Если ЗначениеЗаполнено(ВыборкаДетальные.ИНВ) Тогда
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ ПЕРВЫЕ 1
					|	ИнвентаризацияТовары.Ссылка КАК Ссылка
					|ИЗ
					|	Документ.Инвентаризация.Товары КАК ИнвентаризацияТовары
					|ГДЕ
					|	ИнвентаризацияТовары.Ссылка = &Ссылка
					|	И ИнвентаризацияТовары.Номенклатура В ИЕРАРХИИ(&Номенклатура)";
					
					Запрос.УстановитьПараметр("Номенклатура", ВыборкаИтоги2.Номенклатура);
					Запрос.УстановитьПараметр("Ссылка", ВыборкаДетальные.ИНВ);
					
					РезультатЗапроса1 = Запрос.Выполнить();
					
					Если НЕ РезультатЗапроса1.Пустой() Тогда
						
						Уровень2.ИНВ = ВыборкаДетальные.ИНВ;						 	
						
					КонецЕсли;	
					
				КонецЕсли;

				Если ЗначениеЗаполнено( ВыборкаДетальные.ЗНБ) Тогда
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ ПЕРВЫЕ 1
