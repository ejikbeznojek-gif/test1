&НаКлиенте
Процедура АктивныеБлокировкиПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.АктивныеБлокировки.ТекущиеДанные;
	
	Элементы.АктивныеБлокировкиПометка.ТолькоПросмотр = Ложь;
	
	Если ТекущиеДанные <> Неопределено 
		И ЗначениеЗаполнено(ТекущиеДанные.ЗНБ) Тогда
	
		Элементы.АктивныеБлокировкиПометка.ТолькоПросмотр = истина; 	
	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	//Данилова Е.В. 20.02.2026 HELP-8893 
	Если НЕ ВводДоступен() Тогда Возврат КонецЕсли;
	Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	
	глТорговоеОборудование.СканерПосылкаДанных(1);
	глСобытиеСканераОтработано	= Истина;		
	Данные = СтрЗаменить(Данные,Символы.ПС,"");
    ТекущаяСтраница = Элементы.ГруппаСтраницы.ТекущаяСтраница; 
	
	Если  ТекущаяСтраница = Элементы.ГруппаДелениеЗНБ Тогда
		
		Если СтрДлина(Данные)>14 Тогда
			
			ДокументСпецификации= глНайтиДокПоШК(Данные);
			
			Если ДокументСпецификации<>"" и ДокументСпецификации<>Неопределено и ДокументСпецификации.метаданные().имя="ЗаданиеНабора" тогда
				Если РежимДеленияЗНБ = 1 Тогда 
					ЗНБ_ДелениеЗНБ = ДокументСпецификации; 
					
					ДелениеЗНБПриИзмененииНаСервере();
				Иначе
					//надо найти в дереве и снять флаг отсканировать и проставить метку 
					ПометитьЗНБВДеревеДляДеления(ДокументСпецификации); 
				КонецЕсли; 
				
			Иначе
				Сообщить("Не найден ЗНБ по считанным данным!",СтатусСообщения.Важное);
			КонецЕсли;
			
		Иначе
			Сообщить("Неверная длина считанных данных!",СтатусСообщения.Важное); 
		КонецЕсли; 
		
	КонецЕсли;
КонецПроцедуры    


