
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ВыборПунктаДоставки") Тогда
	
		 ВыборПунктаДоставки = Параметры.ВыборПунктаДоставки; 
		 
	
	 КонецЕсли;
	 
	 Если Параметры.Свойство("МассивКонтрагентов") Тогда
	
		 СписокКонтрагентов.ЗагрузитьЗначения(Параметры.МассивКонтрагентов); 
		 
	
	 КонецЕсли;
	 Если Параметры.Свойство("ВыборЮрЛица") Тогда
	
		 ВыборЮрЛица = Параметры.ВыборЮрЛица; 
		 
	
	 КонецЕсли;
	 
	  Если Параметры.Свойство("МассивПунктовДоставки") Тогда
	
		 СписокПунктовДоставки.ЗагрузитьЗначения(Параметры.МассивПунктовДоставки); 
		 
	
	 КонецЕсли;

	 
	 УстановитьВидимость(); 
 КонецПроцедуры
 
