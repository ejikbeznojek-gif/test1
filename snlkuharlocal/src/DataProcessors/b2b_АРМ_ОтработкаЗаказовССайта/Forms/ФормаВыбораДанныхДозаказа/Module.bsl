 &НаСервере
 Процедура УстановитьВидимость()
 
 	Элементы.ГруппаКонтрагенты.Видимость = ВыборЮрЛица; 
	Элементы.ГруппаПунктыДоставки.Видимость = ВыборПунктаДоставки; 
 
 КонецПроцедуры // УстановитьВидимость()


&НаКлиенте
 Процедура ВыбратьПунктДоставки(Команда)
	 
	 ПередатьПунктДоставки();

 КонецПроцедуры
 
 &НаКлиенте
 Процедура ПередатьПунктДоставки()  	
	 
	 ВыделенныеСтроки = Элементы.СписокПунктовДоставки.ВыделенныеСтроки;
	 Если ВыделенныеСтроки.Количество() = 0 Тогда
		 
		 ПоказатьПредупреждение(,"Не выбран элемент"); 
		 Возврат; 
	 КонецЕсли;
	 ЭлементИзСписка = СписокПунктовДоставки.НайтиПоИдентификатору(ВыделенныеСтроки[0]); 
	 Если ЭлементИзСписка <> неопределено Тогда
		 
		 Закрыть(ЭлементИзСписка.Значение); 	
		 
	 КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
 Процедура ПередатьКонтрагента()  	
	 
	 ВыделенныеСтроки = Элементы.СписокКонтрагентов.ВыделенныеСтроки;
	 Если ВыделенныеСтроки.Количество() = 0 Тогда
		 
		 ПоказатьПредупреждение(,"Не выбран элемент"); 
		  Возврат; 
	 КонецЕсли;
	 ЭлементИзСписка = СписокКонтрагентов.НайтиПоИдентификатору(ВыделенныеСтроки[0]); 
	 Если ЭлементИзСписка <> неопределено Тогда
		 
		 Закрыть(ЭлементИзСписка.Значение); 	
		 
	 КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьЮрЛицо(Команда)
	ПередатьКонтрагента(); 
КонецПроцедуры

&НаКлиенте
Процедура СписокКонтрагентовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ПередатьКонтрагента();
КонецПроцедуры

&НаКлиенте
Процедура СписокПунктовДоставкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ПередатьПунктДоставки(); 
КонецПроцедуры


 
