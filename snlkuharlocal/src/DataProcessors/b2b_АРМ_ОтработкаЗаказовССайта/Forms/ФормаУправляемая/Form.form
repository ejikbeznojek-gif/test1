	КОНЕЦ КАК ТекстОшибки,
	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ КАК Документ
ПОМЕСТИТЬ ВТТекстыОшибок
ИЗ
	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, ) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМаксимальныйПериод КАК ВТМаксимальныйПериод
		ПО b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Период = ВТМаксимальныйПериод.Период
			И b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ = ВТМаксимальныйПериод.Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЗаказДокумент.Ссылка КАК Ссылка,
	ЗаказДокумент.Номер КАК Номер,
	ЗаказДокумент.Дата КАК Дата,
	ЗаказДокумент.Контрагент КАК Контрагент,
	ЗаказДокумент.Склад КАК Склад,
	b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b КАК СтатусЗаказа_b2b,
