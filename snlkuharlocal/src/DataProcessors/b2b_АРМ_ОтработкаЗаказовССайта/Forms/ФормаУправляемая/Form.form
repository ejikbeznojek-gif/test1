			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Загружен,
	МАКСИМУМ(ВЫБОР
			КОГДА ЕЭ_Дозаказы_Основной.Заказ ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ЕстьДозаказ,
	МАКСИМУМ(ВЫБОР
			КОГДА b2b_Дозаказы.Заказ ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ЭтоДозаказ,
	ЗаказДокумент.ДатаОтгрузки КАК ДатаОтгрузки,
	b2b_СоответствиеРНКЗаказы.РНК КАК РНК,
	ВТТекстыОшибок.ТекстОшибки КАК ТекстОшибки
ИЗ
	Документ.Заказ КАК ЗаказДокумент
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентов
		ПО ЗаказДокумент.Ссылка = b2b_ЗаявкиКлиентов.Заказ
			И (b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b В (ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.Выполнена), ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.ЧастичноВыполнена)))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
		ПО ЗаказДокумент.Ссылка = b2b_Дозаказы.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК ЕЭ_Дозаказы_Основной
		ПО ЗаказДокумент.Ссылка = ЕЭ_Дозаказы_Основной.ЗаказОсновной
			И ЗаказДокумент.Ссылка &lt;> ЕЭ_Дозаказы_Основной.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_СоответствиеРНКЗаказы КАК b2b_СоответствиеРНКЗаказы
		ПО (b2b_СоответствиеРНКЗаказы.Заказ = ЗаказДокумент.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаказыОбновленные КАК b2b_ЗаказыОбновленные
		ПО ЗаказДокумент.Ссылка = b2b_ЗаказыОбновленные.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ ВТТекстыОшибок КАК ВТТекстыОшибок
		ПО (ВТТекстыОшибок.Документ = ЗаказДокумент.Ссылка)
ГДЕ
	ЗаказДокумент.ИсточникЗаказа = ЗНАЧЕНИЕ(Перечисление.ИсточникЗаказа.Сайт)
	И НЕ ЗаказДокумент.ПометкаУдаления
	И ЗаказДокумент.СостояниеНакладной &lt;> ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказаКонтрагента.Отменен)
	И ВЫБОР
			КОГДА &amp;ОтборПоСтатусамЗаявок
				ТОГДА b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b В (&amp;СтатусыЗаявок)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОтборПоСтатусамДозаказов
				ТОГДА b2b_Дозаказы.СтатусДоЗаказа_b2b В (&amp;СтатусыДозаказов)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОтборПоКонтрагенту
				ТОГДА ЗаказДокумент.Контрагент = &amp;Контрагент
			ИНАЧЕ ИСТИНА
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	b2b_ЗаявкиКлиентов.ДатаОбновления,
	b2b_Дозаказы.СтатусДоЗаказа_b2b,
	b2b_Дозаказы.СрокПодтвержденияПоДозаказу,
	b2b_Дозаказы.ПРМ,
	ЗаказДокумент.Ссылка,
	b2b_ЗаявкиКлиентов.СтатусЗаказа_b2b,
	ЗаказДокумент.Номер,
	ЗаказДокумент.Дата,
	ЗаказДокумент.Контрагент,
	ЗаказДокумент.Склад,
	ЗаказДокумент.ДатаОтгрузки,
	b2b_СоответствиеРНКЗаказы.РНК,
	b2b_ЗаказыОбновленные.Заказ,
	ВТТекстыОшибок.ТекстОшибки</queryText>
      <mainTable>Document.Заказ</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
