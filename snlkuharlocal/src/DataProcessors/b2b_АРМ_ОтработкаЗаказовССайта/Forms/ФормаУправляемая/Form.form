  <attributes>
    <name>Объект</name>
    <id>1</id>
    <valueType>
      <types>DataProcessorObject.b2b_АРМ_ОтработкаЗаказовССайта</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
  </attributes>
  <attributes>
    <name>ЗаказыКработе</name>
    <title>
      <key>ru</key>
      <value>Заказы к работе</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	МАКСИМУМ(b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Период) КАК Период,
	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ КАК Документ
ПОМЕСТИТЬ ВТМаксимальныйПериод
ИЗ
	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, ) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентовСрезПоследних
		ПО (b2b_ЗаявкиКлиентовСрезПоследних.Заказ = b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ)
			И (b2b_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b В (ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором), ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом)))

СГРУППИРОВАТЬ ПО
	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВЫБОР
		КОГДА (ВЫРАЗИТЬ(b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.ТекстОшибки КАК СТРОКА(500))) = &quot;&quot;
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ТекстОшибки,
	b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ КАК Документ
ПОМЕСТИТЬ ВТТекстыОшибок
ИЗ
	РегистрСведений.b2b_ЗапросыНаОбновлениеИстория.СрезПоследних(, ) КАК b2b_ЗапросыНаОбновлениеИсторияСрезПоследних
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМаксимальныйПериод КАК ВТМаксимальныйПериод
		ПО b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Период = ВТМаксимальныйПериод.Период
			И b2b_ЗапросыНаОбновлениеИсторияСрезПоследних.Документ = ВТМаксимальныйПериод.Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЗаказДокумент.Ссылка КАК Ссылка,
	ЗаказДокумент.Номер КАК Номер,
	ЗаказДокумент.Дата КАК Дата,
	ЗаказДокумент.Контрагент КАК Контрагент,
	ЗаказДокумент.Склад КАК Склад,
	b2b_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b КАК СтатусЗаказа_b2b,
	b2b_Дозаказы.СтатусДоЗаказа_b2b КАК СтатусДоЗаказа_b2b,
	b2b_Дозаказы.ПРМ КАК ДокументДозаказа,
	b2b_ЗаявкиКлиентовСрезПоследних.ДатаОбновления КАК ДатаОбновления,
	b2b_Дозаказы.СрокПодтвержденияПоДозаказу КАК СрокПодтвержденияДоЗаказа,
	ВЫБОР
		КОГДА НЕ b2b_ЗаказыОбновленные.Заказ ЕСТЬ NULL
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Загружен,
	МАКСИМУМ(ВЫБОР
			КОГДА ЕЭ_Дозаказы_Основной.Заказ ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ЕстьДозаказ,
	МАКСИМУМ(ВЫБОР
			КОГДА b2b_Дозаказы.Заказ ЕСТЬ NULL
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ЭтоДозаказ,
	ЗаказДокумент.ДатаОтгрузки КАК ДатаОтгрузки,
	b2b_СоответствиеРНКЗаказы.РНК КАК РНК,
	ВТТекстыОшибок.ТекстОшибки КАК ТекстОшибки
ИЗ
	Документ.Заказ КАК ЗаказДокумент
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК b2b_ЗаявкиКлиентовСрезПоследних
		ПО (b2b_ЗаявкиКлиентовСрезПоследних.Заказ = ЗаказДокумент.Ссылка)
			И (b2b_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b В (ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором), ЗНАЧЕНИЕ(Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияКлиентом)))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
		ПО ЗаказДокумент.Ссылка = b2b_Дозаказы.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК ЕЭ_Дозаказы_Основной
		ПО ЗаказДокумент.Ссылка = ЕЭ_Дозаказы_Основной.ЗаказОсновной
			И ЗаказДокумент.Ссылка &lt;> ЕЭ_Дозаказы_Основной.Заказ
			И (НЕ ЕЭ_Дозаказы_Основной.Заказ.ПометкаУдаления)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_СоответствиеРНКЗаказы КАК b2b_СоответствиеРНКЗаказы
		ПО (b2b_СоответствиеРНКЗаказы.Заказ = ЗаказДокумент.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаказыОбновленные КАК b2b_ЗаказыОбновленные
		ПО ЗаказДокумент.Ссылка = b2b_ЗаказыОбновленные.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ ВТТекстыОшибок КАК ВТТекстыОшибок
		ПО (ВТТекстыОшибок.Документ = ЗаказДокумент.Ссылка)
ГДЕ
	ЗаказДокумент.ИсточникЗаказа = ЗНАЧЕНИЕ(Перечисление.ИсточникЗаказа.Сайт)
	И НЕ ЗаказДокумент.ПометкаУдаления
	И ЗаказДокумент.СостояниеНакладной &lt;> ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказаКонтрагента.Отменен)
	И ВЫБОР
			КОГДА &amp;ОтборПоСтатусамЗаявок
				ТОГДА b2b_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b В (&amp;СтатусыЗаявок)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОтборПоСтатусамДозаказов
				ТОГДА b2b_Дозаказы.СтатусДоЗаказа_b2b В (&amp;СтатусыДозаказов)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОтборПоКонтрагенту
				ТОГДА ЗаказДокумент.Контрагент = &amp;Контрагент
			ИНАЧЕ ИСТИНА
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	b2b_ЗаявкиКлиентовСрезПоследних.ДатаОбновления,
	b2b_Дозаказы.СтатусДоЗаказа_b2b,
	b2b_Дозаказы.СрокПодтвержденияПоДозаказу,
	b2b_Дозаказы.ПРМ,
	ЗаказДокумент.Ссылка,
	b2b_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b,
	ЗаказДокумент.Номер,
	ЗаказДокумент.Дата,
	ЗаказДокумент.Контрагент,
	ЗаказДокумент.Склад,
	ЗаказДокумент.ДатаОтгрузки,
	b2b_СоответствиеРНКЗаказы.РНК,
	b2b_ЗаказыОбновленные.Заказ,
	ВТТекстыОшибок.ТекстОшибки</queryText>
      <mainTable>Document.Заказ</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
