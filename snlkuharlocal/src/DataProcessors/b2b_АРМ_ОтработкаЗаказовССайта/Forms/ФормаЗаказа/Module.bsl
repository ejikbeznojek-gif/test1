//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ЗаполнитьАдресаДоставки()
	
	Элементы.ПунктДоставки.СписокВыбора.Очистить();
	
	СоответствиеЮрЛицаПунктыДоставки = Новый Структура("ЮрЛицаПунктыДоставки",новый Соответствие); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	b2b_ПунктыДоставкиДистрибьютора.ПунктДоставки КАК ПунктДоставки,
	|	b2b_ПунктыДоставкиДистрибьютора.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.b2b_ПунктыДоставкиДистрибьютора КАК b2b_ПунктыДоставкиДистрибьютора";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ПунктДоставкиВыборка = неопределено; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Элементы.ПунктДоставки.СписокВыбора.Добавить(ВыборкаДетальныеЗаписи.ПунктДоставки);
		
		ПунктДоставкиВыборка = ВыборкаДетальныеЗаписи.ПунктДоставки;
		
		Если СписокЮрЛицПоДозаказу.НайтиПоЗначению(ВыборкаДетальныеЗаписи.Контрагент) = Неопределено Тогда
		
			СписокЮрЛицПоДозаказу.Добавить(ВыборкаДетальныеЗаписи.Контрагент);
	
		
		КонецЕсли;
				
		МассивПунктовДоставки = СоответствиеЮрЛицаПунктыДоставки.ЮрЛицаПунктыДоставки.Получить(ВыборкаДетальныеЗаписи.Контрагент); 
		
		Если  МассивПунктовДоставки = Неопределено Тогда
			
			МассивПунктовДоставки = Новый Массив; 
			
		КонецЕсли;
		МассивПунктовДоставки.Добавить(ВыборкаДетальныеЗаписи.ПунктДоставки); 
		
		СоответствиеЮрЛицаПунктыДоставки.ЮрЛицаПунктыДоставки.Вставить(ВыборкаДетальныеЗаписи.Контрагент,МассивПунктовДоставки); 
		
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ПунктДоставки) Тогда
		
		Если Элементы.ПунктДоставки.СписокВыбора.НайтиПоЗначению(ПунктДоставки) = Неопределено Тогда
			
			Элементы.ПунктДоставки.СписокВыбора.Добавить(ПунктДоставки); 	
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЮрЛицоДозаказа) Тогда
		
		Если СписокЮрЛицПоДозаказу.НайтиПоЗначению(ЮрЛицоДозаказа) = неопределено  Тогда
			
			СписокЮрЛицПоДозаказу.Добавить(ЮрЛицоДозаказа);	
			
		КонецЕсли;
		
		
		
	КонецЕсли;
	
	
	ДанныеНастроек = b2b_ОбменЗаявками.ПолучитьПараметрыМетодаЗагрузкиПунктовДоставки();
	
	Если НЕ ЗначениеЗаполнено(ПунктДоставки)
		И НЕ ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда  	
		
		Если ЗначениеЗаполнено(ДанныеНастроек.ПунктДоставкиПоУмолчанию) Тогда
			
			ПунктДоставки = ДанныеНастроек.ПунктДоставкиПоУмолчанию;
			
			Если Элементы.ПунктДоставки.СписокВыбора.НайтиПоЗначению(ПунктДоставки) = Неопределено Тогда
				
				Элементы.ПунктДоставки.СписокВыбора.Добавить(ПунктДоставки); 	
				
			КонецЕсли;
			
			
		ИначеЕсли  Элементы.ПунктДоставки.СписокВыбора.Количество() = 1 Тогда
			ПунктДоставки = ПунктДоставкиВыборка;
		КонецЕсли; 	
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЮрЛицоДозаказа)
		И НЕ ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда
		
		
		Если ЗначениеЗаполнено(ДанныеНастроек.КонтрагентПоУмолчанию) Тогда
			
			ЮрЛицоДозаказа = ДанныеНастроек.КонтрагентПоУмолчанию;
			
			Если СписокЮрЛицПоДозаказу.НайтиПоЗначению(ЮрЛицоДозаказа) = неопределено  Тогда
				
				СписокЮрЛицПоДозаказу.Добавить(ЮрЛицоДозаказа);	
				
			КонецЕсли;
			
			
		ИначеЕсли  СписокЮрЛицПоДозаказу.Количество() = 1 Тогда
			
			ЮрЛицоДозаказа = СписокЮрЛицПоДозаказу[0].Значение;	
			
		КонецЕсли; 	
		
	КонецЕсли;
	
	
	
КонецПроцедуры // ЗаполнитьАдресаДоставки()

&НаКлиенте
Процедура ПунктДоставкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если СписокЮрЛицПоДозаказу.Количество() > 1  Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыборЮрЛица",ЭтаФорма);
		
		ПараметрыОткрытия = Новый Структура; 
		ПараметрыОткрытия.Вставить("ВыборЮрЛица",Истина);
		ПараметрыОткрытия.Вставить("МассивКонтрагентов",СписокЮрЛицПоДозаказу.ВыгрузитьЗначения());
		
	    ОткрытьФорму("Обработка.b2b_АРМ_ОтработкаЗаказовССайта.Форма.ФормаВыбораДанныхДозаказа",ПараметрыОткрытия,ЭтаФорма,,,,ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
	КонецЕсли;
	
	
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ВыборЮрЛица(ВыбранныйКонтрагент,ДополнительныеПараметры)Экспорт
	
	Если ВыбранныйКонтрагент <> неопределено  Тогда
		
		ЮрЛицоДозаказа = ВыбранныйКонтрагент;
		
		МассивАдресов = СоответствиеЮрЛицаПунктыДоставки.ЮрЛицаПунктыДоставки.Получить(ЮрЛицоДозаказа);
		
		Если МассивАдресов = неопределено Тогда 
			ПоказатьПредупреждение(,"Не найдено адресов по юр. лицу");
		ИначеЕсли МассивАдресов.Количество() = 1  Тогда
			
			ПунктДоставки = МассивАдресов[0];
			
			Модифицированность = истина;
			ИзмененияПоДозаказу = Истина;
			НадписьИзменений();
			
		ИначеЕсли МассивАдресов.Количество() = 0  Тогда
			
			ПоказатьПредупреждение(,"Не найдено адресов по юр. лицу"); 
		Иначе 
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыборПунктаДоставки",ЭтаФорма);
			
			ПараметрыОткрытия = Новый Структура; 
			ПараметрыОткрытия.Вставить("ВыборПунктаДоставки",Истина);
			ПараметрыОткрытия.Вставить("МассивПунктовДоставки",МассивАдресов);
			
			ОткрытьФорму("Обработка.b2b_АРМ_ОтработкаЗаказовССайта.Форма.ФормаВыбораДанныхДозаказа",ПараметрыОткрытия,ЭтаФорма,,,,ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
			
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры // ()

