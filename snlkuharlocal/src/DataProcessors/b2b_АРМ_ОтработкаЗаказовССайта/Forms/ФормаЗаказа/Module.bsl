#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Заказ") Тогда
		
		Заказ = Параметры.Заказ;
		
		ЭтоДозаказ = Ложь; 
		Если Параметры.Свойство("ЭтоДозаказ") Тогда
		
			ЭтоДозаказ = Параметры.ЭтоДозаказ; 	
		
		КонецЕсли;
		
		Если ЭтоДозаказ Тогда
		
			Заказ = b2b_ОбменЗаявками.НайтиОсновнойЗаказпоДозаказу(Заказ); 
			
			Если НЕ  ЗначениеЗаполнено(Заказ) Тогда
			
			Сообщить("Основной заказ не найден"); 	
			
				Возврат; 
			
			КонецЕсли;
		
		КонецЕсли;
		
		b2b_ОбменЗаявками.ОчиститьРегистрОбновленныеЗаказыПоЗаказу(Заказ);
		
		Дозаказ = b2b_ОбменЗаявками.НайтиДоЗаказпоОсновному(Заказ);
		Если ЗначениеЗаполнено(Дозаказ) Тогда
		
		b2b_ОбменЗаявками.ОчиститьРегистрОбновленныеЗаказыПоЗаказу(Дозаказ);	
		
		КонецЕсли;
		
		ЗаполнитьТаблицуТоваровПоЗаказу(); 
		
		СостояниеЗаказа = Заказ.СостояниеНакладной;
		СостояниеСогласования = Заказ.СостояниеСогласования;
		
		НомерЗаявкиКонтрагента = Заказ.НомерЗаказа; 
		
		РНКСуществующее = неопределено; 
		
		РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Заказ.ссылка,РНКСуществующее);
		Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
			РасходнаяНакладная1 = РНКСуществующее.ссылка;	
		
		КонецЕсли;
		
		РНКСуществующее = неопределено; 
		
		РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Дозаказ.ссылка,РНКСуществующее);
		Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
			РасходнаяНакладная2 = РНКСуществующее.ссылка;	
		
		КонецЕсли;
		
		РедактированиеДозаказаПоУмолчанию = (СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")) 
		И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором");
		Если РедактированиеДозаказаПоУмолчанию Тогда
			
			НеПересчитыватьКоличествоДозаказ = Истина; 	
			
		КонецЕсли;
 
		
		СохранитьЗаказНаСервере(Истина); 
		
	КонецЕсли;
	
	ЗаблокироватьДокументыЗаказовДляРедактирования();
	
	ЗаполнитьАдресаДоставки(); 
	
	ДоступностьРедактированияЗаказа();
	
	ВывестиПодсказкиПредупреждения(); 
	
	УстановитьУсловноеОформление(); 
	
КонецПроцедуры


&НаКлиенте
Процедура ДанныеПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Модифицированность = истина; 
	ИзмененияПоЗаказу = Истина;
	ИзмененияПоЗаказуСтроки = Истина; 
	
	ТекущиеДанные = Элементы.Данные.ТекущиеДанные; 
	Если ТекущиеДанные <> Неопределено Тогда
		
		ТекущиеДанные.ИзмененаСтрока = Истина; 	
		
	КонецЕсли;
	НадписьИзменений();
	ДоступностьЭлементовПриРедактированииНаКлиенте(); 
	//ДоступностьРедактированияЗаказа(); 
КонецПроцедуры

&НаКлиенте
Процедура СостояниеЗаказаПриИзменении(Элемент)
	Модифицированность = истина;
	ИзмененияПоЗаказу = Истина;
КонецПроцедуры
&НаКлиенте
Процедура СостояниеСогласованияПриИзменении(Элемент)
	Модифицированность = Истина; 
	ИзмененияПоЗаказу = Истина;
	НадписьИзменений(); 
КонецПроцедуры

&НаКлиенте
Процедура ПлановаяДатаОтгрузкиПриИзменении(Элемент)
	Модифицированность = истина; 
	ИзмененияПоЗаказу = Истина;
	НадписьИзменений(); 
КонецПроцедуры

&НаКлиенте
Процедура ПунктДоставкиПриИзменении(Элемент)
	Модифицированность = истина;
	ИзмененияПоДозаказу = Истина;
	НадписьИзменений();
КонецПроцедуры


#КонецОбласти    

#Область Команды 

&НаКлиенте
Процедура Сохранить(Команда)
	МассивОшибок.Очистить();
	
	Отбор = Новый Структура("ИзмененаСтрока",истина); 
	Если Данные.НайтиСтроки(Отбор).Количество() > 0// И Не НеПересчитыватьКоличество) 
		 И ДанныеДозаказа.НайтиСтроки(Отбор).Количество() > 0 Тогда //И НЕ НеПересчитыватьКоличествоДозаказ)  Тогда
	
		Сообщить("Изменения будут сохранены только по основному заказу, так как возможны конфликты при записи данных"); 	
		
		МассивОшибок.Добавить("Изменения будут сохранены только по основному заказу, так как возможны конфликты при записи данных"); 
		
		ИзмененияПоДозаказу = Ложь; 
	КонецЕсли;
	
	Если ИзмененияПоЗаказу Тогда
	
		СохранитьЗаказНаСервере();	
		
	Конецесли; 
	
	Если ИзмененияПоДозаказу тогда 
		СохранитьИзмененияВДозаказе();
	КонецЕсли;
	
		
	ЗаполнитьТаблицуТоваровПоЗаказу();
	
	ДоступностьРедактированияЗаказа(); 
	
	НадписьИзменений();
	
	ВывестиТекстошибок(); 
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДозаказ(Команда)
	
	МассивОшибок.Очистить();
	
	СохранитьЗаказНаСервере(,ложь); 
	
	СоздатьДозаказНаСервере();
	
	ОбновитьЗаказНаСервере(); 
	
	ДоступностьРедактированияЗаказа(); 
	
	ВывестиПодсказкиПредупреждения();
	
	ВывестиТекстОшибок();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыФункции
// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ЗаполнитьТаблицуТоваровПоЗаказу()
	
	МассивТоваров = Заказ.Товары.ВыгрузитьКолонку("Номенклатура"); 
	Склад = Заказ.Склад; 
	КэшОстатки = Новый Соответствие; 
	
	b2b_ОбменЗаявками.ПолучитьОстаткиПоЗаявкам(МассивТоваров,Склад,Заказ,КэшОстатки); 
	
		
	//заполняем заказ в наличии или новый заказ 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЗаказТовары.Количество КАК Количество,
	|	ЗаказТовары.ЦенаИсточник КАК ЦенаИсточник,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Цена КАК Цена,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b КАК СостояниеЗаявки,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ПлановаяДатаОтгрузки КАК ПлановаяДатаОтгрузки,
	|	ЗаказТовары.Заявка КАК Заявка,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Цена * ЗаказТовары.Количество КАК Всего,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.МетодДоставки КАК МетодДоставки,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ПричинаОтменыЗаявки КАК ПричинаОтменыЗаявки,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ПричинаОтменыОтгрузкиЗаказа КАК ПричинаОтменыОтгрузкиЗаказа,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ПричинаОтменыОтгрузкиДозаказа КАК ПричинаОтменыОтгрузкиДозаказа,
	|	ЗаказТовары.ПодтвержденнаяЗаявка КАК ПодтвержденнаяЗаявка,
	|	ЗаказТовары.НомерСтроки КАК НомерСтроки,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.КоличествоРезерв КАК КоличествоРезерв,
	|	ЗаказТовары.Количество - ЕСТЬNULL(ЕЭ_ЗаявкиКлиентовСрезПоследних.КоличествоРезерв, 0) КАК КоличествоДозаказ,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Скидка КАК Скидка,
	|	ВЫБОР
	|		КОГДА ЕЭ_ЗаявкиКлиентовСрезПоследних.Цена <> ЗаказТовары.Цена
	|				ИЛИ ЕЭ_ЗаявкиКлиентовСрезПоследних.Скидка <> ЗаказТовары.Скидка
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЕСТЬИзменения,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ДопСкидкаНаНакладную КАК ДопСкидкаНаНакладную,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.СкидкаНаНакладную КАК СкидкаНаНакладную,
	|	ВЫБОР
	|		КОГДА ЕЭ_ЗаявкиКлиентовСрезПоследних.ДопСкидкаНаНакладную <> ЗаказТовары.Ссылка.ДопСкидкаНаНакладную
	|				ИЛИ ЕЭ_ЗаявкиКлиентовСрезПоследних.СкидкаНаНакладную <> ЗаказТовары.Ссылка.Скидка
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЕСТЬИзмененияВЗаказе,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ЦенаБезСкидки КАК ЦенаБезСкидки
	|ИЗ
	|	РегистрСведений.b2b_ЗаявкиКлиентов КАК ЕЭ_ЗаявкиКлиентовСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Заказ.Товары КАК ЗаказТовары
	|		ПО ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ = ЗаказТовары.Ссылка
	|			И ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура = ЗаказТовары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
	|		ПО ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ = b2b_Дозаказы.Заказ
	|			И (b2b_Дозаказы.Заказ = &Заказ)
	|			И (b2b_Дозаказы.Номенклатура = ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура)
	|ГДЕ
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ = &Заказ
	|	И b2b_Дозаказы.Заказ ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Данные.Очистить();
	
	ПерезаписатьЗаказ = Ложь;
	
	РазницаКоличествоРезерв = Ложь;
	ИзмененияПоЗаказуПредварительно = Ложь; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаТовара = Данные.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаТовара,ВыборкаДетальныеЗаписи);
		Если КэшОстатки.Получить(СтрокаТовара.Номенклатура) <> неопределено Тогда
			
			СтрокаТовара.остаток =  КэшОстатки.Получить(СтрокаТовара.Номенклатура).СвободныйОстаток;	
			
		КонецЕсли;
		СостояниеЗаявки = ВыборкаДетальныеЗаписи.СостояниеЗаявки;
		ПлановаяДатаОтгрузки = Заказ.ДатаОтгрузки; //ВыборкаДетальныеЗаписи.ПлановаяДатаОтгрузки; 
		МетодДоставки = ВыборкаДетальныеЗаписи.МетодДоставки; 
		ПричинаОтменыЗаявки = ВыборкаДетальныеЗаписи.ПричинаОтменыЗаявки;
		ПричинаОтменыОтгрузки1 = ВыборкаДетальныеЗаписи.ПричинаОтменыОтгрузкиЗаказа;
		ПричинаОтменыОтгрузки2 = ВыборкаДетальныеЗаписи.ПричинаОтменыОтгрузкиДозаказа;
		Скидка = ВыборкаДетальныеЗаписи.СкидкаНаНакладную; 
		ДопСкидкаНаНакладную = ВыборкаДетальныеЗаписи.ДопСкидкаНаНакладную; 
		
		Если СтрокаТовара.КоличествоРезерв <> СтрокаТовара.Количество 
			 ИЛИ ВыборкаДетальныеЗаписи.ЕстьИзменения тогда 
			 
			РазницаКоличествоРезерв = Истина; 
			
			СтрокаТовара.ИзмененаСтрока = истина; 
		КонецЕсли; 
		
		Если ВыборкаДетальныеЗаписи.ЕСТЬИзмененияВЗаказе Тогда
		
			ИзмененияПоЗаказуПредварительно = Истина; 
		
		КонецЕсли;
		
		
	КонецЦикла;
	
		
	КомментарийКЗаказу = Заказ.Комментарий; 
	//Скидка = заказ.Скидка; 
	//ДопСкидкаНаНакладную = Заказ.ДопСкидкаНаНакладную; 
	
	// Заполняем дозаказ
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЗаказТовары.Количество КАК Количество,
	|	ЗаказТовары.Цена КАК Цена,
	|	ЗаказТовары.ЦенаИсточник КАК ЦенаИсточник,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.СтатусЗаказа_b2b КАК СостояниеЗаявки,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ПлановаяДатаОтгрузки КАК ПлановаяДатаОтгрузки,
	|	b2b_Дозаказы.Комментарий КАК Комментарий,
	|	b2b_Дозаказы.СтатусДоЗаказа_b2b КАК СтатусДоЗаказа_b2b,
	|	b2b_Дозаказы.ЖелаемаяДатаОтгрузки КАК ЖелаемаяДатаОтгрузки,
	|	b2b_Дозаказы.СрокПодтвержденияПоДозаказу КАК СрокПодтвержденияПоДозаказу,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ.СостояниеНакладной КАК СостояниеДозаказа,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ.СостояниеСогласования КАК СостояниеСогласованияДозаказа,
	|	b2b_Дозаказы.Заказ КАК Дозаказ,
	|	ЗаказТовары.Заявка КАК Заявка,
	|	ЗаказТовары.Всего КАК Всего,
	|	ЗаказТовары.ПодтвержденнаяЗаявка КАК ПодтвержденнаяЗаявка,
	|	ЗаказТовары.НомерСтроки КАК НомерСтроки,
	|	ЗаказТовары.Скидка КАК Скидка,
	|	ЕЭ_ЗаявкиКлиентовСрезПоследних.ЦенаБезСкидки КАК ЦенаБезСкидки,
	|	b2b_Дозаказы.ПунктДоставки КАК ПунктДоставки,
	|	b2b_Дозаказы.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.b2b_Дозаказы КАК b2b_Дозаказы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.b2b_ЗаявкиКлиентов КАК ЕЭ_ЗаявкиКлиентовСрезПоследних
	|		ПО (ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ = b2b_Дозаказы.Заказ)
	|			И b2b_Дозаказы.Номенклатура = ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заказ.Товары КАК ЗаказТовары
	|		ПО (ЕЭ_ЗаявкиКлиентовСрезПоследних.Заказ = ЗаказТовары.Ссылка)
	|			И (ЕЭ_ЗаявкиКлиентовСрезПоследних.Номенклатура = ЗаказТовары.Номенклатура)
	|ГДЕ
	|	b2b_Дозаказы.ЗаказОсновной = &Заказ
	|	И НЕ b2b_Дозаказы.Заказ.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ДанныеДозаказа.Очистить();
	Дозаказ = Документы.Заказ.ПустаяСсылка(); 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаТовара = ДанныеДозаказа.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаТовара,ВыборкаДетальныеЗаписи);
		Если КэшОстатки.Получить(СтрокаТовара.Номенклатура) <> неопределено Тогда
			
			СтрокаТовара.остаток =  КэшОстатки.Получить(СтрокаТовара.Номенклатура).СвободныйОстаток;	
			
		КонецЕсли;
		
		СтрокаТовара.КоличествоДозаказ = СтрокаТовара.Количество;
		
		СостояниеЗаказаНадозаказ = ВыборкаДетальныеЗаписи.СостояниеДозаказа; 
		СостояниеСогласованияНаДозаказ =  ВыборкаДетальныеЗаписи.СостояниеСогласованияДозаказа; 		 
		СостояниеДоЗаказа = ВыборкаДетальныеЗаписи.СтатусДоЗаказа_b2b; 
		Дозаказ = ВыборкаДетальныеЗаписи.Дозаказ; 
		КомментарийКДозаказу = ВыборкаДетальныеЗаписи.Комментарий; 
		ЖелаемаяДатаОтгрузки = ВыборкаДетальныеЗаписи.ЖелаемаяДатаОтгрузки; 
		СрокПодтвержденияПоДозаказу = ВыборкаДетальныеЗаписи.СрокПодтвержденияПоДозаказу; 
		ПлановаяДатаОтгрузкиДозаказа = Дозаказ.ДатаОтгрузки;
		ПунктДоставки = ВыборкаДетальныеЗаписи.ПунктДоставки; 
		ЮрЛицоДозаказа = ВыборкаДетальныеЗаписи.Контрагент; 
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СрокПодтвержденияПоДозаказу) Тогда    
		 
	    РазницаВСекундах = СрокПодтвержденияПоДозаказу - ТекущаяДата(); 
		ЧасыЦелые = Цел(РазницаВСекундах/3600); //,0,РежимОкругления.Окр15как10);
		//Минуты = Окр(РазницаВСекундах/60,0,РежимОкругления.Окр15как10) - ЧасыЦелые*60; 
		ОстатокСекунд = РазницаВСекундах  - ЧасыЦелые * 3600; 
		Минуты = Цел(ОстатокСекунд/60); //,0,РежимОкругления.Окр15как10);
		
		СрокПодтвержденияВЧасах = Формат(ЧасыЦелые,"ЧН=0; ЧГ=0") + " ч." + Формат(Минуты,"ЧН=0; ЧГ=0") + "минут"; 
	Иначе 
		СрокПодтвержденияВЧасах = ""; 
	КонецЕсли;  
	 
	 ПричинаОтменыЗаявкиКлиентом = b2b_ОбменЗаявками.ПолучитьЗначениеРеквизитаПоДокументу(Заказ.Ссылка,"ПричинаОтменыЗаявки"); 

	 ЗаполнитьДанныеПодвала();
	 
	 СостояниеСогласования = Заказ.СостояниеСогласования; 
	 СостояниеЗаказа  = Заказ.СостояниеНакладной; 
	 
	 Если РазницаКоличествоРезерв 
		 И (Не ЗначениеЗаполнено(Дозаказ) ИЛИ НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)) 
		 И СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО
		 И СостояниеЗаказа = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе Тогда 
		 
		 ИзмененияПоЗаказу = истина; 
		 
	 КонецЕсли;
	 
	 Если Не ИзмененияПоЗаказу
		 И ИзмененияПоЗаказуПредварительно 
		 
		 И (Не ЗначениеЗаполнено(Дозаказ) ИЛИ НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)) 
		 И СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО
		 И СостояниеЗаказа = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе  Тогда
		 
		 ИзмененияПоЗаказу = истина;
		 
	 КонецЕсли;

	 
	 ТекстОшибкиПосл = b2b_ОбменЗаявками.ВывестиТекстОшибкиПоследний(Заказ);
	 ТекстОшибкиПослДЗ = "";
	 
	 ТекстОшибкиПоследний = ""; 
	 Если ЗначениеЗаполнено(Дозаказ) Тогда
		 
		 ТекстОшибкиПослДЗ = b2b_ОбменЗаявками.ВывестиТекстОшибкиПоследний(Дозаказ);	
		  
	 КонецЕсли;
	 Если ЗначениеЗаполнено(ТекстОшибкиПосл)  Тогда
		 
		 ТекстОшибкиПоследний = "Заказ резерва:" + ТекстОшибкиПосл; 
		 
	 КонецЕсли;
	 
	 Если ЗначениеЗаполнено(ТекстОшибкиПослДЗ) 
		 И ЗначениеЗаполнено(ТекстОшибкиПосл) Тогда
		 
		 ТекстОшибкиПоследний = ТекстОшибкиПоследний + "; Дозаказ ЕЕЭ:" + ТекстОшибкиПослДЗ; 
	 ИначеЕсли ЗначениеЗаполнено(ТекстОшибкиПослДЗ) Тогда
		 
		 ТекстОшибкиПоследний = "Дозаказ ЕЕЭ::" + ТекстОшибкиПослДЗ;
	 КонецЕсли;
	 
	
КонецПроцедуры // ЗаполнитьТаблицуТоваровПоЗаказу()
&НаСервере
Функция СохранитьЗаказНаСервере(ТолькоРегистр = Ложь, ИзменятьДозаказ = Истина)
	
	Если Не ТолькоРегистр Тогда
		
		ОбъектЗаказ  = Заказ.ПолучитьОбъект();
		ОбъектЗаказ.СостояниеНакладной = СостояниеЗаказа;
		ОбъектЗаказ.СостояниеСогласования = СостояниеСогласования; 
		ОбъектЗаказ.ДатаОтгрузки = ПлановаяДатаОтгрузки;
		ОбъектЗаказ.Комментарий = КомментарийКЗаказу;
		ОбъектЗаказ.Скидка = Скидка; 
		ОбъектЗаказ.ДопСкидкаНаНакладную = ДопСкидкаНаНакладную; 
		
		СоответствиеТоварДействие = Новый Соответствие;
		МассивТоваровНаДозаказ = Новый Массив;
		
		ИзменитьДозаказ = Ложь;
		
		ДоступностьРедактированияДоЗаказа = (НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)
		 ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ТребуетПодтверждения) 
		 И СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором;
		
		СоответствиеТоварКоличествоРезерв = Новый Соответствие; 
		СоответствиеТоварЦенаСкидка = Новый Соответствие; 
		
		Для каждого СтрокаТовара Из Данные Цикл
			
			Если НЕ СтрокаТовара.ИзмененаСтрока Тогда
			
				Продолжить; 	
			
			КонецЕсли;
			
			Отбор = Новый Структура("Номенклатура",СтрокаТовара.Номенклатура); 
			СтрокиЗаказа = ОбъектЗаказ.Товары.НайтиСтроки(Отбор);
			
			Если СтрокаТовара.КоличествоДозаказ > 0 Тогда
			
				ИзменитьДозаказ = ДоступностьРедактированияДоЗаказа И ИзменятьДозаказ; 	
			
			КонецЕсли;
			Если СтрокиЗаказа.Количество() > 0  Тогда
				
				Если СтрокаТовара.Количестворезерв = 0 Тогда
				
					ОбъектЗаказ.Товары.Удалить(СтрокиЗаказа[0]); 
					Продолжить; 
				
				КонецЕсли;
				
				СтрокиЗаказа[0].Количество = СтрокаТовара.Количестворезерв; //СтрокаТовара.Количество;
				
				СтруктураЦенаСкидка = Новый Структура("Цена,ЦенаБезСкидки,Скидка,ДопСкидкаНаНакладную,СкидкаНаНакладную"); 
				ЗаполнитьЗначенияСвойств(СтруктураЦенаСкидка,СтрокаТовара); 
				СтруктураЦенаСкидка.СкидкаНаНакладную = Скидка;
				СтруктураЦенаСкидка.ДопСкидкаНаНакладную = ДопСкидкаНаНакладную;
				//
				СоответствиеТоварКоличествоРезерв.Вставить(СтрокаТовара.Номенклатура,СтрокаТовара.КоличествоРезерв); 
				СоответствиеТоварЦенаСкидка.Вставить(СтрокаТовара.Номенклатура,СтруктураЦенаСкидка);
				
				СтрокиЗаказа[0].Цена = СтрокаТовара.Цена;
				СтрокиЗаказа[0].ЦенаБезСкидки = СтрокаТовара.ЦенаБезСкидки;//	
				СтрокиЗаказа[0].Скидка = СтрокаТовара.Скидка;
				//СтрокиЗаказа[0].Сумма = СтрокиЗаказа[0].Цена * СтрокиЗаказа[0].Количество; 
				//СтрокиЗаказа[0].Всего = СтрокиЗаказа[0].Сумма;
				//СтрокиЗаказа[0].ВсегоБезСкидки = СтрокиЗаказа[0].ЦенаБезСкидки * СтрокиЗаказа[0].Количество;
				 b2b_ОбменЗаявками.РассчитатьСуммуТабЧасти_(СтрокиЗаказа[0],ОбъектЗаказ); 
			КонецЕсли;
			//
			//СтруктураТовара = Новый Структура("Действие,КоличествоРезерв,КоличествоДозаказ",СтрокаТовара.Действие,СтрокаТовара.КоличествоРезерв,СтрокаТовара.КоличествоДоЗаказ); 
			//СоответствиеТоварДействие.Вставить(СтрокаТовара.Номенклатура,СтруктураТовара); 
			
		КонецЦикла;
		
		Попытка 			
			
			Попытка			
				ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение); 			
			Исключение
				Если ОбъектЗаказ.Проведен Тогда
					ОбъектЗаказ.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				Иначе 
					ОбъектЗаказ.Записать(РежимЗаписиДокумента.Запись);
				КонецЕсли;
				
			КонецПопытки;
			 
			
			ПараметрыЗаписиВРегистр = Новый Структура; 
			ПараметрыЗаписиВРегистр.Вставить("ПлановаяДатаОтгрузки",ПлановаяДатаОтгрузки);
			ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки);
			ПараметрыЗаписиВРегистр.Вставить("СоответствиеТоварКоличествоРезерв",СоответствиеТоварКоличествоРезерв);
			ПараметрыЗаписиВРегистр.Вставить("СоответствиеТоварЦенаСкидка",СоответствиеТоварЦенаСкидка);
			b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
			
			
			Модифицированность = Ложь;
			ИзмененияПоЗаказу = Ложь;
			ИзмененияПоЗаказуСтроки = Ложь; 
			
			Если ИзменитьДозаказ Тогда
			
				СоздатьДозаказНаСервере();	
			
			КонецЕсли;
			
			 СнятьФлагИзмененияСтроки("Данные");
			 
		Исключение
			 МассивОшибок.Добавить(ОписаниеОшибки()); 
		КонецПопытки;
	Иначе 
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("ПлановаяДатаОтгрузки",ПлановаяДатаОтгрузки);
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки);
		ПараметрыЗаписиВРегистр.Вставить("ВспомогательныеРеквизиты",Истина);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		//ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки); 
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(Дозаказ.Ссылка,ПараметрыЗаписиВРегистр,ЛОЖЬ);
		
	Конецесли; 
	
КонецФункции // ПреобразоватьТоварыДляПередачи()

&НаСервере
Процедура СоздатьДозаказНаСервере()
	
	ИтогДозаказ = Данные.Итог("КоличествоДозаказ"); 
	
	Если ИтогДозаказ = 0  Тогда
		
		Сообщить("Не найдены товары для формирования запроса на дозаказ");
		
		МассивОшибок.Добавить("Не найдены товары для формирования запроса на дозаказ"); 
		Возврат; 
		
	КонецЕсли;
	
	ЗаказНовый = СоздатьНовыйДокументЗаказаПоДозаказу();
	
	ЗаблокироватьДанныеДляРедактирования(ЗаказНовый,,ЭтаФорма.УникальныйИдентификатор); 
	
	ЗаполнитьТаблицуТоваровПоЗаказу();
		
	
КонецПроцедуры

