&НаКлиенте
Процедура ОтменитьЗаказВводПричины(ЗначениеВвода,ДополнительныеПараметры)Экспорт

	Если ЗначениеЗаполнено(ЗначениеВвода) Тогда
	
		ОтменитьЗаказ(ЗначениеВвода);
		
		ПричинаОтменыЗаявки = Строка(ЗначениеВВода); 
		Элементы.ПричинаОтменыЗаявки.Видимость = Истина; 
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("ПричинаОтменыЗаявки",ЗначениеВВода);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();

	Иначе 
		
		 
		 ПоказатьПредупреждение(,"Необходимо обязательно ввести причину!")

	КонецЕсли;

КонецПроцедуры // ОписаниеОповещения()


&НаКлиенте
Процедура ПодтвердитьДозаказ(Команда)
	МассивОшибок.Очистить();
	Если СостояниеДоЗаказа =  ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ПредварительноПодтвержден")
		И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.Согласована") Тогда
	
		ПодтвердитьДозаказНаСервере();
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
	Иначе 
		Сообщить("Запрос на подтверждение не может быть отправлен, проверьте состояние заявки");
		МассивОшибок.Добавить("Запрос на подтверждение не может быть отправлен, проверьте состояние заявки"); 
	КонецЕсли;
	ВывестиТекстОшибок();
КонецПроцедуры

