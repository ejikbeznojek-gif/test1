&НаКлиенте
Процедура ЗаполнитьПоОстаткамНаКлиенте(ЗаполнениеПоДозаказу = Ложь)
	
	ТаблицаДанных = ?(ЗаполнениеПоДозаказу,"ДанныеДозаказа","Данные"); 
	
	Для каждого СтрокаДанных Из ЭтаФорма[ТаблицаДанных] Цикл
		
		КоличествоРезервДо = СтрокаДанных.Количестворезерв; 
		КоличествоДозаказДо = СтрокаДанных.КоличествоДозаказ; 
		
		Если ТаблицаДанных = "ДанныеДозаказа"
			И Не ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда
		
			ПодтвержденнаяЗаявка = СтрокаДанных.Заявка; 	
		Иначе 
			ПодтвержденнаяЗаявка = СтрокаДанных.ПодтвержденнаяЗаявка;
		КонецЕсли;
		
		СтрокаДанных.Количестворезерв = Мин(СтрокаДанных.Остаток,ПодтвержденнаяЗаявка); 
		СтрокаДанных.КоличествоДозаказ = ПодтвержденнаяЗаявка - СтрокаДанных.КоличествоРезерв; 
		
		Если КоличествоРезервДо <> СтрокаДанных.Количестворезерв 
			ИЛИ КоличествоДозаказДо <> СтрокаДанных.КоличествоДозаказ Тогда
		
			СтрокаДанных.ИзмененаСтрока = Истина; 
		
		КонецЕсли;
	
	КонецЦикла;
	
	ИзмененияПоДозаказу = ЗаполнениеПоДозаказу; 
	ИзмененияПоЗаказу = Не ЗаполнениеПоДозаказу;
	ИзмененияПоЗаказуСтроки = Не ЗаполнениеПоДозаказу; 

КонецПроцедуры // ЗаполнитьПоОстаткамНаКлиенте()

&НаКлиенте
Процедура ЗаполнитьПоОстаткамДозаказ(Команда)
	ЗаполнитьПоОстаткамНаКлиенте(Истина);
КонецПроцедуры

