&НаСервере
Процедура СохранитьИзмененияВДозаказе()	
	
	ИзменитьЗаказ  = Истина; 
	
	ОбъектЗаказ  = Дозаказ.ПолучитьОбъект();
	
	Если ЗначениеЗаполнено(ПлановаяДатаОтгрузкиДозаказа) Тогда
		
		ОбъектЗаказ.ДатаОтгрузки = ПлановаяДатаОтгрузкиДозаказа;	
		
	КонецЕсли;
	
	ОбъектЗаказ.Комментарий = КомментарийКДозаказу; 
	
	Для каждого СтрокаДозаказа Из ДанныеДозаказа Цикл
	
		Если НЕ СтрокаДозаказа.ИзмененаСтрока Тогда
		
			Продолжить; 
		
		КонецЕсли;
		
		Отбор = Новый Структура("Номенклатура",СтрокаДозаказа.Номенклатура); 
		СтрокиЗаказа = ОбъектЗаказ.Товары.НайтиСтроки(Отбор);
		
		Если СтрокаДозаказа.КоличествоРезерв > 0 Тогда
			
			ИзменитьЗаказ = истина; 	
		 
		КонецЕсли;
		Если СтрокиЗаказа.Количество() > 0  Тогда  
			
			
			Если СтрокаДозаказа.КоличествоДозаказ = 0 Тогда
				
				ОбъектЗаказ.Товары.Удалить(СтрокиЗаказа[0]); 
			Иначе 
				
				СтрокиЗаказа[0].Количество = СтрокаДозаказа.КоличествоДозаказ; //СтрокаТовара.Количество;
				Если Не ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда
				
					СтрокиЗаказа[0].Заявка = СтрокиЗаказа[0].Количество;	
				
				КонецЕсли;
				// 
				СтрокиЗаказа[0].Цена = СтрокаДозаказа.Цена; 
				СтрокиЗаказа[0].ЦенаБезСкидки = СтрокаДозаказа.ЦенаБезСкидки;//	
				СтрокиЗаказа[0].Скидка = СтрокаДозаказа.Скидка;
				//СтрокиЗаказа[0].Сумма = СтрокиЗаказа[0].Цена * СтрокиЗаказа[0].Количество; 
				//СтрокиЗаказа[0].Всего = СтрокиЗаказа[0].Сумма;
				//СтрокиЗаказа[0].ВсегоБезСкидки = СтрокиЗаказа[0].ЦенаБезСкидки * СтрокиЗаказа[0].Количество;
				
				b2b_ОбменЗаявками.РассчитатьСуммуТабЧасти_(СтрокиЗаказа[0],ОбъектЗаказ); 
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла;
	
	Попытка
		Попытка
		
			ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение);
		
		Исключение
		    ОбъектЗаказ.Записать(РежимЗаписиДокумента.Запись);
		КонецПопытки;
			
		Модифицированность = Ложь; 
		ИзмененияПоДозаказу = ЛОЖЬ;
		
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("Комментарий",КомментарийКДозаказу);
		ПараметрыЗаписиВРегистр.Вставить("ЖелаемаяДатаОтгрузки",ЖелаемаяДатаОтгрузки);
		ПараметрыЗаписиВРегистр.Вставить("ПунктДоставки",ПунктДоставки);
		ПараметрыЗаписиВРегистр.Вставить("Контрагент",ЮрЛицоДозаказа);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(Дозаказ.Ссылка,ПараметрыЗаписиВРегистр,ложь);
	
		Если ИзменитьЗаказ Тогда
		
			
		     ОбъектОсновнойЗаказ  = Заказ.ПолучитьОбъект();
			 
			 Для каждого  СтрокаДозаказа Из ДанныеДозаказа  Цикл
				 
				 Если НЕ СтрокаДозаказа.ИзмененаСтрока Тогда
					 
					 Продолжить; 
					 
				 КонецЕсли;
				 
				 Отбор = Новый Структура("Номенклатура",СтрокаДозаказа.Номенклатура); 
				 СтрокиЗаказа = ОбъектОсновнойЗаказ.Товары.НайтиСтроки(Отбор);
				 
				 Если СтрокиЗаказа.Количество() = 0 
					 И СтрокаДозаказа.КоличествоРезерв > 0 Тогда
					 
					 ТоварВЗаказе = ОбъектОсновнойЗаказ.Товары.Добавить(); 
					 ЗаполнитьЗначенияСвойств(ТоварВЗаказе,СтрокаДозаказа); 
					 //ТоварВЗаказе.ПодтвержденнаяЗаявка = ТоварВЗаказе.Заявка; 
					 ТоварВЗаказе.Количество = СтрокаДозаказа.КоличествоРезерв;
					 ТоварВЗаказе.ПодтвержденнаяЗаявка = ТоварВЗаказе.Количество;
					 
				 ИначеЕсли СтрокаДозаказа.КоличествоРезерв > 0 Тогда  
					 ТоварВЗаказе = СтрокиЗаказа[0];
					 ТоварВЗаказе.Количество = ТоварВЗаказе.Количество + СтрокаДозаказа.КоличествоРезерв;
				 Иначе 
					 Продолжить; 
				 КонецЕсли;
				 
				 //ТоварВЗаказе.Сумма = ТоварВЗаказе.Цена * ТоварВЗаказе.Количество; 
				 //ТоварВЗаказе.Всего = ТоварВЗаказе.Сумма;
				 //ТоварВЗаказе.ВсегоБезСкидки = ТоварВЗаказе.ЦенаБезСкидки * ТоварВЗаказе.Количество;
				  b2b_ОбменЗаявками.РассчитатьСуммуТабЧасти_(ТоварВЗаказе,ОбъектОсновнойЗаказ);
			 КонецЦикла;
			 
			 Попытка 		 
				 
				 ОбъектОсновнойЗаказ.Записать(РежимЗаписиДокумента.Проведение);
			 Исключение
				 Если ОбъектОсновнойЗаказ.Проведен Тогда
					 ОбъектОсновнойЗаказ.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				 Иначе 
					 ОбъектОсновнойЗаказ.Записать(РежимЗаписиДокумента.Запись);
				 КонецЕсли;
				 
			 КонецПопытки;
			  
			 
			 
			 ПараметрыЗаписиВРегистр = Новый Структура; 
			 
			 ПараметрыЗаписиВРегистр.Вставить("ПлановаяДатаОтгрузки",ПлановаяДатаОтгрузки);
			 b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
			 
		 КонецЕсли;
		 
		 СнятьФлагИзмененияСтроки("ДанныеДозаказа"); 
		
	Исключение
		Сообщить(ОписаниеОшибки()); 
		МассивОшибок.Добавить(ОписаниеОшибки()); 
	КонецПопытки; 

КонецПроцедуры // СохоанитьИзмененияВДозаказе()

