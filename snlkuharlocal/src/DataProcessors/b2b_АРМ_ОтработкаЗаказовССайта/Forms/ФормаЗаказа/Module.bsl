//
&НаСервере
Функция ВывестиПодсказкиПредупреждения()

	ТипыЗапросовВналичии.ЗагрузитьЗначения(b2b_ОбменЗаявками.НеотработанныеЗапросыНаСайт(Заказ));
	ТипыЗапросовДозаказ.ЗагрузитьЗначения(b2b_ОбменЗаявками.НеотработанныеЗапросыНаСайт(Дозаказ));

КонецФункции // ВывестиПодсказкиПредупреждения()

&НаСервере
Процедура ОтправитьНаСогласованиеВналичииНаСервере()
	ОтправитьНаСогласованиеТолькоЗаказ();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНаСогласованиеВналичии(Команда)
	
	МассивОшибок.Очистить();
	
	Если НЕ Заказ.Проведен Тогда
		
		ОповещениеВопрос = Новый ОписаниеОповещения("ВопросПровестиДокументОтправкаВНаличии",ЭтаФорма,Заказ); 
		ПоказатьВопрос(ОповещениеВопрос,"Документ не проведен, провести документ?",РежимДиалогаВопрос.ДаНет); 
		
		
	Иначе 
		ОтправитьНаСогласованиеВналичииНаСервере();
		
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
	КонецЕсли;

	
	
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ВопросПровестиДокументОтправкаВНаличии(ОтветНаВопрос,ДополнительныеПараметры) Экспорт 
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		ТекстСообщения = ""; 
		РезультатПроведения = Ложь; 
		
		ПровестиДокументЗаказаНаСервере(ДополнительныеПараметры,РезультатПроведения,ТекстСообщения); 
		МассивОшибок.Добавить(ТекстСообщения);
		
		Если  РезультатПроведения Тогда
			
			ОтправитьНаСогласованиеВналичииНаСервере();		
			
			ОбновитьЗаказНаСервере();
			ДоступностьРедактированияЗаказа(); 	
			ВывестиПодсказкиПредупреждения();			
			
		КонецЕсли;
		
		ВывестиТекстОшибок();
		
		
		
	Иначе 
		ПоказатьПредупреждение(,"Операция отменена, нельзя отпправить на согласование непроведенные документы"); 
	КонецЕсли; 	

КонецПроцедуры // ()

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервереБезКонтекста
Процедура ПровестиДокументЗаказаНаСервере(Знач ДокЗаказа, РезультатПроведения, ТекстСообщения)

	ДокЗаказаОбъект = ДокЗаказа.ПолучитьОбъект();
	Попытка
		
		ДокЗаказаОбъект.Записать(РежимЗаписиДокумента.Проведение); 
		ТекстСообщения = "Документ успешно проведен"; 
		
		РезультатПроведения = Истина; 
	Исключение
		
		ТекстСообщения = "Не удалось провести документ" + Символы.ПС + ОписаниеОшибки(); 
		
	КонецПопытки;

КонецПроцедуры // ПровестиДокументЗаказаНаСервере()



&НаКлиенте
Процедура ОткрытьДозаказ(Команда)
	РазблокироватьДокументыЗаказовДляРедактирования(,Истина);
	//ДанныеЗакрытия = ОткрытьФормуМодально("Документ.Заказ.Форма.ФормаДокумента",Новый Структура("Ключ",Дозаказ),ЭтаФорма);
	
	ФормаЗаказа = ПолучитьФорму("Документ.Заказ.Форма.ФормаДокумента",Новый Структура("Ключ",Дозаказ),ЭтаФорма); 
	ФормаЗаказа.ИзАРМb2b = истина; 
	ФормаЗаказа.КлючУникальности = Строка(Новый УникальныйИдентификатор); 
	
	ФормаЗаказа.ОткрытьМодально(); 
	
	ОбновитьИзЗаказа("");
	Если НЕ ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда
		
		//ЗаполнитьТаблицуТоваровПоЗаказу(); 
		//СохранитьЗаказНаСервере(Истина); 	
		
		СохранитьЗаказНаСервере(Истина);
		
	КонецЕсли;
	ЗаблокироватьДокументыЗаказовДляРедактирования(,Истина); 
	 
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеВФормеДоЗаказаЗакрытие(ПараметрЗакрытия,ДополнительныеПараметры) Экспорт

	
КонецПроцедуры

&НаКлиенте
Процедура ПовторитьСозданиеДозаказаНаПортал(Команда)	
	
	Если Не ЗначениеЗаполнено(ПунктДоставки) Тогда
		
		ПоказатьПредупреждение(,"Не заполнен адрес доставки"); 
		Возврат; 	
		
	КонецЕсли;
	МассивОшибок.Очистить();
	
	МассивСообщений = Новый Массив; 
	
	b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Дозаказ.ссылка,"СоздатьДозаказ",Новый Структура,МассивСообщений);
	
	Сообщить("Отправлен запрос на дозаказ");
	МассивОшибок.Добавить("Отправлен запрос на дозаказ"); 
	
	Для каждого ЭлементМассива Из МассивСообщений Цикл
	
		МассивОшибок.Добавить(ЭлементМассива); 	
	
	КонецЦикла;
	
	ОбновитьЗаказНаСервере();
	ДоступностьРедактированияЗаказа(); 	
	ВывестиПодсказкиПредупреждения();
	ВывестиТекстОшибок(); 

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИзЗаказа(Команда)
	Если Команда <> ""  Тогда
	
		МассивОшибок.Очистить();	
	
	КонецЕсли;
	
	ЗаполнитьТаблицуТоваровПоЗаказу(); 
	
	СостояниеЗаказа = Заказ.СостояниеНакладной;
	СостояниеСогласования = Заказ.СостояниеСогласования; 
	
	РНКСуществующее = неопределено; 
	
	РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Заказ.ссылка,РНКСуществующее);
	Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
		РасходнаяНакладная1 = РНКСуществующее.ссылка;	
	Иначе
		РасходнаяНакладная1 = ПредопределенноеЗначение("Документ.РасходнаяНакладная.ПустаяСсылка"); 
	КонецЕсли;
	
	РНКСуществующее = неопределено; 
	
	РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Дозаказ.ссылка,РНКСуществующее);
	Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
		РасходнаяНакладная2 = РНКСуществующее.ссылка;	
	Иначе 
		РасходнаяНакладная2 = ПредопределенноеЗначение("Документ.РасходнаяНакладная.ПустаяСсылка");
	КонецЕсли;
	
	ДоступностьРедактированияЗаказа();
	
	ВывестиПодсказкиПредупреждения();
	ВывестиТекстОшибок();

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНаСогласованиеДозаказ(Команда)
	
	МассивОшибок.Очистить();
	
	Если Не Дозаказ.Проведен Тогда
		
		ОповещениеВопрос = Новый ОписаниеОповещения("ВопросПровестиДокументОтправкаДозаказ",ЭтаФорма,Дозаказ); 
		ПоказатьВопрос(ОповещениеВопрос,"Документ не проведен, провести документ?",РежимДиалогаВопрос.ДаНет);  	
		
	ИначеЕсли ПроверкаСостоянияДозаказа() Тогда  		
		
		ОтправитьНаСогласованиеТолькоДоЗаказ();
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
		
	КонецЕсли;
 
КонецПроцедуры

&НаКлиенте
Процедура ВопросПровестиДокументОтправкаДозаказ(ОтветНаВопрос,ДополнительныеПараметры) Экспорт 
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		ТекстСообщения = ""; 
		РезультатПроведения = Ложь; 
		
		ПровестиДокументЗаказаНаСервере(ДополнительныеПараметры,РезультатПроведения,ТекстСообщения); 
		МассивОшибок.Добавить(ТекстСообщения);
		
		Если  РезультатПроведения Тогда
			
			ОтправитьНаСогласованиеТолькоДоЗаказ();		
			
			ОбновитьЗаказНаСервере();
			ДоступностьРедактированияЗаказа(); 	
			ВывестиПодсказкиПредупреждения();			
			
		КонецЕсли;
		
		ВывестиТекстОшибок();
		
		
		
	Иначе 
		ПоказатьПредупреждение(,"Операция отменена, нельзя отпправить на согласование непроведенные документы"); 
	КонецЕсли; 	

КонецПроцедуры // ()


