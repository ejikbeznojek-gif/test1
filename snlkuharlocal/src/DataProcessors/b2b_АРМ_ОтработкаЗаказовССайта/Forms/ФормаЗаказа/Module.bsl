&НаКлиенте
Процедура ВыборИзСпискаМетодДоставки(ВыбранноеЗначение,ДополнительныеПараметры) Экспорт 
	Если ВыбранноеЗначение = неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	Если ЗначениеЗаполнено(ВыбранноеЗначение.Значение)  Тогда  		
			
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр); 		
		
		ПараметрыНаотправку = Новый Структура;
		ПараметрыНаотправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		ПараметрыНаотправку.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
		
		МассивСообщений = Новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(заказ,"ИзменитьМетодДоставки",ПараметрыНаотправку,МассивСообщений);
		
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();

	КонецЕсли;
	

КонецПроцедуры // ВыборИзСпискаМетодДоставки()

&НаКлиенте
Процедура ОтработатьОтгрузку(Команда)
	
	МассивОшибок.Очистить();
	Если  НЕ ЗначениеЗаполнено(МетодДоставки)
		 	И (ЗначениеЗаполнено(Дозаказ)
		 	И СостояниеДоЗаказа <> ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен"))  
		    И СостояниеЗаказа <> ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.Отменен")   Тогда
	
		МетодыДоставки = Новый СписокЗначений; 				
		МетодыДоставки.Добавить("F","Заказ и дозаказ вместе"); 
		МетодыДоставки.Добавить("P","Заказ и дозаказ отдельно");  
		
		ОповещениеВыборИзСписка = Новый ОписаниеОповещения("ВыборИзСпискаМетодДоставкиБезОтправки",ЭтаФорма, Новый Структура); 
		
		ПоказатьВыборИзСписка(ОповещениеВыборИзСписка,МетодыДоставки,Элементы.ОтработатьОтгрузку);
 
		
	Иначе   		 
		 
		 ОтработатьОтгрузкуВОчередь(); 
		 
		 ОбновитьЗаказНаСервере();
		 ДоступностьРедактированияЗаказа(); 	
		 ВывестиПодсказкиПредупреждения();
		 ВывестиТекстОшибок();

	 КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
Процедура ОтработатьОтгрузкуВОчередь(ЗаписатьМетодДоставки = Ложь) 	
	
	ПараметрыНаОтправку = Новый Структура;
	ПараметрыНаОтправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
	
	ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
	
	Если ЗначениеЗаполнено(РасходнаяНакладная1.ДатаОтгрузки)
		И РасходнаяНакладная1.СостояниеНакладной = ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена")  Тогда
		
		ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",РасходнаяНакладная1.ДатаОтгрузки);	
		
	КонецЕсли;
	
	Если МетодДоставки = "F"  Тогда
		Если ЗначениеЗаполнено(Дозаказ) 
			И РасходнаяНакладная2.СостояниеНакладной <>  ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена") Тогда
			
			МетодДоставки = "P";
			
			ЗаписатьМетодДоставки = Истина; 
		КонецЕсли;
		
		Если ЗначениеЗаполнено(РасходнаяНакладная1.ДатаОтгрузки)
			И РасходнаяНакладная1.СостояниеНакладной <> ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена")  Тогда
			
			МетодДоставки = "P";	
			
			ЗаписатьМетодДоставки = Истина;
		КонецЕсли;
		
		Если РасходнаяНакладная2.СостояниеНакладной =  ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена")
			И РасходнаяНакладная1.СостояниеНакладной <> ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена") 
			 И НачалоДня(РасходнаяНакладная1.ДатаОтгрузки) <> НачалоДня(РасходнаяНакладная2.ДатаОтгрузки) Тогда
		
			 МетодДоставки = "P";	
			 
			 ЗаписатьМетодДоставки = Истина;
		
		КонецЕсли;
    КонецЕсли;
	
	
	Если МетодДоставки = "F"  Тогда
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиВместе";
		
		ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",РасходнаяНакладная1.ДатаОтгрузки);
		
	КонецЕсли;
	
	Если МетодДоставки = "P"  Тогда
		
		ТипЗапроса = "ОтправитьДатуОтгрузкиОтдельно";
		
		Если ЗначениеЗаполнено(Дозаказ) 
			И РасходнаяНакладная2.СостояниеНакладной = ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена") Тогда
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",РасходнаяНакладная2.ДатаОтгрузки);
			
		КонецЕсли; 
		Если РасходнаяНакладная1.СостояниеНакладной = ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена") Тогда
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиЗаказа",РасходнаяНакладная1.ДатаОтгрузки); 			 
		КонецЕсли;
		
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(МетодДоставки) Тогда
	
		Если ЗначениеЗаполнено(РасходнаяНакладная2.ДатаОтгрузки)
			И РасходнаяНакладная2.СостояниеНакладной = ПредопределенноеЗначение("Перечисление.СостоянияНакладной.Отгружена")  Тогда
			
			ПараметрыНаОтправку.Вставить("ДатаОтгрузкиДозаказа",РасходнаяНакладная2.ДатаОтгрузки);	
			
		КонецЕсли;	
	
	КонецЕсли;
	
	Если ЗаписатьМетодДоставки Тогда
	
		ПараметрыНаОтправку.Вставить("МетодДоставки",МетодДоставки); 	
	
	КонецЕсли;
	
	МассивСообщений = Новый Массив; 
	b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Заказ,ТипЗапроса,ПараметрыНаОтправку,МассивСообщений);
	
	Для каждого ЭлементМассива Из МассивСообщений Цикл
		
		МассивОшибок.Добавить(ЭлементМассива); 	
		
	КонецЦикла;


КонецПроцедуры

&НаКлиенте
Процедура ВыборИзСпискаМетодДоставкиБезОтправки(ВыбранноеЗначение,ДополнительныеПараметры) Экспорт 
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение.Значение)  Тогда  		
			
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр); 		
		
		ОтработатьОтгрузкуВОчередь(истина); 
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
		
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура ОтменитьОтгрузкуСоСклада(Команда)
	
	перем ПричинаТекст; 
	
	МассивОшибок.Очистить();
	//ПричинаТекст = "Причина отмены"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьОтгрузкуСоСкладаВводПричины",ЭтаФорма); 
	ПоказатьВводЗначения(ОписаниеОповещения,ПричинаТекст,"Причина отмены",Тип("СправочникСсылка.b2b_ПричиныОтменыЗаявок")); 	
	
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ОтменитьОтгрузкуСоСкладаВводПричины(ПричинаВведенная,ДополнительныеПараметры) Экспорт 

	Если ЗначениеЗаполнено(ПричинаВведенная) Тогда
		
		ПараметрыНаОтправку = Новый Структура;
		ПараметрыНаОтправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		ПараметрыНаОтправку.Вставить("ОтменаЗаказа",Истина);
		ПараметрыНаОтправку.Вставить("КомментарийОтменаЗаказа",Строка(ПричинаВведенная));
		ПараметрыНаОтправку.Вставить("ПричинаОтменаЗаказа",Строка(ПричинаВведенная));
		
		МассивСообщений = Новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Заказ,"ОтменитьотгрузкуВналичии",ПараметрыНаОтправку,МассивСообщений);
		
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;

		
		ПричинаОтменыОтгрузки1 = Строка(ПричинаВведенная); 
		Элементы.ПричинаОтменыОтгрузки1.Видимость = Истина; 
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("ПричинаОтменыОтгрузкиЗаказа",ПричинаВведенная);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
	Иначе 
		ПоказатьПредупреждение(,"Необходимо обязательно ввести причину!")
	КонецЕсли;

КонецПроцедуры // ()


&НаКлиенте
Процедура ОтменитьОтгрузкуДозаказа(Команда)
	
	Перем ПричинаТекст; 
	
	МассивОшибок.Очистить();
	
	//ПричинаТекст = "Причина отмены"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьОтгрузкуДозаказаВводПричины",ЭтаФорма); 
	ПоказатьВводЗначения(ОписаниеОповещения,ПричинаТекст,"Причина отмены",Тип("СправочникСсылка.b2b_ПричиныОтменыЗаявок")); 
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьОтгрузкуДозаказаВводПричины(ПричинаВведенная,ДополнительныеПараметры) Экспорт 

	Если ЗначениеЗаполнено(ПричинаВведенная) Тогда
		
		ПараметрыНаОтправку = Новый Структура;
		ПараметрыНаОтправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		ПараметрыНаОтправку.Вставить("ОтменаДозаказа",Истина);
		
		ПараметрыНаОтправку.Вставить("КомментарийОтменаДоЗаказа",Строка(ПричинаВведенная));
		ПараметрыНаОтправку.Вставить("ПричинаОтменаДоЗаказа",Строка(ПричинаВведенная));
		
		МассивСообщений = Новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Дозаказ,"ОтменитьОтгрузкуДозаказа",ПараметрыНаОтправку,МассивСообщений);
		
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;

		
		ПричинаОтменыОтгрузки2 = Строка(ПричинаВведенная); 
		Элементы.ПричинаОтменыОтгрузки2.Видимость = Истина; 
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("ПричинаОтменыОтгрузкиДозаказа",ПричинаВведенная);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
		
	Иначе 
		ПоказатьПредупреждение(,"Необходимо обязательно ввести причину!")
	КонецЕсли;

КонецПроцедуры // ()


