&НаКлиенте
Процедура СоздатьРНКОбщий(Команда)
	//создаем 2 РНК 
	МассивОшибок.Очистить();
	
	Если Не ЗначениеЗаполнено(Дозаказ)
		
		 ИЛИ (ЗначениеЗаполнено(Дозаказ) 
		 И СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен")) Тогда
		
		СоздатьРНКНаКлиенте(Заказ,ПлановаяДатаОтгрузки,Ложь,Элементы.СоздатьРНКОбщий);
		
		
	ИначеЕсли ЗначениеЗаполнено(Дозаказ) И СостояниеЗаказа = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.Отменен") Тогда 
		
		 
		СоздатьРНКНаКлиенте(Дозаказ,ДатаОтгрузкиПоЗаказу(Дозаказ),истина,Элементы.СоздатьРНКОбщий);
		
		
	Иначе 
		
		
		СостояниеЗаказаДБ1 = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВРаботе");
		СостояниеЗаказаДБ2 = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВыполненЧастично");
		СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
		
		РезультатПроверкиСостояния1 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Заказ, СостояниеЗаказаДБ1,СостояниеСогласованияДБ);
		РезультатПроверкиСостояния2 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Заказ, СостояниеЗаказаДБ2,СостояниеСогласованияДБ);
		
		РезультатПроверкиСостоянияДозаказа1 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Дозаказ, СостояниеЗаказаДБ1,СостояниеСогласованияДБ);
		РезультатПроверкиСостоянияДозаказа2 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Дозаказ, СостояниеЗаказаДБ2,СостояниеСогласованияДБ);
		
		Если НЕ (РезультатПроверкиСостояния1 ИЛИ РезультатПроверкиСостояния2)
			ИЛИ НЕ (РезультатПроверкиСостоянияДозаказа1 ИЛИ РезультатПроверкиСостоянияДозаказа2) Тогда
			
			ПоказатьПредупреждение(,"Состояния заказов должно быть ""В работе"""); 
			
			Возврат; 	
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Заказ.ДатаОтгрузки)
			 ИЛИ НЕ ЗначениеЗаполнено(Дозаказ.ДатаОтгрузки) Тогда
			
			ПоказатьПредупреждение(,"Необходимо заполнить в заказах поле ""Дата отгрузки""");
			
			Возврат; 
		 	
		КонецЕсли;
		
		Если НачалоДня(Заказ.ДатаОтгрузки) <= НачалоДня(ТекущаяДата()) 
			ИЛИ НачалоДня(Дозаказ.ДатаОтгрузки) <= НачалоДня(ТекущаяДата()) Тогда
		
			ПоказатьПредупреждение(,"Необходимо поменять плановую дату отгрузки, она должна быть больше текущей даты");
			
			Возврат;	
		
		КонецЕсли;
		
		РНК1 = неопределено; 
		РНК1СвязьПустая = b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Заказ,РНК1);
		
		РНК2 = неопределено; 
		РНК2СвязьПустая = b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Дозаказ,РНК2);
		
		Если НЕ РНК1СвязьПустая 
			ИЛИ НЕ РНК2СвязьПустая Тогда
			
			Если РНК1 <> РНК2 Тогда
				
				МассивОшибок.Добавить("Ранее были созданы РНК по документам заказов:"); 
				МассивОшибок.Добавить(Строка(РНК1));
				МассивОшибок.Добавить(Строка(РНК2));
				
				Сообщить("Ранее были созданы РНК по документам заказов:"); 
				Сообщить(Строка(РНК1));
				Сообщить(Строка(РНК2));
			Иначе 
				ПараметрыФормы = Новый Структура("Ключ", РНК1);
				ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
			КонецЕсли;
			Возврат; 
		КонецЕсли;

		Если Не ЗначениеЗаполнено(МетодДоставки) 
			ИЛИ МетодДоставки = "P" Тогда 
			
			//МетодыДоставки = Новый СписокЗначений; 				
			//МетодыДоставки.Добавить("F","Заказ и дозаказ вместе"); 
			//МетодыДоставки.Добавить("P","Заказ и дозаказ отдельно");  
			//
			//ОповещениеВыборИзСписка = Новый ОписаниеОповещения("ВыборИзСпискаМетодДоставкиПриСозданииРНК",ЭтаФорма, Новый Структура); 
			//
			//ПоказатьВыборИзСписка(ОповещениеВыборИзСписка,МетодыДоставки,Элементы.СоздатьРНКОбщий);
			
			ОповещениеВопрос = Новый ОписаниеОповещения("УстановкаМетодаДоставкиВместе",ЭтаФорма); 
			
			ПоказатьВопрос(ОповещениеВопрос,"Метод доставки будет установлен ""Заказ и дозаказ вместе"", продолжить?",РежимДиалогаВопрос.ОКОтмена); 
		
		Иначе 
			
			//СоздатьРНКНаКлиенте(Заказ,ПлановаяДатаОтгрузки,Ложь,Элементы.СоздатьРНКОбщий);
			//СоздатьРНКНаКлиенте(Дозаказ,ПлановаяДатаОтгрузкиДозаказа,истина,Элементы.СоздатьРНКОбщий);
			
						
			МассивЗаказов = Новый Массив; 
			МассивЗаказов.Добавить(Заказ);
			МассивЗаказов.Добавить(Дозаказ);
			
			МассивСообщений = Новый Массив;
			РазблокироватьДокументыЗаказовДляРедактирования();
			РНКСуществующее = b2b_ОбменЗаявками.СоздатьРНКПоНесколькимЗаказам(МассивЗаказов,МассивСообщений); 
			Для каждого ЭлементМассива Из МассивСообщений Цикл
				
				МассивОшибок.Добавить(ЭлементМассива); 	
				
			КонецЦикла;
			
			//ОбновитьИзЗаказа("");
			ОбновитьЗаказНаСервере();
			ДоступностьРедактированияЗаказа(); 	
			ВывестиПодсказкиПредупреждения();
						
			ЗаблокироватьДокументыЗаказовДляРедактирования();
			
			Если ЗначениеЗаполнено(РНКСуществующее)  Тогда
				
				ПараметрыФормы = Новый Структура("Ключ", РНКСуществующее);
				ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
				
				
			КонецЕсли;

			
		КонецЕсли; 	
				
	Конецесли; 
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура УстановкаМетодаДоставкиВместе(ОтветНаВопрос,ДополнитеныеПараметры) Экспорт

	Если ОтветНаВопрос = Неопределено Тогда
		
		Возврат; 
		
	КонецЕсли;
	
	Если ОтветНаВопрос = КодВозвратаДиалога.ОК Тогда
	
		МетодДоставки = "F";
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр);
		
		МассивЗаказов = Новый Массив; 
		МассивЗаказов.Добавить(Заказ);
		МассивЗаказов.Добавить(Дозаказ);
		
		МассивСообщений = Новый Массив;
		РазблокироватьДокументыЗаказовДляРедактирования(); 
		РНКСуществующее = b2b_ОбменЗаявками.СоздатьРНКПоНесколькимЗаказам(МассивЗаказов,МассивСообщений);
		
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;
		
		//ОбновитьИзЗаказа("");
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
				
		ЗаблокироватьДокументыЗаказовДляРедактирования();
		
		Если ЗначениеЗаполнено(РНКСуществующее)  Тогда
			
			ПараметрыФормы = Новый Структура("Ключ", РНКСуществующее);
			ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
			
			
		КонецЕсли;

	
	КонецЕсли;

КонецПроцедуры // УстановкаМетодаДоставкиВместе()


// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ВыборИзСпискаМетодДоставкиПриСозданииРНК(ВыбранноеЗначение,ДополнительныеПараметры) Экспорт 

	    Если ВыбранноеЗначение = неопределено Тогда
		
			Возврат; 	
		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыбранноеЗначение.Значение)  Тогда  		
			
			ПараметрыЗаписиВРегистр = Новый Структура; 
			ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
			b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр); 		
			
			ПараметрыНаотправку = Новый Структура;
			ПараметрыНаотправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
			ПараметрыНаотправку.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
			
			МассивСообщений = Новый Массив; 
			
			b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(заказ,"ИзменитьМетодДоставки",ПараметрыНаотправку,МассивСообщений);
			
			Для каждого ЭлементМассива Из МассивСообщений Цикл
				
				МассивОшибок.Добавить(ЭлементМассива); 	
				
			КонецЦикла;

			 
			МетодДоставки = ВыбранноеЗначение.Значение; 
			
			СоздатьРНКНаКлиенте(Заказ,ПлановаяДатаОтгрузки,Ложь,Элементы.СоздатьРНКОбщий);
			СоздатьРНКНаКлиенте(Дозаказ,ПлановаяДатаОтгрузкиДозаказа,истина,Элементы.СоздатьРНКОбщий);

			
		КонецЕсли;


КонецПроцедуры // ВыборИзСпискаМетодДоставкиПриСозданииРНК()


&НаКлиенте
Процедура ПометитьНаУдалениеДозаказ(Команда)
	МассивОшибок.Очистить();
	Если Не ЗначениеЗаполнено(СостояниеДоЗаказа) 
			И  ЗначениеЗаполнено(Дозаказ)  Тогда
	
		ПометитьНаУдалениеДозаказНаСервере(); 	
	
	КонецЕсли;
	ВывестиТекстОшибок();
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ПометитьНаУдалениеДозаказНаСервере()
   
	ОбъектДозаказ = Дозаказ.ПолучитьОбъект();
	 
	
	Попытка
		
		Если  ОбъектДозаказ.Проведен Тогда
			
			ОбъектДозаказ.Записать(РежимЗаписиДокумента.ОтменаПроведения);	
			
		КонецЕсли;
		
		ОбъектДозаказ.УстановитьПометкуУдаления(истина); 
		 
		
		НаборЗаписей = РегистрыСведений.b2b_Дозаказы.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Заказ.Установить(ОбъектДозаказ.Ссылка); 
		НаборЗаписей.Записать(); 
	
	Исключение
	   Сообщить(ОписаниеОшибки()); 
	   МассивОшибок.Добавить(ОписаниеОшибки()); 
   КонецПопытки;
   
   ОбновитьЗаказНаСервере(истина);
   ДоступностьРедактированияЗаказа(); 	
   ВывестиПодсказкиПредупреждения();
   
   

КонецПроцедуры // ПометитьНаУдалениеДозаказНаСервере()

&НаКлиенте
Процедура ПлановаяДатаОтгрузкиДозаказаПриИзменении(Элемент)
	Модифицированность = истина; 
	ИзмененияПоДозаказу = Истина;
	НадписьИзменений();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("ПересчитатьСрокПодтвержденияПоЗаявке",30);
	ПодключитьОбработчикОжидания("ЗакрытьФормуПриОбновленииЗаказа",1);

	
	НадписьИзменений(); 
КонецПроцедуры

