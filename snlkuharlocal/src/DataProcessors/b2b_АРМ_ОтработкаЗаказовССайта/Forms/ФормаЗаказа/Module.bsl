&НаКлиенте
Процедура ОбновитьЗаказ(Команда)
	МассивОшибок.Очистить();
	ОбновитьЗаказНаСервере(); 	
	
	ДоступностьРедактированияЗаказа();
	
	ВывестиПодсказкиПредупреждения();
	ВывестиТекстОшибок();
	
	
	b2b_ОбменЗаявками.ОчиститьРегистрОбновленныеЗаказыПоЗаказу(Заказ);
	
	Дозаказ = b2b_ОбменЗаявками.НайтиДоЗаказпоОсновному(Заказ);
	Если ЗначениеЗаполнено(Дозаказ) Тогда
		
		b2b_ОбменЗаявками.ОчиститьРегистрОбновленныеЗаказыПоЗаказу(Дозаказ);	
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаказНаСервере(ВернутьИсходноеСостояние = Ложь)
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("номерЗаявки",Заказ.НомерЗаказа);
	ПараметрыПолучения.Вставить("ВернутьИсходноеСостояние",ВернутьИсходноеСостояние);
	
	ПараметрыПолучения.Вставить("ИзЗаказа",Истина); 
	
	ОбновленныеЗаказы = Новый Массив; 
	
	b2b_ОбменЗаявками.ПолучениеДанныхПоЗаказам(ПараметрыПолучения,ОбновленныеЗаказы); 
	
	//Если ОбновленныеЗаказы.Количество() > 0  Тогда
		
	ЗаполнитьТаблицуТоваровПоЗаказу();
	
	СостояниеЗаказа = Заказ.СостояниеНакладной;
	СостояниеСогласования = Заказ.СостояниеСогласования;
	
	НомерЗаявкиКонтрагента = Заказ.НомерЗаказа; 
	
	РНКСуществующее = неопределено; 
	
	РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Заказ.ссылка,РНКСуществующее);
	Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
		РасходнаяНакладная1 = РНКСуществующее.ссылка;	
	Иначе 
		РасходнаяНакладная1 = Документы.РасходнаяНакладная.ПустаяСсылка(); 
	КонецЕсли;
	
	РНКСуществующее = неопределено; 
	
	РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(Дозаказ.ссылка,РНКСуществующее);
	Если ЗначениеЗаполнено(РНКСуществующее) Тогда
		
		РасходнаяНакладная2 = РНКСуществующее.ссылка;	
	Иначе 
		РасходнаяНакладная2 = Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	
	РедактированиеДозаказаПоУмолчанию = (СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")) 
	И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором");
	Если РедактированиеДозаказаПоУмолчанию Тогда
		
		НеПересчитыватьКоличествоДозаказ = Истина; 	
		
	КонецЕсли;
КонецПроцедуры // ОбновитьЗаказыНаСервере()

