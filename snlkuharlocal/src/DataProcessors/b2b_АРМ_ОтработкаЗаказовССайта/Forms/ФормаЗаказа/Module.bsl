&НаСервере
Процедура РассчитатьЦенуПоТоварамНаСервере()
	ДокументОбъект = Заказ.ПолучитьОбъект();
	ДокументОбъект.Скидка = Скидка; 
	ДокументОбъект.ДопСкидкаНаНакладную = ДопСкидкаНаНакладную; 
	
	Для каждого СтрокаТовара  Из Данные Цикл
	
		 Отбор  = Новый Структура("Номенклатура",СтрокаТовара.Номенклатура); 
		 СтрокиТовара = ДокументОбъект.Товары.НайтиСтроки(Отбор); 
		 Если  СтрокиТовара.Количество() > 0 Тогда
			 
			 СтрокиТовара[0].Скидка = СтрокаТовара.Скидка; 	
			 
		 КонецЕсли;
	КонецЦикла;
	b2b_ОбменЗаявками.ПересчетЦены(ДокументОбъект,Скидка);
	
	Для каждого ТоварСтрока Из ДокументОбъект.Товары Цикл
	
		Отбор = Новый Структура("Номенклатура",ТоварСтрока.Номенклатура); 
		СтрокиДанные = Данные.НайтиСтроки(Отбор);
		
		Если СтрокиДанные.Количество() > 0 Тогда
			
			ЦенаРанее = СтрокиДанные[0].Цена; 
		
			СтрокиДанные[0].Цена = ТоварСтрока.Цена;
			СтрокиДанные[0].ЦенаБезСкидки = ТоварСтрока.ЦенаБезСкидки;
			
			СтрокиДанные[0].Скидка = ТоварСтрока.Скидка;
			СтрокиДанные[0].Всего =  СтрокиДанные[0].Цена *СтрокиДанные[0].Количество; 
			Если ЦенаРанее <> СтрокиДанные[0].Цена  Тогда
				
				СтрокиДанные[0].ИзмененаСтрока = Истина; 
				Модифицированность = Истина; 
				ИзмененияПоЗаказу = Истина;
				ИзмененияПоЗаказуСтроки = Истина;	
				
			КонецЕсли;
		     
		КонецЕсли;
	
	КонецЦикла;

КонецПроцедуры // ()


