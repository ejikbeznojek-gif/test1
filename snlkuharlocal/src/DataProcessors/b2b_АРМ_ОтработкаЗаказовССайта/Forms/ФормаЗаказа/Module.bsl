&НаСервере
Процедура ПодтвердитьДозаказНаСервере()

	ПараметрыДляОтправки = Новый Структура; 
	ПараметрыДляОтправки.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
	ПараметрыДляОтправки.Вставить("IDЗаявки",заказ.ИдЗаказа);
	ПараметрыДляОтправки.Вставить("СтатусДоЗаказа","P");
	
	МассивСообщений = Новый Массив; 
	
	b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(Заказ,"ПодтвердитьДозаказ",ПараметрыДляОтправки,МассивСообщений);
	Для каждого ЭлементМассива Из МассивСообщений Цикл
	
		МассивОшибок.Добавить(ЭлементМассива); 	
	
	КонецЦикла;

