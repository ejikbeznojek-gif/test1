//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ЗакрытьФормуПриОбновленииЗаказа()

	Если ЭтаФорма.Открыта() 
		И (b2b_ОбменЗаявками.ЗапросНаЗакрытиеФормы(Заказ)
		ИЛИ  b2b_ОбменЗаявками.ЗапросНаЗакрытиеФормы(Дозаказ)) Тогда
		
		Сообщить("Форма заказа была закрыта, так как необходимо обновление данных с сайта " + Строка(Заказ.НомерЗаказа)); 
		ПараметрыЗакрытия = Новый Структура; 
		ПараметрыЗакрытия.Вставить("Сообщить", "Форма заказа " + Строка(Заказ.НомерЗаказа) + " была закрыта, так как необходимо обновление данных с сайта " ); 
				
		Закрыть(ПараметрыЗакрытия);
	КонецЕсли; 

КонецПроцедуры // ЗакрытьФормуПриОбновленииЗаказа()


// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ПересчитатьСрокПодтвержденияПоЗаявке()

	Если ЗначениеЗаполнено(СрокПодтвержденияПоДозаказу) Тогда    
		 
	    РазницаВСекундах =  СрокПодтвержденияПоДозаказу - ТекущаяДата() ; 
		ЧасыЦелые = Цел(РазницаВСекундах/3600);// ,0,РежимОкругления.Окр15как10);
		
		ОстатокСекунд = РазницаВСекундах  - ЧасыЦелые * 3600; 
		Минуты = Цел(ОстатокСекунд/60); //,0,РежимОкругления.Окр15как10);             // Окр(РазницаВСекундах/60,0,РежимОкругления.Окр15как10) - ЧасыЦелые*60; 
		
		СрокПодтвержденияВЧасах = Формат(ЧасыЦелые,"ЧН=0; ЧГ=0") + " ч." + Формат(Минуты,"ЧН=0; ЧГ=0") + "минут"; 
	Иначе 
		СрокПодтвержденияВЧасах = ""; 
	КонецЕсли; 

КонецПроцедуры // ПересчитатьСрокПодтвержденияПоЗаявке()

&НаКлиенте
Процедура СохранитьДляДальнейшегоРедактирования(Команда) 
	МассивОшибок.Очистить();
	
	СоответствиеТоварКоличествоРезерв = Новый Соответствие;
	
	СоответствиеТоварЦенаСкидка = Новый Соответствие;
		
	Для каждого СтрокаТовара Из Данные Цикл
		
		СтруктураЦенаСкидка = Новый Структура("Цена,ЦенаБезСкидки,Скидка,ДопСкидкаНаНакладную,СкидкаНаНакладную"); 
		ЗаполнитьЗначенияСвойств(СтруктураЦенаСкидка,СтрокаТовара); 
		СтруктураЦенаСкидка.СкидкаНаНакладную = Скидка;
		СтруктураЦенаСкидка.ДопСкидкаНаНакладную = ДопСкидкаНаНакладную;
		
		СоответствиеТоварКоличествоРезерв.Вставить(СтрокаТовара.Номенклатура,СтрокаТовара.КоличествоРезерв);	
		СоответствиеТоварЦенаСкидка.Вставить(СтрокаТовара.Номенклатура,СтруктураЦенаСкидка);
		//СтрокаТовара.ИзмененаСтрока = Ложь; 
	КонецЦикла;
	
	ПараметрыЗаписиВРегистр = Новый Структура; 
	ПараметрыЗаписиВРегистр.Вставить("СоответствиеТоварКоличествоРезерв",СоответствиеТоварКоличествоРезерв);
	ПараметрыЗаписиВРегистр.Вставить("СоответствиеТоварЦенаСкидка",СоответствиеТоварЦенаСкидка);
	b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ.Ссылка,ПараметрыЗаписиВРегистр);
	
	ИзмененияПоЗаказуСтроки = Ложь;
	
	НадписьИзменений();

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьФактПлан(Команда)
	
	МассивОшибок.Очистить();
	
	ЗаполнитьФактПланНаКлиенте();

	НадписьИзменений(); 
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьФактПланНаКлиенте()
	
	
	Для каждого СтрокаДанных Из Данные Цикл	 
		
		Количество = СтрокаДанных.Количество; 
		
		СтрокаДанных.Количество = СтрокаДанных.Заявка; 
		Если Количество <> СтрокаДанных.Количество Тогда 
			СтрокаДанных.ИзмененаСтрока = Истина;
			
			ИзмененияПоЗаказу = истина;
			ИзмененияПоЗаказуСтроки = Истина; 
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПровестиЗаказНаСервере(Знач ДокументЗаказа)
	ОбъектЗаказ = ДокументЗаказа.ПолучитьОбъект(); 
	Попытка
	
		ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение); 
	
	Исключение
	    Сообщить(ОписаниеОшибки());
		МассивОшибок.Добавить(ОписаниеОшибки()); 
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ПровестиЗаказ(Команда)
	МассивОшибок.Очистить();
	ПровестиЗаказНаСервере(Заказ);
	ВывестиТекстОшибок();
КонецПроцедуры

&НаКлиенте
Процедура ПровестиДозаказ(Команда)
	МассивОшибок.Очистить();
	ПровестиЗаказНаСервере(Дозаказ);
	ВывестиТекстОшибок();
КонецПроцедуры

&НаКлиенте
Процедура УдалитьРНК(Команда)
	МассивОшибок.Очистить();
	Если  СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.Выполнена") Тогда
		
		ПоказатьПредупреждение(,"Пометка на удаление недоступна"); 
		Возврат; 
	КонецЕсли;
	
	Если  СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЧастичноВыполнена")
		  И СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен") Тогда
		
		ПоказатьПредупреждение(,"Пометка на удаление недоступна"); 
		Возврат; 
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Дозаказ)
		
		ИЛИ (ЗначениеЗаполнено(Дозаказ) 
		И СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен")) Тогда
		
		УдалитьРНКНАСервере(Заказ);
		
		ОбновитьИзЗаказа(""); 
		
	ИначеЕсли ЗначениеЗаполнено(Дозаказ) И СостояниеЗаказа = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.Отменен") Тогда 
		
		УдалитьРНКНАСервере(Дозаказ);
		ОбновитьИзЗаказа("");
	ИначеЕсли ЗначениеЗаполнено(РасходнаяНакладная1) И НЕ ЗначениеЗаполнено(РасходнаяНакладная2) Тогда
		
		УдалитьРНКНАСервере(Заказ);
		
		ОбновитьИзЗаказа("");
		
	ИначеЕсли  НЕ ЗначениеЗаполнено(РасходнаяНакладная1) И ЗначениеЗаполнено(РасходнаяНакладная2) Тогда
		
		УдалитьРНКНАСервере(Дозаказ);
		
		ОбновитьИзЗаказа("");
	Иначе 
		
		ОповещениеВопрос = Новый ОписаниеОповещения("УдалитьРНКВопрос",ЭтаФорма);
		
		СписокНакладных = Новый СписокЗначений; 
		Если РасходнаяНакладная1 = РасходнаяНакладная2 Тогда
			
			СписокНакладных.Добавить("РНК1",Строка(РасходнаяНакладная1));	
		ИначеЕсли СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЧастичноВыполнена") Тогда
			Если НЕ (СостояниеРНКОтгружен(РасходнаяНакладная1)
				 И СостояниеЗаказа = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВыполненЧастично")) Тогда
				
				СписокНакладных.Добавить("РНК1",Строка(РасходнаяНакладная2));	
				
			КонецЕсли;
			
			Если НЕ (СостояниеРНКОтгружен(РасходнаяНакладная2)
				 И СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВыполненЧастично")) Тогда
				
				СписокНакладных.Добавить("РНК2",Строка(РасходнаяНакладная2));	
				
			КонецЕсли;
		Иначе 
			СписокНакладных.Добавить("РНК1",Строка(РасходнаяНакладная1));
			СписокНакладных.Добавить("РНК2",Строка(РасходнаяНакладная2));
			СписокНакладных.Добавить("ВыбратьВсе","Выбрать все");
		КонецЕсли;		
		
		СписокНакладных.Добавить("Отмена","Отмена");
		
		ПоказатьВопрос(ОповещениеВопрос,"Выберите РНК для пометки на удаление",СписокНакладных); 
	КонецЕсли; 	
	
КонецПроцедуры

