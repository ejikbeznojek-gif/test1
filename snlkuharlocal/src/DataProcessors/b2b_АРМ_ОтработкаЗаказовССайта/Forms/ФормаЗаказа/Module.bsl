&НаКлиенте
Процедура НадписьИзменений()
	Если ИзмененияПоДозаказу Тогда
	
		Элементы.ДекорацияИзмененияДозаказа.Заголовок = "Есть изменения по дозаказу на форме, сохраните дозаказ"; 	
	Иначе 
		Элементы.ДекорацияИзмененияДозаказа.Заголовок = ""; 
	КонецЕсли;
	
	Если ИзмененияПоЗаказу Тогда
	
		Элементы.ДекорацияИзмененияЗаказа.Заголовок = "Есть изменения по заказу на форме, сохраните заказ"; 	
	Иначе 
		Элементы.ДекорацияИзмененияЗаказа.Заголовок = "";
	КонецЕсли;
	
	Если ИзмененияПоДозаказу 
		ИЛИ  ИзмененияПоЗаказу Тогда
		
		Элементы.ФормаСохранить.ЦветТекста = WebЦвета.Красный;
		
	Иначе 
		Элементы.ФормаСохранить.ЦветТекста = WebЦвета.Черный;
		Элементы.СохранитьДляДальнейшегоРедактирования.ЦветТекста =  WebЦвета.Черный;
	КонецЕсли;
	
	Если ИзмененияПоЗаказуСтроки Тогда
	
		Элементы.СохранитьДляДальнейшегоРедактирования.ЦветТекста =  WebЦвета.Красный;
	Иначе 
		
	    Элементы.СохранитьДляДальнейшегоРедактирования.ЦветТекста =  WebЦвета.Черный;
		
	КонецЕсли;
	 

КонецПроцедуры // НадписьИзменений()

&НаКлиенте
Процедура ДанныеКоличествоРезервПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Данные.ТекущиеДанные; 
	
	ДоступностьРедактированияДоЗаказа = (НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)
		 ИЛИ СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")) 
		 И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором");
	
	Если ТекущиеДанные <> Неопределено 
		  И Не НеПересчитыватьКоличество 
		  И ДоступностьРедактированияДоЗаказа Тогда
	
		ТекущиеДанные.КоличествоДозаказ = ТекущиеДанные.ПодтвержденнаяЗаявка - ТекущиеДанные.КоличествоРезерв; 	
	
	КонецЕсли;
КонецПроцедуры

