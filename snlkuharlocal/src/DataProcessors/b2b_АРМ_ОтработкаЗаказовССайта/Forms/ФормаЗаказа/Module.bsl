	//учесть что не все товары, могут быть включены 
	//еще необходимо продумать резерв 
	
	ПараметрыДляОтправки = Новый Структура; 
	ПараметрыДляОтправки.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
	ПараметрыДляОтправки.Вставить("IDЗаявки",заказ.ИдЗаказа);
	ПараметрыДляОтправки.Вставить("СтатусЗаказа","ZD");
	ПараметрыДляОтправки.Вставить("КомментарийОтмены",Строка(ПричинаОтмены));
	
	ПараметрыДляОтправки.Вставить("Дозаказ",Дозаказ.Ссылка);
	
