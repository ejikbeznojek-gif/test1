&НаКлиенте
Процедура СоздатьРНК(Команда)
	
	МассивОшибок.Очистить();
	СоздатьРНКНаКлиенте(Заказ,Заказ.ДатаОтгрузки,Ложь,Элементы.РедактироватьВФормеЗаказа);
	ВывестиТекстОшибок();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьРНКНаКлиенте(Знач ДокументЗаказа,ДатаОтгрузки,ЭтоДозаказ,ЭлементФормыОткрыть,ПоОстаткам = Ложь) 	
	
	СостояниеЗаказаДБ1 = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВРаботе"); 
	СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
	
	РезультатПроверкиСостояния1 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(ДокументЗаказа, СостояниеЗаказаДБ1,СостояниеСогласованияДБ);
	
	СостояниеЗаказаДБ2 = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВыполненЧастично"); 
	СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
	
	РезультатПроверкиСостояния2 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(ДокументЗаказа, СостояниеЗаказаДБ2,СостояниеСогласованияДБ);

	
	Если НЕ (РезультатПроверкиСостояния1 ИЛИ РезультатПроверкиСостояния2)  Тогда
		
		ПоказатьПредупреждение(,"Состояние заказа должно быть ""В работе"""); 
		
		Возврат; 	
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаОтгрузки)  Тогда
		
		ПоказатьПредупреждение(,"Необходимо заполнить в заказе поле ""Дата отгрузки""");
		
		Возврат; 
		
	КонецЕсли;
	
	Если НачалоДня(ДатаОтгрузки) <= НачалоДня(ТекущаяДата()) Тогда
	
		ПоказатьПредупреждение(,"""Дата отгрузки"" должна быть больше текущей даты");
		
		Возврат; 	
	
	КонецЕсли;
	
	РНКСуществующее = неопределено; 
	РезультатПроверкиСвязи =  b2b_ОбменЗаявками.ПроверитьСвязьСРНК(ДокументЗаказа,РНКСуществующее); 
	Если НЕ РезультатПроверкиСвязи
		И ЗначениеЗаполнено(РНКСуществующее) Тогда 
		
		//ОповещениеВопрос = Новый ОписаниеОповещения("СоздатьРНКПроверкаВопрос",ЭтаФорма); 
		//ПоказатьВопрос(ОповещениеВопрос,"Есть связанный РНК, изменить связь?",РежимДиалогаВопрос.ДаНет);
		
		ПараметрыФормы = Новый Структура("Ключ", РНКСуществующее);
		ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
		
	Иначе 
		//проверить, что выбран метод доставки
		
		//МетодДоставки = b2b_ОбменЗаявками.МетодДоставкиПоЗаказу(ДанныеСтроки.ссылка);
		
		Если НЕ ЗначениеЗаполнено(МетодДоставки) 
			И ЗначениеЗаполнено(Дозаказ)
			И (СостояниеДоЗаказа <>  ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен"))
			И СостояниеЗаказа <> ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.Отменен") Тогда
			
			МетодыДоставки = Новый СписокЗначений; 				
			МетодыДоставки.Добавить("F","Заказ и дозаказ вместе"); 
			МетодыДоставки.Добавить("P","Заказ и дозаказ отдельно");
			
			СтруктураПараметров = Новый Структура("Заказ,Этодозаказ,ПоОстаткам",ДокументЗаказа,ЭтоДозаказ,ПоОстаткам); 
			
			ОповещениеВыборИзСписка = Новый ОписаниеОповещения("ВыборИзСпискаМетодДоставкиСозданиеРНК",ЭтаФорма,СтруктураПараметров); 
			
			ПоказатьВыборИзСписка(ОповещениеВыборИзСписка,МетодыДоставки,ЭлементФормыОткрыть); 
		Иначе 
			МассивСообщений = Новый Массив;
			
			РазблокироватьДокументыЗаказовДляРедактирования(); 
			
			РНКСуществующее = b2b_ОбменЗаявками.СоздатьРНКНаСервере(ДокументЗаказа,ЭтоДозаказ,МассивСообщений,ПоОстаткам);
			
			Для каждого ЭлементМассива Из МассивСообщений Цикл
				
				МассивОшибок.Добавить(ЭлементМассива); 	
				
			КонецЦикла;
			
			ОбновитьЗаказНаСервере(); 
			ДоступностьРедактированияЗаказа(); 	
			ВывестиПодсказкиПредупреждения();
	
			ЗаблокироватьДокументыЗаказовДляРедактирования();
			
			Если ЗначениеЗаполнено(РНКСуществующее)  Тогда
				
				ПараметрыФормы = Новый Структура("Ключ", РНКСуществующее);
				ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
				
				
			КонецЕсли;
		КонецЕсли;
		
		
		
	КонецЕсли;


КонецПроцедуры


&НаКлиенте
Процедура ВыборИзСпискаМетодДоставкиСозданиеРНК(ВыбранноеЗначение,ДополнительныеПараметры) Экспорт 
	
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение.Значение)  Тогда
		
		Если  ДополнительныеПараметры.Этодозаказ Тогда
			
			ОсновнойЗаказ = b2b_ОбменЗаявками.НайтиОсновнойЗаказпоДозаказу(ДополнительныеПараметры.Заказ); 	
		Иначе
			
			ОсновнойЗаказ =  ДополнительныеПараметры.Заказ; 
			
		КонецЕсли;
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",ВыбранноеЗначение.Значение);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(ОсновнойЗаказ,ПараметрыЗаписиВРегистр); 		
		
		МассивСообщений = Новый Массив; 
		
		РазблокироватьДокументыЗаказовДляРедактирования();
		
		РНКСуществующее = b2b_ОбменЗаявками.СоздатьРНКНаСервере(ДополнительныеПараметры.Заказ,ДополнительныеПараметры.Этодозаказ,МассивСообщений,ДополнительныеПараметры.ПоОстаткам);
		
		Для каждого ЭлементМассива Из МассивСообщений Цикл
				
				МассивОшибок.Добавить(ЭлементМассива); 	
				
			КонецЦикла;

	
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		
		ЗаблокироватьДокументыЗаказовДляРедактирования();
		
		Если ЗначениеЗаполнено(РНКСуществующее)  Тогда
			
			ПараметрыФормы = Новый Структура("Ключ", РНКСуществующее);
			ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаДокумента", ПараметрыФормы);
			
			
		КонецЕсли;

	КонецЕсли;
	

КонецПроцедуры // ВыборИзСпискаМетодДоставки()

