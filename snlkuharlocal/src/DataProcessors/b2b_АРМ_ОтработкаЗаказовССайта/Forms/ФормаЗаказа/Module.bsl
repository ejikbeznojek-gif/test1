&НаСервере
Процедура НадписьНеСоответствиеПодтвержденнаяЗаявкаКоличество()
	Элементы.ДекорацияПредупреждениеНесоответствие.Заголовок = ""; 
	Для каждого СтрокаДанных Из Данные Цикл
	
		Если СтрокаДанных.ПодтвержденнаяЗаявка <> СтрокаДанных.Количество Тогда
		
			Элементы.ДекорацияПредупреждениеНесоответствие.Заголовок = "В таблице есть несоответствие ""Подтвержденная заявка"" и ""Количество"" "; 
			
			Прервать; 
		
		КонецЕсли;
	
	КонецЦикла;
	
	Элементы.ДекорацияПредупреждениеНесоответствиеДозаказ.Заголовок = ""; 
	
	Для каждого СтрокаДанных Из Данные Цикл
	
		Если СтрокаДанных.ПодтвержденнаяЗаявка <> СтрокаДанных.Количество Тогда
		
			Элементы.ДекорацияПредупреждениеНесоответствиеДозаказ.Заголовок = "В таблице есть несоответствие ""Подтвержденная заявка"" и ""Количество"" "; 
			
			Прервать; 
		
		КонецЕсли;
	
	КонецЦикла;
	
	Элементы.ДекорацияПредупрежденияПровести.Заголовок = ""; 
	Если Заказ.Товары.Количество() > 0 
		И НЕ Заказ.Проведен  Тогда
	
		Элементы.ДекорацияПредупрежденияПровести.Заголовок = "!!!Товары не зарезервированы, проведите документ"; 	
	
	КонецЕсли;
	

КонецПроцедуры // НадписьНеСоответствиеПодтвержденнаяЗаявкаКоличество()

