		 СтруктураТовара.Вставить("Количество",СтрокаДанных.Количество);
		//СтруктураТовара.Вставить("Цена",СтрокаДанных.Цена);
		 
		 МассивДанных.Добавить(СтруктураТовара); 
		 
	 КонецЦикла;
	 
	 Возврат МассивДанных; 

КонецФункции

