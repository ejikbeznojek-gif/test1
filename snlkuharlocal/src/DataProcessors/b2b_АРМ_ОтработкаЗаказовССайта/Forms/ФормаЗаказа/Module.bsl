&НаСервере
Функция ДоступностьРедактированияЗаказа()
	
	Элементы.ГруппаНаДозаказ.Видимость = ЗначениеЗаполнено(Дозаказ); 
	Элементы.Группа5.Видимость = ЗначениеЗаполнено(Дозаказ);
	Элементы.ОтправитьНаСогласованиеДозаказ.Видимость = ЗначениеЗаполнено(Дозаказ);
	Элементы.ОтменитьОтгрузкуДозаказа.Видимость = ЗначениеЗаполнено(Дозаказ);

	ТолькоПросмотр = b2b_ОбменЗаявками.ДоступностьРедактированияЗаказа(Заказ); 
	
	//Если ТолькоПросмотр Тогда
		
	Элементы.Данные.ТолькоПросмотр = ТолькоПросмотр; 
	
	//Элементы.ГруппаДанныеПоДокументу.ТолькоПросмотр = ТолькоПросмотр;
	
	Элементы.ДанныеЗаполнитьПоОстаткам.Доступность = НЕ ТолькоПросмотр;
	Элементы.ФормаРассчитатьЦенуПоТоварам.Доступность = НЕ ТолькоПросмотр;		
	
	Элементы.ФормаСохранить.Доступность = НЕ ТолькоПросмотр; 
	Элементы.ФормаСоздатьДозаказ.Доступность = НЕ ТолькоПросмотр;
	Элементы.СохранитьДляДальнейшегоРедактирования.Доступность = НЕ ТолькоПросмотр;
	
	Элементы.КомментарийКДозаказу.ТолькоПросмотр = ТолькоПросмотр; 
	Элементы.КомментарийКЗаказу.ТолькоПросмотр = ТолькоПросмотр;
	Элементы.ГруппаКомандаОсновногозаказа.ТолькоПросмотр = ТолькоПросмотр; 
	Элементы.РедактироватьВФормеЗаказа.Доступность = Истина; 
		
	//КонецЕсли;
	Элементы.ПлановаяДатаОтгрузки.ТолькоПросмотр = ЗначениеЗаполнено(РасходнаяНакладная1);
	Элементы.ГруппаДанныеПоДокументу.ТолькоПросмотр = ЗначениеЗаполнено(РасходнаяНакладная1); 
	
	Элементы.ПлановаяДатаОтгрузкиДозаказа.ТолькоПросмотр = ЗначениеЗаполнено(РасходнаяНакладная2);
	Элементы.ФормаСохранить.Доступность = НЕ Элементы.ПлановаяДатаОтгрузки.ТолькоПросмотр ИЛИ НЕ Элементы.ПлановаяДатаОтгрузкиДозаказа.ТолькоПросмотр;
	
	Элементы.СохранитьДляДальнейшегоРедактирования.Доступность = (Не ЗначениеЗаполнено(Дозаказ) ИЛИ НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)) 
	И СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО
	И СостояниеЗаказа = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе
	;
	
	СогласованныйЗаказ = СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.Согласована; 
	
	Элементы.ПовторитьСозданиеДозаказаНаПортал.Видимость = Истина;
	Элементы.ПовторитьСозданиеДозаказаНаПортал.Доступность = Ложь;
	
	//Элементы.ПодтвердитьДозаказ.Видимость = Ложь;	
	//Элементы.ОтправитьНаСогласованиеДозаказ.Видимость = Ложь;
	//
	Элементы.ПодтвердитьДозаказ.Доступность = Ложь;	
	Элементы.ОтправитьНаСогласованиеДозаказ.Доступность = Ложь;
	
	ДозаказПодтвержденКонтрагентом = Не ЗначениеЗаполнено(Дозаказ) ИЛИ (СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ТребуетПодтверждения
	ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Оформлен ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Отменен); 
	
	//Элементы.ОтправитьНаСогласованиеВналичии.Видимость =  СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором И ДозаказПодтвержденКонтрагентом; 
	//Элементы.ФормаОтправитьНаСогласованиеКлиенту.Видимость = СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором И ДозаказПодтвержденКонтрагентом;
	ПустойЗаказОсновной = Заказ.Товары.Количество() = 0; 
	Элементы.ОтправитьНаСогласованиеВналичии.Доступность =  СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором 
	И ДозаказПодтвержденКонтрагентом
	И НЕ ПустойЗаказОсновной
	И НЕ ИзмененияПоЗаказу; 
	
	Элементы.ФормаОтправитьНаСогласованиеКлиенту.Доступность = СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором 
	И ДозаказПодтвержденКонтрагентом 
	И НЕ ПустойЗаказОсновной
	И НЕ ИзмененияПоДозаказу
	И НЕ ИзмененияПоЗаказу
	И НЕ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Отменен;
	
	//Элементы.ОтправитьНаСогласованиеДозаказ.Видимость = СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором;
	
	Элементы.ФормаСоздатьДозаказ.Доступность = НЕ ЗначениеЗаполнено(СостояниеДоЗаказа) И НЕ ТолькоПросмотр И НЕ СогласованныйЗаказ; 
	Если Не ЗначениеЗаполнено(Дозаказ)
		И СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором Тогда
	
		Элементы.ФормаСоздатьДозаказ.Заголовок  = "Создать дозаказ";
		//Элементы.ПовторитьСозданиеДозаказаНаПортал.Видимость = Ложь;
		Элементы.ПовторитьСозданиеДозаказаНаПортал.Доступность = Ложь;
		
	Конецесли;
	
	ДоступностьРедактированияДоЗаказа = ЗначениеЗаполнено(Дозаказ)
		 И (НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)
		 ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ТребуетПодтверждения) 
		 И СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором; 
		 
	Если ДоступностьРедактированияДоЗаказа Тогда 
		 
		 Элементы.ФормаСоздатьДозаказ.Заголовок  = "Изменить дозаказ";
		 Элементы.ПовторитьСозданиеДозаказаНаПортал.Доступность = Не ИзмененияПоДозаказу;
	 КонецЕсли;
	 
	 Если ЗначениеЗаполнено(Дозаказ) 
		 И СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ТребуетПодтверждения  
	     И СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором Тогда
		 
		 //Элементы.ОтправитьНаСогласованиеДозаказ.Видимость = Истина;
		 Элементы.ОтправитьНаСогласованиеДозаказ.Доступность = НЕ ИзмененияПоДозаказу;
	 КонецЕсли; 
	 
	Если ЗначениеЗаполнено(Дозаказ) 
		 И СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.Согласована 
		 И СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ПредварительноПодтвержден Тогда  
		 //Элементы.ПодтвердитьДозаказ.Видимость = Истина;
		 Элементы.ПодтвердитьДозаказ.Доступность = Истина; 
	 КонецЕсли;  
	 
	 
	 Элементы.ДанныеДозаказаГруппаКоличествоДозаказ.ТолькоПросмотр = НЕ ДоступностьРедактированияДоЗаказа; 
	 
	 Элементы.ДанныеДозаказаЗаполнитьПоОстаткамДозаказ.Доступность =  ДоступностьРедактированияДоЗаказа;
	 
	 Элементы.ИзменитьМетодДоставки.Доступность =  СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
	 
	 Элементы.МетодДоставки.Доступность =  СостояниеСогласования = Перечисления.СостоянияСогласования.Согласован;
	 
	 //Элементы.ОтменитьОтгрузкуДозаказа.Видимость = ЗначениеЗаполнено(Дозаказ);
	 Элементы.ОтменитьОтгрузкуДозаказа.Доступность = ЗначениеЗаполнено(Дозаказ);
	 
	 Элементы.ОтменитьОтгрузкуДозаказа.Доступность = Ложь; 
	 
	 Если ЗначениеЗаполнено(РасходнаяНакладная2)
		 И РасходнаяНакладная2.СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена Тогда
		 
		 Элементы.ОтменитьОтгрузкуДозаказа.Доступность =  МетодДоставки = "P" ИЛИ НЕ ЗначениеЗаполнено(МетодДоставки); 	
		 
	 КонецЕсли;
	 
	 Элементы.ОтменитьОтгрузкуСоСклада.Доступность = Ложь;
	 
	 Если ЗначениеЗаполнено(РасходнаяНакладная1)
		 И РасходнаяНакладная1.СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена Тогда
		 
		 Элементы.ОтменитьОтгрузкуСоСклада.Доступность = МетодДоставки = "P" ИЛИ НЕ ЗначениеЗаполнено(Дозаказ); 	
		 
	 КонецЕсли;
	 
	 Элементы.ОтменитьЕдинуюОтгрузку.Доступность = Ложь;
	 
	 ЕстьДозаказ = ЗначениеЗаполнено(Дозаказ) И СостояниеДоЗаказа <> Перечисления.b2b_СтатусыДоЗаказов.Отменен;  
	 
	 //И (СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Оформлен
	 //ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Выполнен ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ЧастичноВыполнен); 
	 УсловиеДозаказ = ЕстьДозаказ И ЗначениеЗаполнено(РасходнаяНакладная2)
	 И РасходнаяНакладная2.СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена; 
	 
	 УсловиеЗаказ =  ЗначениеЗаполнено(РасходнаяНакладная1)
	 И РасходнаяНакладная1.СостояниеНакладной <> Перечисления.СостоянияНакладной.Отгружена; 
	 
	// Элементы.ИзменитьМетодДоставки.Доступность = Ложь;
	 
	 Если  УсловиеЗаказ И УсловиеДозаказ тогда // ИЛИ Не ЕстьДозаказ) Тогда 
		 
		 Элементы.ОтменитьЕдинуюОтгрузку.Доступность = МетодДоставки = "F";	
		// Элементы.ИзменитьМетодДоставки.Доступность = истина; 
	 КонецЕсли;
	 
	 Элементы.ОтработатьОтгрузку.Доступность = Ложь; 
	 
	 ЕстьДозаказ = ЗначениеЗаполнено(Дозаказ) И СостояниеДоЗаказа <> Перечисления.b2b_СтатусыДоЗаказов.Отменен;  //И (СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Оформлен
	// ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.Выполнен ИЛИ СостояниеДоЗаказа = Перечисления.b2b_СтатусыДоЗаказов.ЧастичноВыполнен); 
	 
	 УсловиеДозаказ = ЕстьДозаказ И ЗначениеЗаполнено(РасходнаяНакладная2)
	 И РасходнаяНакладная2.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена; 
	 
	 УсловиеЗаказ =  ЗначениеЗаполнено(РасходнаяНакладная1)
	 И РасходнаяНакладная1.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	 
	 УсловиеЗаказНеУчитывается = СостояниеЗаказа = Перечисления.СостоянияЗаказаКонтрагента.Отменен;
	 
	 НеРедактируется = СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.Выполнена ИЛИ СостояниеЗаявки = Перечисления.b2b_СтатусыЗаказов.Отменена; 
	 
	 Если  (УсловиеЗаказ ИЛИ УсловиеЗаказНеУчитывается) И (УсловиеДозаказ ИЛИ Не ЕстьДозаказ) 
		 И НЕ НеРедактируется Тогда 
		 
		 Элементы.ОтработатьОтгрузку.Доступность = истина;  
		 
	 КонецЕсли;
	 
	 Если МетодДоставки = "P" Тогда
	 
	 	 Элементы.ОтработатьОтгрузку.Доступность = УсловиеЗаказ ИЛИ УсловиеДозаказ;
	 
	 КонецЕсли;
	// Если МетодДоставки = "F" 
	//	 И НЕ Элементы.ОтработатьОтгрузку.Доступность Тогда
	// 
	// 	Элементы.ДекорацияПодсказкаРНК.Заголовок = "Для отработки отгрузки измените метод доставки ""Заказ и дозаказ отдельно"""; 	
	//Иначе 
	//	Элементы.ДекорацияПодсказкаРНК.Заголовок = ""; 
	// КонецЕсли;
	 
	 Элементы.ПричинаОтменыЗаявки.Видимость = ЗначениеЗаполнено(ПричинаОтменыЗаявки);
	 Элементы.ПричинаОтменыОтгрузки1.Видимость = ЗначениеЗаполнено(ПричинаОтменыОтгрузки1);
	 Элементы.ПричинаОтменыОтгрузки2.Видимость = ЗначениеЗаполнено(ПричинаОтменыОтгрузки2);
	 Элементы.ПричинаОтменыЗаявкиКлиентом.Видимость = ЗначениеЗаполнено(ПричинаОтменыЗаявкиКлиентом);
	 
	 Элементы.ГруппаПричиныОтмены.Видимость =  Элементы.ПричинаОтменыЗаявки.Видимость
	 ИЛИ Элементы.ПричинаОтменыОтгрузки1.Видимость
	 ИЛИ  Элементы.ПричинаОтменыОтгрузки2.Видимость
	 ИЛИ  Элементы.ПричинаОтменыЗаявкиКлиентом.Видимость;
	 
	 Элементы.ГруппаИнформация.Видимость = ЗначениеЗаполнено(ТекстОшибкиПоследний); 
	 
	 Элементы.ФормаОтменитьЗаказ.Доступность = НЕ ТолькоПросмотр;
	 
	 СостояниеЗаказаДБ = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВРаботе"); 
	 СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
	 
	 РезультатПроверкиСостояния1 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Заказ, СостояниеЗаказаДБ,СостояниеСогласованияДБ);
	 
	 СостояниеЗаказаДБ = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВыполненЧастично"); 
	 СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
	 
	 РезультатПроверкиСостояния2 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Заказ, СостояниеЗаказаДБ,СостояниеСогласованияДБ);
	 
	 Элементы.ДанныеСоздатьРНК.Доступность = РезультатПроверкиСостояния1 ИЛИ РезультатПроверкиСостояния2;
	 
	 РезультатПроверкиСостоянияДозаказа1 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Дозаказ, СостояниеЗаказаДБ,СостояниеСогласованияДБ);
	 
	 СостояниеЗаказаДБ = ПредопределенноеЗначение("Перечисление.СостоянияЗаказаКонтрагента.ВРаботе"); 
	 СостояниеСогласованияДБ = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Согласован"); 
	 
	 РезультатПроверкиСостоянияДозаказа2 = b2b_ОбменЗаявками.ПроверитьСостояниеЗаказа(Дозаказ, СостояниеЗаказаДБ,СостояниеСогласованияДБ);
	 
	 ПодтвержденОкончально = СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Оформлен")
	 ИЛИ СостояниеДоЗаказа =ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Выполнен")
	 ИЛИ СостояниеДоЗаказа =ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ЧастичноВыполнен");
	 
	 РезультатПроверкиСостоянияДозаказа = (РезультатПроверкиСостоянияДозаказа1 ИЛИ РезультатПроверкиСостоянияДозаказа2) И ПодтвержденОкончально; 
	 
	 Элементы.ДанныеДозаказаСоздатьРНКПоДозаказу.Доступность = РезультатПроверкиСостоянияДозаказа;
	 
	 Элементы.СоздатьРНКОбщий.Доступность = (РезультатПроверкиСостояния1 ИЛИ РезультатПроверкиСостояния2) И (Не ЗначениеЗаполнено(Дозаказ) ИЛИ РезультатПроверкиСостоянияДозаказа); 
	 
	 Элементы.ДанныеСоздатьРНК.Доступность = Элементы.ДанныеСоздатьРНК.Доступность И (НЕ ЕстьДоЗаказ ИЛИ ПодтвержденОкончально); 
	  
	 Элементы.ДанныеДозаказаПометитьНаУдалениеДозаказ.Доступность = ЗначениеЗаполнено(Дозаказ) и Не ЗначениеЗаполнено(СостояниеДоЗаказа); 
	 
	 РедактированиеДозаказаПоУмолчанию = (СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")) 
	 И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором");
	 
	 Элементы.ЖелаемаяДатаОтгрузки.Доступность = ЗначениеЗаполнено(Дозаказ) И (Не ЗначениеЗаполнено(СостояниеДоЗаказа)
	 ИЛИ РедактированиеДозаказаПоУмолчанию) ;
	 
	 Элементы.ПунктДоставки.Доступность = ЗначениеЗаполнено(Дозаказ) И (Не ЗначениеЗаполнено(СостояниеДоЗаказа)
	 ИЛИ РедактированиеДозаказаПоУмолчанию) ;
	 
	 Элементы.КомментарийКДозаказу.Доступность = ЗначениеЗаполнено(Дозаказ) И (Не ЗначениеЗаполнено(СостояниеДоЗаказа)
	 ИЛИ РедактированиеДозаказаПоУмолчанию) ;
	 
	 Элементы.УдалитьРНК.Доступность = ЗначениеЗаполнено(РасходнаяНакладная1) ИЛИ  ЗначениеЗаполнено(РасходнаяНакладная2) И НЕ НеРедактируется;
	 //по просьбе пользователей
	 Элементы.УдалитьРНК.Видимость = Ложь; 
	 
	 МассивЭлементов = Новый Массив; 
	 МассивЭлементов.Добавить("ФормаОбновитьЗаказ");
	 МассивЭлементов.Добавить("ФормаОтменитьЗаказ");
	 МассивЭлементов.Добавить("ОтправитьНаСогласованиеВналичии");
	 МассивЭлементов.Добавить("ОтправитьНаСогласованиеДозаказ");
	 МассивЭлементов.Добавить("ФормаОтправитьНаСогласованиеКлиенту");
	 МассивЭлементов.Добавить("ПодтвердитьДозаказ");
	 МассивЭлементов.Добавить("ПовторитьСозданиеДозаказаНаПортал");
	 
	 МассивЭлементов.Добавить("ОтменитьОтгрузкуСоСклада");
	 МассивЭлементов.Добавить("ОтменитьОтгрузкуДозаказа");
	 МассивЭлементов.Добавить("ОтменитьЕдинуюОтгрузку");
	 
	 МассивЭлементов.Добавить("ИзменитьМетодДоставки");
	 МассивЭлементов.Добавить("ОтработатьОтгрузку");
	 МассивЭлементов.Добавить("УдалитьРНК");
	 
	 МассивЭлементов.Добавить("СоздатьРНКОбщий");
	 МассивЭлементов.Добавить("ВернутьВИсходноеСостояние");
	 
	 
	 Элементы.ВернутьВИсходноеСостояние.Доступность = Не ЗначениеЗаполнено(СостояниеДоЗаказа)
	 И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором");
	 
	 
	 Для каждого ЭлементМассива Из МассивЭлементов Цикл
	 
	 	Если Элементы[ЭлементМассива].Доступность Тогда
		
			Элементы[ЭлементМассива].Шрифт = Новый Шрифт(Элементы[ЭлементМассива].Шрифт,,10,Истина); 
		Иначе
			Элементы[ЭлементМассива].Шрифт = Новый Шрифт(Элементы[ЭлементМассива].Шрифт,,8,Ложь);
		КонецЕсли;
	 
	КонецЦикла;
	
	//Если  РасходнаяНакладная1  = РасходнаяНакладная2 Тогда
	
	Элементы.ГруппаРНК2.Видимость = РасходнаяНакладная1 <> РасходнаяНакладная2; 	
	
		
	НадписьНеСоответствиеПодтвержденнаяЗаявкаКоличество(); 	 
	 
КонецФункции // ДоступностьРедактированияЗаказа()

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ДоступностьЭлементовПриРедактированииНаКлиенте()
	
	ДозаказПодтвержденКонтрагентом = Не ЗначениеЗаполнено(Дозаказ) ИЛИ (СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")
	ИЛИ СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Оформлен")
	ИЛИ СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Отменен"));

	ПустойЗаказОсновной = Заказ.Товары.Количество() = 0; 
	Элементы.ОтправитьНаСогласованиеВналичии.Доступность =  СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором")  
	И ДозаказПодтвержденКонтрагентом
	И НЕ ПустойЗаказОсновной
	И НЕ ИзмененияПоЗаказу; 
	
	Элементы.ФормаОтправитьНаСогласованиеКлиенту.Доступность = СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором")  
	И ДозаказПодтвержденКонтрагентом 
	И НЕ ПустойЗаказОсновной
	И НЕ ИзмененияПоДозаказу
	И НЕ ИзмененияПоЗаказу;


	ДоступностьРедактированияДоЗаказа = ЗначениеЗаполнено(Дозаказ)
	И (НЕ ЗначениеЗаполнено(СостояниеДоЗаказа)
	ИЛИ СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")) 
	И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором"); 
	
	Если ДоступностьРедактированияДоЗаказа Тогда 
		Элементы.ПовторитьСозданиеДозаказаНаПортал.Доступность = Не ИзмененияПоДозаказу;
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(Дозаказ) 
		И СостояниеДоЗаказа = ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.ТребуетПодтверждения")   
		И СостояниеЗаявки = ПредопределенноеЗначение("Перечисление.b2b_СтатусыЗаказов.ЖдетПодтвержденияДистрибьютором") Тогда
		
		Элементы.ОтправитьНаСогласованиеДозаказ.Доступность = НЕ ИзмененияПоДозаказу;
	КонецЕсли;
	
КонецПроцедуры // ДоступностьЭлементовПриРедактировании()


