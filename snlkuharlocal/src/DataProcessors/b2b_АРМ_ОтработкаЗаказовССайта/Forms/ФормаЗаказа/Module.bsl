Процедура ОтменитьЗаказКоманда(Команда)
	
	Перем ПричинаТекст; 
	
	МассивОшибок.Очистить(); 
	//ПричинаТекст = "Причина отмены"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьЗаказВводПричины",ЭтаФорма); 
	ПоказатьВводЗначения(ОписаниеОповещения,ПричинаТекст,"Причина отмены",Тип("СправочникСсылка.b2b_ПричиныОтменыЗаявок")); 
	
