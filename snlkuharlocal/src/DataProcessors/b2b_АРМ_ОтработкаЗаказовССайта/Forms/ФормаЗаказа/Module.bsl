&НаСервере
Функция ДобавитьВМассивТоварыЗаказа(Дозаказ = Ложь)
	 МассивДанных = Новый Массив; 
	 Для каждого СтрокаДанных Из Данные Цикл
		 
		 СтруктураТовара = Новый Структура; 
		 СтруктураТовара.Вставить("IDТовара",b2b_ОбменЗаявками.ПолучитьКодТовараДляПортала(СтрокаДанных.Номенклатура));
		 СтруктураТовара.Вставить("Количество",?(Дозаказ,0,СтрокаДанных.Количество));
		 СтруктураТовара.Вставить("Цена",СтрокаДанных.Цена);
		 
		 МассивДанных.Добавить(СтруктураТовара); 
		 
	 КонецЦикла;
	 
	 Возврат МассивДанных; 

КонецФункции // ДобавитьВМассивТоварыЗаказа()

