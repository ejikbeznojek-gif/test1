&НаКлиенте
Процедура УдалитьРНКВопрос(ОтветНаВопрос,ДопПараметры) Экспорт 
	
	Если ОтветНаВопрос = Неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	Если ОтветНаВопрос = "РНК1" Тогда
	
		УдалитьРНКНАСервере(Заказ); 	
		
	ИначеЕсли ОтветНаВопрос = "РНК2" Тогда
	
		УдалитьРНКНАСервере(Дозаказ);
		
	ИначеЕсли ОтветНаВопрос = "ВыбратьВсе" Тогда
		
		ОповещениеВопросПослеВыбратьВсе = Новый ОписаниеОповещения("УдалениеПослеВыбратьВсе",ЭтаФорма); 
		ПоказатьВопрос(ОповещениеВопросПослеВыбратьВсе,"Будут помечены РНК и по заказу и по дозаказу, продолжить?",РежимДиалогаВопрос.ДаНет); 
		
	Иначе 
		Возврат; 
	КонецЕсли;
	
	ОбновитьИзЗаказа("");

	

КонецПроцедуры // УдалитьРНКВопрос()

