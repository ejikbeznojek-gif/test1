КонецПроцедуры

&НаКлиенте
Процедура ДанныеЦенаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Данные.ТекущиеДанные; 
	Если ТекущиеДанные = Неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	ТекСкидка = ?(ТекущиеДанные.Скидка=0,Скидка,ТекущиеДанные.Скидка);
	Если ТекСкидка >= 0 Тогда
		ТекущиеДанные.ЦенаБезСкидки=ТекущиеДанные.Цена/(1-ТекСкидка/100);
	Иначе
		ТекущиеДанные.ЦенаБезСкидки=ТекущиеДанные.Цена;
	КонецЕсли;
	
	РассчитатьСуммуТаблицыДанных(ТекущиеДанные,Скидка,ДопСкидкаНаНакладную); 
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуТаблицыДанных(СтрокаТЧ,СкидкаШапки,ДопСкидкаНаНакладную)

	СкидкаТЧ = СтрокаТЧ.Скидка;
	Если СкидкаТЧ = 0 Тогда
		СкидкаРасчетная = СкидкаШапки;
	Иначе
		Если СкидкаТЧ > 0 Тогда				
			СкидкаРасчетная = СкидкаТЧ;
			Если ДопСкидкаНаНакладную Тогда
				СкидкаРасчетная = СкидкаРасчетная + СкидкаШапки;
			КонецЕсли; 
		Иначе
			Если СкидкаТЧ = -1 Тогда
				СкидкаРасчетная = 0;
			Иначе
				СкидкаРасчетная = СкидкаТЧ;
				Если ДопСкидкаНаНакладную Тогда
					СкидкаРасчетная = СкидкаРасчетная + СкидкаШапки;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;	
	
	СтрокаТЧ.Цена	= СтрокаТЧ.ЦенаБезСкидки*(1-СкидкаРасчетная/100); //округление под разрядность реквизита "Цена" документа
	Цена			= СтрокаТЧ.Цена;
		
	СтрокаТЧ.Всего 	= Цена * СтрокаТЧ.Количество; 	


КонецПроцедуры

&НаКлиенте
Процедура ДанныеСкидкаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Данные.ТекущиеДанные; 
	Если ТекущиеДанные = Неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	РассчитатьСуммуТаблицыДанных(ТекущиеДанные,Скидка,ДопСкидкаНаНакладную); 
КонецПроцедуры

