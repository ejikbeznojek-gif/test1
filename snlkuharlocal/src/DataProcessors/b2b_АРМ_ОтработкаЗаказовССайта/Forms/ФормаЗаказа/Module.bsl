&НаСервере
Процедура ЗаполнитьДанныеПодвала()

	ВсегоКоличествоДозаказ = ДанныеДозаказа.Итог("Количество");
	ВсегоКоличествоЗаказ = Данные.Итог("Количество");
	
	ВсегоСуммаДозаказ= ДанныеДозаказа.Итог("Всего");
	ВсегоСуммаЗаказ = Данные.Итог("Всего");
	
	ВсегоЗаявкаДозаказ = ДанныеДозаказа.Итог("Заявка");
	ВсегоЗаявкаЗаказ = Данные.Итог("Заявка");
	
	Если СостояниеЗаказа = Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
		ВсегоКоличествоЗаказ  = 0; 
		ВсегоСуммаЗаказ	= 0; 
		ВсегоЗаявкаЗаказ  = 0; 
	КонецЕсли;
	
	Если СостояниеЗаказаНадозаказ = Перечисления.СостоянияЗаказаКонтрагента.Отменен Тогда
	
		 ВсегоКоличествоДозаказ  = 0; 
	     ВсегоСуммаДозаказ   = 0; 
		 ВсегоЗаявкаДозаказ = 0; 
		 
	КонецЕсли;
	
	ИтогоКоличество = ВсегоКоличествоДозаказ +  ВсегоКоличествоЗаказ; 
	//ИтогоЗаявка =  ВсегоЗаявкаДозаказ +  ВсегоЗаявкаЗаказ; 
	ИтогоСумма = ВсегоСуммаДозаказ +  ВсегоСуммаЗаказ; 


КонецПроцедуры // ЗаполнитьИтоги()

