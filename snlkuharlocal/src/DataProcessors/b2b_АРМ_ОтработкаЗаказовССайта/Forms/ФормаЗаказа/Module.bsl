&НаСервере
Функция СоздатьНовыйДокументЗаказаПоДозаказу()
	
	КомментарийЕЕЭАвтомЗаполнение = ""; 
	Если НЕ ЗначениеЗаполнено(Дозаказ) Тогда
		
		НовыйДокумент = Документы.Заказ.СоздатьДокумент();
		СписокСвойств = "ИдЗаказа,НомерЗаказа,ДатаЗаказа,ИсточникЗаказа,Контрагент,ТипЦен,ИБ,ДатаОтгрузки,ТипЦенРаспродажа,
		|ВидОплаты,КодОперации,Склад,Валюта,Менеджер,Курс,Договор,ПунктДоставки,ОтсрочкаПлатежа,Организация,Подразделение,Отгружен"; 
		
		Если ЗначениеЗаполнено(ПлановаяДатаОтгрузкиДозаказа) Тогда
		
			НовыйДокумент.ДатаОтгрузки = ПлановаяДатаОтгрузкиДозаказа; 	
		
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(НовыйДокумент,Заказ,СписокСвойств);
		
		НовыйДокумент.Дата = ТекущаяДатаСеанса(); 
		НовыйДокумент.ДатаОформления =  ТекущаяДатаСеанса();
		НовыйДокумент.Автор = ПараметрыСеанса.Пользователь;
		//НовыйДокумент.Контрагент = Заказ.Контрагент;
		НовыйДокумент.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
		НовыйДокумент.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО; //сразу отправляется на портал ( в очередь на отправку)
		
		НовыйДокумент.Комментарий = "Создан документ дозаказа из основного " + Строка(Заказ);
		НовыйДокумент.b2b_Дозаказ = Истина;
		
		КомментарийЕЕЭАвтомЗаполнение = Строка(НовыйДокумент.Контрагент) + ", №заявки " + Строка(НовыйДокумент.НомерЗаказа); 
		
		КомментарийКДозаказу = КомментарийЕЕЭАвтомЗаполнение;
		
		НовыйДокумент.ДополнительныеСвойства.Вставить("Этоb2bЗаказ", Истина);
	Иначе 
		
		НовыйДокумент = Дозаказ.ПолучитьОбъект(); 
		
	КонецЕсли; 
	
	МассивТоваровНаДозаказ = Новый Массив; 
	ЗаказОбъект = Заказ.ПолучитьОбъект(); 
	
	Для каждого Строка Из  Данные Цикл
		Если Строка.КоличествоДозаказ = 0 Тогда
			//ИЛИ НЕ Строка.ИзмененаСтрока Тогда
		
			Продолжить;  	
		
		КонецЕсли;
		
		ОтборПоТовару = Новый Структура("Номенклатура",Строка.Номенклатура);
		СтрокиДок = НовыйДокумент.Товары.НайтиСтроки(ОтборПоТовару); 
		Если СтрокиДок.Количество() = 0  Тогда
			
			Новыйтовар =  НовыйДокумент.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(Новыйтовар,Строка);
			Новыйтовар.СтавкаНДС = b2b_ОбменЗаявками.ПолучитьСтавкуНДС_(Новыйтовар.Номенклатура); //.Родитель.СтавкаНДС; 
			Новыйтовар.Цена = Строка.Цена;
			Новыйтовар.ЦенаИсточник = Строка.ЦенаИсточник;
			Новыйтовар.ЦенабезСкидки = Строка.ЦенаБезСкидки;
			Новыйтовар.Количество = Строка.КоличествоДоЗаказ;
			НовыйТовар.Заявка =  Новыйтовар.Количество;
			
			//НовыйТовар.Сумма = Новыйтовар.Количество  * Строка.Цена; 
			//
			//НовыйТовар.Всего = НовыйТовар.Сумма; 
			//Новыйтовар.ВсегоБезСкидки = Новыйтовар.ЦенабезСкидки * Новыйтовар.Количество;
			b2b_ОбменЗаявками.РассчитатьСуммуТабЧасти_(НовыйТовар,НовыйДокумент); 
			Новыйтовар.ПодтвержденнаяЗаявка = 0;
			
		Иначе 
			Новыйтовар = СтрокиДок[0]; 
			Новыйтовар.Количество = Новыйтовар.Количество + Строка.КоличествоДоЗаказ;
			Если НЕ ЗначениеЗаполнено(СостояниеДоЗаказа) Тогда
			
				НовыйТовар.Заявка =  Новыйтовар.Количество;	
			
			КонецЕсли;
			//НовыйТовар.Сумма = Новыйтовар.Количество  * Строка.Цена; 
			////НовыйТовар.Заявка =  Новыйтовар.Количество;
			//НовыйТовар.Всего = НовыйТовар.Сумма; 
			//Новыйтовар.ВсегоБезСкидки = Новыйтовар.ЦенабезСкидки * Новыйтовар.Количество;
			
			b2b_ОбменЗаявками.РассчитатьСуммуТабЧасти_(НовыйТовар,НовыйДокумент);
		КонецЕсли;
				 
		//НовыйТовар.Сумма = Новыйтовар.Количество  * Новыйтовар.Цена;
		//НовыйТовар.Всего = НовыйТовар.Сумма;
		//НовыйТовар.ВсегоБезСкидки = НовыйТовар.Сумма;
		
		СтруктураТовара = новый Структура("Номенклатура,Количество,ЖелаемаяДатаОтгрузки,Комментарий"); 
		ЗаполнитьЗначенияСвойств(СтруктураТовара,Строка);
		СтруктураТовара.Количество = Новыйтовар.Количество; 
		МассивТоваровНаДозаказ.Добавить(СтруктураТовара); 
		
		Если Строка.КоличествоДозаказ = Строка.Заявка Тогда
			
			СтрокаДляУдалить = ЗаказОбъект.Товары.Найти(Строка.Номенклатура,"Номенклатура"); 
			Если ЗначениеЗаполнено(СтрокаДляУдалить) Тогда
				
				ЗаказОбъект.Товары.Удалить(СтрокаДляУдалить);	
				
			КонецЕсли;
			
		ИначеЕсли  Строка.КоличествоДозаказ < Строка.ПодтвержденнаяЗаявка
			 И НЕ ЗначениеЗаполнено(Дозаказ) Тогда  //если изменение, то не нужно вычитать, уже записано количество резерв 
			
			//СтрокаДляИзменения = ЗаказОбъект.Товары.Найти(Строка.Номенклатура,"Номенклатура");
			//СтрокаДляИзменения.Количество = СтрокаДляИзменения.Количество - Строка.КоличествоДозаказ;
			////СтрокаДляИзменения.Цена = 0; 
			//СтрокаДляИзменения.Сумма = СтрокаДляИзменения.Количество  * СтрокаДляИзменения.Цена;
			//СтрокаДляИзменения.Всего = СтрокаДляИзменения.Сумма;
			//СтрокаДляИзменения.ВсегоБезСкидки = СтрокаДляИзменения.Сумма;
			
		КонецЕсли;
				
	КонецЦикла;
	
	Попытка
		
		Попытка
		
			 НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		
		Исключение
		     НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
		КонецПопытки;
		
		
		Дозаказ = НовыйДокумент.ссылка; 
		
		ПараметрыЗаписиНового = Новый Структура; 
		ПараметрыЗаписиНового.Вставить("ОсновнойЗаказ",Заказ); 
		ПараметрыЗаписиНового.Вставить("ПлановаяДатаОтгрузки",НовыйДокумент.ДатаОтгрузки);
		//удалить из заказа основного и записать в Регистры
		
		ЗаказОбъект.Записать();
		
		
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(НовыйДокумент.Ссылка,ПараметрыЗаписиНового);
		
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(ЗаказОбъект.Ссылка,Новый Структура);
		
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("Товары",МассивТоваровНаДозаказ);
		ПараметрыЗаписиВРегистр.Вставить("ОсновнойЗаказ",ЗаказОбъект.Ссылка);
		ПараметрыЗаписиВРегистр.Вставить("Дополнить",Истина);
		Если  ЗначениеЗаполнено(КомментарийЕЕЭАвтомЗаполнение) Тогда
		
			ПараметрыЗаписиВРегистр.Вставить("Комментарий",КомментарийЕЕЭАвтомЗаполнение);	
		
		КонецЕсли;
		ПараметрыЗаписиВРегистр.Вставить("ПунктДоставки",ПунктДоставки);
		ПараметрыЗаписиВРегистр.Вставить("Контрагент",ЮрЛицоДозаказа);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрДоЗаказов(НовыйДокумент.Ссылка,ПараметрыЗаписиВРегистр,ЛОЖЬ);
		
	Исключение
		
		Сообщить(ОписаниеОшибки()); 
		
		МассивОшибок.Добавить(ОписаниеОшибки()); 
	КонецПопытки;
	
	Возврат НовыйДокумент.Ссылка; 
	
КонецФункции // СоздатьНовыйДокументЗаказаПоДозаказу()

&НаКлиенте
Процедура ОтправитьНаСогласованиеКлиенту(Команда)
	
	МассивОшибок.Очистить();
	
	Если НЕ Заказ.Проведен 
		ИЛИ (ЗначениеЗаполнено(Дозаказ) И Не Дозаказ.Проведен) Тогда
		
		ТекстВопроса = "Найдены непроведенные документы, провести?"; 
		
		Если НЕ Заказ.Проведен 
			И (НЕ ЗначениеЗаполнено(Дозаказ) 
			ИЛИ ЗначениеЗаполнено(Дозаказ) И Дозаказ.Проведен) Тогда
			
			ТекстВопроса = "Не проведен заказ резерва, провести документ?";  	
			
		ИначеЕсли ЗначениеЗаполнено(Дозаказ) И НЕ Дозаказ.Проведен И Заказ.Проведен тогда 
			
			ТекстВопроса = "Не проведен дозаказ, провести документ?"; 
			
		ИначеЕсли НЕ Заказ.Проведен И ЗначениеЗаполнено(Дозаказ) И НЕ Дозаказ.Проведен Тогда
			
			ТекстВопроса = "Не все документы проведены, провести документы?"; 
			
		КонецЕсли;
		
		
		  
		
		ОповещениеВопрос = Новый ОписаниеОповещения("ВопросПровестиДокументОтправкаПолностью",ЭтаФорма); 
		ПоказатьВопрос(ОповещениеВопрос,ТекстВопроса,РежимДиалогаВопрос.ДаНет); 
		
	Иначе
		
		ОтправитьНаСогласованиеЗаказПолностью();
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		ВывестиТекстОшибок();
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросПровестиДокументОтправкаПолностью(ОтветНаВопрос,ДополнительныеПараметры) Экспорт 
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		 
		РезультатПроведения = Истина; 
		Если Не Заказ.Проведен Тогда
			
			ТекстСообщения = "";
			РезультатПроведенияЗаказ = Ложь; 
			ПровестиДокументЗаказаНаСервере(Заказ,РезультатПроведенияЗаказ,ТекстСообщения); 
			МассивОшибок.Добавить(ТекстСообщения);
			
			Если НЕ РезультатПроведенияЗаказ Тогда
				РезультатПроведения = ложь; 
			Конецесли; 
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Дозаказ) И Не Дозаказ.Проведен Тогда
			
			ТекстСообщения = "";
			РезультатПроведенияЗаказ = Ложь;
			ПровестиДокументЗаказаНаСервере(Дозаказ,РезультатПроведенияЗаказ,ТекстСообщения); 
			МассивОшибок.Добавить(ТекстСообщения);	
			Если НЕ РезультатПроведенияЗаказ Тогда
				РезультатПроведения = ложь; 
			Конецесли;
		КонецЕсли; 	
		
		Если  РезультатПроведения Тогда
			
			ОтправитьНаСогласованиеЗаказПолностью();		
			
			ОбновитьЗаказНаСервере();
			ДоступностьРедактированияЗаказа(); 	
			ВывестиПодсказкиПредупреждения();			
			
		КонецЕсли;
		
		ВывестиТекстОшибок();
		
		
		
	Иначе 
		ПоказатьПредупреждение(,"Операция отменена, нельзя отпправить на согласование непроведенные документы"); 
	КонецЕсли; 	

КонецПроцедуры // ()


