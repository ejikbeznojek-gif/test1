// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Функция ЕстьДоЗаказ()

		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕЭ_ДозаказыСрезПоследних.Заказ КАК Заказ,
		|	ЕЭ_ДозаказыСрезПоследних.СтатусДоЗаказа_b2b КАК СтатусДоЗаказа_b2b
		|ИЗ
		|	РегистрСведений.b2b_Дозаказы КАК ЕЭ_ДозаказыСрезПоследних
		|ГДЕ
		|	ЕЭ_ДозаказыСрезПоследних.ЗаказОсновной = &заказ";
	
	Запрос.УстановитьПараметр("заказ", заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(); 
	
	СтатусДоЗаказа_b2b = неопределено; 
	
	Если Выборка.Следующий() Тогда
	
		СтатусДоЗаказа_b2b = Выборка.СтатусДоЗаказа_b2b; 	
	
	КонецЕсли;
	
	Возврат НЕ РезультатЗапроса.Пустой() 
	И СтатусДоЗаказа_b2b <> ПредопределенноеЗначение("Перечисление.b2b_СтатусыДоЗаказов.Выполнен"); 

КонецФункции // ЕстьДоЗаказ()

