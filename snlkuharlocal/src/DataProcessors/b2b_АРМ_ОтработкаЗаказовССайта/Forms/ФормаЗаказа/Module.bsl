//
&НаСервере
Процедура ОбновитьОстаткиНаСервере(ТаблицаДляОбновления)

	МассивТоваров = ЭтаФорма[ТаблицаДляОбновления].Выгрузить().ВыгрузитьКолонку("Номенклатура"); 
	Склад = Заказ.Склад; 
	КэшОстатки = Новый Соответствие; 
	
	b2b_ОбменЗаявками.ПолучитьОстаткиПоЗаявкам(МассивТоваров,Склад,Заказ,КэшОстатки);
	
	Модифицированность = Истина; 
	
	Если ТаблицаДляОбновления = "Данные" Тогда
		
		ИзмененияПоЗаказу = истина;
		ИзмененияПоЗаказуСтроки = Истина; 
		
	КонецЕсли;
	
	Если ТаблицаДляОбновления = "ДанныеДозаказа" Тогда
		
		ИзмененияПоДозаказу = истина; 	
		
	КонецЕсли;
	
	Для каждого СтрокаДанных  Из ЭтаФорма[ТаблицаДляОбновления] Цикл
		
		Если КэшОстатки.Получить(СтрокаДанных.Номенклатура) <> неопределено Тогда
			
			СтрокаДанных.остаток =  КэшОстатки.Получить(СтрокаДанных.Номенклатура).СвободныйОстаток;	
			
		КонецЕсли;	
		
	КонецЦикла;

КонецПроцедуры // ()

&НаКлиенте
Процедура МетодДоставкиПриИзменении(Элемент)
	МассивОшибок.Очистить();
	Если ЗначениеЗаполнено(МетодДоставки)  Тогда  		
			
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр); 		
		
		ПараметрыНаотправку = Новый Структура;
		ПараметрыНаотправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		ПараметрыНаотправку.Вставить("МетодДоставки",МетодДоставки);
		
		МассивСообщений = новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(заказ,"ИзменитьМетодДоставки",ПараметрыНаотправку,МассивСообщений);
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;
		
		ВывестиТекстОшибок();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьМетодДоставки(Команда)
	
	МассивОшибок.Очистить();
	ИзменитьМетодДоставкиФрагмент(Элементы.ИзменитьМетодДоставки);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьМетодДоставкиФрагмент(ЭлементФормыОткрыть)
	ИзменитьЗдесь = Ложь; 
	
	Если МетодДоставки = "F" Тогда
		
		МетодДоставки = "P";
		ИзменитьЗдесь = Истина; 
		
	ИначеЕсли МетодДоставки = "P" тогда 
		
		МетодДоставки = "F"; 
		ИзменитьЗдесь = Истина;
	Иначе 
		
		МетодыДоставки = Новый СписокЗначений; 				
		МетодыДоставки.Добавить("F","Заказ и дозаказ вместе"); 
		МетодыДоставки.Добавить("P","Заказ и дозаказ отдельно");  
		
		ОповещениеВыборИзСписка = Новый ОписаниеОповещения("ВыборИзСпискаМетодДоставки",ЭтаФорма,Новый Структура); 
		
		ПоказатьВыборИзСписка(ОповещениеВыборИзСписка,МетодыДоставки,ЭлементФормыОткрыть);
	КонецЕсли;
	
	Если ИзменитьЗдесь Тогда 
		ПараметрыЗаписиВРегистр = Новый Структура; 
		ПараметрыЗаписиВРегистр.Вставить("МетодДоставки",МетодДоставки);
		b2b_ОбменЗаявками.ЗаписатьДополнительныеДанныеВРегистрЗаказов(Заказ,ПараметрыЗаписиВРегистр); 		
		
		ПараметрыНаотправку = Новый Структура;
		ПараметрыНаотправку.Вставить("НомерЗаявки",Заказ.НомерЗаказа);
		ПараметрыНаотправку.Вставить("МетодДоставки",МетодДоставки);
		
		МассивСообщений = Новый Массив; 
		b2b_ОбменЗаявками.ЗаписатьВОчередьНаОтправку(заказ,"ИзменитьМетодДоставки",ПараметрыНаотправку,МассивСообщений);
		Для каждого ЭлементМассива Из МассивСообщений Цикл
			
			МассивОшибок.Добавить(ЭлементМассива); 	
			
		КонецЦикла;
		ВывестиТекстОшибок();
		
		ОбновитьЗаказНаСервере();
		ДоступностьРедактированияЗаказа(); 	
		ВывестиПодсказкиПредупреждения();
		 
	КонецЕсли;

КонецПроцедуры

