
&НаСервере               
//Смещает исходящие ПРМ (кроме виртуальных) и РНК от 1го числа закрываемого месяц
//на некоторое количество секунд, чтобы можно было делать  ПРМ раньше  накладных
Процедура ПеренестиВремяИсходящихНакладных(МассивДокументов,СмещениеПоДате,ДопПараметры = Неопределено) экспорт
	ВыполнятьФоново = Истина;
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда 
		если ДопПараметры.Свойство("ВыполнятьФоново") и ДопПараметры.ВыполнятьФоново = ложь тогда
			ВыполнятьФоново = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	//ПараметрыСеанса.ЗапущенаОбработка = Истина;
	МассивСообщений = новый массив;
	
	КоличествоСтрок = МассивДокументов.Количество();
	Сч=1;
	для каждого Документ из МассивДокументов цикл 
		попытка    
			ДокОбъект = Документ.ПолучитьОбъект();  
			ДокОбъект.Дата = НачалоДня(ДокОбъект.дата)+СмещениеПоДате;  
			
			ДокОбъект.ЗаписьБезКонтроляПолномочий(); 
			МассивСообщений.Добавить(СтрШаблон("Успешно изменено время в %1.",ДокОбъект));
		Исключение   
			МассивСообщений.Добавить(СтрШаблон("Не удалось записать %1. %2",ДокОбъект,ОписаниеОшибки()));
		КонецПопытки;	
		
		если ВыполнятьФоново тогда
			Процент = 100*сч/КоличествоСтрок; 
			УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияПереносВремениДокументов",Процент);  
			если Сч = 1 тогда    
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПереносВремениДокументов","Стартовала фоновая запись документов. Дождитесь сообщения о завершении либо отмените через консоль заданий.");
			КонецЕсли;   
		КонецЕсли;      
		
		сч= сч+1;
	КонецЦикла;                   
	
	
	//ПараметрыСеанса.ЗапущенаОбработка = Ложь;
	
	если ВыполнятьФоново тогда
		УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияПереносВремениДокументов",1000);
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПереносВремениДокументов",СтрСоединить(МассивСообщений,символы.ПС));  
	иначе
		Сообщение = новый СообщениеПользователю;
		Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
		Сообщение.Сообщить();
	КонецЕсли;	
КонецПроцедуры


&НаСервере 
//Распроведение виртуальных ПРМ по одному физ. складу.
Процедура РаспровестиВиртуальныеПРМ(МассивДокументов,ФизическийСклад,ЗакрываемыйМесяц,ДопПараметры = Неопределено) экспорт
	ВыполнятьФоново = Истина;
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда 
		если ДопПараметры.Свойство("ВыполнятьФоново") и ДопПараметры.ВыполнятьФоново = ложь тогда
			ВыполнятьФоново = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	//ПараметрыСеанса.ЗапущенаОбработка = Истина;
	МассивСообщений = новый массив;
	
	КоличествоСтрок = МассивДокументов.Количество();
	Сч=1;
	
	МассивРаспроведенныхПРМ = новый Массив;
	
	
	для каждого Документ из МассивДокументов цикл
		попытка
			ДокОбъект = Документ.ПолучитьОбъект();   
			ДокОбъект.УстановитьПометкуУдаления(Истина);
			МассивСообщений.Добавить(СтрШаблон("Успешно помечен на удаление %1.",ДокОбъект));  
			МассивРаспроведенныхПРМ.Добавить(Документ);
		Исключение   
			МассивСообщений.Добавить(СтрШаблон("Не удалось пометить на удаление %1. %2",ДокОбъект,ОписаниеОшибки()));
		КонецПопытки;
		
		если ВыполнятьФоново тогда
			Процент = 100*сч/КоличествоСтрок; 
			УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияРаспровестиВиртуальныеПРМ",Процент);  
			если Сч = 1 тогда    
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеРаспровестиВиртуальныеПРМ","Стартовала фоновая запись документов. Дождитесь сообщения о завершении либо отмените через консоль заданий.");
			КонецЕсли;   
		КонецЕсли;      
		
		сч= сч+1;
		
	КонецЦикла;      
	
	ЗаписатьМассивДанныхВДанныеЗакрытияМесяцаПоСкладу (ФизическийСклад,ЗакрываемыйМесяц,МассивРаспроведенныхПРМ,"МассивРаспроводимыхВиртуальныхПРМ");

	//ПараметрыСеанса.ЗапущенаОбработка = Ложь;

	
	если ВыполнятьФоново тогда
		УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияРаспровестиВиртуальныеПРМ",1000);
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеРаспровестиВиртуальныеПРМ",СтрСоединить(МассивСообщений,символы.ПС));  
	иначе
		Сообщение = новый СообщениеПользователю;
		Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
		Сообщение.Сообщить();
	КонецЕсли;	
	
КонецПроцедуры


&НаСервере  
//Перемещение под 0 на весь товар с виртуальных складов на физический
Процедура СоздатьПРМДляОбнуленияВиртуальныхСкладов(ФизическийСклад,ЗакрываемыйМесяц,ДопПараметры = Неопределено) экспорт  
	ВыполнятьФоново = Истина;
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда 
		если ДопПараметры.Свойство("ВыполнятьФоново") и ДопПараметры.ВыполнятьФоново = ложь тогда
			ВыполнятьФоново = Ложь;
		КонецЕсли;
	КонецЕсли;
	//ПараметрыСеанса.ЗапущенаОбработка = Истина;
	МассивСообщений = новый массив;
	
	МассивСозданныхПРМ = новый Массив;
	
	
	МассивСкладов = ПолучитьМассивВиртуальныхСкладов(ФизическийСклад,ложь);     
	ЗапросИзлишки = новый запрос;    
	ЗапросИзлишки.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросИзлишки.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Склад КАК Склад,
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток > 0
	|ИТОГИ
	|	СУММА(КоличествоОстаток)
	|ПО
	|	Склад";	  
	ЗапросИзлишки.УстановитьПараметр("Дата2",НачалоМесяца(ЗакрываемыйМесяц)+1);	
	
	ВыборкаПоСкладам = ЗапросИзлишки.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Склад");
	Пока ВыборкаПоСкладам.Следующий() цикл

		ПРМОб = СоздатьПеремещение(ВыборкаПоСкладам.Склад,ФизическийСклад,НачалоМесяца(ЗакрываемыйМесяц),"Создано обработкой закрытия минусов. Для временного обнуления вирт. складов");

		ВыборкаПоТоварам = ВыборкаПоСкладам.Выбрать();  
		Сч=1;      
		КоличествоСТрок = ВыборкаПоТоварам.Количество();

		если ВыполнятьФоново тогда
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПРМДляОбнуленияВиртуальныхСкладовНаСервере",
			СтрШаблон("Создаётся ПРМ с %1 количество строк %2",ВыборкаПоСкладам.Склад,КоличествоСтрок));
		КонецЕсли;
		пока ВыборкаПоТоварам.Следующий() цикл
			ДобавитьСтрокуПРМ(ПРМОб,ВыборкаПоТоварам.Номенклатура,ВыборкаПоТоварам.КоличествоОстаток);		
			если ВыполнятьФоново тогда
				Процент = 100*сч/КоличествоСтрок; 
				УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияПРМДляОбнуленияВиртуальныхСкладовНаСервере",Процент);  
			КонецЕсли;      
			сч = сч+1;
		КонецЦикла;      
		
		
		если ВыполнятьФоново тогда			
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПРМДляОбнуленияВиртуальныхСкладовНаСервере",
			СтрШаблон("Начало проведения %1 по складу %2", ПРМОб.Номер,ВыборкаПоСкладам.Склад));
		КонецЕсли;        
		
		попытка
			ПРМОб.Записать(РежимЗаписиДокумента.Проведение);   
			МассивСозданныхПРМ.Добавить(ПРМОб.Ссылка);   
			если ВыполнятьФоново тогда			
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПРМДляОбнуленияВиртуальныхСкладовНаСервере",
				СтрШаблон("ПРМ %1 проведен", ПРМОб.Номер));
			КонецЕсли;      
		Исключение       
			МассивСообщений.Добавить(СтрШаблон("Не удалось создать ПРМ со склада %1. %2",ВыборкаПоСкладам.Склад,ОписаниеОшибки())); 
			если ВыполнятьФоново тогда			
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПРМДляОбнуленияВиртуальныхСкладовНаСервере",
				СтрШаблон("ПРМ %1 не проведен %2", ПРМОб.Номер, ОписаниеОшибки()));
			КонецЕсли;     
		КонецПопытки;
	КонецЦикла;	
	
	//ПараметрыСеанса.ЗапущенаОбработка = ложь;

	ЗаписатьМассивДанныхВДанныеЗакрытияМесяцаПоСкладу(ФизическийСклад,ЗакрываемыйМесяц,МассивСозданныхПРМ,"МассивПРМДляОбнуленияВиртСкладов");
	
	если ВыполнятьФоново тогда
		УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияПРМДляОбнуленияВиртуальныхСкладовНаСервере",1000);
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеПРМДляОбнуленияВиртуальныхСкладовНаСервере",СтрСоединить(МассивСообщений,символы.ПС));        	
	иначе
		Сообщение = новый СообщениеПользователю;
		Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
		Сообщение.Сообщить();
	КонецЕсли;	
	

КонецПроцедуры


&НаСервере
//По каждому дню, сначало на начало дня под отгрузку с вирт. складов перемещает товар с физического
//Потом перемещает обратно если есть излишек (возвраты в течении дня)
Процедура СоздатьПРМДляВыравниванияОстатковПоДням (ФизическийСклад,МассивДней,ПропускатьПроблемныеДни,ДопПараметры) экспорт  
	
	ВыполнятьФоново = Истина;
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда 
		если ДопПараметры.Свойство("ВыполнятьФоново") и ДопПараметры.ВыполнятьФоново = ложь тогда
			ВыполнятьФоново = Ложь;
		КонецЕсли;
	КонецЕсли;
	//ПараметрыСеанса.ЗапущенаОбработка = Истина;
	МассивСообщений = новый массив;
	МассивСкладов = ПолучитьМассивВиртуальныхСкладов(ФизическийСклад,ложь);     
	
	МассивПРМНаВиртуальныеСклады = новый Массив;
	МассивПРМСВиртуальныхСкладов = новый Массив;

	если МассивДней.количество() = 0 тогда
		МассивСообщений.Добавить("Пустое количество дней для закрытия минусов");  
		
		если ВыполнятьФоново тогда
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеСоздатьПРМДляОбработкиДнейНаСервере",СтрСоединить(МассивСообщений,символы.ПС));        		
		иначе
			Сообщение = новый СообщениеПользователю;
			Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
			Сообщение.Сообщить();
		КонецЕсли;	
		
		возврат;
	КонецЕсли;
	
	ТЗДней = новый ТаблицаЗначений;
	ТЗДней.Колонки.Добавить("День");   
	для Каждого СтрМассива из МассивДней Цикл       
		СтрТЗ = ТЗДней.Добавить();
		СтрТЗ.День = СтрМассива;
	КонецЦикла;       
	ТЗДней.Свернуть("День");
	ТЗДней.Сортировать("День");
	
	
	ЗакрываемыйМесяц = НачалоМесяца(МассивДней[0]);
	
	ЗапросИзлишки = новый запрос;    
	ЗапросИзлишки.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросИзлишки.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Склад КАК Склад,
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток > 0
	|ИТОГИ
	|	СУММА(КоличествоОстаток)
	|ПО
	|	Склад";	  
	
	ЗапросМинуса = новый запрос;    
	ЗапросМинуса.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросМинуса.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Склад КАК Склад,
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&Дата2,
	|			Склад В (&МассивСкладов)
	|				И Номенклатура В (&МассивНоменклатуры)) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток < 0
	|ИТОГИ
	|	СУММА(КоличествоОстаток)
	|ПО
	|	Склад";	 
	
	ЗапросМинусаТолькоНоменклатура = новый запрос;    
	ЗапросМинусаТолькоНоменклатура.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросМинусаТолькоНоменклатура.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	                                       |	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	                                       |	ОстаткиТМЦОстатки.Склад КАК Склад
	                                       |ИЗ
	                                       |	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
	                                       |ГДЕ
	                                       |	ОстаткиТМЦОстатки.КоличествоОстаток < 0";	 	
	
	ЗапросНаличиеНаФизСкладе = новый запрос;    
	ЗапросНаличиеНаФизСкладе.УстановитьПараметр("Склад",ФизическийСклад);	
	ЗапросНаличиеНаФизСкладе.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&Дата2,
	|			Склад = &Склад
	|				И Номенклатура В (&МассивНоменклатуры)) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток > 0";	
	
	
	

	ЗапросМинусаВСерединеДня = новый запрос;    
	ЗапросМинусаВСерединеДня.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросМинусаВСерединеДня.Текст = "ВЫБРАТЬ
	                                 |	Остатки.КоличествоКонечныйОстаток КАК КоличествоОстаток,
	                                 |	Остатки.Номенклатура КАК Номенклатура,
	                                 |	Остатки.Склад КАК Склад
	                                 |ИЗ
	                                 |	РегистрНакопления.ОстаткиТМЦ.ОстаткиИОбороты(&Дата1, &Дата2, Запись, , Склад В (&МассивСкладов)) КАК Остатки
	                                 |ГДЕ
	                                 |	Остатки.КоличествоКонечныйОстаток < 0
	                                 |ИТОГИ
	                                 |	МИНИМУМ(КоличествоОстаток)
	                                 |ПО
	                                 |	Склад";	 
	

	ЗапросМинусаВСерединеДняТолькоНоменклатура = новый запрос;    
	ЗапросМинусаВСерединеДняТолькоНоменклатура.УстановитьПараметр("МассивСкладов",МассивСкладов);	
	ЗапросМинусаВСерединеДняТолькоНоменклатура.Текст = "ВЫБРАТЬ
	|	Остатки.КоличествоКонечныйОстаток КАК КоличествоОстаток,
	|	Остатки.Номенклатура КАК Номенклатура,
