//МелкиеФункции
&НаСервере
Функция СоздатьПеремещение(Склад,СкладПолучатель,ДатаПРМ,Комментарий)
	
	СтруктураДокумента = новый Структура();
	СтруктураДокумента.Вставить("Склад",Склад);
	СтруктураДокумента.Вставить("СкладПолучатель",СкладПолучатель);  
	СтруктураДокумента.Вставить("ИБ",Справочники.ИБ.НайтиПоКоду("SSP"));  
	СтруктураДокумента.Вставить("Менеджер",ПараметрыСеанса.Пользователь.ФизЛицо);  
	СтруктураДокумента.Вставить("Автор",ПараметрыСеанса.Пользователь);
	СтруктураДокумента.Вставить("Организация",Справочники.Организации.НайтиПоКоду("SS-001"));
	СтруктураДокумента.Вставить("Организация",Справочники.Организации.НайтиПоКоду("SS-001"));
	СтруктураДокумента.Вставить("Комментарий",Комментарий);
	СтруктураДокумента.Вставить("СостояниеНакладной",Перечисления.СостоянияНакладной.Отгружена);
	СтруктураДокумента.Вставить("СостояниеНакладнойУПолучателя",Перечисления.СостоянияНакладной.Принята);
	СтруктураДокумента.Вставить("Отгружен",Перечисления.Отгружен.Отгружен);
	СтруктураДокумента.Вставить("Дата",ДатаПРМ);
	СтруктураДокумента.Вставить("ДатаПриемки",ДатаПРМ);      
	СтруктураДокумента.Вставить("ДатаОтгрузки",ДатаПРМ);
	
	СтруктураДокумента.Вставить("ДатаПриемки",ПараметрыСеанса.ВалютаУпр);
	СтруктураДокумента.Вставить("Курс",1);
	
	ПРМОб = ЗаполнениеДокументов.НайтиСоздатьПроизвольныйДокументОбъект("Перемещение",СтруктураДокумента);    
	УстановитьПунктДоставкиКлиентСервер(ПРМОб,"СкладПолучатель","ПунктДоставки");
	
	возврат ПРМОб;
КонецФункции   

&НаСервере
Функция ДобавитьСтрокуПРМ (ПРМОб,Номенклатура,Количество)
	СтрТЧ = ПРМОб.Товары.Добавить(); 
	СтрТЧ.Номенклатура	=	Номенклатура;
	СтрТЧ.Заявка		=	Количество;
	стртч.ПодтвержденнаяЗаявка				=	Количество;			
	стртч.ПодтвержденнаяЗаявкаПеремещения	=	Количество;
	СтрТЧ.Количество						=	Количество;	   
	
	ДопПараметры = новый Структура("ОтключитьРасчетСкидок,ЗаполнятьСтавкуНДСИзРодителя,КоэффициентВсегдаОдин,ПредопределеннаяЦена,ОтключитьРасчетЛогистическихРеквизитов"
	,Истина,Истина,Истина,1,Истина);   
	
	ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ПРМОб,,,ДопПараметры);
	РассчитатьСуммуТабЧасти(СтрТЧ, ПРМОб,,ДопПараметры); 	
КонецФункции   


&НаСервере
Функция ПолучитьМассивВиртуальныхСкладов (Склад, ДобавлятьТекущийФизическийСклад = ложь)  экспорт 
	запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|Склады.ФизическийСклад = &Склад
	|	И не Склады.ПометкаУдаления";
	запрос.УстановитьПараметр("Склад",Склад);
	МассивСкладов = запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");   
	если ДобавлятьТекущийФизическийСклад тогда
		МассивСкладов.Добавить(Склад);
	КонецЕсли;
	возврат МассивСкладов;
	
КонецФункции






#Область СохранениеПромежуточныхРезультатов
 
&НаСервере
Процедура ЗаписатьМассивДанныхВДанныеЗакрытияМесяцаПоСкладу (Склад,Месяц,МассивЗначениеПоля,ИмяПоля,ЭтоУдаление = ложь)      
	
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,НачалоМесяца(Месяц)); 
	если ЗначенияДанных = Неопределено тогда
		ЗначенияДанных = новый Структура();
	КонецЕсли;               
	
	если не ЗначенияДанных.Свойство(ИмяПоля) тогда
		ЗначенияДанных.Вставить(ИмяПоля,новый Массив);
	КонецЕсли;    
	
	если  ЭтоУдаление тогда       
		ЗначенияДанных[ИмяПоля] = новый Массив;
	иначе
		Для каждого СтрокаМассива из МассивЗначениеПоля цикл 
			если ЗначенияДанных[ИмяПоля].Найти(СтрокаМассива) = Неопределено тогда
				ЗначенияДанных[ИмяПоля].добавить(СтрокаМассива);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	
	
	МЗ = РегистрыСведений.ДанныеЗакрытияМесяцаПоСкладу.СоздатьМенеджерЗаписи();
	МЗ.Склад = Склад;
	мз.Период = НачалоМесяца(месяц);       
	МЗ.Значение = новый ХранилищеЗначения(ЗначенияДанных);
	МЗ.Записать(Истина);
	
	
КонецПроцедуры          


&НаСервере
Функция ПрочитатьМассивДанныхЗакрытияМесяцаПоСкладу (Склад,Месяц,ИмяПоля) экспорт     
	
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,НачалоМесяца(Месяц)); 
	если ЗначенияДанных = Неопределено тогда
		ЗначенияДанных = новый Структура();
	КонецЕсли;               
	
	если не ЗначенияДанных.Свойство(ИмяПоля) тогда
		возврат новый Массив;  
	иначе
		возврат ЗначенияДанных[ИмяПоля]; 
	КонецЕсли;    
	
КонецФункции


&НаСервере      
Функция ПрочитатьСохранённыеОстаткиСклада(Склад,Месяц) экспорт    
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,Месяц);
	
	если ЗначенияДанных = Неопределено тогда
		возврат Неопределено;
	КонецЕсли;
	
	Если ЗначенияДанных.Свойство("ТаблицаОстатков")  тогда
		возврат ЗначенияДанных.ТаблицаОстатков;
	КонецЕсли;
	
КонецФункции

&НаСервере       
Процедура ЗаписатьОстаткиСклада(Склад,Месяц) экспорт     
	если не ЗначениеЗаполнено(склад) тогда
		ВызватьИсключение "Заполните склад";
	КонецЕсли;
	
	если не ЗначениеЗаполнено(Месяц) тогда
		ВызватьИсключение "Заполните месяц";
	КонецЕсли;
	
	
	
	ТаблицаОстатков = ПолучитьОстаткиСкладаНаНачалоОткрытогоМесяца(Склад,Месяц);  
	
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,Месяц); 
	если ЗначенияДанных = Неопределено тогда
		ЗначенияДанных = новый Структура();
	КонецЕсли; 
	если не ЗначенияДанных.Свойство("ТаблицаОстатков") тогда
		ЗначенияДанных.Вставить("ТаблицаОстатков");
	КонецЕсли;
	
	ЗначенияДанных.ТаблицаОстатков = ТаблицаОстатков;
	
	
	МЗ = РегистрыСведений.ДанныеЗакрытияМесяцаПоСкладу.СоздатьМенеджерЗаписи();
	МЗ.Склад = Склад;
	мз.Период = НачалоМесяца(месяц);       
	МЗ.Значение = новый ХранилищеЗначения(ЗначенияДанных);
	МЗ.Записать(Истина);
	
КонецПроцедуры   

&НаСервере        
Функция ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,Месяц)  экспорт
	если не ЗначениеЗаполнено(склад) тогда
		ВызватьИсключение "Заполните склад";
	КонецЕсли;
	
	если не ЗначениеЗаполнено(Месяц) тогда
		ВызватьИсключение "Заполните месяц";
	КонецЕсли;
	
	
	СтруктураЗначений = РегистрыСведений.ДанныеЗакрытияМесяцаПоСкладу.Получить(НачалоМесяца(Месяц),новый Структура("Склад",Склад));  
	возврат СтруктураЗначений.Значение.Получить();
КонецФункции

&НаСервере        
Функция ПолучитьОстаткиСкладаНаНачалоОткрытогоМесяца(Склад,Месяц) экспорт 
	МассивСкладов = Обработки.АРМ_ЗакрытиеМинусов.ПолучитьМассивВиртуальныхСкладов(Склад,ложь);
	запрос = новый запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток,
	|	ОстаткиТМЦОстатки.Склад КАК Склад
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад В (&МассивСкладов)) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток > 0";     
	запрос.УстановитьПараметр("Дата2",КонецМесяца(месяц)+1);
	запрос.УстановитьПараметр("МассивСкладов",МассивСкладов);
	возврат запрос.Выполнить().Выгрузить();
	
КонецФункции
   

&НаСервере       
Функция ОстаткиСкладовЗаписаны(Склад,Месяц) экспорт   
	ТаблицаОстатков = ПрочитатьСохранённыеОстаткиСклада(Склад,Месяц);
	если ТаблицаОстатков = Неопределено  тогда
		Возврат ложь;
	иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

  




