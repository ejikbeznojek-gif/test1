	ЗаписатьМассивДанныхВДанныеЗакрытияМесяцаПоСкладу(ФизическийСклад,ЗакрываемыйМесяц,МассивПРМСВиртуальныхСкладов,"МассивПеремещенияПеремещенияСВиртуальныхСкладов");

	 МассивСообщений.Добавить("Обработка завершена!!!");
	
	если ВыполнятьФоново тогда
		УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияСоздатьПРМДляОбработкиДнейНаСервере",1000);
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеСоздатьПРМДляОбработкиДнейНаСервере",СтрСоединить(МассивСообщений,символы.ПС));        		
	иначе
		Сообщение = новый СообщениеПользователю;
		Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
		Сообщение.Сообщить();
	КонецЕсли;	
	
	
	
КонецПроцедуры

 &НаСервере       
Процедура ЗаписатьОбработанныеДни(Склад,Месяц,День) экспорт     
	если не ЗначениеЗаполнено(склад) тогда
		ВызватьИсключение "Заполните склад";
	КонецЕсли;
	
	если не ЗначениеЗаполнено(Месяц) тогда
		ВызватьИсключение "Заполните месяц";
	КонецЕсли;
	
	
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,Месяц);
	
	если ЗначенияДанных = Неопределено тогда
		ЗначенияДанных = новый Структура();
	КонецЕсли;                
	
	если не ЗначенияДанных.Свойство("МассивОбработанныхДней") тогда
		ЗначенияДанных.Вставить("МассивОбработанныхДней");  
		ЗначенияДанных.МассивОбработанныхДней = новый Массив;
	КонецЕсли;
	
	Если ЗначенияДанных.МассивОбработанныхДней.найти(День) = Неопределено тогда    
		ЗначенияДанных.МассивОбработанныхДней.Добавить(День);
	КонецЕсли;
	
	
	МЗ = РегистрыСведений.ДанныеЗакрытияМесяцаПоСкладу.СоздатьМенеджерЗаписи();
	МЗ.Склад = Склад;
	мз.Период = НачалоМесяца(месяц);       
	МЗ.Значение = новый ХранилищеЗначения(ЗначенияДанных);
	МЗ.Записать(Истина);
	
КонецПроцедуры    

  &НаСервере       
Процедура ОчиститьОбработанныеДни(Склад,Месяц) экспорт     
	если не ЗначениеЗаполнено(склад) тогда
		ВызватьИсключение "Заполните склад";
	КонецЕсли;
	
	если не ЗначениеЗаполнено(Месяц) тогда
		ВызватьИсключение "Заполните месяц";
	КонецЕсли;
	
	
	
	ТаблицаОстатков = ПолучитьОстаткиСкладаНаНачалоОткрытогоМесяца(Склад,Месяц);  
	
	ЗначенияДанных = ПрочитатьДанныеЗакрытияМесяцаПоСкладу(Склад,Месяц);
	
	если ЗначенияДанных = Неопределено тогда
		ЗначенияДанных = новый Структура();
	КонецЕсли;                
	
	если не ЗначенияДанных.Свойство("МассивОбработанныхДней") тогда
		ЗначенияДанных.Вставить("МассивОбработанныхДней");  
	КонецЕсли;
	ЗначенияДанных.МассивОбработанныхДней = новый Массив;
	
	
	
	МЗ = РегистрыСведений.ДанныеЗакрытияМесяцаПоСкладу.СоздатьМенеджерЗаписи();
	МЗ.Склад = Склад;
	мз.Период = НачалоМесяца(месяц);       
	МЗ.Значение = новый ХранилищеЗначения(ЗначенияДанных);
	МЗ.Записать(Истина);
	
КонецПроцедуры   



&НаСервере  
//Восстановление остатков по виртуальным складам
Процедура ВосстановитьОстаткиВиртуальныхСкладов(ФизическийСклад,ЗакрываемыйМесяц,МассивСозданныхПРМ,ДопПараметры = Неопределено) экспорт     
	
	//   УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияВосстановитьОстаткиВиртуальныхСкладов",100);
	//
	//   УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",МассивСозданныхПРМ);  		
	
	ВыполнятьФоново = Истина;
	если ТипЗнч(ДопПараметры) = Тип("Структура") тогда 
		если ДопПараметры.Свойство("ВыполнятьФоново") и ДопПараметры.ВыполнятьФоново = ложь тогда
			ВыполнятьФоново = Ложь;
		КонецЕсли;
	КонецЕсли;
	МассивСообщений = новый массив;
	
	МассивСкладов = ПолучитьМассивВиртуальныхСкладов(ФизическийСклад,ложь);       
	
	ЗапросНаличиеНаФизСкладе = новый запрос;    
	ЗапросНаличиеНаФизСкладе.УстановитьПараметр("Склад",ФизическийСклад);	 
	ЗапросНаличиеНаФизСкладе.УстановитьПараметр("Дата2",КонецМесяца(ЗакрываемыйМесяц)+1);	 
	ЗапросНаличиеНаФизСкладе.Текст = "ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&Дата2,
	|			Склад = &Склад) КАК ОстаткиТМЦОстатки
	|ГДЕ
	|	ОстаткиТМЦОстатки.КоличествоОстаток > 0";        
	ТаблицаНаличия = ЗапросНаличиеНаФизСкладе.Выполнить().Выгрузить();	
	
	
	
	
	ТаблицаОстатковСтарая = ПрочитатьСохранённыеОстаткиСклада(ФизическийСклад,ЗакрываемыйМесяц); 	
	ТаблицаОстатковНовая = ПолучитьОстаткиСкладаНаНачалоОткрытогоМесяца(ФизическийСклад,ЗакрываемыйМесяц);  
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.КоличествоОстаток КАК КоличествоОстаток,
	               |	ТЗ.Склад КАК Склад
	               |ПОМЕСТИТЬ ВТСтарая
	               |ИЗ
	               |	&ТаблицаОстатковСтарая КАК ТЗ
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Номенклатура,
	               |	Склад
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.КоличествоОстаток КАК КоличествоОстаток,
	               |	ТЗ.Склад КАК Склад
	               |ПОМЕСТИТЬ ВТНовая
	               |ИЗ
	               |	&ТаблицаОстатковНовая КАК ТЗ
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Номенклатура,
	               |	Склад
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ВТНовая.Номенклатура, ВТСтарая.Номенклатура) КАК Номенклатура,
	               |	ЕСТЬNULL(ВТНовая.Склад, ВТСтарая.Склад) КАК Склад,
	               |	ЕСТЬNULL(ВТНовая.КоличествоОстаток, 0) - ЕСТЬNULL(ВТСтарая.КоличествоОстаток, 0) КАК Дельта
	               |ПОМЕСТИТЬ Сводная
	               |ИЗ
	               |	ВТСтарая КАК ВТСтарая
	               |		ПОЛНОЕ СОЕДИНЕНИЕ ВТНовая КАК ВТНовая
	               |		ПО ВТСтарая.Склад = ВТНовая.Склад
	               |			И ВТСтарая.Номенклатура = ВТНовая.Номенклатура
	               |ГДЕ
	               |	ЕСТЬNULL(ВТНовая.КоличествоОстаток, 0) - ЕСТЬNULL(ВТСтарая.КоличествоОстаток, 0) <> 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сводная.Номенклатура КАК Номенклатура,
	               |	Сводная.Склад КАК Склад,
	               |	Сводная.Дельта КАК КоличествоОстаток
	               |ИЗ
	               |	Сводная КАК Сводная
	               |ГДЕ
	               |	Сводная.Дельта > 0
	               |ИТОГИ
	               |	СУММА(КоличествоОстаток)
	               |ПО
	               |	Склад
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сводная.Номенклатура КАК Номенклатура,
	               |	Сводная.Склад КАК Склад,
	               |	-Сводная.Дельта КАК КоличествоОстаток
	               |ИЗ
	               |	Сводная КАК Сводная
	               |ГДЕ
	               |	Сводная.Дельта < 0
	               |ИТОГИ
	               |	СУММА(КоличествоОстаток)
	               |ПО
	               |	Склад";                  
	запрос.УстановитьПараметр("ТаблицаОстатковСтарая",ТаблицаОстатковСтарая); 
	запрос.УстановитьПараметр("ТаблицаОстатковНовая",ТаблицаОстатковНовая);
	
	ПакетРезультатов = запрос.ВыполнитьПакет();
	ВыборкаНедостачиПоСкладам =  ПакетРезультатов[4].выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Склад");
	ВыборкаИзлишкиПоСкладам = ПакетРезультатов[3].выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Склад");
	Пока ВыборкаИзлишкиПоСкладам.Следующий() цикл

		ПРМОб = СоздатьПеремещение(ВыборкаИзлишкиПоСкладам.Склад,ФизическийСклад,КонецМесяца(ЗакрываемыйМесяц),"Создано обработкой закрытия минусов. Для списания излишков после закрытия.");
		
		ВыборкаПоТоварам = ВыборкаИзлишкиПоСкладам.Выбрать();  
		Сч=1;      
		КоличествоСТрок = ВыборкаПоТоварам.Количество();
		
		если ВыполнятьФоново тогда
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
			СтрШаблон("Создаётся на изьятие излишков ПРМ с %1 количество строк %2",ВыборкаИзлишкиПоСкладам.Склад,КоличествоСтрок));
		КонецЕсли;          
		
		пока ВыборкаПоТоварам.Следующий() цикл
			ДобавитьСтрокуПРМ(ПРМОб,ВыборкаПоТоварам.Номенклатура,ВыборкаПоТоварам.КоличествоОстаток);		
			если ВыполнятьФоново тогда
				Процент = 100*сч/КоличествоСтрок; 
				УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияВосстановитьОстаткиВиртуальныхСкладов",Процент);  
			КонецЕсли;      
			сч = сч+1;
		КонецЦикла;      
		
		
		если ВыполнятьФоново тогда			
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
			СтрШаблон("Начало проведения %1 по складу %2", ПРМОб.Номер,ВыборкаИзлишкиПоСкладам.Склад));
		КонецЕсли;        
		
		попытка   
			если ПРМОб.Товары.Итог("Количество") > 0 тогда
				
				ПРМОб.Записать(РежимЗаписиДокумента.Проведение);   
				МассивСозданныхПРМ.Добавить(ПРМОб.Ссылка);   
				если ВыполнятьФоново тогда			
					УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
					СтрШаблон("ПРМ %1 проведен", ПРМОб.Номер));
				КонецЕсли; 
			КонецЕсли;
		Исключение       
			МассивСообщений.Добавить(СтрШаблон("Не удалось создать ПРМ со склада %1. %2",ВыборкаИзлишкиПоСкладам.Склад,ОписаниеОшибки())); 
			если ВыполнятьФоново тогда			
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
				СтрШаблон("ПРМ %1 не проведен %2", ПРМОб.Номер, ОписаниеОшибки()));
			КонецЕсли;     
		КонецПопытки;
	КонецЦикла;	
	
	
	
	Пока ВыборкаНедостачиПоСкладам.Следующий() цикл
		
		ПРМОб = СоздатьПеремещение(ФизическийСклад,ВыборкаНедостачиПоСкладам.Склад,КонецМесяца(ЗакрываемыйМесяц),"Создано обработкой закрытия минусов. Для восстановления остатков после закрытия.");
		
		ВыборкаПоТоварам = ВыборкаНедостачиПоСкладам.Выбрать();  
		Сч=1;      
		КоличествоСТрок = ВыборкаПоТоварам.Количество();
		
		если ВыполнятьФоново тогда
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
			СтрШаблон("Создаётся на закрытиие оставшихся минусов ПРМ на %1 количество строк %2",ВыборкаНедостачиПоСкладам.Склад,КоличествоСтрок));
		КонецЕсли;          
		
		пока ВыборкаПоТоварам.Следующий() цикл     
			СтрокаНаличия = ТаблицаНаличия.Найти(ВыборкаПоТоварам.Номенклатура,"Номенклатура");    
			НужноСписать = ВыборкаПоТоварам.КоличествоОстаток;   
			Номенклатура = ВыборкаПоТоварам.Номенклатура;
			
			если СтрокаНаличия <> Неопределено тогда 
				если СтрокаНаличия.КоличествоОстаток < НужноСписать тогда
					МассивСообщений.Добавить(СтрШаблон("Неудалось вернуть остаток в исходное состояние по складу %1 по номенклатуре %2 с кодом %3. Нужно %4, есть в наличии %5",
					ВыборкаНедостачиПоСкладам.Склад,Номенклатура,номенклатура.код,НужноСписать,СтрокаНаличия.КоличествоОстаток));    
					НужноСписать =  СтрокаНаличия.КоличествоОстаток;
					СтрокаНаличия.КоличествоОстаток = 0;
				Иначе
					СтрокаНаличия.КоличествоОстаток = СтрокаНаличия.КоличествоОстаток - НужноСписать;
				КонецЕсли;                         
			иначе
				НеУдалосьЗакрытьДень = Истина;
				МассивСообщений.Добавить(СтрШаблон("Неудалось вернуть остаток в исходное состояние по складу %1 по номенклатуре %2 с кодом %3. Нужно %4, есть в наличии %5",
				ВыборкаНедостачиПоСкладам.Склад,Номенклатура,номенклатура.код,НужноСписать,0));   					
				Продолжить;				
			КонецЕсли;  
			
			ДобавитьСтрокуПРМ(ПРМОб,ВыборкаПоТоварам.Номенклатура,НужноСписать);		
			если ВыполнятьФоново тогда
				Процент = 100*сч/КоличествоСтрок; 
				УведомленияКлиента.ОтправитьУведомление("ПроцентВыполненияВосстановитьОстаткиВиртуальныхСкладов",Процент);  
			КонецЕсли;      
			сч = сч+1;
		КонецЦикла;      
		
		
		если ВыполнятьФоново тогда			
			УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
			СтрШаблон("Начало проведения %1 по складу %2", ПРМОб.Номер,ВыборкаНедостачиПоСкладам.Склад));
		КонецЕсли;        
		
		попытка       
			если ПРМОб.Товары.Итог("Количество") > 0 тогда
				ПРМОб.Записать(РежимЗаписиДокумента.Проведение);   
				МассивСозданныхПРМ.Добавить(ПРМОб.Ссылка);   
				если ВыполнятьФоново тогда			
					УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
					СтрШаблон("ПРМ %1 проведен", ПРМОб.Номер));
				КонецЕсли;     
			КонецЕсли;
		Исключение       
			МассивСообщений.Добавить(СтрШаблон("Не удалось создать ПРМ на склад %1. %2",ВыборкаНедостачиПоСкладам.Склад,ОписаниеОшибки())); 
			если ВыполнятьФоново тогда			
				УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",
				СтрШаблон("ПРМ %1 не проведен %2", ПРМОб.Номер, ОписаниеОшибки()));
			КонецЕсли;     
		КонецПопытки;
	КонецЦикла;	
	
	
	
	если ВыполнятьФоново тогда
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",1000);
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",СтрСоединить(МассивСообщений,символы.ПС));        
		УведомленияКлиента.ОтправитьУведомление("ОповещенияФоновыеВосстановитьОстаткиВиртуальныхСкладов",МассивСозданныхПРМ);  		
	иначе
		Сообщение = новый СообщениеПользователю;
		Сообщение.Текст = СтрСоединить(МассивСообщений,символы.ПС);
		Сообщение.Сообщить();
	КонецЕсли;	
	
	
КонецПроцедуры




