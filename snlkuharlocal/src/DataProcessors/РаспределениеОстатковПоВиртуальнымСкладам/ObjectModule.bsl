Перем МассивСкладовПРМ;
Перем МассивСкладовОбПРМ;

Процедура Сформировать(ТПараметры = неопределено )  Экспорт
	
	Если ТипЗнч(ТПараметры) <> Тип("ТаблицаЗначений") Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	ПараметрыРегламента = Новый Соответствие;
	
	МассивСкладов = Новый Массив; 
	
	Для каждого СтрокаПараметров Из ТПараметры Цикл   
		
		ЗаписатьВЛог("РегламентСозданиеПРМ","Параметр: "+СтрокаПараметров.Имя+" - "+СтрокаПараметров.Значение,"Информация");		
		ПараметрыРегламента.Вставить(СтрокаПараметров.Имя,СтрокаПараметров.Значение);
		
		Если СтрНайти(СтрокаПараметров.Имя,"Склад",,1) > 0 Тогда
		
			МассивСкладов.Добавить(СтрокаПараметров.Значение); 	
		
		КонецЕсли;
		
	КонецЦикла; 
	
	Если МассивСкладов.Количество() = 0 Тогда
		
		ЗаписатьВЛог("РегламентСозданиеПРМ","Не задан склад для расчета остатков","Информация"); 
		
		//Возврат; 	
	
	КонецЕсли;
	
	ТЗРаспр.Очистить();
	ТЗНастр.Очистить();
	ТЗОст.Очистить();
	ТЗПРМ.Очистить();
	
	МассивСкладовПРМ = МассивСкладов;
	
	//Склады.ЗагрузитьЗначения(МассивСкладовПРМ); 
	
	ЗаполнитьНачальныеНастройки(ПараметрыРегламента); 
	
	МассивНоменклатуры = Новый Массив; 

	ТЗОсновныеОстаткиПоСкладам = ПолучитьТаблицуОстатковПоСкладамДляРаспределения(МассивСкладов,МассивНоменклатуры);
	
	ТЗРаспр.Очистить();
	ТЗОсновныеОстаткиПоСкладам1 = ТЗОсновныеОстаткиПоСкладам.Скопировать();
	ТЗОсновныеОстаткиПоСкладам1.Свернуть("Номенклатура","Остаток"); 
	
	ТЧДляРаспределения = ТЗРаспр.Выгрузить().Скопировать(); 
	Для каждого СтрокаОстатков  Из ТЗОсновныеОстаткиПоСкладам1 Цикл
	
		НСтрока = ТЧДляРаспределения.Добавить(); 
		ЗаполнитьЗначенияСвойств(НСтрока,СтрокаОстатков); 
	
	КонецЦикла;	
	//для проверки 
	//ТЗРаспр.Загрузить(ТЧДляРаспределения); 
	
	Если ТЧДляРаспределения.Количество() = 0  Тогда 	
		ЗаписатьВЛог("РегламентСозданиеПРМ","Не найдены товары для распределения","Информация");
		//Возврат; 		
	КонецЕсли;
	
	Если ТЧДляРаспределения.Итог("Остаток") = 0 Тогда
		ЗаписатьВЛог("РегламентСозданиеПРМ","Нет остатков товаров для распределения","Информация");
		//Возврат;
	КонецЕсли;
	
	//СписокПолучателей = СформСписокПолучат(Справочники.ТипыРассылок.НайтиПоКоду("000000008"));
	
	МСНО = Новый Массив;

	Соот1 = Новый Соответствие;
	Соот2 = Новый Соответствие;
	
	ТЗНастр1 = ТЗНастр.Выгрузить();
	ТЗНастр2 = ТЗНастр.Выгрузить();
	ТЗНастр3 = ТЗНастр.Выгрузить();
	ТЗНастр4 = ТЗНастр.Выгрузить();
	ТЗНастр5 = ТЗНастр.Выгрузить();
	
	МС1 = ТЗНастр3.ВыгрузитьКолонку("Склад");
	МС2 = ТЗНастр3.ВыгрузитьКолонку("СкладМаркировка");
	МС = Объединить2Массива_ВернутьНовый(МС1, МС2);
	
	
	ТЗНастр2.Свернуть("Направление, НачалоРасчета, ОкончаниеРасчета,УчитыватьОстаткиПланыСпаек,НачалоРасчетаКитай,ОкончаниеРасчетаКитай"); 
	ТЗНастр3.Свернуть("Склад, СкладМаркировка, Направление, РасчетОстатка");
	ТЗНастр4.Свернуть("Склад,СкладМаркировка,УчитыватьОстаткиПланыСпаек");
	ТЗНастр5.Свернуть("Склад,ФормПРМОбратные"); 

	Для Каждого ТСтр Из ТЗНастр3 Цикл
		
		Соот1.Вставить(ТСтр.Склад, ТСтр.Направление);
		Соот2.Вставить(ТСтр.СкладМаркировка, ТСтр.Направление);
		
		Если ТСтр.РасчетОстатка = "Факт+Резерв" Тогда
			МСНО.Добавить(ТСтр.Склад);
			МСНО.Добавить(ТСтр.СкладМаркировка);  		
		КонецЕсли;
		
	КонецЦикла;
	
	МНапр = Новый Массив;
	МДОП = Новый Массив;
	МДПС = Новый Массив;
	
	МДОП.Добавить(Справочники.Подразделения.НайтиПоКоду("SMN-0425")); 
	
	ПодрДИП = Новый Массив;
	ПодрДИП.Добавить(Справочники.Подразделения.НайтиПоКоду("SSP-0326"));
	
	
	МДПС.Добавить(Справочники.Подразделения.НайтиПоКоду("SSP-0062"));
	
	МКДОП = Новый Массив;
	МКДПС = Новый Массив;
	
	МКДОП.Добавить(Справочники.Контрагенты.НайтиПоКоду("SSR-4927"));
	МКДПС.Добавить(Справочники.Контрагенты.НайтиПоКоду("SSR-4937"));
	
	ДУИсклДОП = "";
	ДУИсклДПС = "";
	

	
	Если  МассивНоменклатуры.Количество() > 0 Тогда 
		
		ТЗОст1 = ПолучитьОстаткиПоСкладамПолучателям(МассивНоменклатуры, МС, ТЗНастр4);
		
		
		ТЗРНО = ПолучитьРезервыПоРНК(МассивНоменклатуры, МСНО, ТЗНастр4);  
		
		
				
		ТЗП = ПолучитьПланПродажПоНаправлениям(ДУИсклДОП, ДУИсклДПС, МассивНоменклатуры, МДОП, МДПС, МКДОП, МКДПС, МНапр, ПодрДИП, ТЗНастр2);
		
		ТЗПланПродажПоСпайкам = ПолучитьПланПродажПоСпайкам(МДОП, МДПС, МКДОП, МКДПС,ПодрДИП, МассивНоменклатуры,ТЗНастр2);
		
		ТЗОстПоСпайкам = ПолучитьОстаткиПоСпайкам(МС, Соот1, ТЗНастр4, ТЗПланПродажПоСпайкам);
		
		Для каждого СтрокаПродаж Из ТЗПланПродажПоСпайкам Цикл 
			
			Если СтрокаПродаж.Количество <= 0 Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			СтрокиОстатков = ТЗОстПоСпайкам.НайтиСтроки(Новый Структура("Номенклатура, Направление", СтрокаПродаж.Номенклатура, ТСтр.Направление));
			Для каждого СтрокаОстатков Из СтрокиОстатков Цикл
				
				Если СтрокаОстатков.Ост <= 0  Тогда
					
					Продолжить;
					
				КонецЕсли;
				
				СтрокаВычесть = Мин(СтрокаПродаж.Количество,СтрокаОстатков.Ост); 	
				СтрокаПродаж.Количество =   СтрокаПродаж.Количество -  СтрокаВычесть;
				
				СтрокаОстатков.Ост = СтрокаОстатков.Ост - СтрокаВычесть; 
				
			КонецЦикла;
			
		КонецЦикла;
		
		ОстаткиПланКомплПоСпайкам = Новый ТаблицаЗначений; 
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Номенклатура");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Направление");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Количество");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("ПППоСпайкам"); 
		
		Для каждого  СтрокаПродаж Из ТЗПланПродажПоСпайкам  Цикл
			
			Если СтрокаПродаж.Количество <= 0 Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НоменклатураКоплектующие.Номенклатура КАК Номенклатура,
			|	НоменклатураКоплектующие.Количество КАК Количество
			|ИЗ
			|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
			|ГДЕ
			|	НоменклатураКоплектующие.Ссылка = &Ссылка
			|	И НоменклатураКоплектующие.Количество > 0";
			
			Запрос.УстановитьПараметр("Ссылка", СтрокаПродаж.Номенклатура);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НСтрока = ОстаткиПланКомплПоСпайкам.Добавить(); 
				НСтрока.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
				НСтрока.Направление = СтрокаПродаж.Направление; 
				НСтрока.Количество = СтрокаПродаж.Количество * ВыборкаДетальныеЗаписи.Количество;
				НСтрока.ПППоСпайкам = СтрокаПродаж.Количество; 
			КонецЦикла; 
			
		КонецЦикла;   
		ОстаткиПланКомплПоСпайкам.Свернуть("Номенклатура,Направление","Количество,ПППоСпайкам");
		
		Для Каждого ТСтр Из ТЗОст1 Цикл
			
			ТСтр.Направление = Соот1.Получить(ТСтр.Склад);
			НайдыР = ТЗРНО.НайтиСтроки(Новый Структура("Номенклатура, Склад", ТСтр.Номенклатура, ТСтр.Склад));
			
			Если НайдыР.Количество() Тогда
				
				Для Каждого НайдР Из НайдыР Цикл
					ТСтр.Ост = ТСтр.Ост + НайдР.Количество;
				КонецЦикла;
				
			КонецЕсли;	
			
		КонецЦикла; 	 
		
		ТЗОст1.Свернуть("Номенклатура, Направление", "Ост, ПланПродаж"); 
		
		ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(14,3)); 
		ТЗОст1.Колонки.Добавить("ПППоСпайкам",ОписаниеТиповЧисло); 
		ТЗОст1.Колонки.Добавить("ПППоСпайкамКомпл",ОписаниеТиповЧисло);
		
		Для Каждого ТСтр Из ТЗОст1 Цикл
			
			НайдыП = ТЗП.НайтиСтроки(Новый Структура("Номенклатура, Направление", ТСтр.Номенклатура, ТСтр.Направление));
			
			Если НайдыП.Количество() Тогда
				
				Для Каждого НайдП Из НайдыП Цикл
					ТСтр.ПланПродаж = ТСтр.ПланПродаж + НайдП.Количество;
				КонецЦикла;
				
			КонецЕсли;
			СтрокиПоСпайкам = ОстаткиПланКомплПоСпайкам.НайтиСтроки(Новый Структура("Номенклатура, Направление", ТСтр.Номенклатура, ТСтр.Направление));
			Если СтрокиПоСпайкам.Количество() > 0  Тогда
				
				ТСтр.ПППоСпайкам = СтрокиПоСпайкам[0].ПППоСпайкам;
				ТСтр.ПППоСпайкамКомпл = СтрокиПоСпайкам[0].Количество;
				
			КонецЕсли;  	
			
		КонецЦикла;
		
		МФорм = Новый Массив;
		
		нн = 0;
		
		Пока нн < МНапр.Количество() Цикл
			
			МФорм.Добавить(Ложь);
			
			нн = нн + 1;
			
		КонецЦикла;
		//для проверки 
		ТЗОст.Загрузить(ТЗОст1); 
				
		ЗаполнитьТалицуКРаспределениюСоздатьПРМ(МНапр, МФорм, ОстаткиПланКомплПоСпайкам, ТЗНастр1, ТЗОст1, ТЧДляРаспределения,ТЗОсновныеОстаткиПоСкладам); 
		
	КонецЕсли;
	
	//СоздаватьПРМОбратные = Ложь; 
	
	Если СоздаватьПРМОбратные Тогда
		
		ТЗРаспр_1.Очистить();
		ТЗОст_1.Очистить();
				
		МассивНоменклатуры = Новый Массив; 
		МассивСкладовОбПРМ = МС;
		МНапр = Новый Массив; 
		
		ТЗОсновныеОстаткиПоСкладам = ПолучитьТаблицуОстатковПоСкладамДляРаспределения(МассивСкладовОбПРМ,МассивНоменклатуры);
		
		ТЗРаспр_1.Очистить();
		ТЗОсновныеОстаткиПоСкладам1 = ТЗОсновныеОстаткиПоСкладам.Скопировать();
		ТЗОсновныеОстаткиПоСкладам1.Свернуть("Номенклатура","Остаток"); 
		
		ТЧДляРаспределения = ТЗРаспр_1.Выгрузить().Скопировать(); 
		Для каждого СтрокаОстатков  Из ТЗОсновныеОстаткиПоСкладам1 Цикл
			
			НСтрока = ТЧДляРаспределения.Добавить(); 
			ЗаполнитьЗначенияСвойств(НСтрока,СтрокаОстатков); 
			
		КонецЦикла;	
		
	
		ТЗОст1 = ПолучитьОстаткиПоСкладамПолучателямОбратныеПРМ(МассивНоменклатуры, МС, ТЗНастр4);
		
		//ТЗРНО = ПолучитьРезервыПоРНК(МассивНоменклатуры, МСНО, ТЗНастр4);
		
		ТЗП = ПолучитьПланПродажПоНаправлениям(ДУИсклДОП, ДУИсклДПС, МассивНоменклатуры, МДОП, МДПС, МКДОП, МКДПС, МНапр, ПодрДИП, ТЗНастр2);
		
		ТЗПланПродажПоСпайкам = ПолучитьПланПродажПоСпайкам(МДОП, МДПС, МКДОП, МКДПС, ПодрДИП, МассивНоменклатуры, ТЗНастр2);
		
		ТЗОстПоСпайкам = ПолучитьОстаткиПоСпайкам(МС, Соот1, ТЗНастр4, ТЗПланПродажПоСпайкам);
		
		Для каждого СтрокаПродаж Из ТЗПланПродажПоСпайкам Цикл 
			
			Если СтрокаПродаж.Количество <= 0 Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			СтрокиОстатков = ТЗОстПоСпайкам.НайтиСтроки(Новый Структура("Номенклатура, Направление", СтрокаПродаж.Номенклатура, ТСтр.Направление));
			Для каждого СтрокаОстатков Из СтрокиОстатков Цикл
				
				Если СтрокаОстатков.Ост <= 0  Тогда
					
					Продолжить;
					
				КонецЕсли;
				
				СтрокаВычесть = Мин(СтрокаПродаж.Количество,СтрокаОстатков.Ост); 	
				СтрокаПродаж.Количество =   СтрокаПродаж.Количество -  СтрокаВычесть;
				
				СтрокаОстатков.Ост = СтрокаОстатков.Ост - СтрокаВычесть; 
				
			КонецЦикла;
			
		КонецЦикла;
		
		ОстаткиПланКомплПоСпайкам = Новый ТаблицаЗначений; 
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Номенклатура");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Направление");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("Количество");
		ОстаткиПланКомплПоСпайкам.Колонки.Добавить("ПППоСпайкам"); 
		
		Для каждого  СтрокаПродаж Из ТЗПланПродажПоСпайкам  Цикл
			
			Если СтрокаПродаж.Количество <= 0 Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НоменклатураКоплектующие.Номенклатура КАК Номенклатура,
			|	НоменклатураКоплектующие.Количество КАК Количество
			|ИЗ
			|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
			|ГДЕ
			|	НоменклатураКоплектующие.Ссылка = &Ссылка
			|	И НоменклатураКоплектующие.Количество > 0";
			
			Запрос.УстановитьПараметр("Ссылка", СтрокаПродаж.Номенклатура);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НСтрока = ОстаткиПланКомплПоСпайкам.Добавить(); 
				НСтрока.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
				НСтрока.Направление = СтрокаПродаж.Направление; 
				НСтрока.Количество = СтрокаПродаж.Количество * ВыборкаДетальныеЗаписи.Количество;
				НСтрока.ПППоСпайкам = СтрокаПродаж.Количество; 
			КонецЦикла; 
			
		КонецЦикла;   
		ОстаткиПланКомплПоСпайкам.Свернуть("Номенклатура,Направление","Количество,ПППоСпайкам");
		
		Для Каждого ТСтр Из ТЗОст1 Цикл
			
			ТСтр.Направление = Соот1.Получить(ТСтр.Склад);  
			Если Не ЗначениеЗаполнено(ТСтр.Направление) Тогда
				
				ТСтр.Направление = Соот2.Получить(ТСтр.Склад);	
				
			КонецЕсли;
			
			//НайдыР = ТЗРНО.НайтиСтроки(Новый Структура("Номенклатура, Склад", ТСтр.Номенклатура, ТСтр.Склад));
			//
			//Если НайдыР.Количество() Тогда
			//	
			//	Для Каждого НайдР Из НайдыР Цикл
			//		ТСтр.Ост = ТСтр.Ост + НайдР.Количество;
			//	КонецЦикла;
			//	
			//КонецЕсли;	
			
		КонецЦикла;	
		
		ТЗОстПоСкладам = ТЗОст1.Скопировать();
		
		ТЗОст1.Свернуть("Номенклатура, Направление", "Ост, ПланПродаж"); 
		
		ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(14,3)); 
		ТЗОст1.Колонки.Добавить("ПППоСпайкам",ОписаниеТиповЧисло); 
		ТЗОст1.Колонки.Добавить("ПППоСпайкамКомпл",ОписаниеТиповЧисло);
		
		ОстаткиПланКомплПоСпайкам.Свернуть("Номенклатура","Количество,ПППоСпайкам");	
		
		Для Каждого ТСтр Из ТЗОст1 Цикл
			
			НайдыП = ТЗП.НайтиСтроки(Новый Структура("Номенклатура, Направление", ТСтр.Номенклатура, ТСтр.Направление));
			
			Если НайдыП.Количество() Тогда
				
				Для Каждого НайдП Из НайдыП Цикл
					ТСтр.ПланПродаж = ТСтр.ПланПродаж + НайдП.Количество;
				КонецЦикла;
				
			КонецЕсли; 
			
			Если ТСтр.Направление = "ДИП" Тогда   			
				СтрокиПоСпайкам = ОстаткиПланКомплПоСпайкам.НайтиСтроки(Новый Структура("Номенклатура", ТСтр.Номенклатура));	
				Если СтрокиПоСпайкам.Количество() > 0  Тогда 
					Для Каждого СтрокаПоСпайкам Из СтрокиПоСпайкам Цикл
						ТСтр.ПланПродаж = ТСтр.ПланПродаж + СтрокаПоСпайкам.Количество;
					КонецЦикла;
					
					ТСтр.ПППоСпайкам = СтрокиПоСпайкам[0].ПППоСпайкам;
					ТСтр.ПППоСпайкамКомпл = СтрокиПоСпайкам[0].Количество;	
				КонецЕсли;
			КонецЕсли; 					
			
		КонецЦикла; 	
		  	
		МФорм = Новый Массив;
		
		нн = 0;
		
		Пока нн < МНапр.Количество() Цикл
			
			МФорм.Добавить(Ложь);
			
			нн = нн + 1;
			
		КонецЦикла;	
		
		ТЗОст_1.Загрузить(ТЗОст1); 
		
		Для Каждого ТекСтр Из ТЧДляРаспределения Цикл 
			
			Если ТекСтр.Номенклатура.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда
				
				Продолжить; 	
				
			КонецЕсли;
			
			
			нн = 0;
			
			Пока  нн < МНапр.Количество() Цикл 
				
				ТекН = МНапр[нн];
				НайдыОст1 = ТЗОст1.НайтиСтроки(Новый Структура("Номенклатура, Направление", ТекСтр.Номенклатура, ТекН));
				Если нн = 0 Тогда
					
					Если НайдыОст1.Количество() > 0  Тогда
						
						Ост = НайдыОст1[0].Ост; 
						ПланПродаж = НайдыОст1[0].ПланПродаж;
						
						Если ПланПродаж > 0 
							И Ост > ПланПродаж Тогда
							
							ТекСтр.Количество1 = Ост - ПланПродаж; 
							
							МФорм[нн] = Истина;
							
						КонецЕсли;
						
					КонецЕсли;
				ИначеЕсли нн = 1 Тогда
					
					Если НайдыОст1.Количество() > 0  Тогда
						
						Ост = НайдыОст1[0].Ост; 
						ПланПродаж = НайдыОст1[0].ПланПродаж;
						
						Если ПланПродаж > 0
							И Ост > ПланПродаж Тогда
							
							ТекСтр.Количество2 = Ост - ПланПродаж; 
							МФорм[нн] = Истина;
							
						КонецЕсли;
						
					КонецЕсли;
				ИначеЕсли нн = 2 Тогда
					
					Если НайдыОст1.Количество() > 0  Тогда
						
						Ост = НайдыОст1[0].Ост; 
						ПланПродаж = НайдыОст1[0].ПланПродаж;
						
						Если ПланПродаж > 0
							И Ост > ПланПродаж Тогда
							
							ТекСтр.Количество3 = Ост - ПланПродаж; 	
							
							МФорм[нн] = Истина;
						КонецЕсли;
						
					КонецЕсли;  
					
				ИначеЕсли нн = 3 Тогда
					
					Если НайдыОст1.Количество() > 0  Тогда
						
						Ост = НайдыОст1[0].Ост; 
						ПланПродаж = НайдыОст1[0].ПланПродаж;
						
						Если ПланПродаж > 0
							И Ост > ПланПродаж Тогда
							
							ТекСтр.Количество4 = Ост - ПланПродаж; 	
							МФорм[нн] = Истина;
						КонецЕсли;
						
					КонецЕсли;  
					
				ИначеЕсли нн = 4 Тогда
					
					Если НайдыОст1.Количество() > 0  Тогда
						
						Ост = НайдыОст1[0].Ост; 
						ПланПродаж = НайдыОст1[0].ПланПродаж;
						
						Если ПланПродаж > 0
							И Ост > ПланПродаж Тогда
							
							ТекСтр.Количество5 = Ост - ПланПродаж; 	
							МФорм[нн] = Истина;
						КонецЕсли;
						
					КонецЕсли;
				КонецЕсли;
				нн = нн + 1;
			КонецЦикла;  
			
			
		КонецЦикла;
		
		ТЗРаспр_1.Загрузить(ТЧДляРаспределения); 
		
		тт = 0; 	
		Пока тт < МНапр.Количество() Цикл
			
			ТекН = МНапр[тт];
			СклПол = Неопределено; 
			
			Если МФорм[тт] Тогда 
				
				//прм создаем на склад получатель со склада или маркировки или обычного склада 
				
				Найды3 = ТЗНастр1.НайтиСтроки(Новый Структура("Направление", ТекН)); 
				
				СоответствиеСкладыПРМ = Новый Соответствие; 
				МассивПРМДляЗаписи = Новый Массив; 
				Для Каждого Найд3 Из Найды3 Цикл
					Если НЕ Найд3.ФормПРМОбратные Тогда
						Продолжить;
					КонецЕсли; 
					
					ДокПРМ = СоздатьПРМ(Найд3.Склад,СкладОбрПРМ);
					СоответствиеСкладыПРМ.Вставить(Найд3.Склад,ДокПРМ);
					МассивПРМДляЗаписи.Добавить(ДокПРМ); 
					
					ДокПРМ = СоздатьПРМ(Найд3.СкладМаркировка,СкладОбрПРММаркировка);
					СоответствиеСкладыПРМ.Вставить(Найд3.СкладМаркировка,ДокПРМ);
					МассивПРМДляЗаписи.Добавить(ДокПРМ);
				КонецЦикла;
				
				
				Для Каждого ТекСтр Из ТЧДляРаспределения Цикл
					
					КолКол = "Количество" + Строка(тт + 1);
					КолПрм = ТекСтр[КолКол];
					Если КолПрм > 0  Тогда
						
						ОтборПоОстаткам = Новый Структура("Номенклатура,Направление",ТекСтр.Номенклатура,ТекН); 	
						СтрокиОстаткиПоСкладам = ТЗОстПоСкладам.НайтиСтроки(ОтборПоОстаткам); 
						Для каждого СтрокаОстатковПоСкладам Из СтрокиОстаткиПоСкладам Цикл
							Если СтрокаОстатковПоСкладам.Ост = 0
								ИЛИ КолПрм = 0 Тогда
								
								Продолжить;	
								
							КонецЕсли;   
							
							Переместить = Мин(СтрокаОстатковПоСкладам.Ост,КолПрм);
							
							СтрокаОстатковПоСкладам.Ост = СтрокаОстатковПоСкладам.Ост - Переместить; 
							КолПРМ = КолПрм - Переместить;
							
							ДокПРМ =  СоответствиеСкладыПРМ.Получить(СтрокаОстатковПоСкладам.Склад);
							
							Если ДокПРМ = неопределено Тогда
							
								Продолжить; 	
							
							КонецЕсли;
							
							Если ДокПРМ.Товары.Количество() >= 10000 Тогда
							
								ДокПРМ = СоздатьПРМ(ДокПРМ.Склад, ДокПРМ.СкладПолучатель); 	
							    СоответствиеСкладыПРМ.Вставить(СтрокаОстатковПоСкладам.Склад,ДокПРМ);
								МассивПРМДляЗаписи.Добавить(ДокПРМ);
							КонецЕсли;
							
							СтрТЧ = ДокПРМ.Товары.Добавить();
							
							СтрТЧ.Номенклатура = ТекСтр.Номенклатура;
							СтрТЧ.Заявка = Переместить;
							СтрТЧ.ПодтвержденнаяЗаявка = Переместить;			
							СтрТЧ.ПодтвержденнаяЗаявкаПеремещения = Переместить;
							СтрТЧ.Количество = Переместить;				
							
							ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокПРМ);
							РассчитатьСуммуТабЧасти(СтрТЧ, ДокПРМ);  							
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
				
				//Для каждого ЭлСоответствия Из СоответствиеСкладыПРМ Цикл
				Для каждого ЭлементМассива Из МассивПРМДляЗаписи Цикл
					ДокПРМ = ЭлементМассива; //.Значение; 
					
					Если ДокПРМ.Товары.Количество() > 0  Тогда
					
						ДокПРМ.Записать(РежимЗаписиДокумента.Проведение);
						
						ЗаписатьВЛог("РегламентСозданиеПРМ","Записан ПРМ (обратное) " + Строка(ДокПРМ.ссылка),"Информация");
					
					КонецЕсли;
				
				КонецЦикла;
			КонецЕсли;	
							
			тт = тт + 1;
			
		КонецЦикла;	
		

		
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьТалицуКРаспределениюСоздатьПРМ(Знач МНапр, 
	Знач МФорм, 
	Знач ОстаткиПланКомплПоСпайкам,
	Знач ТЗНастр1,
	Знач ТЗОст1, 
	Знач ТЧДляРаспределения,
	Знач ТЗОсновныеОстаткиПоСкладам) 
	
	ОстаткиПланКомплПоСпайкам.Свернуть("Номенклатура","Количество");
	
	ТЗОст1.Колонки.Добавить("ОстРасч"); 
	
	Для Каждого ТекСтр Из ТЧДляРаспределения Цикл
		
		Ост = ТекСтр.Остаток;
		
		ОстРасчетный =  ТекСтр.Остаток; 
		
		План = 0;
		КоэфПлан = 0;
		ТНом = ТекСтр.Номенклатура;
		Ост1 = 0;
		
		НайдыОст = ТЗОст1.НайтиСтроки(Новый Структура("Номенклатура", ТНом));
		
		Для Каждого НайдОст Из НайдыОст Цикл
			
			Ост1 = Ост1 + НайдОст.Ост;
			План = План + НайдОст.ПланПродаж;
			
			
			НайдОст.ОстРасч = НайдОст.Ост; 
			
			
		КонецЦикла;
		
		НайдыП = ОстаткиПланКомплПоСпайкам.НайтиСтроки(Новый Структура("Номенклатура", ТекСтр.Номенклатура));
		ПланНоменклатурыДляСпаек = 0; 
		Если НайдыП.Количество() Тогда   		
			Для Каждого НайдП Из НайдыП Цикл
				ПланНоменклатурыДляСпаек = ПланНоменклатурыДляСпаек + НайдП.Количество;
			КонецЦикла; 		
		КонецЕсли;  
		
		
		КРаспределениюН = 0;  
		ОбщийОстаток = Ост + Ост1;
		Ост1Был = Ост1; 
		Если ПланНоменклатурыДляСпаек > 0 Тогда 
			
			Если Ост1 >= ПланНоменклатурыДляСпаек  Тогда
				
				Ост1 = Ост1 - ПланНоменклатурыДляСпаек; 	
				КРаспределениюН = 0;
				
			ИначеЕсли Ост1 > 0 И Ост1 < ПланНоменклатурыДляСпаек Тогда 				
				
				Если Ост > (ПланНоменклатурыДляСпаек - ост1) Тогда
					Ост = Ост - (ПланНоменклатурыДляСпаек - ост1); 
					КРаспределениюН =  ПланНоменклатурыДляСпаек - ост1; 
				ИначеЕсли Ост <= (ПланНоменклатурыДляСпаек - ост1) Тогда 
					КРаспределениюН =  Ост; //ПланНоменклатурыДляСпаек - ост1 - Ост; 
					Ост = 0; 
				КонецЕсли;
				
				Ост1 = 0;
				
			КонецЕсли; 
			
			РазницаОст = Ост1Был - Ост1;
			
			
			Если Ост1Был > 0 Тогда 
				Для Каждого НайдОст Из НайдыОст Цикл
					Если РазницаОст = 0 Тогда
						
						Прервать; 	
						
					КонецЕсли; 
					
					Если  НайдОст.ОстРасч < 0  Тогда
					
						Продолжить; 	
					
					КонецЕсли;
					
					МинОст = Мин(НайдОст.ОстРасч,РазницаОст); 
					НайдОст.ОстРасч = НайдОст.ОстРасч - МинОст; 
					
					РазницаОст = РазницаОст - МинОст; 
					
				КонецЦикла; 
			КонецЕсли;
		Конецесли;  
		
		
		Рассчит = Истина;
		
		Если ТНом.ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда
			
			КоэфПлан = 1;			
			ТекСтр.КРаспред = Ост; 		
			КРаспределениюН = Ост;			
			Рассчит = Ложь;
			
		Иначе 	
			Если План = 0 Тогда
				Рассчит = Ложь;
			КонецЕсли;
			
			Если Рассчит Тогда
				
				КоэфПлан = (Ост + Ост1) / План; 
				
			КонецЕсли;	
			
			Если (Ост > (План - Ост1)) И ((План - Ост1) > 0) Тогда
				
				КоэфПлан = 1;
				
				ТекСтр.КРаспред = План - Ост1;
				
			Иначе
				
				Если ((План - Ост1) <= 0) Тогда
					
					//остатка хватает 
					Рассчит = Ложь;
					КоэфПлан = 0;
					ТекСтр.КРаспред = 0;
					
				Иначе
					
					ТекСтр.КРаспред = Ост;
					
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		///////////////
		
			
		ОстР = 0;
		
		нн = 0;
		
		Пока  нн < МНапр.Количество() Цикл
			
			ТекН = МНапр[нн]; 
			
			НайдНаправление = ТЗНастр1.НайтиСтроки(Новый Структура("Направление", ТекН));
			РаспределениеСпаек = НайдНаправление[0].РаспределениеСпаек; 
			
			НайдыОст1 = ТЗОст1.НайтиСтроки(Новый Структура("Номенклатура, Направление", ТНом, ТекН));
			
			ЕстьКол = Ложь;
			
			Если нн = 0 Тогда
				
				ТекСтр.Направление1 = ТекН;
				ТекО = 0;
				ТекП = 0;
				
				
				Если РаспределениеСпаек Тогда
					
					ТекСтр.КРаспред1 = КРаспределениюН;
					ОстР = ОстР + КРаспределениюН; 
					КРаспределениюН = 0; 				 
					
				КонецЕсли;
				
				
				Если НайдыОст1.Количество() Тогда	
					
					НайдОст1 = НайдыОст1[0];
					
					ТекО = НайдОст1.ОстРасч;
					
					ТекП = НайдОст1.ПланПродаж;
					
					Если Рассчит Тогда
						
						КолР = Окр((КоэфПлан * НайдОст1.ПланПродаж) - НайдОст1.ОстРасч); //НайдОст1.Ост);
						
						Если (ТекСтр.КРаспред > КолР) И Рассчит Тогда
							ТекСтр.Количество1 = ?(КолР > 0, КолР, 0);
						Иначе
							ТекСтр.Количество1 = ТекСтр.КРаспред;
						КонецЕсли;
						
					КонецЕсли;
					
				Иначе
					
					ТекСтр.Количество1 = 0;
					
				КонецЕсли; 		
				
				ОстР = ОстР + ТекСтр.Количество1;
				
				Если ТекСтр.Количество1 Тогда
					МФорм[нн] = Истина;
				КонецЕсли;
				
				
				Если ТекСтр.КРаспред1 <> 0 Тогда
					МФорм[нн] = Истина;
				КонецЕсли;
				
				
			ИначеЕсли нн = 1 Тогда
				
				ТекСтр.Направление2 = ТекН;
				ТекО = 0;
				ТекП = 0;
				
				
				Если РаспределениеСпаек Тогда
					
					ТекСтр.КРаспред2 = КРаспределениюН;
					ОстР = ОстР + КРаспределениюН;
					КРаспределениюН = 0; 
					
				КонецЕсли;
				
				
				Если НайдыОст1.Количество() Тогда
					
					НайдОст1 = НайдыОст1[0];
					
					
					ТекО = НайдОст1.ОстРасч;
					
					ТекП = НайдОст1.ПланПродаж;
					
					Если Рассчит Тогда
						
						КолР = Окр((КоэфПлан * НайдОст1.ПланПродаж) - НайдОст1.ОстРасч); //НайдОст1.Ост);
						
						Если (ТекСтр.КРаспред > КолР) И Рассчит Тогда
							ТекСтр.Количество2 = ?(КолР > 0, КолР, 0);
						Иначе
							ТекСтр.Количество2 = ТекСтр.КРаспред;
						КонецЕсли;
						
					КонецЕсли;
				Иначе
					
					ТекСтр.Количество2 = 0;
					
				КонецЕсли;
				
				Если ТекСтр.Количество2 > (ОстРасчетный - ОстР) Тогда
					ТекСтр.Количество2 = (ОстРасчетный - ОстР)
				КонецЕсли;
				
				ОстР = ОстР + ТекСтр.Количество2;
				
				
				Если ТекСтр.Количество2 Тогда
					МФорм[нн] = Истина;
				КонецЕсли;
				
				Если ТекСтр.КРаспред2 <> 0 Тогда
					МФорм[нн] = Истина;
				КонецЕсли;
				
				
			ИначеЕсли нн = 2 Тогда
				
				ТекСтр.Направление3 = ТекН;
				ТекО = 0;
				ТекП = 0;
				
				Если РаспределениеСпаек Тогда
					
					ТекСтр.КРаспред3 = КРаспределениюН;
					ОстР = ОстР + КРаспределениюН;
					КРаспределениюН = 0;
					
				КонецЕсли;
				
				
				Если НайдыОст1.Количество() Тогда
					
					НайдОст1 = НайдыОст1[0];
					
					ТекО = НайдОст1.ОстРасч; 
					
					ТекП = НайдОст1.ПланПродаж;
					
					Если Рассчит Тогда
						
						КолР = Окр((КоэфПлан * НайдОст1.ПланПродаж) - НайдОст1.ОстРасч); //НайдОст1.Ост);
						
						Если (ТекСтр.КРаспред > КолР) И Рассчит Тогда
							ТекСтр.Количество3 = ?(КолР > 0, КолР, 0);
						Иначе
							ТекСтр.Количество3 = ТекСтр.КРаспред;
						КонецЕсли;
						
