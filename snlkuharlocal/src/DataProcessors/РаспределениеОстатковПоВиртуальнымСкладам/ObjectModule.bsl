Функция ПолучитьТаблицуОстатковПоСкладамДляРаспределения(Знач МассивСкладов,МассивНоменклатуры)
	
	//ТЗРаспр.Очистить();
	//ТЧдляРаспределения = ТЗРаспр.Выгрузить().Скопировать(); 
	
	Запрос = Новый Запрос; 
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Остаток,
	|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	Остатки.Склад КАК Склад
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			,
	|			Склад В (&Склады)
	|				И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|				И ВЫБОР
	|					КОГДА &ОтборПоГруппе
	|						ТОГДА Номенклатура В ИЕРАРХИИ (&ГруппаТоваров)
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				,
	|				Склад В (&Склады)
	|					И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|					И ВЫБОР
	|						КОГДА &ОтборПоГруппе
	|							ТОГДА Номенклатура В ИЕРАРХИИ (&ГруппаТоваров)
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ) КАК Резервы
	|		ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			И Остатки.Склад = Резервы.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура,
	|	Остатки.Склад
	|
	|ИМЕЮЩИЕ
	|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) > 0";
	Запрос.УстановитьПараметр("Склады",МассивСкладов);
	Запрос.УстановитьПараметр("ГруппаТоваров",ГруппаТоваров);
	Запрос.УстановитьПараметр("ОтборПоГруппе",ЗначениеЗаполнено(ГруппаТоваров));
	//Выборка = Запрос.Выполнить().Выбрать(); 
	//
	//Пока Выборка.Следующий() Цикл
	//	
	//	НоваяСтрока = ТЧдляРаспределения.Добавить(); 	
	//	ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);
	//	
	//	МассивНоменклатуры.Добавить(Выборка.Номенклатура); 
	//	
	//	
	//КонецЦикла;
	// 
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	МассивНоменклатуры = ТЗ.ВыгрузитьКолонку("Номенклатура");
	
	Возврат ТЗ; 

КонецФункции

Функция Объединить2Массива_ВернутьНовый(МассивИсточник, МассивПриемник)
	МассивВозврата = Новый Массив;
	Для Каждого Элемент ИЗ МассивИсточник Цикл
		Если МассивВозврата.Найти(Элемент) = Неопределено И ЗначениеЗаполнено(Элемент) Тогда
			МассивВозврата.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Элемент ИЗ МассивПриемник Цикл
		Если МассивВозврата.Найти(Элемент) = Неопределено И ЗначениеЗаполнено(Элемент) Тогда
			МассивВозврата.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивВозврата;
КонецФункции