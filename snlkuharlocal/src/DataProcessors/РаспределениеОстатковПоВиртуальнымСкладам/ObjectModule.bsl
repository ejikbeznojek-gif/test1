Функция СоздатьПРМ(Знач СкладОтправитель, Знач СклПол)
	
	Перем Подсортировка;
	
	Подсортировка = Документы.Перемещение.СоздатьДокумент();
	Подсортировка.Склад = СкладОтправитель;
	Подсортировка.СкладПолучатель = СклПол;
	Подсортировка.ИБ = Справочники.ИБ.НайтиПоКоду("SSP");
	Подсортировка.Менеджер = ПараметрыСеанса.Пользователь.ФизЛицо;
	Подсортировка.Автор = ПараметрыСеанса.Пользователь;
	Подсортировка.Организация = Справочники.Организации.НайтиПоКоду("SS-001");
	
	УстановитьПунктДоставки1(Подсортировка, "СкладПолучатель", "ПунктДоставки");
	
	Подсортировка.Комментарий = "Создано обработкой распределение остатков по виртуальным складам";
	Подсортировка.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена;
	Подсортировка.СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.Принята;
	Подсортировка.Отгружен = Перечисления.Отгружен.Отгружен;
	Подсортировка.Дата = ТекущаяДата();
	Подсортировка.ДатаПриемки = ТекущаяДата();
	Подсортировка.Валюта = Справочники.Валюты.НайтиПоКоду("810");
	Подсортировка.Курс = 1;
	
	
	УстановитьНомерДокументаКлиентСервер(Подсортировка);
	Возврат Подсортировка;

КонецФункции 

Процедура УстановитьПунктДоставки1(ДокументОбъект, ИмяРеквизитаКонтрагент = "Контрагент", ИмяРеквизитаПД = "ПунктДоставки") Экспорт	
	
	Контрагент = ДокументОбъект[ИмяРеквизитаКонтрагент];
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Если ЕстьРеквизитДокумента("ОсновнойПунктДоставки",Контрагент.Метаданные()) И ЗначениеЗаполнено(Контрагент.ОсновнойПунктДоставки) Тогда
			ДокументОбъект[ИмяРеквизитаПД]=Контрагент.ОсновнойПунктДоставки;	
		ИначеЕсли КоличествоПД1(Контрагент)=1 Тогда		
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин начало
			//для складов, если несколько ПД, выбираем первый
		ИначеЕсли ИмяРеквизитаКонтрагент = "СкладПолучатель" Тогда
			//крохин начало 28.07.2011
			//выбираем первый по наименованию
			//Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
			Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент,,"Наименование Убыв");
			//крохин конец 28.07.2011
			Пока Выборка.Следующий() Цикл
				ДокументОбъект[ИмяРеквизитаПД]=Выборка.Ссылка;			
			КонецЦикла;
			//крохин конец
		Иначе
			ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
		КонецЕсли;		
	Иначе
		ДокументОбъект[ИмяРеквизитаПД]=Неопределено;		
	КонецЕсли;
	
КонецПроцедуры

Функция КоличествоПД1(Контрагент)
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПунктыДоставки.Ссылка) КАК Количество
		               |ИЗ
		               |	Справочник.ПунктыДоставки КАК ПунктыДоставки
		               |ГДЕ
		               |	ПунктыДоставки.Владелец = &Владелец";
		
		Запрос.УстановитьПараметр("Владелец",Контрагент);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Количество;			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ПолучитьОстаткиПоСпайкам(МС, Знач Соот1, ТЗНастр4, ТЗПланПродажПоСпайкам)
	
	
	Запрос22 = Новый Запрос;
	
	Запрос22.Текст =
	"ВЫБРАТЬ
	|	ТЗНом.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомВрем_1
	|ИЗ
	|	&ТЗНом КАК ТЗНом
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_НомВрем_1.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомВрем
	|ИЗ
	|	ВТ_НомВрем_1 КАК ВТ_НомВрем_1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗСкладов.Склад КАК Склад,
	|	ТЗСкладов.СкладМаркировка КАК СкладМаркировка,
	|	ТЗСкладов.УчитыватьОстаткиПланыСпаек КАК УчитыватьОстаткиПланыСпаек
	|ПОМЕСТИТЬ ВТ_СкладВрем
	|ИЗ
	|	&ТЗНастр4 КАК ТЗСкладов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНом.Номенклатура КАК Номенклатура,
	|	ТЗСклад.Склад КАК Склад,
	|	ТЗСклад.СкладМаркировка КАК СкладМаркировка
	|ПОМЕСТИТЬ ВТ_Ном
	|ИЗ
	|	ВТ_НомВрем КАК ТЗНом,
	|	ВТ_СкладВрем КАК ТЗСклад
	|ГДЕ
	|	ТЗСклад.УчитыватьОстаткиПланыСпаек
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Ост,
	|	СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
	|	""Направление"" КАК Направление,
	|	Остатки.Склад КАК Склад,
	|	Остатки.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомОст
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&ТД,
	|			Склад В (&Склады)
	|				И Номенклатура В (&Ном)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				&ТД,
	|				Склад В (&Склады)
	|					И Номенклатура В (&Ном)) КАК Резервы
	|		ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			И Остатки.Склад = Резервы.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура,
	|	Остатки.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(ВТ_НомОст.Ост, 0)) КАК Ост,
	|	СУММА(ЕСТЬNULL(ВТ_НомОст.Резерв, 0)) КАК Резерв,
	|	""Направление"" КАК Направление,
	|	0 КАК ПланПродаж,
	|	ВЫБОР
	|		КОГДА НЕ ВТ_НомОст.Склад ЕСТЬ NULL
	|				И ВТ_НомОст.Склад = ВТ_Ном.СкладМаркировка
	|			ТОГДА ВТ_Ном.Склад
	|		ИНАЧЕ ЕСТЬNULL(ВТ_НомОст.Склад, ВТ_Ном.Склад)
	|	КОНЕЦ КАК Склад,
	|	ВТ_Ном.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТ_Ном КАК ВТ_Ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомОст КАК ВТ_НомОст
	|		ПО ВТ_Ном.Номенклатура = ВТ_НомОст.Номенклатура
	|			И (ВТ_Ном.Склад = ВТ_НомОст.Склад
	|				ИЛИ ВТ_Ном.СкладМаркировка = ВТ_НомОст.Склад)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА НЕ ВТ_НомОст.Склад ЕСТЬ NULL
	|				И ВТ_НомОст.Склад = ВТ_Ном.СкладМаркировка
	|			ТОГДА ВТ_Ном.Склад
	|		ИНАЧЕ ЕСТЬNULL(ВТ_НомОст.Склад, ВТ_Ном.Склад)
	|	КОНЕЦ,
	|	ВТ_Ном.Номенклатура";
	Запрос22.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос22.УстановитьПараметр("ТЗНастр4", ТЗНастр4);
	Запрос22.УстановитьПараметр("Ном", ТЗПланПродажПоСпайкам.ВыгрузитьКолонку("Номенклатура"));
	Запрос22.УстановитьПараметр("ТД", ТекущаяДата());
	Запрос22.УстановитьПараметр("Склады", МС);  
	Запрос22.УстановитьПараметр("ТЗНом", ТЗПланПродажПоСпайкам);
	
	ТЗОстПоСпайкам = Запрос22.Выполнить().Выгрузить(); 
	
	Для Каждого ТСтр Из ТЗОстПоСпайкам Цикл
		
		ТСтр.Направление = Соот1.Получить(ТСтр.Склад);
		
	КонецЦикла;
	
	Возврат ТЗОстПоСпайкам; 

КонецФункции

Функция ПолучитьПланПродажПоСпайкам(МДОП, МДПС, МКДОП, МКДПС, ПодрДИП, МассивНоменклатуры,Знач ТЗНастр2)
	
		
	Запрос21 = Новый Запрос;
	Запрос21.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос21.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СправочникНом.Ссылка КАК Спайка
	|ПОМЕСТИТЬ ВТСпайки
	|ИЗ
	|	Справочник.Номенклатура КАК СправочникНом
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК КоплектующиеНом
	|		ПО СправочникНом.Ссылка = КоплектующиеНом.Ссылка
	|ГДЕ
	|	КоплектующиеНом.Номенклатура В(&Ном)
	|	И СправочникНом.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)";
	Запрос21.УстановитьПараметр("Ном", МассивНоменклатуры);
	Запрос21.Выполнить(); 
	
	н = 0; 
	Пока н < ТЗНастр2.Количество() Цикл
		
		ТС = ТЗНастр2.Получить(н);
		
		Если НЕ ТС.УчитыватьОстаткиПланыСпаек Тогда
			
			н = н + 1;
			
			Продолжить; 	
		
		КонецЕсли;
		
		Если УчитыватьКромеД
			И (ТС.Направление = "ДОП" 
			ИЛИ ТС.Направление = "ДИП") Тогда
			ДУИсклДОП = " И НЕ ПланПродаж.Контрагент В(&Контр" + Строка(н + 1) + ")"; 
		Иначе 
			ДУИсклДОП = ""; 	
		КонецЕсли;
		
		Если УчитыватьКромеС 
			И НЕ(ТС.Направление = "ДОП" 
			ИЛИ ТС.Направление = "ДИП") Тогда
			ДУИсклДПС = " И НЕ ПланПродаж.Контрагент В(&Контр" + Строка(н + 1) + ")";
		Иначе 
			ДУИсклДПС = ""; 
		КонецЕсли;
		
		Если н = 0 Тогда  
			Запрос21.Текст = 
			"ВЫБРАТЬ
			|	ПланПродаж.Номенклатура КАК Номенклатура,
			|	&Направление" + Строка(н + 1) + " КАК Направление,
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) КАК Количество
			|ИЗ  ВТСпайки КАК ВложенныйЗапрос
			//|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
			//|		СправочникНом.Ссылка КАК Спайка
			//|	ИЗ
			//|		Справочник.Номенклатура КАК СправочникНом
			//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК КоплектующиеНом
			//|			ПО СправочникНом.Ссылка = КоплектующиеНом.Ссылка
			//|		ГДЕ 
			//|		КоплектующиеНом.Номенклатура В(&Ном)
			//|		И СправочникНом.ВидКомплекта = Значение(Перечисление.ВидыКомплектов.Комплект)) КАК ВложенныйЗапрос
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПланПродаж КАК ПланПродаж
			|		ПО (ПланПродаж.Номенклатура = ВложенныйЗапрос.Спайка)
			|ГДЕ
			|	ПланПродаж.Период >= &Дата1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &Дата2" + Строка(н + 1) + "
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДОП + "  " + ДУИсклДПС + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура
			|
			|ИМЕЮЩИЕ
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) > 0";
		Иначе
			
			Запрос21.Текст = Запрос21.Текст + 
			" ОБЪЕДИНИТЬ ВСЕ 
			|ВЫБРАТЬ
			|	ПланПродаж.Номенклатура КАК Номенклатура,
			|	&Направление" + Строка(н + 1) + " КАК Направление,
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) КАК Количество
			|ИЗ  ВТСпайки КАК ВложенныйЗапрос
			//|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
			//|		СправочникНом.Ссылка КАК Спайка
			//|	ИЗ
			//|		Справочник.Номенклатура КАК СправочникНом
			//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК КоплектующиеНом
			//|			ПО СправочникНом.Ссылка = КоплектующиеНом.Ссылка
			//|	ГДЕ
			//|		КоплектующиеНом.Номенклатура В(&Ном)
			//|		И СправочникНом.ВидКомплекта = Значение(Перечисление.ВидыКомплектов.Комплект)) КАК ВложенныйЗапрос
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПланПродаж КАК ПланПродаж
			|		ПО (ПланПродаж.Номенклатура = ВложенныйЗапрос.Спайка)
			|ГДЕ
			|	ПланПродаж.Период >= &Дата1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &Дата2" + Строка(н + 1) + "
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДОП + "  " + ДУИсклДПС + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура
			|
			|ИМЕЮЩИЕ
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) > 0 "; 
			
		КонецЕсли; 
		
		Запрос21.УстановитьПараметр("Ном", МассивНоменклатуры);
		Запрос21.УстановитьПараметр("Дата1" + Строка(н + 1), ТС.НачалоРасчета);
		Запрос21.УстановитьПараметр("Дата2" + Строка(н + 1), ТС.ОкончаниеРасчета);
		Запрос21.УстановитьПараметр("Направление" + Строка(н + 1), ТС.Направление);
		
		Если ТС.Направление = "ДОП" Тогда
			
			Запрос21.УстановитьПараметр("Подр" + Строка(н + 1), МДОП);
			
			Если УчитыватьКромеД Тогда
				Запрос21.УстановитьПараметр("Контр" + Строка(н + 1), МКДОП);
			КонецЕсли;	
			
		ИначеЕсли   ТС.Направление = "ДИП" Тогда
			Запрос21.УстановитьПараметр("Подр" + Строка(н + 1), ПодрДИП);
			Если УчитыватьКромеД Тогда
				Запрос21.УстановитьПараметр("Контр" + Строка(н + 1), МКДОП);
			КонецЕсли;
			
		Иначе
			
			Запрос21.УстановитьПараметр("Подр" + Строка(н + 1), МДПС);
			
			Если УчитыватьКромеС Тогда
				Запрос21.УстановитьПараметр("Контр" + Строка(н + 1), МКДПС);
			КонецЕсли;
			
		КонецЕсли;
		
		н = н + 1;
	КонецЦикла;
	
	ТЗПланПродажПоСпайкам = Запрос21.Выполнить().Выгрузить(); 
	
	Возврат ТЗПланПродажПоСпайкам; 

КонецФункции

Функция  ПолучитьПланПродажПоНаправлениям(Знач ДУИсклДОП, Знач ДУИсклДПС, МассивНоменклатуры, МДОП, МДПС, МКДОП, МКДПС, Знач МНапр, ПодрДИП, Знач ТЗНастр2)
	
	н = 0; 
	
	//МНапр = Новый Массив; 
	
	Запрос2 = Новый Запрос;
	
	Пока н < ТЗНастр2.Количество() Цикл
		
		ТС = ТЗНастр2.Получить(н); 
		
		УчитыватьОстаткиПланыСпаек = ТС.УчитыватьОстаткиПланыСпаек; 
		
		Если УчитыватьКромеД
			И (ТС.Направление = "ДОП" 
			ИЛИ ТС.Направление = "ДИП") Тогда
			ДУИсклДОП = " И НЕ ПланПродаж.Контрагент В(&Контр" + Строка(н + 1) + ")"; 
		Иначе 
			ДУИсклДОП = ""; 	
		КонецЕсли;
		
		Если УчитыватьКромеС 
			И НЕ(ТС.Направление = "ДОП" 
			ИЛИ ТС.Направление = "ДИП") Тогда
			ДУИсклДПС = " И НЕ ПланПродаж.Контрагент В(&Контр" + Строка(н + 1) + ")";
		Иначе 
			ДУИсклДПС = ""; 
		КонецЕсли; 
		
		Если УчитыватьОстаткиПланыСпаек Тогда
			
			РегистрНакопления = "РегистрНакопления.ПланПродаж"; 
		Иначе
			
			РегистрНакопления = "РегистрНакопления.ПланПродажШтуки";
		КонецЕсли;
		
		Если н = 0 Тогда
			Запрос2.Текст =
			"ВЫБРАТЬ
			|	ПланПродаж.Номенклатура КАК Номенклатура,
			|	&Направление" + Строка(н + 1) + " КАК Направление,
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) КАК Количество
			|ИЗ
			//|	РегистрНакопления.ПланПродаж КАК ПланПродаж
			|	"+РегистрНакопления+"  КАК ПланПродаж
			|ГДЕ
			|	ПланПродаж.Период >= &Дата1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &Дата2" + Строка(н + 1) + "
			|	И ПланПродаж.Номенклатура В(&Ном)
			|	И НЕ ПланПродаж.Номенклатура.Родитель.Страна.Наименование ПОДОБНО &Китай
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДОП + "   " + ДУИсклДПС + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура
			|   
			| ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ПланПродаж.Номенклатура,
			|	&Направление" + Строка(н + 1) + ",
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0)
			|ИЗ
			|	"+РегистрНакопления+"  КАК ПланПродаж
			|ГДЕ
			|	ПланПродаж.Период >= &ДатаКитай1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &ДатаКитай2" + Строка(н + 1) + "
			|	И ПланПродаж.Номенклатура В(&Ном)
			|	И ПланПродаж.Номенклатура.Родитель.Страна.Наименование ПОДОБНО &Китай
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДОП + "   " + ДУИсклДПС + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура";
			
			
		Иначе
			
			Запрос2.Текст = Запрос2.Текст + 
			" ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ПланПродаж.Номенклатура КАК Номенклатура,
			|	&Направление" + Строка(н + 1) + " КАК Направление,
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0) КАК Количество
			|ИЗ
			|	"+РегистрНакопления+"  КАК ПланПродаж
			|ГДЕ
			|	ПланПродаж.Период >= &Дата1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &Дата2" + Строка(н + 1) + "
			|	И ПланПродаж.Номенклатура В(&Ном)
			|	И НЕ ПланПродаж.Номенклатура.Родитель.Страна.Наименование ПОДОБНО &Китай
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДПС + "  " + ДУИсклДОП + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура
			|   
			|  ОБЪЕДИНИТЬ ВСЕ
			|
			| ВЫБРАТЬ
			|	ПланПродаж.Номенклатура,
			|	&Направление" + Строка(н + 1) + ",
			|	ЕСТЬNULL(СУММА(ПланПродаж.Количество), 0)
			|ИЗ
			|	"+РегистрНакопления+"  КАК ПланПродаж
			|ГДЕ
			|	ПланПродаж.Период >= &ДатаКитай1" + Строка(н + 1) + "
			|	И ПланПродаж.Период < &ДатаКитай2" + Строка(н + 1) + "
			|	И ПланПродаж.Номенклатура В(&Ном)
			|	И ПланПродаж.Номенклатура.Родитель.Страна.Наименование ПОДОБНО &Китай
			|	И ПланПродаж.Подразделение В(&Подр" + Строка(н + 1) + ")
			|   " + ДУИсклДПС + "  " + ДУИсклДОП + "
			|СГРУППИРОВАТЬ ПО
			|	ПланПродаж.Номенклатура";
			
		КонецЕсли;
		
		Запрос2.УстановитьПараметр("Ном", МассивНоменклатуры);
		Запрос2.УстановитьПараметр("Китай", "КИТАЙ");
		Запрос2.УстановитьПараметр("Дата1" + Строка(н + 1), ТС.НачалоРасчета);
		Запрос2.УстановитьПараметр("Дата2" + Строка(н + 1), ТС.ОкончаниеРасчета);
		Запрос2.УстановитьПараметр("Направление" + Строка(н + 1), ТС.Направление);
		
		Запрос2.УстановитьПараметр("ДатаКитай1" + Строка(н + 1), ТС.НачалоРасчетаКитай);
		Запрос2.УстановитьПараметр("ДатаКитай2" + Строка(н + 1), ТС.ОкончаниеРасчетаКитай);
		
		Если ТС.Направление = "ДОП" Тогда
			
			Запрос2.УстановитьПараметр("Подр" + Строка(н + 1), МДОП);
			
			Если УчитыватьКромеД Тогда
				Запрос2.УстановитьПараметр("Контр" + Строка(н + 1), МКДОП);
			КонецЕсли;	
			
		ИначеЕсли   ТС.Направление = "ДИП" Тогда
			Запрос2.УстановитьПараметр("Подр" + Строка(н + 1), ПодрДИП);
			Если УчитыватьКромеД Тогда
				Запрос2.УстановитьПараметр("Контр" + Строка(н + 1), МКДОП);
			КонецЕсли;
			
		Иначе
			
			Запрос2.УстановитьПараметр("Подр" + Строка(н + 1), МДПС);
			
			Если УчитыватьКромеС Тогда
				Запрос2.УстановитьПараметр("Контр" + Строка(н + 1), МКДПС);
			КонецЕсли;
			
		КонецЕсли;
		
		МНапр.Добавить(ТС.Направление);
		
		н = н + 1;
		
	КонецЦикла;	
	
	ТЗП = Запрос2.Выполнить().Выгрузить(); 
	
	Возврат ТЗП; 

КонецФункции

Функция ПолучитьРезервыПоРНК(МассивНоменклатуры, МСНО, ТЗНастр4)	
	
	Запрос1 = Новый Запрос;
	
	Запрос1.Текст = 
	
	"ВЫБРАТЬ
	|	ТЗСкладов.Склад КАК Склад,
	|	ТЗСкладов.СкладМаркировка КАК СкладМаркировка
	|ПОМЕСТИТЬ ВТ_СкладВрем
	|ИЗ
	|	&ТЗНастр4 КАК ТЗСкладов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.Склад = ВТ_СкладВрем.СкладМаркировка
	|			ТОГДА ВТ_СкладВрем.Склад
	|		ИНАЧЕ РасходнаяНакладная.Склад
	|	КОНЕЦ КАК Склад,
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(СУММА(РасходнаяНакладнаяТовары.Количество), 0) КАК Количество
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СкладВрем КАК ВТ_СкладВрем
	|			ПО (РасходнаяНакладная.Склад = ВТ_СкладВрем.Склад
	|					ИЛИ РасходнаяНакладная.Склад = ВТ_СкладВрем.СкладМаркировка)
	|		ПО РасходнаяНакладнаяТовары.Ссылка = РасходнаяНакладная.Ссылка
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка.Контрагент = &Контрагент
	|	И РасходнаяНакладнаяТовары.Ссылка.Проведен
	|	И РасходнаяНакладнаяТовары.Ссылка.СостояниеНакладной = &СостояниеНакладной
	|	И РасходнаяНакладнаяТовары.Номенклатура В(&Ном)
	|	И РасходнаяНакладнаяТовары.Ссылка.Склад В(&Склады)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.Склад = ВТ_СкладВрем.СкладМаркировка
	|			ТОГДА ВТ_СкладВрем.Склад
	|		ИНАЧЕ РасходнаяНакладная.Склад
	|	КОНЕЦ,
	|	РасходнаяНакладнаяТовары.Номенклатура"; 
	
	Запрос1.УстановитьПараметр("ТЗНастр4", ТЗНастр4);
	Запрос1.УстановитьПараметр("Ном", МассивНоменклатуры);
	Запрос1.УстановитьПараметр("Склады", МСНО); 
	Запрос1.УстановитьПараметр("СостояниеНакладной", Перечисления.СостоянияНакладной.ВРаботе);
	Запрос1.УстановитьПараметр("Контрагент", Справочники.Контрагенты.НайтиПоКоду("SSP-5148"));
	
	ТЗРНО = Запрос1.Выполнить().Выгрузить(); 
	
	Возврат ТЗРНО; 

КонецФункции

Функция ПолучитьОстаткиПоСкладамПолучателям(МассивНоменклатуры, МС, ТЗНастр4)   
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СпрНоменклатура.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомВрем
	|ИЗ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|ГДЕ
	|	СпрНоменклатура.Ссылка В(&Ном)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗСкладов.Склад КАК Склад,
	|	ТЗСкладов.СкладМаркировка КАК СкладМаркировка,
	|	ТЗСкладов.УчитыватьОстаткиПланыСпаек КАК УчитыватьОстаткиПланыСпаек
	|ПОМЕСТИТЬ ВТ_СкладВрем
	|ИЗ
	|	&ТЗНастр4 КАК ТЗСкладов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗНом.Номенклатура КАК Номенклатура,
	|	ТЗСклад.Склад КАК Склад,
	|	ТЗСклад.СкладМаркировка КАК СкладМаркировка
	|ПОМЕСТИТЬ ВТ_Ном
	|ИЗ
	|	ВТ_НомВрем КАК ТЗНом,
	|	ВТ_СкладВрем КАК ТЗСклад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВложенныйЗапрос.Ост) КАК Ост,
	|	СУММА(ВложенныйЗапрос.Резерв) КАК Резерв,
	|	ВложенныйЗапрос.Направление КАК Направление,
	|	ВложенныйЗапрос.Склад КАК Склад,
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_НомОст
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Ост,
	|		СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв,
	|		""Направление"" КАК Направление,
	|		Остатки.Склад КАК Склад,
	|		Остатки.Номенклатура КАК Номенклатура
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&ТД,
	|				Склад В (&Склады)
	|					И Номенклатура В (&Ном)) КАК Остатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&ТД,
	|					Склад В (&Склады)
	|						И Номенклатура В (&Ном)) КАК Резервы
	|			ПО Остатки.Номенклатура = Резервы.Номенклатура
	|				И Остатки.Склад = Резервы.Склад
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Остатки.Номенклатура,
	|		Остатки.Склад
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		СУММА((Остатки.КоличествоОстаток - ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) * КомплектующиеСсылка.Количество),
	|		СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)),
	|		""Направление"",
	|		Остатки.Склад,
	|		КомплектующиеСсылка.Номенклатура
	|	ИЗ
	|		Справочник.Номенклатура.Коплектующие КАК КомплектующиеСсылка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&ТД, Склад В (&Склады)) КАК Остатки
	|			ПО КомплектующиеСсылка.Ссылка = Остатки.Номенклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(&ТД, Склад В (&Склады)) КАК Резервы
	|			ПО (Остатки.Номенклатура = Резервы.Номенклатура)
	|				И (Остатки.Склад = Резервы.Склад)
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СкладВрем КАК ВТ_СкладВрем
	|			ПО (ВТ_СкладВрем.Склад = Остатки.Склад
	|					ИЛИ ВТ_СкладВрем.СкладМаркировка = Остатки.Склад)
	|				И (НЕ ВТ_СкладВрем.УчитыватьОстаткиПланыСпаек)
	|	ГДЕ
	|		КомплектующиеСсылка.Номенклатура В(&Ном)
	|		И КомплектующиеСсылка.Ссылка.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КомплектующиеСсылка.Номенклатура,
	|		Остатки.Склад) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Номенклатура,
	|	ВложенныйЗапрос.Склад,
	|	ВложенныйЗапрос.Направление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(ВТ_НомОст.Ост, 0)) КАК Ост,
	|	СУММА(ЕСТЬNULL(ВТ_НомОст.Резерв, 0)) КАК Резерв,
	|	""Направление"" КАК Направление,
	|	0 КАК ПланПродаж,
	|	ВЫБОР
	|		КОГДА НЕ ВТ_НомОст.Склад ЕСТЬ NULL
	|				И ВТ_НомОст.Склад = ВТ_Ном.СкладМаркировка
	|			ТОГДА ВТ_Ном.Склад
	|		ИНАЧЕ ЕСТЬNULL(ВТ_НомОст.Склад, ВТ_Ном.Склад)
	|	КОНЕЦ КАК Склад,
	|	ВТ_Ном.Номенклатура КАК Номенклатура
	|ИЗ
	|	ВТ_Ном КАК ВТ_Ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НомОст КАК ВТ_НомОст
	|		ПО ВТ_Ном.Номенклатура = ВТ_НомОст.Номенклатура
	|			И (ВТ_Ном.Склад = ВТ_НомОст.Склад
	|				ИЛИ ВТ_Ном.СкладМаркировка = ВТ_НомОст.Склад)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА НЕ ВТ_НомОст.Склад ЕСТЬ NULL
	|				И ВТ_НомОст.Склад = ВТ_Ном.СкладМаркировка
	|			ТОГДА ВТ_Ном.Склад
	|		ИНАЧЕ ЕСТЬNULL(ВТ_НомОст.Склад, ВТ_Ном.Склад)
	|	КОНЕЦ,
	|	ВТ_Ном.Номенклатура";
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	//Запрос.УстановитьПараметр("ФормирОбратныхПРМ", ФормирОбратныхПРМ);
	Запрос.УстановитьПараметр("ТЗНастр4", ТЗНастр4);
	//Запрос.УстановитьПараметр("ТЗНастр5", ТЗНастр5);
	Запрос.УстановитьПараметр("Ном", МассивНоменклатуры);
	Запрос.УстановитьПараметр("ТД", ТекущаяДата());
	Запрос.УстановитьПараметр("Склады", МС); 
	
	
	ТЗОст1 = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗОст1;

