Перем МассивУзлов, МассивУзловБ2б экспорт;
Перем ДокументРаспродажи Экспорт;

// стильпарк
Процедура ЗарегистроватьИзменениеПланаОбмена(Ном)
	
	выгружать =  ПРоцедурыОБменаССайтом.ВыгружатьНаСайтСтильпарк(Ном);
	Если Выгружать = "Да" Тогда
		
		Попытка
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, Ном.ссылка);
			//сообщить(ном);
		Исключение 
		конецПопытки;
		
	КонецЕсли;


КонецПроцедуры	


Процедура ЗарегистроватьИзменениеПланаОбменаБ2б(Ном)
	// для б2б                                               // стильпарк = ложь
	выгружать =  ПРоцедурыОБменаССайтом.ВыгружатьНаСайт(Ном, ложь) ;
	
	Если Выгружать = "Да" Тогда
		
		Попытка                                    // в узлы для б2б пишем 
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзловб2б, Ном.ссылка);
			//сообщить(ном);
		Исключение 
		конецПопытки;
		
	КонецЕсли;


КонецПроцедуры	


Процедура ПередачаИзмененийВчерашнегоДня () экспорт
	
	// для документа все, что было вчера перенесем на перевыгрузку.
	//состояние("Передача изменений вчерашнего дня");
	попытка
		ДокументРаспр = ДокументРаспродажи; //документы.РаспродажаИМ.НайтиПоНомеру("SNL-00002");
	исключение
		возврат;
	конецПопытки;	
	
	//	временно заблокировать
	
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ПланыОбмена.ОбменССайтомТоварами.ЭтотУзел().Код="SNL"  И  ТекСтрокаСоединения=СтрокаСоединенияСразрешеннымОбменом Тогда
	Если ПланыОбмена.ОбменССайтомТоварами.ЭтотУзел().Код="SNL"  И  ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза()  Тогда
		//Кухарь А.Ю. 31.03.2026 конец
			
		Для каждого текстр из ДокументРаспр.Распродажа цикл
			
			Ном = текстр.номенклатура.ссылка;
			выгружать =  ПроцедурыОБменаССайтом.ВыгружатьНаСайтСтильпарк(Ном);
			Если Выгружать = "Нет" ТОгда
				продолжить;
			КонецЕсли;	
			ЗарегистроватьИзменениеПланаОбмена(Ном);
			
		конецЦикла;	
		
	КонецЕсли;

	
	
КонецПроцедуры	


Процедура ПолучитьДокументРаспродажи()
	
	ДокументРаспродажи = неопределено;
	
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РаспродажаИМИнетМагазины.Ссылка КАК Ссылка,
	               |	РаспродажаИМИнетМагазины.ИнетМагазин КАК ИнетМагазин
	               |ИЗ
	               |	Документ.РаспродажаИМ.ИнетМагазины КАК РаспродажаИМИнетМагазины
	               |ГДЕ
	               |	РаспродажаИМИнетМагазины.Ссылка.ПометкаУдаления = ложь
	               |	И РаспродажаИМИнетМагазины.ИнетМагазин.Ссылка = &стильпарк";

	  запрос.УстановитьПараметр("стильпарк",справочники.ИнетМагазины.НайтиПоКоду("00008")); // стильпарк
	  Рез = запрос.Выполнить().Выбрать();
	  Если Рез.Следующий() Тогда
		  ДокументРаспродажи = рез.ссылка;
	  КонецЕсли;	  
	
КонецПроцедуры	

Процедура ПерезаписьРаспродажи()
		
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Модель,
	               |	ЦеныНоменклатурыСрезПоследних.ТипЦен КАК ТипЦен,
	               |	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ДатаПрайса,
	               |	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	               |ПОМЕСТИТЬ Цены
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			{(&Дата2)},
	               |			Прайс.Проведен
	               |				И Прайс.Дата2 >= &Дата2) КАК ЦеныНоменклатурыСрезПоследних
	               |ГДЕ
	               |	ЦеныНоменклатурыСрезПоследних.ТипЦен В ИЕРАРХИИ(&ТипЦен)
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Модель,
	               |	ТипЦен
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	МАКСИМУМ(Цены.ДатаПрайса) КАК ДатаПрайса,
	               |	Цены.Модель КАК Модель,
	               |	Цены.ТипЦен КАК ТипЦен
	               |ПОМЕСТИТЬ Прайсы
	               |ИЗ
	               |	Цены КАК Цены
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Цены.ТипЦен,
	               |	Цены.Модель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	""Цены"" КАК Раздел,
	               |	Прайсы.Модель КАК Модель
	               |ИЗ
	               |	Прайсы КАК Прайсы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены
	               |		ПО (Цены.Модель = Прайсы.Модель)
	               |			И (Цены.ТипЦен = Прайсы.ТипЦен)
	               |			И (Цены.ДатаПрайса = Прайсы.ДатаПрайса)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(&Дата2, Склад В ИЕРАРХИИ (&склад)) КАК ОстаткиТМЦОстатки
	               |		ПО Прайсы.Модель = ОстаткиТМЦОстатки.Номенклатура.Родитель
	               |ГДЕ
	               |	ОстаткиТМЦОстатки.КоличествоОстаток > &нуль";
	
	
	пп = 0;
	типыцен = новый массив;
	типыцен.Добавить(справочники.ТипыЦен.НайтиПоКоду("SNL-1638")); //дисконт
	типыцен.Добавить(справочники.ТипыЦен.НайтиПоКоду("SNL-1635"));
	
	Склад = справочники.Склады.НайтиПоКоду("STD-06"); // дисконт
	запрос.УстановитьПараметр("Дата2", Конецдня(ТекущаяДата()));
	запрос.УстановитьПараметр("нуль", пп);
	запрос.УстановитьПараметр("склад", склад);
	запрос.УстановитьПараметр("ТипЦен", типыцен);
	
	Рез = Запрос.Выполнить().Выгрузить();
	попытка
		ДокументРаспр = ДокументРаспродажи.получитьОбъект(); //документы.РаспродажаИМ.НайтиПоНомеру("SNL-00002").ПолучитьОбъект();
	исключение
		возврат;
	конецПопытки;	
	
		
	ДокументРаспр.дата = текущаядата();
	ДокументРаспр.началоПериода = НачалоДня(текущаядата());
	ДокументРаспр.Распродажа.Очистить();
	
	Для каждого текстр из рез цикл
		
		
		выгружать =  ПроцедурыОБменаССайтом.ВыгружатьНаСайтСтильпарк(текстр.модель);
		Если Выгружать = "Нет" ТОгда
			продолжить;
		КонецЕсли;	

		НовСтр = ДокументРаспр.Распродажа.Добавить();
		НовСтр.Номенклатура = текстр.модель;
		
		ЗарегистроватьИзменениеПланаОбмена(текстр.модель);
	
	конецЦикла;	
	
	 ДокументРаспр.Записать();
	
	
КонецПроцедуры	



