Процедура СнятиеРегистрацииХитовНаСайте(Сайт=неопределено)
	
	// для новинок, по которым закончился срок действия.
	
	ТЗНовинок= неопределено;	
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	РаспродажаТовары.Номенклатура КАК Номенклатура,
	               |	РаспродажаИМИнетМагазины.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ХитыИМ.Хиты КАК РаспродажаТовары
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ХитыИМ.ИнетМагазины КАК РаспродажаИМИнетМагазины
	               |		ПО РаспродажаТовары.Ссылка = РаспродажаИМИнетМагазины.Ссылка
	               |ГДЕ
	               |	РаспродажаТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И РаспродажаТовары.Ссылка.КонецПериода >= &Дата1
	               |	И РаспродажаТовары.Ссылка.КонецПериода < &дата2
	               |	И РаспродажаИМИнетМагазины.ИнетМагазин.Ссылка = &стильпарк";
	
	
	запрос.УстановитьПараметр("стильпарк",Сайт); // стильпарк
	дата2 = НачалоДня(ТекущаяДата());
	запрос.УстановитьПараметр("дата2",дата2);
	запрос.УстановитьПараметр("дата1",(дата2)-3*24*60*60); // смотрим документы , которые закончились 3 дня назад.
	Рез = запрос.Выполнить().выгрузить();
	
	Для каждого текстр из рез цикл
		
		Если 	Сайт.код =  "00008" Тогда
			ЗарегистроватьИзменениеПланаОбмена(текстр.номенклатура);  // перевыгрузится информация с текущими значениями, что уже не новинка.
		иначеЕсли Сайт.код =  "00007" Тогда
			ЗарегистроватьИзменениеПланаОбменаБ2б(текстр.номенклатура);  // перевыгрузится информация с текущими значениями, что уже не новинка.
		конецЕсли;	
			
	КонецЦикла;	

	
КонецПроцедуры

