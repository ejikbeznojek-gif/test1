			ОтветС = Новый Структура;
			г = 0;
			Пока г < КолРекв Цикл
				ИмяПоля = СписокПолей.Получить(г).Значение;
				ОтветС.Вставить(ИмяПоля, ТекСтр["Поле" + Строка(г + 1)]);
				г = г + 1;
			КонецЦикла;
			ОтветМ.Добавить(ОтветС);
			КонецЦикла;
	КонецЕсли;
	ОповеститьОВыборе(ОтветМ);
КонецПроцедуры
