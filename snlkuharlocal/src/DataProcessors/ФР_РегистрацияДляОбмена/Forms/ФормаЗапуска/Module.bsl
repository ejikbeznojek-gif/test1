&НаКлиентеНаСервереБезКонтекста
Функция ВыделитьТип(ИмяТипа)
	ПозТ = СтрНайти(ИмяТипа, ".");
	Возврат Новый Структура("ТипОб, ИмяОб", ?(ПозТ, Лев(ИмяТипа, ПозТ - 1), ИмяТипа), ?(ПозТ, Сред(ИмяТипа, ПозТ + 1), ИмяТипа));
КонецФункции

&НаСервере
Процедура ЗаполнитьДерево(ПланОбменаИмя)
	//заполнение списка объектов метаданных на сервере
	МассивТип = Новый Массив;
	ТЗМета.Очистить();
	Для Каждого ТЭл Из МетаДанные.ПланыОбмена[ПланОбменаИмя].Состав Цикл
		НовСтр = ТЗМета.Добавить();
		НовСтр.Имя = СокрЛП(ТЭл.Метаданные.ПолноеИмя());
		НовСтр.ТипОбъекта = ВыделитьТип(НовСтр.Имя).ТипОб;
		НовСтр.Объект = ВыделитьТип(НовСтр.Имя).ИмяОб;
		Если МассивТип.Найти(НовСтр.ТипОбъекта) = Неопределено Тогда
			 МассивТип.Добавить(НовСтр.ТипОбъекта);
		КонецЕсли;
	КонецЦикла;
	ДЗ=Новый ДеревоЗначений;
	ДЗ.Колонки.Добавить("Объект");
	Для Каждого ТТип Из МассивТип Цикл
		ТСтр=ДЗ.Строки.Добавить();
		ТСтр.Объект=ТТип;
		Найды = ТЗМета.НайтиСтроки(Новый Структура("ТипОбъекта", ТТип));
		Для Каждого Найд Из Найды Цикл
			МСтр=ТСтр.Строки.Добавить();
			МСтр.Объект=Найд.Объект;
		КонецЦикла;
	КонецЦикла;
	ЗначениеВРеквизитФормы(ДЗ, "ДеревоМета");
КонецПроцедуры


