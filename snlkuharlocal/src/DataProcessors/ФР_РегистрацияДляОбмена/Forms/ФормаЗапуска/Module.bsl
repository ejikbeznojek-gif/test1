&НаКлиенте
Процедура УдалитьВсюРегистрацию(Команда)
	РезультатВопроса = Вопрос("Уверены, что хотите удалить все зарегистрированные к выгрузке объекты?", РежимДиалогаВопрос.ДаНет, ,КодВозвратаДиалога.Нет);
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		УдалитьВсюРегистрациюНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УдалитьРегистрациюПоТипуОбъектаНаСервере()
	// Вставить содержимое обработчика.
	НаборОВ = РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьНаборЗаписей();
	НаборОВ.Отбор.ОбъектТип.Установить(ОбъектТип);
	НаборОВ.Прочитать();
	НаборОВ.Очистить();
	НаборОВ.Записать();
	ЗаполнитьТЗРег(ОбъектТип);
КонецПроцедуры

