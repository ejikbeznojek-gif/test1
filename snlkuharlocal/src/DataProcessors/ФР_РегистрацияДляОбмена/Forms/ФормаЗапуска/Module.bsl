Процедура УдалитьТекущуюСтрокуНаСервере(ОбъектСсылкаУИД)
	// Вставить содержимое обработчика.
	НаборОВ = РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьНаборЗаписей();
	НаборОВ.Отбор.ОбъектТип.Установить(ОбъектТип);
	НаборОВ.Отбор.ОбъектСсылкаУИД.Установить(ОбъектСсылкаУИД);
	НаборОВ.Прочитать();
	НаборОВ.Очистить();
	НаборОВ.Записать();
	ЗаполнитьТЗРег(ОбъектТип);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТекущуюСтроку(Команда)
	Если Элементы.ТЗРегистрат.ТекущаяСтрока = Неопределено Тогда
		ПоказатьПредупреждение(,"Не выбрана строка");
		Возврат;
	КонецЕсли;
	РезультатВопроса = Вопрос("Уверены, что хотите удалить текущую строку регистрации?", РежимДиалогаВопрос.ДаНет, ,КодВозвратаДиалога.Нет);
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		УдалитьТекущуюСтрокуНаСервере(Элементы.ТЗРегистрат.ТекущиеДанные.ОбъектСсылкаУИД);
	КонецЕсли;
КонецПроцедуры

