Процедура ДеревоМетаПриАктивизацииСтроки(Элемент)
	// Вставить содержимое обработчика.
	ТЗРегистрат.Очистить();
	
	//Элементы.Группа3.Заголовок = "Зарегистрировано к обмену";
	Раздел = "";
	ОбъектК = "";
	ОбъектТип = "";
	Попытка
		Раздел=Строка(Элементы.ДеревоМета.ТекущиеДанные.ПолучитьРодителя().Объект);
		ОбъектК=Строка(Элементы.ДеревоМета.ТекущиеДанные.Объект);
		Если ЗначениеЗаполнено(Раздел) Тогда
			ОбъектТип = Раздел + "." + ОбъектК;
			ЗаполнитьТЗРег(ОбъектТип);
		КонецЕсли;
	Исключение
		
	КонецПопытки;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЗРег(ОбъектТип)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбъектыКВыгрузке.ОбъектСсылкаУИД КАК ОбъектСсылкаУИД,
	|	ОбъектыКВыгрузке.ИД_Пакета КАК ИД_Пакета,
	|	ОбъектыКВыгрузке.ВариантВыгрузки КАК ВариантВыгрузки,
	|	ОбъектыКВыгрузке.Получатель КАК Получатель,
	|	ОбъектыКВыгрузке.ОбъектТип КАК ОбъектТип
	|ИЗ
	|	РегистрСведений.ФР_ОбъектыКВыгрузке КАК ОбъектыКВыгрузке
	|ГДЕ
	|	ОбъектыКВыгрузке.ОбъектТип = &ОбъектТип
	//|	И ОбъектыКВыгрузке.Получатель = &Получатель
	//|ОБЪЕДИНИТЬ
	//|ВЫБРАТЬ
	//|	ОбъектыСИзменениями.ОбъектСсылкаУИД,
	//|	ОбъектыСИзменениями.ИД_Пакета,
	//|	ОбъектыСИзменениями.ВариантВыгрузки,
	//|	&Получатель,
	////|	ОбъектыСИзменениями.Получатель,
	//|	ОбъектыСИзменениями.ОбъектТип
	//|ИЗ
	//|	РегистрСведений.ОбъектыСИзменениями КАК ОбъектыСИзменениями
	//|ГДЕ
	//|	ОбъектыСИзменениями.ОбъектТип = &ОбъектТип
	|";
	//Запрос.УстановитьПараметр("Получатель", УзелОбменаСсылка.Код);
	Запрос.УстановитьПараметр("ОбъектТип", ОбъектТип);
	ТЗРегистрат.Загрузить(Запрос.Выполнить().Выгрузить());
	//Сообщить(ТЗРегистрат.Количество());
	//Элементы.КолвоРег.Заголовок = "Зарегистрировано к обмену " + Формат(ТЗРегистрат.Количество(), "ЧН=0; ЧГ=3,0"); 
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьРегистрацию(Команда)
	// Вставить содержимое обработчика.
	Попытка
		Если ЗначениеЗаполнено(ОбъектТип) Тогда
			Если НРег(Лев(ОбъектТип,7)) = "регистр" Тогда
				ПоказатьПредупреждение(, "Не предусмотрена регистрация для этого типа объекта " + ОбъектТип + " и узла " + Строка(УзелОбменаСсылка));
				Возврат;
			КонецЕсли;
			ОповещениеВыбран = Новый ОписаниеОповещения("ВыборЭлемента", ЭтаФорма);
			ПараметрыФормы = Новый Структура("ОсновнаяТаблица, ТекстЗапроса", ОбъектТип, "ВЫБРАТЬ * ИЗ " + ОбъектТип );
			Если НРег(Лев(ОбъектТип,7)) = "регистр" Тогда
				//ОткрытьФорму("РегистрСведений.История.ФормаСписка"
				ОткрытьФорму("Обработка.ФР_РегистрацияДляОбмена.Форма.ФормаВыборР", ПараметрыФормы, ЭтаФорма,,,, ОповещениеВыбран, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
				//ОткрытьФорму("Обработка.ФР_РегистрацияДляОбмена.Форма.ВыборРегистр",ПараметрыФормы, ЭтаФорма,,,, ОповещениеВыбран, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			Иначе
				ОткрытьФорму("Обработка.ФР_РегистрацияДляОбмена.Форма.ВыборПроизвольный",ПараметрыФормы, ЭтаФорма,,,, ОповещениеВыбран, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			КонецЕсли;
		КонецЕсли;
		
		
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборЭлемента(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	//Сообщить("ВыбранноеЗначение " + строка(ВыбранноеЗначение));
	Если ВыбранноеЗначение <> Неопределено Тогда
		
		РезДоб = ДобавитьРегистрациюВЗ(ВыбранноеЗначение);
		ТекстПред = "Регистрация не выполнена";
		Если РезДоб = 1 Тогда
			ТекстПред = "Выбранный элемент уже зарегистрирован";
		ИначеЕсли РезДоб = 2 Тогда
			ТекстПред = "Не удалось зарегистрировать выбранные элементы";
		ИначеЕсли РезДоб = 3 Тогда
			ТекстПред = "Выбранные элементы добавлены к регистрации";
			
		ИначеЕсли РезДоб = 5 Тогда
			ТекстПред = "Выбранные элементы частично добавлены к регистрации";
		ИначеЕсли РезДоб = 4 Тогда
			ТекстПред = "Ошибка при выполнении регистрации";
		КонецЕсли;	
		ПоказатьПредупреждение(,ТекстПред);
	Иначе
		ПоказатьПредупреждение(,"Не выбрано значение для добавления");
	КонецЕсли;
	
КонецПроцедуры

