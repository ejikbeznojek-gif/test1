&НаКлиенте
Процедура Выбрать(Команда)

	ОтветМ = Новый Массив;
	Если Элементы.СписокВыбора.ВыделенныеСтроки.Количество() Тогда
		Для Каждого ВыдСтр Из Элементы.СписокВыбора.ВыделенныеСтроки Цикл
			ТекСтр = Элементы.СписокВыбора.ДанныеСтроки(ВыдСтр);
			ОтветМ.Добавить(ТекСтр["Ссылка"]);
		КонецЦикла;
	КонецЕсли;
	ОповеститьОВыборе(ОтветМ);
	
КонецПроцедуры

