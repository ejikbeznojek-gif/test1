	//сообщить("СписокВыбора.ТекстЗапроса " + ТекстЗапроса);
	Параметры.ЗакрыватьПриВыборе = Истина;
	СписокВыбора.ТекстЗапроса = Параметры.ТекстЗапроса;
	СписокВыбора.ОсновнаяТаблица = Параметры.ОсновнаяТаблица;
	СписокВыбора.Порядок.Элементы.Очистить();
	ЭлементПорядкаСВ = СписокВыбора.Порядок.Элементы.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	ЭлементПорядкаСВ.Поле = Новый ПолеКомпоновкиДанных("Ссылка");
	ЭлементПорядкаСВ.Использование = Истина;
	ЭлементПорядкаСВ.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Убыв;
КонецПроцедуры

