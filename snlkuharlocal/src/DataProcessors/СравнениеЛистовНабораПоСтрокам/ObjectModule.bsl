    //Мессерле

	РежимЗаписи=?(ДокОбъект.Проведен,РежимЗаписиДокумента.Проведение,РежимЗаписиДокумента.Запись);
	ДокОбъект.Товары.Сортировать("Номенклатура");
	Если (ВидДокумента="КонтрактСПроизводителем" или  ВидДокумента="ЗаказПоставщику" или (ВидДокумента="Инвентаризация" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад)) тогда
