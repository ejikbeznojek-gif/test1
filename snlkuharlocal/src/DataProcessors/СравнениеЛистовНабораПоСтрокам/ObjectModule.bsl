		для каждого стр5 из ДокОбъект.товары цикл
			стр5.количество=стр5.количествофакт-стр5.количестворасч;
		Конеццикла;
	Конецесли;
    //Мессерле

	Если НЕ ЕстьОшибки Тогда
		Если НЕ (ВидДокумента="КонтрактСПроизводителем" или  ВидДокумента="ЗаказПоставщику" или (ВидДокумента="Инвентаризация" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад)) тогда
			
			Если ДокОбъект[ИмяРеквизитаСостояние]=Перечисления.СостоянияНакладной.Сканирование Тогда
