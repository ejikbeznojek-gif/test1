Процедура Заполнить() Экспорт
	ВидДокумента=Документ.Метаданные().Имя;
	
	ИмяРеквизитаКоличество	="Количество";
	ИмяРеквизитаСостояние	="СостояниеНакладной";
	
	Если ВидДокумента="Перемещение" Тогда		
		Если Документ.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда			
			ИмяРеквизитаКоличество="ПодтвержденнаяЗаявка"; //Отгружено
		ИначеЕсли Документ.СкладПолучатель.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда
			ИмяРеквизитаСостояние	="СостояниеНакладнойУПолучателя";			
		КонецЕсли;		
	КонецЕсли;
	
	//Нечаева +++
	Если ВидДокумента="ПродажаИМ" Тогда
		ИмяРеквизитаКоличество="ПодтвержденнаяЗаявка";
	КонецЕсли;	
	//Нечаева --
	
	Если НЕ (ВидДокумента="КонтрактСПроизводителем" или  ВидДокумента="ЗаказПоставщику") тогда
		Если Документ[ИмяРеквизитаСостояние]<>Перечисления.СостоянияНакладной.Сканирование Тогда
			Предупреждение("Не допустимое состояние накладной ! 
			|Заполняются только документы в состоянии ""Сканирование""
			|Текущее состояние: """+Документ[ИмяРеквизитаСостояние]+""" !");
			Возврат;
		КонецЕсли;	
	Конецесли;

	ДокОбъект=Документ.ПолучитьОбъект();
	
	//Мессерле

	
	Запрос=Новый Запрос;
	
	 запрос2=новый запрос;
					 запрос2.Текст="ВЫБРАТЬ
					               |	ЗаказПоставщику.Ссылка
					               |ИЗ
					               |	Документ.ЗаказПоставщику КАК ЗаказПоставщику
					               |ГДЕ
					               |	ЗаказПоставщику.ДокОснование = &ДокОснование
					               |	И (НЕ ЗаказПоставщику.ПометкаУдаления)";
								   
								   Запрос2.УстановитьПараметр("ДокОснование",Документ.Ссылка);
								   
								   Выб=Запрос2.Выполнить().Выбрать();
								   Если выб.Следующий() тогда
									   ДокОсн=выб.ссылка;
								   иначе
									   докосн=НЕОПРЕДЕЛЕНО;
								   Конецесли;	   

								   
	Минусуем=Ложь;
	Если ДокОсн<>НЕОПРЕДЕЛЕНО тогда //Ищем документ с остатком в зоне сборки
			Минусуем=ИСТИНА;
	Конецесли;	
	
	
	//Мессерле
	
	//10.01.12
	
	 Если  ВидДокумента="ЗаказПоставщику" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад тогда    
		  //Не с чем сравнивать! Это отгрузка
		  докобъект.Товары.Очистить();
		  докобъект.ТоварыПартии.Очистить();
	 конецесли;
	 
	Если НЕ (ВидДокумента="ЗаказПоставщику" и Минусуем)  тогда
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ЛистНабораТовары.Номенклатура,
	|	ЛистНабораТовары.ШтВКоробе как ШтукВКоробе, выбор когда ЛистНабораТовары.ШтВКоробе=0 тогда СУММА(ЛистНабораТовары.Количество) иначе СУММА(ЛистНабораТовары.Количество)/ЛистНабораТовары.ШтВКоробе конец  как КоличествоКоробов,ЛистНаборатовары.ссылка.Им7,
	|	СУММА(ЛистНабораТовары.Количество) КАК "+ИмяРеквизитаКоличество+"
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
	|	И  ЛистНабораТовары.Ссылка.Проведен
	|СГРУППИРОВАТЬ ПО
	|	ЛистНабораТовары.Номенклатура,ЛистНабораТовары.ШтВКоробе,ЛистНаборатовары.ссылка.Им7 упорядочить по ЛистНабораТовары.Номенклатура";
	
	//Кухарь начало 21.09.12 пересчёт Кол-ва коробов из ЛН
	коробки = новый Запрос;
	Коробки.Текст="ВЫБРАТЬ
	              |	СУММА(ЛистНабора.КоличествоКоробок) КАК КоличествоКоробок
	              |ИЗ
	              |	Документ.ЛистНабора КАК ЛистНабора
	              |ГДЕ
	              |	ЛистНабора.Проведен
				  |	И ЛистНабора.ДокОснование = &ДокОснование";
	Коробки.УстановитьПараметр("ДокОснование",Документ.Ссылка);
	КолКор=Коробки.Выполнить().Выгрузить().Получить(0).КоличествоКоробок;
	//Кухарь конец 21.09.12
	
	иначе
		Запрос.Текст="ВЫБРАТЬ
					 |	аа.Номенклатура,
					 |	аа.ШтукВКоробе,
