					 |) КАК аа
					 |
					 |СГРУППИРОВАТЬ ПО
					 |	аа.Номенклатура,
					 |	аа.ИМ7,
					 |	аа.ШтукВКоробе";
		
					//Запрос.Текст="ВЫБРАТЬ
					//			 |	ЛистНабораТовары.Номенклатура КАК Номенклатура,
					//			 |	ЛистНабораТовары.ШтВКоробе КАК ШтукВКоробе,
					//			 |	СУММА(ВЫБОР
					//			 |			КОГДА ЛистНабораТовары.ШтВКоробе = 0
					//			 |				ТОГДА ЛистНабораТовары.Количество
					//			 |			ИНАЧЕ ЛистНабораТовары.Количество / ЛистНабораТовары.ШтВКоробе
					//			 |		КОНЕЦ - ЕСТЬNULL(ВЫБОР
					//			 |				КОГДА ЛистНабораТовары1.ШтВКоробе = 0
					//			 |					ТОГДА ЛистНабораТовары1.Количество
					//			 |				ИНАЧЕ ЛистНабораТовары1.Количество / ЛистНабораТовары1.ШтВКоробе
					//			 |			КОНЕЦ, 0)) КАК КоличествоКоробов,
					//			 |	ЛистНабораТовары.Ссылка.ИМ7 КАК ИМ7,
					//			 |	СУММА(ЛистНабораТовары.Количество - ЕСТЬNULL(ЛистНабораТовары1.Количество, 0)) КАК Количество
					//			 |ИЗ
					//			 |	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
					//			 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора.Товары КАК ЛистНабораТовары1
					//			 |		ПО ЛистНабораТовары.Номенклатура = ЛистНабораТовары1.Номенклатура
					//			 |			И ЛистНабораТовары.Ссылка.ИМ7 = ЛистНабораТовары1.Ссылка.ИМ7
					//			 |			И ЛистНабораТовары.ШтВКоробе = ЛистНабораТовары1.ШтВКоробе
					//			 |			И (ЛистНабораТовары1.Ссылка.ДокОснование = &ДокОснованиеЗПС)
					//			 |			И (ЛистНабораТовары1.Ссылка.Проведен)
					//			 |ГДЕ
					//			 |	ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
					//			 |	И ЛистНабораТовары.Ссылка.Проведен
					//			 |
					//			 |СГРУППИРОВАТЬ ПО
					//			 |	ЛистНабораТовары.Номенклатура,
					//			 |	ЛистНабораТовары.ШтВКоробе,
					//			 |	ЛистНабораТовары.Ссылка.ИМ7";

                  						   
					 Запрос.УстановитьПараметр("ДокОснованиеЗПС",ДокОсн);
 
	Конецесли;
	Запрос.УстановитьПараметр("ДокОснование",Документ.Ссылка);
	Выборка=Запрос.Выполнить().Выбрать();
	
	ВидОснования=Документ.Метаданные().Имя;
	
	ЕстьКорректировки=Ложь;
	
	ОбработанныеСтроки=Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл	
		
		если ВидОснования="ПриходнаяНакладная" и докобъект.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад тогда
			отбор=новый структура;
			отбор.Вставить("Номенклатура",Выборка.Номенклатура);
			отбор.Вставить("ШтВКоробе",Выборка.ШтукВКоробе);
			Масс=ДокОбъект.Товары.НайтиСтроки(Отбор);
			Если Масс.количество()=0 тогда
				отбор=новый структура;
				отбор.Вставить("Номенклатура",Выборка.Номенклатура);
				отбор.Вставить("ШтВКоробе",0);
				Масс=ДокОбъект.Товары.НайтиСтроки(Отбор);
			Конецесли;
			Если масс.количество()>1 тогда
				Предупреждение(""+ДокОбъект+" "+Выборка.Номенклатура+" Внутренняя ошибка.Обратитесь в ИТ-отдел");Возврат;
			Конецесли;	
			Если масс.количество()=0 тогда
				СтрокаТч=НЕОПРЕДЕЛЕНО;
			иначе
				СтрокаТч=Масс[0];
			Конецесли;
			
		иначе	
			СтрокаТЧ=ДокОбъект.Товары.Найти(Выборка.Номенклатура);
			//крохин начало 15.11.2011
			//для РНК с комплектацией сравниваем ТЧ "комплектующие"
			Если ДокОбъект.Метаданные().Имя = "РасходнаяНакладная" И ДокОбъект.ОтгрузкаКомплектов Тогда
			СтрокаТЧ=ДокОбъект.Комплектующие.Найти(Выборка.Номенклатура,"Номенклатура");
			КонецЕсли;
			//крохин конец 15.11.2011
		Конецесли;
	
	
		Если СтрокаТЧ=Неопределено Тогда
			Если ВидОснования="РасходнаяНакладная" Тогда
				Если Выборка.Количество<>0 Тогда
					Сообщить("Позиция: """+Выборка.Номенклатура+""" отсутствует в накладной !!! Данная позиция не добавлена в накладную !!!",СтатусСообщения.ОченьВажное);				
				КонецЕсли;				
				Продолжить;
			КонецЕсли; 			
			СтрокаТЧ=ДокОбъект.Товары.Добавить();		
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,Выборка);
			ПриИзмененииНоменклатурыТабЧасти(СтрокаТЧ,ДокОбъект);			
		Иначе
