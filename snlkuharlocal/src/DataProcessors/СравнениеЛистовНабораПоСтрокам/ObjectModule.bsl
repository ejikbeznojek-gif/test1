				отбор.Вставить("ШтукВКоробе",Выборка.ШтукВКоробе);
			Конецесли;
			
			Масс=ДокОбъект.ТоварыПартии.НайтиСтроки(отбор);
			
			Если Масс.Количество()>1 тогда
				сообщить("Для "+Выборка.Номенклатура+" по "+Выборка.Им7+" и шт. в кор.="+Выборка.ШтукВКоробе+" есть дублирующиеся строки!");Возврат;
			Конецесли;
			
			Если Масс.Количество()=1 тогда
				СтрокаТЧ1=масс[0];
			иначе
				СтрокаТЧ1=ДокОбъект.Товарыпартии.Добавить();		
				ЗаполнитьЗначенияСвойств(СтрокаТЧ1,Выборка);
			Конецесли;
			
			
			Если  (ВидДокумента="Инвентаризация" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад) тогда    
				
				СтрокаТЧ1.КоличествоФакт=Выборка.Количество;
				
				//Вот здесь геморой, т.к. по партиям может быть много строк, а по товарам только одна
				СтрокаТЧ1.ШтукВКоробе=выборка.штуквкоробе;
                		
				Отбор=новый структура;
				отбор.Вставить("Номенклатура",Выборка.Номенклатура);
				Масс=ДокОбъект.ТоварыПартии.НайтиСтроки(отбор);
				
				фактОст=0;
				Для каждого стр из масс цикл
					ФактОст=ФактОст+стр.КоличествоФакт;
				Конеццикла;	
				
				СтрокаТЧ.КоличествоФакт=ФактОст;
				СтрокаТЧ.Количество=СтрокаТЧ.КоличествоФакт-СтрокаТЧ.КоличествоРасч;
				
			иначе
				СтрокаТЧ1.Количество=Выборка.Количество;
			Конецесли;
			
		КонецЕсли;	
		
	Конеццикла;
	
	 //Мессерле
	 Если  ВидДокумента="ЗаказПоставщику" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад тогда    
	 //Загрузим товары из партий
	 тз2=новый ТаблицаЗначений;
