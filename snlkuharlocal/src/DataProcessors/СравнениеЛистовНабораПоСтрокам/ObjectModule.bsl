		КонецЕсли;
		//крохин конец 15.11.2011
		 
		 
		РассчитатьСуммуТабЧасти(СтрокаТЧ,ДокОбъект);
		
		ЕстьКорректировки=Истина;
		
		//Партии
		Если  (ВидДокумента="КонтрактСПроизводителем" или  ВидДокумента="ЗаказПоставщику" или (ВидДокумента="Инвентаризация" и документ.Склад.ТипСклада=перечисления.ТипСклада.ВнешнийСклад)) тогда    
			
			Отбор=новый структура;
			отбор.Вставить("Номенклатура",Выборка.Номенклатура);
			отбор.Вставить("Им7",Выборка.Им7);
			
