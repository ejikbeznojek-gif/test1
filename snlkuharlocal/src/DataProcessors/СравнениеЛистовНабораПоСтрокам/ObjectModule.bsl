			//СтрокаТЧ[ИмяРеквизитаКоличество]=Выборка[ИмяРеквизитаКоличество];
			Если ДокОбъект.Метаданные().Имя = "РасходнаяНакладная" И ДокОбъект.ОтгрузкаКомплектов Тогда
				Отбор=новый Структура;
				Отбор.Вставить("Номенклатура",Выборка.Номенклатура);
				МассивСтрок=ДокОбъект.Комплектующие.НайтиСтроки(Отбор);
				Остаток=Выборка[ИмяРеквизитаКоличество];
				Для каждого СтрокаКомлектующих из МассивСтрок цикл
					Если Остаток >= СтрокаКомлектующих.Количество Тогда
						Остаток=Остаток - СтрокаКомлектующих.Количество;
					Иначе
						СтрокаКомлектующих.Количество = Остаток;
						Остаток=0; 
					КонецЕсли;
					ОбработанныеСтроки.Вставить(СтрокаТЧ,Истина);
				Конеццикла;
				
			Иначе
				СтрокаТЧ[ИмяРеквизитаКоличество]=Выборка[ИмяРеквизитаКоличество];
			КонецЕсли;
			
			//крохин конец 15.11.2011
			
			
		КонецЕсли;
		
		Если ВидОснования="ПриходнаяНакладная" тогда
			СтрокаТЧ.ШтВКоробе=выборка.штуквкоробе;
			СтрокаТЧ.КоличествоКоробов=выборка.КоличествоКоробов;
		Конецесли;
 		
			
		Если ВидДокумента="Перемещение" И ИмяРеквизитаКоличество="ПодтвержденнаяЗаявка" 
			И ДокОбъект.СостояниеНакладнойУПолучателя<>Перечисления.СостоянияНакладной.Принята Тогда
			СтрокаТЧ.Количество=СтрокаТЧ.ПодтвержденнаяЗаявка;
		КонецЕсли; 
		
		//Нечаева-+++
		Если ВидДокумента="ПродажаИМ" И ИмяРеквизитаКоличество="ПодтвержденнаяЗаявка" Тогда			
