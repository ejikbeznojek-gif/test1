	Если НЕ Файл.Существует() Тогда
		СоздатьКаталог(ИмяКаталога);			
	КонецЕсли;
КонецФункции //ПроверитьСоздатьКаталогФайлов(ИмяКаталога)

Функция ПолучитьВыборкуКодов(ЗПС_Ссылка, МаксЧислоЭтикеток = 0)
	Запрос = Новый Запрос;
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	ДокументОснование 	КАК ЗПС,
	|	Ссылка 				КАК Эмиссия
	|ПОМЕСТИТЬ ВТ_Эмиссии
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|ГДЕ
	|	ДокументОснование = &ЗПС_Ссылка
	|;
	|ВЫБРАТЬ " + ?(МаксЧислоЭтикеток=0, "", "ПЕРВЫЕ " + МаркировкаКС.ЧислоБезДури(МаксЧислоЭтикеток)) + "
	|	ЕСТЬNULL(КодыАгрегации.КодАгрегации, ""9999"") 	КАК КодАгрегации,
	|	ШК_ЧЗ.Владелец.Родитель 						КАК Модель,
	|	ШК_ЧЗ.Владелец.Родитель.ШтукВКоробке			КАК ШтукВКоробке,
	|	ШК_ЧЗ.Владелец.Родитель.КодПроизводителя		КАК Артикул,
	|	ШК_ЧЗ.Владелец.Цвет								КАК Цвет,
	|	ШК_ЧЗ.Владелец.Размер							КАК Размер,
	|	ШК_ЧЗ.Владелец 									КАК Номенклатура,
	|	ШК_ЧЗ.Владелец.Наименование						КАК Номенклатура_Наименование,
	|	ШК_ЧЗ.Владелец.НаименованиеGS1					КАК Номенклатура_НаименованиеGS1,
	|	ШК_ЧЗ.Владелец.Код								КАК Номенклатура_Код,
	|	ШК_ЧЗ.Владелец.ГТИН								КАК Номенклатура_ГТИН,
	|	ШК_ЧЗ.Ссылка									КАК КМ,
	|	ШК_ЧЗ.Ссылка.Наименование						КАК СГТИН,
	|	ШК_ЧЗ.ЗначениеШтрихкода							КАК ЗначениеКМ
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШК_ЧЗ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Эмиссии КАК ВТ_Эмиссии
	|ПО 
	|	ШК_ЧЗ.ЗаказКМ = ВТ_Эмиссии.Эмиссия
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	Документ.ЗаказПоставщику.Товары КАК ТЧ_Товары
	|ПО
	|	ТЧ_Товары.Ссылка = &ЗПС_Ссылка
	|	И ТЧ_Товары.Номенклатура = ШК_ЧЗ.Владелец	
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК КодыАгрегации
	|ПО 
	|	ШК_ЧЗ.Ссылка = КодыАгрегации.ШтрихкодУпаковки
	|	И (КодыАгрегации.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация))
	|	И (КодыАгрегации.Ссылка.ДокументОснование = &ЗПС_Ссылка)	
	|УПОРЯДОЧИТЬ ПО
	|	КодАгрегации,
	|	ШК_ЧЗ.Владелец,
	|	ШК_ЧЗ.Наименование
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КМ)
	|ПО
	|	Номенклатура,
	|	КодАгрегации
	|";
	
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	Если ТипЗнч(ЗПС_Ссылка) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ".ЗаказПоставщику.", СтрШаблон(".%1.", ЗПС_Ссылка.Метаданные().Имя));
	КонецЕсли;
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец

	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);	
	
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
КонецФункции // ()

Функция СформироватьИмяПапкиНоменклатуры(НаименованиеGS1, Наименование, Код)
	Результат = ?(ПустаяСтрока(НаименованиеGS1), Наименование, НаименованиеGS1); 
	Результат = СтрЗаменить(Результат, "\", "_");
	Результат = СтрЗаменить(Результат, "/", "_");
	Результат = СтрЗаменить(Результат, ".", "_");
	Результат = СтрЗаменить(Результат, ",", "_");
	Результат = СтрЗаменить(Результат, """", "");
								
	Возврат СокрЛП(Результат) + "_" + Код;
КонецФункции // ()

//Шиза из-за отсутствия сериализации параметров области
Функция УстановитьПараметрыОбласти(Область, мПараметры)
	Для Сч = 0 По мПараметры.ВГраница() Цикл
		Область.Параметры.Установить(Сч, мПараметры[Сч]);	
	КонецЦикла;
КонецФункции //УстановитьПараметрыОбласти(Область, мПараметры)


