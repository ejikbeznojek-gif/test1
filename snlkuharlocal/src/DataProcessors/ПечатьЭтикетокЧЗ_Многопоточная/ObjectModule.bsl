Перем ОбработкаПечатиЭтикеток Экспорт;

Функция Печать(ДокОбъект, ДопПараметры = Неопределено) Экспорт	
	
	ДокСсылка = ДокОбъект.Ссылка;
	
	ПолучитьФорму("Форма").Открыть();

КонецФункции //Печать(ДокОбъект, ДопПараметры = Неопределено) Экспорт

Функция СформироватьЭтикету(Макет, Выборка, Знач ДопПараметры = Неопределено) Экспорт
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = Новый Структура;
	КонецЕсли;
	
	КорректировкаРазмераШрифта = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "КорректировкаРазмераШрифта", 0);	
	
	Область 			= Макет.ПолучитьОбласть();	
	
	СтрокаКМ			= Справочники.ШтрихкодыУпаковокТоваров.ВосстановитьКод_GS1(Выборка.ЗначениеКМ); 
	ПоляШК 				= Справочники.ШтрихкодыУпаковокТоваров.ПолучитьПоляШК_GS1(СтрокаКМ);	
	
	//ВывестиШК(Область, "ШК_ДатаМатрикс", СформироватьКартинкуШК_DataMatrix(Символ(232)+СтрокаКМ));
	ОбработкаПечатиЭтикеток.ВывестиШК(Область, "ШК_ДатаМатрикс", ОбработкаПечатиЭтикеток.СформироватьКартинкуШК_DataMatrix(СтрокаКМ));	
		
	ВыводитьЕАН13 = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ВыводитьЕАН13", Ложь);	
	
	Если ВыводитьЕАН13 Тогда
		Рис = Макет.Рисунки.ШК_ЕАН13;
		ОбработкаПечатиЭтикеток.ВывестиШК(Область, "ШК_ЕАН13", ОбработкаПечатиЭтикеток.СформироватьКартинкуШК_EAN(Прав(ПоляШК.ГТИН,13), Рис, КорректировкаРазмераШрифта));
	КонецЕсли; 
	
	Область.Параметры.Заполнить(Выборка);	
	Область.Параметры.Заполнить(ПоляШК);	
	Область.Параметры.Заполнить(ДопПараметры);	
	
	Возврат Область;
КонецФункции //СформироватьЭтикетку(СтрокаКМ)

Функция СформироватьКА(Макет, КодАгрегации, НомерКоробки, КоличествоШтук, Выборка, ДопПараметры = Неопределено) Экспорт	
	Если ДопПараметры = Неопределено Тогда
		Если ТипЗнч(Выборка) = Тип("Структура") Тогда
			ДопПараметры = Выборка;
		Иначе                      
			ДопПараметры = Новый Структура;
		КонецЕсли;			
	КонецЕсли;	
	
	ТипШК 		= МаркировкаКС.ПолучитьЗначениеПараметра(Выборка, "ТипШК", Перечисления.ТипыШтрихКодов.Коробка);
	НомерБлочка	= МаркировкаКС.ПолучитьЗначениеПараметра(Выборка, "НомерБлочка", 0);
	НомерПалеты	= МаркировкаКС.ПолучитьЗначениеПараметра(Выборка, "НомерПалеты", 0);
	
	БезПрефикса 				= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "БезПрефикса", Ложь);
	// Смирнов М.Ю. 01.08.2025 HELP-6117 начало
	//ДобавлятьСкобочкиВТекст 	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДобавлятьСкобочкиВТекст", Ложь);
	ДобавлятьСкобочкиВТекст 	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДобавлятьСкобочкиВТекст", Истина); 
	// Смирнов М.Ю. 01.08.2025 HELP-6117 конец
	
	ПрефиксШК = ?(БезПрефикса, "", "(00)");
	
	Область = Макет.ПолучитьОбласть();	
	
	Рис 	= Неопределено;
	Для Каждого Рис Из Область.Рисунки Цикл
		Если СтрНачинаетсяС(Рис.Имя, "ШК_SSCC") Тогда Прервать КонецЕсли;	
	КонецЦикла; 
	Если Рис = Неопределено Тогда
		Сообщить("В макете не найдено рисунка ШК_SSCC !", СтатусСообщения.Важное);
	КонецЕсли;
	
	Если КодАгрегации = "9999" Тогда		
		Область.Рисунки.Удалить(Рис);
		Область.Параметры.НеполнаяКоробка = "INCOMPLETE BOX";
	ИначеЕсли ЗначениеЗаполнено(КодАгрегации) Тогда
		Картинка = ОбработкаПечатиЭтикеток.СформироватьКартинкуШК_EAN(ПрефиксШК + КодАгрегации, Рис, ДопПараметры);
		ОбработкаПечатиЭтикеток.ВывестиШК(Область, Рис.Имя, Картинка);
	Иначе
		Область.Рисунки.Удалить(Рис);
		пОбласти = Новый Структура("НеполнаяКоробка", "NOT AGGREGATED");
		Область.Параметры.Заполнить(пОбласти);
	КонецЕсли;	
	
	пОбласти = Новый Структура("НомерБлочка,НомерКоробки,НомерПалеты,КоличествоШтук", НомерБлочка, НомерКоробки, НомерПалеты,КоличествоШтук);
	Если ДопПараметры.Свойство("Заголовок") Тогда
		пОбласти.Вставить("Заголовок", ДопПараметры.Заголовок);
	КонецЕсли;	
	ПрефиксКодаАгрегации = ?(ДобавлятьСкобочкиВТекст, "(00)", "");
	пОбласти.Вставить("ШтрихКод", ПрефиксКодаАгрегации + КодАгрегации);
	// Смирнов М.Ю. 01.08.2025 HELP-6117 начало
	пОбласти.Вставить("ШтрихКодКоробки", ПрефиксКодаАгрегации + КодАгрегации);
	// Смирнов М.Ю. 01.08.2025 HELP-6117 конец
	
	ЗаполнитьЗначенияСвойств(Область.Параметры, пОбласти);
	
	Область.Параметры.Заполнить(Выборка);	
	
	Возврат Область;
КонецФункции //СформироватьКА(Макет, КодАгрегации, НомерКоробки, КоличествоШтук, Выборка, ДопПараметры = Неопределено) Экспорт

