Процедура ТоварыНоменклатураПриИзмененииНаКлиенте(СтрТЧобр,КолВЛПСоответствие)
	//++Данилова Е.В. 01.06.2026 SNL-243
	//СтрТЧобр.КоличествоВНакладной = ВернутьКоличествоВНакладной(СтрТЧобр.Номенклатура);
	//СтрТЧобр.КоличествоВЛП = ВернутьКоличествоЛП(СтрТЧобр.Номенклатура);
	СтрТЧобр.КоличествоВНакладной = ВернутьКоличествоВНакладнойНаКлиенте(СтрТЧобр.Номенклатура);	
