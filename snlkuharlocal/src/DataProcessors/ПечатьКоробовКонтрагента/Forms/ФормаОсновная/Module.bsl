	Если ВыбранноеЗначение = неопределено Тогда
		Возврат; 
	КонецЕсли;
	ТипВыбранногоЗначения = ТипЗнч(ВыбранноеЗначение);
	Если  ТипВыбранногоЗначения=Тип("Массив") Тогда	
		//++Данилова Е.В. 01.06.2026 SNL-243
		КолВЛПСоответствие = ВернутьКоличествоЛППоМассиву(ВыбранноеЗначение); 
		//--Данилова Е.В. 01.06.2026 
		Для Каждого СтрМасс Из ВыбранноеЗначение Цикл
			СтрокаТЧ = Объект.Товары.Добавить();
			СтрокаТЧ.Номенклатура=СтрМасс;
			СтрокаТЧ.Количество=1;
			//@skip-check query-in-loop
			ТоварыНоменклатураПриИзмененииНаКлиенте(СтрокаТЧ,КолВЛПСоответствие);
		КонецЦикла;	
		
	КонецЕсли;
