
#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	
	Если Параметры.Свойство("ДокСсылка") Тогда
		Объект.ДокСсылка = параметры.Докссылка;   	 
	КонецЕсли; 
	УправлениеВидимостью();
	УстановитьУсловноеОформление(); 
	//++Данилова Е.В. 01.06.2026 SNL-243
	ЗаполнитьНастройки(); 
	//--Данилова Е.В. 01.06.2026 
КонецПроцедуры

&НаКлиенте
Процедура КоробкиПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.Коробки.ТекущиеДанные; 
	Если ТекущиеДанные = Неопределено Тогда
		Возврат; 	
	КонецЕсли;
	IDКоробкиВыделить =  ТекущиеДанные.id_Короба;
	IDБлочкаВыделитьМ.Очистить();
	СтрокиПоБлочку = Объект.СодержимоеБлочка.НайтиСтроки(Новый Структура("id_Короба",IDКоробкиВыделить)); 
	Для Каждого СтрокиПоБлочку Из СтрокиПоБлочку Цикл
		Если IDБлочкаВыделитьМ.НайтиПоЗначению(СтрокиПоБлочку.id_Блочка) = Неопределено Тогда
			IDБлочкаВыделитьМ.Добавить(СтрокиПоБлочку.id_Блочка);
		КонецЕсли;
	КонецЦикла; 
	IDБлочкаВыделить = 0;
	IDКоробкиВыделитьПоБлочкам = 0; 
	УстановитьУсловноеОформление(); 
КонецПроцедуры


&НаКлиенте
Процедура ВсегоБлочковПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.ВсегоБлочков.ТекущиеДанные; 
	Если ТекущиеДанные = Неопределено Тогда
		Возврат; 	
	КонецЕсли;
	IDБлочкаВыделить =  ТекущиеДанные.id_Блочка; 
	СтрокиПоБлочку = Объект.СодержимоеБлочка.НайтиСтроки(Новый Структура("id_Блочка",IDБлочкаВыделить)); 
	Для Каждого СтрокиПоБлочку Из СтрокиПоБлочку Цикл
		IDКоробкиВыделитьПоБлочкам = СтрокиПоБлочку.id_Короба; 
	КонецЦикла;
	IDБлочкаВыделитьМ.Очистить();
	IDКоробкиВыделить = 0; 
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы
&НаКлиенте
Процедура ПоБлочкамПриИзменении(Элемент)
	Объект.ВсегоБлочков.Очистить();
	Объект.СодержимоеБлочка.Очистить();
	Объект.Товары.Очистить();
	Объект.Коробки.Очистить();
	//++Данилова Е.В. 01.06.2026 SNL-243  
	СборныйКороб.Очистить();
	//--Данилова Е.В. 01.06.2026 
	УправлениеВидимостью(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура КоличествоЛистовПереукладкиПриИзменении(Элемент)
		
	Для Каждого СтрокаТовара Из Объект.товары Цикл
		СтрокаТовара.КоличествоКоробов = КоличествоЛистовПереукладки; 
	КонецЦикла;
КонецПроцедуры
#КонецОбласти


#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары
&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	Если ТекущиеДанные  = неопределено Тогда
		Возврат; 
	КонецЕсли;
	//++Данилова Е.В. 01.06.2026 SNL-243
	КолВЛПСоответствие = ВернутьКоличествоЛППоМассиву(ТекущиеДанные.Номенклатура); 
	//--Данилова Е.В. 01.06.2026
	ТоварыНоменклатураПриИзмененииНаКлиенте(ТекущиеДанные,КолВЛПСоответствие);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	Если ТекущиеДанные  = неопределено Тогда
		Возврат; 
	КонецЕсли;
	Если ТекущиеДанные.Количество = 0 Тогда
		ТекущиеДанные.КоличествоКоробов = 0;
	ИначеЕсли ЗначениеЗаполнено(КоличествоЛистовПереукладки) Тогда
		 ТекущиеДанные.КоличествоКоробов = КоличествоЛистовПереукладки; 
	Иначе
		ТекущиеДанные.КоличествоКоробов = ТекущиеДанные.КоличествоВНакладной / ТекущиеДанные.Количество;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

