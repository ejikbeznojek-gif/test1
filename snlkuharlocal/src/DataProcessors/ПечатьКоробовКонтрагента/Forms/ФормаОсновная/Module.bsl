	КонецЕсли;
	
	ЗаполнитьТЧКоробки(ТипКоробаВыбранный);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧКоробки(Знач ТипКоробаВыбранный) 	
	
	СверитьСтрокиВсегоБлочки(); 
	
	ТекстОшибки = ""; 
	МассивНеЗаполБлочков = Новый Массив; 
	Для каждого ВыделеннаяСтрока Из Элементы.СодержимоеБлочка.ВыделенныеСтроки Цикл
		ДанныеСтроки = Объект.СодержимоеБлочка.НайтиПоИдентификатору(ВыделеннаяСтрока); 
		Отбор = Новый Структура("id_Блочка",ДанныеСтроки.id_Блочка); 
		СтрокаВсегоБлочков = Объект.ВсегоБлочков.НайтиСтроки(Отбор);
		Если СтрокаВсегоБлочков.Количество() > 0 
			И НЕ ЗначениеЗаполнено(СтрокаВсегоБлочков[0].Количество) Тогда
			
			Если МассивНеЗаполБлочков.Найти(ДанныеСтроки.id_Блочка) = Неопределено Тогда
				МассивНеЗаполБлочков.Добавить(ДанныеСтроки.id_Блочка); 
			КонецЕсли; 		  
			
		КонецЕсли; 	
	КонецЦикла;
	
	Если МассивНеЗаполБлочков.Количество() > 0  Тогда
		
		ТекстОшибки = "Не заполнено всего количество блочков по:"  + СтрСоединить(МассивНеЗаполБлочков,",");	
		
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		СообщитьПользователюСервер(ТекстОшибки);
		Возврат; 
		
	КонецЕсли; 
	
	Объект.Коробки.Очистить();
	
	СодержимоеБлочкаКопия = Объект.СодержимоеБлочка.Выгрузить(,"id_Короба"); 
	СодержимоеБлочкаКопия.Свернуть("id_Короба");
	Для каждого СтрокаТЧ Из  СодержимоеБлочкаКопия Цикл
		
		ИдКоробки = СтрокаТЧ.id_Короба; 
		ДобавитьСтрокуВТЧКоробкиНаСервере(ИдКоробки,ТипКоробаВыбранный);  
		ПерезаполнитьРасчПоляТЧКоробки(ИдКоробки);
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура СверитьСтрокиВсегоБлочки()

	СодержимоеБлочкаКопия =  Объект.СодержимоеБлочка.Выгрузить(,"id_Блочка"); 
    СодержимоеБлочкаКопия.Свернуть("id_Блочка");
	
	Для каждого СтрокаТЧ Из СодержимоеБлочкаКопия Цикл
		Отбор = Новый Структура("id_Блочка",СтрокаТЧ.id_Блочка);
		СтрокаВсегоБлочков = Объект.ВсегоБлочков.НайтиСтроки(Отбор);
		Если СтрокаВсегоБлочков.Количество() = 0 Тогда
			
			НоваяСтрока = Объект.ВсегоБлочков.Добавить(); 
			НоваяСтрока.id_Блочка = СтрокаТЧ.id_Блочка;	
			
		КонецЕсли;
		
	КонецЦикла;
	 
	УдалитьСтроки = новый Массив;  
	Для каждого СтрокаТЧ Из  Объект.ВсегоБлочков Цикл
		
		СтрокаБлочков = СодержимоеБлочкаКопия.Найти(СтрокаТЧ.id_Блочка,"id_Блочка"); 
		
		Если СтрокаБлочков = неопределено Тогда
			
			УдалитьСтроки.Добавить(СтрокаТЧ); 
			
		КонецЕсли;
		
	КонецЦикла;
	Для каждого СтрокаУд Из УдалитьСтроки Цикл
		
		
		Объект.ВсегоБлочков.Удалить(СтрокаУд); 
		
	КонецЦикла;
	
	
КонецПроцедуры


&НаКлиенте
Процедура ОпределитьВыделенныеВКоробкуНаКлиенте()
	
	Перем ТипКоробаВыбранный; 
	 
	Если ВвестиЗначение(ТипКоробаВыбранный,"Выберите тип короба",Тип("СправочникСсылка.ТипыКоробов")) Тогда
		
	ИначеЕсли ЗначениеЗаполнено(ТипКороба) Тогда 
		ТипКоробаВыбранный = ТипКороба;
	Иначе 
		ПоказатьПредупреждение(,"Необходимо выбрать тип короба"); 
		Возврат; 
	КонецЕсли;
	
	ТекстОшибки = ""; 
	МассивНеЗаполБлочков = Новый Массив; 
	Для каждого ВыделеннаяСтрока Из Элементы.СодержимоеБлочка.ВыделенныеСтроки Цикл
		ДанныеСтроки = Объект.СодержимоеБлочка.НайтиПоИдентификатору(ВыделеннаяСтрока);
		Отбор = Новый Структура("id_Блочка",ДанныеСтроки.id_Блочка); 
		СтрокаВсегоБлочков = Объект.ВсегоБлочков.НайтиСтроки(Отбор);
		Если СтрокаВсегоБлочков.Количество() > 0 
			И НЕ ЗначениеЗаполнено(СтрокаВсегоБлочков[0].Количество) Тогда
			
			Если МассивНеЗаполБлочков.Найти(ДанныеСтроки.id_Блочка) = Неопределено Тогда
				МассивНеЗаполБлочков.Добавить(ДанныеСтроки.id_Блочка); 
			КонецЕсли; 		  
			
		КонецЕсли; 	
	КонецЦикла;
	
	Если МассивНеЗаполБлочков.Количество() > 0  Тогда
	
		ТекстОшибки = "Не заполнено всего количество блочков по:"  + СтрСоединить(МассивНеЗаполБлочков,",");	
	
	КонецЕсли;	 
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		ПоказатьПредупреждение(,ТекстОшибки); 
		Возврат; 
		
	КонецЕсли;
	
	ИдКоробки = ВернутьСледующийIdКоробки(); 
	
	Если  ВвестиЗначение(ИдКоробки,"Ид Коробки",Тип("Число")) Тогда
		
		 
		Для каждого ВыделеннаяСтрока Из Элементы.СодержимоеБлочка.ВыделенныеСтроки Цикл
			ДанныеСтроки = Объект.СодержимоеБлочка.НайтиПоИдентификатору(ВыделеннаяСтрока);	
			Если ЗначениеЗаполнено(ДанныеСтроки.id_Короба) Тогда
			
				Продолжить; 	
			
			КонецЕсли;
			
			Если НЕ (ДанныеСтроки.Отметка) Тогда
			
				Продолжить; 	
			
			КонецЕсли; 		
				
			
			ДанныеСтроки.id_Короба = ИдКоробки; 
			
			ДобавитьСтрокуВТЧКоробки(ИдКоробки,ТипКоробаВыбранный);
					 
			
		КонецЦикла;	
		
		ПерезаполнитьРасчПоляТЧКоробки(ИдКоробки); 
		
	КонецЕсли;
	

КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьРасчПоляТЧКоробки(ИдКороба)
    Отбор = новый Структура("id_Короба",ИдКороба); 
	СтрокаКоробок = Объект.Коробки.НайтиСтроки(Отбор);
	Если СтрокаКоробок.Количество() > 0 Тогда
		
		СодержимоеБлочкаКопия = Объект.СодержимоеБлочка.Выгрузить(,"id_Короба,id_Блочка"); 
		СодержимоеБлочкаКопия.Свернуть("id_Короба,id_Блочка");
		СтрокиБлочков = СодержимоеБлочкаКопия.НайтиСтроки(Новый Структура("id_Короба",ИдКороба));
		ВсегоБлочковВКоробке = 0; 
		ВидыБлочков = ""; 
		Для каждого СтрокаБлочков Из СтрокиБлочков Цикл
			Отбор = новый Структура("id_Блочка",СтрокаБлочков.id_Блочка);
			СтрокаВсегоБлочков = Объект.ВсегоБлочков.НайтиСтроки(Отбор);
			Если СтрокаВсегоБлочков.Количество() > 0 Тогда
				ВсегоБлочковВКоробке = ВсегоБлочковВКоробке + СтрокаВсегоБлочков[0].Количество;  
			КонецЕсли;
			
			ВидыБлочков = ВидыБлочков + Строка(СтрокаБлочков.id_Блочка) + ";"; 
			
		КонецЦикла;
		
		СтрокаКоробок[0].КоличествоБлочков = ВсегоБлочковВКоробке; 
		СтрокаКоробок[0].ВидыБлочков = ВидыБлочков; 
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокуВТЧКоробки(ИдКоробки,ТипКоробаВыбранный)
    Отбор = Новый Структура("id_Короба",ИдКоробки); 
	СтрокаКоробок = Объект.Коробки.НайтиСтроки(Отбор);
	Если СтрокаКоробок.Количество() = 0 Тогда
		
		НоваяСтрока = Объект.Коробки.Добавить();
		НоваяСтрока.id_Короба = ИдКоробки;
		НоваяСтрока.ТипКороба = ТипКоробаВыбранный; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуВТЧКоробкиНаСервере(ИдКоробки,ТипКоробаВыбранный)
    Отбор = Новый Структура("id_Короба",ИдКоробки);
	СтрокаКоробок = Объект.Коробки.НайтиСтроки(Отбор);
	Если СтрокаКоробок.Количество() = 0  Тогда
		
		НоваяСтрока = Объект.Коробки.Добавить();
		НоваяСтрока.id_Короба = ИдКоробки;
		НоваяСтрока.ТипКороба = ТипКоробаВыбранный; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВернутьСледующийIdКоробки()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТКоробки.id_Короба КАК id_Короба
	|ПОМЕСТИТЬ ВТКоробки
	|ИЗ
	|	&Коробки КАК ВТКоробки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТКоробки.id_Короба КАК id_Короба
	|ИЗ
	|	ВТКоробки КАК ВТКоробки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТКоробки.id_Короба УБЫВ";
	Запрос.УстановитьПараметр("Коробки",Объект.Коробки.Выгрузить(,"id_Короба")); 
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда  	 
		
		Возврат 1; 
		
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.id_Короба + 1;
	КонецЕсли;  	

КонецФункции // ВернутьIdКоробки()

&НаСервере
Процедура СоздатьЛистыНаСервере()
	Если Объект.Коробки.Количество() = 0 Тогда
		СообщитьПользователюСервер("Заполните таблицу коробок!!!");
		Возврат; 
	КонецЕсли;
	
	ТекЗначениеКонстанты=Константы.ЗапускПереукладки.Получить();
	ТекПользователь= ТекущийПользователь(); 
	
	если ТекЗначениеКонстанты=Справочники.ФизическиеЛица.ПустаяСсылка() тогда
		Константы.ЗапускПереукладки.Установить(ТекПользователь);
	ИначеЕсли  ТекЗначениеКонстанты	=  ТекПользователь тогда //Ничего не делаем
		
	иначе
		СообщитьПользователюСервер("В данный момент переукладка запущена у "+ТекЗначениеКонстанты+" дождитесь окончания.");
		ЗаписатьВЛог("ОчередьОбработки","Попытка начать переукладку. Пытался "+ТекПользователь+ " ,помещал "+ТекЗначениеКонстанты,"Информация");
		возврат;
	КонецЕсли;
	
	ТекЗначениеКонстанты=Константы.ЗапускПереукладки.Получить(); //На всякий проверим, что константа установилась
	если  ТекЗначениеКонстанты =   ТекПользователь тогда
	иначе
		СообщитьПользователюСервер("Не удалось начать переукладку. Попробуйте ещё раз.");
		ЗаписатьВЛог("ОчередьОбработки","Не удалось записать константу ЗапускПереукладки - "+ТекПользователь,"Информация");
		возврат;		
	КонецЕсли;
	Если Не ДобавлятьКСуществующим Тогда
		Запрос = Новый Запрос;
		Запрос.Текст= "ВЫБРАТЬ
					  |	ЛистПереукладки.Ссылка как ЛП
					  |ИЗ
					  |	Документ.ЛистПереукладки КАК ЛистПереукладки
					  |ГДЕ
					  |	ЛистПереукладки.Проведен
					  |	И ЛистПереукладки.ДокОснование = &ДокОснование";
		Запрос.УстановитьПараметр("ДокОснование", СсылкаПоДокОбъекту());
		Результат = Запрос.Выполнить().Выгрузить();
		Если результат.Количество() > 0 Тогда
			//Состояние("Удаление старых листов переукладки...");
			Для Каждого СтрРез Из результат Цикл
				ТекЛП=СтрРез.ЛП.ПолучитьОбъект();
				ТекЛП.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	ЕстьОшибки = Ложь; 
	Если Объект.СоздаватьЗНА Тогда
		
		Для Каждого СтрРез Из Объект.Коробки Цикл

			ТЗНомЛП=Новый ТаблицаЗначений;
			ТЗНомЛП.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			ТЗНомЛП.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
			//++Данилова Е.В. 01.06.2026 SNL-243
			Если СтрРез.Сборный Тогда
				НомЛП = СборныйКороб.НайтиСтроки(Новый Структура("id_Короба,отметка", СтрРез.id_Короба, Истина));
				Для Каждого СтрМасс Из НомЛП Цикл
					СтрТЗ = ТЗНомЛП.Добавить();
					СтрТЗ.Номенклатура = СтрМасс.Номенклатура;
					СтрТЗ.Количество   = СтрМасс.Количество;
				КонецЦикла;
				//--Данилова Е.В. 01.06.2026 
			Иначе
				НомЛП = Объект.Товары.НайтиСтроки(Новый Структура("id_Короба,отметка", СтрРез.id_Короба, Истина));
				Для Каждого СтрМасс Из НомЛП Цикл
					СтрТЗ = ТЗНомЛП.Добавить();
					СтрТЗ.Номенклатура = СтрМасс.Номенклатура;
					СтрТЗ.Количество   = СтрМасс.Количество;
				КонецЦикла;
			//++Данилова Е.В. 01.06.2026 SNL-243
			КонецЕсли;
			//--Данилова Е.В. 01.06.2026 
			СтруктураЗаполненияШапкиЗНА = новый Структура("ТипКороба,Товары,КоличествоКоробок",СтрРез.ТипКороба,ТЗНомЛП,СтрРез.Количество);		
			РезультатПолучения = Документы.ЗаданиеНаАгрегацию.НайтиСоздатьЗНАПоНакладнойИСтруктуреПараметров(СсылкаПоДокОбъекту(),СтруктураЗаполненияШапкиЗНА);
			если РезультатПолучения.Успех тогда
				ЗНА = РезультатПолучения.Данные;
				РезультатСоздания = Документы.ЗаданиеНаАгрегацию.ЗаполнитьЛистыПереукладкиПоЗНА(ЗНА,ДобавлятьКСуществующим);			
			
				если не РезультатСоздания.Успех тогда
					
					СообщитьПользователюСервер(СтрСоединить(РезультатСоздания.Ошибки,символы.ПС)); 	 
					СообщитьПользователюСервер("Не удалось создать заполнить листы переукладки по ЗНА. Попробуйте ещё раз");  
					
					ЕстьОшибки = Истина;
									
				КонецЕсли;
				Продолжить;         
			иначе   
				ЕстьОшибки = Истина;
				СообщитьПользователюСервер(СтрСоединить(РезультатПолучения.Ошибки,символы.ПС));
				Прервать;
			КонецЕсли;   
		КонецЦикла; 		
		 
		Если Не ЕстьОшибки Тогда
			//Данилова Е.В. 12.05.2026 SNL-201
			//Документы.ЛистПереукладки.ПереномероватьВсеКоробкиНакладной(СсылкаПоДокОбъекту());

			СообщитьПользователюСервер("Готово");
		КонецЕсли;
	Иначе
		 //здесь необходимо преобразовать в комплектующие 
		 
		ОтгрузкаКомплектов = ПолучитьРеквизитШапки(СсылкаПоДокОбъекту(), "ОтгрузкаКомплектов", "Документ");
		Запрос = Новый запрос;
		запрос.Текст = "ВЫБРАТЬ
					   |	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
					   |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
					   |	РасходнаяНакладнаяКомплектующие.Количество КАК Количество,
					   |	РасходнаяНакладнаяКомплектующие.КоличествоПродукции КАК КоличествоПродукции
					   |ИЗ
					   |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
					   |ГДЕ
					   |	РасходнаяНакладнаяКомплектующие.Ссылка = &Накладная
					   |	И РасходнаяНакладнаяКомплектующие.Количество > 0
					   |	И РасходнаяНакладнаяКомплектующие.Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)";
		запрос.УстановитьПараметр("Накладная", СсылкаПоДокОбъекту());
		ТаблицаНакладнойКомплектующие = запрос.Выполнить().Выгрузить();
		
		Для Каждого СтрРез Из Объект.Коробки Цикл
			ТЗНомЛП=Новый ТаблицаЗначений;
			ТЗНомЛП.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			ТЗНомЛП.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
			//++Данилова Е.В. 01.06.2026 SNL-243
			Если СтрРез.Сборный Тогда
				НомЛП = СборныйКороб.НайтиСтроки(Новый Структура("id_Короба,отметка", СтрРез.id_Короба, Истина));
				Для Каждого СтрМасс Из НомЛП Цикл
					СтрТЗ = ТЗНомЛП.Добавить();
					СтрТЗ.Номенклатура = СтрМасс.Номенклатура;
					СтрТЗ.Количество   = СтрМасс.Количество;
				КонецЦикла;
				//--Данилова Е.В. 01.06.2026 
			Иначе
				НомЛП = Объект.Товары.НайтиСтроки(Новый Структура("id_Короба,Отметка", СтрРез.id_Короба, Истина));
				Для Каждого СтрМасс Из НомЛП Цикл
					СтрТЗ = ТЗНомЛП.Добавить();
					СтрТЗ.Номенклатура = СтрМасс.Номенклатура;
					СтрТЗ.Количество   = СтрМасс.Количество;
				КонецЦикла;
			КонецЕсли;
			Для сч = 1 По СтрРез.Количество Цикл
				НовДок = Документы.ЛистПереукладки.СоздатьДокумент();
				НовДок.Автор = ПараметрыСеанса.Пользователь;
				НовДок.КоличествоДокумента = 0;
				НовДок.ТипКороба = СтрРез.ТипКороба;
				Если ТипКороба <> Справочники.ТипыКоробов.НайтиПоКоду("0000000001") Тогда
					НовДок.ОбъемДокумента = ТипКороба.Объем;
				Иначе
					НовДок.ОбъемДокумента=Объем;
				КонецЕсли;

				НовДок.Дата=ТекущаяДатаСеанса();
				НовДок.ДокОснование = СсылкаПоДокОбъекту();
				Если ОтгрузкаКомплектов Тогда
					ТоварыДляЛП = РазвернутьТоварыВКомплектующие(ТаблицаНакладнойКомплектующие, ТЗНомЛП);
				Иначе
					ТоварыДляЛП = ТЗНомЛП;
				КонецЕсли;
				Для Каждого СтрТЗ Из ТоварыДляЛП Цикл
					СтрТЧ = НовДок.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(СтрТЧ, СтрТЗ);
					СтрТЧ.ТипШК = Перечисления.ТипыШтрихКодов.Штука;
				КонецЦикла;

				НовДок.Записать(РежимЗаписиДокумента.Проведение);
			КонецЦикла;
		КонецЦикла;
		СообщитьПользователюСервер("Готово");
	КонецЕсли;  

	запрос=новый Запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК КоличествоКоробок,
	|	СУММА(ЛистПереукладки.ОбъемДокумента) КАК ОбъемДокумента
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &ДокОснование";
	запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	Результат=запрос.Выполнить().Выгрузить();
	
	Если результат.Количество() > 0  Тогда 
		ДокОбъектРНК  = Объект.Докссылка.ПолучитьОбъект();
		ДокОбъектРНК.КоличествоКоробок = результат.Получить(0).КоличествоКоробок;
		ДокОбъектРНК.ОбъемКоробов = результат.Получить(0).ОбъемДокумента;
		ДокОбъектРНК.Записать();
		ЗаписатьКоличествоИОбъемКоробовВРегистр(СсылкаПоДокОбъекту(),результат.Получить(0).КоличествоКоробок,результат.Получить(0).ОбъемДокумента);
	КонецЕсли;
	 
	Константы.ЗапускПереукладки.Установить(Справочники.ФизическиеЛица.ПустаяСсылка());	
	
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостью(ПроверятьПравила = Истина) 
	Если ПроверятьПравила Тогда 
		Запрос = Новый Запрос; 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладная.ПравилаАгрегацииЧестногоЗнака.ТребуетсяАгрегацияБлочков КАК ТребуетсяАгрегацияБлочков
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	РасходнаяНакладная.Ссылка = &Ссылка"; 
		Запрос.УстановитьПараметр("Ссылка", СсылкаПоДокОбъекту());
		Выборка = Запрос.Выполнить().Выбрать(); 
		Выборка.Следующий(); 
		
		ПоБлочкам = Выборка.ТребуетсяАгрегацияБлочков; 
	КонецЕсли;
	УстановитьВидимостьЗаполненияДанныхПоБлочкам();  
	если РольДоступна("Администратор") тогда 
		Элементы.НеСверятьКоличество.Доступность = Истина;
	КонецЕсли;
	 
	Объект.СоздаватьЗНА = Истина;
	Элементы.СоздаватьЗНА.Видимость 	= РольДоступна("Администратор");
	Элементы.СоздаватьЗНА.Доступность 	= РольДоступна("Администратор");
	
	Элементы.КоробкиРассчитатьКоличествоКоробок.Видимость = ПоБлочкам; 
	Элементы.КоробкиКонтрольРаспределенияТоваровРНК.Видимость = ПоБлочкам;
	Элементы.КоробкиКоличествоБлочков.Видимость = ПоБлочкам; 
	Элементы.КоробкиВидыБлочков.Видимость = ПоБлочкам; 
	//++Данилова Е.В. 01.06.2026 SNL-243
	Элементы.СборныйКороб.Видимость = Не ПоБлочкам И СборныйКороб.Количество() > 0; 
	//--Данилова Е.В. 01.06.2026 

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЗаполненияДанныхПоБлочкам() 
	
	Элементы.ГруппаДляБлочков.Видимость = ПоБлочкам; 
	Элементы.ГруппаДляКоробок.Видимость = не ПоБлочкам; 
	 	
	ДобавлятьКСуществующим = Ложь; //НЕ ПоБлочкам; 
	//Элементы.ДобавлятьКСуществующим.Доступность = НЕ ПоБлочкам; 
	Элементы.ФормаСоздатьЛисты.Видимость = Не ПоБлочкам;
	Элементы.ФормаСоздатьЛистыПоБлочкам.Видимость = ПоБлочкам;  
	//++Данилова Е.В. 02.06.2026 SNL-243
	Элементы.РазделятьБлочкиПоНоменклатуре.Доступность = ПоБлочкам;
	Если Не ПоБлочкам Тогда
		РазделятьБлочкиПоНоменклатуре = Ложь;  
	КонецЕсли;
	//--Данилова Е.В. 02.06.2026 
КонецПроцедуры

