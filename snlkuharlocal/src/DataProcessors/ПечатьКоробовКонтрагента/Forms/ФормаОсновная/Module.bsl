	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Идет обработка...";
	Сообщение.Сообщить();	
	 
	РасчитатьИзМатрицыПоКоробкамНаСервереСЗаполнением();
	//РасчитатьИзМатрицыПоКоробкамНаСервере(); 
	//++Данилова Е.В. 01.06.2026 SNL-243
	МассивТоваров = МассивТоваровПоТЧТовары(); 
	КолВЛПСоответствие = ВернутьКоличествоЛППоМассиву(МассивТоваров); 
	//--Данилова Е.В. 01.06.2026
	Для каждого СтрокаТоваров Из Объект.Товары Цикл
		
		//@skip-check query-in-loop
		//++Данилова Е.В. 01.06.2026 SNL-243
