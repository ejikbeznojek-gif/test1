	Выборка = запрос.Выполнить().Выбрать(); 
	ТЧТоварыСоответствие = Новый Соответствие();
	Пока Выборка.Следующий() Цикл
		ТЧТоварыСоответствие.Вставить(Выборка.Номенклатура,Выборка.Количество); 
	КонецЦикла;
	Возврат ТЧТоварыСоответствие; 
	
