Функция ПолучитьРеквизитыНоменклатурыИзМатрицы(Номенклатура, Документ)
	Если Ложь Тогда
		Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
		Документ = Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
	СтруктураРезультата.Вставить("ШККонтрагента", "");
	СтруктураРезультата.Вставить("АртикулКонтрагента", "");
	СтруктураРезультата.Вставить("Цена", 0);
	СтруктураРезультата.Вставить("Кратность", 0);
	//СтруктураРезультата.Вставить("МинимальноеКоличество","");
	СтруктураРезультата.Вставить("ШККонтрагентаБлочок", "");
	СтруктураРезультата.Вставить("ШККонтрагентаКоробка", "");
	СтруктураРезультата.Вставить("КратностьКоробки", 0);
	СтруктураРезультата.Вставить("НаименованиеКонтрагента", "");
	СтруктураРезультата.Вставить("КодПроизводителяКонтрагента", "");
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				   |	МатрицаТовары.Номенклатура,
				   |	МатрицаТовары.ШККонтрагента,
				   |	МатрицаТовары.АртикулКонтрагента,
				   |	МатрицаТовары.Цена,
				   |	МатрицаТовары.Кратность,
				   |	МатрицаТовары.МинимальноеКоличество,
				   |	МатрицаТовары.ШККонтрагентаБлочок,
				   |	МатрицаТовары.ШККонтрагентаКоробка,
				   |	МатрицаТовары.КратностьКоробки,
				   |	МатрицаТовары.НаименованиеКонтрагента,
				   |	МатрицаТовары.КодПроизводителяКонтрагента
				   |ИЗ
				   |	Документ.Матрица.Товары КАК МатрицаТовары
				   // |		ПОЛНОЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки

				   // |		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
				   |			
				   |ГДЕ
				   |	МатрицаТовары.Ссылка.Дата <= &Дата
				   |	И МатрицаТовары.Ссылка.Проведен
				   |	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
				   |	И МатрицаТовары.Ссылка.ДатаОкончания >= &ДатаОкончания
				   |	И МатрицаТовары.Номенклатура = &Номенклатура ";
	
	//   |	И МатрицаПунктыДоставки.ПунктДоставки.Ссылка = &текПункт";
	
	
	//нечаева 18,07,17++
	//@skip-check empty-except-statement
	Попытка
		//@skip-check reading-attribute-from-database
		Если Документ.ПостояннаяАкция Тогда
			Запрос.Текст = Запрос.Текст + " И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
			//крохин начало 28.07.2017
			//постоянные акции только под галку
		Иначе
			Запрос.Текст = Запрос.Текст + " И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
			//крохин конец 28.07.2017

		КонецЕсли;
	Исключение

	КонецПопытки;
	//нечаева 18,07,17---
	Запрос.Текст =Запрос.Текст + "
								 |УПОРЯДОЧИТЬ ПО
								 |	МатрицаТовары.Ссылка.Дата УБЫВ
								 |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Контрагент", Документ.Контрагент);
	Запрос.УстановитьПараметр("Дата", КонецДня(Документ.Дата));
	Запрос.УстановитьПараметр("ДатаОкончания", конецДня(Документ.Дата));
	Запрос.УстановитьПараметр("текПункт", Документ.ПунктДоставки);

	Выборка = запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураРезультата, Выборка);
	КонецЦикла;
	Возврат СтруктураРезультата;
КонецФункции

