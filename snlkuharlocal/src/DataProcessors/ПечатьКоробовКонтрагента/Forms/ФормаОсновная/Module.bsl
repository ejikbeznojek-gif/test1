&НаКлиенте
Процедура РассчитатьВсегоБлочковНаКлиенте(СтрокаРасчета,ДобавитьНовуюСтроку = Ложь)
    Отбор = Новый Структура("id_Блочка",СтрокаРасчета.id_Блочка);
	СтрокаВсегоБл = Объект.ВсегоБлочков.НайтиСтроки(Отбор); 
	Если СтрокаВсегоБл.Количество() > 0 Тогда
		
		Если СтрокаРасчета.Количество = 0 Тогда
			СтрокаВсегоБл[0].Количество = 0;
		Иначе 
			СтрокаВсегоБл[0].Количество = Окр(СтрокаРасчета.КоличествоВНакладной/СтрокаРасчета.Количество);	
			
		КонецЕсли;
		 	
	ИначеЕсли ДобавитьНовуюСтроку Тогда 
		
		НоваяСтрока = Объект.ВсегоБлочков.Добавить();
		НоваяСтрока.id_Блочка = СтрокаРасчета.id_Блочка; 
		Если СтрокаРасчета.Количество = 0 Тогда
			НоваяСтрока.Количество = 0;
		Иначе 
			НоваяСтрока.Количество = Окр(СтрокаРасчета.КоличествоВНакладной/СтрокаРасчета.Количество);	
			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьidБлочканаКлиенте(СтрокаТЧ)    		
	
	СтрокаТЧ.id_Блочка = ПолучитьidБлочка();
	Отбор = Новый Структура("id_Блочка",СтрокаТЧ.id_Блочка); 
	СтрокаВсегоБлочков = Объект.ВсегоБлочков.НайтиСтроки(Отбор);
	Если СтрокаВсегоБлочков.Количество() = 0 Тогда
	
		НоваяСтрока = Объект.ВсегоБлочков.Добавить(); 
	    НоваяСтрока.id_Блочка = СтрокаТЧ.id_Блочка;  
		
	КонецЕсли;
	
	РассчитатьВсегоБлочковНаКлиенте(СтрокаТЧ);  
	
КонецПроцедуры



&НаСервере
Функция ПолучитьidБлочка()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТСодержимое.id_Блочка КАК id_Блочка
		|ПОМЕСТИТЬ ВТБлочки
		|ИЗ
		|	&СодержимоеБлочка КАК ВТСодержимое
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВТБлочки.id_Блочка КАК id_Блочка
		|ИЗ
		|	ВТБлочки КАК ВТБлочки
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТБлочки.id_Блочка УБЫВ";
	Запрос.УстановитьПараметр("СодержимоеБлочка",Объект.СодержимоеБлочка.Выгрузить(,"id_Блочка")); 
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		//СтрокаТЧ.id_Блочка = 1; 
		
		Возврат 1; 
		
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.id_Блочка + 1;
	КонецЕсли;


КонецФункции // ПолучитьidБлочка()

&НаСервере
Процедура РассчитатьВсегоБлочков(СтрокаРасчета,ДобавитьНовуюСтроку = Ложь,ОбновлятьКоличество = Истина)
    Отбор = Новый Структура("id_Блочка",СтрокаРасчета.id_Блочка);
	СтрокаВсегоБл = Объект.ВсегоБлочков.НайтиСтроки(Отбор); 
	Если СтрокаВсегоБл.Количество() > 0  Тогда
		
		Если СтрокаРасчета.Количество = 0 Тогда
			СтрокаВсегоБл[0].Количество = 0;
		
		ИначеЕсли ОбновлятьКоличество Тогда  
			
			СтрокаВсегоБл[0].Количество = Окр(СтрокаРасчета.КоличествоВНакладной/СтрокаРасчета.Количество);	
			
		КонецЕсли;
		 	
	ИначеЕсли ДобавитьНовуюСтроку Тогда 
		
		НоваяСтрока = Объект.ВсегоБлочков.Добавить();
		НоваяСтрока.id_Блочка = СтрокаРасчета.id_Блочка; 
		Если СтрокаРасчета.Количество = 0 Тогда
			НоваяСтрока.Количество = 0;
		Иначе 
			НоваяСтрока.Количество = Окр(СтрокаРасчета.КоличествоВНакладной/СтрокаРасчета.Количество);	
			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 


&НаСервере
Функция ПодборПоБлочкамНаСервере(Накладная)
	Запрос = Новый Запрос;
	Запрос.текст = ТекстЗапросаРНКЛП();

	Запрос.УстановитьПараметр("Дата", Константы.ДатаЗапретаВидимости.Получить());
	Запрос.УстановитьПараметр("ДокОснование", Накладная.Ссылка);
	Запрос.УстановитьПараметр("ОтборПоНоменклатуре", Ложь);
	Запрос.УстановитьПараметр("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
	Выборка = Запрос.Выполнить().Выбрать();

	МассивТоваров = Новый Массив;
	Пока Выборка.Следующий() Цикл
		МассивТоваров.Добавить(Выборка.Номенклатура);
	КонецЦикла;
	
	//++Данилова Е.В. 06.03.2026 
	МассивТоваров = ИсключитьВидыКомплектовАссорти(МассивТоваров);
		//--Данилова Е.В. 06.03.2026 
	Возврат МассивТоваров; 
КонецФункции
&НаСервере
Функция ИсключитьВидыКомплектовАссорти(Знач СписокТоваров)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НоменклатураСпр.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК НоменклатураСпр
	|ГДЕ
	|	НоменклатураСпр.Ссылка В(&СписокТоваров)
	|	И НЕ НоменклатураСпр.Родитель.ВидКомплекта = &Ассортито";

	Запрос.УстановитьПараметр("Ассортито", Перечисления.ВидыКомплектов.Ассортито);
	Запрос.УстановитьПараметр("СписокТоваров", СписокТоваров);

	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура");
КонецФункции
&НаСервере
Функция ТекстЗапросаРНКЛП()

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	СУММА(ЛистНабораТовары.Количество) КАК Количество,
	|	ЛистНабораТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ЛистыПереукладкиСозданнные
	|ИЗ
	|	Документ.ЛистПереукладки.Товары КАК ЛистНабораТовары
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.Дата >= &Дата
	|	И ЛистНабораТовары.Ссылка.Проведен
	|	И ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
	|	И ВЫБОР
	|			КОГДА &ОтборПоНоменклатуре
	|				ТОГДА ЛистНабораТовары.Номенклатура = &Номенклатура
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛистНабораТовары.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ ВтТовары
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|ГДЕ
	|	РасходнаяНакладнаяТовары.Ссылка = &ДокОснование
	|	И ВЫБОР
	|			КОГДА &ОтборПоНоменклатуре
	|				ТОГДА РасходнаяНакладнаяТовары.Номенклатура = &Номенклатура
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяТовары.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
	|	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
	|ПОМЕСТИТЬ ВтКомплектующие
	|ИЗ
	|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
	|ГДЕ
	|	РасходнаяНакладнаяКомплектующие.Ссылка = &ДокОснование
	|	И ВЫБОР
	|			КОГДА &ОтборПоНоменклатуре
	|				ТОГДА РасходнаяНакладнаяКомплектующие.Номенклатура = &Номенклатура
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяКомплектующие.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтТовары.Номенклатура КАК Номенклатура,
	|	ВтТовары.Количество КАК Количество
	|ПОМЕСТИТЬ ВтТоварыРНК
	|ИЗ
	|	ВтТовары КАК ВтТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКомплектующие КАК ВтКомплектующие
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ВтКомплектующие.Номенклатура ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтКомплектующие.Номенклатура,
	|	ВтКомплектующие.Количество
	|ИЗ
	|	ВтКомплектующие КАК ВтКомплектующие
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтТоварыРНК.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ЛистыПереукладкиСозданнные.Количество, 0) КАК КоличествоЛП,
	|	ВтТоварыРНК.Количество КАК КоличествоРНК
	|ИЗ
	|	ВтТоварыРНК КАК ВтТоварыРНК
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЛистыПереукладкиСозданнные КАК ЛистыПереукладкиСозданнные
	|		ПО ВтТоварыРНК.Номенклатура = ЛистыПереукладкиСозданнные.Номенклатура
	|ГДЕ
	|	ВтТоварыРНК.Количество > 0";

	Возврат ТекстЗапроса;
КонецФункции // ТекстЗапросаРНКЛП()
#КонецОбласти