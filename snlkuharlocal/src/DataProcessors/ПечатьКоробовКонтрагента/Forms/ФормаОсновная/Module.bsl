		РассчитатьВсегоБлочковНаКлиенте(ТекущиеДанные,истина);	
	
	КонецЕсли;
КонецПроцедуры
#КонецОбласти



#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура ПодборПоБлочкам(Команда)
	МассивТоваров = ПодборПоБлочкамНаСервере(СсылкаПоДокОбъекту());
	
	Если МассивТоваров.Количество() = 0 Тогда
		Возврат; 
	КонецЕсли;	
	
	ОписаниеОповещенияВыбор = Новый ОписаниеОповещения("ПослеВыбораНоменклатурыПоБлочкам",ЭтотОбъект);
	ПараметрОткрытияФормы = Новый Структура("НоменклатураВыбора,РежимВыбора",МассивТоваров,истина ); 
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаВыбораУпр",ПараметрОткрытияФормы,ЭтотОбъект,,,,ОписаниеОповещенияВыбор); 
		
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборПоКоробам(Команда)
	МассивТоваров = ПодборПоКоробамНаСервере();
	
	Если МассивТоваров.Количество() = 0 Тогда
		Возврат; 
	КонецЕсли;
	
	ОписаниеОповещенияВыбор = Новый ОписаниеОповещения("ПослеВыбораНоменклатурыПоКоробкам",ЭтотОбъект);
	ПараметрОткрытияФормы = Новый Структура("НоменклатураВыбора,РежимВыбора",МассивТоваров,истина ); 
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаВыбораУпр",ПараметрОткрытияФормы,ЭтотОбъект,,,,ОписаниеОповещенияВыбор);
КонецПроцедуры


