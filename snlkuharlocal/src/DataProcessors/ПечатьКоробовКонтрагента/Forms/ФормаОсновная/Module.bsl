&НаСервере
Процедура РасчитатьИзМатрицыПоКоробкамНаСервереСЗаполнением()

	ДокСсылкаНаОбъект = СсылкаПоДокОбъекту();
	Если Не ЗначениеЗаполнено(ТипКороба) Тогда
		СообщитьПользователюСервер("Заполните тип короба в шапке!");
		Возврат;
	КонецЕсли;
	Объект.товары.Очистить();
    //++Данилова Е.В. 01.06.2026 SNL-243 
	СборныйКороб.Очистить();
	//--Данилова Е.В. 01.06.2026
	ТЗначений = Новый ТаблицаЗначений;
	ТЗначений.Колонки.Добавить("Номенклатура");		//+
	ТЗначений.Колонки.Добавить("АртикулКонтрагента");   //+
	ТЗначений.Колонки.Добавить("КратностьКоробки");            //+
	ТЗначений.Колонки.Добавить("Количество");  
	//+
	НельзяЗагружать = Ложь;
    ТоварыПоДокОбРНК = ВернутьТоварыРНК(); 
	
	Для Каждого СтрокаТЧ Из ТоварыПоДокОбРНК Цикл
		Если СтрокаТЧ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		//@skip-check query-in-loop
		РеквизитыНоменклатуры = ПолучитьРеквизитыНоменклатурыИзМатрицы(СтрокаТЧ.Номенклатура, ДокСсылкаНаОбъект);
		Если РеквизитыНоменклатуры.номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда
			НельзяЗагружать=Истина;
			СообщитьПользователюСервер("по номенклатуре " + СтрокаТЧ.Номенклатура
				+ " нет данных в матрице, ЛП не будут созданы.");
			Продолжить;
		КонецЕсли;
		Если РеквизитыНоменклатуры.КратностьКоробки = 0 Тогда
			НельзяЗагружать=Истина;
			СообщитьПользователюСервер("по номенклатуре " + СтрокаТЧ.Номенклатура
				+ " пустая кратность коробки, ЛП не будут созданы");
			Продолжить;
		КонецЕсли;
		СтрТЗ=ТЗначений.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЗ, РеквизитыНоменклатуры);
		СтрТЗ.Количество=СтрокаТЧ.Количество;
	КонецЦикла;

	Если НельзяЗагружать Тогда
		Возврат;
	КонецЕсли;

	ТЗСверн = ТЗначений.Скопировать();
	ТЗСверн.Свернуть("АртикулКонтрагента,КратностьКоробки", "Количество");
	НомерВидаКоробки = 1;
	Для Каждого СтрТЗСверн Из ТЗСверн Цикл
		НомЛП = ТЗначений.НайтиСтроки(Новый Структура("АртикулКонтрагента", СтрТЗСверн.АртикулКонтрагента));

		КолКор=СтрТЗСверн.Количество / СтрТЗСверн.КратностьКоробки;

		Если Объект.СоздаватьЗНА Тогда
			//++Данилова Е.В. 01.06.2026 SNL-243

//			Если Цел(КолКор) <> КолКор Тогда
//				КолКор = Цел(КолКор) + 1;
//			КонецЕсли;
			ОставшеесяКоличество = 0; 
			Если Цел(КолКор) <> КолКор Тогда
				КолКор = Цел(КолКор); 
				ОставшеесяКоличество =  СтрТЗСверн.Количество - СтрТЗСверн.КратностьКоробки * КолКор; 
			КонецЕсли; 
			//--Данилова Е.В. 01.06.2026 
		КонецЕсли;
		//++Данилова Е.В. 01.06.2026 SNL-243
		ЧастьДляРаспределения = 0;
		Если ОставшеесяКоличество > 0 Тогда
			ЧастьДляРаспределения = Цел(СтрТЗСверн.Количество / ОставшеесяКоличество);
		КонецЕсли;
		//--Данилова Е.В. 01.06.2026 
		Для Каждого СтрМасс Из НомЛП Цикл
			Если КолКор > 0 Тогда
				СтрТЗ = Объект.товары.Добавить();
				СтрТЗ.Номенклатура=СтрМасс.Номенклатура;
				Если ЧастьДляРаспределения = 0 Тогда
					СтрТЗ.Количество=СтрМасс.количество / КолКор;
				Иначе
					СтрТЗ.Количество=(СтрМасс.количество - Цел(СтрМасс.количество / ЧастьДляРаспределения)) / КолКор;
				КонецЕсли;
				СтрТЗ.ТипКороба = ТипКороба;
				СтрТЗ.Отметка = Истина;
				СтрТЗ.КоличествоКоробов = КолКор;
				СтрТЗ.id_Короба = НомерВидаКоробки; 
				
				НомерВидаКоробки = НомерВидаКоробки + 1;
			КонецЕсли; 
			//++Данилова Е.В. 01.06.2026 SNL-243
			Если ОставшеесяКоличество > 0 Тогда
				СтрСборный = СборныйКороб.Добавить();
				СтрСборный.Номенклатура = СтрМасс.Номенклатура;
				СтрСборный.Количество = СтрМасс.количество - СтрТЗ.Количество * КолКор;
				СтрСборный.ОставшеесяКоличество =  СтрСборный.Количество;
				СтрСборный.id_Короба = 1;
				СтрСборный.ТипКороба = ТипКороба;
				СтрСборный.Отметка = истина;
				
				ОставшеесяКоличество = ОставшеесяКоличество -  СтрСборный.Количество;  
			КонецЕсли;
			//--Данилова Е.В. 01.06.2026 
		КонецЦикла;
		//++Данилова Е.В. 01.06.2026 SNL-243
		Если ОставшеесяКоличество > 0 И СтрСборный <> Неопределено Тогда
			СтрСборный.Количество = СтрСборный.Количество + ОставшеесяКоличество; 
		КонецЕсли;
		//--Данилова Е.В. 01.06.2026 
		//НомерВидаКоробки = НомерВидаКоробки + 1;
	КонецЦикла;	
    //++Данилова Е.В. 01.06.2026 SNL-243
	Элементы.СборныйКороб.Видимость = СборныйКороб.Количество() > 0; 
	//--Данилова Е.В. 01.06.2026
КонецПроцедуры

