&НаСервере
Процедура ЗаполнитьНастройки()
	ТЗТовары = ВернутьТоварыРНК();
	ТоварыРНК = Новый Соответствие();
	Для Каждого СтрокаТовара Из ТЗТовары Цикл
		ТоварыРНК.Вставить(СтрокаТовара.Номенклатура,СтрокаТовара.Количество); 
	КонецЦикла;
	ТоварыРНКСтруктура = Новый Структура("ТоварыРНК",ТоварыРНК);
КонецПроцедуры
&НаСервере
Процедура УстановитьУсловноеОформление()
	/////////////////////////////////////////////////////////// 
	 УсловноеОформление.Элементы.Очистить();
	 Если ЗначениеЗаполнено(IDКоробкиВыделить) Тогда  
		 ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		 ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		 ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.id_Короба"); 
		 ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		 ЭлементОтбора.ПравоеЗначение = IDКоробкиВыделить;
		 ЭлементОтбора.Использование = Истина;	
		 
		 ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЖелтыйЗолотистый);
		 ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		 ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Товары");
		 ПолеОформления.Использование = Истина;
		 ////////////////////////////////////////////////////////////
		 ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		 ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		 ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.СодержимоеБлочка.id_Короба"); 
		 ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		 ЭлементОтбора.ПравоеЗначение = IDКоробкиВыделить;
		 ЭлементОтбора.Использование = Истина;	
		 
		 ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЖелтыйЗолотистый);
		 ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		 ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("СодержимоеБлочка");
		 ПолеОформления.Использование = Истина;
	 КонецЕсли;
	 Если ЗначениеЗаполнено(IDКоробкиВыделитьПоБлочкам) Тогда 
		 ////////////////////////////////////////////////////////////
		 ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		 ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		 ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Коробки.id_Короба"); 
		 ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		 ЭлементОтбора.ПравоеЗначение = IDКоробкиВыделитьПоБлочкам;
		 ЭлементОтбора.Использование = Истина;	
		 
		 ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЖелтыйЗолотистый);
		 ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		 ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Коробки");
		 ПолеОформления.Использование = Истина; 
	 КонецЕсли;
 	/////////////////////////////////////////////////////////// 
	Если IDБлочкаВыделитьМ.Количество() > 0 Тогда 
		ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ВсегоБлочков.id_Блочка"); 
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
		ЭлементОтбора.ПравоеЗначение = IDБлочкаВыделитьМ;
		ЭлементОтбора.Использование = Истина;
		
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЖелтыйЗолотистый);
		ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ВсегоБлочков");
		ПолеОформления.Использование = Истина;
	КонецЕсли;
	///////////////////////////////////////////////////////////
	Если ЗначениеЗаполнено(IDБлочкаВыделить) Тогда
		ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.СодержимоеБлочка.id_Блочка"); 
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = IDБлочкаВыделить;
		ЭлементОтбора.Использование = Истина;	
		
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЖелтыйЗолотистый);
		ПолеОформления = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("СодержимоеБлочка");
		ПолеОформления.Использование = Истина;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьБлочкиПоМатрицеНаСервере()
	
	ТЗ = Новый ТаблицаЗначений; 
	
	ОписаниеТиповНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура"); 
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(100)); 
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10)); 
	
	ТЗ.Колонки.Добавить("Номенклатура",ОписаниеТиповНоменклатура);		
	ТЗ.Колонки.Добавить("АртикулКонтрагента",ОписаниеТиповСтрока);   
	ТЗ.Колонки.Добавить("КратностьКоробки",ОписаниеТиповЧисло);            
	ТЗ.Колонки.Добавить("Кратность",ОписаниеТиповЧисло); //кратность блочка  
	ТЗ.Колонки.Добавить("Количество",ОписаниеТиповЧисло); //для расчета комплектующих 
	
	НельзяЗагружать = ложь;	
	ТоварыРНК = ВернутьТоварыРНК(); 
	Для Каждого СтрокаТЧ из ТоварыРНК Цикл
		если СтрокаТЧ.Количество=0 тогда Продолжить;КонецЕсли;
		
		РеквизитыНоменклатуры = ПолучитьРеквизитыНоменклатурыИзМатрицы(СтрокаТЧ.Номенклатура,СсылкаПоДокОбъекту());
		Если РеквизитыНоменклатуры.номенклатура= Справочники.Номенклатура.ПустаяСсылка()  тогда
			НельзяЗагружать=Истина;
			СообщитьПользователюСервер("по номенклатуре "+СтрокаТЧ.Номенклатура.Наименование+" нет данных в матрице, ЛП не будут созданы.");
			Продолжить;
		КонецЕсли;
		Если  РеквизитыНоменклатуры.КратностьКоробки=0 тогда
			НельзяЗагружать=Истина;
			СообщитьПользователюСервер("по номенклатуре "+СтрокаТЧ.Номенклатура.Наименование+" пустая кратность коробки, ЛП не будут созданы");
			Продолжить;
		КонецЕсли;
		
		Если  РеквизитыНоменклатуры.Кратность = 0 тогда
			НельзяЗагружать = Истина;
			СообщитьПользователюСервер("по номенклатуре "+СтрокаТЧ.Номенклатура.Наименование+" пустая кратность блочка, ЛП не будут созданы");
			Продолжить;
		КонецЕсли;
		
		СтрТЗ = ТЗ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЗ,РеквизитыНоменклатуры);
		СтрТЗ.Количество = СтрокаТЧ.Количество; 
	КонецЦикла;
	
	Если НельзяЗагружать тогда 
		Возврат;
	КонецЕсли;
	
	ТЗКопия = ТЗ.Скопировать(); 
	//++Данилова Е.В. 02.06.2026 SNL-243
	ТЗБезРазделБлочПоАртик = ТЗ.Скопировать();
	ТЗБезРазделБлочПоАртикКопия = ТЗ.Скопировать();
	ТЗБезРазделБлочПоАртик.Свернуть("АртикулКонтрагента,КратностьКоробки","Количество");
	ТЗБезРазделБлочПоАртикКопия.Свернуть("АртикулКонтрагента,Номенклатура,КратностьКоробки,Кратность","Количество");
	//--Данилова Е.В. 02.06.2026 
	
	ТЗ.Свернуть("АртикулКонтрагента,КратностьКоробки,Кратность","Количество");
	//проверка, что кратность блочка и кратность коробки  указана одна на артикул 
	//если РазделятьБлочкиПоНоменклатуре 
	//то сумма по кратности, и надо разделить в этом случае id блочка 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗ.АртикулКонтрагента КАК АртикулКонтрагента,
		|	ТЗ.КратностьКоробки КАК КратностьКоробки,
		|	ТЗ.Кратность КАК Кратность
		|ПОМЕСТИТЬ ВТТЗ
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТЗ.АртикулКонтрагента КАК АртикулКонтрагента,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТТЗ.КратностьКоробки) КАК КратностьКоробки,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТТЗ.Кратность) КАК Кратность
		|ИЗ
		|	ВТТЗ КАК ВТТЗ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТТЗ.АртикулКонтрагента
		|
		|ИМЕЮЩИЕ
		|	(КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТТЗ.КратностьКоробки) > 1
		|		ИЛИ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТТЗ.Кратность) > 1)";
	
	Запрос.УстановитьПараметр("ТЗ",ТЗ); 
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать(); 
		
		Пока Выборка.Следующий() Цикл			
			
			СообщитьПользователюСервер("По " + Выборка.АртикулКонтрагента + "неверно указана кратность коробки или кратность блочка"); 	
			
		КонецЦикла;
		
		Возврат; 
		
	КонецЕсли;  	
	
	ТЗ.Колонки.Добавить("id_Блочка",ОписаниеТиповЧисло);
	ТЗ.Колонки.Добавить("КоличествоБлочков",ОписаниеТиповЧисло); 
	
	//++Данилова Е.В. 02.06.2026 SNL-243
	ТЗ.Колонки.Добавить("id_Короба",ОписаниеТиповЧисло); 
	
	ТЗБезРазделБлочПоАртикКопия.Колонки.Добавить("id_Блочка",ОписаниеТиповЧисло);
	ТЗБезРазделБлочПоАртикКопия.Колонки.Добавить("id_Короба",ОписаниеТиповЧисло);
	ТЗБезРазделБлочПоАртикКопия.Колонки.Добавить("КоличествоБлочков",ОписаниеТиповЧисло);
	ТЗБезРазделБлочПоАртикКопия.Колонки.Добавить("КоличествоВсего",ОписаниеТиповЧисло);
	ТЗБезРазделБлочПоАртикКопия.Сортировать("АртикулКонтрагента"); 
	//--Данилова Е.В. 02.06.2026 
	///////////////////////////////////////////////////
	
	Id_Блочка = 1;
	//++Данилова Е.В. 02.06.2026 SNL-243
	Если РазделятьБлочкиПоНоменклатуре Тогда
		АртикулКонтрагента = неопределено;
		Id_Короба = 0; 
    	Для Каждого СтрокаПродукции Из ТЗБезРазделБлочПоАртикКопия Цикл
			СтрокаВсегоБлочков = Объект.ВсегоБлочков.Добавить();
			СтрокаВсегоБлочков.id_Блочка  =  Id_Блочка;
			Отбор = Новый Структура("АртикулКонтрагента", СтрокаПродукции.АртикулКонтрагента);
			СтрокиОбщиеАртикул = ТЗБезРазделБлочПоАртик.НайтиСтроки(Отбор);
			
			Если  АртикулКонтрагента <> СтрокаПродукции.АртикулКонтрагента Тогда
				Id_Короба = Id_Короба + 1; 
			КонецЕсли;
			Если СтрокиОбщиеАртикул.Количество() > 0 Тогда
                
				//кол-во блочков расчетное 
				СтрокаОбщаяАртикул = СтрокиОбщиеАртикул[0];
				КоличествоКоробок = СтрокаОбщаяАртикул.Количество/СтрокаОбщаяАртикул.КратностьКоробки;
				//СтрокаВсегоБлочков.Количество = Цел(СтрокаОбщаяАртикул.КратностьКоробки / СтрокаОбщаяАртикул.Кратность);
                СтрокаВсегоБлочков.Количество =  СтрокаПродукции.Количество/КоличествоКоробок/СтрокаПродукции.Кратность; 
				СтрокаПродукции.id_Блочка 	= Id_Блочка;
				
				СтрокаПродукции.КоличествоВсего = СтрокаОбщаяАртикул.Количество;  //кол-во всего по артикулу , для коробки  			 
				СтрокаПродукции.КоличествоБлочков = СтрокаВсегоБлочков.Количество;
                /////////////////////////////////////////////////////////////////
				СтрокаПродукции.Количество =  СтрокаПродукции.КоличествоВсего; 
				////////////////////////////////////////////////////////
				СтрокаПродукции.id_Короба 	= Id_Короба;
				 
				  
				id_Блочка = id_Блочка + 1;
			КонецЕсли;
            АртикулКонтрагента = СтрокаПродукции.АртикулКонтрагента; 
		КонецЦикла;
    Иначе
    //--Данилова Е.В. 02.06.2026 
		Для Каждого СтрокаОбщаяАртикул Из ТЗ Цикл
			СтрокаВсегоБлочков = Объект.ВсегоБлочков.Добавить();
			СтрокаВсегоБлочков.id_Блочка  =  Id_Блочка;
			СтрокаВсегоБлочков.Количество = Цел(СтрокаОбщаяАртикул.КратностьКоробки / СтрокаОбщаяАртикул.Кратность);

			СтрокаОбщаяАртикул.id_Блочка = Id_Блочка;
			СтрокаОбщаяАртикул.КоличествоБлочков = СтрокаВсегоБлочков.Количество;
            //++Данилова Е.В. 02.06.2026 SNL-243
			СтрокаОбщаяАртикул.id_Короба = Id_Блочка;
			//--Данилова Е.В. 02.06.2026 
			id_Блочка = id_Блочка + 1;
		КонецЦикла;
	КонецЕсли;
	
	////////////////////////////////
	//++Данилова Е.В. 02.06.2026 SNL-243
	ТЗБезРазделБлочПоАртикКопия.Сортировать("Id_Блочка");
	//--Данилова Е.В. 02.06.2026 
	ПоКомплектующим = ложь; 
	Если ПолучитьРеквизитРНК("ОтгрузкаКомплектов") И ВернутьКомплектующиеРНК().Количество() > 0 Тогда
		
		ТЧТовары = ВернутьКомплектующиеРНК(); //ДокОбъект.Комплектующие;
		
		ПоКомплектующим = истина; 
	Иначе 	
		ТЧТовары = ВернутьТоварыРНК(); //ДокОбъект.Товары;
	КонецЕсли;
	
	Запрос = Новый Запрос; 
	Запрос.текст =
	"ВЫБРАТЬ
	|	СУММА(ЛистНабораТовары.Количество) КАК Количество,
	|	ЛистНабораТовары.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.ЛистПереукладки.Товары КАК ЛистНабораТовары
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.Проведен
	|	И ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
	|СГРУППИРОВАТЬ ПО
	|	ЛистНабораТовары.Номенклатура" 
	; 
	Запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	ТоварыЛПСозданные = Запрос.Выполнить().Выгрузить(); 
	
	Для каждого СтрокаТЧ Из ТЧТовары Цикл
		ВидНоменклатуры = ПолучитьРеквизитОбъекта(СтрокаТЧ.Номенклатура.Родитель,"ВидНоменклатуры");
		Если ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
			
			Продолжить; 	
			
		КонецЕсли;
		
		если СтрокаТЧ.Количество=0 тогда Продолжить;КонецЕсли;
		
		Если ПоКомплектующим Тогда
			
			ОтборПоНоменклатуре = СтрокаТЧ.Продукция; 	
		Иначе 
			ОтборПоНоменклатуре = СтрокаТЧ.Номенклатура; 
		КонецЕсли;
		
		Отбор = Новый Структура("Номенклатура",ОтборПоНоменклатуре);
		
		СтрокиИзМатрицы = ТЗКопия.НайтиСтроки(Отбор); 	
		
		Если СтрокиИзМатрицы.Количество() > 0  Тогда
			
			КоличествоВРНК = СтрокиИзМатрицы[0].Количество;
			
			ОтборПоАртикулу = Новый Структура("АртикулКонтрагента",СтрокиИзМатрицы[0].АртикулКонтрагента); 
			
			СтрокиИзСвернТЧ = ТЗ.НайтиСтроки(ОтборПоАртикулу); 
			//++Данилова Е.В. 02.06.2026 SNL-243
			Если РазделятьБлочкиПоНоменклатуре Тогда
				
				ОтборПоАртикулу = Новый Структура("АртикулКонтрагента,Номенклатура",СтрокиИзМатрицы[0].АртикулКонтрагента,ОтборПоНоменклатуре);
				СтрокиИзСвернТЧ = ТЗБезРазделБлочПоАртикКопия.НайтиСтроки(ОтборПоАртикулу);
			КонецЕсли;	
			//--Данилова Е.В. 02.06.2026 
			id_Блочка = 0;
			КратностьБлочкаРасч = 0;
			КоличествоБлочков = 0;
			//++Данилова Е.В. 02.06.2026 SNL-243
			id_Короба = 0; 
			//--Данилова Е.В. 02.06.2026 
			Если СтрокиИзСвернТЧ.Количество() > 0  Тогда
				
				id_Блочка = СтрокиИзСвернТЧ[0].id_Блочка;
				
				//++Данилова Е.В. 02.06.2026 SNL-243
				id_Короба = СтрокиИзСвернТЧ[0].id_Короба;; 
				//--Данилова Е.В. 02.06.2026
				
				КоличествоКоробок = СтрокиИзСвернТЧ[0].Количество/СтрокиИзСвернТЧ[0].КратностьКоробки;
				
				КоличествоБлочков = СтрокиИзСвернТЧ[0].КоличествоБлочков; //Цел(СтрокиИзСвернТЧ[0].КратностьКоробки/СтрокиИзСвернТЧ[0].Кратность); 			
				
				КратностьБлочкаРасч = Цел(КоличествоВРНК/КоличествоКоробок/КоличествоБлочков);     
				// Кухарь А.Ю.  08.04.2026 начало
				// 
				//если РольДоступна("Администратор") тогда   
					КратностьБлочкаРасч = Окр(КоличествоВРНК/КоличествоКоробок/КоличествоБлочков,0); 
				//КонецЕсли;
				// Кухарь А.Ю.  08.04.2026 конец
				
			Иначе 
				
				СообщитьПользователюСервер("Ошибка в определении количества блочков в коробке!!!" + Строка(ОтборПоНоменклатуре)); 
				
				Продолжить; 
				
			КонецЕсли;
			
			
			ВидКомплекта= ПолучитьРеквизитОбъекта(ОтборПоНоменклатуре,"ВидКомплекта");
			Если ВидКомплекта = Перечисления.ВидыКомплектов.Ассортито Тогда
				//++Данилова Е.В. 04.03.2026 SNL-153 
				//КоличествоВблочке = Цел(СтрокаТЧ.Количество/КоличествоБлочков);
				КоличествоВблочке = Цел(СтрокаТЧ.Количество/КоличествоКоробок/КоличествоБлочков);
				//--Данилова Е.В. 04.03.2026 
				
			Иначе 
				КратностьКомплект = СтрокаТЧ.Количество/СтрокиИзМатрицы[0].Количество; 
				
				КоличествоВблочке = КратностьКомплект *  КратностьБлочкаРасч;	
				
			КонецЕсли;
			
			
			//заполняем содержимое 
			НоваяСтрокаСодер = Объект.СодержимоеБлочка.Добавить();
			НоваяСтрокаСодер.id_Блочка = id_Блочка;
			//++Данилова Е.В. 02.06.2026 SNL-243
			//НоваяСтрокаСодер.id_Короба = id_Блочка; 
			НоваяСтрокаСодер.id_Короба = Id_Короба;
			//--Данилова Е.В. 02.06.2026 
			НоваяСтрокаСодер.Количество = КоличествоВблочке;
			НоваяСтрокаСодер.КоличествоВНакладной = СтрокаТЧ.Количество;
			НоваяСтрокаСодер.Номенклатура = СтрокаТЧ.Номенклатура;
			НоваяСтрокаСодер.Отметка = Истина; 
			//Если ДобавлятьКСуществующим Тогда
			ОтборПоНоменклатуре = Новый Структура("Номенклатура", СтрокаТЧ.Номенклатура);
			СтрокиЛП = ТоварыЛПСозданные.НайтиСтроки(ОтборПоНоменклатуре);
			Если СтрокиЛП.Количество() > 0 Тогда
				НоваяСтрокаСодер.КоличествоВЛП =  СтрокиЛП[0].Количество;
			КонецЕсли;
			//КонецЕсли;
		Иначе 
			
			СообщитьПользователюСервер("Не найдены данные в матрице по " + Строка(ОтборПоНоменклатуре)); 
			Продолжить; 
		КонецЕсли;
		
	КонецЦикла;  
	
	//ОКОНЧАНИЕ 
	
	
	Объект.Коробки.Очистить();
	
	СодержимоеБлочкаКопия = Объект.СодержимоеБлочка.Выгрузить(,"id_Короба"); 
	СодержимоеБлочкаКопия.Свернуть("id_Короба");
	Для каждого СтрокаТЧ Из  СодержимоеБлочкаКопия Цикл
		
		ИдКоробки = СтрокаТЧ.id_Короба; 
		ДобавитьСтрокуВТЧКоробкиНаСервере(ИдКоробки,ТипКороба);  
		ПерезаполнитьРасчПоляТЧКоробки(ИдКоробки);
		
	КонецЦикла;
 
	РассчитатьКоличествоКоробокПоВведеннымДанным();
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросСоздатьЛП(ОтветНаВопрос,ДопПараметры) Экспорт
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда

		ТЗКоробов = ДопПараметры.ТЗКоробов;
		ТЗНераспр = ДопПараметры.ТЗНераспр;
		ДопПараметры = Новый Структура("ТЗКоробов,ТЗНераспр", ТЗКоробов, ТЗНераспр);
		Если ПроверитьСущЛисты() Тогда
			ОповещениеВопрос = Новый ОписаниеОповещения("ПослеОтветаНаВопросПометитьнаУдалениеЛП", ЭтотОбъект,
				ДопПараметры);
			ПоказатьВопрос(ОповещениеВопрос, "Пометить на удаление уже существующие листы переукладки?",
				РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);

		Иначе
			СформироватьЛистыПереукладки(ТЗКоробов, ТЗНераспр);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросПометитьнаУдалениеЛП(ОтветНаВопрос,ДопПараметры) Экспорт
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		ТЗКоробов = ДопПараметры.ТЗКоробов;
		ТЗНераспр = ДопПараметры.ТЗНераспр;
 		ПометитьнаУдалениеСущЛисты();  
 		СформироватьЛистыПереукладки(ТЗКоробов, ТЗНераспр);
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция ПолучитьРеквизитРНК(ИмяПоля)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РасходнаяНакладная.%ИмяПоля% КАК %ИмяПоля%
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	РасходнаяНакладная.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.ДокСсылка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяПоля%",ИмяПоля); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий(); 
	
	Возврат ВыборкаДетальныеЗаписи[ИмяПоля]; 	
	
КонецФункции
&НаСервере
Процедура ПометитьнаУдалениеСущЛисты()
	Запрос  = Новый Запрос;
	Запрос.Текст= "ВЫБРАТЬ
				  |	ЛистПереукладки.Ссылка как ЛП
				  |ИЗ
				  |	Документ.ЛистПереукладки КАК ЛистПереукладки
				  |ГДЕ
				  |	ЛистПереукладки.Проведен
				  |	И ЛистПереукладки.ДокОснование = &ДокОснование";
	Запрос.УстановитьПараметр("ДокОснование", СсылкаПоДокОбъекту());
	Результат = Запрос.Выполнить();
	ВЫборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекЛП=Выборка.ЛП.ПолучитьОбъект();
		ТекЛП.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПроверитьСущЛисты()
	
	Если ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.ГотоваКОтгрузке
		Или ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.Отгружена
		Или ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
		СообщитьПользователюСервер("Недопустимое состояние накладной");
		Возврат Ложь; 
	
	КонецЕсли;
	
	Запрос  = новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка как ЛП
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &ДокОснование";
	Запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой(); 
КонецФункции
&НаСервере
Функция СформироватьЛистыПереукладки (ТЗКоробовКонтрагента,ТЗЗаводскихКоробов);
	
	Если ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.ГотоваКОтгрузке
		Или ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.Отгружена
		Или ПолучитьРеквизитРНК("СостояниеНакладной") = Перечисления.СостоянияНакладной.ОтгруженаНаТранзитныйСклад Тогда
		СообщитьПользователюСервер("Недопустимое состояние накладной");
		Возврат 0;
	КонецЕсли;
	
	
	Запрос = новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ЗаданиеНабора.Ссылка КАК ЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора КАК ЗаданиеНабора
	|ГДЕ
	|	ЗаданиеНабора.Дата >= &Дата
	|	И ЗаданиеНабора.Проведен
	|	И ЗаданиеНабора.Накладная = &Накладная";
	запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить()-30*24*3600);
	запрос.УстановитьПараметр("Накладная",СсылкаПоДокОбъекту());
	
	Результат = запрос.Выполнить().Выбрать();
	пока Результат.Следующий() цикл
		ЗНБОбъект = Результат.ЗНБ.ПолучитьОбъект();
		НужноЗаписывать=ложь;
		СтрТЧ =ЗНБОбъект.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.ОжиданиеПереукладки);
		если СтрТЧ=Неопределено тогда
			если СтрТЧ.Пропустить=Истина тогда
				СтрТЧ.Пропустить=ложь;
				НужноЗаписывать=Истина;
			КонецЕсли;
		КонецЕсли;
		СтрТЧ=ЗНБОбъект.ПланируемыеСостояния.Найти(Перечисления.СостоянияНакладной.Переукладка);
		если СтрТЧ=Неопределено тогда
			если СтрТЧ.Пропустить=Истина тогда
				СтрТЧ.Пропустить=ложь;
				НужноЗаписывать=Истина;
			КонецЕсли;
		КонецЕсли;
		если НужноЗаписывать тогда
			ЗНБОбъект.записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;	
	КонецЦикла;

	
	ОбщийОбъем=0;
	ОбщееКоличествоКоробов=0;	
	СчСост=0;
	для каждого СтрТЗ из ТЗКоробовКонтрагента цикл
		СчСост=СчСост+1;
		
		для сч=1 по СтрТЗ.количествоКоробов цикл		
			если сч=СтрТЗ.количествоКоробов и  СтрТЗ.КоличествоБлочковНеПолногоКороба>0 тогда
				если СтрТЗ.Короб.товары.количество()>1 тогда
					СообщитьПользователюСервер("Некорректный расчёт неполного короба. Обратитесь к Кухарю А.Ю.");
					Продолжить;
				КонецЕсли;
				НовДок=Документы.ЛистПереукладки.СоздатьДокумент();
				НовДок.Автор=ПараметрыСеанса.Пользователь;
				НовДок.КоличествоДокумента=СтрТЗ.КоличествоБлочковНеПолногоКороба;
				НовДок.ТипКороба=СтрТЗ.короб;
				НовДок.ОбъемДокумента=СтрТЗ.короб.ТипКороба.Объем;
				ОбщийОбъем=ОбщийОбъем+СтрТЗ.короб.ТипКороба.Объем;
				ТипШК=Перечисления.ТипыШтрихКодов.Штука;
				ОбщееКоличествоКоробов=ОбщееКоличествоКоробов+1;
				СтрТов=НовДок.Товары.Добавить();
				СтрТов.Номенклатура=СтрТЗ.короб.товары.получить(0).номенклатура;
				СтрТов.Количество=СтрТЗ.КоличествоБлочковНеПолногоКороба;   
				СтрТов.ТипШК = ТипШК;
				НовДок.Дата=ТекущаяДатаСеанса();
				НовДок.ДокОснование=СсылкаПоДокОбъекту();
				НовДок.Записать(РежимЗаписиДокумента.Проведение);
				Продолжить;
			КонецЕсли;
			
			НовДок=Документы.ЛистПереукладки.СоздатьДокумент();
			НовДок.Автор=ПараметрыСеанса.Пользователь;
			НовДок.КоличествоДокумента=СтрТЗ.короб.КоличествоДокумента;
			НовДок.ОбъемДокумента=СтрТЗ.короб.ТипКороба.Объем;
			ОбщийОбъем=ОбщийОбъем+СтрТЗ.короб.ТипКороба.Объем;
			НовДок.ТипКороба=СтрТЗ.короб;			
			ТипШК=Перечисления.ТипыШтрихКодов.Штука;
			ОбщееКоличествоКоробов=ОбщееКоличествоКоробов+1;
			НовДок.Товары.Загрузить(СтрТЗ.короб.товары.выгрузить());
			НовДок.Дата=ТекущаяДатаСеанса();
			НовДок.ДокОснование=СсылкаПоДокОбъекту();
			НовДок.Записать(РежимЗаписиДокумента.Проведение);		
		КонецЦикла;
	КонецЦикла;
	
	СтруктураВозврата=Новый  Структура;
	СтруктураВозврата.Вставить("Объём",ОбщийОбъем);
	СтруктураВозврата.Вставить("КоличествоКоробок",ОбщееКоличествоКоробов);
	ПрописатьНомераКоробокЛП();
	Возврат СтруктураВозврата;
КонецФункции

&НаСервере
процедура ПрописатьНомераКоробокЛП()
	СтруктураРНК = Новый Структура;
	СтруктураРНК.Вставить("ДокОснование",СсылкаПоДокОбъекту());
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЛистПереукладки.Ссылка
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.ДокОснование = &ДокОснование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЛистПереукладки.Номер
	|АВТОУПОРЯДОЧИВАНИЕ";
	запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	Выборка = Запрос.Выполнить().Выбрать();
	//@skip-check bsl-variable-name-invalid
	Сч = 1;
	
	Пока Выборка.Следующий() Цикл
		ТекЛистПереукладки = Выборка.Ссылка;  
		Если ТекЛистПереукладки.Проведен = Ложь Тогда
			Продолжить;		
		КонецЕсли;
		НаборЗаписей = РегистрыСведений.ИнформацияШКЛП.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ШКЛистаПереукладки.Значение = ТекЛистПереукладки.Штрихкод;
		НаборЗаписей.Отбор.ШКЛистаПереукладки.использование = Истина;
		НаборЗаписей.Прочитать();
		СписокШК = Новый Соответствие;
		Для Каждого Запись ИЗ НаборЗаписей Цикл
			СписокШК.Вставить(Запись.НомерКоробкиЛП,Запись.ШК);	 
		КонецЦикла;
		ТекШКЛистаПереукладки = ТекЛистПереукладки.Штрихкод;
		НовыйНаборЗаписей = РегистрыСведений.ИнформацияШКЛП.СоздатьНаборЗаписей();
		НовыйНаборЗаписей.Отбор.ШКЛистаПереукладки.Значение = ТекЛистПереукладки.Штрихкод;
		НовыйНаборЗаписей.Отбор.ШКЛистаПереукладки.использование = Истина;
		НовыйНаборЗаписей.Отбор.ШК.Значение = ТекШКЛистаПереукладки;
		НовыйНаборЗаписей.Отбор.ШК.использование = Истина;
		НовыйНаборЗаписей.Прочитать();
		Для Каждого Запись Из НовыйНаборЗаписей Цикл
			Запись.НомерКоробки = Сч;
			Запись.НомерЛП=ТекЛистПереукладки.номер;
		КонецЦикла;
		Сч = Сч + 1;
		НовыйНаборЗаписей.Записать();
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПечатьКоробовКонтрагентаНаСервере(Естьошибки,ТЗКоробов,ТЗНераспр)
	
	//ОбъектПечати = Объект.ДокОбъект;
    
	Линия = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
	
	ТабДок	= Новый ТабличныйДокумент;
	ОбработкаОб = РеквизитФормыВЗначение("Объект"); 
	Макет = ОбработкаОб.ПолучитьМакет("Макет");
	
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОблЗаголовок.параметры.НомерДокумента = ПолучитьРеквизитРНК("Номер");
	ТабДок.Вывести(ОблЗаголовок);
	ОбщКолКоробов=0;
	ТабДок.Вывести(макет.ПолучитьОбласть("Шапка"));	
	
	ТЗТоварыРНК = ВернутьТоварыРНК();	
	
	ТЗКоробов=Новый ТаблицаЗначений;
	ТЗКоробов.Колонки.Добавить("Короб");
	ТЗКоробов.Колонки.Добавить("КоличествоКоробов");
	ТЗКоробов.Колонки.Добавить("КоличествоБлочковНеПолногоКороба");
	
	
	Запрос = Новый запрос;
	Запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
				  |	МатрицаКоробовКонтрагента.Ссылка как Матрица
				  |ИЗ
				  |	Документ.МатрицаКоробовКонтрагента КАК МатрицаКоробовКонтрагента
				  |ГДЕ
				  |	МатрицаКоробовКонтрагента.Контрагент = &Контрагент
				  |	И МатрицаКоробовКонтрагента.Дата >= &Дата
				  |
				  |УПОРЯДОЧИТЬ ПО
				  |	МатрицаКоробовКонтрагента.Дата УБЫВ";
	запрос.УстановитьПараметр("Контрагент", ПолучитьРеквизитРНК("Контрагент"));
	запрос.УстановитьПараметр("Дата",ПолучитьРеквизитРНК("Дата"));
	Результат = запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество()=0 тогда
		СообщитьПользователюСервер("Не обнаружена действующей матрицы коробов контрагента по текущей накладной.");
	иначе
		Матрица = результат.Получить(0).Матрица;
		
		Для Каждого СтрКор Из Матрица.КоробаКонтрагентов Цикл
			ТекКороб = СтрКор.Короб;
			//КоличествоКоробов = 0;
			НабралиКороб = Ложь;
			Пока Не НабралиКороб Цикл

				Для Каждого СтрНом Из ТекКороб.Товары Цикл
					ТекСтрока = ТЗТоварыРНК.Найти(СтрНом.Номенклатура);
					Если ТекСтрока = Неопределено Тогда
						НабралиКороб=Истина;
					КонецЕсли;
				КонецЦикла;
				СчВкоробе=0;
				СписокКоличеств  = Новый СписокЗначений;
				КолНеполного=0;
				Для Каждого СтрНом Из ТекКороб.Товары Цикл
					СчВкоробе=СчВкоробе + 1;
					ТекСтрока=ТЗТоварыРНК.Найти(СтрНом.Номенклатура);
					Если ТекСтрока = Неопределено Тогда
						НабралиКороб=Истина;
					Иначе
						Если ТекСтрока.количество >= СтрНом.Количество Тогда
							КолК=Цел(ТекСтрока.количество / СтрНом.Количество);
							ТекСтрока.количество=ТекСтрока.количество - КолК * СтрНом.Количество;

							Если ТекСтрока.количество > 0 Тогда
								ТекКолНеполного=ТекСтрока.количество;
								ТекСтрока.количество=0;
								КолНеполного=КолНеполного + ТекКолНеполного;
							КонецЕсли;
							СписокКоличеств.Добавить(КолК);
						ИначеЕсли СчВкоробе > 1 Тогда
							СообщитьПользователюСервер("Не корректное количество товара в заказе."
								+ СтрНом.Номенклатура.Наименование);
							Естьошибки = Истина; 
							Возврат ТабДок;
						Иначе
							НабралиКороб=Истина;
						КонецЕсли;
						Если НабралиКороб Тогда
							Прервать;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;

				Если СписокКоличеств.Количество() > 0 Тогда
					КолК=СписокКоличеств.Получить(0).Значение;
					Для Каждого СтрСп Из СписокКоличеств Цикл
						Если СтрСп.Значение <> КолК Тогда
							СообщитьПользователюСервер("Не корректное количество товара в коробе."
								+ ТекКороб.Наименование);
							Естьошибки = Истина; 
							Возврат ТабДок;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;

				Если Не НабралиКороб Тогда
					СтрКоробов=ТЗКоробов.Добавить();
					СтрКоробов.Короб=ТекКороб;
					СтрКоробов.количествоКоробов=КолК;
					ОбщКолКоробов=ОбщКолКоробов + КолК;
				КонецЕсли;
				Если КолНеполного > 0 Тогда
					СтрКоробов.количествоКоробов=СтрКоробов.количествоКоробов + 1;
					ОбщКолКоробов=ОбщКолКоробов + 1;
					СтрКоробов.КоличествоБлочковНеПолногоКороба=КолНеполного;
				КонецЕсли;

			КонецЦикла;
		КонецЦикла;

	КонецЕсли;
	
	ТЗНераспр=новый ТаблицаЗначений;
	ТЗНераспр.Колонки.Добавить("Номенклатура");
	ТЗНераспр.Колонки.Добавить("Количество");
	
	для каждого СтрТз из ТЗТоварыРНК Цикл
		если СтрТз.количество>0 тогда
			СтрН=ТЗНераспр.Добавить();
			ЗаполнитьЗначенияСвойств(СтрН,СтрТз);
		КонецЕсли;
	КонецЦикла;
	
	ТЗКоробов.Свернуть("Короб","количествоКоробов,КоличествоБлочковНеПолногоКороба");	
	
	для каждого СтрТз из ТЗКоробов цикл
		Высота=СтрТз.короб.товары.количество();
		для сч=1 по Высота цикл
			ОблСтрока=макет.ПолучитьОбласть("Строка");
			ОблСтрока.Параметры.СоставКороба=СтрТз.короб.товары.получить(сч-1).номенклатура;
			ОблСтрока.Параметры.КоличествоШтук=СтрТз.короб.товары.получить(сч-1).количество;
			ОблСтрока.Параметры.НаименованиеКороба=СтрТз.короб.наименование;
			ОблСтрока.Параметры.КоличествоКоробов=СтрТз.количествоКоробов;
			если СтрТз.КоличествоБлочковНеПолногоКороба=0 тогда
				ОблСтрока.Параметры.Короба=Строка(СтрТз.количествоКоробов)+"*("+Строка(СтрТз.короб.КоличествоДокумента)+" шт.) ";
			иначе
				ОблСтрока.Параметры.Короба=Строка(СтрТз.количествоКоробов-1)+"*("+Строка(СтрТз.короб.КоличествоДокумента)+" шт.) "+Символы.ПС+"1*("+Строка(СтрТз.КоличествоБлочковНеПолногоКороба)+" шт.)";
				
			КонецЕсли;	
			ТабДок.Вывести(ОблСтрока);
		КонецЦикла;
		
		ТекОбл=ТабДок.Область(ТабДок.ВысотаТаблицы-Высота+1,1,ТабДок.ВысотаТаблицы,ТабДок.ШиринаТаблицы);
		ТекОбл.Обвести(линия,линия,линия,линия);
		ТекОбл3=ТабДок.Область(ТабДок.ВысотаТаблицы-Высота+1,3,ТабДок.ВысотаТаблицы,3);
		ТекОбл4=ТабДок.Область(ТабДок.ВысотаТаблицы-Высота+1,4,ТабДок.ВысотаТаблицы,4);
		ТекОбл5=ТабДок.Область(ТабДок.ВысотаТаблицы-Высота+1,5,ТабДок.ВысотаТаблицы,5);
		текобл3.Объединить();
		текобл4.Объединить();
		ТекОбл5.Объединить();
	КонецЦикла;
	
	Для каждого СтрТз из ТЗНераспр цикл
		ОблСтрока=макет.ПолучитьОбласть("Строка");
		ОблСтрока.Параметры.СоставКороба=СтрТз.номенклатура;
		ОблСтрока.Параметры.КоличествоШтук=СтрТз.номенклатура.родитель.ШтукВКоробке;
		ОблСтрока.Параметры.НаименованиеКороба="Заводской короб "+СтрТз.номенклатура.наименование;
		ОблСтрока.Параметры.КоличествоКоробов=СтрТз.количество/СтрТз.номенклатура.родитель.ШтукВКоробке;
		ТабДок.Вывести(ОблСтрока);
		ОбщКолКоробов=ОбщКолКоробов+ОблСтрока.Параметры.КоличествоКоробов;
	КонецЦикла;
	ОблИтоги=Макет.ПолучитьОбласть("Итоги");
	ОблИтоги.Параметры.КоличествоКоробов=ОбщКолКоробов;
	ТабДок.Вывести(ОблИтоги);
	
	//ТабДок.Показать();
	
	
	запрос=новый Запрос;
	запрос.Текст="ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК КоличествоКоробок,
	|	СУММА(ЛистПереукладки.ОбъемДокумента) КАК ОбъемДокумента
	|ИЗ
	|	Документ.ЛистПереукладки КАК ЛистПереукладки
	|ГДЕ
	|	ЛистПереукладки.Проведен
	|	И ЛистПереукладки.ДокОснование = &ДокОснование";
	запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	результат=запрос.Выполнить().Выгрузить();
	
	ДокОбъектРНК = Объект.ДокСсылка.ПолучитьОбъект();
	ДокОбъектРНК.КоличествоКоробок = результат.Получить(0).КоличествоКоробок;
	ДокОбъектРНК.ОбъемКоробов =  результат.Получить(0).ОбъемДокумента;
	ДокОбъектРНК.Записать();	
	
	Возврат ТабДок; 
КонецФункции

