&НаКлиенте
Процедура ПечатьКоробовКонтрагента(Команда)
	Естьошибки = Ложь; 
	ТЗКоробов = неопределено;
	ТЗНераспр = Неопределено;
	ТабДокумент = ПечатьКоробовКонтрагентаНаСервере(Естьошибки,ТЗКоробов,ТЗНераспр);
	 
	Если Не Естьошибки Тогда
		ТабДокумент.Показать();
		ДопПараметры = Новый Структура("ТЗКоробов,ТЗНераспр",ТЗКоробов,ТЗНераспр);
		ОповещениеВопрос = Новый ОписаниеОповещения("ПослеОтветаНаВопросСоздатьЛП", ЭтотОбъект,ДопПараметры);
		ПоказатьВопрос(ОповещениеВопрос, "Сформировать листы переукладки?", РежимДиалогаВопрос.ДаНет, ,
			КодВозвратаДиалога.Нет);

	КонецЕсли;
КонецПроцедуры

