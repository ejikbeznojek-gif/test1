Процедура ПересчитатьОбъемКоробокНаСервере()
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст= "ВЫБРАТЬ
					  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК КоличествоКоробок,
					  |	СУММА(ЛистПереукладки.ОбъемДокумента) КАК ОбъемДокумента,
					  |	СУММА(ЛистПереукладки.ТипКороба.Объем) КАК ТипКоробаОбъем
					  |ИЗ
					  |	Документ.ЛистПереукладки КАК ЛистПереукладки
					  |ГДЕ
					  |	ЛистПереукладки.Проведен
					  |	И ЛистПереукладки.ДокОснование = &ДокОснование";
		Запрос.УстановитьПараметр("ДокОснование", СсылкаПоДокОбъекту());
		Результат = запрос.Выполнить().Выгрузить();
		ДокОбъектРНК = Объект.ДокСсылка.ПолучитьОбъект(); 
		ДокОбъектРНК.КоличествоКоробок=результат.Получить(0).КоличествоКоробок;
		ДокОбъектРНК.ОбъемКоробов=результат.Получить(0).ТипКоробаОбъем;
		ДокОбъектРНК.Записать();

		ЗаписатьКоличествоИОбъемКоробовВРегистр(СсылкаПоДокОбъекту(), результат.Получить(0).КоличествоКоробок,
			результат.Получить(0).ТипКоробаОбъем);
	Исключение
		СообщитьПользователюСервер("нет листов переукладки");
	КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура СоздатьЛистыПоБлочкамНаСервере()
	Если Не ПоБлочкам Тогда

		Возврат;

	КонецЕсли;

	Если Не СверитьКоличествоЗаполненноеСРНК() Тогда

		Возврат;

	КонецЕсли; 
	/////////с действ. алгоритма 
	ТекЗначениеКонстанты	=	Константы.ЗапускПереукладки.Получить();
	ТекПользователь			= 	ТекущийПользователь();
	Если ТекЗначениеКонстанты = Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
		Константы.ЗапускПереукладки.Установить(ТекПользователь);
	ИначеЕсли ТекЗначениеКонстанты = ТекПользователь Тогда //Ничего не делаем

	Иначе
		СообщитьПользователюСервер("В данный момент переукладка запущена у " + ТекЗначениеКонстанты
			+ " дождитесь окончания.");
		ЗаписатьВЛог("ОчередьОбработки", "Попытка начать переукладку. Пытался " + ТекПользователь + " ,помещал "
			+ ТекЗначениеКонстанты, "Информация");
		Возврат;
	КонецЕсли;

	ТекЗначениеКонстанты	=	Константы.ЗапускПереукладки.Получить(); //На всякий проверим, что константа установилась
	Если ТекЗначениеКонстанты = ТекПользователь Тогда
	Иначе
		СообщитьПользователюСервер("Не удалось начать переукладку. Попробуйте ещё раз.");
		ЗаписатьВЛог("ОчередьОбработки", "Не удалось записать константу ЗапускПереукладки - " + ТекПользователь,
			"Информация");
		Возврат;
	КонецЕсли;
	
	//++Данилова Е.В. 12.05.2026 SNL-201
	Если Не ДобавлятьКСуществующим Тогда

		Запрос = Новый Запрос;
		запрос.Текст =
		"ВЫБРАТЬ
		|	ЛистПереукладки.Ссылка как ЛП
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|ГДЕ
		|	ЛистПереукладки.Проведен
		|	И ЛистПереукладки.ДокОснование = &ДокОснование";
		Запрос.УстановитьПараметр("ДокОснование", СсылкаПоДокОбъекту());
		Результат	=	запрос.Выполнить().Выгрузить();

		Если Результат.Количество() > 0 Тогда

			Для Каждого СтрРез Из Результат Цикл
				ТекЛП = СтрРез.ЛП.ПолучитьОбъект();
				ТекЛП.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	//--Данилова Е.В. 12.05.2026 
	
	Если Объект.СоздаватьЗНА 
		//++Данилова Е.В. 12.05.2026 SNL-201
		И НЕ ДобавлятьКСуществующим тогда
		//--Данилова Е.В. 12.05.2026 
		 РезультатВыполнения = документы.ЗаданиеНаАгрегацию.РаспровестиЗНАПоНакладной(СсылкаПоДокОбъекту(),Истина);     
		 если не РезультатВыполнения.Успех тогда
			 СообщитьПользователюСервер(СтрСоединить(РезультатВыполнения.Ошибки,символы.ПС));
			 возврат;         
		 КонецЕсли;   	
	 КонецЕсли;
	///////////////////////////////
	 
	Если Объект.СоздаватьЗНА Тогда
		
		Для каждого СтрокаКоробок Из Объект.Коробки Цикл
			//ТипКоробаЗНА = СтрокаКоробок.ТипКороба; 
			КоличествоЛистовПереупаковки = СтрокаКоробок.Количество; 
			
			МенеджерВременныхТаблиц = Неопределено;
			//сразу комплектующие			
			
			//@skip-check query-in-loop
			ТЗТовары = ВыгрузитьТЧтоварыПоИдКоробки(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц);			
			
			//@skip-check query-in-loop
			СодержимоеБлочкаДляЗНА = ВыгрузитьСодержимоеБлочкаДляЗНА(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц); 
			
			//@skip-check query-in-loop
			БлочкиВсегоДляЗНА = ВыгрузитьСодержимоеВсегоБлочкиДляЗНА(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц); 
			
			

			СтруктураЗаполненияШапкиЗНА = новый Структура("ТипКороба,Товары,КоличествоКоробок,СодержимоеБлочка,БлочкиВсего,НеРазворачиватьКП"); 
			
			СтруктураЗаполненияШапкиЗНА.ТипКороба = СтрокаКоробок.ТипКороба;
			СтруктураЗаполненияШапкиЗНА.Товары = ТЗТовары;
			СтруктураЗаполненияШапкиЗНА.КоличествоКоробок = КоличествоЛистовПереупаковки;
			СтруктураЗаполненияШапкиЗНА.СодержимоеБлочка = СодержимоеБлочкаДляЗНА; 
			СтруктураЗаполненияШапкиЗНА.БлочкиВсего = БлочкиВсегоДляЗНА;
			СтруктураЗаполненияШапкиЗНА.НеРазворачиватьКП = истина; 			
						
			РезультатПолучения = Документы.ЗаданиеНаАгрегацию.НайтиСоздатьЗНАПоНакладнойИСтруктуреПараметров(СсылкаПоДокОбъекту(),СтруктураЗаполненияШапкиЗНА);
			если РезультатПолучения.Успех тогда
				ЗНА = РезультатПолучения.Данные;
				
				РезультатСоздания = Документы.ЗаданиеНаАгрегацию.ЗаполнитьЛистыПереукладкиПоЗНА(ЗНА,ДобавлятьКСуществующим); 
				
				если не РезультатСоздания.Успех тогда
					
					СообщитьПользователюСервер(СтрСоединить(РезультатСоздания.Ошибки,символы.ПС)); 					
					СообщитьПользователюСервер("Не удалось создать заполнить листы переукладки по ЗНА. Попробуйте ещё раз");  
					
				иначе 
					//Данилова Е.В. 12.05.2026 SNL-201
					//Документы.ЛистПереукладки.ПереномероватьВсеКоробкиНакладной(СсылкаПоДокОбъекту());
					СообщитьПользователюСервер("Создан документ "+ЗНА);
				КонецЕсли;         
			иначе
				СообщитьПользователюСервер(СтрСоединить(РезультатПолучения.Ошибки,символы.ПС));
			КонецЕсли;  
		КонецЦикла; 
	
	Иначе 
		Для каждого СтрокаКоробок Из Объект.Коробки Цикл 
			
			КоличествоЛистовПереупаковки = СтрокаКоробок.Количество; 
			
			для сч = 1 по КоличествоЛистовПереупаковки цикл
				НовДок	=	Документы.ЛистПереукладки.СоздатьДокумент();
				НовДок.Автор	=	ПараметрыСеанса.Пользователь;
				НовДок.КоличествоДокумента	=	0;
				НовДок.ТипКороба			=	СтрокаКоробок.ТипКороба;
				если СтрокаКоробок.ТипКороба	<>	Справочники.ТипыКоробов.НайтиПоКоду("0000000001") тогда 
					НовДок.ОбъемДокумента	=	СтрокаКоробок.ТипКороба.Объем;
				иначе
					НовДок.ОбъемДокумента =	Объем;
				КонецЕсли;
				
				//ТипШК			=	Перечисления.ТипыШтрихКодов.Штука;
				НовДок.Дата		=	ТекущаяДатаСеанса();
				НовДок.ДокОснование	=	СсылкаПоДокОбъекту();
				
				МенеджерВременныхТаблиц = Неопределено;
				//сразу комплектующие			
				//@skip-check query-in-loop
				ТЗТовары = ВыгрузитьТЧтоварыПоИдКоробки(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц);
				//@skip-check query-in-loop
				СодержимоеБлочкаДляЛП 	= ВыгрузитьСодержимоеБлочкаДляЗНА(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц); 
				//@skip-check query-in-loop
				БлочкиВсегоДляЛП 		= ВыгрузитьСодержимоеВсегоБлочкиДляЗНА(СтрокаКоробок.id_Короба,МенеджерВременныхТаблиц);
				
				для каждого СтрТЗ из ТЗТовары цикл
					
					СтрТЧ	=	НовДок.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(СтрТЧ,СтрТЗ); 
					СтрТЧ.ТипШК = Перечисления.ТипыШтрихКодов.Штука;
				КонецЦикла;
				НовДок.СодержимоеБлочка.Загрузить(СодержимоеБлочкаДляЛП);
				НовДок.БлочкиВсего.Загрузить(БлочкиВсегоДляЛП);
				
				НовДок.Записать(РежимЗаписиДокумента.Проведение);
				
				СообщитьПользователюСервер("Создан документ "+НовДок.Ссылка);
			КонецЦикла;
			
			
			
		КонецЦикла;
		
		запрос	=	Новый Запрос;
		запрос.Текст	= "ВЫБРАТЬ
						  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛистПереукладки.Ссылка) КАК КоличествоКоробок,
						  |	СУММА(ЛистПереукладки.ОбъемДокумента) КАК ОбъемДокумента
						  |ИЗ
						  |	Документ.ЛистПереукладки КАК ЛистПереукладки
						  |ГДЕ
						  |	ЛистПереукладки.Проведен
						  |	И ЛистПереукладки.ДокОснование = &ДокОснование";
		запрос.УстановитьПараметр("ДокОснование", СсылкаПоДокОбъекту());
		результат	=	запрос.Выполнить().Выгрузить();
		ДокОбъектРНК  = Объект.Докссылка.ПолучитьОбъект(); 
		ДокОбъектРНК.КоличествоКоробок	=	результат.Получить(0).КоличествоКоробок;
		ДокОбъектРНК.ОбъемКоробов		=	результат.Получить(0).ОбъемДокумента;
		ДокОбъектРНК.Записать();
		
		ЗаписатьКоличествоИОбъемКоробовВРегистр(СсылкаПоДокОбъекту(), результат.Получить(0).КоличествоКоробок,
			результат.Получить(0).ОбъемДокумента);	
		
	
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.СодержимоеБлочка Цикл
		
			//@skip-check query-in-loop
			ЗаполнитьДопПоляПоНоменклатуре(СтрокаТЧ);
		
		КонецЦикла;
	
	Константы.ЗапускПереукладки.Установить(Справочники.ФизическиеЛица.ПустаяСсылка());

КонецПроцедуры

&НаСервере
Функция ВыгрузитьСодержимоеВсегоБлочкиДляЗНА(ИдКоробки, МенеджерВременныхТаблиц)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТВсегоБлочков.id_Блочка КАК id_Блочка,
	|	ВТВсегоБлочков.Количество КАК Количество
	|ИЗ
	|	ВТВсегоБлочков КАК ВТВсегоБлочков
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтСодержимое КАК ВтСодержимое
	|		ПО ВТВсегоБлочков.id_Блочка = ВтСодержимое.id_Блочка
	|			И (ВтСодержимое.id_Короба = &id_Короба)";
	
	
	Запрос.УстановитьПараметр("id_Короба", ИдКоробки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	


КонецФункции // ВыгрузитьСодержимоеБлочка()



&НаСервере
Функция ВыгрузитьСодержимоеБлочкаДляЗНА(ИдКоробки, МенеджерВременныхТаблиц)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВтСодержимое.id_Блочка КАК id_Блочка,
	|	ВтСодержимое.Номенклатура КАК Номенклатура,
	|	СУММА(ВтСодержимое.Количество) КАК Количество
	|ИЗ
	|	ВтСодержимое КАК ВтСодержимое
	|ГДЕ
	|	ВтСодержимое.id_Короба = &id_Короба
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтСодержимое.id_Блочка,
	|	ВтСодержимое.Номенклатура";
	
	
	Запрос.УстановитьПараметр("id_Короба", ИдКоробки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	


КонецФункции 

&НаСервере
Функция ВыгрузитьТЧтоварыПоИдКоробки(ИдКоробки, МенеджерВременныхТаблиц)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВтСодержимое.id_Блочка КАК id_Блочка,
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	ВтСодержимое.Количество КАК Количество,
		|	ВтСодержимое.id_Короба КАК id_Короба
		|ПОМЕСТИТЬ ВтСодержимое
		|ИЗ
		|	&СодержимоеБлочка КАК ВтСодержимое
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВсегоБлочков.id_Блочка КАК id_Блочка,
		|	ВТВсегоБлочков.Количество КАК Количество
		|ПОМЕСТИТЬ ВТВсегоБлочков
		|ИЗ
		|	&ВсегоБлочков КАК ВТВсегоБлочков
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	СУММА(ВтСодержимое.Количество * ВТВсегоБлочков.Количество) КАК Количество
		|ИЗ
		|	ВТВсегоБлочков КАК ВТВсегоБлочков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтСодержимое КАК ВтСодержимое
		|		ПО ВТВсегоБлочков.id_Блочка = ВтСодержимое.id_Блочка
		|			И (ВтСодержимое.id_Короба = &id_Короба)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВтСодержимое.Номенклатура";
	
	Запрос.УстановитьПараметр("СодержимоеБлочка",Объект.СодержимоеБлочка.Выгрузить());
	Запрос.УстановитьПараметр("ВсегоБлочков",Объект.ВсегоБлочков.Выгрузить());
	Запрос.УстановитьПараметр("id_Короба", ИдКоробки);
	
	РезультатЗапроса = Запрос.Выполнить(); 
	МенеджерВременныхТаблиц = запрос.МенеджерВременныхТаблиц; 
	
	Возврат РезультатЗапроса.Выгрузить(); 	


КонецФункции // ВыгрузитьТЧтоварыПоИдКоробки() 


&НаКлиенте
Процедура КонтрольРаспределенияТоваровРНКНаКлиенте()
	Если СверитьКоличествоЗаполненноеСРНК() Тогда
		 
		 ПоказатьПредупреждение(,"Количество распределенное по блочкам и коробкам соответствует количеству в РНК");   	
	 Иначе 
		 ПоказатьПредупреждение(,"Количество распределенное по блочкам и коробкам НЕ соответствует количеству в РНК!!!");
	 КонецЕсли;
КонецПроцедуры

&НаСервере
Функция СверитьКоличествоЗаполненноеСРНК()
	// Кухарь А.Ю.  08.04.2026 начало
	если НеСверятьКоличество тогда
		Возврат Истина;
	КонецЕсли;
	// Кухарь А.Ю.  08.04.2026 конец
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВтСодержимое.id_Блочка КАК id_Блочка,
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	ВтСодержимое.Количество КАК Количество,
		|	ВтСодержимое.id_Короба КАК id_Короба
		|ПОМЕСТИТЬ ВтСодержимое
		|ИЗ
		|	&СодержимоеБлочка КАК ВтСодержимое
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВсегоБлочков.id_Блочка КАК id_Блочка,
		|	ВТВсегоБлочков.Количество КАК Количество
		|ПОМЕСТИТЬ ВТВсегоБлочков
		|ИЗ
		|	&ВсегоБлочков КАК ВТВсегоБлочков
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтКоробки.id_Короба КАК id_Короба,
		|	ВтКоробки.Количество КАК Количество
		|ПОМЕСТИТЬ ВтКоробки
		|ИЗ
		|	&Коробки КАК ВтКоробки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтСодержимое.Номенклатура КАК Номенклатура,
		|	СУММА(ВтСодержимое.Количество * ВТВсегоБлочков.Количество * ВтКоробки.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТВПравилах
		|ИЗ
		|	ВТВсегоБлочков КАК ВТВсегоБлочков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтСодержимое КАК ВтСодержимое
		|		ПО ВТВсегоБлочков.id_Блочка = ВтСодержимое.id_Блочка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтКоробки КАК ВтКоробки
		|		ПО (ВтКоробки.id_Короба = ВтСодержимое.id_Короба)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВтСодержимое.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
		|	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
		|ГДЕ
		|	РасходнаяНакладнаяТовары.Ссылка = &ДокОснование
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходнаяНакладнаяТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходнаяНакладнаяКомплектующие.Номенклатура КАК Номенклатура,
		|	СУММА(РасходнаяНакладнаяКомплектующие.Количество) КАК Количество
		|ПОМЕСТИТЬ ВтКомплектующие
		|ИЗ
		|	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
		|ГДЕ
		|	РасходнаяНакладнаяКомплектующие.Ссылка = &ДокОснование
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходнаяНакладнаяКомплектующие.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТовары.Номенклатура КАК Номенклатура,
		|	ВтТовары.Количество КАК Количество
		|ПОМЕСТИТЬ ВтТоварыРНК
		|ИЗ
		|	ВтТовары КАК ВтТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКомплектующие КАК ВтКомплектующие
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ВтКомплектующие.Номенклатура ЕСТЬ NULL
		|	И ВтТовары.Количество > 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВтКомплектующие.Номенклатура,
		|	ВтКомплектующие.Количество
		|ИЗ
		|	ВтКомплектующие КАК ВтКомплектующие
		|ГДЕ
		|	ВтКомплектующие.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТоварыРНК.Номенклатура КАК Номенклатура,
		|	ВтТоварыРНК.Количество КАК Количество,
		|	ЕСТЬNULL(ВТВПравилах.Количество, 0) КАК КоличествоВПравилахЗаполнения
		|ИЗ
		|	ВтТоварыРНК КАК ВтТоварыРНК
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВПравилах КАК ВТВПравилах
		|		ПО ВтТоварыРНК.Номенклатура = ВТВПравилах.Номенклатура
		|ГДЕ
		|	ВтТоварыРНК.Количество <> ЕСТЬNULL(ВТВПравилах.Количество, 0)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТВПравилах.Номенклатура,
		|	0,
		|	ВТВПравилах.Количество
		|ИЗ
		|	ВТВПравилах КАК ВТВПравилах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВтТоварыРНК КАК ВтТоварыРНК
		|		ПО ВТВПравилах.Номенклатура = ВтТоварыРНК.Номенклатура
		|ГДЕ
		|	ВтТоварыРНК.Номенклатура ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	Запрос.УстановитьПараметр("СодержимоеБлочка",Объект.СодержимоеБлочка.Выгрузить()); 
	Запрос.УстановитьПараметр("ВсегоБлочков",Объект.ВсегоБлочков.Выгрузить());
	Запрос.УстановитьПараметр("Коробки",Объект.Коробки.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
	
		Возврат Истина;
	Иначе 
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		
		Пока Выборка.Следующий() Цикл
		
			
			Текстошибки = СтрШаблон("Несоответствие по номенклатуре %1, количество в РНК %2, количество указанное %3",Выборка.Номенклатура,Выборка.Количество,Выборка.КоличествоВПравилахЗаполнения); 	
		    СообщитьПользователюСервер(Текстошибки); 
			
		КонецЦикла;
		
		Возврат Ложь; 
	
	КонецЕсли;


КонецФункции


