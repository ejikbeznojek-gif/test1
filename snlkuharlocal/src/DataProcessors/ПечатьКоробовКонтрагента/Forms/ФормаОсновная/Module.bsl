&НаКлиенте
Процедура ЗаполнитьДопПоляПоНоменклатуреНаКлиенте(СтрокаТЧ)
	СтруктураДанных = ДопПоляПоНоменклатуреНаСервере(СтрокаТЧ.Номенклатура);  
	ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтруктураДанных); 	
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьДопПоляПоНоменклатуре(СтрокаТЧ)
	СтруктураДанных = ДопПоляПоНоменклатуреНаСервере(СтрокаТЧ.Номенклатура);  
	ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтруктураДанных); 	
КонецПроцедуры

&НаСервере  
Функция ДопПоляПоНоменклатуреНаСервере(Номенклатура)
	Запрос = новый Запрос;
	Запрос.текст = ТекстЗапросаРНКЛП();
	Запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаВидимости.Получить());
	Запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту()); 
	Запрос.УстановитьПараметр("ОтборПоНоменклатуре",Истина);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура); 
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	СтруктураДанных = Новый Структура("КоличествоВНакладной,КоличествоВЛП",0,0); 
		
	Если Выборка.Следующий() Тогда	
		СтруктураДанных.КоличествоВНакладной  = Выборка.КоличествоРНК; 	
	    СтруктураДанных.КоличествоВЛП		  = Выборка.КоличествоЛП;
	КонецЕсли; 
	
	Возврат СтруктураДанных; 
	
КонецФункции

