Функция ПодборПоКоробамНаСервере()
	
	СписокТоваров=новый Массив();
	
	
	Запрос = Новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	СУММА(ЛистНабораТовары.Количество) КАК Количество,
	|	ЛистНабораТовары.Номенклатура,
	|	ЛистНабораТовары.Номенклатура.Код КАК КодТовара
	|ИЗ
	|	Документ.ЛистПереукладки.Товары КАК ЛистНабораТовары
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.Дата >= &Дата
	|	И ЛистНабораТовары.Ссылка.Проведен
	|	И ЛистНабораТовары.Ссылка.ДокОснование = &ДокОснование
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛистНабораТовары.Номенклатура";
	запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаВидимости.Получить());
	запрос.УстановитьПараметр("ДокОснование",СсылкаПоДокОбъекту());
	ТЗЛП=запрос.Выполнить().выгрузить();
	
	ТоварыПоДокОбРНК = ВернутьТоварыРНК();
	Для каждого СтрТЧ из ТоварыПоДокОбРНК цикл
		СтрЛП=ТЗЛП.Найти(СтрТЧ.Номенклатура);
		если СтрЛП<>Неопределено тогда
			Если СтрЛП.Количество>=СтрТЧ.Количество тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		если СтрТЧ.Количество=0 тогда Продолжить;КонецЕсли;
		СписокТоваров.Добавить(СтрТЧ.Номенклатура);
	КонецЦикла;
	
	Возврат СписокТоваров; 

КонецФункции
&НаКлиенте
Процедура ПослеВыбораНоменклатурыПоБлочкам(ВыбранноеЗначение,ДопПараметры) экспорт
	Если ВыбранноеЗначение = неопределено Тогда
		Возврат; 
	КонецЕсли;
	ТипВыбранногоЗначения = ТипЗнч(ВыбранноеЗначение);
	Если  ТипВыбранногоЗначения=Тип("Массив") Тогда
		
		Для каждого СтрМасс из ВыбранноеЗначение цикл
			СтрокаТЧ				=	Объект.СодержимоеБлочка.Добавить(); 
			СтрокаТЧ.Номенклатура	=	СтрМасс;
			СтрокаТЧ.Количество		=	1;
			СтрокаТЧ.Отметка = истина; 
			//@skip-check query-in-loop
			ЗаполнитьДопПоляПоНоменклатуреНаКлиенте(СтрокаТЧ);			 
			//@skip-check query-in-loop
			//ЗаполнитьidБлочка(СтрокаТЧ);
			ЗаполнитьidБлочканаКлиенте(СтрокаТЧ); 
		КонецЦикла; 
		
		
	КонецЕсли;
КонецПроцедуры

