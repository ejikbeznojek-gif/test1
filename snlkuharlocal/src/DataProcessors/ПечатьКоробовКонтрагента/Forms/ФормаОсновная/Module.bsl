	Если СтрТЧобр.КоличествоВЛП >= СтрТЧобр.КоличествоВНакладной Тогда
		СтрТЧобр.Отметка = Ложь;
	Иначе 
		СтрТЧобр.Отметка = Истина;
	КонецЕсли;
