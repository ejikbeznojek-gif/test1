	//запрос.УстановитьПараметр("Документ",Документ.ссылка);
	//запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	//результат=запрос.Выполнить().Выгрузить();
	//ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(результат.Получить(0).Паллета,Документ.ссылка);
	ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(Документы.Паллета.ПустаяСсылка(),Документ.ссылка);
	
	//Кухарь 26.12.17 конец
	
	если ТЗСтрокМатрицы=Неопределено тогда Возврат ТЗМатериалов;КонецЕсли;
	
	
	Для каждого СтрМасс из ТЗСтрокМатрицы цикл
		
		запрос.Текст="ВЫБРАТЬ
		|	ВидыНормРасходаМатериалов.Ссылка КАК ВидНормыСсылка,
		|	ВидыНормРасходаМатериалов.Наименование КАК ВидНормыНаименование,
		|	ВидыНормРасходаМатериалов.ИмяНормыРасхода КАК ИмяНормыРасхода,
		|	ВидыНормРасходаМатериалов.ЗначениеНормыРасхода КАК ЗначениеНормыРасхода,
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода КАК Владелец
		|ИЗ
		|	Справочник.ВидыНормРасходаМатериалов КАК ВидыНормРасходаМатериалов
		|ГДЕ
		|	ВидыНормРасходаМатериалов.ПометкаУдаления = ЛОЖЬ
		|	И ВидыНормРасходаМатериалов.ИмяНормыРасхода = &ИмяНормыРасхода";
		запрос.УстановитьПараметр("ИмяНормыРасхода",СтрМасс.ИмяНормыРасхода);
		НормаТекущейНоменклатуры=запрос.Выполнить().Выгрузить();
		
		
		СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
		СтрокаТЗМатериалов.Номенклатура=СтрМасс.Номенклатура;
		
		
		если СтрМасс.НормаРасхода = 0 тогда
			если НормаТекущейНоменклатуры.Количество()>=1 тогда
				СтрокаТЗМатериалов.Количество=НормаТекущейНоменклатуры.Получить(0).ЗначениеНормыРасхода;
			иначе
				СтрокаТЗМатериалов.Количество=0;
			КонецЕсли;
		иначе 
			СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода;
		КонецЕсли;
		
		СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествоПаллет;
		
		если СтрМасс.НесколькоПозиций и Документ.ссылка.метаданные().имя="РасходнаяНакладная" тогда
			Запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			|	РеквизитыСправочников.ЗначениеРеквизита
			|ИЗ
			|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
			|ГДЕ
			|	РеквизитыСправочников.Справочник = &Справочник
			|	И РеквизитыСправочников.ИмяРеквизита = &ИмяРеквизита";	
			запрос.УстановитьПараметр("Справочник",Документ[СтрМасс.ИсточникДругихПозиций]);
			запрос.УстановитьПараметр("ИмяРеквизита",СтрМасс.РеквизитИсточникаДругихПозиций);
			результат=запрос.Выполнить().Выбрать();
			пока результат.Следующий() цикл
				СтрокаТЗМатериалов.Номенклатура=результат.ЗначениеРеквизита;
			КонецЦикла;
			
			
		КонецЕсли;
		
		
	КонецЦикла;
	
	
	
	возврат ТЗМатериалов;
КонецФункции


Функция ОбработатьНакладную(Документ,ТЗМатериалов)
	ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(Документ);
	
	если ТЗСтрокМатрицы=Неопределено тогда Возврат ТЗМатериалов;КонецЕсли;
	
	
	Для каждого СтрМасс из ТЗСтрокМатрицы цикл
		СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
		СтрокаТЗМатериалов.количество=СтрМасс.НормаРасхода;
		СтрокаТЗМатериалов.номенклатура=СтрМасс.Номенклатура;
		если СтрМасс.НаКаждуюШтукуОтдельно тогда
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествоДокумента;
		ИначеЕсли СтрМасс.НаКаждуюКоробкуОтдельно тогда
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*документ.количествокоробок;
		ИначеЕсли СтрМасс.НаКаждыйБлочокОтдельно тогда
			КоличествоБлочков=0;
			для каждого СтрТч из документ.товары цикл
				если СтрТч.номенклатура.родитель.ШтукВКоробочке=0 тогда Продолжить;КонецЕсли;
				КоличествоБлочков=КоличествоБлочков+СтрТч.количество/СтрТч.номенклатура.родитель.ШтукВКоробочке;
			КонецЦикла;
			КоличествоБлочков=Окр(КоличествоБлочков,0);
			СтрокаТЗМатериалов.количество=СтрокаТЗМатериалов.количество*КоличествоБлочков;
			
		КонецЕсли;
	КонецЦикла;
	
	
	Возврат ТЗМатериалов;
КонецФункции


Функция СформироватьСписокСтрокМатрицы (Документ,накладная=Неопределено)
	
	
	если накладная=Неопределено тогда
		если Документ.метаданные().имя="ЛистНабора" или Документ.метаданные().имя="ЛистПереукладки" тогда
			ДокументСклада=Документ.ДокОснование;
		ИначеЕсли Документ.метаданные().имя="Паллета"  тогда
			если документ.ЛистыНабора.количество()>0 тогда
				ДокументСклада=документ.ЛистыНабора.получить(0).документ;
			иначе 
				возврат Неопределено;
			КонецЕсли;
			
		иначе
			ДокументСклада=документ.ссылка;
		КонецЕсли;
	иначе
		ДокументСклада=накладная
	КонецЕсли;
	
	
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	МатрицаРасходаМатериаловНормыРасхода.ВидДокумента,
	|	МатрицаРасходаМатериаловНормыРасхода.Номенклатура,
	|	МатрицаРасходаМатериаловНормыРасхода.ВидДопОбработки,
	|	МатрицаРасходаМатериаловНормыРасхода.НормаРасхода,
	|	МатрицаРасходаМатериаловНормыРасхода.ТипШтрихКода,
	|	МатрицаРасходаМатериаловНормыРасхода.НаКаждуюКоробкуОтдельно,
	|	МатрицаРасходаМатериаловНормыРасхода.ИмяНормыРасхода,
	|	МатрицаРасходаМатериаловНормыРасхода.НесколькоПозиций,
	|	МатрицаРасходаМатериаловНормыРасхода.ИсточникДругихПозиций,
	|	МатрицаРасходаМатериаловНормыРасхода.РеквизитИсточникаДругихПозиций,
	|	МатрицаРасходаМатериаловНормыРасхода.НаКаждыйБлочокОтдельно,
	|	МатрицаРасходаМатериаловНормыРасхода.НаКаждуюШтукуОтдельно,
	|	МатрицаРасходаМатериаловНормыРасхода.НаКаждуюШтукуПереклейкиОтдельно
	|ИЗ
	|	Справочник.МатрицаРасходаМатериалов.НормыРасхода КАК МатрицаРасходаМатериаловНормыРасхода
	|ГДЕ
	|	 МатрицаРасходаМатериаловНормыРасхода.ВидДокумента = &ВидДокумента
	    // Кухарь А.Ю.  11.08.2022 начало
		// Отбор по складу не нужен
		  //| И	МатрицаРасходаМатериаловНормыРасхода.Ссылка.Склад В ИЕРАРХИИ(&Склад)
		// Кухарь А.Ю.  11.08.2022 конец
		
	|	И МатрицаРасходаМатериаловНормыРасхода.Ссылка.ПометкаУдаления = ЛОЖЬ";
		// Кухарь А.Ю.  11.08.2022 начало
		// Отбор по складу не нужен
		//	запрос.УстановитьПараметр("Склад",ДокументСклада.Склад.Родитель);	
		 
		// Кухарь А.Ю.  11.08.2022 конец
		

	
	запрос.УстановитьПараметр("ВидДокумента",Документ.Метаданные().Имя);
	
	
	ТЗПереченьРасходниковВрем=запрос.Выполнить().Выгрузить();		
	ТЗПереченьРасходников=ТЗПереченьРасходниковВрем.Скопировать();
	ТЗПереченьРасходников.Очистить();
	
	Для каждого СтрТЗВрем из ТЗПереченьРасходниковВрем цикл
		//Кухарь 24.09.17 начало
		//Лишний отбор
		//если СтрТЗВрем.ТипШтрихКода<>Перечисления.ТипыШтрихКодов.ПустаяСсылка() и СтрТЗВрем.ТипШтрихКода<>Документ.типШК тогда
		//	Продолжить;
		//КонецЕсли;
		//Кухарь 24.09.17 конец		
		если  ДокументСклада.метаданные().имя="РасходнаяНакладная"  тогда
			если СтрТЗВрем.ВидДопОбработки<>Справочники.ВидыДопОбработки.ПустаяСсылка()  и ДокументСклада.ДопОбработка тогда
				если ДокументСклада.допобработки.найти(СтрТЗВрем.ВидДопОбработки) = Неопределено тогда
					Продолжить;
				КонецЕсли;
			ИначеЕсли  СтрТЗВрем.ВидДопОбработки<>Справочники.ВидыДопОбработки.ПустаяСсылка() и не ДокументСклада.ДопОбработка тогда
				Продолжить;
				
			КонецЕсли;
		КонецЕсли;
		
		если СтрТЗВрем.ВидДопОбработки<>Справочники.ВидыДопОбработки.ПустаяСсылка() и ДокументСклада.метаданные().имя="Перемещение"  тогда
			если ДокументСклада.пунктдоставки.ВидыДопОбработок.найти(СтрТЗВрем.ВидДопОбработки) = Неопределено тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		
		СтрТЗ=ТЗПереченьРасходников.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЗ,СтрТЗВрем);		
	КонецЦикла;
	
	если ТЗПереченьРасходников.Количество()>0 тогда
		Возврат ТЗПереченьРасходников;
	иначе
		Возврат Неопределено;
	КонецЕсли;
	
	
КонецФункции

Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	// Кухарь А.Ю.  04.09.2025 начало
	//НачПериода=Константы.ДатаЗапретаРедактирования.Получить()-31*86400;     
	НачПериода=ТекущаяДата()-9*86400;        
	// Кухарь А.Ю.  04.09.2025 конец
	
	КонПериода=ТекущаяДата();
	
	Выборка=ПланыОбмена.Основной.Выбрать();	
	СписокУзловПолучателей=новый Массив;
	Пока Выборка.Следующий() Цикл
		Если  выборка.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение  Тогда	
			СписокУзловПолучателей.Добавить(Выборка.Ссылка);
			Прервать;
		КонецЕсли;
	КонецЦикла;		
	
	////////////////////////////////////////Трудозатраты +++
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПланНабора.Ссылка КАК ПланНабора
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	ПланНабора.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ПланНабора.Проведен
	|	И ПланНабора.ДокОснование.Проведен
	|	И ПланНабора.ДокОснование.ЭтоРаскомплектация ЕСТЬ NULL
	|	И ПланНабора.Накладная.ТрудозатратыНаНабор = 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПланНабора.Дата";
	запрос.УстановитьПараметр("Дата1",НачПериода);
	запрос.УстановитьПараметр("Дата2",КонецДня(КонПериода));
	результат=запрос.Выполнить().Выбрать();

	Пока результат.Следующий() цикл
		Заполнить(результат.ПланНабора);
	КонецЦикла;
	////////////////////////////////////////Трудозатраты ---		
	
	
	//////////////////Заполним расходники по старой схеме			
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходнаяНакладная.РасходныеМатериалы КАК Док
	|ГДЕ
	|	Док.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Док.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Док.Ссылка
	|ИЗ
	|	Документ.Перемещение.РасходныеМатериалы КАК Док
	|ГДЕ
	|	Док.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Док.Ссылка.Проведен";
	запрос.УстановитьПараметр("Дата1",НачПериода);
	запрос.УстановитьПараметр("Дата2",КонецДня(КонПериода));
	
	СписокДок=запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Док
	|ГДЕ
	|	Док.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Док.Проведен
	|	И Док.Отгружен = &Отгружен
	|	И НЕ Док.Ссылка В (&СписокДок)
	|	И Док.Контрагент = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Док.Ссылка
	|ИЗ
	|	Документ.Перемещение КАК Док
	|ГДЕ
	|	Док.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Док.Проведен
	|	И НЕ Док.Ссылка В (&СписокДок)
	|	И Док.Контрагент = &Контрагент
	|	И Док.Отгружен = &Отгружен";
	запрос.УстановитьПараметр("Дата1",НачПериода);
	запрос.УстановитьПараметр("Дата2",КонецДня(КонПериода));
	запрос.УстановитьПараметр("Отгружен",Перечисления.Отгружен.Отгружен);
	запрос.УстановитьПараметр("СписокДок",СписокДок);
	//если не ЗначениеЗаполнено(Контрагент) тогда
	запрос.Текст=СтрЗаменить(запрос.Текст,"И Док.Контрагент = &Контрагент","");
	//иначе
