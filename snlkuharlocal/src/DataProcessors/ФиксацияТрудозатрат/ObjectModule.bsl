Перем СписокУзловПолучателей; 
Перем НачПериода;
Перем КонПериода;

Процедура Заполнить(ТекПланНабора)
	//Набор
	запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПланНаборатБрэндов.НачалоНабора,
	|	ПланНаборатБрэндов.ОкончаниеНабора,
	|	ПланНаборатБрэндов.НачалоСканировки,
	|	ПланНаборатБрэндов.ОкончаниеСканировки,
	|	ПланНаборатБрэндов.НачалоДопОбработки,
	|	ПланНаборатБрэндов.ОкончаниеДопОбработки,
	|	ПланНаборатБрэндов.НачалоПаллетирования,
	|	ПланНаборатБрэндов.ОкончаниеПаллетирования,
	|	ПланНаборатБрэндов.НачалоТермоусадки,
	|	ПланНаборатБрэндов.ОкончаниеТермоусадки,
	|	ПланНаборатБрэндов.Ссылка,
	|	ПланНаборатБрэндов.ОстановкаНабора,
	|	ПланНаборатБрэндов.ОстановкаСканирования,
	|	ПланНаборатБрэндов.ОстановкаДопОбработки
	|ПОМЕСТИТЬ т1
	|ИЗ
	|	Документ.ПланНабора.тБрэндов КАК ПланНаборатБрэндов
	|ГДЕ
	|	ПланНаборатБрэндов.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т2.НачалоНабора,
	|	т2.ОкончаниеНабора,
	|	т2.НачалоСканировки,
	|	т2.ОкончаниеСканировки,
	|	т2.НачалоДопОбработки,
	|	т2.ОкончаниеДопОбработки,
	|	т2.НачалоПаллетирования,
	|	т2.ОкончаниеПаллетирования,
	|	т2.НачалоТермоусадки,
	|	т2.ОкончаниеТермоусадки,
	|	т2.Ссылка,
	|	т2.ОстановкаНабора,
	|	т2.ОстановкаСканирования,
	|	т2.ОстановкаДопОбработки
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		т1.НачалоНабора КАК НачалоНабора,
	|		т1.ОкончаниеНабора КАК ОкончаниеНабора,
	|		&ПустаяДата КАК НачалоСканировки,
	|		&ПустаяДата КАК ОкончаниеСканировки,
	|		&ПустаяДата КАК НачалоДопОбработки,
	|		&ПустаяДата КАК ОкончаниеДопОбработки,
	|		&ПустаяДата КАК НачалоПаллетирования,
	|		&ПустаяДата КАК ОкончаниеПаллетирования,
	|		&ПустаяДата КАК НачалоТермоусадки,
	|		&ПустаяДата КАК ОкончаниеТермоусадки,
	|		т1.Ссылка КАК Ссылка,
	|		т1.ОстановкаНабора КАК ОстановкаНабора,
	|		0 КАК ОстановкаСканирования,
	|		0 КАК ОстановкаДопОбработки
	|	ИЗ
	|		т1 КАК т1
	|	ГДЕ
	|		т1.НачалоНабора <> &ПустаяДата
	|		И т1.ОкончаниеНабора <> &ПустаяДата
	//|		И (РАЗНОСТЬДАТ(т1.НачалоНабора, т1.ОкончаниеНабора, СЕКУНДА) - т1.ОстановкаНабора) / 3600 < 10
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.НачалоСканировки,
	|		т1.ОкончаниеСканировки,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.Ссылка,
	|		0,
	|		т1.ОстановкаСканирования,
	|		0
	|	ИЗ
	|		т1 КАК т1
	|	ГДЕ
	|		т1.НачалоСканировки <> &ПустаяДата
	|		И т1.ОкончаниеСканировки <> &ПустаяДата
	//|		И (РАЗНОСТЬДАТ(т1.НачалоСканировки, т1.ОкончаниеСканировки, СЕКУНДА) - т1.ОстановкаСканирования) / 3600 < 10
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.НачалоДопОбработки,
	|		т1.ОкончаниеДопОбработки,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.Ссылка,
	|		0,
	|		0,
	|		т1.ОстановкаДопОбработки
	|	ИЗ
	|		т1 КАК т1
	|	ГДЕ
	|		т1.НачалоДопОбработки <> &ПустаяДата
	|		И т1.ОкончаниеДопОбработки <> &ПустаяДата
	//|		И (РАЗНОСТЬДАТ(т1.НачалоДопОбработки, т1.ОкончаниеДопОбработки, СЕКУНДА) - т1.ОстановкаДопОбработки) / 3600 < 10
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.НачалоПаллетирования,
	|		т1.ОкончаниеПаллетирования,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.Ссылка,
	|		0,
	|		0,
	|		0
	|	ИЗ
	|		т1 КАК т1
	|	ГДЕ
	|		т1.НачалоПаллетирования <> &ПустаяДата
	|		И т1.ОкончаниеПаллетирования <> &ПустаяДата
	//|		И РАЗНОСТЬДАТ(т1.НачалоПаллетирования, т1.ОкончаниеПаллетирования, СЕКУНДА) / 3600 < 10
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		&ПустаяДата,
	|		т1.НачалоТермоусадки,
	|		т1.ОкончаниеТермоусадки,
	|		т1.Ссылка,
	|		0,
	|		0,
	|		0
	|	ИЗ
	|		т1 КАК т1
	|	ГДЕ
	|		т1.НачалоТермоусадки <> &ПустаяДата
	//|		И РАЗНОСТЬДАТ(т1.НачалоТермоусадки, т1.ОкончаниеТермоусадки, СЕКУНДА) / 3600 < 10
	|		И т1.ОкончаниеТермоусадки <> &ПустаяДата) КАК т2";		  
	запрос.УстановитьПараметр("Ссылка",ТекПланНабора);		
	запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
	результат=запрос.Выполнить().Выгрузить();
	///////////////////////////////////////////////////Набор
	ТекТЗ=результат.Скопировать();	
	ТекТЗ.Свернуть("НачалоНабора,ОкончаниеНабора,ОстановкаНабора");
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("ОкончаниеНабора",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("НачалоНабора",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	Если ТекТЗ.Количество()=0 тогда
		ВремяНаНабор=0;
		ТрудозатратыНаНабор=0;
	иначе
		НачалоНабора='21000101';
		ОкончаниеНабора=ПустаяДата();
		ТрудозатратыНаНабор=0;
		Для каждого СтрТЗ из ТекТЗ цикл
			НачалоНабора=Мин(НачалоНабора,СтрТЗ.НачалоНабора);
			ОкончаниеНабора=Макс(ОкончаниеНабора,СтрТЗ.ОкончаниеНабора);
			ТрудозатратыНаНабор=ТрудозатратыНаНабор+ СтрТЗ.ОстановкаНабора+(СтрТЗ.ОкончаниеНабора-СтрТЗ.НачалоНабора)	
		КонецЦикла;
		ТрудозатратыНаНабор=ТрудозатратыНаНабор/3600;
		ВремяНаНабор=(ОкончаниеНабора-НачалоНабора)/3600;
	КонецЕсли;
	///////////////////////////////////////////////////Набор	
	
	
	///////////////////////////////////////////////////Сканирование
	ТекТЗ=результат.Скопировать();	
	ТекТЗ.Свернуть("НачалоСканировки,ОкончаниеСканировки,ОстановкаСканирования");
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("ОкончаниеСканировки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("НачалоСканировки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	Если ТекТЗ.Количество()=0 тогда
		ВремяНаСканировку=0;
		ТрудозатратыНаСканировку=0;
	иначе
		НачалоСканировки='21000101';
		ОкончаниеСканировки=ПустаяДата();
		ТрудозатратыНаСканировку=0;
		Для каждого СтрТЗ из ТекТЗ цикл
			НачалоСканировки=Мин(НачалоСканировки,СтрТЗ.НачалоСканировки);
			ОкончаниеСканировки=Макс(ОкончаниеСканировки,СтрТЗ.ОкончаниеСканировки);
			ТрудозатратыНаСканировку=ТрудозатратыНаСканировку+ СтрТЗ.ОстановкаСканирования+ (СтрТЗ.ОкончаниеСканировки-СтрТЗ.НачалоСканировки);	
		КонецЦикла;
		ТрудозатратыНаСканировку=ТрудозатратыНаСканировку/3600;
		ВремяНаСканировку=(ОкончаниеСканировки-НачалоСканировки)/3600;
	КонецЕсли;
	///////////////////////////////////////////////////Сканирование	
	
	
	///////////////////////////////////////////////////Доп обработка
	ТекТЗ=результат.Скопировать();	
	ТекТЗ.Свернуть("НачалоДопОбработки,ОкончаниеДопОбработки,ОстановкаДопОбработки");
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("ОкончаниеДопОбработки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("НачалоДопОбработки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	Если ТекТЗ.Количество()=0 тогда
		ВремяНаДопОбработку=0;
		ТрудозатратыНаДопОбработку=0;
	иначе
		НачалоДопОбработки='21000101';
		ОкончаниеДопОбработки=ПустаяДата();
		ТрудозатратыНаДопОбработку=0;
		Для каждого СтрТЗ из ТекТЗ цикл
			НачалоДопОбработки=Мин(НачалоДопОбработки,СтрТЗ.НачалоДопОбработки);
			ОкончаниеДопОбработки=Макс(ОкончаниеДопОбработки,СтрТЗ.ОкончаниеДопОбработки);
			ТрудозатратыНаДопОбработку=ТрудозатратыНаДопОбработку+ СтрТЗ.ОстановкаДопОбработки+  (СтрТЗ.ОкончаниеДопОбработки-СтрТЗ.НачалоДопОбработки);	
		КонецЦикла;
		ТрудозатратыНаДопОбработку=ТрудозатратыНаДопОбработку/3600;
		ВремяНаДопОбработку=(ОкончаниеДопОбработки-НачалоДопОбработки)/3600;
	КонецЕсли;
	///////////////////////////////////////////////////Доп обработка	
	
	///////////////////////////////////////////////////Паллетирование
	ТекТЗ=результат.Скопировать();	
	ТекТЗ.Свернуть("НачалоПаллетирования,ОкончаниеПаллетирования");
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("ОкончаниеПаллетирования",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("НачалоПаллетирования",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	Если ТекТЗ.Количество()=0 тогда
		ВремяНаПаллетирование=0;
		ТрудозатратыНаПаллетирование=0;
	иначе
		НачалоПаллетирования='21000101';
		ОкончаниеПаллетирования=ПустаяДата();
		ТрудозатратыНаПаллетирование=0;
		Для каждого СтрТЗ из ТекТЗ цикл
			НачалоПаллетирования=Мин(НачалоПаллетирования,СтрТЗ.НачалоПаллетирования);
			ОкончаниеПаллетирования=Макс(ОкончаниеПаллетирования,СтрТЗ.ОкончаниеПаллетирования);
			ТрудозатратыНаПаллетирование=ТрудозатратыНаПаллетирование+ (СтрТЗ.ОкончаниеПаллетирования-СтрТЗ.НачалоПаллетирования);	
		КонецЦикла;
		ТрудозатратыНаПаллетирование=ТрудозатратыНаПаллетирование/3600;
		ВремяНаПаллетирование=(ОкончаниеПаллетирования-НачалоПаллетирования)/3600;
	КонецЕсли;
	///////////////////////////////////////////////////Паллетирование
	
	
	///////////////////////////////////////////////////Термоусадка
	ТекТЗ=результат.Скопировать();	
	ТекТЗ.Свернуть("НачалоТермоусадки,ОкончаниеТермоусадки");
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("ОкончаниеТермоусадки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	МассПустаяДата=ТекТЗ.НайтиСтроки(Новый Структура("НачалоТермоусадки",ПустаяДата()));
	для каждого СтрМасс из МассПустаяДата цикл
		ТекТЗ.Удалить(ТекТЗ.Индекс(СтрМасс));
	КонецЦикла;
	Если ТекТЗ.Количество()=0 тогда
		ВремяНаТермоусадку=0;
		ТрудозатратыНаТермоусадку=0;
	иначе
		НачалоТермоусадки='21000101';
		ОкончаниеТермоусадки=ПустаяДата();
		ТрудозатратыНаТермоусадку=0;
		Для каждого СтрТЗ из ТекТЗ цикл
			НачалоТермоусадки=Мин(НачалоТермоусадки,СтрТЗ.НачалоТермоусадки);
			ОкончаниеТермоусадки=Макс(ОкончаниеТермоусадки,СтрТЗ.ОкончаниеТермоусадки);
			ТрудозатратыНаТермоусадку=ТрудозатратыНаТермоусадку+ (СтрТЗ.ОкончаниеТермоусадки-СтрТЗ.НачалоТермоусадки);	
		КонецЦикла;
		ТрудозатратыНаТермоусадку=ТрудозатратыНаТермоусадку/3600;
		ВремяНаТермоусадку=(ОкончаниеТермоусадки-НачалоТермоусадки)/3600;
	КонецЕсли;
	///////////////////////////////////////////////////Термоусадка
	НакладнаяОб=ТекПланНабора.Накладная.ПолучитьОбъект();
	НакладнаяОб.ВремяНаНабор=ВремяНаНабор;
	НакладнаяОб.ВремяНаСканирование=ВремяНаСканировку;
	НакладнаяОб.ТрудозатратыНаНабор=ТрудозатратыНаНабор;
	НакладнаяОб.ТрудозатратыНаСканирование=ТрудозатратыНаСканировку;
	
	если НакладнаяОб.ТрудозатратыНаТермоусадку=0 тогда
		НакладнаяОб.ТрудозатратыНаТермоусадку=ТрудозатратыНаТермоусадку;
		НакладнаяОб.ВремяНаТермоусадку=ВремяНаТермоусадку;
	КонецЕсли;
	
	если НакладнаяОб.ТрудозатратыНаДО=0 тогда
		НакладнаяОб.ВремяНаДО=ВремяНаДопОбработку;
		НакладнаяОб.ТрудозатратыНаДО=ТрудозатратыНаДопОбработку;
	КонецЕсли;
	
	если НакладнаяОб.ТрудозатратыНаПаллетирование=0 тогда
		НакладнаяОб.ВремяНаПаллетирование=ВремяНаПаллетирование;
		НакладнаяОб.ТрудозатратыНаПаллетирование= ТрудозатратыНаПаллетирование;
	КонецЕсли;
	
	
	
	
	
	
	НакладнаяОб.ОбменДанными.Загрузка=истина; 	
	НакладнаяОб.Записать();
	ПланыОбмена.УдалитьРегистрациюИзменений(СписокУзловПолучателей,НакладнаяОб.ссылка);
	
	
КонецПроцедуры


Функция ЗаполнитьТЧРасходныхМатериаловВнешняя (Документ) 
	
	
	
	
	если документ.метаданные().имя="Перемещение" тогда
		если документ.склад.родитель=документ.складполучатель.родитель тогда
			возврат Истина;  //Внутрискладские ПРМ, и физические и виртуальные
		КонецЕсли;
	КонецЕсли;
	
	
	если документ.метаданные().имя="РасходнаяНакладная" или (документ.метаданные().имя="Перемещение" и документ.склад.родитель=ПараметрыСеанса.ЭтотУзел.Подразделение.ОсновнойСклад.Родитель) тогда
		ТЗМатериалов=ОбработатьЛистыНабора(Документ);	
		
	иначе
		возврат Истина	
	КонецЕсли;
	
	если ЕстьРеквизитДокумента("КоличествоПаллет",документ.метаданные()) тогда
		КоличествоПаллет=документ.количествоПаллет;
	Иначе
		КоличествоПаллет=0;
	КонецЕсли;
	
	если КоличествоПаллет>0 тогда
		ТЗМатериалов=ОбработатьПаллеты(Документ,ТЗМатериалов);
	КонецЕсли;
	
	ТЗМатериалов=ОбработатьНакладную(Документ,ТЗМатериалов);
	
	
	ТЗМатериалов.Свернуть("Номенклатура","Количество");		
	Документ.РасходныеМатериалы.очистить();
	для каждого СтрТзМатериалов из ТЗМатериалов цикл
		если СтрТзМатериалов.количество=0 тогда Продолжить;КонецЕсли;
		СтрТЧ=Документ.РасходныеМатериалы.добавить();
		ЗаполнитьЗначенияСвойств(СтрТЧ,СтрТзМатериалов);
	КонецЦикла;
	
	
КонецФункции





функция ОбработатьЛистыНабора (Документ)
	ТЗМатериалов=новый ТаблицаЗначений;
	ТЗМатериалов.Колонки.Добавить("Количество");
	ТЗМатериалов.Колонки.Добавить("Номенклатура");
	
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	              |	док.Ссылка КАК ЛН,
	              |	1 КАК КоличествоКоробок,
	              |	док.ТипКороба КАК ТипКороба
	              |ИЗ
	              |	Документ.ЛистПереукладки КАК док
	              |ГДЕ
	              |	док.Проведен
				  |	И док.ДокОснование = &ДокОснование
				  // Кухарь А.Ю.  11.08.2022 начало
				  // ЛП для хранения номеров заказа FBS
				  |	И не док.НеУчитыватьПриОпределенииКоличестваМест";
				  // Кухарь А.Ю.  11.08.2022 конец
				  
	запрос.УстановитьПараметр("ДокОснование",Документ.ссылка);
	результат=запрос.Выполнить().Выгрузить();
	если результат.Количество()=0 тогда				
		Запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ
		|	ЛистНабора.Ссылка как ЛН,
		|	ЛистНабора.КоличествоКоробок как КоличествоКоробок,
		|	ЛистНабора.ТипКороба как ТипКороба
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабора
		|ГДЕ
		|	ЛистНабора.Проведен
		|	И ЛистНабора.ДокОснование = &ДокОснование";
		запрос.УстановитьПараметр("ДокОснование",Документ.ссылка);
		результат=запрос.Выполнить().Выгрузить();
		СписокКоробок=результат.ВыгрузитьКолонку("ТипКороба");		
	КонецЕсли;	
	
	
	
	если результат.Количество()>0 тогда	
		СписокНоменклатуры=новый СписокЗначений;
		Для каждого СтрТовары из Документ.товары цикл
			СписокНоменклатуры.Добавить(СтрТовары.номенклатура.родитель);
		КонецЦикла;		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ВидыНормРасходаМатериалов.Ссылка КАК ВидНормыСсылка,
		|	ВидыНормРасходаМатериалов.Наименование КАК ВидНормыНаименование,
		|	ВидыНормРасходаМатериалов.ИмяНормыРасхода КАК ИмяНормыРасхода,
		|	ВидыНормРасходаМатериалов.ЗначениеНормыРасхода КАК ЗначениеНормыРасхода,
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода КАК Владелец
		|ИЗ
		|	Справочник.ВидыНормРасходаМатериалов КАК ВидыНормРасходаМатериалов
		|ГДЕ
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода В(&СписокНоменклатуры)
		|	И ВидыНормРасходаМатериалов.ПометкаУдаления = ЛОЖЬ
		| Объединить все
		|ВЫБРАТЬ
		|	ВидыНормРасходаМатериалов.Ссылка,
		|	ВидыНормРасходаМатериалов.Наименование,
		|	ВидыНормРасходаМатериалов.ИмяНормыРасхода,
		|	ВидыНормРасходаМатериалов.ЗначениеНормыРасхода,
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода 
		|ИЗ
		|	Справочник.ВидыНормРасходаМатериалов КАК ВидыНормРасходаМатериалов
		|ГДЕ
		|	ВидыНормРасходаМатериалов.ВладелецНормыРасхода В(&СписокКоробок)
		|	И ВидыНормРасходаМатериалов.ПометкаУдаления = ЛОЖЬ";
		запрос.УстановитьПараметр("СписокКоробок",СписокКоробок);
		запрос.УстановитьПараметр("СписокНоменклатуры",СписокНоменклатуры);
		СписокНормДляЛН=запрос.Выполнить().Выгрузить();	
	иначе
		Возврат ТЗМатериалов;
	КонецЕсли;				  
	
	
	//Кухарь 15.08.17 начало
	//Оптимизация
	если результат.Количество()=0 тогда
		Возврат ТЗМатериалов;
	иначе
		ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(результат.Получить(0).ЛН);
	КонецЕсли;
	//Кухарь 15.08.17 конец
	
	Для каждого СтрРез из результат цикл
		//Кухарь 15.08.17 начало
		//Оптимизация
		//ТЗСтрокМатрицы=СформироватьСписокСтрокМатрицы(СтрРез.лн);
		//Кухарь 15.08.17 конец
		
		//Кухарь 03.07.18 начало
		//Будем фиксировать тару не относящиеся к закупаемой
		ЛН=СтрРез.ЛН;
		если ложь тогда ЛН=Документы.ЛистНабора.ПустаяСсылка();КонецЕсли;
		если СтрРез.ЛН.метаданные().имя="ЛистПереукладки"  тогда
			если не ЛН.ТипКороба.ЗакупаемаяТара тогда
				СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
				СтрокаТЗМатериалов.Номенклатура=Справочники.Номенклатура.НайтиПоКоду("SNL-420874"); //Заводская коробка б\у
				СтрокаТЗМатериалов.количество=1;
			КонецЕсли;
		Иначе
			если ЛН.ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда
				СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
				СтрокаТЗМатериалов.Номенклатура=Справочники.Номенклатура.НайтиПоКоду("SNL-420873"); //Заводская коробка новая
				СтрокаТЗМатериалов.количество=лн.КоличествоКоробок;					
			Иначе
				если не ЛН.ТипКороба.ЗакупаемаяТара тогда
					СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
					СтрокаТЗМатериалов.Номенклатура=Справочники.Номенклатура.НайтиПоКоду("SNL-420874"); //Заводская коробка б\у
					СтрокаТЗМатериалов.количество=1;
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;
		//Кухарь 03.07.18 конец
		
		если ТЗСтрокМатрицы=Неопределено тогда Продолжить;КонецЕсли;
		если СтрРез.лн.ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда
			ТЗНом=СтрРез.ЛН.Товары.Выгрузить();
			ТЗНом.Свернуть("Номенклатура","Количество");
			КоличествоЕдиницПленки=0;		
			ОтборКоробочный=новый Структура;
			ОтборКоробочный.Вставить("НаКаждуюКоробкуОтдельно",истина);
			//Кухарь 24.09.17 начало
			//Раньше ТЗСтрокМатрицы была по текущему ЛН, теперь общая 
			ОтборКоробочный.Вставить("ТипШтрихКода",СтрРез.лн.ТипШК);
			//Кухарь 24.09.17 конец
			МассКоробочных=ТЗСтрокМатрицы.НайтиСтроки(ОтборКоробочный);		
			Для каждого СтрТз из ТЗНом цикл
				если СтрТз.номенклатура.родитель.ШтукВКоробке=0 тогда
					КоличествоКоробокТекНоменклатуры=СтрТз.количество;
				иначе
					КоличествоКоробокТекНоменклатуры=СтрТз.количество/СтрТз.номенклатура.родитель.ШтукВКоробке;
				КонецЕсли;				
				для сч=1 по КоличествоКоробокТекНоменклатуры цикл
					Для каждого СтрМасс из МассКоробочных цикл
						//Кухарь 24.09.17 начало
						//Переклейку обрабатываем отдельно
						если СтрМасс.НаКаждуюШтукуПереклейкиОтдельно=ложь тогда
							//Кухарь 24.09.17 начало
							
							СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
							
							
							
							если СтрМасс.НормаРасхода<>0 тогда 
								СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода;
							Иначе
								Отбор=новый Структура;
								Отбор.Вставить("Владелец",СтрТз.номенклатура.родитель);
								Отбор.Вставить("ИмяНормыРасхода",СтрМасс.ИмяНормыРасхода);							
								НормаТекущейНоменклатуры=СписокНормДляЛН.НайтиСтроки(Отбор);
								если НормаТекущейНоменклатуры.Количество()=1 тогда
									СтрокаТЗМатериалов.Количество=НормаТекущейНоменклатуры.Получить(0).ЗначениеНормыРасхода;
								ИначеЕсли НормаТекущейНоменклатуры.Количество()>1 тогда
									СтрокаТЗМатериалов.Количество=НормаТекущейНоменклатуры.Получить(0).ЗначениеНормыРасхода;
									
									#Если клиент тогда
										Сообщить("Обнаружено несколько норм "+СтрМасс.ИмяНормыРасхода+" для номенклатуры "+СтрТз.номенклатура.родитель.наименование );
									#КонецЕсли
								иначе
									СтрокаТЗМатериалов.Количество=0;
									#Если клиент тогда
										Сообщить("Отсутствует "+СтрМасс.ИмяНормыРасхода+" для номенклатуры "+СтрТз.номенклатура.родитель.наименование );
									#КонецЕсли
								КонецЕсли;
								
							КонецЕсли;	
							
							
							СтрокаТЗМатериалов.Номенклатура=СтрМасс.Номенклатура;
							//Кухарь 24.09.17 начало
							//Переклейку обрабатываем отдельно
						иначе
							если СтрМасс.НормаРасхода*СтрРез.ЛН.переклейка.итог("Количество")>0 тогда
								СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
								СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода*СтрРез.ЛН.переклейка.итог("Количество");
								СтрокаТЗМатериалов.Номенклатура=СтрМасс.Номенклатура;
							КонецЕсли;
						КонецЕсли;
						//Кухарь 24.09.17 начало
						
					КонецЦикла;
				КонецЦикла;			
			КонецЦикла;	
			// тут фиксируем расход материалов для каждой отдельной коробки из ЛН конец
			
			// тут фиксируем расход материалов которые на ЛН в целиком начало  
			ОтборНаЛН=новый Структура;
			ОтборНаЛН.Вставить("НаКаждуюКоробкуОтдельно",ложь);
			//Кухарь 24.09.17 начало
			//Раньше ТЗСтрокМатрицы была по текущему ЛН, теперь общая 
			ОтборНаЛН.Вставить("ТипШтрихКода",СтрРез.лн.ТипШК);
			//Кухарь 24.09.17 конец
			
			МассНаЛН=ТЗСтрокМатрицы.НайтиСтроки(ОтборНаЛН);
			Для каждого СтрМасс из МассНаЛН цикл
				//Кухарь 24.09.17 начало
				//Переклейку обрабатываем отдельно
				если СтрМасс.НаКаждуюШтукуПереклейкиОтдельно=ложь тогда
					//Кухарь 24.09.17 начало
					
					СтрокаТЗМатериалов=ТЗМатериалов.Добавить();
					
					если СтрМасс.НормаРасхода<>0 тогда 
						СтрокаТЗМатериалов.Количество=СтрМасс.НормаРасхода;
					Иначе
						Отбор=новый Структура;
