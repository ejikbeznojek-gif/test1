					СтрокаТО.Код			= Объект.Код;
					СтрокаТО.Наименование	= Объект.Наименование;					
					//СтрокаТО.НомерСообщения = Параметры.НомерСообщения;
					
					Если Объект.Метаданные().Реквизиты.Найти("ИД_77")<>Неопределено Тогда
