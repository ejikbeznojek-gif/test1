							Сообщить("Запись объекта: "+ТипОбъекта+"."+Объект.Метаданные().Имя++" "+Объект+" , есть изм. свойств: "+ЕстьИзмененияСвойств+"("+ИзмененнныеСвойства+")");
							
							Объект.Записать();					
						КонецЕсли;				
						
					Исключение
						
						СтрокаМодуля    = ОтделитьРазделителем(ОписаниеОшибки(), "{");
						ОписаниеОшибки  = ОтделитьРазделителем(СтрокаМодуля, "}: ");
						ЗП = ПолучитьСтруктуруЗаписиПротокола();
						ЗП.Объект         = Объект;
						ЗП.ТипОбъекта     = ТипОбъекта;
						ЗП.ОписаниеОшибки = ОписаниеОшибки;
						ЗП.КодСообщения   = 26;
						ЗаписатьВПротоколВыполнения(26, ЗП, Истина);
						
						//Функция ЗаписатьВЛог(ИмяЛога,Сообщение,ТипСообщения,ВыводитьСообщения=Ложь) Экспорт
						ЕстьОшибкиЗагрузки=Истина;

						Если Объект<>Неопределено Тогда
							ЗаписатьВЛог("Загрузка77","Ошибка записи элемента справочника ! "+Объект.Метаданные().Имя+" "+Объект+" "+ОписаниеОшибки,"Ошибка");
						Иначе							
							ЗаписатьВЛог("Загрузка77","Попытка записи пустого объекта ! Тип: """+ИмяТипаОбъекта+""","""+Ссылка+""" "+ОписаниеОшибки,"Ошибка");						
						КонецЕсли;						
					КонецПопытки;
					
				Иначе
					
					УстановитьОбменДаннымиЗагрузка(Объект);
					
					ТипОбъекта=ТипОбъекта(Объект);
										
					Если ТипОбъекта="Справочник" И НЕ ЕстьИзмененияСвойств Тогда
					Иначе
						Сообщить("Запись объекта: "+ТипОбъекта+" "+Объект+" , есть изм. свойств: "+ЕстьИзмененияСвойств+" ("+ИзмененнныеСвойства+")");
						
						Объект.Записать();					
					КонецЕсли;				
					
				КонецЕсли;
				
				Если ТипОбъекта="Справочник" Тогда
					СтрокаТО=ТаблицаЗагруженныхОбъектов.Добавить();
					
					СтрокаТО.Тип = "Справочник";					
