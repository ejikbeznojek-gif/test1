Функция КопироватьУзел(Узел)

	Стр = Узел.Закрыть();

	ЗаписьXML = Новый ЗаписьXML;
	//ЗаписьXML.Отступ = Истина;
	ЗаписьXML.УстановитьСтроку();
	ЗаписьXML.ЗаписатьБезОбработки(Стр);

	Возврат ЗаписьXML;
	
