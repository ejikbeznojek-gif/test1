			ЗагрузитьЗапрос(ПравилаОбмена, ЗаписьXML);
		ИначеЕсли (ИмяУзла = "Запросы") И (ТипУзла = одТипУзлаXML_КонецЭлемента) Тогда
			Прервать;
		Иначе
		КонецЕсли;
