							КонецПопытки;
							
						Иначе
							
							УстановитьОбменДаннымиЗагрузка(Объект);
							Объект.Записать();
							
							ОбъектЗагружен=Истина;
						КонецЕсли;
						
						УстановитьОбменДаннымиЗагрузка(Объект);
