							ЗП.Источник           = Источник;
							
						КонецЕсли;
						
						ЗП.ТипОбъекта             = ТипОбъекта;
						ЗП.Объект                 = Строка(Объект);
						ЗП.Обработчик             = "ПослеЗагрузкиОбъекта (глобальный)";
						ЗП.ОписаниеОшибки         = ОписаниеОшибки;
						ЗП.ПозицияМодуля          = СтрокаМодуля;
						ЗП.КодСообщения           = 54;
						ЗаписатьВПротоколВыполнения(54, ЗП);
						
					КонецПопытки;
					
				Иначе
					
					Выполнить(Конвертация.ПослеЗагрузкиОбъекта);
					
				КонецЕсли;
				
			КонецЕсли;

			
		    // Обработчик события ПослеЗагрузкиОбъекта
			
			Если ЕстьОбработчикПослеЗагрузки Тогда
				
				Если ФлагРежимОтладки Тогда
					
					Попытка
						
						Если ТипОбъекта(Объект)="Документ" И НЕ ПустаяСтрока(Правило.ПослеЗагрузки) И фНеОбрабатыватьПравилаПослеЗагрузкиДокументов Тогда
							Сообщить("Пропускаем правило: "+ТипОбъекта(Объект)+" "+Объект.Метаданные().Имя+" "+Правило.ПослеЗагрузки);						
						Иначе
							Выполнить(Правило.ПослеЗагрузки);							
						КонецЕсли;					
						
					Исключение
						
						СтрокаМодуля              = ОтделитьРазделителем(ОписаниеОшибки(), "{");
						ОписаниеОшибки            = ОтделитьРазделителем(СтрокаМодуля, "}: ");
						ЗП                        = ПолучитьСтруктуруЗаписиПротокола();
						ЗП.ИмяПКО                 = ИмяПравила;
						
						Если Не ПустаяСтрока(Источник) Тогда
							
							ЗП.Источник           = Источник;
							
						КонецЕсли;
						
						ЗП.ТипОбъекта             = ТипОбъекта;
						ЗП.Объект                 = Строка(Объект);
						ЗП.Обработчик             = "ПослеЗагрузкиОбъекта";
						ЗП.ОписаниеОшибки         = ОписаниеОшибки;
						ЗП.ПозицияМодуля          = СтрокаМодуля;
						ЗП.КодСообщения           = 21;
						ЗаписатьВПротоколВыполнения(21, ЗП);
						
					КонецПопытки;
					
				Иначе
					
					Выполнить(Правило.ПослеЗагрузки);
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если ИмяТипаОбъекта = "Документ" Тогда
				
