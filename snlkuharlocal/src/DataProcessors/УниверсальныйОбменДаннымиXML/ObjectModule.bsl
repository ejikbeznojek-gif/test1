				Если ФлагРежимОтладки Тогда
					
					Попытка
						
						УстановитьОбменДаннымиЗагрузка(Объект);
						Объект.Записать();
						
					Исключение
						
						СтрокаМодуля    = ОтделитьРазделителем(ОписаниеОшибки(), "{");
