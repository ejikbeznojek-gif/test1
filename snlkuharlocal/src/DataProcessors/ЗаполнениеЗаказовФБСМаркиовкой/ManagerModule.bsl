// Функция - Текст запроса данные маркировки заказов
// Определено в СквозноеТестирование().
//
// Параметры:
//  ИмяВременнойТаблицы	 - Строка - Имя, уже определенной в начале текста запроса, временной таблицы.
// 
// Возвращаемое значение:
//  Строка - Пакетный запрос, оканчивающийся временной таблицей.
//
Функция МП_ТекстЗапросаДанныеМаркировкиЗаказов(ИмяВременнойТаблицы) Экспорт
	
	// Этот текст запроса конкатенируется с текстом сбора данных о заказах
	// См. подробнее в МодульМенеджера Обработка.ЗаполнениеЗаказовФБСМаркиовкой.МП_ЯндексМаркет_ОтправитьМаркировку()
	ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_Заказы.ЗаказFBS КАК ЗаказFBS,
	|	вт_Заказы.РасходнаяНакладная КАК РасходнаяНакладная,
	|	ЛистНабораШтрихкодыУпаковок.Ссылка КАК ЛистНабора,
	|	вт_Заказы.НомерЗаказа КАК НомерЗаказа,
	|	вт_Заказы.СуффиксЗаказа КАК СуффиксЗаказа,
	|	вт_Заказы.НомерЗаказаВМоделиСервиса КАК НомерЗаказаВМоделиСервиса,
	|	вт_Заказы.АртикулКонтрагента КАК АртикулКонтрагента,
	|	вт_Заказы.Номенклатура КАК Номенклатура,
	|	вт_Заказы.ШтрихКод КАК ШтрихКод,
	|	вт_Заказы.Количество КАК Количество,
	|	ДокументРасходнаяНакладная.СостояниеНакладной КАК СостояниеНакладной,
	|	вт_Заказы.СостояниеУКлиента КАК СостояниеУКлиента
	|ПОМЕСТИТЬ вт_ЛистыНабора
	|ИЗ
	|	%1 КАК вт_Заказы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК ДокументРасходнаяНакладная
	|		ПО вт_Заказы.РасходнаяНакладная = ДокументРасходнаяНакладная.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|		ПО вт_Заказы.РасходнаяНакладная = ЛистНабораШтрихкодыУпаковок.Ссылка.ДокОснование
	|			И вт_Заказы.НомерЗаказа = ЛистНабораШтрихкодыУпаковок.НомерЗаказа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистНабораТовары.Ссылка КАК Ссылка,
	|	ЛистНабораТовары.Номенклатура КАК Номенклатура,
	|	ЛистНабораТовары.ШК КАК ШК,
	|	ЛистНабораТовары.ПорядковыйНомерКоробки КАК ПорядковыйНомерКоробки
	|ПОМЕСТИТЬ вт_ЛистНабораТовары
	|ИЗ
	|	вт_ЛистыНабора КАК вт_ЛистыНабора
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	|		ПО вт_ЛистыНабора.ЛистНабора = ЛистНабораТовары.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЛистНабораТовары.Ссылка,
	|	ЛистНабораТовары.Номенклатура,
	|	ЛистНабораТовары.ШК,
	|	ЛистНабораТовары.ПорядковыйНомерКоробки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистНабораШтрихкодыУпаковок.Ссылка КАК Ссылка,
	|	ЛистНабораШтрихкодыУпаковок.НомерЗаказа КАК НомерЗаказа,
	|	ШтрихкодыУпаковокТоваров.Наименование КАК Наименование,
	|	ШтрихкодыУпаковокТоваров.Владелец КАК Номенклатура
	|ПОМЕСТИТЬ вт_ШтрихкодыУпаковокТоваров
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ПО (ВЫБОР
	|				КОГДА ЛистНабораШтрихкодыУпаковок.ШтрихкодНабора = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|					ТОГДА ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки
	|				ИНАЧЕ ЛистНабораШтрихкодыУпаковок.ШтрихкодНабора
	|			КОНЕЦ = ШтрихкодыУпаковокТоваров.Ссылка)
	|ГДЕ
	|	(ЛистНабораШтрихкодыУпаковок.Ссылка, ЛистНабораШтрихкодыУпаковок.НомерЗаказа) В
	|			(ВЫБРАТЬ
	|				вт_ЛистыНабора.ЛистНабора,
	|				вт_ЛистыНабора.НомерЗаказа
	|			ИЗ
	|				вт_ЛистыНабора)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ЛистыНабора.ЗаказFBS КАК ЗаказFBS,
	|	вт_ЛистыНабора.НомерЗаказаВМоделиСервиса КАК НомерЗаказа,
	// Ихсанов Д. А. Начало 18.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8242
	|	вт_ЛистыНабора.НомерЗаказа КАК НомерЗаказаСИндексом,
	// Ихсанов Д. А. Конец 18.12.2025
	|	вт_ЛистыНабора.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЕСТЬNULL(вт_ШтрихкодыУпаковокТоваров.Наименование, """") КАК КИЗ,
	|	ЕСТЬNULL(вт_ЛистНабораТовары.ПорядковыйНомерКоробки, 0) КАК НомерКоробки,
	|	вт_ЛистыНабора.АртикулКонтрагента КАК Идентификатор,
	|	СУММА(вт_ЛистыНабора.Количество) КАК Количество,
	|	вт_ЛистыНабора.СостояниеНакладной КАК СостояниеНакладной,
	|	вт_ЛистыНабора.СостояниеУКлиента КАК СостояниеУКлиента
	|ПОМЕСТИТЬ вт_Результат
	|ИЗ
	|	вт_ЛистыНабора КАК вт_ЛистыНабора
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ЛистНабораТовары КАК вт_ЛистНабораТовары
	|		ПО вт_ЛистыНабора.ЛистНабора = вт_ЛистНабораТовары.Ссылка
	|			И вт_ЛистыНабора.Номенклатура = вт_ЛистНабораТовары.Номенклатура
	|			И вт_ЛистыНабора.ШтрихКод = вт_ЛистНабораТовары.ШК
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ШтрихкодыУпаковокТоваров КАК вт_ШтрихкодыУпаковокТоваров
	|		ПО вт_ЛистыНабора.ЛистНабора = вт_ШтрихкодыУпаковокТоваров.Ссылка
	|			И вт_ЛистыНабора.НомерЗаказа = вт_ШтрихкодыУпаковокТоваров.НомерЗаказа
	|			И вт_ЛистыНабора.Номенклатура = вт_ШтрихкодыУпаковокТоваров.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_ЛистыНабора.ЗаказFBS,
	|	вт_ЛистыНабора.НомерЗаказаВМоделиСервиса,
	// Ихсанов Д. А. Начало 18.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8242
	|	вт_ЛистыНабора.НомерЗаказа,
	// Ихсанов Д. А. Конец 18.12.2025
	|	вт_ЛистыНабора.СуффиксЗаказа,
	|	вт_ШтрихкодыУпаковокТоваров.Наименование,
	|	вт_ЛистНабораТовары.ПорядковыйНомерКоробки,
	|	вт_ЛистыНабора.АртикулКонтрагента,
	|	вт_ЛистыНабора.СостояниеНакладной,
	|	вт_ЛистыНабора.СостояниеУКлиента";
	
	Возврат СтрШаблон(ТекстЗапроса, ИмяВременнойТаблицы);
	
КонецФункции // МП_ТекстЗапросаДанныеМаркировкиЗаказов()

