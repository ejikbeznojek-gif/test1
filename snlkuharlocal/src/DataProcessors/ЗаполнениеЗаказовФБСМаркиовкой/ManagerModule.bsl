// Функция - Магнит маркет сформировать структуру данных по выборке
// Предназначена для маркировки товара и редактирования состава товаров в заказе
// Определено в СквозноеТестирование().
//
// Параметры:
//  Выборка					 - ВыборкаИзРезультатаЗапроса
//  ОбработанныеДанныеЗаказа - Массив, Неопределено
//  РазрешитьУдалениеТоваров - Булево
// 
// Возвращаемое значение:
//  Структура
//
Функция МП_МагнитМаркет_СформироватьСтруктуруДанныхПоВыборке(Выборка, //ОбработанныеДанныеЗаказа...) Экспорт 
	ОбработанныеДанныеЗаказа = Неопределено) Экспорт 
	
	// Формируем структуру коробок и кодов маркировки по товарам
	// Корень структуры - это коробки, далее товары, далее КМ
	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("order_id", Выборка.НомерЗаказа);
	ДанныеДляJSON.Вставить("parcels",	 Новый Массив);
	
	ВыборкаИдентификатор = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаИдентификатор.Следующий() Цикл
		ВыборкаДетальныеЗаписи = ВыборкаИдентификатор.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтруктураКоробки = Новый Структура;
			СтруктураКоробки.Вставить("items", Новый Массив);
			
			СтруктураТовара = Новый Структура;
			СтруктураТовара.Вставить("sku_id",	  Число(ВыборкаДетальныеЗаписи.Идентификатор));
			СтруктураТовара.Вставить("quantity", ВыборкаДетальныеЗаписи.Количество);
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.КИЗ) Тогда
				СтруктураТовара.Вставить("identifiers", Новый Массив);
				
				ДанныеПоКодуМаркировки = Новый Структура;
				ДанныеПоКодуМаркировки.Вставить("cis", ВыборкаДетальныеЗаписи.КИЗ);
				
				СтруктураТовара.identifiers.Добавить(ДанныеПоКодуМаркировки);
			КонецЕсли;
			
			СтруктураКоробки.items.Добавить(СтруктураТовара);
