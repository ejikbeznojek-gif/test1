#Область ПрограммныйИнтерфейс

#Область МП_ЯндексМаркет

// Ихсанов Д. А. Начало 28.01.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1949
// Процедура - Отправить маркировку яндекс маркет
//
// Параметры:
//  МаркетПлейс	- СправочникСсылка.ИнетМагазины - Ссылка на МаркетПлейс.
//
Процедура МП_ЯндексМаркет_ОтправитьМаркировку(МаркетПлейс) Экспорт
	
	пРеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, 
		"Контрагент, Наименование, ИДКомпании");
	
	// Состояние промаркированного товара
	Состояние_Промаркировано = МП_ЯндексМаркет_СостояниеПромаркированнойПродукции();
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	ЗаказыFBSМаркировка.ЗаказFBS КАК ЗаказFBS,
	|	ЗаказыFBSМаркировка.ЗаказFBS.ДокОснование КАК РасходнаяНакладная,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.РИД КАК НомерЗаказаВМоделиСервиса,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.СостояниеУКлиента КАК СостояниеУКлиента
	|ПОМЕСТИТЬ вт_Заказы
	|ИЗ
	|	РегистрСведений.ЗаказыFBSМаркировка КАК ЗаказыFBSМаркировка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО ЗаказыFBSМаркировка.ЗаказFBS = ЗаказКлиентаFBS.Ссылка
	|			И (ЗаказКлиентаFBS.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -3))
	|			И (ЗаказКлиентаFBS.Контрагент = &Контрагент)
	|			И (НЕ ЗаказКлиентаFBS.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказыFBSМаркировка.ЗаказFBS = ЗаказКлиентаFBSТовары.Ссылка
	|			И (НЕ ЗаказыFBSМаркировка.Обработан)
	|			И (НЕ ЗаказКлиентаFBSТовары.Отменен)
	|ГДЕ
	|	ЗаказКлиентаFBSТовары.СостояниеУКлиента = &СостояниеУКлиента");
	ТекстыЗапросов.Добавить(МП_ЯндексМаркет_ТекстЗапросаДанныеМаркировкиЗаказов("вт_Заказы"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ * ИЗ вт_Результат ГДЕ СостояниеНакладной В (
	// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000087 от 07.06.2026 22:19:02: e1cib/data/Документ.Изменение?ref=89690050568f680711f162a5bd350d2d
	//|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеПаллетирования),
	//|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Паллетирование))
	|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ГотоваКОтгрузке),
	|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Отгружена))
	// Ихсанов Д. А. Конец 07.07.2026
	|ИТОГИ ПО ЗаказFBS, НомерЗаказа, Идентификатор");
	
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";" + Символы.ПС));
	Запрос.УстановитьПараметр("ТекущаяДата",	   ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Контрагент",		   пРеквизитыМаркетПлейс.Контрагент);
	Запрос.УстановитьПараметр("СостояниеУКлиента", Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("PROCESSING;STARTED"));
	
	ВыборкаЗаказFBS = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаЗаказFBS.Следующий() Цикл
		// Инициализируем массив для хранения номера заказа и идентификатора товара
		ОбработанныеЗаказы = Новый Соответствие;
		ОбработанныеДанныеЗаказа = Новый Массив;
		
		// Формируем данные по коробкам для отправки
		ВыборкаНомерЗаказа = ВыборкаЗаказFBS.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНомерЗаказа.Следующий() Цикл
			// Получаем структуру, для перевода ее в формат JSON
			ДанныеДляJSON = МП_ЯндексМаркет_СформироватьСтруктуруДанныхПоВыборке(ВыборкаНомерЗаказа, ОбработанныеДанныеЗаказа);
			
			ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
			ПараметрыОбработки.ДанныеЗапроса.Метод		 = "PUT";
			ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON,
				ПараметрыОбработки);
			ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
				ОбменМаркетПлейс.МП_Яндекс_ВернутьСоединение(МаркетПлейс),
				ОбменМаркетПлейс.МП_Яндекс_ВернутьЗаголовкиHTTP(МаркетПлейс),
				СтрШаблон("/v2/campaigns/%1/orders/%2/boxes.json", пРеквизитыМаркетПлейс.ИДКомпании, ВыборкаНомерЗаказа.НомерЗаказа),
				ПараметрыОбработки);
			
			ДанныеМаркировкиОтправлены = ДанныеОтвета.Свойство("status") И ДанныеОтвета.status = "OK";
			
			// Фиксируем факт ошибки отправки данных маркировки по заказу даже в случае,
			// если часть заказов обработалась нормально
			Если ОбработанныеЗаказы[ВыборкаЗаказFBS.ЗаказFBS] = Неопределено
				Или Не ДанныеМаркировкиОтправлены Тогда
				ОбработанныеЗаказы.Вставить(ВыборкаЗаказFBS.ЗаказFBS);
				ОбработанныеЗаказы[ВыборкаЗаказFBS.ЗаказFBS] = ДанныеМаркировкиОтправлены;
			КонецЕсли;
		КонецЦикла;
		
		// Желательно унести блок в модуль менеджера
		// Записываем в базу кэшированные данные по заказам клиентов FBS
		Для каждого лЗаказFBS из ОбработанныеЗаказы Цикл
			// Если заказ не обработан, либо обработан не полностью, переходим к следующему
			Если Не лЗаказFBS.Значение Тогда
				Продолжить;
			КонецЕсли;
			
			// Если заказ был успешно обработан, фиксируем факт обработки в базу
			МенеджерЗаписиМаркировка = РегистрыСведений.ЗаказыFBSМаркировка.СоздатьМенеджерЗаписи();
			МенеджерЗаписиМаркировка.ЗаказFBS = лЗаказFBS.Ключ;
			МенеджерЗаписиМаркировка.Прочитать();
			
			Если Не МенеджерЗаписиМаркировка.Выбран() Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаказFBSОбъект = лЗаказFBS.Ключ.ПолучитьОбъект();
			
			// Меняем статус у каждого обработанного товара в документе заказа на CUSTOM:MARKED
			Для каждого ПараметрыОтбора из ОбработанныеДанныеЗаказа Цикл
				НайденныеСтроки = ЗаказFBSОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
				Для каждого СтрокаЗаказа из НайденныеСтроки Цикл
					СтрокаЗаказа.СостояниеУКлиента = Состояние_Промаркировано;
				КонецЦикла;
			КонецЦикла;
			
			Попытка
				ЗаказFBSОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
				МенеджерЗаписиМаркировка.Обработан = Истина;
				МенеджерЗаписиМаркировка.Записать();
			Исключение
				// Если документ или регистр не записался, отдаем в лог ошибку
				// Важно понимать, что в регистре одно измерение и без замещения ошибка по нему
				// появляться не должна
				Шаблон_СообщениеОбОшибке = НСтр("ru=''%1. Не удалось зафиксировать данные по документу %2!
					|Возникла ошибка при записи данных после отправки маркировки:
					|%3'", "ru");
				СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ЗаполнениеЗаказовФБСМаркиовкой",
					ЗаказFBSОбъект, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗаписатьВЛог("МП_ЯндексМаркет", СообщениеОбОшибке, "Ошибка");
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры // ПрикрепитьМаркуЯндексМаркет()
// Ихсанов Д. А. Конец  28.01.2025

#КонецОбласти

#Область МП_МагнитМаркет

// Ихсанов Д. А. Начало 25.03.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-1102
// Процедура - Отправить маркировку яндекс маркет
//
// Параметры:
//  МаркетПлейс	- СправочникСсылка.ИнетМагазины - Ссылка на МаркетПлейс.
//
Процедура МП_МагнитМаркет_ОтправитьМаркировку(МаркетПлейс) Экспорт
	
	пРеквизитыМаркетПлейс = ЗначенияРеквизитовОбъекта(МаркетПлейс, 
		"Контрагент, Наименование, ИДКомпании");
	
	// Состояние промаркированного товара
	Состояние_Промаркировано = МП_МагнитМаркет_СостояниеПромаркированнойПродукции();
	
	// Получаем данные по штрихкодам товаров в РНК
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить("ВЫБРАТЬ ПЕРВЫЕ 1000
	|	ЗаказыFBSМаркировка.ЗаказFBS КАК ЗаказFBS,
	|	ЗаказыFBSМаркировка.ЗаказFBS.ДокОснование КАК РасходнаяНакладная,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.РИД КАК НомерЗаказаВМоделиСервиса,
	|	ЗаказКлиентаFBSТовары.СостояниеУКлиента КАК СостояниеУКлиента,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество
	|ПОМЕСТИТЬ вт_Заказы
	|ИЗ
	|	РегистрСведений.ЗаказыFBSМаркировка КАК ЗаказыFBSМаркировка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО ЗаказыFBSМаркировка.ЗаказFBS = ЗаказКлиентаFBS.Ссылка
	|			И (ЗаказКлиентаFBS.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -3))
	|			И (ЗаказКлиентаFBS.Контрагент = &Контрагент)
	|			И (НЕ ЗаказКлиентаFBS.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО ЗаказыFBSМаркировка.ЗаказFBS = ЗаказКлиентаFBSТовары.Ссылка
	|			И (НЕ ЗаказыFBSМаркировка.Обработан)
	|			И (НЕ ЗаказКлиентаFBSТовары.Отменен)");
	ТекстыЗапросов.Добавить(МП_МагнитМаркет_ТекстЗапросаДанныеМаркировкиЗаказов("вт_Заказы"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ вт_Результат.*, вт_Заказы.НомерЗаказа КАК НомерЗаказаВДокументе ИЗ вт_Результат
	|ЛЕВОЕ СОЕДИНЕНИЕ вт_Заказы КАК вт_Заказы
	|ПО вт_Результат.НомерЗаказа = вт_Заказы.НомерЗаказаВМоделиСервиса
	|	И вт_Результат.Идентификатор = вт_Заказы.АртикулКонтрагента ГДЕ СостояниеНакладной В ( 
	|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ОжиданиеПаллетирования),
	|		ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Паллетирование))
	|ИТОГИ МАКСИМУМ(вт_Результат.НомерЗаказа), МАКСИМУМ(вт_Результат.СуффиксЗаказа)
	|ПО вт_Результат.ЗаказFBS, НомерЗаказаВДокументе, Идентификатор");
	
	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";" + Символы.ПС));
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Контрагент",  пРеквизитыМаркетПлейс.Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ЗаказFBS");
	Пока Выборка.Следующий() Цикл
		// Инициализируем массив для хранения номера заказа и идентификатора товара
		ОбработанныеЗаказы = Новый Соответствие;
		ОбработанныеДанныеЗаказа = Новый Массив;
		
		// Формируем данные по коробкам для отправки
		ВыборкаНомераЗаказов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерЗаказаВДокументе");
		Пока ВыборкаНомераЗаказов.Следующий() Цикл
			// Получаем структуру, для перевода ее в формат JSON
			ДанныеДляJSON = МП_МагнитМаркет_СформироватьСтруктуруДанныхПоВыборке(ВыборкаНомераЗаказов, 
				ОбработанныеДанныеЗаказа);
			
			ПараметрыОбработки = ОбменМаркетПлейс.ПолучитьОбщиеПараметрыОбработки();
			ПараметрыОбработки.ДанныеЗапроса.Метод = "POST";
			ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON, 
				ПараметрыОбработки);
			
			ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
				ОбменМаркетПлейс.МП_Магнит_ВернутьСоединение(МаркетПлейс),
				ОбменМаркетПлейс.МП_Магнит_ВернутьЗаголовкиHTTP(МаркетПлейс),
				Обработки.МП_ММ_МагнитМаркет.МП_АдресЗапроса_ПередатьМаркировку(),
				ПараметрыОбработки);
			
			// Получаем и обрабатываем информацию о статусе заказа
			ДанныеМаркировкиОтправлены = Не (ДанныеОтвета.Свойство("error")
				Или ДанныеОтвета.Свойство("errors"));
			
			// Фиксируем факт ошибки отправки данных маркировки по заказу даже в случае,
			// если часть заказов обработалась нормально
			Если ОбработанныеЗаказы[ВыборкаНомераЗаказов.ЗаказFBS] = Неопределено
				Или Не ДанныеМаркировкиОтправлены Тогда
				ОбработанныеЗаказы.Вставить(ВыборкаНомераЗаказов.ЗаказFBS);
				ОбработанныеЗаказы[ВыборкаНомераЗаказов.ЗаказFBS] = ДанныеМаркировкиОтправлены;
			КонецЕсли;
		КонецЦикла;
		
		// Желательно унести блок в модуль менеджера
		// Записываем в базу кэшированные данные по заказам клиентов FBS
		Для каждого лЗаказFBS из ОбработанныеЗаказы Цикл
			// Если заказ не обработан, либо обработан не полностью, переходим к следующему
			Если Не лЗаказFBS.Значение Тогда
				Продолжить;
			КонецЕсли;
			
			НачатьТранзакцию(РежимУправленияБлокировкойДанных.Автоматический);
			
			// Если заказ был успешно обработан, фиксируем факт обработки в базу
			МенеджерЗаписиМаркировка = РегистрыСведений.ЗаказыFBSМаркировка.СоздатьМенеджерЗаписи();
			МенеджерЗаписиМаркировка.ЗаказFBS = лЗаказFBS.Ключ;
			МенеджерЗаписиМаркировка.Прочитать();
			
			Если Не МенеджерЗаписиМаркировка.Выбран() Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаказFBSОбъект = лЗаказFBS.Ключ.ПолучитьОбъект();
			
			// Меняем статус у каждого обработанного товара в документе заказа на IN_ASSEMBLY;MARKED
			Для каждого ПараметрыОтбора из ОбработанныеДанныеЗаказа Цикл
				НайденныеСтроки = ЗаказFBSОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
				Для каждого СтрокаЗаказа из НайденныеСтроки Цикл
					СтрокаЗаказа.СостояниеУКлиента = Состояние_Промаркировано;
				КонецЦикла;
			КонецЦикла;
			
			Попытка
				ЗаказFBSОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
				МенеджерЗаписиМаркировка.Обработан = Истина;
				МенеджерЗаписиМаркировка.Записать();
				
				ЗафиксироватьТранзакцию();
			Исключение
				ОтменитьТранзакцию();
				
				// Если документ или регистр не записался, отдаем в лог ошибку
				// Важно понимать, что в регистре одно измерение и без замещения ошибка по нему
				// появляться не должна
				Шаблон_СообщениеОбОшибке = НСтр("ru=''%1. Не удалось зафиксировать данные по документу %2!
					|Возникла ошибка при записи данных после отправки маркировки:
					|%3'", "ru");
				СообщениеОбОшибке = СтрШаблон(Шаблон_СообщениеОбОшибке, "ЗаполнениеЗаказовФБСМаркиовкой",
					ЗаказFBSОбъект, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗаписатьВЛог("МП_МагнитМаркет", СообщениеОбОшибке, "Ошибка");
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;     	
	
КонецПроцедуры // ПрикрепитьМаркуЯндексМаркет()
