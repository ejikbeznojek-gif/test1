// Ихсанов Д. А. Начало 28.01.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-1949
// Функция - Яндекс маркет сформировать структуру данных по выборке
// Предназначена для маркировки товара и редактирования состава товаров в заказе
// Определено в СквозноеТестирование().
//
// Параметры:
//  Выборка					 - ВыборкаИзРезультатаЗапроса
//  ОбработанныеДанныеЗаказа - Массив, Неопределено
//  РазрешитьУдалениеТоваров - Булево
// 
// Возвращаемое значение:
//  Структура
//
Функция МП_ЯндексМаркет_СформироватьСтруктуруДанныхПоВыборке(Выборка, //ОбработанныеДанныеЗаказа...) Экспорт 
	ОбработанныеДанныеЗаказа = Неопределено, РазрешитьУдалениеТоваров = Ложь) Экспорт 
	
	// Формируем структуру коробок и кодов маркировки по товарам
	// Корень структуры - это коробки, далее товары, далее КМ
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("boxes", 		Новый Массив);
	СтруктураДанных.Вставить("allowRemove", РазрешитьУдалениеТоваров);
	
	ВыборкаИдентификатор = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаИдентификатор.Следующий() Цикл
		ВыборкаДетальныеЗаписи = ВыборкаИдентификатор.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтруктураКоробки = Новый Структура;
			СтруктураКоробки.Вставить("items", Новый Массив);
			
			СтруктураТовара = Новый Структура;
			СтруктураТовара.Вставить("id",		  Число(ВыборкаДетальныеЗаписи.Идентификатор));
			// "instances" - Вставляется позже для контроля количества кодов маркировки
			СтруктураТовара.Вставить("fullCount", ВыборкаДетальныеЗаписи.Количество);
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.КИЗ) Тогда
				СтруктураТовара.Вставить("instances", Новый Массив);
				
				ДанныеПоКодуМаркировки = Новый Структура;
				ДанныеПоКодуМаркировки.Вставить("cis", ВыборкаДетальныеЗаписи.КИЗ);
				
				СтруктураТовара.instances.Добавить(ДанныеПоКодуМаркировки)
			КонецЕсли;
			
			СтруктураКоробки.items.Добавить(СтруктураТовара);
			СтруктураДанных.boxes.Добавить(СтруктураКоробки);
			
			// Ихсанов Д. А. Начало 18.12.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8242
			Если ОбработанныеДанныеЗаказа <> Неопределено
				И ТипЗнч(ОбработанныеДанныеЗаказа) = Тип("Массив") Тогда
				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("НомерЗаказа", ВыборкаДетальныеЗаписи.НомерЗаказаСИндексом);
				
				ОбработанныеДанныеЗаказа.Добавить(ПараметрыОтбора)
			КонецЕсли
			// Ихсанов Д. А. Конец 18.12.2025
		КонецЦикла
	КонецЦикла;
	
	Возврат СтруктураДанных
	
КонецФункции // ЯндексМаркет_СформироватьСтруктуруДанныхПоВыборке()
