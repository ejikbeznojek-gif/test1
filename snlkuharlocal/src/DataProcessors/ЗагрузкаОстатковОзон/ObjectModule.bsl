				Если Статус = "cancelled" Тогда
					
					сообщитьМенеджеруОтменазаказа(ВыборкаДетальныеЗаписи.ссылка);	
					
				КонецЕсли;

				
			КонецЕсли;	 
			
		исключение
			//сообщить(ОписаниеОшибки());
		конецПопытки;
		
		
		//----------------------------------------------------------------------------------------------------------------
		
	КонецЦикла;
	
	
