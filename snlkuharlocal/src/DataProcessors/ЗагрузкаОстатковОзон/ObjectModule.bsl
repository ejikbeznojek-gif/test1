Функция ПоследнийСтатусРНК(РНК)
	
	Запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	СостояниеНакладнойУКлиента.СостояниеУКлиента КАК СостояниеУКлиента,
	|	СостояниеНакладнойУКлиента.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.СостояниеНакладнойУКлиента КАК СостояниеНакладнойУКлиента
	|ГДЕ
	|	СостояниеНакладнойУКлиента.Объект = &текдок
	|
	|УПОРЯДОЧИТЬ ПО
	|	СостояниеНакладнойУКлиента.Дата УБЫВ";
	//|	И СостояниеНакладнойУКлиента.СостояниеУКлиента = &отменен";
	запрос.УстановитьПараметр("текдок",рнк);
	запрос.УстановитьПараметр("отменен",справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("cancelled"));
	
	рез2 = запрос.Выполнить().Выбрать();
	
	
	Если рез2.Следующий() тогда
		возврат рез2.состояниеуклиента.наименование;
	иначе
		возврат "";
	конецесли;	
	
	
	
конецФункции	


