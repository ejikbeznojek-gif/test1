	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата; //ЛокальнаяДата;      "2020-10-31T21:00:00Z",
	
	
	//	Текдата1 = Формат(НачалоМесяца(ТекущаяДата()),"ДФ=""гггг-ММ-дд'T'ЧЧ:мм:сс'.000Z'"""); // время просят с миллисекундами
	//	Текдата2 = Формат(ТекущаяДата(),"ДФ=""гггг-ММ-дд'T'ЧЧ:мм:сс'.000Z'"""); 
	
	СтрПРо= Новый Структура;
	
	
	//	Текдата1 = Формат(НачалоДня(ТекущаяДата()),"ДФ=""гггг-ММ-дд'T'ЧЧ:мм:сс'.000Z'""");  // 2020-10-31T21:00:00Z07:00\
	
	Данные = Новый Структура;
	Данные.Вставить("posting_number",НомерОтправления);
	
	ШК = Новый Структура;
	ШК.Вставить("barcodes",true);
	
	// это структуру добавили
	Данные.Вставить("with",ШК);
	
	
	Попытка
		ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
		Запись.Закрыть();
		// Возврат Истина;
	Исключение
		сообщить(ОписаниеОшибки());
		// ЗаписьЖурналаРегистрации(ИмяСобытияЖР,УровеньЖурналаРегистрации.Ошибка,,,"Прайс не сформирован, произошла ошибка " + ОписаниеОшибки());
		//  Возврат Ложь;
	КонецПопытки;;  
	
	
	// выполнение пост запроса.
	//-------------------------------
	Результат = POSTЗапросИз1С(Команда,ИмяВыходногоФайлаДЖ) ;    // ИмяВыходногоФайла?
	//-------------------------------
	р2=Результат.ПолучитьТелоКакСтроку();
