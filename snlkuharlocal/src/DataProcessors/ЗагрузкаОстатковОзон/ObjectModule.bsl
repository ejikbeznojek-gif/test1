		конецпопытки;
		
		попытка
			ЗаписьВРег=РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьМенеджерЗаписи();
			ЗаписьВРег.Документ= РНК.Ссылка;
			ЗаписьВРег.ИмяРеквизита="НижнийШКЭтикетки"; 
			ЗаписьВРег.ЗначениеРеквизита=Строка(Данные.result.barcodes.lower_barcode);;
			ЗаписьВРег.Записать();
		исключение
		конецпопытки;
		
	КонецЕсли;	
	
	
	
	
	
КонецПроцедуры




