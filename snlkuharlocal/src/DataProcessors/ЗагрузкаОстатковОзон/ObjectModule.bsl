Процедура ПунктДоставки_ПриИзменении(ПунктДоставки,РНК) экспорт
	//  19.08.2020 Кухарь конец
	
	
	
	//Кухарь 01.05.18 начало
	//Будем тип доставки фиксировать в документах
	ТипДоставки=ПунктДоставки.ТипДоставки;
	//Кухарь 01.05.18 конец
	
	
	Если НЕ ПунктДоставки.Пустая() Тогда
		
		
		НуженПересчетЦен=Ложь;
		
		Если ЗначениеЗаполнено(ПунктДоставки.Договор)  Тогда
			РНК.Договор=ПунктДоставки.Договор;
			РНК.Договор_ПриИзменении(Неопределено);
		КонецЕсли;
		
		//крохин конец 07.04.2011
		
		//доставка
		Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
			РНК.РайонДоставки=ПунктДоставки.РайонДоставки;			
		КонецЕсли;	
		Если ЗначениеЗаполнено(ПунктДоставки.Регион) Тогда
			рнк.Регион=ПунктДоставки.Регион;			
		КонецЕсли;	
		
		если РНК.ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
			Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
				РНК.ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
			иначе
				РНК.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
				РНК.ПунктПерегруза=ПунктДоставки.ПунктПерегруза;
			иначе
				РНК.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
			КонецЕсли;	
		иначе
			РНК.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();	
			РНК.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
		КонецЕсли;
		//Кухарь 26.01.16 конец
		
		Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
			РНК.Грузополучатель=ПунктДоставки.Грузополучатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
			РНК.Получатель=ПунктДоставки.Получатель;		
		КонецЕсли;
