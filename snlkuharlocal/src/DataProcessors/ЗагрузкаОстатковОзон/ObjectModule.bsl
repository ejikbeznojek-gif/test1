функция  ПолучитьОстатокТовара(НоменклСп)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	""Остатки"" КАК Раздел,
	|	СУММА(Остатки.КоличествоКонечныйОстаток) КАК КолКонБух,
	|	ВЫБОР
	|		КОГДА СУММА(Остатки.КоличествоКонечныйОстаток) = 0
	|			ТОГДА NULL
	|		ИНАЧЕ СУММА(Остатки.СуммаКонечныйОстаток) / СУММА(Остатки.КоличествоКонечныйОстаток)
	|	КОНЕЦ КАК ЦенаСеб,
	|	СУММА(Остатки.СуммаКонечныйОстаток) КАК СебестоимостьБух,
	|	СУММА(Остатки.КоличествоКонечныйОстаток - ЕСТЬNULL(Резервы.КоличествоКонечныйОстаток, 0)) КАК КолКонФакт,
	|	СУММА(ЕСТЬNULL(Резервы.КоличествоКонечныйОстаток, 0)) КАК Резерв,
	|	Остатки.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.ОстаткиИОбороты(
	|			НАЧАЛОПЕРИОДА(&Дата1, ДЕНЬ),
	|			КОНЕЦПЕРИОДА(&дата1, ДЕНЬ),
	|			Период,
	|			,
	|			Склад В ИЕРАРХИИ (&Склады)
	|				И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.ОстаткиИОбороты(
	|				НАЧАЛОПЕРИОДА(&Дата1, ДЕНЬ),
	|				КОНЕЦПЕРИОДА(&дата1, ДЕНЬ),
	|				Период,
	|				,
	|				Склад В ИЕРАРХИИ (&Склады)
	|					И Номенклатура В ИЕРАРХИИ (&Ном)) КАК Резервы
	|		ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			И Остатки.Склад = Резервы.Склад
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура";
	Склад = справочники.Склады.НайтиПоКоду("STC-81");
	
	Запрос.УстановитьПараметр("Склады",склад);
	Запрос.УстановитьПараметр("Дата1",текущаядата());
	Запрос.УстановитьПараметр("Ном",НоменклСп);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	возврат РезультатЗапроса;
	
	
	
конецФункции	

