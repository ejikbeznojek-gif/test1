	//	Предупреждение("Доп. обработки будут перезаполнены по умолчанию из карточки контрагента !");
	//КонецЕсли;	
	РНК.ДопОбработки.Очистить();
	Если ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
		Для Каждого СтрокаТЧ Из Контрагент.ВидыДопОбработок Цикл
			СтрокаДО=РНК.ДопОбработки.Добавить();	
