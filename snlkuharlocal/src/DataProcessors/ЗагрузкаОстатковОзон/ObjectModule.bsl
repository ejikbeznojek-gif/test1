	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата; //ЛокальнаяДата;      "2020-10-31T21:00:00Z",
	
	Дата2 =ТекущаяДата();
	Дата1 = ДобавитьДату(ТекущаяДата(),-60*60*24*7);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	РасходнаяНакладная.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.ПометкаУдаления = &ложь
	|	И РасходнаяНакладная.Контрагент = &озон
	|	И РасходнаяНакладная.Дата >= &Дата1
	|	И РасходнаяНакладная.Дата <= &Дата2
	|	И РасходнаяНакладная.ПунктДоставки = &ПДОзон";
	
	Запрос.УстановитьПараметр("Дата1", НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата2));
	Запрос.УстановитьПараметр("ложь", ложь);
	Запрос.УстановитьПараметр("озон", контрагент);
	Запрос.УстановитьПараметр("ПДозон", Справочники.ПунктыДоставки.НайтиПоКоду("SNL-024031"));  // пд озон
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		//	состояние( ВыборкаДетальныеЗаписи.ссылка);
		// Вставить обработку выборки ВыборкаДетальныеЗаписи
		НомерОтправления = ВыборкаДетальныеЗаписи.номерЗаказа;
		Если НомерОтправления = "" Тогда
			продолжить;
		конецЕсли;	
		ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".json");
		//сообщить(ИмяВыходногоФайлаДж);
		
		
		Запись = Новый ЗаписьJSON;
		ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
		Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
		
		НастройкиСериализации = Новый НастройкиСериализацииJSON;
		НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
		НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.УниверсальнаяДата;		
		//--------------------------------------------------------------------------------
		// блок по считываю состояния документа
		СтрПРо= Новый Структура;
		
		
		Данные = Новый Структура;
		Данные.Вставить("posting_number",НомерОтправления);
		
		Попытка
			ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
			Запись.Закрыть();
			// Возврат Истина;
		Исключение
			//сообщить(ОписаниеОшибки());
			// ЗаписьЖурналаРегистрации(ИмяСобытияЖР,УровеньЖурналаРегистрации.Ошибка,,,"Прайс не сформирован, произошла ошибка " + ОписаниеОшибки());
			//  Возврат Ложь;
		КонецПопытки;;  
		
		
		// выполнение пост запроса.
		//-------------------------------
		Результат = POSTЗапросИз1С_Статус(Команда,ИмяВыходногоФайлаДЖ,".json") ;    // ИмяВыходногоФайла?
		//-------------------------------
		р2=Результат.ПолучитьТелоКакСтроку();
		//	сообщить(р2);
		
		
		//18333880-0029-2
		
		//		
		//		awaiting_packaging — ожидает упаковки,
		//not_accepted — не принят в сортировочном центре,
		//arbitration — ожидает решения спора,
		//awaiting_deliver — ожидает отгрузки,
		//delivering — доставляется,
		//driver_pickup — у водителя,
		//delivered — доставлено,
		//cancelled — отменено.
		
		
		// 2 вариант для обработки, так проще.
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Результат.ПолучитьТелоКакСтроку());
		
		Данные = ПрочитатьJSON(ЧтениеJSON, Ложь); // тут в структуру все выгружено
		
		Попытка 
			Если Данные.result<>неопределено тогда
				//	пауза(1);
				Статус = Данные.result.status;
				СтатусРНК = ПоследнийСтатусРНК(ВыборкаДетальныеЗаписи.ссылка);
				Если Статус = СтатусРНК тогда
					продолжить;
				КонецЕсли;	
				
				// только новые записываем.
				
				ИмСпр = Справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(статус);				
				// запишем в регистр СостояниеНакладнойУКлиента
				Если имСпр = справочники.СостояниеНакладнойУКлиента.ПустаяСсылка() тогда
					//сообщить(".......не найдено - "+статус);
					продолжить;
				КонецЕсли;	
				МенеджерЗаписи = РегистрыСведений.СостояниеНакладнойУКлиента.СоздатьМенеджерЗаписи();
				
				МенеджерЗаписи.Объект = ВыборкаДетальныеЗаписи.ссылка;
				МенеджерЗаписи.Дата = ТекущаяДата();
				МенеджерЗаписи.СостояниеУклиента = ИмСпр;
				
				МенеджерЗаписи.Записать();
				/// тут если отменен отправим письмо еще раз.
				
