Функция ВызватьФункциюМенеджера(ИмяМенеджера,ИмяФункции,Параметры=Неопределено) Экспорт
	Результат	= Неопределено;	
	
	Если ТипЗнч(Параметры)=Тип("Структура") Тогда		
		ФормПараметры	= Новый Массив;
		ФактПараметры 	= Новый Массив;
		Для Каждого Элемент Из Параметры Цикл
			ФормПараметры.Добавить("ФактПараметры["+ФормПараметры.Количество()+"]");
			ФактПараметры.Добавить(Элемент.Значение);
		КонецЦикла; 
		
		ИсполняемаяФормула="Результат="+ИмяМенеджера+"."+ИмяФункции+"("+СтрСоединить(ФормПараметры,",")+")";
	ИначеЕсли Параметры<>Неопределено Тогда
		ИсполняемаяФормула="Результат="+ИмяМенеджера+"."+ИмяФункции+"(Параметры)";			
	Иначе
		ИсполняемаяФормула="Результат="+ИмяМенеджера+"."+ИмяФункции+"()";		
	КонецЕсли; 
	
	Выполнить(ИсполняемаяФормула);
	
	Возврат Результат;
КонецФункции // ()

