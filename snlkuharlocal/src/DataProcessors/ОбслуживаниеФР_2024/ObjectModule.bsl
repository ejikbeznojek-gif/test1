КонецФункции //РевизияИнтерфейса(Оборудование)
 
Функция ПроверитьПодключитьОборудование(Оборудование) Экспорт
	Результат	= Новый Структура("Успешно,Ошибки", Ложь, "");	
	
	Если ОборудованиеПодключено(Оборудование) Тогда 
		Результат.Успешно = Истина;		
	Иначе		
		рПодключения	= ПодключитьОборудование(Оборудование);
		Если НЕ рПодключения.Успешно Тогда
			Результат.Ошибки = "Ошибка при подключении ТО ! "+рПодключения.Ошибки;
		Иначе              
			Результат.Успешно = Истина;			
		КонецЕсли; 
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПроверитьПодключитьОборудование(Оборудование) Экспорт

Функция ПолучитьПараметрыККТ(Оборудование) Экспорт
	Результат	= Новый Структура("Успешно,Ошибки",Ложь,"");	
	
	РезультатПодключения	= ПроверитьПодключитьОборудование(Оборудование);
	Если НЕ РезультатПодключения.Успешно Тогда
		Результат.Ошибки=РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ВходныеПараметры = Новый Структура("Кассир,КассирИНН,АдресРасчетов,МестоРасчетов","Администратор");
	
	Кассир			= ВходныеПараметры.Кассир;
	КассирИНН		= ВходныеПараметры.КассирИНН;
	
	Если НЕ ПроверитьИННКассира(КассирИНН,Результат.Ошибки) Тогда
		Возврат Результат;	
	КонецЕсли; 
	
	НомерСмены     	= 0;
	НомерДокумента 	= 0;
	СтатусСмены		= 0;
	ПараметрыСмены	= Неопределено;	
	
		
	РевизияИнтерфейса	= РевизияИнтерфейса(Оборудование);
	ОбъектДрайвера		= ПолучитьОбъектДрайвера(Оборудование);		
	
	ПроверитьДемоРежим(ОбъектДрайвера);
	
	ИДУстройства		= ИдентификаторПодключенногоОборудования(Оборудование);
	
	// Получить параметры ККТ при открытии смены.
	ПараметрыККТ = "";
	Попытка		
		Если НЕ ОбъектДрайвера.ПолучитьПараметрыККТ(ИДУстройства, ПараметрыККТ) Тогда
			ОписаниеОшибки = "";
			ОбъектДрайвера.ПолучитьОшибку(ОписаниеОшибки); 
			Результат.Ошибки	= "Ошибка результата метода <ОбъектДрайвера.ПолучитьПараметрыККТ>. " + Символы.ПС + ОписаниеОшибки;
			Возврат Результат;
		КонецЕсли;
	Исключение		
		Результат.Ошибки	= НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ПолучитьПараметрыККТ>.'") + Символы.ПС + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	
	ПараметрыККТ = ПараметрыККТИзXMLПакета(ПараметрыККТ, РевизияИнтерфейса);
	
	Вход 	= ВходныеПараметрыXML(ВходныеПараметры, РевизияИнтерфейса);
	Выход   = "";	
	
	Попытка
		
		Если РевизияИнтерфейса >= 3000 Тогда // Версия стандарта 3.0 (ОФД 1.1)
			РезультатДрайвера = ОбъектДрайвера.ПолучитьТекущееСостояние(ИДУстройства, Вход, Выход); 
			Если РезультатДрайвера Тогда
				ПараметрыСмены		= ПолучитьПараметрыСменыИзXMLПакета(Выход,РевизияИнтерфейса);				
				СтатусСмены			= ПараметрыСмены.СтатусСмены;
				Результат.Успешно   = Истина;
			Иначе
				Ошибка	= "";
				ОбъектДрайвера.ПолучитьОшибку(Ошибка);
			КонецЕсли;
		Иначе
			Если РевизияИнтерфейса >= 2002 Тогда // Версия стандарта 2.2 (ОФД 1.0.5)
				ОбъектДрайвера.ПолучитьТекущееСостояние(ИДУстройства,НомерДокумента,НомерСмены,СтатусСмены,Выход);
				ПараметрыСмены = ПолучитьПараметрыСменыИзXMLПакета(Выход, РевизияИнтерфейса);
			Иначе				
				Результат.Ошибки = "Недопустимая ревизия интерфейса: """+РевизияИнтерфейса+""" !";
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		
		Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.ОткрытьСмену>.'") + Символы.ПС + ОписаниеОшибки();			
		
	КонецПопытки;
	
	
	Если Результат.Успешно Тогда
		// Заполнение выходных параметров.
		ВыходныеПараметры=Новый Структура();
		
		
		ВыходныеПараметры.Вставить("НомерСмены",			НомерСмены);
		ВыходныеПараметры.Вставить("НомерДокумента",		НомерДокумента);
		ВыходныеПараметры.Вставить("СтатусСмены",			СтатусСмены); // 1- закрыта, 2 - Открыта, 3 - просрочена
		ВыходныеПараметры.Вставить("ДатаСеанса",			ТекущаяДата());
		
		ВыходныеПараметры.Вставить("ПараметрыСмены",		ПараметрыСмены);
		ВыходныеПараметры.Вставить("ПараметрыККТ",			ПараметрыККТ);
		ВыходныеПараметры.Вставить("ПараметрыСостояния",	Выход);		
		ВыходныеПараметры.Вставить("ОбъектДрайвера",		ОбъектДрайвера);
		
		Результат.Успешно	= Истина;
		Результат.Вставить("Данные",ВыходныеПараметры);
	Иначе		
		Ошибки	= "";
		ОбъектДрайвера.ПолучитьОшибку(Ошибки);
		
		Результат.Ошибки	= СокрЛП(Результат.Ошибки+" "+Ошибки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьДемоРежим(ОбъектДрайвера) Экспорт
	ОписаниеРезультата		= "";
	АктивированДемоРежим	= "";
	РезультатТеста = ОбъектДрайвера.ТестУстройства(ОписаниеРезультата, АктивированДемоРежим);
	Если РезультатТеста И Не ПустаяСтрока(АктивированДемоРежим) Тогда
		Сообщить(АктивированДемоРежим);
	КонецЕсли;
КонецФункции // ()

Функция ВходныеПараметрыXML(ОбщиеПараметры, РевизияИнтерфейса = 0) Экспорт
	ПараметрыПоУмолчанию	= Новый Структура("Кассир,КассирИНН","Администратор","");
	
	Кассир			= ПолучитьПараметр(ОбщиеПараметры,"Кассир",			ПараметрыПоУмолчанию);
	КассирИНН		= ПолучитьПараметр(ОбщиеПараметры,"КассирИНН",		ПараметрыПоУмолчанию);	
	АдресРасчетов   = ПолучитьПараметр(ОбщиеПараметры,"АдресРасчетов",	ПараметрыПоУмолчанию);
	МестоРасчетов   = ПолучитьПараметр(ОбщиеПараметры,"МестоРасчетов",	ПараметрыПоУмолчанию);
	
	ЗаписьXML = Новый ЗаписьXML();
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("InputParameters");
	ЗаписьXML.ЗаписатьНачалоЭлемента("Parameters");
	
	Если РевизияИнтерфейса >= 3000 Тогда  // Версия стандарта 3.0 (ОФД 1.1)
		ЗаписьXML.ЗаписатьАтрибут("CashierName", Кассир);
		ЗаписьXML.ЗаписатьАтрибут("CashierINN" , КассирИНН);
		Если ЗначениеЗаполнено(АдресРасчетов) Тогда   
			ЗаписьXML.ЗаписатьАтрибут("SaleAddress", АдресРасчетов);
		КонецЕсли;
		Если ЗначениеЗаполнено("МестоРасчетов") Тогда  
			ЗаписьXML.ЗаписатьАтрибут("SaleLocation", МестоРасчетов);
		КонецЕсли;
	Иначе
		ЗаписьXML.ЗаписатьАтрибут("CashierName" , Кассир);
		ЗаписьXML.ЗаписатьАтрибут("CashierVATIN", КассирИНН);
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции

Функция ПолучитьПараметр(Параметры, Имя, ЗначенияПоУмолчанию)
	ТекЗнач	= Неопределено;
	Параметры.Свойство(Имя,ТекЗнач);
	Если НЕ ЗначениеЗаполнено(ТекЗнач) Тогда
		ЗначенияПоУмолчанию.Свойство(Имя,ТекЗнач);		
	КонецЕсли; 
	
	//Возврат XMLСтрока(ТекЗнач); ?????? TODO проверить зачем XMLСтрока 
	//пока заменил т.к. не работает в web клиенте
	Возврат Строка(ТекЗнач);
КонецФункции // ()


#КонецОбласти 


Функция ПараметрыККТИзXMLПакета(Данные, РевизияИнтерфейса = 0) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML; 
	ЧтениеXML.УстановитьСтроку(Данные);
	ЧтениеXML.ПерейтиКСодержимому();
	
	ПараметрыККТ = ПараметрыРегистрацииККТ();
	ПараметрыККТ.Вставить("ТипОборудования", "ККТ");
	
	Если РевизияИнтерфейса >= 3000 Тогда  // Версия стандарта 3.0 (ОФД 1.1)
		
		Если (ЧтениеXML.Имя = "Parameters" Или ЧтениеXML.Имя = "TableParametersKKT") И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
			ПараметрыККТ.ВерсияФФДФН   = ЧтениеXML.ЗначениеАтрибута("FFDVersionFN");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДФН) Тогда
				ПараметрыККТ.ВерсияФФДФН = "1.0";
			КонецЕсли;
			ПараметрыККТ.ВерсияФФДККТ  = ЧтениеXML.ЗначениеАтрибута("FFDVersionKKT");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДККТ) Тогда
				ПараметрыККТ.ВерсияФФДККТ = "1.0";
			КонецЕсли;
			// ФФД 1.0
			ПараметрыККТ.РегистрационныйНомерККТ    = СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTNumber"));
			ПараметрыККТ.ЗаводскойНомерККТ          = СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTSerialNumber"));
			ПараметрыККТ.ЗаводскойНомерФН           = СокрЛП(ЧтениеXML.ЗначениеАтрибута("FNSerialNumber"));
			ПараметрыККТ.ОрганизацияНазвание        = ЧтениеXML.ЗначениеАтрибута("CompanyName");
			ПараметрыККТ.ОрганизацияИНН             = СокрЛП(ЧтениеXML.ЗначениеАтрибута("INN"));
			ПараметрыККТ.АдресПроведенияРасчетов    = ЧтениеXML.ЗначениеАтрибута("SaleAddress");
			ПараметрыККТ.МестоПроведенияРасчетов    = ЧтениеXML.ЗначениеАтрибута("SaleLocation");
			ПараметрыККТ.КодыСистемыНалогообложения = ЧтениеXML.ЗначениеАтрибута("TaxationSystems");
			ПараметрыККТ.ПризнакАвтономногоРежима   = ВРег(ЧтениеXML.ЗначениеАтрибута("IsOffline")) = "TRUE";
			ПараметрыККТ.ПризнакШифрованиеДанных    = ВРег(ЧтениеXML.ЗначениеАтрибута("IsEncrypted")) = "TRUE";
			ПараметрыККТ.ПризнакРасчетовЗаУслуги    = ВРег(ЧтениеXML.ЗначениеАтрибута("IsService")) = "TRUE";
			ПараметрыККТ.ПродажаПодакцизногоТовара  = ВРег(ЧтениеXML.ЗначениеАтрибута("IsExcisable")) = "TRUE";
			ПараметрыККТ.ПроведенияАзартныхИгр      = ВРег(ЧтениеXML.ЗначениеАтрибута("IsGambling")) = "TRUE";
			ПараметрыККТ.ПроведенияЛотерей          = ВРег(ЧтениеXML.ЗначениеАтрибута("IsLottery")) = "TRUE";
			ПараметрыККТ.ПризнакиАгента             = ЧтениеXML.ЗначениеАтрибута("AgentTypes");
			ПараметрыККТ.ПризнакФормированияБСО         = ВРег(ЧтениеXML.ЗначениеАтрибута("BSOSing")) = "TRUE";
			ПараметрыККТ.ПризнакРасчетовТолькоВИнтернет = ВРег(ЧтениеXML.ЗначениеАтрибута("IsOnlineOnly")) = "TRUE";
			ПараметрыККТ.УстановкаПринтераВАвтомате     = ВРег(ЧтениеXML.ЗначениеАтрибута("IsAutomaticPrinter")) = "TRUE";;
			ПараметрыККТ.ПризнакАвтоматическогоРежима   = ВРег(ЧтениеXML.ЗначениеАтрибута("IsAutomatic")) = "TRUE";
			ПараметрыККТ.НомерАвтоматаДляАвтоматическогоРежима = ЧтениеXML.ЗначениеАтрибута("AutomaticNumber");
			ПараметрыККТ.ОрганизацияОФДНазвание     = ЧтениеXML.ЗначениеАтрибута("OFDCompany");
			ПараметрыККТ.ОрганизацияОФДИНН          = СокрЛП(ЧтениеXML.ЗначениеАтрибута("OFDCompanyINN"));
			ПараметрыККТ.ПризнакФискализации        = ВРег(ЧтениеXML.ЗначениеАтрибута("Fiscal")) = "TRUE";
			ПараметрыККТ.НомерДокументаФискализации = ЧтениеXML.ЗначениеАтрибута("DocumentNumber");
			ПараметрыККТ.ДатаВремяФискализации      = ЧтениеXML.ЗначениеАтрибута("DateTime");
			ПараметрыККТ.ОтправительEmail           = ЧтениеXML.ЗначениеАтрибута("SenderEmail");
			ПараметрыККТ.АдресСайтаФНС              = ЧтениеXML.ЗначениеАтрибута("FNSURL");
		КонецЕсли;
		
	Иначе
		
		Если ЧтениеXML.Имя = "Parameters" И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
			ПараметрыККТ.ВерсияФФДФН   = ЧтениеXML.ЗначениеАтрибута("FFDVersionFN");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДФН) Тогда
				ПараметрыККТ.ВерсияФФДФН = "1.0";
			КонецЕсли;
			ПараметрыККТ.ВерсияФФДККТ  = ЧтениеXML.ЗначениеАтрибута("FFDVersionKKT");
			Если ПустаяСтрока(ПараметрыККТ.ВерсияФФДККТ) Тогда
				ПараметрыККТ.ВерсияФФДККТ = "1.0";
			КонецЕсли;
			// ФФД 1.0
			ПараметрыККТ.РегистрационныйНомерККТ        = СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTNumber"));
			ПараметрыККТ.ОрганизацияНазвание            = ЧтениеXML.ЗначениеАтрибута("OrganizationName");
			ПараметрыККТ.ОрганизацияИНН                 = СокрЛП(ЧтениеXML.ЗначениеАтрибута("VATIN"));
			ПараметрыККТ.АдресПроведенияРасчетов        = ЧтениеXML.ЗначениеАтрибута("AddressSettle");
			ПараметрыККТ.МестоПроведенияРасчетов        = ЧтениеXML.ЗначениеАтрибута("PlaceSettle");
			ПараметрыККТ.КодыСистемыНалогообложения     = ЧтениеXML.ЗначениеАтрибута("TaxVariant");
			Если ПустаяСтрока(ПараметрыККТ.КодыСистемыНалогообложения) Тогда
				ПараметрыККТ.КодыСистемыНалогообложения = ЧтениеXML.ЗначениеАтрибута("TaxVarinat");
			КонецЕсли;
			ПараметрыККТ.ПризнакАвтономногоРежима	       		= ВРег(ЧтениеXML.ЗначениеАтрибута("OfflineMode")) = "TRUE";
			ПараметрыККТ.ПризнакАвтоматическогоРежима   		= ВРег(ЧтениеXML.ЗначениеАтрибута("AutomaticMode")) = "TRUE";
			ПараметрыККТ.НомерАвтоматаДляАвтоматическогоРежима = ЧтениеXML.ЗначениеАтрибута("AutomaticNumber");
			ПараметрыККТ.ПризнакФормированияБСО         		= ВРег(ЧтениеXML.ЗначениеАтрибута("BSOSing")) = "TRUE";
			ПараметрыККТ.ПризнакРасчетовТолькоВИнтернет 		= ВРег(ЧтениеXML.ЗначениеАтрибута("CalcOnlineSign")) = "TRUE";
			ПараметрыККТ.ПризнакШифрованиеДанных       		= ВРег(ЧтениеXML.ЗначениеАтрибута("DataEncryption")) = "TRUE";
			ПараметрыККТ.ОрганизацияОФДИНН          			= СокрЛП(ЧтениеXML.ЗначениеАтрибута("OFDVATIN"));
			ПараметрыККТ.ОрганизацияОФДНазвание     			= ЧтениеXML.ЗначениеАтрибута("OFDOrganizationName");
			ПараметрыККТ.ЗаводскойНомерККТ          			= СокрЛП(ЧтениеXML.ЗначениеАтрибута("KKTSerialNumber"));
			ПараметрыККТ.ПризнакФискализации        			= ВРег(ЧтениеXML.ЗначениеАтрибута("Fiscal")) = "TRUE";
			ПараметрыККТ.ЗаводскойНомерФН           			= СокрЛП(ЧтениеXML.ЗначениеАтрибута("FNSerialNumber"));
			ПараметрыККТ.НомерДокументаФискализации 			= ЧтениеXML.ЗначениеАтрибута("DocumentNumber");
			ПараметрыККТ.ДатаВремяФискализации      			= ЧтениеXML.ЗначениеАтрибута("DateTime");
			ПараметрыККТ.ПризнакРасчетовЗаУслуги		   		= ВРег(ЧтениеXML.ЗначениеАтрибута("ServiceSign")) = "TRUE";
			ПараметрыККТ.ПродажаПодакцизногоТовара  			= ВРег(ЧтениеXML.ЗначениеАтрибута("SaleExcisableGoods")) = "TRUE";
			ПараметрыККТ.ПроведенияАзартныхИгр		    		= ВРег(ЧтениеXML.ЗначениеАтрибута("SignOfGambling")) = "TRUE";
			ПараметрыККТ.ПроведенияЛотерей         			= ВРег(ЧтениеXML.ЗначениеАтрибута("SignOfLottery")) = "TRUE";
			ПараметрыККТ.ПризнакиАгента             			= ЧтениеXML.ЗначениеАтрибута("SignOfAgent");
			ПараметрыККТ.УстановкаПринтераВАвтомате 			= ВРег(ЧтениеXML.ЗначениеАтрибута("PrinterAutomatic")) = "TRUE";;
			ПараметрыККТ.ОтправительEmail           			= ЧтениеXML.ЗначениеАтрибута("SenderEmail");
			ПараметрыККТ.АдресСайтаФНС              			= ЧтениеXML.ЗначениеАтрибута("FNSWebSite");
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат ПараметрыККТ;
	
КонецФункции

Функция ИННСоответствуетТребованиям(Знач ИНН, ЭтоЮридическоеЛицо, ТекстСообщения) Экспорт
	
	СоответствуетТребованиям = Истина;
	ТекстСообщения = "";
	
	ИНН      = СокрЛП(ИНН);
	ДлинаИНН = СтрДлина(ИНН);
	
	Если ЭтоЮридическоеЛицо = Неопределено Тогда
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'Не определен тип владельца ИНН'");
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ОценкаПроизводительности.ТолькоЦифрыВСтроке(ИНН) Тогда
		СоответствуетТребованиям = Ложь;
		ТекстСообщения = ТекстСообщения + НСтр("ru = 'ИНН должен состоять только из цифр'");
	КонецЕсли;
	
	Если  ЭтоЮридическоеЛицо И ДлинаИНН <> 10 Тогда
		СоответствуетТребованиям = Ложь;
		ТекстСообщения = ТекстСообщения + ?(ЗначениеЗаполнено(ТекстСообщения), Символы.ПС, "")
			+ НСтр("ru = 'ИНН юридического лица должен состоять из 10 цифр'");
	ИначеЕсли НЕ ЭтоЮридическоеЛицо И ДлинаИНН <> 12 Тогда
		СоответствуетТребованиям = Ложь;
		ТекстСообщения = ТекстСообщения + ?(ЗначениеЗаполнено(ТекстСообщения), Символы.ПС, "")
			+ НСтр("ru = 'ИНН физического лица должен состоять из 12 цифр'");
	КонецЕсли;
	
	Если СоответствуетТребованиям Тогда
		Если ЭтоЮридическоеЛицо Тогда
			КонтрольнаяСумма = 0;
			Для Индекс = 1 По 9 Цикл
				Если Индекс = 1 Тогда
					Множитель = 2;
				ИначеЕсли Индекс = 2 Тогда
					Множитель = 4;
				ИначеЕсли Индекс = 3 Тогда
					Множитель = 10;
				ИначеЕсли Индекс = 4 Тогда
					Множитель = 3;
				ИначеЕсли Индекс = 5 Тогда
					Множитель = 5;
				ИначеЕсли Индекс = 6 Тогда
					Множитель = 9;
				ИначеЕсли Индекс = 7 Тогда
					Множитель = 4;
				ИначеЕсли Индекс = 8 Тогда
					Множитель = 6;
				ИначеЕсли Индекс = 9 Тогда
					Множитель = 8;
				КонецЕсли;
				Цифра = Число(Сред(ИНН, Индекс, 1));
				КонтрольнаяСумма = КонтрольнаяСумма + Цифра * Множитель;
			КонецЦикла;
			
			КонтрольныйРазряд = (КонтрольнаяСумма %11) %10;
			Если КонтрольныйРазряд <> Число(Сред(ИНН, 10, 1)) Тогда
				СоответствуетТребованиям = Ложь;
				ТекстСообщения = ТекстСообщения + ?(ЗначениеЗаполнено(ТекстСообщения), Символы.ПС, "")
				               + НСтр("ru = 'Контрольное число для ИНН не совпадает с рассчитанным'");
			КонецЕсли;
		Иначе
			КонтрольнаяСумма11 = 0;
			КонтрольнаяСумма12 = 0;
			Для Индекс = 1 По 11 Цикл
				// Расчет множителя для 11-го и 12-го разрядов.
				Если Индекс = 1 Тогда
					Множитель11 = 7;
					Множитель12 = 3;
				ИначеЕсли Индекс = 2 Тогда
					Множитель11 = 2;
					Множитель12 = 7;
				ИначеЕсли Индекс = 3 Тогда
					Множитель11 = 4;
					Множитель12 = 2;
				ИначеЕсли Индекс = 4 Тогда
					Множитель11 = 10;
					Множитель12 = 4;
				ИначеЕсли Индекс = 5 Тогда
					Множитель11 = 3;
					Множитель12 = 10;
				ИначеЕсли Индекс = 6 Тогда
					Множитель11 = 5;
					Множитель12 = 3;
				ИначеЕсли Индекс = 7 Тогда
					Множитель11 = 9;
					Множитель12 = 5;
				ИначеЕсли Индекс = 8 Тогда
					Множитель11 = 4;
					Множитель12 = 9;
				ИначеЕсли Индекс = 9 Тогда
					Множитель11 = 6;
					Множитель12 = 4;
				ИначеЕсли Индекс = 10 Тогда
					Множитель11 = 8;
					Множитель12 = 6;
				ИначеЕсли Индекс = 11 Тогда
					Множитель11 = 0;
					Множитель12 = 8;
				КонецЕсли;
				
				Цифра = Число(Сред(ИНН, Индекс, 1));
				КонтрольнаяСумма11 = КонтрольнаяСумма11 + Цифра * Множитель11;
				КонтрольнаяСумма12 = КонтрольнаяСумма12 + Цифра * Множитель12;
				
			КонецЦикла;
			
			КонтрольныйРазряд11 = (КонтрольнаяСумма11 %11) %10;
			КонтрольныйРазряд12 = (КонтрольнаяСумма12 %11) %10;
			
			Если КонтрольныйРазряд11 <> Число(Сред(ИНН,11,1)) ИЛИ КонтрольныйРазряд12 <> Число(Сред(ИНН,12,1)) Тогда
				СоответствуетТребованиям = Ложь;
				ТекстСообщения = ТекстСообщения + ?(ЗначениеЗаполнено(ТекстСообщения), Символы.ПС, "")
				               + НСтр("ru = 'Контрольное число для ИНН не совпадает с рассчитанным'");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СоответствуетТребованиям;
	
КонецФункции 


