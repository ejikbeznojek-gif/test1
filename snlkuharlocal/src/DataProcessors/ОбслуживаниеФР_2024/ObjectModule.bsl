Функция ПечатьСлипЧека(ФискальноеУстройство, ТекстСлипЧека, КоличествоСлипЧеков)
	
	Результат = Новый Структура("Успешно,Ошибки", Ложь, "");	
	
	РезультатПодключения	= ПроверитьПодключитьОборудование(ФискальноеУстройство);
	Если НЕ РезультатПодключения.Успешно Тогда
		Результат.Ошибки=РезультатПодключения.Ошибки;
		Возврат Результат;
	КонецЕсли;
	
	ИДУстройства			= ИдентификаторПодключенногоОборудования(ФискальноеУстройство);
	РевизияИнтерфейса		= РевизияИнтерфейса(ФискальноеУстройство);
	ОбъектДрайвера			= ПолучитьОбъектДрайвера(ФискальноеУстройство);	
	
	ДанныеСлипЧекаXML		= ПолучитьXMLДляПечатиСлипЧеков(ТекстСлипЧека, РевизияИнтерфейса);
	
	Для НомерСлипЧека = 1 По КоличествоСлипЧеков Цикл
		Попытка
			Результат.Успешно = ОбъектДрайвера.НапечататьТекстовыйДокумент(ИДУстройства, ДанныеСлипЧекаXML);
			Если НЕ Результат.Успешно Тогда				
				ОбъектДрайвера.ПолучитьОшибку(Результат.Ошибки);
			КонецЕсли;
		Исключение		
			Результат.Ошибки=НСтр("ru='Ошибка вызова метода <ОбъектДрайвера.НапечататьТекстовыйДокумент>.'") + Символы.ПС + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	
	Возврат Результат;	
	
КонецФункции

Функция ПолучитьXMLДляПечатиСлипЧеков(ТекстСлипЧека, РевизияИнтерфейса) Экспорт
	
	// формируем пакет для печати подарочных сертификатов
	ЗаписьXML = Новый ЗаписьXML();
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("Document");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Positions");
	
	Для НомерСтроки = 1 По СтрЧислоСтрок(ТекстСлипЧека) Цикл
			
		ВыделеннаяСтрока = СтрПолучитьСтроку(ТекстСлипЧека, НомерСтроки);
			
		ЗаписьXML.ЗаписатьНачалоЭлемента("TextString");
		ЗаписьXML.ЗаписатьАтрибут("Text", XMLСтрока(ВыделеннаяСтрока));
		ЗаписьXML.ЗаписатьКонецЭлемента();
			
	КонецЦикла;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	Результат = ЗаписьXML.Закрыть();
	
	Возврат Результат;
	
КонецФункции

