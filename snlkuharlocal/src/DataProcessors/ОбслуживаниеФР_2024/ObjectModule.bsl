&НаКлиенте
Процедура НастроитьОборудование_Завершение(Результат, Параметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		РезультатЗавершения = Ложь;
		Если Результат.Свойство("Оборудование") И Результат.Свойство("ПараметрыОборудования") Тогда
			РезультатЗавершения = СохранитьПараметрыУстройства(Результат.Оборудование, Результат.ПараметрыОборудования);
		КонецЕсли;
		
		Если РезультатЗавершения Тогда 
			ОбновитьПовторноИспользуемыеЗначения();
		Иначе
			СообщениеОбОшибке = НСтр("ru='Не удалось сохранить параметры устройства.'");
			Сообщить(СообщениеОбОшибке);
		КонецЕсли;		
		
	КонецЕсли;
	
КонецПроцедуры
 

