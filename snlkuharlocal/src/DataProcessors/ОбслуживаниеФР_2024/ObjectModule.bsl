	Если ОборудованиеПодключено(Оборудование) Тогда
		//ДрайверСсылка	= ПолучитьРеквизитШапки(Оборудование,	"ДрайверОборудования");		
		//Результат		= ПолучитьРеквизитШапки(ДрайверСсылка,	"РевизияИнтерфейса");
		
		Результат		= 3003;
	КонецЕсли; 
	
