Функция ПолучитьПараметры() Экспорт
	ТП = Новый ТаблицаЗначений;
	ТП.Колонки.Добавить("Имя");
	ТП.Колонки.Добавить("Значение");
	
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "ИмяСервера"; 		СтрокаТП.Значение = "";
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "ИмяБазы"; 		СтрокаТП.Значение = "";
	
	//СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "Пользователь"; 	СтрокаТП.Значение = "Экспорт";
	//СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "Пароль"; 		СтрокаТП.Значение = "";
	
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "Организация";			СтрокаТП.Значение = Организация;
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "ГруппаФЛ_ЕЕ";			СтрокаТП.Значение = ГруппаФЛ_ЕЕ;
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "Уволенные";			СтрокаТП.Значение = Уволенные;	
	СтрокаТП = ТП.Добавить(); СтрокаТП.Имя = "фОтправлятьПисьмо";	СтрокаТП.Значение = Ложь;
	
	Возврат ТП;
КонецФункции //ПолучитьПараметры() Экспорт
 
Функция ЗагрузитьФЛ_Файл(СтрокаДанных) Экспорт
	Чтение = Новый ЧтениеXML();
	Чтение.УстановитьСтроку(СтрокаДанных);
	
	ТЗ = СериализаторXDTO.ПрочитатьXML(Чтение);
	
	ЗагрузитьФЛ(ТЗ);	
КонецФункции // ()

Функция ЗагрузитьФЛ_HTTP() Экспорт
	Результат	= Новый Структура("Успешно,Данные,Ошибки,Сообщения", Истина, Неопределено, Новый Массив, Новый Массив);
	резИст		= ПолучитьДанныеФЛчерезHTTP();	
	
	Если резИст.Успешно Тогда
		ЗагрузитьФЛ(резИст.Данные);
	Иначе
		ДобавитьОшибки(Результат, резИст);
	КонецЕсли;	
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0); 
	Возврат Результат;
КонецФункции //ЗагрузитьФЛ_HTTP()

Функция ЗагрузитьЛС_HTTP() Экспорт
	Результат	= Новый Структура("Успешно,Данные,Ошибки,Сообщения,ЗагруженоОбъектов", Истина, Неопределено, Новый Массив, Новый Массив, 0);	
	
	резИст		= ПолучитьДанныеЛСчерезHTTP();	
	Если резИст.Успешно Тогда
		Результат = ЗагрузитьЛС(резИст.Данные);
	Иначе
		ДобавитьОшибки(Результат, резИст);
	КонецЕсли;	
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0); 
	Возврат Результат;
КонецФункции //ЗагрузитьФЛ_HTTP()

Функция ПолучитьДанныеФЛчерезHTTP()
	Результат = Новый Структура("Успешно,Данные,Ошибки", Истина, Неопределено, Новый Массив);

	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудник	
	|ПОМЕСТИТЬ ВТ_СотрудникиГПХ
	|ИЗ
	|	Документ.ДоговорРаботыУслуги
	|ГДЕ
	|	ДатаНачала>ДАТАВРЕМЯ(1980, 1, 1)
	|	И СпособРасчетовСФизическимиЛицами = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетовСФизическимиЛицами.РасчетыСКонтрагентами)	
	|;
	|ВЫБРАТЬ
	|	ТекКД.Сотрудник.Код					КАК КодЗуп,
	|	ТекКД.Сотрудник.Код					КАК ТабЗуп, //Нечаева. На кой надо ХЗ - но трогать страшно
	|	""EE""+ТекКД.ФизическоеЛицо.Код 	КАК Код,	
	|	ТекКД.ФизическоеЛицо.Наименование	КАК Наименование,
	|	""ES""+История.Подразделение.Код	КАК КодПодр,
	|	История.Подразделение.Наименование	КАК Подразделение,
	|	История.Должность.Наименование		КАК Должность,
	|	ТекКД.ДатаУвольнения				КАК ДатаУвольнения
	|ИЗ
	|	РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК ТекКД
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(&ТекДата)	 КАК История
	|ПО
	|	История.Сотрудник = ТекКД.Сотрудник	
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_СотрудникиГПХ
	|ПО
	|	ВТ_СотрудникиГПХ.Сотрудник = ТекКД.Сотрудник
	|ГДЕ
	|	ТекКД.ДатаПриема <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) 
	|	И ТекКД.ДатаПриема>=ДАТАВРЕМЯ(1, 1, 1) 
	|	И ВТ_СотрудникиГПХ.Сотрудник ЕСТЬ NULL
	|	И (
	|		ТекКД.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|		ИЛИ НачалоПериода(ТекКД.ДатаУвольнения, ДЕНЬ) > &ТекДата
	|	)	
	|	И НЕ ТекКД.Сотрудник.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	ТекКД.ФизическоеЛицо.Наименование	
	|";
	
	Данные = Новый ТаблицаЗначений;
	
	пЗапроса = Новый Структура("ТекДата", ТекущаяДата());	
	резИст = ВыполнитьЗапросКИсточнику(ТекстЗапроса, пЗапроса);
	Если резИст.Успешно Тогда
		Результат.Данные = резИст.Данные;		
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, резИст);
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьДанныеФЛчерезHTTP()

Функция ПолучитьДанныеЛСчерезHTTP()
	Результат = Новый Структура("Успешно,Данные,Ошибки", Истина, Неопределено, Новый Массив);

	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудник	
	|ПОМЕСТИТЬ ВТ_СотрудникиГПХ
	|ИЗ
	|	Документ.ДоговорРаботыУслуги
	|ГДЕ
	|	ДатаНачала>ДАТАВРЕМЯ(1980, 1, 1)
	|	И СпособРасчетовСФизическимиЛицами = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетовСФизическимиЛицами.РасчетыСКонтрагентами)	
	|;	
	|ВЫБРАТЬ	
	|	""EE""+ТекКД.ФизическоеЛицо.Код 	КАК ТабельныйНомер,	
	|	ТекКД.ФизическоеЛицо.Наименование	КАК ФИО,	
	|	ЛицевыеСчета.НомерЛицевогоСчета		КАК НомерЛицевогоСчета,	
	|	ЛицевыеСчета.ЗарплатныйПроект.Банк.Код			КАК Бик, 
	|	ЛицевыеСчета.ЗарплатныйПроект.Банк.ИНН			КАК Банк_ИНН, 
	|	ЛицевыеСчета.ЗарплатныйПроект.Банк.КоррСчет		КАК Банк_КоррСчет,
	|	ЛицевыеСчета.ЗарплатныйПроект.Банк.Наименование	КАК Банк_Наименование
	|ИЗ
	|	РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК ТекКД
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(&ТекДата)	 КАК История
	|ПО
	|	История.Сотрудник = ТекКД.Сотрудник	
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_СотрудникиГПХ
	|ПО
	|	ВТ_СотрудникиГПХ.Сотрудник = ТекКД.Сотрудник
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ЛицевыеСчетаСотрудниковПоЗарплатнымПроектам КАК ЛицевыеСчета
	|ПО
	|	ТекКД.ФизическоеЛицо = ЛицевыеСчета.ФизическоеЛицо
	|ГДЕ
	|	ТекКД.ДатаПриема <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) 
	|	И ТекКД.ДатаПриема>=ДАТАВРЕМЯ(1, 1, 1) 
	|	И ВТ_СотрудникиГПХ.Сотрудник ЕСТЬ NULL
	|	И (
	|		ТекКД.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|		ИЛИ НачалоПериода(ТекКД.ДатаУвольнения, ДЕНЬ) > &ТекДата
	|	)	
	|	И НЕ ТекКД.Сотрудник.ПометкаУдаления	
	|УПОРЯДОЧИТЬ ПО
	|	ФИО
	|";
	
	Данные = Новый ТаблицаЗначений;
	
	пЗапроса = Новый Структура("ТекДата", ТекущаяДата());	
	резИст = ВыполнитьЗапросКИсточнику(ТекстЗапроса, пЗапроса);
	Если резИст.Успешно Тогда
		Результат.Данные = резИст.Данные;		
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, резИст);
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьДанныеФЛчерезHTTP()

Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	ЗаписатьВЛог("Загрузка сотрудников", "Начало. Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера(), "Информация");
	
	пОбработки = Новый Структура;
	
	СП = Новый Массив;
	Для Каждого СтрокаТП Из ТаблицаПараметров Цикл
		пОбработки.Вставить(СтрокаТП.Имя, СтрокаТП.Значение);	
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, пОбработки);  
	
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Пользователь = "*%*%*%";
	//Пароль		 = "*$*$*$";
	Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКЗУП_31).Логин;
	Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКЗУП_31).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	
	резЗагрузки = ЗагрузитьФЛ_HTTP();	
	Если НЕ резЗагрузки.Успешно Тогда
		ЗаписатьВЛог("Загрузка сотрудников", СтрСоединить(резЗагрузки.Ошибки, Символы.ПС), "Ошибки");		
	КонецЕсли; 
	
	резЗагрузки = ЗагрузитьЛС_HTTP();	
	Если резЗагрузки.Успешно Тогда		
		ЗаписатьВЛог("Загрузка лицевых счетов", "Загружено: "+резЗагрузки.ЗагруженоОбъектов+" ЛС.", "Информация");
	Иначе		
		ЗаписатьВЛог("Загрузка лицевых счетов", СтрСоединить(резЗагрузки.Ошибки, Символы.ПС), "Ошибки");		
	КонецЕсли;
	
	ЗаписатьВЛог("Загрузка сотрудников", "Окончание. Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера(), "Информация");
КонецПроцедуры

Процедура ЗагрузитьФЛ(ТЗ)	
	Менеджер		= Справочники.ФизическиеЛица;
	
	СписокПринятых	= Новый Массив;
	СписокУволенных	= Новый Массив;	
	СписокКривых	= Новый Массив;
	
	СписокУзловПолучателей	= УзлыПолучатели();
	
	ИзмененияВДолжностях = Новый ТаблицаЗначений;
	ИзмененияВДолжностях.Колонки.Добавить("ФизЛицо");
	ИзмененияВДолжностях.Колонки.Добавить("ДолжностьНач");
	ИзмененияВДолжностях.Колонки.Добавить("ДолжностьКон");
	
	ЗагруженныеФЛ	= Новый Массив;
	Сч = 1;
	Для Каждого ТекСтрока Из ТЗ Цикл
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();
			Состояние(ТекСтрока.Наименование);
		#КонецЕсли
		
		ТабельныйНомер		= ТекСтрока.Код;
		КодГруппы 			= ТекСтрока.КодПодр;
		КодПодразделения	= Прав(КодГруппы, СтрДлина(КодГруппы)-2);		
		
		ФЛ_Ссылка 			= Менеджер.НайтиПоРеквизиту("ТабельныйНомер", ТабельныйНомер);
		
		//должность
		Должность = Справочники.Должности.НайтиПоНаименованию(ТекСтрока.Должность, Истина);
		Если Должность = Справочники.Должности.ПустаяСсылка() Тогда
			Должность = Справочники.Должности.СоздатьЭлемент();
			Должность.Наименование = ТекСтрока.должность;
			Должность.Записать();
			Должность = Должность.Ссылка;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КодГруппы) Тогда			
			ГруппаСсылка = Менеджер.НайтиПоРеквизиту("ТабельныйНомер", КодГруппы);
		Иначе
			ГруппаСсылка = Менеджер.ПустаяСсылка();				
		КонецЕсли;			

		Если ГруппаСсылка.Пустая() ИЛИ НЕ ГруппаСсылка.ЭтоГруппа  Тогда
			Если ЗначениеЗаполнено(КодГруппы) Тогда	
				ГруппаОбъект = Справочники.ФизическиеЛица.СоздатьГруппу();
				ГруппаОбъект.Наименование	= ТекСтрока.Подразделение;
				ГруппаОбъект.ТабельныйНомер	= ТекСтрока.КодПодр;
				ГруппаОбъект.Записать();
				
				ГруппаСсылка = ГруппаОбъект.Ссылка;
			
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей, ГруппаСсылка);					
			Иначе
				ГруппаСсылка = Менеджер.ПустаяСсылка();					
			КонецЕсли; 				
		КонецЕсли;
		
		Подразделение = Справочники.Подразделения.НайтиПоКоду(КодПодразделения);
		Если Подразделение.Пустая() Тогда
			#Если Клиент Тогда
				Сообщить("Нет найдено подразделение сотрудника: "+ТекСтрока.Наименование+". Код подр.: "+КодПодразделения);
			#КонецЕсли			
		КонецЕсли;		
		
		Если ФЛ_Ссылка.Пустая() Тогда			
			ФЛ_Объект = Справочники.ФизическиеЛица.СоздатьЭлемент();
			ФЛ_Объект.ТабельныйНомер = ТабельныйНомер;			
		Иначе
			ФЛ_Объект	 = ФЛ_Ссылка.ПолучитьОбъект();			
		КонецЕсли;
		ЭтоНовый = ФЛ_Объект.Ссылка.Пустая();
		
		Если НЕ ЭтоНовый И ФЛ_Объект.Должность <> Должность 
			И (ЗначениеЗаполнено(ФЛ_Объект.Должность) ИЛИ ЗначениеЗаполнено(Должность)) Тогда
			СтрокаТ = ИзмененияВДолжностях.Добавить();		
			СтрокаТ.ФизЛицо 		= ФЛ_Объект.Наименование;
			СтрокаТ.ДолжностьНач	= ФЛ_Объект.Должность;
			СтрокаТ.ДолжностьКон	= Должность;
		КонецЕсли; 
		
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "Наименование", 	ТекСтрока.Наименование);
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "Родитель",			ГруппаСсылка);
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "Подразделение",	Подразделение);
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "Должность",		Должность);
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "Штатный",			Истина);
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "ТабельныйНомерСотрудникаЗУП",	ТекСтрока.ТабЗуп);		
		УстановитьНовоеЗначениеРеквизита(ФЛ_Объект, "ДатаУвольнения",	ТекСтрока.ДатаУвольнения);
		
		Если ФЛ_Объект.Модифицированность() Тогда				
			ФЛ_Объект.Записать();
				
			ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей, ФЛ_Объект);
			Если ЭтоНовый Тогда			
				СписокПринятых.Добавить(ФЛ_Объект.Ссылка);				
			КонецЕсли;			
		КонецЕсли;
		
		Если ПустаяСтрока(ФЛ_Объект.ШтрихКод) Тогда				
			ФЛ_Объект.ШтрихКод = ПолучитьШКФизЛица();
			#Если Клиент Тогда
				Сообщить("Прописан ШК " + ФЛ_Объект.Наименование+" "+ФЛ_Объект.ШтрихКод); 
			#КонецЕсли
			
			ФЛ_Объект.Записать();			
			ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей, ФЛ_Объект);
		КонецЕсли;
			
		ЗагруженныеФЛ.Добавить(ФЛ_Объект.Ссылка);
		Если ЭтоНовый Тогда
			#Если Клиент Тогда			
				Сообщить(Строка(ФЛ_Объект) + " // " + Строка(ФЛ_Объект.Родитель) + " принят");
			#КонецЕсли		
		КонецЕсли;		
		
		Если Подразделение.Пустая() Тогда			
			СписокКривых.Добавить(ФЛ_Объект.Ссылка);
		КонецЕсли;	
		
		Сч = Сч + 1;
	КонецЦикла;
	
	#Если Клиент Тогда
	Сообщить("Загрузка списка сотрудников завершена.");
	#КонецЕсли
	
	//----------------------------------------------	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка	
	|ИЗ
	|	Справочник.ФизическиеЛица
	|ГДЕ
	|	ЭтоГруппа = Ложь	
	|	И Ссылка В ИЕРАРХИИ(&ГруппаФЛ_ЕЕ)
	|	И НЕ Ссылка В (&ЗагруженныеФЛ)
	|	И НЕ Ссылка В ИЕРАРХИИ (&Уволенные)
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка.Наименование
	|";
	
	Запрос.УстановитьПараметр("ГруппаФЛ_ЕЕ", 	ГруппаФЛ_ЕЕ);
	Запрос.УстановитьПараметр("Уволенные", 		Уволенные);	
	Запрос.УстановитьПараметр("ЗагруженныеФЛ", 	ЗагруженныеФЛ);
	Запрос.УстановитьПараметр("НачалоДня", 		НачалоДня(ТекущаяДата()));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();			
		#КонецЕсли
		
		ФЛ_Объект = Выборка.Ссылка.ПолучитьОбъект();
		Если ФЛ_Объект.Штатный Тогда
			ФЛ_Объект.Штатный = Ложь;
		КонецЕсли;
						
		Если ФЛ_Объект.Родитель <> Уволенные Тогда
			ФЛ_Объект.Родитель	= Уволенные;
			ФЛ_Объект.Должность = Неопределено;
				
			#Если Клиент Тогда
				Сообщить(""+ФЛ_Объект + " // " + ФЛ_Объект.Родитель + " уволен");
			#КонецЕсли				
		КонецЕсли;
			
		Если ФЛ_Объект.Модифицированность() Тогда				
			ФЛ_Объект.Записать();
			ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей, ФЛ_Объект);
			
			СписокУволенных.Добавить(ФЛ_Объект.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	//письмо		
	//крохин начало 03.07.2019
	//загрузка лицевых счетов	
	#Если Клиент Тогда		
		Состояние("загрузка лицевых счетов");
	#КонецЕсли
	
	//ЗагрузитьЛицевыеСчета(ТекстПисьма);		
	
	ТекстПисьма = СоздатьТекстПисьма(СписокПринятых, СписокУволенных, СписокКривых, ИзмененияВДолжностях);
	Если фОтправлятьПисьмо И НЕ ПустаяСтрока(ТекстПисьма) Тогда
		ОтправитьПисьмо(ТекстПисьма, "Загрузка ФЛ из ЗуП.");	
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьНовоеЗначениеРеквизита(СпрОбъект, РеквИмя, РеквЗначение)
	Если СпрОбъект[РеквИмя]<>РеквЗначение Тогда
		СпрОбъект[РеквИмя] = РеквЗначение;	
	КонецЕсли;		
КонецПроцедуры

Функция СоздатьТекстПисьма(СписокПринятых, СписокУволенных, СписокКривых, ИзмененияВДолжностях)
	Тексты = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Наименование,Код,ТабельныйНомер,Подразделение ИЗ Справочник.ФизическиеЛица ГДЕ Ссылка В (&СписокСсылок)";
	
	Если СписокПринятых.Количество()>0 Тогда	
		Тексты.Добавить("ПРИНЯТЫ:");
		
		Запрос.УстановитьПараметр("СписокСсылок", СписокПринятых);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл		
			Тексты.Добавить(СтрШаблон("	Сотрудник: %1, ТН: %2, код: %3, подразделение: %4.", Выборка.Наименование, Выборка.ТабельныйНомер, Выборка.Код, Выборка.Подразделение));
		КонецЦикла;
	КонецЕсли; 
	
	Если СписокУволенных.Количество()>0 Тогда
		Тексты.Добавить("УВОЛЕНЫ:");
		
		Запрос.УстановитьПараметр("СписокСсылок", СписокУволенных);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Тексты.Добавить(СтрШаблон("	Сотрудник: %1, ТН: %2, код: %3, подразделение: %4.", Выборка.Наименование, Выборка.ТабельныйНомер, Выборка.Код, Выборка.Подразделение));
		КонецЦикла;
	КонецЕсли;	
	
	Если СписокКривых.Количество()>0 Тогда
		Тексты.Добавить("Неверное подразделение:");
		
		Запрос.УстановитьПараметр("СписокСсылок", СписокКривых);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Тексты.Добавить(СтрШаблон("	Сотрудник: %1, ТН: %2, код: %3.", Выборка.Наименование, Выборка.ТабельныйНомер, Выборка.Код));
		КонецЦикла;	
	КонецЕсли;
	
	Если ИзмененияВДолжностях.Количество()>0 Тогда
		ИзмененияВДолжностях.Сортировать("ФизЛицо");
		
		Тексты.Добавить("Изменены должности:");
	
		Для Каждого СтрокаТ Из ИзмененияВДолжностях Цикл
			Тексты.Добавить(СтрШаблон("	Сотрудник: %1, была должность: %2, стала: %3.", СтрокаТ.ФизЛицо, СтрокаТ.ДолжностьНач, СтрокаТ.ДолжностьНач));		
		КонецЦикла;
	КонецЕсли; 
	
	Возврат СтрСоединить(Тексты, Символы.ПС);
КонецФункции //СоздатьТекстПисьма(СписокПринятых, СписокУволенных, СписокКривых) 

Функция ЗагрузитьЛС(ДанныеЗуП)
	Результат	= Новый Структура("Успешно,Данные,Ошибки,Сообщения,ЗагруженоОбъектов", Истина, Неопределено, Новый Массив, Новый Массив, 0);
	
	ТекстПисьма = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ДанныеЗуП ИЗ &ДанныеЗуП КАК ДанныеЗуП ИНДЕКСИРОВАТЬ ПО ТабельныйНомер
	|;
	|ВЫБРАТЬ
	|	ФизическиеЛица.Ссылка									КАК ФизЛицо,
	|	ФизическиеЛица.ТабельныйНомер							КАК ТабельныйНомер,
	|	ЛицевыеСчетаРаботниковОрганизации.НомерЛицевогоСчета 	КАК НомерЛС_Тек,
	|	ВТ_ДанныеЗуП.НомерЛицевогоСчета 						КАК НомерЛС_ЗуП,
	
	|	ЛицевыеСчетаРаботниковОрганизации.Банк.ИНН				КАК Банк_ИНН_Бух,	
	|	ВТ_ДанныеЗуП.Банк_ИНН			 						КАК Банк_ИНН_ЗуП
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ЛицевыеСчетаРаботниковОрганизации КАК ЛицевыеСчетаРаботниковОрганизации
	|ПО 
	|	ЛицевыеСчетаРаботниковОрганизации.ФизЛицо = ФизическиеЛица.Ссылка
	|	И ЛицевыеСчетаРаботниковОрганизации.Организация = &Организация
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_ДанныеЗуП
	|ПО
	|	ФизическиеЛица.ТабельныйНомер = ВТ_ДанныеЗуП.ТабельныйНомер
	|ГДЕ
	|	ФизическиеЛица.Штатный
	|	И ФизическиеЛица.ТабельныйНомер<>"""" 
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("ДанныеЗуП", 		ДанныеЗуП);	
	Запрос.УстановитьПараметр("Организация", 	Организация);	
	
	Банки = Новый Соответствие;
	ЗагруженоЛС	= 0;	
	
	ШаблонСтроки = "%1	: %2, был ЛС: '%3', стал ЛС: '%4'.";
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ТабельныйНомер) И ЗначениеЗаполнено(Выборка.НомерЛС_ЗуП) 
			И (Выборка.НомерЛС_Тек <> Выборка.НомерЛС_ЗуП ИЛИ Выборка.Банк_ИНН_Бух <> Выборка.Банк_ИНН_ЗуП) Тогда			
			ЗагруженоЛС = ЗагруженоЛС + 1;
			
			Результат.Сообщения.Добавить(СтрШаблон(ШаблонСтроки, 
				ЗагруженоЛС,
				Лев(""+Выборка.ФизЛицо		+ "                          ",40),
				//крохин начало 15.11.2023
				//номера ЛС писать не надо
				//Лев(""+Выборка.НомерЛС_Тек	+ "                          ",20), 
				//Выборка.НомерЛС_ЗуП)
				"", 
				"")
				//крохин конец 15.11.2023
			);
			
			Банк_ИНН_ЗуП = Выборка.Банк_ИНН_ЗуП;
			Если ЗначениеЗаполнено(Банк_ИНН_ЗуП) Тогда
				Банк = Банки[Банк_ИНН_ЗуП];
				Если Банк = Неопределено Тогда
					Банк = НайтиБанкПоИНН(Банк_ИНН_ЗуП);
					Банки[Банк_ИНН_ЗуП] = Банк;				
				КонецЕсли;
			Иначе
				Банк = Справочники.Контрагенты.ПустаяСсылка();
			КонецЕсли;			
			
			Запись = РегистрыСведений.ЛицевыеСчетаРаботниковОрганизации.СоздатьМенеджерЗаписи();
			
			Запись.ФизЛицо 				= Выборка.ФизЛицо;						
			Запись.Организация			= Организация;			
			Запись.Банк					= Банк;
			Запись.НомерЛицевогоСчета 	= Выборка.НомерЛС_ЗуП;
			
			Запись.Записать();					
		КонецЕсли;	
	КонецЦикла;
	
	Если Результат.Сообщения.Количество()>0 Тогда
		ТекстПисьма = "Загружены ЛС физ лиц.
		|
		|	" + СтрСоединить(Результат.Сообщения, Символы.ПС+Символы.Таб);
		
		Если фОтправлятьПисьмо И НЕ ПустаяСтрока(ТекстПисьма) Тогда
			ОтправитьПисьмо(ТекстПисьма, "Загрузка ЛС из ЗуП.");		
		Иначе
			Сообщить(ТекстПисьма);
		КонецЕсли;			
	КонецЕсли; 
	
	Результат.Вставить("ЗагруженоОбъектов", ЗагруженоЛС);
	
	Возврат Результат;	
КонецФункции //ЗагрузитьЛС(ДанныеЗуП)

Функция НайтиБанкПоИНН(ИНН)        	       
	Результат = Справочники.Контрагенты.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(ИНН) Тогда
		Если СокрЛП(ИНН) = "7707083893" Тогда //Сбербанк
			Результат = Справочники.Контрагенты.НайтиПоКоду("SSP-0564");
		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст = "
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	Ссылка
			|ИЗ
			|	Справочник.Контрагенты
			|ГДЕ
			|	ИНН = &ИНН
			|	И Владелец = &SSP
			|	И НЕ ПометкаУдаления	
			|УПОРЯДОЧИТЬ ПО
			|	Код	
			|";     
			
			Запрос.УстановитьПараметр("ИНН", СокрЛП(ИНН));
			Запрос.УстановитьПараметр("SSP", Справочники.ИБ.НайтиПоКоду("SSP"));
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
				Результат = Выборка.Ссылка;					
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НайтиБанкПоИНН(ИНН)

Функция УзлыПолучатели()
