Функция ВыполнитьЗапросКИсточнику(Текст, Знач Параметры = Неопределено, ДопПараметры = Неопределено) Экспорт
	Результат	= Новый Структура("Успешно,Ошибки,Данные", Ложь, Новый Массив, Новый ТаблицаЗначений);
	
	Если Параметры = Неопределено Тогда
		Параметры = Новый Структура;	
	КонецЕсли;
	
	ОписаниеЗапроса = Новый Структура("Текст,Параметры,ДопПараметры", Текст, Параметры, ДопПараметры);	
	
	СединениеХТТП = Новый HTTPСоединение(ИмяСервера, , Пользователь, Пароль);
	
	Запрос = Новый HTTPЗапрос(ИмяБазы+"/hs/EE_exchange/execute_query");	
	
	ВсегоСтрок	= 0;	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ДопСоответствиеТипов = ПолучитьЗначениеПараметра(ДопПараметры, "ДопСоответствиеТипов", Новый Соответствие);
	
	СтрокаХМЛ = ЗначениеВХМЛСтроку(ОписаниеЗапроса);
	ЗаменитьТипы_Тек_Ист(СтрокаХМЛ, ДопСоответствиеТипов);	
	Запрос.УстановитьТелоИзСтроки(СтрокаХМЛ);	
	
	Попытка
		Ответ = СединениеХТТП.ОтправитьДляОбработки(Запрос);
	Исключение
		Ответ		= Неопределено;
		ТекстОшибки	= СтрШаблон("Ошибка отправки запроса. Сервер: %1, база: %2. Ошибка: %3.", ИмяСервера, ИмяБазы, ОписаниеОшибки());
		Результат.Ошибки.Добавить(ТекстОшибки);		
	КонецПопытки;		
	
	Если Ответ<>Неопределено Тогда		
		Если Ответ.КодСостояния = 200 Тогда	
			Тело			= Ответ.ПолучитьТелоКакСтроку();	
			Тело 			= ЗаменитьТипы_Ист_Тек(Тело);		
			
			Попытка
				резРазбора	= ЗначениеИзХМЛСтроки(Тело);
				
				Результат.Данные	= резРазбора.Данные;
				Результат.Успешно	= резРазбора.Успешно;
				Результат.Ошибки 	= резРазбора.Ошибки;
			Исключение
				Результат.Ошибки.Добавить("Ошибка разбора ответа ! "+ОписаниеОшибки()+" "+Лев(Тело, 1000));
				Результат.Успешно = Ложь;
			КонецПопытки;		
		Иначе
			Результат.Ошибки.Добавить("Ошибка обработки на сервере ! "+Ответ.КодСостояния);		
		КонецЕсли;
	КонецЕсли; 
	
	Результат.Успешно = (Результат.Ошибки.Количество()=0);
	
	Возврат Результат;
КонецФункции //ВыполнитьЗапросКИсточнику(Текст, Знач Параметры = Неопределено) Экспорт

Функция ЗначениеВХМЛСтроку(Значение)
	ЗаписьХМЛ = Новый ЗаписьXML;
	ЗаписьХМЛ.УстановитьСтроку();
	СериализаторXDTO.ЗаписатьXML(ЗаписьХМЛ, Значение, НазначениеТипаXML.Явное);	
	
	СтрокаХМЛ = ЗаписьХМЛ.Закрыть();	
	Возврат СтрокаХМЛ
КонецФункции //ЗначениеВХМЛСтроку(Значение)

Функция ЗначениеИзХМЛСтроки(СтрокаХМЛ) Экспорт
	ЧтениеХМЛ = Новый ЧтениеXML;
	ЧтениеХМЛ.УстановитьСтроку(СтрокаХМЛ);	
	
	Значение = СериализаторXDTO.ПрочитатьXML(ЧтениеХМЛ);	
	
	ЧтениеХМЛ.Закрыть();
	
	Возврат Значение;
КонецФункции //ЗначениеИзХМЛСтроки(СтрокаХМЛ)

Функция ЗаменитьТипы_Тек_Ист(СтрокаХМЛ, ДопСоответствиеТипов)
	Если ТипЗнч(ДопСоответствиеТипов)= Тип("Соответствие") Тогда //Иногда бывает 2 к 1
		Для Каждого КиЗ Из ДопСоответствиеТипов Цикл
			Если КиЗ.Ключ<>КиЗ.Значение Тогда				
		    	СтрокаХМЛ = СтрЗаменить(СтрокаХМЛ, КиЗ.Значение, КиЗ.Ключ);
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;
	
	Для Каждого КиЗ Из СоответствиеТипов Цикл
		Если КиЗ.Ключ<>КиЗ.Значение Тогда						
			Если КиЗ.Ключ<>"CatalogRef.ХарактеристикиНоменклатуры" Тогда			
				СтрокаХМЛ = СтрЗаменить(СтрокаХМЛ, КиЗ.Значение, КиЗ.Ключ);			
			КонецЕсли;		    
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат СтрокаХМЛ;
КонецФункции // ()

Функция ЗаменитьТипы_Ист_Тек(СтрокаХМЛ)
	Для Каждого КиЗ Из СоответствиеТипов Цикл
		Если КиЗ.Ключ<>КиЗ.Значение Тогда						
		    СтрокаХМЛ = СтрЗаменить(СтрокаХМЛ,КиЗ.Ключ, КиЗ.Значение);
		КонецЕсли;	
	КонецЦикла;
	Для Каждого КиЗ Из СоответствиеПеречислений Цикл
		Если КиЗ.Ключ<>КиЗ.Значение Тогда
			ЧастиИст = СтрРазделить(КиЗ.Ключ,".");
			ЧастиТек = СтрРазделить(КиЗ.Значение,".");
			
			СтрИст = ЧастиИст[0]+""">"+ЧастиИст[1]+"<";
			СтрТек = ЧастиТек[0]+""">"+ЧастиТек[1]+"<";
			
			//Элемент.Значение
			//<Value xmlns:d5p1="http://v8.1c.ru/8.1/data/enterprise/current-config" xsi:type="d5p1:EnumRef.ВидыОперацийПеремещениеТоваров">ТоварыПродукция</Value>
			//<Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:EnumRef.ВариантыОплатыЧекаККМ</Type>
		    СтрокаХМЛ = СтрЗаменить(СтрокаХМЛ, СтрИст, СтрТек);
			
			СтрИст	= ":EnumRef."+ЧастиИст[0]+"<";
			СтрТек	= ":EnumRef."+ЧастиТек[0]+"<";
			
			СтрокаХМЛ = СтрЗаменить(СтрокаХМЛ, СтрИст, СтрТек);
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат СтрокаХМЛ;
КонецФункции //ЗаменитьТипы_Ист_Ист(СтрокаХМЛ)

Функция СформироватьТестовыйЗапрос() Экспорт
	Текст = "
	|ВЫБРАТЬ 
	|	Наименование
	|ИЗ 
	|	Справочник.Организации
	|ГДЕ 
	|	Ссылка = &Организация
	|";
	
	Параметры = Новый Структура("Организация", Организация);
	
	Возврат Новый Структура("Текст,Параметры", Текст, Параметры);
КонецФункции //СформироватьТестовыйЗапрос()

Функция ТестСоединенияИст(ПараметрыПодключения = Неопределено) Экспорт
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ПараметрыПодключения);
	
	Результат 		= Новый Структура("Успешно,Ошибки,Сообщения,Данные", Истина, Новый Массив, Новый Массив, Новый Массив);
	
	ТекстЗапроса 	= "ВЫБРАТЬ ПЕРВЫЕ 1 Наименование ИЗ Справочник.Организации ГДЕ НЕ ПометкаУдаления";
	резИст	 		= ВыполнитьЗапросКИсточнику(ТекстЗапроса);
	
	Если резИст.Успешно Тогда
		Данные = Новый Массив;
		Для Каждого СтрокаТД Из резИст.Данные Цикл
			Данные.Добавить(СтрокаТД.Наименование);	
		КонецЦикла;	
		Результат.Данные = Данные;		
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, резИст);
	КонецЕсли;
	
	Возврат Результат;		
КонецФункции


#КонецОбласти


