КонецФункции //УзлыПолучатели() 

Функция ПолучитьШКФизЛица()
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПОДСТРОКА(ФизическиеЛица.ШтрихКод, 4, 9) КАК НомерШК
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ 
	|	ПОДСТРОКА(ФизическиеЛица.ШтрихКод, 1, 3)=""777""
	|УПОРЯДОЧИТЬ ПО 
	|	ПОДСТРОКА(ФизическиеЛица.ШтрихКод, 4, 9) УБЫВ";
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		НомерШК =  Число(Выборка.НомерШК);	
	Иначе
		НомерШК = "000000000";
	КонецЕсли; 
	
	НомерШК=НомерШК+1;
	ШтрихКод = "777" + Формат(НомерШК,"ЧЦ=9; ЧРГ=; ЧВН=; ЧГ=0");
	ШтрихКод = ШтрихКод + КонтрольныйСимволEAN(Число(ШтрихКод),13);
	Возврат ШтрихКод;
КонецФункции

