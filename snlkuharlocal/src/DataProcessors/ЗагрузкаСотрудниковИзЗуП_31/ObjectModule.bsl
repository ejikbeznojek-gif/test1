Функция СоответствиеТипов_Тек_Ист(СоответствиеТипов)
	СТ = Новый Соответствие;
	Для Каждого КиЗ Из СоответствиеТипов Цикл
		СТ.Вставить(КиЗ.Значение, КиЗ.Ключ);	
	КонецЦикла;
	
	Возврат СТ;
КонецФункции //СоответствиеТипов_Тек_Ист(СоответствиеТипов)


Функция ДобавитьОшибки(Рез1, Рез2) Экспорт
	Если Рез1 = Рез2 Тогда //На всякий случай, а то уходит в даун
		Возврат Неопределено;	
	КонецЕсли; 
	Ошибки1 = ПолучитьЗначениеПараметра(Рез1, "Ошибки", Новый Массив);
	Ошибки2 = ПолучитьЗначениеПараметра(Рез2, "Ошибки", Новый Массив);
	
	Для Каждого ТекстОшибки Из Ошибки2 Цикл
		Ошибки1.Добавить(ТекстОшибки);		
	КонецЦикла; 
	
	УстановитьЗначениеПараметра(Рез1, "Ошибки", Ошибки1);	
КонецФункции //ПолучитьЗначениеПараметра(СтруктураПараметров,Имя,ЗначениеПоУмолчанию=Неопределено) Экспорт

Функция ПолучитьЗначениеПараметра(СтруктураПараметров,Имя,ЗначениеПоУмолчанию=Неопределено) Экспорт
	Результат	= ЗначениеПоУмолчанию;
	
	Если ТипЗнч(СтруктураПараметров)=Тип("Структура") Тогда
		ВремЗнач=Неопределено;
		Если СтруктураПараметров.Свойство(Имя,ВремЗнач) Тогда
			Результат	= ВремЗнач;		
		КонецЕсли; 
	ИначеЕсли ТипЗнч(СтруктураПараметров)=Тип("ДанныеФормыСтруктура") Тогда
		ВремЗнач=Неопределено;
		Если СтруктураПараметров.Свойство(Имя,ВремЗнач) Тогда
			Результат	= ВремЗнач;		
		КонецЕсли; 
	ИначеЕсли ТипЗнч(СтруктураПараметров)=Тип("Соответствие") Тогда
		ВремЗнач=СтруктураПараметров.Получить(Имя);
		Если ВремЗнач<>Неопределено Тогда
			Результат=ВремЗнач;		
		КонецЕсли;				
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьЗначениеПараметра(СтруктураПараметров,Имя,ЗначениеПоУмолчанию=Неопределено) Экспорт

Функция УстановитьЗначениеПараметра(СтруктураПараметров,Имя,Значение,Перезаписывать=Истина) Экспорт	
	
	Результат = Ложь;
	
	Если 
		ТипЗнч(СтруктураПараметров)=Тип("Структура") ИЛИ 
		ТипЗнч(СтруктураПараметров)=Тип("Соответствие") Тогда
		
		ТекЗнач=ПолучитьЗначениеПараметра(СтруктураПараметров,Имя);
		Если ТекЗнач=Неопределено ИЛИ (ТекЗнач<>Значение И Перезаписывать) Тогда
			СтруктураПараметров.Вставить(Имя,Значение);		
			Результат = Истина;
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции //УстановитьЗначениеПараметра(СтруктураПараметров,Имя,Значение,Перезаписывать=Истина) Экспорт

