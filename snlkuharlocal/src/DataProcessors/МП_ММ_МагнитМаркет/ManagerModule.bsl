		МП_АдресЗапроса_ОтменаЗаказа(), ПараметрыОбработки);

	Если ТипЗнч(ДанныеОтвета) = Тип("Структура") И (ДанныеОтвета.Свойство("errors") Или ДанныеОтвета.Свойство("error")) Тогда
		СообщитьИзМодуля("Ошибка");

		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции // ОтменитьЗаказыПолностью()

