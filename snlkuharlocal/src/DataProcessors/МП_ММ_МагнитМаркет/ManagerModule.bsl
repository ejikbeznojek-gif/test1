
#Область ПрограммныйИнтерфейс

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Процедура - МП Обработать загрузку закзов порционно
// 
// Параметры:
//  ПараметрыОбработки - Структура - Параметры обработки данных сервиса Магнит Маркет
//  РезультатыЗапроса - Массив из РезультатЗапроса - Результаты запроса для выборки данных
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура МП_ОбработатьЗагрузкуЗаказовПорционно(ПараметрыОбработки, РезультатыЗапроса, РеквизитыМаркетПлейс) Экспорт
	
	// Инициализация
	ПараметрыОтбора = Новый Структура;
	
	НаборЗаписейДанныеЗаказов = ОбменМаркетПлейс.ПолучитьДанныеНабораРегистраСведенийПоДаннымМаркетплейса(
		ПараметрыОбработки.МаркетПлейс, "МП_ДанныеЗаказовСервиса",
		РезультатыЗапроса[РезультатыЗапроса.ВГраница() - 1]);
	НаборЗаписейДанныеТоваров = ОбменМаркетПлейс.ПолучитьДанныеНабораРегистраСведенийПоДаннымМаркетплейса(
		ПараметрыОбработки.МаркетПлейс, "МП_ДанныеНоменклатурыЗаказовСервиса",
		РезультатыЗапроса[РезультатыЗапроса.ВГраница()]);
	
	СмещениеПакетаЗапроса_ДанныеЗаказов  = 5;
	Выборка = РезультатыЗапроса[СмещениеПакетаЗапроса_ДанныеЗаказов - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ПараметрыОбработки.ДополнительныеПараметры.Json = Новый Структура;
	ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("page_size", 1000);
	ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("page_token", "");
	ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("created_at", Новый Структура);
	ПараметрыОбработки.ДополнительныеПараметры.Json.created_at.Вставить("from",
		ЗаписатьДатуJSON(ПараметрыОбработки.ДатаНачала, ФорматДатыJSON.ISO,
			ВариантЗаписиДатыJSON.УниверсальнаяДата));
	ПараметрыОбработки.ДополнительныеПараметры.Json.created_at.Вставить("to",
		ЗаписатьДатуJSON(ПараметрыОбработки.ДатаОкончания, ФорматДатыJSON.ISO,
			ВариантЗаписиДатыJSON.УниверсальнаяДата));
	
	Пока Истина Цикл
		СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1%2", РеквизитыМаркетПлейс.Host,
				МП_АдресЗапроса_СписокЗаказов()),, ПараметрыОбработки.ДополнительныеПараметры);
		ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета,
			ПараметрыОбработки.ДополнительныеПараметры.ПараметрыПреобразованияJSON);
		// Обработка ошибок со стороны сервиса
		Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
			Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
			ВызватьИсключение "Ошибка получения данных по заказам";
		КонецЕсли;
		
		// Проверяем на наличие заказа и соответствующе обрабатываем.
		// Если заказа в наличии нет, то создаем его.
		МассивЗаказов = ДанныеОтвета[ПараметрыОбработки.ИменаСтруктурДанных.ТелоЗаказа];
		
		МассивНомеровЗаказов = Новый Массив;
		Для Каждого ДанныеЗаказа Из МассивЗаказов Цикл
			МассивНомеровЗаказов.Добавить(ДанныеЗаказа[ПараметрыОбработки.ИменаПолей.ВнешнийИдентификатор]);
		КонецЦикла;
		ДанныеПосылокПоЗаказам = ПолучитьПосылкиПоНомерамЗаказов(МассивНомеровЗаказов, ПараметрыОбработки,
			РеквизитыМаркетПлейс);
		
		Для Каждого ДанныеЗаказа Из МассивЗаказов Цикл
			// Ихсанов Д. А. Начало 18.06.2026 Изменение 0000000070 от 05.06.2026 10:46:32: e1cib/data/Документ.Изменение?ref=89690050568f680711f160b2a681657e
			ДатаПриемки = ДанныеЗаказа[ПараметрыОбработки.ИменаПолей.ДатаСоздания] + 12 * 60 * 60;
			ПараметрыОбработки.АгрегируемыеПоля.Интервал = ОбменМаркетПлейс.ПолучитьВремяПриемкиИзДатыЗагрузки(
				ДеньНедели(ДатаПриемки), Час(ДатаПриемки), ДатаПриемки);
			// Ихсанов Д. А. Конец 18.06.2026
			
			ДвижениеДанныеЗаказов = НаборЗаписейДанныеЗаказов.Добавить();
			ДвижениеДанныеЗаказов.Период	  = Выборка.ДатаСоздания;
			ДвижениеДанныеЗаказов.МаркетПлейс = ПараметрыОбработки.МаркетПлейс;
			
			// Проверяем существуют ли данные в базе, если существуют, то модифицируем их, если нет, создаем новые
			ПараметрыОтбора.Очистить();
			ПараметрыОтбора.Вставить("ВнешнийИдентификатор",
				ДанныеЗаказа[ПараметрыОбработки.ИменаПолей.ВнешнийИдентификатор]);
			Если Выборка.НайтиСледующий(ПараметрыОтбора) Тогда
				ЗаполнитьЗначенияСвойств(ДвижениеДанныеЗаказов, Выборка);
			КонецЕсли;
			
			ДанныеПосылки = ДанныеПосылокПоЗаказам[ДанныеЗаказа[ПараметрыОбработки.ИменаПолей.ВнешнийИдентификатор]];
			
			ОбменМаркетПлейс.ЗаполнитьПоляКоллекцииПоВложенности(ПараметрыОбработки.ИменаПолей, ДанныеЗаказа,
				ДвижениеДанныеЗаказов);
			
			ВыборкаИдентификаторыЗаказа = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			МассивТоваров = ДанныеЗаказа[ПараметрыОбработки.ИменаСтруктурДанных.Товары];
			СмещениеПоТовару = 1;
			Для Каждого Товар Из МассивТоваров Цикл
				ПараметрыОтбора.Очистить();
				ПараметрыОтбора.Вставить("Идентификатор",
					Формат(Товар[ПараметрыОбработки.ИменаПолейТоваров.Идентификатор], "ЧГ="));
				
				ВыборкаИдентификаторыЗаказа.НайтиСледующий(ПараметрыОтбора);
				
				КоличествоОтмененных = 0;
				ВыборкаДетальныеЗаписи = ВыборкаИдентификаторыЗаказа.Выбрать();
				КоличествоТовара = Макс(Товар.quantity, ВыборкаДетальныеЗаписи.Количество());
				Для ИндексТовара = 1 По КоличествоТовара Цикл
					ДвижениеДанныеТоваров = НаборЗаписейДанныеТоваров.Добавить();
					ДвижениеДанныеТоваров.МаркетПлейс = ПараметрыОбработки.МаркетПлейс;
					
					ЭкземплярТовараОтменен = Ложь;
					Если ВыборкаДетальныеЗаписи.НайтиСледующий(ПараметрыОтбора) Тогда
						ЗаполнитьЗначенияСвойств(ДвижениеДанныеТоваров, ВыборкаДетальныеЗаписи);
						
						ЭкземплярТовараОтменен = ВыборкаДетальныеЗаписи.Отменен;
					КонецЕсли;
					
					ДопСтатус = "CUSTOM";
					НомерПосылки = "";
					ШтрихКод = "";
					Если ДанныеПосылки <> Неопределено Тогда
						ДанныеПосылокПоЗаказу =
							ДанныеПосылки[Формат(Товар[ПараметрыОбработки.ИменаПолейТоваров.Идентификатор], "ЧГ=")];
						Если ДанныеПосылокПоЗаказу <> Неопределено Тогда
							Для Каждого ДанныеЭкземпляраПосылки Из ДанныеПосылокПоЗаказу Цикл
								ДопСтатус	 = ДанныеЭкземпляраПосылки.Значение.status;
								НомерПосылки = ДанныеЭкземпляраПосылки.Значение.parcel_id;
								ШтрихКод	 = ДанныеЭкземпляраПосылки.Значение.barcode;
								
								ДанныеПосылокПоЗаказу.Удалить(ДанныеЭкземпляраПосылки.Ключ);
								
								Прервать;
							КонецЦикла;
						КонецЕсли;
					КонецЕсли;
					
					ОбменМаркетПлейс.ЗаполнитьПоляКоллекцииПоВложенности(ПараметрыОбработки.ИменаПолейТоваров, Товар,
						ДвижениеДанныеТоваров);
					ОбменМаркетПлейс.ЗаполнитьПоляКоллекцииПоВложенности(ПараметрыОбработки.ПоляТовараИзДанныхЗаказа,
						ДанныеЗаказа, ДвижениеДанныеТоваров);
					
					ПараметрыОбработки.АгрегируемыеПоляТовара.НомерЗаказа = СтрШаблон("%1-%2",
						ДанныеЗаказа[ПараметрыОбработки.ИменаПолей.ВнешнийИдентификатор], СмещениеПоТовару);
					ПараметрыОбработки.АгрегируемыеПоляТовара.НомерПосылки = НомерПосылки;
					ПараметрыОбработки.АгрегируемыеПоляТовара.ШтрихКод = ШтрихКод;
					ПараметрыОбработки.АгрегируемыеПоляТовара.Цена = Товар.financial_data.price;
					ПараметрыОбработки.АгрегируемыеПоляТовара.Количество = 1;
					
					// Проконтролируем частичную отмену товара
					Если ИндексТовара > Товар.quantity + КоличествоОтмененных
						И ДвижениеДанныеТоваров.Статус <> "CANCELED" Тогда
						ПараметрыОбработки.АгрегируемыеПоляТовара.ДополнительныйСтатус = "CANCELED";
						ПараметрыОбработки.АгрегируемыеПоляТовара.СостояниеУКлиента =
							ПараметрыОбработки.ХешТаблицаСтатусов["CANCELED;CUSTOM"];
					ИначеЕсли ЭкземплярТовараОтменен
						И ДвижениеДанныеТоваров.Статус <> "CANCELED" Тогда
						ПараметрыОбработки.АгрегируемыеПоляТовара.ДополнительныйСтатус = "CANCELED";
						ПараметрыОбработки.АгрегируемыеПоляТовара.СостояниеУКлиента =
							ПараметрыОбработки.ХешТаблицаСтатусов["CANCELED;CUSTOM"];
						
						КоличествоОтмененных = КоличествоОтмененных + 1;
					Иначе
						ПараметрыОбработки.АгрегируемыеПоляТовара.ДополнительныйСтатус = ДопСтатус;
						ПараметрыОбработки.АгрегируемыеПоляТовара.СостояниеУКлиента	=
							ПараметрыОбработки.ХешТаблицаСтатусов[СтрШаблон("%1;%2",
								ДвижениеДанныеТоваров.Статус, ДопСтатус)];
					КонецЕсли;
					
					Для Каждого пПолеТовара Из ПараметрыОбработки.АгрегируемыеПоляТовара Цикл
						ДвижениеДанныеТоваров[пПолеТовара.Ключ] = пПолеТовара.Значение;
					КонецЦикла;
					
					ПараметрыОбработки.АгрегируемыеПоля.Сумма =
						ПараметрыОбработки.АгрегируемыеПоля.Сумма + Товар.financial_data.price;
					
					СмещениеПоТовару = СмещениеПоТовару + 1;
				КонецЦикла;
				
				ВыборкаДетальныеЗаписи.Сбросить();
			КонецЦикла;
			
			Для Каждого пПолеЗаказа Из ПараметрыОбработки.АгрегируемыеПоля Цикл
				ДвижениеДанныеЗаказов[пПолеЗаказа.Ключ] = пПолеЗаказа.Значение;
			КонецЦикла;
			
			Выборка.Сбросить();
		КонецЦикла;
		
		// Для получения данных следующей порции входим в рекурсию.
		Если ДанныеОтвета.Свойство("next_page_token") Тогда
			ПараметрыОбработки.ДополнительныеПараметры.Json.page_token = ДанныеОтвета.next_page_token;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Очень редко возникают ситуации, когда необходимо контролировать уникальность записей товаров по заказам
	// Таблица позволяет это сделать, так как у товаров есть количественное поле, а значит её можно свернуть
	ОбменМаркетПлейс.ВыполнитьГруппировкуЗаписейПоНабору(НаборЗаписейДанныеЗаказов, "Сумма");
	ОбменМаркетПлейс.ВыполнитьГруппировкуЗаписейПоНабору(НаборЗаписейДанныеТоваров, "Количество");

	Попытка
		// Сохраним данные о товарах к заказу на стороне сервиса
		НаборЗаписейДанныеЗаказов.Записать();
		НаборЗаписейДанныеТоваров.Записать();
	Исключение
		ЗаписатьВЛог("МП_МагнитМаркет", СтрШаблон("Не была записана информация по заказам по причине: %1",
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "Ошибка", Истина);
	КонецПопытки;

КонецПроцедуры // МП_ОбработатьЗагрузкуЗакзовПорционно()

// Процедура - Создать документы заказов и накладных
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура СоздатьДокументыЗаказовИНакладных(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	ПараметрыОбработки.ПараметрыЗадания.Вставить("КритическиеОшибкиОзон", Новый Массив);
	
	// Сложим в массив коллекции номеров заказов после обработки
	ДанныеМассивовЗаказов = Новый Массив;

	ТекстОповещения = "";
	
	// Получаем данные по заказам, по которым нет документа заказ клиента FBS
	// Если нет заказа, то нет и расходной накладной
	Запрос = Новый Запрос("ВЫБРАТЬ
						  |	ЕСТЬNULL(ЗаказКлиентаFBSТовары.Ссылка, ПредварительныйЗаказКлиентаТовары.Ссылка) КАК Ссылка,
						  |	&ТекущаяДата КАК ДатаСоздания,
						  |	вт_СериализированныеДанныеЗаказов.ДатаОтгрузки КАК ДатаОтгрузки,
						  |	вт_СериализированныеДанныеЗаказов.НомерЗаказа КАК ИДЗаказа,
						  |	0 КАК КолНеТовар,
						  |	вт_СериализированныеДанныеЗаказов.ШтрихКод КАК ШтрихКод,
						  |	вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор КАК РИД,
						  |	вт_СериализированныеДанныеЗаказов.Номенклатура КАК Номенклатура,
						  |	вт_СериализированныеДанныеЗаказов.Идентификатор КАК АртКонтра,
						  |	вт_СериализированныеДанныеЗаказов.Цена КАК СуммаЗак,
						  |	вт_СериализированныеДанныеЗаказов.Количество КАК Количество,
						  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП1,
						  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП2,
						  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП3,
						  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК НомРП4,
						  |	вт_СериализированныеДанныеЗаказов.НомерОтгрузки КАК ПрефиксЗаказа,
						  |	вт_СериализированныеДанныеЗаказов.НомерПосылки КАК СуффиксЗаказа,
						  |	вт_СериализированныеДанныеЗаказов.СостояниеУКлиента КАК СостояниеУКлиента,
						  |	вт_СериализированныеДанныеЗаказов.ЗаказПоЮрЛицу КАК ЗаказПоЮрЛицу,
						  |	0 КАК НДС,
						  |	0 КАК Всего,
						  |	ЕСТЬNULL(вт_СериализированныеДанныеЗаказов.КоличествоОстаток, 0) КАК КоличествоОстаток
						  |ПОМЕСТИТЬ вт_ДанныеДляФормированияДокументов
						  |ИЗ
						  |	вт_СериализированныеДанныеЗаказов КАК вт_СериализированныеДанныеЗаказов
						  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
						  |		ПО вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ЗаказКлиентаFBSТовары.РИД
						  |			И (НЕ ЗаказКлиентаFBSТовары.Ссылка.ПометкаУдаления)
						  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
						  |		ПО вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ПредварительныйЗаказКлиентаТовары.РИД
						  |			И (НЕ ПредварительныйЗаказКлиентаТовары.Ссылка.ПометкаУдаления)
						  |ГДЕ
						  |	ЗаказКлиентаFBSТовары.Ссылка ЕСТЬ NULL
						  |	И ПредварительныйЗаказКлиентаТовары.Ссылка ЕСТЬ NULL
						  |;
						  |
						  |////////////////////////////////////////////////////////////////////////////////
						  |ВЫБРАТЬ
						  |	вт_ДанныеДляФормированияДокументов.РИД КАК РИД,
						  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ вт_ДанныеДляФормированияДокументов.ИДЗаказа) КАК КоличествоЭкземпляров
						  |ПОМЕСТИТЬ вт_КоличествоЭкзепляровНаЗаказ
						  |ИЗ
						  |	вт_ДанныеДляФормированияДокументов КАК вт_ДанныеДляФормированияДокументов
						  |
						  |СГРУППИРОВАТЬ ПО
						  |	вт_ДанныеДляФормированияДокументов.РИД
						  |;
						  |
						  |////////////////////////////////////////////////////////////////////////////////
						  |ВЫБРАТЬ
						  |	вт_ДанныеДляФормированияДокументов.*,
						  |	вт_КоличествоЭкзепляровНаЗаказ.КоличествоЭкземпляров
						  |ИЗ
						  |	вт_ДанныеДляФормированияДокументов КАК вт_ДанныеДляФормированияДокументов
						  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_КоличествоЭкзепляровНаЗаказ КАК вт_КоличествоЭкзепляровНаЗаказ
						  |		ПО вт_ДанныеДляФормированияДокументов.РИД = вт_КоличествоЭкзепляровНаЗаказ.РИД
						  |ГДЕ
						  |	вт_КоличествоЭкзепляровНаЗаказ.КоличествоЭкземпляров = 1
						  |;
						  |
						  |////////////////////////////////////////////////////////////////////////////////
						  |ВЫБРАТЬ
						  |	вт_ДанныеДляФормированияДокументов.*,
						  |	вт_КоличествоЭкзепляровНаЗаказ.КоличествоЭкземпляров
						  |ИЗ
						  |	вт_ДанныеДляФормированияДокументов КАК вт_ДанныеДляФормированияДокументов
						  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_КоличествоЭкзепляровНаЗаказ КАК вт_КоличествоЭкзепляровНаЗаказ
						  |		ПО вт_ДанныеДляФормированияДокументов.РИД = вт_КоличествоЭкзепляровНаЗаказ.РИД
						  |ГДЕ
						  |	вт_КоличествоЭкзепляровНаЗаказ.КоличествоЭкземпляров > 1");
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;

	МассивРезультатовЗапроса = Запрос.ВыполнитьПакет();
	Для Индекс = МассивРезультатовЗапроса.ВГраница() - 1 По МассивРезультатовЗапроса.ВГраница() Цикл
		РезультатЗапроса = МассивРезультатовЗапроса[Индекс];

		ТаблицаДанныхПоЗаказам = РезультатЗапроса.Выгрузить();

		ТаблицаДатыОтгрузки = ТаблицаДанныхПоЗаказам.Скопировать();
		ТаблицаДатыОтгрузки.Свернуть("ДатаОтгрузки");
		ТаблицаДатыОтгрузки.Сортировать("ДатаОтгрузки");

		Для Каждого СтрокаДатыОтгрузки Из ТаблицаДатыОтгрузки Цикл
			ОбменМаркетПлейс.ЯндексМаркет_ОбработатьСозданиеДокументовПоЗаказамПЗК(
				Справочники.ИнетМагазины.НайтиПоКоду("00014"), ТаблицаДанныхПоЗаказам,
				ПараметрыОбработки.ПараметрыЗадания, ДанныеМассивовЗаказов, СтрокаДатыОтгрузки.ДатаОтгрузки,
				ТекстОповещения);
		КонецЦикла;
	КонецЦикла;

	Если ПараметрыОбработки.МаркетПлейс.Тест Тогда
		СообщитьИзМодуля(ТекстОповещения);
		ЗаписатьВЛог("МП_МагнитМаркет", НСтр("ru='Окончание выполнения. Задача: Загрузка заказов Яндекс!'"),
			"Информация");
	КонецЕсли;

КонецПроцедуры // СоздатьДокументыЗаказовИНакладных()

// Процедура - Заполнить документы данными сервиса
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура с параметрами обработки данных сервиса Магнит Маркет 
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ЗаполнитьДокументыДаннымиСервиса(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	// Ихсанов Д. А. Начало 23.06.2026 Изменение 0000000147 от 09.06.2026 7:50:49: e1cib/data/Документ.Изменение?ref=89690050568f680711f163bec84d8034
	Запрос = Новый Запрос(ОбменМаркетПлейс.ТекстЗапросаЗаполнитьДокументыДаннымиСервиса());
	// Ихсанов Д. А. Конец 23.06.2026
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("СостояниеУКлиента", ПараметрыОбработки.ХешТаблицаСтатусов["CANCELED;CUSTOM"]);

	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		ДокументОбъектЗаказКлиентаFBS = Выборка.Ссылка.ПолучитьОбъект();

		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("НомерЗаказа", ВыборкаДетальныеЗаписи.НомерЗаказа);

			НайденныеСтроки = ДокументОбъектЗаказКлиентаFBS.Товары.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество() > 0 Тогда
				Для Каждого СтрокаТабличнойЧасти Из НайденныеСтроки Цикл
					ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, ВыборкаДетальныеЗаписи);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;

		ДокументОбъектЗаказКлиентаFBS.Записать();
	КонецЦикла;

КонецПроцедуры // ЗаполнитьДокументыДаннымиСервиса()

// Процедура - Привязать документы к заказам
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура с параметрами обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ПривязатьДокументыКЗаказам(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА НЕ ЗаказКлиентаFBSТовары.Ссылка ЕСТЬ NULL
	|			ТОГДА ЗаказКлиентаFBSТовары.Ссылка
	|		КОГДА НЕ ПредварительныйЗаказКлиентаТовары.Ссылка ЕСТЬ NULL
	|			ТОГДА ПредварительныйЗаказКлиентаТовары.Ссылка
	|		ИНАЧЕ вт_СериализированныеДанныеЗаказов.Документ
	|	КОНЕЦ КАК Документ,
	|	МП_ДанныеЗаказовСервиса.МаркетПлейс КАК МаркетПлейс,
	|	вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор КАК ВнешнийИдентификатор,
	|	вт_СериализированныеДанныеЗаказов.ДатаСоздания КАК ДатаСоздания,
	|	вт_СериализированныеДанныеЗаказов.Сумма КАК Сумма,
	|	вт_СериализированныеДанныеЗаказов.ДатаОтгрузки КАК ДатаОтгрузки,
	|	вт_СериализированныеДанныеЗаказов.Интервал КАК Интервал,
	// Ихсанов Д. А. Начало 07.07.2026 Изменение 0000000087 от 07.06.2026 22:19:02: e1cib/data/Документ.Изменение?ref=89690050568f680711f162a5bd350d2d
	|	вт_СериализированныеДанныеЗаказов.ЗаказПоЮрЛицу КАК ЗаказПоЮрЛицу
	// Ихсанов Д. А. Конец 07.07.2026
	|ИЗ
	|	вт_СериализированныеДанныеЗаказов КАК вт_СериализированныеДанныеЗаказов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МП_ДанныеЗаказовСервиса КАК МП_ДанныеЗаказовСервиса
	|		ПО вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = МП_ДанныеЗаказовСервиса.ВнешнийИдентификатор
	|			И (МП_ДанныеЗаказовСервиса.МаркетПлейс = &МаркетПлейс)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ЗаказКлиентаFBSТовары.РИД
	|			И (НЕ ЗаказКлиентаFBSТовары.Ссылка.ПометкаУдаления)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказКлиента.Товары КАК ПредварительныйЗаказКлиентаТовары
	|		ПО вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ПредварительныйЗаказКлиентаТовары.РИД
	|			И (НЕ ПредварительныйЗаказКлиентаТовары.Ссылка.ПометкаУдаления)");
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("МаркетПлейс", ПараметрыОбработки.МаркетПлейс);

	НаборЗаписей = РегистрыСведений.МП_ДанныеЗаказовСервиса.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.МаркетПлейс.Установить(ПараметрыОбработки.МаркетПлейс);
	НаборЗаписей.Прочитать();

	НаборЗаписей.Загрузить(Запрос.Выполнить().Выгрузить());

	НаборЗаписей.Записать(Истина);

КонецПроцедуры // ПривязатьДокументыКЗаказам()

// Процедура - Выполнить распределение товаров
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ВыполнитьРаспределениеТоваров(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	МенеджерОбработкиПоПодготовкеЗаказов = Обработки.ЗаполнениеЗаказовФБСМаркиовкой;

	СостояниеНеОбработано = ПараметрыОбработки.ХешТаблицаСтатусов["NEW;CUSTOM"];
	СостояниеОбработано   = ПараметрыОбработки.ХешТаблицаСтатусов["IN_ASSEMBLY;CUSTOM"];

	МассивСостоянийУКлиента = Новый Массив;
	МассивСостоянийУКлиента.Добавить(СостояниеНеОбработано);
	МассивСостоянийУКлиента.Добавить(СостояниеОбработано);
	
	// Получаем данные по товарам заказов
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить("ВЫБРАТЬ
	|	ЗаказКлиентаFBSТовары.Ссылка КАК ЗаказFBS,
	|	ЗаказКлиентаFBS.ДокОснование КАК РасходнаяНакладная,
	|	ЗаказКлиентаFBSТовары.РИД КАК НомерЗаказаВМоделиСервиса,
	|	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	|	ЗаказКлиентаFBSТовары.АртикулКонтрагента КАК АртикулКонтрагента,
	|	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	|	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	|	ЗаказКлиентаFBSТовары.СостояниеУКлиента КАК СостояниеУКлиента,
	|	ЗаказКлиентаFBSТовары.СуффиксЗаказа КАК СуффиксЗаказа,
	|	ЗаказКлиентаFBSТовары.ПрефиксЗаказа КАК ПрефиксЗаказа
	|ПОМЕСТИТЬ вт_ЗаказыНаРаспределение_Предварительная
	|ИЗ
	|	вт_СериализированныеДанныеЗаказов КАК вт_СериализированныеДанныеЗаказов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	|		ПО вт_СериализированныеДанныеЗаказов.Документ = ЗаказКлиентаFBSТовары.Ссылка
	|			И вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор = ЗаказКлиентаFBSТовары.РИД
	|			И вт_СериализированныеДанныеЗаказов.НомерЗаказа = ЗаказКлиентаFBSТовары.НомерЗаказа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиентаFBS КАК ЗаказКлиентаFBS
	|		ПО вт_СериализированныеДанныеЗаказов.Документ = ЗаказКлиентаFBS.Ссылка
	|ГДЕ
	|	вт_СериализированныеДанныеЗаказов.СостояниеУКлиента В(&СостоянияУКлиента)
	|	И вт_СериализированныеДанныеЗаказов.Документ <> ЗНАЧЕНИЕ(Документ.ЗаказКлиентаFBS.ПустаяСсылка);
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ЗаказыНаРаспределение_Предварительная.*,
	|	ДокументРасходнаяНакладная.СостояниеНакладной КАК СостояниеНакладной
	|ПОМЕСТИТЬ вт_ЗаказыНаРаспределение
	|ИЗ
	|	вт_ЗаказыНаРаспределение_Предварительная КАК вт_ЗаказыНаРаспределение_Предварительная
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК ДокументРасходнаяНакладная
	|		ПО вт_ЗаказыНаРаспределение_Предварительная.РасходнаяНакладная = ДокументРасходнаяНакладная.Ссылка
	|ГДЕ
	|	ДокументРасходнаяНакладная.Проведен
	|	И ДокументРасходнаяНакладная.СостояниеНакладной <> &СостояниеНакладной");
	ТекстыЗапросов.Добавить(МенеджерОбработкиПоПодготовкеЗаказов.МП_МагнитМаркет_ТекстЗапросаДанныеМаркировкиЗаказов(
		"вт_ЗаказыНаРаспределение"));
	ТекстыЗапросов.Добавить("ВЫБРАТЬ вт_ЗаказыНаРаспределение.НомерЗаказа КАК НомерЗаказаВДокументе, вт_ЗаказыНаРаспределение.Количество, вт_Результат.* ИЗ вт_Результат
	|ЛЕВОЕ СОЕДИНЕНИЕ вт_ЗаказыНаРаспределение КАК вт_ЗаказыНаРаспределение
	|ПО вт_Результат.НомерЗаказаСИндексом = вт_ЗаказыНаРаспределение.НомерЗаказа
	|	И вт_Результат.Идентификатор = вт_ЗаказыНаРаспределение.АртикулКонтрагента
	|ИТОГИ МАКСИМУМ(вт_Результат.НомерЗаказа), МАКСИМУМ(вт_Результат.СуффиксЗаказа) ПО вт_Результат.ЗаказFBS, НомерЗаказаВМоделиСервиса, Идентификатор");

	Запрос = Новый Запрос(СтрСоединить(ТекстыЗапросов, ";"));
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("СостоянияУКлиента", МассивСостоянийУКлиента);
	Запрос.УстановитьПараметр("СостояниеНакладной", Перечисления.СостоянияНакладной.ВРаботе);

	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		// Формируем данные по коробкам для отправки
		ВыборкаНомераЗаказов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНомераЗаказов.Следующий() Цикл
			// Проверка статуса не нужна, идет постобработка заказов после создания документов
			// Получаем структуру, для перевода ее в формат JSON
			// А так же получаем необходимый для разбиения адрес эндпоинта
			// Ихсанов Д. А. Начало 25.06.2026 Изменение 0000000221 от 25.06.2026 13:13:13: e1cib/data/Документ.Изменение?ref=89690050568f680711f1707e79109a75
			ПараметрыОбработки.ДополнительныеПараметры.Json = МенеджерОбработкиПоПодготовкеЗаказов.МП_МагнитМаркет_СформироватьСтруктуруДанныхПоВыборке(
				ВыборкаНомераЗаказов);
			
			СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1/%2", РеквизитыМаркетПлейс.Host,
					МП_АдресЗапроса_РазбитьНаПосылки()),, ПараметрыОбработки.ДополнительныеПараметры);
			ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета,
				ПараметрыОбработки.ДополнительныеПараметры.ПараметрыПреобразованияJSON);
			// Обработка ошибок со стороны сервиса
			Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
				Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
				СообщитьИзМодуля("Возникла ошибка при создании посылки");
				
				Продолжить;
			КонецЕсли;
			// Ихсанов Д. А. Конец 25.06.2026
			
			// Получаем и обрабатываем информацию о статусе заказа
			ДанныеМаркировкиОтправлены = (ДанныеОтвета.Свойство("parcels") Или ДанныеОтвета.Свойство("items"));
			Если ДанныеМаркировкиОтправлены Тогда
				ЗаказFBSОбъект = ВыборкаНомераЗаказов.ЗаказFBS.ПолучитьОбъект();

				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("НомерЗаказа", ВыборкаНомераЗаказов.НомерЗаказа);

				НайденныеСтроки = ЗаказFBSОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
				Если НайденныеСтроки.Количество() > 0 Тогда
					Для Каждого СтрокаТаблицыТоваров Из НайденныеСтроки Цикл
						СтрокаТаблицыТоваров.СостояниеУКлиента = ПараметрыОбработки.ХешТаблицаСтатусов["IN_ASSEMBLY;NEW"];
					КонецЦикла;
				КонецЕсли;

				Если Не ЗаказFBSОбъект.Модифицированность() Тогда
					Продолжить;
				КонецЕсли;

				РежимЗаписи = РежимЗаписиДокумента.Запись;
				Если ЗаказFBSОбъект.Проведен Тогда
					РежимЗаписи = РежимЗаписиДокумента.Проведение;
				КонецЕсли;
				ЗаказFBSОбъект.Записать(РежимЗаписи);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры // ВыполнитьПервичноеРаспределениеТоваров()

// Процедура - Сформировать этикетки для посылок
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура СформироватьЭтикеткиДляПосылок(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	Запрос = Новый Запрос("ВЫБРАТЬ
	|	*
	|ИЗ
	|	РегистрСведений.МП_ДанныеНоменклатурыЗаказовСервиса КАК МП_ДанныеНоменклатурыЗаказовСервиса
	|ГДЕ
	|	НЕ МП_ДанныеНоменклатурыЗаказовСервиса.ЭтикеткаСформирована
	|	И МП_ДанныеНоменклатурыЗаказовСервиса.СостояниеУКлиента = &СостояниеУКлиента");
	Запрос.УстановитьПараметр("СостояниеУКлиента", ПараметрыОбработки.ХешТаблицаСтатусов["IN_ASSEMBLY;NEW"]);

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ПолныйПутьКФайлуЭтикетки = Выборка.ПутьКЭтикетке;

		Файл = Новый Файл(ПолныйПутьКФайлуЭтикетки);
		Если Файл.Существует() И Файл.Размер() > 1000 Тогда
			МенеджерЗаписи = РегистрыСведений.МП_ДанныеНоменклатурыЗаказовСервиса.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
			МенеджерЗаписи.МаркетПлейс = ПараметрыОбработки.МаркетПлейс;
			МенеджерЗаписи.Прочитать();
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.ЭтикеткаСформирована = Истина;
				МенеджерЗаписи.ПутьКЭтикетке 		= ПолныйПутьКФайлуЭтикетки;
				МенеджерЗаписи.Записать();
			КонецЕсли;

			Продолжить;
		КонецЕсли;

		ПутьКПапкеСЭтикетками = РеквизитыМаркетПлейс.КаталогДляЭтикеток;
		Если Не ЗначениеЗаполнено(ПутьКПапкеСЭтикетками) Тогда
			ПутьКПапкеСЭтикетками = "\\srvfiles\1C_Logs_MarketPlace\";
		КонецЕсли;

		ПолныйПутьКФайлуЭтикетки = СтрШаблон("%1%2.pdf", ПутьКПапкеСЭтикетками, Выборка.НомерЗаказа);

		Файл = Новый Файл(ПолныйПутьКФайлуЭтикетки);
		Если Файл.Существует() И Файл.Размер() > 1000 Тогда
			МенеджерЗаписи = РегистрыСведений.МП_ДанныеНоменклатурыЗаказовСервиса.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
			МенеджерЗаписи.МаркетПлейс = ПараметрыОбработки.МаркетПлейс;
			МенеджерЗаписи.Прочитать();
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.ЭтикеткаСформирована = Истина;
				МенеджерЗаписи.ПутьКЭтикетке 		= ПолныйПутьКФайлуЭтикетки;
				МенеджерЗаписи.Записать();
			КонецЕсли;

			Продолжить;
		КонецЕсли;

		ПараметрыОбработки.ДополнительныеПараметры.Json = Новый Структура;
		ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("parcel_id", Новый Массив);
		ПараметрыОбработки.ДополнительныеПараметры.Json.parcel_id.Добавить(Выборка.НомерПосылки);
		
		СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1/%2", РеквизитыМаркетПлейс.Host,
				МП_АдресЗапроса_Этикетки()),, ПараметрыОбработки.ДополнительныеПараметры);
		ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета,
			ПараметрыОбработки.ДополнительныеПараметры.ПараметрыПреобразованияJSON);
		// Обработка ошибок со стороны сервиса
		Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
			Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
			ВызватьИсключение "Ошибка получения данных по заказам";
		КонецЕсли;

		ДвоичныеДанные = ПолучитьДвоичныеДанныеИзСтроки(ДанныеОтвета.file_content);
		ДвоичныеДанные.Записать(ПолныйПутьКФайлуЭтикетки);

		МенеджерЗаписи = РегистрыСведений.МП_ДанныеНоменклатурыЗаказовСервиса.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.МаркетПлейс = ПараметрыОбработки.МаркетПлейс;
		МенеджерЗаписи.Прочитать();
		Если МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.ЭтикеткаСформирована = Истина;
			МенеджерЗаписи.ПутьКЭтикетке 		= ПолныйПутьКФайлуЭтикетки;
			МенеджерЗаписи.Записать();
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры // СформироватьЭтикеткиДляПосылок()

// Процедура - Обработать отмену заказов
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ОбработатьОтменуЗаказов(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	Запрос = Новый Запрос(ОбменМаркетПлейс.ТекстЗапросаДанныеДляОтменыДокументов());
	Запрос.УстановитьПараметр("Статус", "CANCELED");
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаказFBSОбъект = Выборка.Ссылка.ПолучитьОбъект();

		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Номенклатура", Выборка.Номенклатура);
		ПараметрыОтбора.Вставить("НомерЗаказа", Выборка.НомерЗаказа);

		НайденныеСтроки = ЗаказFBSОбъект.Товары.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для Каждого СтрокаТаблицыТоваров Из НайденныеСтроки Цикл
				СтрокаТаблицыТоваров.Количество		   = 0;
				СтрокаТаблицыТоваров.Отменен		   = Истина;
				СтрокаТаблицыТоваров.ПереданоНаСайт	   = Истина;
			КонецЦикла;
		КонецЕсли;

		Если Не ЗаказFBSОбъект.Модифицированность() Тогда
			Продолжить;
		КонецЕсли;

		РежимЗаписи = РежимЗаписиДокумента.Запись;
		Если ЗаказFBSОбъект.Проведен Тогда
			РежимЗаписи = РежимЗаписиДокумента.Проведение;
		КонецЕсли;
		ЗаказFBSОбъект.Записать(РежимЗаписи);
	КонецЦикла;

КонецПроцедуры // ОбработатьОтменуЗаказов()

// Процедура - Обработать подтверждение заказов
// 
// Параметры:
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркетплейса
Процедура ОбработатьПодтверждениеЗаказов(ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	МассивСостояний = Новый Массив;
	СостоянияДокументаДляПодтверждения = ОбменМаркетПлейс.СостоянияДокументаДляПодтверждения();
	Для Каждого КлючИЗначение Из СостоянияДокументаДляПодтверждения Цикл
		МассивСостояний.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;

	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор КАК ВнешнийИдентификатор,
	|	КОЛИЧЕСТВО(вт_СериализированныеДанныеЗаказов.Номенклатура) КАК КоличествоТоваров,
	|	вт_СериализированныеДанныеЗаказов.Документ КАК Документ,
	|	вт_СериализированныеДанныеЗаказов.СостояниеНакладной КАК СостояниеНакладной
	|ПОМЕСТИТЬ вт_ДанныеПоНомерамЗаказовКПодтверждению
	|ИЗ
	|	вт_СериализированныеДанныеЗаказов КАК вт_СериализированныеДанныеЗаказов
	|ГДЕ
	|	вт_СериализированныеДанныеЗаказов.ДополнительныйСтатус = &ДополнительныйСтатус
	|
	|СГРУППИРОВАТЬ ПО
	|	вт_СериализированныеДанныеЗаказов.ВнешнийИдентификатор,
	|	вт_СериализированныеДанныеЗаказов.Документ,
	|	вт_СериализированныеДанныеЗаказов.СостояниеНакладной
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению.ВнешнийИдентификатор КАК ВнешнийИдентификатор
	|ИЗ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению КАК вт_ДанныеПоНомерамЗаказовКПодтверждению
	|ГДЕ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> НЕОПРЕДЕЛЕНО
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> ЗНАЧЕНИЕ(Документ.ЗаказКлиентаFBS.ПустаяСсылка)
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> ЗНАЧЕНИЕ(Документ.ПредварительныйЗаказКлиента.ПустаяСсылка)
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.СостояниеНакладной В(&СостояниеНакладной)
	|	
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению.ВнешнийИдентификатор КАК ВнешнийИдентификатор
	|ИЗ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению КАК вт_ДанныеПоНомерамЗаказовКПодтверждению
	|ГДЕ
	|	вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> НЕОПРЕДЕЛЕНО
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> ЗНАЧЕНИЕ(Документ.ЗаказКлиентаFBS.ПустаяСсылка)
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.Документ <> ЗНАЧЕНИЕ(Документ.ПредварительныйЗаказКлиента.ПустаяСсылка)
	|	И вт_ДанныеПоНомерамЗаказовКПодтверждению.КоличествоТоваров = 1");
	Запрос.УстановитьПараметр("ДополнительныйСтатус", "NEW");
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СостояниеНакладной", МассивСостояний);
	Запрос.МенеджерВременныхТаблиц = ПараметрыОбработки.МенеджерВременныхТаблиц;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ПараметрыОбработки.ДополнительныеПараметры.Json = Новый Структура;
		ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("order_id", Выборка.ВнешнийИдентификатор);

		СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1/%2", РеквизитыМаркетПлейс.Host,
				МП_АдресЗапроса_ПодтверждениеСборки()),, ПараметрыОбработки.ДополнительныеПараметры);
		// Обработка ошибок со стороны сервиса
		Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
			Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
			Продолжить;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры // ОбработатьПодтверждениеЗаказов()

#КонецЕсли

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Функция - МП Параметры обработки
// Возвращает структуру параметров обработки данных сервиса Яндекс Маркет
// 
// Возвращаемое значение:
//  Структура - М п параметры обработки:
// * МаркетПлейс - СправочникСсылка.ИнетМагазины - ссылка на справочник ИнетМагазины.
// * ДатаЗапроса - Дата - Текущая дата запроса.
// * ДатаНачала - Дата - дата начала периода запроса данных сервиса.
// * ДатаОкончания - Дата - дата окончания периода запроса данных сервиса.
// * МенеджерОбъекта - ОбработкаОбъект.МП_ММ_МагнитМаркет, Неопределено - менеджер объекта обработки.
// * МенеджерВременныхТаблиц - МенеджерВременныхТаблиц - менеджер временных таблиц
// * ХешТаблицаСтатусов - Соответствие из Строка - хештаблицы статусов
// * ДополнительныеПараметры - Структура - дополнительные параметры
// * ИменаСтруктурДанных - Структура - имена структур данных
// * ИменаПолей - Структура - имена полей
// * ИменаПолейТоваров - Структура - имена полей товаров
// * ПоляТовараИзДанныхЗаказа - Структура - поля товара из данных заказа
// * АгрегируемыеПоля - Структура - агрегируемые поля
// * АгрегируемыеПоляТовара - Структура - агрегируемые поля товара
// * ПолеСоответствияКодаТовара - Строка - поле соответствия кода товара в матрице
Функция МП_ПараметрыОбработки() Экспорт
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("МаркетПлейс", Справочники.ИнетМагазины.ПустаяСсылка());
	СтруктураПараметров.Вставить("ДатаЗапроса", ТекущаяДатаСеанса());
	СтруктураПараметров.Вставить("ДатаНачала", Дата(1, 1, 1));
	СтруктураПараметров.Вставить("ДатаОкончания", Дата(1, 1, 1));
	СтруктураПараметров.Вставить("МенеджерОбъекта", Неопределено);
	СтруктураПараметров.Вставить("МенеджерВременныхТаблиц", Новый МенеджерВременныхТаблиц);
	СтруктураПараметров.Вставить("ХешТаблицаСтатусов", Новый Соответствие);
	СтруктураПараметров.Вставить("ДополнительныеПараметры", Новый Структура);
	СтруктураПараметров.Вставить("ИменаСтруктурДанных", Новый Структура);
	СтруктураПараметров.Вставить("ИменаПолей", Новый Структура);
	СтруктураПараметров.Вставить("ИменаПолейТоваров", Новый Структура);
	СтруктураПараметров.Вставить("ПоляТовараИзДанныхЗаказа", Новый Структура);
	СтруктураПараметров.Вставить("АгрегируемыеПоля", Новый Структура);
	СтруктураПараметров.Вставить("АгрегируемыеПоляТовара", Новый Структура);
	// Ихсанов Д. А. Начало 25.06.2026 Изменение 0000000221 от 25.06.2026 13:13:13: e1cib/data/Документ.Изменение?ref=89690050568f680711f1707e79109a75
	СтруктураПараметров.Вставить("ПолеСоответствияКодаТовара", "");
	// Ихсанов Д. А. Конец 25.06.2026
	
	Возврат СтруктураПараметров;
	
КонецФункции // МП_ПараметрыОбработки()

// Процедура - МП Заполнить параметры обработки
// Заполняет параметры стандартными стандартными значениями текущего объекта.
// 
// Параметры:
//  СтруктураПараметров - Структура - структура параметров обработки данных сервиса Магнит Маркет.
Процедура МП_ЗаполнитьПараметрыОбработки(СтруктураПараметров) Экспорт
	
	// Общие настройки для работы в модели сервиса
	СтруктураПараметров.ДополнительныеПараметры	   = КоннекторHTTP.НовыеПараметры();
	
	// Инициализируем параметры библиотеки
	СтруктураПараметров.ДополнительныеПараметры.Заголовки =
		ОбменМаркетПлейс.МП_Магнит_ВернутьЗаголовкиHTTP(СтруктураПараметров.МаркетПлейс);
