// Функция - МП Восстановление значений полей JSON
// Вспомогательная функция, вызываемая при чтении JSON объекта. Необходима для коррекции
// типов данных и значений полей.
// 
// Параметры:
//  Свойство - Строка - Имя поля структуры JSON для обработки.
//  Значение - Строка, Число - Значения поля для обработки.
//  ДополнительныеПараметры - Структура - Перечень дополнительных параметров для обработки.
// 
// Возвращаемое значение:
//  Неопределено, Строка, Число - Строка, Число, Дата, Любая ссылка.
Функция МП_ВосстановлениеЗначенийПолейJSON(Свойство, Значение, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(ДополнительныеПараметры.ИменаПолейДляВосстановления) = Тип("Строка") Тогда
		МассивПолейДляВосстановления = СтрРазделить(СтрЗаменить(
			ДополнительныеПараметры.ИменаПолейДляВосстановления, " ", ""), ",", Ложь);
	Иначе
		МассивПолейДляВосстановления = ДополнительныеПараметры.ИменаПолейДляВосстановления;
	КонецЕсли;

	Если МассивПолейДляВосстановления.Найти(Свойство) = Неопределено Тогда
		Возврат Значение;
	КонецЕсли;

	Результат = Неопределено;
	УстановитьБезопасныйРежим(Истина);
	Выполнить (ДополнительныеПараметры.ОбработчикПолейВосстановления[Свойство]);
	УстановитьБезопасныйРежим(Ложь);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Возврат Значение;

КонецФункции // МП_ВосстановлениеЗначенийПолейJSON()

// Функция - МП Преобразование значений полей JSON
// Вспомогательная функция, вызываемая при записи JSON объекта. Необходима для коррекции
// типов данных и значений полей.
// 
// Параметры:
//  Свойство - Строка - Имя поля структуры JSON для обработки.
//  Значение - Строка, Число - Значения поля для обработки.
//  ДополнительныеПараметры - Структура - Перечень дополнительных параметров для обработки.
//  Отказ - Булево - 
// 
// Возвращаемое значение:
//  Строка, Число - Строка, Число, Дата, Любая ссылка.
Функция МП_ПреобразованиеЗначенийПолейJSON(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт

	Возврат Значение;

КонецФункции // МП_ПреобразованиеЗначенийПолейJSON()

// Функция - Получить посылки по номерам заказов
// 
// Параметры:
//  МассивНомеровЗаказов - Массив из Строка - Массив номеров заказов по которым будут получены посылки
//  ПараметрыОбработки - Структура - Структура параметров обработки данных сервиса Магнит Маркет
//  РеквизитыМаркетПлейс - Структура - Реквизиты маркет плейс
// 
// Возвращаемое значение:
//  Соответствие из Строка - Данные по посылкам, ключ - это номер заказа, в значении структура с данными посылки
Функция ПолучитьПосылкиПоНомерамЗаказов(МассивНомеровЗаказов, ПараметрыОбработки, РеквизитыМаркетПлейс) Экспорт

	ХешКартаЗаказовИПосылок = Новый Соответствие;
	
	ПараметрыОбработки.ДополнительныеПараметры.Json = Новый Структура;
	ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("order_id", МассивНомеровЗаказов);
	ПараметрыОбработки.ДополнительныеПараметры.Json.Вставить("page_size", 1000);
	
	СтруктураДанныхОтвета = КоннекторHTTP.Post(СтрШаблон("https://%1%2", РеквизитыМаркетПлейс.Host,
			МП_АдресЗапроса_СписокПосылок()),, ПараметрыОбработки.ДополнительныеПараметры);
	ДанныеОтвета = КоннекторHTTP.КакJson(СтруктураДанныхОтвета,
		ПараметрыОбработки.ДополнительныеПараметры.ПараметрыПреобразованияJSON);
	// Обработка ошибок со стороны сервиса
	Если Не СтруктураДанныхОтвета.Свойство("КодСостояния")
		Или СтруктураДанныхОтвета.КодСостояния > 400 Тогда
		ВызватьИсключение "Ошибка получения данных по посылкам!";
	КонецЕсли;
	
	// Обработка ошибок со стороны сервиса
	Если ДанныеОтвета.Свойство("errors") Тогда
		СообщитьИзМодуля("НУЖНО ЗАФИКСИРОВАТЬ ЛОГ");
	КонецЕсли;

	Для Каждого ДанныеПосылки Из ДанныеОтвета.parcels Цикл
		СтруктураПосылки = ХешКартаЗаказовИПосылок[ДанныеПосылки.order_id];
		Если СтруктураПосылки = Неопределено Тогда
			СтруктураПосылки = Новый Соответствие;

			ХешКартаЗаказовИПосылок.Вставить(ДанныеПосылки.order_id, СтруктураПосылки);
		КонецЕсли;

		Для Каждого ДанныеТовара Из ДанныеПосылки.items Цикл
			СтруктураТовара = СтруктураПосылки[Формат(ДанныеТовара.sku_id, "ЧГ=")];
			Если СтруктураТовара = Неопределено Тогда
				СтруктураТовара = Новый Соответствие;

				СтруктураПосылки.Вставить(Формат(ДанныеТовара.sku_id, "ЧГ="), СтруктураТовара);
			КонецЕсли;

			СтруктураДанныхПосылки = Новый Структура;
			СтруктураДанныхПосылки.Вставить("parcel_id");
			СтруктураДанныхПосылки.Вставить("order_id");
			СтруктураДанныхПосылки.Вставить("status");
			СтруктураДанныхПосылки.Вставить("barcode");
			СтруктураДанныхПосылки.Вставить("cutoff_time");
			ЗаполнитьЗначенияСвойств(СтруктураДанныхПосылки, ДанныеПосылки);

			СтруктураТовара.Вставить(ДанныеПосылки.parcel_id, СтруктураДанныхПосылки);
		КонецЦикла;
	КонецЦикла;

	Возврат ХешКартаЗаказовИПосылок;

КонецФункции // ПолучитьПосылкиПоНомерамЗаказов()

// Функция - Отменить заказы полностью
// 
// Параметры:
//  ПараметрыОбработки - Структура - Параметры обработки данных сервиса Магнит Маркет
//  НомерЗаказа - Строка - Номер заказа строкой
// 
// Возвращаемое значение:
//  Булево - Результат отмены заказа, если Ложь, то заказ не отменен, истина если отменен
Функция ОтменитьЗаказыПолностью(ПараметрыОбработки, НомерЗаказа) Экспорт

	ДанныеДляJSON = Новый Структура;
	ДанныеДляJSON.Вставить("order_id", НомерЗаказа);

	ПараметрыОбработки.ДанныеЗапроса.Метод 		 = "POST";
	ПараметрыОбработки.ДанныеЗапроса.ТелоЗапроса = ОбменМаркетПлейс.СформироватьСтрокуJSON(ДанныеДляJSON,
		ПараметрыОбработки);

	ДанныеОтвета = ОбменМаркетПлейс.ВыполнитьИОбработатьЗапросВМоделиСервиса(
		ОбменМаркетПлейс.МП_Магнит_ВернутьСоединение(ПараметрыОбработки.МаркетПлейс),
