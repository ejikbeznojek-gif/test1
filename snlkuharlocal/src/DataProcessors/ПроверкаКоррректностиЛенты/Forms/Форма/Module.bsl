
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ЗаданиеНаМаркировку") Тогда
		
		ЗаданиеНаМаркировку = Параметры.ЗаданиеНаМаркировку; 		
				
	КонецЕсли;
	
	ДобавитьУсловноеОформление(); 
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	Если ТолькоПросмотр Тогда Возврат КонецЕсли;	
	Если НЕ ВводДоступен() Тогда Возврат КонецЕсли;
	
	Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	
	Данные=СтрЗаменить(Данные,Символы.ПС,"");
	
	глТорговоеОборудование.СканерПосылкаДанных(1);
	глСобытиеСканераОтработано = Истина;
	
	ОтработкаДанныхШККм(Данные);

КонецПроцедуры

&НаКлиенте
Процедура ОтработкаДанныхШККм(Данные)
	
	//Перем ДанныеМаркиЧЗ, КоличествоИзШК, НоваяСтрока, Номенклатура, Отбор, СтрокиСкан, ТипАгрегацииЧКод, ШтрихкодУпаковки;
	
	ДанныеМаркиЧЗ=Неопределено;
	
	КоличествоИзШК	= 0;
	Номенклатура	= НайтиТоварПоШтрихКоду(Данные,неопределено,КоличествоИзШК,ДанныеМаркиЧЗ);
	
	Если ДанныеМаркиЧЗ.СканировалиКодЧЗ  тогда
		
		ШтрихкодУпаковки = ДанныеМаркиЧЗ.МаркаЧЗ; 		
		
		Если ЗначениеЗаполнено(КодАгрегации) Тогда
			
			//заполняем ТЧ
			Отбор = Новый Структура("КодМаркировки",ШтрихкодУпаковки);
			
			СтрокиСкан =  ДанныеОтсканированные.НайтиСтроки(Отбор); 
			Если СтрокиСкан.Количество() = 0  Тогда
				
				ТипАгрегацииЧКод = ОпределитьТипАгрегации(ШтрихкодУпаковки);
				Если ТипАгрегацииЧКод = неопределено Тогда
					
					Сообщить("неверно отсканированный код",СтатусСообщения.Важное); 
					
					Возврат; 	
					
				КонецЕсли;
				
				НоваяСтрока = ДанныеОтсканированные.Добавить();
				НоваяСтрока.КодМаркировки =  ШтрихкодУпаковки; 
				НоваяСтрока.ТипАгрегации = ТипАгрегацииЧКод;  
				
			КонецЕсли;
			
		Иначе 
			ТипАгрегацииЧКод = ОпределитьТипАгрегации(ШтрихкодУпаковки,истина);
			
			Если ТипАгрегацииЧКод = неопределено Тогда
				
				Сообщить("неверно отсканированный код",СтатусСообщения.Важное); 
				Возврат; 	
				
			КонецЕсли;
			КодАгрегации = ШтрихкодУпаковки;
			ТипАгрегации = ТипАгрегацииЧКод; 
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

