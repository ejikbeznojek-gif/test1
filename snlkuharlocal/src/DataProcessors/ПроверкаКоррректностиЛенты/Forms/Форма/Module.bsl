//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Функция ОпределитьТипАгрегации(ШтрихкодУпаковки,ВШапку  = Ложь)
                                                 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИСТИНА КАК ЭтоШтука,
		|	ЛОЖЬ КАК ЭтоБлочок,
		|	ЛОЖЬ КАК ЭтоКоробка,
		|	ЛОЖЬ КАК ЭтоПаллета,
		|	4 КАК ЧисловойКод
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
		|		ПО ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = ЗаданиеНаМаркировку.Ссылка
		|ГДЕ
		|	ЗаданиеНаМаркировку.Ссылка = &Ссылка
		|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодУпаковки = &ШтрихкодУпаковки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛОЖЬ,
		|	ИСТИНА,
		|	ЛОЖЬ,
		|	ЛОЖЬ,
		|	3
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
		|		ПО ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = ЗаданиеНаМаркировку.Ссылка
		|ГДЕ
		|	ЗаданиеНаМаркировку.Ссылка = &Ссылка
		|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодБлочка = &ШтрихкодУпаковки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛОЖЬ,
		|	ЛОЖЬ,
		|	ИСТИНА,
		|	ЛОЖЬ,
		|	2
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
		|		ПО ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = ЗаданиеНаМаркировку.Ссылка
		|ГДЕ
		|	ЗаданиеНаМаркировку.Ссылка = &Ссылка
		|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодКоробки = &ШтрихкодУпаковки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛОЖЬ,
		|	ЛОЖЬ,
		|	ЛОЖЬ,
		|	ИСТИНА,
		|	1
		|ИЗ
		|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаМаркировку КАК ЗаданиеНаМаркировку
		|		ПО ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = ЗаданиеНаМаркировку.Ссылка
		|ГДЕ
		|	ЗаданиеНаМаркировку.Ссылка = &Ссылка
		|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодПалеты = &ШтрихкодУпаковки";
	
	Запрос.УстановитьПараметр("Ссылка", ЗаданиеНаМаркировку);
	Запрос.УстановитьПараметр("ШтрихкодУпаковки", ШтрихкодУпаковки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
	 
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		Если ВШапку И ВыборкаДетальныеЗаписи.ЭтоШтука Тогда
			
			Сообщить("Для проверки отсканируйте паллету, короб или блочок!!!",СтатусСообщения.Важное); 
			
			Возврат неопределено; 
		Иначе 
			
			Возврат ВыборкаДетальныеЗаписи.ЧисловойКод; 
			
		КонецЕсли;
		
	Иначе 
		
		Возврат неопределено; 
	КонецЕсли;

КонецФункции // ЗаполнитьДанныеНаФорме()


&НаКлиенте
Процедура ДобавитьКодВручную(Команда)
	
	перем КодКМ; 
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаКМВручную",ЭтаФорма);
	
	ОписаниеТипов = Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(200)); 
	ПоказатьВводЗначения(ОписаниеОповещения,КодКМ,"Введите КМ",ОписаниеТипов); 
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ПослеВводаКМВручную(ШККм,ДополнительныеПараметры) Экспорт 
	Если ШККм = Неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	Если СтрДлина(ШККм) = 18 Тогда
		
		ШККм = "00" + ШККм; 	
	Иначе 
		ШККм1  =  СокрЛП(Справочники.ШтрихкодыУпаковокТоваров.ВосстановитьКод_GS1(ШККм));
		
		ШККм = Лев(ШККм1, 31) + СтрЗаменить(Сред(ШККм1, 32), Символ(29), "<GS>"); 
		
		КоличествоНулей = 83 - СтрДлина(ШККм); 
		Дополнить = Формат(1,"ЧЦ="+КоличествоНулей+"; ЧВН="); 
		
		ШККм  = ШККм  + Дополнить; 
	КонецЕсли;

	ОтработкаДанныхШККм(ШККм); 

КонецПроцедуры // ОписаниеТипов()

&НаКлиенте
Процедура ПроверитьВведенныеДанные(Команда)
	Если Не ЗначениеЗаполнено(КодАгрегации)
		 ИЛИ Не ЗначениеЗаполнено(ТипАгрегации) Тогда
		
		Сообщить("Для проверки отсканируйте паллету, короб или блочок!!!",СтатусСообщения.Важное);
		
		Возврат; 
		
	КонецЕсли;
	
	Если ДанныеОтсканированные.Количество() = 0 Тогда
	
		Сообщить("Для проверки заполните таблицу!!!",СтатусСообщения.Важное);
		
		Возврат; 
		
	КонецЕсли;
	
	МассивВозможныхКодов = ПолучитьМассивКодовПоТипуАгрегации(ТипАгрегации,ЗаданиеНаМаркировку,КодАгрегации);
	
	Для каждого СтрокаДанных Из ДанныеОтсканированные Цикл
	
		Если МассивВозможныхКодов.Найти(СтрокаДанных.КодМаркировки) = Неопределено  Тогда
		
			СтрокаДанных.Ошибка = Истина;  
		Иначе 
			СтрокаДанных.Проверено = Истина;
		КонецЕсли;
		 
	
	КонецЦикла;
	
КонецПроцедуры

