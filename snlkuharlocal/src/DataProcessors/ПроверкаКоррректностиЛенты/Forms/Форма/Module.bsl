//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервереБезКонтекста
Функция ПолучитьМассивКодовПоТипуАгрегации(ТипАгрегации,ДокОснование,КодКМ)
	Запрос = Новый Запрос;
	
	ТекстЗапросаШтуки = 
	"ВЫБРАТЬ Различные
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодУпаковки КАК Штрихкод
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
	|ГДЕ
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.%ИмяКолонки% = &КодКМ
	|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = &Ссылка "; 
	
	ТекстЗапросаБлочки =
	"ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодБлочка
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
	|ГДЕ
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.%ИмяКолонки% = &КодКМ
	|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = &Ссылка";
	
	ТекстЗапросаКоробки =
	"ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.ШтрихкодКоробки
	|ИЗ
	|	Документ.ЗаданиеНаМаркировку.ШтрихкодыУпаковок КАК ЗаданиеНаМаркировкуШтрихкодыУпаковок
	|ГДЕ
	|	ЗаданиеНаМаркировкуШтрихкодыУпаковок.%ИмяКолонки% = &КодКМ
	|	И ЗаданиеНаМаркировкуШтрихкодыУпаковок.Ссылка = &Ссылка";
	
	Если ТипАгрегации = 3 Тогда   //блочок
		
		Запрос.Текст = ТекстЗапросаШтуки;
		ИмяКолонки = "ШтрихкодБлочка"; 
		
	ИначеЕсли ТипАгрегации = 2 Тогда //коробка
		
		Запрос.Текст = ТекстЗапросаШтуки + ТекстЗапросаБлочки;
		ИмяКолонки = "ШтрихкодКоробки";
		
	ИначеЕсли  ТипАгрегации = 3 Тогда //паллета
		
		Запрос.Текст = ТекстЗапросаШтуки + ТекстЗапросаБлочки + ТекстЗапросаКоробки;
		ИмяКолонки = "ШтрихкодПалеты";
	КонецЕсли;		
	
	Запрос.УстановитьПараметр("КодКМ", КодКМ);
	Запрос.УстановитьПараметр("Ссылка", ДокОснование);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ИмяКолонки%",ИмяКолонки); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Штрихкод"); 

КонецФункции // ()

&НаКлиенте
Процедура ОчиститьВсе(Команда)
	КодАгрегации = ПредопределенноеЗначение("Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка"); 
	ДанныеОтсканированные.Очистить();
КонецПроцедуры

