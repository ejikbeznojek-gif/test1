Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	             |	Док.Ссылка КАК Ссылка
	             |ИЗ
	             |	Документ.КоррекцияРНК КАК Док
	             |ГДЕ
	             |	Док.Дата >= &Дата
	             |	И Док.Проведен
	             |	И Док.ДокОснование.Проведен
	             |	И Док.СостояниеКоррекции = &Утверждена
	             |
	             |ОБЪЕДИНИТЬ ВСЕ
	             |
	             |ВЫБРАТЬ
	             |	Док.Ссылка
	             |ИЗ
	             |	Документ.КоррекцияТоваров КАК Док
	             |ГДЕ
	             |	Док.Дата >= &Дата
	             |	И Док.Проведен
	             |	И Док.ДокОснование.Проведен
	             |	И Док.СостояниеКоррекции = &Утверждена";
	запрос.УстановитьПараметр("Дата",Константы.ДатаЗапретаРедактирования.Получить());
	запрос.УстановитьПараметр("Утверждена",Перечисления.СостоянияКоррекции.Утверждена);	
	//Кухарь 18.12.19 начало
	//Выкидывает в фоновых заданиях с метод не обнаружен следующий()
	//результат = запрос.выполнить().выбрать();	
	//Пока результат.следующий() цикл
	ТЗ=запрос.Выполнить().выгрузить();	
	Для Каждого результат из тз цикл 
	//Кухарь 18.12.19 конец		
		Коррекция=результат.ссылка;
		
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		             |	ПисьмаНаОтправку.Основание КАК Основание
		             |ИЗ
		             |	РегистрСведений.ПисьмаНаОтправку КАК ПисьмаНаОтправку
		             |ГДЕ
		             |	ПисьмаНаОтправку.ДатаСозданияПисьма МЕЖДУ &Дата1 И &Дата2
		             |	И ПисьмаНаОтправку.ТемаПисьма ПОДОБНО ""Уведомление об утверждении коррекции""
		             |	И (ПисьмаНаОтправку.Основание = &Коррекция
		             |			ИЛИ ПисьмаНаОтправку.Основание = ""Универсальная обработка коррекций пакет созданный""
		             |				И ПисьмаНаОтправку.ТекстПисьма ПОДОБНО &НомерКоррекции)";
		//Кухарь 23.12.19 начало
		//Отбивка по коррекциям утверждённым более чем 2 часа назад
		//запрос.УстановитьПараметр("Сегодня",НачалоДня(ТекущаяДата()));
		//запрос.УстановитьПараметр("ПустаяДата",ПустаяДата());
		запрос.УстановитьПараметр("Дата1",НачалоДня(ТекущаяДата()));

		// Кухарь А.Ю. 09.02.2021 начало
		// 		запрос.УстановитьПараметр("Дата2",ТекущаяДата()-2*3600);
		запрос.УстановитьПараметр("Дата2",ТекущаяДата());		 
		// Кухарь А.Ю. 09.02.2021 конец
		
		//Кухарь 23.12.19 конец

		запрос.УстановитьПараметр("Коррекция",Коррекция);
		запрос.УстановитьПараметр("НомерКоррекции","%"+Коррекция.номер+"%");
		результат=запрос.Выполнить().Выгрузить();
		если результат.Количество()>0 тогда
			Продолжить;
		КонецЕсли;
		
		СформироватьУведомление(Коррекция);
	КонецЦикла;
	
КонецПроцедуры



//Кухарь 10.01.19 начало
//Создание записей в РС ПисьмаНаОтправку
Процедура СформироватьУведомление(Коррекция) экспорт
	если ложь тогда Коррекция=Документы.КоррекцияРНК.ПустаяСсылка();КонецЕсли;
	
	СписокПолучателей=новый СписокЗначений;
	ТемаПисьма="Повторное уведомление об отработке";
	
	Согласования=Коррекция.Согласования;
	ТипКоррекции=Коррекция.метаданные().имя;
	Автор=Коррекция.Автор;
	Номер=Коррекция.Номер;
	ДокОснование=Коррекция.ДокОснование;
	ТипДокОснования=ДокОснование.метаданные().имя;
	если ТипДокОснования="ЗаявкаВТранспортныйОтдел" тогда
		Отправитель=ДокОснование.Отправитель;
		Получатель=ДокОснование.Получатель;
	КонецЕсли;
	
	если Коррекция.ДокОснование.Метаданные().Имя="РасходнаяНакладная" тогда
		ТекстКонтрагента=" по контрагенту "+ДокОснование.Контрагент.Наименование;
	иначе
		ТекстКонтрагента="";
	КонецЕсли;
	
	ТекстПисьма="Просьба не забыть отработать коррекцию "+Номер+ТекстКонтрагента;
	
	если ТипКоррекции="КоррекцияТоваров" тогда
		ТекстПисьма=СтрЗаменить(ТекстПисьма," коррекцию "," коррекцию по товарам ");
	КонецЕсли;
	
	//Михайловский С. 20220712 -придется так+++
	МИскл=Новый Массив;
	МИскл.Добавить("krohin@collant.ru");
	МИскл.Добавить("kuhar@collant.ru");
	//Михайловский С. 20220712 -придется так---
	СписокПолномочий=новый СписокЗначений;
	//Михайловский С. 20220718 -коррекция по полномочиям+++
	СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SSP-0145"));	
	ДопСписок1=СформСписокПолучат(Справочники.ТипыРассылок.ПовторноеУведомлениеОбОбработке,Справочники.Подразделения.НайтиПоКоду("SSP-0145"));
	ДопСписок2=СформСписокПолучат(Справочники.ТипыРассылок.ПовторноеУведомлениеОбОбработке,Справочники.Подразделения.НайтиПоКоду("SMN-0434"));
	ДопСписок3=СформСписокПолучат(Справочники.ТипыРассылок.ПовторноеУведомлениеОбОбработке,Справочники.Подразделения.НайтиПоКоду("SMN-0436"));
	если СтрТЧ<>Неопределено и не СтрТЧ.Согласовано тогда  //Претензионно-ревизионный отдел
				
		
		Если ДопСписок1.Количество() Тогда
			Для Каждого ТЭл ИЗ ДопСписок1 Цикл
				СписокПолучателей.Добавить(ТЭл.Значение);
			КонецЦикла;	
		Иначе
			СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработка);
		КонецЕсли;	
		
	КонецЕсли;	
	
	СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0434"));	
	если СтрТЧ<>Неопределено и не СтрТЧ.Согласовано  тогда   //ОВЛ
		
		Если ДопСписок2.Количество() Тогда
			Для Каждого ТЭл ИЗ ДопСписок2 Цикл
				СписокПолучателей.Добавить(ТЭл.Значение);
			КонецЦикла;	
		Иначе
			СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработкаОВЛ);
		КонецЕсли;
		
	КонецЕсли;		
	
	СтрТЧ=Согласования.Найти(Справочники.Подразделения.НайтиПоКоду("SMN-0436"));	
	если СтрТЧ<>Неопределено  и не СтрТЧ.Согласовано  тогда  //Складской Комплекс Общие
		
		Если ДопСписок3.Количество() Тогда
			Для Каждого ТЭл ИЗ ДопСписок3 Цикл
				СписокПолучателей.Добавить(ТЭл.Значение);
			КонецЦикла;	
		Иначе
			СписокПолномочий.Добавить(ПланыВидовХарактеристик.ПолномочияПользователей.ДокументКоррекцияОбработкаСК);
		КонецЕсли;
		
		
	КонецЕсли;	
	Если НЕ ДопСписок1.Количество() И НЕ ДопСписок2.Количество() И НЕ ДопСписок3.Количество() Тогда
		Запрос=новый запрос;
		запрос.Текст= "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(ПолномочияПользователей.Пользователь.ФизЛицо.ЕМэйл КАК СТРОКА(100)) КАК Почта,
		|	ПолномочияПользователей.Полномочие
		|ИЗ
		|	РегистрСведений.ПолномочияПользователей КАК ПолномочияПользователей
		|ГДЕ
		|	ПолномочияПользователей.Полномочие В(&СписокПолномочий)
		|	И ПолномочияПользователей.Значение = ИСТИНА";
		запрос.УстановитьПараметр("СписокПолномочий",СписокПолномочий);
		//Кухарь 18.12.19 начало
		//Выкидывает в фоновых заданиях с метод не обнаружен следующий()
		//результат = запрос.выполнить().выбрать();	
		//Пока результат.следующий() цикл
		ТЗ=запрос.Выполнить().выгрузить();	
		Для Каждого результат из тз цикл 
			//Кухарь 18.12.19 конец	
			если Найти(результат.Почта,"@")>0 тогда
				//Михайловский С. 20220712 -придется так+++
				//вместо
				//СписокПолучателей.Добавить(СокрЛП(результат.Почта));
				Если МИскл.Найти(СокрЛП(результат.Почта))=неопределено Тогда
					СписокПолучателей.Добавить(СокрЛП(результат.Почта));
				КонецЕсли;	
				//Михайловский С. 20220712 -придется так---
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	
	//Михайловский С. 20220718 -изменения по полномочиям---
	
	если Найти(автор.ФизЛицо.ЕМэйл,"@")>0 тогда
		СписокПолучателей.Добавить(СокрЛП(автор.ФизЛицо.ЕМэйл));
	КонецЕсли;
	
	если Найти(ДокОснование.Менеджер.ЕМэйл,"@")>0 тогда
		СписокПолучателей.Добавить(СокрЛП(ДокОснование.Менеджер.ЕМэйл));
	КонецЕсли;


	если СокрЛП(ТекстПисьма="") тогда
		ЗаписатьВЛог("Регламент","Пустой текст при формировании письма к коррекции № "+Номер,"Ошибка");		
	ИначеЕсли СписокПолучателей.Количество()=0 тогда
		ЗаписатьВЛог("Регламент","Пустой список адресатов при формировании письма к коррекции № "+Номер,"Ошибка");
	иначе
		//Кухарь 15.01.19 начало
		тз=новый ТаблицаЗначений;
		тз.Колонки.Добавить("Склад");
		тз.Колонки.Добавить("ГруппыТоваров");
		тз.Колонки.Добавить("Номер");
		тз.Колонки.Добавить("СостояниеНакладной");
		тз.Колонки.Добавить("ДатаОтгрузки");
		тз.Колонки.Добавить("Получатель");
		тз.Колонки.Добавить("ТипДоставки");
		тз.Колонки.Добавить("ПунктДоставки");
		тз.Колонки.Добавить("КоличествоДокумента");
		тз.Колонки.Добавить("Объем");
		тз.Колонки.Добавить("АвторКоррекции");
		тз.Колонки.Добавить("ИзменяемыеРеквизитыНакладной");
		тз.Колонки.Добавить("ТекущееЗначение");
		тз.Колонки.Добавить("НовоеЗначение");
		тз.Колонки.Добавить("Накладная");
		
		СтрТЗ=тз.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЗ,ДокОснование);
		если ДокОснование.ОбъемКоробов >0 тогда
			СтрТЗ.Объем=ДокОснование.ОбъемКоробов;
		иначе
			СтрТЗ.Объем=ДокОснование.ОбъемДокумента;
		КонецЕсли;
		СтрТЗ.Накладная=ДокОснование;
		СтрТЗ.АвторКОррекции=автор;

		
		если ДокОснование.метаданные().имя<>"ЗаявкаВТранспортныйОтдел" тогда
			СтрТЗ.Получатель=?(ДокОснование.метаданные().имя="Перемещение",ДокОснование.СкладПолучатель,ДокОснование.Контрагент);
		иначе
			СтрТЗ.Получатель=?(типзнч(отправитель)=тип("СправочникСсылка.Контрагенты"),Отправитель,Получатель);
		КонецЕсли;
		
		если ТипКоррекции<>"КоррекцияТоваров" тогда			
			ТЗИзменений=новый ТаблицаЗначений;
			ТЗИзменений.Колонки.Добавить("ИмяРеквизита");
			ТЗИзменений.Колонки.Добавить("СинонимРеквизита");
			ТЗИзменений.Колонки.Добавить("ДоИзменения");
			ТЗИзменений.Колонки.Добавить("ПослеИзменения");
			ТЗИзменений.Колонки.Добавить("ВНакладной");
			ТЗИзменений.Колонки.Добавить("Накладная");	
			ТЗРеквизитов=ПолучитьТЗДоступныхКИзменениюРеквизитов(Коррекция);	
			для каждого ТекРеквизит из  ТЗРеквизитов цикл
				ИмяИзменяемогоРеквизит=Коррекция.Метаданные().Реквизиты.Найти(ТекРеквизит.ИмяРеквизита+"ДоИзменения");	
				если ИмяИзменяемогоРеквизит=Неопределено тогда Продолжить;КонецЕсли;
				ЗначениеИзменяемогоРеквизита=Коррекция[ИмяИзменяемогоРеквизит.имя];
				ЗначениеТекущегоРеквизита=Коррекция[ТекРеквизит.ИмяРеквизита];	
				если ЗначениеИзменяемогоРеквизита<>ЗначениеТекущегоРеквизита тогда
					СтрТЧ=ТЗИзменений.Добавить();
					СтрТЧ.ИмяРеквизита=ТекРеквизит.ИмяРеквизита;
					СтрТЧ.СинонимРеквизита=Коррекция.Метаданные().Реквизиты.Найти(ТекРеквизит.ИмяРеквизита).синоним;
					СтрТЧ.ДоИзменения=ЗначениеИзменяемогоРеквизита;
					СтрТЧ.ПослеИзменения=ЗначениеТекущегоРеквизита;
					СтрТЧ.ВНакладной=ДокОснование[ТекРеквизит.ИмяРеквизита];	
					СтрТЧ.Накладная=ДокОснование;
					если СтрТЧ.ИмяРеквизита="ПунктДоставки" тогда
					//Кухарь 02.04.20 начало
					//+ изменения в доп. печати
					если СтрТЧ.ДоИзменения.ПечГрузополучательТорг12<>СтрТЧ.ПослеИзменения.ПечГрузополучательТорг12 тогда
						СтрТЧ2=ТЗИзменений.Добавить();
						ЗаполнитьЗначенияСвойств(СтрТЧ2,СтрТЧ);	
						СтрТЧ2.ДоИзменения=СтрТЧ2.ДоИзменения.ПечГрузополучательТорг12;
						СтрТЧ2.ВНакладной=СтрТЧ2.ВНакладной.ПечГрузополучательТорг12;	
						СтрТЧ2.ПослеИзменения=СтрТЧ2.ПослеИзменения.ПечГрузополучательТорг12;	
						СтрТЧ2.ИмяРеквизита="Грузополучатель торг12 из доп. печати";
						СтрТЧ2.СинонимРеквизита="Грузополучатель торг12 из доп. печати";
					КонецЕсли;
					
					если СтрТЧ.ДоИзменения.ПечГрузополучательСФ<>СтрТЧ.ПослеИзменения.ПечГрузополучательСФ тогда
						СтрТЧ2=ТЗИзменений.Добавить();
						ЗаполнитьЗначенияСвойств(СтрТЧ2,СтрТЧ);	
						СтрТЧ2.ДоИзменения=СтрТЧ2.ДоИзменения.ПечГрузополучательСФ;
						СтрТЧ2.ВНакладной=СтрТЧ2.ВНакладной.ПечГрузополучательСФ;	
						СтрТЧ2.ПослеИзменения=СтрТЧ2.ПослеИзменения.ПечГрузополучательСФ;	
						СтрТЧ2.ИмяРеквизита="Грузополучатель СФ из доп. печати";
						СтрТЧ2.СинонимРеквизита="Грузополучатель СФ из доп. печати";
					КонецЕсли;			                  
					//Кухарь 02.04.20 конец
						
						
						СтрТЧ.ДоИзменения=Строка(СтрТЧ.ДоИзменения)+"; Адрес: "+СтрТЧ.ДоИзменения.ПочтовыйАдрес;
						СтрТЧ.ПослеИзменения=Строка(СтрТЧ.ПослеИзменения)+"; Адрес: "+СтрТЧ.ПослеИзменения.ПочтовыйАдрес;
					КонецЕсли;
				КонецЕсли;	
			КонецЦикла;
		иначе
			ТЗИзменений=новый ТаблицаЗначений;		
			ТЗИзменений.Колонки.Добавить("Реквизит");
			ТЗИзменений.Колонки.Добавить("ДоИзменения");
			ТЗИзменений.Колонки.Добавить("ПослеИзменения");
			если Коррекция.ОбъемДокумента<>Коррекция.ОбъемДокументаДоИзменения тогда
				СтрТЗ=ТЗИзменений.Добавить();
				СтрТЗ.Реквизит="Объём номенклатуры";
				СтрТЗ.ДоИзменения=Коррекция.ОбъемДокументаДоИзменения;
				СтрТЗ.ПослеИзменения=Коррекция.ОбъемДокумента;	
			КонецЕсли;
			если Коррекция.СуммаДокумента<>Коррекция.СуммаДокументаДоИзменения тогда
				СтрТЗ=ТЗИзменений.Добавить();
				СтрТЗ.Реквизит="Сумма документа";
				СтрТЗ.ДоИзменения=Коррекция.СуммаДокументаДоИзменения;
				СтрТЗ.ПослеИзменения=Коррекция.СуммаДокумента;	
			КонецЕсли;
			если Коррекция.КоличествоДокумента<>Коррекция.КоличествоДокументаДоИзменения тогда
				СтрТЗ=ТЗИзменений.Добавить();
				СтрТЗ.Реквизит="Количество";
				СтрТЗ.ДоИзменения=Коррекция.КоличествоДокументаДоИзменения;
				СтрТЗ.ПослеИзменения=Коррекция.КоличествоДокумента;	
			КонецЕсли;			
		КонецЕсли;
		ХТМЛТекст=ПреобразоватьТаблицуВHTMLText(тз,ТекстПисьма,ТЗИзменений,Коррекция);
