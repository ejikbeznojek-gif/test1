
Функция ОткорректироватьПроцентыВТаблице(Таблица) Экспорт
	
	Если Таблица.Количество() = 0 Тогда
		Возврат Таблица;
	КонецЕсли;
	
	ОбщийПроцент = Таблица.Итог("Процент");
	
	Если ОбщийПроцент = 100 Тогда
		Возврат Таблица;
	КонецЕсли;
	
	Разница = 100 - ОбщийПроцент;
	
	Если Разница <> 0 Тогда
	
		ПоследняяСтрока = Таблица.Получить(Таблица.Количество()-1);

		ПоследняяСтрока.Процент = ПоследняяСтрока.Процент + Разница;
	
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции