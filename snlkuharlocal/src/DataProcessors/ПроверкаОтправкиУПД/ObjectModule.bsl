Функция ВыбратьДокументыПР(СПК) Экспорт
	
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	СчетФактураВыданный.Номер КАК Номер,
	|	СчетФактураВыданный.Дата КАК Дата,
	|	СчетФактураВыданный.Контрагент КАК Контрагент,
	|	СчетФактураВыданный.Ссылка КАК Документ,
	|	СчетФактураВыданный.Всего КАК Сумма,
	|	СчетФактураВыданный.Контрагент.ДатаНачалаЭСФ КАК датаНачалаЭСФ,
	|	ЛОЖЬ КАК Пометка,
	|	ВЫБОР
	|		КОГДА ПОДСТРОКА(СчетФактураНакладные.Накладная.ПунктДоставки.ПечГрузополучательСФ, 1, 1) = """"
	|			ТОГДА СчетФактураНакладные.Накладная.ПунктДоставки.ПочтовыйАдрес
	|		ИНАЧЕ СчетФактураНакладные.Накладная.ПунктДоставки.ПечГрузополучательСФ
	|	КОНЕЦ КАК АдресДоставки,
	|	СчетФактураНакладные.Накладная.ПунктДоставки КАК СсылкаАдреса,
	|	СчетФактураНакладные.Накладная.ДатаПриемки КАК ДатаАвизации,
	|	СчетФактураНакладные.Накладная.Номер КАК НомерРНК
	|ИЗ
	|	Документ.СчетФактура.Накладные КАК СчетФактураНакладные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактура КАК СчетФактураВыданный
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				ЗначенияСвойствОбъектов.Объект.Номер КАК ОбъектНомер,
	|				ЗначенияСвойствОбъектов.Свойство КАК Свойство,
	|				ЗначенияСвойствОбъектов.Значение КАК Значение,
	|				ЗначенияСвойствОбъектов.Объект КАК Объект
	|			ИЗ
	|				РегистрСведений.ЗначенияСвойствОбъектовУПД КАК ЗначенияСвойствОбъектов
	|			ГДЕ
	|				ЗначенияСвойствОбъектов.Свойство = &ТекСвойство) КАК ВложенныйЗапрос
	|			ПО СчетФактураВыданный.Ссылка = ВложенныйЗапрос.Объект
	|		ПО СчетФактураНакладные.Ссылка = СчетФактураВыданный.Ссылка
	|ГДЕ
	|	СчетФактураНакладные.Накладная.Дата >= &ДатаНач
	|	И СчетФактураНакладные.Накладная.Дата <= &ДатаКон
	|	И СчетФактураВыданный.Проведен = ИСТИНА
	|	И ВложенныйЗапрос.Значение ЕСТЬ NULL
	|	И СчетФактураВыданный.ПометкаУдаления = ЛОЖЬ
	|	И СчетФактураНакладные.Накладная.Проведен
	|	И СчетФактураВыданный.Контрагент.ОтправлятьУПД = ИСТИНА
	|	И СчетФактураВыданный.Контрагент.ДатаНачалаЭСФ <= СчетФактураНакладные.Накладная.Дата
	|	И СчетФактураВыданный.Контрагент В ИЕРАРХИИ(&ТекКонтрагенты)
	|	И (ВЫРАЗИТЬ(СчетФактураВыданный.Номер КАК СТРОКА(3))) = &прОфиса
	|	и ( ДОБАВИТЬКДАТЕ(СчетФактураНакладные.Накладная.ДатаПриемки, ДЕНЬ, 3)< &датапроверки ) 
	|	и ( ДОБАВИТЬКДАТЕ(СчетФактураНакладные.Накладная.ДатаОтгрузки, ДЕНЬ, 3)< &датапроверки )
	|   И  НЕ СчетФактураНакладные.Накладная.ПунктДоставки В ИЕРАРХИИ(&ТекспПД)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Контрагент,
	|	Дата";
	
	
	// для дистрибьютеров на отдельной закладке надо сделать. 
	
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.АдресДоставкиКонтрагента);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("ТекКонтрагенты",СПК);
	ДатаНачалаЭСФ = Дата(2021,03,01);
	Запрос.УстановитьПараметр("ДатаНач",НачалоДня(ДатаНачалаЭСФ));
	Запрос.УстановитьПараметр("ДатаКон",КонецДня(КонецГода(ТекущаяДата())));
	ТекспПД = Новый Массив;
	ТекспПД.Добавить(справочники.ПунктыДоставки.НайтиПоКоду("SNL-015875"));
	ТекспПД.Добавить(справочники.ПунктыДоставки.НайтиПоКоду("SNL-015743"));
	ТекспПД.Добавить(справочники.ПунктыДоставки.НайтиПоКоду("SNL-019991"));
	
	Запрос.УстановитьПараметр("ТекспПД",ТекспПД);
	Запрос.УстановитьПараметр("ТекСвойство",планыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("EDIНомер").Ссылка);
	Запрос.УстановитьПараметр("профиса","SSо");
	
	ДатаПроверки = ТекущаяДата(); 
	Запрос.УстановитьПараметр("ДатаПроверки",НачалоДня(ДатаПроверки));
	
	
	Запрос.Текст = ТекстЗапроса;
	//сообщить(ТекстЗапроса);
	ТаблицаФактур2 = Запрос.Выполнить().Выгрузить();
	
	возврат таблицафактур2;
	
КонецФункции



Процедура Сформировать(ТаблицаПараметров=НЕОПРЕДЕЛЕНО) Экспорт
	
	//+++
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом тогда
	Если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда
		//Кухарь А.Ю. 31.03.2026 конец
       
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача проверка отправки УПД: Отправка писем. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
		Возврат;
	КонецЕсли;
	
	
	
	Ошибки.Очистить();
	
	
	Если ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
		
		Запрос = Новый запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА ВложенныйЗапрос.КодУзла <> """"
		|			ТОГДА ВложенныйЗапрос.КодУзла
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК кодУзла,
		|	ВЫБОР
		|		КОГДА ВложенныйЗапрос2.КодУзла <> """"
		|			ТОГДА ВложенныйЗапрос2.КодУзла
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК кодУзла2,
		|	ВЫБОР
		|		КОГДА ВложенныйЗапрос3.КодУзла <> """"
		|			ТОГДА ВложенныйЗапрос3.КодУзла
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК кодУзла3,
		|	ВЫБОР
		|		КОГДА ВложенныйЗапрос4.КодУзла <> """"
		|			ТОГДА ВложенныйЗапрос4.КодУзла
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК кодУзла4
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			КонтрагентыРегиональныеУзлы.КодУзла КАК КодУзла,
		|			1 КАК Поле1,
		|			КонтрагентыРегиональныеУзлы.Ссылка КАК Ссылка
		|		ИЗ
		|			Справочник.Контрагенты.РегиональныеУзлы КАК КонтрагентыРегиональныеУзлы) КАК ВложенныйЗапрос
