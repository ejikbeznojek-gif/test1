Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт  
	
	КаталогФайловОзон = "\\srvfile-sk\FBS";
	КаталогФайловОзонPNG = КаталогФайловОзон + "\OZON-PNG";
	КаталогФайловОзонZPL = КаталогФайловОзон + "\Ozon-ZPL-TXT";
	
	Контрагент = Справочники.Контрагенты.НайтиПоКоду("SSP-4991");
	
	НачалоЧасовНазад = 2;
	ОкончаниеЧасовНазад = 1;
	ВысотаКартинки = 311;
	Перезаписывать = Ложь;
	
	Если ТаблицаПараметров <> Неопределено Тогда 
		
		Для Каждого СтрокаТП Из ТаблицаПараметров Цикл 
			
			Если СтрокаТП.Имя = "НачалоЧасовНазад" Тогда			
				НачалоЧасовНазад = СтрокаТП.Значение;
			ИначеЕсли СтрокаТП.Имя = "ОкончаниеЧасовНазад" Тогда			
				ОкончаниеЧасовНазад = СтрокаТП.Значение;
			ИначеЕсли СтрокаТП.Имя = "ВысотаКартинки" Тогда
				Если ЗначениеЗаполнено(СтрокаТП.Значение) Тогда
					ВысотаКартинки = СтрокаТП.Значение;
				КонецЕсли;
			ИначеЕсли СтрокаТП.Имя = "Перезаписывать" Тогда			
				Перезаписывать = СтрокаТП.Значение;
			КонецЕсли;
			
		КонецЦикла;  

	КонецЕсли; 	

	ДатаНачала = ТекущаяДата() - НачалоЧасовНазад * 3600;
	ДатаОкончания = ДатаНачала + (НачалоЧасовНазад - ОкончаниеЧасовНазад) * 3600;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказКлиентаFBSТовары.Ссылка КАК Заказ,
	               |	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа
	               |ИЗ
	               |	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	               |ГДЕ
	               |	ЗаказКлиентаFBSТовары.Ссылка.Контрагент = &Контрагент
	               |	И ЗаказКлиентаFBSТовары.Ссылка.Проведен
	               |	И ЗаказКлиентаFBSТовары.Ссылка.Дата >= &ДатаНачала
	               |	И ЗаказКлиентаFBSТовары.Ссылка.Дата < &ДатаОкончания
	               |	И ЗаказКлиентаFBSТовары.НомерЗаказа <> """"
				   // Кельманов А.В. - Оптимизация работы - 2026.06.03 {
				   //|	И НЕ ЗаказКлиентаFBSТовары.Отменен
				   //|	И НЕ ЗаказКлиентаFBSТовары.ВычеркОфис
				   //|	И НЕ ЗаказКлиентаFBSТовары.ВычеркСклад
				   // Кельманов А.В. - Оптимизация работы - 2026.06.03 }
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ЗаказКлиентаFBSТовары.Ссылка.Дата,
	               |	ЗаказКлиентаFBSТовары.Ссылка,
	               |	ЗаказКлиентаFBSТовары.НомерСтроки";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ИмяФайлаTXT = КаталогФайловОзонZPL + "\" + Выборка.НомерЗаказа + ".txt";
		
		ФайлTXT = Новый Файл(ИмяФайлаTXT);
		
		Если Не ФайлTXT.Существует() Или Перезаписывать Тогда
			
			ИмяФайлаPNG = КаталогФайловОзонPNG + "\" + Выборка.НомерЗаказа + ".png";
			
			ФайлPNG = Новый Файл(ИмяФайлаPNG);
			
			Если ФайлPNG.Существует() Тогда
				
				Попытка
					
					ZPL = КартинкаВZPL(ИмяФайлаPNG, , ВысотаКартинки);
					
				Исключение
					
					ТекстОшибки = "Для номера заказа FBS " + Выборка.НомерЗаказа + " не удалось получить текст ZPL по файлу PNG: " + ОписаниеОшибки();
					
					ЗаписатьВЛог("Отладка", ТекстОшибки, "Информация");
				
					ZPL = Неопределено;
					
				КонецПопытки;
				
				Если ZPL <> Неопределено Тогда
					
					Текст = Новый ТекстовыйДокумент;
					Текст.ДобавитьСтроку(ZPL);
					Текст.Записать(ИмяФайлаTXT);
					
				КонецЕсли;
				
			КонецЕсли;
				
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

