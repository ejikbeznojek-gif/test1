#Область СобытияФормы


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	ОбновитьтаблицуЗаданий_НаСервере();
	
	АдресаРезультатов	= Новый СписокЗначений;
	Терминал1_ХТМЛ		= ПолучитьТестМакета("ХТМЛ_ОкноТерминала");
КонецПроцедуры

&НаСервере
Процедура ОбновитьтаблицуЗаданий_НаСервере()
	ОтборФЗ		= Новый Структура("Состояние,ИмяМетода",СостояниеФоновогоЗадания.Активно,"ФР_Регламент.Обмен_в_Фоне");
	СписокФЗ	= ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФЗ);
	
	Объект.ЗаданияОбмена.Очистить();
	
	Для Каждого ФЗ Из СписокФЗ Цикл		
		СтрокаФЗ	= Объект.ЗаданияОбмена.Добавить();		
		ЗаполнитьЗначенияСвойств(СтрокаФЗ,ФЗ);		
	КонецЦикла; 
	
	МЗ	= ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Состояние,ИмяМетода,Начало",СостояниеФоновогоЗадания.ЗавершеноАварийно,"Регламент.Обмен_в_Фоне",ТекущаяДата()-24*60*60));
	Для Каждого Задание Из МЗ Цикл
		СтрокаФЗ	= Объект.ЗаданияОбмена.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаФЗ,Задание,,"ИнформацияОбОшибке");	
		
		СтрокаФЗ.ИнформацияОбОшибке	=  
			Задание.ИнформацияОбОшибке.ИмяМодуля+"
			| "+Задание.ИнформацияОбОшибке.ИсходнаяСтрока+ "(Стр. "+Задание.ИнформацияОбОшибке.НомерСтроки+")
			| "+Задание.ИнформацияОбОшибке.Описание;
	КонецЦикла;
КонецПроцедуры //ЗаполнитьСтатусыЗаданий()

&НаКлиенте
Процедура ПриОткрытии(Отказ)	
КонецПроцедуры


#КонецОбласти 

&НаКлиенте
Процедура ЗапутитьОбменВФоне(Команда)
	ПараметрыКоманды	= ФР_ОбщегоНазначения_КС.СтрокуВСтруктуру(Команда.Имя,"Ч,Направление","_");
	
	ФР_Регламент.ЗапуститьФЗ_Обмена("ФР_ОбменСФРК",ПараметрыКоманды.Направление);
	
	ОбновитьтаблицуЗаданий_НаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьЗадания(Кнопка)	
	Если Элементы.ЗаданияОбмена.ВыделенныеСтроки.Количество()>0 Тогда
		Для Каждого ИД_Строки Из Элементы.ЗаданияОбмена.ВыделенныеСтроки Цикл
			СтрокаТЗ	= Объект.ЗаданияОбмена.НайтиПоИдентификатору(ИД_Строки);
			Результат	= ОстановитьФЗ_НаСервере(СтрокаТЗ.УникальныйИдентификатор);
		
			Если НЕ ПустаяСтрока(Результат) Тогда		
				ВывестиВТерминалНаКлиенте(СтрШаблон("Остановлено ФЗ: '%1'.",Результат),"DarkOrange","p");
			КонецЕсли;		
		КонецЦикла;
	
		ПодключитьОбработчикОжидания("ОбновитьТаблицуЗаданий",3,1);	
	Иначе
		ВывестиВТерминалНаКлиенте("Не выбрано ни одного задания для остановки.","red","H1");	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ОстановитьФЗ_НаСервере(ФЗ_УИД)
	Результат  = "";
	ФЗ	= ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ФЗ_УИД);
	Если ФЗ<>Неопределено И ФЗ.Состояние=СостояниеФоновогоЗадания.Активно Тогда
		ФЗ.Отменить();	
		
		Результат=СтрШаблон("%1 (%2)",ФЗ.Наименование,ФЗ.УникальныйИдентификатор);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции
 

&НаСервере
