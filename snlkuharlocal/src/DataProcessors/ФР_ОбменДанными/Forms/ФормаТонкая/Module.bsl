Функция ВывестиВТерминалНаКлиенте(Текст,Знач Цвет="black",Тэг="div")	
	Элементы.Терминал1_ХТМЛ.Документ.defaultView.write_mes(СтрШаблон("<%3 style='color: %2'>%1</%3>",Текст,Цвет,Тэг));	
КонецФункции //ВывестиВТерминал(Текст)

&НаСервере
Функция СоздатьСообщение(ТекстСообщения,Цвет,Ошибка)
	Возврат Новый Структура("ТекстСообщения,Цвет,Ошибка",ТекстСообщения,Цвет,Ошибка);	
КонецФункции // ()

&НаКлиенте
Процедура кнВыполнитьОбмен(Команда)
	ФД.Очистить();	
	Объект.ИД_Сеанса = Новый УникальныйИдентификатор;
	
	ВыполнитьОбменЧерезДлительнуюОперацию("ОбменСЕЕ","Прием,Отправка");
КонецПроцедуры

&НаСервере
Функция ПолучитьСостояниеФЗ()
	Результат = Новый Структура("Состояние","");	
	
	СписокФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("УникальныйИдентификатор",Новый УникальныйИдентификатор(ИД_ФЗ)));
	Для Каждого ФЗ Из СписокФЗ Цикл
		Результат = Новый Структура("Состояние",""+ФЗ.Состояние);	
		
		Результат.Вставить("Сообщения",ФЗ.ПолучитьСообщенияПользователю(Истина));
	КонецЦикла;	
	
	Возврат Результат;
КонецФункции // ()

&НаКлиенте
Функция ОО_СостояниеФЗ() Экспорт	
	Результат = ПолучитьСостояниеФЗ();
	Если Результат.Состояние="Задание выполняется" Тогда
		//Сообщить(Результат.Состояние);			
		
		Для Каждого Сообщение Из Результат.Сообщения Цикл
			ВывестиВТерминалНаКлиенте(Сообщение.Текст);		
		КонецЦикла; 
		
		ПодключитьОбработчикОжидания("ОО_СостояниеФЗ",1.1,Истина);
	КонецЕсли; 
	
КонецФункции // ()
 
&НаКлиенте
Процедура ВыполнитьОбменЧерезДлительнуюОперацию(ИмяПланаОбмена,Знач Направления)
	ПодключитьОбработчикОжидания("ЧтениеСообщений",1);
	
	Поз=СтрНайти(Направления,",");	
	Если Поз>0 Тогда
		Направление		= Лев(Направления,Поз-1);
		ДопНаправления	= Сред(Направления,Поз+1);
	Иначе
		Направление		= Направления;
		ДопНаправления	= "";		
	КонецЕсли;	
	
	ДлительнаяОперация = ВыполнитьОбмен_с_ЦБ_ФР_НаСервере(Направление);	
	
	Если ДлительнаяОперация<>Неопределено Тогда		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);    
		
		ПараметрыОжидания.ВыводитьПрогрессВыполнения	= Ложь;
		ПараметрыОжидания.ВыводитьОкноОжидания			= Ложь;
		// указываем интервал обновления состояния в секундах, если не указать, 
		// то интервал будет увеличиваться при каждой итерации в 1.4 раза.
		ПараметрыОжидания.Интервал = 1.1;
		
		ДопПараметрыОО	= Новый Структура("ИмяПланаОбмена,Направление,ДопНаправления",ИмяПланаОбмена,Направление,ДопНаправления);
		ОО				= Новый ОписаниеОповещения("ОбменВФоне_Выполнено", ЭтотОбъект,ДопПараметрыОО);
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация,ОО,ПараметрыОжидания);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ВыполнитьОбмен_с_ЦБ_ФР_НаСервере(Направление)	
	АдресРезультата	= ПоместитьВоВременноеХранилище(Неопределено,ЭтаФорма.УникальныйИдентификатор);	
	ИД_ФЗ			= ФР_Регламент.Выполнить_Обмен(ПланыОбмена.ФР_ОбменСФРК,Направление,1,ПолучитьПараметрыОбмена(АдресРезультата));	
	
	Возврат ДлительнаяОперация(ИД_ФЗ,АдресРезультата);
КонецФункции

&НаСервере
Функция ПолучитьПараметрыОбмена(АдресРезультата)
	Возврат Новый Структура("АдресРезультата,ИД_Сеанса,ВыводитьСообщения",АдресРезультата,Объект.ИД_Сеанса,Истина);
КонецФункции // ()

&НаСервере
Функция ДлительнаяОперация(ИД_ФЗ,АдресРезультата)
	ДанныеДО	= Новый Структура("
	|АдресДополнительногоРезультата,
	|АдресРезультата,
	|ИдентификаторЗадания,
	|КраткоеПредставлениеОшибки,
	|ПодробноеПредставлениеОшибки,
	|Сообщения,
	|Статус");
	
	ДанныеДО.АдресРезультата		= АдресРезультата;
	ДанныеДО.ИдентификаторЗадания   = Новый УникальныйИдентификатор(ИД_ФЗ);
	ДанныеДО.Статус					= ДлительныеОперации.ОперацияВыполнена(ИД_ФЗ).Статус;
	
	Возврат ДанныеДО;
КонецФункции // ()

&НаКлиенте
Процедура ЧтениеСообщений()	
	Если НЕ ПустаяСтрока(ИД_ФЗ) Тогда	
		Результат = ЧтениеСообщенийНаСервере();
		Для Каждого Сообщение Из Результат.Сообщения Цикл
			ВывестиВТерминалНаКлиенте(Сообщение.Текст);		
		КонецЦикла;
		
		Если Результат.ЗаданиеЗавершено  Тогда
			АдресРезультата	= АдресаРезультатов.НайтиПоЗначению(ИД_ФЗ);
			Если АдресРезультата<>Неопределено Тогда
				Результат	= ПолучитьИзВременногоХранилища(АдресРезультата);
				Если Результат<>Неопределено Тогда			
					Для Каждого ЭлементПакета Из Результат.Статистика Цикл
						Сообщить(ЭлементПакета);
					КонецЦикла;
				КонецЕсли;
			КонецЕсли; 
			ОтключитьОбработчикОжидания("ЧтениеСообщений");
		КонецЕсли;	
	Иначе
		ОтключитьОбработчикОжидания("ЧтениеСообщений");		
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция ЧтениеСообщенийНаСервере()	
	Результат	= Новый Структура("ЗаданиеЗавершено,Сообщения",Истина,Новый Массив);	
	Попытка
		ФЗ	= ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Новый УникальныйИдентификатор(ИД_ФЗ));
	Исключение
		ФЗ	= Неопределено;	
	КонецПопытки;	
	
	Если ФЗ<>Неопределено Тогда		
		Результат.Сообщения	= ФЗ.ПолучитьСообщенияПользователю(Истина);			
		
		Если ФЗ.Состояние=СостояниеФоновогоЗадания.Активно Тогда
			Результат.ЗаданиеЗавершено = Ложь;		
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ОбменВФоне_Выполнено(Результат,ДопПараметры) Экспорт	
	Если Результат=Неопределено Тогда Возврат КонецЕсли;
	
	Если НЕ Результат.Статус="Выполнено" Тогда
		ВывестиВТерминалНаКлиенте(Результат.КраткоеПредставлениеОшибки);	
	КонецЕсли;	
	
	ДопНаправления	= ФР_ОбщегоНазначения.ПолучитьЗначениеПараметра(ДопПараметры,"ДопНаправления","");
	Если НЕ ПустаяСтрока(ДопНаправления) Тогда		
		ВыполнитьОбменЧерезДлительнуюОперацию(ДопПараметры.ИмяПланаОбмена,ДопНаправления);	
	КонецЕсли;
	
	Если Результат.Статус="Выполнено" Тогда
		Данные	= ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если Данные<>Неопределено Тогда
			//Сообщить("ИД_Сеанса_: "+Данные.ИД_Сеанса);		
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

