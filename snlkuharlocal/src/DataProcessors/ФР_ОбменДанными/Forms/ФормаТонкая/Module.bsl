&НаКлиенте
Процедура ЗагрузитьДанные(Команда)
	ДД = Новый ДвоичныеДанные(Объект.ИмяФайлаОбмена);
	
	Результат = ЗагрузитьДанныеНаСервере(ПолучитьСтрокуИзДвоичныхДанных(ДД));		
КонецПроцедуры

&НаСервере
Функция ЗагрузитьДанныеНаСервере(СтрокаДанных)
	ОбработкаОбмена = Обработки.ВыгрузкаВоФранчБазу.Создать();			
	ОбработкаОбмена.ИмяФайлаОбмена = Объект.ИмяФайлаОбмена;
	
	ПротоколЗагрузки = ОбработкаОбмена.ЗагрузитьФайлХДТО(СтрокаДанных);
	ВывестиПротоколЗагрузки(ОбработкаОбмена,ПротоколЗагрузки);
	
	Возврат ПротоколЗагрузки;
КонецФункции

&НаСервере
Процедура ВывестиПротоколЗагрузки(ОбработкаОбмена,Протокол) Экспорт
	Если Протокол.Ошибки.Количество()=0 Тогда
		Сообщить("Загруженные объекты: ");
		Для Каждого Элемент Из ОбработкаОбмена.ОбъектыОбмена Цикл
			ОбъектСсылка=Неопределено;
			Если СтрНайти(Элемент.ОбъектТип,"РегистрСведений.")=0 Тогда			
				Менеджер 	= ОбработкаОбмена.ПолучитьМенеджерКласса(Элемент.ОбъектТип);
				Если Менеджер<>Неопределено Тогда				
					ОбъектСсылка= Менеджер.ПолучитьСсылку(Элемент.ОбъектСсылкаУИД);
				КонецЕсли;				
			КонецЕсли;			
			
			Если СтрНайти(Элемент.ОбъектТип,"РегистрСведений.")=1 Тогда
				Сообщить("	"+Элемент.ОбъектТип+", записей: "+Элемент.КоличествоЗаписей+" "+Элемент.ВариантВыгрузки);	
			Иначе
				Сообщить("	"+Элемент.ОбъектТип+" "+ОбъектСсылка+" ("+Элемент.ОбъектСсылкаУИД+")"+Элемент.ВариантВыгрузки);	
			КонецЕсли; 			
		КонецЦикла;
	Иначе
		ТекстОшибки=СтрСоединить(Протокол.Ошибки,Символы.ПС);
		Сообщить(ТекстОшибки,СтатусСообщения.Важное);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайла_ОбменаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ФР_РаботаСДиалогами.ЧудесатыйВыборФайла(ЭтаФорма, Элемент, "xml", "Файл xml (*.xml)|*.xml", РежимДиалогаВыбораФайла.Открытие);
КонецПроцедуры
