		ПунктДоставкиКод =  СтрокаТД.ЗаказСсылка.пунктДоставки.код;
		
		Если Рез.Следующий() ТОгда
			СтрЗнЗамены = рез;
			ВедущийКод = Рез.ВедущийКонтрагент_B2B;
			КонтрагентКод = РЕз.Контрагент_B2B;
