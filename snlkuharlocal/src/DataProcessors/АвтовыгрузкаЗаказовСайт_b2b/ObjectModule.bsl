Процедура ПунктДоставкиПриИзменении2(док) 
	
	//Док.ТипДоставки=Док.ПунктДоставки.ТипДоставки;
	ПунктДоставки = Док.ПунктДоставки;
	
	Если НЕ Док.ПунктДоставки.Пустая() Тогда
		
		
		НуженПересчетЦен=Ложь;
		
		Если ЗначениеЗаполнено(Док.ПунктДоставки.Договор)  Тогда
			Док.Договор=Док.ПунктДоставки.Договор;
			Договор_ПриИзменении2(Док);
		КонецЕсли;
		
		//доставка
		Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
			Док.РайонДоставки=ПунктДоставки.РайонДоставки;			
		КонецЕсли;	
		Если ЗначениеЗаполнено(ПунктДоставки.Регион) Тогда
			Док.Регион=ПунктДоставки.Регион;			
		КонецЕсли;	
		
		если ПунктДоставки.ТипДоставки=Перечисления.ТипыДоставки.ТранспортнаяКомпания тогда
			Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
				Док.ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
			иначе
				Док.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
				Док.ПунктПерегруза=ПунктДоставки.ПунктПерегруза;
			иначе
				Док.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
			КонецЕсли;	
		иначе
			Док.ТранспортнаяКомпания=Справочники.Контрагенты.ПустаяСсылка();	
			Док.ПунктПерегруза=Справочники.ПунктыДоставки.ПустаяСсылка();
		КонецЕсли;
		//Кухарь 26.01.16 конец
		
		Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
			Док.Грузополучатель=ПунктДоставки.Грузополучатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
			Док.Получатель=ПунктДоставки.Получатель;		
		КонецЕсли;
		Если ЗначениеЗаполнено(ПунктДоставки.ОтсрочкаПлатежа) Тогда
			Док.ОтсрочкаПлатежа=ПунктДоставки.ОтсрочкаПлатежа;		
		КонецЕсли;
		
		//типы цен скидки
		Если ЗначениеЗаполнено(ПунктДоставки.ТипЦен) И Док.ТипЦен<>ПунктДоставки.ТипЦен Тогда
			Док.ТипЦен=ПунктДоставки.ТипЦен;		
			НуженПересчетЦен=Истина;
		КонецЕсли; 
		Если ЗначениеЗаполнено(ПунктДоставки.ТипСкидок) И Док.ТипСкидок<>ПунктДоставки.ТипСкидок Тогда
			Док.ТипСкидок=ПунктДоставки.ТипСкидок;		
			НуженПересчетЦен=Истина;
		КонецЕсли;
		Если ПунктДоставки.Скидка<>0 И ПунктДоставки.Скидка<>Док.Скидка Тогда
			Док.Скидка=ПунктДоставки.Скидка;		
			НуженПересчетЦен=Истина;
		КонецЕсли;
		Если НуженПересчетЦен Тогда
			//ПересчетТЧ(Док,"Товары",Валюта,Валюта,Курс,Курс,Истина);			
		КонецЕсли;	
		
		//ставка НДС
		Если ПунктДоставки.НулеваяСтавкаНДС или Док.Контрагент.НулеваяСтавкаНДС Тогда
			Док.НулеваяСтавкаНДС = Истина;	
			НулеваяСтавкаНДСПриИзменении2(Док);
		ИначеЕсли Док.НулеваяСтавкаНДС Тогда
			Док.НулеваяСтавкаНДС = Ложь;
			НулеваяСтавкаНДСПриИзменении2(Док);
			
		КонецЕсли;
		
	КонецЕсли; 
	
	
	
	КодПоставщикаПунктаДоставки=ПунктДоставки.КодПоставщика;
	Если НЕ КодПоставщикаПунктаДоставки.Пустая() И Док.КодПоставщика<>КодПоставщикаПунктаДоставки Тогда
		Док.КодПоставщика=КодПоставщикаПунктаДоставки;
	КонецЕсли; 
	ВремяДоставки=ПолучитьВремяПриемки(док.ссылка);
	если ВремяДоставки=Справочники.ВремяПриемки.ПустаяСсылка() или ВремяДоставки=Неопределено тогда
		пВремяДоставки=ПунктДоставки.ВремяДоставки;
	иначе
		пВремяДоставки=ВремяДоставки;
	КонецЕсли;
	
	ДатаПриемки=ОпределитьДатуАвизацииДокумента(док.Ссылка);	
	КодПоставщикаПунктаДоставки=ПунктДоставки.КодПоставщика;
	Если НЕ КодПоставщикаПунктаДоставки.Пустая() И Док.КодПоставщика<>КодПоставщикаПунктаДоставки Тогда
		Док.КодПоставщика=КодПоставщикаПунктаДоставки;
	КонецЕсли; 
	
	
КонецПроцедуры


