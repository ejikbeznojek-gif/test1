				или СтрЧислоВхождений(ЗначениеСтатуса, "[D]")>0  или СтрЧислоВхождений(ЗначениеСтатуса, "[P]")>0
				Тогда
				Обновлять=Истина;
			КонецЕСли;
		КонецЕсли;
		
		// d B P только статусы меняем и все.
		//--------------------------------------------------------------------------------------------
		Если СтатусЗаказа = "D" и не НовыйДокумент Тогда
			попытка
				ДокРанееЗагр = ДокЗагруженныйОб;
				ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.ОтмененКонтрагент;
				ДокРанееЗагр.записать();
				
				СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
				НовыйДокумент = Ложь;
				
				Если ПризнакПроведения Тогда
					
					МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект.ссылка);
					
				КонецЕсли;	
				
				продолжить;
			исключение
				//нечаева 27,12,2023 ++
				записатьВЛОг("b2b"," ИдЗаказа -"+Док.ИдЗаказа+" - Статус на отменен контрагентом не изменен! "+ДокРанееЗагр.ссылка+" заказ не перезаписан!!"+ОписаниеОшибки(),,,);
				//нечаева 27,12,2023 --
				
			конецпопытки;
		КонецЕсли;	
		
		//*************************************************
