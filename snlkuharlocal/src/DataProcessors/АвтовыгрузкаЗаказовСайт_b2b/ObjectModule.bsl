Процедура НулеваяСтавкаНДСПриИзменении2(док)
	Для Каждого СтрокаТЧ Из док.Товары Цикл
		Если Док.НулеваяСтавкаНДС Тогда
			СтрокаТЧ.СтавкаНДС = Перечисления.СтавкиНДС.НДС0;
		Иначе
			СтрокаТЧ.СтавкаНДС = СтрокаТЧ.Номенклатура.Родитель.СтавкаНДС;			
		КонецЕсли;
		РассчитатьСуммуТабЧасти(СтрокаТЧ, Док,"ОтВсего");
	КонецЦикла;
