Функция ЗаписатьСвойство(ТекДокумент, ТзСтр)  Экспорт
	Если ТекДокумент = документы.Заказ.ПустаяСсылка() ТОгда
		возврат ложь;
	КонецЕсли;	
	
	Если ТЗСтр.Ведущий = "" или ТЗСтр.Ведущий = неопределено ТОгда
		возврат ложь;
	КонецЕсли;
	
	//ID документа
	НоваяЗапись = РегистрыСведений.РеквизитыB2BОбмена.СоздатьНаборЗаписей();
	Кб2б =Справочники.Контрагенты.НайтиПоКоду(ТзСтр.контрагент);
	ПДб2б =  Справочники.ПунктыДоставки.НайтиПоКоду(ТзСтр.пунктдоставки);
	Ведущий =  Справочники.контрагенты.НайтиПоКоду(ТзСтр.ведущий);
	
	НоваяЗапись.Отбор.Документ.Установить(ТекДокумент);
	НоваяЗапись.Прочитать();
	Если НоваяЗапись.Количество() = 0 Тогда
		НоваяЗаписьТек = НоваяЗапись.Добавить();
	Иначе
		НоваяЗаписьТек = НоваяЗапись[0];
	КонецЕсли;
	НоваяЗаписьТек.Документ   = ТекДокумент;
	НоваяЗаписьТек.ДатаЗаказа = ТекДокумент.ДатаЗаказа;
	НоваяЗаписьТек.ИдЗаказа   = ТекДокумент.ИдЗаказа;
	НоваяЗаписьТек.Контрагент_B2B = кб2б; 
	НоваяЗаписьТек.ПунктДоставки_B2B =  пдб2б;
	НоваяЗаписьТек.ВедущийКонтрагент_B2B = ведущий;
	НоваяЗаписьТек.КодКонтрагентаИзЗаказаб2б = ТзСтр.контрагент; 
	НоваяЗаписьТек.КодПунктаДоставкиИзЗаказаб2б = ТзСтр.ПунктДоставки;
	НоваяЗаписьТек.КодВедущегоб2б = ТзСтр.ведущий;

	попытка
		НоваяЗапись.Записать();
	исключение
		сообщить(ОписаниеОшибки());
	конецПопытки ;
	//ID документа
	
	возврат истина;
	
КонецФункции
