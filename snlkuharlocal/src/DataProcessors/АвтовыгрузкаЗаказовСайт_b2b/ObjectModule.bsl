Процедура ОтсрочкаПлатежаПриИзменении(Док)

	Если   Не ЗначениеЗаполнено(Док.ДатаОтгрузки) Тогда
		Док.ДатаОплаты  =  Дата(1,1,1); 
	Иначе
		Если  Док.ОтсрочкаПлатежа.ВидОтсрочки = Перечисления.ВидыОтсрочки.БанковскиеДни Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	КалендарьДни.Дата КАК Дата
			|ИЗ
			|	Справочник.Календарь.Дни КАК КалендарьДни
			|ГДЕ
			|	КалендарьДни.Дата >= &ДатаОтгрузки
			|	И КалендарьДни.Часы <> 0
			|	И (НЕ КалендарьДни.Ссылка.ПометкаУдаления)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Дата
			|АВТОУПОРЯДОЧИВАНИЕ";
			Запрос.УстановитьПараметр("ДатаОтгрузки",Док.ДатаОтгрузки);
			Выборка = Запрос.Выполнить().Выбрать();
			НПП = 0;
			Пока Выборка.Следующий() Цикл
				
				Если НПП = Док.ОтсрочкаПлатежа.Отсрочка Тогда
					Док.ДатаОплаты = Выборка.Дата;
					Прервать; 
				Конецесли;
				НПП = НПП + 1;
			КонецЦикла;
			
			Док.ДатаОплаты =  Док.ДатаОтгрузки + Док.ОтсрочкаПлатежа.Отсрочка*24*60*60;		
		Иначе		
			Док.ДатаОплаты = Док.ДатаОтгрузки + Док.ОтсрочкаПлатежа.Отсрочка*24*60*60;
		КонецЕсли;
	КонецЕсли;
	


КонецПроцедуры

