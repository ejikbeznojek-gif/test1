Функция ПроверитьРанееСформированноеПисьмоПоТеме(ТемаПисьма,Основание, ИнтервалОтправки)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПисьмаНаОтправку.ДатаСозданияПисьма) КАК ДатаСозданияПисьма
		|ИЗ
		|	РегистрСведений.ПисьмаНаОтправку КАК ПисьмаНаОтправку
		|ГДЕ
		|	ПисьмаНаОтправку.ТемаПисьма ПОДОБНО &ТемаПисьма
		|	И ПисьмаНаОтправку.Основание = &Основание";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	Запрос.УстановитьПараметр("ТемаПисьма", ТемаПисьма);
	
	РезультатЗапроса = Запрос.Выполнить(); 
	
	Если РезультатЗапроса.Пустой() Тогда
	
		Возврат ложь; 	
	
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
	
		Если ВыборкаДетальныеЗаписи.ДатаСозданияПисьма + ИнтервалОтправки > ТекущаяДатаСеанса() Тогда
		
			Возврат истина; 	
		
		КонецЕсли;		
		 
	КонецЕсли;
	
	Возврат ложь;

КонецФункции // ПроверитьРанееСформированноеПисьмоПоТеме()

