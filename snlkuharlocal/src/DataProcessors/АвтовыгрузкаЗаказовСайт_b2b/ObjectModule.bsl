	ДобавитьУзелCML(СписокЗначенийCML, "Наименование"	   , ФорматНаименованияДляCML(Товар.Ссылка.Наименование));
	
	//ЭлементТов=ДокументДом.СоздатьЭлемент("БазоваяЕдиница");
