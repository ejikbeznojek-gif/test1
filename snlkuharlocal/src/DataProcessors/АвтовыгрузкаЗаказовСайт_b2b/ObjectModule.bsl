процедура   ВыгрузитьТоварыУслугиЗаказаВCML(ОбъектCML, Док)
	
	// выгрузка товаров для заказа --------------------------------------------------------------	
	ОбъектCML.ЗаписатьНачалоЭлемента("Товары");
	СохрНомерСтроки = 0;
	
	ТЧТовары = док.заказссылка.товары;  // было - количество бралось, а нам нужны исходные данные  Док.товары
	
	Для каждого выборка из  ТЧТовары Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.Номенклатура) Тогда 
			Продолжить;
		КонецЕсли;
		
		//Не выгружаем дубли строки, которые возникают если один товар имеет более одного штрихкода
		Если СохрНомерСтроки = Выборка.НомерСтроки Тогда
			Продолжить;
		Иначе
			СохрНомерСтроки = Выборка.НомерСтроки;
		КонецЕсли;
		
		ОбъектCML.ЗаписатьНачалоЭлемента("Товар");
		
		ВыгрузитьОсновныеРеквизитыТовара(ОбъектCML, Выборка, ""+Выборка.Номенклатура.Родитель.код+"#"+""+Выборка.Номенклатура.код);
		
		
		ВыгрузитьБазовыеРеквизитыТабличнойЧастиТоваров(ОбъектCML, Выборка, "b2b");
		
		//Выгрузка информации по налогам
		//ВыгрузитьИнформациюОНалогахДляВыборки(ОбъектCML, Выборка);
		
		//ВыгрузитьИнформациюОСерийномНомере(ОбъектXML, Выборка);
		
		ОбъектCML.ЗаписатьКонецЭлемента();
		
		
	КонецЦикла;
	
	ОбъектCML.ЗаписатьКонецЭлемента();
	
	
	
	
конецПроцедуры


// Процедура пищет в XML-файл обязательные для товара реквизиты
// если передан пустой идентификатор, то он формируется по умолчанию
//
// Параметры:
//  ОбъектXML - объект типа ЗаписьXML
//  Товар     - структура, содержащая реквизиты товара
//  Ид        - строка идентификатор товара
//
Процедура ВыгрузитьОсновныеРеквизитыТовара(ОбъектXML, Товар, Ид = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(Ид) Тогда
		ИдТовара = СформироватьИдентификатовТовара(Товар.НоменклатураСсылка, Товар.ХарактеристикаСсылка);
		ЗаписатьТекстовойУзел(ОбъектXML, "Ид", ИдТовара);
	Иначе
		ЗаписатьТекстовойУзел(ОбъектXML, "Ид", Ид);		
	КонецЕсли;
	
	//++-++
	// выводить штрих код товара
	
	ШтрихКод="";
	//-------------------
	Попытка
		
		ТипШк = Перечисления.ТипыШтрихКодов.Штука;
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	ШтрихКоды.Владелец КАК Номенклатура,
		|	ШтрихКоды.Наименование КАК номер,
		|	ШтрихКоды.Код
		|ИЗ
		|	Справочник.ШтрихКоды КАК ШтрихКоды
		|ГДЕ
		|	ШтрихКоды.ТипШК = &ТипШК
		|	И ШтрихКоды.Владелец = &ТекНом
		|	И ШтрихКоды.ВидШК = &Основной";
		
		Запрос.УстановитьПараметр("ТекНом",Товар.НоменклатураСсылка); 
		Запрос.УстановитьПараметр("ТипШК",ТипШк);
		Запрос.УстановитьПараметр("Основной",Перечисления.ВидыШК.Основной);
		
		Выборка1 = запрос.Выполнить().Выбрать();
		
		Пока выборка1.Следующий() Цикл
			ШтрихКод=выборка1.Номер; //ШКО+"@"
		КонецЦикла;	
		
	Исключение
	КонецПопытки;
	
	Тов5=Товар.Номенклатура;
	
	ЗаписатьТекстовойУзел(ОбъектXML, "Штрихкод",    ШтрихКод);
	//ЗаписатьТекстовойУзел(ОбъектXML, "Артикул",      Товар.Артикул);
	ЗаписатьТекстовойУзел(ОбъектXML, "Артикул",    Строка(Тов5.Родитель.КодПроизводителя));
	
	ВыгрузитьНаименованиеНоменклатуры(ОбъектXML, Тов5);
	
	ВыгрузитьИнформациюОЕдиницеИзмерения(ОбъектXML, Тов5);
	
	//ВыгрузитьИдентификаторГруппыДляТовара(ОбъектXML, Товар);
	
	// выгрузить информацию по ставке налога
	ВыгрузитьИнформациюОСтавкеНалога(ОбъектXML, Тов5);
	
	ВыгрузитьДопИнформациюОНоменклатуре(ОбъектXML, Тов5);	
	
	
КонецПроцедуры

