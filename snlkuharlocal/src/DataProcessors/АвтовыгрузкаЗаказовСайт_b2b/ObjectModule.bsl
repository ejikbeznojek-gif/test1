			// нечаева 18,01,23 --- - для закрытого периода не перезаписываем
			СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
			
			Если ПризнакПроведения Тогда
				
				МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект.ссылка);
				
			КонецЕсли;	
			
			продолжить;
			
