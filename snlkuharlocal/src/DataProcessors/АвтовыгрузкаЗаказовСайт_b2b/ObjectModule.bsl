	//		ЭлементТов.УстановитьАтрибут("НаименованиеПолное","Штука");
	//		текстДом=ДокументДом.СоздатьТекстовыйУзел("Штука");
	//		ТекУзелТов.ДобавитьДочерний(ТекстДом);
	
	
	ДобавитьНачалоЭлементаCML(СписокЗначенийCML, "БазоваяЕдиница");	
	
