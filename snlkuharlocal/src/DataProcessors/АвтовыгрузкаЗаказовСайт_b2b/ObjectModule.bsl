		ЗначениеСтатуса=Неопределено;
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			ЗначениеСтатуса = НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		
		//--------------------------------------------------------------------------
		// нечаева 23,05,23+++
		НайденнаяСтрока = ТаблицаСтрок.Найти("Дата доставки", "СвойствоНаименование");
		ДатаОтгрузки = Дата(1,1,1);
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			ДатаОтгрузки = СокрЛП(НайденнаяСтрока.СвойствоЗначение);  //  "23.05.2022"
			ДатаОтгрузки = Дата(ДатаОтгрузки + " 00:00:00"); //НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		// нечаева 23,05,23 ---
		
		
		//--------------------------------------------------------------------------
		// "Комментарии покупателя"
		КомментарииПокупателя = "";
		НайденнаяСтрока = ТаблицаСтрок.Найти("Комментарии покупателя", "СвойствоНаименование");
		
