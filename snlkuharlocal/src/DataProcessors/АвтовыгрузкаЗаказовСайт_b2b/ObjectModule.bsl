Процедура СформироватьДопФайл(Док,ЗаписьXML)
	
	
	//	сообщить(ИмяФайлаОбмена);
	
	
	//ЗаписьXML=Новый ЗаписьXML;
	//ЗаписьXML.ОткрытьФайл(ИмяФайлаОбмена);   //(Путь+Имя+".xml");
