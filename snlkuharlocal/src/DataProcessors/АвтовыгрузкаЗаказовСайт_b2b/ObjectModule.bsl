			Если ДокРанееЗагр.Дата <= ДатаЗапрета Тогда
				записатьВЛОг("b2b","дата заказа < даты запрета редактирования "+ДокРанееЗагр.ссылка+" заказ не перезаписан!!",,,);
				//нечаева 27,01,2023++
				МассивН = Новый Массив;
