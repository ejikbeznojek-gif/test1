		Иначе
			КомментарииПокупателя = СокрЛП(НайденнаяСтрока.СвойствоЗначение);
		КонецЕсли;
		Если новыйДокумент Тогда
			Док.ДокументОбъект.комментарий = КомментарииПокупателя;
			// для подстраховки еще раз пропишем
			Док.ДокументОбъект.ИдЗаказа = Док.ИдЗаказа;
