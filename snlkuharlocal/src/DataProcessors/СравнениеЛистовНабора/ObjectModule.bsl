// Кухарь А.Ю. 07.04.2020 начало
// Скорректируем ЗНБ
Функция ЗаполнитьЗНБ(ТЗВычерков)
	
	// Кухарь А.Ю. 26.01.2021 начало
	СписокЗНБ=новый СписокЗначений; 
	// Кухарь А.Ю. 26.01.2021 конец
	
	ТЗВычерков.колонки.добавить("КоличествоШтуки");
	// Кухарь А.Ю.  06.08.2022 начало
	// Оптимизация
	МассивНоменклатуры=ТЗВычерков.выгрузитьколонку("Номенклатура"); 
	Запрос=новый Запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	Номенклатура.Родитель.ШтукВКоробке КАК ШтукВКоробке
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&МассивНоменклатуры)";
	запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);
	ТЗШтукВКоробек=запрос.Выполнить().Выгрузить();
	// Кухарь А.Ю.  06.08.2022 конец
	
	для каждого СтрТЗ из ТЗВычерков цикл
		
		// Кухарь А.Ю.  06.08.2022 начало
		//КоличествоВКоробе=СтрТЗ.Номенклатура.родитель.ШтукВКоробке;
		КоличествоВКоробе=ТЗШтукВКоробек.Найти(СтрТЗ.Номенклатура,"Номенклатура").ШтукВКоробке; 
		// Кухарь А.Ю.  06.08.2022 конец
		
		если КоличествоВКоробе=0 тогда
			СтрТЗ.КоличествоШтуки=СтрТЗ.количество;
		иначе
			СтрТЗ.КоличествоШтуки=стртз.количество - цел(СтрТЗ.количество/КоличествоВКоробе);
		КонецЕсли;
	КонецЦикла;
	
	Запрос=новый запрос;
	запрос.Текст= "ВЫБРАТЬ
	|	ЗаданиеНабораТовары.Номенклатура КАК Номенклатура,
	|	ЗаданиеНабораТовары.Ссылка КАК ЗНБ
	|ИЗ
	|	Документ.ЗаданиеНабора.Товары КАК ЗаданиеНабораТовары
	|ГДЕ
	|	ЗаданиеНабораТовары.Ссылка.Дата >= &Дата
	|	И ЗаданиеНабораТовары.Ссылка.Проведен
	|	И ЗаданиеНабораТовары.Ссылка.Накладная = &Накладная
	|	И ЗаданиеНабораТовары.Номенклатура В(&СписокНоменклатуры)
	// Кухарь А.Ю.  06.08.2022 начало
	//	              |	И ЗаданиеНабораТовары.Количество > 0
	// Кухарь А.Ю.  06.08.2022 конец
	
	
	|ИТОГИ ПО
	|	ЗНБ,
	|	Номенклатура";
	запрос.УстановитьПараметр("Дата",Документ.Дата-30*24*3600);
	запрос.УстановитьПараметр("Накладная",Документ);
	
	// Кухарь А.Ю.  06.08.2022 начало
	// 	запрос.УстановитьПараметр("СписокНоменклатуры",ТЗВычерков.выгрузитьколонку("Номенклатура"));
	запрос.УстановитьПараметр("СписокНоменклатуры",МассивНоменклатуры);	 
	// Кухарь А.Ю.  06.08.2022 конец
	
	ВыборкаЗНБ=запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ЗНБ");
	если ВыборкаЗНБ.Количество()=0 тогда
		возврат Истина;
	КонецЕсли;
	НачатьТранзакцию();
	
	пока ВыборкаЗНБ.Следующий() цикл
		ЗНБ=ВыборкаЗНБ.ЗНБ.получитьобъект();
		этоблочки= ЗНБ.этоблочки;
		если ложь тогда ЗНБ=документы.ЗаданиеНабора.ПустаяСсылка().ПолучитьОбъект();КонецЕсли;
		ВыборкаНоменклатура=ВыборкаЗНБ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");
		пока ВыборкаНоменклатура.Следующий() цикл
			Номенклатура=ВыборкаНоменклатура.Номенклатура;
			СтрТЗ=ТЗВычерков.найти(Номенклатура);
			если  этоблочки тогда  //Сортировка выборки такова, что сначала вычёркивают ЗНБ с этоблочки, потом коробные
				если СтрТЗ.КоличествоШтуки<>0 тогда
					СтрТЧ=ЗНБ.Товары.Найти(Номенклатура);
					Если СтрТЧ.Количество>=-СтрТЗ.КоличествоШтуки тогда
						СтрТЧ.Количество=СтрТЧ.Количество+СтрТЗ.КоличествоШтуки;  //Строка из ЗНБ
						СтрТЗ.Количество=СтрТЗ.Количество-СтрТЗ.КоличествоШтуки;  //Строка из ТЗ
						
						СтрТЗ.КоличествоШтуки=0;
						
					Иначе    //По идее такого не дольжно быть, это значит что в ЗНБ со штуками товара меньше чем пытаются вычеркнуть щтук
						Дельта=СтрТЧ.Количество+СтрТЗ.КоличествоШтуки;
						СтрТЧ.Количество=0;
						СтрТЗ.Количество =СтрТЗ.Количество-СтрТЗ.КоличествоШтуки+Дельта;
						СтрТЗ.КоличествоШтуки=Дельта;
					КонецЕсли;
				КонецЕсли;
			иначе
				если СтрТЗ.Количество<>0 тогда //Могло уже всё выбраться в ЗНБ со штуками
					СтрТЧ=ЗНБ.Товары.Найти(Номенклатура);
					Если СтрТЧ.Количество>=-СтрТЗ.Количество тогда
						СтрТЧ.Количество=СтрТЧ.Количество+СтрТЗ.Количество; //Строка из ЗНБ
						СтрТЗ.Количество=0; 								//Строка из ТЗ
					Иначе    //По идее такого не дольжно быть, это значит что в ЗНБ со штуками товара меньше чем пытаются вычеркнуть щтук
						Дельта=СтрТЧ.Количество+СтрТЗ.Количество;
						СтрТЧ.Количество=0;
						СтрТЗ.Количество=Дельта;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		если ЗНБ.Модифицированность() тогда
			знб.Записать(РежимЗаписиДокумента.Проведение);
			// Кухарь А.Ю. 26.01.2021 начало
			//
			если СписокЗНБ.НайтиПоЗначению(ЗНБ) = Неопределено тогда
				СписокЗНБ.Добавить(знб.Ссылка);
			КонецЕсли;
			// Кухарь А.Ю. 26.01.2021 конец
			
		КонецЕсли;	
	КонецЦикла;
	
	
	
	если ТЗВычерков.найтистроки(Новый Структура("Количество",0)).количество()<>ТЗВычерков.количество() тогда
		ОтменитьТранзакцию();
		Возврат ложь;     //Если что-то не так, то все ЗНБ возвращаем как было
	КонецЕсли;
	ЗафиксироватьТранзакцию();
	возврат Истина;
	
КонецФункции
