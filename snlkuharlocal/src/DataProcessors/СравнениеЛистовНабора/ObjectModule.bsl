Функция ВывестиРезультатСравнения() Экспорт
	ТД=Новый ТабличныйДокумент;
	

// Кухарь А.Ю.  14.11.2022 начало
//
МаксУровень=0; 
// Кухарь А.Ю.  14.11.2022 конец
	
	
	//крохин начало 21.09.2018
	//номера паллет
	Если фВыводитьЛН И фВыводитьПаллеты Тогда
		ЗапросПаллеты = Новый Запрос;	
		ЗапросПаллеты.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПаллетаЛистыНабора.Ссылка.Номер КАК НомерПаллеты,
		|	ПаллетаЛистыНабора.ЛистНабора.Номер КАК НомерЛН
		|ИЗ
		|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
		|ГДЕ
		|	ПаллетаЛистыНабора.ЛистНабора.ДокОснование = &ДокОснование
		| И ПаллетаЛистыНабора.Ссылка.Проведен
		|	И ПаллетаЛистыНабора.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2";
		ЗапросПаллеты.УстановитьПараметр("ДокОснование",Документ);				
		ЗапросПаллеты.УстановитьПараметр("Дата1",Документ.Дата - 30*24*60*60);
		ЗапросПаллеты.УстановитьПараметр("Дата2",Документ.Дата + 30*24*60*60);
		ТаблицаПаллет = ЗапросПаллеты.Выполнить().Выгрузить();
		
	КонецЕсли;
	//крохин конец 21.09.2018
	
	Макет=ПолучитьМакет("СравнениеЛН");
	
	ОблЗаголовок=Макет.ПолучитьОбласть("Заголовок|Начало");
	
	ОблЗаголовок.Параметры.Док=Документ;
	ОблЗаголовок.Параметры.Заполнить(Документ);
	
	ТД.Вывести(ОблЗаголовок);
	//крохин начало 21.09.2018
	//номера паллет
	//ТД.Вывести(Макет.ПолучитьОбласть("Шапка|Начало"));
	Если фВыводитьЛН И фВыводитьПаллеты Тогда
		
		ТД.Вывести(Макет.ПолучитьОбласть("ШапкаПаллеты|Начало"))
	Иначе
		ТД.Вывести(Макет.ПолучитьОбласть("Шапка|Начало"));	
	КонецЕсли;
	//крохин конец 21.09.2018
	
	ТД.НачатьАвтогруппировкуКолонок();
	
	ВыборкаПоЛН=РезультатСравнения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЛН");
	Пока ВыборкаПоЛН.Следующий() Цикл
		Если ВыборкаПоЛН.НомерЛН="НАКЛ" Тогда Продолжить КонецЕсли;
		
		
		//крохин начало 21.09.2018
		//номера паллет
		//ОблЛН=Макет.ПолучитьОбласть("Шапка|НомерЛН");
		//ОблЛН.Параметры.НомерЛН=СтрЗаменить(ВыборкаПоЛН.НомерЛН,СокрЛП(Документ.Номер)+"/","");
		Если фВыводитьЛН И фВыводитьПаллеты Тогда
			ОблЛН=Макет.ПолучитьОбласть("ШапкаПаллеты|НомерЛН"); 
			//++Данилова Е.В. 27.02.2026 SNL-150
			ОблЛН.Параметры.ЛН = ?(СравнениеЛП,"ЛП","ЛН"); 
			//--Данилова Е.В. 27.02.2026 
			ОблЛН.Параметры.НомерЛН=СтрЗаменить(ВыборкаПоЛН.НомерЛН,СокрЛП(Документ.Номер)+"/","");	
			ОтборПаллеты = Новый Структура();
			ОтборПаллеты.Вставить("НомерЛН",ВыборкаПоЛН.НомерЛН);
			НайденныеСтроки = ТаблицаПаллет.НайтиСтроки(ОтборПаллеты);
			СписокПаллет = "";
			Для Каждого НайденнаяСтроки Из НайденныеСтроки Цикл
				СписокПаллет = 	СписокПаллет + НайденнаяСтроки.НомерПаллеты + ",";
			КонецЦикла;
			Если ПустаяСтрока(СписокПаллет) Тогда
				СписокПаллет = "без паллет";
			Иначе
				СписокПаллет = Лев(СписокПаллет,СтрДлина(СписокПаллет) - 1);
			КонецЕсли;
			ОблЛН.Параметры.СписокПаллет = СписокПаллет;
			//++Данилова Е.В. 27.02.2026 SNL-150
			ТД.Присоединить(ОблЛН,1);
			//Иначе
		ИначеЕсли  фВыводитьЛН Тогда  		
			//--Данилова Е.В. 27.02.2026 
			ОблЛН=Макет.ПолучитьОбласть("Шапка|НомерЛН");
			//++Данилова Е.В. 27.02.2026 SNL-150
			ОблЛН.Параметры.ЛН = ?(СравнениеЛП,"ЛП","ЛН"); 
			//--Данилова Е.В. 27.02.2026
			ОблЛН.Параметры.НомерЛН=СтрЗаменить(ВыборкаПоЛН.НомерЛН,СокрЛП(Документ.Номер)+"/",""); 
			//++Данилова Е.В. 27.02.2026 SNL-150
			ТД.Присоединить(ОблЛН,1);
			//--Данилова Е.В. 27.02.2026
		КонецЕсли;
		//крохин конец 21.09.2018
		//ТД.Присоединить(ОблЛН,1);	
	КонецЦикла; 
	
	ТД.Присоединить(Макет.ПолучитьОбласть("Шапка|Разница"));	
	
	ТД.ФиксацияСверху=ТД.ВысотаТаблицы;
	
	ТД.НачатьАвтогруппировкуСтрок();	
	
	ЕстьОшибки=Ложь;
	
	ВыборкаПоНоменклатуре=РезультатСравнения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");
	Всего=ВыборкаПоНоменклатуре.Количество();
	
	Пока ВыборкаПоНоменклатуре.Следующий() Цикл
		
		// Кельманов А.В. - SNL-119 - 2026.03.19 {
		//ОбработкаПрерыванияПользователя();
		//
		//Состояние(Всего);
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();
			
			Состояние(Всего);
		#КонецЕсли
		// Кельманов А.В. - SNL-119 - 2026.03.19 }
		
		Всего=Всего-1;
		
		ОблСтрока=Макет.ПолучитьОбласть("Строка|Начало");
		
		ОблСтрока.Параметры.Заполнить(ВыборкаПоНоменклатуре);
		Если НЕ ВыборкаПоНоменклатуре.ЭтоГруппа Тогда		
			ОблСтрока.Параметры.Код77=ВыборкаПоНоменклатуре.Код77;
		ИначеЕсли фТолькоОшибки Тогда
			Продолжить;			
		КонецЕсли; 
		Если ВыборкаПоНоменклатуре.Разница=0 И фТолькоОшибки Тогда Продолжить КонецЕсли; 
		
		
		ТД.Вывести(ОблСтрока,ВыборкаПоНоменклатуре.Уровень(),,Ложь);
		// Кухарь А.Ю.  14.11.2022 начало
		//
		МаксУровень=Макс(МаксУровень,ВыборкаПоНоменклатуре.Уровень()); 
		// Кухарь А.Ю.  14.11.2022 конец
				 
		Если фВыводитьЛН Тогда
			ВыборкаПоЛН=ВыборкаПоНоменклатуре.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЛН","Все");
			Пока ВыборкаПоЛН.Следующий() Цикл
				Если ВыборкаПоЛН.НомерЛН="НАКЛ" Тогда Продолжить КонецЕсли;
				
				ОблЛН=Макет.ПолучитьОбласть("Строка|НомерЛН");
				ОблЛН.Параметры.Заполнить(ВыборкаПоЛН);
				
				ТД.Присоединить(ОблЛН);		
			КонецЦикла;			
		КонецЕсли;		
		
		ОблКонец=Макет.ПолучитьОбласть("Строка|Разница");
		ОблКонец.Параметры.Заполнить(ВыборкаПоНоменклатуре);
		
		ТД.Присоединить(ОблКонец,0);
		
		ТекОбласть=ТД.Область(ТД.ВысотаТаблицы,2,ТД.ВысотаТаблицы,ТД.ШиринаТаблицы);
		
		Если ВыборкаПоНоменклатуре.ЭтоГруппа Тогда
			ТекОбласть.Шрифт=Новый Шрифт(,,Истина);	
		КонецЕсли; 
		
		Если ВыборкаПоНоменклатуре.Разница>0 Тогда
			ЕстьОшибки=Истина;
			ТекОбласть.ЦветФона=Новый Цвет(255,255,0);		
		ИначеЕсли ВыборкаПоНоменклатуре.Разница<0 Тогда
			ЕстьОшибки=Истина;
			ТекОбласть.ЦветФона=Новый Цвет(255,150,150);
		КонецЕсли;		
	КонецЦикла; 
	
	ТД.ЗакончитьАвтогруппировкуСтрок();
	
	ТД.ЗакончитьАвтогруппировкуКолонок();
	
	
	ОблИтогоНачало	=Макет.ПолучитьОбласть("Итого|Начало");
	ОблИтогоРазница	=Макет.ПолучитьОбласть("Итого|Разница");
	
	Выборка=РезультатСравнения.Выбрать();
	Если Выборка.Следующий() Тогда
		ОблИтогоНачало.Параметры.Заполнить(Выборка);
		ОблИтогоРазница.Параметры.Заполнить(Выборка);		
	КонецЕсли; 
	ТД.Вывести(ОблИтогоНачало);
	//++Данилова Е.В. 27.02.2026 SNL-150
	если фВыводитьЛН Тогда
		ВыборкаПоЛН=РезультатСравнения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"НомерЛН");
		Пока ВыборкаПоЛН.Следующий() Цикл
			Если ВыборкаПоЛН.НомерЛН="НАКЛ" Тогда Продолжить КонецЕсли;
			
			ОблЛН=Макет.ПолучитьОбласть("Итого|НомерЛН");
			ОблЛН.Параметры.Заполнить(ВыборкаПоЛН);
			ТД.Присоединить(ОблЛН);	
		КонецЦикла;
	КонецЕсли;
	//--Данилова Е.В. 27.02.2026
	ТД.Присоединить(ОблИтогоРазница);
	
	ТД.ОтображатьЗаголовки	=Ложь;
	ТД.ОтображатьСетку		=Ложь;
	
	
	ТД.ИмяПараметровПечати			="ОпцииПечати_СравнениеЛистовНабора";	
	ТД.ИмяСохраненияПоложенияОкна   ="РазмерОкна_СравнениеЛистовНабора";
	
	
	Обл=ТД.Область(6,2,6,2);
	Если ЕстьОшибки Тогда
		Обл.Текст="ЕСТЬ ОШИБКИ НАБОРА";	
		Обл.ЦветТекста=Новый Цвет(255,0,0);		
	Иначе
		Обл.Текст="НЕТ ОШИБОК";			
	КонецЕсли; 
	
	
	// Кельманов А.В. - SNL-119 - 2026.03.19 {
	//УстановитьКолонтитулы(ТД);	
	#Если Клиент Тогда
		УстановитьКолонтитулы(ТД);	
	#КонецЕсли
	// Кельманов А.В. - SNL-119 - 2026.03.19 }
	
	//ТД.Показать("Сравнение набора: "+Документ);
	
	// Кухарь А.Ю.  14.11.2022 начало
	//
	ТД.ПоказатьУровеньГруппировокСтрок(МаксУровень); 
	// Кухарь А.Ю.  14.11.2022 конец
	
	
	
	Возврат ТД;	
КонецФункции

Функция ПолучитьОбъемКоробов()
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	СУММА(ОбъемКоробов) КАК ОбъемКоробов,	
	|	СУММА(КоличествоКоробок) КАК КоличествоКоробок
	|ИЗ
	|	Документ.ЛистНабора
	|ГДЕ
	|	ДокОснование= &Ссылка
	|	И Проведен";
	
	Запрос.УстановитьПараметр("Ссылка",Документ);	
	//++Данилова Е.В. 26.02.2026 SNL-150  
	если СравнениеЛП Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ.ЛистПереукладки"); 
	КонецЕсли;
	//--Данилова Е.В. 26.02.2026 
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда		
		Результат=Новый Структура("ОбъемКоробов,КоличествоКоробок",Выборка.ОбъемКоробов,Выборка.КоличествоКоробок);
	Иначе
		Результат=Новый Структура("ОбъемКоробов,КоличествоКоробок",0,0);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьОбъемКоробов() 

Функция ПолучитьОшибкиНабора() Экспорт
	Ошибки=Ложь;
	
	ТП=Новый ТаблицаЗначений;
	ТП.Колонки.Добавить("Номенклатура");
	ТП.Колонки.Добавить("КолВНакл");
	ТП.Колонки.Добавить("КолВЛН");
	ТП.Колонки.Добавить("Разница");
	
	ТН=ТП.Скопировать();
	
	Если РезультатСравнения=Неопределено Тогда ПолучитьРезультатСравнения() КонецЕсли; 	
	Если РезультатСравнения=Неопределено Тогда Возврат Новый Структура("Ошибки,ТП,ТН",Истина,ТП,ТН) КонецЕсли; // видимо не указан докмент или какая ошибка		
	
	ВыборкаПоНоменклатуре=РезультатСравнения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Номенклатура");
	Пока ВыборкаПоНоменклатуре.Следующий() Цикл
		Если ВыборкаПоНоменклатуре.ТипЗаписи()=ТипЗаписиЗапроса.ИтогПоГруппировке Тогда
			Если ВыборкаПоНоменклатуре.Разница<0 Тогда //Перебор
				СтрокаТО=ТП.Добавить();
			ИначеЕсли ВыборкаПоНоменклатуре.Разница>0 Тогда //Недобор
				СтрокаТО=ТН.Добавить();
			Иначе //усе в порядке
				Продолжить;			
			КонецЕсли;		
			
			ЗаполнитьЗначенияСвойств(СтрокаТО,ВыборкаПоНоменклатуре);
			Ошибки=Истина;
		КонецЕсли;		
	КонецЦикла;
	
	ТП.Сортировать("Номенклатура");
	ТН.Сортировать("Номенклатура");
	
	ОбъемКоробов=ПолучитьОбъемКоробов();
	
	Возврат Новый Структура("Ошибки,ТП,ТН,ОбъемКоробов,КоличествоКоробок",Ошибки,ТП,ТН,ОбъемКоробов.ОбъемКоробов,ОбъемКоробов.КоличествоКоробок);
КонецФункции // ПолучитьОшибкиНабора()

Процедура ВывестиТаблицуОшибок(ТО,ВидТО) Экспорт
	ТД		=Новый ТабличныйДокумент;
	
	Макет	=ПолучитьМакет("ТаблицаОшибок");	
	
	ОблЗаголовок=Макет.ПолучитьОбласть("Заголовок");
	ОблЗаголовок.Параметры.Документ	=Документ;
	ОблЗаголовок.Параметры.ВидТО	=ВидТО;
	
	ТД.Вывести(ОблЗаголовок);
	
	ОблШапка	=Макет.ПолучитьОбласть("Шапка");	
	ТД.Вывести(ОблШапка);
	
	Для Каждого СтрокаТО Из ТО Цикл
		ОблСтрока=Макет.ПолучитьОбласть("Строка");
		ОблСтрока.Параметры.Заполнить(СтрокаТО);	
		
		ТД.Вывести(ОблСтрока);
	КонецЦикла; 
	
	// Кельманов А.В. - SNL-119 - 2026.03.19 {
	//УстановитьКолонтитулы(ТД);	
	#Если Клиент Тогда
		УстановитьКолонтитулы(ТД);	
	#КонецЕсли
	// Кельманов А.В. - SNL-119 - 2026.03.19 }
	
	ТД.ИмяПараметровПечати			="ПараметрыПечати_ТаблицаОшибокНабора";
	ТД.ИмяСохраненияПоложенияОкна   ="ПоложениеОкна_ТаблицаОшибокНабора";
	ТД.ОтображатьСетку		=Ложь;
	ТД.ОтображатьЗаголовки	=Ложь;
	
	ТД.Показать("Перебор по накладной: "+Документ);
КонецПроцедуры


//кухарь 17.03.15 начало
Процедура ЗаполнитьПланыНабора (Накладная)
	запрос=новый Запрос;
	//++Данилова Е.В. 26.02.2026 SNL-150
	//запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	//|	ЛистНабора.Ссылка как ЛН
	//|ИЗ
	//|	Документ.ЛистНабора КАК ЛистНабора
	//|ГДЕ
	//|	ЛистНабора.Проведен
	//|	И ЛистНабора.ДокОснование = &ДокОснование
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	ЛистНабора.Дата УБЫВ";
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЛистНабораДок.Ссылка КАК ЛН
	|ИЗ
	|	Документ.ЛистНабора КАК ЛистНабораДок
	|ГДЕ
	|	ЛистНабораДок.Проведен
	|	И ЛистНабораДок.ДокОснование = &ДокОснование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЛистНабораДок.Дата УБЫВ";
	//--Данилова Е.В. 26.02.2026 
	запрос.УстановитьПараметр("ДокОснование",Накладная.ссылка); 
	//++Данилова Е.В. 26.02.2026 SNL-150  
	если СравнениеЛП Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ.ЛистПереукладки"); 
	КонецЕсли;
	//--Данилова Е.В. 26.02.2026
	Результат=запрос.Выполнить().Выбрать();
	пока Результат.Следующий() цикл
		ЛН=Результат.ЛН.получитьобъект();
		ЛН.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
КонецПроцедуры


