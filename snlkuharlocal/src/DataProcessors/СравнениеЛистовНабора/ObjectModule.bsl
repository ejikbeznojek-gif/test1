   // Оптимизация
   запрос.УстановитьПараметр("ДатаЛиста",ПолучитьРеквизитШапки(Документ,"Дата","Документ")-60*24*3600);
   если  УчитыватьТребующиеПроверкиЛН тогда
	   запрос.Текст = СтрЗаменить(запрос.Текст,"И не Ссылка.ТребуетПроверки","");
   КонецЕсли;
   // Кухарь А.Ю.  04.03.2026 конец
   
