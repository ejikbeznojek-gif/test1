//Планы набора меняем тоже
Процедура ПроверитьОшибкиПоПланамНабораИИсправить(ДокОснование )
	
	
	ПланНабора=Неопределено;
	Разбивали=ложь;
	НужноЗаписатьПланНабора=ложь;
	Запрос=Новый запрос;
	запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПланНабора.Ссылка как ПланНабора
	|ИЗ
	|	Документ.ПланНабора КАК ПланНабора
	|ГДЕ
	|	ПланНабора.ДокОснование = &ДокОснование
	|	И ПланНабора.Проведен";
	запрос.УстановитьПараметр("ДокОснование",ДокОснование.Ссылка);
	результат=запрос.Выполнить().Выбрать();
	пока результат.Следующий() цикл
		ПланНабора=результат.ПланНабора.получитьобъект();
		
		если ложь тогда
			ПланНабора=Документы.ПланНабора.НайтиПоНомеру("").ПолучитьОбъект();
		КонецЕсли;
		
		Для каждого СтрТЧ из ПланНабора.тБрэндов цикл
			СтрТЧ.Состояние=ДокОснование.состояниенакладной;
			СтрТЧ.СканировкаЗакончена=Истина;
			если СтрТЧ.ОкончаниеСканировки=ПустаяДата() тогда
				СтрТЧ.ОкончаниеСканировки=ТекущаяДата();
			КонецЕсли;
			
		КонецЦикла;
		
		ПланНабора.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
	
	
	
	
	
	
КонецПроцедуры
