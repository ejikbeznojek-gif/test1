Функция ПолучитьОшибкиНабораПоЛистамОбщий() Экспорт
	Ошибки=Ложь; 
	перебор = ложь; 
	Недостача = Ложь; 
	Результат = ПолучитьРезультатСравненияОптим(); 
	Выборка = Результат.Выбрать(); 
	Пока Выборка.Следующий() Цикл
	
	
		Недостача = Выборка.Разница > 0; 
		перебор   = Выборка.Разница < 0;
		
		Ошибки = Недостача Или Перебор; 
	КонецЦикла;
		
	ОбъемКоробов=ПолучитьОбъемКоробов();
	
	Возврат Новый Структура("Ошибки,Перебор,Недостача,ОбъемКоробов,КоличествоКоробок",Ошибки,перебор,Недостача,ОбъемКоробов.ОбъемКоробов,ОбъемКоробов.КоличествоКоробок);
КонецФункции // ПолучитьОшибкиНабора()

Функция ПолучитьРезультатСравненияОптим() Экспорт
	 
	ВидДокумента=Документ.Метаданные().Имя;
	
	ИмяРеквизитаКоличество	="Количество";
	ИмяТЧ					="Товары";
	
	Если ВидДокумента="Перемещение" Тогда
		Если Документ.СкладПолучатель.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда			
		ИначеЕсли Документ.Склад.КодФизическогоУзла=ПараметрыСеанса.ЭтотУзел.Код Тогда			
			ИмяРеквизитаКоличество="ПодтвержденнаяЗаявка"; //Отгружено
		КонецЕсли;		
	ИначеЕсли ВидДокумента="Инвентаризация" Тогда
		ИмяРеквизитаКоличество="КоличествоФакт";		
	ИначеЕсли ВидДокумента="Комплектация" Тогда
		если документ.ЭтоРаскомплектация и документ.ЭтоВозвратИМ тогда
			ИмяТЧ="Товары";
		иначе
			ИмяТЧ="Комплектующие";
		КонецЕсли;	 
	ИначеЕсли ВидДокумента = "РасходнаяНакладная" Тогда
		
		// Кельманов А.В. - SNL-119 - 2026.03.24 {
		//Если Документ.ОтгрузкаКомплектов Тогда   		
		ИспользоватьЛНТолькоДляНабора = ИспользоватьЛНТолькоДляНабора(Документ);
		
		ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(Документ);
		
		Если Документ.ОтгрузкаКомплектов И Не (СравнениеЛП И ИспользоватьЛНТолькоДляНабора И ДопПараметрыНакладной.ОтгрузкаFBS = Истина) Тогда   		
		// Кельманов А.В. - SNL-119 - 2026.03.24 }				
			
			ИмяТЧ = "Комплектующие";
			
		КонецЕсли;
		
	КонецЕсли;
	
	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	СУММА("+ИмяРеквизитаКоличество+") КАК КолВНакл
	|ПОМЕСТИТЬ ВТНакладная
	|ИЗ
	|	Документ."+ВидДокумента+"."+ИмяТЧ+" КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|	И "+ИмяРеквизитаКоличество+" <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЛистНабораДок.КоличествоДокумента) КАК КолЛН
	|ПОМЕСТИТЬ ВТЛН
	|ИЗ
	|	Документ.ЛистНабора КАК ЛистНабораДок
	|ГДЕ
	|	ВЫРАЗИТЬ(ЛистНабораДок.Ссылка.ДокОснование КАК Документ."+Документ.Метаданные().Имя+").Ссылка = &Ссылка
	|	И ЛистНабораДок.Ссылка.Проведен
	|	И НЕ ЛистНабораДок.Ссылка.ТребуетПроверки
	|	И ЛистНабораДок.Ссылка <> &ИсключаемыйЛН
	|	И ЛистНабораДок.Завершен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сумма(ЕСТЬNULL(ВТНакладная.КолВНакл,0)) - Сумма(ЕСТЬNULL(ВТЛН.КолЛН, 0)) КАК Разница
	|ИЗ
	|	ВТНакладная КАК ВТНакладная
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТЛН КАК ВТЛН
	|		ПО (ИСТИНА)"; 
	
	
//	Запрос=Новый Запрос;
//	Запрос.Текст="
//	|ВЫБРАТЬ	
////	|	ПРЕДСТАВЛЕНИЕ(Номенклатура) КАК НоменклатураПредставление,
//	|	Номенклатура,
//	|	Номенклатура.Код77 КАК Код77,
//	|	Номенклатура.ЭтоГруппа КАК ЭтоГруппа,
//	|	НомерЛН,
//	|	СУММА(КолВНакл) КАК КолВНакл,	
//	|	СУММА(КолВЛН) КАК КолВЛН,
//	|	СУММА(КолВНакл)-СУММА(КолВЛН) КАК Разница,	
//	|	ВЫБОР 
//	|		КОГДА СУММА(КолВНакл)>СУММА(КолВЛН) ТОГДА СУММА(КолВНакл)-СУММА(КолВЛН)
//	|		ИНАЧЕ СУММА(КолВЛН)-СУММА(КолВНакл)
//	|	КОНЕЦ
//	|	КАК МодульРазницы
//	|ИЗ
//	|(
//	|ВЫБРАТЬ
//	|	Номенклатура,
//	|	""НАКЛ"" КАК НомерЛН,
//	|	"+ИмяРеквизитаКоличество+" КАК КолВНакл,
//	|	0 КАК КолВЛН
//	|ИЗ
//	|	Документ."+ВидДокумента+"."+ИмяТЧ+" КАК Товары
//	|ГДЕ
//	|	Товары.Ссылка = &Ссылка	
//	|	И "+ИмяРеквизитаКоличество+" <> 0
//	|ОБЪЕДИНИТЬ ВСЕ
//	|ВЫБРАТЬ
//	|	Номенклатура,
//	|	Ссылка.Номер КАК НомерЛН,
//	|	0 КАК КолВНакл,
//	//++Данилова Е.В. 26.02.2026 SNL-150 
//	//|	Количество КАК КолВЛН
//	|	%Количество% КАК КолВЛН
//	//--Данилова Е.В. 26.02.2026 
//	|ИЗ
//	|	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
//	|ГДЕ
//	|	ВЫРАЗИТЬ(Ссылка.ДокОснование КАК Документ."+Документ.Метаданные().Имя+").Ссылка= &Ссылка
//	|	И Ссылка.Проведен
//	// Кухарь А.Ю.  06.08.2022 начало
//	|	И не Ссылка.ТребуетПроверки
//	// Кухарь А.Ю.  06.08.2022 конец
//	
//	|	И Ссылка<>&ИсключаемыйЛН
//	|) КАК Сводный
//	|СГРУППИРОВАТЬ ПО Номенклатура,НомерЛН	
//	|ИТОГИ 
//	|	СУММА(КолВНакл),СУММА(КолВЛН),СУММА(Разница),СУММА(МодульРазницы) 
//	|ПО ОБЩИЕ,Номенклатура ИЕРАРХИЯ,НомерЛН"; 
	// Кухарь А.Ю.  23.10.2025 начало  
	//Help-7574	
	//|АВТОУПОРЯДОЧИВАНИЕ";
	// Кухарь А.Ю.  23.10.2025 конец

	Запрос.УстановитьПараметр("ИсключаемыйЛН",	ИсключаемыйЛН);
	Запрос.УстановитьПараметр("Ссылка",			Документ); 
	
	Если СравнениеЛП Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ.ЛистПереукладки");
		//	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Количество%","Отсканировано");
		//Иначе 
		//	Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Количество%","Количество");
	КонецЕсли;
	//--Данилова Е.В. 26.02.2026 
	Результат=Запрос.Выполнить();
	
	Возврат результат; 
КонецФункции


//--Данилова Е.В. 27.02.2026 
