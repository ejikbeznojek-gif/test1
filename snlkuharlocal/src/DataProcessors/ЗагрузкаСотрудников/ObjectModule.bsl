Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	
	ЗаписатьВЛог("Загрузка сотрудников","Начало. Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера(),"Информация");
	
	ЕЕ="EE";
	ЕС="ES";
	Организация = Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00849");
	Уволенные = Справочники.ФизическиеЛица.НайтиПоКоду("SNL-00918");
//	ЗаписатьВЛог("Загрузка сотрудников",Логин,"Информация");
Если ПустаяСтрока(Логин) Тогда
		// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
		//Логин = "*%*%*%";
		//Пароль = "*$*$*$";
		Логин = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
			Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКЗУП_ЕЕ).Логин;
		Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
			Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКЗУП_ЕЕ).Пароль;
		// Ихсанов Д. А. Конец  14.10.2025
	КонецЕсли;
//	ЗаписатьВЛог("Загрузка сотрудников",Логин,"Информация");
//крохин начало 25.03.2022
	//СтрокаСоединения = "Srvr=""srvbuh"";Ref=""ZUP_EE"";";
	СтрокаСоединения = "Srvr=""SRV1C"";Ref=""ZUP_EE"";";
//крохин конец 25.03.2022	
	           
	Попытка	
		//крохин начало 02.05.2017
		//теперь 8.3
		//Соединение = Новый COMОбъект("V82.COMConnector");
		Соединение = Новый COMОбъект("V83.COMConnector");
		//крохин конец 02.05.2017
		База_Ист = Соединение.Connect(СтрокаСоединения + "Usr=""" + Логин + """;Pwd=""" + Пароль + """;");
	Исключение                 
		//крохин начало 26.09.2013
		ЗаписатьВЛог("Загрузка сотрудников","Ошибка установки соединения с 8.* ! " + ОписаниеОшибки(),"Информация");
		#Если Клиент Тогда
			Сообщить("Ошибка установки соединения с 8.* ! " + ОписаниеОшибки(), СтатусСообщения.Важное);
		#КонецЕсли
		//крохин конец 26.09.2013
		Возврат;
		
	КонецПопытки;
	
	// получаем данные из 8.2
	Запрос_Ист = База_Ист.NewObject("Запрос");
	Запрос_Ист.Текст = 
	"ВЫБРАТЬ
	|	МАКСИМУМ(Ссылка) КАК Ссылка
	|ПОМЕСТИТЬ ВТ_РаботающиеСотрудники
	|ИЗ
	|	Справочник.СотрудникиОрганизаций
	|ГДЕ
	|	ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровСФизЛицами.ТрудовойДоговор)
	|	И ДатаПриемаНаРаботу <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) 
	|	И (ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	ИЛИ началоПериода(ДатаУвольнения,день) > &Текдата)
	|	И (НЕ ПометкаУдаления)
	|	И (НЕ ЭтоГруппа)
	|
	|СГРУППИРОВАТЬ ПО
	|	Физлицо
	|	
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СотрудникиОрганизаций.Физлицо.Код КАК Код,
    |	СотрудникиОрганизаций.Код КАК КодЗуп,
	|	СотрудникиОрганизаций.ТекущееПодразделениеОрганизации.Код КАК КодПодр,	
	|	СотрудникиОрганизаций.Физлицо.Наименование КАК Наименование,
	|	СотрудникиОрганизаций.ТекущееПодразделениеОрганизации.Наименование КАК Подразделение,
	|	СотрудникиОрганизаций.ТекущаяДолжностьОрганизации.Наименование КАК Должность,
	|	СотрудникиОрганизаций.ДатаУвольнения как ДатаУвольнения
	|ИЗ
	|	ВТ_РаботающиеСотрудники КАК ВТ_РаботающиеСотрудники
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СотрудникиОрганизаций КАК СотрудникиОрганизаций
	|		ПО ВТ_РаботающиеСотрудники.Ссылка = СотрудникиОрганизаций.Ссылка";
	
	
	Запрос_Ист.установитьПараметр("Текдата",НачалоДня(текущаяДата()));
	Выборка_Ист = Запрос_Ист.Выполнить().Выбрать();
	
	
	Табл = Новый ТаблицаЗначений;
	Табл.Колонки.Добавить("Код");
	Табл.Колонки.Добавить("КодПодр");
	Табл.Колонки.Добавить("Наименование");
	Табл.Колонки.Добавить("Подразделение");
	Табл.Колонки.Добавить("Тип");
	Табл.Колонки.Добавить("Должность");
	Табл.Колонки.Добавить("ДатаУвольнения");
	Табл.Колонки.Добавить("ТабЗуп");

	Пока Выборка_Ист.Следующий() Цикл
		
		//Если Выборка_Ист.ДатаУвольнения>ТекущаяДата() тогда
		//	продолжить;
		//КонецЕсли;	
			
		НоваяСтрока = Табл.Добавить();
		НоваяСтрока.Код				= ЕЕ + СокрЛП(Выборка_Ист.Код);
		НоваяСтрока.КодПодр			= ЕС + СокрЛП(Выборка_Ист.КодПодр);
		НоваяСтрока.Наименование	= СокрЛП(Выборка_Ист.Наименование);
		НоваяСтрока.Подразделение	= СокрЛП(Выборка_Ист.Подразделение);
		НоваяСтрока.Тип				= "элемент";
		НоваяСтрока.Должность		= СокрЛП(Выборка_Ист.Должность);
		НоваяСтрока.ДатаУвольнения	= СокрЛП(Выборка_Ист.ДатаУвольнения);
		//нечаева 22,09,22+++
		НоваяСтрока.ТабЗуп	= СокрЛП(Выборка_Ист.кодЗуп);
		//нечаева 22,09,22---
	КонецЦикла;
	
	База_Ист = Неопределено;
	
	Если Табл.Количество() = 0 Тогда
		#Если Клиент Тогда
			Сообщить("Ошибка получения данных из Базы 8.2.");
		#КонецЕсли
		Возврат;
	КонецЕсли;
	ЗаписатьВЛог("Загрузка сотрудников", "загружена информация из 8.2", "Информация");
	
	// загружаем в нашу базу.
	ЗагрузитьФЛ(Табл);
	

	#Если Клиент Тогда
		Сообщить("Данные загружены!");
	#КонецЕсли
	ЗаписатьВЛог("Загрузка сотрудников","Окончание","Информация");
КонецПроцедуры


Процедура ЗагрузитьФЛ(ТЗ) 
	
	СписокПринятыхСотрудников = Новый СписокЗначений;
	СписокУволенныхСотрудников = Новый СписокЗначений;
	СписокКривыхСотрудников = Новый СписокЗначений;
	СписокУзловПолучателей=Новый Массив;
	КБСТИЛЬ = Справочники.Подразделения.НайтиПоКоду("SSP-0013");
	
	ВыборкаУзловОбмена=ПланыОбмена.Основной.Выбрать();
	Пока ВыборкаУзловОбмена.Следующий() Цикл
		Если ВыборкаУзловОбмена.Ссылка <> ПараметрыСеанса.ЭтотУзел Тогда
			СписокУзловПолучателей.Добавить(ВыборкаУзловОбмена.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	СЗ = Новый СписокЗначений;
	Сч = 1;
	Для каждого ТекСтрока Из ТЗ Цикл
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();
			состояние(ТекСтрока.Наименование);
		#КонецЕсли
		
		СтрокаКода = ТекСтрока.Код;
		СтрокаКодаГруппы = ТекСтрока.КодПодр;
		СтрокаКодаПодразделения = Прав(СтрокаКодаГруппы,СтрДлина(СтрокаКодаГруппы)-2);  //-2
		ФизЛица = Справочники.ФизическиеЛица;
		НайденнаяСсылка = ФизЛица.НайтиПоРеквизиту("ТабельныйНомер",СтрокаКода);
		Если НайденнаяСсылка = ФизЛица.ПустаяСсылка() Тогда
			
			Группа = ФизЛица.НайтиПоРеквизиту("ТабельныйНомер",СтрокаКодаГруппы);
			
			Если Группа.ЭтоГруппа Тогда
				// 
				
				ФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
				ФизЛицо.Наименование = ТекСтрока.Наименование;
				ФизЛицо.ТабельныйНомер = ТекСтрока.Код;
				
				ФизЛицо.Родитель = Группа;
				//
			иначе
				Группа = Справочники.ФизическиеЛица.СоздатьГруппу();
				Группа.Наименование = ТекСтрока.Подразделение;
				Группа.ТабельныйНомер = ТекСтрока.КодПодр;
				Группа.Записать();
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей,Группа);
				
				Группа = ФизЛица.НайтиПоРеквизиту("ТабельныйНомер",СтрокаКодаГруппы);
				//
				ФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
				ФизЛицо.Наименование = ТекСтрока.Наименование;
				ФизЛицо.ТабельныйНомер = ТекСтрока.код;
				// нечаева 22,09,22+++
				ФизЛицо.ТабельныйНомерСотрудникаЗУП = ТекСтрока.ТабЗуп;
				// нечаева 22,09,22--
				ФизЛицо.Родитель = Группа;
				//
			КонецЕсли; 
			//подр новый
			Если СокрЛП(Организация.код) = "SNL-00756" Тогда  // кб стиль
				Если ФизЛицо.Подразделение <> КБСТИЛЬ Тогда
					ФизЛицо.Подразделение = КБСТИЛЬ;
				КонецЕсли;
				
			иначе
				Подразделение = Справочники.Подразделения.НайтиПоКоду(СтрокаКодаПодразделения);
				
				Если ПустаяСтрока(Подразделение) Тогда
					#Если Клиент Тогда
						сообщить("Нет подразделения по сотруднику "+ФизЛицо.Наименование+". Код:"+СтрокаКодаГруппы);
					#КонецЕсли
				иначе
					Если ФизЛицо.Подразделение <> Подразделение Тогда
						ФизЛицо.Подразделение = Подразделение;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			//должность
			Должность = Справочники.Должности.НайтиПоНаименованию(ТекСтрока.Должность,Истина);
			Если Должность = Справочники.Должности.ПустаяСсылка() Тогда
				Должность = Справочники.Должности.СоздатьЭлемент();
				Должность.Наименование = ТекСтрока.должность;
				Должность.Записать();
				Должность = Должность.Ссылка;
			КонецЕсли;
			Если ФизЛицо.Должность <> Должность Тогда
				ФизЛицо.Должность = Должность;
			КонецЕсли;
			
			Если не ФизЛицо.Штатный Тогда
				ФизЛицо.Штатный = Истина;
			КонецЕсли;
			Если ФизЛицо.Модифицированность() Тогда
				
				ФизЛицо.Записать();
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей,ФизЛицо);
				СписокПринятыхСотрудников.Добавить(ФизЛицо);
			КонецЕсли;
			
			СтрокаСЗ = ФизЛицо.Ссылка;
			
			СЗ.Добавить(СтрокаСЗ,СтрокаСЗ,Истина);
			#Если Клиент Тогда
				Сообщить(строка(ФизЛицо) + " // " + строка(ФизЛицо.Родитель) + " принят");
			#КонецЕсли
		Иначе
			Группа = ФизЛица.НайтиПоРеквизиту("ТабельныйНомер",СтрокаКодаГруппы);
			
			Если Группа.ЭтоГруппа Тогда
				ФизЛицо = НайденнаяСсылка.ПолучитьОбъект();
				Если ФизЛицо.Родитель <> Группа Тогда
					ФизЛицо.Родитель = Группа; 
				КонецЕсли;
			Иначе
				Группа = Справочники.ФизическиеЛица.СоздатьГруппу();
				Группа.Наименование = ТекСтрока.Подразделение;
				Группа.ТабельныйНомер = ТекСтрока.КодПодр;
				
				Группа.Записать();
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей,Группа);
				Группа = ФизЛица.НайтиПоРеквизиту("ТабельныйНомер",СтрокаКодаГруппы);
				ФизЛицо = НайденнаяСсылка.ПолучитьОбъект();
				
				ФизЛицо.Родитель = Группа;
			КонецЕсли;
			
			Если СокрЛП(Организация.код) = "SNL-00756" Тогда  // кб стиль
				Если ФизЛицо.Подразделение <> КБСТИЛЬ Тогда
					ФизЛицо.Подразделение = КБСТИЛЬ;
				КонецЕсли;
			иначе
				Подразделение = Справочники.Подразделения.НайтиПоКоду(СтрокаКодаПодразделения);
				Если ПустаяСтрока(Подразделение) Тогда
					#Если Клиент Тогда
						сообщить("Нет подразделения по сотруднику "+ФизЛицо.Наименование+". Код:"+СтрокаКодаГруппы);
					#КонецЕсли
					СписокКривыхСотрудников.Добавить(ФизЛицо);
				иначе
					Если ФизЛицо.Подразделение <> Подразделение Тогда
						ФизЛицо.Подразделение = Подразделение;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			//должность
			Должность = Справочники.Должности.НайтиПоНаименованию(ТекСтрока.Должность,Истина);
			Если Должность = Справочники.Должности.ПустаяСсылка() Тогда
				Должность = Справочники.Должности.СоздатьЭлемент();
				Должность.Наименование = ТекСтрока.должность;
				Должность.Записать();
				Должность = Должность.Ссылка;
			КонецЕсли;
			Если ФизЛицо.Должность <> Должность Тогда
				ФизЛицо.Должность = Должность;
			КонецЕсли;
			
			Если НЕ ФизЛицо.Штатный Тогда
				ФизЛицо.Штатный = Истина;
			КонецЕсли;
			СтрокаСЗ = ФизЛицо.Ссылка;
			СЗ.Добавить(СтрокаСЗ,СтрокаСЗ,Истина);
			Если ФизЛицо.Наименование <> ТекСтрока.Наименование Тогда
				ФизЛицо.Наименование = ТекСтрока.Наименование;
			КонецЕсли;
			
			// нечаева 22,09,22+++
			Если ФизЛицо.ТабельныйНомерСотрудникаЗУП <> ТекСтрока.ТабЗуп Тогда
				ФизЛицо.ТабельныйНомерСотрудникаЗУП = ТекСтрока.ТабЗуп;
			КонецЕсли;
			// нечаева 22,09,22--
			
			Если ФизЛицо.Модифицированность() Тогда
				ФизЛицо.Записать();
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей,ФизЛицо);
				СписокПринятыхСотрудников.Добавить(ФизЛицо);
			КонецЕсли;
			//Сообщить(ФизЛицо);
			
		КонецЕсли;
		
		Сч = Сч + 1;
	КонецЦикла;
	#Если Клиент Тогда
		сообщить("Загрузка списка сотрудников завершена.");
	#КонецЕсли
	
	//----------------------------------------------
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ФизическиеЛица.Ссылка  КАК ФизЛицо
	|ИЗ
	|	Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|	ФизическиеЛица.ЭтоГруппа = Ложь
	//    |	И ФизическиеЛица.Штатный = Истина
	|	И ФизическиеЛица.Ссылка В ИЕРАРХИИ(&Организация)";
	Запрос.УстановитьПараметр("Организация",Организация);
	выборка = Запрос.Выполнить().Выбрать();
	пока выборка.Следующий() Цикл
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();
		#КонецЕсли
		Если СЗ.НайтиПоЗначению(выборка.ФизЛицо) = Неопределено Тогда
			
			ФизЛицо = выборка.ФизЛицо.ПолучитьОбъект();
			Если ФизЛицо.штатный Тогда
				ФизЛицо.Штатный = Ложь;
			КонецЕсли;
			#Если Клиент Тогда
				сообщить(строка(ФизЛицо) + " // " + строка(ФизЛицо.Родитель) + " уволен");
			#КонецЕсли
			Если ФизЛицо.Родитель <> Уволенные Тогда
				ФизЛицо.Родитель = Уволенные;
				ФизЛицо.Должность = Справочники.Должности.ПустаяСсылка();
			КонецЕсли;
			Если ФизЛицо.Модифицированность() Тогда
				
				ФизЛицо.Записать();
				ПланыОбмена.ЗарегистрироватьИзменения(СписокУзловПолучателей,ФизЛицо);
				СписокУволенныхСотрудников.Добавить(ФизЛицо);
			КонецЕсли;	
		Иначе
			
			ФизЛицо = выборка.ФизЛицо.ПолучитьОбъект(); 
			
			Если ПустаяСтрока(ФизЛицо.ШтрихКод) И  ФизЛицо.Штатный Тогда
				
				ФизЛицо.ШтрихКод = ПолучитьШКФизЛица();
				#Если Клиент Тогда
					сообщить("прописан ШК " + ФизЛицо.Наименование); 
				#КонецЕсли
				Если ФизЛицо.Модифицированность() Тогда
					ФизЛицо.Записать();
