
&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	Если НЕ ВводДоступен() Тогда Возврат КонецЕсли;
	Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	
	глТорговоеОборудование.СканерПосылкаДанных(1);
	глСобытиеСканераОтработано	= Истина;		
	
	ОбработкаДанныхШК(Данные);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаДанныхШК(Данные)
	
	Перем ЛП, СсылкаДок;
	
	Данные = СтрЗаменить(Данные,Символы.ПС,"");
	
	Попытка
	
		СсылкаНадок = ЗначениеИзСтрокиВнутр(Данные);
	
	Исключение
	     ОчиститьЗНАНаКлиенте();
		 ОбновитьНадписи("Отсканирован ЗНА:");
		 Сообщить("Не удалось найти ЗНА по ШК. "+ОписаниеОшибки()); 
		 Возврат; 
	КонецПопытки;
	
	ЗНАСсылка = Документы.ЗаданиеНаАгрегацию.ПолучитьСсылку(СсылкаНадок.УникальныйИдентификатор()); 
	 
	Если ЗначениеЗаполнено(ЗНАСсылка) 
		И ТипЗнч(ЗНАСсылка) = Тип("ДокументСсылка.ЗаданиеНаАгрегацию") Тогда
		
		ЗНА = ЗНАСсылка; 		
		
		ЛП = НайтиЛППоЗНА(ЗНА);
		
		Если НЕ ЗначениеЗаполнено(ЛП) Тогда
			
			//	ОбновитьНадписи("Найден необработанный ЛП! " + Строка(ЛП));
			//	
			//	//ОткрытьЗначение(ЛП); 
			//Иначе 
			ОбновитьНадписи("Не найдены ЛП по ЗНА!");
		Иначе 
			ОбновитьНадписи("Отсканирован ЗНА:");
		КонецЕсли;
		
	Иначе 
		ОчиститьЗНАНаКлиенте();  
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.ИмитацияСканирования.Видимость = РольДоступна("Администратор");
	ЛистыПереукладки.Параметры.УстановитьЗначениеПараметра("ЗаданиеНаАгрегацию",ЗНА); 
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ОбновитьНадписи(Текст = "")
    Если Не ЗначениеЗаполнено(ЗНА) Тогда 
		Элементы.ДекорацияИнформация.Заголовок = "Отсканируйте ЗНА";
		ЛистыПереукладки.Параметры.УстановитьЗначениеПараметра("ЗаданиеНаАгрегацию",ЗНА);
	ИначеЕсли ЗначениеЗаполнено(Текст) Тогда 
		Элементы.ДекорацияИнформация.Заголовок = Текст; 
    КонецЕсли;
КонецПроцедуры // ОбновитьНадписи()


&НаКлиенте
Процедура ОчиститьЗНА(Команда)
	
	ОчиститьЗНАНаКлиенте();

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЗНАНаКлиенте()
	
	ЗНА = ПредопределенноеЗначение("Документ.ЗаданиеНаАгрегацию.ПустаяСсылка");
	
	ОбновитьНадписи();

КонецПроцедуры 

// <Описание функции>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
// Возвращаемое значение:
//   <Тип.Вид>   - <описание возвращаемого значения>
//
&НаСервере
Функция НайтиЛППоЗНА(Знач ЗНА)
	
    ЛистыПереукладки.Параметры.УстановитьЗначениеПараметра("ЗаданиеНаАгрегацию",ЗНА);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЛистПереукладки.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
		|		ПО (ЛистПереукладкиТовары.Ссылка = ЛистПереукладки.Ссылка)
		|ГДЕ
		|	ЛистПереукладки.Проведен
		//|	И ЛистПереукладки.ДокОснование = &ДокОснование
		//|	И (ЛистПереукладкиТовары.Ссылка ЕСТЬ NULL
	//	|			ИЛИ ЛистПереукладкиТовары.Количество <> ЛистПереукладкиТовары.Отсканировано)
		//|	И НЕ ЛистПереукладки.Завершен
		|	И ЛистПереукладки.ЗаданиеНаАгрегацию = &ЗаданиеНаАгрегацию
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЛистПереукладки.Дата";
	
//	Запрос.УстановитьПараметр("ДокОснование", ЗНА.ДокОснование);
	Запрос.УстановитьПараметр("ЗаданиеНаАгрегацию", ЗНА);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		Возврат ВыборкаДетальныеЗаписи.ссылка; 
	КонецЕсли;

    Возврат Неопределено; 
КонецФункции // НайтиНеОтсканированныйЛП()

&НаКлиенте
Процедура ИмитацияСканированияПриИзменении(Элемент)
	ОбработкаДанныхШК(ИмитацияСканирования); 
КонецПроцедуры


