  <attributes>
    <name>ЛистыПереукладки</name>
    <title>
      <key>ru</key>
      <value>Листы переукладки</value>
    </title>
    <id>4</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЛистПереукладки.Ссылка КАК Ссылка,
	МАКСИМУМ(ВЫБОР
			КОГДА ЛистПереукладкиТовары.Количество &lt;> ЛистПереукладкиТовары.Отсканировано
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ) КАК Недозаполненный,
	ЛистПереукладки.Завершен КАК Завершен
ИЗ
	Документ.ЛистПереукладки КАК ЛистПереукладки
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
		ПО (ЛистПереукладкиТовары.Ссылка = ЛистПереукладки.Ссылка)
ГДЕ
	ЛистПереукладки.Проведен
	И ЛистПереукладки.ЗаданиеНаАгрегацию = &amp;ЗаданиеНаАгрегацию
	И ЛистПереукладки.ЗаданиеНаАгрегацию &lt;> ЗНАЧЕНИЕ(Документ.ЗаданиеНаАгрегацию.пустаяСсылка)

СГРУППИРОВАТЬ ПО
	ЛистПереукладки.Ссылка,
	ЛистПереукладки.Завершен</queryText>
      <mainTable>Document.ЛистПереукладки</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Ссылка</dataPath>
        <field>Ссылка</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Номер</dataPath>
        <field>Номер</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Автор</dataPath>
        <field>Автор</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ГруппыТоваров</dataPath>
