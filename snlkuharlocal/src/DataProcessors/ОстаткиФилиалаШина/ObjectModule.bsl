	//Рез=Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Группа");
	Рез=Запрос.Выполнить().Выбрать();
	//#Если Клиент Тогда
	//	Сообщить(" Количество выгружаемого товара - "+Рез.Количество());	
