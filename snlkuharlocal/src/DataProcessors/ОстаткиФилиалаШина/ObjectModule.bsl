	                     |				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.ОстаткиИОбороты(&дата1, &дата2, Период, , Склад В ИЕРАРХИИ (&Склады)) КАК Резервы
	                     |				ПО Остатки.Номенклатура = Резервы.Номенклатура
	                     |					И Остатки.Склад = Резервы.Склад
	                     |		
	                     |		СГРУППИРОВАТЬ ПО
	                     |			Остатки.Номенклатура.Ссылка,
	                     |			Остатки.Склад) КАК ВложенныйЗапрос
	                     |		ПО Ном.Ссылка = ВложенныйЗапрос.НоменклатураСсылка
	                     |		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	                     |			Номенклатура.Код КАК Код,
	                     |			Номенклатура.Наименование КАК Наименование,
	                     |			ШтрихКоды.Наименование КАК ШК,
	                     |			Номенклатура.Цвет КАК Цвет,
	                     |			Номенклатура.Размер КАК Размер,
	                     |			Номенклатура.Родитель.Код КАК РодительКод,
	                     |			Номенклатура.Ссылка КАК Ссылка,
	                     |			ШтрихКоды.Ссылка КАК ШКСсылка
	                     |		ИЗ
	                     |			Справочник.Номенклатура КАК Номенклатура
