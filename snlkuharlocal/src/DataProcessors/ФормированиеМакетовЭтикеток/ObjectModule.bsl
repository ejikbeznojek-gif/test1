	ТипТовара			= СокрЛП(ТипТовара);				
	ТипТовара=СтрЗаменить(Строка(ТипТовара),"дет.","детские");
	ТипТовара=СтрЗаменить(Строка(ТипТовара),"жен.","женские");
	ТипТовара=СтрЗаменить(Строка(ТипТовара),"муж.","мужские");	
