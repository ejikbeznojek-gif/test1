			ДатаВыпуска = ТекущаяДата()		
		КонецЕсли;
	КонецЕсли;
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	ОснованиеЗПС		= ПолучитьРеквизитШапки(ЗПС, "ДокОснование");
	
	ДанныеОрганизации=ЗаполнитьДанныеОрганизации();
	
	Запрос = Новый запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Номенклатура		КАК Номенклатура,
	|	АртикулаНосков.Значение 				КАК АртикулДляПечатиНосковНаСтикере,
	|	АртикулаКолготок.Значение				КАК АртикулДляПечатиКолготокНаСтикере,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет 	КАК Цвет,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер	КАК Размер,
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель.КодПроизводителя КАК КодПроизводителя,
	|	ЗаказПоставщикуТовары.Номенклатура.Состав 	КАК НоменклатураСостав,
	|	ЗаказПоставщикуТовары.Номенклатура.Цвет.РусскоеНаименование КАК ЦветРусский,
	|	ЗаказПоставщикуТовары.Номенклатура.Размер 	КАК ПростоРазмер,
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК ОбхватГруди,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК ОбхватПодГрудью,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК Рост,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК ОбхватТалии,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК ОбхватБедер,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК РеквизитыРазмера,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК Изготовитель,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК Изготовитель2,
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	|	ЗаказПоставщикуТовары.Номенклатура.ДопПараметрРазмера КАК ДопПараметрРазмера,
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель.Состав КАК Состав,
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель.Состав КАК СоставДляСпорта,
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель.ТипТовара КАК ТипТовара,
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель.ФР_ТипТовара КАК ФР_ТипТовара,
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(20)) КАК ШтрихКод,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(20)) КАК ДатаВыпуска,
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель КАК Модель,
	|	ЗаказПоставщикуТовары.Ссылка.Организация КАК Организация,
	|	ЗаказПоставщикуТовары.Ссылка.Организация.ИНН КАК ИННОрганизации,
	|	ЗаказПоставщикуТовары.Ссылка.Организация.КПП КАК КППОрганизации,
	|	ЗаказПоставщикуТовары.Ссылка.Организация.Телефоны КАК ТелефонОрганизации,
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК ЮрАдресОрганизации,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК ИмпортерИстория,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК ИННИмпортера,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(500)) КАК КППИмпортера
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК АртикулаНосков
	|ПО
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель = АртикулаНосков.Объект
	|	И (АртикулаНосков.Свойство = &АртикулДляПечатиНосковНаСтикере)
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК АртикулаКолготок
	|ПО 
	|	ЗаказПоставщикуТовары.Номенклатура.Родитель = АртикулаКолготок.Объект
	|	И (АртикулаКолготок.Свойство = &АртикулДляПечатиКолготокНаСтикере)
	|ГДЕ
	|	ЗаказПоставщикуТовары.Количество > 0
	|	И ЗаказПоставщикуТовары.Ссылка.Ссылка = &Ссылка
	|	И ЗаказПоставщикуТовары.Номенклатура В (&мНоменклатура)
	|";	
	
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	Если ТипЗнч(ЗПС) = Тип("ДокументСсылка.КонтрактСПроизводителем") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ".ЗаказПоставщику.", СтрШаблон(".%1.", ЗПС.Метаданные().Имя));
	КонецЕсли;
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	
	Запрос.УстановитьПараметр("Ссылка",			ЗПС);	
	
	Запрос.УстановитьПараметр("АртикулДляПечатиНосковНаСтикере", 			ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("АртикулДляПечатиНосковНаСтикере", Истина));
	Запрос.УстановитьПараметр("АртикулДляПечатиКолготокНаСтикере", 	ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("АртикулДляПечатиКолготокНаСтикере", Истина));
	
	Запрос.УстановитьПараметр("мНоменклатура", мНоменклатура);
	
	ДанныеДляЭтикеток = Запрос.Выполнить().Выгрузить();

	#Область ПоляЭтикеток		
	
	Поля = Новый Массив;
	Для Каждого Кол Из ДанныеДляЭтикеток.Колонки Цикл
		Поля.Добавить(Кол.Имя);
	КонецЦикла;
	
	СтрокаПолей = СтрСоединить(Поля, ",");
	
	//Номенклатура
	//АртикулДляПечатиНосков
	//АртикулДляПечатиКолготокНаСтикере
	//Цвет
	//Размер
	//КодПроизводителя
	//НоменклатураСостав
	//ЦветРусский
	//ПростоРазмер
	//ОбхватГруди
	//ОбхватПодГрудью
	//Рост
	//ОбхватТалии
	//ОбхватБедер
	//РеквизитыРазмера
	//Изготовитель
	//Изготовитель2
	//ДопПараметрРазмера
	//Состав
	//СоставДляСпорта
	//ТипТовара
	//ФР_ТипТовара
	//ШтрихКод
	//ДатаВыпуска
	//Модель
	//Организация
	//ИННОрганизации
	//КППОрганизации
	//ТелефонОрганизации	        
	#КонецОбласти                       
	
	ДопПараметры = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "ДопПараметры");	
