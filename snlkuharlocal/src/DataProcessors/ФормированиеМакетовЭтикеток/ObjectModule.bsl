		ДопПараметры = Новый Структура;	
	КонецЕсли;
	
	// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
	//ДопПараметры.Вставить("ДатаВыпуска", ВРег(Формат(ДатаВыпуска,"ДФ='MMMM yyyy'")));
	ДопПараметры.Вставить("ДатаВыпуска", Формат(ДатаВыпуска,"ДФ='MMMM yyyy'"));
	// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
	
	Для Каждого СтрокаТД из ДанныеДляЭтикеток цикл
		ЗаполнитьЗначенияСвойств(СтрокаТД, ДанныеИзготовителя);
		ЗаполнитьЗначенияСвойств(СтрокаТД, ДанныеОрганизации);
	
		НаборВремПолей = ПолучитьРеквизитыРазмера(СтрокаТД.Размер, ИмяМакета);
		ЗаполнитьЗначенияСвойств(СтрокаТД, НаборВремПолей);
		
		НаборВремПолей = ПерезаполнитьСостав(СтрокаТД.Номенклатура, ИмяМакета);
		ЗаполнитьЗначенияСвойств(СтрокаТД, НаборВремПолей);
		
		НаборВремПолей = ПерезаполнитьТипТовара(СтрокаТД.ТипТовара, ИмяМакета);
		ЗаполнитьЗначенияСвойств(СтрокаТД, НаборВремПолей);
		
		// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
		//ДопУсловие="	И подстрока(ШтрихКоды.Описание,1,3) = ""GS1""";
		ДопУсловие="	И ШтрихКоды.ЭтоКодGS1 = Истина";
		// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
		СтрокаТД.ШтрихКод = ПолучитьШтрихКодТовара(СтрокаТД.Номенклатура, Перечисления.ТипыШтрихКодов.Штука, Перечисления.ВидыШК.Основной, , ДопУсловие, Истина);	
		
		// Смирнов М.Ю. 28.07.2025 HELP-6117 начало
		//НаборВремПолей = ДанныеИмпортёра(ИмяМакета, СтрокаТД.Модель, ДатаВыпуска);
		//ЗаполнитьЗначенияСвойств(СтрокаТД, НаборВремПолей);
		Если ТипЗнч(пОбработки) = Тип("Структура") И пОбработки.Свойство("Импортер") 
			И ЗначениеЗаполнено(пОбработки.Импортер) Тогда
			НаборВремПолей = ПолучитьРеквизитыШапки(пОбработки.Импортер, "Наименование, ЮридическийАдрес, ИНН, КПП");
			СтрокаТД.ИмпортерИстория = СтрШаблон("%1, %2", НаборВремПолей.Наименование, НаборВремПолей.ЮридическийАдрес);
			СтрокаТД.ИННИмпортера = НаборВремПолей.ИНН; 
			СтрокаТД.КППИмпортера = НаборВремПолей.КПП;
		Иначе
			НаборВремПолей = ДанныеИмпортёра(ИмяМакета, СтрокаТД.Модель, ДатаВыпуска);
			ЗаполнитьЗначенияСвойств(СтрокаТД, НаборВремПолей);
		КонецЕсли;
		// Смирнов М.Ю. 28.07.2025 HELP-6117 конец
		ЗаполнитьЗначенияСвойств(СтрокаТД, ДопПараметры);		
	КонецЦикла;
	
	Результат.Данные = ДанныеДляЭтикеток;
	
	Возврат Результат;	
КонецФункции

Функция ПолучитьРеквизитыРазмера (Размер,ИмяМакета)
	
	НаборПолей = новый Структура;
	НаборПолей.Вставить("ОбхватГруди",""); 
	НаборПолей.Вставить("ОбхватПодГрудью",""); 
	НаборПолей.Вставить("Рост",""); 
	НаборПолей.Вставить("ОбхватТалии",""); 
	НаборПолей.Вставить("ОбхватБедер",""); 
	НаборПолей.Вставить("РеквизитыРазмера","");
	МассивРеквизитовРазмера=новый Массив;
	Запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	РеквизитыСправочников.ИмяРеквизита КАК ИмяРеквизита,
	|	РеквизитыСправочников.ЗначениеРеквизита КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	РеквизитыСправочников.Справочник = &Размер";
	запрос.УстановитьПараметр("Размер",Размер);
	ВыборкаРеквизитыРазмера=запрос.Выполнить().Выбрать();
	пока ВыборкаРеквизитыРазмера.Следующий() цикл
		если ВыборкаРеквизитыРазмера.ИмяРеквизита="Обхват под грудью" или ВыборкаРеквизитыРазмера.ИмяРеквизита="Обхватподгрудью" тогда
			НаборПолей.ОбхватПодГрудью="Обхват под грудью:"+ВыборкаРеквизитыРазмера.ЗначениеРеквизита;
		ИначеЕсли  ВыборкаРеквизитыРазмера.ИмяРеквизита="Обхватбедер" тогда
			НаборПолей.ОбхватБедер="Обхват бедер:"+ВыборкаРеквизитыРазмера.ЗначениеРеквизита;
		ИначеЕсли  ВыборкаРеквизитыРазмера.ИмяРеквизита="ОбхватГруди" тогда
			НаборПолей.ОбхватГруди="Обхват груди:"+ВыборкаРеквизитыРазмера.ЗначениеРеквизита;
		ИначеЕсли  ВыборкаРеквизитыРазмера.ИмяРеквизита="Рост" тогда
			НаборПолей.Рост="Рост:"+ВыборкаРеквизитыРазмера.ЗначениеРеквизита;
		ИначеЕсли  ВыборкаРеквизитыРазмера.ИмяРеквизита="ОбхватТалии" тогда
			НаборПолей.ОбхватТалии="Обхват талии:"+ВыборкаРеквизитыРазмера.ЗначениеРеквизита;
		иначе
			Продолжить;;
		КонецЕсли;
	КонецЦикла;
	
	Если НаборПолей.ОбхватГруди <> "" Тогда
		МассивРеквизитовРазмера.Добавить(НаборПолей.ОбхватГруди);
	КонецЕсли;
	Если НаборПолей.ОбхватПодГрудью <> "" Тогда
		МассивРеквизитовРазмера.Добавить(НаборПолей.ОбхватПодГрудью);
	КонецЕсли;	
	Если НаборПолей.ОбхватТалии <> "" Тогда
		МассивРеквизитовРазмера.Добавить(НаборПолей.ОбхватТалии);
	КонецЕсли;
	Если НаборПолей.ОбхватБедер <> "" Тогда
		МассивРеквизитовРазмера.Добавить(НаборПолей.ОбхватБедер);
	КонецЕсли;
	Если НаборПолей.Рост <> "" Тогда
		МассивРеквизитовРазмера.Добавить(НаборПолей.Рост);
	КонецЕсли;	
	
	НаборПолей.РеквизитыРазмера=СтрСоединить(МассивРеквизитовРазмера,символы.ПС);
	
	возврат НаборПолей;
КонецФункции

