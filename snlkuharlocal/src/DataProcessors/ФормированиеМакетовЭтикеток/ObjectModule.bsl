	НаборПолей.Вставить("ТипТовара",ТипТовара);
	
	Возврат НаборПолей;	
КонецФункции

Функция ЗаполнитьДанныеИзготовителя (ЗПС,ИмяМакета)
	РеквизитыШапки = ПолучитьРеквизитыШапки(зпс,"Контрагент,Контрагент.Код,Контрагент.ЮридическийАдрес,Контрагент.ПолноеНаименование,Контрагент.ПочтовыйАдрес","Документ");
	НаборПолей=новый Структура();
	КодКонтрагента=РеквизитыШапки.Контрагент_Код;
	если КодКонтрагента ="SSR-7303" или  КодКонтрагента="SSP-4032"  тогда    //Пром-Текс ООО (носки GRIFF) и Арт-текс
		Изготовитель=РеквизитыШапки.Контрагент_ПочтовыйАдрес;
		Импортер=Справочники.Организации.ПустаяСсылка();
	иначе
		Изготовитель=РеквизитыШапки.Контрагент_ПолноеНаименование+". "+РеквизитыШапки.Контрагент_ЮридическийАдрес;
	КонецЕсли;
	изготовитель=СтрЗаменить(Изготовитель,"Поставщик ","");
	// Андреев И.Д. 16.02.2021 конец
	НаборПолей.Вставить("Изготовитель", ?(Изготовитель="","","Изготовитель и его адрес: "+Изготовитель));
	НаборПолей.Вставить("Изготовитель2", ?(Изготовитель="","","Изготовитель и его адрес: "+Изготовитель));		
	возврат НаборПолей;
КонецФункции

Функция ДанныеИмпортёра (ИмяМакета,Модель,ДатаВыпуска,Фабрика="",Страна=Неопределено)
	НаборПолей=новый Структура;
	ИмпортерИстория=Неопределено;
	
	если ЗначениеЗаполнено(Страна) Тогда 
		ОтборДляГТД=новый Структура;
		ОтборДляГТД.Вставить("Страна",Страна);
		ГТД = ПолучитьГрупповойПериодическийРеквизит(Модель,"НомерГТД",,ОтборДляГТД);
		если ГТД=Неопределено тогда
			ГТД=Справочники.ГТД.НайтиПоНаименованию("Без номера");
		КонецЕсли;	
	иначе
		ГТД = ПолучитьГрупповойПериодическийРеквизит(Модель,"НомерГТД");
		если ГТД=Неопределено тогда
			ГТД=Справочники.ГТД.НайтиПоНаименованию("Без номера");
		КонецЕсли;
	КонецЕсли;
	
	
	Если (ГТД <> Неопределено или ГТД=Справочники.ГТД.НайтиПоНаименованию("Без номера")) Тогда
		//если (ЗначениеЗаполнено(Страна) и ГТД.СтранаПроисхождения <>  Страна)  тогда
		//	НаборПолей.Вставить("Импортер", Справочники.Контрагенты.ПустаяСсылка());
		//	НаборПолей.Вставить("ЮрАдресИмпортера", "");
		//иначе
			ИмпортерИстория = ГТД.Импортер;
			ИмпортердляИстории = ГТД.Импортер.ПолноеНаименование;
			НаборПолей.Вставить("Импортер", ИмпортерИстория);
			ЮрАдресОрганизации=ПолучитьПоследнееЗначениеИзПериодическиеРеквизитыДокументовИСправочников("ЮридическийАдрес",ИмпортерИстория,ДатаВыпуска); 
			если ЮрАдресОрганизации=Неопределено тогда
				ЮрАдресОрганизации=ИмпортерИстория.ЮридическийАдрес;
			КонецЕсли;
			НаборПолей.Вставить("ЮрАдресИмпортера", ЮрАдресОрганизации);
			НаборПолей.Вставить("ИмпортерИстория", Строка(ИмпортердляИстории)+", "+Строка(ЮрАдресОрганизации));
		//КонецЕсли;
	КонецЕсли;	
	
	НаборПолей.Вставить("ГТД", ГТД);
	
	
	
	если ЗначениеЗаполнено(Страна) тогда
		ОтборДляГТД=новый Структура;
		ОтборДляГТД.Вставить("Страна",Страна);
		Декларация = ПолучитьПериодическийРеквизит(Модель,"Декларация",ТекущаяДата(),,,ОтборДляГТД);		
	иначе
		Декларация = ПолучитьПериодическийРеквизит(Модель,"Декларация",ТекущаяДата());
	КонецЕсли;
	
	если Декларация<>Неопределено тогда 
		НаборПолей.Вставить("Декларация", декларация);
		НаборПолей.Вставить("фабрика",?(Фабрика="","","Адрес по изготовлению продукции: "+Фабрика+" "));		 
		
		//если ЗначениеЗаполнено(Страна) и ГТД.СтранаПроисхождения <>  Страна тогда
		//	НаборПолей.Вставить("Декларация", Неопределено);	
		//иначе
			
			НаборПолей.Вставить("Импортер",СтрЗаменить(Декларация.организация,"«Стиль Трейд»","""Стиль Трейд"""));
			
			ЮрАдресОрганизации=ПолучитьПоследнееЗначениеИзПериодическиеРеквизитыДокументовИСправочников("ЮридическийАдрес",Декларация.организация,ДатаВыпуска); 
			если ЮрАдресОрганизации=Неопределено тогда
				ЮрАдресОрганизации=Декларация.организация.ЮридическийАдрес;
			КонецЕсли;
			НаборПолей.Вставить("ЮрАдресИмпортера",ЮрАдресОрганизации);
		//КонецЕсли;
		
		//если ЗначениеЗаполнено(Импортер) тогда	
		//	НаборПолей.Вставить("Импортер",Импортер);
		//	НаборПолей.Вставить("ЮрАдресИмпортера",ЮрАдресИмпортера);
		//КонецЕсли;
	иначе
		//НаборПолей.Вставить("Декларация", Неопределено);
		//НаборПолей.Вставить("фабрика",?(Фабрика="","","Адрес по изготовлению продукции: "+Фабрика+" "));			
		//если ЗначениеЗаполнено(Импортер) тогда	
		//	НаборПолей.Вставить("Импортер",Импортер);
		//	НаборПолей.Вставить("ЮрАдресИмпортера",ЮрАдресИмпортера);
		//КонецЕсли;
	КонецЕсли;
	если ЗначениеЗаполнено(ИмпортерИстория) тогда
		НаборПолей.Вставить("ИННИмпортера", ИмпортерИстория.ИНН);
		НаборПолей.Вставить("КППИмпортера", ИмпортерИстория.КПП);
	КонецЕсли;
	возврат НаборПолей;
КонецФункции

Функция ЗаполнитьДанныеОрганизации()
		
