Процедура СообщитьМенеджеруАкт() Экспорт
	
	//Катаев+ 28/03/13 походу лишняя проверка
	//// Катаев+ 15/03/13 В локальных базах вывод ошибок отключаем
	//Если СтрокаСоединенияИнформационнойБазы() <> Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить() Тогда
	//	Возврат;
	//КонецЕсли;
	//// Катаев- 15/03/13
	//Катаев- 28/03/13
	//Катаев+ 09/04/13 Если в режиме отладки то сообщения не отправляются
	//Если ПараметрыСеанса.Отладка Тогда
	//	Возврат;
	//КонецЕсли;
	//Катаев- 09/04/13
	
	СтрШапка=АктШапка.Получить(0);
	
	Если СтрШапка.контрагент=Неопределено Тогда
		возврат;
	КонецЕсли;	
	сз = Новый СписокЗначений;
	
	Менеджер=СтрШапка.контрагент.Менеджер;
	Профиль= Новый ИнтернетПочтовыйПрофиль;
	// Кухарь А.Ю.  08.09.2022 начало
	//Профиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//Профиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//Если ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
	//	Профиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//	Профиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//Иначе
	//	Профиль.АдресСервераPOP3   = "87.236.190.180";
	//	Профиль.АдресСервераSMTP   =  "87.236.190.180";
	//КонецЕсли;
	//Профиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);		 
	// Кухарь А.Ю.  08.09.2022 конец
	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 15.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  15.10.2025
	Сообщение=новый ИнтернетПочтовоеСообщение;
	Сообщение.Отправитель.Адрес = "Ecode@collant.ru";
	Если НЕ Сокрлп(Менеджер.ЕМэйл)=""  тогда
		//Катаев+ 08/04/14 Отправку делаем только по штатным сотрудникам
		//сз.Добавить(Менеджер.ЕМэйл);
		Если Менеджер.Штатный Тогда
			сз.Добавить(Менеджер.ЕМэйл);
		КонецЕсли;
		//Катаев- 08/04/14
	конецесли;
	//---------------------------------------------------
	// получаем заместителей, для отправки из справочника пользователи.
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ПользователиЗаместители.Заместитель,
	|	ПользователиЗаместители.Заместитель.ЕМэйл  как ЗамЕМэйл
	|ИЗ
	|	Справочник.Пользователи.Заместители КАК ПользователиЗаместители
	|ГДЕ
	|	ПользователиЗаместители.Ссылка.ФизЛицо = &ТекМенеджер";
	Запрос.УстановитьПараметр("ТекМенеджер",Менеджер);
	Результат=Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		Если СтрДлина(Результат.ЗамЕМэйл)>5 Тогда
			//Катаев+ 08/04/14 Отправку делаем только по штатным сотрудникам
			//сз.Добавить(Результат.ЗамЕМэйл);
			Если Результат.Заместитель.Штатный Тогда
				сз.Добавить(Результат.ЗамЕМэйл);
			КонецЕсли;
			//Катаев- 08/04/14
		Иначе
			КритичОшибки.Добавить("Для менеджера (зам)"+Результат.Заместитель.Наименование+" не определен ЕМэйл. "+Символ(13));
		КонецЕсли;
	КонецЦикла;
	Если сз.Количество() = 0 Тогда
		КритичОшибки.Добавить("Для акта приемки товара по заказу № "+СтрШапка.НомерЗаказа+" не определены получатели "+Символ(13));
	Иначе
		Для каждого стр из сз Цикл
			Сообщение.Получатели.Добавить(стр.Значение);
		КонецЦикла;
		//Сообщение.Получатели.Добавить("kataev@collant.ru");
		Если стрШапка.РНК = Документы.РасходнаяНакладная.ПустаяСсылка() Или стрШапка.РНК = Неопределено Тогда
			Сообщение.Тема = "Автообмен Ecode. Получен акт о приеме товара по заказу № "+стрШапка.НомерЗаказа+" от "+стрШапка.ДатаЗаказа+". Номер РНК автоматически определить не удалось";
		Иначе
			Сообщение.Тема = "Автообмен Ecode. Получен акт о приеме товара по РНК № "+стрШапка.РНК.Номер+" от "+стрШапка.РНК.Дата;
		КонецЕсли;
		Строка = "Номер РНК в акте покупателя = "+стрШапка.НомерРНК+"<BR>Пункт доставки = "+стрШапка.ПунктДоставки+"<BR>Дата приемки товара = "+стрШапка.ДатаПриемаТовара;
		Если стрШапка.СостоянияРКМ = Перечисления.СостоянияРКМ.Отсутствует Тогда
			Строка = Строка+"<BR>По документу РНК имеются расхождения.";
		Иначе
			Строка = Строка+"<BR>По документу РНК расхождения не обнаружены.";
		КонецЕсли;
		Текст = Сообщение.Тексты.Добавить(Строка);
		Почта= Новый ИнтернетПочта;
		Текст.ТипТекста = ТипТекстаПочтовогоСообщения.HTML;
		попытка
			Почта.Подключиться(Профиль);
		исключение
			КритичОшибки.Добавить("Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки() );
			ЗаписатьВЛог("екод","Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки(),"Информация");
			
		КонецПопытки;
		Попытка
			Почта.Послать(Сообщение);
		Исключение
			
			КритичОшибки.Добавить("Не возможно отправить сообщение!   "+ОписаниеОшибки() );
			//Катаев+ 27/02/14 Катаев+
			КритичОшибки.Добавить("Узел - "+ПланыОбмена.Основной.ЭтотУзел());
			КритичОшибки.Добавить("Менеджер - "+Менеджер);
			попытка
				КритичОшибки.Добавить("Заказ ЕКОД - "+СтрШапка.номЗаказа);
			исключение
			конецПопытки;
			//Катаев- 27/02/14
			Для Каждого пол из сообщение.Получатели цикл
				КритичОшибки.Добавить("Получатель="+пол+" "+пол.ОтображаемоеИмя);
			КонецЦикла;
		КонецПопытки;
		Почта.Отключиться();
	КонецЕсли;
	
КонецПроцедуры

Процедура СообщитьМенеджеру(ПутьФайла, Шапка) Экспорт
	
	//Катаев+ 28/03/13 походу лишняя проверка
	//// Катаев+ 15/03/13 В локальных базах вывод ошибок отключаем
	//Если СтрокаСоединенияИнформационнойБазы() <> Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить() Тогда
	//	Возврат;
	//КонецЕсли;
	//// Катаев- 15/03/13
	//Катаев- 28/03/13
	//Катаев+ 09/04/13 Если в режиме отладки то сообщения не отправляются
	//Если ПараметрыСеанса.Отладка Тогда
	//	Возврат;
	//КонецЕсли;
	//Катаев- 09/04/13
	
	СтрШапка=Шапка.Получить(0);
	
	//Катаев+ 15/04/13
	//Если СтрШапка.контрагент=Неопределено Тогда
	Если СтрШапка.контрагент=Неопределено или стрШапка.Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда
		возврат;
	КонецЕсли;	
	//Катаев- 15/04/13
	
	Менеджер=СтрШапка.контрагент.Менеджер;
	Профиль= Новый ИнтернетПочтовыйПрофиль;
	// Кухарь А.Ю.  08.09.2022 начало
	//Профиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//Профиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//Если ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
	//	Профиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//	Профиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//Иначе
	//	Профиль.АдресСервераPOP3   = "87.236.190.180";
	//	Профиль.АдресСервераSMTP   =  "87.236.190.180";
	//КонецЕсли;
	//Профиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);		 
	// Кухарь А.Ю.  08.09.2022 конец

	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 15.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  15.10.2025
	//---------------------------------------------------------------
	Попытка
		ИмяФайлаПечати=ФормированиеПечати(ТЗПечать,ТЗШапка); //+++
	Исключение
		КритичОшибки.Добавить("Не сформирован файл печати! "+Символ(13));
	КонецПопытки;
	
	// и прикрепляем файл;
	
	//----------------------------------------------------------------
	Сообщение=новый интернетПочтовоеСообщение;
	Если НЕ Сокрлп(Менеджер.ЕМэйл)=""  тогда
		//Катаев+ 08/04/14 Отправку делаем только по штатным сотрудникам
		//Сообщение.Получатели.Добавить(Менеджер.ЕМэйл);
		Если Менеджер.Штатный Тогда
			Сообщение.Получатели.Добавить(Менеджер.ЕМэйл);
		КонецЕсли;
		//Катаев- 08/04/14
	конецесли;
	//---------------------------------------------------
	// получаем заместителей, для отправки из справочника пользователи.
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ПользователиЗаместители.Заместитель,
	|	ПользователиЗаместители.Заместитель.ЕМэйл  как ЗамЕМэйл
	|ИЗ
	|	Справочник.Пользователи.Заместители КАК ПользователиЗаместители
	|ГДЕ
	|	ПользователиЗаместители.Ссылка.ФизЛицо = &ТекМенеджер";
	Запрос.УстановитьПараметр("ТекМенеджер",Менеджер);
	Результат=Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		Если СтрДлина(Результат.ЗамЕМэйл)>5 Тогда
			//Катаев+ 08/04/14 Отправку делаем только по штатным сотрудникам
			//Сообщение.Получатели.Добавить(Результат.ЗамЕМэйл);
			Если Результат.Заместитель.Штатный Тогда
				Сообщение.Получатели.Добавить(Результат.ЗамЕМэйл);
			КонецЕсли;
			//Катаев- 08/04/14
			
		Иначе
			КритичОшибки.Добавить("Для менеджера (зам)"+Результат.Заместитель.Наименование+" не определен ЕМэйл. "+Символ(13));
		КонецЕсли;
	КонецЦикла;	
	
	
	//Нечаева 11,03,19+++
	//-----------------------------------------------
	// если есть ошибки какие-то то сообщать ассистентам.
	Если Ошибки.Количество()>0 Тогда
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	УведомленияПоЕкоду.Пользователь
		|ИЗ
		|	РегистрСведений.УведомленияПоЕкоду КАК УведомленияПоЕкоду
		|ГДЕ
		|	УведомленияПоЕкоду.Контрагент = &ТекКонтр
		|	И УведомленияПоЕкоду.ТипУведомления = &ТипУвед";
		Запрос.УстановитьПараметр("ТекКонтр",СтрШапка.контрагент);
		Запрос.УстановитьПараметр("ТипУвед","заказ");
		Результат=Запрос.Выполнить().Выбрать();
		Пока Результат.Следующий() Цикл
			Попытка	
				Если СтрДлина(Результат.Пользователь)>5 Тогда
					Сообщение.Получатели.Добавить(Результат.Пользователь.ЕМэйл);
				Иначе
					КритичОшибки.Добавить("Для менеджера (зам)"+Результат.Пользователь.Наименование+" не определен ЕМэйл. "+Символ(13));
				КонецЕсли;
			Исключение	
				ошибки.Добавить(" добавление адресов - ошибка "+ОписаниеОшибки());
				Сообщение.Получатели.Добавить("nechaeva@mail.ru");
			КонецПопытки;	
			
		КонецЦикла;
		
		
	КонецЕсли;
	
	//-----------------------------------------------
	//Нечаева 11,03,19---
	
	
	
	
	
	//-----------------------------------------------
	//Катаев+ 09/04/13
	//Сообщение.Получатели.Добавить("ecode@collant.ru"); //+++
	Если Сообщение.Получатели.Количество() = 0 Тогда
		//Катаев+ 15/04/13 Если менеджер не заполнен, то выводим контрагента для которого не заполнен менеджер
		//КритичОшибки.Добавить("У менеджера "+Менеджер+" и его заместителей не определен ЕМэйл. "+Символ(13));
		Если Менеджер = Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
			КритичОшибки.Добавить("У Контрагента "+СтрШапка.контрагент+" не определен менеждер. "+Символ(13));
		Иначе
			КритичОшибки.Добавить("У менеджера "+Менеджер+" и его заместителей не определен ЕМэйл. "+Символ(13));
		КонецЕсли;
		//Катаев- 15/04/13
		Возврат
	КонецЕсли;
	//Катаев- 09/04/13
	
	//Сообщение.Получатели.Добавить("nechaeva@collant.ru");
	Сообщение.Отправитель="ecode@collant.ru";
	
	//Если Ашан Тогда
	//	Сообщение.Получатели.Добавить("chernyh@collant.ru"); //+++
	//КонецЕсли;	
	
	ПунктДоставки=СтрШапка.ПунктДоставки;
	
	Если ПунктДоставки=Неопределено тогда
		ПунктДоставки="";
	Конецесли;	
	
	Сообщение.Тема="Автообмен Ecode. Новый заказ ЕКОДЕ № "+СтрШапка.номЗаказа+" - "+СтрШапка.контрагент+" - "+ПунктДоставки;
	Строка=Символ(13)+Символ(13)+"       Добрый день!"+Символ(13)+Символ(13)+Строка("Новый заказ в ECODE № "+СтрШапка.НомЗаказа+"  от компании  "+СтрШапка.контрагент+".");
	//Символы.ПС+"Сформировано новое РНК № "+Док.номер+" "+Док.Дата+".")+Символ(13)+Символ(13);
	Для рр=0 по файлы.Количество()-1 Цикл
		Строка=Строка+символы.ПС+Файлы[рр];
	КонецЦикла;
	
	
	НомСтр=1;
	Строка=Строка+Символы.ПС+символы.ПС+"Фактический адрес, пунк доставки: "+СтрШапка.ПунктДоставки;
	Строка=Строка+Символы.ПС;
	Если Ошибки.количество()>1 Тогда
		Строка=Строка+Символы.ПС+"Сообщения по загрузке данных:";
	КонецЕсли;	
	Если НЕ Ошибки=Неопределено и ошибки.Количество()>0 Тогда
		Для рр=0 по ошибки.Количество()-1 Цикл
			Строка=Строка+Символы.ПС+НомСтр+". "+Ошибки[рр];
			Строка=Строка+Символы.ПС;
			НомСтр=НомСтр+1;
		КонецЦикла;
	конецЕсли;
	Строка=Строка+Символы.ПС+"________________________________________________________________";
	
	Сообщение.Тексты.Добавить(Строка);
	
	Сообщение.Вложения.Добавить(ПутьФайла);
	Попытка
		Сообщение.Вложения.Добавить(ИмяФайлаПечати);     //+++
	Исключение
		КритичОшибки.Добавить("Не возможно добавить файл печати для заказа "+СтрШапка.НомЗаказа+". Контрагент - "+СтрШапка.контрагент+".  "+ОписаниеОшибки() );
	КонецПопытки;
	
	Почта= Новый ИнтернетПочта;
	попытка
		Почта.Подключиться(Профиль);
	исключение
		КритичОшибки.Добавить("Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки() );
		ЗаписатьВЛог("екод","Не возможно подключиться к почте, для отправке сообщений ! "+ОписаниеОшибки(),"Информация");
		
	конецПопытки;
	Попытка
		Почта.Послать(Сообщение);
	исключение
		
