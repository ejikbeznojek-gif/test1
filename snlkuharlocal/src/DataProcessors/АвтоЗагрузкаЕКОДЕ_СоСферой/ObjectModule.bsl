Функция ПроверитьПаллетыПоДокументу(Накладная)
	
	Отказ = ложь;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ
	|	ПаллетаЛистыНабора.Ссылка КАК Паллета,
	|	ПаллетаЛистыНабора.Описание КАК НомерКоробки,
	|	ПаллетаЛистыНабора.Ссылка.ОкончаниеПаллетирования КАК ОкончаниеПаллетирования
	|ИЗ
	|	Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|ГДЕ
	|	ПаллетаЛистыНабора.Ссылка.Проведен
	|	И ПаллетаЛистыНабора.Документ.ссылка = &Документ
	|	И ПаллетаЛистыНабора.Ссылка.ОкончаниеПаллетирования <> &ОкончаниеПаллетирования";
	запрос.УстановитьПараметр("Документ", Накладная.ссылка);
	запрос.УстановитьПараметр("ОкончаниеПаллетирования",ПустаяДата());
	
	результат=запрос.Выполнить().Выгрузить();
	
	
	ОбИКол=ПолучитьКоличествоИОбъемКоробовИзРегистра(Накладная);
	если ОбИКол<>Неопределено тогда
		КоличествоКоробок=ОбИКол.КоличествоКоробок;			
	иначе
		КоличествоКоробок=Накладная.КоличествоКоробок
	КонецЕсли;
	
	для сч=1 по КоличествоКоробок цикл
		СтруктураПоиска=новый Структура;
		СтруктураПоиска.Вставить("НомерКоробки",Строка(сч));
		МассивКоробок=результат.НайтиСтроки(СтруктураПоиска);
		
		если МассивКоробок.Количество()=0 тогда
			#если клиент тогда
				сообщить("Не найдена в паллетах коробка № "+Строка(сч));
				КритичОшибкиЛента.Добавить("Не найдена в паллетах коробка № "+Строка(сч));
			#КонецЕсли
			Отказ = истина;
		ИначеЕсли МассивКоробок.Количество()>1 тогда
			СписокПаллет="";
			Для каждого СтрМасс из МассивКоробок Цикл 
				СписокПаллет=СписокПаллет+СтрМасс.Паллета.Номер+"  ";
				
			КонецЦикла;
			#если клиент тогда
				сообщить("Коробка № "+Строка(сч)+" отсканирована несколько раз в паллеты "+СписокПаллет);
				КритичОшибкиЛента.Добавить("Коробка № "+Строка(сч)+" отсканирована несколько раз в паллеты "+СписокПаллет);
			#КонецЕсли
			
			Отказ = истина;
		КонецЕсли;
	КонецЦикла;
	
	возврат отказ;
	
КонецФункции
