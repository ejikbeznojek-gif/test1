Процедура ПроверитьФайлыНаФТП()
	Запрос = Новый Запрос;
	ЗапросДок = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрФайловЕКОД.ПолноеИмяФайла,
	|	РегистрФайловЕКОД.НомерЗаказа,
	|	РегистрФайловЕКОД.ДатаЗаказа,
	|	РегистрФайловЕКОД.Узел
	|ИЗ
	|	РегистрСведений.РегистрФайловЕКОД КАК РегистрФайловЕКОД
	|ГДЕ
	|	РегистрФайловЕКОД.Документ_Создан = ЛОЖЬ";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		// Находим документ по номеру и дате заказа
		Если Найти(Выборка.ПолноеИмяФайла, "ORDER") > 0 Тогда
			ЗапросДок.Текст =
			"ВЫБРАТЬ
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.НомерЗаказа = &НомерЗаказа
			|	И РасходнаяНакладная.ДатаЗаказа = &ДатаЗаказа
			|	И РасходнаяНакладная.Склад.Подразделение = &Подразделение";
			поз = Найти(Выборка.ПолноеИмяФайла, "ORDER");
		Иначе
			ЗапросДок.Текст =
			"ВЫБРАТЬ
			|	АктПриемки.Ссылка
			|ИЗ
			|	Документ.АктПриемки КАК АктПриемки
			|ГДЕ
			|	АктПриемки.НомерЗаказа = &НомерЗаказа
			|	И АктПриемки.ДатаЗаказа = &ДатаЗаказа
			|	И АктПриемки.РНК.Склад.Подразделение = &Подразделение";
			поз = Найти(Выборка.ПолноеИмяФайла, "RECADV");
		КонецЕсли;
		ЗапросДок.УстановитьПараметр("НомерЗаказа", Выборка.НомерЗаказа);
		ЗапросДок.УстановитьПараметр("ДатаЗаказа", Выборка.ДатаЗаказа); 
		ЗапросДок.УстановитьПараметр("Подразделение", Выборка.Узел.Подразделение);
		ВыборкаДок = ЗапросДок.Выполнить().Выбрать();
		Если ВыборкаДок.Количество() > 0 Тогда
			ПутьКФайлу = Лев(Выборка.ПолноеИмяФайла, поз-1);
			ИмяФайла = СтрЗаменить(Выборка.ПолноеИмяФайла, ПутьКФайлу, "");
			//Катаев+ 26/06/13 Добавил проверку на наличие слеша. Если он есть то оставляем только то что после него находится.
			поз = Найти(ИмяФайла,"\");
			Если поз > 0 Тогда
				ИмяФайла = Прав(ИмяФайла,стрДлина(имяФайла)-поз);
			КонецЕсли;
			//Катаев- 26/06/13
			
			//нечаева 23,05,17+++
			ПутьКФТП = "\\srvftp\ftp_1c$\snl\ecod\"+Выборка.Узел.Код+"\";
			//нечаева 23,05,17---
			
			// Удаляем файл с фтп
			//Катаев+ 14/07/14 На фтп из имени файла убраны русские буквы
			//УдалитьФайлы(ПутьКФТП, ИмяФайла);
			ИмяФайлаНаФТП = УбратьРБ(ИмяФайла);
			УдалитьФайлы(ПутьКФТП, ИмяФайлаНаФТП);
			//Катаев- 14/07/14
			// Переносим файл из папки ЕКОД в архив
			фф = новый файл(ПутьКФайлу+"ARHIV\");
			Если НЕ фф.Существует() Тогда
				//создатькаталог(ПутьКФайлу+"ARHIV\");
				попытка
					создатькаталог(ПутьКФайлу+"ARHIV\");
				исключение
					#Если клиент тогда
						сообщить(" +++++++++++++++++"+ПутьКФайлу);
					#конецесли	
				конецпопытки;
				
			КонецЕсли;	
			ИмяДляЗаписи=ПутьКФайлу+"ARHIV\"+ИмяФайла;
			Попытка
				КопироватьФайл(Выборка.ПолноеИмяФайла,ИмяДляЗаписи);
			Исключение
			КонецПопытки;	
			// Отмечаем в регистре сведений что документ создан, что бы впоследсвии не проверять его
			рег = РегистрыСведений.РегистрФайловЕКОД;
