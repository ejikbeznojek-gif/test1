// для ашана 
Процедура ОбработкаДанныхЗагрузкиАшан(Шапка,Строки)
	
	Ашан=1;
	
	СтрШапка=Шапка.Получить(0);
	ТипЦен=Справочники.ТипыЦен.ПустаяСсылка();
	ТипСкидки=Справочники.ТипыСкидок.ПустаяСсылка();
	Организация=Неопределено;
	Менеджер=Неопределено;
	Регион=Неопределено;
	Договор=Неопределено;
	Подразделение=Неопределено;
	ОтсрочкаПлатежа=Неопределено;
	КодПоставщикаКонтрагента=Неопределено;
	ПунктДоставки=Неопределено;
	НомерЗаказа=Неопределено;
	ТипILNКонтрагента=Неопределено;
	ДатаЗаказа=Неопределено;
	ДатаОтгрузки=Неопределено;
	Склад=Неопределено;   //Справочники.Склады.НайтиПоКоду("STD-97");
	Контрагент=СтрШапка.Контрагент;
	Если Контрагент=Неопределено тогда
		Контрагент=Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	ПунктДоставки=СтрШапка.ПунктДоставки;
	НомЗаказа=СтрШапка.НомЗаказа;
	НомерЗаказа=СтрШапка.НомЗаказа;
	ДатаЗаказа=СтрШапка.ДатаЗаказа;
	ДатаДоставки=СтрШапка.ДатаДоставки;
	ТипILNКонтрагента=СтрШапка.ТипILNКонтрагента;
	
	//нечаева 13,08,19+++
	КодПоставщикаШапка = СтрШапка.КодДоговора;
	//нечаева 13,08,19---
	
	ПризКр=0;
	//сообщить("    запись документа");
	Если не Контрагент.Пустая() Тогда 	
		// 1. Обрабатываем количество, делаем округление  соответствуещее коли-ву в блочке
		Если Контрагент.ОткруглятьКоличество Тогда
			
			Для каждого ТекСтрока Из Строки Цикл
				ПризКратности=1;
				Ном=ТекСтрока.Номенклатура;
				КолЗаказано=ТекСтрока.Колво;
				
				Если НЕ ТипЗнч(Ном) = Тип("СправочникСсылка.Номенклатура") Тогда
					ТекСтрока.КолвоОтредактированное=КолЗаказано;
					продолжить;
				КонецЕсли;
				
				ШтукВКор=Ном.Родитель.ШтукВКоробочке;
				Если ШтукВКор-0>0 Тогда 
					// проверяем на кратность 5 или 6
					Если (ШтукВКор/5)=Цел((ШтукВКор/5)) Тогда
						ПризКратности=5
					ИначеЕсли (ШтукВКор/6)=Цел((ШтукВКор/6)) Тогда
						ПризКратности=6
					Иначе
						ПризКратности=1;
					КонецЕсли;
					
					Если (КолЗаказано/ПризКратности)<>Цел((КолЗаказано/ПризКратности)) Тогда
						КолУпак=Цел(Окр(КолЗаказано/ПризКратности,0,0));
						НовКолво=КолУпак*ПризКратности;
						ТекСтрока.КолвоОтредактированное=НовКолво;
					Иначе
