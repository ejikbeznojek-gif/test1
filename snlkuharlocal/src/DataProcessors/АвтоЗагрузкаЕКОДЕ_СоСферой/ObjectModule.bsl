	|	ЛистНабораТовары.Номенклатура,
	|	ЛистНабораТовары.ТипШК,
	|	ВЫРАЗИТЬ(ВложенныйЗапрос.SSCCКод КАК СТРОКА(50)) КАК Номер,
	|	ВложенныйЗапрос.ЛистНабора
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	|		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПаллетаЛистыНабора.Ссылка.SSCCКод КАК SSCCКод,
	|			ПаллетаЛистыНабора.Ссылка КАК Ссылка,
	|			ПаллетаЛистыНабора.ЛистНабора КАК ЛистНабора
	|		ИЗ
	|			Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|		ГДЕ
	|			ПаллетаЛистыНабора.ЛистНабора.Проведен = ИСТИНА) КАК ВложенныйЗапрос
	|		ПО ЛистНабораТовары.Ссылка = ВложенныйЗапрос.ЛистНабора
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.ДокОснование = &ТекРНК
	|	И ЛистНабораТовары.Номенклатура в иерархии(&ТекНом)
	//нечаева 03,03,17++
	|	И ЛистНабораТовары.Ссылка.ПометкаУдаления = ложь
	|	И ВложенныйЗапрос.Ссылка.Проведен = истина";
	//нечаева 03,03,17--
	
	запрос.УстановитьПараметр("ТекРНК",ТекДок.ссылка);
