						Попытка
							рег = регистрыСведений.РеквизитыРНКПНКПРМ;
							Элемент = Рег.СоздатьМенеджерЗаписи();
							Элемент.Документ = ДокОбъект.ссылка;
							Элемент.ИмяРеквизита = "GLNпокупателя";
							Элемент.ЗначениеРеквизита = СтрШапка.ИЛНПокупателя;
							Элемент.Записать();
						Исключение
						КонецПопытки;
						//нечаева 02,11,17---
						
						
					КонецЕсли;
					//Нечаева 25,10,17--
					
					//нечаева 07,10,2022+++
					Если стрШапка.контрагент.код = "SSR-1593" и ( СтрШапка.ГЛН_Конечный = "" или  СтрШапка.ГЛН_Конечный = неопределено) тогда  // это лента
						
						СтрШапка.ГЛН_Конечный = ДокОбъект.ПунктДоставки.КодИЛН;
						
					конецЕсли;	
					// нечаева 07,10,22--
					
					
					
					// нечаева 23,03,16 +++ если напрямую грузим! не через рц
					Если СтрШапка.ГЛН_Конечный = "" Тогда
						СтрШапка.ГЛН_Конечный = ДокОбъект.ПунктДоставки.КодИЛН;
					КонецЕсли;
					// нечаева 23,03,16 ---	
					
					Если СтрШапка.ГЛН_Конечный <> Неопределено Тогда
						//нечаева 13,03,17+++
						
						//было
						//рег = регистрыСведений.РеквизитыРНКПНКПРМ;
						//ВыборкаРег = Рег.Выбрать();
						//Пока ВыборкаРег.Следующий() Цикл
						//	Если ВыборкаРег.ИмяРеквизита = "GLN" И ВыборкаРег.Документ = ДокОбъект.Ссылка Тогда;
						//		ВыборкаРег.ПолучитьМенеджерЗаписи().Удалить();
						//	КонецЕсли;
						//КонецЦикла;
						//Элемент = Рег.СоздатьМенеджерЗаписи();
						//Элемент.Документ = ДокОбъект.ссылка;
						//Элемент.ИмяРеквизита = "GLN";
						//Элемент.ЗначениеРеквизита = СтрШапка.ГЛН_Конечный;
						//Элемент.Записать();
						
						попытка
							
							НаборЗаписей = РегистрыСведений.РеквизитыРНКПНКПРМ.СоздатьНаборЗаписей();
							НаборЗаписей.Отбор.Документ.Установить(ДокОбъект.Ссылка); 
							НаборЗаписей.Отбор.ИмяРеквизита.Установить("GLN"); 
							НаборЗаписей.Очистить();;
							НаборЗаписей.Записать();
							
						исключение
						конецПопытки;
						
						рег = регистрыСведений.РеквизитыРНКПНКПРМ;
						Элемент = Рег.СоздатьМенеджерЗаписи();
						Элемент.Документ = ДокОбъект.ссылка;
						Элемент.ИмяРеквизита = "GLN";
						Элемент.ЗначениеРеквизита = СтрШапка.ГЛН_Конечный;
						Элемент.Записать();
						
						//нечаева 13,03,17----
						
					КонецЕсли;
					//Катаев- 31/10/13
				Исключение
					Если ПризКр=0 тогда
						КритичОшибки.Добавить("После обновления нумерации для заказа Заказ из ECODE №"+НомерЗаказа+".  Контрагент -"+Контрагент +". ПунктДоставки - "+ПунктДоставки+" документ не записан! "+ОписаниеОшибки() );
						//Катаев+ 11/12/14
						Отказ = Истина;
						//Катаев- 11/12/14
					конецЕсли;
				КонецПопытки;
			Иначе	
				Если ПризКр=0 тогда
					КритичОшибки.Добавить("Для заказа Заказ из ECODE №"+НомерЗаказа+".  Контрагент -"+Контрагент +". ПунктДоставки - "+ПунктДоставки+" документ не записан! "+ОписаниеОшибки() );
					//Катаев+ 11/12/14
					Отказ = Истина;
					//Катаев- 11/12/14
