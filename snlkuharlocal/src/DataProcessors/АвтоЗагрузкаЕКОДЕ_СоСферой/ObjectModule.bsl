				//Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
				//	ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
				//	ДокОбъект.ТранспортнаяКомпания=ТранспортнаяКомпания;
				//КонецЕсли;	
				//Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
				//	ПунктПерегруза=ПунктДоставки.ПунктПерегруза;	
				//	ДокОбъект.ПунктПерегруза=ПунктПерегруза;
				//КонецЕсли;		
				Если ПунктДоставки.ТипДоставки = Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда
					Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
						ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
						ДокОбъект.ТранспортнаяКомпания=ТранспортнаяКомпания;
					КонецЕсли;
					Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
						ПунктПерегруза=ПунктДоставки.ПунктПерегруза;	
						ДокОбъект.ПунктПерегруза=ПунктПерегруза;
					КонецЕсли;		
				КонецЕсли;
				//Катаев- 10/04/14
				Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
					Грузополучатель=ПунктДоставки.Грузополучатель;		
					ДокОбъект.Грузополучатель=Грузополучатель;
				КонецЕсли;
				Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
					Получатель=ПунктДоставки.Получатель;		
					ДокОбъект.Получатель=Получатель;
				КонецЕсли;
				Если ЗначениеЗаполнено(ПунктДоставки.ОтсрочкаПлатежа) Тогда
					ОтсрочкаПлатежа=ПунктДоставки.ОтсрочкаПлатежа;		
					ДокОбъект.ОтсрочкаПлатежа=ОтсрочкаПлатежа;
				КонецЕсли;
				
				//типы цен скидки
				Если ЗначениеЗаполнено(ПунктДоставки.ТипЦен) И ТипЦен<>ПунктДоставки.ТипЦен Тогда
					ТипЦен=ПунктДоставки.ТипЦен;		
				КонецЕсли; 
				Если ЗначениеЗаполнено(ПунктДоставки.ТипСкидок) И ДокОбъект.ТипСкидок<>ПунктДоставки.ТипСкидок Тогда
					ТипСкидок=ПунктДоставки.ТипСкидок;		
				КонецЕсли;
				Если ПунктДоставки.Скидка<>0 И ПунктДоставки.Скидка<>ДокОбъект.Скидка Тогда
					Скидка=ПунктДоставки.Скидка;		
					ДокОбъект.Скидка=Скидка;
				КонецЕсли;
			КонецЕсли;
			//-------------------------------------------------------------------		
			
			ДокОбъект.Дата=ТекущаяДата();
			ЗаполнитьШапкуДокумента(ДокОбъект, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
			//УстановитьНомерДокументаКлиентСервер(ДокОбъект);
			ДокОбъект.Контрагент=Контрагент;
			ДокОбъект.Организация=Организация;
			ДокОбъект.Договор=Договор;
			ДокОбъект.ИБ=Справочники.ИБ.НайтиПоКоду("SSP");
			ДокОбъект.Менеджер= Менеджер;
			ДокОбъект.НомерЗаказа= УбратьНули(НомерЗаказа,Контрагент.УбиратьНулиПередНомеромЗаказа);
			
			Попытка
				ДокОбъект.ДатаЗаказа=Дата(СтрЗаменить(ДатаЗаказа, "-", ""));
				ДокОбъект.ДатаОтгрузки=Дата(СтрЗаменить(ДатаДоставки, "-", ""));
			Исключение
			КонецПопытки;
			
			
			ДокОбъект.КодПоставщика=КодПоставщикаКонтрагента;
			
			ДокОбъект.Регион = Регион;
			ТипШК=перечисления.ТипыШтрихКодов.Штука;
			
			ДокОбъект.ОтсрочкаПлатежа=ОтсрочкаПлатежа;		
			ДокОбъект.ТипЦен=ТипЦен; //Контрагент.ТипЦен;
			ДокОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН;
			ДокОбъект.Подразделение = Подразделение;
			ДокОбъект.ЛевыйКонтрагент=Контрагент;
			ДокОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
			ДокОбъект.Отгружен=перечисления.Отгружен.Резерв;
			ДокОбъект.ПунктДоставки=ПунктДоставки;
			ДокОбъект.Склад=Склад;		
			УстановитьНомерДокументаКлиентСервер(ДокОбъект);
			ДокОбъект.Валюта=Справочники.Валюты.НайтиПоКоду("810");
			ДокОбъект.Автор	=Неопределено;
			
			//крохин начало 02.08.2021
			//Если СокрЛП(Контрагент.Код)=КодМетро И (Лев(ДокОбъект.Номер,3)<>"SSP" или Лев(ДокОбъект.Номер,3)<>"SST") Тогда
			Если СокрЛП(Контрагент.Код)=КодМетро И (Лев(ДокОбъект.Номер,3)<>"SSP" или Лев(ДокОбъект.Номер,3)<>"SST" или Лев(ДокОбъект.Номер,3)<>"SSV") Тогда
				//крохин конец 02.08.2021
				УстановитьНомерДокументаКлиентСервер(ДокОбъект);	
			КонецЕсли;
			
			ДокОбъект.КодОперации=Перечисления.КодыОперацийОстатки.Реализация;
			ДокОбъект.ДатаОформления	=ДокОбъект.Дата;
			
			
			ДокОбъект.ДатаОплаты	    =ПолучитьДатуОплаты1(ДокОбъект.ДатаОтгрузки,ДокОбъект.ОтсрочкаПлатежа);	
			СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
			ДокОбъект.Скидка=СкидкаКонтрагента;
			
			ПересчетТЧ(ДокОбъект,"Товары",ДокОбъект.Валюта,ДокОбъект.Валюта,ДокОбъект.Курс,ДокОбъект.Курс,Истина);	
			
			
			//проверим на пустые цены!!
			//нечаева 15,03,16+++
			
			ОтборНулевыеЦены=новый Структура("Цена",0);
			МассивНулевыхЦен=ДокОбъект.Товары.НайтиСтроки(ОтборНулевыеЦены);
			
			
			Для каждого текстрока из МассивНулевыхЦен цикл
				
				Отбор2=новый Структура("номенклатура",ТекСтрока.номенклатура);
				тстрока=ДокОбъект.Товары.НайтиСтроки(Отбор2);
				Ошибки.Добавить("Для товара -  "+ТекСтрока.номенклатура +" Цена =0, не записано в заказе, проверьте матрицу! " );
				ТекНом =тстрока[0].НомерСтроки; //.удалить()
				докобъект.товары.Удалить(ТекНом-1);
				
			КонецЦикла;
			//нечаева 15,03,16---
			
			
			Попытка
				ДокОбъект.Записать(режимЗаписиДокумента.Запись);
				Файлы.Добавить("Создан документ: "+ДокОбъект.Дата+" "+ДокОбъект.Номер+", склад: "+ДокОбъект.Склад+".");
				//Сообщить("Записан документ - "+ДокОбъект.Дата+" "+ДокОбъект.Номер);
