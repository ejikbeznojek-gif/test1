//Катаев+ 29/03/13
Функция НайтиСклад(Номенклатура)
	УровеньН = номенклатура.Уровень();
	Группа = Номенклатура.Родитель;
	Пока Группа.СкладОтгрузкиКБ = Справочники.Склады.ПустаяСсылка() И УровеньН > 1 Цикл
		Группа = Группа.Родитель;
		УровеньН = УровеньН - 1;
	КонецЦикла;
	Возврат Группа.СкладОтгрузкиКБ;
КонецФункции

Функция НайтиКодГруппыНоменклатуры(Номенклатура, ВыбУровень = 1)
	УровеньН = номенклатура.Уровень();
	Группа = Номенклатура.Родитель;
	Пока УровеньН > ВыбУровень Цикл
		Группа = Группа.Родитель;
		УровеньН = УровеньН - 1;
	КонецЦикла;
	Возврат Группа.код;
КонецФункции
