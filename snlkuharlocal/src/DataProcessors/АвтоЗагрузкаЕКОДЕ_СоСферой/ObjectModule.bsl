					Если СокрЛП(Контрагент.Код)="SSP-8643" Тогда  // метро
						Если СтрокаТЧ.ДопОбработка.Код="ODN-00014" Тогда
							продолжить; // не пишем эту доп обработку.   антикражка и поставщик не пишем
						КонецЕсли;
						
						Если СтрокаТЧ.ДопОбработка.Код="SNL-00036" Тогда
							продолжить; // не пишем эту доп обработку.   белье на вешалках метро не пишем
						КонецЕсли;
						
						
					КонецЕсли;
					
					
					
					Если СокрЛП(Контрагент.Код)="SSP-8643"  или СокрЛП(Контрагент.Код)="SSP-2412"  Тогда  
						// для метро и реал  делаем спец. обработку. 
						
						//Если КоличествоСкладов>1 И (Склад.код="SNL-79" или Склад.код="SNL-22") Тогда     
						//нечаева поменяла склад 22,01,15++
						Если КоличествоСкладов>1 И (Склад.код="STA-10" или Склад.код="STA-20") Тогда     
							//нечаева поменяла склад 22,01,15++
							
							
							
							
							// если склад белье, то одну доп обработку не берем.
							Если СтрокаТЧ.ДопОбработка.Код="ODB-00017" Тогда
								продолжить; // не пишем эту доп обработку.   палетный ярлык не пишем
							КонецЕсли;
						КонецЕсли;
						
						СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
						СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка; // остальные стандартные добавляем
						
					КонецЕсли;
					
				КонецЦикла;  
				//нечаева 23,03,17+++
				// добавляем из пункта доставки доп. обработки.
				Попытка
					Для Каждого СтрокаТЧ Из ПунктДоставки.ВидыДопОбработок Цикл
						СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
						СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
					КонецЦикла;  
				исключение
				КонецПопытки;
				//нечаева 23,03,17---
				
				
				
				
				
				// бельевой склад
				//Если СокрЛП(Контрагент.Код)="SSP-8643" И (Склад.код="SNL-79" или Склад.код="SNL-22") Тогда 
				
				//нечаева поменяла склад 22,01,15++
				Если СокрЛП(Контрагент.Код)="SSP-8643" И (Склад.код="STA-10" или Склад.код="STA-20") Тогда      
					//нечаева поменяла склад 22,01,15++
					
					
					// метро 
					попытка
						СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
						СтрокаДО.ВидДопОбработки=Справочники.ВидыДопОбработки.НайтиПоКоду("SNL-00036"); // белье на вешалках метро				
					исключение
					конецпопытки;
				КонецЕсли;
				
				// когда колготочный склад
				Если СокрЛП(Контрагент.Код)="SSP-8643" И (Склад.код="STD-97" или Склад.код="SNL-82") Тогда 
					// метро 
					попытка
						СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
						//СтрокаДО.ВидДопОбработки=Справочники.ВидыДопОбработки.НайтиПоКоду("ODN-00014");  // антикражка + поставщик  				
						//Теперь другая ДО
						//СтрокаДО.ВидДопОбработки=Справочники.ВидыДопОбработки.НайтиПоКоду("ODN-00014");  // антикражка + поставщик 	
						СтрокаДО.ВидДопОбработки=Справочники.ВидыДопОбработки.НайтиПоКоду("OD7-00101");  // антикражка + поставщик 
						//Кухарь 28.06.17 конец
						
					исключение
					конецпопытки;
				КонецЕсли;
				
				
				
				
				
				//-----------------------------------------------
				
				Менеджер=Контрагент.Менеджер;
				Если Менеджер=Неопределено или Менеджер=Справочники.ФизическиеЛица.ПустаяСсылка() и ПризКр=0 Тогда
					КритичОшибки.Добавить("Для контрагента "+контрагент.наименование+"  код - "+контрагент.код+"  не определен менеджер! Заказ екоде №"+ Номерзаказа );
				Иначе
					Если Не СтрДлина(Менеджер.Емэйл)>2  и ПризКр=0   Тогда
						КритичОшибки.Добавить("Для менеджера "+Менеджер.наименование+"  код - "+Менеджер.код+"  не определен ЕМэйл!" );
					КонецЕсли;
				КонецЕсли;
				//++Данилова Е.В. 30.09.2025  HELP-7048  
				//Подразделение = Контрагент.Менеджер.Подразделение;
				Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Контрагент.Менеджер);
				//--Данилова Е.В. 30.09.2025	
				
				Запрос = Новый Запрос;
				Запрос.Текст=
				"ВЫБРАТЬ
				|	КодыПоставщиков.Ссылка
				|ИЗ
				|	Справочник.КодыПоставщиков КАК КодыПоставщиков
				|ГДЕ
				|	КодыПоставщиков.Владелец = &Контрагент
				|	И КодыПоставщиков.Наименование = &КодДоговора";
				Запрос.УстановитьПараметр("Контрагент",Контрагент);		
				Запрос.УстановитьПараметр("КодДоговора",КодДоговора);		
				Результат=Запрос.Выполнить().Выбрать();
				Результат.Следующий();
				КодПоставщикаКонтрагента = Результат.Ссылка;
				//Катаев- 22/08/14
			КонецЕсли;
			
			//----------------------------------------------
			//доставка
			Если не ПунктДоставки=Неопределено  Тогда 
				Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
