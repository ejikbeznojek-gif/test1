функция ДокументПрописан(Док,состояние)
	
	ДокументПрописан= ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СостояниеЭлектронногоУПД.СостояниеУПД КАК СостояниеУПД,
	               |	СостояниеЭлектронногоУПД.Дата КАК Дата
	               |ИЗ
	               |	РегистрСведений.СостояниеЭлектронногоУПД КАК СостояниеЭлектронногоУПД
	               |ГДЕ
	               |	СостояниеЭлектронногоУПД.Объект = &текдок
	               |	И СостояниеЭлектронногоУПД.СостояниеУПД = &тексост";
	Запрос.УстановитьПараметр("ТекДок", Док.ссылка);
	Запрос.УстановитьПараметр("Тексост", состояние);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество()>0 Тогда
		
		ДокументПрописан = истина;
	КонецЕсли;   
	
	возврат ДокументПрописан;
	
	
