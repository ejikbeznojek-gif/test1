Функция УбратьРБ(ИмяФайла)
	результат = ИмяФайла;
	Для код = 1040 По 1103 Цикл
		результат = стрЗаменить(результат, Символ(код),"_");
	КонецЦикла;
	Возврат результат;
КонецФункции
//Катаев- 08/11/13


Процедура ЗагрузкаАкта(файл) Экспорт
	Отказ = Ложь;
	АктШапка.Очистить();
	стрШапка = АктШапка.Добавить();
	// Считываем файл
	Пока Файл.Прочитать() Цикл
		
		
		//нечаева 14,11,19+++ 
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "AdditionalReferenceNumber" тогда
			// Номер идентификатора акта
			файл.Прочитать(); 
			стрШапка.ИдентификаторАктаПриемки = Файл.Значение;
		КонецЕсли;
		//нечаева 14,11,19---
		
		
		//Катаев+ 20/11/14
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ReceivingAdviceNumber" тогда
			// Номер акта
			файл.Прочитать(); 
			стрШапка.НомерАкта = Файл.Значение;
		КонецЕсли;
		//Катаев- 20/11/14
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ReceivingAdviceDate" тогда
			// Дата приемки
			файл.Прочитать(); 
			ДатаУвед = Файл.Значение;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ReceivingAdviceTime" тогда
			// Время приемки
			файл.Прочитать(); 
			ВремяУвед = Файл.Значение;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "BuyerOrderNumber" тогда
			// Номер заказа
			файл.Прочитать(); 
			стрШапка.НомерЗаказа = Файл.Значение;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "BuyerOrderDate" тогда
			// Дата заказа
			файл.Прочитать();
			стрШапка.ДатаРНК = Файл.Значение
			////Катаев+ 14/04/14 Если в номере РНК используется русская буква Р, то делаем замену;
			////стрШапка.НомерРНК = Файл.Значение;
			//НомерРНК = СтрЗаменить(Файл.Значение, "SSР", "SSP");
			//стрШапка.НомерРНК = НомерРНК;
			////Катаев- 14/04/14
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "DeliveryNoteNumber" тогда
			// Номер РНК
			файл.Прочитать();
			//Катаев+ 21/07/14 Если в номере РНК используется русская буква Р, то делаем замену;
			//стрШапка.НомерРНК = Файл.Значение;
			НомерРНК = СтрЗаменить(Файл.Значение, "SSР", "SSP");
			стрШапка.НомерРНК = НомерРНК;
			//Катаев- 21/07/14
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "DeliveryNoteDate" тогда
			// Дата РНК
			файл.Прочитать();
			стрШапка.ДатаРНК = Файл.Значение;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "Buyer" тогда
			// ИЛН контрагента
			Пока НЕ (Файл.ТипУзла = ТипУзлаXML.КонецЭлемента И Файл.ЛокальноеИмя = "Buyer") цикл
				файл.Прочитать(); 
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ILN" тогда
					файл.Прочитать(); 
					ИЛНКонтрагента=Файл.Значение;
					прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "DeliveryPoint" тогда
			// ИЛН пункта доставки
			Пока НЕ (Файл.ТипУзла = ТипУзлаXML.КонецЭлемента И Файл.ЛокальноеИмя = "DeliveryPoint") цикл
				файл.Прочитать(); 
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ILN" тогда
					файл.Прочитать(); 
					ИЛНПунктаДоставки=Файл.Значение;
					прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// Считываем табличную часть
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "Line-Item" тогда
			стрТаб = АктТаблица.Добавить();
			Пока НЕ (Файл.ТипУзла = ТипУзлаXML.КонецЭлемента И Файл.ЛокальноеИмя = "Line-Item") цикл
				Файл.Прочитать();
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "EAN" тогда
					Файл.Прочитать();
					стрТаб.ШК = Файл.Значение;
				КонецЕсли;
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "BuyerItemCode" тогда
					Файл.Прочитать();
					стрТаб.Артикул = Файл.Значение;
				КонецЕсли;
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ItemDescription" тогда
					файл.Прочитать(); 
					стрТаб.Товар = Файл.Значение;
					стрТаб.НаименованиеКонтрагента = СокрЛП(Файл.Значение);
				КонецЕсли; 
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "OrderedQuantity" тогда
					Файл.Прочитать();
					стрТаб.Заказано = Число(Файл.Значение);
				КонецЕсли;
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "DeliveredQuantity" тогда
					Файл.Прочитать();
					стрТаб.Отправлено = Число(Файл.Значение);
				КонецЕсли;
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "AcceptedQuantity" тогда
					Файл.Прочитать();
					стрТаб.Принято = Число(Файл.Значение);
				КонецЕсли;
				
				//нечаева 14,05,18+++
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "UnitNetPrice" тогда
					Файл.Прочитать();
					стрТаб.ЦенаПриемки = Число(Файл.Значение);
				КонецЕсли;
				//цена с ндс
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "UnitGrossPrice" тогда
					Файл.Прочитать();
					стрТаб.ЦенаПриемкиСНДС = Число(Файл.Значение);
				КонецЕсли;
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "NetAmount" тогда
					Файл.Прочитать();
					стрТаб.СуммаПриемки = Число(Файл.Значение);
				КонецЕсли;
				
				//сумма приемки с ндс
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "GrossAmount" тогда
					Файл.Прочитать();
					стрТаб.СуммаПриемкиСНДС = Число(Файл.Значение);
				КонецЕсли;
				
				//штук в упаковке
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "UnitPacksize" тогда
					Файл.Прочитать();
					стрТаб.ШтВУпаковке = Число(Файл.Значение);
				КонецЕсли;
				//нечаева 14,05,18---
				
				
				//нечаева 18,03,19+++
				// вид упаковки
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "UnitOfMeasure" тогда
					Файл.Прочитать();
					стрТаб.ВидУпаковки = Файл.Значение;
				КонецЕсли;
				//нечаева 18,03,19---
				
				
				
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	Файл.Закрыть();
	
	
	//нечаева 18,03,19+++ Если короба, то сразу перемножаем , переведем в штуки
	Для каждого ТСтр из АктТаблица Цикл
		
		Если ТСтр.видУпаковки = "CT"  и ТСтр.ШтВУпаковке<>0 Тогда
			
			// коробами, например Лента
			//нечаева 18,03,19---
			//нечаева 20,04,23+++
			// для метро берем кратность блочка из матрицы
			ШтВУпаковке = 1;
			
			// найдем кратность по матрице
			Если   НЕ ТСтр.ШтВУпаковке = неопределено Тогда
				
				ШтВУпаковке = ТСтр.ШтВУпаковке;
			иначе
				контрагент = НайтиКонтрагента(ИЛНКонтрагента, ИЛНПунктаДоставки);
				ШтВУпаковке = НайтиКратностьПоМатрице(ТСтр.ШК,ТСтр.Артикул,"",Контрагент,стрШапка.ДатаРНК); //дата рнк
							
			КонецЕсли;	
				
			
			попытка
				ТСтр.Заказано = ТСтр.Заказано * ШтВУпаковке;
			исключение	
			конецПопытки;
			
			
			попытка
				ТСтр.Принято= ТСтр.Принято * ШтВУпаковке;
			исключение	
			конецПопытки;
			//нечаева 20,04,23---		

		КонецЕсли;	
		
	КонецЦикла;
	//Нечаева 18,03,19---
	
	
	// Определяем недоступные параметры
	стрШапка.ДатаПриемаТовара = Дата(СтрЗаменить(ДатаУвед,"-","")+СтрЗаменить(ВремяУвед,":",""));
	// Определяем контрагента
	стрШапка.Контрагент = НайтиКонтрагента(ИЛНКонтрагента, ИЛНПунктаДоставки);
	стрШапка.ПунктДоставки = НайтиПунктДоставкиПоГЛН(ИЛНПунктаДоставки);
	Если стрШапка.Контрагент = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	//нечаева 08,04,19++
	стрШапка.НомерЗаказа = УбратьНули(стрШапка.НомерЗаказа,стрШапка.Контрагент.УбиратьНулиПередНомеромЗаказа);
	//нечаева 08,04,19---
	// Заполняем пустые колонки в табличной части
	Для Каждого стр из АктТаблица Цикл
		Номенклатура = НайтиПОШКМатрицаАкт(стр.ШК,стр.Артикул,"",стрШапка.Контрагент,стрШапка.ДатаРНК);
		Если Номенклатура = Неопределено или Номенклатура=Справочники.Номенклатура.ПустаяСсылка() Тогда
			//Катаев+ 28/03/14 Для Окей ШК и Артикул поменяны местами
			//Строка="Не найден товар с типом ШК Штука: "+стр.ШК + " Артикул: " + стр.Артикул;
			Если стрШапка.Контрагент.ИспШтрихКодАртикул = 5 Тогда
				Строка="Не найден товар с типом ШК Штука: "+стр.Артикул;
			Иначе
				Строка="Не найден товар с типом ШК Штука: "+стр.ШК + " Артикул: " + стр.Артикул;
			КонецЕсли;
			//Катаев- 28/03/14
			Ошибки.Добавить(Строка);
		Иначе
			стр.Номенклатура = Номенклатура;
			стр.Склад = НайтиСклад(Номенклатура);
		КонецЕсли;
		
		//нечаева 15,10,18++
		Если Стр.склад  = Неопределено Тогда
			Стр.Склад = справочники.Склады.НайтиПоКоду("STD-97");
		КонецЕсли;
		//нечаева 15,10,18---
		
		
	КонецЦикла;
	// Определяем склады отгрузки
	Склады = АктТаблица.Скопировать();
	Склады.Свернуть("Склад");
	Для каждого стр из Склады Цикл
		//Если стр.Склад = Справочники.Склады.ПустаяСсылка() Или стр.Склад = Неопределено Тогда
		//	Продолжить;
		//КонецЕсли;
		Отбор = Новый Структура("Склад");
		Отбор.Вставить("Склад", стр.Склад);
		АктТаблица1 = АктТаблица.Скопировать(Отбор);
		АктТаблица1.Колонки.Добавить("РНК");
		// Определяем РНК
		// Катаев+ 22/03/13 РНК может быть несколько.
		спРНК = НайтиРНК(стрШапка);
		//нечаева 21,10,19++
		Если спРНК= Неопределено Тогда
			попытка
				Если НЕ стрШапка.Контрагент.код="SSP-2270" Тогда
					КритичОшибки.Добавить("Уведомление о поступлении товара - "+СтрШапка.НомерАкта+". Акт приемки по заказу № "+стрШапка.НомерЗаказа+" (№ РНК - "+стрШапка.РНК+") не был записан. Причина ошибки -"+ОписаниеОшибки());
				КонецЕсли;
			исключение
			конецПопытки;
		КонецЕсли;
		//нечаева 21,10,19---
		Если спРНК <> Неопределено Тогда
			Для Каждого тРНК из спРНК Цикл
				РНК = тРНК.Значение;
				тз = РНК.Товары.Выгрузить();
				Для Каждого стр из АктТаблица1 Цикл
					Если стр.РНК = Неопределено Тогда
						НайденаяСтрока = тз.Найти(стр.Номенклатура,"Номенклатура");
						Если НайденаяСтрока <> Неопределено Тогда
							стр.РНК = РНК;
							Если стр.Заказано = 0 или стр.Заказано = Неопределено Тогда
								стр.Заказано = НайденаяСтрока.Заявка;
							КонецЕсли;
							Если стр.Отправлено = 0 или стр.Отправлено = Неопределено Тогда
								стр.Отправлено = НайденаяСтрока.Количество;
							КонецЕсли;
						Иначе
							
							//нечаева 24,09,18+++
							//х5
							// Если товар относится к той же группе что и Группа товаров у РНК, то заполняем РНК
							// если не нашли и это паллет для х5
							Если стрШапка.Контрагент.родитель.код = "SSR-4117" и стр.Артикул ="3354748"  ТОгда
								
								Стр.номенклатура = справочники.Номенклатура.НайтиПоКоду("ODB-000325");
								//отправлено берем из РНК
								Стр.Отправлено  = РНк.количествоПаллет;
								
							КонецЕсли;
							
							// для экспозиторов еще отдельно загрузку сделать   х5
							Если стрШапка.Контрагент.родитель.код = "SSR-4117" и стр.Артикул ="3626191"  ТОгда
								
								Стр.номенклатура = справочники.Номенклатура.НайтиПоКоду("SNL-398078");
								
							КонецЕсли;
							
							попытка
								Бренд = стр.Номенклатура.Родитель.Брэнд;
								Если Найти(РНК.ГруппыТоваров, Бренд) > 0 Тогда
									стр.РНК = РНК;
								КонецЕсли;
							исключение
								Если  спРНК.количество() = 1 Тогда
									стр.РНК = РНК;
								КонецЕсли;
							конецПопытки;
							
							
							//нечаева 24,09,18---
							
							
							
							//Бренд = стр.Номенклатура.Родитель.Брэнд;
							//Если Найти(РНК.ГруппыТоваров, Бренд) > 0 Тогда
							//	стр.РНК = РНК;
							//КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				РНК1 = РНК;
			КонецЦикла;
