			//КонецЕсли;	
			//Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
			//	ПунктПерегруза=ПунктДоставки.ПунктПерегруза;	
			//	ДокОбъект.ПунктПерегруза=ПунктПерегруза;
			//КонецЕсли;		
			Если ПунктДоставки.ТипДоставки = Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда
				Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
