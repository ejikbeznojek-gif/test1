Функция SQLiteInit(ФайлБД) Экспорт
	SQLiteObject = Новый COMОбъект("ADODB.Connection");
	SQLiteConnectionString = "DRIVER=SQLite3 ODBC Driver;Database=" + ФайлБД + ";";
	Попытка
		ЗаписатьВЛог("Тестирование екод","Путь к базе :"+SQLiteConnectionString,"Информация");
		SQLiteObject.Open(SQLiteConnectionString);
		
	Исключение
		// Сообщить("Невозможно подключится к драйверу SQLite. Возможно файл [" + ФайлБД + "] открыт другим пользователем или программой!");
		ЗаписатьВЛог("Тестирование екод","Инициализация: "+ОписаниеОшибки(),"Информация");
		Возврат Ложь;
	КонецПопытки;
	Возврат Истина;
КонецФункции


Функция SQLiteQuery(Запрос) Экспорт
	SQLiteRS = Новый COMОбъект("ADODB.Recordset");
	Попытка
		SQLiteRS = SQLiteObject.Execute(Запрос);
	Исключение
		//Сообщить("Невозможно выполнить SQL запрос " + ОписаниеОшибки(), СтатусСообщения.Важное);
		ЗаписатьВЛог("Тестирование екод","Невозможно выполнить SQL запрос " + ОписаниеОшибки(),"Информация");
		Возврат Ложь;
	КонецПопытки;
	
	Возврат SQLiteRS;
КонецФункции


// отрезает нужное количество от пути "/"
Функция НайтиПодстроку(СтрокаПоиска,Итератор)
	
	Итератор=Итератор-1;
	Поиск1=Найти(СтрокаПоиска,"\"); 
	СтрокаПоиска =  Прав(СтрокаПоиска,СтрДлина(СтрокаПоиска)-Поиск1);
	Если Итератор=0 Тогда 
		
		возврат СтрокаПоиска;
	Иначе
		
		возврат НайтиПодстроку(СтрокаПоиска,Итератор);
	КонецЕсли;
	
	
КонецФункции

