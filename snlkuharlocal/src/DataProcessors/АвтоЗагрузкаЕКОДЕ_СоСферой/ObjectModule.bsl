				//// если ашан то :
				//Если контрагент=Справочники.Контрагенты.НайтиПоКоду("SSP-2450") ТОгда
				//	Если Склад=Справочники.Склады.НайтиПоКоду("STD-97") тОгда
				//		КодПоставщикаКонтрагента=Справочники.КодыПоставщиков.НайтиПоКоду("SSP-000003");
				//	Иначе
				//		КодПоставщикаКонтрагента=Справочники.КодыПоставщиков.НайтиПоКоду("SSP-000002");
				//	КонецЕсли;
				//КонецЕсли;
