		Если результат.Ошибки.Количество() > 0  Тогда
			
			Для каждого Данныеошибки Из результат.Ошибки Цикл
				
				Сообщить(Данныеошибки); 
				
			КонецЦикла;		
			
		КонецЕсли;
		
		РезультатОбщий.ОбработаноОбъектов = РезультатОбщий.ОбработаноОбъектов + Результат.ОбработаноОбъектов; 
		
		Для каждого СоздДокумент Из Результат.Данные Цикл
			
