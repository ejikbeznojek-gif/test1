			Сч = 1;
			
			Для Каждого Часть Из Части Цикл		
				Для Каждого КиЗ Из Часть Цикл
					СтрокаТР = ТР.Добавить();
					
					СтрокаТР.Часть 			= Сч;
					СтрокаТР.Номенклатура   = КиЗ.Ключ;
					
					СтруктураКлюча = КиЗ.Значение; 
					СтрокаТР.Количество		= СтруктураКлюча.Количество;
					
					МассивДо = СтруктураКлюча.МассивДО; 
					
					Для каждого Основание Из МассивДо Цикл
						
						СтрокаТРОснование = ТРОснования.Добавить(); 	
						СтрокаТРОснование.Часть = Сч;
						СтрокаТРОснование.ДокументОснование = Основание; 
