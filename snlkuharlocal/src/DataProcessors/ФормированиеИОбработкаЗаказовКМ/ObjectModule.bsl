Процедура ПроставитьВведенВОборотПоНакладным(ПараметрыОтработки)
	
	//+ заказы км на комплектующие 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная
	|ПОМЕСТИТЬ ВТДокументыОснования
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.ЗаказаныМарки)
	|	И ВЫБОР
	|			КОГДА ТИПЗНАЧЕНИЯ(СтатусыЗаказаМарокДляДокументов.Накладная) = ТИП(Документ.РасходнаяНакладная)
	|				ТОГДА СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В (&Подразделение)
	|			ИНАЧЕ СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В (&Подразделение)
	|		КОНЕЦ
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДокументыОснования.Накладная КАК Накладная,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК ЗаказКМ
	|ПОМЕСТИТЬ ВТЗаказыКМ_Основные
	|ИЗ
	|	ВТДокументыОснования КАК ВТДокументыОснования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументыОснования КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|			ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|				И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|		ПО ВТДокументыОснования.Накладная = ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТЗаказыКМ.Накладная КАК Накладная,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК ЗаказКМ
	|ПОМЕСТИТЬ ВТЗаказыКМ
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЗаказыКМ_Основные КАК ВТЗаказыКМ
	|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = ВТЗаказыКМ.ЗаказКМ
	|			И (ВТЗаказыКМ.ЗаказКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТЗаказыКМ.Накладная,
	|	ВТЗаказыКМ.ЗаказКМ
	|ИЗ
	|	ВТЗаказыКМ_Основные КАК ВТЗаказыКМ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Накладная КАК Накладная
	|ПОМЕСТИТЬ ВтНакладныеНезавершенные
	|ИЗ
	|	ВТЗаказыКМ КАК ВТЗаказыКМ
	|ГДЕ
	|	ВТЗаказыКМ.ЗаказКМ.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Накладная
	|ИЗ
	|	ВТЗаказыКМ КАК ВТЗаказыКМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПДок
	|		ПО (МаркировкаТоваровИСМПДок.ДокументОснование = ВТЗаказыКМ.ЗаказКМ)
	|			И (МаркировкаТоваровИСМПДок.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ФормированиеНабора))
	|			И (МаркировкаТоваровИСМПДок.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|			И (МаркировкаТоваровИСМПДок.Проведен)
	|ГДЕ
	|	ВТЗаказыКМ.ЗаказКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|	И МаркировкаТоваровИСМПДок.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Накладная
	|ИЗ
	|	ВТЗаказыКМ КАК ВТЗаказыКМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПДок
	|		ПО (МаркировкаТоваровИСМПДок.ДокументОснование = ВТЗаказыКМ.ЗаказКМ)
	|			И (МаркировкаТоваровИСМПДок.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВоборот)
	|				ИЛИ МаркировкаТоваровИСМПДок.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.перемаркировка))
	|			И (МаркировкаТоваровИСМПДок.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|			И (МаркировкаТоваровИСМПДок.Проведен)
	|ГДЕ
	|	ВТЗаказыКМ.ЗаказКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|	И МаркировкаТоваровИСМПДок.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Накладная
	|ИЗ
	|	ВТЗаказыКМ КАК ВТЗаказыКМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПДок
	|		ПО (МаркировкаТоваровИСМПДок.ДокументОснование = ВТЗаказыКМ.ЗаказКМ)
	|			И (МаркировкаТоваровИСМПДок.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВоборот)
	|				ИЛИ МаркировкаТоваровИСМПДок.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.перемаркировка))
	|			И (МаркировкаТоваровИСМПДок.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|			И (МаркировкаТоваровИСМПДок.Проведен)
	|ГДЕ
	|	ВТЗаказыКМ.ЗаказКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Товар)
	|	И ТИПЗНАЧЕНИЯ(ВТЗаказыКМ.ЗаказКМ.ДокументОснование) <> ТИП(Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ)
	|	И МаркировкаТоваровИСМПДок.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Накладная КАК Накладная
	|ИЗ
	|	ВТЗаказыКМ КАК ВТЗаказыКМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтНакладныеНезавершенные КАК ВтНакладныеНезавершенные
	|		ПО ВТЗаказыКМ.Накладная = ВтНакладныеНезавершенные.Накладная
	|ГДЕ
	|	ВтНакладныеНезавершенные.Накладная ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Подразделение",ПараметрыОтработки.Подразделение);
	Выборка = Запрос.Выполнить().Выбрать(); 
	//НачатьТранзакцию(); 	
	Пока Выборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.СтатусыЗаказаМарокДляДокументов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Накладная.Установить(Выборка.Накладная);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() > 0 Тогда 
			НоваяЗапись = НаборЗаписей[0];
			Если НоваяЗапись.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.ЗаказаныМарки Тогда
				НоваяЗапись.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.МаркиВведеныВОборот;
				НоваяЗапись.ДатаВводаВОборот = ТекущаяДата();
				НаборЗаписей.Записать();
				Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
