Процедура ОтработатьОшибкиПолученияКМ()

	ВыборкаДетальныеЗаписи = ПолучитьДанныеИзОчередиДляОтработки("ПолучитьКМ_ЗаказКм",Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки);
	МассивПовторнаяОтправкаВСУЗ = Новый Массив; 
	МассивПовторнаяОтправкаПолучениеКМ = Новый Массив; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	
		ЗаказКМ = ВыборкаДетальныеЗаписи.ссылка; 
		
		Если СтрНайти(ЗаказКМ.ТекстОшибки,"Ошибка: 3360") > 0 Тогда
			МассивПовторнаяОтправкаПолучениеКМ.Добавить(ЗаказКМ);
			Продолжить; 
		КонецЕсли;
		
		Если СтрНайти(ЗаказКМ.ТекстОшибки,"Недопустимый статус кода идентификации") > 0 Тогда
			МассивПовторнаяОтправкаВСУЗ.Добавить(ЗаказКМ);
			Продолжить; 
		КонецЕсли;		
	
	КонецЦикла;	
	
	Для каждого ДокументЗаказа Из МассивПовторнаяОтправкаПолучениеКМ Цикл 		
		УстановитьРеквизитыОбъекта(ДокументЗаказа, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.Обрабатывается)); 
	КонецЦикла;
	
	Для каждого ДокументЗаказа Из МассивПовторнаяОтправкаВСУЗ Цикл
		
		УстановитьРеквизитыОбъекта(ДокументЗаказа, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.КОбработке));
		
	КонецЦикла; 
	
	ОтправитьНаОтработкуВЧЗЗАказыКМ(МассивПовторнаяОтправкаВСУЗ); 
	

КонецПроцедуры 


