				ТЧОснования.Колонки.Добавить("Количество"); 
				
				Пока Выборка.Следующий() Цикл
					ОтборНакладные = Новый структура("ДокументОснование",Выборка.Накладная);
					СтрокиОснования = ТЧОснования.НайтиСтроки(ОтборНакладные);
					Если СтрокиОснования.Количество() >  0 Тогда
						
						Продолжить;	
						
					КонецЕсли;
					НоваяСтрока = ТЧОснования.Добавить(); 
					НоваяСтрока.ДокументОснование 	= Выборка.Накладная; 
					НоваяСтрока.Количество 			= Выборка.Количество; 
					
