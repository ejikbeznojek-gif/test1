Процедура КорректировкаЗаказовПоКоличествуПолученныхКодов() Экспорт 

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗаказыКМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВтЗаказыГН
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ВТЗаказыКМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПФормНабора
	|		ПО (МаркировкаТоваровИСМПФормНабора.ДокументОснование = ВТЗаказыКМ.Ссылка)
	|			И (МаркировкаТоваровИСМПФормНабора.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ФормированиеНабора))
	|			И (МаркировкаТоваровИСМПФормНабора.Проведен)
	|ГДЕ
	|	ВТЗаказыКМ.Проведен
	|	И ВТЗаказыКМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан)
	|	И (ВТЗаказыКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект)
	|			ИЛИ ВТЗаказыКМ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект)
	|				И ВТЗаказыКМ.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Импорт))
	|	И (МаркировкаТоваровИСМПФормНабора.Ссылка ЕСТЬ NULL
	|			ИЛИ МаркировкаТоваровИСМПФормНабора.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|	И ВТЗаказыКМ.Дата > &ДатаЗапретаРедактирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтЗаказыГН.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ВтЗаказыГН.Ссылка.КоличествоКомплект) КАК СсылкаКоличествоКомплект,
	|	СУММА(ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолученоКодов) КАК ПолученоКодов,
	|	ВтЗаказыГН.Ссылка.ВидКомплекта КАК ВидКомплекта
	|ИЗ
	|	ВтЗаказыГН КАК ВтЗаказыГН
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = ВтЗаказыГН.Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтЗаказыГН.Ссылка,
	|	ВтЗаказыГН.Ссылка.ВидКомплекта
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолученоКодов) = МАКСИМУМ(ВтЗаказыГН.Ссылка.КоличествоКомплект) И
	|	МАКСИМУМ(ВтЗаказыГН.Ссылка.ПолученоКодовКомплект) <> МАКСИМУМ(ВтЗаказыГН.Ссылка.КоличествоКомплект)"; 
	Запрос.УстановитьПараметр("ДатаЗапретаРедактирования",Константы.ДатаЗапретаРедактирования.Получить());
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Пока Выборка.Следующий()  Цикл
		
		ЗаказОб = Выборка.ссылка.ПолучитьОбъект(); 	
		ЗаказОб.ПолученоКодовКомплект = Выборка.ПолученоКодов; 
		ЗаказОб.Записать(); 
		
	КонецЦикла;

КонецПроцедуры
