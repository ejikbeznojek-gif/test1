	АвтоматизацияРаботыЗаказовКМНД 			= Документы.АвтоматизацияРаботыЗаказовКМ.СоздатьДокумент();
	АвтоматизацияРаботыЗаказовКМНД.Дата 	= ДатаЗапускаЭтапа;
