Функция ПолучитьДанныеСертификата(ОрганизацияСуз = Неопределено) Экспорт
	
	Если ОрганизацияСуз = Неопределено Тогда
	
		ОрганизацияСуз = Организация; 	
	
	КонецЕсли;

	Сертификаты = ОбменСЧЗЧерезОУКЭП.ПолучитьСписокСертификатовСИНН();
	
	СУЗСерт 			= Неопределено;
	ЗначениеСертификата = Неопределено; 
	
	Для Каждого Серт Из Сертификаты Цикл 		
		
		СУЗСерт = ПолучитьСУЗПоОрганизации(ОрганизацияСуз,Серт.Представление);
		
		Если ЗначениеЗаполнено(СУЗСерт)  Тогда
			
			ЗначениеСертификата = Серт.Значение; 
			
			Прервать; 
		
		КонецЕсли;
		
		
	КонецЦикла;
	
	Если СУЗСерт = неопределено
		ИЛИ ЗначениеСертификата = Неопределено Тогда
	
		Возврат Неопределено; 
	
	КонецЕсли;
