КонецПроцедуры

Процедура ОтправитьВОчередьЗаказыКМНеОтправленные()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.АвтоматизацияРаботыЗаказовКМ.ЗаказыКМ КАК АвтоматизацияРаботыЗаказовКМЗаказыКМ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АвтоматизацияРаботыЗаказовКМ КАК АвтоматизацияРаботыЗаказовКМ
		|		ПО АвтоматизацияРаботыЗаказовКМЗаказыКМ.Ссылка = АвтоматизацияРаботыЗаказовКМ.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
		//|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументыОснования КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования
		//|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
		//|				ПО (СтатусыЗаказаМарокДляДокументов.Накладная = ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.ДокументОснование)
		//|					И (СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказаКодовМаркировки.ЗаказаныМарки))
		//|			ПО (ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка)
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
		|			ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка = ОчередьЗадач.Основание
		|				И (ОчередьЗадач.ИмяОчереди = ""ПолучитьКМ_ЗаказКм"")
		|		ПО АвтоматизацияРаботыЗаказовКМЗаказыКМ.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
		|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СозданАвтоматически)
		|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
		|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.ВРаботе))
		|			//И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = НЕОПРЕДЕЛЕНО)
		|ГДЕ
		|	НЕ АвтоматизацияРаботыЗаказовКМ.ПометкаУдаления
		|	И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ИД_ДокументаЧЗ = """"
		|	И АвтоматизацияРаботыЗаказовКМ.Дата >= &ДатаЗакрытияПериода
		|	И ОчередьЗадач.Основание ЕСТЬ NULL"; 	
		
			
	Запрос.УстановитьПараметр("ДатаЗакрытияПериода", КонецДня(Константы.ДатаЗапретаРедактирования.Получить()));
	
	МассивДляОтправки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ссылка");
	
	Если МассивДляОтправки.Количество() > 0  Тогда
		
		ОтправитьНаОтработкуВЧЗЗАказыКМ(МассивДляОтправки);	
		
	КонецЕсли;  


КонецПроцедуры
