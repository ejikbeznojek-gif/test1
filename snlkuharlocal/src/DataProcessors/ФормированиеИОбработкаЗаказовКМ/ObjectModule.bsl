Процедура СоздатьЗаказыКМПоПеремаркировке()
	
	ЗаписатьВлог("Заказы КМ Перемаркировка","Создание заказов КМ по перемаркировке.Начало","Информация"); 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Перемаркировка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Перемаркировка КАК Перемаркировка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументОснование = Перемаркировка.Ссылка
	|		И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен
	|ГДЕ
	|	Перемаркировка.Проведен
	|	И Перемаркировка.Статус = ЗНАЧЕНИЕ(перечисление.СтатусыПеремаркировки.КОтработкеЧЗ)
	|	И ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка ЕСТЬ NULL
	|	И Перемаркировка.Дата >= ДОБАВИТЬКДАТЕ(&ДатаЗапретаРедактирования, МЕСЯЦ, -1)";

	Запрос.УстановитьПараметр("ДатаЗапретаРедактирования", КонецДня(Константы.ДатаЗапретаРедактирования.Получить()));

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	НачатьТранзакцию();
	СОшибками = Ложь; 
	МассивЗаказов = Новый Массив; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РезультатСоздания = Документы.Перемаркировка.СоздатьЗаказыКодовМаркировки(ВыборкаДетальныеЗаписи.ссылка);
		Если Не РезультатСоздания.Успешно Тогда
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			СОшибками = Истина; 
			Прервать; 
		Иначе 
			Для каждого ЗаказКМ Из РезультатСоздания.Данные Цикл
				
				МассивЗаказов.Добавить(ЗаказКМ); 
				
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;  
	
	Если НЕ СОшибками Тогда
		
		АвтоматизацияРаботыЗаказовКМНД 			= Документы.АвтоматизацияРаботыЗаказовКМ.СоздатьДокумент();
		АвтоматизацияРаботыЗаказовКМНД.Дата 	= ТекущаяДатаСеанса();
		АвтоматизацияРаботыЗаказовКМНД.Автор	= ПараметрыСеанса.Пользователь; 
		АвтоматизацияРаботыЗаказовКМНД.Комментарий = "Созданные заказы КМ по перемаркировке"; 
		
		Если МассивЗаказов.Количество() > 0  Тогда
			
			Для каждого ДокЗаказКМ Из МассивЗаказов Цикл
				
				СтрокаТЧ = АвтоматизацияРаботыЗаказовКМНД.ЗаказыКМ.Добавить(); 
				СтрокаТЧ.ЗаказКМ = ДокЗаказКМ; 
				
			КонецЦикла;
			АвтоматизацияРаботыЗаказовКМНД.Записать();
		КонецЕсли;		
	КонецЕсли;


	Если ТранзакцияАктивна() Тогда
		ЗафиксироватьТранзакцию();
		ЗаписатьВлог("Заказы КМ Перемаркировка", "Создание заказов КМ по перемаркировке.Успешно. Окончание",
			"Информация"); 	
	Иначе
		ЗаписатьВлог("Заказы КМ Перемаркировка", "Создание заказов КМ по перемаркировке.Ошибка выполнения. Окончание",
			"Ошибка");
	КонецЕсли; 
	
	Если  НЕ СОшибками 
		И МассивЗаказов.Количество() > 0 Тогда 
		ОтправитьНаОтработкуВЧЗЗАказыКМ(МассивЗаказов); 
	КонецЕсли;
КонецПроцедуры
