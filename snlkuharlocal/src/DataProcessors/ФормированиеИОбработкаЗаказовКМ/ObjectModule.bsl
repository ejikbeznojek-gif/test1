Функция СоздатьЗаказыКМПоЧастям(Запрос, Знач Организация, Знач ПодразделениеЗначение, Знач ЧастиПоВидамКомплектов)
	
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Для каждого ЧастьПоВидамКомплектов  Из ЧастиПоВидамКомплектов Цикл
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Части ИЗ &Части КАК Части
		|;
		|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Части_ДО ИЗ &ЧастиДО КАК Части
		|;
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	ВТ_Части_ДО; 
		|ВЫБРАТЬ
		|	Номенклатура.ГТИН КАК ГТИН,
		|	*
		|ИЗ
		|	ВТ_Части
		|ИТОГИ ПО
		|	Часть
		|";
		
		Запрос.УстановитьПараметр("Части",ЧастьПоВидамКомплектов.Значение.Части);
		Запрос.УстановитьПараметр("ЧастиДО",ЧастьПоВидамКомплектов.Значение.ЧастиДо); 
		
		рЗапроса 		= Запрос.ВыполнитьПакет();
		
		РЗапросаЧасти = рЗапроса[3]; 
		Выборка_Часть 	= РЗапросаЧасти.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Часть");	
		
		Если РЗапросаЧасти.Пустой() Тогда
			//Результат.Ошибки.Добавить("Не найдено данных для обработки !");		
		КонецЕсли;
		
		РЗапросаЧастиДО = рЗапроса[2];
		Если РЗапросаЧастиДО.Пустой() Тогда
			//Результат.Ошибки.Добавить("Не найдено документов оснований для обработки !");		
		КонецЕсли;
		Выборка_Часть_ДО = РЗапросаЧастиДО.выбрать(); 
		
		//НачатьТранзакцию(); 	
		Пока Выборка_Часть.Следующий() Цикл
			
			ДокОбъект = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
			
			ДокОбъект.Дата			= ТекущаяДата();
			ДокОбъект.Заполнить(Организация);		
			ДокОбъект.ПодразделениеНанесения = ПодразделениеЗначение; 
			ДокОбъект.СозданАвтоматически = истина; 
			
			ДокОбъект.Комментарий	= "Пополнение запаса КМ.";
			
			ДокОбъект.Товары.Очистить();
			
			Выборка = Выборка_Часть.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаТЧ = ДокОбъект.Товары.Добавить();			
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
			КонецЦикла;
			
			ОтборПоОснованиям = Новый Структура("Часть",Выборка_Часть.Часть);
			Пока Выборка_Часть_ДО.НайтиСледующий(ОтборПоОснованиям) Цикл
				
				//++Данилова Е.В. 29.07.2025
				Если ДокОбъект.ДокументыОснования.Найти(Выборка_Часть_ДО.ДокументОснование,"ДокументОснование") <> Неопределено Тогда
					Продолжить;
				КонецЕсли; 
				//--Данилова Е.В. 29.07.2025
				СтрокаТЧ = ДокОбъект.ДокументыОснования.Добавить();			
				СтрокаТЧ.ДокументОснование = Выборка_Часть_ДО.ДокументОснование; 	
				
			КонецЦикла; 
			//++Данилова Е.В. 16.10.2025 MARK-3132
			Выборка_Часть_ДО.Сбросить(); 
			//--Данилова Е.В. 16.10.2025
			
			ДокОбъект.ПометкаУдаления = Ложь; 
			Попытка
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				Результат.Ошибки.Добавить(ОписаниеОшибки());
				
				 
				//Если  ТранзакцияАктивна() Тогда
				//
				//	 ОтменитьТранзакцию();
				//
				// КонецЕсли;
				 
				 Возврат Результат;
				 
			КонецПопытки;
			
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
			Результат.Данные.Добавить(ДокОбъект.Ссылка);
			
			Если ДокОбъект.Ссылка.ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
			    //здесь надо в Заказ КМ внести изменения , чтобы отдавал данные 
				РезультатОтработки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьЗаказыКМКомплектующие(ДокОбъект.Ссылка);
				Если РезультатОтработки.Успешно Тогда
					
					Для каждого ДокументОтработки Из РезультатОтработки.Данные Цикл
						
						Результат.Данные.Добавить(ДокументОтработки);
						
					КонецЦикла;	
				ИначеЕсли  РезультатОтработки.Ошибки.Количество() > 0 Тогда  
					
					Для каждого ОшибкаОтработки Из РезультатОтработки.Ошибки Цикл
						
						Результат.Ошибки.Добавить(ОшибкаОтработки);
						
					КонецЦикла;
				КонецЕсли;
			    
			КонецЕсли;
		КонецЦикла;	
		
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0 И Результат.ОбработаноОбъектов>0);
	//Если ТранзакцияАктивна() Тогда
	//	
	//	ЗафиксироватьТранзакцию();	
	//	
	//КонецЕсли;
	Возврат Результат;
	
КонецФункции

Функция ПроставитьПоНакладнымМаркиЗаказаны(Знач ДокументыЗаказыКМ,Знач НакладныеБезТоваров)
    Успешно = Ложь; 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.ДокументОснование КАК ДокументОснование
		|ИЗ
		|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ДокументыОснования КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
		|		ПО ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
		|		ПО (СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.ТребуетсяЗаказМарок))
		|			И (СтатусыЗаказаМарокДляДокументов.Накладная = ЗаказНаЭмиссиюКодовМаркировкиСУЗДокументыОснования.ДокументОснование)
		|ГДЕ
		|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка В(&ЗаказыКМ)";
	
	Запрос.УстановитьПараметр("ЗаказыКМ", ДокументыЗаказыКМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	//НачатьТранзакцию(); 	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		Если НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДокументОснование) Тогда
			
			Продолжить; 
			
		КонецЕсли;
		МенеджерЗаписи = РегистрыСведений.СтатусыЗаказаМарокДляДокументов.СоздатьМенеджерЗаписи(); 
		МенеджерЗаписи.Накладная = ВыборкаДетальныеЗаписи.ДокументОснование; 
		МенеджерЗаписи.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.ЗаказаныМарки; 
		МенеджерЗаписи.ДатаЗаказаМарок = ТекущаяДата();
		МенеджерЗаписи.Записать(); 
	КонецЦикла;
	
	Если НакладныеБезТоваров.Количество() > 0 Тогда
		
		Для каждого  Накладная Из НакладныеБезТоваров Цикл
			
			МенеджерЗаписи = РегистрыСведений.СтатусыЗаказаМарокДляДокументов.СоздатьМенеджерЗаписи(); 
			МенеджерЗаписи.Накладная = Накладная; 
			МенеджерЗаписи.СтатусыЗаказаКодовМаркировки = Перечисления.СтатусыЗаказаКодовМаркировки.МаркиВведеныВОборот; 
			МенеджерЗаписи.ДатаВводаВОборот = ТекущаяДата();
			МенеджерЗаписи.Записать(); 
			
			Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
				//для ЕКата
				
				Если Накладная.СостояниеНакладной = Перечисления.СостоянияНакладной.ЗаказКМЧЗ Тогда
					
					НакладнаяОбъект =  Накладная.ПолучитьОбъект(); 
					НакладнаяОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.ПолученоСкладом;
					НакладнаяОбъект.Записать(); 
					
				КонецЕсли;
				ПланыОбмена.ЗарегистрироватьИзменения(ПланыОбмена.Основной.НайтиПоКоду(Накладная.Склад.КодФизическогоУзла),Накладная);
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЕсли;
		
	Успешно = Истина; 
	//КонецЕсли;
	
	
     Возврат Успешно; 

КонецФункции // ПроставитьПоНакладнымМаркиЗаказаны()  

Функция ОтправитьНаОтработкуВЧЗЗАказыКМ(Знач МассивЗаказовКМ)  Экспорт 
	Если МассивЗаказовКМ = неопределено Тогда
	
		МассивЗаказовКМ = ЗаказыКМ.ВыгрузитьКолонку("ЗаказКМ"); 
	
	КонецЕсли; 
	
	ДанныеСертификата = ПолучитьДанныеСертификата(); 
	Если ДанныеСертификата = неопределено Тогда
		
		ЗаписатьВЛог("ОтправкаВСУЗЗаказКМРегламент", "Не найден действующий сертификат для ЧЗ по организации " + Строка(Организация),"Ошибка!!!");
		
		Возврат неопределено; 
		//++Данилова Е.В. 16.06.2026 без задачи (код ревью)	
		//Иначе
		//--Данилова Е.В. 16.06.2026 	
		
	КонецЕсли;    
	
	Для каждого ДокСсылка Из МассивЗаказовКМ Цикл   
			
		ОбработкаПроверки = Обработки.ПроверкаКарточекДляНК.Создать();
		тОшибок = ОбработкаПроверки.ПроверитьДанныеТоваровДляМаркировки(ДокСсылка, , Ложь);
		тОшибок.Очистить(); 
		Если тОшибок.Количество() = 0 Тогда
			рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередОтправкойВЧЗ(ДокСсылка);
			
			Если рПроверки.Успешно Тогда
				
				пМетода		= Новый Структура("ДокСсылка,ДопПараметры", ДокСсылка,ДанныеСертификата);
				пОбработки 	= Новый Структура("ПараметрыМетода", пМетода);
				
				РезультатСозданияЗадачи =  РегистрыСведений.ОчередьЗадач.СоздатьЗадачу("Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОтправитьНаОбработкуВСУЗ", "ОтправкаВСУЗЗаказКМ", ДокСсылка, пОбработки);
				
				Если РезультатСозданияЗадачи.Успешно Тогда
					
					СтрСообщение = СтрШаблон("Отправлен в СУЗ %1",ДокСсылка); 
					ЗаписатьВЛог("ОтправкаВСУЗЗаказКМРегламент", СтрСообщение,"Информация"); 	
				Иначе 
					СтрСообщение = СтрШаблон("НЕ Отправлен в СУЗ %1",ДокСсылка); 
					ЗаписатьВЛог("ОтправкаВСУЗЗаказКМРегламент", СтрСообщение,"Ошибка!!!"); 
				КонецЕсли;
				
				Попытка
					СтрокаЗапроса = "ping -n 1 -w "+Формат(1000 * 1, "ЧДЦ=0; ЧГ=") + " 127.255.255.255";
					WshShell = Новый COMОбъект("WScript.Shell");
					WshShell.Run(СтрокаЗапроса, 0, -1);
				Исключение
				КонецПопытки;
				
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
КонецФункции // ОтправитьНаОтработкуВЧЗЗАказыКМ()

Функция ПолучитьКМПоЗаказамКМ()
	
	
	ВыборкаДетальныеЗаписи = ПолучитьДанныеИзОчередиДляОтработки("ОтправкаВСУЗЗаказКМ",Перечисления.СтатусыДокументовМаркировки.Обрабатывается);  	
	
	ДанныеСертификата = ПолучитьДанныеСертификата(); 
	Если ДанныеСертификата = неопределено Тогда
		
		ЗаписатьВЛог("ПолучитьКМПоЗаказамКМРегламент", "Не найден действующий сертификат для ЧЗ по организации " + Строка(Организация),"Ошибка!!!");
		
		Возврат неопределено; 
		
	Иначе
		
		
		
	КонецЕсли; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 	
		
		рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередПолучениемИзЧЗ(ВыборкаДетальныеЗаписи.ссылка);
		Если рПроверки.Успешно Тогда
			
			пМетода		= Новый Структура("ДокСсылка,ДопПараметры", ВыборкаДетальныеЗаписи.ссылка,ДанныеСертификата);
			пОбработки 	= Новый Структура("ПараметрыМетода", пМетода);
			
			РезультатСозданияЗадачи =  РегистрыСведений.ОчередьЗадач.СоздатьЗадачу("Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолучитьКМ_Очереди", "ПолучитьКМ_ЗаказКм", ВыборкаДетальныеЗаписи.ссылка, пОбработки);
			
			Если РезультатСозданияЗадачи.Успешно Тогда
				
				СтрСообщение = СтрШаблон("Получены КМ по заказу КМ %1",ВыборкаДетальныеЗаписи.ссылка); 
				ЗаписатьВЛог("ПолучитьКМ_ЗаказКм_Регламент", СтрСообщение,"Информация"); 	
			Иначе 
				СтрСообщение = СтрШаблон("НЕ Получены КМ по заказу КМ %1 %1",ВыборкаДетальныеЗаписи.ссылка); 
				ЗаписатьВЛог("ПолучитьКМ_ЗаказКм_Регламент", СтрСообщение,"Ошибка!!!"); 
			КонецЕсли;
			
			Попытка
				СтрокаЗапроса = "ping -n 1 -w "+Формат(1000 * 1, "ЧДЦ=0; ЧГ=") + " 127.255.255.255";
				WshShell = Новый COMОбъект("WScript.Shell");
				WshShell.Run(СтрокаЗапроса, 0, -1);
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

Функция ПолучитьДанныеИзОчередиДляОтработки(ИмяОчереди,Статус)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК Ссылка,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОчередьЗадач.ИД_Задачи) КАК КоличествоПопыток,
	|	МАКСИМУМ(ОчередьЗадач.ДатаЗавершения) КАК ДатаЗавершения
	|ПОМЕСТИТЬ ВТОчередиАвтомат
	|ИЗ
	|	РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ОчередьЗадач.Основание = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = &Статус)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|ГДЕ
	|	ОчередьЗадач.ИмяОчереди = &ИмяОчереди
	|	И ОчередьЗадач.СостояниеЗадания = ЗНАЧЕНИЕ(Перечисление.СостоянияФЗ.Завершено)
	|	И ОчередьЗадач.Успешно
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|;
	|  
	//++Данилова Е.В. 12.09.2025  MARK-2886
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК ссылка,
	|	1 КАК КоличествоПопыток,
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Дата КАК ДатаЗавершения
	|ПОМЕСТИТЬ ВТОчереди
	|ИЗ
	|	Документ.АвтоматизацияРаботыЗаказовКМ.ЗаказыКМ КАК АвтоматизацияРаботыЗаказовКМЗаказыКМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО АвтоматизацияРаботыЗаказовКМЗаказыКМ.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = &Статус)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОчередиАвтомат КАК ВТОчередиАвтомат
	|		ПО (ВТОчередиАвтомат.Ссылка = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка)
	|ГДЕ
	|	ВТОчередиАвтомат.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТОчередиАвтомат.Ссылка,
	|	ВТОчередиАвтомат.КоличествоПопыток,
	|	ВТОчередиАвтомат.ДатаЗавершения
	|ИЗ
	|	ВТОчередиАвтомат КАК ВТОчередиАвтомат
	|;
	| 
	//--Данилова Е.В. 12.09.2025 
	|////////////////////////////////////////////////////////////////////////////////
	//++Данилова Е.В. 28.10.2025 MARK-3166
	//|ВЫБРАТЬ 
	|ВЫБРАТЬ  %ОграничениеПоОтработке%
	//--Данилова Е.В. 28.10.2025
	|	ВТОчереди.ссылка КАК Ссылка,
	|	ВТОчереди.ДатаЗавершения КАК ДатаЗавершения
	|ИЗ
	|	ВТОчереди КАК ВТОчереди
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &Таймаут
	|				ТОГДА ВЫБОР
	|						КОГДА ВТОчереди.КоличествоПопыток >= 3
	|							ТОГДА ДОБАВИТЬКДАТЕ(ВТОчереди.ДатаЗавершения, МИНУТА, 30) <= &Текущаядата
	|						ИНАЧЕ ДОБАВИТЬКДАТЕ(ВТОчереди.ДатаЗавершения, МИНУТА, 3) <= &Текущаядата
	|					КОНЕЦ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ 
	//++Данилова Е.В. 28.10.2025
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗавершения";
	//--Данилова Е.В. 28.10.2025
	
	
	Таймаут = Имяочереди = "ОтправкаВСУЗЗаказКМ" 
	ИЛИ (Имяочереди = "ПолучитьКМ_ЗаказКм" И Статус = Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки);
		
	Запрос.УстановитьПараметр("ИмяОчереди",ИмяОчереди);
	Запрос.УстановитьПараметр("Статус",Статус ); 
	Запрос.УстановитьПараметр("Таймаут",Таймаут);
	Запрос.УстановитьПараметр("Текущаядата",ТекущаяДатаСеанса() );
	//++Данилова Е.В. 28.10.2025 MARK-3166 
	Если Имяочереди = "ОтправкаВСУЗЗаказКМ" Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ОграничениеПоОтработке%",	" ПЕРВЫЕ 50 "); 
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ОграничениеПоОтработке%",	" ");
	КонецЕсли;
	//--Данилова Е.В. 28.10.2025
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;

КонецФункции // ПолучитьКМПоЗаказамКМ() 

Функция ПолучитьДанныеИзОчередиДляОтработкиВводовВОборот(ИмяОчереди,Статус)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МаркировкаТоваровИСМП.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ОчередьЗадач.ДатаЗавершения) КАК ДатаЗавершения
	|ПОМЕСТИТЬ ВТОчереди
	|ИЗ
	|	РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО ОчередьЗадач.Основание = МаркировкаТоваровИСМП.Ссылка
	|			И (МаркировкаТоваровИСМП.Статус = &Статус)
	|			И (МаркировкаТоваровИСМП.Проведен)
	|ГДЕ
	|	ОчередьЗадач.ИмяОчереди = &ИмяОчереди
	|	И ОчередьЗадач.СостояниеЗадания = ЗНАЧЕНИЕ(Перечисление.СостоянияФЗ.Завершено)
	|	И ОчередьЗадач.Успешно
	|
	|СГРУППИРОВАТЬ ПО
	|	МаркировкаТоваровИСМП.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТОчереди.Ссылка КАК Ссылка
	|ИЗ
	|	ВТОчереди КАК ВТОчереди
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &Таймаут
	|				ТОГДА ДОБАВИТЬКДАТЕ(ВТОчереди.ДатаЗавершения, МИНУТА, 1) <= &Текущаядата
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ИмяОчереди",ИмяОчереди);
	Запрос.УстановитьПараметр("Статус",Статус );
	Запрос.УстановитьПараметр("Текущаядата",ТекущаяДатаСеанса() );
	Запрос.УстановитьПараметр("Таймаут",ИмяОчереди = "ОтправкаВСУЗ_ВводВоборот" );
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;

КонецФункции

Процедура ЗаписатьКМПоЗаказамКМ()
   	
	ВыборкаДетальныеЗаписи = ПолучитьДанныеИзОчередиДляОтработки("ПолучитьКМ_ЗаказКм",Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ); 
			
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередЗаписьюКМ(ВыборкаДетальныеЗаписи.ссылка);
		Если рПроверки.Успешно Тогда 	
			
			СпособВводаВОборот = ПолучитьРеквизитШапки(ВыборкаДетальныеЗаписи.ссылка, "СпособВводаВОборот");
			
			пМетода		= Новый Структура("ДокСсылка,Перезаписывать", ВыборкаДетальныеЗаписи.ссылка, Ложь);
			пОбработки 	= Новый Структура("ПараметрыМетода", пМетода);
			//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
			Если СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков ИЛИ СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка Тогда
				пОбработки.Вставить("Приоритет", 0); 	
			КонецЕсли;	
			
			РезультатСозданияЗадачи =  РегистрыСведений.ОчередьЗадач.СоздатьЗадачу("Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ЗагрузитьКодыИзЛогов", "ЗагрузкаКМ_Регламент", ВыборкаДетальныеЗаписи.ссылка, пОбработки);
			
			Если РезультатСозданияЗадачи.Успешно Тогда
				
				СтрСообщение = СтрШаблон("Загружены КМ по заказу %1",ВыборкаДетальныеЗаписи.ссылка); 
				ЗаписатьВЛог("ЗагрузкаКМ_Регламент", СтрСообщение,"Информация"); 	
			Иначе 
				СтрСообщение = СтрШаблон("НЕ Загружены КМ по заказу %1 %1",ВыборкаДетальныеЗаписи.ссылка); 
				ЗаписатьВЛог("ЗагрузкаКМ_Регламент", СтрСообщение,"Ошибка!!!"); 
			КонецЕсли;

			
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

