			//--Данилова Е.В. 11.06.2026
			//--Данилова Е.В. 26.06.2026  
		Иначе	
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
		КонецЕсли;
	//++Данилова Е.В. 26.06.2026 Изм.№0000000222 
	//++Данилова Е.В. 27.03.2026 без задачи, исправление ошибки 
