	|			ИЛИ ОчередьЗадач.Основание.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК ЗаказКМ,
	|	МАКСИМУМ(ОчередьЗадач.ДатаЗавершения) КАК ДатаЗавершения
	|ПОМЕСТИТЬ ВТОчереди
	|ИЗ
	|	РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АвтоматизацияРаботыЗаказовКМ.ЗаказыКМ КАК АвтоматизацияРаботыЗаказовКМЗаказыКМ
	|		ПО ОчередьЗадач.Основание = АвтоматизацияРаботыЗаказовКМЗаказыКМ.ЗаказКМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО (АвтоматизацияРаботыЗаказовКМЗаказыКМ.ЗаказКМ = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СозданАвтоматически)
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОчередиАвтомат КАК ВТОчередиАвтомат
	|		ПО (ВТОчередиАвтомат.ЗаказКМ = ОчередьЗадач.Основание)
	|ГДЕ
	|	ОчередьЗадач.ИмяОчереди = ""ЗагрузкаКМ""
	|	И ОчередьЗадач.СостояниеЗадания = ЗНАЧЕНИЕ(Перечисление.СостоянияФЗ.Завершено)
	|	И (ОчередьЗадач.Успешно
	|			ИЛИ ОчередьЗадач.Основание.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|	И ВТОчередиАвтомат.ЗаказКМ ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТОчередиАвтомат.ЗаказКМ,
	|	ВТОчередиАвтомат.ДатаЗавершения
	|ИЗ
	|	ВТОчередиАвтомат КАК ВТОчередиАвтомат
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТОчереди.ЗаказКМ КАК Ссылка,
	|	ЕСТЬNULL(МаркировкаТоваровИСМПДляОтработки.Ссылка, ЗНАЧЕНИЕ(Документ.МаркировкаТоваровИСМП.ПустаяСсылка)) КАК ВводВОборот
	|ИЗ
	|	ВТОчереди КАК ВТОчереди
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	|		ПО (МаркировкаТоваровИСМП.ДокументОснование = ВТОчереди.ЗаказКМ)
	|			И (МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВОборот)
	|				ИЛИ МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Перемаркировка))
	|			И (МаркировкаТоваровИСМП.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Вработе))
	|			И (МаркировкаТоваровИСМП.Проведен)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПДляОтработки
	|		ПО (МаркировкаТоваровИСМПДляОтработки.ДокументОснование = ВТОчереди.ЗаказКМ)
	|			И (МаркировкаТоваровИСМПДляОтработки.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.ВводВОборот)  
	//++Данилова Е.В. 25.03.2026  MARK-3577
	//|				ИЛИ МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Перемаркировка)) 
	|				ИЛИ МаркировкаТоваровИСМПДляОтработки.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Перемаркировка))
	//--Данилова Е.В. 25.03.2026 
	|			И (МаркировкаТоваровИСМПДляОтработки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.ВРаботе))
	|			И (МаркировкаТоваровИСМПДляОтработки.Проведен)
	|ГДЕ
	|	ДОБАВИТЬКДАТЕ(ВТОчереди.ДатаЗавершения, МИНУТА, 3) <= &Текущаядата
	|	И МаркировкаТоваровИСМП.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Текущаядата",ТекущаяДатаСеанса());
	ВыборкаДетальныеЗаписи = запрос.Выполнить().Выбрать(); 	
	НачатьТранзакцию(); 
	МассивВводовВВОборот = Новый Массив; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ВводВОборот) Тогда
			
			МассивВводовВВОборот.Добавить(ВыборкаДетальныеЗаписи.ВводВОборот); 
			
			Продолжить; 	
		
		КонецЕсли;    ////
		ВидКомплекта = ПолучитьРеквизитШапки(ВыборкаДетальныеЗаписи.ссылка, "ВидКомплекта");
		ДокументОснование = ПолучитьРеквизитШапки(ВыборкаДетальныеЗаписи.ссылка, "ДокументОснование");
		Если ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект 
			 ИЛИ ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда 
			 
		    Продолжить;    			
		
		КонецЕсли;
		
		Если ВидКомплекта = Перечисления.ВидыКомплектов.Товар
			И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
			
			ВидКомплекта = ПолучитьРеквизитШапки(ДокументОснование.ссылка, "ВидКомплекта");
			
			Если ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда //ГН отрабатываются отдельно
				Продолжить;
			КонецЕсли;
			//++Данилова Е.В. 23.06.2026 Проб.№0000000129
			Если ВидКомплекта = Перечисления.ВидыКомплектов.Комплект Тогда 
				
				ДокументОснованиеЗаказаКМ = ПолучитьРеквизитШапки(ДокументОснование, "ДокументОснование");
				Если ТипЗнч(ДокументОснованиеЗаказаКМ) = Тип("ДокументСсылка.Перемаркировка") Тогда
					
					Продолжить;
					
				КонецЕсли;  		
				
			КонецЕсли;
			//--Данилова Е.В. 23.06.2026 
		КонецЕсли;
		
		рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередВводомВОборот(ВыборкаДетальныеЗаписи.ссылка);
		Если рПроверки.Успешно Тогда
			
			СпособВводаВоборот = ПолучитьРеквизитШапки(ВыборкаДетальныеЗаписи.ссылка, "СпособВводаВОборот");
			
			ВидОперацииИСМП = ?(СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт, 
			Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт, 
			//Валетов + 24,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522 
			//Перечисления.ВидыОперацийИСМП.ВводВОборот_МаркировкаОстатков 
			Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно
			); 	
			
			ПоляПоиска = Новый Структура("ДокументОснование,ВидОперацииИСМП,ПометкаУдаления", ВыборкаДетальныеЗаписи.ссылка, ВидОперацииИСМП,ЛОЖЬ); 	
			ДокСсылка =  НайтиДокумент("МаркировкаТоваровИСМП", ПоляПоиска);
			               
			
			Если ЗначениеЗаполнено(ДокСсылка) Тогда
				Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка, "Статус");			
				Если Реквизиты.Статус<>Перечисления.СтатусыДокументовМаркировки.ВРаботе Тогда
					ТекстОшибки = СтрШаблон("Невозможно перезаполнить ввод в оборот: %1, недопустимый сатус: ''.", ДокСсылка, Реквизиты.Статус);
					Продолжить;							
				КонецЕсли; 
				ДокОбъект = ДокСсылка.ПолучитьОбъект();
			Иначе
				ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент(); 
				ДокОбъект.СозданАвтоматически = Истина; 
			КонецЕсли; 
			
			ДокОбъект.Заполнить(ВыборкаДетальныеЗаписи.ссылка);
			
			ДокОбъект.ВидОперации 		= ?(ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.Перемаркировка_ИспорченоЛибоУтеряно,Перечисления.ВидыОперацийМаркировки.Перемаркировка,Перечисления.ВидыОперацийМаркировки.ВводВОборот);		
			ДокОбъект.ВидОперацииИСМП	= ВидОперацииИСМП;		
			
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			МассивВводовВВОборот.Добавить(ДокОбъект.Ссылка); 
		КонецЕсли; 
		
	КонецЦикла;
	
	Если ТранзакцияАктивна() Тогда
	
		ЗафиксироватьТранзакцию();	
	
	КонецЕсли;
	
	ПоставитьНаОтработкуВводВОборот(МассивВводовВВОборот);
	 
КонецПроцедуры 

Процедура ПоставитьНаОтработкуВводВОборот(МассивДокументов)
	
	ДанныеСертификата = ПолучитьДанныеСертификата(); 
	Если ДанныеСертификата = неопределено Тогда
		
		ЗаписатьВЛог("ОтправкаВСУЗОперацияМаркировкаРегламент", "Не найден действующий сертификат для ЧЗ по организации " + Строка(Организация),"Ошибка!!!");
		
		Возврат; 
		
	Иначе
		
				
	КонецЕсли; 
	//++Данилова Е.В. 23.07.2025 нельзя здесь ставить транзакцию, так как внутри сразу документы отправляются в ЧЗ	
	//НачатьТранзакцию(); 

	Для каждого ДОкСсылка Из  МассивДокументов Цикл
		
		рПроверки = Документы.МаркировкаТоваровИСМП.ПроверитьДокументПередОтправкойВЧЗ(ДокСсылка);
		Если рПроверки.Успешно Тогда
			
			пМетода		= Новый Структура("ДокСсылка,ДопПараметры", ДокСсылка,ДанныеСертификата);
			пОбработки 	= Новый Структура("ПараметрыМетода", пМетода);
			
			РезультатСозданияЗадачи =  РегистрыСведений.ОчередьЗадач.СоздатьЗадачу("Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОтправитьНаОбработкуВСУЗИСМП", "ОтправкаВСУЗ_ВводВоборот", ДокСсылка, пОбработки);
			
			Если РезультатСозданияЗадачи.Успешно Тогда
				
				СтрСообщение = СтрШаблон("Отправлен в СУЗ %1",ДокСсылка); 
				ЗаписатьВЛог("ОтправкаВСУЗ_ВводВоборот_Регламент", СтрСообщение,"Информация"); 	
			Иначе 
				СтрСообщение = СтрШаблон("НЕ Отправлен в СУЗ %1 %1",ДокСсылка); 
				ЗаписатьВЛог("ОтправкаВСУЗ_ВводВоборот_Регламент", СтрСообщение,"Ошибка!!!"); 
			КонецЕсли;
			
			Попытка
				СтрокаЗапроса = "ping -n 1 -w "+Формат(1000 * 1, "ЧДЦ=0; ЧГ=") + " 127.255.255.255";
				WshShell = Новый COMОбъект("WScript.Shell");
				WshShell.Run(СтрокаЗапроса, 0, -1);
			Исключение
			КонецПопытки;

			
		КонецЕсли;
		
	КонецЦикла;
	
	//Если ТранзакцияАктивна() Тогда
	//
	//	ЗафиксироватьТранзакцию();	
	//
	//КонецЕсли;

	
КонецПроцедуры

Процедура ПоставитьНаПолучениеРезультатовВводВОборот()

	ВыборкаДетальныеЗаписи = ПолучитьДанныеИзОчередиДляОтработкиВводовВОборот("ОтправкаВСУЗ_ВводВоборот",Перечисления.СтатусыДокументовМаркировки.Обрабатывается);  	
	
	ДанныеСертификата = ПолучитьДанныеСертификата(); 
	Если ДанныеСертификата = неопределено Тогда
		
		ЗаписатьВЛог("ПолучениеРезВводВОборотРегламент", "Не найден действующий сертификат для ЧЗ по организации " + Строка(Организация),"Ошибка!!!");
		
		Возврат; 
		
	Иначе
		
		
		
	КонецЕсли; 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ДокСсылка = ВыборкаДетальныеЗаписи.ссылка; 
		рПроверки = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПроверитьДокументПередПолучениемИзЧЗ(ДокСсылка);
		Если рПроверки.Успешно Тогда 
			
			пМетода		= Новый Структура("ДокСсылка,ДопПараметры", ДокСсылка,ДанныеСертификата);
			пОбработки 	= Новый Структура("ПараметрыМетода", пМетода);
			
			РезультатСозданияЗадачи =  РегистрыСведений.ОчередьЗадач.СоздатьЗадачу("Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПолучитьРезультаты_ОперМаркировки", "ПолучитьРезЧЗ_ВводВоборот", ДокСсылка, пОбработки);
			
				
			Если РезультатСозданияЗадачи.Успешно Тогда
				
				СтрСообщение = СтрШаблон("Получены результаты из СУЗ %1",ДокСсылка); 
				ЗаписатьВЛог("ПолучитьРезЧЗ_ВводВоборот_Регламент", СтрСообщение,"Информация"); 	
			Иначе 
				СтрСообщение = СтрШаблон("НЕ Получены результаты из СУЗ %1 %1",ДокСсылка); 
				ЗаписатьВЛог("ПолучитьРезЧЗ_ВводВоборот_Регламент", СтрСообщение,"Ошибка!!!"); 
			КонецЕсли;
			
			Попытка
				СтрокаЗапроса = "ping -n 1 -w "+Формат(1000 * 1, "ЧДЦ=0; ЧГ=") + " 127.255.255.255";
				WshShell = Новый COMОбъект("WScript.Shell");
				WshShell.Run(СтрокаЗапроса, 0, -1);
			Исключение
			КонецПопытки;

			
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры 

Процедура ОтправитьВЧЗФормированияНаборовПоГН()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка КАК ЗаказКМ,
	|	МАКСИМУМ(ОчередьЗадач.ДатаЗавершения) КАК ДатаЗавершения
	|ПОМЕСТИТЬ ВТОчереди
	|ИЗ
	|	РегистрСведений.ОчередьЗадач КАК ОчередьЗадач
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|		ПО ОчередьЗадач.Основание = ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект))
	|			И (ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Проведен)
	|ГДЕ
	|	ОчередьЗадач.ИмяОчереди = ""ЗагрузкаКМ_Регламент""
	|	И ОчередьЗадач.СостояниеЗадания = ЗНАЧЕНИЕ(Перечисление.СостоянияФЗ.Завершено)
	|	И (ОчередьЗадач.Успешно
	|			ИЛИ ОчередьЗадач.Основание.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовМаркировки.Обработан))
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТОчереди.ЗаказКМ КАК Ссылка,
	|	ЕСТЬNULL(МаркировкаТоваровИСМПДляОтработки.Ссылка, ЗНАЧЕНИЕ(Документ.МаркировкаТоваровИСМП.ПустаяСсылка)) КАК ФормированиеНабора
	|ИЗ
	|	ВТОчереди КАК ВТОчереди
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМПДляОтработки
	|		ПО (МаркировкаТоваровИСМПДляОтработки.ДокументОснование = ВТОчереди.ЗаказКМ)
