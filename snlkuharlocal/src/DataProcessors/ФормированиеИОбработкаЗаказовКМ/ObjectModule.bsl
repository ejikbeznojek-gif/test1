	//ОбработкаАПИ = Обработки.АпиЧЗ.Создать();
	//
	//ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ПарольДоступаКЗакрытомуКлючу", "");
	//
	//Токен 		=  ОбработкаАПИ.ПолучитьТокен_СУЗ(СУЗСерт,ЗначениеСертификата);
	//ТокенТруАпи	= ОбработкаАПИ.ПолучитьТокен_TrueApi(ЗначениеСертификата);
	//
	//ОбработкаАПИ.Токен_СУЗ 		= Токен;
	//ОбработкаАПИ.Токен_TrueApi 	= ТокенТруАпи;
	//ОбработкаАПИ.Организация 	= СУЗСерт.Владелец;
	
	
    //Возврат Новый Структура("Токен_СУЗ,ТокенТруАпи,ОтпечатокСертификатаЭЦП,ТекущаяСУЗ,Организация",Токен,ТокенТруАпи,ЗначениеСертификата,СУЗСерт,ОрганизацияСуз);
	Возврат Новый Структура("ОтпечатокСертификатаЭЦП,СУЗ",ЗначениеСертификата,СУЗСерт);
	
КонецФункции // ПолучитьДанныеСертификатов()

Функция ПолучитьСУЗПоОрганизации(Знач Организация, ИНН) Экспорт
	
	СУЗ = Справочники.СтанцииУправленияЗаказамиИСМП.ПустаяСсылка();
	
	Запрос = новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтанцииУправленияЗаказамиИСМП.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтанцииУправленияЗаказамиИСМП КАК СтанцииУправленияЗаказамиИСМП
	|ГДЕ
	|	СтанцииУправленияЗаказамиИСМП.Владелец.ИНН = &ИНН
	|	И НЕ СтанцииУправленияЗаказамиИСМП.Владелец.ПометкаУдаления
	|	И СтанцииУправленияЗаказамиИСМП.СУЗДляОУКЭП
	|	И СтанцииУправленияЗаказамиИСМП.Владелец = &Организация";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИНН",ИНН);
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
	
		Возврат Выборка.ссылка; 	
	
	КонецЕсли;
	
	Возврат СУЗ; 
	
КонецФункции


Процедура ЭтапПервый(ПараметрыОтработки = неопределено) Экспорт 
    Если ПараметрыОтработки = неопределено Тогда
	
		ПараметрыОтработки = Новый Структура; 
		ПараметрыОтработки.Вставить("Организация",Организация);
		ПараметрыОтработки.Вставить("Подразделение",Подразделение);
	
	КонецЕсли;
	РезультатФормированияЗаказов = СформироватьЗаказыКМПоНакладным(ПараметрыОтработки);
	Если НЕ РезультатФормированияЗаказов.Успешно Тогда
		СтрокаОшибки = СтрСоединить(РезультатФормированияЗаказов.Ошибки,";"); 
		ЗаписатьВЛог("ФормированиеЗаказовКМПоНакладнымРегламент","Не сформированы заказы КМ по накладным. Ошибки:"+ СтрокаОшибки,"Ошибка!!"); 
		Возврат;
	ИначеЕсли РезультатФормированияЗаказов.Данные.Количество() > 0 Тогда 
		РезультатУстановки = ПроставитьПоНакладнымМаркиЗаказаны(РезультатФормированияЗаказов.Данные,РезультатФормированияЗаказов.МассивНакладныеБезТоваров); 
		Если РезультатУстановки тогда
			
			//получение сертификата
			ОтправитьНаОтработкуВЧЗЗАказыКМ(РезультатФормированияЗаказов.Данные);
		КонецЕсли;
	КонецЕсли;	 
	 	
     /////////////////////////////////////////////////////////////
	 
	 /////////////////////////////////////////////////////////////
 КонецПроцедуры
 
 Процедура ЭтапВторой() экспорт 
    
 	ПолучитьКМПоЗаказамКМ(); 
 
КонецПроцедуры 

Процедура ЭтапТретий() экспорт
	
	ОтработатьОшибкиПолученияКМ(); 
	ЗаписатьКМПоЗаказамКМ();

КонецПроцедуры 

Процедура ЭтапЧетвертый()экспорт

	СоздатьИОтправитьВЧЗВводыВОборотПоЕдиницам();

КонецПроцедуры 

Процедура ЭтапПятый()экспорт

	ПоставитьНаПолучениеРезультатовВводВОборот();

КонецПроцедуры 

Процедура ЭтапШестой()экспорт

	ОтправитьВЧЗФормированияНаборовПоГН();

КонецПроцедуры 

Процедура ЭтапСедьмой() Экспорт

	 ПоставитьНаПолучениеРезультатовФормированиеНаборов(); 

КонецПроцедуры

Процедура ЭтапВосьмой(ПараметрыОтработки = неопределено) экспорт
	Если ПараметрыОтработки = неопределено Тогда
		
		ПараметрыОтработки = Новый Структура; 
		ПараметрыОтработки.Вставить("Организация",Организация);
		ПараметрыОтработки.Вставить("Подразделение",Подразделение);
		
	КонецЕсли;
	ПроставитьВведенВОборотПоНакладным(ПараметрыОтработки);

КонецПроцедуры
 
Процедура ОтработатьПоЭтапно(ПараметрыОтработки) Экспорт 

	 ЭтапПервый(ПараметрыОтработки); 
	 
	 ЭтапВторой();  
	 
	 ЭтапТретий(); 
	 
	 ЭтапЧетвертый();  
	 
	 ЭтапПятый(); 
	 
	 ЭтапШестой(); 
	 //////////////////////////////////////////////////////////// 
	 ЭтапСедьмой();
	  
	 ЭтапВосьмой(ПараметрыОтработки); 
КонецПроцедуры

Функция СформироватьЗаказыКМПоНакладным(Знач ПараметрыОтработки) Экспорт 
	
	ПодразделениеПараметр = ПараметрыОтработки.Подразделение; 
	Организация   = ПараметрыОтработки.Организация;
	ДатаЗапускаЭтапа = ТекущаяДатаСеанса(); 
	//собираем 
	
    Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная,
	|	СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение КАК Подразделение,
	|	ВЫБОР
	|		КОГДА СтатусыЗаказаМарокДляДокументов.Накладная.ТребуетсяМаркировкаПриоритет
	|			ТОГДА &ТекущаяДатаМинусМесяц
	|		КОГДА СтатусыЗаказаМарокДляДокументов.Накладная.Контрагент.ДатаНачалаРаботыСМаркировкой = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ДАТАВРЕМЯ(2026, 1, 1)
	|		ИНАЧЕ СтатусыЗаказаМарокДляДокументов.Накладная.Контрагент.ДатаНачалаРаботыСМаркировкой
	|	КОНЕЦ КАК ДатаНачалаРаботыСМаркировкой,
	|	СтатусыЗаказаМарокДляДокументов.Накладная.Контрагент.ВыполнятьПоискДатыНачалаМаркировкиВМатрице КАК НакладнаяКонтрагентВыполнятьПоискДатыНачалаМаркировкиВМатрице
	|ПОМЕСТИТЬ РНКСкладыНемаркир
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыСпр
	|		ПО (СкладыСпр.Ссылка = СтатусыЗаказаМарокДляДокументов.Накладная.Склад)
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.ТребуетсяЗаказМарок)
	|	И ТИПЗНАЧЕНИЯ(СтатусыЗаказаМарокДляДокументов.Накладная) = ТИП(Документ.РасходнаяНакладная)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.ТребуетсяМаркировка
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Проведен
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В(&Подразделение)
	|	И НЕ СкладыСпр.ЭтоСкладМаркированногоТовара
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная,
	|	СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ РНКСкладыМаркир
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыСпр
	|		ПО (СкладыСпр.Ссылка = СтатусыЗаказаМарокДляДокументов.Накладная.Склад)
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.ТребуетсяЗаказМарок)
	|	И ТИПЗНАЧЕНИЯ(СтатусыЗаказаМарокДляДокументов.Накладная) = ТИП(Документ.РасходнаяНакладная)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.ТребуетсяМаркировка
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В(&Подразделение)
	|	И СкладыСпр.ЭтоСкладМаркированногоТовара
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная,
	|	СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение КАК Подразделение,
	|	ВЫБОР
	|		КОГДА СтатусыЗаказаМарокДляДокументов.Накладная.СкладПолучатель.ЭтоСкладМаркированногоТовара
	|			ТОГДА &ТекущаяДатаМинусМесяц
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СтатусыЗаказаМарокДляДокументов.Накладная.Контрагент.ДатаНачалаРаботыСМаркировкой = ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ДАТАВРЕМЯ(2026, 1, 1)
	|				ИНАЧЕ СтатусыЗаказаМарокДляДокументов.Накладная.Контрагент.ДатаНачалаРаботыСМаркировкой
	|			КОНЕЦ
	|	КОНЕЦ КАК ДатаНачалаРаботыСМаркировкой
	|ПОМЕСТИТЬ ПРМ
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СкладыСпр
	|		ПО (СкладыСпр.Ссылка = СтатусыЗаказаМарокДляДокументов.Накладная.Склад)
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(перечисление.Статусызаказакодовмаркировки.ТребуетсяЗаказМарок)
	|	И ТИПЗНАЧЕНИЯ(СтатусыЗаказаМарокДляДокументов.Накладная) = ТИП(Документ.Перемещение)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.ТребуетсяМаркировка
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В(&Подразделение)
	|	И НЕ СкладыСпр.ЭтоСкладМаркированногоТовара
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	// Кельманов А.В. - SNL-239 - 2026.05.28 {
	|ВЫБРАТЬ
	|	СтатусыЗаказаМарокДляДокументов.Накладная КАК Накладная,
	|	СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ КМП
	|ИЗ
	|	РегистрСведений.СтатусыЗаказаМарокДляДокументов КАК СтатусыЗаказаМарокДляДокументов
	|ГДЕ
	|	СтатусыЗаказаМарокДляДокументов.СтатусыЗаказаКодовМаркировки = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказаКодовМаркировки.ТребуетсяЗаказМарок)
	|	И ТИПЗНАЧЕНИЯ(СтатусыЗаказаМарокДляДокументов.Накладная) = ТИП(Документ.Комплектация)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Склад.Подразделение В(&Подразделение)
	|	И СтатусыЗаказаМарокДляДокументов.Накладная.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	// Кельманов А.В. - SNL-239 - 2026.05.28 }
	|ВЫБРАТЬ
	|	РНКСкладыМаркир.Подразделение КАК Подразделение,
	|	РНКСкладыМаркир.Накладная КАК Накладная,
