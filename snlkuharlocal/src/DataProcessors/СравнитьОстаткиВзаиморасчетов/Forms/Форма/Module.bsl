&НаКлиенте
Процедура ФайлЗагрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл JSON";
	Диалог.ПолноеИмяФайла = ""; 
	Диалог.Фильтр = "JSON (*.json)|*.json";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Каталог = КаталогВременныхФайлов();
	
	Если Диалог.Выбрать() Тогда
		Объект.Файл = Диалог.ПолноеИмяФайла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	
	Если ПустаяСтрока(Объект.Файл) Тогда
		Сообщить("Не выбран файл JSON");
		Возврат;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьФайл(Объект.Файл);
	МассивДанных = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Объект.Сравнение.Очистить();
	Для Каждого Стр ИЗ МассивДанных Цикл
		НоваяСтрока = Объект.Сравнение.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
		НоваяСтрока.Контрагент = Обработки.СравнитьОстаткиВзаиморасчетов.НайтиОбъектКонфигурацииПоУИД(НоваяСтрока.КонтрагентУИД, "Справочник", "Контрагенты");
		НоваяСтрока.Договор = Обработки.СравнитьОстаткиВзаиморасчетов.НайтиОбъектКонфигурацииПоУИД(НоваяСтрока.ДоговорУИД, "Справочник", "Договоры");
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Сравнить(Команда)
	
	Если Объект.Сравнение.Количество() = 0 Тогда
		Сообщить("Не заполнена ТЧ <Сравнение>.");
		Возврат;
	КонецЕсли;
	
	СравнитьНаСервере();
	СравнениеИсточникаИПриемника();
	
КонецПроцедуры

&НаСервере
Процедура СравнитьНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", ?(НЕ ЗначениеЗаполнено(Объект.Период), ТекущаяДатаСеанса(), Объект.Период));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Контрагент КАК Контрагент,
	|	Остатки.Договор КАК Договор,
	|	ВЫРАЗИТЬ(Остатки.СуммаВалОстаток КАК ЧИСЛО(19, 2)) КАК СуммаВалПриемник,
	|	ВЫРАЗИТЬ(Остатки.СуммаУпрОстаток КАК ЧИСЛО(19, 2)) КАК СуммаУпрПриемник
	|ИЗ
	|	РегистрНакопления.Взаиморасчеты.Остатки(&Период, ) КАК Остатки";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗВыборка = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Для Каждого Стр ИЗ ТЗВыборка Цикл
		
		НайденныеСтроки = Объект.Сравнение.НайтиСтроки(Новый Структура("Контрагент, Договор", Стр.Контрагент, Стр.Договор));
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для Каждого СтрН ИЗ НайденныеСтроки Цикл
				СтрН.СуммаВалПриемник = Стр.СуммаВалПриемник;
				СтрН.СуммаУпрПриемник = Стр.СуммаУпрПриемник;
			КонецЦикла;
		Иначе
			НоваяСтрока = Объект.Сравнение.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
			НоваяСтрока.КонтрагентУИД = Строка(Стр.Контрагент.УникальныйИдентификатор());
			НоваяСтрока.ДоговорУИД = Строка(Стр.Договор.УникальныйИдентификатор());
			НоваяСтрока.КонтрагентНаименование = СокрЛП(Стр.Контрагент.Наименование);
			НоваяСтрока.ДоговорНаименование = СокрЛП(Стр.Договор.Наименование);
			НоваяСтрока.СтрокаСравнения = "Только в базе-приемнике";
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СравнениеИсточникаИПриемника()
	
	Для Каждого Стр ИЗ Объект.Сравнение Цикл
		
		Если ПустаяСтрока(Стр.СтрокаСравнения) Тогда
			
			Если Стр.СуммаУпрПриемник <> 0 И Стр.СуммаУпр <> 0 И Стр.СуммаУпрПриемник <> Стр.СуммаУпр Тогда
				Стр.СтрокаСравнения = "Отличаются Суммы вал. источника и приемника";
			КонецЕсли;
			Если Стр.СуммаВалПриемник <> 0 И Стр.СуммаВал <> 0 И Стр.СуммаВалПриемник <> Стр.СуммаВал Тогда
				Стр.СтрокаСравнения = "Отличаются Суммы в руб. источника и приемника";
			КонецЕсли;
			Если Стр.СуммаУпрПриемник = 0 ИЛИ Стр.СуммаВалПриемник = 0 Тогда
				Стр.СтрокаСравнения = "Не найдены суммы в приемнике";	
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЦикла;
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// Цвет раскраски строк
    ЭлементОформления = УсловноеОформление.Элементы.Добавить();
    ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЗеленый);
	
	// Условия раскраски
    ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Сравнение.СуммаВал");
    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
    ЭлементОтбора.ПравоеЗначение = 0;
	ЭлементОтбора.Использование = Истина;
	
	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Сравнение.СуммаВалПриемник");
    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
    ЭлементОтбора.ПравоеЗначение = 0;
	ЭлементОтбора.Использование = Истина;
	
	//ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	//ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Сравнение.СуммаВал");
	//ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
	//ЭлементОтбора.ПравоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Сравнение.СуммаВалПриемник");
	//ЭлементОтбора.Использование = Истина;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьУсловноеОформление();
КонецПроцедуры

