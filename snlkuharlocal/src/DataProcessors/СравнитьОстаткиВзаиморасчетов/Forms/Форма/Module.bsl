&НаКлиенте
Процедура ФайлНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Выберите файл JSON";
	Диалог.ПолноеИмяФайла = ""; 
	Диалог.Фильтр = "JSON (*.json)|*.json";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Каталог = КаталогВременныхФайлов();
	
	Если Диалог.Выбрать() Тогда
		Объект.Файл = Диалог.ПолноеИмяФайла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВФайл(Команда)
	
	Если ПустаяСтрока(Объект.Файл) Тогда
		Сообщить("Не выбран файл JSON");
		Возврат;
	КонецЕсли;
	
	Если Объект.Остатки.Количество() = 0 Тогда
		Сообщить("Не заполнена ТЧ <Остатки>.");
		Возврат;
	КонецЕсли;
	
	МассивДанных = Новый Массив;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(Объект.Файл,,, Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб));
	
	Для Каждого Стр ИЗ Объект.Остатки Цикл
		СтруктураДанных = Новый Структура("КонтрагентУИД, КонтрагентНаименование, ДоговорУИД, ДоговорНаименование, СуммаВал, СуммаУпр",
			Строка(Стр.Контрагент.УникальныйИдентификатор()), СокрЛП(Стр.Контрагент.Наименование),
			Строка(Стр.Договор.УникальныйИдентификатор()), СокрЛП(Стр.Договор.Наименование),
			Стр.СуммаВал, Стр.СуммаУпр);
			
		МассивДанных.Добавить(СтруктураДанных);
	КонецЦикла;
	
	ЗаписатьJSON(ЗаписьJSON,МассивДанных); 
	
	ЗаписьJSON.Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОстаткиНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", ?(НЕ ЗначениеЗаполнено(Объект.Период), ТекущаяДатаСеанса(), Объект.Период));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Контрагент КАК Контрагент,
	|	Остатки.Договор КАК Договор,
	|	ВЫРАЗИТЬ(Остатки.СуммаВалОстаток КАК ЧИСЛО(19, 2)) КАК СуммаВал,
	|	ВЫРАЗИТЬ(Остатки.СуммаУпрОстаток КАК ЧИСЛО(19, 2)) КАК СуммаУпр
	|ИЗ
	|	РегистрНакопления.Взаиморасчеты.Остатки(&Период, ) КАК Остатки";
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗВыборка = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Объект.Остатки.Загрузить(ТЗВыборка);

КонецПроцедуры

&НаКлиенте
Процедура СформироватьОстатки(Команда)
	СформироватьОстаткиНаСервере();
КонецПроцедуры

