Функция ПолучитьДаныеАгрегации(body) Экспорт
	ТипСтрока = ПолучитьОписаниеТиповСтроки(Метаданные.Справочники.ШтрихкодыУпаковокТоваров.ДлинаНаименования);
	
	тКодов = Новый ТаблицаЗначений;
	тКодов.Колонки.Добавить("КодКоробки", 	ТипСтрока);
	тКодов.Колонки.Добавить("КодУпаковки", 	ТипСтрока);	
	
	Для каждого ДанныеАгрегата Из body.aggregationUnits Цикл
		КодКоробки = ДанныеАгрегата.unitSerialNumber;			
		Для каждого КодУпаковки Из ДанныеАгрегата.sntins Цикл
			СтрокаТ = тКодов.Добавить(); 
			СтрокаТ.КодКоробки	= КодКоробки;
			СтрокаТ.КодУпаковки = КодУпаковки;				
		КонецЦикла;
	КонецЦикла;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Коды ИЗ &тКодов КАК тКодов
	|;
	|ВЫБРАТЬ
	|	ВТ_Коды.КодКоробки	КАК КодКоробки,   
	|	ВТ_Коды.КодУпаковки	КАК КодУпаковки,
	|	Спр_Коробки.Ссылка 	КАК ШтрихКодКоробки,
	|	Спр_Штуки.Ссылка 	КАК ШтрихКодУпаковки
	|ИЗ
	|	ВТ_Коды
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров	КАК Спр_Коробки
	|ПО
	|	Спр_Коробки.Наименование = ВТ_Коды.КодКоробки 
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров	КАК Спр_Штуки
	|ПО
	|	Спр_Штуки.Наименование = ВТ_Коды.КодКоробки 
	|";
	
	Запрос.УстановитьПараметр("тКодов", тКодов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

