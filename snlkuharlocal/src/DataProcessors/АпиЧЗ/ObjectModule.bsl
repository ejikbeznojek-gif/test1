Функция ПолучитьИипДокументаЧЗ(ТипДокумента)                          
	Результат = "OTHER";
	Если ТипДокумента = Перечисления.ТипыДокументовИСМП.АктУничтожения Тогда
		Результат = "DESTRUCTION_ACT";	
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.КассовыйЧек Тогда
		Результат = "RECEIPT";			
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
		Результат = "OTHER";			
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.ТаможеннаяДекларация Тогда
		Результат = "CUSTOMS_DECLARATION";
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.ТоварнаяНакладная Тогда
		Результат = "CONSIGNMENT_NOTE";
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.ТоварныйЧек Тогда
		Результат = "SALES_RECEIPT";
	ИначеЕсли ТипДокумента = Перечисления.ТипыДокументовИСМП.УПД Тогда
		Результат = "UTD";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьИипДокументаЧЗ(ТипДокумента)


Функция ПолучитьДатуГТД(НомерГТД)
	Результат = "";
	Части = СтрРазделить(НомерГТД,"/");
	Если Части.Количество()>1 Тогда
		Результат = "20"+Прав(Части[1],2)+"-"+Сред(Части[1],3,2)+"-"+Лев(Части[1],2);			
	КонецЕсли;   
	Возврат Результат;
КонецФункции //ПолучитьДатуГТД(НомерГТД)

Функция ПолучитьСтатус_ОперацияМаркировки(ДокСсылка)	
	Результат 		= СтруктураРезультата(Ложь);	
	Результат.Вставить("ДокИнфо", Новый Структура);
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();
	
	ДопЗаголовки 	= Новый Соответствие;
	
	АдресРесурса	= "api/v4/true-api/doc/"+ДокСсылка.ИД_ДокументаЧЗ+"/info?pg=lp&body=true";
		
	рЗапроса 		= ВыполнитьЗапрос_TrueApi(АдресРесурса, "GET", СоединениеХТТП, Новый Структура("Основание", ДокСсылка));
	
	Если рЗапроса.Успешно Тогда	
		
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);
		Если ТипЗнч(Данные) = Тип("Массив") И Данные.Количество()>0 Тогда
			Данные = Данные[0];		
		КонецЕсли; 
		
		Если Данные.status = "IN_PROGRESS" Тогда
			Сообщить("В процессе (IN_PROGRESS) ....");
		ИначеЕсли Данные.status = "WAIT_FOR_CONTINUATION" Тогда
			Сообщить("В процессе (WAIT_FOR_CONTINUATION) ....");
		ИначеЕсли Данные.status = "CHECKED_OK" Тогда
			Результат.Успешно = Истина;
			Сообщить("Обработан", СтатусСообщения.Информация);
			ЗаписатьРезультатыОбработкиДокументаМаркировки(ДокСсылка, Данные.body);
		ИначеЕсли Данные.status = "CHECKED_NOT_OK" ТОГДА
			//++Данилова Е.В. 12.12.2025 MARK-3370 
			ВернутьСтатусКОбработке = Ложь; 
			//--Данилова Е.В. 12.12.2025
			Если Данные.Свойство("errors") И Данные.errors <> Неопределено Тогда
				Для Каждого ТекстОшибки Из Данные.errors Цикл
					Результат.Ошибки.Добавить(ТекстОшибки);
					//++Данилова Е.В. 12.12.2025 MARK-3370 
					Если СтрНайти(ТекстОшибки,"14: Недопустимый статус кода идентификации") > 0 Тогда
					
						ВернутьСтатусКОбработке = Истина; 	
					
					КонецЕсли;
					//--Данилова Е.В. 12.12.2025 
				КонецЦикла;
			ИначеЕсли Данные.Свойство("commonErrors") И Данные.commonErrors <> Неопределено Тогда
				Для Каждого ОписаниеОшибки Из Данные.commonErrors Цикл
					Результат.Ошибки.Добавить(ОписаниеОшибки.errorMessage);
				КонецЦикла;			
			Иначе                                                          
				Результат.Ошибки.Добавить("Статус обработки ЧЗ: " + Данные.status);
			КонецЕсли;
			//++Данилова Е.В. 12.12.2025 MARK-3370
			Если ВернутьСтатусКОбработке Тогда 
				ВернутьДокументМаркировкиКОбработке(ДокСсылка);
			КонецЕсли; 
			//--Данилова Е.В. 12.12.2025
		Иначе
			Сообщить(рЗапроса.Ответ);	
		КонецЕсли; 
	Иначе
		Если ЗначениеЗаполнено(ДокСсылка.ИД_ДокументаЧЗ) И рЗапроса.КодСостояния = 404 Тогда //Висит ЧЗ
			Сообщить("Ошибка ЧЗ. " + рЗапроса.КодСостояния + " " + СтрСоединить(рЗапроса.Ошибки, Символы.ПС));
			Результат.Ошибки.Добавить("404");
		Иначе			
			ДобавитьОшибки(Результат, рЗапроса);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьСтатус_ОперацияМаркировки(ДокСсылка) Экспорт

Функция ПолучитьДанные_ОперацияМаркировки(ИД_ДокументаЧЗ) Экспорт	
	Результат 		= СтруктураРезультата(Ложь);
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();
	
	ДокСсылка = Документы.МаркировкаТоваровИСМП.НайтиПоРеквизиту("ИД_ДокументаЧЗ", Новый УникальныйИдентификатор(ИД_ДокументаЧЗ));
	
	АдресРесурса	= "api/v4/true-api/doc/" + ИД_ДокументаЧЗ + "/info?pg=lp&body=true";
		
	рЗапроса 		= ВыполнитьЗапрос_TrueApi(АдресРесурса, "GET", СоединениеХТТП, Новый Структура("Основание", ДокСсылка));
	
	Если рЗапроса.Успешно Тогда	
		
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);
		Если ТипЗнч(Данные) = Тип("Массив") И Данные.Количество()>0 Тогда
			Данные = Данные[0];		
		КонецЕсли; 
		
		Если Данные.status = "IN_PROGRESS" Тогда
			Сообщить("В процессе (IN_PROGRESS) ....");
		ИначеЕсли Данные.status = "WAIT_FOR_CONTINUATION" Тогда
			Сообщить("В процессе (WAIT_FOR_CONTINUATION) ....");
		ИначеЕсли Данные.status = "CHECKED_OK" Тогда
			Результат.Успешно = Истина;
			Результат.Данные = данные;			
		ИначеЕсли Данные.status = "CHECKED_NOT_OK" ТОГДА
			Если Данные.Свойство("errors") И Данные.errors <> Неопределено Тогда
				Для Каждого ТекстОшибки Из Данные.errors Цикл
					Результат.Ошибки.Добавить(ТекстОшибки);
				КонецЦикла;
			ИначеЕсли Данные.Свойство("commonErrors") И Данные.commonErrors <> Неопределено Тогда
				Для Каждого ОписаниеОшибки Из Данные.commonErrors Цикл
					Результат.Ошибки.Добавить(ОписаниеОшибки.errorMessage);
				КонецЦикла;			
			Иначе                                                          
				Результат.Ошибки.Добавить("Статус обработки ЧЗ: " + Данные.status);
			КонецЕсли;
		Иначе
			Сообщить(рЗапроса.Ответ);	
		КонецЕсли; 
	Иначе
		Если рЗапроса.КодСостояния = 404 Тогда
			Результат.Ошибки.Добавить("Документ не найден");
		Иначе			
			ДобавитьОшибки(Результат, рЗапроса);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьДанные_ОперацияМаркировки(ДокСсылка) Экспорт

Функция ПолучитьСтатус_ФИД(ДокСсылка) Экспорт
	Результат 		= СтруктураРезультата(Ложь);	
	
	Результат.Вставить("ДокИнфо", Новый Структура);
		
	рПроверкиПодкл	= ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка);
	
	Если НЕ рПроверкиПодкл.Успешно Тогда
		ДобавитьОшибки(Результат, рПроверкиПодкл);		
		Возврат Результат;
	КонецЕсли;
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();
	
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ") Тогда
		ИД_ДокументаЧЗ = ПолучитьРеквизитШапки(ДокСсылка, "ИД_ДокументаЧЗ");
	Иначе
		ИД_ДокументаЧЗ = ""+ДокСсылка;	
	КонецЕсли;
	
	СоединениеХТТП 	= СоздатьСоединение_НК();	
	АдресРесурса 	= "v3/feed-status?feed_id="+ИД_ДокументаЧЗ+"&verbose=false";	
	
	ДопПараметры 	= Новый Структура("Основание", ДокСсылка);
	
	рЗапроса 		= ВыполнитьЗапрос_НК(АдресРесурса, , , ДопПараметры);
	Если рЗапроса.Успешно Тогда
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ, Истина);
		
		Статус = Данные["result"]["status"];
		
		Результат.Данные = Статус;
		
		Попытка
			ВсегоОшибок = Число(Данные["result"]["result"]["totalErrors"]);
		Исключение
			ВсегоОшибок = 0;
		КонецПопытки;		
		
		Для Сч = 0 По ВсегоОшибок-1 Цикл
			Ошибки = Данные["result"]["result"][ЧислоБезДури(Сч)];
			Если ТипЗнч(Ошибки) = Тип("Массив") И Ошибки.Количество()>0 Тогда
				ДобавитьОшибки(Результат, Ошибки);				
			КонецЕсли; 
		КонецЦикла; 		
	Иначе
		ДобавитьОшибки(Результат, рЗапроса);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПолучитьСтатус_ФИД(ДокСсылка)

