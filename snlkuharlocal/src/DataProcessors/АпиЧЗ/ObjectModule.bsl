	тТовары			= ПолучитьТаблицуТоваров(ЗаказКМ);	
	//тТовары			= ПолучитьТаблицуТоваровЗаказКМ(ЗаказКМ);
	//--Данилова Е.В. 29.01.2025
	
	МассивЗаписей 	= Новый Массив;
	ОбработаноОбъектов = 0;
	
	Ошибки = Новый Соответствие;
	
	Для Каждого СтрокаТ Из тТовары Цикл
		Состояние_("Проверка "+СтрокаТ.productDescription);
		
		рСтатусы = ПолучитьСтатусСтрокиЗаказаКМ_v3(ИД_Заказа, СтрокаТ.gtin, СоединениеХТТП, СтанцияСУЗ, ДопПараметры);
		Если рСтатусы.Успешно Тогда			
			Для Каждого Буфер Из рСтатусы.Данные Цикл				
				Если ВРег(Буфер.bufferStatus) = "REJECTED" Тогда
					Результат.Ошибки.Добавить(Буфер.rejectionReason);
				Иначе
					Если Буфер.availableCodes > 0 Тогда
						рПолучения = СкачатьКМпоGTIN(ИД_Заказа, СтрокаТ.gtin, Буфер.availableCodes, СоединениеХТТП, СтанцияСУЗ, ДопПараметры);
						Если НЕ рПолучения.Успешно Тогда
							ДобавитьОшибки(Результат, рПолучения);
						КонецЕсли;
					КонецЕсли;		
				КонецЕсли;			
			КонецЦикла;
		Иначе			
			ДобавитьОшибки(Результат, рСтатусы);		
		КонецЕсли; 
	КонецЦикла;	
	
	МассивЗаписей = ПолучитьМассивЗаписейЗагрузкиКМ(ЗаказКМ);
	Если МассивЗаписей.Количество()>0 Тогда
		ТК 			  = ПрочитатьКодыИзЛогов(МассивЗаписей);
		ПолученоКодов = ТК.Количество();
		
		рЗаказа 	  = Новый Структура("ПолученоКодовИзЧЗ", ПолученоКодов);
		//++Данилова Е.В. 30.01.2025
		//ЗаписаноКодов = КоличестваКодовПоЗаказу(ЗаказКМ);
		ЗаписаноКодов = КоличестваКодовПоЗаказу(ЗаказКМ).ПолученоКМ;
		//--Данилова Е.В. 30.01.2025
		
		Если ПолученоКодов >= ПолучитьРеквизитШапки(ЗаказКМ, "КоличествоДокумента") Тогда
			рЗаказа.Вставить("Статус", ?(ЗаписаноКодов = ПолученоКодов, Перечисления.СтатусыДокументовМаркировки.Обработан, Перечисления.СтатусыДокументовМаркировки.ОбработанЧЗ));
		КонецЕсли;
		
		УстановитьРеквизитыОбъекта(ЗаказКМ, рЗаказа, РежимЗаписиДокумента.Проведение);
		
		ОбработаноОбъектов = ПолученоКодов;
	КонецЕсли;
	
	Результат.Вставить("ОбработаноОбъектов", ОбработаноОбъектов);
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И ОбработаноОбъектов>0);
	
	Возврат Результат;
КонецФункции //ЗагрузитьКодыПоЗаказуКМ(ЗаказКМ)

Функция ПолучитьКодыНаборов(ДокМаркировки)
	Запрос	= Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ
	|	ШтрихкодНабора,
	|	ШтрихкодНабора.Наименование 	КАК Набор_КМ,
	|	ШтрихкодУпаковки.Наименование	КАК Комплектующее_КМ
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок	 
	|ГДЕ
	|	Ссылка = &ДокМаркировки
	|ИТОГИ ПО
	|	ШтрихкодНабора
	|";
	
	Запрос.УстановитьПараметр("ДокМаркировки", ДокМаркировки);
	
	Результат = Новый Массив;
	
	рЗапроса		= Запрос.Выполнить();
	Выборка_Набор	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихкодНабора");
	Пока Выборка_Набор.Следующий() Цикл
		Коды = Новый Массив;
		Выборка = Выборка_Набор.Выбрать();
		Пока Выборка.Следующий() Цикл
			Коды.Добавить(Выборка.Комплектующее_КМ);		
		КонецЦикла;
		
		Результат.Добавить(Новый Структура("unitSerialNumber,sntins", Выборка_Набор.Набор_КМ, Коды));
	КонецЦикла;
	
	Возврат Результат;	
КонецФункции //ПолучитьКодыНаборов(ДокМаркировки) 

