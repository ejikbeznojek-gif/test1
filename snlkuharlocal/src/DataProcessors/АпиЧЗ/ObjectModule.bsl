Функция ЗаписатьРезультатыОбработкиДокументаМаркировки(ДокСсылка, ДокИнфоЧЗ)
	ВидОперацииИСМП = ПолучитьРеквизитШапки(ДокСсылка, "ВидОперацииИСМП");	
	
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.АТК Тогда
		ДокОбъект = ДокСсылка.ПолучитьОбъект();
		Если 1=2 Тогда
			ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();	
		КонецЕсли; 
		
		ДокОбъект.АТК = ДокИнфоЧЗ.atk;
		
		ДокОбъект.ОбменДанными.Загрузка = Истина;
		ДокОбъект.Записать();
	КонецЕсли; 
	
	УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.Обработан), РежимЗаписиДокумента.Проведение);
	
	Если ПолучитьРеквизитОбъекта(ДокСсылка, "Проведен") Тогда
		ДокОбъект = ДокСсылка.ПолучитьОбъект();
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
	КонецЕсли;
КонецФункции //ЗаписатьРезультатыОбработкиДокументаМаркировки(ДокСсылка, ДокИнфоЧЗ)
 

