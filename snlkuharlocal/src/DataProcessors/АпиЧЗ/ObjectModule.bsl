Функция ОтправитьНаОбработку_ОперМаркировки(ДокСсылка, ДопПараметры = Неопределено, АдресВозврата = неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли;
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка, ДопПараметры);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
	Иначе			             
		МаркировкаКС.ДобавитьОшибки(Результат, рПроверкиПодкл);
