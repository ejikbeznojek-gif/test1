Функция ПолучитьРезультаты_РегистрацияКарточекНоменклатурывНК(ДокСсылка, пОбработки = Неопределено) Экспорт
	Результат 		= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");		
		Возврат Результат;
	КонецЕсли; 
		
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
	Иначе			
		Результат.Ошибки.Добавить("Не указаны параметры подключения к СУЗ !");
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	рПроверкиСтатуса = ПолучитьСтатус_ФИД(ДокСсылка);	
	Если рПроверкиСтатуса.Успешно Тогда
		Если ВРег(рПроверкиСтатуса.Данные) = ВРег("Received")
			ИЛИ ВРег(рПроверкиСтатуса.Данные) = ВРег("Moderated")
			ИЛИ ВРег(рПроверкиСтатуса.Данные) = ВРег("Signed") Тогда			
			рПолучения = ПолучитьИнфоОКарточкахЗаказа(ДокСсылка);
			Если рПолучения.Успешно Тогда
				Результат.Данные	= рПолучения.Данные;
				
				тКарточки			= рПолучения.Данные;
				
				//ОбновитьСтатусыКарточек(тКарточки);
				ОбновитьСтатусыКарточекВЗаказе(ДокСсылка, тКарточки);
				
				Результат.Успешно = Истина;
			Иначе			
				ДобавитьОшибки(Результат, рПолучения);
			КонецЕсли;
		Иначе
			Результат.Сообщения.Добавить("Статус обработки в ЧЗ: "+рПроверкиСтатуса.Данные);			
		КонецЕсли;
	Иначе		
		ДобавитьОшибки(Результат, рПроверкиСтатуса);		
	КонецЕсли;
	
	Возврат Результат;
