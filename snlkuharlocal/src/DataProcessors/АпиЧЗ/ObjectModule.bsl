Функция ОбновитьСтатусыКарточек(тКарточки)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Карточки ИЗ &тКарточки КАК тКарточки
	|;
	|ВЫБРАТЬ
	|	ВТ_Карточки.ГТИН					КАК ГТИН,
	|	ВТ_Карточки.Статус					КАК СтатусЧЗ,
	|	СпрНоменклатура.СтатусКарточкиВЧЗ	КАК СтатусСпр,
	|	СпрНоменклатура.Ссылка 				КАК Номенклатура,
	|	СпрНоменклатура.Код 				КАК Номенклатура_Код	
	|ИЗ
	|	ВТ_Карточки
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|ПО
	|	ВТ_Карточки.ГТИН = СпрНоменклатура.ГТИН
	|	И СпрНоменклатура.СтатусКарточкиВЧЗ <> ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.Создана)
	|ГДЕ
	|	НЕ СпрНоменклатура.Ссылка ЕСТЬ NULL
	|";
	
	
	Запрос.УстановитьПараметр("тКарточки", тКарточки);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
			Если Выборка.СтатусСпр = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НеСоздана			
				ИЛИ Выборка.СтатусСпр = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.КОтправкевНК
				ИЛИ Выборка.СтатусСпр = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Создана Тогда
				
				Если Выборка.СтатусЧЗ = "moderation" Тогда
					УстановитьРеквизитыОбъекта(Выборка.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НаМодерации));
					ОповеститьОбИзменении_(Выборка.Номенклатура); //Может поможет обновить форму......
				ИначеЕсли Выборка.СтатусЧЗ = "published" Тогда
					УстановитьРеквизитыОбъекта(Выборка.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована)); 			
					ОповеститьОбИзменении_(Выборка.Номенклатура); //Может поможет обновить форму......
				Иначе
					ТекстСообщения = СтрШаблон("Необрабатываемый статус карточки в ЧЗ: '%1'. Номенклатура: %2 (%3). GTIN: '%4'.",
						Выборка.СтатусЧЗ, Выборка.Номенклатура, Выборка.Номенклатура_Код, Выборка.ГТИН);
					Сообщить(ТекстСообщения, СтатусСообщения.БезСтатуса);
				КонецЕсли;		
			ИначеЕсли 
				Выборка.СтатусСпр = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НаМодерации 
				ИЛИ Выборка.СтатусСпр = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Создана Тогда
				Если Выборка.СтатусЧЗ = "signed" Тогда                                                                                                            
					УстановитьРеквизитыОбъекта(Выборка.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.ОжидаетПодписания));
					ОповеститьОбИзменении_(Выборка.Номенклатура); //Может поможет обновить форму......
				ИначеЕсли Выборка.СтатусЧЗ = "published" Тогда
					УстановитьРеквизитыОбъекта(Выборка.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована));
					ОповеститьОбИзменении_(Выборка.Номенклатура); //Может поможет обновить форму......
				КонецЕсли;		
			Иначе
				ТекстСообщения = СтрШаблон("Не обрабатываемый статус карточки в базе: '%1'. Номенклатура: %2 (%3). GTIN: '%4'.",
						Выборка.СтатусСпр, Выборка.Номенклатура, Выборка.Номенклатура_Код, Выборка.ГТИН);
				Сообщить(ТекстСообщения, СтатусСообщения.Важное);				
			КонецЕсли;			
		Иначе
			Сообщить("Ошибка обновления статуса карточки ! Не найдена номенклатура по GTIN: "+Выборка.ГТИН, СтатусСообщения.ОченьВажное);		
		КонецЕсли;			
	КонецЦикла; 	
	
КонецФункции //ОбновитьСтатусыКарточек(тКарточки)

Функция ОбновитьСтатусыКарточекВЗаказе(ДокСсылка, Знач тКарточки)
	тКарточки.Колонки.Добавить("Статус1С", Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыКарточкиНоменклатурыВЧЗ"));
	
	Для Каждого СтрокаТЧ Из тКарточки Цикл
		СтрокаТЧ.Статус1С = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.СтатусЧЗ_Статус1С(СтрокаТЧ.Статус);
	КонецЦикла;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Карточки ИЗ &тКарточки КАК тКарточки
	|;
	|ВЫБРАТЬ
	|	ВТ_Карточки.ГТИН					КАК ГТИН,
	|	ВТ_Карточки.Статус1С				КАК Статус,	
	|	СпрНоменклатура.Ссылка 				КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_Статусы
	|ИЗ
	|	ВТ_Карточки
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|ПО
	|	ВТ_Карточки.ГТИН = СпрНоменклатура.ГТИН	
	|ГДЕ
	|	НЕ СпрНоменклатура.Ссылка ЕСТЬ NULL
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|ВЫБРАТЬ
	|   ТЧ_Товары.НомерСтроки	КАК НомерСтроки,
	|	ТЧ_Товары.Номенклатура	КАК Номенклатура, 
	|	ВТ_Статусы.Статус 		КАК Статус
	|ИЗ
	|	Документ.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.Товары КАК ТЧ_Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_Статусы
	|ПО
	|	ТЧ_Товары.Номенклатура	= ВТ_Статусы.Номенклатура
	|ГДЕ
	|	Ссылка = &ДокСсылка	
	|	И НЕ ВТ_Статусы.Статус ЕСТЬ NULL
	|	И НЕ ВТ_Статусы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)
	|	И ВТ_Статусы.Статус <> ТЧ_Товары.Статус
	|";
	
	Запрос.УстановитьПараметр("тКарточки", тКарточки);
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	ЗарегистрированоКарточек = 0;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 Тогда
		ДокОбъект = ДокСсылка.ПолучитьОбъект();		
		
		Пока Выборка.Следующий() Цикл                        
			СтрокаТЧ = ДокОбъект.Товары[Выборка.НомерСтроки-1];
			Если СтрокаТЧ.Номенклатура = Выборка.Номенклатура Тогда
				СтрокаТЧ.Статус = Выборка.Статус;							
			КонецЕсли;			
		КонецЦикла;	
		
		Опубликованы = Истина; 
		Для Каждого СтрокаТЧ Из ДокОбъект.Товары Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) И СтрокаТЧ.Статус <> Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована Тогда
				Опубликованы = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла; 
		
		Если Опубликованы Тогда		
			ДокОбъект.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан;
		КонецЕсли;		
		
		ДокОбъект.Записать(?(ДокОбъект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
	КонецЕсли;

КонецФункции // ()

Функция ПроверитьОрганизациюСУЗ(СтанцияСУЗ, ДокСсылка)
	Результат = МаркировкаКС.СтруктураРезультата();
	
    Организация_Док = ПолучитьРеквизитШапки(ДокСсылка, 	"Организация");
	Организация_СУЗ = ПолучитьРеквизитШапки(СтанцияСУЗ, "Владелец");
	Если Организация_Док <> Организация_СУЗ Тогда                                                                                                
		Результат.Успешно = Ложь;
		ТекстОшибки = СтрШаблон("Не совпадает организация документа: '%1' и организация текущего СУЗ: '%2' !", Организация_Док, Организация_СУЗ);			
		Результат.Ошибки.Добавить(ТекстОшибки);							
	КонецЕсли;                                                  
	
	Возврат Результат;
КонецФункции //ПроверитьОрганизациюСУЗ(СтанцияСУЗ, ДокСсылка)
