Функция ПолучитьОшибкиИзОтвета(ДанныеОтвета) Экспорт
	Ошибки = Новый Массив;
	success = ПолучитьЗначениеПараметра(ДанныеОтвета, "success", Истина);
	Если success Тогда
		Возврат Ошибки;					
	Иначе		
		globalErrors = ПолучитьЗначениеПараметра(ДанныеОтвета, "globalErrors", Новый Массив);
		Для Каждого Ошибка Из globalErrors Цикл
			Ошибки.Добавить(СтрШаблон("Ошибка: %1. %2.", Ошибка.errorCode, Ошибка.error));			
		КонецЦикла; 
		
		fieldErrors = ПолучитьЗначениеПараметра(ДанныеОтвета, "fieldErrors", Новый Массив);
		Для Каждого Ошибка Из fieldErrors Цикл
			Ошибки.Добавить(СтрШаблон("Ошибка: %1. %2.", Ошибка.fieldError, Ошибка.fieldName));			
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ошибки;
КонецФункции // ()

Функция ЭтоОшибкаТокена(ТекстОтвета)
	Результат = Ложь;
	Если СтрНачинаетсяС(СокрЛП(ТекстОтвета), "{") И СтрНайти(ТекстОтвета, "errorCode") <> 0 Тогда
		Попытка
			Данные 			= ПрочитатьЖСОН(ТекстОтвета);
			globalErrors 	= МаркировкаКС.ПолучитьЗначениеПараметра(Данные, "globalErrors");
			errorCode		= МаркировкаКС.ПолучитьЗначениеПараметра(globalErrors, "errorCode");
			
			Результат = (errorCode = 1100);
		Исключение
		КонецПопытки;
	КонецЕсли;    
	
	Возврат Результат;
КонецФункции //ЭтоОшибкаТокена(ТекстОтвета)


