Функция ПолучитьДанныеКарточекТовара(тСсылок)
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Товары ИЗ &тСсылок КАК тСсылок
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_Товары.Номенклатура.Родитель КАК Модель,
	|	МАКСИМУМ(Категория) 			КАК Категория
	|ПОМЕСТИТЬ ВТ_Категории
	|ИЗ
	|	ВТ_Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.КатегорииОбъектов КАК Категории
	|ПО
	|	Категории.Объект = ВТ_Товары.Номенклатура.Родитель
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Товары.Номенклатура.Родитель
	|ИНДЕКСИРОВАТЬ ПО
	|	Модель
	|;
	|ВЫБРАТЬ
	|	Владелец 				КАК Номенклатура,
	|	МАКСИМУМ(Наименование) 	КАК ШК	
	|ПОМЕСТИТЬ ВТ_ШК
	|ИЗ
	|	Справочник.ШтрихКоды КАК СпрШтрихКоды
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_Товары
	|ПО
	|	ВТ_Товары.Номенклатура = СпрШтрихКоды.Владелец
	|ГДЕ
	|	ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И ВидШК = ЗНАЧЕНИЕ(Перечисление.ВидыШК.Основной)
	|СГРУППИРОВАТЬ ПО 
	|	Владелец
	|;
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура 			КАК Набор,
	|	Комплектующие.Номенклатура.ГТИН	КАК Комплектующее_ГТИН,	
	
	|	Комплектующие.Количество	    КАК Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК Комплектующие
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_Товары 
	|ПО
	|	Комплектующие.Ссылка = ВТ_Товары.Номенклатура
	|	И Комплектующие.Количество > 0	
	|ИТОГИ ПО
	|	Набор
	|;
	|ВЫБРАТЬ
	|	IsNULL(ВТ_Категории.Категория.Код,"""")						КАК _Категория,
	|
	|	ВТ_Товары.Номенклатура.Родитель		 						КАК _Модель,	    
	|	ВТ_Товары.Номенклатура.Родитель.ВидНоменклатурыЧЗ			КАК _ВидНоменклатурыЧЗ,	    
	|	ВТ_Товары.Номенклатура.Родитель.НазваниеТовараДляСайта		КАК _НаименованиеПолное,
	|	ВТ_Товары.Номенклатура.Родитель.Страна.КодАльфа2			КАК _Страна,
	//Кухарь А.Ю.  16.03.2026 начало      
	//MARK-3537
	// 	|	ВТ_Товары.Номенклатура.Родитель.КодПроизводителя			КАК _Артикул,
	|	ВТ_Товары.Номенклатура.Родитель.АртикулЧЗ			КАК _Артикул, 
	//Кухарь А.Ю.  16.03.2026 конец
	|	ВТ_Товары.Номенклатура.Родитель.ТНВЭД.Код					КАК tnved,	
	|	ВТ_Товары.Номенклатура.Родитель.ТНВЭД.КоличествоСимволовВКарточку КАК _КоличествоСимволовВКарточку,
	|	ВТ_Товары.Номенклатура.Родитель.ФР_Бренд.НаименованиеПолное	КАК brand, 
	|
	|	ВТ_Товары.Номенклатура				 						КАК _Номенклатура,	
	|	ВТ_Товары.Номенклатура.ВидКомплекта							КАК _ВидКомплекта,
	|	ВТ_Товары.Номенклатура.Код			 						КАК _Код,	
	|	ВТ_Товары.Номенклатура.НаименованиеGS1 						КАК good_name,
	//++Данилова Е.В. 03.07.2026 Изм.№0000000172
	//|	ВТ_Товары.Номенклатура.Цвет.ОсновнойЦвет.ЦветЧЗ				КАК _Цвет,	
	|	ВТ_Товары.Номенклатура.Цвет.ЦветЧЗ							КАК _Цвет,
	//--Данилова Е.В. 03.07.2026 
	|	ВТ_Товары.Номенклатура.РазмерДляСайта 						КАК _Размер,	
	|	ВТ_Товары.ГТИН												КАК gtin,
	|
	|	ЗначенияСвойств.Свойство.ИД_ЧЗ								КАК _Атрибут_ЧЗ_Ид,
	|	ЗначенияСвойств.Значение.Наименование						КАК _Атрибут_ЧЗ_Зн,
	|
	|	ВТ_Товары.Номенклатура.Родитель.ТНВЭД.ТипРазмера.Наименование КАК _ТипРазмера
	|ИЗ
	|	ВТ_Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_Категории
	|ПО
	|	ВТ_Товары.Номенклатура.Родитель = ВТ_Категории.Модель
	|ЛЕВОЕ СОЕДИНЕНИЕ
