Функция ПолучитьТелоЗапроса_ВыводИзОборота_ОперМаркировки(ДокМаркировки, ВидОперацииИСМП)	
	
	Товары = Новый Массив;
	//++Данилова Е.В. 20.11.2025 MARK-2862 
	ПрефиксАгрегации = ПолучитьПрефиксАгрегации(ДокМаркировки);	  
	//--Данилова Е.В. 20.11.2025 
	
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа
		ИЛИ ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_РозничнаяПродажа Тогда
		рКоды = ПолучитьКодыМаркировкиПоМТ_СЦенами(ДокМаркировки);
		Если рКоды.Успешно Тогда
			Для Каждого СтрокаК Из рКоды.Данные Цикл  
				
				Товары.Добавить(Новый Структура("cis,product_cost", СтрокаК.СГТИН, 100*СтрокаК.Цена));
				
			КонецЦикла;
		КонецЕсли;
	Иначе
		мКодыМаркировки = ПолучитьКодыМаркировкиПоМТ(ДокМаркировки);		
		Для Каждого СтрокаКода Из мКодыМаркировки Цикл	
			//++Данилова Е.В. 20.11.2025 MARK-2862
			//Товары.Добавить(Новый Структура("cis", СтрокаКода.СГТИН));
			Если СтрокаКода.ТипШК = Перечисления.ТипыШтрихКодов.Штука Тогда
			    Товары.Добавить(Новый Структура("cis", СтрокаКода.СГТИН));				
			Иначе 
				Товары.Добавить(Новый Структура("cis", ПрефиксАгрегации  + СтрокаКода.СГТИН));
			КонецЕсли;
			//--Данилова Е.В. 20.11.2025
		КонецЦикла;
	КонецЕсли;	
	
	Пакет = Новый Структура;
	//Пакет.Вставить("productGroup", "lp");
	//++Данилова Е.В. 11.06.2026 №0000001162
//	рШапки = ПолучитьРеквизитыШапки(ДокМаркировки, "
//		|Дата,Номер,Организация,Организация.ИНН,ТипДокумента,НаименованиеПервичногоДокумента,ОписаниеПричины,ИдентификаторГосКонтракта,
//		|ДокументОснование.Номер,ДокументОснование.Дата,
//		|Страна.Код,Страна.КодАльфа2,Страна.КодАльфа3,ИмпортерИД,ИННПокупателя");
	рШапки = ОбщегоНазначенияС.ПолучитьРеквизитыШапкиСервер(ДокМаркировки, "
		|Дата,Номер,Организация,Организация.ИНН,ТипДокумента,НаименованиеПервичногоДокумента,ОписаниеПричины,ИдентификаторГосКонтракта,
		|ДокументОснование.Номер,ДокументОснование.Дата,
		|Страна.Код,Страна.КодАльфа2,Страна.КодАльфа3,ИмпортерИД,ИННПокупателя,ПодразделениеНанесения.КПП,ПодразделениеНанесения.ИдентификаторФИАС");
	//--Данилова Е.В. 11.06.2026 
	ТипДокумента 	= ПолучитьИипДокументаЧЗ(рШапки.ТипДокумента);
	Основание_Номер	= рШапки.ДокументОснование_Номер;
	Основание_Дата	= Формат(рШапки.ДокументОснование_Дата, "ДФ=yyyy-MM-dd");
	//++Данилова Е.В. 11.06.2026 №0000001162
	Подразделение_КПП 				= рШапки.ПодразделениеНанесения_КПП;
	Подразделение_ИдентификаторФИАС = рШапки.ПодразделениеНанесения_ИдентификаторФИАС;
	//--Данилова Е.В. 11.06.2026 
	Пакет.Вставить("inn", 			рШапки.Организация_ИНН);
	
	Пакет.Вставить("action", 		Перечисления.ВидыОперацийИСМП.КодЧЗ(ВидОперацииИСМП));	
	Пакет.Вставить("action_date",   Формат(рШапки.Дата, "ДФ=yyyy-MM-dd"));	
	
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_БезвозмезднаяПередача Тогда				
		Пакет.Вставить("document_number", 	Основание_Номер);
		Пакет.Вставить("document_date",		Основание_Дата);
		
		Если ТипДокумента = Перечисления.ТипыДокументовИСМП.Прочее Тогда
			Пакет.Вставить("primary_document_custom_name", рШапки.НаименованиеПервичногоДокумента);
		КонецЕсли;
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ВозвратФизическомуЛицу Тогда				
		Пакет.Вставить("document_type",		"OTHER");
		Пакет.Вставить("document_number", 	Основание_Номер);
		Пакет.Вставить("document_date",		Основание_Дата);		                           
		
		Пакет.Вставить("primary_document_custom_name", рШапки.НаименованиеПервичногоДокумента);		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ДистанционнаяПродажа Тогда				
		Пакет.Вставить("document_type",		ТипДокумента);
		Пакет.Вставить("document_number", 	Основание_Номер);
		Пакет.Вставить("document_date",		Основание_Дата);		                           
		//++Данилова Е.В. 11.06.2026 №0000001162
		Пакет.Вставить("kpp", Подразделение_КПП);
		Пакет.Вставить("fias_id", Подразделение_ИдентификаторФИАС);
		//--Данилова Е.В. 11.06.2026 
		Если ТипДокумента = "OTHER" Тогда		
			Пакет.Вставить("primary_document_custom_name", рШапки.НаименованиеПервичногоДокумента);
		КонецЕсли;
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_ИспользованиеДляСобственныхНужд Тогда				
		Пакет.Вставить("document_type",		"OTHER");
		Пакет.Вставить("document_number", 	Основание_Номер);
		Пакет.Вставить("document_date",		Основание_Дата);
		Пакет.Вставить("buyer_inn",			рШапки.ИННПокупателя);
		
		Пакет.Вставить("primary_document_custom_name", рШапки.НаименованиеПервичногоДокумента);		
	ИначеЕсли ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВыводИзОборота_Конфискация Тогда				
		Пакет.Вставить("document_type",		ТипДокумента);
		Пакет.Вставить("document_number", 	Основание_Номер);
		Пакет.Вставить("document_date",		Основание_Дата);		                           
		
		Если ТипДокумента = "OTHER" Тогда
			Пакет.Вставить("primary_document_custom_name", рШапки.НаименованиеПервичногоДокумента);		
		КонецЕсли;	
