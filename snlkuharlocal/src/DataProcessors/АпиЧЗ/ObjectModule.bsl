Функция СоздатьПараметрыCMS(Открепленная = Истина)
	
	ПараметрыCMS = Новый Структура("ТипПодписи,Открепленная", "CAdES-BES", Открепленная);
	
	
	ВключениеСертификатовВПодпись = РежимВключенияСертификатовКриптографии.НеВключать;		
	ВключениеСертификатовВПодпись = РежимВключенияСертификатовКриптографии.ВключатьСертификатСубъекта;		
	
	ПараметрыCMS.Вставить("ВключениеСертификатовВПодпись", ВключениеСертификатовВПодпись);
	
	Возврат ПараметрыCMS;
КонецФункции // ()

Функция НайтиСертификатПоОтпечатку(Отпечаток)
	Результат 	= Неопределено;
	
	Менеджер	= Новый МенеджерКриптографии("Crypto-Pro GOST R 34.10-2012 Cryptographic Service Provider","",80);
	Хранилище 	= Менеджер.ПолучитьХранилищеСертификатов(ТипХранилищаСертификатовКриптографии.ПерсональныеСертификаты);
	
	СписокСертификатов = Новый СписокЗначений;
	Для Каждого Сертификат Из Хранилище.ПолучитьВсе() Цикл		
		Если ДДвHEX(Сертификат.Отпечаток) = Отпечаток Тогда			
			Результат = Сертификат;						
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции // ()
 
Функция ПодписатьПо1Совски(Данные, Отпечаток, Открепленная = Истина)
	
	Попытка
		МенеджерКриптографии	= Новый МенеджерКриптографии("Crypto-Pro GOST R 34.10-2012 Cryptographic Service Provider", "", 80);	
	Исключение		
		ТекстОшибки = СтрШаблон("Ошибка формирования подписи данных !
		|%1. Компьютер: %2.", ОписаниеОшибки(), ИмяКомпьютера());
		
		ЗаписатьВЛог("Токены ЧЗ", ТекстОшибки, "Ошибка");
		ВызватьИсключение ТекстОшибки; 
	КонецПопытки;	
	
	СертификатКриптографии 	= НайтиСертификатПоОтпечатку(Отпечаток);
	
	Возврат ПодписатьCMS(Данные, СоздатьПараметрыCMS(Открепленная), СертификатКриптографии, МенеджерКриптографии);

КонецФункции //ПодписатьПо1Совски(Данные)


