Функция ОтправитьЗапрос_Агрегация(ДокСсылка) Экспорт
	Результат 	= СтруктураРезультата(Ложь);		 	
	
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда
		ТелоЗапроса	= ПолучитьТелоЗапроса_Агрегация_ОперМаркировки(ДокСсылка);
	Иначе
		ТелоЗапроса	= ПолучитьТелоЗапроса_Агрегация_ЗаказКМ(ДокСсылка);
	КонецЕсли;	
	Подпись		= ДвоичныеДанныеBase64(ПодписатьПо1Совски(ТелоЗапроса, ТекущийОтпечатокСертификатаЭЦП));	
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();
	
	ЗапросЕМСД = Новый Структура;
	ЗапросЕМСД.Вставить("document_format", 	"MANUAL");
	ЗапросЕМСД.Вставить("product_document", Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(ТелоЗапроса)));
	ЗапросЕМСД.Вставить("signature", 		Подпись);
	ЗапросЕМСД.Вставить("type",				"AGGREGATION_DOCUMENT");	
	
	ДопЗаголовки 	= Новый Соответствие;
	
	АдресРесурса	= "api/v3/true-api/lk/documents/create?pg=lp";
	
	ЗапросХТТП 		= СоздатьЗапрос_TrueApi(АдресРесурса, ЗаписатьЖСОН(ЗапросЕМСД), ДопЗаголовки);
	
	ДопПараметры 	= Новый Структура("Основание,ТелоЗапроса", ДокСсылка, ТелоЗапроса);
	рЗапроса 		= ВыполнитьЗапрос_TrueApi(ЗапросХТТП, "POST", СоединениеХТТП, ДопПараметры);
	
	Если рЗапроса.Успешно Тогда
		УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("Статус,ИД_ДокументаЧЗ", Перечисления.СтатусыДокументовМаркировки.Обрабатывается, рЗапроса.Ответ));
		Результат.Успешно = Истина;
	Иначе
		ДобавитьОшибки(Результат, рЗапроса);
	КонецЕсли;

	Возврат Результат;
