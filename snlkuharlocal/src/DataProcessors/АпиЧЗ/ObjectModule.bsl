Функция ОтправитьКарточкуТовараНаРегистрацию(Номенклатура) Экспорт
	АдресРесурса 	= "v3/feed";
	
	ТекстЗапроса	= ПолучитьДанныеКарточкиТовара(Номенклатура);
	ЗапросХТТП		= СоздатьЗапрос_НК(АдресРесурса, ТекстЗапроса);	
	
	рЗапроса	 	= ВыполнитьЗапрос_НК(ЗапросХТТП, "POST");
	
	Если рЗапроса.Успешно Тогда		
		Данные	= ПрочитатьЖСОН(рЗапроса.Ответ);
		feed_id =  Данные.result.feed_id;	
	КонецЕсли;
КонецФункции // ()

Функция ПолучитьДанныеКарточкиТовара(Номенклатура)
	Данные = Новый Структура;
	
	Данные = ПолучитьДанныеКарточекТовара(Номенклатура);
	
	Возврат ЗаписатьЖСОН(ТЗвМассивСтруктур(Данные));
КонецФункции //
 
Функция ОтправитьЗапрос_РегистрацияКарточекНоменклатуры(ДокСсылка, ОтпечатокСертификатаЭЦП) Экспорт
	тНоменклатуры	= ПолучитьТаблицуКарточек(ДокСсылка);
	ДанныеКарточек	= ПолучитьДанныеКарточекТовара(тНоменклатуры);	
	ДанныеЗапроса	= ЗаписатьЖСОН(ТЗвМассивСтруктур(ДанныеКарточек));	
	
	Токен_НК		= ХранилищеОбщихНастроек.Загрузить(КлючОбъекта_ДляНастроек, "Токен_TrueApi");
	
	АдресРесурса 	= "v3/feed";
	
	ЗапросХТТП		= СоздатьЗапрос_НК(АдресРесурса, ДанныеЗапроса);		
	
	рЗапроса		= ВыполнитьЗапрос_НК(ЗапросХТТП, "POST", , Новый Структура("Основание", ДокСсылка));
	Если рЗапроса.Успешно Тогда
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);
		УстановитьРеквизитыОбъекта(ДокСсылка, Новый Структура("Статус,ИД_ДокументаЧЗ", Перечисления.СтатусыДокументовМаркировки.Обрабатывается, Данные.result.feed_id));		
	КонецЕсли; 

	Возврат рЗапроса;
КонецФункции //ОтправитьНоменклатуруНаРегистрацию(ДокСсылка)

Функция ПолучитьТаблицуКарточек(ДокСсылка)
	Запрос 			= Новый Запрос;
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	ГТИН
	|ИЗ
	|	Документ.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.Товары
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции // ()

