	Для Каждого СтрокаС Из тСостав Цикл		
		Строки.Добавить(СтрШаблон("%1 %2", СтрокаС.Материал, СтрокаС.Процент)+"%");		
	КонецЦикла; 
	
	Возврат Новый Структура("Таблица,Строка", тСостав, СтрСоединить(Строки, ", "));
КонецФункции //ПолучитьСостав(Модель)

// Функция - Получить атрибуты группы товаров НК
//
// Параметры:
//  КодТНВЭД4	 4 первых цифры ТНВЭД 
//  ТипАтрибута	 - 	
//		attr_type — тип атрибута (необязательный). Может принимать следующие значения:
//  		a — (используется по умолчанию) вернуть все атрибуты
//  		m — вернуть только обязательные атрибуты
//  		r — вернуть только рекомендуемые атрибуты
//  		o — вернуть только опциональные атрибуты
// Возвращаемое значение:
//   Структура результата 
Функция ПолучитьАтрибутыГруппыТоваровНК(КодТНВЭД4, ТипАтрибута = "a", ДляНабора = Ложь) Экспорт
	рПроверкиПодкл	= ПроверитьПолучитьПараметрыПодключенияTrueApi(Неопределено);
	
	Если НЕ рПроверкиПодкл.Успешно Тогда				
		Возврат рПроверкиПодкл;		
	КонецЕсли;
	
	Результат 		= СтруктураРезультата();
	АдресРесурса 	= "/v3/attributes?tnved=" + КодТНВЭД4 + "&attr_type=" + ТипАтрибута;
	Если ДляНабора Тогда		
		АдресРесурса = АдресРесурса + "&is_set=1";
	КонецЕсли; 
	рЗапроса		= ВыполнитьЗапрос_НК(АдресРесурса, "GET");
	
	Если рЗапроса.Успешно Тогда		
		СтрокаЖСОН 			= ЗаписатьЖСОН(ПрочитатьЖСОН(рЗапроса.Ответ)); //Ответ приходит в одну строку - не читабельно
		Результат.Данные	= ПолучитьДвоичныеДанныеИзСтроки(СтрокаЖСОН, КодировкаТекста.UTF8);
	Иначе
		Результат.Ошибки.Добавить(рЗапроса.Ответ);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПолучитьАтрибутыГруппыТоваровНК(КодТНВЭД4, ТипАтрибута = "a")

Функция ВложеноШтук(Набор)
	Результат = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	Номенклатура,
	|	Номенклатура.Родитель.ВидКомплекта КАК ВидКомплекта,
	|	Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	Ссылка = &Набор
	|";
	
	Запрос.УстановитьПараметр("Набор", Набор);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			Если Выборка.ВидКомплекта = Перечисления.ВидыКомплектов.Товар Тогда
				Результат = Результат + Выборка.Количество;
			Иначе
				Результат = Результат + Выборка.Количество * ВложеноШтук(Выборка.Номенклатура);
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Результат;	
КонецФункции //ВложеноШтук(Набор)

Функция СоставНабораРазобраныйДоШтук(Набор, КоличествоНаборов = 1)
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ГТИН", 			ПолучитьОписаниеТиповСтроки(200));
	Результат.Колонки.Добавить("Количество",	ПолучитьОписаниеТиповЧисла(5));
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ	
	|	Номенклатура						КАК Номенклатура,
	|	Номенклатура.ГТИН					КАК ГТИН,
	|	Номенклатура.Родитель.ВидКомплекта	КАК ВидКомплекта,
	|	Количество
	|ИЗ
	|	Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	|ГДЕ
	|	Ссылка = &Набор
	|	И Количество>0
	|";
	
	Запрос.УстановитьПараметр("Набор", Набор);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			Если Выборка.ВидКомплекта = Перечисления.ВидыКомплектов.Товар Тогда
				СтрокаР = Результат.Добавить();
				СтрокаР.ГТИН 		= Выборка.ГТИН;
				СтрокаР.Количество 	= Выборка.Количество * КоличествоНаборов;				
			Иначе                   
				Вложения = СоставНабораРазобраныйДоШтук(Выборка.Номенклатура, Выборка.Количество);
				Для каждого СтрокаВ Из Вложения Цикл
					СтрокаР = Результат.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаР, СтрокаВ);
				КонецЦикла;				
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Результат;	
