Функция ВыполнитьКоманду(Команда, пОбработки = Неопределено) Экспорт
	Результат 		= Новый Структура("Успешно,Ошибки,ОбработаноОбъектов", Истина, Новый Массив, 0);
	
	ДокСсылка		= ПолучитьЗначениеПараметра(пОбработки, "ДокСсылка");	
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли; 
	
	Организация		= ПолучитьРеквизитШапки(ДокСсылка, "Организация", "Документ");	
	
	Если Команда = "ОтправитьНоменклатуруНаРегистрацию" Тогда
		рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка);
		
		Если НЕ рПроверкиПодкл.Успешно Тогда			
			Результат.Ошибки.Добавить("Не указаны параметры подключения к НК !");
			Результат.Успешно = Ложь;					
			Возврат Результат;
		КонецЕсли;		
		
		рОтправки = ОтправитьЗапрос_РегистрацияКарточекНоменклатуры(ДокСсылка, рПроверкиПодкл.ОтпечатокСертификатаЭЦП);
		
		Если рОтправки.Успешно Тогда
			Сообщить("Заказ на карточки отправлен на обработку в НК", СтатусСообщения.Информация);		
		Иначе
			Результат.Успешно = Ложь;
			ДобавитьОшибки(Результат, рОтправки);
		КонецЕсли;
		
	ИначеЕсли Команда = "ЗаказатьКоды" ИЛИ Команда = "ПолучитьКоды" Тогда
		
		рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияСУЗ(ДокСсылка, пОбработки);
		Если рПроверкиПодкл.Успешно Тогда
			СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
		Иначе			
			Результат.Ошибки.Добавить("Не указаны параметры подключения к СУЗ !");
			Результат.Успешно = Ложь;					
			Возврат Результат;
		КонецЕсли; 
		
		Если Команда = "ЗаказатьКоды" Тогда
		
			рОтправки = ОтправитьЗапрос_ЗаказКМ(ДокСсылка, СтанцияСУЗ, рПроверкиПодкл.ОтпечатокСертификатаЭЦП);
			Если рОтправки.Успешно Тогда
				Сообщить("Заказ на коды отправлен на обработку в СУЗ", СтатусСообщения.Информация);
			Иначе
				Результат.Успешно = Ложь;
				ДобавитьОшибки(Результат, рОтправки);
			КонецЕсли;
			
		ИначеЕсли Команда = "ПолучитьКоды" Тогда
			
			рПолучения = ПолучитьКодыПоЗаказуКМ_v3(ДокСсылка, СтанцияСУЗ);
			Если рПолучения.Успешно Тогда			
				Результат.ОбработаноОбъектов = рПолучения.ОбработаноОбъектов;
			Иначе
				Результат.Успешно = Ложь;
				ДобавитьОшибки(Результат, рПолучения);
			КонецЕсли;		    
			
		КонецЕсли;
		
	ИначеЕсли Команда = "ОтправитьНаОбработкуМТ" Тогда
		Сообщить("Команда: "+Команда);		
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции //ВыполнитьКоманду(Команда, пОбработки = Неопределено) Экспорт

Функция ОтправитьНаОбработку_РегистрацияКарточекНоменклатурыВНК(ДокСсылка, ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли;
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка);
	Если НЕ рПроверкиПодкл.Успешно Тогда		
		Результат.Ошибки.Добавить("Не указаны параметры подключения к API НК !");
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	рОтправки = ОтправитьЗапрос_РегистрацияКарточекНоменклатуры(ДокСсылка, рПроверкиПодкл.ОтпечатокСертификатаЭЦП);
	Если рОтправки.Успешно Тогда
		ТекстСобщения = СтрШаблон("Документ: '%1' отправлен на обработку в НК.", ДокСсылка);
		Сообщить(ТекстСобщения, СтатусСообщения.Информация);
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, рОтправки);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ОтправитьНаОбработку_ЗаказКМ(ДокСсылка, ДопПараметры = Неопределено) Экспорт  

