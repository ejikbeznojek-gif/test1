		рОтправки = ОтправитьЗапрос_Расформирование(ДокСсылка);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.АТК Тогда
		рОтправки = ОтправитьЗапрос_ГенерацияАТК(ДокСсылка);		
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВводВОборот Тогда
		рОтправки = ОтправитьЗапрос_ВводВОборот(ДокСсылка, ВидОперацииИСМП);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВыводИзОборота Тогда
		рОтправки = ОтправитьЗапрос_ВыводИзОборота(ДокСсылка, ВидОперацииИСМП);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.Списание Тогда
		рОтправки = ОтправитьЗапрос_Списание(ДокСсылка, ВидОперацииИСМП);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ВозвратВОборот Тогда
		рОтправки = ОтправитьЗапрос_ВозвратВОборот(ДокСсылка, ВидОперацииИСМП);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ОтгрузкаВЕАЭС Тогда
		рОтправки = ОтправитьЗапрос_ОтгрузкаВЕАЭС(ДокСсылка);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ФормированиеНабора Тогда
		рОтправки = ОтправитьЗапрос_ФормированиеНабора(ДокСсылка);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.Перемаркировка Тогда
		рОтправки = ОтправитьЗапрос_Перемаркировка(ДокСсылка);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияАТК Тогда
		рОтправки = ОтправитьЗапрос_ТрансформацияАТК(ДокСсылка);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийМаркировки.ТрансформацияУпаковки Тогда		
		рОтправки = ОтправитьЗапрос_ТрансформацияУпаковки(ДокСсылка, ВидОперацииИСМП);
	Иначе
		рОтправки = МаркировкаКС.СтруктураРезультата(Ложь);
		рОтправки.Ошибки.Добавить(СтрШаблон("Вид операции: '%1' пока не поддерживается.", ВидОперацииИСМП));		
	КонецЕсли; 
	
	Если рОтправки.Успешно Тогда
		ТекстСобщения = СтрШаблон("Док. маркировки: '%1' (%2) отправлен на обработку в ЧЗ.", ДокСсылка, ВидОперацииИСМП);
		Сообщить(ТекстСобщения, СтатусСообщения.Информация);
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, рОтправки);
	КонецЕсли;
	
	//++Данилова Е.В. 11.04.2025 MARK-1675
		
	Если ЗначениеЗаполнено(АдресВозврата) И ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);
	КонецЕсли;                                                  
	
	Если инт_ДлительныеОперации.ЭтоФоновоеЗадание() Тогда
		ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();			
	КонецЕсли;
	//--Данилова Е.В. 11.04.2025
	
	Возврат Результат;
