КонецФункции //ПолучитьКодыМаркировкиПоМТ(МТ_Ссылка)

Функция ПолучитьКодыМаркировкиПоМТ_СЦенами(МТ_Ссылка)
	Результат = СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|   Товары.НомерСтроки,
	|	Товары.Номенклатура,
	|	Товары.Количество,
	|	Товары.Цена,
	|
	|	ШК.ШтрихкодУпаковки.Наименование 	КАК СГТИН 
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.Товары КАК Товары
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ШК 
	|ПО
	|	ШК.Ссылка = Товары.Ссылка
	|	И ШК.ШтрихкодУпаковки.Владелец = Товары.Номенклатура	
	|ГДЕ	
	|	Товары.Ссылка = &МТ_Ссылка
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование
	|ИТОГИ  
	|	МАКСИМУМ(Номенклатура), МАКСИМУМ(Количество), МАКСИМУМ(Цена) 
	|ПО
	|	Товары.НомерСтроки
	|";
	
	Запрос.УстановитьПараметр("МТ_Ссылка", МТ_Ссылка);
	рЗапроса = Запрос.Выполнить();
	
	ТР = Новый ТаблицаЗначений;
	ТР.Колонки.Добавить("СГТИН");
	ТР.Колонки.Добавить("Цена");
	
	
	Остатки = Новый Соответствие;
	
	Выборка_НомерСтроки = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерСтроки");
	Пока Выборка_НомерСтроки.Следующий() Цикл
		НадоСписать = Выборка_НомерСтроки.Количество;
		
		мКоды = Остатки[Выборка_НомерСтроки.Номенклатура];
		Если мКоды=Неопределено Тогда
			мКоды = Новый Массив;	
		КонецЕсли; 
		
		Выборка = Выборка_НомерСтроки.Выбрать();
		Пока Выборка.Следующий() Цикл
			мКоды.Добавить(Выборка.СГТИН);	
		КонецЦикла; 
		
		Остатки[Выборка_НомерСтроки.Номенклатура] = мКоды;
	КонецЦикла; 
	
	Выборка_НомерСтроки = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерСтроки");
	Пока Выборка_НомерСтроки.Следующий() Цикл
		НадоСписать = Выборка_НомерСтроки.Количество;		
		мКоды 		= Остатки[Выборка_НомерСтроки.Номенклатура];	
		
		Пока НадоСписать>0 Цикл
			Если мКоды.Количество() = 0 Тогда Прервать КонецЕсли; 
			
			Строка = ТР.Добавить();
			
			Строка.СГТИН	= мКоды[0];
			Строка.Цена		= Выборка_НомерСтроки.Цена; 
						
			мКоды.Удалить(0);
			
			НадоСписать = НадоСписать - 1;		
		КонецЦикла; 
		
		Если НадоСписать>0 Тогда
			ТекстОшибки = СтрШаблон("Недостаточно кодов но номенклатуре: %1. Не хватает: %2 кодов.", Выборка_НомерСтроки.Номенклатура, НадоСписать);
			Результат.Ошибки.Добавить(ТекстОшибки);		
		КонецЕсли; 		
		
		Остатки[Выборка_НомерСтроки.Номенклатура] = мКоды;
	КонецЦикла;
	
	Результат.Успешно	= (Результат.Ошибки.Количество()=0);	
	Результат.Данные	= ТР;
	
	Возврат Результат;
КонецФункции //ПолучитьКодыМаркировкиПоМТ_СЦенами(МТ_Ссылка)

Функция СоздатьЗапрос_КодыМаркировкиЗПС_САгрегатами()
	Запрос	= Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ДокументОснование КАК ЗПС,
	|	Ссылка КАК Эмиссия
	|ПОМЕСТИТЬ ВТ_Эмиссии	
	|ИЗ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ
	|ГДЕ
	|	ДокументОснование = &ЗПС_Ссылка
	|;			
	|ВЫБРАТЬ
	|	IsNull(ДокАгрегации.КодАгрегации,""9999"")	КАК КодАгрегации,		
	|	ДокАгрегации.Ссылка							КАК ДокАгрегации,		
	|	ШК_ЧЗ.Владелец 								КАК Номенклатура,
	|	ШК_ЧЗ.Ссылка 								КАК КМ_Штука,
	|	СпрШК_КодыАгрегации.Ссылка					КАК КМ_Коробка,
	|	ШК_ЧЗ.Ссылка.Наименование 					КАК КМ_Штука_Наименование,
	|	СпрШК_КодыАгрегации.Ссылка.Наименование		КАК КМ_Коробка_Наименование
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШК_ЧЗ	
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_Эмиссии
	|ПО
	|	ШК_ЧЗ.ЗаказКМ = ВТ_Эмиссии.Эмиссия
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ДокАгрегации
	|ПО
	|	ДокАгрегации.ШтрихкодУпаковки 			= ШК_ЧЗ.Ссылка 
	|	И ДокАгрегации.Ссылка.ВидОперацииИСМП	= ЗНАЧЕНИЕ(Перечисление.ВидыОперацийИСМП.Агрегация)
	|	И ДокАгрегации.Ссылка.ДокументОснование = &ЗПС_Ссылка	
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК_КодыАгрегации	
	|ПО
	|	ДокАгрегации.КодАгрегации		= СпрШК_КодыАгрегации.Наименование
	|	И СпрШК_КодыАгрегации.ТипКода 	= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|ГДЕ
	|	ШК_ЧЗ.ТипКода 	= ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
	|УПОРЯДОЧИТЬ ПО		
	|	КодАгрегации,
	|	ШК_ЧЗ.Владелец,
	|	ШК_ЧЗ.Наименование
	|ИТОГИ 
	|	КОЛИЧЕСТВО(Различные КМ_Штука),
	|	МАКСИМУМ(КМ_Коробка),
	|	МАКСИМУМ(КМ_Коробка_Наименование),
	|	МАКСИМУМ(ДокАгрегации)
	|ПО
	|	Номенклатура,
	|	КодАгрегации		
	|";
	
	Возврат Запрос;
КонецФункции // ()

Функция КолСтрок_ТЧ(ДокСсылка, ИмяТЧ = "Товары")
	КолСтрок = 0;
	
	Запрос = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	СУММА(1) КАК КолСтрок
	|ИЗ
	|	" + ДокСсылка.Метаданные().ПолноеИмя() + "." + ИмяТЧ + "
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);	
	
	Выборка	= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КолСтрок) Тогда
		КолСтрок = Выборка.КолСтрок;	
	КонецЕсли; 
	
	Возврат КолСтрок;
КонецФункции //КолСтрок_Товары(ДокСсылка)
 

#Область ПроверкаКонтрагентов
	

Функция ПроверитьКонтрагентов(пОбработки = Неопределено) Экспорт
	Результат 		= СтруктураРезультата();	
	
	Запрос 			= Новый Запрос;
	Запрос.Текст	= "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагент,
	|	Контрагент.ИНН КАК ИНН
	|ИЗ
	|	Документ.РасходнаяНакладная
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	И ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ВидыОплаты.БН)
	|	И Отгружен = ЗНАЧЕНИЕ(Перечисление.Отгружен.Отгружен)
	|	И Проведен
	|	И НЕ Контрагент.РаботаСМаркированнымТоваром
	//|	И Товары.Номенклатура.Родитель
	|";
	
	Запрос.УстановитьПараметр("Дата1", НачалоГода(НачалоГода(ТекущаяДата())-1));
	Запрос.УстановитьПараметр("Дата2", КонецГода(ТекущаяДата()));
	
	Организация		= МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Организация", Организация);
	рПроверкиПодкл	= ПроверитьПолучитьПараметрыПодключенияTrueApi(Неопределено);
	
	Если НЕ рПроверкиПодкл.Успешно Тогда		
		ДобавитьОшибки(Результат, рПроверкиПодкл);
		Результат.Успешно = Ложь;
		Возврат Результат;		
	КонецЕсли;	
	
	ХТТПСоединение = Новый HTTPСоединение("markirovka.crpt.ru",,,,,,Новый ЗащищенноеСоединениеOpenSSL);
	
	//https://markirovka.crpt.ru/api/v3/true-api/participants?inns=860100089884
	
	РазмерПорции = 50;
	
	мИНН 	= Новый Массив;	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	ОбработаноОбъектов = 0;
	
	Пока Выборка.Следующий() Цикл
		ОбработкаПрерыванияПользователя_();		
		
		Сч = Сч+1;
		
		мИНН.Добавить("inns="+Выборка.ИНН);
		
		Если мИНН.Количество()>=РазмерПорции Тогда
			Состояние_("К обработке: "+(ВсегоСтрок-Сч));
			
			рЗапроса = ВыполнитьЗапросПоСтатусамУчастников(мИНН, ХТТПСоединение);			
			МаркировкаС.СообщитьПрогресс(100*Сч/ВсегоСтрок, "Чтение данных ЧЗ. "+Сч+" из "+ВсегоСтрок);
			
			Если рЗапроса.Успешно Тогда
				мИНН = ПолучитьЗарегистрированныхКонтрагентов(рЗапроса.Данные);				
				ОбработаноОбъектов = ОбработаноОбъектов +
					УстановитьФлаг_РаботаСМаркированнымТоваромм(мИНН);
			КонецЕсли; 
		
			мИНН.Очистить();
			
			МаркировкаС.СообщитьПрогресс(100*Сч/ВсегоСтрок, "Запись флагов");
		КонецЕсли;		
	КонецЦикла;	
	
	Если мИНН.Количество()>0 Тогда
		рЗапроса = ВыполнитьЗапросПоСтатусамУчастников(мИНН, ХТТПСоединение);
		МаркировкаС.СообщитьПрогресс(100*Сч/ВсегоСтрок, "Чтение данных ЧЗ. "+Сч+" из "+ВсегоСтрок);
		
		Если рЗапроса.Успешно Тогда		
			мИНН = ПолучитьЗарегистрированныхКонтрагентов(рЗапроса.Данные);
			
			ОбработаноОбъектов = ОбработаноОбъектов 
				+ УстановитьФлаг_РаботаСМаркированнымТоваромм(мИНН);			
			
			МаркировкаС.СообщитьПрогресс(100*Сч/ВсегоСтрок, "Запись флагов");
		КонецЕсли;	
	КонецЕсли;	
	
	Результат.ОбработаноОбъектов = ОбработаноОбъектов;
	Результат.Сообщения.Добавить("Запрошена информация по "+Сч+" контрагентам.");
	
	Возврат Результат;

КонецФункции // ()

Функция ПроверитьКонтрагента(Контрагент) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ХТТПСоединение = Новый HTTPСоединение("markirovka.crpt.ru",,,,,,Новый ЗащищенноеСоединениеOpenSSL);
	
	мИНН = Новый Массив;
	мИНН.Добавить("inns="+Контрагент.ИНН);
	
	ГруппыЧЗ = Новый Массив;
	
	рЗапроса = ВыполнитьЗапросПоСтатусамУчастников(мИНН, ХТТПСоединение);	
		
	Если рЗапроса.Успешно Тогда		
		мИНН = Новый Массив;
		Для Каждого СтрокаД Из рЗапроса.Данные Цикл
			Если ВРег(СтрокаД.status) = ВРег("Зарегистрирован") Тогда
				Для Каждого СтрокаТГ Из СтрокаД.productGroups Цикл					
					ГруппыЧЗ.Добавить(СтрокаТГ);
				КонецЦикла; 		
			КонецЕсли; 		
		КонецЦикла;	
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, рЗапроса);
	КонецЕсли;
	
	Результат.ОбработаноОбъектов = 1;
	Результат.Вставить("ГруппыЧЗ", ГруппыЧЗ);	
	
	Возврат Результат;
КонецФункции //ПроверитьКонтрагента(Контрагент) 

Функция ВыполнитьЗапросПоСтатусамУчастников(мИНН, ХТТПСоединение)
	Результат 		= МаркировкаКС.СтруктураРезультата();	
	
	ХТТП_Запрос = Новый HTTPЗапрос("api/v3/true-api/participants?"+СтрСоединить(мИНН,"&"));		
	
	рЗапроса 	= ХТТПСоединение.ВызватьHTTPМетод("GET", ХТТП_Запрос);
	Текст		= рЗапроса.ПолучитьТелоКакСтроку();
	
	Если рЗапроса.КодСостояния = 200 Тогда
		Результат.Данные = ПрочитатьЖСОН(Текст);		
	Иначе
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить("Код состояния: "+рЗапроса.КодСостояния+". "+Текст);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()

Функция УстановитьФлаг_РаботаСМаркированнымТоваромм(мИНН)
	Запрос = Новый Запрос;
	Запрос.Текст = "	
	|ВЫБРАТЬ	
	|	Ссылка	КАК Контрагент
	|ИЗ	
	|	Справочник.Контрагенты КАК СпрКонтрагенты	
	|ГДЕ
	|	СпрКонтрагенты.Владелец.Код = ""SSP""
	|	И ИНН В (&мИНН)
	|	И НЕ СпрКонтрагенты.РаботаСМаркированнымТоваром
	|";
	
	Запрос.УстановитьПараметр("мИНН", мИНН);
	
	Реквизиты = Новый Структура("РаботаСМаркированнымТоваром", Истина);
		
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		ОбработкаПрерыванияПользователя_();
		УстановитьРеквизитыОбъекта(Выборка.Контрагент, Реквизиты, , Истина);
	КонецЦикла;
	
	Возврат Выборка.Количество();
КонецФункции

Функция ПолучитьЗарегистрированныхКонтрагентов(ДанныеЗапроса)
	мИНН = Новый Массив;
	Для Каждого СтрокаД Из ДанныеЗапроса Цикл
		Если ВРег(СтрокаД.status) = ВРег("Зарегистрирован") Тогда
			Для Каждого СтрокаТГ Из СтрокаД.productGroups Цикл
				Если ВРег(СтрокаТГ) = "LP" Тогда
					мИНН.Добавить(СтрокаД.inn);					
				КонецЕсли; 							
			КонецЦикла; 		
		КонецЕсли; 		
	КонецЦикла;
	Возврат мИНН;
КонецФункции

 
#КонецОбласти

#Область РеестрыДокументов

Функция ПолучитьДанныеРеестраЧЗ(мОрганизация, ВидОперации, Дата1, Дата2, пОбработки = Неопределено, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Если НЕ ЗначениеЗаполнено(мОрганизация) Тогда
		Результат.Ошибки.Добавить("Не указана организация !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли; 
	
	Организация = мОрганизация;	
	
	рПроверкиПодкл	= ПроверитьПолучитьПараметрыПодключенияTrueApi(, пОбработки);
	
	Если НЕ рПроверкиПодкл.Успешно Тогда	
		ДобавитьОшибки(Результат, рПроверкиПодкл);		
		Возврат Результат;	
	КонецЕсли;
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();		
	
	КодОперацииЧЗ 	= КодЧЗ(ВидОперации);
	
	АдресРесурса	= СтрШаблон("api/v4/true-api/doc/list?pg=lp&dateFrom=%1&dateTo=%2&documentType=%3&limit=1000", 
		ДатаВФорматеЧЗ(Дата1), ДатаВФорматеЧЗ(Дата2), КодОперацииЧЗ);
		
	рЗапроса 		= ВыполнитьЗапрос_TrueApi(АдресРесурса, "GET", СоединениеХТТП);
	
	тРезультат = Новый ТаблицаЗначений;
	тРезультат.Колонки.Добавить("ИД_ДокументаЧЗ");
	тРезультат.Колонки.Добавить("ДокСсылка");
	
	тРезультат.Колонки.Добавить("status");
	тРезультат.Колонки.Добавить("type");
	тРезультат.Колонки.Добавить("senderInn");
	тРезультат.Колонки.Добавить("docDate");
	
	Если рЗапроса.Успешно Тогда
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);		
		Для каждого Элемент Из Данные.results Цикл
			СтрокаТ = тРезультат.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаТ, Элемент); 
			
			СтрокаТ.ИД_ДокументаЧЗ	= Элемент.number; 
			СтрокаТ.ДокСсылка		= Документы.МаркировкаТоваровИСМП.НайтиПоРеквизиту("ИД_ДокументаЧЗ", СтрокаТ.ИД_ДокументаЧЗ);
			
			//рЗапросаДанных = ПолучитьДанные_ОперацияМаркировки(Элемент.number);
		КонецЦикла;
	Иначе		
		ДобавитьОшибки(Результат, рЗапроса);		
		ДобавитьОшибки(Результат, рЗапроса.Ответ);		
	КонецЕсли;
	
	Результат.Данные = тРезультат;
	
	Если ЗначениеЗаполнено(АдресВозврата) И ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);
	КонецЕсли;
		
	Возврат Результат;	
КонецФункции //ПолучитьДанныеРеестраЧЗ(ВидОперации, Дата1, Дата2, ДопПараметры = Неопределено, АдресВозврата = Неопределено) Экспорт

Функция КодЧЗ(ВидОперации)	
	Если ВидОперации = Перечисления.ВидыОперацийИСМП.Агрегация Тогда
		Возврат "AGGREGATION_DOCUMENT";
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийИСМП.ФормированиеНабора Тогда
		Возврат "SETS_AGGREGATION";		
	Иначе                               
		Возврат "NOBODY";
	КонецЕсли;
КонецФункции // ()


Функция ДатаВФорматеЧЗ(Дата)
	//yyyy-MM-ddTHH:mm:ss.SSS’Z
	Возврат Формат(Дата, "ДФ=yyyy-MM-ddTHH:mm:ss") + ".000Z";
КонецФункции //ДатаВФорматеЧЗ(Дата)


