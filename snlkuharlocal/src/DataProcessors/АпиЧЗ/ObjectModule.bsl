			если (ТипШКАгрегации = Перечисления.ТипыШтрихКодов.Коробка или ТипШКАгрегации = Перечисления.ТипыШтрихКодов.Палета) и ТипВложения<>Перечисления.ТипыШтрихКодов.Штука тогда  
			// Кухарь А.Ю.  10.09.2025 конец
					
				
				МассивКодов.Добавить(ПрефиксАгрегации+СокрЛП(Выборка.СТИН));
			иначе
				МассивКодов.Добавить(СокрЛП(Выборка.СТИН));
			КонецЕсли;     
			// Кухарь А.Ю.  21.08.2025 конец
		
