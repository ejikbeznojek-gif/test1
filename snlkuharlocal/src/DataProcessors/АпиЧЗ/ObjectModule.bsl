		Выборка 	= Выборка_КодАгрегации.Выбрать();
		Пока Выборка.Следующий() Цикл			
			  
			// Кухарь А.Ю.  21.08.2025 начало  
			//МассивКодов.Добавить(СокрЛП(Выборка.СТИН));          
			          
			// Кухарь А.Ю.  10.09.2025 начало
			// HELP-6980
