	|		ИЛИ ВТ_Товары.Номенклатура.Родитель = ЗначенияСвойств.Объект
	|	)
	|	И НЕ ЗначенияСвойств.Свойство.ИД_ЧЗ В (0, 35, 36)	
	|ИТОГИ 
	|	МАКСИМУМ(gtin), 
	|	МАКСИМУМ(_Категория),
	|	МАКСИМУМ(tnved)
	|ПО
	|	_Модель,
	|	_Номенклатура
	|";	
	
	Запрос.УстановитьПараметр("тСсылок",  тСсылок);
	
	рЗапросов	= Запрос.ВыполнитьПакет();	
	
	СоставНаборов	= Новый Соответствие;
	рЗапроса_Набор	= рЗапросов[рЗапросов.ВГраница()-1];
	Выборка_Набор 	= рЗапроса_Набор.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Набор");
	Пока Выборка_Набор.Следующий() Цикл
		СоставНабора = Новый Массив;
		
		//+++Чирков 20.08.2025 - наборы из наборов
		//Выборка = Выборка_Набор.Выбрать();
		//Пока Выборка.Следующий() Цикл			
			//Если ЗначениеЗаполнено(Выборка.Комплектующее_ГТИН) И Выборка.Количество > 0 Тогда
			//	СоставНабора.Добавить(Новый Структура("gtin,quantity", СокрЛП(Выборка.Комплектующее_ГТИН), Выборка.Количество));
			//КонецЕсли;			
		//КонецЦикла;		
		
		тСостава = СоставНабораРазобраныйДоШтук(Выборка_Набор.Набор);
		Для каждого СтрокаС Из тСостава Цикл
			СоставНабора.Добавить(Новый Структура("gtin,quantity", СокрЛП(СтрокаС.ГТИН), СтрокаС.Количество)); 			
		КонецЦикла;		
		//---Чирков 20.08.2025 - наборы из наборов
		
		//СоставНаборов[Выборка_Набор.Набор] = ВложеноШтук(Выборка_Набор.Набор);
		СоставНаборов[Выборка_Набор.Набор] = СоставНабора;
	КонецЦикла; 
	
	рЗапроса	= рЗапросов[рЗапросов.ВГраница()];
	Данные		= Новый ТаблицаЗначений;
	Для Каждого Кол Из рЗапроса.Колонки Цикл
		Если СтрНачинаетсяС(Кол.Имя,"_") Тогда Продолжить КонецЕсли;		
		Данные.Колонки.Добавить(Кол.Имя);		
	КонецЦикла; 
	
	Данные.Колонки.Добавить("good_attrs");
	Данные.Колонки.Добавить("categories");
	Данные.Колонки.Добавить("moderation");
	Данные.Колонки.Добавить("set_gtins");
	Данные.Колонки.Добавить("good_id");
	Данные.Колонки.Добавить("is_tech_gtin");
	
	Данные.Колонки.Добавить("is_kit", 		ПолучитьОписаниеТиповЧисла(0));
	Данные.Колонки.Добавить("is_set", 		ПолучитьОписаниеТиповЧисла(0));
	//Данные.Колонки.Добавить("multiplier", 	ПолучитьОписаниеТиповЧисла(3));	
	
	//{'cat_id': 238944, 'cat_name': 'Блузки, блузы и блузоны', 'cat_parent_id': 30686, 'cat_level': 6, 'category_active': True, 'gismt_codes': [1]}
	
	Выборка_Модель = рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "_Модель");
	Пока Выборка_Модель.Следующий() Цикл
		
		Состав 		= ПолучитьСостав(Выборка_Модель._Модель);
		Описание    = Выборка_Модель._Модель.ОписаниеТовараДляСайта;
		Страна    	= Выборка_Модель._Страна;		
		
		Категории = Новый Массив;
		Если СокрЛП(Выборка_Модель.tnved) = "6212900000" Тогда
			Категории.Добавить(214958);
		Иначе	
			Если ЗначениеЗаполнено(Выборка_Модель._Категория) Тогда			
				Категории.Добавить(Число(Выборка_Модель._Категория));
			КонецЕсли;		
		КонецЕсли;
		
		Выборка_Номенклатура = Выборка_Модель.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "_Номенклатура");
		Пока Выборка_Номенклатура.Следующий() Цикл
			СтрокаД = Данные.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаД, Выборка_Номенклатура);			
			
			СимволовВКарточку 	= ?(Выборка_Номенклатура._КоличествоСимволовВКарточку = 0, 4, 10);
			СтрокаД.tnved 		= Лев(СокрЛП(СтрокаД.tnved), СимволовВКарточку); //Было 4 знака, поставили 10. Письмо Петрова от 19.09.2024 (ЧЗ просит 10 знаков по каким-то группам)
			СтрокаД.moderation	= 1; //1-на модерацию
			//СтрокаД.multiplier	= 1;
			
			СтрокаД.categories = Новый Массив;
			Если Выборка_Модель._ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Единица Тогда
				Если Категории.Количество()>0 Тогда			
					СтрокаД.categories = Категории;			
				КонецЕсли;							
			КонецЕсли;			
			
			Атрибуты = Новый Массив;
			
			Если СимволовВКарточку > 4 Тогда
				//Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 3959, СокрЛП(СтрокаД.tnved))); 	//Группа ТНВЭД
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Страна) Тогда
				//MARK-743 - Не отправлять страну в НК, тк поле не обязательное
				//Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 2630, Страна));
			КонецЕсли;
			
			Если Выборка_Модель._ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Единица Тогда
				Выборка_Артибуты = Выборка_Номенклатура.Выбрать();	
				Пока Выборка_Артибуты.Следующий() Цикл
					Если ЗначениеЗаполнено(Выборка_Артибуты._Атрибут_ЧЗ_Ид) Тогда			
						Атрибуты.Добавить(Новый Структура("attr_id, attr_value", Выборка_Артибуты._Атрибут_ЧЗ_Ид, Выборка_Артибуты._Атрибут_ЧЗ_Зн));
					КонецЕсли;			
				КонецЦикла;			
				
				Если ЗначениеЗаполнено(Описание) Тогда			
					Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 13929,	Описание));					//Описание				
				КонецЕсли;			
				
				Если ЗначениеЗаполнено(Выборка_Номенклатура._Артикул) Тогда
					Атрибуты.Добавить(Новый Структура("attr_id,attr_value_type,attr_value", 13914, "Артикул", ""+Выборка_Номенклатура._Артикул));
				КонецЕсли;		
				
				Если ЗначениеЗаполнено(Выборка_Номенклатура._НаименованиеПолное) Тогда
					Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 2478, ""+Выборка_Номенклатура._НаименованиеПолное));
				КонецЕсли;
				
				Если ЗначениеЗаполнено(Состав.Строка) Тогда
					Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 2483, Состав.Строка));
				КонецЕсли;
				
				//Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 3961,   "14.31.10.189")); 			//"Группа ОКПД2
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 2504,   Выборка_Номенклатура.brand)); 	//Товарный знак
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 13933,  Выборка_Номенклатура.tnved)); 	//ТНВЭД полный
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 13797,  Выборка_Номенклатура._Код));  	//Код в уч системе				
				Если ЗначениеЗаполнено(Выборка_Номенклатура._Цвет) Тогда
					Атрибуты.Добавить(Новый Структура("attr_id, attr_value", 36, ""+Выборка_Номенклатура._Цвет));
				КонецЕсли;
				
				Если ЗначениеЗаполнено(Выборка_Номенклатура._Размер) Тогда
					Если ЗначениеЗаполнено(Выборка_Номенклатура._ТипРазмера) Тогда
						ТипРазмера = Выборка_Номенклатура._ТипРазмера;
					Иначе
						ТипРазмера = "РОССИЯ";			
					КонецЕсли; 
					Атрибуты.Добавить(Новый Структура("attr_value_type,attr_id, attr_value", ТипРазмера, 35, ""+Выборка_Номенклатура._Размер));
				КонецЕсли; 
			ИначеЕсли Выборка_Модель._ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Набор Тогда
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 3959, СокрЛП(СтрокаД.tnved))); 	//Группа ТНВЭД
				
				СтрокаД.is_set = 1;			
				
				//+++Чирков 
				//СтрокаД.set_gtins = СоставНаборов[Выборка_Номенклатура._Номенклатура];				
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 23821, ВложеноШтук(Выборка_Номенклатура._Номенклатура)));
				//---Чирков
				
				Атрибуты.Добавить(Новый Структура("attr_id,attr_value", 23768, 1));  	//23768 "Товарная группа": 1 - Легкая промыщленность
			КонецЕсли; 
			
			Если Атрибуты.Количество()>0 Тогда
				СтрокаД.good_attrs = Атрибуты;		
			КонецЕсли; 
			
			Если Выборка_Номенклатура._ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Комплект Тогда
				СтрокаД.is_kit  = 1;							
			ИначеЕсли Выборка_Номенклатура._ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Набор Тогда
				СтрокаД.is_set  = 1;							
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	
	Возврат Данные;
КонецФункции //ПолучитьДанныеКарточекТовара

Функция ПолучитьИнфоОКарточкахЗаказа(Заказ)	Экспорт
	Результат = СтруктураРезультата();	
	
	рПроверкиПодключения = ПроверитьПолучитьПараметрыПодключенияTrueApi(Заказ);
	Если рПроверкиПодключения.Успешно Тогда
	Иначе
		ДобавитьОшибки(Результат, рПроверкиПодключения);
		Результат.Успешно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура("Основание", Заказ);
	
	Запрос = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура.ГТИН КАК ГТИН
	|ИЗ
	|	Документ.ЗаявкаНаПередачуКарточекНоменклатурыВЧЗ.Товары
	|ГДЕ
	|	Ссылка = &Заказ
	|";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	ТР = СоздатьТаблицуИнформацииОКарточках();
	
	ДопПараметры 	= Новый Структура("Основание", Заказ);
	РазмерПорции	= 10;
	мГТИН			= Новый Массив;
	
	Выборка			= Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		мГТИН.Добавить(Выборка.ГТИН);
		
		Если мГТИН.Количество() > РазмерПорции Тогда
			рПолучения = ПолучитьИнфоОКарточках(мГТИН, ДопПараметры);
			Если рПолучения.Успешно Тогда
				СложитьТаблицы_(ТР, рПолучения.Данные);		
			КонецЕсли;
			
			мГТИН.Очистить();
		КонецЕсли;	
	КонецЦикла; 
	
	Если мГТИН.Количество() > 0 Тогда
		рПолучения = ПолучитьИнфоОКарточках(мГТИН, ДопПараметры);
		Если рПолучения.Успешно Тогда
			СложитьТаблицы_(ТР, рПолучения.Данные);		
		КонецЕсли;
	КонецЕсли;	

	Для Каждого СтрокаТР Из ТР Цикл
		СтрокаТР.ГТИН = Прав("00000000000000"+СтрокаТР.ГТИН, 14); 					
	КонецЦикла;
	
	Результат.Вставить("Данные", ТР);
	
	Возврат Результат;
КонецФункции //ПолучитьИнфоОКарточкахЗаказа(Заказ)

Функция ПолучитьКарточкиЗаказаПоПорциям(Заказ, РазмерПорции = 10) Экспорт
	Запрос = Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.ГТИН КАК ГТИН
	|ИЗ
	|	"+Заказ.Метаданные().ПолноеИмя()+".Товары
	|ГДЕ
	|	Ссылка = &Заказ
	|	И Номенклатура.ГТИН<>""""	
	|";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Результат 		= Новый Массив;
	
	мГТИН			= Новый Массив;
	
	рЗапроса		= Запрос.Выполнить();
	Если РазмерПорции = 0 Тогда
		мГТИН = рЗапроса.Выгрузить().ВыгрузитьКолонку("ГТИН");
	Иначе
		Выборка			= рЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			мГТИН.Добавить(Выборка.ГТИН);
			
			Если мГТИН.Количество() > РазмерПорции Тогда
				Результат.Добавить(мГТИН);			
				
				мГТИН	= Новый Массив;
			КонецЕсли;	
		КонецЦикла;		
	КонецЕсли;	
	
	Возврат ?(РазмерПорции=0, мГТИН, Результат);
КонецФункции //ПолучитьПорцииКарточекЗаказа(Заказ)

Функция ПолучитьИнфоОКарточках(мГТИН, ДопПараметры = Неопределено) Экспорт	
	Результат		= СтруктураРезультата();	
		
	АдресРесурса 	= "v3/feed-product?gtins=" + СтрСоединить(мГТИН,";");		
	
	тИнфоКарточках = СоздатьТаблицуИнформацииОКарточках();
	
	рЗапроса	 	= ВыполнитьЗапрос_НК(АдресРесурса, , , ДопПараметры);	
	Если рЗапроса.Успешно Тогда
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);		
		Для Каждого ДанныеТ Из Данные.result Цикл
			identified_by = ДанныеТ.identified_by[0];
			Если ДанныеТ.good_detailed_status.Количество()>0 Тогда
				//Сообщить(""+identified_by.type+" "+identified_by.value+" "+ДанныеТ.good_detailed_status[0]);							
				Если identified_by.type = "gtin" Тогда
					СтрокаТР = тИнфоКарточках.Добавить(); 									
					
					СтрокаТР.ГТИН	= identified_by.value;
					СтрокаТР.Статус = ДанныеТ.good_detailed_status[0];
				КонецЕсли; 
			КонецЕсли;			
		КонецЦикла; 
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, рЗапроса);
	КонецЕсли;	
	
	Результат.Вставить("Данные", тИнфоКарточках);
	
	Возврат Результат; 
КонецФункции //ПолучитьИнфоОКарточках(мГТИН)

