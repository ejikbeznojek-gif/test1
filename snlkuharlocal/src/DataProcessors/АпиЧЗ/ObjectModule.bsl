Функция ПолучитьТелоЗапроса_ВводВОборот_ОперМаркировки(ДокМаркировки, ВидОперацииИСМП)	
	мКодыМаркировки = ПолучитьКодыМаркировкиПоМТ(ДокМаркировки);	
	
	Товары = Новый Массив;	
	
	Для Каждого СтрокаКода Из мКодыМаркировки Цикл		
		Товары.Добавить(Новый Структура(СтрокаКода.ИмяУзла, СтрокаКода.СГТИН));
	КонецЦикла; 	
	
	Пакет = Новый Структура;
	//Пакет.Вставить("productGroup", "lp");
	
	Пакет.Вставить("trade_participant_inn", 	ДокМаркировки.Организация.ИНН);	
	
	Если ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ВводВОборот_Импорт Тогда
		Машина 	= ПолучитьРеквизитШапки(ДокМаркировки, "ДокументОснование");
		ГТД		= ПолучитьРеквизитШапки(Машина, "ГТД");		
		
		Пакет.Вставить("declaration_number",		ГТД.Наименование); 
		Пакет.Вставить("declaration_date",			ПолучитьДатуГТД(ГТД.Наименование));
	КонецЕсли;	
	
	Пакет.Вставить("products_list", 			Товары);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
