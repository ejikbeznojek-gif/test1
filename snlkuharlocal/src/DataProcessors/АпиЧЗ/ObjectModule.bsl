Функция ПроверитьСоздатьКаталогЗагрузкиКодов() Экспорт
	мКаталогОбмена = СокрЛП(Константы.КаталогВнешнихОтчетов.Получить());
	Если Прав(мКаталогОбмена,1)<>"\" Тогда
		мКаталогОбмена = мКаталогОбмена+"\";			
	КонецЕсли;
	
	Файл = Новый Файл(мКаталогОбмена);
	Если НЕ Файл.Существует() Тогда
		Возврат "";
	КонецЕсли; 
	
	мКаталогОбмена = мКаталогОбмена + "ЗагрузкаКМ";
	Файл = Новый Файл(мКаталогОбмена);
	Если НЕ Файл.Существует() Тогда
		СоздатьКаталог(мКаталогОбмена);	
	КонецЕсли;
	
	Возврат мКаталогОбмена+"\";
КонецФункции //ПроверитьСоздатьКаталогЗагрузкиКодов()

Функция ПрочитатьКодыИзЛогов(МассивИД) Экспорт
	ТК = СоздатьТаблицуКодов();
	Для Каждого ИД Из МассивИД Цикл
		МЗ = РегистрыСведений.ЗапросыЧЗ.СоздатьМенеджерЗаписи();
		МЗ.ИД = ИД;
		МЗ.Прочитать();
		
		Если ЗначениеЗаполнено(МЗ.ИД) Тогда
			СтрокаОтвета= МЗ.ДанныеОтвета.Получить();
			
			ИД_ДокументаЧЗ	= ПолучитьРеквизитШапки(МЗ.Основание, "ИД_ДокументаЧЗ");
			
			ДобавитьКодыИзСтроки(СтрокаОтвета, ИД_ДокументаЧЗ, ТК);			
		КонецЕсли; 		
	КонецЦикла;	
	
	Возврат ТК;
КонецФункции //ПрочитатьКодыИзЛогов(МассивИД)

Функция ЗагрузитьКодыИзЛогов(МассивИД, ПерезаписыватьКМ = Ложь, АдресВозврата = Неопределено) Экспорт
	Результат	= СтруктураРезультата();
	
	ТК = ПрочитатьКодыИзЛогов(МассивИД);	
	
	ОбработаноОбъектов = ЗагрузитьКодыИзТаблицы(ТК, ПерезаписыватьКМ);
	
	Возврат ОбработаноОбъектов;
КонецФункции //ЗагрузитьКодыИзЛогов(Перезаписывать = Ложь)

Функция ЗагрузитьКодыИзТаблицы(ТК, ПерезаписыватьКМ = Ложь, АдресВозврата = Неопределено) Экспорт
	Результат	= СтруктураРезультата();	
	
	ЗаписьЖурналаРегистрации("Отладка", УровеньЖурналаРегистрации.Информация,,, "КП1 " + ТК.Количество());
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Коды ИЗ &ТК КАК ТК
	|;
	|ВЫБРАТЬ
	|	ВТ_Коды.ГТИН				КАК ГТИН,
	|	ВТ_Коды.Наименование		КАК Наименование,
	|	ВТ_Коды.ЗначениеШтрихкода   КАК ЗначениеШтрихкода,
	|
	|   СпрНоменклатура.Ссылка 		КАК Номенклатура,
	|   СпрНоменклатура.Родитель.ВидНоменклатурыЧЗ КАК ВидНоменклатурыЧЗ,
	|	СпрШК_КМ.Ссылка				КАК ШК_КМ,
	|
	|	ДокЗаказКМ.Ссылка				КАК ЗаказКМ,
	|	ДокЗаказКМ.Дата					КАК ЗаказКМ_Дата,
	|	ДокЗаказКМ.СпособВводаВОборот	КАК СпособВводаВОборот
	|ИЗ
	|	ВТ_Коды
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.ЗаказНаЭмиссиюКодовМаркировкиСУЗ КАК ДокЗаказКМ
	|ПО
	|	ДокЗаказКМ.ИД_ДокументаЧЗ = ВТ_Коды.ИД_ДокументаЧЗ
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|ПО
	|	ВТ_Коды.ГТИН = СпрНоменклатура.ГТИН 
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК СпрШК_КМ
	|ПО
	|	ВТ_Коды.Наименование = СпрШК_КМ.Наименование
	|ГДЕ
	|	СпрШК_КМ.Ссылка ЕСТЬ NULL ИЛИ &ПерезаписыватьКМ
	|";
	                                            	
	Запрос.УстановитьПараметр("ТК", 				ТК);
	Запрос.УстановитьПараметр("ПерезаписыватьКМ",	ПерезаписыватьКМ);	
	
	РеквизитыШК = Новый Структура(
		"ТипУпаковки,ТипШК,ТипКода,КодировкаШтрихкода,Количество",
		Перечисления.ТипыУпаковок.МаркированныйТовар,
		Перечисления.ТипыШтрихКодов.Штука,
		Перечисления.ТипыКодовМаркировки.Товар,
		Перечисления.ТипыКодировокШК.GS1_DataMatrix,
		1
	);	
	
	ОбработаноОбъектов = 0;
	ОбработанныеЗаказы = Новый Соответствие;
	
	рЗапроса	= Запрос.Выполнить();
	Выборка 	= рЗапроса.Выбрать();
	
	ВсегоСтрок 	= Выборка.Количество();
	Сч			= 0;
	
	Получатели 	= Новый Массив;
	Коды		= Новый Массив;
	Коды_Импорт = Новый Массив;
	
	Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Получатели = Маркировка_ПИ.ПолучитьМассивУзловПоТипу(Перечисления.ТипУзлаИБ.Склад, "ДанныеЧЗ");
	КонецЕсли;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Пока Выборка.Следующий() Цикл
		Сч = Сч+1;
		Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
			Если ЗначениеЗаполнено(Выборка.ШК_КМ) Тогда
				СпрОбъект = Выборка.ШК_КМ.ПолучитьОбъект();
			Иначе
				СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
			КонецЕсли;
			
			ЗаполнитьЗначенияСвойств(СпрОбъект, РеквизитыШК);
			
			Поля = ПолучитьПоляШК(Выборка.ЗначениеШтрихкода);			
			
			СпрОбъект.Владелец 			= Выборка.Номенклатура;			
			СпрОбъект.Наименование 		= Выборка.Наименование;						
			СпрОбъект.ЗначениеШтрихкода = Выборка.ЗначениеШтрихкода;
			
			СпрОбъект.ЗаказКМ				= Выборка.ЗаказКМ;
			СпрОбъект.ДатаУпаковки			= Выборка.ЗаказКМ_Дата;
			СпрОбъект.СпособВводаВОборот	= Выборка.СпособВводаВОборот;
			
			Если Выборка.ВидНоменклатурыЧЗ = Перечисления.ВидыНоменклатурыЧЗ.Набор Тогда
				СпрОбъект.ТипКода	= Перечисления.ТипыКодовМаркировки.Набор;
			КонецЕсли;
			
			//СпрОбъект.ОбменДанными.Загрузка = Истина;
			
			СпрОбъект.ПометкаУдаления = Ложь;
			
			Попытка
				СпрОбъект.Записать();
				Коды.Добавить(СпрОбъект.Ссылка);
				Если Выборка.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда
					Коды_Импорт.Добавить(СпрОбъект.Ссылка);
				КонецЕсли;
			Исключение
				Сообщить("Ошибка записи КМ: " + СпрОбъект.Наименование + " " + СпрОбъект.Владелец.Код+" "+СпрОбъект.Владелец+" "+ОписаниеОшибки());								
			КонецПопытки;						
			
			ОбработаноОбъектов = ОбработаноОбъектов + 1;
			
			ОбработаноПоЗаказу = МаркировкаКС.ПолучитьЗначениеПараметра(ОбработанныеЗаказы, Выборка.ЗаказКМ, 0);
			ОбработанныеЗаказы[Выборка.ЗаказКМ] = ОбработаноПоЗаказу + 1;
		КонецЕсли;		
		
		Если Сч % 100 = 0 Тогда
			Состояние_("Запись КМ "+Выборка.Номенклатура, 100*Сч/ВсегоСтрок);		
			
			ТекстСообщения = СтрШаблон("Запись кодов по ном-ре: %1, 
			|	записано: %2 из %3.", Выборка.Номенклатура, Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);
		КонецЕсли;
		
		Если Сч % 1000 = 0 Тогда
			Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
			ТекстСообщения = СтрШаблон("Записано 1000 КМ. Время выполнения: %1, скорость записи: %2 кодов/с.", Время, Формат(1000 / Время, "ЧДЦ=0"));
			//ЗаписьЖурналаРегистрации("Отладка", УровеньЖурналаРегистрации.Информация, Справочники.ШтрихкодыУпаковокТоваров, , ТекстСообщения);					
			ЗаписатьВЛог("Загрузка КМ", ТекстСообщения, "Информация", , , Время);
			
			Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли; 
	КонецЦикла;	
	
	Если Получатели.Количество() > 0 И Коды_Импорт.Количество() > 0 Тогда
		ОбменДаннымиЧЗ.УстановитьПолучателей(Получатели, Коды_Импорт);		
	КонецЕсли;
	
	Для Каждого КиЗ Из ОбработанныеЗаказы Цикл
		Если КиЗ.Значение > 0 И МаркировкаС.ОбъектСуществует(КиЗ.Ключ) Тогда
			Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ОбновитьКоличествоПолученныхКодов(КиЗ.Ключ);
		КонецЕсли;	
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = ОбработаноОбъектов;
	
	Если ЗначениеЗаполнено(АдресВозврата) И ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);
	КонецЕсли;                                                  
	
	Если инт_ДлительныеОперации.ЭтоФоновоеЗадание() Тогда
		ОценкаПроизводительностиКлиентСервер.ЗаписатьКэшЛогов();			
	КонецЕсли;

	Возврат Результат;
КонецФункции //ЗагрузитьКодыИзТаблицы(ТК, ПерезаписыватьКМ = Ложь, АдресВозврата = Неопределено) Экспорт

Функция ДобавитьКодыИзСтроки(СтрокаЖСОН, ИД_ДокументаЧЗ, ТК) Экспорт	
	Данные = ПрочитатьЖСОН(СтрокаЖСОН);
	
	Для Каждого ЗначениеШтрихкода Из Данные.codes Цикл
		Поля = ПолучитьПоляШК(ЗначениеШтрихкода);
		
		СтрокаТК = ТК.Добавить();
		
		СтрокаТК.ИД_ДокументаЧЗ		= ИД_ДокументаЧЗ;
		//СтрокаТК.Наименование		= "(01)"+Поля.ГТИН+"(21)"+СтрЗаменить(Поля.СН,Символ(29),"");
		СтрокаТК.Наименование		= Справочники.ШтрихкодыУпаковокТоваров.СформироватьНаименованиеШкGS1(Поля);
		СтрокаТК.ГТИН 				= Поля.ГТИН;
		СтрокаТК.ЗначениеШтрихкода 	= Справочники.ШтрихкодыУпаковокТоваров.ПреобразоватьКод_GS1(ЗначениеШтрихкода);		
		
		//Поз1 = НайтиНедопустимыеСимволыXML(Код);
		//Пока Поз1>0 Цикл		
		//	Сообщить(""+Поз1+" - "+КодСимвола(Сред(Код, Поз1,1)));			
		//	Поз1 = НайтиНедопустимыеСимволыXML(Код, Поз1+1);
		//КонецЦикла;		
	КонецЦикла;
КонецФункции //ПолучитьКодыИзСтроки(СтрокаЖСОН)

Функция ПолучитьПоляШК(Знач СтрШК) Экспорт
	СтрШК = СокрЛП(СтрШК);
	
	Если Лев(СтрШК,1) = Символ(232) Тогда
		СтрШК = Сред(СтрШК, 22);	
	КонецЕсли;
	
	ГТИН 	= Сред(СтрШК,3,14);
	СН		= Сред(СтрШК,19,13);
	ИДКП	= Сред(СтрШК,35,4);	
	
	Возврат Новый Структура("ГТИН,СН,ИДКП", ГТИН, СН, ИДКП);
КонецФункции // ()

Функция СоздатьТаблицуКодов() Экспорт
	ТК = Новый ТаблицаЗначений;
	
	ТК.Колонки.Добавить("ИД_ДокументаЧЗ",       Метаданные.Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.Реквизиты.ИД_ДокументаЧЗ.Тип);
	ТК.Колонки.Добавить("ГТИН", 				ПолучитьОписаниеТиповСтроки(14));	
	ТК.Колонки.Добавить("Наименование",			ПолучитьОписаниеТиповСтроки(50));
	ТК.Колонки.Добавить("ЗначениеШтрихкода", 	ПолучитьОписаниеТиповСтроки(200));
	
	Возврат ТК;
КонецФункции //СоздатьТаблицуКодов()

Функция ПолучитьТелоЗапроса_СписаниеНеНанесенных_ОперМаркировки(ДокМаркировки, ВидОперацииИСМП)	
	
	Товары = Новый Массив;
	
	мКодыМаркировки = ПолучитьКодыМаркировкиПоМТ(ДокМаркировки);		
	Для Каждого СтрокаКода Из мКодыМаркировки Цикл		
		Товары.Добавить(Новый Структура("cis", СтрокаКода.СГТИН));
	КонецЦикла;	
	
	Пакет = Новый Структура;
	//Пакет.Вставить("productGroup", "lp");
	
	рШапки = ПолучитьРеквизитыШапки(ДокМаркировки, "
		|Дата,Номер,Организация,Организация.ИНН,
		|ДокументОснование.Номер,ДокументОснование.Дата
		|");
	
	
	Основание_Номер	= рШапки.ДокументОснование_Номер;
	Основание_Дата	= Формат(рШапки.ДокументОснование_Дата, "ДФ=yyyy-MM-dd");	
	
	Пакет.Вставить("trade_participant_inn",		рШапки.Организация_ИНН);	
	
	Пакет.Вставить("cancellation_doc_date", 	Основание_Номер);
	Пакет.Вставить("cancellation_doc_number",	Основание_Дата);
	Пакет.Вставить("cancellation_reason",		Основание_Дата);
	
	Пакет.Вставить("products",		Товары);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции //ПолучитьТелоЗапроса_СписаниеНеНанесенных_ОперМаркировки()	

Функция ПолучитьТелоЗапроса_ФормированиеНабора_ОперМаркировки(ДокМаркировки)
	рШапки	= ПолучитьРеквизитыШапки(ДокМаркировки, "Организация.ИНН");		
	Наборы	= ПолучитьКодыНаборов(ДокМаркировки);
	
	Пакет = Новый Структура;	
	
	Пакет.Вставить("participantId",		рШапки.Организация_ИНН);
	Пакет.Вставить("aggregationUnits",	Наборы);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции //ПолучитьТелоЗапроса_ФормированиеНабора_ОперМаркировки(ДокМаркировки)

Функция ПолучитьТелоЗапроса_Перемаркировка_ОперМаркировки(ДокМаркировки)
	рШапки					= ПолучитьРеквизитыШапки(ДокМаркировки, "Организация.ИНН,ВидОперацииИСМП,Дата");		
	КодыДляПеремаркировки	= ПолучитьКодыПеремаркировки(ДокМаркировки);
	
	Пакет = Новый Структура;	
	
	Пакет.Вставить("participant_inn",	рШапки.Организация_ИНН);
	Пакет.Вставить("remarking_date",	Формат(рШапки.Дата, "ДФ=yyyy-MM-dd"));                                         
	Пакет.Вставить("remarking_cause",   Перечисления.ВидыОперацийИСМП.КодЧЗ(рШапки.ВидОперацииИСМП));
	
	Пакет.Вставить("products", КодыДляПеремаркировки);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции //ПолучитьТелоЗапроса_ФормированиеНабора_ОперМаркировки(ДокМаркировки)

Функция ПолучитьТелоЗапроса_ТрансформацияУпаковки_ОперМаркировки(ДокМаркировки)
	рШапки	= ПолучитьРеквизитыШапки(ДокМаркировки, "Организация.ИНН,ВидОперацииИСМП,ШтрихкодУпаковки.Наименование");		
	//++Данилова Е.В. 20.11.2025 MARK-2862 
	ПрефиксАгрегации = ПолучитьПрефиксАгрегации(ДокМаркировки); 
	//--Данилова Е.В. 20.11.2025 
	мКоды	= Новый Массив;
	Для Каждого СтрокаКода Из ПолучитьКодыМаркировкиПоМТ(ДокМаркировки) Цикл
		//++Данилова Е.В. 20.11.2025 MARK-2862
		//мКоды.Добавить(Новый Структура("uit_uitu", СтрокаКода.СГТИН));
		Если СтрокаКода.ТипШК = Перечисления.ТипыШтрихКодов.Штука Тогда
			мКоды.Добавить(Новый Структура("uit_uitu", СтрокаКода.СГТИН));
		Иначе
			мКоды.Добавить(Новый Структура("uit_uitu", ПрефиксАгрегации + СтрокаКода.СГТИН));
		КонецЕсли;
		//--Данилова Е.В. 20.11.2025
	КонецЦикла;	
	
	Пакет = Новый Структура;	
	
	Пакет.Вставить("participant_inn",		рШапки.Организация_ИНН);	
	Пакет.Вставить("reaggregation_type",   	Перечисления.ВидыОперацийИСМП.КодЧЗ(рШапки.ВидОперацииИСМП));
	Пакет.Вставить("uitu",					рШапки.ШтрихкодУпаковки_Наименование);
	
	Пакет.Вставить("uit_uitu_list", мКоды);
	
	ТелоЗапроса	= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции //ПолучитьТелоЗапроса_ТрансформацияУпаковки_ОперМаркировки(ДокМаркировки)

Функция ПолучитьТелоЗапроса_ТрансформацияАТК_ОперМаркировки(ДокМаркировки)	
	РеквизитыШ		= ПолучитьРеквизитыШапки(ДокМаркировки, "ВидОперацииИСМП,АТК");
	
	мКодыМаркировки = ПолучитьКодыМаркировкиПоМТ(ДокМаркировки);	
	
	Товары = Новый Массив;	
	Для Каждого СтрокаКода Из мКодыМаркировки Цикл		
		Товары.Добавить(Новый Структура("ki", СтрокаКода.СГТИН));
	КонецЦикла; 	
	
	Пакет = Новый Структура;
	//Пакет.Вставить("productGroup", "lp");
	Пакет.Вставить("trade_participant_inn", ДокМаркировки.Организация.ИНН);	
	Пакет.Вставить("atk",					СокрЛП(РеквизитыШ.АТК));
	Пакет.Вставить("transformation_type",	?(РеквизитыШ.ВидОперацииИСМП = Перечисления.ВидыОперацийИСМП.ТрансформацияАТК_Добавление, "ADDING", "REMOVING"));
	Пакет.Вставить("products_list", 		Товары);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции //ПолучитьТелоЗапроса_ТрансформацияАТК_ОперМаркировки()	


