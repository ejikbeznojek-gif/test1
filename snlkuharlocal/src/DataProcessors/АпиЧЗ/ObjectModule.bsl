КонецФункции //ОтправитьЗапрос_ЗакрытьЗаказКМ(ЗаказКМ, СтанцияСУЗ, ОтпечатокСертификатаЭЦП) Экспорт

Функция ЗакрытьЗаказКМ(ДокСсылка) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли;
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияСУЗ(ДокСсылка);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
		
		рПроверкиСУЗ = ПроверитьОрганизациюСУЗ(СтанцияСУЗ, ДокСсылка);
		Если НЕ рПроверкиСУЗ.Успешно Тогда
			Результат.Успешно = Ложь;
			МаркировкаКС.ДобавитьОшибки(Результат, рПроверкиСУЗ);		
			Возврат Результат;		
		КонецЕсли;
	Иначе			
		Результат.Ошибки.Добавить("Не указаны параметры подключения к СУЗ !");
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	рОтправки = ОтправитьЗапрос_ЗакрытьЗаказКМ(ДокСсылка, СтанцияСУЗ, рПроверкиПодкл.ОтпечатокСертификатаЭЦП);
	Если рОтправки.Успешно Тогда
		ТекстСобщения = СтрШаблон("Запрос на закрытие заказа КМ: '%1' отправлен на обработку в СУЗ.", ДокСсылка);
		Сообщить(ТекстСобщения, СтатусСообщения.Информация);
	Иначе
		Результат.Успешно = Ложь;
		ДобавитьОшибки(Результат, рОтправки);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЗакрытьЗаказКМ(ДокСсылка) Экспорт 

Функция СоздатьТело_ЗаказКМ_v2(ЗаказКМ_Ссылка)
	Если 1=2 Тогда
		ЗаказКМ_Ссылка = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.ПустаяСсылка();	
	КонецЕсли; 
	
	СпособВводаВОборот = ПолучитьРеквизитОбъекта(ЗаказКМ_Ссылка, "СпособВводаВОборот");
	
	Данные = Новый Структура;
	
	Данные.Вставить("productionOrderId", 	XMLСтрока(ЗаказКМ_Ссылка.УникальныйИдентификатор()));
	Данные.Вставить("releaseMethodType", 	СпособВводаВОборотЧЗ(СпособВводаВОборот));
	Данные.Вставить("createMethodType", 	"SELF_MADE");
	Данные.Вставить("contactPerson",		""+ЗаказКМ_Ссылка.Автор);	
	
	ДопПоляТоваров = Новый Структура("serialNumberType,templateId", "OPERATOR", 10);
	Данные.Вставить("products", 			ТЗвМассивСтруктур(ПолучитьТаблицуТоваров(ЗаказКМ_Ссылка, ДопПоляТоваров)));
	
	Возврат ЗаписатьЖСОН(Данные);	
КонецФункции //СоздатьТело_ЗаказКМ(ЗаказКМ_Ссылка)

