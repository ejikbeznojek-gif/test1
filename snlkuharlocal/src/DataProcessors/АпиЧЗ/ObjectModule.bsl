Функция ПолучитьКодыПоЗаказуКМ(ЗаказКМ, СтанцияСУЗ) Экспорт
	Возврат ПолучитьКодыПоЗаказуКМ_v3(ЗаказКМ, СтанцияСУЗ);
КонецФункции //ЗагрузитьКодыПоЗаказуКМ(ЗаказКМ)

Функция ПолучитьКодыПоЗаказуКМ_v2(ЗаказКМ, СтанцияСУЗ) Экспорт
	Результат 		= СтруктураРезультата();		 
	
	Токен_СУЗ		= ХранилищеОбщихНастроек.Загрузить(КлючОбъекта_ДляНастроек, "Токен_СУЗ");
	
	СоединениеХТТП	= СоздатьСоединение_СУЗ();	
	
	ДопПараметры	=  Новый Структура("Основание", ЗаказКМ);
	ИД_Заказа 		= ЗаказКМ.ИД_ДокументаЧЗ;		
	
	тТовары			= ПолучитьТаблицуТоваров(ЗаказКМ);
	
	МассивЗаписей 	= Новый Массив;
	ОбработаноОбъектов = 0;
	
	Ошибки = Новый Соответствие;
	
	Для Каждого СтрокаТ Из тТовары Цикл
		Состояние_("Проверка "+СтрокаТ.productDescription);
		
		рСтатусы = ПолучитьСтатусСтрокиЗаказаКМ_v2(ИД_Заказа, СтрокаТ.gtin, СоединениеХТТП, СтанцияСУЗ, ДопПараметры);
		Если рСтатусы.Успешно Тогда			
			Если ВРег(рСтатусы.Данные.bufferStatus) = "REJECTED" Тогда
				Результат.Ошибки.Добавить(рСтатусы.Данные.rejectionReason);
			Иначе
				Если рСтатусы.Данные.availableCodes > 0 Тогда
					рПолучения = СкачатьКМпоGTIN(ИД_Заказа, СтрокаТ.gtin, рСтатусы.Данные.availableCodes, СоединениеХТТП, СтанцияСУЗ, ДопПараметры);
					Если рПолучения.Успешно Тогда					
						МассивЗаписей.Добавить(рПолучения.ИД_ЗаписиЛога);					
					Иначе
						ДобавитьОшибки(Результат, рПолучения);
					КонецЕсли;
				КонецЕсли;		
			КонецЕсли;			
		Иначе			
			ДобавитьОшибки(Результат, рСтатусы);		
		КонецЕсли; 
	КонецЦикла;
	
	Если МассивЗаписей.Количество()=0 Тогда
		МассивЗаписей = ПолучитьМассивЗаписейЗагрузкиКМ(ЗаказКМ);
	КонецЕсли;	
		
	Если МассивЗаписей.Количество()>0 Тогда
		ОбработаноОбъектов = ЗагрузитьКодыИзЛогов(МассивЗаписей);
		
		КолКодов = КоличестваКодовПоЗаказу(ЗаказКМ);
		Если КолКодов.ПолученоКМ = КолКодов.ЗаказаноКМ Тогда
			УстановитьРеквизитыОбъекта(ЗаказКМ, Новый Структура("Статус", Перечисления.СтатусыДокументовМаркировки.Обработан), РежимЗаписиДокумента.Проведение);
		КонецЕсли; 
	КонецЕсли;
	
	Результат.Вставить("ОбработаноОбъектов", ОбработаноОбъектов);
	Результат.Успешно = (Результат.Ошибки.Количество()=0 И ОбработаноОбъектов>0);
	
	Возврат Результат;
КонецФункции //ЗагрузитьКодыПоЗаказуКМ(ЗаказКМ)

Функция ПолучитьКодыПоЗаказуКМ_v3(ЗаказКМ, СтанцияСУЗ) Экспорт
