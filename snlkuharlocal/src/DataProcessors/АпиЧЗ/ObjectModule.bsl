		Агрегат.Вставить("aggregationUnitCapacity",		МассивКодов.Количество()); 
		Агрегат.Вставить("sntins",						МассивКодов); 
		// Кухарь А.Ю.  21.08.2025 начало
		//Агрегат.Вставить("unitSerialNumber",			Выборка_КодАгрегации.КодАгрегации);
		Агрегат.Вставить("unitSerialNumber",			ПрефиксАгрегации+Выборка_КодАгрегации.КодАгрегации);		 
		// Кухарь А.Ю.  21.08.2025 конец
		
		Агрегаты.Добавить(Агрегат);			
