Процедура ПерезаполнитьХранилищеОбщихНастрок(Знач ДопПараметры,Знач ДокСсылка)	
	
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда
		
		
		ФормированиеИОбработкаЗаказовКМОб = Обработки.ФормированиеИОбработкаЗаказовКМ.Создать();
		
		Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда
		
			Организация = ДокСсылка.Организация; 
			
		ИначеЕсли ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") 
			И  ТипЗнч(ДокСсылка.ДокументОснование) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда  
			
			Организация = ДокСсылка.ДокументОснование.Организация;	
		ИначеЕсли ДопПараметры.Свойство("Организация") Тогда  
			Организация = ДопПараметры.Организация;
		Иначе 
			Организация = Справочники.Организации.ПустаяСсылка(); 
		КонецЕсли;
		
		ДанныеСертификата = ФормированиеИОбработкаЗаказовКМОб.ПолучитьДанныеСертификата(Организация); 
		Если ДанныеСертификата.Свойство("Токен_СУЗ") Тогда
			
			ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "Токен_СУЗ", ДанныеСертификата.Токен_СУЗ);
			
		КонецЕсли;
		
		Если ДанныеСертификата.Свойство("ТокенТруАпи") Тогда
			
			ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТокенТруАпи", ДанныеСертификата.ТокенТруАпи);
			
		КонецЕсли;
		
		Если ДанныеСертификата.Свойство("ОтпечатокСертификатаЭЦП") Тогда
			
			ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ОтпечатокСертификатаЭЦП",ДанныеСертификата.ОтпечатокСертификатаЭЦП);
			
		КонецЕсли;
		
		Если ДанныеСертификата.Свойство("ТекущаяСУЗ") Тогда
			
			ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ТекущаяСУЗ",ДанныеСертификата.ТекущаяСУЗ);
			ХранилищеОбщихНастроек.Сохранить("АпиЧЗ", "ПарольДоступаКЗакрытомуКлючу", "");
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры 

	
#КонецОбласти 


#Область ПолучениеТокеновДоступа


Функция ПолучитьТокен_СУЗ(СУЗ, ОтпечатокСертификатаЭЦП) Экспорт	
	Токен_СУЗ 		= "";                                      
	
	Если (ЗначениеЗаполнено(СУЗ) И ТипЗнч(СУЗ) = Тип("СправочникСсылка.СтанцииУправленияЗаказамиИСМП")) Тогда
		Организация = ПолучитьРеквизитШапки(СУЗ, "Владелец");
	Иначе		
		Возврат Токен_СУЗ;	
	КонецЕсли;
	
	АдресДляКлюча				= МаркировкаВС.ПолучитьАдресСервераTrueApi();
	
	АдресРесурса_ПарАвторизации	= "api/v3/true-api/auth/key";
	АдресРесурса_КлючСессии 	= "api/v3/true-api/auth/simpleSignIn/";	
	
	ИД_Соединения				= СУЗ.Идентификатор;
	
	СоединениеХТТП = СоздатьСоединение_СУЗ(АдресДляКлюча);
	
	рЗапроса = ВыполнитьЗапрос_СУЗ(АдресРесурса_ПарАвторизации, , СоединениеХТТП);
	
	Если НЕ рЗапроса.Успешно Тогда
		Сообщить(СтрСоединить(рЗапроса.Ошибки, Символы.ПС), Символы.ПС);
		Возврат "";	
	КонецЕсли;

    Данные	= ПрочитатьЖСОН(рЗапроса.Ответ);
	
	ПодписанныеДанные 	= ДвоичныеДанныеBase64(ПодписатьПо1Совски(Данные.data, ОтпечатокСертификатаЭЦП, Ложь));
	
	Если НЕ ЗначениеЗаполнено(ПодписанныеДанные) Тогда
		Сообщить("Ошибка подписи запрсоа СУЗ.", СтатусСообщения.Важное);
        Возврат "";
    КонецЕсли;
       
    ТекстЗапроса	= ЗаписатьЖСОН(Новый Структура("inn,omsConnection,uuid,data", СокрЛП(Организация.ИНН), ИД_Соединения, Данные.uuid, ПодписанныеДанные));	
	рЗапроса 		= ВыполнитьЗапрос_СУЗ(СоздатьЗапрос_СУЗ(АдресРесурса_КлючСессии+ИД_Соединения, ТекстЗапроса), "POST", СоединениеХТТП);
	
	Если рЗапроса.Успешно Тогда
		Данные 		= ПрочитатьЖСОН(рЗапроса.Ответ);
		Токен_СУЗ 	= Данные.token;
		
		РегистрыСведений.ТокеныАвторизацииИСМП.СохранитьТокен(Токен_СУЗ, "СУЗ", Организация, ОтпечатокСертификатаЭЦП, СУЗ);
		
		Сообщить("Получен токен СУЗ. Длинна: "+СтрДлина(Токен_СУЗ), СтатусСообщения.Информация);
	Иначе
		Сообщить(рЗапроса.Ответ, СтатусСообщения.Важное);
	КонецЕсли;
	
	ХранилищеОбщихНастроек.Сохранить(КлючОбъекта_ДляНастроек, "Токен_СУЗ", Токен_СУЗ);
	
	Возврат Токен_СУЗ;
КонецФункции //ПолучитьТокен_СУЗ(СУЗ, ОтпечатокСертификатаЭЦП) Экспорт

Функция ПолучитьТокен_TrueApi(ОтпечатокСертификатаЭЦП, мОрганизация = Неопределено) Экспорт
	Сервер			= Сервер_TrueApi;
	СоединениеХТТП 	= Новый HTTPСоединение(Сервер, 443, , , , , Новый ЗащищенноеСоединениеOpenSSL);
	
	АдресРесурса_ПарАвторизации	= "api/v3/true-api/auth/key";
	АдресРесурса_КлючСессии 	= "api/v3/true-api/auth/simpleSignIn";	
	
	рЗапроса = ВыполнитьЗапрос_НК(АдресРесурса_ПарАвторизации, , СоединениеХТТП);
	
	Если НЕ рЗапроса.Успешно Тогда 
		Возврат 0;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(мОрганизация) Тогда
		Организация = мОрганизация;
	КонецЕсли;
	
	Данные 				= ПрочитатьЖСОН(рЗапроса.Ответ);    
	ПодписанныеДанные 	= ДвоичныеДанныеBase64(ПодписатьПо1Совски(Данные.data, ОтпечатокСертификатаЭЦП, Ложь));	
	Если ПодписанныеДанные = "" Тогда
		Возврат 0;         
    КонецЕсли;
       
    ТекстЗапроса = ЗаписатьЖСОН(Новый Структура("inn,uuid,data", Организация.ИНН, Данные.uuid, ПодписанныеДанные));	
	
	ЗапросХТТП	= СоздатьЗапрос_НК(АдресРесурса_КлючСессии, ТекстЗапроса);
	рЗапроса	= ВыполнитьЗапрос_НК(ЗапросХТТП, "POST", СоединениеХТТП);
		
	Если рЗапроса.Успешно Тогда
		Данные = ПрочитатьЖСОН(рЗапроса.Ответ);		
		
		Токен_TrueApi = Данные.token;
		ХранилищеОбщихНастроек.Сохранить(КлючОбъекта_ДляНастроек, "Токен_TrueApi", Токен_TrueApi);
		
		РегистрыСведений.ТокеныАвторизацииИСМП.СохранитьТокен(Токен_TrueApi, "TrueApi", Организация, ОтпечатокСертификатаЭЦП);
		
		Сообщить("Получен токен TrueApi. Длинна: "+СтрДлина(Токен_TrueApi), СтатусСообщения.Информация);	
	КонецЕсли;	
	
	Возврат Токен_TrueApi;
КонецФункции //ПолучитьТокен_TrueApi()

Функция ПроверитьПолучитьПараметрыПодключенияСУЗ(ДокСсылка, пОбработки = Неопределено) Экспорт
	Результат				= СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(ДокСсылка) Тогда
		Организация = ПолучитьРеквизитШапки(ДокСсылка, "Организация");
	Иначе		
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");		
		Возврат Результат;
	КонецЕсли;
	
	СУЗ = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "СУЗ");
	Если НЕ ЗначениеЗаполнено(СУЗ) Тогда
		рПолучения = Справочники.СтанцииУправленияЗаказамиИСМП.ПолучитьСузПользователя(Организация);	
		Если рПолучения.Успешно Тогда
			СУЗ = рПолучения.Данные;
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;	
	
	ОтпечатокСертификатаЭЦП = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "ОтпечатокСертификатаЭЦП");
	Если НЕ ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) Тогда
		ОтпечатокСертификатаЭЦП = ХранилищеОбщихНастроек.Загрузить(КлючОбъекта_ДляНастроек, "ОтпечатокСертификатаЭЦП");
	КонецЕсли;
	
	Если НЕ (ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) И ЗначениеЗаполнено(СУЗ)) Тогда
		#ЕСЛИ КЛИЕНТ ТОГДА
		пПодключения = ЭтотОбъект.Получитьформу("НастройкаПараметров").ОткрытьМодально();
		
		ОтпечатокСертификатаЭЦП = ПолучитьЗначениеПараметра(пПодключения, "ОтпечатокСертификатаЭЦП");
		СУЗ 					= ПолучитьЗначениеПараметра(пПодключения, "ТекущаяСУЗ");			
		#ИНАЧЕ
			Если НЕ ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП)  Тогда
				Результат.Ошибки.Добавить("Не указан сертификат ЭЦП !");			
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(СУЗ)  Тогда
				Результат.Ошибки.Добавить("Не указан СУЗ !");			
			КонецЕсли;
			
			Возврат Результат;
		#КОНЕЦЕСЛИ
	КонецЕсли; 
	
	Если НЕ (ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) И ЗначениеЗаполнено(СУЗ)) Тогда
		ТекстОшибки = "Не указан используемый сертификат ЭЦП или текущая СУЗ !";
		
		Результат.Ошибки.Добавить(ТекстОшибки);		
		Возврат Результат;
	КонецЕсли;
	
	рПолучения = РегистрыСведений.ТокеныАвторизацииИСМП.ПолучитьТокен("СУЗ", Организация, ОтпечатокСертификатаЭЦП, СУЗ);
	
	Если рПолучения.Успешно Тогда                       
		Данные = рПолучения.Данные;
		
		Токен_СУЗ = Данные.Токен;
		
		Результат.Вставить("СтанцияСУЗ", 				СУЗ);
		Результат.Вставить("ОтпечатокСертификатаЭЦП", 	ОтпечатокСертификатаЭЦП);		
		
		Результат.Успешно	= Истина;		
	Иначе
		Токен_СУЗ 			= "";	
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПроверитьПолучитьПараметрыПодключенияСУЗ()

Функция ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка = Неопределено, пОбработки = Неопределено) Экспорт
	Результат = СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(ДокСсылка) Тогда
		Организация = ПолучитьРеквизитШапки(ДокСсылка, "Организация");
	Иначе	
		Если НЕ ЗначениеЗаполнено(Организация) Тогда		
			Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");			
			Возврат Результат;		
		КонецЕсли;		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		ТекстОшибки = СтрШаблон("Невозможно определить организацию документа: '%1' !", ДокСсылка);
		Результат.Ошибки.Добавить(ТекстОшибки);
		
		Возврат Результат;	
	КонецЕсли;
	
	ОтпечатокСертификатаЭЦП = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "ОтпечатокСертификатаЭЦП");
	Если НЕ ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) Тогда
		ОтпечатокСертификатаЭЦП = ХранилищеОбщихНастроек.Загрузить(КлючОбъекта_ДляНастроек, "ОтпечатокСертификатаЭЦП");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) Тогда		
		#ЕСЛИ КЛИЕНТ ТОГДА
		пПодключения 			= ЭтотОбъект.Получитьформу("НастройкаПараметров").ОткрытьМодально();		
		
		ОтпечатокСертификатаЭЦП = ПолучитьЗначениеПараметра(пПодключения, "ОтпечатокСертификатаЭЦП");		
		#ИНАЧЕ			
			Результат.Ошибки.Добавить("Не указан сертификат ЭЦП !");			
			Возврат Результат;
		#КОНЕЦЕСЛИ
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ОтпечатокСертификатаЭЦП) Тогда
		ТекстОшибки = "Не указан используемый сертификат ЭЦП !";
		
		Результат.Ошибки.Добавить(ТекстОшибки);
		
		Возврат Результат;
	КонецЕсли;
	
	ТекущийОтпечатокСертификатаЭЦП = ОтпечатокСертификатаЭЦП;
	
	Пользователь	= МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Пользователь");
	рПолучения 		= РегистрыСведений.ТокеныАвторизацииИСМП.ПолучитьТокен("TrueApi", Организация, ОтпечатокСертификатаЭЦП, , Пользователь);
	Если рПолучения.Успешно Тогда                       
		Данные = рПолучения.Данные;
		
		Токен_TrueApi = Данные.Токен;		
		
		Результат.Вставить("ОтпечатокСертификатаЭЦП", 	ОтпечатокСертификатаЭЦП);
		Результат.Вставить("СтанцияСУЗ", 				Данные.СУЗ);
		
		Результат.Успешно	= Истина;
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		Токен_TrueApi		= "";		
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПроверитьПолучитьПараметрыПодключенияTrueApi(ДокСсылка, пОбработки = Неопределено)

Функция ПроверитьТокен_TrueApi(Токен, мОрганизация) Экспорт	
	Результат 		= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Токен_TrueApi 	= Токен;
	Организация		= мОрганизация;
	
	СоединениеХТТП	= СоздатьСоединение_TrueApi();
	АдресРесурса	= "api/v3/true-api/participants?inns=" + ПолучитьРеквизитШапки(Организация, "ИНН");	
	рЗапроса = ВыполнитьЗапрос_TrueApi(АдресРесурса, , СоединениеХТТП);
	
	Если рЗапроса.Успешно Тогда	
		Если рЗапроса.КодСостояния = 200 Тогда
			Если ПустаяСтрока(рЗапроса.Ответ) Тогда			
				ТекстОшибки = "Получен пустой ответ.";
				Результат.Ошибки.Добавить(ТекстОшибки);				
			Иначе				
				Данные = ПрочитатьЖСОН(рЗапроса.Ответ);
				Если ТипЗнч(Данные) = Тип("Массив") И Данные.Количество() > 0 Тогда
					СтатусИНН = МаркировкаКС.ПолучитьЗначениеПараметра(Данные[0],"statusInn");			
					Если ВРег(СтатусИНН) = "REGISTERED" Тогда
						Результат.Успешно = Истина;
						Результат.Сообщения.Добавить("Успешно проверен токен TrueApi.");
					Иначе                         
						ТекстОшибки = "Получен обычный ответ вместо расширеного. " + рЗапроса.Ответ;
						Результат.Ошибки.Добавить(ТекстОшибки);
					КонецЕсли;
				Иначе   
					ТекстОшибки = СтрШаблон("Некорректный ответ: '%1' !", рЗапроса.Ответ);
					Результат.Ошибки.Добавить(ТекстОшибки);
				КонецЕсли;
			КонецЕсли;
		Иначе
			ТекстОшибки = СтрШаблон("Некорректный код ответа: %1 !", рЗапроса.КодСостояния);
			Результат.Ошибки.Добавить(ТекстОшибки);			
		КонецЕсли;	
	Иначе
		МаркировкаКС.ДобавитьОшибки(Результат, рЗапроса);
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ПроверитьТокен_TrueApi(Токен, мОрганизация) Экспорт

#КонецОбласти


#Область ЗапросыHTTP

// ЗапросХТТП - ЗапросHTTP или Строка: АдресРесурса 
Функция ВыполнитьЗапрос_НК(Знач ЗапросХТТП, МетодХТТП = "GET", Знач СоединениеХТТП = Неопределено, ДопПараметры = Неопределено) Экспорт
	Если СоединениеХТТП = Неопределено Тогда
		СоединениеХТТП 	= СоздатьСоединение_НК();	
	КонецЕсли;
	
	Если ТипЗнч(ЗапросХТТП) = Тип("Строка") Тогда	
		ЗапросХТТП = СоздатьЗапрос_НК(ЗапросХТТП);	
	КонецЕсли;
	
	Результат = Новый Структура("Успешно,Сообщения,Ошибки,КодСостояния,Ответ", Истина, Новый Массив, Новый Массив, "");
	
	Начало  = ТекущаяУниверсальнаяДатаВМиллисекундах(); 
	
	МЗ		= НачатьЗаписьЛога(СоединениеХТТП, ЗапросХТТП, ДопПараметры);
	
	Ответ 	= СоединениеХТТП.ВызватьHTTPМетод(МетодХТТП, ЗапросХТТП);	
	Текст	= Ответ.ПолучитьТелоКакСтроку();
	
	Результат.КодСостояния	= Ответ.КодСостояния;
	Результат.Ответ			= Текст;
	
	Если Ответ.КодСостояния <> 200 Тогда
		Результат.Успешно	= Ложь;		
		Результат.Ошибки.Добавить("Код cостояния: "+Ответ.КодСостояния+Символы.ПС+Текст);		
		
		Сообщить("Код cостояния: "+Ответ.КодСостояния+Символы.ПС+"	"+СтрСоединить(Результат.Ошибки,Символы.ПС+"	"), СтатусСообщения.ОченьВажное);
	КонецЕсли;
	
	ЗавершитьЗаписьЛога(МЗ, Ответ.КодСостояния, Текст, Начало);
	
	Результат.Вставить("ИД_ЗаписиЛога", МЗ.ИД);
	
	Возврат Результат;
КонецФункции //ВыполнитьЗапрос_НК(Знач ЗапросХТТП, МетодХТТП = "GET", СоединениеХТТП = Неопределено)

// ЗапросХТТП - ЗапросHTTP или Строка: АдресРесурса 
Функция ВыполнитьЗапрос_СУЗ(Знач ЗапросХТТП, МетодХТТП = "GET", Знач СоединениеХТТП = Неопределено, ДопПараметры = Неопределено) Экспорт
	Если СоединениеХТТП = Неопределено Тогда
		СоединениеХТТП 	= СоздатьСоединение_СУЗ();	
	КонецЕсли;
	
	Если ТипЗнч(ЗапросХТТП) = Тип("Строка") Тогда	
		ЗапросХТТП = СоздатьЗапрос_СУЗ(ЗапросХТТП);	
	КонецЕсли;
	
	Результат = Новый Структура("Успешно,Сообщения,Ошибки,КодСостояния,Ответ", Истина, Новый Массив, Новый Массив, "");
	
	Начало  = ТекущаяУниверсальнаяДатаВМиллисекундах(); 
	
	МЗ		= НачатьЗаписьЛога(СоединениеХТТП, ЗапросХТТП, ДопПараметры);	
	
	Ответ 	= СоединениеХТТП.ВызватьHTTPМетод(МетодХТТП, ЗапросХТТП);	
	Текст	= Ответ.ПолучитьТелоКакСтроку();
	
	Результат.КодСостояния	= Ответ.КодСостояния;
	Результат.Ответ			= Текст;
	
	Если Ответ.КодСостояния = 200 Тогда				
		Результат.Успешно	= Истина;		
	Иначе		
		Результат.Успешно	= Ложь;
		
		Попытка
			Результат.Ошибки	= ПолучитьОшибкиИзОтвета(ПрочитатьЖСОН(Текст));
		Исключение
			Результат.Ошибки.Добавить(Текст);			
		КонецПопытки;		
		
		Сообщить("Код cостояния: "+Ответ.КодСостояния+Символы.ПС+"	"+СтрСоединить(Результат.Ошибки,Символы.ПС+"	"), СтатусСообщения.ОченьВажное);
	КонецЕсли;
	
	ЗавершитьЗаписьЛога(МЗ, Ответ.КодСостояния, Текст, Начало);
	
	Результат.Вставить("ИД_ЗаписиЛога", МЗ.ИД);
	
	Возврат Результат;
КонецФункции //ВыполнитьЗапрос_НК(Знач ЗапросХТТП, МетодХТТП = "GET", СоединениеХТТП = Неопределено)

// ЗапросХТТП - ЗапросHTTP или Строка: АдресРесурса 
Функция ВыполнитьЗапрос_TrueApi(Знач ЗапросХТТП, МетодХТТП = "GET", Знач СоединениеХТТП = Неопределено, ДопПараметры = Неопределено, Повторный = Ложь) Экспорт
	Если СоединениеХТТП = Неопределено Тогда
		СоединениеХТТП 	= СоздатьСоединение_TrueApi(ДопПараметры);
	КонецЕсли;
	
	Если ТипЗнч(ЗапросХТТП) = Тип("Строка") Тогда	
		ЗапросХТТП = СоздатьЗапрос_TrueApi(ЗапросХТТП);	
	КонецЕсли;
	
	Результат = Новый Структура("Успешно,Сообщения,Ошибки,КодСостояния,Ответ", Истина, Новый Массив, Новый Массив, "");
	
	Начало  = ТекущаяУниверсальнаяДатаВМиллисекундах(); 
	МЗ		= НачатьЗаписьЛога(СоединениеХТТП, ЗапросХТТП, ДопПараметры);	
	
	Попытка
		Ответ = СоединениеХТТП.ВызватьHTTPМетод(МетодХТТП, ЗапросХТТП);	
		Текст = Ответ.ПолучитьТелоКакСтроку();
	Исключение
		//Сообщить(ОписаниеОшибки());
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить("АпиЧЗ.ВыполнитьЗапрос_TrueApi: ошибка выполнения запроса: " + ОписаниеОшибки());
		Результат.Вставить("ОшибкаЧЗ", Истина);
		
		Возврат Результат;				
	КонецПопытки;	
	
	Результат.КодСостояния	= Ответ.КодСостояния;
	Результат.Ответ			= Текст;
	
	ОшибкаТокена = Ложь;
	
	Если Ответ.КодСостояния = 200 Тогда
	ИначеЕсли Ответ.КодСостояния = 201 Тогда
	ИначеЕсли Ответ.КодСостояния = 408 Тогда
		ТекстОшибки = СтрШаблон("Превышен таймаут запроса к ЧЗ ! Код ответа: %1, ответ: %2 !", Ответ.КодСостояния, Текст);		
		
		Результат.Успешно	= Ложь;
		Результат.Ошибки.Добавить(ТекстОшибки);
		Результат.Вставить("ОшибкаЧЗ", Истина);
	Иначе		
		Если Ответ.КодСостояния = "400" И ЭтоОшибкаТокена(Текст) Тогда
			ОшибкаТокена = Истина;			
		КонецЕсли;
		
		//+++Чирков 01.06.2026
		Если ОшибкаТокена Тогда
			ТекстОшибки = СтрШаблон("Не удалось получить токен ЧЗ. Ответ сервера: %1, код состояния: %2.", Текст, Ответ.КодСостояния);
		Иначе
			ТекстОшибки = СтрШаблон("Неожиданный ответ сервера %1, код состояния: %2.", Текст, Ответ.КодСостояния);
		КонецЕсли;
		//---Чирков 01.06.2026
		
		Результат.Успешно	= Ложь;		
		//+++Чирков 01.06.2026
		//Результат.Ошибки.Добавить(Текст);
		Результат.Ошибки.Добавить(ТекстОшибки);
		//---Чирков 01.06.2026
	КонецЕсли;
	
	ЗавершитьЗаписьЛога(МЗ, Ответ.КодСостояния, Текст, Начало);
	Результат.Вставить("ИД_ЗаписиЛога", МЗ.ИД);
	
	Если ОшибкаТокена Тогда
		Если Повторный  Тогда
			ЗаписатьВЛог("Токены ЧЗ", "Двойная ошибка получения токена TrueApi.", "Ошибка");
		Иначе
			Если ЗначениеЗаполнено(ТекущийОтпечатокСертификатаЭЦП) Тогда
				Токен_TrueApi = ПолучитьТокен_TrueApi(ТекущийОтпечатокСертификатаЭЦП, Организация);		
				
				Если ЗначениеЗаполнено(Токен_TrueApi) Тогда			                               
					РегистрыСведений.ТокеныАвторизацииИСМП.СохранитьТокен(Токен_TrueApi, "TrueApi", Организация, ТекущийОтпечатокСертификатаЭЦП);
					
					//Повторная отправка запроса с новым токеном
					ЗапросХТТП.Заголовки.Вставить("Authorization", СтрШаблон("Bearer %1", Токен_TrueApi));
					Результат = ВыполнитьЗапрос_TrueApi(ЗапросХТТП, МетодХТТП, СоединениеХТТП, ДопПараметры, Истина);
					
					ЗаписатьВЛог("Токены ЧЗ", "Обновлен токен TrueApi.", "Отладка");
				Иначе
					ЗаписатьВЛог("Токены ЧЗ", "Не удалось получить повторный токен TrueApi.", "Ошибка");
				КонецЕсли;			
			Иначе   
				ЗаписатьВЛог("Токены ЧЗ", "Не удалось получить повторный токен TrueApi. Пустой отпечаток ЭЦП.", "Ошибка");
			КонецЕсли;		
		КонецЕсли;				
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ВыполнитьЗапрос_TrueApi(Знач ЗапросХТТП, МетодХТТП = "GET", СоединениеХТТП = Неопределено)

Функция НачатьЗаписьЛога(СоединениеХТТП, ЗапросХТТП, ДопПараметры = Неопределено)
	МЗ				= РегистрыСведений.ЗапросыЧЗ.СоздатьМенеджерЗаписи();
	
	МЗ.ИД			= Новый УникальныйИдентификатор;
	МЗ.Пользователь	= ПараметрыСеанса.Пользователь;
	МЗ.Сервер   	= СоединениеХТТП.Сервер;
	МЗ.ДатаНачала	= ТекущаяДата();                         
	
	Части 			= СтрРазделить(ЗапросХТТП.АдресРесурса,"?");
	МЗ.АдресРесурса	= Части[0];
	Если Части.Количество()>1 Тогда	
		МЗ.ПараметрыURL = Части[1]; 
	КонецЕсли;		
	МЗ.Основание	= ПолучитьЗначениеПараметра(ДопПараметры, "Основание");
	ТелоЗапроса		= ПолучитьЗначениеПараметра(ДопПараметры, "ТелоЗапроса", "");
	Если ПустаяСтрока(ТелоЗапроса) Тогда
		ТелоЗапроса = ЗапросХТТП.ПолучитьТелоКакСтроку();
	КонецЕсли;	
	МЗ.ДанныеЗапроса = Новый ХранилищеЗначения(ТелоЗапроса);

	Возврат МЗ;
КонецФункции //НачатьЗаписьЛога(СоединениеХТТП, ЗапросХТТП, ДопПараметры = Неопределено)

Функция ЗавершитьЗаписьЛога(МЗ, КодСостояния, ТекстОтвета, Начало)
	МЗ.КодОтветаHTTP 	= КодСостояния;
	МЗ.ДанныеОтвета		= Новый ХранилищеЗначения(ТекстОтвета);
	МЗ.ВремяВыполнения	= (ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало)/1000;
	
	МЗ.Записать();
КонецФункции // ()

Функция СоздатьСоединение_СУЗ(Знач Сервер = "") Экспорт
	Если НЕ ЗначениеЗаполнено(Сервер) Тогда
		Сервер = Сервер_СУЗ;	
	КонецЕсли; 
	СоединениеХТТП = Новый HTTPСоединение(Сервер, 443, , , , , Новый ЗащищенноеСоединениеOpenSSL);
	
	Возврат СоединениеХТТП;
КонецФункции //СоздатьСоединение_СУЗ()

Функция СоздатьСоединение_НК() Экспорт
	СоединениеХТТП = Новый HTTPСоединение(Сервер_НК, 443, , , , , Новый ЗащищенноеСоединениеOpenSSL);
	
	Возврат СоединениеХТТП;
КонецФункции //СоздатьСоединение_СУЗ()

Функция СоздатьСоединение_TrueApi(ДопПараметры = Неопределено) Экспорт
	//+++Чирков 16.01.2026
	Таймаут = ПолучитьЗначениеПараметра(ДопПараметры, "Таймаут", 0);
	//---Чирков 16.01.2026	
	
	СоединениеХТТП = Новый HTTPСоединение(Сервер_TrueApi, 443, , , , Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
	
	Возврат СоединениеХТТП;
КонецФункции //СоздатьСоединение_TrueApi(ДопПараметры = Неопределено) Экспорт 

Функция СоздатьЗапрос_НК(АдресРесурса, ТекстЗапроса = "") Экспорт
	ЗаголовкиХТТП = Новый Соответствие;
	ЗаголовкиХТТП.Вставить("Accept",		"*");
	ЗаголовкиХТТП.Вставить("Content-type",	"application/json; charset=utf-8");	
	
