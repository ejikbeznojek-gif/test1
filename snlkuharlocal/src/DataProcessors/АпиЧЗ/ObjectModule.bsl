Функция ОтправитьНаОбработку_ЗаказКМ(ДокСсылка, ДопПараметры = Неопределено, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();	
	
	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли;
	//++Данилова Е.В. 13.05.2025 MARK-1675
	//+++Чирков 16.06.2025 
	//ПерезаполнитьХранилищеОбщихНастрок(ДопПараметры,ДокСсылка);
	//---Чирков 16.06.2025
	//--Данилова Е.В. 13.05.2025
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияСУЗ(ДокСсылка, ДопПараметры);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
		
		рПроверкиСУЗ = ПроверитьОрганизациюСУЗ(СтанцияСУЗ, ДокСсылка);
		Если НЕ рПроверкиСУЗ.Успешно Тогда
			Результат.Успешно = Ложь;
			МаркировкаКС.ДобавитьОшибки(Результат, рПроверкиСУЗ);		
			Возврат Результат;		
		КонецЕсли;
	Иначе			
		МаркировкаКС.ДобавитьОшибки(Результат, рПроверкиПодкл); //+++Чирков 17.09.2025 - так понятнее
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	рОтправки = ОтправитьЗапрос_ЗаказКМ(ДокСсылка, СтанцияСУЗ, рПроверкиПодкл.ОтпечатокСертификатаЭЦП);
	Если рОтправки.Успешно Тогда
