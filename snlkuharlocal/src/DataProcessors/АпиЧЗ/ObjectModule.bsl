Функция ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка, ВидОперацииИСМП)
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,
	|	Статус
	|ИЗ	
	|	Документ.МаркировкаТоваровИСМП
	|ГДЕ
	|	ДокументОснование	= &ЗПС_Ссылка
	|	И ВидОперацииИСМП 	= &ВидОперацииИСМП
	|";
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка",			ЗПС_Ссылка);
	Запрос.УстановитьПараметр("ВидОперацииИСМП",	ВидОперацииИСМП);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ (
			Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.ВРаботе 
			ИЛИ Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.КОбработке
			ИЛИ Выборка.Статус = Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки ) Тогда
			
			ТекстОшибки = СтрШаблон("Недопустимый статус заказа на КМ: '%1', тек. статус: '%2', допустимые статусы: 'В работе' или 'К обработке'.", Выборка.Ссылка, Выборка.Статус);
			Результат.Ошибки.Добавить(ТекстОшибки);
		КонецЕсли; 	
	КонецЦикла;
	
	СуществующиеДокументы = Новый Соответствие;
	
	Сч = 1;
	Если Результат.Ошибки.Количество() = 0 Тогда
		Выборка.Сбросить();
		
		НачатьТранзакцию(РежимУправленияБлокировкойДанных.Управляемый);
		
		Пока Выборка.Следующий() Цикл
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ДокОбъект.Статус 			= Перечисления.СтатусыДокументовМаркировки.ВРаботе;
			ДокОбъект.ИД_ДокументаЧЗ    = "";
			
			ДокОбъект.Товары.Очистить();
			ДокОбъект.ШтрихкодыУпаковок.Очистить();
			
			ДокОбъект.Проведен 			= Ложь;
			ДокОбъект.ПометкаУдаления 	= Истина;
		
			ДокОбъект.Записать();		
			
			СуществующиеДокументы[Сч] = ДокОбъект.Ссылка;
			Сч	= Сч+1;
		КонецЦикла;		
		
		ЗафиксироватьТранзакцию();	
	Иначе
		Результат.Успешно = Ложь;
	КонецЕсли; 
	
	Результат.Вставить("СуществующиеДокументы", СуществующиеДокументы);

	Возврат Результат;
КонецФункции //ОчиститьПодчиненныеДокументыМаркировки(ЗПС_Ссылка)


Функция ПолучитьТелоЗапроса_Агрегация_ЗаказКМ(ЗаказКМ)
	
	КодSSCC 		= "462718735"+"0"+"0000001";
	Сообщить(СтрДлина(КодSSCC));
	КодSSCC			= КодSSCC+МаркировкаКС.КонтрольныйСимволSSCC(КодSSCC);

	Запрос 			= Новый Запрос;
	
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	Владелец.ШтукВКоробке КАК ШтукВКоробке,
	|	Ссылка,
	|	Наименование КАК СТИН
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ЗаказКМ = &ЗаказКМ
	|
	|";
	
	Запрос.УстановитьПараметр("ЗаказКМ", ЗаказКМ);
	
	МассивКодов = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл		
		МассивКодов.Добавить(СокрЛП(Выборка.СТИН));
	КонецЦикла;
	
	Пакет = Новый Структура;
	//Пакет.Вставить("productGroup", "lp");
	Пакет.Вставить("participantId", Организация.ИНН);
	
	Агрегат = Новый Структура;
	
	Агрегат.Вставить("aggregatedItemsCount", 		МассивКодов.Количество()); 
	Агрегат.Вставить("aggregationType", 			"AGGREGATION");
	Агрегат.Вставить("aggregationUnitCapacity",		МассивКодов.Количество()); 
	Агрегат.Вставить("sntins",						МассивКодов); 
	Агрегат.Вставить("unitSerialNumber",			КодSSCC);
	
	Агрегаты = Новый Массив;
	Агрегаты.Добавить(Агрегат);	
	
	Пакет.Вставить("aggregationUnits", Агрегаты);
	
	ТелоЗапроса		= ЗаписатьЖСОН(Пакет);

	Возврат ТелоЗапроса;
КонецФункции // ()

Функция ПолучитьТелоЗапроса_Агрегация_ОперМаркировки(ДокСсылка)
	Запрос 			= Новый Запрос;	
	Запрос.Текст	= "
	|ВЫБРАТЬ	
	|	КодАгрегации,
	|	ШтрихкодУпаковки.Наименование КАК СТИН
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ДокСсылка	
	|УПОРЯДОЧИТЬ ПО
	|	КодАгрегации
	|ИТОГИ ПО
	|	КодАгрегации
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Агрегаты = Новый Массив;	
	// Кухарь А.Ю.  21.08.2025 начало
	ПрефиксАгрегации = ПолучитьПрефиксАгрегации(ДокСсылка);	     
