#Область ПроверкаКМвЧЗ


Функция ПроверитьКМвЧЗ(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);	
	
	ПорцииКМ 		= МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "ПорцииКМ");
	Основание		= МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Основание");
	мОрганизация 	= МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Организация", Маркировка_ПИ.ОрганизацияЕЕЭ());	
	
	Если НЕ ЗначениеЗаполнено(мОрганизация) Тогда	
		мОрганизация = ПолучитьРеквизитШапки(Основание, "Организация");
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(мОрганизация) Тогда
		Результат.Ошибки.Добавить("Не указана организация !");
		Результат.Успешно = Ложь;		
		Возврат Результат;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Основание) Тогда
		Результат.Ошибки.Добавить("Не указан проверяемый документ !");
		Результат.Успешно = Ложь;		
		Возврат Результат;	
	КонецЕсли;
	
	Организация = мОрганизация;	
	
	рПроверкиПодкл	= ПроверитьПолучитьПараметрыПодключенияTrueApi(, пОбработки);	
	
	Если НЕ рПроверкиПодкл.Успешно Тогда	
		ДобавитьОшибки(Результат, рПроверкиПодкл);		
		Токен_TrueApi = "";
		Возврат Результат;	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПорцииКМ) Тогда
		ПорцииКМ = МаркировкаС.ПолучитьПорцииКМДляПроверки(Основание);	
	КонецЕсли;
	
	пОбработки.Вставить("Таймаут", Маркировка_ПИ.ВремяОжиданияОтветаЧЗ());
	СоединениеХТТП	= СоздатьСоединение_TrueApi(пОбработки);
	
	АдресРесурса	= "api/v3/true-api/cises/info?pg=lp";	
	
	РазмерПорции = 1000;
	
	Результаты	= Новый Массив;	
	ТекПорция 	= Новый Массив;
	
	ЗаписиЛогов	= Новый Массив;
	
	ПараметрыПорций = Новый Массив;    
	ОшибкаЧЗ		= Ложь;
	
	Для каждого ПорцияКМ Из ПорцииКМ Цикл		
		ЗапросХТТП	= СоздатьЗапрос_TrueApi(АдресРесурса, МаркировкаКС.ЗаписатьЖСОН(ПорцияКМ)); 
		рЗапроса 	= ВыполнитьЗапрос_TrueApi(ЗапросХТТП, "POST", СоединениеХТТП, Новый Структура("Основание", Основание));
			
		Если рЗапроса.Успешно Тогда
			ЗаписиЛогов.Добавить(рЗапроса.ИД_ЗаписиЛога);
		Иначе                                            
			Если рЗапроса.КодСостояния = 404 Тогда //При проверке КМ - ЧЗ возвращает 404- если не нашел код - логика ЧЗ - крайне странная
				ЗаписиЛогов.Добавить(рЗапроса.ИД_ЗаписиЛога);					
			Иначе					
				Результат.Успешно = Ложь;
				МаркировкаКС.ДобавитьОшибки(Результат, рЗапроса);
				ОшибкаЧЗ		= Истина;					
			КонецЕсли;				
		КонецЕсли;
		
		МаркировкаКС.Пауза(Маркировка_ПИ.ИнтервалМеждуПакетамиПроверки());
	КонецЦикла;	
	
	Если ОшибкаЧЗ Тогда		
		МаркировкаС.ЗафиксироватьОтвалЧЗ();		
	Иначе		
		Результат.Данные = ЗаписиЛогов;
		Результат.Успешно = Истина;		
		
		Если НЕ Маркировка_ПИ.ЧЗ_Живой() Тогда
			МаркировкаВС.ЗафиксироватьРаботоспособностьЧЗ();		
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресВозврата) И ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);
	КонецЕсли;
		
	Возврат Результат;	
КонецФункции //ПроверитьКМвЧЗ(пОбработки, АдресВозврата = Неопределено) Экспорт

Функция ПолучитьРезультатыПроверкиКМпоДокументу(ДокСсылка, Знач ЗаписиЛогов = Неопределено,Знач ДопПараметры = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Если ЗаписиЛогов = Неопределено Тогда	
		ЗаписиЛогов = ПолучитьЗаписиЛоговПроверкиКМ(ДокСсылка);
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ДанныеОтвета
	|ИЗ
	|	РегистрСведений.ЗапросыЧЗ
	|ГДЕ
	|	ИД В (&ЗаписиЛогов)
	|";
	
	Данные = Неопределено; 
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = Новый Структура;
	КонецЕсли;
	ДопПараметры.Вставить("ДопустимыеСтатусы", ДопустимыеСтатусыКМДляДокумента(ДокСсылка));
	
	Запрос.УстановитьПараметр("ЗаписиЛогов", ЗаписиЛогов);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		рРазбора = РазобратьДанныеОтветаПроверки(Выборка.ДанныеОтвета.Получить(), ДопПараметры);		
		Если рРазбора.Успешно Тогда
			Если Данные = Неопределено Тогда
				Данные = рРазбора.Данные;
			Иначе
				Данные = СложитьТаблицы(Данные, рРазбора.Данные);		
			КонецЕсли;
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рРазбора);
		КонецЕсли;		
	КонецЦикла;
	
	Результат.Данные = Данные;
	
	Возврат Результат;	
КонецФункции //ПолучитьРезультатыПроверкиКМпоДокументу(ДокСсылка, Знач ЗаписиЛогов = Неопределено) Экспорт

Функция ПолучитьЗаписиЛоговПроверкиКМ(ДокСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ИД
	|ИЗ
	|	РегистрСведений.ЗапросыЧЗ
	|ГДЕ
	|	Основание = &ДокСсылка
	|	И АдресРесурса = ""api/v3/true-api/cises/info""
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ИД");
КонецФункции //ПолучитьЗаписиЛоговПроверкиКМ(ДокСсылка)

Функция РазобратьДанныеОтветаПроверки(ТекстОтвета, ДопПараметры = Неопределено)
	Результат		= МаркировкаКС.СтруктураРезультата();
	
	ТолькоОшибки		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТолькоОшибки", Истина);	
	ДопустимыеСтатусы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ДопустимыеСтатусы");
	
	тРезультатов	= СоздатьТаблицуРезультатовПроверки();
	НеНайденоВЧЗ 	= Новый Массив;
	
	Попытка
		Данные = МаркировкаКС.ПрочитатьЖСОН(ТекстОтвета);
	Исключение  
		Результат.Данные	= ТекстОтвета;
		Результат.Успешно	= Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Ошибка разбора JSON результатов проверки ! Ошибка: '%1' !", ОписаниеОшибки()));
		Возврат Результат;
	КонецПопытки;
	
	Для каждого Элемент Из Данные Цикл
		cisInfo 	= МаркировкаКС.ПолучитьЗначениеПараметра(Элемент, "cisInfo");
		errorCode	= МаркировкаКС.ПолучитьЗначениеПараметра(Элемент, "errorCode");
		Если cisInfo = Неопределено Тогда
		Иначе
			Если errorCode = "404" Тогда
				НеНайденоВЧЗ.Добавить(cisInfo.requestedCis);				
			Иначе				
				СтрокаТР = тРезультатов.Добавить();
				
				СтрокаТР.Владелец_ИНН 			= cisInfo.ownerInn;
				СтрокаТР.Владелец_Наименование	= cisInfo.ownerName;
				СтрокаТР.Статус					= cisInfo.status;		
				СтрокаТР.ТекстКМ 				= cisInfo.cis;
				СтрокаТР.Вложен					= ЗначениеЗаполнено(ПолучитьЗначениеПараметра(cisInfo, "parent"));
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Результаты ИЗ &РезультатыПроверки КАК РезультатыПроверки
	|;
	|ВЫБРАТЬ 
	|	*,                                       
	//+++Чирков 03.03.2026 - отдельная логика для готовых наборов
	|	Спр.Владелец.Родитель.ВидКомплекта КАК ВидКомплекта,
	//---Чирков 03.03.2026 - отдельная логика для готовых наборов
	|	Спр.ТипКода	КАК ТипКода,
	|	Спр.Ссылка 	КАК КМ
	|ИЗ
	|	ВТ_Результаты
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК Спр
	|ПО
	|	Спр.Наименование = ВТ_Результаты.ТекстКМ
	|";
	
	Запрос.УстановитьПараметр("РезультатыПроверки", тРезультатов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ИНН = СокрЛП(Организация.ИНН);
	
	тРезультатов.Очистить();
	Пока Выборка.Следующий() Цикл
		СтрокаР = тРезультатов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаР, Выборка);	
		
		Если НЕ ЗначениеЗаполнено(СтрокаР.КМ) Тогда
			СтрокаР.Ошибка = "КМ не найден в базе !";		
		ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаР.Владелец_ИНН) Тогда
			СтрокаР.Ошибка = "Не получен ИНН владельца !";
		Иначе
			Если СокрЛП(СтрокаР.Владелец_ИНН) <> ИНН Тогда
				СтрокаР.Ошибка = "Код принадлежит другому юр. лицу !";
			Иначе				
				ТекТипКода 		= ТипКодаСтрокой(Выборка.ТипКода, Выборка.ВидКомплекта);
				
				пПроверки       = ПолучитьЗначениеПараметра(ДопустимыеСтатусы, ТекТипКода);
				СтрокаСтатусов 	= ПолучитьЗначениеПараметра(пПроверки, "ДопустимыеСтатусы", "*");				
				ДопустимаяВложенность = ПолучитьЗначениеПараметра(пПроверки, "ДопустимаяВложенность");
				
				Ошибки = Новый Массив;
				
				Если СтрокаСтатусов <> "*" Тогда
					ТекСтатус = СокрЛП(СтрокаР.Статус);
					Если СтрНайти(СтрокаСтатусов, ТекСтатус) > 0 Тогда
					Иначе
						ТекстОшибки = СтрШаблон("Недопустимый статус: '%1' ! Разрешенные статусы: '%2'.", СтатусКМпоРусски(ТекСтатус), СтатусКМпоРусски(СтрокаСтатусов));
						Ошибки.Добавить(ТекстОшибки);
					КонецЕсли;
				КонецЕсли;
				
				Если ДопустимаяВложенность = "Вложен" И СтрокаР.Вложен = Ложь Тогда
					ТекстОшибки = СтрШаблон("Недопустимая вложенность: '%1' ! Разрешенная: '%2'.", ВложенностьСтр(СтрокаР.Вложен), ВложенностьСтр(Истина));
					Ошибки.Добавить(ТекстОшибки);
				ИначеЕсли ДопустимаяВложенность = "Не вложен" И СтрокаР.Вложен = Истина Тогда					
					ТекстОшибки = СтрШаблон("Недопустимая вложенность: '%1' ! Разрешенная: '%2'.", ВложенностьСтр(СтрокаР.Вложен), ВложенностьСтр(Ложь));
					Ошибки.Добавить(ТекстОшибки);
				КонецЕсли;
				
				СтрокаР.Ошибка = СтрСоединить(Ошибки, Символы.ПС);
			КонецЕсли;
		КонецЕсли;
		
		Если ТолькоОшибки И НЕ ЗначениеЗаполнено(СтрокаР.Ошибка) Тогда
			тРезультатов.Удалить(СтрокаР);					
		КонецЕсли;
	КонецЦикла;
	
	неНайденныеКМ = НайтиКодыВБазе(НеНайденоВЧЗ);
	Для каждого СтрокаТЗ Из неНайденныеКМ Цикл
		СтрокаР = тРезультатов.Добавить();
		СтрокаР.ТекстКМ = СтрокаТЗ.ТекстКМ;	
		СтрокаР.КМ 		= СтрокаТЗ.КМ;
		СтрокаР.Ошибка 	= "КМ не найден в ЧЗ !";		
	КонецЦикла;
	
	Результат.Данные = тРезультатов; 
	Возврат Результат; 
КонецФункции //РазобратьДанныеОтветаПроверки(ТекстОтвета)

Функция СтатусКМпоРусски(СтатусыПоАнглийски)
	Части_Вход 	= СтрРазделить(СтатусыПоАнглийски, ",");
	Части_Выход	= Новый Массив;
	
	Для каждого СтатусАнгл Из Части_Вход Цикл
		Части_Выход.Добавить(Маркировка_ПИ.СтатусКМпоРусски(СтатусАнгл));	
	КонецЦикла;
	
	Возврат СтрСоединить(Части_Выход, ",");
КонецФункции //СтатусКМпоРусскм(СтатусПоАнглийски)

Функция ТипКодаСтрокой(ТипКода, ВидКомплекта)
	Результат = "Товар";
	Если ВидКомплекта = Перечисления.ВидыКомплектов.ГотовыйКомплект Тогда
		Результат = "Готовый набор";
	Иначе
		Если ТипКода = Перечисления.ТипыКодовМаркировки.Набор Тогда
			Результат = "Набор";
		ИначеЕсли ТипКода = Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка Тогда
			Результат = "Коробка";
		КонецЕсли;	
	КонецЕсли;	     
	
	Возврат Результат;
КонецФункции //ВидКодаСтрокой(ТипКода, ВидКомплекта)

Функция НайтиКодыВБазе(мКоды)
	тКодов = Новый ТаблицаЗначений;
	тКодов.Колонки.Добавить("Наименование", ПолучитьОписаниеТиповСтроки(Метаданные.Справочники.ШтрихкодыУпаковокТоваров.ДлинаНаименования));
	Для каждого Наименование Из мКоды Цикл
		СтрокаТ = тКодов.Добавить();
		СтрокаТ.Наименование = Наименование;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Наименования ИЗ &тКодов КАК тКодов
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СпрКМ.Ссылка КАК КМ,
	|	ВТ_Наименования.Наименование КАК ТекстКМ	
	|ИЗ
	|	ВТ_Наименования
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК СпрКМ
	|ПО
	|	СпрКМ.Наименование = ВТ_Наименования.Наименование
	|";
	
	Запрос.УстановитьПараметр("тКодов", тКодов);	
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции //НайтиКоды(мКоды) Экспорт

Функция СоздатьТаблицуРезультатовПроверки()
	ТЗ = Новый ТаблицаЗначений;	
	
	ТЗ.Колонки.Добавить("Владелец_ИНН", 			ПолучитьОписаниеТиповСтроки(12));
	ТЗ.Колонки.Добавить("Владелец_Наименование", 	ПолучитьОписаниеТиповСтроки(150));
	ТЗ.Колонки.Добавить("Статус", 					ПолучитьОписаниеТиповСтроки(30));
	ТЗ.Колонки.Добавить("Вложен",					Новый ОписаниеТипов("Булево"));
	ТЗ.Колонки.Добавить("ТекстКМ", 					ПолучитьОписаниеТиповСтроки(50));
	ТЗ.Колонки.Добавить("КМ", 						Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));	
	ТЗ.Колонки.Добавить("Ошибка", 					ПолучитьОписаниеТиповСтроки(500));
	
	Возврат ТЗ;
КонецФункции //СоздатьТаблицуРезультатовПроверки()

Функция ДопустимыеСтатусыКМДляДокумента(ДокСсылка) Экспорт	
	ДопустимыеСтатусы = Новый Соответствие;
	
	Если НЕ (ЗначениеЗаполнено(ДокСсылка) И Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(ДокСсылка))) Тогда
		Возврат ДопустимыеСтатусы;	
	КонецЕсли;	
	
	ТипДокумента 	= ТипЗнч(ДокСсылка); 
	ЭтоФБС			= ЭтоФБС(ДокСсылка);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ТипКода,
	|	ДопустимыеСтатусы,
	|	ДопустимаяВложенность,
	|	Комментарий КАК Комментарий
	|ИЗ
	|	РегистрСведений.ПравилаПроверкиКМ
	|ГДЕ
	|	ВидДокумента = &ВидДокумента
	|	И ФБС = &ФБС
	|";
	
	Запрос.УстановитьПараметр("ВидДокумента", 	ДокСсылка.Метаданные().Имя);
	Запрос.УстановитьПараметр("ФБС", 			ЭтоФБС(ДокСсылка));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл                                                                               
		пПроверки = Новый Структура("ДопустимыеСтатусы,ДопустимаяВложенность");
		ЗаполнитьЗначенияСвойств(пПроверки, Выборка);		
		ДопустимыеСтатусы[Выборка.ТипКода] = пПроверки;			
	КонецЦикла;	
	
	Возврат ДопустимыеСтатусы;
КонецФункции //ПолучитьДопустимыеСтатусыКМДляДокумента()

Функция ЭтоФБС(ДокСсылка)
	ЭтоFBS = Ложь;
	
	ТипДокумента = ТипЗнч(ДокСсылка);
	
	Если ТипДокумента = Тип("ДокументСсылка.ЛистСборкиКомплектовЧЗ") Тогда
		ЭтоFBS = ПолучитьРеквизитШапки(ДокСсылка, "ДокОснование.ДокОснование.Склад.ЭтоСкладFBS", "Документ");		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ЛистНабора") Тогда
		ЭтоFBS = ПолучитьРеквизитШапки(ДокСсылка, "Склад.ЭтоСкладFBS", "Документ");		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ЛистПереукладки") Тогда
		ЭтоFBS = ПолучитьРеквизитШапки(ДокСсылка, "ДокОснование.Склад.ЭтоСкладFBS", "Документ");		
	КонецЕсли;
	
	ЭтоFBS = (ЭтоFBS = Истина);
	Возврат ЭтоFBS;
КонецФункции //ЭтоФБС(ДокСсылка)

Функция ВложенностьСтр(Вложен)
	Возврат ?(Вложен = Истина, "Вложен", "Не вложен");
КонецФункции //ВложенностьСтр(Вложен)

#КонецОбласти         

Функция СоздатьКодыАгрегации(ЗПС_Ссылка) Экспорт
	
	Запрос = СоздатьЗапрос_КодыМаркировкиЗПС_САгрегатами();
	Если 1=2 Тогда
		Запрос = Новый Запрос;	
	КонецЕсли; 
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);	
	
	рЗапроса 				= Запрос.Выполнить();
	
	Выборка_Номенклатура	= рЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
	Пока Выборка_Номенклатура.Следующий() Цикл
		Выборка_КодАгрегации = Выборка_Номенклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "КодАгрегации");	
		Пока Выборка_КодАгрегации.Следующий() Цикл
			КодАгрегации = Выборка_КодАгрегации.КодАгрегации;
			Если КодАгрегации = "9999" Тогда Продолжить КонецЕсли; 
			
			Если Выборка_КодАгрегации.КМ_Коробка = NULL Тогда				
				СпрОбъект = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
				
				СпрОбъект.Наименование		= СокрЛП(КодАгрегации);
				СпрОбъект.ЗначениеШтрихкода	= СокрЛП(КодАгрегации);
				
				СпрОбъект.Владелец		= Выборка_Номенклатура.Номенклатура;
				СпрОбъект.ТипУпаковки	= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
				СпрОбъект.ТипКода 		= Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка;
				СпрОбъект.ТипШК			= Перечисления.ТипыШтрихКодов.Коробка;				
				
				СпрОбъект.ЗаказКМ		= Выборка_КодАгрегации.ДокАгрегации;
				
				Выборка = Выборка_КодАгрегации.Выбрать();
				Пока Выборка.Следующий() Цикл
					СтрокаПК = СпрОбъект.ВложенныеШтрихкоды.Добавить();				
					СтрокаПК.Штрихкод = Выборка.КМ_Штука;
				КонецЦикла; 
				
				СпрОбъект.Записать();
				Состояние_("Записан код  агрегации: "+КодАгрегации+" "+Выборка_Номенклатура.Номенклатура);				
			КонецЕсли; 								
		КонецЦикла;	
	КонецЦикла; 

КонецФункции //СоздатьКодыАгрегации(ЗПС_Ссылка)
 
Функция ПолучитьКодыМаркировкиПоЗПС(ЗПС_Ссылка, ЧтоПолучать = "Ссылки")
	Результат = Новый Массив;
	
	Запрос = СоздатьЗапрос_КодыМаркировкиЗПС_САгрегатами();	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);	
	
	рЗапроса = Запрос.Выполнить();	
	
	ВключатьАгрегационныеКоды = Ложь; 
	
	Выборка_КодАгрегации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "КодАгрегации");	
	Пока Выборка_КодАгрегации.Следующий() Цикл
		КодАгрегации = Выборка_КодАгрегации.КодАгрегации;	
		
		Выборка_Номенклатура	= Выборка_КодАгрегации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
		Пока Выборка_Номенклатура.Следующий() Цикл			
			Если КодАгрегации = "9999" Тогда 
				Выборка = Выборка_Номенклатура.Выбрать();
				Пока Выборка.Следующий() Цикл
					Результат.Добавить(?(ЧтоПолучать="Ссылки", Выборка.КМ_Штука, Выборка.КМ_Штука_Наименование));
				КонецЦикла; 				
			Иначе
				Если ВключатьАгрегационныеКоды Тогда
					Результат.Добавить(?(ЧтоПолучать="Ссылки", Выборка_КодАгрегации.КМ_Коробка, Выборка_КодАгрегации.КМ_Коробка_Наименование));
				Иначе
					Выборка = Выборка_Номенклатура.Выбрать();
					Пока Выборка.Следующий() Цикл
						Результат.Добавить(?(ЧтоПолучать="Ссылки", Выборка.КМ_Штука, Выборка.КМ_Штука_Наименование));
					КонецЦикла;				
				КонецЕсли;				
			КонецЕсли;
		КонецЦикла;	
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ПолучитьКодыМаркировкиПоЗПС() 

Функция ПолучитьКодыМаркировкиПоМТ(МТ_Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки.Наименование КАК СГТИН,
	|	ВЫБОР 
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.АТК) 	ТОГДА ""atk""
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)	ТОГДА ""ki""
	|		ИНАЧЕ ""kitu""
	|	КОНЕЦ КАК ИмяУзла,
	//++Данилова Е.В. 21.11.2025 MARK-2862 
	|   ШтрихкодУпаковки.ТипШК КАК ТипШК
	//--Данилова Е.В. 21.11.2025 
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок 
	|ГДЕ
	|	Ссылка = &МТ_Ссылка
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки.Наименование КАК СГТИН,
	|	ВЫБОР 
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.АТК) 	ТОГДА ""atk""
	|		КОГДА ШтрихкодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)	ТОГДА ""ki""
	|		ИНАЧЕ ""kitu""
	|	КОНЕЦ КАК ИмяУзла,
	//++Данилова Е.В. 21.11.2025 MARK-2862 
	|   ШтрихкодУпаковки.ТипШК КАК ТипШК
	//--Данилова Е.В. 21.11.2025
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка.ДокументОснование = &МТ_Ссылка
	|	И Ссылка.Проведен	
	|";
				
	Запрос.УстановитьПараметр("МТ_Ссылка", МТ_Ссылка);
	
