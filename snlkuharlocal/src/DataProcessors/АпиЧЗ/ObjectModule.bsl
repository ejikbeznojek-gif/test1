Функция ПолучитьКраткуюИнфоОКарточкахВЧЗ(Док_Ссылка, ДопПараметры = Неопределено) Экспорт
	Результат 		= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если НЕ ЗначениеЗаполнено(Док_Ссылка) Тогда
		Результат.Ошибки.Добавить("Не указан обрабатываемый документ !");		
		Возврат Результат;
	КонецЕсли; 
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(Док_Ссылка);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ = рПроверкиПодкл.СтанцияСУЗ;
	Иначе			
		Результат.Ошибки.Добавить("Не указаны параметры подключения к СУЗ !");
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	тИнфоКарточках = СоздатьТаблицуИнформацииОКарточках();
	
	тТовары 	= ПолучитьКарточкиПоДокументу(Док_Ссылка);
	ВсегоСтрок	= тТовары.Количество();	
	
	Для Каждого СтрокаТ Из тТовары Цикл
		Если СтрокаТ.СтатусКарточкиВЧЗ = Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована Тогда
	//		Продолжить;		
		КонецЕсли;
		ГТИН = СтрокаТ.ГТИН;
		Сообщить(ГТИН);
		ОбработкаПрерыванияПользователя_();
		
		Начало 			= ТекущаяДата();
		
		Результат		= СтруктураРезультата();
		
		АдресРесурса 	= "v3/feed-product?gtins=" + ГТИН;
		
		рЗапроса	 	= ВыполнитьЗапрос_НК(АдресРесурса, , , ДопПараметры);	
		Если рЗапроса.Успешно Тогда
			Данные = ПрочитатьЖСОН(рЗапроса.Ответ);		
			Для Каждого ДанныеТ Из Данные.result Цикл
				identified_by = ДанныеТ.identified_by[0];
				Если ДанныеТ.good_detailed_status.Количество()>0 Тогда
					//Сообщить(""+identified_by.type+" "+identified_by.value+" "+ДанныеТ.good_detailed_status[0]);							
					Если identified_by.type = "gtin" Тогда
						СтрокаТР = тИнфоКарточках.Добавить(); 									
						
						СтрокаТР.ГТИН	= identified_by.value;
						СтрокаТР.Статус = ДанныеТ.good_detailed_status[0];
						
						Если СтрокаТР.Статус = "published" Тогда						
							Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатусКарточкиВЧЗ) 
								ИЛИ  СтрокаТ.СтатусКарточкиВЧЗ<>Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована Тогда			
															
						        УстановитьРеквизитыОбъекта(СтрокаТ.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована));
							КонецЕсли;						
						ИначеЕсли СтрокаТР.Статус = "moderation" Тогда
							Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатусКарточкиВЧЗ) 
								ИЛИ  СтрокаТ.СтатусКарточкиВЧЗ<>Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НаМодерации Тогда			
															
						        УстановитьРеквизитыОбъекта(СтрокаТ.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.Опубликована));
							КонецЕсли;								
						КонецЕсли;						
					КонецЕсли; 
				КонецЕсли;			
			КонецЦикла;			
		Иначе
			Результат.Успешно = Ложь;
			ДобавитьОшибки(Результат, рЗапроса);
			Если ЗначениеЗаполнено(СтрокаТ.СтатусКарточкиВЧЗ) 
								И СтрокаТ.СтатусКарточкиВЧЗ<>Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НеСоздана Тогда			
															
				УстановитьРеквизитыОбъекта(СтрокаТ.Номенклатура, Новый Структура("СтатусКарточкиВЧЗ", Перечисления.СтатусыКарточкиНоменклатурыВЧЗ.НеСоздана));
			КонецЕсли;
		КонецЕсли;
		
		Пока ТекущаяДата() < Начало+0.1 Цикл
			ОбработкаПрерыванияПользователя_();					
		КонецЦикла;		
		
		ВсегоСтрок = ВсегоСтрок-1;
		Состояние_(ВсегоСтрок);
	КонецЦикла;
	
	тИнфоКарточках.ВыбратьСтроку();	
КонецФункции //ПолучитьКраткуюИнфоОКарточкахВЧЗ(Док_Ссылка, ДопПараметры = Неопределено) Экспорт

Функция ПолучитьСписокКарточек(МаксКол = 0, Смещение = 0, ДопПараметры = Неопределено) Экспорт
	Результат 		= МаркировкаКС.СтруктураРезультата(Ложь);	
	
	рПроверкиПодкл = ПроверитьПолучитьПараметрыПодключенияTrueApi(Неопределено);
	Если рПроверкиПодкл.Успешно Тогда
		СтанцияСУЗ 	= рПроверкиПодкл.СтанцияСУЗ;              	
		Организация = СтанцияСУЗ.Владелец;
	Иначе			
		Результат.Ошибки.Добавить("Не указаны параметры подключения к СУЗ !");
		Результат.Успешно = Ложь;					
		Возврат Результат;
	КонецЕсли;
	
	тИнфоКарточках = СоздатьТаблицуИнформацииОКарточках();
	ОбработаноОбектов = 0;
		
	Пока МаксКол = 0 ИЛИ ОбработаноОбектов < МаксКол Цикл
		Сообщить(ОбработаноОбектов);
		ОбработкаПрерыванияПользователя_();
		
		Начало 			= ТекущаяДата();
		
		Результат		= СтруктураРезультата();
		
		Хвост			= ?(МаксКол>0, "limit="+ЧислоБезДури(МаксКол), "")+?(Смещение>0, "offset="+ЧислоБезДури(Смещение) ,"");
		АдресРесурса 	= "v4/product-list"+?(ПустаяСтрока(Хвост), "","?")+Хвост;
		АдресРесурса 	= "v4/product-list";
		
		рЗапроса	 	= ВыполнитьЗапрос_НК(АдресРесурса, , , ДопПараметры);	
		Если рЗапроса.Успешно Тогда
			Данные = ПрочитатьЖСОН(рЗапроса.Ответ);		
			Для Каждого ДанныеТ Из Данные.result.goods Цикл
				identified_by = ДанныеТ.identified_by[0];
				Если ДанныеТ.good_detailed_status.Количество()>0 Тогда
					//Сообщить(""+identified_by.type+" "+identified_by.value+" "+ДанныеТ.good_detailed_status[0]);							
					Если identified_by.type = "gtin" Тогда
						СтрокаТР = тИнфоКарточках.Добавить(); 									
						
						СтрокаТР.ГТИН	= identified_by.value;
						СтрокаТР.Статус = ДанныеТ.good_detailed_status[0];
					КонецЕсли; 
				КонецЕсли;			
			КонецЦикла;			
			
			//Данные.result.offset
			//Данные.result.total
			Если Данные.result.total = 0 ИЛИ Данные.result.goods.Количество() = 0 Тогда
				Прервать;			
			КонецЕсли;
		Иначе
			Результат.Успешно = Ложь;
			ДобавитьОшибки(Результат, рЗапроса);
			Прервать;
		КонецЕсли;
		
		Пока ТекущаяДата() < Начало+0.5 Цикл
			ОбработкаПрерыванияПользователя_();					
		КонецЦикла;
	КонецЦикла;
	
	тИнфоКарточках.ВыбратьСтроку();
	
	
КонецФункции // ()

Функция СоздатьТаблицуИнформацииОКарточках()
	ТР = Новый ТаблицаЗначений;
	ТР.Колонки.Добавить("ГТИН",		ПолучитьОписаниеТиповСтроки(14));
	ТР.Колонки.Добавить("Статус",	ПолучитьОписаниеТиповСтроки(20));

	Возврат ТР;
КонецФункции // СоздатьТаблицуИнформацииОКарточках()

Функция ПолучитьСостав(Модель)
	Запрос 			= Новый Запрос;
	
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	МатериалСостав.МатериалЧЗ.Наименование КАК Материал,
	|	Процент КАК Процент
	|ИЗ
	|	Справочник.Номенклатура.СоставНоменклатуры
	|ГДЕ
	|	Ссылка = &Модель
	|	И Процент>0
	|УПОРЯДОЧИТЬ ПО
	|	Материал
	|";
	
	Запрос.УстановитьПараметр("Модель", Модель);
	
	Строки = Новый Массив;
