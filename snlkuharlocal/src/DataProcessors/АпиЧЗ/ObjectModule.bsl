Функция СпособВводаВОборотЧЗ(СпособВводаВОборот)
	Результат = "";
	
	Если СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Производство Тогда
		Результат = "PRODUCTION";		
	ИначеЕсли СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда
		Результат = "IMPORT";
	ИначеЕсли СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков Тогда
		Результат = "REMAINS";
	ИначеЕсли СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка Тогда
		Результат = "REMARK";	
	ИначеЕсли СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Комиссия Тогда
		Результат = "COMMISSION";	
	Иначе
		Результат = "";		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //СпособВводаВОборотЧЗ(СпособВводаВОборот)
 

Функция ПолучитьТаблицуТоваров(ДокСсылка, ДопПоля = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	СУММА(Количество) КАК Количество
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ."+ДокСсылка.Метаданные().Имя+".Товары 
	|ГДЕ
	|	Ссылка = &ДокСсылка
	|СГРУППИРОВАТЬ ПО 
	|	Номенклатура	
	|;
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура.Наименование КАК productDescription,
	|	ВТ_Товары.Количество 				КАК quantity,
	|	ВТ_Товары.Номенклатура.ГТИН			КАК gtin,
	|	ВЫБОР 
	|		КОГДА ВТ_Товары.Номенклатура.Родитель.ВидНоменклатурыЧЗ = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклатурыЧЗ.Комплект) ТОГДА ""BUNDLE""
	|		КОГДА ВТ_Товары.Номенклатура.Родитель.ВидНоменклатурыЧЗ = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклатурыЧЗ.Набор) ТОГДА ""SET""
	|		ИНАЧЕ ""UNIT""
	|	КОНЕЦ 								КАК cisType
	|ИЗ
	|	ВТ_Товары	
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Товары.Номенклатура.Наименование
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);	
	
	тШК = Запрос.Выполнить().Выгрузить();	
	Если ДопПоля<>Неопределено Тогда
		Для Каждого КиЗ Из ДопПоля Цикл
			тШК.Колонки.Добавить(КиЗ.Ключ);					
			тШК.ЗаполнитьЗначения(КиЗ.Значение, КиЗ.Ключ);
		КонецЦикла; 	
	КонецЕсли; 
	
	Для Каждого СтрокаТ Из тШК Цикл
		СтрокаТ.gtin = Прав("00000000000000"+СокрЛП(СтрокаТ.gtin),14);	
	КонецЦикла;	
	
	Возврат тШК;
КонецФункции //ПолучитьТаблицуТоваров(ДокСсылка, ДопПоля = Неопределено)

Функция УстановитьИД_КМвЗаказеКМ(ДокСсылка, ИД_Заказа)
