Функция КонтрольПросроченнойЗадолженности(Контрагент) Экспорт
	
	ПросроченнаяЗадолженность=0;
	ВыбКонтрагент=?(ЗначениеЗаполнено(Контрагент.Ведущий),Контрагент.Ведущий,Контрагент);
	ЕстьКонтроль=ПолучитьГрупповоеСвойствоОбъекта(ВыбКонтрагент,ПланыВидовХарактеристик.СвойстваОбъектов.КонтрольПросроченнойЗадолженности);
	
	Запрос=Новый Запрос;	
	Запрос.Текст="	
	|ВЫБРАТЬ	
	|	ВЫБОР КОГДА ВидДвижения=&Приход ТОГДА СуммаВал ИНАЧЕ -СуммаВал КОНЕЦ КАК НепрОтгр,
	|	0 КАК ДолгКон
	|ИЗ РегистрНакопления.Взаиморасчеты
	|ГДЕ
	|	Период<=&Дата2
	//крохин начало 10.02.2016
	//Дата оплаты в регистре "взаиморасчеты", документы закрытого периода в документе "ввод остатков взаиморасчетов"
	//|	И КОНЕЦПЕРИОДА(Регистратор.ДатаОплаты,День) >= &Дата2
	//|	И Регистратор Ссылка Документ.РасходнаяНакладная
	//крохин начало 10.07.2016
			//информация перенесена из измерения в реквизит
	//|	И КОНЕЦПЕРИОДА(ДатаНачалаЗадолженности,День) >= &Дата2
	|	И КОНЕЦПЕРИОДА(Дата_НачалаЗадолженности,День) >= &Дата2
	//крохин конец 10.07.2016
	|	И (Регистратор Ссылка Документ.РасходнаяНакладная ИЛИ Регистратор Ссылка Документ.ВводОстатковВзаиморасчетов)
	//крохин конец 10.02.2016
		//крохин начало 30.09.2011
	//используем только договора продажи
	|	И Договор.ВидДоговора_Новый=&ВидДоговора
	//крохин конец 30.09.2011
	|	И Контрагент=&Контрагент	
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ	
	|	0 КАК НепрОтгр,	
	|	IsNull(СуммаВалКонечныйОстаток,0) КАК ДолгКон
	|ИЗ
	//крохин начало 30.09.2011
	//используем только договора продажи
	//|	РегистрНакопления.Взаиморасчеты.ОстаткиИОбороты(, &Дата2,Период,,Контрагент=&Контрагент)
	|	РегистрНакопления.Взаиморасчеты.ОстаткиИОбороты(, &Дата2,Период,,Контрагент=&Контрагент И Договор.ВидДоговора_Новый=&ВидДоговора)
	//крохин конец 30.09.2011
	|ИТОГИ
	|	СУММА(ДолгКон),СУММА(НепрОтгр) 		
	|ПО ОБЩИЕ";	
	
	Запрос.УстановитьПараметр("Приход",ВидДвиженияНакопления.Приход);
	
	ДатаКонтроля=КонецДня(ТекущаяДата()-24*60*60)-24*60*60*Константы.ЛьготныхДнейКонтроляПросроченнойЗадолженноси.Получить();
	
	Запрос.УстановитьПараметр("Дата2",ДатаКонтроля);
	Запрос.УстановитьПараметр("Контрагент",ВыбКонтрагент);
	//крохин начало 30.09.2011
	//используем только договора продажи
	Запрос.УстановитьПараметр("ВидДоговора",Справочники.ВидыДоговоров.Товары_Продажа);
	//крохин конец 30.09.2011
	
	ПросроченнаяЗадолженность=0;
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТипЗаписи()=ТипЗаписиЗапроса.ОбщийИтог Тогда	
			ПросроченнаяЗадолженность=Макс(0,Выборка.ДолгКон-Выборка.НепрОтгр);	
			Прервать;
		КонецЕсли;	
	КонецЦикла;	
		
	Возврат ПросроченнаяЗадолженность;
	
КонецФункции // КонтрольПросроченнойЗадолженности()

Функция КонтрольЛимитаКредита(Контрагент,КодУзла) Экспорт 
	
	ВыбКонтрагент=?(ЗначениеЗаполнено(Контрагент.Ведущий),Контрагент.Ведущий,Контрагент);
    ЕстьКонтроль=ПолучитьГрупповоеСвойствоОбъекта(ВыбКонтрагент,ПланыВидовХарактеристик.СвойстваОбъектов.КонтрольЛимитаЗадолженности);
		
	Запрос=Новый Запрос;	
	Запрос.Текст="	
	|ВЫБРАТЬ	
	|	КодЦБ,
	|	ВалютаКредита КАК ВалютаРасчетов,
	|	СУММА(ЛимитКредита)	КАК ЛимитКредита,
	|	СУММА(ВЫБОР КОГДА ДопСоглашение ТОГДА ЛимитКредита ИНАЧЕ 0 КОНЕЦ) КАК ЛимитКредитаПоДопСоглашению
	|ИЗ 
	|	Справочник.Договоры	
	|ГДЕ
	|	КодЦБ=&КодЦБ
	|	И НЕ ПометкаУдаления
	|	И НЕ НеИспользовать	
	|СГРУППИРОВАТЬ ПО 
	|	КодЦБ,ВалютаКредита";	
	
	ДатаКонтроля=КонецДня(ТекущаяДата()-24*60*60);
	
	Запрос.УстановитьПараметр("КодЦБ",ВыбКонтрагент.Код);
	
	ВалютаИтогов=ПараметрыСеанса.ВалютаУпр_2009;
	
	ЛимитКредита				= 0;
	ЛимитКредитаПоДопСоглашению = 0;
		
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЛимитКредита				= ЛимитКредита					+глПересчет(Выборка.ЛимитКредита,					Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);
		ЛимитКредитаПоДопСоглашению = ЛимитКредитаПоДопСоглашению	+глПересчет(Выборка.ЛимитКредитаПоДопСоглашению,	Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);		
		//крохин начало 25.02.2011
		//оптовикТЦ, лимит всегда 0
		Если Выборка.КодЦБ = "SMN-1118" Тогда
		ЛимитКредита = 0;
		ЛимитКредитаПоДопСоглашению = 0;
		КонецЕсли;
		//крохин конец 25.02.2011
	КонецЦикла;	
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Договор,
	|	Договор.ВалютаКредита	КАК ВалютаРасчетов,
	|	СуммаВалОстаток КАК ОбщийДолг,
	|	ВЫБОР КОГДА Договор.ДопСоглашение ТОГДА 1 ИНАЧЕ 0 КОНЕЦ*СуммаВалОстаток КАК ДолгПоДопСоглашению 
	|ИЗ
	|	РегистрНакопления.Взаиморасчеты.Остатки(&ДатаКонтроля, Контрагент = &Контрагент) КАК ВзаиморасчетыОстатки
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Договор,
	|	Договор.ВалютаКредита	КАК ВалютаРасчетов,
	|	СуммаДокумента 			КАК ОбщийДолг,
	|	ВЫБОР КОГДА Договор.ДопСоглашение ТОГДА 1 ИНАЧЕ 0 КОНЕЦ*СуммаДокумента КАК ДолгПоДопСоглашению 
	|ИЗ
	|	Документ.РасходнаяНакладная
	|ГДЕ
	|	Проведен
	|	И Отгружен=ЗНАЧЕНИЕ(Перечисление.Отгружен.Резерв)
		//крохин начало 25.11.2012
	//РНК по подразделению выгрузки не учитываем
	|	И Склад.Подразделение.КодФизическогоУзла77 <>  &КодУзла
	//крохин конец 25.11.2012
	|	И (
	|		СостояниеНакладной<>ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ВРаботе)
	//|   	ИЛИ Ссылка=&Накладная
	|	) 	
	|	И (
	|	Контрагент.Ведущий	=&Контрагент
	|	ИЛИ Контрагент		=&Контрагент
	|	)";
	
	Запрос.УстановитьПараметр("ДатаКонтроля",	ДатаКонтроля);
	Запрос.УстановитьПараметр("Контрагент",		ВыбКонтрагент);	
	//Запрос.УстановитьПараметр("Накладная",		Накладная);
			//крохин начало 25.11.2012
	//РНК по подразделению выгрузки не учитываем
	Запрос.УстановитьПараметр("КодУзла",		КодУзла);
	//крохин конец 25.11.2012

	
	
	ОбщийДолг=0;
	ДолгПоДопСоглашению=0;
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбщийДолг			=ОбщийДолг			+глПересчет(Выборка.ОбщийДолг,			Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);			
		ДолгПоДопСоглашению	=ДолгПоДопСоглашению+глПересчет(Выборка.ДолгПоДопСоглашению,Выборка.ВалютаРасчетов,ДатаКонтроля,ВалютаИтогов,ДатаКонтроля);
	КонецЦикла; 
	
	
	ТЗ=Новый ТаблицаЗначений;
	ТЗ.Очистить();
	
	ТЗ.Колонки.Добавить("ЛимитКредита",Новый ОписаниеТипов("Число"));
	ТЗ.Колонки.Добавить("ЛимитКредитаПоДопСоглашению",Новый ОписаниеТипов("Число"));
	ТЗ.Колонки.Добавить("ОбщийДолг",Новый ОписаниеТипов("Число"));
	ТЗ.Колонки.Добавить("ДолгПоДопСоглашению",Новый ОписаниеТипов("Число"));
	
	Строка=ТЗ.Добавить();
	Строка.ЛимитКредита=ЛимитКредита;
	Строка.ЛимитКредитаПоДопСоглашению=ЛимитКредитаПоДопСоглашению;
	Строка.ОбщийДолг=ОбщийДолг;
	Строка.ДолгПоДопСоглашению=ДолгПоДопСоглашению;
	 
	
	Возврат Строка;

	
КонецФункции

Процедура СформироватьВэймарт() Экспорт
	
	
	//-----------------------------------------------------------------------------------------------------------
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));     //+++
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом тогда
	Если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда
		//Кухарь А.Ю. 31.03.2026 конец
        
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Выгрузка просроченной задолженности. Разрешено для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
		Возврат;
	КонецЕсли;
	
	//-----------------------------------------------------------------------------------------------------------

	// выгрузка файла xml, для формирования задолженности.
	
	// получаем запрос данных
	// 1 - скписок конрагентов
	
	ЗаписатьВЛог("Регламент","Автоформирование файла просроч.задолж. для Вейморта. Начало... ","Информация");  
	
	СпКонтр=Новый Запрос;
	СпКонтр.Текст="ВЫБРАТЬ
	              |	Контрагенты.Код,
	              |	Контрагенты.Наименование,
	              |	Контрагенты.Ссылка
	              |ИЗ
	              |	Справочник.Контрагенты КАК Контрагенты
	              |ГДЕ
	              |	Контрагенты.ссылка В ИЕРАРХИИ(&группаКонтр)
	              |	И Контрагенты.ЭтоГруппа = ЛОЖЬ";
	СпКонтр.УстановитьПараметр("ГруппаКонтр",Справочники.Контрагенты.НайтиПоКоду("SSP-1682  "));
	//VAR-0339  ) Балыбина ВА   SMN-1725
	
	СписокКонтрагентов=СпКонтр.Выполнить().Выбрать();
	
	
	// заполнение файла;
	
	//Путь="C:\Documents and Settings\nechaeva\Рабочий стол\Вейморт\" ;
	//Путь="\\E-cod\ediconnector2\Stoletov\Price\";
    Путь="\\Srvmail2\FTPFolders$\exch80\snl\TAX\";    //WMR.xml";
	
	Имя="WMR";
	
	ЗаписьХМЛ=Новый ЗаписьXML;
	ЗаписьХМЛ.ОткрытьФайл(Путь+Имя+".xml");  //ДиалогСохранения.ПолноеИмяФайла); 
	ДокументДом=Новый ДокументDom("http://v8.1c./8.1/sample91_DOM","Document-Order");
	КорневойЭлемент=ДокументДом.ЭлементДокумента;
	// Order-Header ------------------------------------------
	ЭлементДом=ДокументДом.СоздатьЭлемент("Order");
	ТекУзел1=КорневойЭлемент.ДобавитьДочерний(ЭлементДом);
	//------------------------------------------------------------
	Элемент2=ДокументДом.СоздатьЭлемент("OrderDate");
	ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент2);
	текстДом=ДокументДом.СоздатьТекстовыйУзел(строка(ТекущаяДата()));
	ТекУзел2.ДобавитьДочерний(ТекстДом);
	//-------------------------
	//    заполнение строк
	//-------------------------
	ЭлементДом=ДокументДом.СоздатьЭлемент("Order-Lines");
	ТекУзел1=КорневойЭлемент.ДобавитьДочерний(ЭлементДом);
	
	РР=1;
	Пока СписокКонтрагентов.Следующий() цикл
		
		ТекСтрока=СписокКонтрагентов;
		Контрагент=ТекСтрока.ссылка;
		//Состояние(текстрока.наименование);
		// получаем просроченную задолженность и общ задолженность.
		// лимит кредита.
		//-------------------
		Лимит=0;  ТекЗад=0;
        ЛимитКредита=0; ЛимитКредитаПоДопСоглашению=0;
		ОбщийДолг=0; ДолгПоДопСоглашению=0;
		Попытка
			ТекЗад=КонтрольПросроченнойЗадолженности(Контрагент);
			Лимит=КонтрольЛимитаКредита(Контрагент,"");
			ЛимитКредита=Лимит.ЛимитКредита;
			ЛимитКредитаПоДопСоглашению=Лимит.ЛимитКредитаПоДопСоглашению;
			ОбщийДолг=Лимит.ОбщийДолг;
			ДолгПоДопСоглашению=Лимит.ДолгПоДопСоглашению;
		Исключение
		КонецПопытки;
		
		Если ТекЗад=0 и ЛимитКредита=0 и ЛимитКредитаПоДопСоглашению=0 и ОбщийДолг=0 и ДолгПоДопСоглашению=0 Тогда
			продолжить;
		конецЕсли;	
        		
		Элемент=ДокументДом.СоздатьЭлемент("Line");
		ТекУзел2=ТекУзел1.ДобавитьДочерний(Элемент);
		//----------------------------------------------
		Элемент=ДокументДом.СоздатьЭлемент("LineNumber");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(рр));                 
		ТекУзел3.ДобавитьДочерний(ТекстДом);
				
		//---------------------------------------------------------
		// заполняем данные по контрагенту.
		
		Элемент=ДокументДом.СоздатьЭлемент("KOD");  //штрихкод
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(ТекСтрока.Код);                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		//----------------------------------------------------------
				
		Элемент=ДокументДом.СоздатьЭлемент("NAIM");  // наименование номенклатуры
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(ТекСтрока.Наименование);                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
				
		Элемент=ДокументДом.СоздатьЭлемент("LimitKredita");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ЛимитКредита));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("LimitPoDopSog");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ЛимитКредитаПоДопСоглашению));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("ObDolg");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ОбщийДолг));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("DolgPoDopSog");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ДолгПоДопСоглашению));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		Элемент=ДокументДом.СоздатьЭлемент("TekZadol");
		ТекУзел3=ТекУзел2.ДобавитьДочерний(Элемент);
		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекЗад));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		
		РР=РР+1;
		
	КонецЦикла;
	
	//---------------------------------------------------------------
	ЗаписьДом=Новый ЗаписьDom;
	ЗаписьДом.Записать(ДокументДом,ЗаписьХМЛ);
	ЗаписьХМЛ.Закрыть();	
	
	//сообщить("Выполнено!");
	ЗаписатьВЛог("Регламент","Автоформирование файла просроч.задолж. для Вейморта. ...Конец. ","Информация");  
	
	
КонецПроцедуры

Процедура СформироватьКазань() Экспорт
	
	
	//-----------------------------------------------------------------------------------------------------------
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));     //+++
