		текстДом=ДокументДом.СоздатьТекстовыйУзел(Строка(ТекЗад));                      
		ТекУзел3.ДобавитьДочерний(ТекстДом);
		
		
		РР=РР+1;
		
	КонецЦикла;
	
	//---------------------------------------------------------------
	ЗаписьДом=Новый ЗаписьDom;
	ЗаписьДом.Записать(ДокументДом,ЗаписьХМЛ);
	ЗаписьХМЛ.Закрыть();	
	
	//сообщить("Выполнено!");
	ЗаписатьВЛог("Регламент","Автоформирование файла просроч.задолж. для Волгограда. ...Конец. ","Информация");  
	
	
КонецПроцедуры

Процедура СформироватьАвто(КодУзла,ПутьКФайлу,Контрагент) Экспорт
	
