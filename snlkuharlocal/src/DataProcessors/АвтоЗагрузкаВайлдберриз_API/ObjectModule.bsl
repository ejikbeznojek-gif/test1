Функция ЗапросПоСтикерам(Док)

	Результат = неопределено;
	
//  "orderIds": [
//    8423848,
//    6436344
//  ]
//}

	Команда =  "/api/v2/orders/stickers";
	ДокОб = док.ПолучитьОбъект();

	//ТелоДЖ = "";
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".JSON");
	#если клиент тогда
		сообщить(ИмяВыходногоФайлаДж);
	# конецесли
	//
	ЕстьИзмененияВДокументе = ложь;
	
	ТЗ1 = Новый ТаблицаЗначений;
	Запрос = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказКлиентаFBSТовары.РИД КАК РИД,
	               |	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	               |	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	               |	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	               |	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	               |	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	               |	ЗаказКлиентаFBSТовары.НомерСтроки КАК НомерСтроки
	               |ИЗ
	               |	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	               |ГДЕ
	               |	ЗаказКлиентаFBSТовары.Ссылка = &текдок";
				//   |	И ЗаказКлиентаFBSТовары.ШтрихКод = &Пусто";
	
	
	запрос.УстановитьПараметр("ТекДок",Док.ссылка);
	запрос.УстановитьПараметр("Пусто","");

	тз1 =Запрос.Выполнить().Выгрузить();
	
//	  ДОк тут уже обьект
	текстр=1;
	Для каждого Текстрока из  тз1 цикл
		
		
		Если ТекСтрока.штрихкод<>"" Тогда
			продолжить;
		КонецЕсли;
	
		//*********************************************************************************
		// формирование запроса
		Ордер = Число(Текстрока.НомерЗаказа);   		
		СтрПРо= Новый массив;
	   	стрпро.Добавить(ордер); 
			
		ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".JSON");
		
		Запись = Новый ЗаписьJSON;
		ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
		Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
		
		НастройкиСериализации = Новый НастройкиСериализацииJSON;
		НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
		НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением; 
		
		Данные = Новый Структура;

		Данные.Вставить("orderIds",стрПро);

		
		Попытка
			ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
			Запись.Закрыть();
		Исключение
			//сообщить(ОписаниеОшибки());
			
		КонецПопытки;;  
		//**************************************************************************************
		// выполнение пост запроса.
		//-------------------------------
		Результат = Post_Запрос(Команда,ИмяВыходногоФайлаДЖ) ; 
		// записываем результат
		Если    Результат.кодсостояния = 200 тогда
			
			// тут получаем этикетку и записываем
			Ответ=Результат.ПолучитьТелоКакСтроку();
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(Ответ);
			
			Данные = ПрочитатьJSON(ЧтениеJSON, Ложь);
			
			НовД = Данные.data;
			// нечаева  260122 ++
			попытка
				Если НовД.количество()>0 Тогда
					// нечаева 260122 --
					Для каждого текСтрока2 из НовД цикл
						// текстрока.order
						ШК = ТекСтрока2.sticker.wbStickerEncoded;
						ШК1= ТекСтрока2.sticker.wbstickerIdParts.A;
						ШК2= ТекСтрока2.sticker.wbstickerIdParts.B;
						
						#если клиент тогда
							состояние(" заказ - "+ордер+" -"+ШК);
						# конецесли
						
						попытка						
							докОб.товары[ТекСтрока.номерСтроки-1].Штрихкод = ШК;
							докОб.товары[ТекСтрока.номерСтроки-1].ПрефиксЗаказа = ШК1;
							докОб.товары[ТекСтрока.номерСтроки-1].СуффиксЗаказа = ШК2;
						исключение
							#если клиент тогда
								сообщить(" заказ - "+ордер+" "+ОписаниеОшибки());
							# конецесли
						конецПопытки;
						ЕстьИзмененияВДокументе = истина;
					КонецЦикла;
				Иначе
					#если клиент тогда
						сообщить(" заказ - "+ордер+" нет этикетки!!!");
					# конецесли
					КритическиеОшибкиОзон2.Добавить("Заказ "+ордер+"нет этикетки от контаргента ВБ");
				КонецЕсли;
			исключение
				#если клиент тогда
					сообщить(" заказ - "+ордер+" нет этикетки!!!");
				# конецесли
				КритическиеОшибкиОзон2.Добавить("Заказ "+ордер+"нет этикетки от контаргента ВБ");
				
				
			конецпопытки;
		иначе
			
			#если клиент тогда
				сообщить(" заказ - "+ордер+" - код состояния -"+Результат.кодсостояния);
			# конецесли
			
		конецЕсли;
		
		текстр=текстр+1;
	конецЦикла;
	
	Если ЕстьИзмененияВДокументе ТОгда
		попытка	
			ДокОб.записать();
		исключение
			
				#если клиент тогда
					состояние(ОписаниеОшибки());
				# конецесли

			
		конецПопытки;	
	КонецЕсли;	
	
	возврат неопределено;     

		
конецФункции



 
