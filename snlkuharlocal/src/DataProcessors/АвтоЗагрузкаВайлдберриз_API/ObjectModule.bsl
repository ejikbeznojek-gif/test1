Функция ЗапросПоЗаказам(ДатаЗаказаНачалоСтрокой,ДатаЗаказаКонецСтрокой,ВсегоЗаказов=1000,ПропуститьЗаказов=0)

	//новые статусы
	
	//	0 - Новый заказ 1 - Принял заказ 2 - Сборочное задание завершено 
	//	3 - Сборочное задание отклонено 5 - На доставке курьером 6 - Курьер довез и клиент принял товар 7 - Клиент не принял товар
	//	
	//	
	//  /api/v2/orders?date_start=2021-09-10T00%3A00%3A00%2B02%3A00&status=1&take=10&skip=0
	
	Результат = неопределено;
	
	// 10,09,21  +++ нечаева
	Команда =  "/api/v2/orders?date_start="+ДатаЗаказаНачалоСтрокой+"&date_end="+ДатаЗаказаКонецСтрокой+"&status=0&take="+ВСегоЗаказов+"&skip="+ПРопуститьЗаказов;
	//"/api/v1/orders?date_start=2020-03-23T14:58:33.102-08:00";  // считывает заказы с сайта   /api/v1/orders?date_start=2020-09-14T00:00:00+03:00
	ТелоДЖ = "";
	// 10,09,21  --- нечаева
	
	
	ИмяВыходногоФайлаДЖ = ПолучитьИмяВременногоФайла(".JSON");
	#если клиент тогда
		сообщить(ИмяВыходногоФайлаДж);
	# конецесли
	
	//
	Запись = Новый ЗаписьJSON;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( ,Символы.Таб);
	Запись.ОткрытьФайл(ИмяВыходногоФайлаДЖ,,,ПараметрыЗаписиJSON);
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением; //ЛокальнаяДата;      "2020-10-31T21:00:00Z",
	
	                                                   
	Данные = Новый Структура;
	
	Попытка
		ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
		Запись.Закрыть();
		// Возврат Истина;
	Исключение
		//сообщить(ОписаниеОшибки());
		// ЗаписьЖурналаРегистрации(ИмяСобытияЖР,УровеньЖурналаРегистрации.Ошибка,,,"Прайс не сформирован, произошла ошибка " + ОписаниеОшибки());
		//  Возврат Ложь;
	КонецПопытки;;  
	
	
	// выполнение пост запроса.
	//-------------------------------
	
	Результат = GET_ЗапросЗаказы(Команда,ИмяВыходногоФайлаДЖ) ;    // ИмяВыходногоФайла?
	// total - дает всего заказов эа период времени.
	
	
	Если Результат.кодсостояния = 204 или Результат.кодсостояния = 401  тогда
		#если клиент тогда
			сообщить("Нет заказов");
			
			р2=Результат.ПолучитьТелоКакСтроку();
			ИмяВыхОтвет=результат.ПолучитьИмяФайлаТела();
			Сообщить(" - "+ИмяВыхОтвет);
			
		# конецесли
		возврат Неопределено;
	иначе
				
	КонецЕсли;
	
	
	#если клиент тогда
		сообщить(Результат.кодсостояния);

	# конецесли

	
	возврат Результат;

конецФункции


