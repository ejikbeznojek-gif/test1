			|ИЗ
			|	Документ.Матрица.ПунктыДоставки КАК Матрица
			|ГДЕ
			|	Матрица.Ссылка.Контрагент = &Контрагент
			|	И Матрица.Ссылка.Дата <= &Дата1
			|	И Матрица.Ссылка.ДатаОкончания >= &Дата2
			|	И Матрица.Ссылка.Договор = &Договор
			|	И Матрица.Ссылка.Проведен = ИСТИНА
			|	И Матрица.ПунктДоставки = &ПДИМ
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			
			Запрос.УстановитьПараметр("Дата2",НачалоДня(ДокОбъект.дата));
			Запрос.УстановитьПараметр("Дата1",КонецДня(ДокОбъект.дата));
			Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
			Запрос.УстановитьПараметр("Договор",ДокОбъект.Договор);
			Запрос.УстановитьПараметр("ПДИМ",МППунктДоставки);  // фбс озон
			
			ТЗЕстьМатрицаПоДоговору = Запрос.Выполнить().Выгрузить();
			
			
			//запрос на получение
			Запрос=Новый Запрос;
			Запрос.Текст=
			"ВЫБРАТЬ
			|	МатрицаТовары.Номенклатура КАК Номенклатура,
			|	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
			|	МатрицаТовары.АртикулКонтрагента КАК АртикулКонтрагента,
			|	МатрицаТовары.Ссылка КАК Ссылка,
			|	МатрицаТовары.НаименованиеКонтрагента КАК НаименованиеКонтрагента,
			|	МатрицаТовары.Кратность КАК Кратность,
			|	МатрицаТовары.ШККонтрагентаБлочок КАК ШККонтрагентаБлочок,
			|	МатрицаТовары.ШКСпайки КАК ШКСпайки,
			|	МатрицаТовары.МинимальныйОстатокКоличество КАК МинимальныйОстатокКоличество
			|ИЗ
			|	Документ.Матрица.Товары КАК МатрицаТовары
			|ГДЕ
			|	МатрицаТовары.Ссылка.Дата <= &Дата1
			|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
			|	И МатрицаТовары.Ссылка.ДатаОкончания >= &ТекДата
			|	И МатрицаТовары.Ссылка.Проведен = ИСТИНА
			|	И МатрицаТовары.Ссылка В ИЕРАРХИИ(&спМатриц)";
			
			
			Если ТЗЕстьМатрицаПоДоговору.Количество()>0 Тогда
				ЕстьМатрицаПоДоговору = истина;
				//с учетом договора
				Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.Договор = &Договор";
				
			иначе
				ЕстьМатрицаПоДоговору = ложь;
			КонецЕсли;
			
			Попытка
				Если Ссылка.ПостояннаяАкция Тогда
					Запрос.Текст = Запрос.Текст +" И МатрицаТовары.Ссылка.ПостояннаяАкция = истина";
					//постоянные акции только под галку
				Иначе
					Запрос.Текст = Запрос.Текст +" И НЕ МатрицаТовары.Ссылка.ПостояннаяАкция";
					
				КонецЕсли;
			Исключение
			КонецПопытки;	
			Запрос.Текст = Запрос.Текст +"	
			|УПОРЯДОЧИТЬ ПО
			|	МатрицаТовары.Ссылка.Дата УБЫВ
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			Запрос.УстановитьПараметр("Контрагент",ДокОбъект.Контрагент);
			Запрос.УстановитьПараметр("Договор",ДокОбъект.Договор);
			Запрос.УстановитьПараметр("Дата1",КонецДня(ДокОбъект.Дата));
			Запрос.УстановитьПараметр("ТекДата",ДокОбъект.Дата);
			Запрос.УстановитьПараметр("спМатриц",ТЗЕстьМатрицаПоДоговору);
			
			
			тз1 = Запрос.Выполнить().Выгрузить();
			
			Возврат ТЗ1;
			
		КонецЕсли;
	исключение
		Возврат ТЗ;
	конецПопытки;	
	
	возврат ТЗ; //пустая таблица
	
КонецФункции


