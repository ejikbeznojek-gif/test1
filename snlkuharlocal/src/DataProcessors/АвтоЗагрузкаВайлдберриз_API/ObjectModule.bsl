		ТекСтр=РНК.Товары.Получить(н);
		Если НЕ ЗначениеЗаполнено(ТекСтр.Цена) Тогда
			ЕстьЦены0=Истина;
			Рез=Рез+СокрЛП(ТекСтр.Номенклатура)+" ";
			ТекстОповещения=ТекстОповещения+СокрЛП(ТекСтр.Номенклатура)+Символы.ПС;
			МасНом.Добавить(ТекСтр.Номенклатура);
			РНК.Товары.Удалить(н);
		КонецЕсли;	
		н=н-1;
