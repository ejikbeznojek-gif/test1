Процедура ОтправитьСтатусыРНКНаОтгрузку()
	
	ДатаОтгрузки = Началодня(ТекущаяДата());
	
	ДеньВСекундах=24*60*60;
		
	запрос = новый Запрос;
	запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗаказКлиентаFBS.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBS
	               |ГДЕ
	               |	ЗаказКлиентаFBS.Ссылка.Проведен = ИСТИНА
	               |	И ЗаказКлиентаFBS.Ссылка.Контрагент = &Вайлдб
	               |	И ЗаказКлиентаFBS.Ссылка.ДокОснование.ДатаОтгрузки >= &датаотгрузки
	               |	И ЗаказКлиентаFBS.Ссылка.Дата >= &ДатаДок
	               |	И ЗаказКлиентаFBS.СостояниеУКлиента <> &Статус";
	запрос.УстановитьПараметр("Датадок",ТекущаяДата() - 7*ДеньВСекундах);
	запрос.УстановитьПараметр("Вайлдб", МПКонтрагент);
	запрос.УстановитьПараметр("датаотгрузки",НачалоДня(ТекущаяДата()));
	запрос.УстановитьПараметр("Статус",справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию("2"));
		
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока рез.Следующий() цикл
	
		РНК = Рез.ссылка.ДокОснование;
		СостояниеНакладной = РНК.состояниеНакладной;
		# если клиент тогда
		    сообщить(рез.ссылка);
		# конецЕсли
		
		Если (СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена  или СостояниеНакладной = Перечисления.СостоянияНакладной.ГотоваКОтгрузке или СостояниеНакладной = Перечисления.СостоянияНакладной.Паллетирование или СостояниеНакладной = Перечисления.СостоянияНакладной.ОжиданиеПаллетирования)
			//и НЕ РНК.ПереданПокупателюВЭлВиде         //    тогда
		тогда	
			
			СобратьЗаказы(РНК,2);
						
			//ПереданПокупателюВЭлВиде = Истина;
			// если все = 2, тогда ставим статус ПереданПокупателювЭлВиде
			
		конецЕсли;
	
			
	КонецЦикла;
	

		
	
КонецПроцедуры	


