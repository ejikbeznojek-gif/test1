// переводим на сборку заказы
Процедура СобратьЗаказы(Накладная,Статус)
	
	//	возврат;

	// приняли заказ
	// смена статуса заказа  тут на 1 , на 2 при смене на рГ статуса заказа.
	// данные по товарам, пока временно 2 вида товаров только добавила для тестов
	
	ЕстьИзменения=ложь;
	
	ТЗ1 = Новый ТаблицаЗначений;
	Запрос = новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказКлиентаFBSТовары.РИД КАК РИД,
	               |	ЗаказКлиентаFBSТовары.ШтрихКод КАК ШтрихКод,
	               |	ЗаказКлиентаFBSТовары.НомерЗаказа КАК НомерЗаказа,
	               |	ЗаказКлиентаFBSТовары.Количество КАК Количество,
	               |	ЗаказКлиентаFBSТовары.Номенклатура КАК Номенклатура,
	               |	ЗаказКлиентаFBSТовары.Ссылка КАК Ссылка,
	               |	ВЫБОР
	               |		КОГДА ЗаказКлиентаFBSТовары.СостояниеУКлиента.Наименование = ""1""
	               |			ТОГДА ""1""
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА ЗаказКлиентаFBSТовары.СостояниеУКлиента.Наименование = ""2""
	               |					ТОГДА ""2""
	               |				ИНАЧЕ ""0""
	               |			КОНЕЦ
	               |	КОНЕЦ КАК СостояниеУКлиента,
	               |	ЗаказКлиентаFBSТовары.НомерСтроки КАК НомерСтроки
	               |ИЗ
	               |	Документ.ЗаказКлиентаFBS.Товары КАК ЗаказКлиентаFBSТовары
	               |ГДЕ
	               |	ЗаказКлиентаFBSТовары.Ссылка.ДокОснование = &текдок
	               |	И ЗаказКлиентаFBSТовары.СостояниеУКлиента <> &Статус
	               |	И ВЫБОР
	               |			КОГДА ЗаказКлиентаFBSТовары.СостояниеУКлиента.Наименование = ""1""
	               |				ТОГДА ""1""
	               |			ИНАЧЕ ВЫБОР
	               |					КОГДА ЗаказКлиентаFBSТовары.СостояниеУКлиента.Наименование = ""2""
	               |						ТОГДА ""2""
	               |					ИНАЧЕ ""0""
	               |				КОНЕЦ
	               |		КОНЕЦ <= &Ст2";

	ЗначениеСтатуса =справочники.СостояниеНакладнойУКлиента.НайтиПоНаименованию(Строка(Статус));
	запрос.УстановитьПараметр("ТекДок",Накладная.ссылка);
	запрос.УстановитьПараметр("Статус",ЗначениеСтатуса);
	запрос.УстановитьПараметр("Ст2",Строка(Статус));

	тз1 =Запрос.Выполнить().Выгрузить();
	НачатьТранзакцию();
	ДокФБС= тз1[0].ссылка.получитьОбъект();
	
	текстр=1;
	Для каждого Текстрока из  тз1 цикл
		// нельзя отправить на отправку, если не переведен на сборку !
		// если уже на сборке -  на отправку 
		Если Число (Текстрока.СостояниеУКлиента) >= Статус Тогда
			продолжить;
		КонецЕсли;
		
		РИд = Текстрока.РИд;
		Ордер = Текстрока.НомерЗаказа;
		
		СтрПРо= Новый ТаблицаЗначений;
		СтрПРо.Колонки.Добавить("orderId");
		СтрПРо.Колонки.Добавить("status");
		
		НовСт = стрпро.Добавить();
		НовСт.orderId= ордер;            //  артикул вайлдберриз   код производителя у нас
		НовСт.status= Статус;          // массив с размерами цветами	   // 2 - в состоянии рг отправляем
		
			
		ОтправленоБезОшибок = ОтправитьСтрокуЗаказа(ТабЗначВМассив(СтрПро));
		
		Если ОтправленоБезОшибок Тогда
			// запишем в документ
			ДокФБС.товары[ТексТрока.НомерСтроки-1].СостояниеУКлиента = ЗначениеСтатуса;
			ЕстьИзменения = истина;
		КонецЕсли;	
				
		текстр=текстр+1;
	конецЦикла;
	
	Если ЕстьИзменения Тогда
		
		Попытка
			ДокФБС.записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			# если клиент тогда
				сообщить(ОписаниеОшибки());
			# конецЕсли
		КонецПопытки;
		
	КонецЕсли;	
		
	// Кухарь А.Ю. 10.02.2022 начало
	// Если ЕстьИзменения = ложь, то все следующие процедуры ничего в базу не напишут, потому что транзакция не завершится
	если ТранзакцияАктивна() тогда
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	// Кухарь А.Ю. 10.02.2022 конец
	
	
	возврат;
	
	
КонецПроцедуры
