Функция ЕстьРасхожденияВСписании(Ссылка)
	Если Ссылка.Отгружен=Перечисления.Отгружен.Резерв ИЛИ Ссылка.Отгружен=Перечисления.Отгружен.РезервТранзит Тогда
		Возврат Ложь;	
	КонецЕсли;
	//
	ЗапросПоДвижениям.УстановитьПараметр("МоментВремени",		Новый МоментВремени(Ссылка.Дата,Ссылка.Ссылка));
	ЗапросПоДвижениям.УстановитьПараметр("Ссылка",				Ссылка);
	ЗапросПоДвижениям.УстановитьПараметр("Склад",				Ссылка.Склад);
	ЗапросПоДвижениям.УстановитьПараметр("СписокНомекнлатуры",	Ссылка.Товары.ВыгрузитьКолонку("Номенклатура"));
			
	Результат=ЗапросПоДвижениям.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		//Если фОтладка Тогда
		//	Сообщить(Ссылка);			
		//	ВыборкаОтклонений=Результат.Выбрать();
		//	Пока ВыборкаОтклонений.Следующий() Цикл
		//		Сообщить(""+ВыборкаОтклонений.Номенклатура+" "+ВыборкаОтклонений.ЦенаОстатка+" "+ВыборкаОтклонений.ЦенаСписания);				
		//	КонецЦикла;			
		//КонецЕсли;	
	Возврат Истина;	
	//крохин начало 07.11.2011
		//+ контроль баланса
    Иначе
	ЗапросКонтрольБаланса.УстановитьПараметр("Регистратор",Ссылка);
	Результат = ЗапросКонтрольБаланса.Выполнить();
	Если НЕ Результат.Пустой() Тогда
	Возврат Истина;		
	КонецЕсли;
	//крохин конец 07.11.2011
	КонецЕсли; 
	
	
	Возврат Ложь;
КонецФункции //ЕстьРасхожденияВСписании(Ссылка)

Функция НужноПерепроводитьДокумент(Ссылка)
	//крохин начало 09.11.2011
	//пока не требуется ничего ускорять
	Возврат Истина;
	//крохин конец 09.11.2011
	Если ТипЗнч(Ссылка)=Тип("ДокументСсылка.РасходнаяНакладная")  ИЛИ ТипЗнч(Ссылка)=Тип("ДокументСсылка.Перемещение") Тогда		
		Если ТипЗнч(Ссылка)=Тип("ДокументСсылка.РасходнаяНакладная") И Ссылка.ОтгрузкаКомплектов Тогда
			Возврат Истина;		
		Иначе
			Возврат ЕстьРасхожденияВСписании(Ссылка);			
		КонецЕсли;		
	Иначе
		Возврат Истина;	
	КонецЕсли; 	
КонецФункции

