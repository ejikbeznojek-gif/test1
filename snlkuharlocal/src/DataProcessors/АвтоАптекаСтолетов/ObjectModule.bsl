Функция СкидкаКонтрагента1(Номенклатура,ТипСкидок_Контрагент)  Экспорт
	
	Запрос=Новый Запрос;
	//Запрос.Текст="
	//|ВЫБРАТЬ ПЕРВЫЕ 1		
