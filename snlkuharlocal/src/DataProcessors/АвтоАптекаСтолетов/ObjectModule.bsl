				Номенклатура = Поиск;
				строкатоваров.Номенклатура=Номенклатура;
				строкатоваров.Заявка = БД.QNT;
				ПриИзмененииНоменклатурыТабЧасти(строкатоваров,ДокОбъект);   //  
				РассчитатьСуммуТабЧасти(строкатоваров,ДокОбъект);
				
				НовСтр.Номенклатура=Поиск;
