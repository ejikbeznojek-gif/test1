			КонецЦикла;  
			//-----------------------------------------------
			Менеджер=Контрагент.Менеджер;
			Если Менеджер=Неопределено или Менеджер=Справочники.ФизическиеЛица.ПустаяСсылка() и ПризКр=0 Тогда
				КритичОшибки.Добавить("Для контрагента "+контрагент.наименование+"  код - "+контрагент.код+"  не определен менеджер! Заказ екоде №"+ НомерЗаказа );
			Иначе
				Если Не СтрДлина(Менеджер.Емэйл)>2  и ПризКр=0   Тогда
					КритичОшибки.Добавить("Для менеджера "+Менеджер.наименование+"  код - "+Менеджер.код+"  не определен ЕМэйл!" );
				КонецЕсли;
			КонецЕсли;
			
			Если Контрагент.ТипЦен=Справочники.ТипыЦен.ПустаяСсылка() и ПризКр=0 Тогда
				КритичОшибки.Добавить("Для контрагента "+Контрагент.Наименование+" не установлен тип цен по умолчанию!");
			КонецЕсли;
			//++Данилова Е.В. 30.09.2025 HELP-7048
			//Подразделение = Контрагент.Менеджер.Подразделение;
			Подразделение = ЗаполнениеДокументов.ПодразделениеПродажПоМенеджеру(Контрагент.Менеджер); 
			//--Данилова Е.В. 30.09.2025
			//------------------------
			// код поставщика
			//------------------------
			КодПоставщикаКонтрагента=Контрагент.КодПоставщика;
			Если КодПоставщикаконтрагента.пустая() ИЛИ кодПоставщикаКонтрагента=Неопределено Тогда
				// Берем первую из справочника коды контрагентов
				Запрос=Новый Запрос;
				Запрос.Текст="ВЫБРАТЬ
				|	КодыПоставщиков.Ссылка
				|ИЗ
				|	Справочник.КодыПоставщиков КАК КодыПоставщиков
				|ГДЕ
				|	КодыПоставщиков.Владелец = &Контрагент
				|	И (КодыПоставщиков.Организация = &ТекОрганизация
				|			ИЛИ КодыПоставщиков.Организация = &Контр2)";
				Запрос.УстановитьПараметр("Контрагент",Контрагент);		
				Запрос.УстановитьПараметр("Контр2",Справочники.Контрагенты.ПустаяСсылка());		
				Запрос.УстановитьПараметр("ТекОрганизация",Организация);		
				Результат=Запрос.Выполнить().Выбрать();
				Пока Результат.Следующий() Цикл
					КодПоставщикаКонтрагента=Результат.ссылка;
					возврат;
				КонецЦикла;
				// если ашан то :
				Если контрагент=Справочники.Контрагенты.НайтиПоКоду("SSP-2450") ТОгда
					Если Склад=Справочники.Склады.НайтиПоКоду("SNL-84") тОгда
						КодПоставщикаКонтрагента=Справочники.КодыПоставщиков.НайтиПоКоду("SSP-000003");
					Иначе
						КодПоставщикаКонтрагента=Справочники.КодыПоставщиков.НайтиПоКоду("SSP-000002");
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		//----------------------------------------------
		//доставка
		Если не ПунктДоставки=Неопределено  Тогда 
			Если ЗначениеЗаполнено(ПунктДоставки.РайонДоставки) Тогда
				РайонДоставки=ПунктДоставки.РайонДоставки;	
				ДокОбъект.РайонДоставки=РайонДоставки;
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.Регион) Тогда
				Регион=ПунктДоставки.Регион;
				ДокОбъект.Регион=Регион;
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.ТраспортнаяКомпания) Тогда
				ТранспортнаяКомпания=ПунктДоставки.ТраспортнаяКомпания;	
				ДокОбъект.ТранспортнаяКомпания=ТранспортнаяКомпания;
			КонецЕсли;	
			Если ЗначениеЗаполнено(ПунктДоставки.ПунктПерегруза) Тогда
				ПунктПерегруза=ПунктДоставки.ПунктПерегруза;	
				ДокОбъект.ПунктПерегруза=ПунктПерегруза;
			КонецЕсли;		
			Если ЗначениеЗаполнено(ПунктДоставки.Грузополучатель) Тогда
				Грузополучатель=ПунктДоставки.Грузополучатель;		
				ДокОбъект.Грузополучатель=Грузополучатель;
			КонецЕсли;
			Если ЗначениеЗаполнено(ПунктДоставки.Получатель) Тогда
				Получатель=ПунктДоставки.Получатель;		
				ДокОбъект.Получатель=Получатель;
			КонецЕсли;
			Если ЗначениеЗаполнено(ПунктДоставки.ОтсрочкаПлатежа) Тогда
				ОтсрочкаПлатежа=ПунктДоставки.ОтсрочкаПлатежа;		
				ДокОбъект.ОтсрочкаПлатежа=ОтсрочкаПлатежа;
			КонецЕсли;
			
			//типы цен скидки
			Если ЗначениеЗаполнено(ПунктДоставки.ТипЦен) И ТипЦен<>ПунктДоставки.ТипЦен Тогда
				ТипЦен=ПунктДоставки.ТипЦен;		
			КонецЕсли; 
			Если ЗначениеЗаполнено(ПунктДоставки.ТипСкидок) И ДокОбъект.ТипСкидок<>ПунктДоставки.ТипСкидок Тогда
				ТипСкидок=ПунктДоставки.ТипСкидок;		
			КонецЕсли;
			Если ПунктДоставки.Скидка<>0 И ПунктДоставки.Скидка<>ДокОбъект.Скидка Тогда
				Скидка=ПунктДоставки.Скидка;		
				ДокОбъект.Скидка=Скидка;
			КонецЕсли;
		КонецЕсли;
		//-------------------------------------------------------------------		
		
		ДокОбъект.Дата=ТекДата;
		ЗаполнитьШапкуДокумента(ДокОбъект, ПараметрыСеанса.Пользователь, ПараметрыСеанса.ВалютаНац, "Продажа");
		ДокОбъект.Контрагент=Контрагент;
		ДокОбъект.Организация=Организация;
		ДокОбъект.Договор=Договор;
		ДокОбъект.ИБ=Справочники.ИБ.НайтиПоКоду("SSP");
		ДокОбъект.Менеджер= Менеджер;
		
		ДокОбъект.НомерЗаказа=НомерЗаказа;
		ДокОбъект.ДатаЗаказа=ДатаЗаказа;  //Дата(СтрЗаменить(ДатаЗаказа, "-", ""));
		
		//----------------------------------------------------------------	
		СтрокаШапка.ДатаЗаказа=ДатаЗаказа;
		СтрокаШапка.НомерЗаказа=НомерЗаказа;
		СтрокаШапка.Контрагент=Контрагент;
		СтрокаШапка.ПунктДоставки=ПунктДоставки;
		СтрокаШапка.КодМестаДоставки=ПунктДоставки.НомерМагазина;
		//------------------------------------------------------------------
		
		
		//ДокОбъект.ДатаОтгрузки=Дата(СтрЗаменить(ДатаДоставки, "-", ""));
		ДокОбъект.КодПоставщика=КодПоставщикаКонтрагента;
		
		ДокОбъект.Регион = Регион;
		ТипШК=перечисления.ТипыШтрихКодов.Штука;
		
		ДокОбъект.ОтсрочкаПлатежа=ОтсрочкаПлатежа;		
		ДокОбъект.ТипЦен=ТипЦен; //Контрагент.ТипЦен;
		ДокОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН;
		ДокОбъект.Подразделение = Подразделение;
		ДокОбъект.ЛевыйКонтрагент=Контрагент;
		ДокОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
		ДокОбъект.Отгружен=перечисления.Отгружен.Резерв;
		ДокОбъект.ПунктДоставки=ПунктДоставки;
		ДокОбъект.Склад=Склад;		
		УстановитьНомерДокумента2(ДокОбъект);
		ДокОбъект.Валюта=Справочники.Валюты.НайтиПоКоду("810");
		//ДокОбъект.Автор				=Неопределено;
		
		ДокОбъект.КодОперации=Перечисления.КодыОперацийОстатки.Реализация;
		ДокОбъект.ДатаОформления	=ДокОбъект.Дата;
		СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
		ДокОбъект.Скидка=СкидкаКонтрагента;
		
		ПересчетТЧ(ДокОбъект,"Товары",ДокОбъект.Валюта,ДокОбъект.Валюта,ДокОбъект.Курс,ДокОбъект.Курс,Истина);	
		
		Попытка
			ДокОбъект.Записать(режимЗаписиДокумента.Запись);     //+++
			Файлы.Добавить("Создан документ: "+ДокОбъект.Дата+" "+ДокОбъект.Номер+", склад: "+ДокОбъект.Склад+".");
			//Сообщить("Записан документ - "+ДокОбъект.Дата+" "+ДокОбъект.Номер);
		Исключение
			
			КритичОшибки.Добавить("Для заказа от <<Столетов>> Заказ  №"+ДокОбъект.НомерЗаказа+" документ не записан! "+ОписаниеОшибки() );
			
		КонецПопытки;
		
		//Сообщить(""+ДокОбъект.Номер+"   документ записан");
		ПризКр=ПризКр+1;
		
		//--------------------------------------------------
		
		БД.ЗакрытьФайл();
		
		//----------------------------------------------------
		СообщитьМенеджеру(ТекФайл, ТЗШапка);       //++++
		СообщитьКритОшибки();
		
	КонецЦикла;
	
	
	//---------------------------------------------------------------------------	
	//3. удаляем файл на сервере фтп
	
	Попытка
		// Удалить(<Путь>, <Маска>) - шпаргалка
		Сервер.Удалить("/Заказ","*.*");         //+++
	Исключение
		КритичОшибки.Добавить(""+МассивФайлов.Количество()+" шт. - Файлы заказов не удалены на ФТП! Очистите ФТП! "+ОписаниеОшибки() );
	КонецПопытки;
	
	Сервер=Неопределено;
	
	//Сообщить("Загрузка завершена! "+ МассивФайлов.Количество()+ "  файлов загружено.");
	
КонецПроцедуры

//************************************************************

Процедура СообщитьМенеджеру(ПутьФайла, Шапка) Экспорт
	
	СтрШапка=Шапка.Получить(0);
	Менеджер=СтрШапка.контрагент.Менеджер;
	
	//---------------------------------------------------------------
	Попытка
		ИмяФайлаПечати=ФормированиеПечати(ТЗПечать,ТЗШапка); //+++
	Исключение
		КритичОшибки.Добавить("Не сформирован файл печати! "+Символ(13));
	КонецПопытки;
	
	Профиль= Новый ИнтернетПочтовыйПрофиль;
	
	// Кухарь А.Ю.  08.09.2022 начало
	//Профиль.АдресСервераPOP3   = "srvmail2.collant.ru";
	//Профиль.АдресСервераSMTP   =  "srvmail2.collant.ru";
	//Профиль.ПортPOP3           = 110; 
	ПараметрыПочты = ОбщегоНазначения_ПИ.ПолучитьДанныеПочтовогоСервера();
	ЗаполнитьЗначенияСвойств(Профиль,ПараметрыПочты);	
	// Кухарь А.Ю.  08.09.2022 конец
	Профиль.ВремяОжидания      = 60; 
	// Ихсанов Д. А. Начало 14.10.2025 https://yougile.collant.ru/team/ab6bad3a05c0/#ASU-2548
	//Профиль.Пользователь="*%*%*%";
	//Профиль.Пароль="*$*$*$";
	Профиль.Пользователь = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Логин;
	Профиль.Пароль = РаботаСБезопаснымХранилищемПовтИсп.ПрочитатьДанныеАвторизацииПоКлючу(
		Справочники.КлючиБезопасногоХранилищаДанных.ДанныеАвторизацииКПочтовомуСерверуЕкод).Пароль;
	// Ихсанов Д. А. Конец  14.10.2025
	//---------------------------------------------------------------
	
	//----------------------------------------------------------------
	Сообщение=новый интернетПочтовоеСообщение;
	
	////---------------------------------------------------------------
	Сообщение.Получатели.Добавить(Менеджер.ЕМэйл);     // +++
	
	// получаем заместителей, для отправки из справочника пользователи.
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ПользователиЗаместители.Заместитель,
	|	ПользователиЗаместители.Заместитель.ЕМэйл  как ЗамЕМэйл
	|ИЗ                                                                 //+++
	|	Справочник.Пользователи.Заместители КАК ПользователиЗаместители
	|ГДЕ
	|	ПользователиЗаместители.Ссылка.ФизЛицо = &ТекМенеджер";
	Запрос.УстановитьПараметр("ТекМенеджер",Менеджер);
	Результат=Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		Если СтрДлина(Результат.ЗамЕМэйл)>5 Тогда
			Сообщение.Получатели.Добавить(Результат.ЗамЕМэйл);
		Иначе
			КритичОшибки.Добавить("Для менеджера (зам)"+Результат.Заместитель.Наименование+" не определен ЕМэйл. "+Символ(13));
		КонецЕсли;
	КонецЦикла;	
	//-----------------------------------------------
	Сообщение.Получатели.Добавить("ecode@collant.ru"); //+++
	
	Сообщение.Получатели.Добавить("nechaeva@collant.ru");
	Сообщение.Отправитель="ecode@collant.ru";
	
	
	Попытка
		Сообщение.Вложения.Добавить(ПутьФайла);  // ++++
	Исключение
		КритичОшибки.Добавить("Не возможно добавить файл заказа .dbf "+СтрШапка.НомерЗаказа+". Контрагент - "+СтрШапка.контрагент+".  "+ОписаниеОшибки() );
	КонецПопытки;
	
	Попытка
		Сообщение.Вложения.Добавить(ИмяФайлаПечати);  // ++++
	Исключение
		КритичОшибки.Добавить("Не возможно добавить файл печати "+СтрШапка.НомерЗаказа+". Контрагент - "+СтрШапка.контрагент+".  "+ОписаниеОшибки() );
	КонецПопытки;
	
	// и прикрепляем файл;
	//----------------------------------------------------------------
	ПунктДоставки=СтрШапка.ПунктДоставки;
	Если ПунктДоставки=Неопределено тогда
		ПунктДоставки="";
	Конецесли;	
	//----------------------------------------------------------------
	
	Сообщение.Тема="Автообмен Столетов. Новый заказ № "+СтрШапка.номерЗаказа+" - "+СтрШапка.контрагент+" - "+ПунктДоставки;
	Строка=Символ(13)+Символ(13)+"       Добрый день!"+Символ(13)+Символ(13)+Строка("Новый заказ от Эркафарм(Доктор Столетова) № "+СтрШапка.НомерЗаказа+"  от компании  "+СтрШапка.контрагент+".");
	
	Для рр=0 по файлы.Количество()-1 Цикл
		Строка=Строка+символы.ПС+Файлы[рр];
	КонецЦикла;
	
	
	НомСтр=1;
	Строка=Строка+Символы.ПС+символы.ПС+"Фактический адрес, пунк доставки: "+СтрШапка.ПунктДоставки;
	Строка=Строка+Символы.ПС;
	Если Ошибки.количество()>1 Тогда
		Строка=Строка+Символы.ПС+"Сообщения по загрузке данных:";
	КонецЕсли;	
	Если НЕ Ошибки=Неопределено и ошибки.Количество()>0 Тогда
		Для рр=0 по ошибки.Количество()-1 Цикл
			Строка=Строка+Символы.ПС+НомСтр+". "+Ошибки[рр];
			Строка=Строка+Символы.ПС;
			НомСтр=НомСтр+1;
		КонецЦикла;
	конецЕсли;
	Строка=Строка+Символы.ПС+"________________________________________________________________";
	
	Сообщение.Тексты.Добавить(Строка);
	
