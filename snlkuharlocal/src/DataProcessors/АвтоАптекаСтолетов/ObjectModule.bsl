Функция ЗагрузитьСписокДляПрайсаТекстовый() 
	
	// заполняем из экселя список номенклатуры.
	//Путь="\\SRVECOD\EdiConnector\Stoletov\Price\";
	Путь = Константы.КаталогЕКОД.Получить() + "Stoletov\Price\";
	//нечаева  06,08,19 ---
	ИмяФайла1=Путь+"СписокДляПрайса.txt";
	СписокДляПрайса= Новый Массив;
	
	
	Текст = Новый ТекстовыйДокумент;
	Текст.Прочитать(ИмяФайла1);
	КоличествоСтрок = Текст.КоличествоСтрок();
	
	Стр=0;
	
	Пока Стр<=КоличествоСтрок Цикл		
		
		ТекСтр=Текст.ПолучитьСтроку(Стр);
		Поиск=Найти(ТекСтр,Символы.Таб);
		Если Поиск > 0 Тогда
			
			текКод=Лев(ТекСтр,Поиск-1);
			// ищем если не пустой то добовляем
			Ном=Справочники.Номенклатура.НайтиПоКоду(ТекКод);
			Если не Ном.Пустая() Тогда
				СписокДляПрайса.Добавить(Ном);
			конецЕсли;
		Иначе
			Поиск=Найти(ТекСтр," ");
			Если Поиск > 0 Тогда
				
				текКод=Лев(ТекСтр,Поиск-1);
				
				Ном=Справочники.Номенклатура.НайтиПоКоду(ТекКод);
				Если не Ном.Пустая() Тогда
					СписокДляПрайса.Добавить(Ном);
				конецЕсли;
				
			КонецЕсли;	
			
		КонецЕсли;
		
		Стр=Стр+1;
		
	КонецЦикла;
	
	
	Возврат СписокДляПрайса;
	
КонецФункции


