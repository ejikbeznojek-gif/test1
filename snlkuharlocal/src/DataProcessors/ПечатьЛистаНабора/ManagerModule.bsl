 //Данилова Е.В. 13.05.2026 HELP-9756
 Функция ПолучитьНомерКоробкиПоЛистуПереукладки(Знач ЛистПереукладки,НомерПопытки = 1,ЗаписыватьВРС = Истина) Экспорт 
 
	 Если ЗначениеЗаполнено(ЛистПереукладки.номерКоробки) Тогда
		 
		 Возврат ЛистПереукладки.НомерКоробки; 	
		 
	 КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистПереукладки.НомерКоробки КАК НомерКоробки
		|ПОМЕСТИТЬ ВТНомераИспользуемые
		|ИЗ
		|	Документ.ЛистПереукладки КАК ЛистПереукладки
		|ГДЕ
		|	ЛистПереукладки.ДокОснование = &ДокОснование
		|	И ЛистПереукладки.НомерКоробки <> 0
		|	И ЛистПереукладки.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВТНомераИспользуемые.НомерКоробки + 1 КАК НомерКоробки,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ ВТНомерКоробкиСледующий
		|ИЗ
		|	ВТНомераИспользуемые КАК ВТНомераИспользуемые
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТНомераИспользуемые.НомерКоробки УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	0 КАК Цифра
		|ПОМЕСТИТЬ ВТ_Цифры
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	1
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	3
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	4
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	5
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	6
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	7
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	8
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	9
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Число КАК Число
		|ПОМЕСТИТЬ ВТВсеЧислаДоПоследнего
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_Цифры.Цифра * 100 + ВТ_Цифры1.Цифра * 10 + ВТ_Цифры2.Цифра КАК Число
		|	ИЗ
		|		ВТ_Цифры КАК ВТ_Цифры,
		|		ВТ_Цифры КАК ВТ_Цифры1,
		|		ВТ_Цифры КАК ВТ_Цифры2) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНомерКоробкиСледующий КАК ВТНомерКоробкиСледующий
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ВложенныйЗапрос.Число < ВТНомерКоробкиСледующий.НомерКоробки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВТВсеЧислаДоПоследнего.Число КАК НомерКоробки,
		|	1 КАК Приоритет
		|ПОМЕСТИТЬ ВТНомераПомеченные
		|ИЗ
		|	ВТВсеЧислаДоПоследнего КАК ВТВсеЧислаДоПоследнего
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНомераИспользуемые КАК ВТНомераИспользуемые
		|		ПО ВТВсеЧислаДоПоследнего.Число = ВТНомераИспользуемые.НомерКоробки
		|ГДЕ
		|	ВТНомераИспользуемые.НомерКоробки ЕСТЬ NULL
		|	И ВТВсеЧислаДоПоследнего.Число <> 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТВсеЧислаДоПоследнего.Число
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТНомера.НомерКоробки КАК НомерКоробки,
		|	ВТНомера.Приоритет КАК Приоритет
		|ИЗ
		|	ВТНомерКоробкиСледующий КАК ВТНомера
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТНомераПомеченные.НомерКоробки,
		|	ВТНомераПомеченные.Приоритет
		|ИЗ
		|	ВТНомераПомеченные КАК ВТНомераПомеченные
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТНомера.Приоритет УБЫВ";
	
	Запрос.УстановитьПараметр("ДокОснование", ЛистПереукладки.ДокОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		//++Данилова Е.В. 28.04.2026 HELP-9565
		//Возврат ВыборкаДетальныеЗаписи.НомерКоробки;
		НомерКоробки =  ВыборкаДетальныеЗаписи.НомерКоробки;
		//--Данилова Е.В. 28.04.2026 
	Иначе 
		НомерКоробки = 1;
	КонецЕсли;
	
	//Возврат 1;
	//++Данилова Е.В. 13.05.2026  HELP-9756 
	Если ЗаписыватьВРС Тогда 
		//++Данилова Е.В. 28.04.2026 HELP-9565
		ПараметрыЗаписи = РегистрыСведений.НомераКоробокПоЛистам.СтруктураПараметровЗаписиВРегистр(); 
		ПараметрыЗаписи.Докоснование 	= ЛистПереукладки.ДокОснование; 
		ПараметрыЗаписи.НомерКоробки 	= НомерКоробки; 
		ПараметрыЗаписи.Лист 			= ЛистПереукладки.ссылка;
		
		РезультатЗаписи = РегистрыСведений.НомераКоробокПоЛистам.ЗаписатьНомерКоробки(ПараметрыЗаписи);
		Если РезультатЗаписи.Успешно Тогда
			
			Возврат НомерКоробки;	
			
		ИначеЕсли НомерПопытки < 3 Тогда 
			
			Возврат ПолучитьНомерКоробкиПоЛистуПереукладки(ЛистПереукладки,НомерПопытки + 1); 
			
		Иначе
			
			ВызватьИсключение "Не удалось получить номер коробки!!Попробуйте заново сформировать этикетку";
			
		КонецЕсли;
		
		
		//--Данилова Е.В. 28.04.2026 
	Иначе
		
		Возврат НомерКоробки; 
		
	КонецЕсли; 
	//--Данилова Е.В. 13.05.2026 
 
КонецФункции // ПолучитьНомерКоробкиПоЛистуПереукладки() 

Функция ПолучитьНомерКоробкиПоЛистуНабора(Знач ЛистНабора, ТЗТоваров,НомерПопытки = 1,ЗаписыватьВРС = Истина)Экспорт 

	//надо получить начальный номер, а затем уже идти по таблице товаров сч +1 
	 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистНабораНомераКоробок.НомерКоробки КАК НомерКоробки
		|ПОМЕСТИТЬ ВТНомераИспользуемые
		|ИЗ
		|	Документ.ЛистНабора КАК ЛистНабораДок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистНабора.НомераКоробок КАК ЛистНабораНомераКоробок
		|		ПО ЛистНабораДок.Ссылка = ЛистНабораНомераКоробок.Ссылка
		|ГДЕ
		|	ЛистНабораДок.ДокОснование = &ДокОснование
		|	И ЛистНабораНомераКоробок.НомерКоробки <> 0
		|	И ЛистНабораДок.Проведен
		|	И ЛистНабораНомераКоробок.Ссылка <> &ЭтотЛист
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВТНомераИспользуемые.НомерКоробки + 1 КАК НомерКоробки,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ ВТНомерКоробкиСледующий
		|ИЗ
		|	ВТНомераИспользуемые КАК ВТНомераИспользуемые
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТНомераИспользуемые.НомерКоробки УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	0 КАК Цифра
		|ПОМЕСТИТЬ ВТ_Цифры
