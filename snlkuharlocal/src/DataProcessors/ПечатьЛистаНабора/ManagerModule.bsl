		ТабНом=СтруктураКоробок.Скопировать();
		ТабНом.Свернуть("Номенклатура");
		СтруктураКоробок.колонки.добавить("ПорядковыйНомерСканирования");
		для каждого СтрТЗ из ТабНом цикл
			Отбор=новый Структура;
			Отбор.Вставить("Номенклатура",СтрТЗ.Номенклатура);
			МассИзТч=ДокументПечатиОбъект.Товары.НайтиСтроки(Отбор);
			если МассИзТч.Количество()<>1 тогда Продолжить; КонецЕсли;
			МассИзСтруктурыКоробок=СтруктураКоробок.НайтиСтроки(Отбор);
			//++Данилова Е.В. 16.03.2026 SNL-153 
			если ВидДокументаПечати = "ЛистНабора" Тогда 
				ТекстНомеровСтрок=МассИзТч.Получить(0).ПорядковыйНомерКоробки;
			Иначе
				ТекстНомеровСтрок= ""; 
			КонецЕсли;
			//--Данилова Е.В. 16.03.2026 
			если ТекстНомеровСтрок="" тогда
				Продолжить;
			КонецЕсли;
			ТекстНомеровСтрок=СтрЗаменить(ТекстНомеровСтрок,";",Символы.ПС);
			Сч=1;
			Для Каждого СтрМассСтруктуры из МассИзСтруктурыКоробок цикл  
				если СтрПолучитьСтроку(ТекстНомеровСтрок,сч)<>"" тогда
					СтрМассСтруктуры.ПорядковыйНомерСканирования=число(СтрПолучитьСтроку(ТекстНомеровСтрок,сч));
				иначе
					СтрМассСтруктуры.ПорядковыйНомерСканирования=0;
				КонецЕсли;		
				сч=сч+1;
			КонецЦикла;				
		КонецЦикла;
		//++Данилова Е.В. 16.03.2026 SNL-153
		если ВидДокументаПечати = "ЛистНабора"
			И ДокументПечатиОбъект.товары.Получить(0).ПорядковыйНомерКоробки<>"" тогда
			//--Данилова Е.В. 16.03.2026 
			СтруктураКоробок.Сортировать("ПорядковыйНомерСканирования");
		КонецЕсли;	
	КонецЕсли;         
	
	
	ТабДок	= Новый ТабличныйДокумент;
	
	
	если не ПечатьНовойКомпонентой тогда
		Макет=Обработки.НаклейкиНаКоробки.ПолучитьМакет("ШК");
	иначе  
		Макет=Обработки.НаклейкиНаКоробки.ПолучитьМакет("ШКНоваяКомпонента");
	КонецЕсли;
	
	НаборПолей = Новый Структура;
	попытка
		сектор = Лев(РеквизитыДокОснования.РайонДоставки_Сектор_Наименование,2);
		НаборПолей.Вставить("сектор",сектор);
	Исключение
	КонецПопытки;
	
	НаборПолей.Вставить("Отправитель",РеквизитыДокОснования.Организация_Наименование);
	НаборПолей.Вставить("Телефон",РеквизитыДокОснования.Организация_Телефоны);	
	НаборПолей.Вставить("ЮрАД",РеквизитыДокОснования.Организация_ЮридическийАдрес);		 
	
	Регион=Неопределено; 
	АдресДляЭтикеткиИзРег ="";
	Если ВидДокументаПечати="Перемещение" Тогда
		Получатель = РеквизитыДокОснования.Организация_Наименование+" "+РеквизитыДокОснования.ПунктДоставки;
		Регион= РеквизитыДокОснования.ПунктДоставки_Регион;
	ИначеЕсли ВидДокументаПечати="ПриходнаяНакладная" тогда
		Получатель	=РеквизитыДокОснования.Контрагент_наименование;
		Регион= РеквизитыДокОснования.ПунктДоставки_Регион;
	ИначеЕсли ВидДокументаПечати="РасходнаяНакладная" тогда
		Получатель	=РеквизитыДокОснования.Контрагент_наименование;;
		Регион= РеквизитыДокОснования.ПунктДоставки_Регион;	
		Грузополучатель=РеквизитыДокОснования.Контрагент;		
		Получатель=СокрЛП(РеквизитыДокОснования.Контрагент_Наименование)+" "+СокрЛП(РеквизитыДокОснования.ПунктДоставки);
		если ДопПараметрыНакладной.имя="SSP-3698" тогда
			НаборПолей.Вставить("НомерМагазина",РеквизитыДокОснования.ПунктДоставки_НомерМагазина);	 
		КонецЕсли;   
		АдресДляЭтикеткиИзРег=ПрочитатьЗначениеРеквизитаПНКПРМРНК("АдресДляЭтикетки",ДокОснование);	
	Иначе
		Грузополучатель=?(ДокОснование.Грузополучатель.Пустая(),ДокОснование.Контрагент,ДокОснование.Грузополучатель);		
		Получатель	=Грузополучатель.Наименование;
		Если НЕ Грузополучатель.Регион.Пустая() Тогда					
			Регион=Грузополучатель.Регион;
		КонецЕсли;
		Если ЕстьРеквизитДокумента("ПунктДоставки",МетаДок) И ЗначениеЗаполнено(ДокОснование.ПунктДоставки) Тогда
			Получатель=СокрЛП(Получатель)+" "+СокрЛП(ДокОснование.ПунктДоставки);
		КонецЕсли; 		
	КонецЕсли; 
	НаборПолей.Вставить("Получатель",Получатель);	
	НаборПолей.Вставить("Регион",Регион);	
	
	НаборПолей.Вставить("ад", РеквизитыДокОснования.ПунктДоставки_АдресПолучателя+ " тел.: "+РеквизитыДокОснования.ПунктДоставки_Телефоны);
	если ЗначениеЗаполнено(АдресДляЭтикеткиИзРег) тогда
		НаборПолей.ад=АдресДляЭтикеткиИзРег;
	КонецЕсли;
	НаборПолей.Вставить("Пользователь",Строка(ДокументПечатиОбъект.Сканировщик)+?(ПараметрыСеанса.Пользователь.ФизЛицо=ДокументПечатиОбъект.Сканировщик,"","\"+Строка(ПараметрыСеанса.Пользователь.ФизЛицо)));
	
	НаборПолей.Вставить("Номер", РеквизитыДокОснования.Номер);	
	
	если ТипШК<>Перечисления.ТипыШтрихКодов.Коробка тогда
		НаборПолей.Вставить("ШтукВЛН"," - "+ДокументПечатиОбъект.Товары.Итог("Количество")+"шт.");	
		НужноОбрезать=Истина;
	иначе
		НужноОбрезать=Ложь;
	КонецЕсли;
	
	ДопПараметрыПечати=новый Структура("КодКонтрагента,КодКонтрагентаРодителя,КолКоробок,МожноВыводитьОбщееКоличествоМест,НаборПолей,НужноОбрезать,ТабДок"
		,КодКонтрагента,КодКонтрагентаРодителя,КолКоробок,МожноВыводитьОбщееКоличествоМест,НаборПолей,НужноОбрезать,ТабДок);        
	//++Данилова Е.В. 26.03.2026 SNL-153
	//КодАгрегации = ДокументПечатиОбъект.КодАгрегации;
	
	КодАгрегации = ДопПараметры.КодАгрегации;
	//--Данилова Е.В. 26.03.2026
	//++Данилова Е.В. 27.03.2026 SNL-153 
	//ДопПараметрыПечати.Вставить("ТребуетсяАгрегацияКоробок",ЗначениеЗаполнено(КодАгрегации));	
	ТребуетсяВыводКоробки = ВыводитьКодАгрегацииВЭтикетку И  ЗначениеЗаполнено(КодАгрегации); 
	ДопПараметрыПечати.Вставить("ТребуетсяАгрегацияКоробок",ТребуетсяВыводКоробки);
	//--Данилова Е.В. 27.03.2026 
	ДопПараметрыПечати.Вставить("ОбработкаПечати", Обработки.ПечатьЭтикетокЧЗ.Создать());     
	
	если ЗначениеЗаполнено(КодАгрегации) тогда
		ТипШКАгрегации = ПолучитьРеквизитШапки(РеквизитыДокОснования.Контрагент,"ТипШКАгрегации","Справочник"); 
		если ТипШКАгрегации = Перечисления.ТипыКодировокШК.Code128 тогда   
			ДопПараметрыПечати.Вставить("ПечататьCode128ДляАгрегаций",Истина);
		иначе
			ДопПараметрыПечати.Вставить("ПечататьCode128ДляАгрегаций",ложь);
		КонецЕсли;
	КонецЕсли;	
	//++Данилова Е.В. 07.05.2026 HELP-8363 
	МассивКодовQR = Новый Массив; 
	//--Данилова Е.В. 07.05.2026 
	для Каждого СтрТз из СтруктураКоробок цикл 	
		//++Данилова Е.В. 26.03.2026 SNL-153  
		//ПечатьЭтикеткиОнлайнНаСтрокуКороба(СтрТЗ,ДопПараметрыПечати,ДокументПечатиОбъект,Макет,ДокОснование);
		//++Данилова Е.В. 07.05.2026 HELP-8363
		ШтрихКодЭтикетки = Неопределено; 
		ПечатьЭтикеткиОнлайнНаСтрокуКороба(СтрТЗ,ДопПараметрыПечати,ДокументПечатиОбъект,Макет,ДокОснование,КодАгрегации,ШтрихКодЭтикетки);
		Если ЗначениеЗаполнено(ШтрихКодЭтикетки) Тогда
		
			МассивКодовQR.Добавить(ШтрихКодЭтикетки); 	
		
		КонецЕсли; 
		//--Данилова Е.В. 07.05.2026 
		//--Данилова Е.В. 26.03.2026 
	КонецЦикла; 
	//++Данилова Е.В. 07.05.2026 HELP-8363
	СтруктураРезультат.МассивКодовQR  = МассивКодовQR;  
	//--Данилова Е.В. 07.05.2026 
	если не ЗначениеЗаполнено(ТабДок.ИмяПараметровПечати) тогда
		ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_"+ВидДокументаПечати+"_НаклейкиНаКоробки";
	КонецЕсли;
	
	ТабДок.ОтображатьСетку 		= Ложь;	
	ТабДок.ОтображатьЗаголовки 	= Ложь;	
	ТабДок.ПолеСверху=0; ТабДок.ПолеСнизу=0; ТабДок.ПолеСлева=3; ТабДок.ПолеСправа=0;
	
	если ВнешнийТД<>Неопределено тогда
		ВнешнийТД.вывести(ТабДок);
	иначе
		//ТабДок.Показать("Наклейки "+ РеквизитыДокОснования.Номер);
		СтруктураРезультат.Успех = истина; 
		СтруктураРезультат.ТабДокумент = ТабДок; 
	КонецЕсли;
	
	
	если МожноВыводитьОбщееКоличествоМест тогда
		   
		если КоличествоКоробокНакладной<>КолКоробок тогда   		 
			
			НакладнаяОбъект=ДокОснование.ПолучитьОбъект();
			СтрТЗ=ФинальныйПересчетКоробокИОбъемов(ДокОснование.ПолучитьОбъект());
			ЗаполнитьЗначенияСвойств(НакладнаяОбъект,СтрТЗ);
			НакладнаяОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;
	
	
	ТабДокументДоп = НапечататьДополнительнуюЭтикетку(ДокОснование,ДокументПечатиОбъект,Форма,ВнешнийДополнительныйТД,ДопПараметрыНакладной); 
	Если ВнешнийДополнительныйТД = неопределено  Тогда
		
		СтруктураРезультат.ТабДокументДоп = ТабДокументДоп; 	
		
	КонецЕсли;
	если ДопПараметрыНакладной <> Неопределено и  ДопПараметрыНакладной.ОтгрузкаКомплектов тогда	 
		если   ДопПараметрыНакладной.имя = "OZON_FBS" тогда
			ТЗУпаковки=ПолучитьРазбивкуНоменклатурыПоУпаковкеДокумента(ДокументПечатиОбъект.Товары.ВыгрузитьКолонку("Номенклатура"),ДопПараметрыНакладной.МассивДО);
			Для каждого СтрТЗ из ТЗУпаковки цикл
				Сообщить("Положите "+СтрТЗ.Владелец+" в "+СтрТЗ.Упаковка);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли; 

	Возврат СтруктураРезультат;  
	 
КонецФункции // ПечатьЭтикеткиОнлайн() 

Функция НапечататьДополнительнуюЭтикетку(ДокОснование,ДокументПечати,Форма,ВнешнийДополнительныйТД,ДопПараметрыНакладной) 
	Накладная = ДокОснование;
	если не ЗначениеЗаполнено(ДокументПечати.Ссылка) тогда
		возврат Неопределено;
	КонецЕсли;
	
	если ложь тогда Накладная = Документы.РасходнаяНакладная.ПустаяСсылка();КонецЕсли;
	
	если Накладная.Метаданные().Имя <> "РасходнаяНакладная" тогда
		возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПечати=ПолучитьПараметрыПечати(Накладная);
	если ПараметрыПечати=Неопределено тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТаблицаТоваров=ДокументПечати.Товары.выгрузить();
	если ПараметрыПечати.СворачиватьТовары тогда
		ТаблицаТоваров.свернуть(ПараметрыПечати.КолонкиГруппировки,ПараметрыПечати.КолонкиСуммы);
	КонецЕсли;
	ТабДок=Новый ТабличныйДокумент;
	 
	ИмяПараметровПечати = "ДополнительнаяЭтикеткаНаКоробИзЛН" + СтрЗаменить(Накладная.контрагент.код, "-", "");
	ТабДок.ИмяПараметровПечати = ИмяПараметровПечати;
	
	Макет=ПараметрыПечати.Макет;
	МожноПечатать=Истина; 
	
	если Накладная.контрагент.код="SSR-9059" или Накладная.контрагент.код="SST-1208" тогда //Вайлдберриз
		если не ДокументПечати.Проведен тогда
			Форма.ЗаписатьВФорме(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
		
		Если НЕ  Накладная.ОтгрузкаКомплектов 
			И ОтсканированыКоробаВЛН(ДокументПечати) Тогда  		
			
			ТабДок = НапечататьДополнительнуюЭтикеткуПоВБПоНесколькимТоварам(ПараметрыПечати,ДокОснование,ДокументПечати,ДопПараметрыНакладной);
			Если ТабДок = неопределено  Тогда
				
				Возврат Неопределено; 	
				
			КонецЕсли;
			ТабДок.ИмяПараметровПечати = ИмяПараметровПечати;
		Иначе 
			
			
			ОблЭтикетка=Макет.получитьобласть("Этикетка");
			Если Накладная.ОтгрузкаКомплектов тогда
				Возврат Неопределено;
			КонецЕсли;	
			Если ТаблицаТоваров.Количество()<>1 тогда
				возврат Неопределено;
			КонецЕсли;
			Номенклатура=ТаблицаТоваров.Получить(0).Номенклатура;
			
			СтрШК = ШКпоИндексуТекЛН(Накладная,Номенклатура,ДопПараметрыНакладной,ДокументПечати); 
			
			Если СтрШК = Неопределено Тогда
				
				Возврат Неопределено; 	
				
			КонецЕсли;
			
			ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
			Для Каждого Рисунок Из ОблЭтикетка.Рисунки Цикл							
				
				ДопПараметры = Новый Структура; 
				ДопПараметры.Вставить("НужнаТолькоКартинка", Истина);
				ДопПараметры.Вставить("ОтображатьТекст", Ложь); 
				ДопПараметры.Вставить("ВысотаРисунка", Рисунок.Высота);
				ДопПараметры.Вставить("ШиринаРисунка", Рисунок.Ширина);
				ДопПараметры.Вставить("БезПрефикса", Истина); // Кельманов А.В. - HELP-5825 - 2025.07.02
				КартинкаКода 		=  ОбработкаПечати.СформироватьКА(Макет,СтрШК.ШтрихКод,,,,ДопПараметры);     
				Рисунок.Картинка 	= КартинкаКода;
				ОблЭтикетка.Параметры.СтараяНоменклатура = СтрШК.ШтрихКод; 
				
			КонецЦикла; 	
			
			ТабДок.Вывести(ОблЭтикетка);
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЕсли; 
		
	иначе
		если Накладная.контрагент.код="SSR-5004" тогда //МАКСИМА ГРУПП
			//если Накладная.контрагент.код="SSR-1593" тогда //для теста
			//SSR-1593
			ОблШапка=Макет.ПолучитьОбласть("шапка");
			ОблСтрока = Макет.ПолучитьОбласть("Строка");
			НомерПоставщика = ДокументПечати.Ссылка.ДокОснование.Контрагент.КодПоставщика;
			ОблШапка.Параметры.НомерПоставщика=НомерПоставщика;
			НомерЛистаНабора = Прав(ДокументПечати.Ссылка.Номер,6);
			НомерЛистаНабора = Число(НомерЛистаНабора);
			ОблШапка.Параметры.НомерКороба=НомерЛистаНабора;
			ВсегоЛистовНабора = 0; 
			Если ДокументПечати.Ссылка.Метаданные().Имя = "ЛистНабора" Тогда 
				ВсегоЛистовНабора = ДокументПечати.Ссылка.ЛистыНабора.Количество();
			КонецЕсли;
			ТекЛистНабора = ДокументПечати.Ссылка;
			Если ТекЛистНабора.Проведен = Ложь Тогда
				
				Возврат Неопределено;		
			КонецЕсли;
			
				
			ТабДок.Вывести(ОблШапка);		
			ОблЗаголовок = Макет.ПолучитьОбласть("заголовок");
			ТабДок.Вывести(ОблЗаголовок);
						
			ТЗ=ДокументПечати.Товары.Выгрузить();
			ТЗ.Свернуть("Номенклатура,ШКМатрицы","Количество");
			
			ТЗ.Колонки.Добавить("артикул");
			ТЗ.Колонки.Добавить("ШККонтрагента");
			
			Для каждого СтрокаТЗ Из ТЗ Цикл
				Попытка
					СтрокаТЗ.ФамилияНаменованиеТовара =  ПолучитьСвойстваНоменклатуры1(СтрокаТЗ.Номенклатура).ФамилияНаменованиеТовара.Наименование;
					сообщить(СтрокаТЗ.ФамилияНаменованиеТовара);
				Исключение КонецПопытки;
				
				Попытка
					СтрокаТЗ.ФамилияМодель = ПолучитьСвойстваНоменклатуры1(СтрокаТЗ.Номенклатура).ФамилияМодель.Наименование;
				Исключение КонецПопытки;
				
				ЗапросНов=Новый Запрос;
				ЗапросНов.Текст = "ВЫБРАТЬ
				|	МатрицаТовары.КодПроизводителяКонтрагента КАК КодПроизводителяКонтрагента,
				|	МатрицаТовары.НаименованиеКонтрагента КАК НаименованиеКонтрагента,
				|	МатрицаТовары.АртикулКонтрагента КАК АртикулКонтрагента,
				|	МатрицаТовары.КратностьКоробки КАК Кратность,
				|	МатрицаТовары.ШККонтрагента  КАК ШККонтрагента
				|ИЗ
				|	Документ.Матрица.Товары КАК МатрицаТовары
				|ГДЕ
				|	МатрицаТовары.Номенклатура = &Номенклатура
				|	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
				|	И МатрицаТовары.Ссылка.Договор = &Договор
				|	И МатрицаТовары.Ссылка.Проведен
				|	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата1
				|	И МатрицаТовары.Ссылка.Дата <= &Дата2
				|
				|УПОРЯДОЧИТЬ ПО
				|	МатрицаТовары.Ссылка.Дата УБЫВ
				|АВТОУПОРЯДОЧИВАНИЕ";
				ЗапросНов.УстановитьПараметр("Номенклатура",СтрокаТЗ.Номенклатура);
				ЗапросНов.УстановитьПараметр("Контрагент",Накладная.Контрагент);
				ЗапросНов.УстановитьПараметр("Договор",Накладная.Договор);
				ЗапросНов.УстановитьПараметр("Дата1",НачалоДня(ТекущаяДата()));
				ЗапросНов.УстановитьПараметр("Дата2",КонецДня(ТекущаяДата()));
				ВыборкаНов = 	ЗапросНов.Выполнить().Выбрать();
				Если ВыборкаНов.Следующий() Тогда
					
					СтрокаТЗ.ШККонтрагента = ВыборкаНов.ШККонтрагента;
					СтрокаТЗ.Артикул  = ВыборкаНов.АртикулКонтрагента;
					
				КонецЕсли;
				
			КонецЦикла;
			
			НПП = 1;
			Для Каждого СтрокаТЧ Из ТЗ Цикл
				ПараметрыСтрока = Новый Структура;
				номенклатураНаименование =СтрокаТЧ.Номенклатура.Наименование;
				НоменклатураМодель = СтрокаТЧ.Номенклатура.Родитель.Наименование;
				Если ЗначениеЗаполнено(СтрокаТЧ.ШККонтрагента) Тогда
					ШККонтрагента = СтрокаТЧ.ШККонтрагента;
				Иначе
					ШККонтрагента = СтрокаТЧ.ШКМатрицы;
				КонецЕсли;
				
				попытка
					Номенклатура = номенклатураНаименование+" "+НоменклатураМодель;
				Исключение Номенклатура  = ""; КонецПопытки;
				ПараметрыСтрока.Вставить("ШККонтрагента", ШККонтрагента);
				ПараметрыСтрока.Вставить("наименование", номенклатура);	
				ПараметрыСтрока.Вставить("количество",СтрокаТЧ.количество);
				артикул=СтрокаТЧ.Артикул;
				
				
				ПараметрыСтрока.Вставить("артикул",артикул);
								
				
				Рисунок				=ОблСтрока.Рисунки.ОбъектШКНом;
				ОбъектШК			=Рисунок.Объект;
				
				ОбъектШК.Сообщение = ШККонтрагента;
				ОблСтрока.Параметры.Нпп=НПП;//(ТекЛистНабора.Товары.Индекс(СтрокаТЧ)+1);
				НПП = НПП + 1;
				ОблСтрока.Параметры.Заполнить(ПараметрыСтрока);
				ТабДок.Вывести(ОблСтрока);
				
			КонецЦикла; 
			
			ОблИтого = Макет.ПолучитьОбласть("Итого");
			ОблИтого.Параметры.итогопостоке = ТекЛистНабора.КоличествоДокумента;
			ТабДок.Вывести(ОблИтого);
			ОблПодвал = Макет.ПолучитьОбласть("Подвал");
			ОблПодвал.Параметры.дата  = Формат(Накладная.ДатаОтгрузки,"ДФ=dd.MM.yyyy");
			ТабДок.Вывести(ОблПодвал);
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЕсли;
		
	КонецЕсли;	
	
	если МожноПечатать тогда		
		
		если ВнешнийДополнительныйТД=Неопределено тогда
			//ТабДок.Показать(ИмяПараметровПечати);
			Возврат ТабДок; 
		иначе
			
			ВнешнийДополнительныйТД.ИмяПараметровПечати = ИмяПараметровПечати;
			
			ВнешнийДополнительныйТД.Вывести(ТабДок);
		КонецЕсли;	
		
	КонецЕсли;	
	
КонецФункции

Функция ПолучитьПараметрыПечати (Накладная)
	если ложь тогда Накладная=Документы.РасходнаяНакладная.ПустаяСсылка();КонецЕсли;
	СтруктураПараметров=новый Структура;
	
	СтруктураПараметров.Вставить("СворачиватьТовары",Истина);
	СтруктураПараметров.Вставить("КолонкиГруппировки","Номенклатура");	
	СтруктураПараметров.Вставить("КолонкиСуммы","Количество");	
	СтруктураПараметров.Вставить("Макет",Неопределено);	
	СтруктураПараметров.Вставить("РаботаПоМатрица",Накладная.Контрагент.ИспользоватьНоменклатурнуюМатрицу);	
	если Накладная.контрагент.код="SSR-9059" или  Накладная.контрагент.код="SST-1208" тогда //Вайлдберриз
		попытка  
			СтруктураПараметров.Вставить("Макет",ВнешниеОбработки.Создать(Константы.КаталогВнешнихОтчетов.Получить()+"ПечатьШКWB.epf").получитьмакет("МакетНоваяКомпонента"));
			
		исключение
			возврат Неопределено;
		КонецПопытки;				
	иначе
		если Накладная.контрагент.код="SSR-5004" тогда //МАКСИМА ГРУПП
			
			попытка
				СтруктураПараметров.Вставить("Макет",ВнешниеОбработки.Создать(Константы.КаталогВнешнихОтчетов.Получить()+"ПечатьШКМГ.epf").получитьмакет("Макет"));
			исключение
				возврат Неопределено;
			КонецПопытки;				
		иначе	
			возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	возврат СтруктураПараметров;
КонецФункции

Функция ОтсканированыКоробаВЛН(Знач ДокПечати)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛистНабораШтрихкодыУпаковок.ШтрихкодУпаковки.ТипШК КАК ТипШК
	|ИЗ
	|	Документ.ЛистНабора.ШтрихкодыУпаковок КАК ЛистНабораШтрихкодыУпаковок
	|ГДЕ
	|	ЛистНабораШтрихкодыУпаковок.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДокПечати.Ссылка);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ." + ДокПечати.ссылка.Метаданные().Имя); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТипыШК = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ТипШК"); 	
	
	Если ТипыШК.Количество() > 0 
		И ТипыШК[0] = Перечисления.ТипыШтрихКодов.Коробка Тогда
		
		Возврат Истина;		
		
	КонецЕсли;
	
	Возврат Ложь; 
	
КонецФункции
//Данилова Е.В. 07.05.2026 HELP-8363 
//Данилова Е.В. 26.03.2026  SNL-153 
Процедура ПечатьЭтикеткиОнлайнНаСтрокуКороба(СтрТЗ,ДопПараметрыПечати,ДокументПечати, Макет,Докоснование,КодАгрегации = неопределено,ШтрихКодЭтикетки = неопределено)
	КодКонтрагента 						=	ДопПараметрыПечати.КодКонтрагента; 
	КодКонтрагентаРодителя 				=	ДопПараметрыПечати.КодКонтрагентаРодителя;
	КолКоробок 							= 	ДопПараметрыПечати.КолКоробок;
	МожноВыводитьОбщееКоличествоМест 	= 	ДопПараметрыПечати.МожноВыводитьОбщееКоличествоМест;
	НаборПолей							= 	ДопПараметрыПечати.НаборПолей;
	НужноОбрезать 						= 	ДопПараметрыПечати.НужноОбрезать;
	ТабДок 								= 	ДопПараметрыПечати.ТабДок;
	ТребуетсяАгрегацияКоробок 			=	ДопПараметрыПечати.ТребуетсяАгрегацияКоробок;              
	
	ОбработкаПечати						= 	ДопПараметрыПечати.ОбработкаПечати;
	Лист								=	ДокументПечати.Ссылка;
	
	//Если СтруктураДанныхКомпонентыПечати=Неопределено тогда   
	ОбработкаФормированияКартинки=Обработки.СформироватьКартинкуКодаШКQR.Создать();
	СтруктураДанныхКомпонентыПечати=ОбработкаФормированияКартинки.ПолучитьКомпонентуФормированияDataMatrixКода();	
	если не СтруктураДанныхКомпонентыПечати.Успех тогда 
		Сообщить(СтруктураДанныхКомпонентыПечати.Ошибки);
		возврат;
	КонецЕсли;      
	//КонецЕсли; 	
	
	если   ТребуетсяАгрегацияКоробок  тогда
		ОблЭтикетка=Макет.ПолучитьОбласть("Строка|Этикетка"); 
		ПечататьCode128ДляАгрегаций 		= 	ДопПараметрыПечати.ПечататьCode128ДляАгрегаций;  
	иначе 
		ОблЭтикетка=Макет.ПолучитьОбласть("СтрокаQR|Этикетка");
		ПечататьCode128ДляАгрегаций 		= 	ложь;  
	КонецЕсли;  
	
	
	если   ТребуетсяАгрегацияКоробок тогда
		ИмяОбластиНоменклатура =  "ОбластьНоменклатура";
		ИмяОбластиКороба =  "ОбластьКороба";
	иначе 
		ИмяОбластиНоменклатура =  "ОбластьНоменклатураQR"; 
		ИмяОбластиКороба =  "ОбластьКоробаQR";
	КонецЕсли;
	
	если не ТребуетсяАгрегацияКоробок тогда
		попытка
			Рисунок=ОблЭтикетка.Рисунки.QRКод;     
		Исключение  
			СообщитьИзМодуля("В области макета не обнаружено рисунка с именем QRКод");
			возврат;
		КонецПопытки;    	 
	иначе
		попытка
			Рисунок=ОблЭтикетка.Рисунки.ШтрихКод;     
		Исключение  
			СообщитьИзМодуля("В области макета не обнаружено рисунка с именем ШтрихКод");
			возврат;
		КонецПопытки;    
	КонецЕсли; 	          
	
	
	если ТипЗнч(СтрТЗ.номенклатура)=Тип("СправочникСсылка.Номенклатура") тогда
		если ЗначениеЗаполнено(СтрТЗ.ШтукВКоробке) тогда
			ШтукВКоробе=СтрТЗ.ШтукВКоробке;
		иначе
			ШтукВКоробе=СтрТЗ.номенклатура.родитель.ШтукВКоробке;
		КонецЕсли;		 
		если ШтукВКоробе>0 тогда
			НаборПолей.Вставить("ШтукВЛН"," - "+ШтукВКоробе+"шт.");	
		КонецЕсли;
	КонецЕсли;		         
	
	
	ДопПараметры = новый Структура;
	
	если не ТребуетсяАгрегацияКоробок тогда  
		
		КодЭтикетки	=  ЗакодироватьЛистИКоробкуВСтроку(Лист,СтрТЗ.НомерКоробки);
		// Кухарь А.Ю.  29.07.2025 начало
		ДопПараметры.Вставить("ТипКода",16);
		// Кухарь А.Ю.  29.07.2025 конец
		
		КартинкаКода=ОбработкаФормированияКартинки.СформироватьКартинкуШК_DataMatrix(СтруктураДанныхКомпонентыПечати,КодЭтикетки,ДопПараметры);  
		Рисунок.Картинка=КартинкаКода;      
		НаборПолей.Вставить("ШтрихКод",КодЭтикетки);
		//++Данилова Е.В. 07.05.2026 HELP-8363 
		ШтрихКодЭтикетки = КодЭтикетки; 
		//--Данилова Е.В. 07.05.2026 
	иначе
		//++Данилова Е.В. 26.03.2026  SNL-153 
		Если Не ЗначениеЗаполнено(КодАгрегации) Тогда 
			КодАгрегации=ПолучитьРеквизитШапки(Лист,"КодАгрегации","Документ"); 
		КонецЕсли;
		//--Данилова Е.В. 26.03.2026 
		Если ПечататьCode128ДляАгрегаций Тогда 
			ДопПараметры.Вставить("АгрегацииВCode128",ПечататьCode128ДляАгрегаций);
		иначе
			ДопПараметры.Вставить("ДобавлятьСкобочкиВТекст",Истина); 
		КонецЕсли;		 
		ДопПараметры.Вставить("НужнаТолькоКартинка",Истина);   
		ДопПараметры.Вставить("ОтображатьТекст",ложь); 
		ДопПараметры.Вставить("ВысотаРисунка",Рисунок.Высота);
		ДопПараметры.Вставить("ШиринаРисунка",Рисунок.Ширина);		 
		Рисунок.Картинка = ОбработкаПечати.СформироватьКА(Макет, ПолучитьРеквизитШапки(КодАгрегации,"Наименование","справочник"), 0, 0, ДопПараметры);  
		
		ПрефиксКодаАгрегации="";	
		если  ДопПараметры.Свойство("ДобавлятьСкобочкиВТекст") тогда
			если ДопПараметры.ДобавлятьСкобочкиВТекст=Истина тогда
				ПрефиксКодаАгрегации="(00)";		
			КонецЕсли;
		КонецЕсли;
		НаборПолей.вставить("ШтрихКод",ПрефиксКодаАгрегации+КодАгрегации);
		//++Данилова Е.В. 07.05.2026 HELP-8363 
		ШтрихКодЭтикетки = КодАгрегации; 
		//--Данилова Е.В. 07.05.2026
	КонецЕсли;
	
	ОблЭтикетка.Параметры.Заполнить(НаборПолей);	 	    	
	ОблЭтикетка.Параметры.номенклатура=СтрТЗ.номенклатура;  	
	
	попытка
		если СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>48 и НужноОбрезать тогда
			ОблЭтикетка.Параметры.Номенклатура=СтрЗаменить(ОблЭтикетка.Параметры.Номенклатура,"АРТ:","");
		КонецЕсли;
	Исключение
	КонецПопытки; 
	
	ОбластьНоменклатура=ОблЭтикетка.Области.Найти(ИмяОбластиНоменклатура); 
	если ОбластьНоменклатура<>Неопределено тогда
		если СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>70 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,5);
		иначеесли СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>50 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,6);
		иначеесли СтрДлина(ОблЭтикетка.Параметры.Номенклатура)>40 тогда
			ОбластьНоменклатура.шрифт=Новый Шрифт(ОбластьНоменклатура.шрифт,,7);
		КонецЕсли;
	КонецЕсли;         
	
	ОблЭтикетка.Параметры.НомерКороба=СтрТЗ.НомерКоробки;			
	
	ОбластьКороба=ОблЭтикетка.Области.Найти(ИмяОбластиКороба); 
	
	если МожноВыводитьОбщееКоличествоМест и облЭтикетка.Параметры.НомерКороба=КолКоробок  тогда			
		ОблЭтикетка.Параметры.ВсегоКоробов=КолКоробок;
	иначе       
		если ОбластьКороба<>Неопределено тогда
			ОбластьКороба.Текст=СтрЗаменить(ОбластьКороба.Текст,"из","");         
		КонецЕсли;
	КонецЕсли;
	
	
	Если КодКонтрагента = "EKF-0301" или КодКонтрагента = "SSR-1593" или КодКонтрагентаРодителя="SSR-7156" тогда	
		АдресИзРегистра=ПрочитатьЗначениеРеквизитаПНКПРМРНК("АдресДляЭтикетки",ДокОснование);
		если ЗначениеЗаполнено(АдресИзРегистра) тогда
			ОблЭтикетка.Параметры.АД=АдресИзРегистра;
		КонецЕсли;
		ОблЭтикетка.Параметры.НомерЗаказаЭтикетка=ДокОснование.НомерЗаказа;
		ОблЭтикетка.Параметры.Регион="";
		// Кухарь А.Ю.  11.06.2025 начало
		//ОблЭтикетка.Область("ГородЗаголовок").Текст="Заказ №";
		если ДопПараметрыПечати.ТребуетсяАгрегацияКоробок тогда 
			ОблЭтикетка.Область("ГородЗаголовок").Текст="Заказ №";
		иначе
			ОблЭтикетка.Область("ГородЗаголовок1").Текст="Заказ №";
		КонецЕсли;		 
		// Кухарь А.Ю.  11.06.2025 конец
		
	КонецЕсли;   
	
	ТабДок.Вывести(ОблЭтикетка);
	ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	
КонецПроцедуры

Функция НапечататьДополнительнуюЭтикеткуПоВБПоНесколькимТоварам(ПараметрыПечати,ДокОснование,докПечати,ДопПараметрыНакладной)
	
	Макет = ПараметрыПечати.Макет;
	
	ТабДокумент = Новый ТабличныйДокумент; 
	
	Для каждого СтрокаТовара Из докПечати.Товары Цикл  	
		
		СтрШК = ШКпоИндексуТекЛН(ДокОснование,СтрокаТовара.Номенклатура,ДопПараметрыНакладной,ДокПечати); 
		
		Если СтрШК = неопределено  Тогда
			
			Возврат неопределено; 	
			
		КонецЕсли;
		
		ОблЭтикетка = Макет.получитьобласть("Номенклатура");
		ОблЭтикетка.Параметры.Номенклатура = СтрокаТовара.Номенклатура;
		
		ТабДокумент.Вывести(ОблЭтикетка);
		ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		ОблЭтикетка = Макет.получитьобласть("Этикетка"); 
		
		ОбработкаПечати = Обработки.ПечатьЭтикетокЧЗ.Создать();
		Для Каждого Рисунок Из ОблЭтикетка.Рисунки Цикл
			ДопПараметры = Новый Структура; 
			ДопПараметры.Вставить("НужнаТолькоКартинка",истина);
			ДопПараметры.Вставить("ОтображатьТекст",ложь); 
			ДопПараметры.Вставить("ВысотаРисунка",Рисунок.Высота);
			ДопПараметры.Вставить("ШиринаРисунка",Рисунок.Ширина);  
			// Кухарь А.Ю.  22.07.2025 начало
			если не ДопПараметры.Свойство("БезПрефикса") тогда
				ДопПараметры.Вставить("БезПрефикса", Истина);
			иначе
				ДопПараметры.БезПрефикса = Истина;
			КонецЕсли;
			// Кухарь А.Ю.  22.07.2025 конец
			
			КартинкаКода= ОбработкаПечати.СформироватьКА(Макет,СтрШК.ШтрихКод,,,,ДопПараметры); 
			Рисунок.Картинка=КартинкаКода;
			ОблЭтикетка.Параметры.СтараяНоменклатура = СтрШК.ШтрихКод;
		КонецЦикла;
		ТабДокумент.Вывести(ОблЭтикетка);
		ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
	КонецЦикла;
	
	Возврат ТабДокумент; 
	
	
КонецФункции // НапечататьДополнительнуюЭтикеткуПоВБПоНесколькимТоварам() 

Функция ШКпоИндексуТекЛН(Накладная,Номенклатура,ДопПараметрыНакладной,ДокПечати)  Экспорт
	
	Запрос=Новый запрос;
	запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.ЗначениеРеквизита КАК ШтрихКод,
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.ИмяРеквизита КАК ИмяРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыТЧ_Товары_РНКПНКПРМ КАК РеквизитыТЧ_Товары_РНКПНКПРМ
	|ГДЕ
	|	РеквизитыТЧ_Товары_РНКПНКПРМ.Документ = &Документ
	|	И РеквизитыТЧ_Товары_РНКПНКПРМ.Номенклатура = &Номенклатура
	|	И РеквизитыТЧ_Товары_РНКПНКПРМ.ИмяРеквизита ПОДОБНО &ИмяРеквизита
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИмяРеквизита";
	Запрос.УстановитьПараметр("Документ",Накладная);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("ИмяРеквизита","Код артикула%");
	ТаблицаШК=запрос.Выполнить().Выгрузить();
	Если ТаблицаШК.Количество()=0 тогда
		// Кухарь А.Ю. 23.08.2021 начало
		// Для ФБО вайлдберриса
		если ДопПараметрыНакладной.имя<>"WB_FBS" тогда
			Сообщить("нет ШК WB, обратитесь к менеджеру");
		КонецЕсли;
		// Кухарь А.Ю. 23.08.2021 конец
		
		Возврат неопределено;
	КонецЕсли;
	
	запрос=новый запрос;
	запрос.Текст="ВЫБРАТЬ различные
	|	ЛистНабораТовары.Ссылка КАК ЛН
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.Дата >= &Дата
	|	И ЛистНабораТовары.Ссылка.Проведен
	|	И ЛистНабораТовары.Номенклатура = &Номенклатура
	|	И ЛистНабораТовары.Ссылка.ДокОснование = &Накладная
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЛистНабораТовары.Ссылка.Дата";
	запрос.УстановитьПараметр("Дата",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования()-30*24*3600);
	запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	запрос.УстановитьПараметр("Накладная",Накладная);
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","Документ." + ДокПечати.ссылка.Метаданные().Имя);
	ТаблицаЛН=запрос.Выполнить().Выгрузить();
	Если ТаблицаЛН.Количество()>ТаблицаШК.Количество() тогда  //Значит что-то не распределили или ещё какая-нибудь шляпа.
		Сообщить("Ошибка распределения ШК вайлдберрис. Проверьте этикетки на все короба.");
		возврат неопределено;
	КонецЕсли;
	
	
	ИндексТекЛН=ТаблицаЛН.Индекс(ТаблицаЛН.Найти(ДокПечати.Ссылка)); 
	
	СтрШК = ТаблицаШК.Получить(ИндексТекЛН);
	
	Возврат  СтрШК; 
	
	
КонецФункции // ИндексТекЛН()

Функция ПолучитьСвойстваНоменклатуры1(Номенклатура) Экспорт
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ЗначенияСвойствОбъектов.Объект = &Брэнд
	|			ТОГДА 1
	|		КОГДА ЗначенияСвойствОбъектов.Объект = &Модель
	|			ТОГДА 2
	|		КОГДА ЗначенияСвойствОбъектов.Объект = &Номенклатура
	|			ТОГДА 3
	|		ИНАЧЕ 4
	|	КОНЕЦ КАК Уровень,
	|	ЗначенияСвойствОбъектов.Свойство,
	|	ЗначенияСвойствОбъектов.Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	(ЗначенияСвойствОбъектов.Объект = &Модель
	|			ИЛИ ЗначенияСвойствОбъектов.Объект = &Брэнд
	|			ИЛИ ЗначенияСвойствОбъектов.Объект = &Номенклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Уровень,
	|	ЗначенияСвойствОбъектов.Объект";	
	
	Свойства=Новый Структура;
	
	Запрос.УстановитьПараметр("Модель",Номенклатура.Родитель);
	Запрос.УстановитьПараметр("Брэнд",Номенклатура.Родитель.родитель);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Попытка
			КодСвойства=СтрЗаменить(Выборка.Свойство,"""","");	
			КодСвойства=СтрЗаменить(Выборка.Свойство," ","");
			
			Свойства.Вставить(КодСвойства,Выборка.Значение);		
		Исключение
			Сообщить("Ошибочное свойство: "+Выборка.Свойство);
		КонецПопытки;		
	КонецЦикла;	
	
	Возврат Свойства;
КонецФункции
 
 Функция СформироватьКодАгрегацииНаКоробку(Знач КодАгрегации, ДокументПечатиОбъект,ДокОснование,Форма,ПравилаРаботыСАгрегациейЧЗ) 
	если ЗначениеЗаполнено(КодАгрегации) тогда
		возврат Истина;
	КонецЕсли; 
	
	ВидДокументаОснования =	ДокОснование.Метаданные().Имя;
	
	ВидДокументаПечати 	= ДокументПечатиОбъект.ссылка.Метаданные().Имя; 
	ТипШК 				=  ДокументПечатиОбъект.ТипШК; 
		
	если ДокументПечатиОбъект.ШтрихкодыКоробокДляАгрегации.Количество()> 0 тогда
		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ
		|	ТЧ.ИсходныйКодКоробки КАК ИсходныйКодКоробки
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	&ТЧ КАК ТЧ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.ИсходныйКодКоробки.Ссылка КАК ИсходныйКодКоробкиСсылка
		|ИЗ
		|	ВТ КАК ВТ
		|ГДЕ
		|	ВТ.ИсходныйКодКоробки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)";
		запрос.УстановитьПараметр("ТЧ",ДокументПечатиОбъект.ШтрихкодыКоробокДляАгрегации.Выгрузить());
		Выборка = запрос.Выполнить().Выбрать();
		пока выборка.Следующий() цикл
			возврат Истина;
		КонецЦикла;
	КонецЕсли;
	
	если ВидДокументаПечати = "ЛистНабора" 
		И ЕстьЛПСАгрегацией(ДокОснование) тогда
		Сообщить("Агрегация начата в листах переукладки");
		возврат ложь;
	КонецЕсли;
	
	если ВидДокументаОснования <> "РасходнаяНакладная"		
		И НЕ РазрешенаПечатьАгрегатаПоПНК(ТипШК,ВидДокументаОснования,ДокОснование) тогда 		 
		 
		Сообщить("Код агрегации печатается только для РНК и для ПНК Закупка Р");
		Возврат ложь;
	КонецЕсли;
	
	АгрегацияБудетВЛистахПереукладки=ОбщегоНазначения_ПИ.ПланируетсяРаботаСАгрегациейЧЗвЛП(ДокОснование);         
	Если ВидДокументаПечати = "ЛистНабора" 
		И АгрегацияБудетВЛистахПереукладки тогда
		Сообщить("Агрегацию требуется нужно выполнить по коробам, сформированных листами переукладки");
		Возврат ложь;
	КонецЕсли;
	
	если ТипШК<>Перечисления.ТипыШтрихКодов.Коробка тогда
		ШтукЧЗВКоробке = ДокументПечатиОбъект.ШтрихкодыУпаковок.Количество();
		если ШтукЧЗВКоробке=0 тогда
			Сообщить("В ЛН отсутствуют коды ЧЗ, агрегация не требуется");
			Возврат ложь;
		КонецЕсли; 		
	КонецЕсли;  
	
	если  ДокументПечатиОбъект.ШтрихкодыУпаковок.Количество()= 0 тогда
		Сообщить("Нет ни одного отсканированного кода ЧЗ в ЛН. Нечего агрегировать");
		Возврат ложь;
	КонецЕсли;
	
	если не ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок
		И НЕ РазрешенаПечатьАгрегатаПоПНК(ТипШК,ВидДокументаОснования,ДокОснование) тогда  	
		Сообщить("В правилах агрегации не указано, что требуются коробки");
		Возврат ложь
	КонецЕсли; 
	
	ТЗТовары = ДокументПечатиОбъект.товары.Выгрузить(,"Номенклатура");
	ТЗТовары.Свернуть("Номенклатура");
	если ТЗТовары.Количество()>1 тогда 
		ТипУпаковки=Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
	иначе	
		ТипУпаковки=Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	КонецЕсли;	
	 
	если  ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияБлочков тогда
		 
		РезультатПроверкиКодов = ПроверитьОтсканированныеКодыДляАгрегПоБлочкам(ДокументПечатиОбъект.ШтрихкодыУпаковок,ТипШК);
		
		Если НЕ РезультатПроверкиКодов Тогда
			
			Возврат ЛОЖЬ; 	
			
		КонецЕсли;
	КонецЕсли;

	если КодАгрегации=Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() тогда   	
		 
		ДокументПечатиОбъект.ТребуетПроверки=Истина;	
		ДокументПечатиОбъект.Проведен = Истина; 
		 
		если не Форма.Модифицированность() тогда
			если не ДокументПечатиОбъект.ДополнительныеСвойства.Свойство("УпрощенныйРежим") тогда
				ДокументПечатиОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим",Истина);
			иначе
				ДокументПечатиОбъект.ДополнительныеСвойства.УпрощенныйРежим=Истина;
			КонецЕсли;
		КонецЕсли;
		Форма.ЗаписатьВФорме();	 	
		
		РезультатПроверкиАгрегатов = Истина; 
		ФормироватьКодАгрегацииНовый = Ложь; 
		ДокументПечатиОбъект.КодАгрегации = ОтработатьПечатьКодаАгрегацииПоАгрегатам(РезультатПроверкиАгрегатов,
		ФормироватьКодАгрегацииНовый,ДокОснование,ТипШК,ПравилаРаботыСАгрегациейЧЗ, ДокументПечатиОбъект); 
		
		Если НЕ РезультатПроверкиАгрегатов Тогда
			
			Возврат Ложь; 	
			
		КонецЕсли; 
		
		если НЕ ЗначениеЗаполнено(ДокументПечатиОбъект.КодАгрегации) 
			И НЕ ФормироватьКодАгрегацииНовый 
			И Маркировка_ПИ.ЕстьПредварительноСозданыйАгрегат(ДокОснование) тогда
			
			
			Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
			
			рБронирования= Документы.МаркировкаТоваровИСМП.ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста(ДокументПечатиОбъект.ссылка,ДокОснование, Перечисления.ТипыШтрихКодов.Коробка);
			
			
			ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
			ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", "Документы.МаркировкаТоваровИСМП.ПолучитьРанееЗабронированныйКодАгрегацииДляЛиста (ЛН)", , , , ВремяВыполнения);
			
			
			Если рБронирования.Успешно тогда			
				ПолучаемыйКодАгрегации = рБронирования.Данные[0];
				запрос=новый запрос;
				запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
				|	ЛистНабора.КодАгрегации КАК КодАгрегации,
				|	ЛистНабора.Ссылка КАК Ссылка
				|ИЗ
				|	Документ.ЛистНабора КАК ЛистНабора
				|ГДЕ
				|	ЛистНабора.Проведен
				|	И ЛистНабора.КодАгрегации = &КодАгрегации
				|	И ЛистНабора.Ссылка <> &Ссылка";
				запрос.УстановитьПараметр("КодАгрегации",ПолучаемыйКодАгрегации);
				запрос.УстановитьПараметр("Ссылка",ДокументПечатиОбъект.ссылка);
				Выборка=запрос.Выполнить().Выбрать();
				пока выборка.Следующий() Цикл 
					Сообщить(СтрШаблон("Обнаружен дубль кода %1 в %2",ПолучаемыйКодАгрегации,выборка.ссылка));
					Возврат ложь;	
				КонецЦикла;
				ДокументПечатиОбъект.КодАгрегации=ПолучаемыйКодАгрегации;
				попытка
					
					если не ДокументПечатиОбъект.ДополнительныеСвойства.Свойство("УпрощенныйРежим") тогда
						ДокументПечатиОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим",Истина);
					иначе
						ДокументПечатиОбъект.ДополнительныеСвойства.УпрощенныйРежим=Истина;
					КонецЕсли;
					
					Форма.ЗаписатьВФорме();	
					
					ДокументПечатиОбъект.ДополнительныеСвойства.УпрощенныйРежим=ложь;
					
					
				Исключение     
					ДокументПечатиОбъект.КодАгрегации=Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
				КонецПопытки;
			Иначе
				МаркировкаКС.ВывестиОшибки(рБронирования);			
			КонецЕсли;
		КонецЕсли;
		
		
		если ДокументПечатиОбъект.КодАгрегации=Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() тогда
			// Кухарь А.Ю.  02.04.2025 конец
			
			Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
			
			рБронирования = Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляЛН(ДокументПечатиОбъект.ссылка, Перечисления.ТипыШтрихКодов.Коробка,ТипУпаковки);
			
			ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
			ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", "Документы.МаркировкаТоваровИСМП.ПолучитьЗабронироватьКодАгрегацииДляЛН (ЛН)", , , , ВремяВыполнения);
			
			Если рБронирования.Успешно тогда			
				ПолучаемыйКодАгрегации = рБронирования.Данные;
				запрос=новый запрос;
				запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
				|	ЛистНабора.КодАгрегации КАК КодАгрегации,
				|	ЛистНабора.Ссылка КАК Ссылка
				|ИЗ
				|	Документ.ЛистНабора КАК ЛистНабора
				|ГДЕ
				|	ЛистНабора.Проведен
				|	И ЛистНабора.КодАгрегации = &КодАгрегации
				|	И ЛистНабора.Ссылка <> &Ссылка";
				запрос.УстановитьПараметр("КодАгрегации",ПолучаемыйКодАгрегации);
				запрос.УстановитьПараметр("Ссылка",ДокументПечатиОбъект.ссылка);
				Выборка=запрос.Выполнить().Выбрать();
				пока выборка.Следующий() Цикл 
					Сообщить(СтрШаблон("Обнаружен дубль кода %1 в %2",ПолучаемыйКодАгрегации,выборка.ссылка));
					Возврат ложь;	
				КонецЦикла;
				ДокументПечатиОбъект.КодАгрегации=ПолучаемыйКодАгрегации;
				попытка
					
					если не ДокументПечатиОбъект.ДополнительныеСвойства.Свойство("УпрощенныйРежим") тогда
						ДокументПечатиОбъект.ДополнительныеСвойства.Вставить("УпрощенныйРежим",Истина);
					иначе
						ДокументПечатиОбъект.ДополнительныеСвойства.УпрощенныйРежим=Истина;
					КонецЕсли;
					
					Форма.ЗаписатьВФорме();	
					
					ДокументПечатиОбъект.ДополнительныеСвойства.УпрощенныйРежим=ложь;
					
					
				Исключение     
					ДокументПечатиОбъект.КодАгрегации=Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
				КонецПопытки;
			Иначе
				МаркировкаКС.ВывестиОшибки(рБронирования);	
				возврат Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
		
	КонецЕсли;	
	
	
	возврат Истина;
КонецФункции

Функция ПроверитьОтсканированныеКодыДляАгрегПоБлочкам(ШтрихкодыУпаковок,ТипШК)
	
	Если НЕ ПроверитьОтсканированныеШКПоТипамШК(ШтрихкодыУпаковок,ТИпШК) Тогда
		
		Возврат ЛОЖЬ; 
		
	Конецесли;
	
	Если ШтрихкодыУпаковок.Количество() = 0 Тогда
		
		Возврат ЛОЖЬ; 	
		
	КонецЕсли; 
	
	ТипШК = ШтрихкодыУпаковок[0].ШтрихкодУпаковки.ТипШК; 
	
	Если ТипШК = Перечисления.ТипыШтрихКодов.Штука Тогда
		
		МассивПустыхБлочков=ШтрихкодыУпаковок.НайтиСтроки(новый Структура("ШтрихкодБлочка",Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка()));
		если МассивПустыхБлочков.Количество()>0 тогда
			Сообщить("Закончите печать кодов на блочок.");
			Возврат ложь;
		КонецЕсли;
		
	ИначеЕсли  ТипШК = Перечисления.ТипыШтрихКодов.Блочок Тогда 
		Возврат Истина; 
	Иначе
		Сообщить("Печать кода коробки или по блочкам или по штукам.");
		Возврат Ложь; 
	КонецЕсли;
	
	Возврат истина; 
	
КонецФункции

Функция ПроверитьОтсканированныеШКПоТипамШК(ШтрихкодыУпаковок,ТипШК)
	
	ТипыШтрихСоответств = Новый Соответствие; 
	Для каждого СтрокаШК из ШтрихкодыУпаковок цикл
		ТипыШтрихСоответств.Вставить(СтрокаШК.ШтрихкодУпаковки.ТипШК,истина); 			
	КонецЦикла;
	Если ТипыШтрихСоответств.Количество() > 0  
		И ТипыШтрихСоответств.Получить(ТипШК)  = неопределено Тогда 
		Сообщить("В документе присутствуют уже коды с другим типом ШК!! - " + Строка(ШтрихкодыУпаковок[0].ШтрихкодУпаковки.ТипШК));
		
		Возврат Ложь; 
		
	КонецЕсли;
	
	Возврат Истина; 
	
	
КонецФункции

Функция РазрешенаПечатьАгрегатаПоПНК(ТипШК,ВидДокументаОснования,ДокОснование)
	
	РазрешенаПечать = 
	ТипШК <> перечисления.ТипыШтрихКодов.Коробка
	И ВидДокументаОснования = "ПриходнаяНакладная" 
	И  ПолучитьРеквизитШапки(ДокОснование,"КодОперации","Документ") = Перечисления.КодыОперацийОстатки.ЗакупкаР; 
	
    Возврат РазрешенаПечать; 
КонецФункции

Функция ОтработатьПечатьКодаАгрегацииПоАгрегатам(РезультатПроверкиПоАгрегатам,ФормироватьКодАгрегата,ДокОснование,ТипШК,ПравилаРаботыСАгрегациейЧЗ, Докпечати)
	ВидДокументаОснования = ДокОснование.Метаданные().Имя; 
	
	Если НЕ ПравилаРаботыСАгрегациейЧЗ.ТребуетсяАгрегацияКоробок 
		
		И НЕ РазрешенаПечатьАгрегатаПоПНК(ТипШК,ВидДокументаОснования,ДокОснование) тогда 
		
		Сообщить("В правилах агрегации не указано, что требуются коробки");
		
		РезультатПроверкиПоАгрегатам = Ложь;
		
		Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(); 
		
	КонецЕсли;
	
	ТипыШтрихСоответств = Новый Соответствие; 
	Для каждого СтрокаШК из Докпечати.ШтрихкодыУпаковок цикл
		ТипыШтрихСоответств.Вставить(СтрокаШК.ШтрихкодУпаковки.ТипШК,истина); 			
	КонецЦикла; 
	
	Если ТипыШтрихСоответств.Получить(Перечисления.ТипыШтрихКодов.Коробка) <> неопределено Тогда 
		
		Если  ДокПечати.ШтрихкодыУпаковок.Количество()  > 1 тогда
			
			Сообщить("Для печати кода агрегации по коробке может быть отсканирована только одна коробка!!!"); 
			
			РезультатПроверкиПоАгрегатам = Ложь; 
			
			Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(); 
			
		Иначе 
			
			ФормироватьКодАгрегата = истина;
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СтатусыКМ_ФактСрезПоследних.ШтрихКодУпаковки КАК ШтрихКодУпаковки
			|ИЗ
			|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(, ШтрихКодУпаковки в (&ШК)) КАК СтатусыКМ_ФактСрезПоследних
			|ГДЕ
			|	СтатусыКМ_ФактСрезПоследних.Статус В(&Статусы)";
			
			СтатусыМассив = Новый Массив; 
			СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.ВОбороте);
			СтатусыМассив.Добавить(Перечисления.СтатусыКодовМаркировкиФакт.Нанесен);
			Запрос.УстановитьПараметр("ШК", Докпечати.ШтрихкодыУпаковок[0].ШтрихкодУпаковки);
			Запрос.УстановитьПараметр("Статусы",СтатусыМассив);  
			РезультатЗапроса = Запрос.Выполнить();
			
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				Возврат Докпечати.ШтрихкодыУпаковок[0].ШтрихкодУпаковки; 
			Иначе 
				
				Сообщить("Отсканированный код не в обороте, будет сформирован новый агрегационный код");
				Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка(); 
			КонецЕсли;	
			
		КонецЕсли; 
	Иначе 
		РезультатПроверкиПоАгрегатам = Истина;
		//++Данилова Е.В. 15.06.2026 0000001470
		Возврат Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
		//--Данилова Е.В. 15.06.2026 
	КонецЕсли; 
	
	
КонецФункции
 
Функция ЭтикеткаОнлайнСтарая(ДокументПечатиОбъект, Форма, ДопПараметры,ВнешнийТД = Неопределено,ВнешнийДополнительныйТД = Неопределено) экспорт
	ВидДокументаПечати =  ДокументПечатиОбъект.ссылка.Метаданные().Имя;
	если не ДокументПечатиОбъект.ЭтоНовый() тогда
		если ВидДокументаПечати = "ЛистНабора"
			И ПолучитьРеквизитШапки(ДокументПечатиОбъект.Ссылка,"ШКЛистаНабора","Документ")="" и ДокументПечатиОбъект.ШКЛистаНабора<>"" тогда
			Форма.ЗаписатьВФорме();
		КонецЕсли;
		если ВидДокументаПечати = "ЛистПереукладки"
			И ПолучитьРеквизитШапки(ДокументПечатиОбъект.Ссылка,"ШтрихКод","Документ")="" и ДокументПечатиОбъект.штрихкод<>"" тогда
			Форма.ЗаписатьВФорме();
		КонецЕсли;
	КонецЕсли;
	
	КодАгрегации 				= ДопПараметры.КодАгрегации;
	//ВнешнийТД					= ДопПараметры.ВнешнийТД;
	ЭтоУзел_Склад 				= ДопПараметры.ЭтоУзел_Склад;
	ДопПараметрыНакладной 		= ДопПараметры.ДопПараметрыНакладной;
	КоличествоЕдиниц 			= ДопПараметры.КоличествоЕдиниц;
	ПравилаРаботыСАгрегациейЧЗ 	= ДопПараметры.ПравилаРаботыСАгрегациейЧЗ;
	//КоличествоЕдиниц 			= ДопПараметры.КоличествоЕдиниц; 
	СтруктураРезультат = Новый Структура("Успех,ТабДокумент,ТабДокументДоп,ЗаменятьЭтикеткуОнлайн,Ошибки,СтараяЭтикеткаОнлайн",
	Ложь,Новый ТабличныйДокумент,Неопределено,ложь,Новый Массив,Ложь); 
	
	ДокОснование = ДокументПечатиОбъект.ДокОснование; 
	МетаДок						=	ДокОснование.Метаданные();	
	ВидДокументаОснования		=	МетаДок.Имя; 
	
	 
	
	
	КодКонтрагента=ДокОснование.Контрагент.Код; 
	КодКонтрагентаРодителя=ДокОснование.Контрагент.Родитель.Код;
	//  
	ТипШК = ДокументПечатиОбъект.ТипШК; 
	если ВнешнийТД=Неопределено тогда 
			
		Если  ЭтоУзел_Склад и ПараметрыСеанса.ЭтотУзел.Код<>"RI2" и (ВидДокументаОснования="РасходнаяНакладная" или ВидДокументаОснования="Перемещение") тогда	
			// Кухарь А.Ю. 12.10.2021 начало
			//  У некоторых количество единиц в целях ускорения решили не контролировать
			если ДопПараметрыНакладной<>Неопределено и ДопПараметрыНакладной.НеКонтролироватьКоличествоЕдиниц тогда 
			иначе
				// Кухарь А.Ю. 12.10.2021 конец
				
				Если ТипШК=Перечисления.ТипыШтрихКодов.Коробка
					И ВидДокументаПечати = "ЛистНабора" тогда
					ТекКоличествоКоробок=0;	
					Для Каждого СтрокаТз из ДокументПечатиОбъект.Товары цикл
						ТекКоличествоКоробок=ТекКоличествоКоробок+?(СтрокаТЗ.ШтВКоробе=0,СтрокаТз.Количество,СтрокаТз.Количество/СтрокаТз.ШтВКоробе);
					Конеццикла;			
					
					Если КоличествоЕдиниц<>ТекКоличествоКоробок тогда 
						//++Данилова Е.В. 19.03.2026 без задачи 
						//Предупреждение("Не совпало расчётное количество единиц с фактическим"); 
						Сообщить("Не совпало расчётное количество единиц с фактическим");
						//--Данилова Е.В. 19.03.2026 
						Возврат СтруктураРезультат;
					КонецЕсли;			
				Иначе
					Если ВидДокументаПечати = "ЛистНабора" 
						И КоличествоЕдиниц<>ДокументПечатиОбъект.Товары.Итог("Количество") тогда
						//++Данилова Е.В. 19.03.2026 без задачи
						//Предупреждение("Не совпало расчётное количество единиц с фактическим"); 
						Сообщить("Не совпало расчётное количество единиц с фактическим"); 
						//--Данилова Е.В. 19.03.2026
						Возврат СтруктураРезультат;
					КонецЕсли;
				КонецЕсли;
				
				
			КонецЕсли; 
			
			//++Данилова Е.В. 04.03.2026 SNL-153
			Если ВидДокументаПечати = "ЛистПереукладки" Тогда 
				РезультатПроверки = ДокументПечатиОбъект.СверитьКолШтВКоробке();
				Если НЕ РезультатПроверки.Успешно Тогда			
					Для каждого СтрПроверки Из РезультатПроверки.ошибки Цикл
						
						СтруктураРезультат.Ошибки.Добавить(СтрПроверки); 	
						
					КонецЦикла; 
					Возврат СтруктураРезультат;  
				КонецЕсли;
			КонецЕсли;
			//--Данилова Е.В. 04.03.2026

		КонецЕсли;
			
		
		Если ДокументПечатиОбъект.ЭтоНовый() тогда
			//Кухарь 07.06.17 начало
			//Небольшой костыль
			//ЭтотОбъект.Записать(РежимЗаписиДокумента.Проведение);
			//ПеремОтказ=ложь;
			//ПередЗаписью(ПеремОтказ,РежимЗаписиДокумента.Проведение,Неопределено);
			//Если ПеремОтказ=ложь тогда  				 
			РезультатЗаписи = 	Форма.ЗаписатьВФорме(РежимЗаписиДокумента.Проведение); 			 
			Если РезультатЗаписи = Ложь Тогда
				
				Сообщить("Не удалось провести документ"); 
				Возврат СтруктураРезультат; 
				
			КонецЕсли;
			
			//КонецЕсли;
		Иначе 
			
			
			если ДопПараметрыНакладной<>Неопределено и (ДопПараметрыНакладной.имя="WB_FBS" или ДопПараметрыНакладной.имя="OZON_FBS") тогда				
				// Кухарь А.Ю. 24.02.2025 конец
				
				НужноПроводить= не ПолучитьРеквизитШапки(ДокументПечатиОбъект.Ссылка,"Проведен","Документ");
				если НужноПроводить тогда
					//ПеремОтказ=ложь;
					ДокументПечатиОбъект.Дата=ТекущаяДатаСеанса();
					//ПередЗаписью(ПеремОтказ,РежимЗаписиДокумента.Проведение,Неопределено);
					//Если ПеремОтказ=ложь тогда
						 
					РезультатЗаписи = Форма.ЗаписатьВФорме(РежимЗаписиДокумента.Проведение); 			 
					Если РезультатЗаписи = Ложь Тогда
						
						Сообщить("Не удалось провести документ"); 
						Возврат СтруктураРезультат; 
						
					КонецЕсли;	
					
					//КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			
		КонецЕсли;           
		
		если не ОбщегоНазначения_ПИ.ПечататьКоробныеЭтикеткиНовойКомпонентой(ДокОснование) тогда
			
			если ВидДокументаПечати = "Листнабора" Тогда 
				запрос=новый Запрос;
				запрос.Текст="ВЫБРАТЬ
				|	ЛистНабора.ШКЛистаНабора,
				|	ЛистНабора.Ссылка
				|ИЗ
				|	Документ.ЛистНабора КАК ЛистНабора
				|ГДЕ
				|	ЛистНабора.Дата >= &Дата
				|	И ЛистНабора.ШКЛистаНабора = &ШКЛистаНабора
				|
				|СГРУППИРОВАТЬ ПО
				|	ЛистНабора.ШКЛистаНабора,
				|	ЛистНабора.Ссылка";
				запрос.УстановитьПараметр("Дата",НачалоДня(ДокументПечатиОбъект.Дата));
				запрос.УстановитьПараметр("ШКЛистаНабора",ДокументПечатиОбъект.ШКЛистаНабора);
				результат=запрос.Выполнить().Выгрузить();
				если результат.Количество()>1 тогда
					ДокументПечатиОбъект.ШКЛистаНабора="";
					 
					Форма.ЗаписатьВФорме(РежимЗаписиДокумента.Проведение); 			 
					
					
					Сообщить("Неудачная попытка распечатать этикетку, попробуйте ещё раз.");
					
					Возврат СтруктураРезультат;
					
					
				КонецЕсли; 
			Иначе
				запрос=новый Запрос;
				запрос.Текст="ВЫБРАТЬ
				             |	ЛистНабораДок.Штрихкод КАК Штрихкод,
				             |	ЛистНабораДок.Ссылка КАК Ссылка
				             |ИЗ
				             |	Документ.ЛистПереукладки КАК ЛистНабораДок
				             |ГДЕ
				             |	ЛистНабораДок.Дата >= &Дата
				             |	И ЛистНабораДок.Штрихкод = &Штрихкод
				             |
				             |СГРУППИРОВАТЬ ПО
				             |	ЛистНабораДок.Штрихкод,
				             |	ЛистНабораДок.Ссылка";
				запрос.УстановитьПараметр("Дата",НачалоДня(ДокументПечатиОбъект.Дата));
				запрос.УстановитьПараметр("Штрихкод",ДокументПечатиОбъект.Штрихкод);
				результат=запрос.Выполнить().Выгрузить();
				если результат.Количество()>1 тогда
					ДокументПечатиОбъект.Штрихкод="";
					 
					Форма.ЗаписатьВФорме(РежимЗаписиДокумента.Проведение); 			 
					
					
					Сообщить("Неудачная попытка распечатать этикетку, попробуйте ещё раз.");
					
