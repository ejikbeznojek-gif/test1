				ТекНоменклатура = "Номенклатура: Сборная ("+ ЛН.ГруппыТоваров+")";
			иначе
				ТекНоменклатура = "АРТ: "+ ЛН.товары.получить(0).Номенклатура;
			КонецЕсли;
		КонецЕсли;
		СтрТЗ.ШтукВКоробке=ТекШтукВКоробке; 
		СтрТЗ.номенклатура=ТекНоменклатура;
		
		Если НЕ ЭтоЛН
			и ЗначениеЗаполнено(НомерКоробкиПоЛП) Тогда
		
			СтрТЗ.НомерКоробки = НомерКоробкиПоЛП; 	
		
		КонецЕсли;
				
	КонецЦикла;
	
	Если ЭтоЛН Тогда
		ПереформироватьТаблицуНомеров = Ложь; 
		Если ТаблицаНомеров.Количество() <> ТЗ.Количество() Тогда
			
			ТаблицаНомеров.Очистить();
			//++Данилова Е.В. 13.05.2026 HELP-9756
			//ТаблицаНомеров = ПолучитьНомерКоробкиПоЛистуНабора(ЛН,ТЗ);
			ТаблицаНомеров = ПолучитьНомерКоробкиПоЛистуНабора(ЛН,ТЗ,,ЗаписыватьВРС);
			 //--Данилова Е.В. 13.05.2026 
			ПереформироватьТаблицуНомеров = Истина; 
		Иначе
			 
			Для каждого СтрокаТЗ Из ТЗ Цикл                
				// Кухарь А.Ю.  07.04.2026 начало
				если ТипЗнч(СтрокаТЗ.Номенклатура) = Тип("Строка") и СтрДлина(СтрокаТЗ.Номенклатура)>150 тогда 
					СтрокаТЗ.Номенклатура = Лев(СтрокаТЗ.Номенклатура,150);
				КонецЕсли;				 
				// Кухарь А.Ю.  07.04.2026 конец
				
			    ОтборНом = Новый Структура("Номенклатура",СтрокаТЗ.Номенклатура); 
				СтрокиИзНомеров = ТаблицаНомеров.НайтиСтроки(ОтборНом);
				Если  СтрокиИзНомеров.Количество() > 1 Тогда
					ОтборНом = Новый Структура("Номенклатура,НомерСтроки",СтрокаТЗ.Номенклатура,СтрокаТЗ.НомерКоробкиЛН);
					СтрокиИзНомеров = ТаблицаНомеров.НайтиСтроки(ОтборНом);
					Если СтрокиИзНомеров.Количество() > 0 Тогда
						
						СтрокаТЗ.НомерКоробки = СтрокиИзНомеров[0].НомерКоробки;	
					Иначе 
						ПереформироватьТаблицуНомеров = Истина; 
						Прервать;
					КонецЕсли;
					
				ИначеЕсли СтрокиИзНомеров.Количество() > 0 Тогда
					СтрокаТЗ.НомерКоробки = СтрокиИзНомеров[0].НомерКоробки;
				Иначе 
					ПереформироватьТаблицуНомеров = Истина; 
					Прервать; 
					
				КонецЕсли;
			     
			КонецЦикла;
			
			Если ПереформироватьТаблицуНомеров Тогда
			    //++Данилова Е.В. 13.05.2026 HELP-9756 
				//ТаблицаНомеров = ПолучитьНомерКоробкиПоЛистуНабора(ЛН,ТЗ);
				ТаблицаНомеров = ПолучитьНомерКоробкиПоЛистуНабора(ЛН,ТЗ,,ЗаписыватьВРС);
				//--Данилова Е.В. 13.05.2026
			
			КонецЕсли;
			
		КонецЕсли; 
		
		Если ПереформироватьТаблицуНомеров Тогда
			
			Для каждого СтрокаТЗ Из ТЗ Цикл
				ОтборНом = Новый Структура("Номенклатура",СтрокаТЗ.Номенклатура); 
				СтрокиИзНомеров = ТаблицаНомеров.НайтиСтроки(ОтборНом);
				Если  СтрокиИзНомеров.Количество() > 1 Тогда
					ОтборНом = Новый Структура("Номенклатура,НомерСтроки",СтрокаТЗ.Номенклатура,СтрокаТЗ.НомерКоробкиЛН);
					СтрокиИзНомеров = ТаблицаНомеров.НайтиСтроки(ОтборНом);
					Если СтрокиИзНомеров.Количество() > 0 Тогда
						СтрокаТЗ.НомерКоробки = СтрокиИзНомеров[0].НомерКоробки; 
					КонецЕсли;
				ИначеЕсли СтрокиИзНомеров.Количество() > 0 Тогда
					СтрокаТЗ.НомерКоробки = СтрокиИзНомеров[0].НомерКоробки;
				КонецЕсли;
				
			КонецЦикла; 		
			
		КонецЕсли;
		
		ДанныеДляПерезаписиНомеров = ТаблицаНомеров; 
		
	КонецЕсли;
	
	Возврат ТЗ;	


КонецФункции // ПолучитьСписокШКкоробокЛистаНабора()

Процедура ПерезаполнитьНомераКоробок(ЛистОбъект,ДанныеДляПерезаполнения) Экспорт 

	Если ДанныеДляПерезаполнения  = Неопределено Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	Если ТипЗнч(ЛистОбъект) = Тип("ДокументОбъект.ЛистНабора")
		И ТипЗнч(ДанныеДляПерезаполнения) = Тип("ТаблицаЗначений") Тогда
		Если НЕ ТаблицыНомераКоробокИдентичны(ЛистОбъект.НомераКоробок.выгрузить(),ДанныеДляПерезаполнения) Тогда 
			ЛистОбъект.НомераКоробок.Очистить(); 
			ЛистОбъект.НомераКоробок.Загрузить(ДанныеДляПерезаполнения);
			//++Данилова Е.В. 05.05.2026 HELP-9636 
			Попытка
				ЛистОбъект.Записать();
			Исключение
				Обработки.ПечатьЛистаНабора.ОчиститьРегистрНомераКоробокСПредварСверкой(ЛистОбъект.ссылка); 
			КонецПопытки; 
			//--Данилова Е.В. 05.05.2026 
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ЛистОбъект) = Тип("ДокументОбъект.ЛистПереукладки")
		И ТипЗнч(ДанныеДляПерезаполнения) = Тип("Число") Тогда
		Если ЛистОбъект.НомерКоробки <> ДанныеДляПерезаполнения Тогда
			
			ЛистОбъект.НомерКоробки = ДанныеДляПерезаполнения;	
			//++Данилова Е.В. 05.05.2026 HELP-9636 
			Попытка
				ЛистОбъект.Записать();
			Исключение
				Обработки.ПечатьЛистаНабора.ОчиститьРегистрНомераКоробокСПредварСверкой(ЛистОбъект.ссылка); 
			КонецПопытки; 
			//--Данилова Е.В. 05.05.202
		КонецЕсли; 
	
	КонецЕсли;
	
	 

КонецПроцедуры // ПерезаписатьНомераКоробок()

Функция ТаблицыНомераКоробокИдентичны(ТЧ1,ТЧ2)Экспорт
   	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЧ1",ТЧ1);
	Запрос.УстановитьПараметр("ТЧ2",ТЧ2);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧ1.НомерКоробки КАК НомерКоробки,
		|	ТЧ1.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТЧ1
		|ИЗ
		|	&ТЧ1 КАК ТЧ1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧ2.НомерКоробки КАК НомерКоробки,
		|	ТЧ2.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТЧ2
		|ИЗ
		|	&ТЧ2 КАК ТЧ2
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТЧ1.НомерКоробки КАК НомерКоробки,
		|	ТЧ2.НомерКоробки КАК НомерКоробки1
		|ИЗ
		|	ТЧ1 КАК ТЧ1
		|		ПОЛНОЕ СОЕДИНЕНИЕ ТЧ2 КАК ТЧ2
		|		ПО ТЧ1.НомерКоробки = ТЧ2.НомерКоробки
		|			И ТЧ1.Номенклатура = ТЧ2.Номенклатура
		|ГДЕ
		|	(ТЧ1.НомерКоробки ЕСТЬ NULL
		|			ИЛИ ТЧ2.НомерКоробки ЕСТЬ NULL
		|			ИЛИ ТЧ1.Номенклатура ЕСТЬ NULL
		|			ИЛИ ТЧ2.Номенклатура ЕСТЬ NULL)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Пустой(); 	

КонецФункции // СравнитьТаблицы()

 
