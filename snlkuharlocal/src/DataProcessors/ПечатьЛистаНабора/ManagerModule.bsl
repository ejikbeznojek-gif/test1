  Функция ПроверитьЗанятыеНомераБезЗаписиВЛист(Знач ДокОснование, Знач Лист) Экспорт
	  Если ТипЗнч(Лист) = Тип("ДокументСсылка.ЛистНабора") Тогда
		  
		  Запрос = Новый Запрос;
		  Запрос.Текст = 
		  "ВЫБРАТЬ
		  |	НомераКоробокПоЛистам.ДокОснование КАК ДокОснование,
		  |	НомераКоробокПоЛистам.Лист КАК Лист
		  |ИЗ
		  |	РегистрСведений.НомераКоробокПоЛистам КАК НомераКоробокПоЛистам
		  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистНабора.НомераКоробок КАК ЛистНабораНомераКоробок
		  |		ПО НомераКоробокПоЛистам.Лист = ЛистНабораНомераКоробок.Ссылка
		  |ГДЕ
		  |	НомераКоробокПоЛистам.ДокОснование = &ДокОснование
		  |	И ЛистНабораНомераКоробок.Ссылка ЕСТЬ NULL
		  |	И НомераКоробокПоЛистам.Лист ССЫЛКА Документ.ЛистНабора";  	  
		  
	  Иначе 
		  Запрос = Новый Запрос;
		  Запрос.Текст = 
		  "ВЫБРАТЬ
		  |	НомераКоробокПоЛистам.ДокОснование КАК ДокОснование,
		  |	НомераКоробокПоЛистам.Лист КАК Лист
		  |ИЗ
		  |	РегистрСведений.НомераКоробокПоЛистам КАК НомераКоробокПоЛистам
		  |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистПереукладки КАК ЛистПереукладкиДок
		  |		ПО НомераКоробокПоЛистам.Лист = ЛистПереукладкиДок.Ссылка
		  |ГДЕ
		  |	НомераКоробокПоЛистам.ДокОснование = &ДокОснование
		  |	И ЛистПереукладкиДок.НомерКоробки = 0
		  |	И НомераКоробокПоЛистам.Лист ССЫЛКА Документ.ЛистПереукладки";  	  
		 
	  КонецЕсли;
	  Запрос.УстановитьПараметр("ДокОснование", ДокОснование);
	  РезультатЗапроса = Запрос.Выполнить();
	  
	  ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();  	  
	  
	  Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		  РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(ВыборкаДетальныеЗаписи.Лист); 
	  КонецЦикла; 
  КонецФункции // ПроверитьЗанятыеНомераБезЗаписиВЛист()
