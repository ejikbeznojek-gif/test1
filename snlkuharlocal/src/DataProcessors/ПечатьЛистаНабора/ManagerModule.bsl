 Функция КодАгрегацииИзТЧШтрихкодов(Знач ТаблицаКодовКоробок)  Экспорт
	 Результат = маркировкаКС.СтруктураРезультата(истина); 
	 Если ТаблицаКодовКоробок.Количество() = 1 тогда
		 запрос=новый запрос;
		 запрос.Текст="ВЫБРАТЬ
		              |	ВЫРАЗИТЬ(ТЧ.НовыйКодКоробки КАК Справочник.ШтрихкодыУпаковокТоваров) КАК НовыйКодКоробки
		              |ПОМЕСТИТЬ ВТ
		              |ИЗ
		              |	&ТЧ КАК ТЧ
		              |;
		              |
		              |////////////////////////////////////////////////////////////////////////////////
		              |ВЫБРАТЬ
		              |	ВТ.НовыйКодКоробки КАК НовыйКодКоробки
		              |ИЗ
		              |	ВТ КАК ВТ
		              |ГДЕ
		              |	ВТ.НовыйКодКоробки.ТипШК = ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Коробка)";
		 запрос.УстановитьПараметр("ТЧ",ТаблицаКодовКоробок);
		 Выборка = Запрос.Выполнить().Выбрать(); 
		 Если Выборка.Следующий() Тогда
			 
			 Результат.Данные = Выборка.НовыйКодКоробки; 	
			 
		 КонецЕсли;
	 ИначеЕсли ТаблицаКодовКоробок.Количество() > 1 тогда 
		  Результат.Успешно = Ложь; 
		  Результат.Ошибки.Добавить("Отсканированы коробки в ЧЗ!!Код не может быть распечатан!!"); 
	 КонецЕсли;
	 
	 Возврат Результат; 
	 
 КонецФункции // КодАгрегацииИзТЧ()
  
