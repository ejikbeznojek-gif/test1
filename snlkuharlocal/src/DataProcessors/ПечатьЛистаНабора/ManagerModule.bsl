	ТаблицаНомеров.Колонки.Добавить("Номенклатура");
	
	НомерКоробкиПоЛП = ""; 
	Если ТипЗнч(ЛН) = Тип("ДокументСсылка.ЛистПереукладки") 
		или ТипЗнч(ЛН) = Тип("ДокументОбъект.ЛистПереукладки") Тогда
	    //++Данилова Е.В. 13.05.2026 HELP-9756 
		//НомерКоробкиПоЛП = Обработки.ПечатьЛистаНабора.ПолучитьНомерКоробкиПоЛистуПереукладки(ЛН);
		НомерКоробкиПоЛП = Обработки.ПечатьЛистаНабора.ПолучитьНомерКоробкиПоЛистуПереукладки(ЛН,,ЗаписыватьВРС);
		//--Данилова Е.В. 13.05.2026 
		ДанныеДляПерезаписиНомеров = НомерКоробкиПоЛП; 
		
	КонецЕсли;
	
	Если ЭтоЛН Тогда
		
		ТаблицаНомеров = ЛН.НомераКоробок.Выгрузить();
			
	КонецЕсли;
	
	Для Сч=1 по ЛН.КоличествоКоробок Цикл 
		СтрТЗ=тз.Добавить();
		СтрТЗ.НомерКоробкиЛН = сч;
		
		если не ПечатьПоНовому тогда		
			
			Если ЭтоЛН
				И Не ЗначениеЗаполнено(ЛН.ШКЛистаНабора) Тогда  
				ТекШК = ""; 	
			Иначеесли ЭтоЛН тогда
				
				ТекШК=ЛН.ШКЛистаНабора+формат(Сч,"ЧЦ=5; ЧВН=");
				ТекШК=ТекШК+КонтрольныйСимволEAN(ТекШК,13);
			иначе
				ТекШК=ЛН.ШтрихКод;		
			КонецЕсли;
			
		Иначе
			
		КонецЕсли;			
		
		СтрТЗ.ШК=ТекШК;
		
		если лн.ТипШК=Перечисления.ТипыШтрихКодов.Коробка и ТабНоменклатурыПоКоробам.Количество()>0 тогда
			ТекСтрокаНоменклатурыПоКоробам= ТабНоменклатурыПоКоробам.Получить(Сч-1);
			ТекНоменклатура=ТекСтрокаНоменклатурыПоКоробам.номенклатура;
			ТекШтукВКоробке=ТекСтрокаНоменклатурыПоКоробам.ШтукВКоробке;			 
		иначе
			ТекШтукВКоробке=ЛН.КоличествоДокумента; 
			если ЛН.товары.количество()>1 тогда
				ТекНоменклатура = ЛН.ГруппыТоваров+" mix";
