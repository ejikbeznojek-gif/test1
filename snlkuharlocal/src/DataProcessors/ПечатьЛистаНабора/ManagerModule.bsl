 //++Данилова Е.В. 05.05.2026  HELP-9636 
 Процедура ОчиститьРегистрНомераКоробокСПредварСверкой(Знач Лист) Экспорт
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	НомераКоробокПоЛистам.ДокОснование КАК ДокОснование,
	 |	НомераКоробокПоЛистам.НомерКоробки КАК НомерКоробки
	 |ИЗ
	 |	РегистрСведений.НомераКоробокПоЛистам КАК НомераКоробокПоЛистам
	 |ГДЕ
	 |	НомераКоробокПоЛистам.Лист = &Лист
	 |	И НомераКоробокПоЛистам.ДокОснование = &ДокОснование";
	 
	 Запрос.УстановитьПараметр("ДокОснование", Лист.ДокОснование);
	 Запрос.УстановитьПараметр("Лист", Лист);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 Если РезультатЗапроса.Пустой() Тогда
		 
		 Возврат; 	
		 
	 КонецЕсли;
	 
	 Выборка = РезультатЗапроса.Выбрать(); 
	  
	 
	 Если ТипЗнч(Лист) = Тип("ДокументСсылка.ЛистПереукладки") Тогда
		 
		 Выборка.Следующий();
		 Если НЕ ЗначениеЗаполнено(Лист.НомерКоробки)
			 ИЛИ Лист.НомерКоробки <> Выборка.НомерКоробки Тогда
			 
			 РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(Лист);  
			 
		 КонецЕсли;
	 ИначеЕсли ТипЗнч(Лист) = Тип("ДокументСсылка.ЛистНабора") Тогда
		 
		 Если Лист.НомераКоробок.Количество() = 0   Тогда
			 
			 РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(Лист); 
		 Иначе
			 ОчиститьРС = Ложь; 
			 Пока Выборка.Следующий()  Цикл
				 
				 НомерКоробки = Выборка.НомерКоробки; 
				 Отбор = Новый Структура("НомерКоробки",НомерКоробки); 
				 СтрокиНайденные = Лист.НомераКоробок.НайтиСтроки(Отбор); 	 
				 Если СтрокиНайденные.Количество() = 0  Тогда
					 
					 ОчиститьРС = Истина; 	
					 Прервать; 
				 КонецЕсли;
			 КонецЦикла;
			 Если ОчиститьРС Тогда
				 
				 РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(Лист);	
				 
			 КонецЕсли;		 
			 
		 КонецЕсли;
		 
		 
	 КонецЕсли;
	 
 КонецПроцедуры // ОчиститьРегистрНомераКоробокСПредварСверкой()
 
