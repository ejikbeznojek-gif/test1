		// Кухарь А.Ю. 06.10.2020 конец
		
		
		ОблЭтикетка.Параметры.НомерКороба=СтрТЗ.НомерКоробки;	
		
		если ДокОснование.Контрагент.Код = "SSR-9059" или ДокОснование.Контрагент.Код = "SST-1208" тогда	 
			// Кухарь А.Ю.  06.08.2024 конец
			
			если МоноКороба = Истина тогда
				СтрТЗВБ=тзвб.Найти(ДокументПечатиОбъект.товары.Получить(0).Номенклатура);
				ОблЭтикетка.Параметры.НомерКороба=СтрТЗВБ.НомерСтроки;
						
				запрос=новый запрос;
				запрос.Текст= "ВЫБРАТЬ ПЕРВЫЕ 1
				|	ЛистНабораДок.ШКЛистаНабора КАК ШКЛистаНабора
				|ИЗ
				|	Документ.ЛистНабора КАК ЛистНабораДок
				|ГДЕ
				|	ЛистНабораДок.Дата >= &Дата1
				|	И ЛистНабораДок.ДокОснование = &ДокОснование
				|	И ЛистНабораДок.Проведен
				|	И ЛистНабораДок.Товары.Номенклатура = &Номенклатура
				|	И ЛистНабораДок.Ссылка <> &Ссылка
				|	И ЛистНабораДок.Дата < &Дата2
				|
				|УПОРЯДОЧИТЬ ПО
				|	ЛистНабораДок.Дата";
				запрос.УстановитьПараметр("Дата1",ОбщегоНазначения_ПИ.Константа_ДатаЗапретаРедактирования());
				запрос.УстановитьПараметр("ДокОснование",ДокОснование);
				запрос.УстановитьПараметр("Ссылка",ДокументПечатиОбъект.Ссылка);
				запрос.УстановитьПараметр("Дата2",ДокументПечатиОбъект.Дата);
				запрос.УстановитьПараметр("Номенклатура",ДокументПечатиОбъект.Товары.Получить(0).Номенклатура);
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ЛистНабора","документ." + ВидДокументаПечати);
				Если ВидДокументаПечати = "ЛистПереукладки"  Тогда
				
					Запрос.Текст = СтрЗаменить(Запрос.Текст,"ЛистНабораДок.ШКЛистаНабора","ЛистНабораДок.ШтрихКод");	
				
				КонецЕсли;
				СтарыеЛН=запрос.Выполнить().Выбрать();
				
				пока СтарыеЛН.Следующий() цикл
					ТекШК=СтарыеЛН.ШКЛистаНабора+формат(1,"ЧЦ=5; ЧВН=");
					ТекШК=ТекШК+КонтрольныйСимволEAN(ТекШК,13);
					Для Каждого Рисунок Из ОблЭтикетка.Рисунки Цикл				
						Если Рисунок.Имя="ШКОбъект" Тогда
							ОбъектШК			=Рисунок.Объект;
							ОбъектШК.Сообщение	= ТекШК;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
				// Кухарь А.Ю. 18.08.2020 конец
				
			КонецЕсли;	
			
		КонецЕсли;
		
		СтрокаПолучателя = ОблЭтикетка.Параметры.Получатель;
		Если СтрДлина(СтрокаПолучателя) > 36 Тогда
			ОблЭтикетка.Область("R3C2:R3C5").Шрифт = Новый Шрифт(,8,Истина);
		ИначеЕсли СтрДлина(СтрокаПолучателя) > 28 Тогда
			
			ОблЭтикетка.Область("R3C2:R3C5").Шрифт = Новый Шрифт(,9,Истина);
			
		КонецЕсли;	
		
		если МожноВыводитьОбщееКоличествоМест и облЭтикетка.Параметры.НомерКороба=КолКоробок  тогда			
			ОблЭтикетка.Параметры.ВсегоКоробов=КолКоробок;
		иначе
			ОблЭтикетка.Область("R1C4:R1C6").Текст=СтрЗаменить(ОблЭтикетка.Область("R1C4:R1C6").Текст,"из","");
		КонецЕсли;
		
		если КодКонтрагента="SSR-5327" или  КодКонтрагента="SST-0419"  тогда
						
			если ТипЗнч(СтрТЗ.номенклатура)=Тип("СправочникСсылка.Номенклатура") тогда
				Номенклатура=СтрТЗ.Номенклатура;
			иначе
				Номенклатура=ДокументПечатиОбъект.товары.Получить(0).Номенклатура;
			КонецЕсли;
			СтрокаМатрицы=СтрокиМатриц.найти(Номенклатура,"Номенклатура");
			если СтрокаМатрицы<>Неопределено тогда
				ОблЭтикетка.Параметры.АртикулКонтрагента=СтрокаМатрицы.АртикулКонтрагента;
				ОблЭтикетка.Параметры.НомерЗаказа=ДокОснование.НомерЗаказа;
				если ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда			
					ОблЭтикетка.Параметры.количестводокумента=Номенклатура.Родитель.ШтукВКоробке;
				иначе
					ОблЭтикетка.Параметры.количестводокумента=ДокументПечатиОбъект.КоличествоДокумента;
				КонецЕсли;
			КонецЕсли;	
				
		ИначеЕсли КодКонтрагента = "EKF-0301" или КодКонтрагента = "SSR-1593" или КодКонтрагентаРодителя="SSR-7156" тогда	
			АдресИзРегистра=ПрочитатьЗначениеРеквизитаПНКПРМРНК("АдресДляЭтикетки",ДокОснование);
			если ЗначениеЗаполнено(АдресИзРегистра) тогда
				ОблЭтикетка.Параметры.АД=АдресИзРегистра;
			КонецЕсли;
			ОблЭтикетка.Параметры.НомерЗаказаЭтикетка=ДокОснование.НомерЗаказа;
			ОблЭтикетка.Параметры.Регион="";
			ОблЭтикетка.Область("ГородЗаголовок").Текст="Заказ №"; 		
			
			
		КонецЕсли;
		
		
		
		ТабДок.Вывести(ОблЭтикетка);
		
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц(); 
		
		
	КонецЦикла;
	
	// Кухарь А.Ю.  07.10.2022 начало
	// 	ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_"+ЭтотОбъект.Метаданные().Имя+"_НаклейкиНаКоробки";
	если не ЗначениеЗаполнено(ТабДок.ИмяПараметровПечати) тогда
		ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_"+ВидДокументаПечати+"_НаклейкиНаКоробки";
	КонецЕсли;
	// Кухарь А.Ю.  07.10.2022 конец
	
	
	
	ТабДок.ОтображатьСетку 		= Ложь;	
	ТабДок.ОтображатьЗаголовки 	= Ложь;
	
	ТабДок.ПолеСверху=0; ТабДок.ПолеСнизу=0; ТабДок.ПолеСлева=3; ТабДок.ПолеСправа=0;
	
		
	если ВнешнийТД<>Неопределено тогда
		ВнешнийТД.вывести(ТабДок);
	иначе
		//ТабДок.Показать("Наклейки "+ Объект.Номер); 
		СтруктураРезультат.Успех = истина;
		СтруктураРезультат.ТабДокумент = ТабДок; 
	КонецЕсли; 

	если МожноВыводитьОбщееКоличествоМест тогда
		если Накладная.КоличествоКоробок<>КолКоробок тогда
			НакладнаяОбъект=Накладная.ПолучитьОбъект();
			СтрТЗ=ФинальныйПересчетКоробокИОбъемов(Накладная.ПолучитьОбъект());
			ЗаполнитьЗначенияСвойств(НакладнаяОбъект,СтрТЗ);
			НакладнаяОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЕсли;
	
	ТабДокДоп = НапечататьДополнительнуюЭтикетку(ДокОснование,ДокументПечатиОбъект,Форма,ВнешнийДополнительныйТД,ДопПараметрыНакладной);
	СтруктураРезультат.Вставить("ТабДокументДоп",ТабДокДоп); 
	
	если ДопПараметрыНакладной <> Неопределено и  ДопПараметрыНакладной.ОтгрузкаКомплектов тогда	 
				
		если   ДопПараметрыНакладной.имя = "OZON_FBS" тогда
			ТЗУпаковки=ПолучитьРазбивкуНоменклатурыПоУпаковкеДокумента(ДокументПечатиОбъект.Товары.ВыгрузитьКолонку("Номенклатура"),ДопПараметрыНакладной.МассивДО);
			Для каждого СтрТЗ из ТЗУпаковки цикл
				Сообщить("Положите "+СтрТЗ.Владелец+" в "+СтрТЗ.Упаковка);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктураРезультат; 
		
КонецФункции
 
