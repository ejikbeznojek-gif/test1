		|	7
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	8
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	9
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Число КАК Число
		|ПОМЕСТИТЬ ВТВсеЧислаДоПоследнего
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_Цифры.Цифра * 100 + ВТ_Цифры1.Цифра * 10 + ВТ_Цифры2.Цифра КАК Число
		|	ИЗ
		|		ВТ_Цифры КАК ВТ_Цифры,
		|		ВТ_Цифры КАК ВТ_Цифры1,
		|		ВТ_Цифры КАК ВТ_Цифры2) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНомерКоробкиСледующий КАК ВТНомерКоробкиСледующий
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ВложенныйЗапрос.Число < ВТНомерКоробкиСледующий.НомерКоробки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВсеЧислаДоПоследнего.Число КАК НомерКоробки,
		|	1 КАК Приоритет
		|ПОМЕСТИТЬ ВТНомераПомеченные
		|ИЗ
		|	ВТВсеЧислаДоПоследнего КАК ВТВсеЧислаДоПоследнего
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНомераИспользуемые КАК ВТНомераИспользуемые
		|		ПО ВТВсеЧислаДоПоследнего.Число = ВТНомераИспользуемые.НомерКоробки
		|ГДЕ
		|	ВТНомераИспользуемые.НомерКоробки ЕСТЬ NULL
		|	И ВТВсеЧислаДоПоследнего.Число <> 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТНомера.НомерКоробки КАК НомерКоробки,
		|	ВТНомера.Приоритет КАК Приоритет
		|ИЗ
		|	ВТНомерКоробкиСледующий КАК ВТНомера
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТНомераПомеченные.НомерКоробки,
		|	ВТНомераПомеченные.Приоритет
		|ИЗ
		|	ВТНомераПомеченные КАК ВТНомераПомеченные
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТНомера.Приоритет УБЫВ,
		|	НомерКоробки";
	
	Запрос.УстановитьПараметр("ДокОснование", ЛистНабора.ДокОснование);
	Запрос.УстановитьПараметр("ЭтотЛист", ЛистНабора.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	НачНомерКоробки = 1; 
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	КоличествоКодов = ТЗТоваров.Количество(); 
	
	МассивСвободныхКодов = Новый Массив; 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если МассивСвободныхКодов.Количество() =  КоличествоКодов Тогда
		
			Прервать; 	
		
		КонецЕсли;
		МассивСвободныхКодов.Добавить(ВыборкаДетальныеЗаписи.НомерКоробки); 
	КонецЦикла;
	
	Если РезультатЗапроса.Пустой() Тогда
	
		МассивСвободныхКодов.Добавить(1); 	
	
	КонецЕсли;
	//++Данилова Е.В. 02.04.2026  SNL-27 
	МассивТипов = Новый Массив; 
	МассивТипов.Добавить(Тип("СправочникСсылка.Номенклатура"));
	МассивТипов.Добавить(Тип("Строка"));
	ОписаниеТипаНоменклатура = Новый ОписаниеТипов(МассивТипов,,,,Новый КвалификаторыСтроки(150)); 
	ТаблицаНомеров = Новый ТаблицаЗначений; 
	ТаблицаНомеров.Колонки.Добавить("НомерКоробки",Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(6,0)));
	ТаблицаНомеров.Колонки.Добавить("Номенклатура",ОписаниеТипаНоменклатура);
	ТаблицаНомеров.Колонки.Добавить("НомерСтроки",Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(6,0))); 
	//--Данилова Е.В. 02.04.2026 
	Сч = 0;
	Сч1 = 1; 
	ПоследнийНомерКоробки = 0; 
	Для каждого СтрокаТоваров Из ТЗТоваров Цикл 
		
		Если МассивСвободныхКодов.ВГраница() < Сч Тогда
			
			СтрокаНомеров = ТаблицаНомеров.Добавить();
			СтрокаНомеров.Номенклатура = СтрокаТоваров.Номенклатура; 
			СтрокаНомеров.НомерКоробки = ПоследнийНомерКоробки + Сч1;  
			СтрокаНомеров.НомерСтроки = Сч + 1;
			Сч1  =Сч1 + 1; 
		Иначе 
			СтрокаНомеров = ТаблицаНомеров.Добавить();
			СтрокаНомеров.Номенклатура = СтрокаТоваров.Номенклатура; 
			СтрокаНомеров.НомерКоробки = МассивСвободныхКодов[Сч]; //НачНомерКоробки + Сч;
			СтрокаНомеров.НомерСтроки = Сч + 1;
			
			ПоследнийНомерКоробки =  СтрокаНомеров.НомерКоробки; 
		КонецЕсли; 
		
		Сч = Сч + 1; 
	КонецЦикла;
	
	//++Данилова Е.В. 28.04.2026  HELP-9565 
	
	ПолучитьПовторно = Ложь; 
	//++Данилова Е.В. 13.05.2026 HELP-9756 
	Если ЗаписыватьВРС Тогда  
		Для каждого СтрокаТЧ  Из ТаблицаНомеров Цикл
			
			ПараметрыЗаписи = РегистрыСведений.НомераКоробокПоЛистам.СтруктураПараметровЗаписиВРегистр(); 	
			ПараметрыЗаписи.Докоснование 	= ЛистНабора.ДокОснование; 
			ПараметрыЗаписи.НомерКоробки 	= СтрокаТЧ.НомерКоробки; 
			ПараметрыЗаписи.Лист 			= ЛистНабора.ссылка;
			ПараметрыЗаписи.НомерСтрокиЛН    = СтрокаТЧ.НомерСтроки; 
			РезультатЗаписи = РегистрыСведений.НомераКоробокПоЛистам.ЗаписатьНомерКоробки(ПараметрыЗаписи);
			Если НЕ РезультатЗаписи.Успешно Тогда
				ПолучитьПовторно = Истина; 
				прервать; 
			КонецЕсли;
		КонецЦикла;
		Если ПолучитьПовторно Тогда
			
			РегистрыСведений.НомераКоробокПоЛистам.ОчиститьЗаписьПоЛисту(ЛистНабора); 
			
			Если НомерПопытки < 3 Тогда 
				Возврат  ПолучитьНомерКоробкиПоЛистуНабора(ЛистНабора,ТЗТоваров, НомерПопытки + 1);
			Иначе
				ВызватьИсключение "Не удалось получить номер коробки!!Попробуйте заново сформировать этикетку";;
			КонецЕсли; 		
		Иначе
			Возврат ТаблицаНомеров;
		КонецЕсли;
		//--Данилова Е.В. 28.04.2026 
		
		//Возврат ТаблицаНомеров; 
	Иначе
		Возврат ТаблицаНомеров;
	КонецЕсли;
	//--Данилова Е.В. 13.05.2026 
КонецФункции // ПолучитьНомерКоробкиПоЛистуНабора()
 //Данилова Е.В. 13.05.2026 HELP-9756
Функция ПолучитьСписокШКкоробокЛистаНабораИПереукладки(ЛН,ПечатьПоНовому,ДанныеДляПерезаписиНомеров = неопределено,ЗаписыватьВРС = Истина) Экспорт 
   
	ТЗ=новый таблицазначений;
	тз.Колонки.Добавить("НомерКоробкиЛН");	
	тз.Колонки.Добавить("НомерКоробки");
	тз.Колонки.Добавить("ШК");		
	тз.Колонки.Добавить("Номенклатура");
	тз.Колонки.Добавить("ШтукВКоробке");
	
	если лн.ТипШК=Перечисления.ТипыШтрихКодов.Коробка тогда
		ТабНоменклатурыПоКоробам=новый ТаблицаЗначений;
		ТабНоменклатурыПоКоробам.Колонки.Добавить("Номенклатура");
		ТабНоменклатурыПоКоробам.Колонки.Добавить("ШтукВКоробке"); 
		Для Каждого СтрокаТЧ Из ЛН.Товары Цикл
			КоличествоКоробов=?(СтрокаТЧ.ШтВКоробе=0,СтрокаТЧ.количество,СтрокаТЧ.количество/СтрокаТЧ.ШтВКоробе);
			Для СчКоробов=1 по КоличествоКоробов цикл
				СтрТабНом=ТабНоменклатурыПоКоробам.Добавить();
				СтрТабНом.Номенклатура=СтрокаТЧ.Номенклатура;
				СтрТабНом.ШтукВКоробке=СтрокаТЧ.ШтВКоробе; 
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	если ТипЗнч(ЛН) = Тип("ДокументСсылка.ЛистНабора") 
		или ТипЗнч(ЛН) = Тип("ДокументОбъект.ЛистНабора") тогда
		ЭтоЛН=Истина;
	иначе
		ЭтоЛН=Ложь;
	КонецЕсли;
	
