Процедура Провести() Экспорт
	
	Если Последовательность.Количество()>0 тогда
		 			  
			  ПараметрыСеанса.ОтключитьЖурнализациюЗаписи	=Истина;	
			  ПараметрыСеанса.ОтключитьКонтрольДЗР		=Истина;
			  ПараметрыСеанса.ОтключитьКонтрольРезервов	=Истина;	
			  
			    Если Транзакции тогда
			  	НачатьТранзакцию();
		  		Конецесли;
		  
			  ном=0;
			  Стардата=НачалоДня(Последовательность[0].документ.Дата);
			  
			  КолДокЗаПериод=0;
			  Для каждого стр из  Последовательность цикл
				  
				  Док=стр.документ.получитьобъект();
				  
				  //попытка
				  //	ДатаД=Док.дата;
				  //исключение
				  //	продолжить;
				  //КонецПопытки;
				  //
