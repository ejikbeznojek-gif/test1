				  //	Если ДатаД<ВыбГран тогда
				  //  	  продолжить;
				  //	Конецесли;	  
				  //Конецесли;	
				  
						  
				  #ЕСЛИ КЛИЕНТ ТОГДА
                  ОбработкаПрерыванияПользователя();
			  	  #КОНЕЦЕСЛИ
			  
				  Если НачалоДня(док.дата)=НачалоДня(ТекущаяДата()) тогда
					  прервать;
				  Конецесли;
				  
				  Если Транзакции тогда
					  Если Ном=10 тогда
						  ном=0;
						  Зафиксироватьтранзакцию();
						  НачатьТранзакцию();
					  Конецесли;	  
				  Конецесли;	  	  
				  
				  ном=ном+1;
		
				  Если док.проведен тогда
					  
					  для ном3=1 по 3 цикл
						  Попытка
							  Док.записать(РежимЗаписиДокумента.Проведение);
							  КолДокЗаПериод=КолДокЗаПериод+1;
                  			  прервать;
						  Исключение
						  Конецпопытки;
					  Конеццикла;
					  
					  					  
					  Если ном3=4 тогда
						  сообщить1("Не провелся "+док);
					  Конецесли;
					  
					  //Если док.Метаданные().Имя="ОтчетКассовойСмены" тогда
					  //	сообщить1("Провели "+док);
					  //Конецесли;	
					  
					  Если НачалоДня(док.дата)<>СтарДата тогда
						  Сообщить1("Проведено с "+СтарДата+" по "+док.дата+" документов="+КолДокЗаПериод);
						  КолДокЗаПериод=0;
						  Константы.ДатаРасчетнойПоследовательности.Установить(док.дата);
					  Конецесли;
					  
					  стардата=НачалоДня(док.дата);
				  Конецесли;
				  
			  Конеццикла;	
			  
			  Сообщить1("Проведено с "+СтарДата+" по "+док.дата+" документов="+КолДокЗаПериод);

			  Если Транзакции тогда
			  Зафиксироватьтранзакцию();
			  Конецесли;
			  
			  Константы.ДатаРасчетнойПоследовательности.Установить(ТекущаяДата()); //Со временем окончания проведения
