Функция ЗагрузитьСпр_КС(Вид,СтрокаРеквизитов,КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь,ЭтоГруппа=Ложь)	
	Менеджер	= Справочники[Вид];
	
	Если НЕ ЗначениеЗаполнено_(КС_ХДТО) Тогда Возврат Менеджер.ПустаяСсылка() КонецЕсли; 
	
	Если ПустаяСтрока(КС_ХДТО.Ссылка) Тогда
		Возврат ?(ВернутьОбъект,Неопределено,Менеджер.ПустаяСсылка());	
	КонецЕсли; 
	
	Ссылка		= ПолучитьСсылку(КС_ХДТО.Ссылка,Менеджер);
	СпрОбъект	= Неопределено;
	
	Если ТипЗнч(СтрокаРеквизитов)=Тип("Строка") Тогда
		МР	= Новый Структура(СтрокаРеквизитов);
	Иначе
		МР	= СтрокаРеквизитов;	
	КонецЕсли;	
	
	Если (фСоздаватьОбъектыПоСсылкам ИЛИ ВернутьОбъект) 
		И НЕ ОбъектСуществует(Ссылка,"Справочник."+Вид) Тогда
		
		СпрОбъект	= ?(ЭтоГруппа,Менеджер.СоздатьГруппу(),Менеджер.СоздатьЭлемент());
		СпрОбъект.УстановитьСсылкуНового(Ссылка);		
		
		ЗагрузитьРеквизитыОбъекта(СпрОбъект,КС_ХДТО,МР);
		
		Если ФР_ОбщегоНазначения_ПИ.ЭтоСправочникСГруппами(ЗначениеВСтрокуВнутр(ТипЗнч(Ссылка))) Тогда
			ГруппаХДТО	= ПолучитьСвойствоХДТО(КС_ХДТО,"Группа");
			Если ГруппаХДТО<>Неопределено Тогда
				СпрОбъект.Родитель = ЗагрузитьСпр_КС(Вид,СтрокаРеквизитов,ГруппаХДТО,Отправитель,,Истина);							
			КонецЕсли;			
		КонецЕсли; 
		
		Если НЕ ВернутьОбъект Тогда			
			Ссылка	= ЗаписатьОбъект(СпрОбъект,Отправитель);		
		КонецЕсли;
	КонецЕсли;
	
	Если ВернутьОбъект И СпрОбъект=Неопределено Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();		 
		
		Если фПерезаписыватьРеквизитыСправочников Тогда		
			ЗагрузитьРеквизитыОбъекта(СпрОбъект,КС_ХДТО,МР);
			
			Если ФР_ОбщегоНазначения_ПИ.ЭтоСправочникСГруппами(ЗначениеВСтрокуВнутр(ТипЗнч(Ссылка))) Тогда
				ГруппаХДТО	= ПолучитьСвойствоХДТО(КС_ХДТО,"Группа");
				Если ГруппаХДТО<>Неопределено Тогда
					СпрОбъект.Родитель = ЗагрузитьСпр_КС(Вид,СтрокаРеквизитов,ГруппаХДТО,Отправитель,,Истина);							
				КонецЕсли;			
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;
	
	Возврат ?(ВернутьОбъект,СпрОбъект,Ссылка);	
КонецФункции //ЗагрузитьСпр_КС(ОбъектХДТО,Отправитель=Неопределено)

Функция НайтиСоздатьСправочник(ТекстСсылки,Вид,ЭтоГруппа=Ложь)
	Менеджер	= Справочники[Вид];
	
	Результат 	= Новый Структура("Найден,Ссылка,Объект,ПолныйТип",Ложь,Менеджер.ПустаяСсылка(),Неопределено,Метаданные.Справочники[Вид].ПолноеИмя());	
	
	Если ТипЗнч(ТекстСсылки)=Тип("Строка") Тогда		
		Результат.Ссылка	= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекстСсылки));		
	ИначеЕсли ТипЗнч(ТекстСсылки)=ТипЗнч(Результат.Ссылка) Тогда
		Результат.Ссылка	= ТекстСсылки;
	КонецЕсли;	
	
	Если ОбъектСуществует(Результат.Ссылка,"Справочник."+Вид) Тогда			
		Результат.Найден	= Истина;
		Если фПерезаписыватьРеквизитыСправочников Тогда
			Результат.Объект = Результат.Ссылка.ПолучитьОбъект();		
		КонецЕсли;		
	Иначе
		Если ЭтоГруппа Тогда
			СпрОбъект	= Менеджер.СоздатьГруппу();
		Иначе
			СпрОбъект	= Менеджер.СоздатьЭлемент();		
		КонецЕсли;
		
		СпрОбъект.УстановитьСсылкуНового(Результат.Ссылка);
		
		Результат.Объект = 	СпрОбъект;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьСправочник(ТекстСсылки,Вид,ЭтоГруппа=Ложь)

Функция ЗагрузитьСпр_СТАНДАРТНО(Менеджер,ОбъектХДТО,ЭтоГруппа,Отправитель,ДопПараметры=Неопределено)
	МетаОбъект	= Менеджер.ПустаяСсылка().Метаданные();
	Имя			= МетаОбъект.Имя;
	Результат	= НайтиСоздатьСправочник(ОбъектХДТО.Ссылка,Имя,ЭтоГруппа);
	
	Если Результат.Найден И НЕ фПерезаписыватьРеквизитыСправочников Тогда
		Возврат Результат.Ссылка;		
	Иначе
		СпрОбъект	= Результат.Объект;		
	КонецЕсли;	
	
	ЗаполнитьЗначенияСвойств(СпрОбъект,ЗаполненныеСвойстваХДТО(ОбъектХДТО),,"Ссылка");
	
	ИмяПредопределенныхДанных	= ПолучитьСвойствоХДТО(ОбъектХДТО,"ИмяПредопределенныхДанных");
	Если ИмяПредопределенныхДанных<>Неопределено Тогда
		Попытка		
			СпрОбъект.ИмяПредопределенныхДанных = ИмяПредопределенныхДанных;
		Исключение					
		КонецПопытки;	
	КонецЕсли; 
	
	ИменаТЧ	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"ИменаТЧ","");
	Если НЕ ПустаяСтрока(ИменаТЧ) Тогда		
		ЗагрузитьТЧОбъекта(СпрОбъект,ОбъектХДТО,ИменаТЧ);
	КонецЕсли;	
	
	Возврат ЗаписатьОбъект(СпрОбъект,Отправитель);
КонецФункции //ЗагрузитьСпр_СТАНДАРТНО()


#КонецОбласти


