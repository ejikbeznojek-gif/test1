Функция СоздатьЗапросПоНоменклатуреНакладных(МассивСсылок)
	Запрос							= Новый ("Запрос");
	Запрос.МенеджерВременныхТаблиц	= Новый МенеджерВременныхТаблиц;
	
	ТекстыЗапросов	= Новый Массив;
	ШаблонЗапроса	= "
	|ВЫБРАТЬ 
	|	Номенклатура,
	|	Номенклатура.Родитель КАК Модель	
	|ИЗ 
	|	%1.Товары
	|ГДЕ 			
	|	Ссылка В (&%2)
	|";
	
	Для Каждого ЭлементТипа Из ФР_ОбщегоНазначения_КС.РассортироватьПоТипам(МассивСсылок) Цикл
		Тип				= ЭлементТипа.Ключ;
		ИмяПараметра	= СтрЗаменить(Тип,".","_");
		
		Запрос.УстановитьПараметр(ИмяПараметра,ЭлементТипа.Значение);	
		
		ТекстыЗапросов.Добавить(СтрШаблон(ШаблонЗапроса,Тип,ИмяПараметра));
	КонецЦикла; 
	
	Запрос.МенеджерВременныхТаблиц	= Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Модель,
	|	Номенклатура	
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ	
	|(
	|	"+СтрСоединить(ТекстыЗапросов,"ОБЪЕДИНИТЬ"+Символы.ПС)+"
	|) КАК Сводный
	|
	|";

	Запрос.Выполнить();	

	Возврат Запрос;
КонецФункции //СоздатьЗапросПоНоменклатуреНакладных()

Функция СравнитьЗначенияПеречисления(Зн1,Зн2) Экспорт
	Результат = 0;
	
	Тип1 = ТипЗнч(Зн1);
	Если ТипЗнч(Зн1)=ТипЗнч(Зн2) Тогда
		МетаПер = Метаданные.НайтиПоТипу(Тип1);
		Если МетаПер<>Неопределено И Метаданные.Перечисления.Содержит(МетаПер) Тогда
			Менеджер = Перечисления[МетаПер.Имя];
			
			Индекс1 = ?(ЗначениеЗаполнено(Зн1),Менеджер.Индекс(Зн1),-1);	
			Индекс2 = ?(ЗначениеЗаполнено(Зн2),Менеджер.Индекс(Зн2),-1);	
			
			Если Индекс1<Индекс2 Тогда
				Результат = -1;			
			ИначеЕсли Индекс1=Индекс2 Тогда
				Результат = 0;
			Иначе
				Результат = 1;		
			КонецЕсли;					
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //СравнитьЗначенияПеречисления(Зн1,Зн2)

