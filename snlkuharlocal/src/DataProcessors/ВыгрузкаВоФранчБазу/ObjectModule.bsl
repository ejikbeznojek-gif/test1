//Проблема 0000000187
Функция ЗагрузитьДок_ПНК_ИзФР(ОбъектХДТО, Отправитель)
	
	Если ОбъектХДТО = Неопределено ИЛИ Отправитель = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СостояниеПНК = ОбъектХДТО.СостояниеНакладной; 
	
	Если СостояниеПНК <> "Принята" ИЛИ ОбъектХДТО.ВидВходящегоДокумента <> "ПРМ" Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	Вид = "Перемещение";
	
	УИД = ОбъектХДТО.Ссылка.УникальныйИдентификатор();
	Ссылка = Документы.Перемещение.ПолучитьСсылку(УИД);
		
	ДокОбъект = Ссылка.ПолучитьОбъект();
	Если ДокОбъект = Неопределено Тогда
		СтрокаТО = ОбъектыОбмена.Добавить();
		СтрокаТО.ОбъектТип = Вид;
		СтрокаТО.Ошибки = "ПРМ не найден по ссылке: " + УИД;
		СтрокаТО.Действие = "Ошибка";
		СтрокаТО.СтатусЗаписи = "ОшибкаЗагрузки";
		Возврат Неопределено;
	КонецЕсли;
	
	ДокОбъект.ОбменДанными.Отправитель = Отправитель;
	
	НоваяДатаПриемки = ОбъектХДТО.Дата;
	НовыйСтатусПРМ = Перечисления.СостоянияНакладной.Принята;
	
	ДатаИзменилась = (ДокОбъект.ДатаПриемки <> НоваяДатаПриемки) И ЗначениеЗаполнено(НоваяДатаПриемки);
	СтатусИзменился = Ложь;
	
	Если СостояниеПНК = "Принята" И ДокОбъект.СостояниеНакладнойУПолучателя <> НовыйСтатусПРМ Тогда
		СтатусИзменился = Истина;
	КонецЕсли;
	
	Если СтатусИзменился ИЛИ ДатаИзменилась Тогда 
		
		ДокОбъект.СостояниеНакладнойУПолучателя = НовыйСтатусПРМ;
		ДокОбъект.ДатаПриемки = НоваяДатаПриемки;     
		
		Попытка
			ДокОбъект.ДополнительныеСвойства.Вставить("НеРегистрировать", Истина);
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			// Обработка ошибок перепроведения
			ОписаниеОшибки = ОписаниеОшибки();
			
			// Записываем в протокол обмена
			СтрокаТО = ОбъектыОбмена.Добавить();
			СтрокаТО.ОбъектТип = "Документ.Перемещение";
			СтрокаТО.ОбъектСсылкаУИД = ДокОбъект.Ссылка.УникальныйИдентификатор();
			СтрокаТО.Ошибки = "Ошибка при обновлении ПРМ " + ДокОбъект.Ссылка + ": " + ОписаниеОшибки;
			СтрокаТО.Действие = "Ошибка";
			СтрокаТО.СтатусЗаписи = "";
			
			Возврат Неопределено;
		КонецПопытки;  
		
	КонецЕсли;  
	
	Возврат ДокОбъект.Ссылка;
	
КонецФункции
