Функция ПолучитьСхемуИзМакета(ИмяМакета)
	ЧтениеXML = Новый ЧтениеXML;    
	
	//УстановитьБезопасныйРежим(Ложь);
	
	ИмяВФ=ПолучитьИмяВременногоФайла("xsd");
	ДвоичныеДанные=ПолучитьМакет(ИмяМакета);
	ДвоичныеДанные.Записать(ИмяВФ);
    ЧтениеXML.ОткрытьФайл(ИмяВФ);   	
 
    ПостроительDOM	= Новый ПостроительDOM;
    ДокументДом		= ПостроительDOM.Прочитать(ЧтениеXML);   
	ЧтениеXML.Закрыть();
 
    ПостроительСхем = Новый ПостроительСхемXML;
    Схема 			= ПостроительСхем.СоздатьСхемуXML(ДокументДом);
	
	ЧтениеXML.Закрыть();
	УдалитьФайлы(ИмяВФ);
	
	Возврат Схема;
КонецФункции // ()

