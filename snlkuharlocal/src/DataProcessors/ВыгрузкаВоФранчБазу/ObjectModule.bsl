Функция МассивРеквизитовШапки(МетаОбъект)
	МР=Новый Массив;
	
	Для Каждого МетаРеквизит Из МетаОбъект.Реквизиты Цикл
		МР.Добавить(МетаРеквизит.Имя);	
	КонецЦикла; 
	
	Возврат МР;
КонецФункции // ()

Функция СтрокаПолейТаблицыРеквизитов(ТР)
	Возврат СтрСоединить(ТР.ВыгрузитьКолонку("ПолеЗапроса"),",");
КонецФункции //СтрокаПолейТаблицыРеквизитов(ТР)
 

#КонецОбласти


#Область Выгрузка


Функция ПустаяТаблицаРеквизитов()
	ТР	= Новый ТаблицаЗначений;
	
	ТР.Колонки.Добавить("Имя");
	ТР.Колонки.Добавить("ПолеЗапроса");
	ТР.Колонки.Добавить("ТипСтрокой");
	ТР.Колонки.Добавить("Кэшировать",Новый ОписаниеТипов("Булево"));

	Возврат ТР;
КонецФункции // ()

Функция СоздатьТаблицуРеквизитов(МетаОбъект,Знач СтрокаРеквизитов=Неопределено)
	ТР	= ПустаяТаблицаРеквизитов();	
	
	Если ЗначениеЗаполнено(СтрокаРеквизитов) Тогда
		СтрокаРеквизитов=СтрЗаменить(СтрокаРеквизитов,Символы.ПС,"");		
	Иначе
		СтрокаРеквизитов	= "*";		
	КонецЕсли;
	
	времМР	= СтрРазделить(СтрокаРеквизитов,",");
	
	МР	= Новый Массив;
	Для Каждого ИмяРеквизита Из времМР Цикл
		Если ИмяРеквизита="*" Тогда
			ВсеРеквизиты = МассивРеквизитов(МетаОбъект);
			Для Каждого ИмяРеквизита Из ВсеРеквизиты Цикл
				МР.Добавить(ИмяРеквизита);			
			КонецЦикла; 
		Иначе
			МР.Добавить(ИмяРеквизита);
		КонецЕсли; 	
	КонецЦикла;
	
	Для Каждого ОписанияПоля Из МР Цикл
		СтрокаТР 	= ТР.Добавить();
		Части		= СтрРазделить(ОписанияПоля," ");
		
		ПолеЗапроса	= Части[0];
		Псевдоним	= СтрЗаменить(?(Части.Количество()>1,Части[1],ПолеЗапроса),".","_");	
		
		СтрокаТР.Имя			= Псевдоним;
		СтрокаТР.ПолеЗапроса	= ПолеЗапроса;
		СтрокаТР.ТипСтрокой		= ОпределитьТипРеквизита(ПолеЗапроса,МетаОбъект);		
		СтрокаТР.Кэшировать		= СтрНайти(СтрокаТР.ТипСтрокой,".")>0; //Ссылочный тип (с точкой)
	КонецЦикла;	
	
	Возврат ТР;
КонецФункции

Функция МассивРеквизитов(МетаОбъект)
	МР=Новый Массив;
	
	Для Каждого МетаРеквизит Из МетаОбъект.Реквизиты Цикл		
		МР.Добавить(МетаРеквизит.Имя);
	КонецЦикла;
	
	Возврат МР;
КонецФункции //МассивРеквизитов(МетаОбъект,КлассОбъекта)

Процедура УстановитьПараметрыВСтрокеТР(ТР,Имя,Параметры)
	СтрокаТР	= ТР.Найти(Имя,"Имя");
	Если СтрокаТР<>Неопределено Тогда
		ЗаполнитьЗначенияСвойств(СтрокаТР,Параметры);		
	КонецЕсли;
КонецПроцедуры

Функция ЗапросДляВыгрузкиЕД(ИмяТаблицы,РеквизитыДляВыгрузки)
	Имена	= Новый Массив;
	Для Каждого СтрокаТР Из РеквизитыДляВыгрузки.Шапка Цикл
		ТекТаблица	= ?(СтрокаТР.ПолеЗапроса=СтрокаТР.Имя,"Список.","");
		Имена.Добавить(ТекТаблица+СтрокаТР.ПолеЗапроса+" КАК "+СтрокаТР.Имя);
	КонецЦикла;
	
	ДопРеквизиты=ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(РеквизитыДляВыгрузки,"ДопРеквизиты",Неопределено);
	
	Тексты=Новый Массив;
	Если Имена.Количество()>0 Тогда
		Тексты.Добавить(СтрСоединить(Имена,","));	
	КонецЕсли;	
	
	ПолеПорядка="ВТ_ТаблицаСсылок.Номер";	
	
	СписокТЧ=Неопределено;
	Если РеквизитыДляВыгрузки.Свойство("СписокТЧ",СписокТЧ) Тогда
		Для Каждого ЭлементТЧ Из СписокТЧ Цикл
			Имя_ТЧ	= ЭлементТЧ.Ключ;
			Имена.Очистить();
			
			Для Каждого СтрокаТР Из ЭлементТЧ.Значение Цикл
				Имена.Добавить(СтрокаТР.ПолеЗапроса+" КАК "+СтрокаТР.Имя);							
			КонецЦикла;					
			
			Если Имена.Количество()>0 Тогда
				Тексты.Добавить(Имя_ТЧ+".("+СтрСоединить(Имена,",")+") КАК "+Имя_ТЧ);
			КонецЕсли;
			
			ПолеПорядка=ПолеПорядка+",
			|	"+Имя_ТЧ+".НомерСтроки";
		КонецЦикла;	
	КонецЕсли;
	
	ПоляДР = Новый Массив;
	Если ДопРеквизиты<>Неопределено Тогда		
		ПоляДанных		= Новый Массив;
		Для Каждого ИмяДР Из СтрРазделить(ДопРеквизиты,",") Цикл
			ПоляДанных.Добавить(СтрШаблон("
			|МАКСИМУМ(
			|	ВЫБОР КОГДА Реквизиты.ИмяРеквизита=""%1"" ТОГДА ЗначениеРеквизита 
			|	ИНАЧЕ NULL 
			|КОНЕЦ
			|) КАК %1",ИмяДР)
			);	
			
			ПоляДР.Добавить(СтрШаблон("ДопРеквизиты.%1 КАК %1_ДР",ИмяДР));
		КонецЦикла;
		
		ТекстЗапросаДР="
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|(
		|ВЫБРАТЬ
		|	Реквизиты.Справочник КАК Ссылка,
		|	"+СтрСоединить(ПоляДанных,",")+"
		|ИЗ
		|	РегистрСведений.РеквизитыСправочников КАК Реквизиты
		|ПРАВОЕ СОЕДИНЕНИЕ 
		|	 ВТ_ТаблицаСсылок
		|ПО
		|	Реквизиты.Справочник=ВТ_ТаблицаСсылок.ОбъектСсылка
		|СГРУППИРОВАТЬ ПО 
		|	Реквизиты.Справочник
		|) КАК ДопРеквизиты
		|ПО
		|	Список.Ссылка=ДопРеквизиты.Ссылка
		|";
	Иначе
		ТекстЗапросаДР="";
	КонецЕсли; 
	
	Запрос	= Новый Запрос;	
	Запрос.Текст="
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ТаблицаСсылок ИЗ &ТаблицаСсылок КАК ТаблицаСсылок ИНДЕКСИРОВАТЬ ПО ОбъектСсылка
	|;
	|ВЫБРАТЬ	
	|	ВТ_ТаблицаСсылок.ОбъектТип			КАК ОбъектТип,
	|	ВТ_ТаблицаСсылок.ОбъектСсылкаУИД	КАК ОбъектСсылкаУИД,
	|	ВТ_ТаблицаСсылок.ОтборРС_Хэш 		КАК ОтборРС_Хэш,
	|	"+?(ПоляДР.Количество()=0,"",СтрСоединить(ПоляДР,",")+",")+"
	|	"+СтрСоединить(Тексты,",")+",	
	|	IsNULL(ДопИнформация.Получатель,ВТ_ТаблицаСсылок.Получатель)			КАК ПодразделениеПолучатель_ДИ,
	|	ВЫРАЗИТЬ(IsNULL(ДопИнформация.Получатель,ВТ_ТаблицаСсылок.Получатель)	КАК Справочник.Подразделения).ОсновнойСклад	КАК СкладПолучатель_ДИ
	|ИЗ
	|	"+ИмяТаблицы+" КАК Список	
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_ТаблицаСсылок
	|ПО
	|	Список.Ссылка	= ВТ_ТаблицаСсылок.ОбъектСсылка
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	РегистрСведений.ФР_ОбъектыКВыгрузке КАК ДопИнформация
	|ПО
	|	ДопИнформация.ОбъектСсылкаУИД	= ВТ_ТаблицаСсылок.ОбъектСсылкаУИД
	|	И ДопИнформация.Номер			= ВТ_ТаблицаСсылок.Номер
	|"+ТекстЗапросаДР+"
	|УПОРЯДОЧИТЬ ПО 
	|	"+ПолеПорядка+"
	|";
	
	Возврат Запрос;
КонецФункции //ЗапросДляВыгрузкиЕД(ИмяТаблицы,РеквизитыДляВыгрузки)

Функция ОпределитьТипРеквизитов(СписокРеквизитов,МетаОбъект)
	Для Каждого Элемент Из СписокРеквизитов Цикл
		МетаРеквизит	= МетаОбъект.Реквизиты.Найти(Элемент.Ключ);	
		
		Если МетаРеквизит=Неопределено Тогда Продолжить КонецЕсли; 
		
		Типы=МетаРеквизит.Тип.Типы();
		Если Типы.Количество()>1 Тогда Продолжить КонецЕсли;	
		
		ТипРеквизита	= Типы[0];
		
		Если ЭтоПростойРеквизит(МетаРеквизит) Тогда Продолжить КонецЕсли; 
		Если ТипРеквизита=Тип("ХранилищеЗначения") Тогда Продолжить КонецЕсли;	
		
		СписокРеквизитов[Элемент.Ключ]=Метаданные.НайтиПоТипу(ТипРеквизита).ПолноеИмя();		
	КонецЦикла;
КонецФункции //ОпределитьТипРеквизитов(СписокРеквизитов,МетаОбъект)

Функция ОпределитьТипРеквизита(ИмяРеквизита,МетаОбъект)
	Результат		= "";
	
	МетаРеквизит	= МетаОбъект.Реквизиты.Найти(ИмяРеквизита);	
	//Если МетаРеквизит	= Неопределено Тогда
	//	Для Каждого ТекРеквизит Из МетаОбъект.СтандартныеРеквизиты Цикл
	//		Если ТекРеквизит.Имя=ИмяРеквизита Тогда
	//			МетаРеквизит = ТекРеквизит;
	//			Прервать;			
	//		КонецЕсли;		
	//	КонецЦикла;		
	//КонецЕсли; 
		
	Если МетаРеквизит<>Неопределено Тогда		
		Типы=МетаРеквизит.Тип.Типы();
		Если Типы.Количество()=1 Тогда 
			ТипРеквизита	= Типы[0];		
			Если ЭтоПростойРеквизит(МетаРеквизит) Тогда 
				Результат="Простой";
			ИначеЕсли ТипРеквизита=Тип("ХранилищеЗначения") Тогда 
				Результат="ХранилищеЗначения";			
			ИначеЕсли ТипРеквизита=Тип("УникальныйИдентификатор") Тогда 
				Результат="УникальныйИдентификатор";			
			Иначе				
				Результат=Метаданные.НайтиПоТипу(ТипРеквизита).ПолноеИмя();
			КонецЕсли;			
		Иначе
			Результат="Мульти";			
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат Результат;		
КонецФункции //ОпределитьТипРеквизита(ИмяРеквизита,МетаОбъект)

Процедура ЗаполнитьКэшиПоНоменклатуреХарактеристикам_ЕД()
	//Выгрузка Номенклатура
	Начало	= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	МН		= МассивНовыхЭлементовКэша("Справочник.Номенклатура");	
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало;
	
	//Сообщить_("Соответствие в массив (номенклатура): "+Окр(Время/1000,2,1)+" сек., кол-во элементов: "+МН.Количество());	
	//Сообщить_("Запрос по номенклатуре...");
	
	Запрос	= Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц	= Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	Ссылка,
	|	Код,
	|	КодПроизводителя,
	|	Наименование,
	|	Родитель				КАК Родитель,
	|	Родитель.Наименование 	КАК Родитель_Наименование,
	|	ЭтоГруппа,
	|	ПометкаУдаления 
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	Справочник.Номенклатура 
	|ГДЕ Ссылка В (&МН)
	|ИНДЕКСИРОВАТЬ ПО Ссылка
	|;
	|ВЫБРАТЬ
	|	* 
	|ИЗ 
	|	ВТ_Номенклатура
	|";
	
	Запрос.УстановитьПараметр("МН",МН);
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Сч			= 0;
	
	Выборка		= Запрос.Выполнить().Выбрать();	
	ВсегоСтрок	= Выборка.Количество();
	Пока Выборка.Следующий() Цикл
		Попытка
			ВыгрузитьСпр_Номенклатура_Элемент_КС(Выборка,Ложь);
		Исключение
		КонецПопытки;
		
		Сч=Сч+1;
		Если Сч%100=0 Тогда
			Состояние_("Заполнение кэша (номенклатура)"+(ВсегоСтрок-Сч));		
		КонецЕсли; 
	КонецЦикла; 
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало;	
	//Сообщить_("Время выгрузки (номенклатура): "+Окр(Время/1000,2,1)+" сек., сч: "+ВсегоСтрок);		
		
	//Выгрузка групп номенклатуры
	Запрос.Текст	= "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Родитель.ВерсияДанных	КАК ВерсияДанных,
	|	Родитель 				КАК Ссылка,
	|	Родитель.Код			КАК Код,
	|	Родитель.Наименование  	КАК Наименование,
	|	Родитель.Родитель		КАК Родитель
	|ИЗ 
	|	ВТ_Номенклатура
	|ГДЕ
	|	НЕ Родитель = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|";	
		
	ВыборкаГрупп	= Запрос.Выполнить().Выбрать();
	Пока ВыборкаГрупп.Следующий() Цикл		
		ВыгрузитьСпр_Номенклатура_Группа_КС(ВыборкаГрупп);
	КонецЦикла; 
	
	//Сообщить_("Групп: "+Выборка.Количество());	
	
	Запрос.Текст="ВЫБРАТЬ * ИЗ ВТ_Номенклатура";
	Выборка		= Запрос.Выполнить().Выбрать();
	ВсегоСтрок	= Выборка.Количество();
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало;
	//Сообщить_("Время выгрузки (группы номенклатуры): "+Окр(Время/1000,2,1)+" сек., сч: "+ВсегоСтрок);
	
	Начало	= ТекущаяУниверсальнаяДатаВМиллисекундах();
			
	//Выгрузка Характеристик	
	МХ		= МассивНовыхЭлементовКэша("Справочник.ФР_ХарактеристикиНоменклатуры");	
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало;
	//Сообщить_("Соответствие в массив (характеристики): "+Окр(Время/1000,2,1)+" сек., сч: "+МН.Количество());
	
	//Сообщить_("Запрос по характеристикам...");	
	
	РеквизитыКС	= "ВерсияДанных,Ссылка,Код,Наименование,Родитель";
	
	РеквизитыШапок.Вставить("Справочник.ФР_ХарактеристикиНоменклатуры.КС",РеквизитыКС);
	
	Запрос.Текст="
	|ВЫБРАТЬ 
	|	"+РеквизитыКС+"
	|ИЗ
	|	Справочник.Номенклатура
	|ГДЕ Ссылка В (&МХ)	
	|";
	
	Запрос.УстановитьПараметр("МХ",МХ);
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
		
	Выборка		= Запрос.Выполнить().Выбрать();
	Сч			= 0;
	ВсегоСтрок	= Выборка.Количество();
	Пока Выборка.Следующий() Цикл
		ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_КС(Выборка);
		
		Сч=Сч+1;
		Если Сч%100=0 Тогда
			Состояние_("Заполнение кэша (характеристики номенклатуры):"+(ВсегоСтрок-Сч));		
		КонецЕсли; 
	КонецЦикла; 
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало;
	//Сообщить_("Время выгрузки (характеристики): "+Окр(Время/1000,2,1)+" сек., сч: "+ВсегоСтрок);

КонецПроцедуры

Процедура ЗаполнитьКэшиПоНоменклатуреХарактеристикам()
	//Вообще не нужна никакая хрень
	ЗаполнитьКэшиПоНоменклатуреХарактеристикам_ЕД(); //временно
КонецПроцедуры

