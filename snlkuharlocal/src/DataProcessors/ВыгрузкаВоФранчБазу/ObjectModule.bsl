Функция ЗначениеЗаполнено_(Значение)	
	//Чушебред, но 1С отказывается проверять мутабельные значения на заполненность
	Если НЕ (Значение=Неопределено ИЛИ Значение="" ИЛИ Значение=NULL) Тогда
		Результат = Истина;
	Иначе
		Результат = ЗначениеЗаполнено(Значение);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()


