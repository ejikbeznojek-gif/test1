	Если ЗначениеЗаполнено(РеквизитыШ.ПодразделениеПредъявления) Тогда
		ПодрХДТО	= ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШ.ПодразделениеПредъявления);
		ДобавитьСвойствоХДТО(ОбъектХДТО,ПодрХДТО,"ПодразделениеПредъявления",ПространствоИмен_ЕЕ);	
	КонецЕсли;	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.НачалоДействия,	"НачалоДействия",  	 	"date",		ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ОкончаниеДействия,"ОкончаниеДействия",	"date",		ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ДатаВыдачи,		"ДатаВыдачи",			"date",		ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ДатаПогашения,	"ДатаПогашения",    	"date",		ПространствоИмен_СТ);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.НомерЧекаВыдачи,				"НомерЧекаВыдачи",				"string", ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.НомерЧекаПогашения,			"НомерЧекаПогашения",			"string", ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Подарок,						"Подарок",						"boolean", ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.МинимальнаяСуммаЧекаПогашения,"МинимальнаяСуммаЧекаПогашения","string", ПространствоИмен_СТ);		
	//ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ВидСертификата,				"ВидСертификата",				"string", ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(РеквизитыШ.Акция),				"Акция",						"string", ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ОплатаНеБолее30Процентов,		"ОплатаНеБолее30Процентов",		"boolean", ПространствоИмен_СТ);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",		"boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ПодарочныеСертификаты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_ПодарочныеСертификаты_КС(СпрВыборка)
	ИмяТаблицы	= "Справочник.ПодарочныеСертификаты";
	ИмяТипаХДТО	= "ОбщиеСвойстваДанныеПодарочногоСертификата";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"КС");
	
	Если ПустаяСтрока(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= ПолучитьИзКэша(РеквизитыШ.Ссылка,ИмяТаблицы+".КС");
	
	Если ОбъектХДТО = Неопределено Тогда		
		ОбъектХДТО							= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕД);
		
		ОбъектХДТО.СерийныйНомер			= РеквизитыШ.Код;
		ОбъектХДТО.Штрихкод					= РеквизитыШ.КодСертификата;
		ОбъектХДТО.ВидПодарочногоСертификата= ВыгрузитьСпр_ВидыПодарочныхСертификатов_КС(РеквизитыШ.ВидСертификата);
		ОбъектХДТО.ДействителенДо			= РеквизитыШ.ОкончаниеДействия;		
		
		ДобавитьЭлементХДТО(ОбъектХДТО,СериализаторXDTO.XMLСтрока(РеквизитыШ.Ссылка),				"Ссылка",	"string", ПространствоИмен_СТ);		
		ДобавитьЭлементХДТО(ОбъектХДТО,СериализаторXDTO.XMLСтрока(РеквизитыШ.Владелец_Родитель),	"Владелец",	"string", ПространствоИмен_СТ);	
		
		ВставитьВКэш(РеквизитыШ.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ПодарочныеСертификаты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Пользователи_Элемент(СпрВыборка)
	ОбъектХДТО	= Неопределено;
	
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка = Справочники.Пользователи.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	ОбъектХДТО	= ПолучитьИзКэша(ТекСсылка,"Справочник.Пользователи");
	
	Если ОбъектХДТО = Неопределено Тогда
		Если НаВходеВыборка Тогда		
			Реквизиты					= СпрВыборка;
		Иначе
			Реквизиты					= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Родитель,Код,Наименование");			
		КонецЕсли;		
	
		ОбъектХДТО						= СоздатьОбъектХДТО("Справочник.Пользователи");		
		
		ОбъектХДТО.КлючевыеСвойства		= ВыгрузитьСпр_Пользователи_Элемент_КС(СпрВыборка);
		ДобавитьСвойствоХДТО(ОбъектХДТО,XMLСтрока(СпрВыборка.Подразделение_ДР),"Подразделение",ПространствоИмен_ЕЕ);		
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Пользователи_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Пользователи_Элемент_КС(Ссылка)	
	ОбъектХДТО	= ВыгрузитьСпр_КС(Ссылка,"Пользователи","Наименование","КлючевыеСвойстваПользователь");
	Если ЗначениеЗаполнено(Ссылка.ФизЛицо) Тогда
		ОбъектХДТО.ФизическоеЛицо=ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(Ссылка.ФизЛицо);			
	КонецЕсли; 
	
	Возврат ОбъектХДТО;
