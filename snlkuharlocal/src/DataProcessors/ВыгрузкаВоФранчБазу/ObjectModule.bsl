Функция ЗагрузитьТЧОбъекта1(Объект,ОбъектХДТО,ИменаТЧ,ДопПараметы = Неопределено)
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл
		текДопПараметры		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметы,ИмяТЧ);
		СоотвРеквизитов		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(текДопПараметры,"СоответствиеРеквизитов",	Новый Структура);
		ЗначенияПоУмолчанию = ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(текДопПараметры,"ЗначенияПоУмолчанию",		Новый Структура);
		
		ТЧ_Объекта	= Объект[ИмяТЧ];
		ТЧ_Объекта.Очистить();
		ТЧ_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяТЧ);
		Ед_Штука					= Справочники.ОКЕИ.НайтиПоКоду("796");
		Если ТЧ_ХДТО<>Неопределено Тогда
			Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
				СтрокаТЧ	= ТЧ_Объекта.Добавить();
								
				Попытка
					Если ИмяТЧ = "Товары" Тогда
						ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО, ,"СтавкаНДС,Единица");
						СтрокаТЧ.СтавкаНДС = ЗагрузитьПер_СтавкаНДС(СтрокаТЧ_ХДТО.СтавкаНДС); 
						СтрокаТЧ.Единица = Ед_Штука;
					Иначе
						ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО); 
					КонецЕсли;	
				Исключение
				КонецПопытки;	
				
				//Если Прав(ИмяТипаХДТО, 6) = "Товары" Тогда
				//	ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаТЧ, ,"СтавкаНДС");  
				//	
				//	Попытка
				//		УстановитьСвойствоХДТО(СтрокаТЧ_ХДТО, "СтавкаНДС", ВыгрузитьПер_СтавкаНДС(ВыборкаТЧ.СтавкаНДС));
				//	Исключение
				//	КонецПопытки;
				//Иначе
				//	ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаТЧ);
				//КонецЕсли;
				
				Для Каждого Элемент Из СоотвРеквизитов Цикл
					СтрокаТЧ[Элемент.Ключ]	= СтрокаТЧ_ХДТО[Элемент.Значение];
				КонецЦикла; 
				Для Каждого Элемент Из ЗначенияПоУмолчанию Цикл				
					Если НЕ ЗначениеЗаполнено(СтрокаТЧ[Элемент.Ключ]) Тогда
						СтрокаТЧ[Элемент.Ключ]	= Элемент.Значение;
					КонецЕсли;
				КонецЦикла; 
			КонецЦикла; 			
		КонецЕсли;
	КонецЦикла;
КонецФункции

