Функция ВыгрузитьОстатки() Экспорт	
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	Номенклатура,
	|	КоличествоНачальныйОстаток  КАК КолНачИст,
	|	КоличествоПриход			КАК КолПрихИст,
	|	КоличествоРасход			КАК КолРасхИст,
	|	КоличествоКонечныйОстаток	КАК КолКонИст
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.ОстаткиИОбороты(&Дата1,&Дата2,,,
	|		Склад.Подразделение = &ПодразделениеПолучатель	
	|		И Склад.ВидСклада=ЗНАЧЕНИЕ(Перечисление.ВидСклада.Физический)
	|	)
	|";			
	
	Запрос.УстановитьПараметр("Дата1",		НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2",		КонецДня(Дата2));
	
	Запрос.УстановитьПараметр("ПодразделениеЦО",			ПодразделениеЦО);	
	Запрос.УстановитьПараметр("ПодразделениеПолучатель",	ПодразделениеПолучатель);	
	
	Сч			= 0;
	
	НачВремя	= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат	= Запрос.Выполнить();	
	
	ТД	= Результат.Выгрузить();
	
	ТД.Колонки.Добавить("ХарактеристикаНоменклатурыУИД");
	Для Каждого СтрокаТЧ Из ТД Цикл
		СтрокаТЧ.ХарактеристикаНоменклатурыУИД	= СтрокаТЧ.Номенклатура.УникальныйИдентификатор();
	КонецЦикла; 
	
	ПараметрыСверки	= Новый Структура("ПодразделениеПолучатель,ОборотыПоОстаткам,Дата1,Дата2",ПодразделениеПолучатель.УникальныйИдентификатор(),ТД,Дата1,Дата2);
	
	Результат = ЗначениеВСтрокуВнутр(ПараметрыСверки);
	
	ВремяОбработки	= Формат((ТекущаяУниверсальнаяДатаВМиллисекундах()-НачВремя)/1000,"ЧДЦ=3");
	
	Сообщить(СтрШаблон("Выгружено: %1 строк, остаток: %2, время обработки: %3.",ТД.Количество(),ТД.Итог("КолКонИст"),ВремяОбработки));	   
	
	Возврат Результат;	
КонецФункции //ВыгрузитьОстатки()

