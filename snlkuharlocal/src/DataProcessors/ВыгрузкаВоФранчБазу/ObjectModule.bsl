#Область Регламент

Процедура Сформировать(ТаблицаПараметров=Неопределено) Экспорт	
	Если НЕ ФР_ОбщегоНазначения_ПИ.МожноЗапускатьАвтоОбмен() Тогда
		ЗаписатьВЛог("Регламент","Отмена выполнения. Задача: Внешнее задание: Обмен с франч базой. Недопустимая строка соединения текущей ИБ !","Информация");		
		Возврат;			
	Иначе
		
	КонецЕсли;
	
	СтрПараметров="";
	мПараметры=Новый Соответствие;
	Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
		мПараметры.Вставить(СтрокаТП.Имя,СтрокаТП.Значение);
		СтрПараметров=Символы.ПС+СтрПараметров+СтрокаТП.Имя+" - "+СтрокаТП.Значение
	КонецЦикла;
	
	ЗаписатьВЛог("Регламент","Задача: Внешнее задание: Обмен с франч базой. Запуск ! "+Символы.ПС+СтрПараметров,"Информация");		
	
	Направления	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(мПараметры,"Направление");
	Для Каждого Направление Из СтрРазделить(Направления,",") Цикл
		Если Направление="Прием" ИЛИ Направление="Отправка" Тогда
			Если НЕ ЗаданиеАктивно(Направление) Тогда
				ФР_Регламент.ЗапуститьФЗ_Обмена("ФР_ОбменСФРК",Направление,мПараметры);
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

Функция ЗаданиеАктивно(Направление)
	Ключ		= "ОбменСТЦ.ЦО."+Направление;
	
	Результат		= Ложь;
	МассивЗаданий	= ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Ключ",Ключ));
	Для Каждого ФЗ Из МассивЗаданий Цикл
		Если ФЗ.Состояние=СостояниеФоновогоЗадания.Активно Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ЗаданиеАктивно(Направление)

