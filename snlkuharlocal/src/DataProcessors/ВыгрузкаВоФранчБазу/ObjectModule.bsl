Функция ЗагрузитьПер_СтавкаНДС(СтавкаНДС)	
	Результат	= Перечисления.СтавкиНДС.БезНДС;
	
	Если СтавкаНДС="НДС20" Тогда
		Результат	= Перечисления.СтавкиНДС.НДС20;
	ИначеЕсли СтавкаНДС="НДС10" Тогда		
		Результат	= Перечисления.СтавкиНДС.НДС10;	
	//+SNL-77 20260111 Михайловский	
	ИначеЕсли СтавкаНДС="НДС22" Тогда		
		Результат	= Перечисления.СтавкиНДС.НДС22;
	//-SNL-77 20260111 Михайловский	
	//+HELP-2538 20250115 Михайловский
	ИначеЕсли СтавкаНДС="НДС5" Тогда
		Результат	= Перечисления.СтавкиНДС.НДС5;
	ИначеЕсли СтавкаНДС="НДС7" Тогда
		Результат	= Перечисления.СтавкиНДС.НДС7;
	//-HELP-2538 20250115 Михайловский	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ЗагрузитьПер_СтавкаНДС(СтавкаНДС)

Функция ЗагрузитьПер(ИмяПеречисления,Знач ИмяЗначения, ЗначениеПоУмолчанию = Неопределено)
	Результат   = Перечисления[ИмяПеречисления].ПустаяСсылка();
	Если ЗначениеЗаполнено(ИмяЗначения) Тогда
		ИмяТек		= СоответствиеЗначенийПеречислений.Получить(ИмяПеречисления+"."+ИмяЗначения);
		ИмяЗначения	= ?(ИмяТек=Неопределено,ИмяЗначения,ИмяТек);		
		
		Попытка
			НовЗнач		= Перечисления[ИмяПеречисления][ИмяЗначения];
			Результат	= НовЗнач;
		Исключение
			Если ЗначениеЗаполнено(ЗначениеПоУмолчанию) Тогда
				Результат	= ЗначениеПоУмолчанию;			
			КонецЕсли; 			
		КонецПопытки;		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ЗагрузитьПер(ИмяПеречисления,Знач ИмяЗначения, ЗначениеПоУмолчанию = Неопределено)

	
