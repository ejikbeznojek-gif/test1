Функция ФранчПодразделениеСсылки(СсылкаНаОбъект)
	Результат	= Справочники.Подразделения.ПустаяСсылка();
	
	Запрос=Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ			
	|	ЗначениеРеквизита КАК Подразделение
	|ИЗ	
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	Справочник	 	= &СсылкаНаОбъект
	|	И ИмяРеквизита	= ""ПодразделениеФранчайзинга""
	|";
	Запрос.УстановитьПараметр("СсылкаНаОбъект",СсылкаНаОбъект);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Подразделение) Тогда
		Результат	= Выборка.Подразделение;	
	КонецЕсли; 

	Возврат Результат;
КонецФункции //ФранчПодразделениеСсылки(Договор)

Функция ВыгрузитьТЧвХДТО(ВыборкаТЧ,ИмяТипаХДТО,ПостоянныеРеквизитыТЧ=Неопределено)
	ОбъектХДТО_ТЧ		= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ИмяТипаХДТО_Строка	= ИмяТипаХДТО+".Строка";
	
	ЕстьПостоянныеРеквизиты	= (ЗначениеЗаполнено(ПостоянныеРеквизитыТЧ));
	
	Пока ВыборкаТЧ.Следующий() Цикл
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО_Строка,ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаТЧ);
		
		Если ЕстьПостоянныеРеквизиты Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ПостоянныеРеквизитыТЧ);
		КонецЕсли;
			
		ОбъектХДТО_ТЧ.Строка.Добавить(СтрокаТЧ_ХДТО);
	КонецЦикла;	
	
	Возврат ОбъектХДТО_ТЧ;
КонецФункции // ()

Функция ПрочитатьЗначениеСвойства(Объект,Свойство)
	МЗ = РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьМенеджерЗаписи();
	
	МЗ.Объект 	= Объект;
	МЗ.Свойство = Свойство;
	
	МЗ.Прочитать();
	
	Возврат МЗ.Значение;
	
КонецФункции // ()

