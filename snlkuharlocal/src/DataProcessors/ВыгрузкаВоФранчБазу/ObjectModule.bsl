Функция ВыгрузитьСпр_Склады_Элемент(СпрВыборка)
	ОбъектХДТО	= Неопределено;
	
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка = Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	КС_ХДТО			= ПолучитьИзКэша(ТекСсылка,"Справочник.Склады");
	
	Если КС_ХДТО = Неопределено Тогда
		КС_ХДТО	= ВыгрузитьСпр_Склады_Элемент_КС(СпрВыборка);		
	КонецЕсли;	
	
	Если НаВходеВыборка Тогда		
		Реквизиты					= СпрВыборка;
	Иначе
		Реквизиты					= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Родитель,Код,Наименование,Подразделение");			
	КонецЕсли;		

	ОбъектХДТО						= СоздатьОбъектХДТО("Справочник.Склады");		
	
	ОбъектХДТО.КлючевыеСвойства		= КС_ХДТО;		
	Если ЗначениеЗаполнено(Реквизиты.Родитель) Тогда
		ОбъектХДТО.Группа			= ВыгрузитьСпр_Склады_Группа_КС(Реквизиты.Родитель);						
	КонецЕсли;
	УстановитьСвойствоХДТО(ОбъектХДТО,"Подразделение",ВыгрузитьСпр_Подразделения_Элемент_КС(Реквизиты.Подразделение));
	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.Код),"Код","string",ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,"ПометкаУдаления",		"boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСправочник_Склады_Элемент(Ссылка)

Функция ВыгрузитьСпр_Склады_Группа(СпрВыборка)	
	ИмяТаблицы	= "Справочник.Склады";
