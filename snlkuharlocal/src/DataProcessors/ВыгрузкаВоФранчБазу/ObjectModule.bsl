	МенеджерРегистраРегистрации	= РегистрыСведений.ФР_ОбъектыКВыгрузке;
	
	Для Каждого ЭлементСостава Из Метаданные.ПланыОбмена[ИмяПланаОбмена].Состав Цикл
		МетаОбъект = ЭлементСостава.Метаданные;
		Если Метаданные.Справочники.Содержит(МетаОбъект) Тогда
			ОбработкаПрерыванияПользователя_();
			
