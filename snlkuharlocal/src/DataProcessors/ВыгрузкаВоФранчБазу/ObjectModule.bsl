Функция ЭтоПРМКассаСНЛ(Склад, СкладПолучатель, ДокНом)
	Рез = Ложь;
	Запр = Новый Запрос;
	Запр.Текст = 
	"ВЫБРАТЬ
	|	Кассы.РозничныйСклад КАК РозничныйСклад
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	НЕ Кассы.ПодразделениеДляУчета = ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	|";
	Выб = Запр.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		//Если Выб.РозничныйСклад = Склад ИЛИ Выб.РозничныйСклад = СкладПолучатель Тогда
		Если Выб.РозничныйСклад = СкладПолучатель Тогда
			Рез = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	//Если Рез И НЕ Лев(ДокНом, 3) = "SNM" Тогда
	//	Рез = Ложь;
	//КонецЕсли;
	Возврат Рез;
КонецФункции
//-HELP-3414 HELP-3399 20250314 Михайловский

Функция ЗагрузитьДок_ПРМ(ОбъектХДТО,Отправитель)
	Менеджер	= Документы.Перемещение;
	Вид			= Метаданные.НайтиПоТипу(ТипЗнч(Менеджер.ПустаяСсылка())).Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли; 
	
	ДокОбъект	= РезультатПоиска.Объект;
	//+Корр обм 20260205 Михайловский
	ДокОбъект.ОбменДанными.Отправитель	= Отправитель;
	//-Корр обм 20260205 Михайловский
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);	
	ДокОбъект.СостояниеНакладной			= ЗагрузитьПер("СостоянияНакладной", ОбъектХДТО.СостояниеНакладной, Перечисления.СостоянияНакладной.ВРаботе);
	ДокОбъект.СостояниеНакладнойУПолучателя = ЗагрузитьПер("СостоянияНакладной", ОбъектХДТО.СостояниеНакладнойУПолучателя, Перечисления.СостоянияНакладной.ВРаботе);
	
	//+HELP-3414 HELP-3399 20250314 Михайловский
	ЭтоОтвКассаСНЛ = РезультатПоиска.Найден И ЭтоПРМКассаСНЛ(ДокОбъект.Склад, ДокОбъект.СкладПолучатель, ДокОбъект.Номер);  
	Если НЕ ЭтоОтвКассаСНЛ Тогда
	//-HELP-3414 HELP-3399 20250314 Михайловский
		//+HELP-7543 20251023 Михайловский
		//ПровПодтвЗаяв = ?((ДокОбъект.СостояниеНакладнойУПолучателя = Перечисления.СостоянияНакладной.ВРаботе) И (ДокОбъект.Склад.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ) И (ДокОбъект.СкладПолучатель.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ), Истина, Ложь);
		//+20260114 Кривые ПРМ Михайловский
		//ПровПодтвЗаяв = ?((ДокОбъект.Склад.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ) И (ДокОбъект.СкладПолучатель.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ), Истина, Ложь);
		ПровПодтвЗаяв = ?((ДокОбъект.Склад.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ) ИЛИ (ДокОбъект.СкладПолучатель.ТипСклада = Перечисления.ТипСклада.РозничныйТЦ), Истина, Ложь);
        //-20260114 Кривые ПРМ Михайловский
		//-HELP-7543 20251023 Михайловский
		ЗагрузитьТЧОбъекта(ДокОбъект,ОбъектХДТО,"Товары");
		//+HELP-7543 20251023 Михайловский
		ПровПодтвЗаяв1 = ?(ДокОбъект.Товары.Итог("ПодтвержденнаяЗаявка") = 0, Истина, Ложь);
		//-HELP-7543 20251023 Михайловский
		Для Каждого СтрокаТЧ Из ДокОбъект.Товары Цикл
			//+HELP-7543 20251023 Михайловский
			Если ПровПодтвЗаяв И ПровПодтвЗаяв1 Тогда
				Если НЕ (СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Заявка) И (СтрокаТЧ.ПодтвержденнаяЗаявка = 0) Тогда
					СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Заявка;
				КонецЕсли;
				Если (СтрокаТЧ.ПодтвержденнаяЗаявка < СтрокаТЧ.Количество) Тогда
					СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Количество;
				КонецЕсли;
			КонецЕсли;	
			//-HELP-7543 20251023 Михайловский
			СтрокаТЧ.ПодтвержденнаяЗаявкаПеремещения 	= СтрокаТЧ.ПодтвержденнаяЗаявка;	
			СтрокаТЧ.ЦенаБезСкидки						= СтрокаТЧ.Цена;
			СтрокаТЧ.ВсегоБезСкидки						= СтрокаТЧ.Всего;
			ЗаполнитьСтавкуНДСТабЧасти(СтрокаТЧ, ДокОбъект);		
		КонецЦикла;	
	КонецЕсли;

	Если ДокОбъект.СостояниеНакладной = Перечисления.СостоянияНакладной.Отгружена Тогда
		ДокОбъект.Отгружен  = Перечисления.Отгружен.Отгружен;
	Иначе
		ДокОбъект.Отгружен  = Перечисления.Отгружен.Резерв;			
	КонецЕсли;
	
	ДокОбъект.ПунктДоставки	= ПолучитьПунктДоставки(ДокОбъект.СкладПолучатель);	
	ДокОбъект.ИБ			= ФР_ОбщегоНазначения_ПИ.ТекущаяИБ();
	ДокОбъект.Валюта 		= ВалютаНац;	
	ДокОбъект.Курс			= ПолучитьКурсВалюты(ДокОбъект.Валюта, ДокОбъект.Дата).Курс;
	
	Описание				= "";
	ЕстьРассогласования		= Ложь;
	ОтправитьОбратно		= Ложь;	
	
	Если 1=2 Тогда
		ДокОбъект=Документы.Перемещение.СоздатьДокумент();	
	КонецЕсли; 
	
	ОтправительДляЕЕ	= ОтправительПеремещенияДляЦО_ЕЕ(ДокОбъект.Склад,ДокОбъект.СкладПолучатель,ДокОбъект.СостояниеНакладнойУПолучателя);
	
	ЭтотУзел			= ФР_ОбщегоНазначения_ПИ.ЭтотУзел("Основной").ПолучитьОбъект();
