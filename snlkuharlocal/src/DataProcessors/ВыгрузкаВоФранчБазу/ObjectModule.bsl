			//	Если НужнаГруппа И Выборка.ЭтоГруппа Тогда					
			//		МенеджерРегистраРегистрации.ЗарегистрироватьОбъект(Выборка.Ссылка);
			//		
			//		НужнаГруппа	= Ложь;
			//	КонецЕсли;
