Функция ЗагрузитьСпр_ВидыПодарочныхСертификатов_КС(ОбъектХДТО,Отправитель=Неопределено)
	Вид			= "ВидыПодарочныхСертификатов";
	ПолныйТип	= "Справочник.ВидыПодарочныхСертификатов_КС";	
	
	Результат	= ПолучитьИзКэша(ОбъектХДТО.Ссылка,ПолныйТип); 
	
	Если Результат<>Неопределено Тогда
		Возврат Результат;		
	Иначе		
		Если ОбъектХДТО.Ссылка="a0792ed1-cc9f-4004-9a55-b7dc6ed64c7d" Тогда
			Результат	= Перечисления.ВидыПодарочныхСертификатов.Собственный;		
		Иначе
			Результат	= Перечисления.ВидыПодарочныхСертификатов.СертификатИзЧека;			
		КонецЕсли; 
	КонецЕсли;		
	
	Возврат Результат;	
КонецФункции //ЗагрузитьСпр_ВидыПодарочныхСертификатов_КС(ОбъектХДТО,Отправитель=Неопределено)

Функция ЗагрузитьСпр_Кассы_Элемент_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)
	Менеджер	= Справочники.Кассы;
	
	Если КС_ХДТО=Неопределено Тогда Возврат Менеджер.ПустаяСсылка() КонецЕсли; 
	
	Ссылка		= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	СпрОбъект	= Неопределено;
	
	Если (фСоздаватьОбъектыПоСсылкам ИЛИ ВернутьОбъект) 
		И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		
		СпрОбъект	= Менеджер.СоздатьЭлемент();		
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
	
		СпрОбъект.Наименование			= КС_ХДТО.Наименование;		
		
		Если НЕ ВернутьОбъект Тогда			
			Ссылка		= ЗаписатьОбъект(СпрОбъект,Отправитель);		
		КонецЕсли;
	КонецЕсли;
	
	Если ВернутьОбъект И СпрОбъект=Неопределено Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();		 
	КонецЕсли;
	
	Возврат ?(ВернутьОбъект,СпрОбъект,Ссылка);
КонецФункции //ЗагрузитьСпр_Кассы_Элемент_КС(ОбъектХДТО_КС,Отправитель=Неопределено,ВернутьОбъект=Ложь)

Функция ЗагрузитьСпр_Организации_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)
	Менеджер	= Справочники.Организации;	
	
	Ссылка		= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	СпрОбъект	= Неопределено;
	
	Если (фСоздаватьОбъектыПоСсылкам ИЛИ ВернутьОбъект) 
		И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		
		СпрОбъект	= Менеджер.СоздатьЭлемент();		
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
		
		СпрОбъект.Наименование			= КС_ХДТО.Наименование;
		СпрОбъект.НаименованиеПолное	= КС_ХДТО.НаименованиеПолное;
	
		СпрОбъект.ИНН					= ПолучитьСвойствоХДТО(КС_ХДТО,"ИНН");
		СпрОбъект.КПП					= ПолучитьСвойствоХДТО(КС_ХДТО,"КПП");
	    //+ HELP-1058 20241002 Михайловский
		Попытка
			//- HELP-1058 20241002 Михайловский
			
			Если КС_ХДТО.ЮридическоеФизическоеЛицо="ЮридическоеЛицо" Тогда
				СпрОбъект.ЮрФизЛицо=Перечисления.ЮрФизЛицо.ЮрЛицо;
			Иначе
				СпрОбъект.ЮрФизЛицо=Перечисления.ЮрФизЛицо.ФизЛицо;		
			КонецЕсли;	
			//+ HELP-1058 20241002 Михайловский
		Исключение
		КонецПопытки;
		//- HELP-1058 20241002 Михайловский
		Если НЕ ВернутьОбъект Тогда			
			Ссылка		= ЗаписатьОбъект(СпрОбъект,Отправитель);		
		КонецЕсли;
	КонецЕсли;
	
	Если ВернутьОбъект И СпрОбъект=Неопределено Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();		 
	КонецЕсли;
	
	Возврат ?(ВернутьОбъект,СпрОбъект,Ссылка);
КонецФункции //ЗагрузитьСпр_Организации_КС(ОбъектХДТО,Отправитель=Неопределено)

Функция ЗагрузитьСпр_Склады_Элемент_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)
	Менеджер	= Справочники.Склады;
	
	Ссылка		= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	СпрОбъект	= Неопределено;
	
	Если (фСоздаватьОбъектыПоСсылкам ИЛИ ВернутьОбъект) 
		И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		
		СпрОбъект	= Менеджер.СоздатьЭлемент();		
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
	
		СпрОбъект.Наименование			= КС_ХДТО.Наименование;		
		
		Если НЕ ВернутьОбъект Тогда			
			Ссылка		= ЗаписатьОбъект(СпрОбъект,Отправитель);		
		КонецЕсли;
	КонецЕсли;
	
	Если ВернутьОбъект И СпрОбъект=Неопределено Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();		 
	КонецЕсли;
	
	Возврат ?(ВернутьОбъект,СпрОбъект,Ссылка);
КонецФункции //ЗагрузитьСпр_Склады_Элемент_КС(ОбъектХДТО_КС,Отправитель=Неопределено)

