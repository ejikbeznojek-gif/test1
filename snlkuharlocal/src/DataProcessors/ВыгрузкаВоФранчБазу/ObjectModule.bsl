Функция ПолучитьМенеджерКласса(Знач КлассПолноеИмя)	Экспорт
	Результат	= Неопределено;
	
	Части		= СтрРазделить(КлассПолноеИмя,".");
	КлассИмя	= Части[0];	
	
	Если КлассИмя="Справочник" ИЛИ КлассИмя="Справочники" Тогда
		Результат = Справочники;
	ИначеЕсли КлассИмя="Документ" ИЛИ КлассИмя="Документы" Тогда
		Результат = Документы;				
	ИначеЕсли КлассИмя="БизнесПроцесс" ИЛИ КлассИмя="БизнесПроцессы" Тогда
		Результат = БизнесПроцессы;
	ИначеЕсли КлассИмя="Задача" ИЛИ КлассИмя="Задачи" Тогда
		Результат = Задачи;
	ИначеЕсли КлассИмя="ПланВидовХарактеристик" ИЛИ КлассИмя="ПланыВидовХарактеристик" Тогда
		Результат = ПланыВидовХарактеристик;
	ИначеЕсли КлассИмя="РегистрСведений" ИЛИ КлассИмя="РегистрыСведений" Тогда
		Результат = РегистрыСведений;	
	КонецЕсли;
	
	Если Части.Количество()>1 И Результат<>Неопределено Тогда
		МетаОбъект	= Метаданные.НайтиПоПолномуИмени(КлассПолноеИмя);
		Если МетаОбъект<>Неопределено Тогда		
			Результат	= Результат[Части[1]];		
		Иначе
			Результат	= Неопределено;		
		КонецЕсли;		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьМенеджерКласса(КлассИмя)

Функция РазобратьВходнойПараметр(Выборка,ИмяТаблицы)
	Результат	= Новый Структура("Результат",Ложь);
	
	Части		= СтрРазделить(ИмяТаблицы,".");
	
	КлассИмя	= Части[0];
	Вид			= Части[1];
	
	МенеджерКласса	= ПолучитьМенеджерКласса(КлассИмя);
	
	Если МенеджерКласса=Неопределено Тогда
		Результат.Вставить("Ошибки","Невозможно определить менеджер класса для таблицы: "+ИмяТаблицы);
	Иначе
		Менеджер = МенеджерКласса[Вид];
		Если Выборка = Неопределено ИЛИ Выборка = Менеджер.ПустаяСсылка() Тогда
		Иначе
			ТипПараметра	= ТипЗнч(Выборка);
			НаВходеВыборка	= (ТипПараметра=Тип("ВыборкаИзРезультатаЗапроса"));
			
			Результат.Вставить("НаВходеВыборка",НаВходеВыборка);
			Результат.Вставить("Ссылка",		?(НаВходеВыборка,Выборка.Ссылка,Выборка));			
			Результат.Вставить("Выборка",		Выборка);
			Результат.Вставить("ИмяТаблицы",	ИмяТаблицы);
			Результат.Вставить("КлассИмя",		КлассИмя);
			
			Результат.Результат	= ЗначениеЗаполнено(Результат.Ссылка);			
		КонецЕсли; 				
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы)

Функция ПолучитьРеквизитыДляВыгрузки(ВходПараметр,ВариантВыгрузки)
	Если ВходПараметр.НаВходеВыборка Тогда
		Возврат ВходПараметр.Выборка;
	Иначе
		Возврат ПолучитьРеквизитыШапки(ВходПараметр.Ссылка,РеквизитыШапок.Получить(ВходПараметр.ИмяТаблицы+"."+ВариантВыгрузки),ВходПараметр.КлассИмя);
	КонецЕсли;
КонецФункции //ПолучитьРеквизитыДляВыгрузки(ВходПараметр,ВариантВыгрузки)
 
Функция СКДвСтроку(СКД)
	Результат	= Неопределено;
	Если СКД<>Неопределено Тогда		
		времЗаписьXML=Новый ЗаписьXML();
		времЗаписьXML.УстановитьСтроку();
		
		СериализаторXDTO.ЗаписатьXML(времЗаписьXML,СКД,НазначениеТипаXML.Неявное);	
		
		Результат	= Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(времЗаписьXML.Закрыть()));
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //СКДвСтроку(СКД)

Функция СлепитьЗаполненныеПараметры(Разделитель,П1="",П2="",П3="",П4="",П5="",П6="",П7="",П8="",П9="",П10="")
	МП=Новый Массив;
	Для Сч=1 По 10 Цикл
		ЗначПараметра=Вычислить("П"+Сч);
		Если ЗначениеЗаполнено(ЗначПараметра) Тогда
			МП.Добавить(ЗначПараметра);		
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат	СтрСоединить(МП,Разделитель);	
КонецФункции // ()

Функция ВыгрузитьПвх_СвойстваОбъектов_Элемент(СпрВыборка)	
	ИмяТаблицы	= "ПланВидовХарактеристик.СвойстваОбъектов";
	ИмяУзлаХДТО	= "ПланВидовХарактеристик.СвойстваОбъектов.Элемент";	
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяУзлаХДТО,ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьПвх_СвойстваОбъектов_Элемент(СпрВыборка)

Функция ВыгрузитьПвх_СвойстваОбъектов_Элемент_КС(Наименование)	
	ИмяТаблицы="ПланВидовХарактеристик.СвойстваОбъектов";
	Ссылка	= ПолучитьИзКэша(Наименование,ИмяТаблицы);
	Если Ссылка	= Неопределено Тогда
		Ссылка	= ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию(Наименование);
		ВставитьВКэш(Наименование,Ссылка,ИмяТаблицы);
	КонецЕсли; 	
	
	Возврат Ссылка;
КонецФункции //ВыгрузитьПвх_СвойстваОбъектов_Элемент_КС(СпрВыборка)

Функция ВыгрузитьСпр_КС(Ссылка,Вид,Знач Свойства,Знач ИмяТипаХДТО="",ПространствоИмен="")
	ДанныеВида	= ФР_ОбщегоНазначения_КС.СтрокуВСтруктуру(Вид,"Вид,Хвост");	
	ИмяТаблицы	= "Справочник."+ДанныеВида.Вид;
	
	ВхПараметр	= РазобратьВходнойПараметр(Ссылка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
		
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,СлепитьЗаполненныеПараметры(".",ДанныеВида.Хвост,"КС"));	
	
	ОбъектХДТО 	= ПолучитьИзКэша(РеквизитыШ.Ссылка,ИмяТаблицы);
	
	Если ОбъектХДТО = Неопределено Тогда		
		Если ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда 
			Если ПустаяСтрока(ИмяТипаХДТО) Тогда
				ИмяТипаХДТО	= "КлючевыеСвойства"+Вид; 			
			КонецЕсли; 
			ОбъектХДТО			= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен);
			
			ОбъектХДТО.Ссылка	= СериализаторXDTO.XMLСтрока(РеквизитыШ.Ссылка);			
			
			Если ТипЗнч(Свойства)=Тип("Строка") Тогда
				Свойства=Новый Структура(Свойства);	
			КонецЕсли;
			
			Для Каждого Элемент Из Свойства Цикл
				РеквизитИмя=Элемент.Ключ;
				
				Если ЗначениеЗаполнено(Элемент.Значение) Тогда
					ОбъектХДТО[РеквизитИмя] = Элемент.Значение;
				Иначе			
					ОбъектХДТО[РеквизитИмя] = РеквизитыШ[РеквизитИмя];		
				КонецЕсли; 	
			КонецЦикла;
		Иначе
			ОбъектХДТО=Ложь;
		КонецЕсли;
		
		ВставитьВКэш(Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;
	
	//Битая ссылка засунутая в кэш
	Если ОбъектХДТО = Ложь Тогда
		ОбъектХДТО = Неопределено;	
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_КС(Ссылка,Вид,Знач Свойства,Знач ИмяТипаХДТО="")

Функция ПолучитьОрганизациюКонтрагента(КонтрагентСсылка)
