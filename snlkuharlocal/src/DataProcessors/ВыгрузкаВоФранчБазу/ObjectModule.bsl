Функция ВыгрузитьДок_ПСАЗ(ДокВыборка)
	ИмяТаблицы	= "Документ.ЗаявкаНаПостСторонАссорт";
	ИмяТипаХДТО	= "Документ.ЗаявкаНаПостСторонАссорт";
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ИменаТЧ	= "ИменаКолонок,ЗначенияКолонок,Товары,Брэнды,ВидыНоменклатуры,Цвета,Размеры,Коллекции";//,ПродажаПодарочныхСертификатов,ВозвратПодарочныхСертификатов";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"Состояние," + ИменаТЧ);		
	УстановитьСвойствоХДТО(ОбъектХДТО, "Состояние", XMLСтрока(РеквизитыШ.Состояние));
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл	
		ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТаблицы+"."+ИмяТЧ);
	КонецЦикла;
	
	Возврат ОбъектХДТО;	
КонецФункции //-HELP-2306 20250220 Михайловский

Функция ВыгрузитьДок_ОКС_КС(ДокСсылка)
	Если ТипЗнч(ДокСсылка)=Тип("ДокументСсылка.ОтчетКассовойСмены") Тогда
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,"Ссылка,Дата,Номер,Склад.Организация,Номер_Z_Отчета,Касса");
	Иначе
		РеквизитыШапки	= ДокСсылка;
	КонецЕсли;	
	
	КС_XDTO					= СоздатьОбъектХДТО("КлючевыеСвойстваОтчетОРозничныхПродажах");	
	
	КС_XDTO.Ссылка			= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	КС_XDTO.Дата			= РеквизитыШапки.Дата;
	КС_XDTO.Номер			= РеквизитыШапки.Номер; 
	КС_XDTO.Организация		= ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Склад_Организация);
	
	КС_XDTO.КассоваяСмена	= ВыгрузитьДок_КС_КС(РеквизитыШапки);
	
	Возврат КС_XDTO;
КонецФункции //Выгрузить_КлючевыеСвойстваОтчетОРозничныхПродажах(ДокСсылка)

