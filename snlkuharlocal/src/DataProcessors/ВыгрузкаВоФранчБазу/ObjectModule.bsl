Функция ВыгрузитьСпр_Размеры_КС(СпрВыборка)		
	ИмяТаблицы	= "Справочник.Размеры";	
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицы);	
	
	Если ОбъектХДТО=Неопределено Тогда	
		РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");	
		
		Если ПустаяСтрока(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
		
		ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТаблицы+".КС",ПространствоИмен_ЕЕ);	
				
		ОбъектХДТО.Ссылка		= XMLСтрока(РеквизитыШ.Ссылка);
		ОбъектХДТО.Код			= РеквизитыШ.Код;
		ОбъектХДТО.Наименование	= РеквизитыШ.Наименование;
				
		Если ЗначениеЗаполнено(РеквизитыШ.Родитель) Тогда
			ОбъектХДТО.Группа	= ВыгрузитьСпр_Размеры_КС(РеквизитыШ.Родитель);
		КонецЕсли;
		
		ВставитьВКэш(ВхПараметр.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;
	
	Возврат ОбъектХДТО;
