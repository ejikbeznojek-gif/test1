Функция ВыгрузитьСправочник(СсылкаНаОбъект,ВариантВыгрузки=0)		
	ОбъектХДТО	= Неопределено;
	ВидОбъекта	= СсылкаНаОбъект.Метаданные().Имя;
	
	
	Если ВидОбъекта="Номенклатура" Тогда
		Если ВариантВыгрузки=0 Тогда
			ОбъектХДТО	= ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент(СсылкаНаОбъект);
			//ВыгружаемыеХарактеристки.Добавить(СсылкаНаОбъект);
		ИначеЕсли ВариантВыгрузки=1 Тогда
			ОбъектХДТО = ВыгрузитьСпр_Номенклатура_Элемент(СсылкаНаОбъект);
		ИначеЕсли ВариантВыгрузки=2 Тогда
			ОбъектХДТО = ВыгрузитьСпр_Номенклатура_Группа(СсылкаНаОбъект);			
		КонецЕсли; 
		//Реквизиты	= ПолучитьРеквизитыШапки(СсылкаНаОбъект,"Родитель,ЭтоГруппа");
		//Если НЕ Реквизиты.ЭтоГруппа И ЗначениеЗаполнено(Реквизиты.Родитель) Тогда
		//	ВыгрузитьХарактеристикиПоСписку(СсылкаНаОбъект);										
		//КонецЕсли;		
	ИначеЕсли ВидОбъекта="ШтрихКоды" Тогда
		ОбъектХДТО = ВыгрузитьСпр_ШтрихКоды_Элемент(СсылкаНаОбъект);		
	ИначеЕсли ВидОбъекта="Подразделения" Тогда
		ОбъектХДТО = ВыгрузитьСпр_Подразделения_Элемент(СсылкаНаОбъект);
	ИначеЕсли ВидОбъекта="Организации" Тогда
		ОбъектХДТО = ВыгрузитьСпр_Организации_Элемент(СсылкаНаОбъект);		
	ИначеЕсли ВидОбъекта="Цвета" Тогда
		ОбъектХДТО = ВыгрузитьСпр_Цвета_Элемент(СсылкаНаОбъект);		
	ИначеЕсли ВидОбъекта="Кассы" Тогда
		ОбъектХДТО = ВыгрузитьСпр_Кассы_Элемент(СсылкаНаОбъект);
	ИначеЕсли ВидОбъекта="Пользователи" Тогда
		ОбъектХДТО	= ВыгрузитьСпр_Пользователи_Элемент(СсылкаНаОбъект);
	ИначеЕсли ВидОбъекта="Склады" Тогда
		ОбъектХДТО	= ВыгрузитьСпр_Склады_Элемент(СсылкаНаОбъект);
	КонецЕсли;	
	
	
	Возврат ОбъектХДТО;
КонецФункции

Функция ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ="Товары")
	Результат		= Неопределено;
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));
	Если НаВходеВыборка Тогда
		Результат	= ДокВыборка[ИмяТЧ].Выбрать();
	Иначе		
		Запрос	= Новый Запрос;	
		
		Запрос.Текст="
		|ВЫБРАТЬ	
		|	Номенклатура.Родитель 	КАК Номенклатура,
		|	Номенклатура			КАК Характеристика,			
		|	Номенклатура			КАК ХарактеристикаНоменклатуры,
		|	*
		|ИЗ
		|	Документ."+ДокВыборка.Метаданные().Имя+"."+ИмяТЧ+"
		|ГДЕ
		|	Ссылка=&Ссылка
		|УПОРЯДОЧИТЬ ПО 
		|	НомерСтроки
		|";	
		
		Запрос.УстановитьПараметр("Ссылка",ДокВыборка);
		
		Результат = Запрос.Выполнить().Выбрать();		
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьДанныеТЧ_Товары(Ссылка)

Функция ПолучитьДанныеТЧ_Прайс(Ссылка,ОтборРС=Неопределено)
	Запрос	= Новый Запрос;		
	
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ	
	|	ВЫБОР 
	|		КОГДА ТипЦен.Базовый<>ЗНАЧЕНИЕ(Справочник.ТипыЦен.ПустаяСсылка) ТОГДА ТипЦен.Базовый 
	|		ИНАЧЕ ТипЦен 
	|	КОНЕЦ КАК ТипЦен,
	|	Номенклатура					КАК Номенклатура,
	|	Номенклатура.Код				КАК Номенклатура_Код,
	|	Номенклатура.Наименование		КАК Номенклатура_Наименование,
	|	Номенклатура.КодПроизводителя	КАК Номенклатура_Артикул,	
	|
	|	Цена	
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК Цены
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.Номенклатура КАК Спр
	|ПО
	|	Спр.Родитель=Цены.Номенклатура И НЕ Спр.ЭтоГруппа 
	|ГДЕ
	|	Прайс=&Ссылка
	|	И НЕ Спр.Ссылка ЕСТЬ NULL
	|";	
	
	Если ЗначениеЗаполнено(ОтборРС) Тогда
		ЧтениеXML	= Новый ЧтениеXML();
		
		ЧтениеXML.УстановитьСтроку(ОтборРС);
		ЧтениеXML.Прочитать();
		
		НЗ	= СериализаторXDTO.ПрочитатьXML(ЧтениеXML);
			
	КонецЕсли; 
	
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);	
	
	ТР=Запрос.Выполнить().Выгрузить();
	
	ТР.Колонки.Добавить("ДанныеНоменклатуры");	
	
	Сч=0;	
	Для Каждого СтрокаТЧ ИЗ ТР Цикл
		ДанныеНоменклатуры	= Новый Структура();
		
		ДанныеНоменклатуры.Вставить("Номенклатура",	ЗаполнитьПоляПоВыборке(СтрокаТЧ,"Номенклатура",		"Ссылка,Код,Наименование,Артикул"));		
		
		СтрокаТЧ.ДанныеНоменклатуры	= ДанныеНоменклатуры;		
		
		Сч=Сч+1;
		Если Сч%10=0 Тогда
			Состояние_(Сч);		
		КонецЕсли; 
	КонецЦикла;	
	
	Возврат ТР;
КонецФункции //ПолучитьДанныеТЧ_Товары(Ссылка)

