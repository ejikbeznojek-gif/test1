						Если СтрокаТР.Кэшировать Тогда
							Кэши[СтрокаТР.ТипСтрокой].Вставить(Выборка_ТЧ[СтрокаТР.Имя]);						
						КонецЕсли;						
					КонецЦикла;
				КонецЦикла;			
			КонецЦикла;
		КонецЕсли;
		
		ДопЗапросы=Неопределено;
		Если РеквизитыДляВыгрузки.Свойство("ДопЗапросы",ДопЗапросы) И ДопЗапросы<>Неопределено Тогда
			Для Каждого ДопЗапрос Из ДопЗапросы Цикл
				
				Реквизиты_ТЧ	= ДопЗапрос.Реквизиты_ТЧ;
				
				Запрос			= Новый("Запрос");
				Запрос.Текст	= ДопЗапрос.Текст;
				Запрос.УстановитьПараметр("Ссылка",Выборка_Ш.Ссылка);
				
				Выборка_ТЧ	= Запрос.Выполнить().Выбрать();
				Пока Выборка_ТЧ.Следующий() Цикл
					Для Каждого СтрокаТР Из Реквизиты_ТЧ Цикл
						Если СтрокаТР.Кэшировать Тогда
							Кэши[СтрокаТР.ТипСтрокой].Вставить(Выборка_ТЧ[СтрокаТР.Имя]);						
						КонецЕсли;						
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;		
		КонецЕсли; 
		
	КонецЦикла;
	
	Возврат МоментВремени;
КонецФункции

Функция МассивНовыхЭлементовКэша(ИмяКэща)
	Результат	= Новый Массив;
	
	ТекКэш		= Кэши[ИмяКэща];
	Если ТекКэш<>Неопределено Тогда
		Для Каждого Элемент Из ТекКэш Цикл
			Если ТекКэш.Получить(Элемент.Ключ)=Неопределено Тогда
				Результат.Добавить(Элемент.Ключ);		
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции // ()


