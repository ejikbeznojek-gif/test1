Функция ВыгрузитьСпр_ШтрихКоды_Элемент(СпрВыборка) Экспорт
	Если 1=2 Тогда
		СпрОбъект=Справочники.ШтрихКоды.СоздатьЭлемент()	
	КонецЕсли; 
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	Если НаВходеВыборка Тогда
		Реквизиты	= СпрВыборка;
	Иначе
		Реквизиты	= РеквизитыШапок.Получить("Справочник.ШтрихКоды");		
	КонецЕсли;
	
	ОбъектХДТО						= СоздатьОбъектХДТО("Справочник.ШтрихкодыНоменклатуры");	
		
	ОбъектХДТО.ШтрихкодОтбор		= Реквизиты.Наименование;	
	
	ОбъектХДТО.ХарактеристикаОтбор	= ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_КС(Реквизиты.Владелец);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.ТипШК),		"ТипШК", 	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.ВидШК),		"ВидШК", 	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.ФорматШК), 	"ФорматШК", "string",	ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.Ссылка), 	"Ссылка",   "string",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ШтрихКоды_Элемент(СпрВыборка) Экспорт

