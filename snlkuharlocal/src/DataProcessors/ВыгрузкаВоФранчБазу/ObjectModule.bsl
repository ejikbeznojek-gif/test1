Функция ДобавитьОбработчикВыгрузки(ТО,	ИмяТаблицы, ВариантВыгрузки,Знач ПроцедураВыгрузки = "")
	СтрокаТО	= ТО.Добавить();
	
	СтрокаТО.ТипОбъекта			= СформироватьТипСсылки(ИмяТаблицы);
	СтрокаТО.ВариантВыгрузки	= ВариантВыгрузки;	
	СтрокаТО.ИмяТаблицы			= ИмяТаблицы;
	
	Если ПустаяСтрока(ПроцедураВыгрузки) Тогда
		Части	= СтрРазделить(ИмяТаблицы,".");
		
		Класс	= Части[0];
		Если Класс="Документ" Тогда
			ПрефиксКласса="Док";		
		ИначеЕсли Класс="ПланВидовХарактеристик" Тогда				
			ПрефиксКласса="Пвх";		
		ИначеЕсли Класс="Справочник" Тогда
			ПрефиксКласса="Спр";
		Иначе
			ПрефиксКласса=Лев(Класс,3);						
		КонецЕсли; 
		
		ПроцедураВыгрузки	= "Выгрузить"+ПрефиксКласса+"_"+Части[1]+"_"+ВариантВыгрузки;
	КонецЕсли;
	
	СтрокаТО.ПроцедураВыгрузки	= ПроцедураВыгрузки;
	
КонецФункции //ДобавитьОбработчикВыгрузки(ТО,	ИмяТаблицы, ВариантВыгрузки,Знач ПроцедураВыгрузки = "")
 
Функция СформироватьТипСсылки(ИмяМетаданных,ВернутьИмяТипа=Ложь)
	Результат   = Неопределено;
	Части		= СтрРазделить(ИмяМетаданных,".");
	Если Части.Количество()=2 Тогда
		Результат	= Части[0]+"Ссылка."+Части[1];
		Если НЕ ВернутьИмяТипа Тогда
			Результат	= Тип(Результат);		
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //СформироватьТипСсылки(ИмяМетаданных)

Функция ВыгрузитьПакетом(РежимВыгрузки, ДопПараметры=Неопределено) Экспорт
	Результат		= Новый Структура("ИД_Сеанса,Адрес,ВыгруженоОбъектов,ВыгруженныеОбъекты,Ошибки,Данные",ИД_Сеанса,"",0,Новый Массив,Новый Массив,"");
	
	СписокОбъектов	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"СписокОбъектов");
	Получатель		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"Получатель");	
	ИД_Сеанса		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"ИД_Сеанса",Новый УникальныйИдентификатор);
	
	Если СписокОбъектов<>Неопределено И СписокОбъектов.Количество()=0 Тогда 
		ТекстСообщения	= "Передан пустой список объектов !";
		Сообщить_(,СтатусСообщения.Важное);
		Результат.Ошибки.Добавить(ТекстСообщения);
		Возврат Результат; 
	КонецЕсли;
	
	НужнаИнициализация	= Ложь;
	Если ТекУзелПолучатель<>УзелПолучатель Тогда
		ТекУзелПолучатель	= УзелПолучатель;
		НужнаИнициализация	= Истина;
	КонецЕсли; 
	
	Если КомпонентаОбмена=Неопределено Тогда
		НужнаИнициализация=Истина;	
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(УзелОтправитель)  Тогда
		УзелОтправитель	= ПланыОбмена[УзелПолучатель.Метаданные().Имя].ЭтотУзел();	
	КонецЕсли;	
	
	Если РежимВыгрузки="Очередь" Тогда				
		Очередь				= "to_"+ТекУзелПолучатель.Код;
		Если НужнаИнициализация И НЕ  ИнициализироватьКомпонентуОбмена(ТекУзелПолучатель) Тогда
			ТекстСообщения	= "Обмен с ФР. Не удалось соединиться с очередью !";
			ЗаписатьВЛог("Регламент",ТекстСообщения,"Ошибка",Истина);		
			
			Результат.Ошибки.Добавить(ТекстСообщения);
			Возврат Результат;
		КонецЕсли;		
	КонецЕсли;	
	
	Кэши	= Новый Соответствие;	
	
	Если РежимВыгрузки="Файл" Тогда
		ИнициализироватьЗаписьXML(ИмяФайлаОбмена);	
	КонецЕсли;		
	
	ОбработчикиВыгрузки	= ПолучитьОбработчикиВыгрузки();
	Для Каждого СтрокаО Из ОбработчикиВыгрузки Цикл
		Если СтрНайти(СтрокаО.ВариантВыгрузки,"РегистрСведений.")=0 Тогда
			Реквизиты	= РеквизитыДляВыгрузки(СтрокаО.ИмяТаблицы,СтрокаО.ВариантВыгрузки);	
		КонецЕсли;		
	КонецЦикла; 
	
	Если СписокОбъектов=Неопределено Тогда
		Запрос			= Новый Запрос;
		Запрос.Текст	= "	
		|ВЫБРАТЬ РАЗЛИЧНЫЕ 
		|	ОбъектТип,
		|	ВариантВыгрузки	
		|ИЗ
		|	РегистрСведений.ФР_ОбъектыКВыгрузке
		|ИТОГИ ПО ОбъектТип,ВариантВыгрузки";		
		
		ЗапросСписка	= Неопределено;
	Иначе
		Запрос	= ЗапросПоСпискуОбъектов(СписокОбъектов,Получатель);
		
		Запрос.Текст="
		|ВЫБРАТЬ РАЗЛИЧНЫЕ 
		|	ОбъектТип,
		|	ВариантВыгрузки	
		|ИЗ
		|	ВТ_ОбъектыКВыгрузке
		|ИТОГИ ПО ОбъектТип,ВариантВыгрузки";
		
		ЗапросСписка = Новый Запрос;
		ЗапросСписка.МенеджерВременныхТаблиц	= Запрос.МенеджерВременныхТаблиц;
		
		ЗапросСписка.Текст="
		|ВЫБРАТЬ РАЗЛИЧНЫЕ 
		|	ОбъектТип,
		|	ОбъектСсылка,
		|	ОбъектСсылкаУИД,
		|	ВариантВыгрузки,			
		|	Номер,
		|	Получатель
		|ИЗ
		|	ВТ_ОбъектыКВыгрузке		
		|ГДЕ
		|	ОбъектТип 			= &ОбъектТип
		|	И ВариантВыгрузки	= &ВариантВыгрузки
		|	И Номер				> &НачНомер
		|УПОРЯДОЧИТЬ ПО 
		|	ОбъектТип,
		|	ВариантВыгрузки,			
		|	Номер,
		|	ОбъектСсылка
		|";		
	КонецЕсли; 
	
	ВыборкаПоТипам	= Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ОбъектТип");
			
	Пока ВыборкаПоТипам.Следующий() Цикл
		ОбъектТип	=  ВыборкаПоТипам.ОбъектТип;
		ВыборкаПоВариантамВыгрузки = ВыборкаПоТипам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ВариантВыгрузки");
		Пока ВыборкаПоВариантамВыгрузки.Следующий() Цикл			
			ОбработкаПрерыванияПользователя_();			
			
			ВариантВыгрузки	= ВыборкаПоВариантамВыгрузки.ВариантВыгрузки;
			
			Если ЗапросСписка<>Неопределено Тогда
				ЗапросСписка.УстановитьПараметр("ОбъектТип",		ОбъектТип);
				ЗапросСписка.УстановитьПараметр("ВариантВыгрузки",	ВариантВыгрузки);
			КонецЕсли; 
			
			СтрокиТО		= ОбработчикиВыгрузки.НайтиСтроки(Новый Структура("ИмяТаблицы,ВариантВыгрузки",ОбъектТип,СокрЛП(ВариантВыгрузки))); 
			Если СтрокиТО.Количество()=0 Тогда
				Сообщить_("Не найдена процедура выгрузки ! Тип объекта: """+ОбъектТип+""", вариант выгрузки: """+ВариантВыгрузки+""" !",СтатусСообщения.Важное);
			ИначеЕсли СтрокиТО.Количество()=1 Тогда
				СтрокаТО	= СтрокиТО[0];
				Если СтрНайти(ВариантВыгрузки,"РегистрСведений.")=1 Тогда
					ТекРез	= ВыгрузитьПакетом_Регистр(СтрокаТО.ИмяТаблицы,СтрокаТО.ПроцедураВыгрузки,ВариантВыгрузки,РежимВыгрузки);				
				Иначе
					Попытка
						ТекРез	= ВыгрузитьПакетом_Объект(СтрокаТО.ИмяТаблицы,СтрокаТО.ПроцедураВыгрузки,ВариантВыгрузки,РежимВыгрузки,ЗапросСписка);
						Если ТекРез.ЕстьОшибки Тогда
							ДобавитьОшибки(Результат,ТекРез);
						КонецЕсли; 
						Результат.ВыгруженоОбъектов=Результат.ВыгруженоОбъектов+ТекРез.ВыгруженоОбъектов;
					Исключение
						ТекстСообщения	= "Ошибка выгрузки объекта: "+ОбъектТип+", вариант выгрузки: "+ВариантВыгрузки+". "+ОписаниеОшибки();
						Сообщить_(ТекстСообщения);
						Результат.Ошибки.Добавить(ТекстСообщения);
					КонецПопытки;					
				КонецЕсли;			
			Иначе
				Сообщить_("Определено несколько процедур выгрузки ! Тип объекта: """+ОбъектТип+""", вариант выгрузки: """+ВариантВыгрузки+""" !",СтатусСообщения.Важное);
			КонецЕсли;			
		КонецЦикла; 
	КонецЦикла;		
	
	Если РежимВыгрузки = "Файл" Тогда		
		Результат.Данные = ЗакрытьЗаписьXML();	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Процедура ДобавитьОшибки(Рез1,Рез2)
	Для Каждого ТекстОшибки Из Рез2.Ошибки Цикл
		Рез1.Ошибки.Добавить(ТекстОшибки);	
	КонецЦикла;
КонецПроцедуры
 

Функция ЗапросПоСпискуОбъектов(СписокОбъектов,Получатель=Неопределено)	
	ТипСтрока200	= ПолучитьОписаниеТиповСтроки(200);
	
	ТабОбъектов = Новый ТаблицаЗначений();		
	ТабОбъектов.Колонки.Добавить("ОбъектТип",		ТипСтрока200);
	ТабОбъектов.Колонки.Добавить("ОбъектСсылкаУИД",	Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТабОбъектов.Колонки.Добавить("ОбъектСсылка",	ФР_ОбщегоНазначения_С.Тип_ВсеСсылки());
	ТабОбъектов.Колонки.Добавить("Тип",				ТипСтрока200);	
	ТабОбъектов.Колонки.Добавить("Вид",				ТипСтрока200);	
	ТабОбъектов.Колонки.Добавить("ИмеетГруппы",		Новый ОписаниеТипов("Булево"));
	ТабОбъектов.Колонки.Добавить("ВариантВыгрузки",	ТипСтрока200);	
	ТабОбъектов.Колонки.Добавить("Номер",			ПолучитьОписаниеТиповЧисла(10));
	ТабОбъектов.Колонки.Добавить("Получатель",		Новый ОписаниеТипов("СправочникСсылка.Подразделения"));	
	
	Если ТипЗнч(СписокОбъектов)=Тип("Массив") Тогда
		Для Каждого Элемент Из СписокОбъектов Цикл			
			СтрокаТО					= ТабОбъектов.Добавить();
			СтрокаТО.ОбъектСсылка	 	= Элемент;
		КонецЦикла; 	
	ИначеЕсли ТипЗнч(СписокОбъектов)=Тип("ТаблицаЗначений") Тогда
		Для Каждого СтрокаИсх Из СписокОбъектов Цикл
			СтрокаТО					= ТабОбъектов.Добавить();
			СтрокаТО.ОбъектСсылка		= СтрокаИсх.ОбъектСсылка;
			СтрокаТО.ВариантВыгрузки	= СтрокаИсх.ВариантВыгрузки;
		КонецЦикла;				
	КонецЕсли; 
	
	Менеджер = РегистрыСведений.ФР_ОбъектыКВыгрузке;
	
	СтрокиКУдалению=Новый Массив;
	
	Номер	= 0;
	Для Каждого СтрокаТО Из ТабОбъектов Цикл
		Если ЗначениеЗаполнено(СтрокаТО.ОбъектСсылка) Тогда
			Номер = Номер+1;
			
			ОТ	  = ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ЗначениеВСтрокуВнутр(ТипЗнч(СтрокаТО.ОбъектСсылка)));			
			
			СтрокаТО.ОбъектСсылкаУИД 	= СтрокаТО.ОбъектСсылка.УникальныйИдентификатор();			
			СтрокаТО.ОбъектТип			= ОТ.ПолноеИмя;			
			СтрокаТО.Номер				= Номер;
			
			Если ОТ.КлассЕЧ="Справочник" ИЛИ ОТ.КлассЕЧ="ПланВидовХарактеристик" Тогда				
				СтрокаТО.ИмеетГруппы	= ОТ.ИмеетГруппы;
			КонецЕсли;
			
			СтрокаТО.ВариантВыгрузки	= РегистрыСведений.ФР_ОбъектыКВыгрузке.ВариантВыгрузки(СтрокаТО.ОбъектСсылка,СтрокаТО.ВариантВыгрузки);
			СтрокаТО.Получатель			= Получатель;
		КонецЕсли;	
	КонецЦикла;
	Для Каждого СтрокаТО Из СтрокиКУдалению Цикл
		ТабОбъектов.Удалить(СтрокаТО);	
	КонецЦикла;
	
	Запрос=Новый ("Запрос");
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	
	Запрос.Текст="	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_ТабОбъектов ИЗ &ТабОбъектов КАК ТабОбъектов	
	|;	
	|ВЫБРАТЬ
	|	ОбъектТип		КАК ОбъектТип,
	|	ОбъектСсылка	КАК ОбъектСсылка,
	|	ОбъектСсылкаУИД	КАК ОбъектСсылкаУИД,
	|	ВЫБОР 
	|		КОГДА ИмеетГруппы И ВариантВыгрузки="""" ТОГДА 
	|			ВЫБОР 
	|				КОГДА ОбъектСсылка.ЭтоГруппа ТОГДА ""Группа"" 
	|				ИНАЧЕ ""Элемент"" 
	|			КОНЕЦ
	|		ИНАЧЕ ВариантВыгрузки
	|	КОНЕЦ КАК ВариантВыгрузки,
	|	Номер,
	|	Получатель
	|ПОМЕСТИТЬ ВТ_ОбъектыКВыгрузке
	|ИЗ
	|	ВТ_ТабОбъектов
	|";	
	
	Запрос.УстановитьПараметр("ТабОбъектов",ТабОбъектов);
	Запрос.Выполнить();
	
	Запрос.Текст="ВЫБРАТЬ * ИЗ ВТ_ОбъектыКВыгрузке";
//	Т1=Запрос.Выполнить().Выгрузить();
	 
	Возврат Запрос;
КонецФункции //ЗапросПоСпискуОбъектов()

Функция ИмяМетаданныхПоТипу(ТипОбъекта)
	Результат	= ""+ТипОбъекта;
	МетаОбъект	= Метаданные.НайтиПоТипу(ТипОбъекта);
	Если МетаОбъект<>Неопределено Тогда
		Результат=МетаОбъект.ПолноеИмя();			
	КонецЕсли; 	
	Возврат Результат;
КонецФункции //ИмяМетаданныхПоТипу(ТипОбъекта)

