Функция ПолучитьПунктДоставкиПодразделения(Подразделение)
	Результат = Справочники.ПунктыДоставки.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Справочник КАК ПунктДоставки
	|ИЗ
	|	РегистрСведений.РеквизитыСправочников КАК РеквизитыСправочников
	|ГДЕ
	|	ИмяРеквизита		= ""ПодразделениеФранчайзинга""
	|	И ЗначениеРеквизита	= &Подразделение
	|	И Справочник Ссылка Справочник.ПунктыДоставки
	|";
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ПунктДоставки) Тогда
		Результат = Выборка.ПунктДоставки; 	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции // ()
 

Функция НайтиСоздатьДокумент(ТекстСсылки,Вид)
	Менеджер		= Документы[Вид];
	
	Результат 		= Новый Структура("Найден,Ссылка,Объект,ПолноеИмяТипа",Ложь,Менеджер.ПустаяСсылка(),Неопределено,Метаданные.Документы[Вид].ПолноеИмя());
	
	Если ТипЗнч(ТекстСсылки)=Тип("Строка") Тогда
		Результат.Ссылка = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекстСсылки));	
	ИначеЕсли ТипЗнч(ТекстСсылки)=Тип("УникальныйИдентификатор") Тогда
		Результат.Ссылка = Менеджер.ПолучитьСсылку(ТекстСсылки);			
	Иначе
		Результат.Ссылка = ТекстСсылки;		
	КонецЕсли;
	
	Если ОбъектСуществует(Результат.Ссылка,"Документ."+Вид) Тогда			
		Результат.Найден	= Истина;
		Если фПерезаписыватьДокументы Тогда
			Результат.Объект = Результат.Ссылка.ПолучитьОбъект();		
		КонецЕсли;		
	Иначе
		ДокОбъект	= Менеджер.СоздатьДокумент();		
		ДокОбъект.УстановитьСсылкуНового(Результат.Ссылка);
		
		Результат.Объект = 	ДокОбъект;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьДокумент(ТекстСсылки,Вид)

Функция ДанныеНоменклатуры(ОбъектХДТО)
	Результат=Новый Структура;
	
	Номенклатура_УИД	= Новый УникальныйИдентификатор(ОбъектХДТО.ДанныеНоменклатуры.Номенклатура.Ссылка);
	Характеристика_УИД	= Новый УникальныйИдентификатор(ОбъектХДТО.ДанныеНоменклатуры.Характеристика.Ссылка);
	
	Результат.Вставить("Номенклатура",	Справочники.Номенклатура.ПолучитьСсылку(Характеристика_УИД));	
	
	Возврат Результат;
КонецФункции //ПолучитьДанныеНоменклатуры(ОбъектХДТО)

Функция ЗаписатьДокумент(ДокОбъект,Отправитель,Найден)
	Если ДокОбъект.Метаданные().Имя="УстановкаСкидок" Тогда
		ПроверятьЛогикуОбмена = Ложь;
	Иначе
		ПроверятьЛогикуОбмена = Истина;			
	КонецЕсли; 
	
	Результат = МожноЗаписатьДокумент_(ДокОбъект,Отправитель,Найден,ПроверятьЛогикуОбмена);
	Если Результат.Результат Тогда
		ДокОбъект.ОбменДанными.Загрузка	= Истина;
		Если Отправитель<>"Нечто" Тогда
			Попытка
				ДокОбъект.ОбменДанными.Отправитель = Отправитель;	
			Исключение
				#ЕСЛИ КЛИЕНТ ТОГДА
				Сообщить("Ошибка установки отправителя: "+ОписаниеОшибки(), СтатусСообщения.Важное);
				#КОНЕЦЕСЛИ
			КонецПопытки;			
		КонецЕсли; 
		
		ДокОбъект.Записать();	
		
		Статус			= "Записан";
		СтатусЗаписи    = ?(Найден,"Перезапись","Новый");		
		
		Если ДокОбъект.Проведен Тогда
			ДокОбъект.ОбменДанными.Загрузка=Ложь;
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);	
			
			Статус			= "Проведен";			
		Иначе
			Если ЗначениеЗаполнено(ДокОбъект.Ссылка) Тогда
				ОчиститьДвиженияДокумента(ДокОбъект.Ссылка, Истина);			
			КонецЕсли;			
		КонецЕсли;
		ДобавитьОбъектВПротоколОбмена(ДокОбъект,СтатусЗаписи,Статус);
	Иначе
		ДобавитьОбъектВПротоколОбмена(ДокОбъект,"","Пропущен",СтрСоединить(Результат.Ошибки,Символы.ПС));		
	КонецЕсли;
КонецФункции //ЗаписатьДокумент(ДокОбъект)

Функция МожноЗаписатьДокумент_(ДокОбъект,Отправитель,Найден,ПроверятьЛогикуОбмена=Истина)
	Результат 		= Новый Структура("Результат,Ошибки",Истина,Новый Массив);	
	
	ИмяПланаОбмена	= "ФР_ОбменСФРК";
	ИмяТаблицы		= ДокОбъект.Метаданные().ПолноеИмя();	
	
	Если ПроверятьЛогикуОбмена И НЕ ФР_ОбщегоНазначения_ПИ.ОбъектХодитСнизуВверх(ИмяПланаОбмена,ИмяТаблицы) Тогда
		Результат.Результат = Ложь;
		Результат.Ошибки.Добавить("Объект не ходит снизу вверх.");		
	Иначе		
		//+ASU-824 20260316 Михайловский
		//вместо
		//Если НЕ КонтрольДатыЗапрета(ДокОбъект) Тогда
		Если НЕ ОбщегоНазначения_ПИ.КонтрольДатыЗапрета_ПИ(ДокОбъект.Метаданные().Имя, ДокОбъект.Дата) Тогда
		//-ASU-824 20260316 Михайловский
			Результат.Результат = Ложь;
			Результат.Ошибки.Добавить("Объект находится за границей редактирования.");
		Иначе
			Если Найден Тогда			 
				Если ТипЗнч(ДокОбъект)=Тип("ДокументОбъект.Заказ") Тогда
					СостояниеЗаказа = ПолучитьРеквизитШапки(ДокОбъект.Ссылка,"СостояниеНакладной","Документ");
					Если СостояниеЗаказа<>Перечисления.СостоянияЗаказаКонтрагента.ВРаботе Тогда
						ТекстОшибки = СтрШаблон("Недопустимое состояние заказа в базе SNL: '%1' !",СостояниеЗаказа);
						Результат.Результат = Ложь;
						Результат.Ошибки.Добавить(ТекстОшибки);
					КонецЕсли; 
				ИначеЕсли ТипЗнч(ДокОбъект)=Тип("ДокументОбъект.ЗаявкаНаВозвратОтПокупателя") Тогда
					РеквизитыШ = ПолучитьРеквизитШапки(ДокОбъект.Ссылка,"СостояниеСогласования_Поставщик,СостояниеСогласования_Покупатель","Документ");
					
					Если СравнитьЗначенияПеречисления(РеквизитыШ.СостояниеСогласования_Поставщик,Перечисления.СостоянияСогласования.НаСогласованииЦО)>0
						И СравнитьЗначенияПеречисления(РеквизитыШ.СостояниеСогласования_Покупатель,Перечисления.СостоянияСогласования.ОтмененКонтрагент)>=0 Тогда
						ТекстОшибки = СтрШаблон("Недопустимое состояние заявки в базеSNL ! Поставщик: '%1', покупатель: '%2' !",
							РеквизитыШ.СостояниеСогласования_Поставщик,
							РеквизитыШ.СостояниеСогласования_Покупатель
						);
						
						Результат.Результат = Ложь;
						Результат.Ошибки.Добавить(ТекстОшибки);
					КонецЕсли; 					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //МожноЗаписатьДокумент_(ДокОбъект,Отправитель,Найден)

Функция ДобавитьОбъектВПротоколОбмена(Знач Объект,СтатусЗаписи,Действие,ТекстОшибки=Неопределено)	
	
	Если ТипЗнч(Объект)=Тип("Строка") Тогда
		ИмяТаблицы	= ПолучитьТипТек(Объект);
		Ссылка		= Неопределено;
	Иначе
		ИмяТаблицы		= Объект.Метаданные().ПолноеИмя();
		ТипЗнчСтрВнутр	= ЗначениеВСтрокуВнутр(ТипЗнч(Объект));	
		
		Если ФР_ОбщегоНазначения_ПИ.ЭтоСсылочныйТип(ТипЗнчСтрВнутр) Тогда
			Если ФР_ОбщегоНазначения_ПИ.ЭтоСсылка(ТипЗнчСтрВнутр) Тогда
				Ссылка= Объект;
			Иначе
				Ссылка= Объект.Ссылка;				
			КонецЕсли;			
		Иначе						
			Ссылка= Неопределено;			
		КонецЕсли;		
	КонецЕсли; 
	
	СтрокаТО				= ОбъектыОбмена.Добавить();
	
	СтрокаТО.ОбъектТип			= ИмяТаблицы;
	Если Ссылка<>Неопределено Тогда
		СтрокаТО.ОбъектСсылкаУИД= Ссылка.УникальныйИдентификатор();	
	КонецЕсли;	
	СтрокаТО.Ошибки				= ТекстОшибки;	
	СтрокаТО.Действие			= Действие;
	СтрокаТО.СтатусЗаписи		= СтатусЗаписи;
	СтрокаТО.Ссылка				= Ссылка;
	
	Если СтрНайти(ИмяТаблицы,"РегистрСведений.")=1 Тогда
		СтрокаТО.КоличествоЗаписей = Объект.Количество();		
	КонецЕсли; 
	
КонецФункции //ДобавитьОбъектВПротоколЗагрузки()

Функция ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,Ошибки="")	
		
	СтрокаТО				= ОбъектыОбмена.Добавить();
	
	СтрокаТО.ОбъектТип			= РезультатПоиска.ПолноеИмяТипа;
	Если РезультатПоиска.Ссылка<>Неопределено Тогда
		СтрокаТО.ОбъектСсылкаУИД= РезультатПоиска.Ссылка.УникальныйИдентификатор();	
	КонецЕсли;	
	СтрокаТО.Ошибки				= Ошибки;	
	СтрокаТО.Действие			= "Пропуск";
	СтрокаТО.СтатусЗаписи		= "";
		
КонецФункции // ()

Процедура ОчиститьДвиженияДокумента(ДокСсылка,Записывать=Ложь) Экспорт
	
	Если ДокСсылка.Пустая() Тогда Возврат КонецЕсли; 
	
	МетаДок	= Метаданные.НайтиПоТипу(ТипЗнч(ДокСсылка));
	Для Каждого Движение Из МетаДок.Движения Цикл
		ОписаниеТипа=ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(Движение.ПолноеИмя());
		Если ОписаниеТипа.Тип="РегистрНакопления" Тогда
			НЗ=РегистрыНакопления[ОписаниеТипа.Вид].СоздатьНаборЗаписей();
		ИначеЕсли ОписаниеТипа.Тип="РегистрСведений" Тогда
			НЗ=РегистрыСведений[ОписаниеТипа.Вид].СоздатьНаборЗаписей();
		Иначе
			НЗ=Неопределено;		
		КонецЕсли; 
		Если НЗ<>Неопределено Тогда
			НЗ.Отбор.Регистратор.Установить(ДокСсылка,Истина);
			НЗ.Записать();
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры // ОчиститьДвиженияДокумента()

