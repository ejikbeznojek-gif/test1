		УстановитьСвойствоХДТО(СтрокаXDTO,"ЕдиницаИзмерения",ВыгрузитьСпр_Единицы_Элемент_КС(ВыборкаПоТЧ.Единица));
		
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.Цена					= ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество;
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);
		СтрокаXDTO.СуммаНДС				= ВыборкаПоТЧ.НДС;
		СтрокаXDTO.НомерЧекаККМПродажи	= ВыборкаПоТЧ.НомерЧекаККМ;
		
		//ГТД=ПолучитьГТД(СтрокаТЧ.Номенклатура.Родитель,ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли; 
		
		ТЧ_XDTO.Строка.Добавить(СтрокаXDTO);
	КонецЦикла;
	
	Возврат ТЧ_XDTO;
КонецФункции //Выгрузить_ТЧ_ОтчетОРозничныхПродажах_Возвраты(ДокСсылка)

Функция ВыгрузитьДок_ПрайсЛист(ДокВыборка,ДопИнфо=Неопределено)
	ИмяТаблицы	= Метаданные.Документы.ПрайсЛист.ПолноеИмя();
	ИмяТипаХДТО	= ИмяТаблицы;
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);	
	
	Если ЗначениеЗаполнено(ДокВыборка.ТипЦен_Базовый) Тогда
		ТипЦен			= ДокВыборка.ТипЦен_Базовый;
		Подразделение	= ПодразделениеТипаЦен(ДокВыборка.ТипЦен);
	Иначе	
		ТипЦен			= ДокВыборка.ТипЦен;
		Подразделение	= Справочники.Подразделения.ПустаяСсылка();
	КонецЕсли;	
	
	ОбъектХДТО.ТипЦен		 = ТипЦен;
	ОбъектХДТО.Подразделение = Подразделение;
	
	ОбъектХДТО.ДействителенПо= РеквизитыШ.Дата2; 
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьДок_ПрайсЛист(ДокВыборка,ДопИнфо=Неопределено)

Функция ВыгрузитьДок_ПрайсЛист_ЕД(ДокВыборка,ДопИнфо=Неопределено)
	Если 1=2 Тогда
		ДокСсылка=Документы.ПрайсЛист.ПустаяСсылка();	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);	
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		ИменаРеквизитов	= РеквизитыШапок.Получить("Документ.ПрайсЛист");
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,ИменаРеквизитов);	
	КонецЕсли;	
	
	ДокОбъектХДТО					= СоздатьОбъектХДТО("Документ.УстановкаЦенНоменклатуры");	
	
	ДокОбъектХДТО.КлючевыеСвойства 	= ВыгрузитьДок_УстановкаЦенНоменклатуры_КС(ДокСсылка);		
	УстановитьСвойствоХДТО(ДокОбъектХДТО,"Ответственный", ВыгрузитьСпр_Пользователи_Элемент_КС(ДокСсылка.Автор));
	
	Если ЗначениеЗаполнено(ДокВыборка.ТипЦен_Базовый) Тогда
		ТипЦен			= ДокВыборка.ТипЦен_Базовый;
		Подразделение	= ПодразделениеТипаЦен(ДокВыборка.ТипЦен);
	Иначе	
		ТипЦен			= ДокВыборка.ТипЦен;
		Подразделение	= Справочники.Подразделения.ПустаяСсылка();
	КонецЕсли;	
	
	ДокОбъектХДТО.ТипЦен			= ВыгрузитьСпр_ТипыЦен_Элемент_КС(ТипЦен);	
	
	ДокОбъектХДТО.Комментарий		= РеквизитыШапки.Комментарий;
	
	Надо=Ложь;
	
	
	Если ТипЗнч(ДопИнфо)=Тип("Строка")  Тогда
		Товары	= ПолучитьДанныеТЧ_Прайс(ДокСсылка,ДопИнфо);
	Иначе
		Товары	= ПолучитьДанныеТЧ_Прайс(ДокСсылка);
	КонецЕсли; 
	
	Если Товары.Количество()>0 Тогда		
		ТоварыXDTO						= СоздатьОбъектХДТО("Документ.УстановкаЦенНоменклатуры.Товары");
		
		Для Каждого СтрокаТЧ Из Товары Цикл
			Если СтрокаТЧ.Цена = 0 Тогда Продолжить КонецЕсли;
			
			СтрокаXDTO					= СоздатьОбъектХДТО("Документ.УстановкаЦенНоменклатуры.Товары.Строка");
			
			СтрокаXDTO.Номенклатура		= ВыгрузитьСпр_Номенклатура_Элемент_КС(СтрокаТЧ.ДанныеНоменклатуры.Номенклатура.Ссылка);
			//СтрокаXDTO.Характеристика	= ДанныеНоменклатурыXDTO.Характеристика;
			
			СтрокаXDTO.Цена				= Окр(СтрокаТЧ.Цена,2,1);
			
			ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
			
			Надо	= Истина;
			
			Прервать;
		КонецЦикла;	
		
		ДокОбъектХДТО.Товары				= ТоварыXDTO;
	КонецЕсли; 

	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.Проведен,				"Проведен",			"boolean", 				ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.ПометкаУдаления,		"ПометкаУдаления",	"boolean", 				ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ДокОбъектХДТО,XMLСтрока(РеквизитыШапки.Дата2),		"ДействителенПо",	"dateTime",				ПространствоИмен_СТ);
	
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕД,"Валюта",ВыгрузитьСпр_Валюты_КС(РеквизитыШапки.Валюта));	
	
	//Сообщить_(""+РеквизитыШапки.Ссылка+" "+РеквизитыШапки.Комментарий);
	
	Если ЗначениеЗаполнено(Подразделение) Тогда
		ПодразделениеXDTO	= ВыгрузитьСпр_Подразделения_Элемент_КС(Подразделение); 
		ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"Подразделение",	ПодразделениеXDTO);
	КонецЕсли;	
	
	Если Надо=0 Тогда //Не читаются объекты без ТЧ
		ДокОбъектХДТО=Неопределено;		
	КонецЕсли;	
	
	Возврат ДокОбъектХДТО;
КонецФункции

Функция ВыгрузитьДок_КС_КС(ДокВыборка)
	КС_XDTO	= СоздатьОбъектХДТО("КлючевыеСвойстваОткрытиеКассовойСмены");
	
	КС_XDTO.Дата				= ДокВыборка.Дата;
	КС_XDTO.НомерКассовойСмены  = Номер_Z_Отчета(ДокВыборка.Дата,ДокВыборка.Касса);
	КС_XDTO.КассаККМ			= ВыгрузитьСпр_Кассы_Элемент_КС(ДокВыборка.Касса);
	
	Возврат КС_XDTO;	
КонецФункции //ВыгрузитьДок_КС_КС()

Функция ВыгрузитьДок_УстановкаСкидок(ДокВыборка,ДопИнфо=Неопределено)
	ИмяТаблицы	= "Документ.УстановкаСкидок";
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
