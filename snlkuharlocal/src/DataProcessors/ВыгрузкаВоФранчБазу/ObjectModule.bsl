Функция ВыгрузитьРС_РеквизитыСправочников(Отбор)	
	НЗ			= РегистрыСведений.РеквизитыСправочников.СоздатьНаборЗаписей();	
	ИмяТипаХДТО	= "РегистрСведений.ЗначенияСвойствОбъектов"; 
	
	ЗаполнитьОтборНЗ(НЗ,Отбор);
	
	Свойство		= ВыгрузитьПвх_СвойстваОбъектов_Элемент_КС(НЗ.Отбор.ИмяРеквизита.Значение);
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей",		ПространствоИмен_ЕЕ);
	
	ОтборХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей.Отбор",	ПространствоИмен_ЕЕ);
	
	ОтборХДТО.Объект	= НЗ.Отбор.Справочник.Значение;
	ОтборХДТО.Свойство	= Свойство;
	//ОтборХДТО.Документ	= НЗ.Отбор.Документ.Значение;		
	
	НЗ.Прочитать();
	Для Каждого Запись Из НЗ Цикл				
		СтрокаХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО+".Запись",		ПространствоИмен_ЕЕ);			
		
		СтрокаХДТО.Объект	= Запись.Справочник;
		СтрокаХДТО.Свойство	= Свойство;
		СтрокаХДТО.Значение	= Запись.ЗначениеРеквизита;		
		
		ОбъектХДТО.Строка.Добавить(СтрокаХДТО);
	КонецЦикла;
	
	ОбъектХДТО.Отбор	= ОтборХДТО;
	
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,НЗ.Количество());	
КонецФункции //ВыгрузитьРС_РеквизитыСправочников(Отбор)

Функция ВыгрузитьРС_СкидкиНоменклатуры(Отбор)	
	НЗ			= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();	
	ИмяТипаХДТО	= "РегистрСведений.СкидкиНоменклатуры";	
	
	Документ = Неопределено;
	
	Для Каждого Элемент_Ист Из Отбор Цикл
		Если Элемент_Ист.Использование Тогда
			Элемент_Пол	= НЗ.Отбор[Элемент_Ист.Имя];
			ЗаполнитьЗначенияСвойств(Элемент_Пол,Элемент_Ист,"ВидСравнения,Использование,Значение");
			
			Если Элемент_Ист.Имя = "Документ" Тогда
				Документ = Элемент_Ист.Значение;			
			КонецЕсли; 
		КонецЕсли;	
	КонецЦикла;	
	
	ОбъектХДТО			= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей",		ПространствоИмен_ЕЕ);
	
	ОтборХДТО			= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей.Отбор",	ПространствоИмен_ЕЕ);
	
	ДействующийТипСкидок= ДействующийТипСкидок(НЗ.Отбор.ТипСкидок.Значение);
	Если НЕ ЗначениеЗаполнено(ДействующийТипСкидок) И ЗначениеЗаполнено(Документ) Тогда
		ДействующийТипСкидок = ДействующийТипСкидок(ПолучитьРеквизитШапки(Документ, "ТипСкидок", "Документ"));
	КонецЕсли; 
	
	ОтборХДТО.ТипСкидок					= ДействующийТипСкидок;
	ОтборХДТО.ДокументУстановкаСкидок	= НЗ.Отбор.Документ.Значение;
	Если НЗ.Отбор.Номенклатура.Использование Тогда
		ОтборХДТО.Номенклатура	= НЗ.Отбор.Номенклатура.Значение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДействующийТипСкидок) Тогда
		НЗ.Прочитать();
		Для Каждого Запись Из НЗ Цикл				
			СтрокаХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Запись",		ПространствоИмен_ЕЕ);
			
			ЗаполнитьЗначенияСвойств(СтрокаХДТО,Запись);		
			
			СтрокаХДТО.ДокументУстановкаСкидок	= Запись.Документ;
			СтрокаХДТО.ТипСкидок				= ДействующийТипСкидок;
			
			ОбъектХДТО.Строка.Добавить(СтрокаХДТО);
		КонецЦикла;	
	КонецЕсли;	
	
	ОбъектХДТО.Отбор	= ОтборХДТО;
	
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,НЗ.Количество());	
КонецФункции //ВыгрузитьРС_СкидкиНоменклатуры(Отбор)

Функция ВыгрузитьРС_ЦеныНоменклатуры(Отбор)
	ИмяТипаХДТО	= "РегистрСведений.ЦеныНоменклатуры";
	
	НЗ	= РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	
	ОбязательныеИзмерения = Новый Структура("ТипЦен,Прайс",Неопределено,Неопределено);	
	
	Для Каждого Элемент_Ист Из Отбор Цикл
		Если Элемент_Ист.Использование Тогда
			Элемент_Пол = НЗ.Отбор[Элемент_Ист.Имя];
			ЗаполнитьЗначенияСвойств(Элемент_Пол,Элемент_Ист,"ВидСравнения,Использование,Значение");
			Если ОбязательныеИзмерения.Свойство(Элемент_Ист.Имя) Тогда
				ОбязательныеИзмерения[Элемент_Ист.Имя]	= Элемент_Ист.Значение;				
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
	
	Для Каждого Измерение Из ОбязательныеИзмерения Цикл
		Если ТипЗнч(Измерение.Значение)=Тип("Булево") Тогда
			Возврат Неопределено;
		КонецЕсли;	
	КонецЦикла;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей",	ПространствоИмен_ЕЕ);
	
	Если ЗначениеЗаполнено(ОбязательныеИзмерения.ТипЦен) Тогда
		ТекТипЦен = ОбязательныеИзмерения.ТипЦен;		
	ИначеЕсли ЗначениеЗаполнено(ОбязательныеИзмерения.Прайс) Тогда	
		ТекТипЦен	= ПолучитьРеквизитШапки(ОбязательныеИзмерения.Прайс,"ТипЦен");		
	Иначе
		Возврат Неопределено;	
	КонецЕсли;
	
	БазовыйТипЦен	= ПолучитьРеквизитШапки(ТекТипЦен,"Базовый");
	Если ЗначениеЗаполнено(БазовыйТипЦен) Тогда
		ТекТипЦен=БазовыйТипЦен;							
	КонецЕсли;
	
	НЗ.Прочитать();
	Для Каждого Запись Из НЗ Цикл				
		СтрокаХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Запись",	ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаХДТО,Запись);
		
		СтрокаХДТО.ПрайсЛист	= Запись.Прайс;
		СтрокаХДТО.ТипЦен		= ТекТипЦен;
		
		ОбъектХДТО.Строка.Добавить(СтрокаХДТО);		
	КонецЦикла;
	
	ОтборХДТО			= СоздатьОбъектХДТО(ИмяТипаХДТО+".НаборЗаписей.Отбор",		ПространствоИмен_ЕЕ);
	
	ОтборХДТО.ПрайсЛист	= ОбязательныеИзмерения.Прайс;
	ОтборХДТО.ТипЦен	= ТекТипЦен;
	
	Если НЗ.Отбор.Номенклатура.Использование Тогда
		ОтборХДТО.Номенклатура	= НЗ.Отбор.Номенклатура.Значение;
	КонецЕсли;
	
	ОбъектХДТО.Отбор	= ОтборХДТО;
	
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,НЗ.Количество());	
КонецФункции //ВыгрузитьРС_ЦеныНоменклатуры(Отбор)


Процедура ЗаполнитьОтборНЗ(НЗ,Отбор)
	Для Каждого Элемент_Ист Из Отбор Цикл
		Если Элемент_Ист.Использование Тогда
			Элемент_Пол	= НЗ.Отбор[Элемент_Ист.Имя];
			ЗаполнитьЗначенияСвойств(Элемент_Пол,Элемент_Ист,"ВидСравнения,Использование,Значение");
		КонецЕсли;	
	КонецЦикла;
КонецПроцедуры


Функция ВыгрузитьРС_СТАНДАРТНО(Менеджер,Отбор)
	НЗ			= Менеджер.СоздатьНаборЗаписей();	
	ИмяТипаХДТО	= НЗ.Метаданные().ПолноеИмя(); 
	
	ЗаполнитьОтборНЗ(НЗ,Отбор);
	
	НЗ.Прочитать();
	ОбъектХДТО	= СериализаторXDTO.ЗаписатьXDTO(НЗ);	
	
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,НЗ.Количество());	
КонецФункции

	
