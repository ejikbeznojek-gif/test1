	ИмяТаблицы	= МетаОбъект.ПолноеИмя();
	ИмяТипаХДТО	= ИмяТаблицы+".Элемент";
	
	ВхПараметры = РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметры.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметры,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean", 	ПространствоИмен_СТ);	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Организации_Элемент(СпрВыборка)

