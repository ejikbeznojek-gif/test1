Функция ОбъектСуществует(Ссылка, ИмяТаблицы) Экспорт
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1 ВерсияДанных
	|
	|ИЗ "+ИмяТаблицы+"
	|ГДЕ Ссылка=&Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ВерсияДанных));
КонецФункции //ОбъектСуществует(Ссылка,Таблица)

Функция ОтправитьСообщение(Данные,Ссылка,ОбъектТип,ОбъектСсылкаУИД,ОтборРС_Хэш="",ВариантВыгрузки,ВыгруженоЗаписей=0)
	Если НЕ ЗначениеЗаполнено(ТекПакет) Тогда
		ТекПакет	= СоздатьПакет("CO_FR");	
	КонецЕсли;
	
	ТекПакет.Размер	= ТекПакет.Размер+СтрДлина(Данные);
		
	ТекПакет.Данные.Добавить(Данные);
	ТекПакет.Ссылки.Добавить(Новый Структура("Ссылка,ОбъектТип,ОбъектСсылкаУИД,ОтборРС_Хэш,ВариантВыгрузки,ВыгруженоЗаписей",Ссылка,ОбъектТип,ОбъектСсылкаУИД,ОтборРС_Хэш,ВариантВыгрузки,ВыгруженоЗаписей));
	
	Если ТекПакет.Размер>=100000 Тогда
		ОтправитьПакет(ТекПакет);		
	КонецЕсли;	
КонецФункции //ОтправитьСообщение(КомпонентаОбмена,Строка)

Функция СоздатьПакет(Получатель,Тип="Данные") Экспорт	
	Пакет	= Новый Структура("
		|КлючОтправителя,КлючПолучателя,
		|Тип,Размер,Данные,Ссылки,
		|НачалоОбработки,ДатаОтправки,
		|ИД_Пакета,ИД_Сеанса",
		ФР_ОбщегоНазначения_ПИ.ЭтотУзелКод(),Получатель,
		Тип,0,Новый Массив,Новый Массив,
		ТекущаяДата(),ТекущаяДата(),
		Новый УникальныйИдентификатор(),
		ИД_Сеанса);
		
	Возврат Пакет;
КонецФункции //СоздатьПакет(Получатель)

Функция ОтправитьПакет(Пакет)
	МассивСсылок	= Пакет.Ссылки;	
	Пакет.Ссылки	= "";
	Пакет.ДатаОтправки	= ТекущаяДата();
	
	Сообщение		= ПолучитьДвоичныеДанныеИзСтроки(ЗначениеВСтрокуВнутр(Пакет));
	
	ЗаписатьВЛог("Регламент","Обмен ФР. Начало отправки пакета. Получатель:"+Пакет.КлючПолучателя+". Размер: "+Пакет.Размер,"Информация",Ложь);
	
	НомерДоставки	= КомпонентаОбмена.ОтправитьСообщение("",Очередь,Сообщение);
	
	Сообщить_(НомерДоставки);
	
	Если НомерДоставки>0 Тогда
		Пакет.Ссылки	= МассивСсылок;
		ЗаписатьЭлементСтатистики_Отправка(Пакет);
		
		ОчиститьРегистрацию(МассивСсылок);		
		Сообщить_("Пакет отправлен. Размер: "+Пакет.Размер);		
	КонецЕсли;	
	
	Пакет	= Неопределено;
КонецФункции // ()

Процедура ОчиститьРегистрацию(МассивСсылок)
	//Возврат; //Временно отключили
	
	НачатьТранзакцию();
	
	Для Каждого ДанныеСсылки Из МассивСсылок Цикл
		РегистрыСведений.ФР_ОбъектыКВыгрузке.УдалитьРегистрацию(ДанныеСсылки.ОбъектТип,ДанныеСсылки.ОбъектСсылкаУИД,ДанныеСсылки.ОтборРС_Хэш,ДанныеСсылки.ВариантВыгрузки);		
	КонецЦикла;	
	
	ЗафиксироватьТранзакцию();	

КонецПроцедуры //ОчиститьРегистрацию(МассивСсылок)

Функция ЗаписатьЭлементСтатистики_Отправка(Пакет)
	ТекКодОтправителя	= ФР_ОбщегоНазначения_ПИ.ЭтотУзелКод();
	
	СпрОбъект			= Справочники.ФР_СтатистикаОбменов.СоздатьЭлемент();
	
	ФР_ОбщегоНазначения_КС.СообщитьПользователю(СтрШаблон("Отправлен пакет, размер: %1 байт.",Пакет.Размер));
	
	СпрОбъект.Операция 			= 1; //0-Прием,1 - Отправка
	СпрОбъект.ИД_Сеанса			= Пакет.ИД_Сеанса;	
	СпрОбъект.УстановитьСсылкуНового(Справочники.ФР_СтатистикаОбменов.ПолучитьСсылку(Пакет.ИД_Пакета));
	СпрОбъект.РазмерСообщения   = Пакет.Размер;	
	СпрОбъект.Получатель		= Пакет.КлючПолучателя;
	СпрОбъект.Отправитель		= ТекКодОтправителя;
		
	Для Каждого СтрокаДанных Из Пакет.Ссылки Цикл
		СтрокаП	= СпрОбъект.ОбработанныеОбъекты.Добавить();
		
		СтрокаП.ОбъектТип 			= СтрокаДанных.ОбъектТип;
		СтрокаП.ОбъектСсылкаУИД 	= СтрокаДанных.ОбъектСсылкаУИД;
		СтрокаП.ОтборРС_Хэш 		= СтрокаДанных.ОтборРС_Хэш;
		СтрокаП.ВариантВыгрузки 	= СтрокаДанных.ВариантВыгрузки;		
		СтрокаП.ПредставлениеСсылки	= СтрокаДанных.Ссылка;
		СтрокаП.КоличествоЗаписей	= СтрокаДанных.ВыгруженоЗаписей;
		
		Если ФР_ОбщегоНазначения_ПИ.ЕстьСтатусыОбмена(СтрокаДанных.ОбъектТип) Тогда
			РегистрыСведений.ФР_СтатусыОбмена.УстановитьСтатус(СтрокаДанных.Ссылка,Перечисления.СтатусыОбмена.Отправлено,ТекКодОтправителя,Пакет.КлючПолучателя);
		КонецЕсли;
	КонецЦикла;		
		
	СпрОбъект.НачалоОбработки	= Пакет.НачалоОбработки;
	СпрОбъект.ДатаОтправки		= ТекущаяДата();
	СпрОбъект.Пользователь		= ПараметрыСеанса.Пользователь;	
	
	ПараметрыСеанса.ОтключитьЖурнализациюЗаписи	= Истина;
	СпрОбъект.Записать();
	ПараметрыСеанса.ОтключитьЖурнализациюЗаписи	= Ложь;
КонецФункции //ЗаписатьЭлементСтатистики_Отправка(Операция,Корреспондент,ДанныеОбмена,Ошибки)

Функция ЗаписатьЭлементСтатистики_Прием(РазмерСообщения,Пакет,Ошибки,НачалоОбработки,ИД_Сеанса,СообщениеСтрокой)
	Менеджер	= Справочники.ФР_СтатистикаОбменов;
	
	Если Пакет<>Неопределено Тогда
		Ссылка	=  Менеджер.ПолучитьСсылку(Пакет.ИД_Пакета);
		Если ОбъектСуществует(Ссылка,"Справочник.ФР_СтатистикаОбменов") Тогда
			СпрОбъект	= Ссылка.ПолучитьОбъект();
		Иначе
			СпрОбъект	= Менеджер.СоздатьЭлемент();
			СпрОбъект.УстановитьСсылкуНового(Ссылка);
		КонецЕсли; 
		
		СпрОбъект.Получатель	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(Пакет,"КлючПолучателя");	
	Иначе
		СпрОбъект				= Менеджер.СоздатьЭлемент();		
	КонецЕсли;	
	
	СпрОбъект.Операция 			= 0; //0-Прием,1 - Отправка
	СпрОбъект.ИД_Сеанса			= ИД_Сеанса;	
	СпрОбъект.РазмерСообщения   = РазмерСообщения;
	
	СпрОбъект.Отправитель		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(Пакет,"КлючОтправителя");
	
	ТекКодПолучателя			= ФР_ОбщегоНазначения_ПИ.ЭтотУзелКод();	
	
	Для Каждого СтрокаДанных Из ОбъектыОбмена Цикл
		СтрокаП	= СпрОбъект.ОбработанныеОбъекты.Добавить();
		
		СтрокаП.ОбъектТип 			= СтрокаДанных.ОбъектТип;
		СтрокаП.ОбъектСсылкаУИД 	= СтрокаДанных.ОбъектСсылкаУИД;
		СтрокаП.ОтборРС_Хэш 		= СтрокаДанных.ОтборРС_Хэш;
		СтрокаП.ВариантВыгрузки 	= СтрокаДанных.ВариантВыгрузки;		
		СтрокаП.ПредставлениеСсылки	= СтрокаДанных.Ссылка;
		
		СтрокаП.Ошибки				= СтрокаДанных.Ошибки;
		СтрокаП.СтатусЗаписи		= СтрокаДанных.СтатусЗаписи;
		СтрокаП.Действие			= СтрокаДанных.Действие;		
		
		СпрОбъект.ЕстьОшибки	= СпрОбъект.ЕстьОшибки ИЛИ НЕ ПустаяСтрока(СтрокаП.Ошибки);
		
		Если ЗначениеЗаполнено(СтрокаДанных.Ссылка) 
			И СтрНайти(СтрокаП.ВариантВыгрузки,"РегистрСведений.")=0 
			И ФР_ОбщегоНазначения_ПИ.ЕстьСтатусыОбмена(ЗначениеВСтрокуВнутр(ТипЗнч(СтрокаДанных.Ссылка))) Тогда
			РегистрыСведений.ФР_СтатусыОбмена.УстановитьСтатус(СтрокаДанных.Ссылка,Перечисления.СтатусыОбмена.Получено,СпрОбъект.Отправитель,ТекКодПолучателя);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекстОшибки Из Ошибки Цикл		
		СпрОбъект.ЕстьОшибки	= Истина;
		
		СтрокаО	= СпрОбъект.ОшибкиОбмена.Добавить();
		СтрокаО.ТекстОшибки = ТекстОшибки;
	КонецЦикла; 
	
	Если СпрОбъект.ЕстьОшибки Тогда
		СпрОбъект.ДанныеСообщения   = Новый ХранилищеЗначения(СообщениеСтрокой,Новый СжатиеДанных(9));	
	КонецЕсли; 
	
	СпрОбъект.НачалоОбработки	= НачалоОбработки;
	СпрОбъект.ДатаОтправки		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(Пакет,"ДатаОтправки");
	СпрОбъект.ДатаПриемки		= ТекущаяДата();
	СпрОбъект.Пользователь		= ПараметрыСеанса.Пользователь;	
	
	ПараметрыСеанса.ОтключитьЖурнализациюЗаписи	= Истина;
	СпрОбъект.Записать();
	ПараметрыСеанса.ОтключитьЖурнализациюЗаписи	= Ложь;
КонецФункции //ЗаписатьЭлементСтатистики_Отправка(Операция,Корреспондент,ДанныеОбмена,Ошибки)

Функция ТипСсылки(ТипЗначения) Экспорт
	Результат = Новый Структура("Тип,Вид,ПолныйТип","","");
	
	МетаОбъект	= Метаданные.НайтиПоТипу(ТипЗначения);
	Если МетаОбъект <> Неопределено  Тогда
		ПолныйТип	= МетаОбъект.ПолноеИмя();
		Части		= СтрРазделить(ПолныйТип,".");
		
		Если Части.Количество()>=1 Тогда
			Результат.Тип=Части[0];
		КонецЕсли;
		Если Части.Количество()>=2 Тогда
			Результат.Вид=Части[1];			
		КонецЕсли;
		
		Результат.ПолныйТип=ПолныйТип;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ТипОбъекта(ТипЗначения) Экспорт

Функция СжатьДанные(Строка)
