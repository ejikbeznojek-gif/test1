Функция ВыгрузитьПер_СтавкаНДС(СтавкаНДС)
	Если СтавкаНДС=Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат "БезНДС";
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС0 Тогда
		Возврат "НДС0";				
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС10 Тогда
		Возврат "НДС10";
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС18 Тогда
		Возврат "НДС18";
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС20 Тогда
		Возврат "НДС20";
	//+SNL-77 20260111 Михайловский	
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС22 Тогда
		Возврат "НДС22";
	//-SNL-77 20260111 Михайловский	
	//+HELP-2538 20250115 Михайловский
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС5 Тогда
		Возврат "НДС5";
	ИначеЕсли СтавкаНДС=Перечисления.СтавкиНДС.НДС7 Тогда
		Возврат "НДС7";
	//-HELP-2538 20250115 Михайловский
	Иначе
		Возврат "НДС20";
	КонецЕсли; 
КонецФункции // ()

Функция ВыгрузитьПер_ЮрФизЛицо_КС(Значение)
	Возврат ?(Значение=Перечисления.ЮрФизЛицо.ЮрЛицо,"ЮридическоеЛицо","ФизическоеЛицо");
