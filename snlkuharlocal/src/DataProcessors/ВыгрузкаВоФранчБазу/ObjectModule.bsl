Функция ЗагрузитьТЧОбъектаМКО(Объект,ОбъектХДТО,ИменаТЧ,ДопПараметы=Неопределено)
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл		
		текДопПараметры	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметы,ИмяТЧ);
		СоотвРеквизитов	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(текДопПараметры,"СоответствиеРеквизитов",Новый Структура);
		
		ТЧ_Объекта	= Объект[ИмяТЧ];
		
		МетаТЧ		= Объект.Метаданные().ТабличныеЧасти[ИмяТЧ];
		ЕстьЕдиница	= (МетаТЧ.Реквизиты.Найти("Единица")<>Неопределено); 
		
		ТЧ_Объекта.Очистить();
		ТЧ_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяТЧ);
		Если ТЧ_ХДТО<>Неопределено Тогда
			Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
				СтрокаТЧ	= ТЧ_Объекта.Добавить();		
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);
				
				Если ИмяТЧ = "Товары" Тогда
					Харка_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"ХарактеристикаНоменклатуры");
					Ном_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"Номенклатура");
					СтрокаТЧ.ХарактеристикаНоменклатуры = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(Харка_ХДТО)));
					СтрокаТЧ.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(Ном_ХДТО)));
				КонецЕсли;
			КонецЦикла; 			
		КонецЕсли;
	КонецЦикла;
КонецФункции

Функция ЗагрузитьХПС(ДокОбъект,ТЧ_Сертификаты_ХДТО,Отправитель)
	Найден 		= Ложь;
	ХПС_Ссылка	= НайтиДокумент("ХранилищеПодарочныхСертификатов",Новый Структура("ДокОбъект",ДокОбъект.Ссылка));
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ХПС_Объект	= ХПС_Ссылка.ПолучитьОбъект();
		Найден		= Истина;
	Иначе		
		Если ТЧ_Сертификаты_ХДТО.Строка.Количество()=0 Тогда
			Возврат Неопределено; //Пустая ТЧ Сертификаты 
		Иначе			
			ХПС_Объект = Документы.ХранилищеПодарочныхСертификатов.СоздатьДокумент();
		КонецЕсли;		
	КонецЕсли;
	
	ХПС_Объект.Дата			= ДокОбъект.Дата;
	ХПС_Объект.ДокОбъект 	= ДокОбъект.Ссылка;
	//+ ASU-1025, ASU-946 20241220 Михайловский
	//вместо
	//ХПС_Объект.Склад 		= ДокОбъект.Склад;
	Если ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.ОприходованиеТМЦ") Тогда
		ХПС_Объект.СкладПолучатель 	= ДокОбъект.Склад;
	Иначе
		ХПС_Объект.Склад 		= ДокОбъект.Склад;
	КонецЕсли;
	//- ASU-1025, ASU-946 20241220 Михайловский
	Если ТипЗнч(ДокОбъект.Ссылка) = Тип("ДокументСсылка.Перемещение") Тогда
		ХПС_Объект.СкладПолучатель 	= ДокОбъект.СкладПолучатель;
	КонецЕсли;
	
	ХПС_Объект.Сертификаты.Очистить();
	Для Каждого СтрокаХДТО Из ТЧ_Сертификаты_ХДТО.Строка Цикл
		СтрокаТЧ = ХПС_Объект.Сертификаты.Добавить();	
		
		СтрокаТЧ.Сертификат		= СтрокаХДТО.ПодарочныйСертификат;
		
		СтрокаТЧ.Количество		= 1;
		СтрокаТЧ.КоличествоРасч	= 1;
		СтрокаТЧ.КоличествоФакт	= 1;
		СтрокаТЧ.Принято		= 1;
		
		Если ОбъектСуществует(СтрокаТЧ.Сертификат,"Справочник.ПодарочныеСертификаты") Тогда
			РеквизитыСертификата	= ПолучитьРеквизитыШапки(СтрокаТЧ.Сертификат,"Владелец,КодСертификата,Номинал");				
			
			СтрокаТЧ.КодСертификата		= Прав(СокрЛП(РеквизитыСертификата.КодСертификата),7);			
			СтрокаТЧ.Номенклатура		= РеквизитыСертификата.Владелец;
			СтрокаТЧ.Номинал			= РеквизитыСертификата.Номинал;
		КонецЕсли; 
	КонецЦикла;
	
	Если НЕ Найден Тогда
		Префикс = СокрЛП(ДокОбъект.Склад.Подразделение.КодФизическогоУзла77);
		
		Если ЗначениеЗаполнено(Префикс) Тогда		
			ХПС_Объект.УстановитьНовыйНомер(Префикс+"-");
		КонецЕсли;		
	КонецЕсли; 
	
	ЗаписатьДокумент(ХПС_Объект,Отправитель,Найден);	
КонецФункции //ЗагрузитьХПС(ДокОбъект,ТЧ_Сертификаты_ХДТО,Отправитель)

Функция ПолучитьПунктДоставки(Склад)
	Менеджер	= Справочники.ПунктыДоставки;	
	Результат	= Менеджер.ПустаяСсылка();
	
	//крохин начало 28.07.2011
	//выбираем первый по наименованию
	//Выборка=Справочники.ПунктыДоставки.Выбрать(,Контрагент);
	Выборка=Менеджер.Выбрать(,Склад,,"Наименование Убыв");
	//крохин конец 28.07.2011
	Пока Выборка.Следующий() Цикл
		Результат = Выборка.Ссылка;			
	КонецЦикла;
	//крохин конец
	
	Возврат Результат;
КонецФункции // ()

Функция ЗагрузитьДок_РКО(ОбъектХДТО,Отправитель)	
	Вид			= "РасходныйКассовыйОрдер";	
	Менеджер	= Документы[Вид];
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли; 
	
	ДокОбъект	= РезультатПоиска.Объект;
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);
	
	ДокОбъект.ВидОперации	= ЗагрузитьПер("ВидыОперацийРКО",ОбъектХДТО.ВидОперации);	
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект,ОбъектХДТО,"Контрагент");	
	
	Если ТипЗнч(ДокОбъект.Контрагент)=ТипЗнч(Справочники.Контрагенты.ПустаяСсылка()) Тогда
		ДокОбъект.КонтрагентЦБ = ДокОбъект.Контрагент.Ведущий;	
	КонецЕсли;	
	
	ДокОбъект.ИБ	= ФР_ОбщегоНазначения_ПИ.ТекущаяИБ();
		
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);
КонецФункции //ЗагрузитьДок_РКО(ОбъектХДТО,Отправитель)

Функция ОтправительПеремещенияДляЦО_ЕЕ(Склад,СкладПолучатель,СостояниеНакладнойУПолучателя)
	Если СравнитьЗначенияПеречисления(СостояниеНакладнойУПолучателя,Перечисления.СостоянияНакладной.ВРаботе)>0 Тогда
		Реквизиты = ПолучитьРеквизитыШапки(СкладПолучатель,"Подразделение,Подразделение.ВидПодразделения");
		Если Реквизиты.Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Торговое
			ИЛИ Реквизиты.Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
			Возврат ФР_ОбщегоНазначения_ПИ.УзелПодразделения(Реквизиты.Подразделение);	
		КонецЕсли;	
	КонецЕсли;
	
	Реквизиты = ПолучитьРеквизитыШапки(Склад,"Подразделение,Подразделение.ВидПодразделения");
	Если Реквизиты.Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Торговое 
		ИЛИ Реквизиты.Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
		Возврат ФР_ОбщегоНазначения_ПИ.УзелПодразделения(Реквизиты.Подразделение);	
	КонецЕсли;
	
	Возврат ПланыОбмена.Основной.ПустаяСсылка();
КонецФункции //ОтправительПеремещенияДляЦО_ЕЕ()
 

Функция ЗагрузитьРеквизитыСМультиТипами(Объект,ОбъектХДТО,Знач ИменаРеквизитов)
	ИменаРеквизитов	= СтрРазделить(ИменаРеквизитов,",");
	Для Каждого ИмяРеквизита Из ИменаРеквизитов Цикл
		ДанныеРекв	= ОбъектХДТО[ИмяРеквизита];
		ИмяТипа		= ОбъектХДТО[ИмяРеквизита+"Тип"];
		
		Если ЗначениеЗаполнено(ДанныеРекв) И ЗначениеЗаполнено(ИмяТипа) Тогда
			ИмяТипа = ПолучитьПолноеИмяТипаТек(ИмяТипа);
			Если ТипЗнч(ДанныеРекв)=Тип("Строка") Тогда
				УИД = Новый УникальныйИдентификатор(ДанныеРекв);
			Иначе
				УИД = ДанныеРекв.УникальныйИдентификатор();			
			КонецЕсли; 
			//+ASU-946 20250130 Михайловский
			Если ИмяРеквизита = "ДокОснование" И ИмяТипа = "Документ.АктОРасхождениях" Тогда
				Объект[ИмяРеквизита] = ФР_ОбщегоНазначения_ПИ.ПолучитьМенеджер("Документ.ЗаявкаНаРекламацию").ПолучитьСсылку(УИД);
			//-ASU-946 20250130 Михайловский
			//+HELP-8926 20260327 Михайловский
			ИначеЕсли ИмяРеквизита = "ДокОснование" И ИмяТипа = "Документ.ЗаявкаНаВозвратПоставщику" Тогда
				Объект[ИмяРеквизита] = ФР_ОбщегоНазначения_ПИ.ПолучитьМенеджер("Документ.ЗаявкаНаВозвратОтПокупателя").ПолучитьСсылку(УИД);
			//-HELP-8926 20260327 Михайловский	
			Иначе	
				Объект[ИмяРеквизита] = ФР_ОбщегоНазначения_ПИ.ПолучитьМенеджер(ИмяТипа).ПолучитьСсылку(УИД);
			КонецЕсли;
		КонецЕсли;			
	КонецЦикла;
КонецФункции // ()
 

Функция ЗагрузитьДок_ПС_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ПереводСредств;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);	
	
	ДокОбъект.ВидОперации	= ЗагрузитьПер("ВидыОперацийПС",ОбъектХДТО.ВидОперации);
	ДокОбъект.Сумма			= ОбъектХДТО.СуммаДокумента;	
	ДокОбъект.ИБ 			= ИБ_SSP;
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ПС_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_СПН_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.СписаниеТМЦ;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.СписаниеТМЦ.СоздатьДокумент();	
	КонецЕсли;
	
	ИменаТЧ	= "Товары";
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,ИменаТЧ);
	
	ДокОбъект.КодОперации			= Перечисления.КодыОперацийОстатки.Списание;
	ДокОбъект.СостояниеНакладной	= Перечисления.СостоянияНакладной[ОбъектХДТО.СостояниеНакладной];
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.Единица		= Ед_Штука;
			СтрокаТЧ.Коэффициент	= 1;
		КонецЦикла;
	КонецЕсли;
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект,ОбъектХДТО,"ДокОснование");	
	
	ДокОбъект.ИБ = ИБ_SSP;
	//+ ASU-1025, ASU-946 20241220 Михайловский
	ТЧ_Сертификаты_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"Сертификаты");
	Если ТЧ_Сертификаты_ХДТО<>Неопределено И ЗначениеЗаполнено(ДокОбъект.Ссылка) Тогда
		ЗагрузитьХПС(ДокОбъект,ТЧ_Сертификаты_ХДТО,Отправитель);	
	КонецЕсли;
	//- ASU-1025, ASU-946 20241220 Михайловский
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_СПН_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_УстановкаСкидок(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.УстановкаСкидок;
	Вид			= Метаданные.НайтиПоТипу(ТипЗнч(Менеджер.ПустаяСсылка())).Имя;
	
	Результат	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	
	Если Результат.Объект<>Неопределено Тогда		
		ТипСкидок_Ист	= ОбъектХДТО.ТипСкидок;
		ТипСкидок_Тек	= НайтиТипСкидок(ОбъектХДТО.Подразделение,ТипСкидок_Ист);
		
		ДокОбъект	= Результат.Объект;
		ДокСсылка	= Результат.Ссылка;
		
		Если 1=2 Тогда
			ДокОбъект=Документы.УстановкаСкидок.СоздатьДокумент();	
		КонецЕсли;	
		
		ДокОбъект.Дата			= ОбъектХДТО.Дата;
		ДокОбъект.Номер			= ОбъектХДТО.Номер;		
		ДокОбъект.Автор			= ОбъектХДТО.Автор;
		ДокОбъект.ТипСкидок		= ТипСкидок_Тек;				
		
		Подразделение			= ПолучитьСвойствоХДТО(ОбъектХДТО,"Подразделение");			
		
		ДокОбъект.Дата2			= ОбъектХДТО.ДействителенПо;

		ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
		Если НЕ ДокОбъект.ПометкаУдаления Тогда
			ДокОбъект.Проведен = Истина;		
		КонецЕсли;
		
		ЗаписатьДокумент(ДокОбъект,Отправитель,Результат.Найден);
		
		Если ДокОбъект.ПометкаУдаления Тогда
			НЗ			= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();		
			НЗ.Отбор.ДокументУстановкаСкидок.Установить(ДокСсылка,Истина);
			
			НЗ.Очистить();		
			
			ЗаписатьОбъект(НЗ,Отправитель);			
		КонецЕсли;	
	Иначе
		ЗаписатьВПротокол_ОбъектПропущен(Результат);		
	КонецЕсли;	
	
	Возврат Результат.Ссылка;
КонецФункции //ЗагрузитьДокумент_ПрайсЛист(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ХКМ(ОбъектХДТО, Отправитель)
	Менеджер	= Документы.ХранилищеКодовМаркировки;
	Вид			= Менеджер.ПустаяСсылка().Метаданные().Имя;	
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли; 
	
	ДокОбъект	= РезультатПоиска.Объект;
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);
		
	ИменаТЧ	= "Товары,ШтрихкодыУпаковок";
	
	ЗагрузитьТЧОбъекта(ДокОбъект, ОбъектХДТО, ИменаТЧ);
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект, ОбъектХДТО, "ДокОснование,Отправитель,Получатель");
		
	ЗаписатьДокумент(ДокОбъект, Отправитель, РезультатПоиска.Найден);
	//+HELP-3182 20250313 Михайловский
	Если ЗначениеЗаполнено(ДокОбъект.Ссылка) Тогда
		Если ТипЗнч(ДокОбъект.Ссылка.ДокОснование) = Тип("ДокументСсылка.Перемещение") Тогда
			ПроверитьПРМ(ДокОбъект.Ссылка.ДокОснование);
		КонецЕсли;	
	КонецЕсли;	
	//-HELP-3182 20250313 Михайловский
	
КонецФункции //ЗагрузитьДок_ХКМ(ОбъектХДТО,Отправитель)

//+HELP-3182 20250313 Михайловский
Процедура ПроверитьПРМ(ДокОснование)	
	Попытка
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		|	Перемещение.Ссылка,
		|	Перемещение.ТребуетсяМаркировка
		|ИЗ
		|	Документ.Перемещение КАК Перемещение
		|ГДЕ
		|	Перемещение.Ссылка = &ДокОснование";
		Запр.УстановитьПараметр("ДокОснование", ДокОснование);
		Выб = Запр.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Если НЕ Выб.ТребуетсяМаркировка Тогда
				ДокОб = Выб.Ссылка.ПолучитьОбъект();
				Если НЕ ДокОб = Неопределено Тогда
					ДокОб.ТребуетсяМаркировка = Истина;
					ДокОб.Записать();
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры //-HELP-3182 20250313 Михайловский

