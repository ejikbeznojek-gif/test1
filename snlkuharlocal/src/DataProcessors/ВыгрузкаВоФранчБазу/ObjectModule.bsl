Функция ЗагрузитьСпр_Подразделения_Элемент_КС(КС_ХДТО,Отправитель=Неопределено)
	Менеджер	= Справочники.Подразделения;	
	
	Если КС_ХДТО=Неопределено Тогда
		Возврат Менеджер.ПустаяСсылка();	
	КонецЕсли; 
	
	Ссылка	= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	Если фСоздаватьОбъектыПоСсылкам И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		СпрОбъект	= Менеджер.СоздатьЭлемент();
		
		СпрОбъект.Код			= ПолучитьСвойствоХДТО(КС_ХДТО,"Код");
		СпрОбъект.Наименование	= КС_ХДТО.Наименование;
		
		Ссылка		= ЗаписатьОбъект(СпрОбъект,Отправитель);
	КонецЕсли; 
	
	Возврат Ссылка;		
КонецФункции //ЗагрузитьСпр_Подразделения_Элемент_КС(ОбъектХДТО,Отправитель=Неопределено)

Функция ЗагрузитьСпр_Пользователи_Элемент_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)
	Менеджер	= Справочники.Пользователи;	
	
	Если КС_ХДТО=Неопределено Тогда Возврат Менеджер.ПустаяСсылка() КонецЕсли;	
	
	Ссылка	= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	Если фСоздаватьОбъектыПоСсылкам И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		СпрОбъект	= Менеджер.СоздатьЭлемент();
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
		
		СпрОбъект.Наименование 	= КС_ХДТО.Наименование;		
		СпрОбъект.ФизическоеЛицо= ЗагрузитьСпр_ФизическиеЛица_Элемент_КС(ПолучитьСвойствоХДТО(КС_ХДТО,"ФизическоеЛицо"));		
		
		Ссылка		 = ЗаписатьОбъект(СпрОбъект,Отправитель);
	КонецЕсли; 
	
	Возврат Ссылка;	
КонецФункции //ЗагрузитьСпр_Пользователи_Элемент_КС(КС_ХДТО,Отправитель=Неопределено)

Функция ЗагрузитьСпр_ПодарочныеСертификаты_Элемент(ОбъектХДТО,Отправитель=Неопределено)	
	Результат	= НайтиСоздатьСправочник(ОбъектХДТО.Ссылка,"ПодарочныеСертификаты",Ложь);	
	
	Если Результат.Найден И НЕ фПерезаписыватьРеквизитыСправочников Тогда
		Возврат Результат.Ссылка;		
	Иначе
		СпрОбъект	= Результат.Объект;
	КонецЕсли;
	
	ИменаТЧ	= "СписокТЦПриемки";
	
	ЗаполнитьЗначенияСвойств(СпрОбъект,ОбъектХДТО,,"Владелец,Код,ВидСертификата,ПодразделениеЗатрат,ПодразделениеПолучатель");	
	//Это какой-то мухлеж с повторноиспользуемыми сертификатами..........
	
	Если НЕ ЗначениеЗаполнено(СпрОбъект.Владелец) ИЛИ ПолучитьРеквизитШапки(СпрОбъект.Владелец, "ЭтоГруппа", "Справочник") = Истина Тогда
		СпрОбъект.Владелец		= ПолучитьПервыйЭлементВГруппе(ОбъектХДТО.Владелец);	
	КонецЕсли;	
	СпрОбъект.КодСертификата	= ОбъектХДТО.Код;
	СпрОбъект.Код				= ОбъектХДТО.Наименование;
	
	Если СпрОбъект.ДатаПогашения>'1980.01.01' Тогда
		СпрОбъект.Использован = Истина;		
	КонецЕсли; 
	
	Если ОбъектХДТО.ВидСертификата="СертификатИзЧека" Тогда
		СпрОбъект.ВидСертификата = Справочники.ВидыПодарочныхСертификатов.ЕЕИзЧека; 		
	КонецЕсли;	
	
	ЗагрузитьТЧОбъекта(СпрОбъект,ОбъектХДТО,ИменаТЧ);	
		
	Возврат ЗаписатьОбъект(СпрОбъект,Отправитель);	
КонецФункции //ЗагрузитьСпр_ПодарочныеСертификаты_Элемент(ОбъектХДТО,Отправитель=Неопределено)

Функция ПолучитьПервыйЭлементВГруппе(Группа)
	Если ЗначениеЗаполнено(Группа) И Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Группа)) И НЕ Группа.Пустая() Тогда		
		ИмяКэша		= "ПервыеЭлементыГрупп";
		Результат 	= ПолучитьИзКэша(Группа, ИмяКэша);
		Если Результат = Неопределено Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	Ссылка
			|ИЗ
			|	Справочник."+Группа.Метаданные().Имя+"
			|ГДЕ
			|	Родитель = &Группа
			|	И НЕ ЭтоГруппа
			|УПОРЯДОЧИТЬ ПО
			|	ПометкаУдаления,
			|	Код
			|";
			Запрос.УстановитьПараметр("Группа", Группа);	
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
				Результат = Выборка.Ссылка;					
			Иначе
				Результат = Группа;			
			КонецЕсли;
			
			ВставитьВКэш(Группа, Результат, ИмяКэша);
		КонецЕсли;
	Иначе
		Результат = Неопределено;
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьПервыйЭлементВГруппе(Группа)
 

Функция ЗагрузитьСпр_ПодарочныеСертификаты_Элемент_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)
	Менеджер	= Справочники.ПодарочныеСертификаты;
	
	Ссылка		= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Ссылка));
	СпрОбъект	= Неопределено;
	
	Если (фСоздаватьОбъектыПоСсылкам ИЛИ ВернутьОбъект) 
		И НЕ ОбъектСуществует(Ссылка,"Справочник."+Ссылка.Метаданные().Имя) Тогда
		
		СпрОбъект	= Менеджер.СоздатьЭлемент();		
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
		
		СпрОбъект.Владелец		= Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(КС_ХДТО.Владелец));
		
		СпрОбъект.ВидСертификата	= ЗагрузитьСпр_ВидыПодарочныхСертификатов_КС(КС_ХДТО.ВидПодарочногоСертификата);
		СпрОбъект.Код				= КС_ХДТО.СерийныйНомер;
		СпрОбъект.Наименование		= КС_ХДТО.Штрихкод;	
		
		Если НЕ ВернутьОбъект Тогда			
			Ссылка		= ЗаписатьОбъект(СпрОбъект,Отправитель);		
		КонецЕсли;
	КонецЕсли;
	
	Если ВернутьОбъект И СпрОбъект=Неопределено Тогда
		СпрОбъект = Ссылка.ПолучитьОбъект();		 
	КонецЕсли;
	
	Возврат ?(ВернутьОбъект,СпрОбъект,Ссылка);	
КонецФункции //ЗагрузитьСпр_ПодарочныеСертификаты_КС(ОбъектХДТО,Отправитель=Неопределено)

Функция ЗагрузитьСпр_ФизическиеЛица_Элемент_КС(КС_ХДТО,Отправитель=Неопределено,ВернутьОбъект=Ложь)	
