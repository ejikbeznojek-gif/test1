Функция ПолучитьДатуИзСтр(СтрДата) Экспорт
	
	Рез = Неопределено;
	Попытка
		СтрДата = СокрЛП(СтрДата);
		СтрРез = "";
		РаздТ = Найти(СтрДата,".");
		РаздТр = Найти(СтрДата,"-");
		РаздЗ = Найти(СтрДата,",");
		РаздСП = Найти(СтрДата,"/");
		РаздСО = Найти(СтрДата,"\");
		РаздДТ = Найти(СтрДата,":");
		Если (РаздТ>0) И (РаздТр>0) Тогда
			Если (РаздТ>РаздТр) Тогда
				РаздТ = 0;
			КонецЕсли;
		КонецЕсли;
		
		Если (РаздТ > 0) ИЛИ (РаздЗ > 0) Тогда
			//сообщить("РаздСП "+строка(РаздСП));
			//предположим германский с разными разделителями
			Если (Сред(СтрДата,3,1) = ".") Тогда
				Попытка
					Если (РаздДТ > 0) Тогда
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						СтрЧМ = СокрЛП(Сред(СтрДата,11));
						СтрЧМ = СтрЗаменить(СтрЧМ,":","");
						СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ) = 5 Тогда
							СтрЧМ = "0" + СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ = Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ = "000000") Тогда
							СтрРез = СтрРез + СтрЧМ;
						КонецЕсли;
						Рез = Дата(СтрРез);
					Иначе	
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						Рез = Дата(СтрРез);
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;
			
		ИначеЕсли РаздТр>0 Тогда
			
			Если Сред(СтрДата,3,1) = "-" Тогда
				Попытка
					Если РаздДТ>0 Тогда
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						СтрЧМ = СокрЛП(Сред(СтрДата,11));
						
						СтрЧМ = СтрЗаменить(СтрЧМ,":","");
						СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
						Если СтрДлина(СтрЧМ) = 5 Тогда
							СтрЧМ = "0" + СтрЧМ;
						КонецЕсли;
						Если СтрДлина(СтрЧМ)>6 Тогда
							СтрЧМ = Лев(СтрЧМ,6);
						КонецЕсли;
						Если НЕ(СтрЧМ = "000000") Тогда
							СтрРез = СтрРез + СтрЧМ;
						КонецЕсли;
						Рез = Дата(СтрРез);
					Иначе	
						СтрРез = Сред(СтрДата,7,4) + Сред(СтрДата,4,2) + Лев(СтрДата,2);
						Рез = Дата(СтрРез);
					КонецЕсли;
				Исключение
				КонецПопытки;
			Иначе
				СтрЧМ = СокрЛП(Сред(СтрДата,11));
				СтрРез = СтрЗаменить(СокрЛП(Лев(СтрДата,10)),"-","");
				СтрЧМ = СтрЗаменить(СтрЧМ,":","");
				СтрЧМ = СтрЗаменить(СтрЧМ,"T","");
				Если СтрДлина(СтрЧМ) = 5 Тогда
					СтрЧМ = "0" + СтрЧМ;
				КонецЕсли;
				Если СтрДлина(СтрЧМ)>6 Тогда
					СтрЧМ = Лев(СтрЧМ,6);
				КонецЕсли;
				Если НЕ(СтрЧМ = "000000") Тогда
					СтрРез = СтрРез + СтрЧМ;
				КонецЕсли;
				Рез = Дата(СтрРез);
			КонецЕсли;
			
		ИначеЕсли РаздСП>0 Тогда
			ДлС = СтрДлина(СтрДата);
			сообщить(длс);
			СтрГод = "";
			СтрМес = "";
			СтрДень = "";
			Поз = 1;
			СчтСлаш = 0;
			Пока Поз<= ДлС Цикл
				Если Сред(СтрДата, Поз, 1) = "/" Тогда
					СчтСлаш = СчтСлаш + 1;
				Иначе
					Если СчтСлаш = 0 Тогда
						СтрМес = СтрМес + Сред(СтрДата, Поз, 1);
					ИначеЕсли СчтСлаш = 1 Тогда
						СтрДень = СтрДень + Сред(СтрДата, Поз, 1);
					Иначе
						СтрГод = СтрГод + Сред(СтрДата, Поз, 1);
					КонецЕсли;
				КонецЕсли;
				Поз  =  Поз  +  1;
			КонецЦикла;
			СтрГод = ?(СтрДлина(СтрГод)>4, Лев(СтрГод,4), СтрГод);
			Рез = Дата(Число(СтрГод),Число(СтрМес), Число(СтрДень));
		Иначе
			//анси формат
			Если СтрДлина(СтрДата)>= 8 Тогда
				Рез = Дата(Лев(СтрДата,8));
			КонецЕсли;
		КонецЕсли;
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	Возврат Рез;
	
КонецФункции // - HELP-1867 20241031 Михайловский

Процедура ЗагрузитьРегистрСведений(ОбъектХДТО,Вид,Отправитель)
	Если Вид="КоличествоПосетителей" Тогда
		ЗагрузитьРС_КоличествоПосетителей(ОбъектХДТО,Отправитель);		
	ИначеЕсли Вид="СкидкиНоменклатуры" Тогда
		ЗагрузитьРС_СкидкиНоменклатуры(ОбъектХДТО,Отправитель);		
	Иначе
		Сообщить_("Загрузка регистра сведений: """+Вид+""" пока не разработана !",СтатусСообщения.Важное);
	КонецЕсли;	
КонецПроцедуры

Функция ЗагрузитьСправочник(ОбъектХДТО,ИмяТипаХДТО,Отправитель)
	ПолныйТипИст	= ИмяТипаХДТО;
	ПолныйТипТек	= ПолучитьТипТек(ПолныйТипИст);	
	
	Если ЗначениеЗаполнено(ПолныйТипТек) Тогда		
		ТипОбъекта	= РазложитьПолныйТип(ПолныйТипТек);
		ВидТек		= ТипОбъекта.Вид;
		
		ОбработчикЗагрузки	= ПолучитьОбработчикЗагрузки(ИмяТипаХДТО);
		Если ОбработчикЗагрузки.Найден Тогда
			Рез	= Вычислить(ОбработчикЗагрузки.ПроцедураЗагрузки+"(ОбъектХДТО,Отправитель)");
		КонецЕсли;		
	Иначе
		ТекстОшибки	= "Не найдено соответствие типа для: "+ПолныйТипИст;
		ДобавитьОбъектВПротоколОбмена(ПолныйТипИст,,"Поиск соответствия типов",ТекстОшибки);		
		Сообщить_(ТекстОшибки,СтатусСообщения.Важное);
	КонецЕсли;
	
КонецФункции //ЗагрузитьСправочник(ОбъектХДТО,ВидИст,Отправитель)

Функция ЗагрузитьРС_СкидкиНоменклатуры(ОбъектХДТО,Отправитель)
	ТипСкидок_Ист	= ОбъектХДТО.Отбор.ТипСкидок;
	ТипСкидок_Тек	= НайтиТипСкидок(ОбъектХДТО.Подразделение,ТипСкидок_Ист);
	
	Если НЕ ЗначениеЗаполнено(ТипСкидок_Тек) Тогда Возврат Неопределено КонецЕсли; 
	
	НЗ				= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();
	
	НЗ.Отбор.Документ.Установить(ОбъектХДТО.Отбор.ДокументУстановкаСкидок,Истина);
	НЗ.Отбор.ТипСкидок.Установить(ТипСкидок_Тек,Истина);	
	
	Если ОбъектХДТО.Отбор.Номенклатура<>Неопределено Тогда
		НЗ.Отбор.Номенклатура.Установить(ОбъектХДТО.Отбор.Номенклатура,Истина);	
	КонецЕсли;	
	
	Для Каждого ЗаписьХДТО Из ОбъектХДТО.Строка Цикл
		Запись	= НЗ.Добавить();	
		ЗаполнитьЗначенияСвойств(Запись,ЗаписьХДТО);		
		
		Запись.Документ	= ЗаписьХДТО.ДокументУстановкаСкидок;
		
		Запись.Период		= ОбъектХДТО.Период;
		Запись.ТипСкидок	= ТипСкидок_Тек;
	КонецЦикла;	
	
	НЗ.ОбменДанными.Загрузка=Истина;
	Если Отправитель<>Неопределено И Отправитель<>"Нечто" Тогда
		НЗ.ОбменДанными.Отправитель=Отправитель;	
	КонецЕсли; 
	
	ЗаписатьОбъект(НЗ,Отправитель);
КонецФункции //ЗагрузитьРС_СкидкиНоменклатуры(ОбъектХДТО,Отправитель=Неопределено)

Функция НайтиТипСкидок(Подразделение,БазовыйТипСкидок)
	Результат = Справочники.ТипыСкидок.ПустаяСсылка();
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	РозничныйТипСкидок КАК ТипСкидок
	|ИЗ
	|	Справочник.Подразделения
	|ГДЕ
	|	РозничныйТипСкидок.Базовый = &БазовыйТипСкидок
	|	И Ссылка = &Подразделение
	|";
	
	//Запрос.УстановитьПараметр("",);
	Запрос.УстановитьПараметр("Подразделение",		Подразделение);
	Запрос.УстановитьПараметр("БазовыйТипСкидок",	БазовыйТипСкидок);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат = Выборка.ТипСкидок;	
	КонецЦикла; 
	
	Возврат Выборка.ТипСкидок;
КонецФункции //НайтиТипСкидок(Подразделение,БазовыйТипСкидок)
 


#Область Загрузка_СлужебныеФункции


Функция ПолучитьТипТек(Знач ТипИст)
	Части	= СтрРазделить(ТипИст,".");
	Если Части.Количество()>2 Тогда
		ТипИст=Части[0]+"."+Части[1];			
	КонецЕсли; 
		
	ТипТек	= СоответствиеТиповОбъектов_ЕД.Получить(ТипИст);
	Если ТипТек = Неопределено Тогда		
		ТипТек	= СоответствиеТипов_Нов_Стар.Получить(ТипИст);	
	КонецЕсли;
	
	Возврат ?(ЗначениеЗаполнено(ТипТек),ТипТек,ТипИст);
КонецФункции //ПолучитьТипТек(ТипИст)

Функция СокращениеТипа(Тип)
	Если Тип="ПланВидовХарактеристик" Тогда			
		Сокр="Пвх";		
	ИначеЕсли Тип="РегистрСведений" Тогда
		Сокр="РС";		
	Иначе
		Сокр=Лев(Тип,3);						
	КонецЕсли;
	
	Возврат Сокр;	
КонецФункции //СокращениеТипа(Тип)

Процедура ВывестиПротоколЗагрузки(Протокол) Экспорт
	Если Протокол.Ошибки.Количество()=0 Тогда
		Сообщить_("Загруженные объекты: ");
		Для Каждого Элемент Из ОбъектыОбмена Цикл
			ОбъектСсылка=Неопределено;
			Если СтрНайти(Элемент.ОбъектТип,"РегистрСведений.")=0 Тогда			
				Менеджер 	= ПолучитьМенеджерКласса(Элемент.ОбъектТип);
				Если Менеджер<>Неопределено Тогда				
					ОбъектСсылка= Менеджер.ПолучитьСсылку(Элемент.ОбъектСсылкаУИД);
				КонецЕсли;				
			КонецЕсли; 
			
			Сообщить_("	"+Элемент.ОбъектТип+" "+ОбъектСсылка+" ("+Элемент.ОбъектСсылкаУИД+")"+Элемент.ВариантВыгрузки);	
		КонецЦикла;
	Иначе
		ТекстОшибки=СтрСоединить(Протокол.Ошибки,Символы.ПС);
		Сообщить_(ТекстОшибки,СтатусСообщения.Важное);
	КонецЕсли;
КонецПроцедуры

Функция СоздатьПротоколЗагрузки()
	Возврат Новый Структура("ОшибкаРазбораФйла,Отправитель,ЗагруженныеОбъекты,ОшибкиЗагрузки","",Неопределено,Новый Соответствие,Новый Соответствие);
КонецФункции // ()

Функция ЗаписатьОбъект(Объект,Отправитель)
	Объект.ОбменДанными.Загрузка	= Истина;
	
	Если ЗначениеЗаполнено(Отправитель) И Отправитель<>"Нечто" Тогда		
		Попытка
			Объект.ОбменДанными.Отправитель	= Отправитель;			
		Исключение
			Сообщить_("Ошибка установки отправителя ! "+Объект+" "+ТипЗнч(Объект)+" "+Отправитель+" "+ТипЗнч(Отправитель));
		КонецПопытки;		
	КонецЕсли;	
	
	Попытка
		Если ЗначениеЗаполнено(Отправитель) И ТипЗнч(Отправитель) = Тип("ПланОбменаСсылка.ФР_ОбменСФРК") Тогда
			Объект.ДополнительныеСвойства.Вставить("НеРегистрировать", Истина);					
		КонецЕсли; 
		Объект.Записать();
		
		ДобавитьОбъектВПротоколОбмена(Объект,"Запись","Запись");
		
		Если ФР_ОбщегоНазначения_ПИ.ЭтоСсылочныйТип(ЗначениеВСтрокуВнутр(ТипЗнч(Объект))) Тогда
			Результат	= Объект.Ссылка;		
		Иначе
			Результат	= Неопределено;
		КонецЕсли;
	Исключение
		ТекстОшибки	= "Ошибка записи объекта: "+Объект+" "+ОписаниеОшибки();
		ДобавитьОбъектВПротоколОбмена(Объект,"Запись","Запись",ТекстОшибки);
		
		Сообщить_(ТекстОшибки,СтатусСообщения.Важное);				
	КонецПопытки;
	
	Возврат Результат;
КонецФункции //ЗаписатьОбъект(Объект,Отправитель)

Функция ПолучитьОбработчикЗагрузки(ИмяТипаХДТО)
	Результат	= Новый Структура("Найден,ПроцедураЗагрузки,ИмяТаблицы,Ошибки",Ложь,"","",Новый Массив);
	СтрокиТО	= ОбработчикиЗагрузки.НайтиСтроки(Новый Структура("ИмяТипаХДТО",ИмяТипаХДТО)); 
	Если СтрокиТО.Количество()=1 Тогда
		СтрокаТО					= СтрокиТО[0];						
		
		Результат.Найден			= Истина;
		Результат.ПроцедураЗагрузки = СтрокаТО.ПроцедураЗагрузки;
		Результат.ИмяТаблицы		= СтрокаТО.ИмяТаблицы;
	Иначе		
		Если СтрокиТО.Количество()=0 Тогда
			ТекстОшибки	= "Не найдена процедура загрузки ! Тип объекта: """+ИмяТипаХДТО+""" !";		
		Иначе
			ТекстОшибки	= "Определено несколько процедур загрузки ! Тип объекта: """+ИмяТипаХДТО+""" !";
		КонецЕсли;
		Сообщить_(ТекстОшибки,СтатусСообщения.Важное);
		Результат.Ошибки.Добавить(ТекстОшибки);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьОбработчикЗагрузки(ПолныйТипИст)

Функция РазложитьПолныйТип(ПолныйТип)
	Результат	= Новый Структура("Тип,Вид","","");
	
	ЧастиТипа	= СтрРазделить(ПолныйТип,".");
		
	Если ЧастиТипа.Количество()>1 Тогда
		Результат.Тип	= ЧастиТипа[0];
		Результат.Вид	= ЧастиТипа[1];
		
		Если ЧастиТипа.Количество()>2 И ЧастиТипа[2]="Группа" Тогда		
			Результат.Вид=Результат.Вид+ЧастиТипа[2];
		КонецЕсли;		
	Иначе
		Результат.Тип	= "";
		Результат.Вид	= ЧастиТипа[0];
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //РазложитьТипXML(ТипXML)


