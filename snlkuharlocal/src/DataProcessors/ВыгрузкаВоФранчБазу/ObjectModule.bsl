Функция ИнициализироватьЗаписьXML(ИмяФайлаВыгрузки="") Экспорт
	
	ЗаписьXML = Новый ЗаписьXML();
	Если ЗначениеЗаполнено(ИмяФайлаВыгрузки) Тогда
		ЗаписьXML.ОткрытьФайл(ИмяФайлаВыгрузки,,Ложь);
	Иначе
		ЗаписьXML.УстановитьСтроку();	
	КонецЕсли; 
    
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();	
		
	ЗаписьXML.ЗаписатьНачалоЭлемента("Message");
	
	ХедерXDTO					= Фабрика.Создать(Фабрика.Тип("http://www.1c.ru/SSL/Exchange/Message","Header"));
	
	ХедерXDTO.Format			= "1.6";
	ХедерXDTO.CreationDate  	= СериализаторXDTO.XMLСтрока(ТекущаяДата());	
	
	Если ЗначениеЗаполнено(УзелОтправитель) Тогда		
		КонфирмХДТО					= СоздатьОбъектХДТО("Confirmation",ПространствоИмен_ЕМ);
		
		КонфирмХДТО.ExchangePlan	= УзелОтправитель.Метаданные().Имя;	
		Если ЗначениеЗаполнено(УзелПолучатель) Тогда
			КонфирмХДТО.To			= XMLСтрока(УзелПолучатель.Код);			
		КонецЕсли;		
		КонфирмХДТО.From			= XMLСтрока(УзелОтправитель.Код);	
		
		ХедерXDTO.Confirmation		= КонфирмХДТО;	
	КонецЕсли;	
	
	ХедерXDTO.AvailableVersion.Добавить("1.6");
	
	Фабрика.ЗаписатьXML(ЗаписьXML,ХедерXDTO,,,,НазначениеТипаХМЛ);	
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Body");
	
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("",		ПространствоИмен_ЕД);
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("ee",	ПространствоИмен_ЕЕ);
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xs", 	"http://www.w3.org/2001/XMLSchema");	
    ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsi", 	"http://www.w3.org/2001/XMLSchema-instance");

КонецФункции //ИнициализироватьЗаписьXML()

