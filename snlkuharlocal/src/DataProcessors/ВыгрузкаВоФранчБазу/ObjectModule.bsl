		ОбъектХДТОКол.Наименование = СокрЛП(Реквизиты.Родитель.ФР_Коллекция.Наименование);
		ОбъектХДТОКол.Код	= Число(Формат(СокрЛП(Реквизиты.Родитель.ФР_Коллекция.Код), "ЧГ=0"));
		МОб.Добавить(Новый Структура("ОбъектХДТО, Ссылка, ОбъектТип, ОбъектСсылкаУИД, ОтборРС_Хэш, ВариантВыгрузки", ОбъектХДТОКол, Реквизиты.Родитель.ФР_Коллекция, "Справочник.Коллекции", XMLСтрока(Реквизиты.Родитель.ФР_Коллекция), "", "Элемент"));
