Функция ВыгрузитьСпр_Кассы_Элемент_ЕД(СпрВыборка)	
	ИмяТаблицы		= "Справочник.Кассы";
	ИмяОбъектаХДТО  = "Справочник.КассыККМ";
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(Реквизиты.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяОбъектаХДТО,ПространствоИмен_ЕД);
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_Кассы_Элемент_КС(Реквизиты.Ссылка);	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,	Реквизиты.Код,					"Код", 				"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,	Реквизиты.ПодключенФР,			"ПодключенФР", 		"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,	Реквизиты.ПодключенТерминал,	"ПодключенТерминал","boolean",	ПространствоИмен_СТ);	
	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"РозничныйСклад",	ВыгрузитьСпр_Склады_Элемент_КС(Реквизиты.РозничныйСклад));
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"Владелец",		ВыгрузитьСпр_Подразделения_Элемент_КС(Реквизиты.Владелец));
	
	ДобавитьЭлементХДТО(ОбъектХДТО,	Реквизиты.ПометкаУдаления,		"ПометкаУдаления","boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Кассы_Элемент(Ссылка)

