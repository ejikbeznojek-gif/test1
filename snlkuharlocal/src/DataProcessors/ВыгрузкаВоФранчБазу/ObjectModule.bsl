Функция ВыгрузитьТЧвХДТО1(ВыборкаТЧ,ИмяТипаХДТО,ПостоянныеРеквизитыТЧ=Неопределено)
	ОбъектХДТО_ТЧ		= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ИмяТипаХДТО_Строка	= ИмяТипаХДТО+".Строка";
	
	ЕстьПостоянныеРеквизиты	= (ЗначениеЗаполнено(ПостоянныеРеквизитыТЧ));
	
	Пока ВыборкаТЧ.Следующий() Цикл
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО_Строка,ПространствоИмен_ЕЕ);
		
		Если Прав(ИмяТипаХДТО, 6) = "Товары" Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаТЧ, ,"СтавкаНДС");  
			
			Попытка
				УстановитьСвойствоХДТО(СтрокаТЧ_ХДТО, "СтавкаНДС", ВыгрузитьПер_СтавкаНДС(ВыборкаТЧ.СтавкаНДС));
			Исключение
			КонецПопытки;
		Иначе
			ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаТЧ);
		КонецЕсли;
		
		Если ЕстьПостоянныеРеквизиты Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ПостоянныеРеквизитыТЧ);
		КонецЕсли;
			
		ОбъектХДТО_ТЧ.Строка.Добавить(СтрокаТЧ_ХДТО);
	КонецЦикла;	
	
	Возврат ОбъектХДТО_ТЧ;
КонецФункции

Функция ВыгрузитьДок_ЗаказИМ(ДокВыборка)	
