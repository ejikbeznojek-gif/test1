	ТектсЗапроса	= "ВЫБРАТЬ РАЗЛИЧНЫЕ Номенклатура ИЗ РегистрСведений.ЦеныНоменклатуры ГДЕ Прайс=&Ссылка";
	
	ДопЗапросы.Добавить(Новый Структура("Текст,Реквизиты_ТЧ",ТектсЗапроса,Реквизиты_ТЧ));	
	
	Возврат Новый Структура("Шапка,СписокТЧ,ДопЗапросы",Реквизиты_Ш,СписокТЧ,ДопЗапросы);
