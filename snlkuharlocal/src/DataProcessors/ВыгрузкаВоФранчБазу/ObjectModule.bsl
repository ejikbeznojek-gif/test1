Функция ДействующийТипЦен(ТипЦен)
	ИмяТипа	= "Справочник.ТиыЦен";
	ТипЦенВКэше=ПолучитьИзКэша(ТипЦен,ИмяТипа);
	Если ТипЦенВКэше=Неопределено Тогда
		Если ТипЦен.Базовый.Пустая() Тогда
			ТипЦенВКэше=ТипЦен;
		Иначе
			ТипЦенВКэше=ТипЦен.Базовый;
		КонецЕсли;
		
		ВставитьВКэш(ТипЦен,ТипЦенВКэше,ИмяТипа);
	КонецЕсли; 
	
	Возврат ТипЦенВКэше;
КонецФункции //ДействующийТипЦен(ТипЦен)
 
Функция ДействующийТипСкидок(ТипСкидок)
	ИмяТипа		= "Справочник.ТиыСкидок";
	СсылкаВКэше	= ПолучитьИзКэша(ТипСкидок,ИмяТипа);
	Если СсылкаВКэше=Неопределено Тогда
		Если ТипСкидок.Базовый.Пустая() Тогда
			СсылкаВКэше=ТипСкидок;
		Иначе
			СсылкаВКэше=ТипСкидок.Базовый;
		КонецЕсли;
		
		ВставитьВКэш(ТипСкидок,СсылкаВКэше,ИмяТипа);
	КонецЕсли; 
	
	Возврат СсылкаВКэше;
КонецФункции //ДействующийТипСкидок(ТипЦен)

Функция ВыгрузитьРС_ЗначенияСвойствОбъектов(Отбор)	
	Возврат ВыгрузитьРС_СТАНДАРТНО(РегистрыСведений.ЗначенияСвойствОбъектов,Отбор);	
