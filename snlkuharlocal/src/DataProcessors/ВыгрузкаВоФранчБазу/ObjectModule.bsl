#Область СлужебныеПроцедуры 


Процедура ВыгрузитьКлассификаторы() Экспорт
	
	Если ПустаяСтрока(ИмяФайлаОбмена) Тогда
		Предупреждение_("Не указано имя файла обмена");
		Возврат;
	КонецЕсли;
	
	ИнициализироватьЗаписьXML(ИмяФайлаОбмена);	
	
	Выборка	= Справочники.КлассификаторСтранМира.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбъектХДТО	= ВыгрузитьСпр_СтраныМира_Элемент(Выборка.Ссылка);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЦикла;
	
	Выборка	= Справочники.ОКЕИ.Выбрать();
	Пока Выборка.Следующий() Цикл
		ОбъектХДТО	= ВыгрузитьСпр_Единицы_Элемент(Выборка.Ссылка);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЦикла;	
	
	ЗакрытьЗаписьXML();	

КонецПроцедуры

Процедура ВыгрузитьНачальныеНастройки() Экспорт
	
	Если ПустаяСтрока(ИмяФайлаОбмена) Тогда
		Предупреждение_("Не указано имя файла обмена");
		Возврат;
	КонецЕсли;
	
	ИнициализироватьЗаписьXML(ИмяФайлаОбмена);	
	
	Для Каждого Пользователь Из ПользователиИнформационнойБазы.ПолучитьПользователей() Цикл
		Элемент=Справочники.Пользователи.НайтиПоКоду(Пользователь.Имя);
		Если НЕ Элемент.Пустая() Тогда
			ОбъектХДТО	= ВыгрузитьСправочник(Элемент);
			Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);		
		КонецЕсли;		
	КонецЦикла;
	
	ЭтотУзел			= ПланыОбмена.Основной.ЭтотУзел();	
	
	ТекПодразделение	= ЭтотУзел.Подразделение;
	
	ОбъектХДТО			= ВыгрузитьСправочник(ЭтотУзел.Подразделение);
	Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	
	Если ЗначениеЗаполнено(ТекПодразделение.ОсновнойСклад) Тогда
		ОбъектХДТО		= ВыгрузитьСпр_Склады_Элемент(ЭтотУзел.Подразделение.ОсновнойСклад);
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЕсли;
	
	Если НЕ ТекПодразделение.РозничныйТипЦен.Пустая() Тогда		
		Если ТекПодразделение.РозничныйТипЦен.Базовый.Пустая() Тогда
			ТекТипЦен=ТекПодразделение.РозничныйТипЦен;
		Иначе
			ТекТипЦен=ТекПодразделение.РозничныйТипЦен.Базовый;		
		КонецЕсли; 	
		
		ОбъектХДТО=ВыгрузитьСпр_ТипыЦен_Элемент(ТекТипЦен);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЕсли;
	
	Если НЕ ТекПодразделение.РозничныйТипЦенРаспродажа.Пустая() Тогда		
		Если ТекПодразделение.РозничныйТипЦенРаспродажа.Базовый.Пустая() Тогда
			ТекТипЦен=ТекПодразделение.РозничныйТипЦенРаспродажа;
		Иначе
			ТекТипЦен=ТекПодразделение.РозничныйТипЦенРаспродажа.Базовый;		
		КонецЕсли; 	
		
		ОбъектХДТО=ВыгрузитьСпр_ТипыЦен_Элемент(ТекТипЦен);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЕсли;
	
	Если НЕ ТекПодразделение.РозничныйТипСкидок.Пустая() Тогда
		ОбъектХДТО	= ВыгрузитьСпр_ТипыСкидок_Элемент(ТекПодразделение.РозничныйТипСкидок);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);			
	КонецЕсли;
	
	Выборка=Справочники.Кассы.Выбрать(,ТекПодразделение);
	Пока Выборка.Следующий() Цикл
		ОбъектХДТО	= ВыгрузитьСпр_Кассы_Элемент(Выборка.Ссылка);		
		Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	КонецЦикла; 
	
	ОбъектХДТО=ВыгрузитьПО_Основной(ПланыОбмена.Основной.ЭтотУзел());
	Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
	
	ЗакрытьЗаписьXML();	

КонецПроцедуры

Процедура ВыгрузитьУзлы_ОбменСТЦ() Экспорт
	
	Если ПустаяСтрока(ИмяФайлаОбмена) Тогда
		Предупреждение_("Не указано имя файла обмена");
		Возврат;
	КонецЕсли;
	
	ИнициализироватьЗаписьXML(ИмяФайлаОбмена);	
	
	Выборка=ПланыОбмена.Основной.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если НЕ Выборка.ПометкаУдаления И Выборка.Подразделение.ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
			ОбъектХДТО=ВыгрузитьПО_ОбменСТЦ(Выборка.Ссылка);
			Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
		КонецЕсли;
	КонецЦикла;
	
	ЗакрытьЗаписьXML();	

КонецПроцедуры


