Функция ВыгрузитьСпр_Склады_Элемент_КС(СпрВыборка)
	ИмяТаблицы	= "Справочник.Склады";	
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицы);
	
	Если ОбъектХДТО = Неопределено Тогда
		Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
		
		ОбъектХДТО						= СоздатьОбъектХДТО("КлючевыеСвойстваСклад");
	
		ОбъектХДТО.Ссылка				= XMLСтрока(Реквизиты.Ссылка);			
