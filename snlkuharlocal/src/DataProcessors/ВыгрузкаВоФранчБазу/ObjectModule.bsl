Функция РеквизитыДляВыгрузкивЕД_Справочник_Акции_Элемент()
	ИмяТаблицы			= "Справочник.Акции";
	МетаОбъект			= Метаданные.НайтиПоПолномуИмени(ИмяТаблицы);
	ИменаРеквизитов_Ш	= "ВерсияДанных,Ссылка,Родитель,Код,Наименование,ДатаНачала,ДатаОкончания,ВыдаватьСертификаты,МинимальнаяСуммаПокупки,Описание,ПроцентСертификата,ШтрихКод";
	Реквизиты_Ш			= СоздатьТаблицуРеквизитов(МетаОбъект,ИменаРеквизитов_Ш);
	
	РеквизитыШапок.Вставить(ИмяТаблицы,ИменаРеквизитов_Ш);
	
	УстановитьПараметрыВСтрокеТР(Реквизиты_Ш,"ВыдаватьСертификаты", Новый Структура("ПолеЗапроса","ВыдаватьСертификат"));
	УстановитьПараметрыВСтрокеТР(Реквизиты_Ш,"Родитель", Новый Структура("Кэшировать",Ложь));
	
	СписокТЧ	= Новый Структура;	
	ИменаТЧ		= "Подразделения,ЦеныПродажиБлочками";
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл
		Реквизиты_ТЧ = СоздатьТаблицуРеквизитов(МетаОбъект.ТабличныеЧасти[ИмяТЧ]);	
		СписокТЧ.Вставить(ИмяТЧ,Реквизиты_ТЧ);
	КонецЦикла;	
	
	Возврат Новый Структура("Шапка,СписокТЧ",Реквизиты_Ш,СписокТЧ);
