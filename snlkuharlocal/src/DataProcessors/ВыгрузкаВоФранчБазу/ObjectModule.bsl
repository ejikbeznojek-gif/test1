		ОбъектХДТО.ТипСклада			= "Оптовый";		
		
		ВставитьВКэш(ВхПараметр.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;	
	
	Возврат ОбъектХДТО;	
