	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 	
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= ВыгрузитьСпр_ПодарочныеСертификаты_КС(РеквизитыШ);	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Использован,		"Использован",	     	"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Номинал,			"Номинал",		     	"decimal",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.СрокДействия,		"СрокДействия",     	"decimal",	ПространствоИмен_СТ);
	
	Если ЗначениеЗаполнено(РеквизитыШ.ПодразделениеВыдачи) Тогда
		ПодрХДТО	= ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШ.ПодразделениеВыдачи);
		ДобавитьСвойствоХДТО(ОбъектХДТО,ПодрХДТО,"ПодразделениеВыдачи",ПространствоИмен_ЕЕ);	
