					ПровПодтвЗаяв1 = ?(ДокОбъект.Товары.Итог("ПодтвержденнаяЗаявка") = 0, Истина, Ложь);
					Если ПровПодтвЗаяв И ПровПодтвЗаяв1 Тогда
						Для Каждого СтрокаТЧ Из ДокОбъект.Товары Цикл
							
							Если НЕ (СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Заявка) И (СтрокаТЧ.ПодтвержденнаяЗаявка = 0) Тогда
								СтрокаТЧ.ПодтвержденнаяЗаявка = СтрокаТЧ.Заявка;
								СтрокаТЧ.ПодтвержденнаяЗаявкаПеремещения 	= СтрокаТЧ.ПодтвержденнаяЗаявка;
							КонецЕсли;
							
						КонецЦикла;	
						ДокОбъект.Записать();
					КонецЕсли;
				КонецЕсли;
				//-HELP-8861 20260316 Михайловский
				Статус			= "Записан";
				СтатусЗаписи    = ?(РезультатПоиска.Найден,"Перезапись","Новый");		
				
				Если ДокОбъект.Проведен Тогда			
					Статус			= "Проведен";			
				КонецЕсли;		
				ДобавитьОбъектВПротоколОбмена(ДокОбъект,СтатусЗаписи,Статус);		
			Иначе
				ДобавитьОбъектВПротоколОбмена(ДокОбъект,"","Пропущен",Описание);
			КонецЕсли;
		КонецЕсли;
	Иначе
		ДобавитьОбъектВПротоколОбмена(ДокОбъект,"","Пропущен",Описание);		
	КонецЕсли;	
	
	ТЧ_Сертификаты_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"Сертификаты");
	Если ТЧ_Сертификаты_ХДТО<>Неопределено И ЗначениеЗаполнено(ДокОбъект.Ссылка) Тогда
		ЗагрузитьХПС(ДокОбъект,ТЧ_Сертификаты_ХДТО,ОтправительДляЕЕ);	
