#Область Загрузка_СлужебныеФункции


Процедура УстановитьРеквизитОбъекта(Объект,Имя,Значение)
	Если ЗначениеЗаполнено(Значение) Тогда
		Объект[Имя]=Значение;	
	КонецЕсли;
КонецПроцедуры

Процедура ЗагрузитьРеквизитыОбъекта(Объект,ОбъектХДТО,МассивРеквизитов)
	Для Каждого Элемент Из МассивРеквизитов Цикл
		ИмяРеквизитаТек			= Элемент.Ключ;			
		ИмяРеквизитаХДТО		= ?(ЗначениеЗаполнено(Элемент.Значение),Элемент.Значение,ИмяРеквизитаТек);
			
		Объект[ИмяРеквизитаТек]	= ОбъектХДТО[ИмяРеквизитаХДТО];
	КонецЦикла;	
КонецПроцедуры

Функция ПолучитьСсылку(ДанныеСсылки,Менеджер)
	Результат = Менеджер.ПустаяСсылка();
	
	Если ТипЗнч(ДанныеСсылки)=Тип("Строка") Тогда
		Результат	= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеСсылки))
	ИначеЕсли ТипЗнч(ДанныеСсылки)=ТипЗнч(Результат) Тогда
		Результат	= ДанныеСсылки;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции // ()

Функция ЗагрузитьТЧОбъекта(Объект,ОбъектХДТО,ИменаТЧ,ДопПараметы=Неопределено)
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл		
		текДопПараметры	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметы,ИмяТЧ);
		СоотвРеквизитов	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(текДопПараметры,"СоответствиеРеквизитов",Новый Структура);
		
		ТЧ_Объекта	= Объект[ИмяТЧ];
		
		МетаТЧ		= Объект.Метаданные().ТабличныеЧасти[ИмяТЧ];
		ЕстьЕдиница	= (МетаТЧ.Реквизиты.Найти("Единица")<>Неопределено); 
		
		ТЧ_Объекта.Очистить();
		ТЧ_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяТЧ);
		Если ТЧ_ХДТО<>Неопределено Тогда
			Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
				СтрокаТЧ	= ТЧ_Объекта.Добавить();		
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);
				
				Харка_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"ХарактеристикаНоменклатуры");
				Если Харка_ХДТО<>Неопределено И Харка_ХДТО<>Справочники.Номенклатура.ПустаяСсылка() Тогда
					СтрокаТЧ.Номенклатура	= Харка_ХДТО;
				КонецЕсли;
				Если ЕстьЕдиница Тогда
					СтрокаТЧ.Единица	= ЕдиницаШт(СтрокаТЧ.Номенклатура);				
				КонецЕсли; 
				Для Каждого Элемент Из СоотвРеквизитов Цикл
					СтрокаТЧ[Элемент.Ключ]	= СтрокаТЧ_ХДТО[Элемент.Значение];
				КонецЦикла;
			КонецЦикла; 			
		КонецЕсли;
	КонецЦикла;
КонецФункции //ЗагрузитьТЧОбъекта(Объект,ОбъектХДТО,ИменаТЧ)

Функция ЕдиницаШт(Номенклатура)
	Результат	= Справочники.Единицы.ПустаяСсылка();
	Выборка		= Справочники.Единицы.Выбрать(,Номенклатура);
	Пока Выборка.Следующий() Цикл
		Если Выборка.ОКЕИ	= Ед_Штука Тогда
			Результат	= Выборка.Ссылка;
			
			Если НЕ Выборка.ПометкаУдаления Тогда Прервать КонецЕсли;			
		КонецЕсли;	
	КонецЦикла; 	
	
	Возврат Результат;
КонецФункции // ()
 

