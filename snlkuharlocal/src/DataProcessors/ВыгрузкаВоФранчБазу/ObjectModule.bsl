Функция СоздатьОбъектХДТО(ИмяТипа,Знач ВыбПространствоИмен="") Экспорт
	Если ПустаяСтрока(ВыбПространствоИмен) Тогда
		ВыбПространствоИмен=ПространствоИмен_ЕД;	
	КонецЕсли;
	
	Возврат Фабрика.Создать(Фабрика.Тип(ВыбПространствоИмен,ИмяТипа));
КонецФункции //СоздатьОбъектХДТО(ИмяТипа,Знач ВыбПространствоИмен="")

Функция СоздатьЗначениеХДТО(ИмяТипа,Значение,Знач ВыбПространствоИмен="")
	Если Значение=Неопределено ИЛИ Значение=NULL ИЛИ ПустаяСтрока(Значение) Тогда Возврат Неопределено КонецЕсли;
	
	Если ПустаяСтрока(ВыбПространствоИмен) Тогда
		ВыбПространствоИмен=ПространствоИмен_ЕД;	
	КонецЕсли;
	
	Возврат Фабрика.Создать(Фабрика.Тип(ВыбПространствоИмен,ИмяТипа),Значение);
КонецФункции //СоздатьЗначениеХДТО()

Процедура ДобавитьЭлементХДТО(ОбъектХДТО,Значение,ИмяПоля,ИмяТипа,ПространствоИмен)
	Если ЗначениеЗаполнено_(Значение) Тогда
		ЭлементXDTO	= СоздатьЗначениеХДТО(ИмяТипа,Значение,ПространствоИмен);
		ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен,ИмяПоля,ЭлементXDTO);
	КонецЕсли;	
КонецПроцедуры

Функция ДобавитьСвойствоХДТО(ОбъектХДТО,ЗначениеХДТО,ИмяПоля,ПространствоИмен)
	Если ЗначениеЗаполнено_(ЗначениеХДТО) Тогда
		ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен,ИмяПоля,ЗначениеХДТО);		
	КонецЕсли;
КонецФункции //ЗаписатьСвойствоХДТО(ОбъектХДТО,ЗначениеХДТО,ИмяПоля,ПространствоИмен)

Функция ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяСвойства) Экспорт
	Результат	= Неопределено;
	Если ОбъектХДТО.Свойства().Получить(ИмяСвойства)<>Неопределено Тогда
		Результат	= ОбъектХДТО[ИмяСвойства];
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяСвойства)

Функция ЗаполненныеСвойстваХДТО(ОбъектХДТО)
	Результат	= Новый Структура;	
	Для Каждого Свойство Из ОбъектХДТО.Свойства() Цикл
		Значение	= ОбъектХДТО.Получить(Свойство);
		Если Значение<>Неопределено Тогда
			Результат.Вставить(Свойство,Значение);							
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;
КонецФункции //ЗаполненныеСвойстваХДТО(ОбъектХДТО)


