	ИменаРеквизитов	= "
		|ВерсияДанных,Ссылка,Проведен,ПометкаУдаления,Дата,Номер,ТипЦен.Базовый,*
		|";
	
	РеквизитыШапок.Вставить("Документ.ПрайсЛист",ИменаРеквизитов);
	
	Реквизиты_Ш		= СоздатьТаблицуРеквизитов(МетаДок,ИменаРеквизитов);	
	
	СписокТЧ		= Новый Структура;
	
	ДопЗапросы		= Новый Массив;
	
	Реквизиты_ТЧ	= ПустаяТаблицаРеквизитов();
	СтрокаТР=Реквизиты_ТЧ.Добавить(); СтрокаТР.Имя="Номенклатура"; СтрокаТР.ПолеЗапроса="Номенклатура"; 
