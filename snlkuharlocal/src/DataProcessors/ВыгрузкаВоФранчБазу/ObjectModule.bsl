//+HELP-3182 20250313 Михайловский
Процедура ПроверитьХКМ(ДокСсылка);	
	Попытка
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
		|ГДЕ
		|	ХранилищеКодовМаркировки.ДокОснование = &ДокСсылка";
		Запр.УстановитьПараметр("ДокСсылка", ДокСсылка);
		Выб = Запр.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Если НЕ ДокСсылка.ТребуетсяМаркировка Тогда
				ДокОб = ДокСсылка.ПолучитьОбъект();
				Если НЕ ДокОб = Неопределено Тогда
					ДокОб.ТребуетсяМаркировка = Истина;
					ДокОб.Записать();
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры //-HELP-3182 20250313 Михайловский

