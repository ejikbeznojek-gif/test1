Функция ЗаполнитьСоответствия()
	СоответствиеТипов_Стар_Нов	= Новый Соответствие();
	
	СоответствиеТипов_Стар_Нов.Вставить("Справочник.Договоры",		"Справочник.ДоговорыКонтрагентов");
	СоответствиеТипов_Стар_Нов.Вставить("Справочник.Номенклатура",	"Справочник.ХарактеристикиНоменклатуры");
	
	СоответствиеТипов_Стар_Нов.Вставить("Документ.Заказ",			"Документ.ЗаказПокупателя");
	СоответствиеТипов_Стар_Нов.Вставить("Документы.Инвентаризация",	"Документ.ИнвентаризацияТМЦ");	
	
	СоответствиеТипов_Нов_Стар=Новый Соответствие;
	Для Каждого Элемент Из СоответствиеТипов_Стар_Нов Цикл
		СоответствиеТипов_Нов_Стар.Вставить(Элемент.Значение,Элемент.Ключ);	
	КонецЦикла;
	
	СоответствиеТиповОбъектов_ЕД	= СоответствиеТиповОбъектов_ЕД();	
	
	СоответствиеЗначенийПеречислений= СоответствиеЗначенийПеречислений();
КонецФункции //ЗаполнитьСоответствиеТипов()

