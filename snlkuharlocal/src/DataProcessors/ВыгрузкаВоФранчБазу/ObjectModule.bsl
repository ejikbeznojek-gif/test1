						СтрокаТЧ.Коллекция = Справочники.ФР_Коллекции.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(УИД_ХДТО)));
					КонецЕсли;
				ИначеЕсли ИмяТЧ = "Цвета" Тогда
					УИД_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"УИД");
					Если НЕ УИД_ХДТО = "00000000-0000-0000-0000-000000000000" И НЕ ПустаяСтрока(УИД_ХДТО) Тогда
						СтрокаТЧ.Цвет = Справочники.Цвета.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(УИД_ХДТО)));
					КонецЕсли;
				ИначеЕсли ИмяТЧ = "Размеры" Тогда
					УИД_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"УИД");
					Если НЕ УИД_ХДТО = "00000000-0000-0000-0000-000000000000" И НЕ ПустаяСтрока(УИД_ХДТО) Тогда
						СтрокаТЧ.Размер = Справочники.Размеры.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(УИД_ХДТО)));
					КонецЕсли;
				КонецЕсли;	
				//Харка_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"ХарактеристикаНоменклатуры");
				//Если Харка_ХДТО<>Неопределено И Харка_ХДТО<>Справочники.Номенклатура.ПустаяСсылка() Тогда
				//	СтрокаТЧ.Номенклатура	= Харка_ХДТО;
				//КонецЕсли;
				//Если ЕстьЕдиница Тогда
				//	СтрокаТЧ.Единица	= ЕдиницаШт(СтрокаТЧ.Номенклатура);				
				//КонецЕсли; 
				//Для Каждого Элемент Из СоотвРеквизитов Цикл
				//	СтрокаТЧ[Элемент.Ключ]	= СтрокаТЧ_ХДТО[Элемент.Значение];
				//КонецЦикла;
			КонецЦикла; 			
		КонецЕсли;
	КонецЦикла;
КонецФункции //-HELP-2306 20250220 Михайловский

Функция ЗагрузитьДок_МКО(ОбъектХДТО, Отправитель)
	Менеджер	= Документы.МаркировкаОстатковТЦ;
	Вид			= Менеджер.ПустаяСсылка().Метаданные().Имя;	
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли; 
	
	ДокОбъект	= РезультатПоиска.Объект;
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);
	
	ДокОбъект.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(ОбъектХДТО.Организация)));
	ДокОбъект.Подразделение = Справочники.Подразделения.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(ОбъектХДТО.Подразделение)));	
	ИменаТЧ	= "Товары";
	
	ЗагрузитьТЧОбъектаМКО(ДокОбъект, ОбъектХДТО, ИменаТЧ);
	
	//ЗагрузитьРеквизитыСМультиТипами(ДокОбъект, ОбъектХДТО, "ДокОснование,Отправитель,Получатель");
		
	ЗаписатьДокумент(ДокОбъект, Отправитель, РезультатПоиска.Найден);
	
	
КонецФункции

