	ВариантВыгрузки = "Элемент";
	ИмяОбъектаХДТО	= ИмяТаблицы;
	
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО					= СоздатьОбъектХДТО(ИмяОбъектаХДТО);
	
	ОбъектХДТО.КлючевыеСвойства		= ВыгрузитьСпр_ТипыЦен_Элемент_КС(СпрВыборка);
	ОбъектХДТО.ЦенаВключаетНДС		= Истина;	
	ОбъектХДТО.ТочностьОкругления	= РеквизитыШ.ТочностьОкругления;	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Код,		"Код",		"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.sale,		"sale",		"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Розничный,"Розничный","boolean",	ПространствоИмен_СТ);	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,"ПометкаУдаления", "boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;	
КонецФункции //Выгрузить_КС_ТипыЦен(Ссылка)

Функция ВыгрузитьСпр_ТипыЦен_Элемент_КС(СпрВыборка)		
	ИмяТаблицы	= "Справочник.ТипыЦен";
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицы);	
	
	Если ОбъектХДТО=Неопределено Тогда
		РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"КС");
		
		Если ПустаяСтрока(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
		ОбъектХДТО	= ВыгрузитьСпр_КС(РеквизитыШ.Ссылка,"ТипыЦен","Наименование","КлючевыеСвойстваТипЦен");	
		ОбъектХДТО.ВалютаЦены	= ВыгрузитьСпр_Валюты_КС(РеквизитыШ.Валюта);
		
		ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Код,"Код","string",ПространствоИмен_СТ);
	КонецЕсли;
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьСпр_ТипыЦен_Элемент_КС(СпрВыборка)

