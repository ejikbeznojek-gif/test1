Функция ВыгрузитьСпр_ФизическиеЛица_Элемент_ЕД(СпрВыборка)	
	ИмяТаблицы	= "Справочник.ФизическиеЛица";	
	ИмяТипаХДТО = "Справочник.ФизическиеЛица";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(Реквизиты.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО					= СоздатьОбъектХДТО(ИмяТипаХДТО);
	
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(СпрВыборка);			
		
	ДобавитьЭлементХДТО(ОбъектХДТО,СпрВыборка.Код,"Код","string",ПространствоИмен_СТ);
	
	Если ЗначениеЗаполнено(Реквизиты.Подразделение) Тогда
		ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"Подразделение",ВыгрузитьСпр_Подразделения_Элемент_КС(Реквизиты.Подразделение));
	КонецЕсли;
	
	Возврат ОбъектХДТО;	
