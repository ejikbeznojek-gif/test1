	|Автор.ФизЛицо,*
	|";
	
	РеквизитыШапок.Вставить("Документ.Перемещение_ПРМ_РНК",ИменаРеквизитов);
	
	Реквизиты_Ш		= СоздатьТаблицуРеквизитов(МетаДок,ИменаРеквизитов);	
	
	ПолеЗапроса		= "Склад.Подразделение";
	УстановитьПараметрыВСтрокеТР(Реквизиты_Ш,"Подразделение",		Новый Структура("ПолеЗапроса",ПолеЗапроса));	
	
	ИменаРеквизитов	= "Номенклатура,ХарактеристикаНоменклатуры,Единица,СтавкаНДС,Заявка,ПодтвержденнаяЗаявка,Количество,Цена,Сумма,НДС,Всего,Себестоимость";
	
	Реквизиты_ТЧ_Товары	= СоздатьТаблицуРеквизитов(МетаДок.ТабличныеЧасти.Товары,ИменаРеквизитов);	
	
	УстановитьПараметрыВСтрокеТР(Реквизиты_ТЧ_Товары,"Номенклатура",				Новый Структура("ПолеЗапроса","Номенклатура.Родитель"));
