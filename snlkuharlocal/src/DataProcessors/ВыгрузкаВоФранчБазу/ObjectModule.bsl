Функция ВыгрузитьСпр_Акции_Элемент(СпрВыборка)
	ИмяТаблицы	= "Справочник.Акции";
	ИмяУзлаХДТО	= ИмяТаблицы+".Элемент";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
	ТекСсылка	= РеквизитыШ.Ссылка;
	
	ОбъектХДТО							= СоздатьОбъектХДТО(ИмяУзлаХДТО,ПространствоИмен_ЕЕ);		
	
	ОбъектХДТО.Ссылка					= ТекСсылка;
	
	ОбъектХДТО.Код						= РеквизитыШ.Код;
	ОбъектХДТО.Наименование				= РеквизитыШ.Наименование;
	ОбъектХДТО.Описание					= РеквизитыШ.Описание;
	ОбъектХДТО.ДатаНачала				= РеквизитыШ.ДатаНачала;
	ОбъектХДТО.ДатаОкончания			= РеквизитыШ.ДатаОкончания;
	ОбъектХДТО.ВыдаватьСертификаты		= РеквизитыШ.ВыдаватьСертификаты;		
	ОбъектХДТО.МинимальнаяСуммаПокупки  = РеквизитыШ.МинимальнаяСуммаПокупки;
	ОбъектХДТО.Штрихкод					= РеквизитыШ.ШтрихКод;
	
	ТЧ_УчаствующиеПодразделенияXDTO		= СоздатьОбъектХДТО("Справочник.Акции.УчаствующиеПодразделения",ПространствоИмен_ЕЕ);		
	
	ВыборкаПоТЧ_Подразделения			= СпрВыборка.Подразделения.Выбрать();	
	Пока ВыборкаПоТЧ_Подразделения.Следующий() Цикл
		Если ВыборкаПоТЧ_Подразделения.Подразделение=ПодразделениеПолучатель Тогда
			СтрокаТЧ_ХДТО				= СоздатьОбъектХДТО("Справочник.Акции.УчаствующиеПодразделения.Строка",ПространствоИмен_ЕЕ);				
			СтрокаТЧ_ХДТО.Подразделение	= СериализаторXDTO.XMLСтрока(ВыборкаПоТЧ_Подразделения.Подразделение);			
			
			ТЧ_УчаствующиеПодразделенияXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);			
		КонецЕсли;			
	КонецЦикла;		
	
	Если ТЧ_УчаствующиеПодразделенияXDTO.Строка.Количество()>0 Тогда
		ОбъектХДТО.УчаствующиеПодразделения=ТЧ_УчаствующиеПодразделенияXDTO;		
	КонецЕсли; 
	
	//НоменклатураКаскаднаяСкидка+НоменклатураДляСкидокНаБлочок
	ТЧ_ХДТО			= СоздатьОбъектХДТО("Справочник.Акции.Номенклатура",ПространствоИмен_ЕЕ);		
	ВыборкаПоТЧ		= НоменклатураИзАкции(ТекСсылка);		
	
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаПоТЧ.ВерсияДанных) Тогда
			СтрокаТЧ_ХДТО				= СоздатьОбъектХДТО("Справочник.Акции.Номенклатура.Строка",ПространствоИмен_ЕЕ);				
			СтрокаТЧ_ХДТО.Номенклатура	= XMLСтрока(ВыборкаПоТЧ.Ссылка);			
			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);			
		КонецЕсли;			
	КонецЦикла;
	
	Если ТЧ_ХДТО.Строка.Количество()>0 Тогда
		ОбъектХДТО.Номенклатура=ТЧ_ХДТО;
	КонецЕсли;
	
	ИмяТЧ			= "ЦеныПродажиБлочками";
	ТЧ_ХДТО			= СоздатьОбъектХДТО("Справочник.Акции."+ИмяТЧ,ПространствоИмен_ЕЕ);		
	ВыборкаПоТЧ		= ПолучитьВыборкуТЧ(СпрВыборка,ИмяТЧ);	
	Пока ВыборкаПоТЧ.Следующий() Цикл		
		СтрокаТЧ_ХДТО				= СоздатьОбъектХДТО(СтрШаблон("%1.%2.%3",ИмяТаблицы,ИмяТЧ,"Строка"),ПространствоИмен_ЕЕ);				
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ);		
			
		ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
	КонецЦикла;	
	Если ТЧ_ХДТО.Строка.Количество()>0 Тогда
		ОбъектХДТО[ИмяТЧ]=ТЧ_ХДТО;
	КонецЕсли;
	

	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Акции_Элемент(СпрВыборка)

Функция НоменклатураИзАкции(АкцияСсылка)
	ИмяТаблицы	= "Справочник.Номенклатура";
	РеквизитыШ	= РеквизитыШапок.Получить(ИмяТаблицы+".Элемент.КС");
	
	МР=Новый Массив;
	Для Каждого Реквизит Из СтрРазделить(РеквизитыШ,",") Цикл
		МР.Добавить("Номенклатура.Родитель."+Реквизит+" КАК "+Реквизит);	
	КонецЦикла; 
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	"+СтрСоединить(МР,",")+"
	|ИЗ
	|	Справочник.Акции.НоменклатураДляСтильнойАрифметики
	|ГДЕ
	|	Ссылка=&АкцияСсылка
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	"+СтрСоединить(МР,",")+"
	|ИЗ
	|	Справочник.Акции.НоменклатураДляСкидокНаБлочок
	|ГДЕ
	|	Ссылка=&АкцияСсылка
	|";
	
	Запрос.УстановитьПараметр("АкцияСсылка",АкцияСсылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
КонецФункции //НоменклатураИзАкции(АкцияСсылка)
 

Функция ВыгрузитьСпр_Валюты_КС(ВалютаСсылка)	
	ОбъектХДТО				= СоздатьОбъектХДТО("КлючевыеСвойстваВалюта");
	
	ОбъектХДТО.Ссылка		= ""+ВалютаСсылка.УникальныйИдентификатор();
	ОбъектХДТО.Код			= ?(ВалютаСсылка.Код="810","643",ВалютаСсылка.Код);
	ОбъектХДТО.Наименование	= ВалютаСсылка.Наименование;	
	
	Возврат ОбъектХДТО;
