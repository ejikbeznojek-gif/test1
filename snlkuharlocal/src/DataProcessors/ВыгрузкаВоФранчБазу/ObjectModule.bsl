Функция ВыгрузитьСпр_Номенклатура_Элемент_КС(СпрВыборка,КраткийФормат=Истина)	
	ОбъектХДТО	= Неопределено;
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка	= Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	ОбъектХДТО	= ПолучитьИзКэша(ТекСсылка);		
	Если ОбъектХДТО	= Неопределено Тогда		
		Если НаВходеВыборка Тогда
			Реквизиты	= СпрВыборка;
		Иначе
			Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Родитель,Код,Наименование,КодПроизводителя");		
		КонецЕсли;		
		
		ОбъектХДТО					= СоздатьОбъектХДТО("КлючевыеСвойстваНоменклатура");		
		
		ОбъектХДТО.Ссылка			= XMLСтрока(ТекСсылка);	
		
		Если НЕ КраткийФормат Тогда
			ОбъектХДТО.НаименованиеПолное	= Реквизиты.Наименование;
			ОбъектХДТО.КодВПрограмме		= Реквизиты.Код;	
			ОбъектХДТО.Артикул				= Реквизиты.КодПроизводителя;	
		КонецЕсли;
		
		ОбъектХДТО.Наименование		= Реквизиты.Наименование;
		
		Если НЕ КраткийФормат Тогда			
			УстановитьСвойствоХДТО(ОбъектХДТО,"Группа",ВыгрузитьСпр_Номенклатура_Группа_КС(Реквизиты.Родитель));
		КонецЕсли;
		
		ВставитьВКэш(ТекСсылка,ОбъектХДТО);
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(Номенклатура,Фабрика)

Функция ВыгрузитьСпр_Номенклатура_Элемент_ЕД(СпрВыборка)
	ОбъектХДТО	= Неопределено;
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка	= Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	Если НаВходеВыборка Тогда
		Реквизиты	= СпрВыборка;
	Иначе
		Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Родитель,Код,СтавкаНДС,Наименование,ОписаниеТовараДляСайта");		
	КонецЕсли;		
	
	ОбъектХДТО					= СоздатьОбъектХДТО("Справочник.Номенклатура");
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_Номенклатура_Элемент_КС(СпрВыборка,Ложь);
	ОбъектХДТО.ТипНоменклатуры	= "Товар";
	ОбъектХДТО.Описание 		= Реквизиты.ОписаниеТовараДляСайта;	
	ОбъектХДТО.ЕдиницаИзмерения	= ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);
	
	Если ЗначениеЗаполнено(Реквизиты.СтавкаНДС) Тогда
		ОбъектХДТО.СтавкаНДС	= ВыгрузитьПер_СтавкаНДС(Реквизиты.СтавкаНДС);	
	КонецЕсли;	
	
	ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_Номенклатура_Элемент_СоставНоменклатуры(ТекСсылка),"Состав",ПространствоИмен_ЕЕ);		
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.РусскоеНаименование,			"НаименованиеДляЭтикетки",	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ТипТовара,						"ТипТовара",				"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.ВидНоменклатуры),	"ВидНоменклатурыЕЕ",		"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.СнятСПроизводства,				"СнятСПроизводства",		"boolean",	ПространствоИмен_СТ);	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,				"ПометкаУдаления",			"boolean", 	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_Номенклатура_Элемент_Объект(СпрВыборка)

Функция ВыгрузитьСпр_Номенклатура_Элемент(СпрВыборка)
	ИмяТаблицы	= Метаданные.Справочники.Номенклатура.ПолноеИмя();
	ОбъектХДТО	= Неопределено;
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка	= Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	Если НаВходеВыборка Тогда
		Реквизиты	= СпрВыборка;
	Иначе
		Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Родитель,Код,СтавкаНДС,Наименование,ОписаниеТовараДляСайта");		
	КонецЕсли;		
	
	ОбъектХДТО					= СоздатьОбъектХДТО("Справочник.Номенклатура.Элемент",ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,СпрВыборка,,"СоставНоменклатуры,ВидНоменклатуры");
	
	ОбъектХДТО.НаименованиеДляЭтикетки	= Реквизиты.РусскоеНаименование;
	ОбъектХДТО.Артикул					= Реквизиты.КодПроизводителя;
	ОбъектХДТО.ВидНоменклатуры			= Реквизиты.ФР_ВидНоменклатуры;
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ТипТовара,						"ТипТовара",				"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Реквизиты.ВидНоменклатуры),	"ВидНоменклатурыЕЕ",		"string",	ПространствоИмен_СТ);	
	
	
	ИмяТЧ			= "СоставНоменклатуры";
	ТЧ_ХДТО			= СоздатьОбъектХДТО(ИмяТаблицы+"."+ИмяТЧ,ПространствоИмен_ЕЕ);		
	ВыборкаПоТЧ		= ПолучитьВыборкуТЧ(СпрВыборка,ИмяТЧ);		
	
	Пока ВыборкаПоТЧ.Следующий() Цикл		
		СтрокаТЧ_ХДТО				= СоздатьОбъектХДТО(СтрШаблон("%1.%2.%3",ИмяТаблицы,ИмяТЧ,"Строка"),ПространствоИмен_ЕЕ);				
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ);		
			
		ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
	КонецЦикла;		
	
	Если ТЧ_ХДТО.Строка.Количество()>0 Тогда
		ОбъектХДТО[ИмяТЧ]=ТЧ_ХДТО;
	КонецЕсли;

	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_Номенклатура_Элемент_Объект(СпрВыборка)

Функция ВыгрузитьСпр_Номенклатура_Группа_КС(СпрВыборка)
	ИмяТаблиы	= "Справочник.Номенклатура";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблиы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	КС_XDTO	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблиы);
	
	Если КС_XDTO=Неопределено Тогда	
		РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Группа.КС");
	
		Если ПустаяСтрока(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
		КС_XDTO					= СоздатьОбъектХДТО("КлючевыеСвойстваНоменклатураГруппа");
	
		КС_XDTO.Ссылка			= XMLСтрока(РеквизитыШ.Ссылка);	
		КС_XDTO.Наименование	= РеквизитыШ.Наименование;
		КС_XDTO.КодВПрограмме	= РеквизитыШ.Код;		
		
		Если ЗначениеЗаполнено(РеквизитыШ.Родитель) Тогда
			КС_XDTO.Группа	= ВыгрузитьСпр_Номенклатура_Группа_КС(РеквизитыШ.Родитель);	
		КонецЕсли;
		
		ВставитьВКэш(РеквизитыШ.Ссылка,КС_XDTO,ИмяТаблиы);
	КонецЕсли;	
	
	Возврат КС_XDTO;
КонецФункции //ВыгрузитьСпр_Номенклатура_Группа_КС(СпрВыборка)

Функция ВыгрузитьСпр_Номенклатура_Группа(СпрВыборка)
	ОбъектХДТО	= Неопределено;
	Если СпрВыборка	= Неопределено ИЛИ СпрВыборка = Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат ОбъектХДТО;
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	Если НаВходеВыборка Тогда
		Реквизиты	= СпрВыборка;
	Иначе
		Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,РеквизитыШапок.Получить("Справочник.Номенклатура_Группа"));
	КонецЕсли;			
	
	ОбъектХДТО					= СоздатьОбъектХДТО("Справочник.НоменклатураГруппа",ПространствоИмен_ЕД);
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_Номенклатура_Группа_КС(СпрВыборка);		
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_Номенклатура_Группа_Объект(Ссылка)

Функция ВыгрузитьСпр_Номенклатура_Группа_Корень()
	СвойстваXDTO					= СоздатьОбъектХДТО("КлючевыеСвойстваНоменклатураГруппа");
	
	СвойстваXDTO.Ссылка				= СериализаторXDTO.XMLСтрока(Новый УникальныйИдентификатор("b80145a5-e351-11e9-b7f3-cf347837b296"));		
	СвойстваXDTO.Наименование		= "СтильПарк";
	СвойстваXDTO.КодВПрограмме		= "БП-00000229";	
	
	Возврат СвойстваXDTO;
КонецФункции // ()

Функция ВыгрузитьСпр_Номенклатура_Элемент_СоставНоменклатуры(Ссылка)
	Запрос		 = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	МатериалСостав,
	|	Процент
	|ИЗ
	|	Справочник.Номенклатура.СоставНоменклатуры
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И Процент>0
	|";
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Количество()>0 Тогда
		СоставXDTO	= СоздатьОбъектХДТО("Справочник.Номенклатура.Состав",ПространствоИмен_ЕЕ);
		Пока Выборка.Следующий() Цикл
			СтрокаСоставаXDTO	= СоздатьОбъектХДТО("Справочник.Номенклатура.Состав.Строка",ПространствоИмен_ЕЕ);			
			ЗаполнитьЗначенияСвойств(СтрокаСоставаXDTO,Выборка);
			
			СоставXDTO.Строка.Добавить(СтрокаСоставаXDTO);
		КонецЦикла; 		
	Иначе
		СоставXDTO	= Неопределено;
	КонецЕсли;
	
	Возврат СоставXDTO;
КонецФункции // ()

Функция ВыгрузитьСпр_ФР_НоменклатурныеГруппы_Элемент(СпрВыборка)
