Функция ЗагрузитьРС_КоличествоПосетителей(ОбъектХДТО,Отправитель)
	НЗ	= РегистрыСведений.КоличествоПосетителей.СоздатьНаборЗаписей();
	
	Дата			= ОбъектХДТО.Отбор.Дата;
	Подразделение	= ОбъектХДТО.Отбор.Подразделение; 
	Попытка
		Склад		 	= Подразделение.ОсновнойСклад;
	Исключение
	КонецПопытки;
	
	НЗ.Отбор.Дата.Установить(Дата,Истина);
	НЗ.Отбор.Подразделение.Установить(Подразделение,Истина);
	НЗ.Отбор.Склад.Установить(Склад,Истина);
		
	Для Каждого ЗаписьХДТО Из ОбъектХДТО.Строка Цикл
		Запись	= НЗ.Добавить();	
		ЗаполнитьЗначенияСвойств(Запись,ЗаписьХДТО);
		Запись.Склад				 	= Склад;
		Запись.Дата						= Дата;
		
		Запись.КоличествоПосетителей	= ЗаписьХДТО.Количество;		
	КонецЦикла; 
	
	ЗаписатьОбъект(НЗ,Отправитель);	
КонецФункции //ЗагрузитьРС_КоличествоПосетителей(ОбъектХДТО,Отправитель=Неопределено)


