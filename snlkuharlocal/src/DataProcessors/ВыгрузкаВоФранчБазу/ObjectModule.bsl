Функция ЭтоПростойТип(Значение)
	Результат	= Ложь;
	
	Если ТипЗнч(Значение)=Тип("Тип") Тогда
		ТекТип	= Значение;		
	Иначе
		ТекТип	= ТипЗнч(Значение);		
	КонецЕсли;	
	
	Если ТекТип=Тип("Число") 
		ИЛИ ТекТип=Тип("Строка")
		ИЛИ ТекТип=Тип("Дата")
		ИЛИ ТекТип=Тип("Булево") Тогда	
		
		Результат	= Истина;	
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ЭтоПростойТип(Значение)

Функция ЭтоПростойРеквизит(МетаРеквизит)
	ПолноеИмя	= МетаРеквизит.ПолноеИмя();
	Результат	= ПростыеРеквизиты.Получить(ПолноеИмя);
	Если Результат=Неопределено Тогда	
		Если МетаРеквизит.Тип.Типы().Количество()=1 Тогда
			Результат=ЭтоПростойТип(МетаРеквизит.Тип.Типы()[0]);
		Иначе
			Результат=Ложь; //А фиг его знает что там на самом деле
		КонецЕсли;
		
		ПростыеРеквизиты.Вставить(ПолноеИмя,Результат);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ЭтоПростойРеквизит()
 
Процедура РасковырятьСсылкиИзОбъекта(Объект) Экспорт	
	ОбработкаПрерыванияПользователя_();	
		
	Если ТипЗнч(НаковырянныеСсылки)<>Тип("Соответствие") Тогда
		НаковырянныеСсылки=Новый Соответствие;	
	КонецЕсли;
	Если ТипЗнч(ПростыеРеквизиты)<>Тип("Соответствие") Тогда
		ПростыеРеквизиты=Новый Соответствие;	
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Объект) Тогда Возврат КонецЕсли;
	
	ТипОбъекта = ТипЗнч(Объект);
	
	Если ЭтоПростойТип(ТипОбъекта) Тогда Возврат КонецЕсли;
	Если ТипОбъекта=Тип("ХранилищеЗначения") Тогда Возврат КонецЕсли;	
	
	Если НЕ ФР_ОбщегоНазначения_ПИ.ЭтоСсылочныйТип(ЗначениеВСтрокуВнутр(ТипОбъекта)) Тогда Возврат КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект) Тогда
		Если НаковырянныеСсылки.Получить(Объект)=Неопределено Тогда			
			НаковырянныеСсылки.Вставить(Объект,Истина);					
			Состояние_(НаковырянныеСсылки.Количество());
		Иначе
			Возврат;		
		КонецЕсли;		
	КонецЕсли;
	
	Если ТипОбъекта=Тип("СправочникСсылка.Акции")
		ИЛИ ТипОбъекта=Тип("СправочникСсылка.Подразделения")
		ИЛИ ТипОбъекта=Тип("СправочникСсылка.Пользователи") 
		ИЛИ ТипОбъекта=Тип("СправочникСсылка.Номенклатура") Тогда
		Возврат;	
	КонецЕсли; 
	
	МетаОбъект=Объект.Метаданные();
	Для Каждого МетаРеквизит Из МетаОбъект.Реквизиты Цикл
		Если ЭтоПростойРеквизит(МетаРеквизит) Тогда Продолжить КонецЕсли;
		
		ТекЗначение	= Объект[МетаРеквизит.Имя];
		РасковырятьСсылкиИзОбъекта(ТекЗначение);		
	КонецЦикла; 
	
	Для Каждого МетаТЧ Из МетаОбъект.ТабличныеЧасти Цикл	
		Для Каждого СтрокаТЧ Из Объект[МетаТЧ.Имя] Цикл
			Для Каждого РеквизитТЧ Из МетаТЧ.Реквизиты Цикл				
				Если ЭтоПростойРеквизит(РеквизитТЧ) Тогда Продолжить КонецЕсли;
				
				ТекЗначение	= СтрокаТЧ[РеквизитТЧ.Имя];				
				РасковырятьСсылкиИзОбъекта(ТекЗначение);				
			КонецЦикла;		
		КонецЦикла; 
	КонецЦикла;
	
	//Если Метаданные.Документы.Содержит(МетаОбъект) И МетаОбъект.Движения.Содержит(Метаданные.РегистрыБухгалтерии.Хозрасчетный) Тогда
	//	НЗ=РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
	//	НЗ.Отбор.Регистратор.Установить(Объект,Истина);
	//	НЗ.Прочитать();
	//	Для Каждого Проводка Из НЗ Цикл
	//		РасковырятьСсылкиИзОбъекта(Проводка.ПодразделениеДт);					
	//		РасковырятьСсылкиИзОбъекта(Проводка.ПодразделениеКт);
	//		
	//		РасковырятьСсылкиИзОбъекта(Проводка.ВалютаДт);
	//		РасковырятьСсылкиИзОбъекта(Проводка.ВалютаКт);
	//		
	//		Для Сч=1 По Проводка.СчетДт.ВидыСубконто.Количество() Цикл
	//			РасковырятьСсылкиИзОбъекта(Проводка.СубконтоДт[Проводка.СчетДт.ВидыСубконто[Сч-1].ВидСубконто]);		
	//		КонецЦикла; 
	//		Для Сч=1 По Проводка.СчетКт.ВидыСубконто.Количество() Цикл
	//			РасковырятьСсылкиИзОбъекта(Проводка.СубконтоКт[Проводка.СчетКт.ВидыСубконто[Сч-1].ВидСубконто]);		
	//		КонецЦикла;			
	//	КонецЦикла;	
	//КонецЕсли; 
	
КонецПроцедуры

Функция ЗарегистрироватьВыборку(ТекстЗапроса,ИмяОбъекта,ВариантВыгрузки="",ДопПараметры=Неопределено) Экспорт
	Если ТипЗнч(ТекстЗапроса)=Тип("Строка") Тогда
		Запрос	= Новый Запрос(ТекстЗапроса);
	
		Запрос.УстановитьПараметр("Дата1",НачалоДня(Дата1));
		Запрос.УстановитьПараметр("Дата2",КонецДня(Дата2));
	
		Запрос.УстановитьПараметр("ПодразделениеПолучатель",ПодразделениеПолучатель);	
	Иначе
		Запрос	= ТекстЗапроса;
	КонецЕсли;	
	
	Если ДопПараметры<>Неопределено Тогда
		Для Каждого Элемент Из ДопПараметры Цикл
			Запрос.УстановитьПараметр(Элемент.Ключ,Элемент.Значение);		
		КонецЦикла;
	КонецЕсли;
	
	
	
	ТО			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Результат	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	
	//Сообщить_("К регистрации по типу "+ИмяОбъекта+" найдено: "+Выборка.Количество()+" объектов.");
	Пропущено=0;
	
	Пока Выборка.Следующий() Цикл
		ОбработкаПрерыванияПользователя_(); 	
		
		Результат	= РегистрыСведений.ФР_ОбъектыКВыгрузке.НужноРегистрироватьОбъект(Выборка.Ссылка);
		Если Результат.Нужно Тогда			
			СтрокаТО	= ТО.Добавить();
			
			СтрокаТО.ОбъектСсылка		= Результат.ВыгружаемаяСсылка;		
			СтрокаТО.ВариантВыгрузки	= Результат.ВариантВыгрузки;
			СтрокаТО.Получатель			= Результат.ПодразделениеПолучатель;			
			
			Если ИмяОбъекта="Документ.ПрайсЛист" Тогда
				НЗ			= РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
				НЗ.Отбор.Прайс.Установить(Выборка.Ссылка,Истина);
				НЗ.Отбор.ТипЦен.Установить(Выборка.ТипЦен,Истина);
				
				СтрокаТО	= ТО.Добавить();
				
				СтрокаТО.ОбъектСсылка		= Выборка.Ссылка;		
				СтрокаТО.ВариантВыгрузки	= "РегистрСведений.ЦеныНоменклатуры";
				СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
				СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);
			ИначеЕсли ИмяОбъекта="Документ.УстановкаСкидок" Тогда			
				НЗ			= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();
				НЗ.Отбор.Документ.Установить(Выборка.Ссылка,Истина);
				НЗ.Отбор.ТипСкидок.Установить(Выборка.ТипСкидок,Истина);
				
				СтрокаТО	= ТО.Добавить();
				
				СтрокаТО.ОбъектСсылка		= Выборка.Ссылка;		
				СтрокаТО.ВариантВыгрузки	= "РегистрСведений.СкидкиНоменклатуры";
				СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
				СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);
			КонецЕсли; 
		Иначе
			Пропущено=Пропущено+1;
		КонецЕсли;
		
		Если ТО.Количество()>=1000 Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);
			ТО.Очистить();		
		КонецЕсли; 	
		
		Сч=Сч+1;
		Если Сч%100=0 Тогда
			Состояние_("Регистрация "+ИмяОбъекта+": "+(ВсегоСтрок-Сч));		
		КонецЕсли;		
	КонецЦикла; 
	
	Если ТО.Количество()>0 Тогда
		РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО,ДопПараметры);
	КонецЕсли; 
	
	СтрокаРезультата	= СтрШаблон("	зарегистрировано: %1, пропущено: %2",ТО.Количество(),Пропущено);
	
	//Сообщить_(СтрокаРезультата);
	
	Состояние_("");

	Возврат Новый  Структура("Зарегистрировано,Пропущено,СтрокаРезультата",ТО.Количество(),Пропущено,СтрокаРезультата);
КонецФункции

Процедура Зарегистрировать_ФранчСклады() Экспорт	
	ТекстЗапроса="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склад
	|ИЗ
	|	Документ.ОтчетКассовойСмены
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	И Склад.Подразделение.ВидПодразделения = ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|";	
	
	ЗарегистрироватьВыборку(ТекстЗапроса,"Справочники.Склады");
КонецПроцедуры //Зарегистрировать_ФранчСклады() Экспорт

Процедура Зарегистрировать_НоменклатураПоОстаткамФР() Экспорт
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура КАК Ссылка	
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ
	|ГДЕ
	|	Период МЕЖДУ &Дата1 И &Дата2
	|	И Склад.Подразделение.ВидПодразделения=ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И Номенклатура.ВерсияДанных<>""""
