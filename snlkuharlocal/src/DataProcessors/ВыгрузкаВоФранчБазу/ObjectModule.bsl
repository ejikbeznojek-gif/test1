Функция ВыгрузитьПакетом_Объект(ИмяТаблицы,ИмяПроцедурыВыгрузки,ВариантВыгрузки="",РежимВыгрузки="Файл",Знач ЗапросСписка=Неопределено)	
	Результат		= Новый Структура("ВыгруженоОбъектов,ЕстьОшибки,Ошибки",0,Ложь,Новый Массив);
	
	НачалоНачал		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ЭтоДокумент		= (СтрНайти(ИмяТаблицы,"Документ.")=1);	
	
	Если ЗапросСписка=Неопределено Тогда
		ЗапросСписка	= ЗапросСпискаОбъектов(ИмяТаблицы,ЭтоДокумент);	
	КонецЕсли;
	ЗапросСписка.УстановитьПараметр("ИмяТаблицы",		ИмяТаблицы);
	ЗапросСписка.УстановитьПараметр("ВариантВыгрузки",	ВариантВыгрузки);
	
	Начало					= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	РеквизитыДляВыгрузки	= РеквизитыДляВыгрузки(ИмяТаблицы,ВариантВыгрузки);
	
	ИнициализироватьКэши(Кэши,РеквизитыДляВыгрузки.Шапка);
	СписокТЧ=Неопределено;
	Если РеквизитыДляВыгрузки.Свойство("СписокТЧ",СписокТЧ) Тогда
		Для Каждого ЭлементТЧ Из СписокТЧ Цикл
			ИнициализироватьКэши(Кэши,ЭлементТЧ.Значение);
		КонецЦикла;			
	КонецЕсли;	
	
	ДопЗапросы=Неопределено;
	Если РеквизитыДляВыгрузки.Свойство("ДопЗапросы",ДопЗапросы) Тогда
		Для Каждого ЭлементДЗ Из ДопЗапросы Цикл
			ИнициализироватьКэши(Кэши,ЭлементДЗ.Реквизиты_ТЧ);
		КонецЦикла;	
	КонецЕсли; 
	
	НачНомер		= 0;
	
	ЗапросОбъектов	= ЗапросДляВыгрузкиЕД(ИмяТаблицы,РеквизитыДляВыгрузки);
	
	МассивВыборок	= Новый Массив;	
	
	ТекНомер		= ЦиклПоПорции_ПоместитьСсылкиВКэш(ИмяТаблицы,ЗапросСписка,ЗапросОбъектов,НачНомер,Кэши,РеквизитыДляВыгрузки);
	Пока ТекНомер>0 Цикл
		ТекНомер = ЦиклПоПорции_ПоместитьСсылкиВКэш(ИмяТаблицы,ЗапросСписка,ЗапросОбъектов,ТекНомер,Кэши,РеквизитыДляВыгрузки);		
	КонецЦикла;
	
	Для Каждого Элемент Из Кэши Цикл
		ТекстСообщения	= "Элементов кэша: "+Элемент.Ключ+" "+Элемент.Значение.Количество();		
		//Сообщить_(ТекстСообщения);
	КонецЦикла;
	//+HELP-2306 20250220 Михайловский
	ЕстьДопОб = Ложь;
	МДопОб = Неопределено;
	Если ИмяТаблицы = "Документ.ЗаявкаНаПостСторонАссорт" Тогда
		МДопОб = ЗаполнитьКэшиПоНоменклатуреХарактеристикамПСАЗ();
		Если МДопОб.Количество() Тогда
			ЕстьДопОб = Истина;
		КонецЕсли	
	Иначе
		Если НЕ ИмяТаблицы = "Справочник.Номенклатура" Тогда
	//-HELP-2306 20250220 Михайловский		
			ЗаполнитьКэшиПоНоменклатуреХарактеристикам();
	//+HELP-2306 20250220 Михайловский		
		КонецЕсли;
	КонецЕсли;
	//-HELP-2306 20250220 Михайловский
	ТекПакет	= Неопределено;
	
	Сч			= 0;
	ВсегоСсылок = 0;
	Для Каждого Выборка Из МассивВыборок Цикл
		ВсегоСсылок = ВсегоСсылок+Выборка.Количество();
	КонецЦикла;
		
	Для Каждого Выборка Из МассивВыборок Цикл		
		Выборка.Сбросить();		
		Пока Выборка.Следующий() Цикл
			ОбработкаПрерыванияПользователя_();			
			
			Если РежимВыгрузки<>"Файл" Тогда
				ИнициализироватьЗаписьXML();			
			КонецЕсли; 
			
			Если Сч%100=0 Тогда
				Состояние_("Выгрузка "+ИмяТаблицы+"."+ВариантВыгрузки+": "+(ВсегоСсылок-Сч));			
			КонецЕсли;			
			
			Попытка
				ОбъектХДТО	= Вычислить(ИмяПроцедурыВыгрузки+"(Выборка)");
				Если ТипЗнч(ОбъектХДТО) = Тип("Массив") Тогда
					Результат.ВыгруженоОбъектов = Результат.ВыгруженоОбъектов + ОбъектХДТО.Количество();
				Иначе	
					Результат.ВыгруженоОбъектов=Результат.ВыгруженоОбъектов+1;
				КонецЕсли;
			Исключение
				ТекстСообщения	= "Выгрузка: "+ИмяТаблицы+"."+ОписаниеОшибки();
				Сообщить_(ТекстСообщения,СтатусСообщения.Важное);
				Результат.Ошибки.Добавить(ТекстСообщения);
				ОбъектХДТО	= Неопределено;
			КонецПопытки;
			
			Если ОбъектХДТО<>Неопределено Тогда
				Если ТипЗнч(ОбъектХДТО) = Тип("Массив") Тогда
					Для Каждого ТЭл Из ОбъектХДТО Цикл
						Фабрика.ЗаписатьXML(ЗаписьXML,ТЭл,,,,НазначениеТипаХМЛ);
					КонецЦикла;
				Иначе	
					Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
				КонецЕсли;
				Если РежимВыгрузки<>"Файл" Тогда
					Сообщение	= ЗакрытьЗаписьXML();
					Данные		= СжатьДанные(Сообщение);
					ОтправитьСообщение(Данные,Выборка.Ссылка,Выборка.ОбъектТип,Выборка.ОбъектСсылкаУИД,Выборка.ОтборРС_Хэш,ВариантВыгрузки);				
				КонецЕсли;				
			КонецЕсли;			
			
			Сч=Сч+1;
		КонецЦикла;		
	КонецЦикла;	
	//+HELP-2306 20250220 Михайловский
	Если НЕ (МДопОб = Неопределено) Тогда
		Для Каждого ТЭл Из МДопОб Цикл
			Попытка
				Если РежимВыгрузки<>"Файл" Тогда
					ИнициализироватьЗаписьXML();			
				КонецЕсли;
				Фабрика.ЗаписатьXML(ЗаписьXML,ТЭл.ОбъектХДТО,,,,НазначениеТипаХМЛ);
				Если РежимВыгрузки<>"Файл" Тогда
					Сообщение	= ЗакрытьЗаписьXML();
					Данные		= СжатьДанные(Сообщение);
					ОтправитьСообщение(Данные, ТЭл.Ссылка, ТЭл.ОбъектТип, ТЭл.ОбъектСсылкаУИД, ТЭл.ОтборРС_Хэш, ТЭл.ВариантВыгрузки);				
				КонецЕсли;
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	//-HELP-2306 20250220 Михайловский
	Если РежимВыгрузки<>"Файл" Тогда		
		//Последний пакет
		Если ТекПакет<>Неопределено Тогда
			ОтправитьПакет(ТекПакет);	
		КонецЕсли;
		КомпонентаОбмена.ОтправитьБуферСообщений();
	КонецЕсли;	
	
	Время	= Окр((ТекущаяУниверсальнаяДатаВМиллисекундах()-НачалоНачал)/1000,2,1);
	
	ТекстСообщения	= СтрШаблон("Обмен с ФР. Объект: %1, вариант: %2 выгружено: %3 объектов, время выгрузки: %4.",ИмяТаблицы,ВариантВыгрузки,ВсегоСсылок,Время);	
	Сообщить_(ТекстСообщения);
	
	Результат.ЕстьОшибки=(Результат.Ошибки.Количество()>0);
	
	ЗаписатьВЛог("Регламент",ТекстСообщения+". Есть ошибки выгрузки: "+Результат.ЕстьОшибки,"Информация",,,Время);	
	
	Если Результат.ЕстьОшибки Тогда
		ТекстОшибок=СтрСоединить(Результат.Ошибки,Символы.ПС);
		ЗаписатьВЛог("Регламент","Обмен с ФР. Ошибки выгрузки: "+ТекстОшибок,"Ошибка",,,Время);
	КонецЕсли; 
	
	Возврат Результат;	
КонецФункции
 
Функция ВыгрузитьПакетом_Регистр(ИмяТаблицы,ИмяПроцедурыВыгрузки,ВариантВыгрузки="",РежимВыгрузки="Файл")	
	Результат		= Новый Структура("ВыгруженоОбъектов,ВыгруженоЗаписей,ЕстьОшибки,Ошибки",0,0,Ложь,Новый Массив);
	
	НачалоНачал		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	ЗапросСписка	= Новый ("Запрос");
	Если СтрНайти(ВариантВыгрузки,"Сведений.")>0 Тогда		
		ЗапросСписка.Текст	= ТекстЗапросаСписка_РегистрСведений(ИмяТаблицы,ВариантВыгрузки);		
	Иначе
		ЗапросСписка.Текст	= ТекстЗапросаСписка_РегистрНакопления(ИмяТаблицы);
	КонецЕсли;
	
	ЗапросСписка.УстановитьПараметр("Дата1",			НачалоДня(Дата1));
	ЗапросСписка.УстановитьПараметр("Дата2",			КонецДня(Дата2));
	
	ЗапросСписка.УстановитьПараметр("ВариантВыгрузки",	ВариантВыгрузки);
	ЗапросСписка.УстановитьПараметр("НачНомер",			0);
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();		
	НачНомер	= 0;
	ВсегоСсылок	= 0;
	
	Менеджер	= ФР_ОбщегоНазначения_ПИ.ПолучитьМенеджер(ИмяТаблицы);
	
	Выборка		= ЗапросСписка.Выполнить().Выбрать();
	Пока Выборка.Количество()>0 Цикл		
		ВсегоСсылок	= ВсегоСсылок+Выборка.Количество();
		Сч			= 0;
		Пока Выборка.Следующий() Цикл		
			ОбработкаПрерыванияПользователя_();		
			НачНомер	= Выборка.Номер;
			
			Сч		= Сч+1;		
			
			Отбор	= Выборка.ОтборРС.Получить();		
			Если ПустаяСтрока(Отбор) Тогда
				Результат.Ошибки.Добавить("Не установлен отбор РС !");
				Продолжить;
			Иначе			
				Отбор=ЗначениеИзСтрокиВнутр(Отбор);		
			КонецЕсли;		
			
			Если РежимВыгрузки<>"Файл" Тогда
				ИнициализироватьЗаписьXML();			
			КонецЕсли;			
			
			КоличествоЗаписей	= 0;
			Попытка
				ДанныеВыгрузки	= Вычислить(ИмяПроцедурыВыгрузки+"(Отбор)");
				
				ОбъектХДТО			= ДанныеВыгрузки.ОбъектХДТО;
				ВыгруженоЗаписей	= ДанныеВыгрузки.ВыгруженоЗаписей;
				
				Результат.ВыгруженоОбъектов	= Результат.ВыгруженоОбъектов	+ 1;
				Результат.ВыгруженоЗаписей	= Результат.ВыгруженоЗаписей	+ ДанныеВыгрузки.ВыгруженоЗаписей;
			Исключение
				ТекстСообщения	= "Выгрузка: "+ИмяТаблицы+"."+ОписаниеОшибки();
				Сообщить_(ТекстСообщения,СтатусСообщения.Важное);
				Результат.Ошибки.Добавить(ТекстСообщения);
				ОбъектХДТО	= Неопределено;
			КонецПопытки;			
			
			Состояние_("Выгрузка "+ИмяТаблицы+": "+(ВсегоСсылок-Сч));
			
			Если ОбъектХДТО<>Неопределено Тогда
				Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
				
				Если РежимВыгрузки<>"Файл" Тогда
					Сообщение	= ЗакрытьЗаписьXML();
					Данные		= СжатьДанные(Сообщение);					
					Ссылка		= Менеджер.ПолучитьСсылку(Выборка.ОбъектСсылкаУИД);
					ОтправитьСообщение(Данные,Ссылка,Выборка.ОбъектТип,Выборка.ОбъектСсылкаУИД,Выборка.ОтборРС_Хэш,ВариантВыгрузки,ВыгруженоЗаписей);
				КонецЕсли;				
			КонецЕсли;
						
		КонецЦикла;	
		
		ЗапросСписка.УстановитьПараметр("НачНомер",	НачНомер);
		Выборка		= ЗапросСписка.Выполнить().Выбрать();
	КонецЦикла;

	Если РежимВыгрузки<>"Файл" Тогда		
		//Последний пакет
		Если ТекПакет<>Неопределено Тогда
			ОтправитьПакет(ТекПакет);	
		КонецЕсли;
		КомпонентаОбмена.ОтправитьБуферСообщений();
	КонецЕсли;	
	
	Время	= ТекущаяУниверсальнаяДатаВМиллисекундах()-НачалоНачал;
	
	Сообщить_("Время выгрузки: "+Окр(Время/1000,2,1)+" сек., документов: "+ВсегоСсылок);	
	
	Результат.ЕстьОшибки=(Результат.Ошибки.Количество()>0);
	
	Возврат Результат;
КонецФункции

Функция ЗапросСпискаОбъектов(ИмяТаблицы,ЭтоДокумент)
	ЗапросСписка	= Новый ("Запрос");
	Если ЭтоДокумент Тогда		
		ЗапросСписка.Текст	= ТекстЗапросаСписка_Документ(ИмяТаблицы);		
	Иначе
		ЗапросСписка.Текст	= ТекстЗапросаСписка_Справочник(ИмяТаблицы);
	КонецЕсли;	
	
	Возврат ЗапросСписка;
КонецФункции //ЗапросСпискаОбъектов()
 
Функция РеквизитыДляВыгрузки(ИмяТаблицы,ВариантВыгрузки)	
