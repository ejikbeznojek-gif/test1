Функция ВыгрузитьСпр_МатериалыСостав_КС(СпрВыборка)	
	ИмяТаблицы	= "Справочник.МатериалыСостав";
	ИмяУзлаХДТО	= "Справочник.МатериалыСостава.КС";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда	Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицы);
	Если ОбъектХДТО	= Неопределено И ВхПараметр.Результат Тогда
		Реквизиты					= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент.КС");
		ОбъектХДТО					= СоздатьОбъектХДТО(ИмяУзлаХДТО,ПространствоИмен_ЕЕ);
		
		ОбъектХДТО.Ссылка			= XMLСтрока(ВхПараметр.Ссылка);
		ОбъектХДТО.Код				= Реквизиты.Код;
		ОбъектХДТО.Наименование		= Реквизиты.Наименование;
		
		УстановитьСвойствоХДТО(ОбъектХДТО,"Группа",ВыгрузитьСпр_МатериалыСостав_КС(Реквизиты.Родитель));		
		
