Функция ВыгрузитьСпр_ХарактеристикиНоменклатуры_ЭлементГрп(Реквизиты)	
	ИмяТаблицы		= "Справочник.Номенклатура";
	ОбъектХДТО = СоздатьОбъектХДТО("Справочник.ХарактеристикиНоменклатуры.Элемент",ПространствоИмен_ЕЕ);		
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,Реквизиты);
	ОбъектХДТО.Владелец		= Реквизиты.Родитель;
	ОбъектХДТО.ГТИН			= СокрЛП(Реквизиты.Ссылка.ГТИН);
	Если Реквизиты.Родитель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.МБП 
		ИЛИ Реквизиты.Родитель.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.ОсновноеСредство Тогда
		ОбъектХДТО.Наименование	= СокрЛП(Реквизиты.Ссылка.Наименование);
	Иначе			
		ОбъектХДТО.Наименование	= СокрЛП(Реквизиты.Ссылка.Цвет.Наименование)+" "+СокрЛП(Реквизиты.Ссылка.Размер.Наименование);
		Если СтрДлина(СокрЛП(ОбъектХДТО.Наименование)) < 4 Тогда
			НаимХ = СокрЛП(Реквизиты.Ссылка.Наименование);
			ПозП = СтрНайти(НаимХ, " ");
			Если ПозП > 1 Тогда
				НаимХ = Сред(НаимХ, ПозП + 1);
				ПозП1 = СтрНайти(НаимХ, " ");
				Если ПозП1 > 1 Тогда
					НаимХ = Сред(НаимХ, ПозП1 + 1);
					ПозП2 = СтрНайти(НаимХ, " ");
					
					Если ПозП2 > 1 Тогда
						Если СтрДлина(Сред(НаимХ, ПозП2 + 1)) > 1 Тогда
							ОбъектХДТО.Наименование = Сред(НаимХ, ПозП2 + 1);
						Иначе
							ОбъектХДТО.Наименование = НаимХ;
						КонецЕсли;	
					Иначе
						ОбъектХДТО.Наименование = НаимХ;
					КонецЕсли;
					
				Иначе
					ОбъектХДТО.Наименование = НаимХ;
				КонецЕсли;	
			Иначе
				ОбъектХДТО.Наименование = НаимХ;
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	ОбъектХДТО.Код	= СокрЛП(Реквизиты.Ссылка.Код);
	ОбъектХДТО.ПервичнаяГруппа = XMLСтрока(Реквизиты.Родитель);
	ОбъектХДТО.Ссылка = XMLСтрока(Реквизиты.Ссылка);
	ОбъектХДТО.Размер = XMLСтрока(Реквизиты.Ссылка.Размер);
	ОбъектХДТО.Цвет = XMLСтрока(Реквизиты.Ссылка.Цвет);
	ДобавитьЭлементХДТО(ОбъектХДТО, Реквизиты.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	ОбъектХДТОВл					= СоздатьОбъектХДТО("Справочник.Номенклатура.Элемент",ПространствоИмен_ЕЕ);
	ОбъектХДТОВл.Ссылка					= XMLСтрока(Реквизиты.Родитель);
	ОбъектХДТОВл.Наименование	= СокрЛП(Реквизиты.Родитель.Наименование);
	ОбъектХДТОВл.Код	= СокрЛП(Реквизиты.Родитель.Код);
	ОбъектХДТОВл.НаименованиеДляЭтикетки	= СокрЛП(Реквизиты.Родитель.РусскоеНаименование);
	
	Если СтрДлина(СокрЛП(ОбъектХДТОВл.НаименованиеДляЭтикетки)) < 4 Тогда
		НаимН = СокрЛП(Реквизиты.Родитель.Наименование);
		НаимН1 = НаимН;
		НаимН2 = НаимН;
		ПозПН = СтрНайти(НаимН, " ");
		Если ПозПН > 1 Тогда
			НаимН1 = Сред(НаимН, ПозПН + 1);
			ПозПН1 = СтрНайти(НаимН1, " ");
			Если ПозПН1 > 1 Тогда
				НаимН2 = Сред(НаимН1, ПозПН1 + 1);
			КонецЕсли;	
		КонецЕсли;
		ОбъектХДТОВл.НаименованиеДляЭтикетки = ?(СтрДлина(НаимН) <= 32, НаимН, ?(СтрДлина(НаимН1) <= 32, НаимН1, НаимН2));
		
	КонецЕсли;
	
	ОбъектХДТОВл.Артикул					= СокрЛП(Реквизиты.Родитель.КодПроизводителя);
	ОбъектХДТОВл.ВидНоменклатуры			= XMLСтрока(Реквизиты.Родитель.ФР_ВидНоменклатуры);
	ОбъектХДТОВл.Бренд			= XMLСтрока(Реквизиты.Родитель.ФР_Бренд);
	ОбъектХДТОВл.Коллекция			= XMLСтрока(Реквизиты.Родитель.ФР_Коллекция);
	ОбъектХДТОВл.КодТНВЭД = XMLСтрока(Реквизиты.Родитель.ТНВЭД);
	Если ЗначениеЗаполнено(Реквизиты.Родитель.СтавкаНДС) Тогда
		ОбъектХДТОВл.СтавкаНДС	= ВыгрузитьПер_СтавкаНДС(Реквизиты.Родитель.СтавкаНДС);	
	КонецЕсли;
	
	Попытка
		Если ЗначениеЗаполнено(Реквизиты.Родитель.Родитель) Тогда
			ОбъектХДТОВл.Родитель	= XMLСтрока(Реквизиты.Родитель.Родитель);	
		КонецЕсли;
	Исключение
	КонецПопытки;
	ДобавитьЭлементХДТО(ОбъектХДТОВл, Реквизиты.Родитель.ТипТовара,	"ТипТовара", "string", ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТОВл, XMLСтрока(Реквизиты.Родитель.ВидНоменклатуры), "ВидНоменклатурыЕЕ", "string",	ПространствоИмен_СТ);	
	ИмяТЧВл			= "СоставНоменклатуры";
	ТЧ_ХДТОВл			= СоздатьОбъектХДТО(ИмяТаблицы + "." + ИмяТЧВл, ПространствоИмен_ЕЕ);		
	
	Запр = Новый Запрос;
	Запр.Текст = 
	"ВЫБРАТЬ
	|	НоменклатураСоставНоменклатуры.Ссылка КАК Ссылка,
	|	НоменклатураСоставНоменклатуры.НомерСтроки КАК НомерСтроки,
	|	НоменклатураСоставНоменклатуры.МатериалСостав КАК МатериалСостав,
	|	НоменклатураСоставНоменклатуры.Процент КАК Процент
	|ИЗ
	|	Справочник.Номенклатура.СоставНоменклатуры КАК НоменклатураСоставНоменклатуры
	|ГДЕ
	|	НоменклатураСоставНоменклатуры.Ссылка = &Ссылка";
	Запр.УстановитьПараметр("Ссылка", Реквизиты.Родитель);
	ВыборкаПоТЧ		= Запр.Выполнить().Выбрать();
	Пока ВыборкаПоТЧ.Следующий() Цикл		
		СтрокаТЧ_ХДТОВл				= СоздатьОбъектХДТО(СтрШаблон("%1.%2.%3",ИмяТаблицы, ИмяТЧВл ,"Строка"),ПространствоИмен_ЕЕ);				
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТОВл, ВыборкаПоТЧ);		
		
		ТЧ_ХДТОВл.Строка.Добавить(СтрокаТЧ_ХДТОВл);
	КонецЦикла;		
	
	Если ТЧ_ХДТОВл.Строка.Количество()>0 Тогда
		ОбъектХДТОВл[ИмяТЧВл]=ТЧ_ХДТОВл;
	КонецЕсли;
	
	МОб = Новый Массив;
	
