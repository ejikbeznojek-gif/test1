#Область Загрузка_Документы


Процедура ЗагрузитьДокумент(ОбъектХДТО,ВидИст,Отправитель)	
	Если ЗначениеЗаполнено(ВидИст) Тогда		
		ОбработчикЗагрузки	= ПолучитьОбработчикЗагрузки(ВидИст);
		Если ОбработчикЗагрузки.Найден Тогда
			Попытка
				Рез	= Вычислить(ОбработчикЗагрузки.ПроцедураЗагрузки+"(ОбъектХДТО,Отправитель)");
			Исключение				
				ТекстОшибки	= ОписаниеОшибки();
				Сообщить_(ТекстОшибки,СтатусСообщения.Важное);
				ДобавитьОбъектВПротоколОбмена(ВидИст,"","Ошибка",ТекстОшибки);
			КонецПопытки;			
		Иначе
			ДобавитьОбъектВПротоколОбмена(ВидИст,"","Ошибка","Не найден обработчик загрузки !");			
		КонецЕсли;		
	Иначе
		Сообщить_("Не найдено соответствие типа для: "+ВидИст,СтатусСообщения.Важное);
	КонецЕсли; 			
КонецПроцедуры

//Был вариант с Актом.......но почему бы не сделать еще парочку однотипны документов......см.  "ЗаявкаНаРекламацию"
Функция ЗагрузитьДок_АКТ_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.АктПриемки;	
	Вид			= Менеджер.ПустаяСсылка().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.АктПриемки.СоздатьДокумент();	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,"Номер");	
	
	ДокОбъект.РНК						= ОбъектХДТО.ДокОснование;	
	ДокОбъект.НомерАкта					= ОбъектХДТО.Номер;
	ДокОбъект.ИдентификаторАктаПриемки	= ОбъектХДТО.Номер;
	
	Если ЗначениеЗаполнено(ДокОбъект.РНК) Тогда
		РеквизитыШ_Основание	= ПолучитьРеквизитыШапки(ДокОбъект.РНК,"Контрагент,ПунктДоставки,Склад,Организация","Документ");	
		ЗаполнитьЗначенияСвойств(ДокОбъект,РеквизитыШ_Основание);
	КонецЕсли;	
	
	Если НЕ РезультатПоиска.Найден ИЛИ НЕ ЗначениеЗаполнено(ДокОбъект.СостояниеДокумента) Тогда
		ДокОбъект.СостояниеДокумента = Перечисления.СостоянияНакладной.Доставлена;
		//ДокОбъект.СостояниеСогласования	= Перечисления.СостоянияСогласования.НаСогласованииЦО;
	КонецЕсли;	
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.Заказано		= СтрокаТЧ_ХДТО.КоличествоПоДокументу;
			СтрокаТЧ.Отправлено		= СтрокаТЧ_ХДТО.КоличествоПоДокументу;
			СтрокаТЧ.Принято		= СтрокаТЧ_ХДТО.Количество;
			
			СтрокаТЧ.ЦенаПриемкиСНДС    = СтрокаТЧ_ХДТО.Цена;
			СтрокаТЧ.ЦенаПриемки		= СтрокаТЧ_ХДТО.Цена/(1+ПроцентНДСпоСтавке(СтрокаТЧ.Номенклатура.Родитель.СтавкаНДС));
			
			СтрокаТЧ.СуммаПриемки			= СтрокаТЧ.Принято*СтрокаТЧ.ЦенаПриемки;
			СтрокаТЧ.СуммаПриемкиСНДС		= СтрокаТЧ.Принято*СтрокаТЧ.СуммаПриемкиСНДС;
		КонецЦикла;
	КонецЕсли;
	
	Если ДокОбъект.ЭтоНовый() ИЛИ НЕ ЗначениеЗаполнено(ДокОбъект.Номер) Тогда
		ДокОбъект.УстановитьНовыйНомер("SNL-");	
	КонецЕсли; 
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_АКТ_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗРК_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ЗаявкаНаРекламацию;	
	Вид			= Менеджер.ПустаяСсылка().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ЗаявкаНаРекламацию.СоздатьДокумент();	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);	
	
	ДокОбъект.ДокОснование	= ОбъектХДТО.ДокОснование;	
	ДокОбъект.Валюта		= ВалютаНац;
	ДокОбъект.Курс			= 1;
	
	Если ЗначениеЗаполнено(ДокОбъект.ДокОснование) Тогда
		РеквизитыШ_Основание	= ПолучитьРеквизитыШапки(ДокОбъект.ДокОснование,"Контрагент,ПунктДоставки,Склад,Организация","Документ");	
		РеквизитыШ_Основание.Вставить("Корреспондент", РеквизитыШ_Основание.Контрагент);
		
		ЗаполнитьЗначенияСвойств(ДокОбъект,РеквизитыШ_Основание);
	КонецЕсли;	
	
	Если НЕ РезультатПоиска.Найден ИЛИ НЕ ЗначениеЗаполнено(ДокОбъект.СостояниеЗаявки) Тогда
		Попытка
			ДокОбъект.СостояниеЗаявки = Перечисления.СостоянияКоррекции.ВРаботе;
		Исключение
		КонецПопытки;		
		//ДокОбъект.СостояниеСогласования	= Перечисления.СостоянияСогласования.НаСогласованииЦО;
	КонецЕсли;	
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.КоличествоИсх	= СтрокаТЧ_ХДТО.КоличествоПоДокументу;
			СтрокаТЧ.КоличествоФакт	= СтрокаТЧ_ХДТО.Количество;
			СтрокаТЧ.Количество		= СтрокаТЧ.КоличествоФакт - СтрокаТЧ.КоличествоИсх;
			
			СтрокаТЧ.Единица		= ЕдиницаШт(СтрокаТЧ.Номенклатура);
			СтрокаТЧ.Коэффициент	= 1;	
			
			СтрокаТЧ.Цена		    = СтрокаТЧ_ХДТО.Цена;			
			
			СтрокаТЧ.Всего			= СтрокаТЧ.Количество*СтрокаТЧ.Цена;			
		КонецЦикла;
	КонецЕсли;
	
	Если ДокОбъект.ЭтоНовый() И НЕ ЗначениеЗаполнено(ДокОбъект.Номер) Тогда
		ДокОбъект.УстановитьНовыйНомер("SNL-");	
	КонецЕсли; 
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗРК_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗНС_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ЗаявкаНаСкидки;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект	= РезультатПоиска.Объект;
		
	ИменаТЧ		= "Скидки";
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,ИменаТЧ);
	
	ЗагрузитьТЧОбъекта(ДокОбъект,ОбъектХДТО,"Скидки");		
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗНС_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗНЦ_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ЗаявкаНаУстановкуЦен;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект	= РезультатПоиска.Объект;
	Если 1=2 Тогда
		ДокОбъект = Документы.ЗаявкаНаУстановкуЦен.СоздатьДокумент();	
	КонецЕсли; 
		
	ИменаТЧ		= "ЦеныНоменклатуры";
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,ИменаТЧ);
	
	Если СтрНайти(ДокОбъект.ТипЦен.Наименование,"SALE")<>0 Тогда
		ДокОбъект.ТипЦен = ДокОбъект.Подразделение.РозничныйТипЦенРаспродажа;
	Иначе
		ДокОбъект.ТипЦен = ДокОбъект.Подразделение.РозничныйТипЦен;		
	КонецЕсли; 
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект,ОбъектХДТО,"ДокОснование");
	
	ЗагрузитьТЧОбъекта(ДокОбъект,ОбъектХДТО,"ЦеныНоменклатуры");		
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗНЦ_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗНВПок(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ЗаявкаНаВозвратОтПокупателя;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ЗаявкаНаВозвратОтПокупателя.СоздатьДокумент();	
	КонецЕсли;
	
	ИменаТЧ	= "Товары";
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,ИменаТЧ);
	
	РеквизитыДоговора		= ПолучитьРеквизитыШапки(ДокОбъект.Договор,"Организация,Владелец","Справочник");
	
	ДокОбъект.Организация	= РеквизитыДоговора.Организация;
	ДокОбъект.Контрагент	= РеквизитыДоговора.Владелец;
	
	ДокОбъект.СостояниеСогласования_Покупатель	= ЗагрузитьПер("СостоянияСогласования",ОбъектХДТО.СостояниеСогласования_Покупатель);
	ДокОбъект.СостояниеСогласования_Поставщик	= ЗагрузитьПер("СостоянияСогласования",ОбъектХДТО.СостояниеСогласования_Поставщик);
	
	Если ДокОбъект.СостояниеСогласования_Покупатель=Перечисления.СостоянияСогласования.НаСогласованииЦО Тогда
		ДокОбъект.СостояниеСогласования_Покупатель=Перечисления.СостоянияСогласования.НаСогласованииКонтрагент;
	ИначеЕсли ДокОбъект.СостояниеСогласования_Покупатель=Перечисления.СостоянияСогласования.ОтмененЦО Тогда
		ДокОбъект.СостояниеСогласования_Покупатель=Перечисления.СостоянияСогласования.ОтмененКонтрагент;
	КонецЕсли;
	
	СоотвРекв_Товары	= Новый Структура("СоответствиеРеквизитов",	Новый Структура("ДокументОтгрузки","ПриходнаяНакладная"));
	ДопПараметры		= Новый Структура("Товары",					СоотвРекв_Товары);
	
	ЗагрузитьТЧОбъекта(ДокОбъект, ОбъектХДТО, ИменаТЧ, ДопПараметры);
	
	ЗаписатьДокумент(ДокОбъект, Отправитель, РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗНВПок(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗНВПок_СтатусОбмена(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ЗаявкаНаВозвратОтПокупателя;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);
	Если НЕ РезультатПоиска.Найден Тогда
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Не найден документ: "+ОбъектХДТО.Ссылка.УникальныйИдентификатор());
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект = ОбъектХДТО.Ссылка.ПолучитьОбъект();
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,"Ссылка");	
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗНВПок(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ЗПК_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.Заказ;	
	Вид			= "Заказ";
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект = РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект = Документы.Заказ.СоздатьДокумент();	
	КонецЕсли;
	
	Если РезультатПоиска.Найден Тогда
		Если ДокОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииКонтрагент
			ИЛИ ДокОбъект.СостояниеСогласования = Перечисления.СостоянияСогласования.НаСогласованииЦО Тогда		
			
			Если ОбъектХДТО.Состояние = "Согласован" Тогда			
				ДокОбъект.СостояниеСогласования	= Перечисления.СостоянияСогласования.Согласован;							
				ЗаписатьДокумент(ДокОбъект, Отправитель, РезультатПоиска.Найден);	
			КонецЕсли;			
			//Малахов 14.11.23
			//В SNL: при загрузке из ЦО_ФР редактируется только «подтвержденная заявка», за исключением первичной записи
			ТЧ_ХДТО	= ОбъектХДТО.Товары;
			Если ТЧ_ХДТО<>Неопределено Тогда
				Сч=0;
				Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
				ДокОбъект.Товары[Сч].ПодтвержденнаяЗаявка=СтрокаТЧ_ХДТО.ПодтвержденнаяЗаявка;
				Сч=Сч+1;
				КонецЦикла;
			ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);
			КонецЕсли;
			//Малахов 14.11.23
			Возврат ДокОбъект.Ссылка;
		КонецЕсли; 	
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,"Номер,Склад");	
	
	ДокОбъект.ВидОплаты				= Перечисления.ВидыОплаты.БН;
	ДокОбъект.Номер					= ОбъектХДТО.Номер;
	ДокОбъект.НомерЗаказа			= ОбъектХДТО.Номер;
	ДокОбъект.ДатаЗаказа			= ОбъектХДТО.Дата;		
	ДокОбъект.ОтсрочкаПлатежа		= ДокОбъект.Договор.ОтсрочкаПлатежа;
	
	Если НЕ РезультатПоиска.Найден ИЛИ Истина Тогда
		ДокОбъект.ИсточникЗаказа		= Перечисления.ИсточникЗаказа.БазаТЦфранчайзинг;
		ДокОбъект.Организация			= Справочники.Организации.НайтиПоКоду("SS-001");
		ДокОбъект.Склад 				= Справочники.Склады.НайтиПоКоду("STB-01");
		ДокОбъект.СостояниеНакладной    = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
		//ДокОбъект.ПунктДоставки			= ПолучитьПунктДоставкиПодразделения(ОбъектХДТО.Подразделение);
		ДокОбъект.ПунктДоставки			= ДокОбъект.Контрагент.ОсновнойПунктДоставки;
		ДокОбъект.ТипЦен				= ДокОбъект.Контрагент.ТипЦен;
		ДокОбъект.ТипЦенРаспродажа		= ДокОбъект.Контрагент.ТипЦенРаспродажа;
		
		ДокОбъект.ДополнительныеСклады.Очистить();
		Для Каждого Склад Из ПолучитьДопСклады(ДокОбъект.Склад) Цикл
			СтрокаС = ДокОбъект.ДополнительныеСклады.Добавить();		
			СтрокаС.Склад = Склад;		
		КонецЦикла;		
		
		ДокОбъект.СостояниеСогласования	= Перечисления.СостоянияСогласования.НаСогласованииЦО;			
		ДокОбъект.ДатаОтгрузки			= ОбъектХДТО.ДатаОтгрузкиПлан;
		ДокОбъект.ИсточникЗаказа		= Перечисления.ИсточникЗаказа.БазаТЦфранчайзинг;
		//ДокОбъект.ДатаОплаты			= ОбъектХДТО.ДатаОплаты;
		//ДокОбъект.СостояниеНакладной	= ЗагрузитьПер("СостоянияНакладной",ОбъектХДТО.Состояние);			
	КонецЕсли;	
	
	СуммаВключаетНДС		= Истина;	
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.Единица		= Ед_Штука;
			СтрокаТЧ.Коэффициент	= 1;
			СтрокаТЧ.ЦенаИсточник	= СтрокаТЧ.Цена;
		КонецЦикла;
	КонецЕсли;

	
	
	ПересчетТЧ(ДокОбъект,"Товары",ДокОбъект.Валюта,ДокОбъект.Валюта,ДокОбъект.Курс,ДокОбъект.Курс,Истина);	
	
	ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
	ДокОбъект.Проведен			= ОбъектХДТО.Проведен;
	
	ДокОбъект.ИБ = ИБ_SSP;	
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ЗПК_ЕЕ(ОбъектХДТО,Отправитель)

Функция ПолучитьДопСклады(Склад)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ Ссылка ИЗ Справочник.Склады 
	|ГДЕ 
	|	Ссылка = &ФизическийСклад 
//	|	И НЕ ФизическийСклад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
//	|	И Ссылка<>&Склад
	|	И НЕ ПометкаУдаления
	|";
	
	Запрос.УстановитьПараметр("Склад", 			 Склад);	
	Запрос.УстановитьПараметр("ФизическийСклад", Склад.ФизическийСклад);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции // ()
 

Функция ЗагрузитьДок_ИНВ(ОбъектХДТО,Отправитель)
	Менеджер	= Документы.Инвентаризация;
	Вид			= Менеджер.ПустаяСсылка().Метаданные().Имя;	
	
	РезПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);	
	Если РезПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли;
	
	ДокОбъект	= РезПоиска.Объект;	
	
	Если 1=2 Тогда
		ДокОбъект= Документы.Инвентаризация.СоздатьДокумент();	
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);	
	
	ДокОбъект.СостояниеНакладной	 	= ЗагрузитьПер("СостоянияНакладной", ОбъектХДТО.СостояниеНакладной, Перечисления.СостоянияНакладной.ВРаботе);
	ДокОбъект.СкладВременногоХранения	= ДокОбъект.Склад;
	ДокОбъект.НеФормироватьПроводки		= Истина;
	
	ДокОбъект.ИБ			= ФР_ОбщегоНазначения_ПИ.ТекущаяИБ();
	ДокОбъект.Валюта 		= ВалютаНац;	
	ДокОбъект.Курс			= ПолучитьКурсВалюты(ДокОбъект.Валюта, ДокОбъект.Дата).Курс;
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.Единица		= Ед_Штука;
			СтрокаТЧ.Коэффициент	= 1;
		КонецЦикла;
	КонецЕсли;	
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезПоиска.Найден);	
КонецФункции //ЗагрузитьДокумент_ИНВ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ОКС_ЕЕ(ОбъектХДТО,Отправитель)
	
	Если ОбъектХДТО.Товары<>Неопределено Тогда
		ЗагрузитьДок_ОКС_ЕЕ_Продажа(ОбъектХДТО,Отправитель);		
	КонецЕсли;	
	
	Возвраты_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"Возвраты");
	Если Возвраты_ХДТО<>Неопределено И Возвраты_ХДТО.Строка.Количество()>0 Тогда	
		ЗагрузитьДок_ОКС_ЕЕ_Возврат(ОбъектХДТО,Отправитель);		
	КонецЕсли;	
	
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ОКС_ЕЕ_Продажа(ОбъектХДТО,Отправитель)
	Вид			= "ОтчетКассовойСмены";
	Менеджер	= Документы[Вид];	
	КодОперации	= Перечисления.КодыОперацийОстатки.Реализация;	
	
	РезультатПоиска	= НайтиСоздатьОКС(ОбъектХДТО.Дата,ОбъектХДТО.Ссылка.УникальныйИдентификатор(),КодОперации);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ОтчетКассовойСмены.СоздатьДокумент();	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,"Комментарий");	
	ДокОбъект.КодОперации	= КодОперации;
	
	СуммаВключаетНДС		= Истина;	
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());
			СтрокаТЧ.ВсегоБезСкидки	= СтрокаТЧ.Количество*СтрокаТЧ.ЦенаБезСкидки;
			
			СтрокаТЧ.Единица		= Ед_Штука;
			СтрокаТЧ.Коэффициент	= 1;			
		КонецЦикла;
	КонецЕсли;
	
	//Оплата платежными картами
	СуммаОплатыБН	= 0;
	
	ТЧ_ХДТО	= ОбъектХДТО.Оплата;
	Если ТЧ_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			Если ЭтоБезнал(СтрокаТЧ_ХДТО.ВидОплаты) Тогда
				СуммаОплатыБН	= СуммаОплатыБН+СтрокаТЧ_ХДТО.СуммаОплаты;			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;	
	
	ДокОбъект.ПодарочныеСертификаты.Очистить();	
	ТЧ_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"ПодарочныеСертификаты");
	Если ТЧ_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ							= ДокОбъект.ПодарочныеСертификаты.Добавить();		
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
		КонецЦикла; 
	КонецЕсли;	
	
	СуммаОКС 		= ДокОбъект.Товары.Итог("Всего");
	СуммаОплатыСерт = ДокОбъект.ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");
	СуммаОплатыНал	= СуммаОКС-СуммаОплатыСерт-СуммаОплатыБН;
	
	ДокОбъект.ВидОплаты			=?(СуммаОплатыБН>0,Перечисления.ВидыОплаты.БН,Перечисления.ВидыОплаты.НАЛ);	
	ДокОбъект.Номер				= СформироватьНомерОКС(ОбъектХДТО.Номер,ДокОбъект.ВидОплаты);
	
	ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
	ДокОбъект.Проведен			= ОбъектХДТО.Проведен;
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ОКС_ЕЕ_Возврат(ОбъектХДТО,Отправитель)
	Вид			= "ОтчетКассовойСмены";
	Менеджер	= Документы[Вид];	
	КодОперации	= Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
	
	РезПоиска	= НайтиСоздатьОКС(ОбъектХДТО.Дата,ОбъектХДТО.Ссылка.УникальныйИдентификатор(),КодОперации);	
	Если РезПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли;
	
	ДокОбъект				= РезПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ОтчетКассовойСмены.СоздатьДокумент();	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО,,"Комментарий");
	ДокОбъект.КодОперации	= КодОперации;
	
	СуммаВключаетНДС	= Истина;	
	
	ДокОбъект.Товары.Очистить();
	
	Для Каждого СтрокаТЧ_ХДТО Из ОбъектХДТО.Возвраты.Строка Цикл
		СтрокаТЧ				= ДокОбъект.Товары.Добавить();		
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);
		
		СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());
		СтрокаТЧ.ВсегоБезСкидки	= СтрокаТЧ.Количество*?(СтрокаТЧ.ЦенаБезСкидки=0,СтрокаТЧ.Цена,СтрокаТЧ.ЦенаБезСкидки);
		СтрокаТЧ.Единица		= Ед_Штука;
		СтрокаТЧ.Коэффициент	= 1;
		СтрокаТЧ.Подразделение	= ДокОбъект.Подразделение;
	КонецЦикла;
	
	СуммаОплатыБН	= 0;
	ТЧ_ХДТО	= ОбъектХДТО.ВозвратОплаты;
	Если ТЧ_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			Если ЭтоБезнал(СтрокаТЧ_ХДТО.ВидОплаты) Тогда
				СуммаОплатыБН	= СуммаОплатыБН+СтрокаТЧ_ХДТО.СуммаОплаты;			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;	
	
	ДокОбъект.ПодарочныеСертификаты.Очистить();
	
	СуммаОКС 		= ДокОбъект.Товары.Итог("Всего");
	СуммаОплатыСерт = ДокОбъект.ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");
	СуммаОплатыНал	= СуммаОКС-СуммаОплатыСерт-СуммаОплатыБН;	
	
	ДокОбъект.ВидОплаты			=?(СуммаОплатыБН>0,Перечисления.ВидыОплаты.БН,Перечисления.ВидыОплаты.НАЛ);	
	ДокОбъект.Номер				= СформироватьНомерОКС(ОбъектХДТО.Номер,ДокОбъект.ВидОплаты);	
	
	ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
	ДокОбъект.Проведен			= ОбъектХДТО.Проведен;
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезПоиска.Найден);
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция ЭтоБезнал(ВидОплатыЧекаККМ)
	Результат = Ложь;
	Если ТипЗнч(ВидОплатыЧекаККМ)=Тип("СправочникСсылка.ФР_ВидыОплатЧекаККМ") И
		ЗначениеЗаполнено(ВидОплатыЧекаККМ) Тогда
					
		Результат = (ПолучитьРеквизитШапки(ВидОплатыЧекаККМ,"ВидОплаты","Справочник")=Перечисления.ВидыОплаты.БН);
	КонецЕсли;
	
	Возврат	Результат;
КонецФункции // ()


Функция ЗагрузитьДок_ОКС_ЕД(ОбъектХДТО,Отправитель)
	
	Если ОбъектХДТО.ТоварыПродажа<>Неопределено Тогда
		ЗагрузитьДок_ОКС_ЕД_Продажа(ОбъектХДТО,Отправитель);		
	КонецЕсли;	
	
	Если ОбъектХДТО.ТоварыВозвратПродажи<>Неопределено И ОбъектХДТО.ТоварыВозвратПродажи.Строка.Количество()>0 Тогда	
		ЗагрузитьДок_ОКС_ЕД_Возврат(ОбъектХДТО,Отправитель);		
	КонецЕсли;	
	
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ОКС_ЕД_Продажа(ОбъектХДТО,Отправитель)
	Вид			= "ОтчетКассовойСмены";
	Менеджер	= Документы[Вид];	
	КодОперации	= Перечисления.КодыОперацийОстатки.Реализация;
	
	КС_ХДТО		= ОбъектХДТО.КлючевыеСвойства;
	
	РезультатПоиска	= НайтиСоздатьОКС(КС_ХДТО.Дата,КС_ХДТО.Ссылка,КодОперации);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект				= РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ОтчетКассовойСмены.СоздатьДокумент();	
	КонецЕсли;
		
	ДокОбъект.Дата			= КС_ХДТО.Дата;
	ДокОбъект.Номер			= КС_ХДТО.Номер;
	
	ДокОбъект.КодОперации	= КодОперации;
	
	ДокОбъект.Организация	= ЗагрузитьСпр_Организации_КС(КС_ХДТО.Организация);	
	
	ДокОбъект.Автор			= ЗагрузитьСпр_Пользователи_Элемент_КС(ОбъектХДТО.Ответственный);	
	
	ДокОбъект.СуммаДокумента= ОбъектХДТО.Сумма;	
	ДокОбъект.Валюта		= ЗагрузитьСпр_Валюты_КС(ОбъектХДТО.Валюта);
	ДокОбъект.Склад			= ЗагрузитьСпр_Склады_Элемент_КС(ОбъектХДТО.Склад);
	ДокОбъект.Касса			= ЗагрузитьСпр_Кассы_Элемент_КС(ОбъектХДТО.КассаККМ);
	
	ДокОбъект.Подразделение	= ЗагрузитьСпр_Подразделения_Элемент_КС(ОбъектХДТО.Подразделение);
	
	Контрагент_ЧЛ			= ПолучитьРеквизитШапки(ДокОбъект.Подразделение,"ЧастноеЛицо","Справочник");
	
	СуммаВключаетНДС		= ОбъектХДТО.СуммаВключаетНДС;
	
	//Малахов сдача с сертификатов 27.12.2023
	ДокОбъект.СуммаСдачиПодарочногоСертификата=ОбъектХДТО.СуммаСдачиПодарочногоСертификата;
	//Малахов конец 27.12.2023
	
	ДокОбъект.Товары.Очистить();
	Если ОбъектХДТО.ТоварыПродажа<>Неопределено Тогда	
		Для Каждого СтрокаТЧXDTO Из ОбъектХДТО.ТоварыПродажа.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			
			ДанныеНоменклатуры	= ДанныеНоменклатуры(СтрокаТЧXDTO);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,ДанныеНоменклатуры);			
			
			СтрокаТЧ.Количество		= СтрокаТЧXDTO.Количество;			
			СтрокаТЧ.Коэффициент	= 1;	
			СтрокаТЧ.Цена			= СтрокаТЧXDTO.Цена;
			
			СтрокаТЧ.НДС			= СтрокаТЧXDTO.СуммаНДС;
			СтрокаТЧ.Всего			= СтрокаТЧXDTO.Сумма+?(СуммаВключаетНДС,0,СтрокаТЧ.СуммаНДС);
			////////////////////////////////////////////////////////////////////////
			СтрокаТЧ.ВсегоОФД		= СтрокаТЧXDTO.ВсегоОФД;
			////////////////////////////////////////////////////////////////////////
			
			//СтрокаТЧ.СуммаБезНДС	= СтрокаТЧ.Всего-СтрокаТЧ.СуммаНДС;		
			СтрокаТЧ.СтавкаНДС		= ЗагрузитьПер_СтавкаНДС(СтрокаТЧXDTO.СтавкаНДС);
			
			СтрокаТЧ.НомерЧекаККМ	= СтрокаТЧXDTO.НомерЧекаККМ;
			СтрокаТЧ.Менеджер		= Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТЧXDTO.Продавец));
			СтрокаТЧ.Акция			= Справочники.Акции.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТЧXDTO.Акция));
			СтрокаТЧ.ВсегоБезСкидки	= СтрокаТЧXDTO.ВсегоБезСкидки;
			
			СтрокаТЧ.Сумма			= СтрокаТЧ.Всего-СтрокаТЧ.НДС;
			
			СтрокаТЧ.Подразделение	= ДокОбъект.Подразделение;
			
			СтрокаТЧ.Скидка			= ПривестиСтрокуКЧислу(ПолучитьСвойствоХДТО(СтрокаТЧXDTO,"Скидка"));
			СтрокаТЧ.СуммаСкидкиПоКупону=СтрокаТЧXDTO.СуммаСкидкиПоКупону;
			//+ HELP-1709 20241024 Михайловский
			Попытка
				СтрокаТЧ.СуммаСкидкиЗаВидОплаты=СтрокаТЧXDTO.СуммаСкидкиЗаВидОплаты;
			Исключение				
			КонецПопытки;
			//- HELP-1709 20241024 Михайловский
			Попытка
				СтрокаТЧ.Контрагент	= Контрагент_ЧЛ;
			Исключение				
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	
	//Оплата платежными картами
	СуммаОплатыБН	= 0;
	ОплатаПК_ХДТО	= ОбъектХДТО.ОплатаПлатежнымиКартами;
	Если ОплатаПК_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ОплатаПК_ХДТО.Строка Цикл
			Если СтрокаТЧ_ХДТО.СуммаОплаты>0 Тогда				
				СуммаОплатыБН = СуммаОплатыБН+СтрокаТЧ_ХДТО.СуммаОплаты;			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли; 
	//+HELP-5235 20250905 Михайловский	
	СуммаОплатыБНПодели	= 0;
	ОплатаПД_ХДТО	= ОбъектХДТО.ОплатаБанковскимиКредитами;
	Если ОплатаПД_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ОплатаПД_ХДТО.Строка Цикл
			Если СтрокаТЧ_ХДТО.СуммаОплаты > 0 Тогда				
				СуммаОплатыБНПодели = СуммаОплатыБНПодели + СтрокаТЧ_ХДТО.СуммаОплаты;
				//ДокОбъект.КонтрагентПодели  
				ДокОбъект.ПроцентКомиссииПодели = ПривестиСтрокуКЧислу(ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО, "ПроцентКомиссии"));
				ДокОбъект.КонтрагентПодели		= Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТЧ_ХДТО.Эквайрер));
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	//-HELP-5235 20250905 Михайловский	
	
	ДокОбъект.ПодарочныеСертификаты.Очистить();
	
	ОплатаСертификатамиХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"ОплатаСертификатами");
	//Малахов начало Очистка сертификатов при загрузке возвратных ОКС в базу SNL 
	//Если ОплатаСертификатамиХДТО<>Неопределено Тогда
	Если ОплатаСертификатамиХДТО<>Неопределено Тогда
	//Малахов конец
		Для Каждого СтрокаПС_ХДТО Из ОплатаСертификатамиХДТО.Строка Цикл
			СтрокаТЧ							= ДокОбъект.ПодарочныеСертификаты.Добавить();		
			
			СтрокаТЧ.Сертификат 				= ЗагрузитьСпр_ПодарочныеСертификаты_Элемент_КС(СтрокаПС_ХДТО.ДанныеСертификата,Отправитель);
			СтрокаТЧ.СуммаОплатыСертификатами   = СтрокаПС_ХДТО.Сумма;
			
			СтрокаТЧ.НомерЧекаККМ				= СтрокаПС_ХДТО.НомерЧекаККМ;
			СтрокаТЧ.СуммаЧека					= СтрокаПС_ХДТО.СуммаЧека;
			
			АвторЧекаХДТО						= ПолучитьСвойствоХДТО(СтрокаПС_ХДТО,"АвторЧека");
			Если АвторЧекаХДТО<>Неопределено Тогда			
				СтрокаТЧ.АвторЧека				= ЗагрузитьСпр_Пользователи_Элемент_КС(АвторЧекаХДТО);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТЧ.Сертификат) Тогда
				РеквизитыСертификата	= ПолучитьРеквизитыШапки(СтрокаТЧ.Сертификат,"ВидСертификата,КодСертификата,ОкончаниеДействия,НомерЧекаПогашения,Номинал");			
				
				СтрокаТЧ.ВидСертификата		= РеквизитыСертификата.ВидСертификата;
				СтрокаТЧ.НомерСертификата	= Прав(СокрЛП(РеквизитыСертификата.КодСертификата),7);
				СтрокаТЧ.СрокДействия		= РеквизитыСертификата.ОкончаниеДействия;
				СтрокаТЧ.НомерЧека			= РеквизитыСертификата.НомерЧекаПогашения;
				СтрокаТЧ.Контрагент			= ДокОбъект.Подразделение.ЧастноеЛицо;
				СтрокаТЧ.Номинал			= РеквизитыСертификата.Номинал;
			КонецЕсли;
			
		КонецЦикла; 
	КонецЕсли;	
	
	СуммаОКС 		= ДокОбъект.Товары.Итог("Всего");
	СуммаОплатыСерт = ДокОбъект.ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");
	СуммаОплатыНал	= СуммаОКС-СуммаОплатыСерт-СуммаОплатыБН;
	
	ДокОбъект.СуммаОплатыБН		= СуммаОплатыБН; 
	//+HELP-5235 20250905 Михайловский
	ДокОбъект.СуммаОплатыБНПодели = СуммаОплатыБНПодели;
	//-HELP-5235 20250905 Михайловский
	ДокОбъект.ВидОплаты			=?(СуммаОплатыБН>0 ИЛИ СуммаОплатыБНПодели > 0, Перечисления.ВидыОплаты.БН, Перечисления.ВидыОплаты.НАЛ);	
	//По логике Крохина смешанная оплата должна быть с типом оплаты НАЛ 
	Если СуммаОплатыНал<>0 И (СуммаОплатыБН<>0 ИЛИ СуммаОплатыБНПодели<>0) Тогда
		ДокОбъект.ВидОплаты		= Перечисления.ВидыОплаты.БН; 				
	КонецЕсли;
	ДокОбъект.Номер				= СформироватьНомерОКС(ОбъектХДТО.КлючевыеСвойства.Номер,ДокОбъект.ВидОплаты);
	
	ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
	ДокОбъект.Проведен			= ОбъектХДТО.Проведен;
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ОКС_ЕД_Возврат(ОбъектХДТО,Отправитель)
	Вид			= "ОтчетКассовойСмены";
	Менеджер	= Документы[Вид];	
	КодОперации	= Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя;
	
	КС_ХДТО		= ОбъектХДТО.КлючевыеСвойства;
	
	РезПоиска	= НайтиСоздатьОКС(КС_ХДТО.Дата,КС_ХДТО.Ссылка,КодОперации);	
	Если РезПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли;
	
	ДокОбъект				= РезПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ОтчетКассовойСмены.СоздатьДокумент();	
	КонецЕсли;
	
	ДокОбъект.Дата			= КС_ХДТО.Дата-1;
	ДокОбъект.Номер			= КС_ХДТО.Номер;
	
	ДокОбъект.КодОперации	= КодОперации;
	
	ДокОбъект.Организация	= ЗагрузитьСпр_Организации_КС(КС_ХДТО.Организация);	
	
	ДокОбъект.Автор			= ЗагрузитьСпр_Пользователи_Элемент_КС(ОбъектХДТО.Ответственный);	
	
	ДокОбъект.СуммаДокумента= ОбъектХДТО.Сумма;	
	ДокОбъект.Валюта		= ЗагрузитьСпр_Валюты_КС(ОбъектХДТО.Валюта);
	ДокОбъект.Склад			= ЗагрузитьСпр_Склады_Элемент_КС(ОбъектХДТО.Склад);
	ДокОбъект.Касса			= ЗагрузитьСпр_Кассы_Элемент_КС(ОбъектХДТО.КассаККМ);
	
	ДокОбъект.Подразделение	= ЗагрузитьСпр_Подразделения_Элемент_КС(ОбъектХДТО.Подразделение);
	Контрагент_ЧЛ			= ПолучитьРеквизитШапки(ДокОбъект.Подразделение,"ЧастноеЛицо","Справочник");
	
	СуммаВключаетНДС		= ОбъектХДТО.СуммаВключаетНДС;	
	
	ДокОбъект.Товары.Очистить();
	
	Для Каждого СтрокаТЧXDTO Из ОбъектХДТО.ТоварыВозвратПродажи.Строка Цикл
		СтрокаТЧ				= ДокОбъект.Товары.Добавить();
		
		ДанныеНоменклатуры		= ДанныеНоменклатуры(СтрокаТЧXDTO);
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,ДанныеНоменклатуры);			
		
		СтрокаТЧ.Количество		= СтрокаТЧXDTO.Количество;			
		СтрокаТЧ.Коэффициент	= 1;	
		СтрокаТЧ.Цена			= СтрокаТЧXDTO.Цена;
		
		СтрокаТЧ.НДС			= СтрокаТЧXDTO.СуммаНДС;
		СтрокаТЧ.Всего			= СтрокаТЧXDTO.Сумма+?(СуммаВключаетНДС,0,СтрокаТЧ.СуммаНДС);
		//СтрокаТЧ.СуммаБезНДС	= СтрокаТЧ.Всего-СтрокаТЧ.СуммаНДС;		
		СтрокаТЧ.СтавкаНДС		= ЗагрузитьПер_СтавкаНДС(СтрокаТЧXDTO.СтавкаНДС);
		
		СтрокаТЧ.НомерЧекаККМ	= СтрокаТЧXDTO.НомерЧекаККМПродажи;
		
		СтрокаТЧ.Сумма			= СтрокаТЧ.Всего-СтрокаТЧ.НДС;
		Попытка
			СтрокаТЧ.Контрагент		= Контрагент_ЧЛ;
		Исключение				
		КонецПопытки;
	КонецЦикла;	

	//Оплата платежными картами
	СуммаОплатыБН	= 0;
	ОплатаПК_ХДТО	= ОбъектХДТО.ОплатаПлатежнымиКартами;
	Если ОплатаПК_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ОплатаПК_ХДТО.Строка Цикл
			Если СтрокаТЧ_ХДТО.СуммаОплаты<0 Тогда								
				СуммаОплатыБН	= СуммаОплатыБН-СтрокаТЧ_ХДТО.СуммаОплаты;			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	
	СуммаОплатыБНПодели	= 0;
	ОплатаПД_ХДТО	= ОбъектХДТО.ОплатаБанковскимиКредитами;
	Если ОплатаПД_ХДТО<>Неопределено Тогда		
		Для Каждого СтрокаТЧ_ХДТО Из ОплатаПД_ХДТО.Строка Цикл
			Если СтрокаТЧ_ХДТО.СуммаОплаты < 0 Тогда				
				СуммаОплатыБНПодели = СуммаОплатыБНПодели - СтрокаТЧ_ХДТО.СуммаОплаты;
				//ДокОбъект.КонтрагентПодели
				ДокОбъект.ПроцентКомиссииПодели = ПривестиСтрокуКЧислу(ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО, "ПроцентКомиссии"));
				ДокОбъект.КонтрагентПодели		= Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТЧ_ХДТО.Эквайрер));
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	
	ОплатаСертификатамиХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"ОплатаСертификатами");
	Если ОплатаСертификатамиХДТО<>Неопределено Тогда
		ДокОбъект.ПодарочныеСертификаты.Очистить();
		
		//Для Каждого СтрокаПС_ХДТО Из ОплатаСертификатамиХДТО.Строка Цикл
		//	СтрокаТЧ							= ДокОбъект.ПодарочныеСертификаты.Добавить();		
		//	
		//	СтрокаТЧ.Сертификат 				= ЗагрузитьСпр_ПодарочныеСертификаты_Элемент_КС(СтрокаПС_ХДТО.ДанныеСертификата,Отправитель);
		//	СтрокаТЧ.СуммаОплатыСертификатами   = СтрокаПС_ХДТО.Сумма;
		//	
		//	СтрокаТЧ.НомерЧекаККМ				= СтрокаПС_ХДТО.НомерЧекаККМ;
		//	СтрокаТЧ.СуммаЧека					= СтрокаПС_ХДТО.СуммаЧека;
		//	СтрокаТЧ.АвторЧека					= ЗагрузитьСпр_Пользователи_Элемент_КС(СтрокаПС_ХДТО.АвторЧека);
		//КонецЦикла; 
	КонецЕсли;	
	
	//ДокОбъект.ПодарочныеСертификаты.Очистить();	
	
	СуммаОКС 		= ДокОбъект.Товары.Итог("Всего");
	СуммаОплатыСерт = ДокОбъект.ПодарочныеСертификаты.Итог("СуммаОплатыСертификатами");
	СуммаОплатыНал	= СуммаОКС-СуммаОплатыСерт-СуммаОплатыБН;	
	
	ДокОбъект.СуммаОплатыБН		= СуммаОплатыБН;
	ДокОбъект.СуммаОплатыБНПодели = СуммаОплатыБНПодели;
	ДокОбъект.ВидОплаты			=?(СуммаОплатыБН>0 ИЛИ СуммаОплатыБНПодели > 0, Перечисления.ВидыОплаты.БН, Перечисления.ВидыОплаты.НАЛ);	
	//По логике Крохина смешанная оплата должна быть с типом оплаты НАЛ 
	Если СуммаОплатыНал<>0 И (СуммаОплатыБН<>0 ИЛИ СуммаОплатыБНПодели<>0) Тогда
		ДокОбъект.ВидОплаты		= Перечисления.ВидыОплаты.БН; 				
	КонецЕсли;
	ДокОбъект.Номер				= СформироватьНомерОКС(ОбъектХДТО.КлючевыеСвойства.Номер,ДокОбъект.ВидОплаты);	
	
	ДокОбъект.ПометкаУдаления	= ОбъектХДТО.ПометкаУдаления;
	ДокОбъект.Проведен			= ОбъектХДТО.Проведен;
	
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезПоиска.Найден);
КонецФункции //ЗагрузитьДокумент_ОКС(ОбъектХДТО,Отправитель)

Функция СформироватьНомерОКС(ИсходныйНомер,ВидОплаты)
	ДлиннаНомера= Метаданные.Документы.ОтчетКассовойСмены.ДлинаНомера;
	ПоляНомера	= ФР_ОбщегоНазначения_КС.СтрокуВСтруктуру(ИсходныйНомер,"Префикс,Номер","-");
	
	НовНомер	= ПоляНомера.Префикс+?(ВидОплаты=Перечисления.ВидыОплаты.БН,"кб","кн")+"-";
	
	Возврат НовНомер+Прав(ИсходныйНомер,ДлиннаНомера-СтрДлина(НовНомер));	
КонецФункции //СформироватьНомерОКС()
 
Функция НайтиСоздатьОКС(Дата,Ссылка,КодОперации)
	ПолноеИмяТипа	= Метаданные.Документы.ОтчетКассовойСмены.ПолноеИмя();
	Результат		= Новый Структура("Найден,Ссылка,Объект,ПолноеИмяТипа",
		Ложь,Документы.ОтчетКассовойСмены.ПустаяСсылка(),Неопределено,ПолноеИмяТипа);
	
	Комментарий	= "#ОКС ФР "+КодОперации+" "+Ссылка;
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка
	|ИЗ
	|	Документ.ОтчетКассовойСмены	
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(Дата,Год)			= &Дата_Год
	|	И ПОДСТРОКА(Комментарий,1,200)	= &Комментарий
	|УПОРЯДОЧИТЬ ПО ПометкаУдаления
	|";	
	
	Запрос.УстановитьПараметр("Дата_Год",	НачалоГода(Дата));
	Запрос.УстановитьПараметр("Комментарий",Комментарий);	
	
	ДокОбъект	= Неопределено;
	Выборка	= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат.Найден	= Истина;		
		Результат.Ссылка		= Выборка.Ссылка;
		Если фПерезаписыватьДокументы Тогда
			ДокОбъект	= Выборка.Ссылка.ПолучитьОбъект();				
		КонецЕсли; 
	Иначе
		ДокОбъект				= Документы.ОтчетКассовойСмены.СоздатьДокумент();	
		ДокОбъект.Комментарий	= Комментарий;		
	КонецЕсли; 
	
	Результат.Объект = ДокОбъект;
	
	Возврат Результат;
КонецФункции //НайтиСоздатьОКС()

Функция ЗагрузитьДок_ОПР_ЕЕ(ОбъектХДТО,Отправитель)	
	Менеджер	= Документы.ОприходованиеТМЦ;	
	Вид			= Менеджер.ПолучитьСсылку().Метаданные().Имя;
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка.УникальныйИдентификатор(),Вид);	
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда 
		ЗаписатьВПротокол_ОбъектПропущен(РезультатПоиска,"Пропущен существующий объект.");
		Возврат РезультатПоиска.Ссылка;
	КонецЕсли;
	
	ДокОбъект = РезультатПоиска.Объект;
	
	Если 1=2 Тогда
		ДокОбъект=Документы.ОприходованиеТМЦ.СоздатьДокумент();	
	КонецЕсли;
	
	ИменаТЧ	= "Товары";
	ЗаполнитьЗначенияСвойств(ДокОбъект, ОбъектХДТО ,, ИменаТЧ);
	
	ДокОбъект.КодОперации 			= ЗагрузитьПер("КодыОперацийОстатки", ОбъектХДТО.КодОперации, Перечисления.КодыОперацийОстатки.Оприходование);	
	ДокОбъект.СостояниеНакладной	= Перечисления.СостоянияНакладной[ОбъектХДТО.СостояниеНакладной];
	
	ТЧ_ХДТО	= ОбъектХДТО.Товары;
	ДокОбъект.Товары.Очистить();
	Если ТЧ_ХДТО<>Неопределено Тогда	
		Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
			СтрокаТЧ	= ДокОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);			
			
			СтрокаТЧ.Номенклатура	= Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры.УникальныйИдентификатор());	
			
			СтрокаТЧ.Единица		= Ед_Штука;
			СтрокаТЧ.Коэффициент	= 1;
		КонецЦикла;
	КонецЕсли;
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект,ОбъектХДТО,"ДокОснование");
	
	ДокОбъект.ИБ = ИБ_SSP;
	//+ ASU-1025, ASU-946 20241220 Михайловский
	ТЧ_Сертификаты_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"Сертификаты");
	Если ТЧ_Сертификаты_ХДТО<>Неопределено И ЗначениеЗаполнено(ДокОбъект.Ссылка) Тогда
		ЗагрузитьХПС(ДокОбъект,ТЧ_Сертификаты_ХДТО,Отправитель);	
	КонецЕсли;
	//- ASU-1025, ASU-946 20241220 Михайловский
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);	
КонецФункции //ЗагрузитьДок_ОПР_ЕЕ(ОбъектХДТО,Отправитель)

Функция ЗагрузитьДок_ПКО(ОбъектХДТО,Отправитель)
	Вид			= "ПриходныйКассовыйОрдер";	
	Менеджер	= Документы[Вид];
	
	РезультатПоиска	= НайтиСоздатьДокумент(ОбъектХДТО.Ссылка,Вид);
	Если РезультатПоиска.Найден И НЕ фПерезаписыватьДокументы Тогда Возврат Неопределено КонецЕсли; 
	
	ДокОбъект	= РезультатПоиска.Объект;
	ЗаполнитьЗначенияСвойств(ДокОбъект,ОбъектХДТО);
	
	//Если Сокрлп(ОбъектХДТО.ВидОперации) = "ВозвратОтПодотчетногоЛица" Тогда
	//	ДокОбъект.ВидОперации	= Перечисления.ВидыОперацийПКО.ВозвратАвансовыйОтчет;
	//Иначе
		ДокОбъект.ВидОперации	= ЗагрузитьПер("ВидыОперацийПКО",ОбъектХДТО.ВидОперации);  // "ВозвратОтПодотчетногоЛица"
	//КонецЕсли;
	
	ЗагрузитьРеквизитыСМультиТипами(ДокОбъект,ОбъектХДТО,"Контрагент,ДокОснование");
	
	ДокОбъект.ИБ	= ФР_ОбщегоНазначения_ПИ.ТекущаяИБ();
		
	ЗаписатьДокумент(ДокОбъект,Отправитель,РезультатПоиска.Найден);
КонецФункции //ЗагрузитьДок_ПКО(ОбъектХДТО,Отправитель)

