Функция ИнициализироватьКэши(Кэши,Реквизиты) Экспорт
	Если Кэши=Неопределено Тогда
		Кэши	= Новый Соответствие;
	КонецЕсли;
	
	Для Каждого СтрокаТР Из Реквизиты Цикл
		ТипСтрокой=СтрокаТР.ТипСтрокой;
		Если СтрокаТР.Кэшировать Тогда
			Если Кэши.Получить(ТипСтрокой)=Неопределено Тогда
				Кэши.Вставить(ТипСтрокой,Новый Соответствие);		
			КонецЕсли;		
		КонецЕсли;		 		
	КонецЦикла;
	
	Возврат Кэши;
КонецФункции //ИнициализироватьКэши(Реквизиты)

Функция ПолучитьИзКэша(Ссылка,Знач ИмяТипа=Неопределено) Экспорт
	Результат  = Неопределено;
	
	Если ИмяТипа=Неопределено Тогда
		Попытка
			ИмяТипа	= Ссылка.Метаданные().ПолноеИмя();	
		Исключение
			Сообщить_("Ой");
		КонецПопытки;		
	КонецЕсли;
	
	ТекКэш		= Кэши.Получить(ИмяТипа); 
	
	Если ТекКэш <> Неопределено Тогда
		Результат = ТекКэш.Получить(Ссылка);	
	Иначе
		Кэши.Вставить(ИмяТипа,Новый Соответствие);
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПолучитьИзКэша(Ссылка)

Процедура ВставитьВКэш(Ссылка,Данные,Знач ИмяТипа=Неопределено) Экспорт
	Если ИмяТипа=Неопределено Тогда
		ИмяТипа		= Ссылка.Метаданные().ПолноеИмя();		
	КонецЕсли;
	
	ТекКэш		= Кэши.Получить(ИмяТипа); 	
	
	Если ТекКэш=Неопределено Тогда
		Кэши.Вставить(ИмяТипа,Новый Соответствие);	
	КонецЕсли; 
	
	Кэши[ИмяТипа][Ссылка]=Данные;
КонецПроцедуры

Функция ЦиклПоПорции_ПоместитьСсылкиВКэш(ИмяТаблицы,ЗапросСписка,ЗапросОбъектов,НачНомер,Кэши,РеквизитыДляВыгрузки)	
	ТипСсылки	= СформироватьТипСсылки(ИмяТаблицы,Истина);
	Менеджер	= ПолучитьМенеджерКласса(ИмяТаблицы);
	
	ЗапросСписка.УстановитьПараметр("НачНомер",	НачНомер);
	
	ТекНомер		= 0;
	
	ТаблицаСсылок	= Новый ТаблицаЗначений;
	ТаблицаСсылок.Колонки.Добавить("ОбъектТип",			ПолучитьОписаниеТиповСтроки(80));
	ТаблицаСсылок.Колонки.Добавить("ОбъектСсылка",		Новый ОписаниеТипов(ТипСсылки));
	ТаблицаСсылок.Колонки.Добавить("ОбъектСсылкаУИД",	Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТаблицаСсылок.Колонки.Добавить("ОтборРС_Хэш",		ПолучитьОписаниеТиповСтроки(32));
	
	ТаблицаСсылок.Колонки.Добавить("Номер",				ПолучитьОписаниеТиповЧисла(20));
	ТаблицаСсылок.Колонки.Добавить("Получатель",		Новый ОписаниеТипов("СправочникСсылка.Подразделения"));
	
	Выборка	= ЗапросСписка.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТС	= ТаблицаСсылок.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТС,Выборка);
		СтрокаТС.ОбъектСсылка = Менеджер.ПолучитьСсылку(СтрокаТС.ОбъектСсылкаУИД);		
		
		ТекНомер=Выборка.Номер;
	КонецЦикла;	
	
	ЗапросОбъектов.УстановитьПараметр("ТаблицаСсылок",ТаблицаСсылок);
	ЗапросОбъектов.УстановитьПараметр("Единица_Штука",Ед_Штука);
	
	Реквизиты_Ш	= РеквизитыДляВыгрузки.Шапка;
	
	Выборка_Ш	= ЗапросОбъектов.Выполнить().Выбрать();
	МассивВыборок.Добавить(Выборка_Ш);
	
	Пока Выборка_Ш.Следующий() Цикл
		ОбработкаПрерыванияПользователя_(); 
		
		Для Каждого СтрокаТР Из Реквизиты_Ш Цикл
			Если СтрокаТР.Кэшировать Тогда
				Кэши[СтрокаТР.ТипСтрокой].Вставить(Выборка_Ш[СтрокаТР.Имя]);			
			КонецЕсли;			
		КонецЦикла;
		
		СписокТЧ = Неопределено;
		Если РеквизитыДляВыгрузки.Свойство("СписокТЧ",СписокТЧ) Тогда
			Для Каждого ЭлементТЧ Из СписокТЧ Цикл
				Если ИмяТаблицы = "Справочник.Контрагенты" Тогда Продолжить КонецЕсли; //ТЧ скидки в карточке постоянно падает на кэшах номенклатуры
				Имя_ТЧ		 = ЭлементТЧ.Ключ;
				Реквизиты_ТЧ = ЭлементТЧ.Значение;
				
				Выборка_ТЧ = Выборка_Ш[Имя_ТЧ].Выбрать();
				Пока Выборка_ТЧ.Следующий() Цикл
					Для Каждого СтрокаТР Из Реквизиты_ТЧ Цикл
						Если СтрокаТР.Кэшировать Тогда
							Кэши[СтрокаТР.ТипСтрокой].Вставить(Выборка_ТЧ[СтрокаТР.Имя]);						
						КонецЕсли;						
					КонецЦикла;
				КонецЦикла;			
			КонецЦикла;
		КонецЕсли;
		
		ДопЗапросы=Неопределено;
		Если РеквизитыДляВыгрузки.Свойство("ДопЗапросы",ДопЗапросы) И ДопЗапросы<>Неопределено Тогда
			Для Каждого ДопЗапрос Из ДопЗапросы Цикл
				
				Реквизиты_ТЧ	= ДопЗапрос.Реквизиты_ТЧ;
				
				Запрос			= Новый("Запрос");
				Запрос.Текст	= ДопЗапрос.Текст;
				Запрос.УстановитьПараметр("Ссылка",Выборка_Ш.Ссылка);
				
				Выборка_ТЧ	= Запрос.Выполнить().Выбрать();
				Пока Выборка_ТЧ.Следующий() Цикл
					Для Каждого СтрокаТР Из Реквизиты_ТЧ Цикл
						Если СтрокаТР.Кэшировать Тогда
							Кэши[СтрокаТР.ТипСтрокой].Вставить(Выборка_ТЧ[СтрокаТР.Имя]);						
						КонецЕсли;						
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;		
		КонецЕсли; 
		
	КонецЦикла;
	
	Возврат ТекНомер;
КонецФункции

Функция ЦиклПоПорции_ВыгрузитьДвижения(ЗапросСписка,ЗапросОбъектов,МоментВремени,Кэши,РеквизитыДляВыгрузки)	
