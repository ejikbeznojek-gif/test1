Функция ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(СпрВыборка)
	ИмяТаблицы	= "Справочник.ФизическиеЛица";
	ИмяТипаХДТО	= "КлючевыеСвойстваФизическоеЛицо";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	ОбъектХДТО	= ПолучитьИзКэша(Реквизиты.Ссылка,ИмяТаблицы);
	
	Если ОбъектХДТО = Неопределено Тогда		
		ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО);
		
		ОбъектХДТО.Ссылка		= XMLСтрока(Реквизиты.Ссылка);
		ОбъектХДТО.ФИО			= ?(ЗначениеЗаполнено(Реквизиты.Наименование),Реквизиты.Наименование,"");		
		
		Если ЗначениеЗаполнено(Реквизиты.ИНН) Тогда
			ОбъектХДТО.ИНН=СокрЛП(Реквизиты.ИНН);
		КонецЕсли;
		
		ВставитьВКэш(Реквизиты.Ссылка,ОбъектХДТО,ИмяТаблицы);		
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(Ссылка)

Функция ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент(СпрВыборка)	
	ИмяТаблицы		= "Справочник.Номенклатура";
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	ОбъектХДТО	= ПолучитьИзКэша(Реквизиты.Ссылка);
	Если ОбъектХДТО	= Неопределено Тогда				
		ОбъектХДТО = СоздатьОбъектХДТО("Справочник.ХарактеристикиНоменклатуры.Элемент",ПространствоИмен_ЕЕ);		
		
		ЗаполнитьЗначенияСвойств(ОбъектХДТО,Реквизиты);
		
		ОбъектХДТО.Владелец		= Реквизиты.Родитель;
		//Валетов + 07.11.2024 Выгрузка GTIN
		ОбъектХДТО.ГТИН			= Реквизиты.Ссылка.ГТИН;
		//Валетов -
		Если СпрВыборка.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.МБП 
			ИЛИ СпрВыборка.Родитель_ВидНоменклатуры = Перечисления.ВидыНоменклаутры.ОсновноеСредство Тогда
			ОбъектХДТО.Наименование	= СпрВыборка.Наименование;
		Иначе			
			ОбъектХДТО.Наименование	= СокрЛП(СокрЛП(Реквизиты.Цвет_Наименование))+" "+(СокрЛП(Реквизиты.Размер_Наименование));
			Если ЗначениеЗаполнено(Реквизиты.ДопПараметрРазмера_Наименование) Тогда
				ОбъектХДТО.Наименование = СокрЛП(ОбъектХДТО.Наименование)+" "+СокрЛП(Реквизиты.ДопПараметрРазмера_Наименование);
			КонецЕсли;			
		КонецЕсли;		
		
		ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);		
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_ХарактеристикаНоменклатуры(ХарактеристикаНоменклатуры)

Функция ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_ЕД(СпрВыборка)	
	
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	ОбъектХДТО	= ПолучитьИзКэша(ТекСсылка);
	Если ОбъектХДТО	= Неопределено Тогда				
		ОбъектХДТО = СоздатьОбъектХДТО("Справочник.ХарактеристикиНоменклатуры");
		
		Если НаВходеВыборка Тогда
			Реквизиты	= СпрВыборка;
		Иначе
			Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Код,Наименование,Цвет,Размер");			
		КонецЕсли;
		
		ТекСсылка	= Реквизиты.Ссылка;		
		
		ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_КС(Реквизиты);
		ОбъектХДТО.Наименование		= Реквизиты.Наименование;	
		
		ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.Код,				"Код",				"string",	ПространствоИмен_СТ);	
		ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.СнятСПроизводства,	"СнятСПроизводства","boolean",	ПространствоИмен_СТ);	
		ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
		
		ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_Цвета_КС(Реквизиты.Цвет),		"Цвет",		ПространствоИмен_ЕЕ);
		ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_Размеры_КС(Реквизиты.Размер),	"Размер",	ПространствоИмен_ЕЕ);		
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_ЕД(ХарактеристикаНоменклатуры)

Функция ВыгрузитьСпр_ХарактеристикиНоменклатуры_Элемент_КС(СпрВыборка)	
	ИмяТаблицы	= "Справочник.ФР_ХарактеристикиНоменклатуры";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицы);
	
	Если ОбъектХДТО = Неопределено Тогда	
		РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент.КС");	
		
		Если ПустаяСтрока(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
		ОбъектХДТО						= СоздатьОбъектХДТО("КлючевыеСвойстваХарактеристикаНоменклатуры");
	
		ОбъектХДТО.Ссылка				= XMLСтрока(РеквизитыШ.Ссылка);	
		ОбъектХДТО.Номенклатура			= ВыгрузитьСпр_Номенклатура_Элемент_КС(РеквизитыШ.Родитель,Истина);
		ОбъектХДТО.НаименованиеПолное	= РеквизитыШ.Наименование;	
		
		ВставитьВКэш(РеквизитыШ.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(Номенклатура,Фабрика)

