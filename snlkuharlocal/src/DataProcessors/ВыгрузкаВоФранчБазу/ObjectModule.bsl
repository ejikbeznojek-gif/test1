Функция ВыгрузитьСпр_Единицы_Элемент_КС(СпрВыборка)	
	ИмяТаблицы		= "Справочник.Единицы";
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса") ИЛИ ТипЗнч(СпрВыборка)=Тип("Структура"));	
	Если НЕ НаВходеВыборка Тогда
		Если СпрВыборка=Неопределено ИЛИ СпрВыборка=NULL ИЛИ СпрВыборка=Справочники.ОКЕИ.ПустаяСсылка() Тогда			
			Возврат ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);
		КонецЕсли;			
	КонецЕсли;
	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);	
	ОбъектХДТО		= ПолучитьИзКэша(ТекСсылка,ИмяТаблицы);
	
	Если ОбъектХДТО=Неопределено Тогда
		Если НаВходеВыборка Тогда
			Реквизиты	= СпрВыборка;
		Иначе
			Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Код,Наименование");		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Реквизиты.Ссылка) Тогда
			ОбъектХДТО					= СоздатьОбъектХДТО("КлючевыеСвойстваЕдиницаИзмерения");
		
			ОбъектХДТО.Ссылка			= XMLСтрока(Реквизиты.Ссылка);	
			ОбъектХДТО.Код				= Реквизиты.Код;	
			ОбъектХДТО.Наименование		= Реквизиты.Наименование;		
		Иначе
			ОбъектХДТО					= ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);
		КонецЕсли;		
		
		ВставитьВКэш(ТекСсылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Единицы_Элемент(Номенклатура,Фабрика)

Функция ВыгрузитьСпр_Единицы_Элемент(СпрВыборка)	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	Если НЕ ЗначениеЗаполнено(ТекСсылка) Тогда
		ВыгрузитьСпр_Единицы_Элемент(Ед_Штука);			
	КонецЕсли; 
	
	Если НаВходеВыборка Тогда
		Реквизиты	= СпрВыборка;
	Иначе
		Реквизиты	= ПолучитьРеквизитыШапки(ТекСсылка,"Ссылка,Код,Наименование,НаименованиеПолное");		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Реквизиты.Ссылка) Тогда
		ОбъектХДТО					= СоздатьОбъектХДТО("Справочник.ЕдиницыИзмерения");
		
		ОбъектХДТО.КлючевыеСвойства		= ВыгрузитьСпр_Единицы_Элемент_КС(Реквизиты);	
		ОбъектХДТО.НаименованиеПолное	= Реквизиты.НаименованиеПолное;		
	Иначе
		ОбъектХДТО						= ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);						
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Единицы_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_ЛинииНоменклатуры_Элемент(СпрВыборка)
	Возврат ВыгрузитьСпр_СТАНДАРТНО_Элемент(Справочники.ЛинииНоменклатуры, СпрВыборка, "Справочник.ЛинииНоменклатуры");
КонецФункции //ВыгрузитьСпр_ЛинииНоменклатуры_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Контрагенты_Элемент(СпрВыборка)	
	ИмяТаблицы	= "Справочник.Контрагенты";
	
	Если СпрВыборка=Неопределено 
		ИЛИ СпрВыборка=ПустаяСсылка_Спр_Контрагенты
		ИЛИ СпрВыборка=ПустаяСсылка_Спр_Организации Тогда		
		Возврат Неопределено;	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	ОбъектХДТО		= Неопределено;	
	
	Вид				= ТекСсылка.Метаданные().Имя;
	
	СписокРеквизитов= Новый Структура("ВерсияДанных,Код,Ссылка,ЭтоГруппа,ПометкаУдаления,ИНН,КПП");		
	СписокРеквизитов.Вставить(?(Вид="Контрагенты","ПолноеНаименование","НаименованиеПолное"),"НаименованиеПолное");		
	
	РеквизитыШапки	= ПолучитьРеквизитыШапки(ТекСсылка,СписокРеквизитов);	
	
	Если РеквизитыШапки.ВерсияДанных<>"" И НЕ РеквизитыШапки.ЭтоГруппа Тогда		
		Объект_ХДТО					= СоздатьОбъектХДТО("Справочник.Контрагенты");		
		Объект_ХДТО.КлючевыеСвойства= ВыгрузитьСпр_Контрагенты_Элемент_КС(СпрВыборка);    		
		
		
		ДобавитьЭлементХДТО(Объект_ХДТО,РеквизитыШапки.Код,				"Код",				"string",	ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(Объект_ХДТО,РеквизитыШапки.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	КонецЕсли;	
	
	Возврат Объект_ХДТО;
КонецФункции //ВыгрузитьСпр_Контрагенты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Контрагенты_Группа(СпрВыборка)	
	ИмяТаблицы		= "Справочник.Контрагенты";
	ИмяТипаХДТО     = "Справочник.КонтрагентыГруппа";
	
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(Реквизиты.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО					= СоздатьОбъектХДТО(ИмяТипаХДТО);		
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_Контрагенты_Группа_КС(СпрВыборка);
		
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.Код,				"Код",				"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Контрагенты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Контрагенты_Элемент_КС(СпрВыборка)	
	ИмяТаблицы	= "Справочник.Контрагенты";
	
	Если СпрВыборка=Неопределено 
		ИЛИ СпрВыборка=ПустаяСсылка_Спр_Контрагенты
		ИЛИ СпрВыборка=ПустаяСсылка_Спр_Организации Тогда		
		Возврат Неопределено;	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ТекСсылка		= ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	КС_ХДТО	= ПолучитьИзКэша(ТекСсылка,ИмяТаблицы);
	Если КС_ХДТО = Неопределено Тогда
		Вид	= ТекСсылка.Метаданные().Имя;
		
		Если НаВходеВыборка Тогда
			РеквизитыШапки	= СпрВыборка;
		Иначе
			СписокРеквизитов	= Новый Структура("ВерсияДанных,Ссылка,Код,Наименование,ИНН,КПП");		
			СписокРеквизитов.Вставить(?(Вид="Контрагенты","ПолноеНаименование","НаименованиеПолное"),"НаименованиеПолное");		
		
			РеквизитыШапки	= ПолучитьРеквизитыШапки(ТекСсылка,СписокРеквизитов);				
		КонецЕсли;		
		
		Если РеквизитыШапки.ВерсияДанных<>"" Тогда
			КС_ХДТО	= СоздатьОбъектХДТО("КлючевыеСвойстваКонтрагент");
			
			КС_ХДТО.Ссылка				= XMLСтрока(РеквизитыШапки.Ссылка);
			КС_ХДТО.Наименование		= РеквизитыШапки.Наименование;					
			КС_ХДТО.НаименованиеПолное	= РеквизитыШапки.НаименованиеПолное;		
			Если СтрДлина(СокрЛП(РеквизитыШапки.ИНН))>=10 Тогда
				КС_ХДТО.ИНН				= СокрЛП(РеквизитыШапки.ИНН);
			КонецЕсли;		
			Если СтрДлина(СокрЛП(РеквизитыШапки.КПП))=9 Тогда
				КС_ХДТО.КПП				= СокрЛП(РеквизитыШапки.КПП);
			КонецЕсли;	
			//+ HELP-1058 20241002 Михайловский
			Попытка
			//+ HELP-1058 20241002 Михайловский
				Если СтрНайти(ВРег(РеквизитыШапки.НаименованиеПолное),"ЧАСТНОЕ ЛИЦО")<>0  Тогда
					КС_ХДТО.ЮридическоеФизическоеЛицо 	= "ФизическоеЛицо";
				Иначе		
					КС_ХДТО.ЮридическоеФизическоеЛицо 	= "ЮридическоеЛицо";			
				КонецЕсли;
			//+ HELP-1058 20241002 Михайловский	
			Исключение
			КонецПопытки;
			//- HELP-1058 20241002 Михайловский
		КонецЕсли;
		
		ВставитьВКэш(ТекСсылка,КС_ХДТО,ИмяТаблицы);
	КонецЕсли;	
	
	Возврат КС_ХДТО;
КонецФункции //ВыгрузитьСпр_Контрагенты_Элемент_КС(СпрСсылка)

Функция ВыгрузитьСпр_Контрагенты_Группа_КС(СпрВыборка)	
	ИмяТаблицы	= "Справочник.Контрагенты";
	ИмяТипаХДТО	= "КлючевыеСвойстваКонтрагентГруппа";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Группа");
	
	Если НЕ ЗначениеЗаполнено(Реквизиты.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО	= ПолучитьИзКэша(Реквизиты.Ссылка,ИмяТаблицы);
	
	Если ОбъектХДТО=Неопределено Тогда	
		ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕД);
	
		ОбъектХДТО.Ссылка		= XMLСтрока(Реквизиты.Ссылка);
		ОбъектХДТО.Наименование = XMLСтрока(Реквизиты.Наименование);		
		
		Если ЗначениеЗаполнено(Реквизиты.Родитель) Тогда
			ОбъектХДТО.Группа	= ВыгрузитьСпр_Контрагенты_Группа_КС(Реквизиты.Родитель);
		КонецЕсли; 
		
		ВставитьВКэш(Реквизиты.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Контрагенты_Группа_КС(СпрСсылка)

Функция ВыгрузитьСпр_Контрагенты_Документ_ЦеныПоставщика(СпрВыборка)	
	ИмяТаблицы		= "Справочник.Контрагенты";	
	
	ИмяТипаХДТО		= "Документ.ЦеныПоставщика";
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Документ.ЦеныПоставщика");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,СпрВыборка);
	ОбъектХДТО.Дата	= НачалоДня(ТекущаяДата());
	
	ОбъектХДТО.Подразделение	= ПодразделениеКонтрагента(РеквизитыШ.Ссылка);
	
	ИмяТЧ	= "Скидки";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);
	
	ОбъектХДТО.Цены	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(СпрВыборка,ИмяТЧ),ИмяТипаХДТО+".Цены");
	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Контрагенты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_Контрагенты_РегистрСведений_СкидкиКонтрагентов_Документ_ЦеныПоставщика(СпрВыборка)
	
	//////////////////// ВХОД ////////////////////////////////////////////////////////////////
	
	ВхПараметр = РазобратьВходнойПараметр(СпрВыборка, "Справочник.Контрагенты");
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ = ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Документ.ЦеныПоставщика");
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	НаВходеВыборка = (ТипЗнч(СпрВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));         
	ТекСсылка      = ?(НаВходеВыборка,СпрВыборка.Ссылка,СпрВыборка);
	
	/////////////////// ВЫХОД ////////////////////////////////////////////////////////////////
	ИмяТипаХДТО                 = "Документ.ЦеныПоставщика";
	
	ОбъектХДТО    = СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,СпрВыборка);
	ОбъектХДТО.Дата         = НачалоДня(ТекущаяДата());
	
	ОбъектХДТО.Подразделение = ПодразделениеКонтрагента(РеквизитыШ.Ссылка);
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);
	
	////////////// ВЫГРУЗИМ РС СкидкиКонтрагентов ////////////////////////////////////////////
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ведущий", ТекСсылка.Ведущий);
	Запрос.Текст =
	"ВЫБРАТЬ
	|             СкидкиКонтрагентов.Контрагент КАК Контрагент,
	|             СкидкиКонтрагентов.ТипЦен КАК ТипЦен,
	|             СкидкиКонтрагентов.Номенклатура КАК Номенклатура,
	|             СкидкиКонтрагентов.Скидка КАК Скидка,
	|             СкидкиКонтрагентов.Наценка КАК Наценка,
	|             СкидкиКонтрагентов.ТипТовара КАК ТипТовара,
	|             СкидкиКонтрагентов.Брэнд КАК Брэнд,
	|             СкидкиКонтрагентов.Модель КАК Модель,
	|             СкидкиКонтрагентов.Статус КАК Статус,
	|             СкидкиКонтрагентов.ПричинаИзменийУсловийРаботы КАК ПричинаИзменийУсловийРаботы
	|ИЗ
	|             РегистрСведений.СкидкиКонтрагентов КАК СкидкиКонтрагентов
	|ГДЕ
	|             СкидкиКонтрагентов.Контрагент = &Ведущий";
	
	УстановитьПривилегированныйРежим(Истина);
	ВыборкаРС = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	ОбъектХДТО.Цены       = ВыгрузитьТЧвХДТО(ВыборкаРС, ИмяТипаХДТО+".Цены");
	
	Возврат ОбъектХДТО;
	
КонецФункции

Функция Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(Валюта,Договор=Неопределено,МенятьКонтаргентаИОрганизацию=Ложь)
