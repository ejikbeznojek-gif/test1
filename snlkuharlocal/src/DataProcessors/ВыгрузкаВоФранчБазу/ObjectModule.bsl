Функция ЗаполнитьПоляПоВыборке(Выборка,Префикс,Поля)
	Результат=Новый Структура(Поля);	
	
	Для Каждого Элемент Из Результат Цикл
		ИмяПоля=Элемент.Ключ;
		Если ИмяПоля="Ссылка" Тогда
			Ссылка	= Выборка[Префикс];
			
			Результат.Вставить("УИД",	XMLСтрока(Ссылка));
			Результат.Вставить("Ссылка",Ссылка);
		ИначеЕсли ИмяПоля="Родитель" Тогда
			Ссылка	= Выборка[Префикс+"_"+ИмяПоля];
			
			Результат.Вставить("Родитель_УИД",		XMLСтрока(Ссылка));
			Результат.Вставить("Родитель_Ссылка",	Ссылка);			
		Иначе
			Результат.Вставить(Элемент.Ключ,Выборка[Префикс+"_"+ИмяПоля]);
		КонецЕсли;			
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ЗаполнитьПоляПоВыборке(Выборка,Префикс,Поля)

