	|	Период МЕЖДУ &Дата1 И &Дата2
	|	И Склад.Подразделение.ВидПодразделения=ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И Номенклатура.ВерсияДанных<>""""
	|";
	
	ЗарегистрироватьВыборку(ТекстЗапроса,"Справочник.Номенклатура","Элемент");
	
	ТекстЗапроса = "
