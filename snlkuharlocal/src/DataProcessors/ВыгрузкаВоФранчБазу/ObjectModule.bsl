Функция ВыгрузитьСпр_ПодарочныеСертификаты_Элемент(СпрВыборка)
	ИмяТаблицы		= "Справочник.ПодарочныеСертификаты";
	ИмяТипаХДТО		= "Справочник.ПодарочныеСертификаты.Элемент";
	ПространствоИмен= ПространствоИмен_ЕЕ;
	
	ВхПараметр		= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"ВидСертификата");	
	
	Если РеквизитыШ.ВидСертификата=Справочники.ВидыПодарочныхСертификатов.Содексо Тогда
		ОбъектХДТО.ВидСертификата="Сторонний";
	ИначеЕсли РеквизитыШ.ВидСертификата=Справочники.ВидыПодарочныхСертификатов.ЕЕ Тогда		
		ОбъектХДТО.ВидСертификата="Собственный";
	ИначеЕсли РеквизитыШ.ВидСертификата=Справочники.ВидыПодарочныхСертификатов.ЕЕИзЧека Тогда
		ОбъектХДТО.ВидСертификата="СертификатИзЧека";
	ИначеЕсли РеквизитыШ.ВидСертификата=Справочники.ВидыПодарочныхСертификатов.ЕЕИзЧека2011 Тогда			
		ОбъектХДТО.ВидСертификата="СертификатИзЧека";
	ИначеЕсли РеквизитыШ.ВидСертификата=Справочники.ВидыПодарочныхСертификатов.КупонНаСкидку Тогда
		ОбъектХДТО.ВидСертификата="КупонНаСкидку";
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_ПодарочныеСертификаты_Элемент(СпрВыборка)

Функция ВыгрузитьСпр_ПодарочныеСертификаты_Элемент_ЕД(СпрВыборка)
