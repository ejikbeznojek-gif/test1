Функция ИнициализироватьКомпонентуОбмена(ТекУзелПолучатель) Экспорт
	УзелСПараметрами	= ФР_ОбщегоНазначения_ПИ.ЭтотУзел("ФР_ОбменСФРК");
	
	АдресСервера		= УзелСПараметрами.АдресОчереди;
	Пользователь		= УзелСПараметрами.Пользователь;
	Пароль				= УзелСПараметрами.Пароль;		
	
	Результат	= ФР_Регламент.ИнициализироватьКомпонентуОбмена(АдресСервера,"Прием",Пользователь,Пароль,"Обмен с узлом: "+ТекУзелПолучатель);
	
	Если Результат.Результат Тогда
		КомпонентаОбмена=Результат.КомпонентаОбмена;	
	Иначе
		КомпонентаОбмена=Неопределено;
	КонецЕсли; 
	
	Возврат  Результат.Результат;
КонецФункции //ИнициализироватьКомпонентуОбмена(ТекУзелПолучатель)
  
Функция ПодразделениеРНК(РНК_Ссылка) Экспорт
	Запрос=Новый ("Запрос");
	Запрос.Текст="	
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Реквизиты.ЗначениеРеквизита КАК Справочник.Подразделения) КАК Подразделение	
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Накладные
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.РеквизитыСправочников КАК Реквизиты
	|ПО 
	|	Накладные.ПунктДоставки = Реквизиты.Справочник
	|	И Реквизиты.ИмяРеквизита = ""ПодразделениеФранчайзинга""	
	|ГДЕ
	|	Накладные.Ссылка = &РНК_Ссылка	
	|";
	
	Запрос.УстановитьПараметр("РНК_Ссылка",РНК_Ссылка);
	
