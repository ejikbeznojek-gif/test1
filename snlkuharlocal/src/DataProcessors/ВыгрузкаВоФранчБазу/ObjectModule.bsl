Функция ЗагрузитьТЧОбъектаСторАс(Объект,ОбъектХДТО,ИменаТЧ,ДопПараметы=Неопределено)
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл		
		текДопПараметры	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметы,ИмяТЧ);
		СоотвРеквизитов	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(текДопПараметры,"СоответствиеРеквизитов",Новый Структура);
		
		ТЧ_Объекта	= Объект[ИмяТЧ];
		
		МетаТЧ		= Объект.Метаданные().ТабличныеЧасти[ИмяТЧ];
		ЕстьЕдиница	= (МетаТЧ.Реквизиты.Найти("Единица")<>Неопределено); 
		
		ТЧ_Объекта.Очистить();
		ТЧ_ХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,ИмяТЧ);
		Если ТЧ_ХДТО<>Неопределено Тогда
			Для Каждого СтрокаТЧ_ХДТО Из ТЧ_ХДТО.Строка Цикл
				СтрокаТЧ	= ТЧ_Объекта.Добавить();		
				ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаТЧ_ХДТО);
				Если ИмяТЧ = "Товары" Тогда
					Харка_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"ХарактеристикаНоменклатуры");
					Ном_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"Номенклатура");
					СтрокаТЧ.ХарактеристикаНоменклатуры = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(Харка_ХДТО)));
					СтрокаТЧ.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(Ном_ХДТО)));
				ИначеЕсли ИмяТЧ = "Брэнды" Тогда
					УИД_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"УИД");
					Если НЕ УИД_ХДТО = "00000000-0000-0000-0000-000000000000" И НЕ ПустаяСтрока(УИД_ХДТО) Тогда
						СтрокаТЧ.Брэнд = Справочники.ФР_Бренды.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(УИД_ХДТО)));
					КонецЕсли;
				ИначеЕсли ИмяТЧ = "ВидыНоменклатуры" Тогда
					УИД_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"УИД");
					Если НЕ УИД_ХДТО = "00000000-0000-0000-0000-000000000000" И НЕ ПустаяСтрока(УИД_ХДТО) Тогда
						СтрокаТЧ.ВидНоменклатуры = Справочники.ФР_ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(XMLСтрока(УИД_ХДТО)));
					КонецЕсли;
				ИначеЕсли ИмяТЧ = "Коллекции" Тогда
					УИД_ХДТО	= ПолучитьСвойствоХДТО(СтрокаТЧ_ХДТО,"УИД");
