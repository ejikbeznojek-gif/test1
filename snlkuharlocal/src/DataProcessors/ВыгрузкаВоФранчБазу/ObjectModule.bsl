Функция ВыгрузитьСпр_Организации_КС(КонтрагентСсылка)
	ИмяТаблицы	= "Справочник.Организации";
	ОбъектХДТО	= ПолучитьИзКэша(КонтрагентСсылка,ИмяТаблицы);
	
	Если ОбъектХДТО = Неопределено Тогда
		РеквизитыШапки				= ПолучитьРеквизитыШапки(КонтрагентСсылка,"Ссылка,Код,Наименование,ИНН,КПП","Справочник");
	
		//ОрганизацияXDTO			= СоздатьОбъектХДТО("Справочник.Организации"));	
		ОбъектХДТО					= СоздатьОбъектХДТО("КлючевыеСвойстваОрганизация");
		
		ОбъектХДТО.Ссылка			= СериализаторXDTO.XMLСтрока(КонтрагентСсылка);
		ОбъектХДТО.Наименование		= КонтрагентСсылка.Наименование;
		
		Если ТипЗнч(КонтрагентСсылка)=Тип("СправочникСсылка.Контрагенты") Тогда
			ОбъектХДТО.НаименованиеПолное = КонтрагентСсылка.ПолноеНаименование;
		Иначе
			ОбъектХДТО.НаименованиеПолное = КонтрагентСсылка.НаименованиеПолное;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(РеквизитыШапки.ИНН) Тогда
			ОбъектХДТО.ИНН=СокрЛП(РеквизитыШапки.ИНН);
		КонецЕсли;
		Если ЗначениеЗаполнено(РеквизитыШапки.КПП) Тогда
			ОбъектХДТО.КПП=СокрЛП(РеквизитыШапки.КПП);
		КонецЕсли;
		//+ HELP-1058 20241002 Михайловский
		Попытка
		//- HELP-1058 20241002 Михайловский
			ОбъектХДТО.ЮридическоеФизическоеЛицо 	= ВыгрузитьПер_ЮрФизЛицо_КС(КонтрагентСсылка);
		//+ HELP-1058 20241002 Михайловский
		Исключение
		КонецПопытки;
		//- HELP-1058 20241002 Михайловский
		//ОрганизацияXDTO.КлючевыеСвойства=КлючевыеСвойстваXDTO;
		ВставитьВКэш(КонтрагентСсылка,ОбъектХДТО,"Справочник.Организации");
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //Выгрузить_Организация(КонтрагентСсылка,Фабрика)

Функция ВыгрузитьСпр_Организации_Элемент(СпрВыборка)
