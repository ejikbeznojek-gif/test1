Функция ВыгрузитьРС_История(Отбор)	
	НЗ			= РегистрыСведений.История.СоздатьНаборЗаписей();	
	ИмяТипаХДТО	= "РегистрСведений.История"; 
	
	Для Каждого Элемент_Ист Из Отбор Цикл
		Если Элемент_Ист.Использование И Элемент_Ист.ПутьКДанным<>"Документ" Тогда
			Элемент_Пол	= НЗ.Отбор[Элемент_Ист.Имя];
			ЗаполнитьЗначенияСвойств(Элемент_Пол,Элемент_Ист,"ВидСравнения,Использование,Значение");
		КонецЕсли;	
	КонецЦикла; 
		
	СтрокиКУдалению=Новый Массив;
	НЗ.Прочитать();
	Сч=НЗ.Количество()-1;
	Пока Сч>=0 Цикл
		Если НЗ[Сч].Реквизит="ЦенаПоследнегоПрихода" Тогда
			НЗ.Удалить(НЗ[Сч]);				
		КонецЕсли;
		Сч=Сч-1;	
	КонецЦикла;	
	Для Каждого Запись Из НЗ Цикл
		Запись.Документ=Неопределено;	
	КонецЦикла; 
	
	ОбъектХДТО	= СериализаторXDTO.ЗаписатьXDTO(НЗ);	
	
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,НЗ.Количество());	
КонецФункции //ВыгрузитьРС_История(Отбор)

Функция ВыгрузитьРС_КоличествоПосетителей_ЕЕ(Отбор)	
	ИмяТаблицы	= "РегистрСведений.КоличествоПосетителей";
	Вид			= "КоличествоПосетителей";
	
	НЗ	= РегистрыСведений[Вид].СоздатьНаборЗаписей();
	ЗаполнитьОтборНЗ(НЗ,Отбор);
	НЗ.Прочитать();
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТаблицы+".НаборЗаписей",ПространствоИмен_ЕЕ);
	
	ОтборХДТО	= СоздатьОбъектХДТО(ИмяТаблицы+".Отбор",ПространствоИмен_ЕЕ);
	ОтборХДТО.Дата			= НЗ.Отбор.Дата.Значение;
	ОтборХДТО.Подразделение	= НЗ.Отбор.Подразделение.Значение;	
	
	ОбъектХДТО.Отбор	= ОтборХДТО;
	
	Для Каждого Запись Из НЗ Цикл
		ЗаписьХДТО	= СоздатьОбъектХДТО(ИмяТаблицы+".Запись",ПространствоИмен_ЕЕ);	
		ЗаполнитьЗначенияСвойств(ЗаписьХДТО,Запись);
		
		ЗаписьХДТО.Количество	= Запись.КоличествоПосетителей;
		
		ОбъектХДТО.Строка.Добавить(ЗаписьХДТО);
	КонецЦикла;
		
	Возврат Новый Структура("ОбъектХДТО,ВыгруженоЗаписей",ОбъектХДТО,ОбъектХДТО.Строка.Количество());
КонецФункции //ВыгрузитьРС_КоличествоПосетителей_ЕЕ(Отбор)

