Функция ВыгрузитьСпр_Договоры_Элемент_КС(СпрВыборка,МенятьКонтаргентаИОрганизацию=Ложь)
	ИмяТаблицы	= "Справочник.Договоры";
	ИмяТипаХДТО	= "КлючевыеСвойстваДоговор";
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	ИмяТаблицыДляКэша	= ИмяТаблицы+"_"+МенятьКонтаргентаИОрганизацию;
	ОбъектХДТО	= ПолучитьИзКэша(ВхПараметр.Ссылка,ИмяТаблицыДляКэша);
	Если ОбъектХДТО=Неопределено Тогда
		Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
		
		ОрганизацияФР	= ПолучитьОрганизациюДоговора(ВхПараметр.Ссылка);
		Если МенятьКонтаргентаИОрганизацию Тогда
			Организация	= ?(ЗначениеЗаполнено(ОрганизацияФР), ОрганизацияФР, Реквизиты.Владелец);		
			Контрагент	= Реквизиты.Организация;
		Иначе			
			Организация = ?(ЗначениеЗаполнено(ОрганизацияФР), ОрганизацияФР, Реквизиты.Организация);		
			Контрагент	= Реквизиты.Владелец;		
		КонецЕсли; 
		
		ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО);
		
		ОбъектХДТО.Ссылка 		= XMLСтрока(ВхПараметр.Ссылка);		
		ОбъектХДТО.ВидДоговора	= "СПоставщиком";
		
		
		ОбъектХДТО.Организация	= ВыгрузитьСпр_Организации_КС(Организация);	
		ОбъектХДТО.Контрагент	= ВыгрузитьСпр_Контрагенты_Элемент_КС(Контрагент);	
		
		ОбъектХДТО.ВалютаВзаиморасчетов	= ВыгрузитьСпр_Валюты_КС(Реквизиты.ВалютаКредита);
		ОбъектХДТО.Наименование			= Реквизиты.Наименование;
		
		УстановитьСвойствоХДТО(ОбъектХДТО,	"Дата",	Реквизиты.Дата);
		УстановитьСвойствоХДТО(ОбъектХДТО,	"Номер",Реквизиты.Номер);		
		
		ДобавитьЭлементХДТО(ОбъектХДТО,	Реквизиты.Код,"Код", "string",ПространствоИмен_СТ);
		
		ВставитьВКэш(ВхПараметр.Ссылка,ОбъектХДТО,ИмяТаблицыДляКэша);
	КонецЕсли; 
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Договоры_Элемент_КС(СпрВыборка,МенятьКонтаргентаИОрганизацию=Ложь)

Функция ВыгрузитьСпр_Договоры_Элемент_КС_ЕЕ(РеквизитыШ,МенятьКонтаргентаИОрганизацию=Ложь)
	ИмяТаблицы	= "Справочник.Договоры.ЕЕ";
	ИмяТипаХДТО	= "КлючевыеСвойстваДоговор";
		
	ОбъектХДТО	= ПолучитьИзКэша(РеквизитыШ.Ссылка,ИмяТаблицы);
	Если ОбъектХДТО=Неопределено Тогда		
		ОбъектХДТО			= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
		
		ОбъектХДТО.Ссылка 	= XMLСтрока(РеквизитыШ.Ссылка);		
		
		ВставитьВКэш(РеквизитыШ.Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли; 
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Договоры_Элемент_КС_ЕЕ(СпрВыборка,МенятьКонтаргентаИОрганизацию=Ложь)

Функция ВыгрузитьСпр_Договоры_Элемент_ЕД(РеквизитыШ, МенятьКонтаргентаИОрганизацию = Ложь)
	ИмяТаблицы	= "Справочник.Договоры";
	ИмяТипаХДТО	= "Справочник.Договоры";
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО);
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьСпр_Договоры_Элемент_КС(РеквизитыШ,МенятьКонтаргентаИОрганизацию);	
	
	Агентский = (РеквизитыШ.ВидДоговора_Новый_Код = "000001022");
	ДобавитьЭлементХДТО(ОбъектХДТО,	Агентский, "Агентский", "boolean",ПространствоИмен_СТ);	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Договоры_Элемент_ЕД(СпрВыборка,МенятьКонтаргентаИОрганизацию=Ложь)

Функция ВыгрузитьСпр_Договоры_Элемент_ЕЕ(РеквизитыШ,МенятьКонтаргентаИОрганизацию=Ложь)
	ИмяТаблицы	= "Справочник.Договоры";
	ИмяТипаХДТО	= "Справочник.ДоговорыЕЕ.Элемент";	
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);
	
	ВыгрузитьРеквизитыСМультиТипами(ОбъектХДТО,РеквизитыШ,"Владелец");
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Договоры_Элемент_ЕД(СпрВыборка,МенятьКонтаргентаИОрганизацию=Ложь)

