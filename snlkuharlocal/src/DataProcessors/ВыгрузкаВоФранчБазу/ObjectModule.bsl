	КонецЦикла;
КонецПроцедуры

Функция ПолучитьСсылкуНаСправочник(Вид,ЭтоГруппа,НужноНаименование)	
	Запрос=Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник."+Вид+" ГДЕ Не ПометкаУдаления";
	Если ЭтоГруппа<>Неопределено Тогда
		Запрос.Текст=Запрос.Текст+" И ЭтоГруппа=&ЭтоГруппа";
	КонецЕсли; 
	Если НужноНаименование Тогда
		Запрос.Текст=Запрос.Текст+" И НЕ Наименование=""""";	
	КонецЕсли; 
	Запрос.УстановитьПараметр("ЭтоГруппа",ЭтоГруппа);
	
	Результат	= Справочники[Вид].ПустаяСсылка();
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат = Выборка.Ссылка;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьСсылкуНаСправочник(Вид,ЭтоГруппа,НужноНаименование)
 

