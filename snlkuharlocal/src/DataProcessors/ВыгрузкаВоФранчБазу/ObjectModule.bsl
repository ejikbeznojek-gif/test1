Процедура ЗаполнитьСтрокуРегистрации_РС(СтрокаТО,Вид,Отбор) Экспорт
	НЗ=РегистрыСведений[Вид].СоздатьНаборЗаписей();
	Для Каждого Элемент Из Отбор Цикл
		НЗ.Отбор[Элемент.Ключ].Установить(Элемент.Значение,Истина);	
	КонецЦикла;	
	
	СтрокаТО.ВариантВыгрузки="РегистрСведений."+Вид;
	
	СтрокаОтбора			= ЗначениеВСтрокуВнутр(НЗ.Отбор);
	СтрокаТО.ОтборРС		= Новый ХранилищеЗначения(СтрокаОтбора);
