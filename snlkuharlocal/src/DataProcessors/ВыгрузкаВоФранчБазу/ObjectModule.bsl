Функция ВыгрузитьСпр_СТАНДАРТНО(Менеджер,СпрВыборка,ЭтоГруппа,Знач ИмяТипаХДТО="")	
	ИмяТаблицы	= Менеджер.ПустаяСсылка().Метаданные().ПолноеИмя();
	ИмяТипаХДТО	= ?(ПустаяСтрока(ИмяТипаХДТО),ИмяТаблицы,ИмяТипаХДТО);
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Суффикс	= ?(ЭтоГруппа,"Группа","Элемент");
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,Суффикс);
	//+HELP-3612 20250325 Михайловский до релиза фр!! пока так пусть
	Попытка
		Если ИмяТипаХДТО="Справочник.ШтрихкодыУпаковокТоваров" Тогда
			Если Реквизиты.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.ПокупкаВРФ Тогда
				Реквизиты.СпособВводаВОборот = Перечисления.СпособыВводаВОборотСУЗ.Импорт;
			КонецЕсли;	
		КонецЕсли;
	Исключение
	КонецПопытки;
	//-HELP-3612 20250325 Михайловский
	ОбъектХДТО = СоздатьОбъектХДТО(ИмяТипаХДТО+"."+Суффикс,ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,Реквизиты);	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_СТАНДАРТНО_Элемент(Менеджер,СпрВыборка,ИмяТаблицыПолучатель="")

