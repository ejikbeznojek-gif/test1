Функция ВыгрузитьДок_Чек_КС(ДокСсылка)
	Если ТипЗнч(ДокСсылка)=Тип("ДокументСсылка.Чек") Тогда
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,"Ссылка,Дата,Номер,НомерЧекаККМ,НомерСменыККМ,КассаККМ,Организация");
	Иначе
		РеквизитыШапки	= ДокСсылка;
	КонецЕсли;
	
	ОбектXDTO						= СоздатьОбъектХДТО("КлючевыеСвойстваЧекККМ");	
	
	ОбектXDTO.Ссылка				= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	ОбектXDTO.Дата					= РеквизитыШапки.Дата;
	ОбектXDTO.НомерКассовойСмены 	= РеквизитыШапки.НомерСменыККМ;
	ОбектXDTO.КассаККМ				= ВыгрузитьСпр_Кассы_Элемент_КС(РеквизитыШапки.КассаККМ);	
	ОбектXDTO.НомерВПрограмме		= РеквизитыШапки.Номер; 
	ОбектXDTO.НомерЧекаФР			= РеквизитыШапки.НомерЧекаККМ;	

	Возврат ОбектXDTO;
КонецФункции //ВыгрузитьДок_Чек_КС(ДокСсылка)

Функция ВыгрузитьДок_Чек(ДокВыборка)
	ИмяТаблицы	= "Документ.Чек";
	
	Если 1=2 Тогда
		ДокСсылка=Документы.ЧекККМ.ПустаяСсылка();	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);	
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе		
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,РеквизитыШапок.Получить(ИмяТаблицы));	
	КонецЕсли;
	
	ДокОбъектХДТО					= СоздатьОбъектХДТО("Документ.ЧекККМ");	
	
	ДокОбъектХДТО.КлючевыеСвойства 	= ВыгрузитьДок_Чек_КС(РеквизитыШапки);		
	ДокОбъектХДТО.ДанныеОперацииККМ	= Выгрузить_ОбщиеСвойстваОперацияККМ(РеквизитыШапки);
	
	//Товары
	ТоварыПродажаXDTO				= СоздатьОбъектХДТО("ОперацияККМТовары");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл	
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		СтрокаXDTO			= СоздатьОбъектХДТО("ОперацияККМТовары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		
		УстановитьСвойствоХДТО(СтрокаXDTO,"ЕдиницаИзмерения",ВыгрузитьСпр_Единицы_Элемент_КС(ВыборкаПоТЧ.Единица));
		
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.Цена					= ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество;
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);
		СтрокаXDTO.СуммаНДС				= ВыборкаПоТЧ.НДС;		
		
		ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.ЦенаБезСкидки,	"ЦенаБезСкидки",	"decimal", ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.ВсегоБезСкидки,	"ВсегоБезСкидки",	"decimal", ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.Скидка,			"Скидка",			"decimal", ПространствоИмен_СТ);
		
		ПродавецХДТО	= ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(ВыборкаПоТЧ.Продавец);
		СтрокаXDTO.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕД,"Менеджер",ПродавецХДТО);		
		
		ТоварыПродажаXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ДокОбъектХДТО.ТоварыПродажа		= ТоварыПродажаXDTO;
	
	Если РеквизитыШапки.ВидОплаты=Перечисления.ВидыОплаты.БН Тогда	
		ОплатаПлатежнымиКартамиXDTO		= СоздатьОбъектХДТО("ОплатаПлатежнымиКартами");		
		
		СтрокаХДТО						= СоздатьОбъектХДТО("ОплатаПлатежнымиКартами.Строка");
		
		СтрокаХДТО.СуммаОплаты			= РеквизитыШапки.СуммаДокумента;
		СтрокаХДТО.НомерКарты           = "9999 9999 9999 9999 9999";
		СтрокаХДТО.Эквайрер             = ВыгрузитьСпр_Контрагенты_Элемент_КС(КонтрагентЭквайринг);
		
		ОплатаПлатежнымиКартамиXDTO.Строка.Добавить(СтрокаХДТО);	
		
		ДокОбъектХДТО.ОплатаПлатежнымиКартами=ОплатаПлатежнымиКартамиXDTO;	
	КонецЕсли; 
	
	//Подарочные сертификаты
	ОплатаСертификатами_XDTO		= СоздатьОбъектХДТО("ПодарочныеСертификаты");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка,"ПодарочныеСертификаты");
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		СтрокаXDTO						= СоздатьОбъектХДТО("ПодарочныеСертификаты.Строка");
		
		СтрокаXDTO.ДанныеСертификата	= ВыгрузитьСпр_ПодарочныеСертификаты_КС(ВыборкаПоТЧ.Сертификат);
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.СуммаОплатыСертификатами;		
		
		ОплатаСертификатами_XDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ДокОбъектХДТО.ОплатаСертификатами	= ОплатаСертификатами_XDTO;	
	
	
	
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕД,"Склад",			ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад));	
	
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.ЧекПробитНаККМ,		"ЧекПробитНаККМ",	"boolean", 				ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.НомерЧекаККМ,			"НомерЧекаККМ",		"decimal", 				ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.ГруппыТоваров,			"ГруппыТоваров",	"string", 				ПространствоИмен_СТ);
	
	ДобавитьЭлементХДТО(ДокОбъектХДТО,XMLСтрока(РеквизитыШапки.ВидОплаты),	"ВидОплаты",		"string",				ПространствоИмен_СТ);	
	ДобавитьЭлементХДТО(ДокОбъектХДТО,XMLСтрока(РеквизитыШапки.КодОперации),"КодОперации",		"КодыОперацийОстатки",	ПространствоИмен_ЕЕ);	
	
	ТипЦен	=	?(ЗначениеЗаполнено(РеквизитыШапки.ТипЦен_Базовый),РеквизитыШапки.ТипЦен_Базовый,РеквизитыШапки.ТипЦен);
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,	"ТипЦен",		XMLСтрока(ТипЦен));
	
	ТипЦенРаспродажа =	?(ЗначениеЗаполнено(РеквизитыШапки.ТипЦенРаспродажа_Базовый),РеквизитыШапки.ТипЦенРаспродажа_Базовый,РеквизитыШапки.ТипЦенРаспродажа);
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,	"ТипЦенРаспродажа",	ВыгрузитьСпр_ТипыЦен_Элемент_КС(ТипЦенРаспродажа));
	
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,	"ТипСкидок",	XMLСтрока(РеквизитыШапки.ТипСкидок));
	
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,	"Организация",	ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Организация));
	ДокОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,	"Подразделение",ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШапки.Подразделение));
	
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.Проведен,			"Проведен",			"boolean", 				ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ДокОбъектХДТО,РеквизитыШапки.ПометкаУдаления,	"ПометкаУдаления",	"boolean", 				ПространствоИмен_СТ);
	
	Возврат ДокОбъектХДТО;
КонецФункции //ВыгрузитьДок_Чек(ДокВыборка)

Функция ВыгрузитьДок_ЭПС_СПН(ДокВыборка)
	ИмяТаблицы	= Метаданные.Документы.ЭмиссияПодарочныхСертификатов.ПолноеИмя();
	ИмяТипаХДТО	= "Документ.СписаниеТМЦ";
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);
	
	ИменаТЧ	= "Сертификаты";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ);		
	
	ОбъектХДТО.СостояниеНакладной	= Перечисления.СостоянияНакладной.Отгружена;
	ДобавитьЭлементХДТО(ОбъектХДТО,""+ДокВыборка.КодОперации,"КодОперацииЭПС","string",ПространствоИмен_СТ);
	
	ВыборкаПоСертификатам	= ПолучитьВыборкуПС(РеквизитыШ.Ссылка);
	
	ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);
	Пока ВыборкаПоСертификатам.Следующий() Цикл
		Если НЕ ЗначениеЗаполнено(ВыборкаПоСертификатам.Сертификат) Тогда Продолжить КонецЕсли;
		
		СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
		СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоСертификатам.Сертификат;
		
		ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);	
	КонецЦикла; 
	КоличествоСертификатов	= ТЧ_ХДТО.Строка.Количество();
	Если КоличествоСертификатов>0 Тогда
		ОбъектХДТО.Сертификаты	= ТЧ_ХДТО;
	КонецЕсли;	
	
	ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);
	
	СтрокаТЧ_ХДТО								= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
	СтрокаТЧ_ХДТО.Номенклатура					= РеквизитыШ.Номенклатура.Родитель;
	СтрокаТЧ_ХДТО.ХарактеристикаНоменклатуры	= РеквизитыШ.Номенклатура;
	СтрокаТЧ_ХДТО.Количество					= КоличествоСертификатов;		
		
	ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
	
	Если ТЧ_ХДТО.Строка.Количество()>0 Тогда
		ОбъектХДТО.Товары	= ТЧ_ХДТО;
	КонецЕсли;
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьДок_СПН(ДокВыборка)


Функция ПолучитьВыборкуПС(ДокСсылка)
	Запрос			= Новый ("Запрос");
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	Номенклатура,
	|	ТЧ_ЭПС.КодСертификата	КАК КодСертификата,
	|	СпрСертификаты.Ссылка 	КАК Сертификат
	|ИЗ
	|	Документ.ЭмиссияПодарочныхСертификатов.Сертификаты КАК ТЧ_ЭПС
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Справочник.ПодарочныеСертификаты КАК СпрСертификаты
	|ПО
	|	СпрСертификаты.КодСертификата	= ТЧ_ЭПС.КодСертификата	
	|ГДЕ
	|	ТЧ_ЭПС.Ссылка	= &ДокСсылка
	|";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Выборка	= Запрос.Выполнить().Выбрать();
	Возврат Выборка;
КонецФункции // ()
 

Функция Номер_Z_Отчета(Дата,Касса)
	Результат	= 0;
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	МАКСИМУМ(Номер_Z_Отчета) КАК Номер_Z_Отчета
	|ИЗ
	|   Документ.ОтчетКассовойСмены
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(Дата,ДЕНЬ)= &Дата 
	|	И Касса	= &Касса
	|";
	
	Запрос.УстановитьПараметр("Дата",НачалоДня(Дата));
	Запрос.УстановитьПараметр("Касса",Касса);
	
	Выборка	= Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Номер_Z_Отчета) Тогда
		Результат	= Выборка.Номер_Z_Отчета;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //Номер_Z_Отчета(Дата,Касса)

Функция ДобавитьСостояниеНакладной(ОбъектХДТО,СостояниеНакладной,ДопИмя="")
	Если ЗначениеЗаполнено(СостояниеНакладной) Тогда
		СостояниеXDTO	= СоздатьЗначениеХДТО("СостоянияНакладной",ИмяЗначенияПеречисления(СостояниеНакладной),ПространствоИмен_ЕЕ);	
		ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"СостояниеНакладной"+ДопИмя,СостояниеXDTO);	
	КонецЕсли;	
КонецФункции // ()

Функция Выгрузить_ОбщиеСвойстваОперацияККМ(ДокСсылка)
	ОбектXDTO			= СоздатьОбъектХДТО("ОбщиеСвойстваОперацияККМ");	
	
	ОбектXDTO.Валюта	= ВалютаРубХДТО;
	ОбектXDTO.Сумма		= ДокСсылка.СуммаДокумента;
	ОбектXDTO.Кассир	= ВыгрузитьСпр_Пользователи_Элемент_КС(ДокСсылка.Автор);
	
	Возврат ОбектXDTO;
КонецФункции //Выгрузить_ОбщиеСвойстваОперацияККМ(ДокСсылка)

Функция ПодразделениеТипаЦен(ТипЦен)
	Результат	= Справочники.Подразделения.ПустаяСсылка();
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СпрПодразделения.Ссылка КАК Подразделение	
	|ИЗ
	|	Справочник.Подразделения КАК СпрПодразделения
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ПланОбмена.Основной КАК ПланОбмена	
	|ПО
	|	ПланОбмена.Код	=  СпрПодразделения.КодФизическогоУзла77
	|ГДЕ
	|	(РозничныйТипЦен = &ТипЦен
	|	ИЛИ РозничныйТипЦенРаспродажа = &ТипЦен)
	|	И (НЕ ПланОбмена.ПометкаУдаления ИЛИ ПланОбмена.ВерсияДанных ЕСТЬ NULL)
	|";
	
	Запрос.УстановитьПараметр("ТипЦен",ТипЦен);	
	
	Выборка		= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Подразделение) Тогда
		Результат	= Выборка.Подразделение;			
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПодразделениеТипаЦен(ТипЦен)

