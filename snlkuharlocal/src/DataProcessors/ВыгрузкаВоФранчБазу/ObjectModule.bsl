Функция ВыгрузитьСпр_Организации_Элемент_ЕД(СпрВыборка)
	ИмяТаблицы	= "Справочник.Организации";
	ИмяТипаХДТО	= "Справочник.Организации";
	
	ВхПараметры = РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметры.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметры,"Элемент");
	
	Если НЕ ЗначениеЗаполнено(Реквизиты.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО);
	
	ОбъектХДТО.КлючевыеСвойства = ВыгрузитьСпр_Организации_КС(Реквизиты.Ссылка);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.Код,				"Код",				"string", 	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,	"ПометкаУдаления",	"boolean", 	ПространствоИмен_СТ);	
	
	Возврат ОбъектХДТО;
