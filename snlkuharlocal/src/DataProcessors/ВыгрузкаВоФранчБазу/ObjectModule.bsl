	МетаДок			= Метаданные.Документы.Перемещение;
	
	ИменаРеквизитов	= "ВерсияДанных,Ссылка,Дата,Номер,Проведен,ПометкаУдаления,
	|Склад.Организация,Склад.Подразделение,
