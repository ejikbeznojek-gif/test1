Функция ВыгрузитьПер_СостояниеСогласования(ЗначениеПеречисления)
	Если ЗначениеПеречисления=Перечисления.СостоянияСогласования.ПустаяСсылка() Тогда		
		Возврат Неопределено;
	ИначеЕсли ЗначениеПеречисления=Перечисления.СостоянияСогласования.НаСогласованииЦО Тогда
		Возврат "НаСогласовании";				
	ИначеЕсли ЗначениеПеречисления=Перечисления.СостоянияСогласования.НаСогласованииКонтрагент Тогда
		Возврат "НаСогласовании";				
	ИначеЕсли ЗначениеПеречисления=Перечисления.СостоянияСогласования.ОтмененКонтрагент Тогда
		Возврат "НеСогласовано";	
	ИначеЕсли ЗначениеПеречисления=Перечисления.СостоянияСогласования.ОтмененЦО Тогда
		Возврат "НеСогласовано";	
	ИначеЕсли ЗначениеПеречисления=Перечисления.СостоянияСогласования.Согласован Тогда
		Возврат "Согласовано";	
	Иначе
		Возврат "ВРаботе";		
	КонецЕсли;	
КонецФункции //ВыгрузитьПер_СостояниеСогласования(ЗначениеПеречисления)

#КонецОбласти


#Область Выгрузка_Документы


Процедура ВыгрузитьДокументы(РежимВыгрузки,Получатель) Экспорт			
	Выборка	= ПолучитьВыборкуДокументовКВыгрузке(ВыбранныеВариантыКВыгрузке());
	
	ТО=РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Сч	= Выборка.Количество();
	Сообщить_("К выгрузке: "+Сч);
	Пока Выборка.Следующий() Цикл		
		ОбработкаПрерыванияПользователя_();
		
		СтрокаТО				= ТО.Добавить();
		
		СтрокаТО.ОбъектСсылка	= Выборка.ОбъектСсылка;
		СтрокаТО.ВариантВыгрузки= Выборка.ВариантВыгрузки;
		
		Если ТипЗнч(СтрокаТО.ОбъектСсылка)=Тип("ДокументСсылка.ПрайсЛист") Тогда
			СтрокаТО	= ТО.Добавить();
			СтрокаТО.ОбъектСсылка		= Выборка.ОбъектСсылка;					
			СтрокаТО.ВариантВыгрузки	= "РегистрСведений.ЦеныНоменклатуры";
		КонецЕсли; 
		
		//СписокОбъектов.Добавить(Выборка.ОбъектСсылка);
	
		//Состояние_("Выгрузка: "+Выборка.ОбъектСсылка);				
		//
		//ОбъектХДТО	= ВыгрузитьДокумент(Выборка.СсылкаНаОбъект,Выборка.Получатель);
		//Если ОбъектХДТО<>Неопределено Тогда
		//	Фабрика.ЗаписатьXML(ЗаписьXML,ОбъектХДТО,,,,НазначениеТипаХМЛ);
		//КонецЕсли;
		//
		//Сч=Сч-1;
		Если Сч%100=0 Тогда			
			Состояние_(Сч);				
		КонецЕсли; 
	КонецЦикла;	
		
	ВыгрузитьПакетом(РежимВыгрузки,Новый Структура("СписокОбъектов,Получатель",ТО,Получатель));
		
	Состояние_("");
КонецПроцедуры

Функция ВсеВариантыВыгрузки() Экспорт
	ВариантыВыгрузки	= "ВводОстатковТМЦ,РНК_ПНК,ПНК,ПНК_ВЗВ,ПРМ_ПНК,ПРМ_ПРМ,ПРМ_РНК,ОКС,ЧекККМ,ПС,РКО,ПКО,ПрайсЛист,УстановкаСкидок,ОПР,СПН,ИНВ";
	
	Возврат СтрРазделить(ВариантыВыгрузки,",");
КонецФункции //ВсеВариантыВыгрузки()
 

Функция ВыбранныеВариантыКВыгрузке()
	ВариантыВыгрузки	= ВсеВариантыВыгрузки();
	ВыбранныеВарианты	= Новый Массив;
	
	Для Каждого ВариантВыгрузки Из ВариантыВыгрузки Цикл
		Если ЭтотОбъект["ф"+ВариантВыгрузки] Тогда
			ВыбранныеВарианты.Добавить(ВариантВыгрузки);					
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ВыбранныеВарианты;
КонецФункции // ()
 

Функция ВыгрузитьДокумент(ДокСсылка,ДопИнфо=Неопределено)		
	ОбъектХДТО	= Неопределено;
	
	ВидДокумента=ДокСсылка.Метаданные().Имя;
	Если ВидДокумента="ПриходнаяНакладная" Тогда
		Если ДокСсылка.КодОперации=Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда
			ОбъектХДТО	= ВыгрузитьДок_ПНК_ВЗВ(ДокСсылка);
		Иначе
			ОбъектХДТО	= ВыгрузитьДок_ПНК(ДокСсылка);
		КонецЕсли;		
	ИначеЕсли ВидДокумента="Перемещение" Тогда
		//+HELP-1380 20241015 Михайловский
		//вместо
		//Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка,"Склад.Подразделение,Склад.Подразделение.ВидПодразделения,СкладПолучатель.Подразделение,СкладПолучатель.Подразделение.ВидПодразделения","Документ");
		Реквизиты = ПолучитьРеквизитыШапки(ДокСсылка,"Склад.Подразделение,Склад.Подразделение.ВидПодразделения,СкладПолучатель.Подразделение,СкладПолучатель.Подразделение.ВидПодразделения, Склад.ТипСклада, СкладПолучатель.ТипСклада","Документ");

		//вместо 
		//Если Реквизиты.Склад_Подразделение=Реквизиты.СкладПолучатель_Подразделение Тогда
		ДопУсловие = Ложь;
		Попытка
			//Склад.ТипСклада 
			Если (Реквизиты.СкладПолучатель_ТипСклада = Перечисления.ТипСклада.РозничныйТЦ) ИЛИ (Реквизиты.Склад_ТипСклада = Перечисления.ТипСклада.РозничныйТЦ)
				ИЛИ (Реквизиты.СкладПолучатель_ТипСклада = Перечисления.ТипСклада.Филиал) ИЛИ (Реквизиты.СкладПолучатель_ТипСклада = Перечисления.ТипСклада.Филиал) Тогда
				ДопУсловие = Истина;
			КонецЕсли;	
		Исключение
			//это просто заглушка нет сообщения
		КонецПопытки;
		Если Реквизиты.Склад_Подразделение=Реквизиты.СкладПолучатель_Подразделение И ДопУсловие Тогда
		//-HELP-1380 20241015 Михайловский
			ОбъектХДТО	= ВыгрузитьДок_ПРМ_ПРМ_ЕЕ(ДокСсылка); //Обычное перемещение			
		Иначе			
			Если Реквизиты.Склад_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
				Если Реквизиты.СкладПолучатель_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
					//Вообще странная ситуация.....перемещение в другой франч - такого в принципе быть не должно
					ОбъектХДТО	= ВыгрузитьДок_ПРМ_ПРМ_ЕЕ(ДокСсылка);
				Иначе
					ОбъектХДТО	= ВыгрузитьДок_ПРМ_РНК_ЕЕ(ДокСсылка); //Возврат в ЕЕ
				КонецЕсли;			
			ИначеЕсли Реквизиты.СкладПолучатель_Подразделение_ВидПодразделения=Перечисления.ВидыПодразделений.Франчайзинг Тогда
				ОбъектХДТО	= ВыгрузитьДок_ПРМ_ПНК_ЕЕ(ДокСсылка);	//Приход во франч
			КонецЕсли;
		КонецЕсли;				
	ИначеЕсли ВидДокумента="ОтчетКассовойСмены" Тогда		
		ОбъектХДТО	= ВыгрузитьДок_ОКС(ДокСсылка);	
	ИначеЕсли ВидДокумента="Чек" Тогда		
		ОбъектХДТО	= ВыгрузитьДок_Чек(ДокСсылка);
	ИначеЕсли ВидДокумента="ОприходованиеТМЦ" Тогда
		ОбъектХДТО	= ВыгрузитьДок_ОПР(ДокСсылка);
	ИначеЕсли ВидДокумента="СписаниеТМЦ" Тогда
		ОбъектХДТО	= ВыгрузитьДок_СПН(ДокСсылка);
	ИначеЕсли ВидДокумента="Инвентаризация" Тогда
		ОбъектХДТО	= ВыгрузитьДок_ИНВ(ДокСсылка);
	ИначеЕсли ВидДокумента="ПрайсЛист" Тогда		
		ОбъектХДТО	= ВыгрузитьДок_ПрайсЛист(ДокСсылка,ДопИнфо);
	ИначеЕсли ВидДокумента="РасходнаяНакладная" Тогда
		ОбъектХДТО	= ВыгрузитьДок_РНК_ПНК(ДокСсылка);
	КонецЕсли;	
	
	Возврат ОбъектХДТО;
КонецФункции

Процедура ЗарегистрироватьДокументыКВыгрузке() Экспорт
	Выборка		= ПолучитьВыборкуДокументовКВыгрузке(ВыбранныеВариантыКВыгрузке());	
	ВсегоСтрок	= Выборка.Количество();
	
	Сообщить_("К регистрации: "+ВсегоСтрок+" документов.");
	
	ТД			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Сч			= 0;
	
	ВыгруженныеПрайсы	= Новый Массив;
	
	Пока Выборка.Следующий() Цикл	
		ОбработкаПрерыванияПользователя_(); 
		
		Сч=Сч+1;
		
		СтрокаТД	= ТД.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТД,Выборка);	
		
		ДокСсылка		= СтрокаТД.ОбъектСсылка;
		ТипДокумента	= ТипЗнч(ДокСсылка);
		
		Если ТипДокумента=Тип("ДокументСсылка.ПрайсЛист") Тогда
			ЗарегистрироватьНЗ_ЦеныНоменклатуры(ДокСсылка);
		ИначеЕсли ТипДокумента=Тип("ДокументСсылка.УстановкаСкидок") Тогда			
			ЗарегистрироватьНЗ_СкидкиНоменклатуры(ДокСсылка);
		КонецЕсли; 
		
		Если Сч%100=0 Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТД);
			
			ТД.Очистить();		
			
			Состояние_(ВсегоСтрок-Сч);
		КонецЕсли;			
	КонецЦикла; 
	
	Если ТД.Количество()>0 Тогда
		РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТД);
	КонецЕсли;	
	
КонецПроцедуры

Функция ЗарегистрироватьНЗ_ЦеныНоменклатуры(ДокСсылка) Экспорт
	НЗ	= РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	НЗ.Отбор.Прайс.Установить(ДокСсылка,Истина);
	НЗ.Отбор.ТипЦен.Установить(ДокСсылка.ТипЦен,Истина);
	
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъект(НЗ);
КонецФункции // ()

Функция ЗарегистрироватьНЗ_СкидкиНоменклатуры(ДокСсылка) Экспорт
	НЗ	= РегистрыСведений.СкидкиНоменклатуры.СоздатьНаборЗаписей();
	НЗ.Отбор.Документ.Установить(ДокСсылка,Истина);
	НЗ.Отбор.ТипСкидок.Установить(ДокСсылка.ТипСкидок,Истина);
	
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъект(НЗ);
КонецФункции // ()
		
Функция ТекстЗапроса_СписокДоковПоВиду(ВидДокумента,Знач Фильтр=Неопределено,Знач ПолеПолучателя=Неопределено,ВариантВыгрузки="",ОбратныйПорядок=Ложь)
	Если Фильтр=Неопределено Тогда
		Фильтр="
		|	НЕ Склад.Подразделение=ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
		|	И (
		|			Склад.Подразделение	= &ПодразделениеТек 
		|			ИЛИ (
		|				&ПодразделениеТек	= ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
		|				И Склад.Подразделение.ВидПодразделения	= ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
		|			)
		|	)
		|";
	КонецЕсли;	
	
	Если ПолеПолучателя=Неопределено Тогда
		ПолеПолучателя="Склад.Подразделение";
	КонецЕсли; 
	
	Текст="
	|ВЫБРАТЬ "+?(ОбратныйПорядок,"ПЕРВЫЕ 1","")+"
	|	Ссылка,
	|	Дата,
	|	"+ПолеПолучателя+"		КАК Получатель,
	|	"""+ВариантВыгрузки+"""	КАК ВариантВыгрузки,
	|	Неопределено 			КАК ДокОснование
	|ИЗ
	|	Документ."+ВидДокумента+"
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	"+?(ВидДокумента="Чек","","И Проведен")+"	
	|	И "+Фильтр+"
	|	И (Ссылка=&ВыбДок ИЛИ &ВыбДок=Неопределено)
	|"+?(ОбратныйПорядок,"УПОРЯДОЧИТЬ ПО Дата УБЫВ","");	
	
	Возврат Текст;	
КонецФункции // ()

Функция ТекстЗапроса_РНК_ПНК(ОбратныйПорядок)
	Текст="
	|ВЫБРАТЬ "+?(ОбратныйПорядок,"ПЕРВЫЕ 1","")+"
	|	ДокОснование 					КАК Ссылка,
	|	ВЫРАЗИТЬ(ДокОснование 			КАК Документ.РасходнаяНакладная).Дата	КАК Дата,
	|   СкладПолучатель.Подразделение 	КАК Получатель,
	|	""РНК_ПНК""						КАК ВариантВыгрузки,
	|	Ссылка							КАК ДокОснование
	|ИЗ
	|	Документ.Перемещение
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	И Проведен
	|	И СостояниеНакладной	= ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.Отгружена)	
	|	И "+ТекстФильтраПоФранчПодразделению("СкладПолучатель")+"
	|	И НЕ ВЫРАЗИТЬ(ДокОснование КАК Документ.РасходнаяНакладная).Номер ЕСТЬ NULL	
	|	И (ДокОснование=&ВыбДок ИЛИ &ВыбДок=Неопределено)
	|"+?(ОбратныйПорядок,"УПОРЯДОЧИТЬ ПО Дата УБЫВ","")+"
	|";	
	
	Возврат Текст;
КонецФункции //ТекстЗапроса_РНК_ПНК()

Функция ТекстЗапроса_Прайс(ОбратныйПорядок) Экспорт				
	Текст="	
	|ВЫБРАТЬ  "+?(ОбратныйПорядок,"ПЕРВЫЕ 1","")+" 
	|	Ссылка,
	|	Дата,
	|	ВТ_ТипыЦен.Подразделение	КАК Получатель,
	|	""""						КАК ВариантВыгрузки,
	|	Неопределено 				КАК ДокОснование
	|ИЗ
	|	Документ.ПрайсЛист КАК Прайс
	|ПРАВОЕ СОЕДИНЕНИЕ
	|(
	|ВЫБРАТЬ
	|	Ссылка 						КАК Подразделение,
	|	РозничныйТипЦен 			КАК ТипЦен,
	|	РозничныйТипЦен.Базовый		КАК ТипЦенБазовый,
	|	РозничныйТипЦенРаспродажа 	КАК ТипЦенРаспродажа,
	|	РозничныйТипЦенРаспродажа.Базовый,
	|	РозничныйТипСкидок 			КАК ТипСкидок,	
	|	
	|	Подразделения.ВидПодразделения КАК ВидПодразделения	
	|ИЗ
	|	Справочник.Подразделения КАК Подразделения
	|ГДЕ
	|	ВидПодразделения	= ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|	И (Ссылка	= &ПодразделениеТек ИЛИ &ПодразделениеТек	= ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	|	)
	|) КАК ВТ_ТипыЦен
	|ПО
	|	Прайс.ТипЦен		=  ВТ_ТипыЦен.ТипЦен
	|	ИЛИ Прайс.ТипЦен	=  ВТ_ТипыЦен.ТипЦенРаспродажа
	|	ИЛИ Прайс.ТипЦен	=  ВТ_ТипыЦен.ТипЦенБазовый
	|	ИЛИ Прайс.ТипЦен	= &ТипЦенЧЛ	 
	|ГДЕ
	|	Дата2 >= &Дата1
	|	И Проведен	
	|	И (Ссылка=&ВыбДок ИЛИ &ВыбДок=Неопределено)
	|"+?(ОбратныйПорядок,"УПОРЯДОЧИТЬ ПО Дата УБЫВ","")+"
	|";
	
	Возврат Текст;	
КонецФункции // ()

Функция ТекстФильтраПоФранчПодразделению(ИмяРеквизита)
	Возврат "
	|	("+ИмяРеквизита+".Подразделение = &ПодразделениеТек 
	|		ИЛИ (
	|			 &ПодразделениеТек=ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	|			 И 	"+ИмяРеквизита+".Подразделение.ВидПодразделения	= ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
	|		)
	|	)
	|";
КонецФункции // ()

Функция ПолучитьВыборкуДокументовКВыгрузке(Знач ВариантыВыгрузки,ОбратныйПорядок=Ложь) Экспорт
	МД				= Новый Массив;
	
	ТекстыЗапроса	= Новый Массив;	
	
	Запрос	= Новый ("Запрос");
	
	Если ТипЗнч(ВариантыВыгрузки)=Тип("Массив") Тогда
		МассивВариантов=ВариантыВыгрузки; 
	Иначе		
		МассивВариантов=СтрРазделить(ВариантыВыгрузки,",");
	КонецЕсли; 
	
	Для Каждого ВариантВыгрузки Из МассивВариантов Цикл
		Если ВариантВыгрузки="ВводОстатковТМЦ" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ВводОстатковТМЦ",,,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ПРМ_ПНК" Тогда
			Фильтр	= "
			|	Склад.Подразделение = &ПодразделениеЦО
			|	И "+ТекстФильтраПоФранчПодразделению("СкладПолучатель")+"
			|	И ВЫРАЗИТЬ(ДокОснование КАК Документ.РасходнаяНакладная).Номер ЕСТЬ NULL
			|";
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("Перемещение",Фильтр,"СкладПолучатель.Подразделение","ПРМ_ПНК",ОбратныйПорядок));		
		ИначеЕсли ВариантВыгрузки="ПРМ_РНК" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("Перемещение","СкладПолучатель.Подразделение = &ПодразделениеЦО И Склад.Подразделение = &ПодразделениеТек","Склад.Подразделение","ПРМ_РНК",ОбратныйПорядок));	
		ИначеЕсли ВариантВыгрузки="ПРМ_ПРМ" Тогда			
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("Перемещение","СкладПолучатель.Подразделение = &ПодразделениеТек И Склад.Подразделение = &ПодразделениеТек","Склад.Подразделение","ПРМ_ПРМ",ОбратныйПорядок));	
		ИначеЕсли ВариантВыгрузки="РНК_ПНК" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_РНК_ПНК(ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="РНК_ПНК" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_РНК_ПНК(ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ПНК" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ПриходнаяНакладная","Склад.Подразделение=&ПодразделениеТек И КодОперации<>ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя)",,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ПНК_ВЗВ" Тогда
			Фильтра="
			|	Склад.Подразделение.ВидПодразделения	= ЗНАЧЕНИЕ(Перечисление.ВидыПодразделений.Франчайзинг)
			|	И КодОперации							= ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.ВозвратОтПокупателя)
			|	И Склад.Подразделение=&ПодразделениеТек ИЛИ &ПодразделениеТек=ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
			|";
			
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ПриходнаяНакладная",Фильтр,,"ПНК_ВЗВ",ОбратныйПорядок));			
		ИначеЕсли ВариантВыгрузки="ОКС" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ОтчетКассовойСмены",,,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ЧекККМ" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("Чек",,,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ОПР" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ОприходованиеТМЦ",,,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="СПН" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("СписаниеТМЦ",,,,ОбратныйПорядок));			
		ИначеЕсли ВариантВыгрузки="ИНВ" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("Инвентаризация",,,,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ПрайсЛист" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_Прайс(ОбратныйПорядок));					
			Запрос.УстановитьПараметр("ТипЦенЧЛ",ТипЦенЧЛ);			
		ИначеЕсли ВариантВыгрузки="УстановкаСкидок" Тогда			
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("УстановкаСкидок","ТипСкидок.Розничный=ИСТИНА","&ПодразделениеТек",,ОбратныйПорядок));	
		ИначеЕсли ВариантВыгрузки="ПС" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ПереводСредств","(Источник_Подразделение=&ПодразделениеТек ИЛИ Получатель_Подразделение=&ПодразделениеТек)","Получатель_Подразделение",,ОбратныйПорядок));			
		ИначеЕсли ВариантВыгрузки="РКО" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("РасходныйКассовыйОрдер","Подразделение=&ПодразделениеТек","Подразделение",,ОбратныйПорядок));
		ИначеЕсли ВариантВыгрузки="ПКО" Тогда
			ТекстыЗапроса.Добавить(ТекстЗапроса_СписокДоковПоВиду("ПриходныйКассовыйОрдер","Подразделение=&ПодразделениеТек","Подразделение",,ОбратныйПорядок));
		КонецЕсли;		
	КонецЦикла;	
	
	Запрос.УстановитьПараметр("Дата1",НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2",КонецДня(Дата2));
	
	Запрос.УстановитьПараметр("ПодразделениеТек",		ПодразделениеПолучатель);
	Запрос.УстановитьПараметр("ПодразделениеЦО",		ПодразделениеЦО);	
	
	Если ЗначениеЗаполнено(ВыбДок) Тогда
		Запрос.УстановитьПараметр("ВыбДок",ВыбДок);
	Иначе
		Запрос.УстановитьПараметр("ВыбДок",Неопределено);
	КонецЕсли; 
	
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка КАК ОбъектСсылка,
	|	Дата,
	|	Получатель,
	|	ВариантВыгрузки,
	|	ДокОснование	
	|ИЗ 
	|	("+СтрСоединить(ТекстыЗапроса," ОБЪЕДИНИТЬ "+Символы.ПС)+") 
	|КАК Сводный
	|УПОРЯДОЧИТЬ ПО Дата
	|";	
	
	Выборка	= Запрос.Выполнить().Выбрать();	
	
	Возврат Выборка;
КонецФункции //ПолучитьВыборкуДокументовКВыгрузке() Экспорт


Функция НайтиХПС(ДокОснование)	
	Результат		= Документы.ХранилищеПодарочныхСертификатов.ПустаяСсылка();
	
	Запрос			= Новый Запрос;
	
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Запрос.Текст	= "
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ХПС.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Перемещение КАК Перемещение
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	Документ.ХранилищеПодарочныхСертификатов КАК ХПС
		|ПО
		|	ХПС.ДокОБъект=Перемещение.Ссылка
		|ГДЕ
		|	Перемещение.ДокОснование = &ДокОснование	
		|	И НЕ ХПС.ПометкаУдаления
		|	И ХПС.ВерсияДанных<>""""	
		|";	
	Иначе
		Запрос.Текст	= "
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Ссылка
		|ИЗ
		|	Документ.ХранилищеПодарочныхСертификатов.Сертификаты
		|ГДЕ
		|	Ссылка.ДокОбъект = &ДокОснование	
		|	И НЕ Ссылка.ПометкаУдаления
		|	И Ссылка.ВерсияДанных<>""""	
		|";	
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("ДокОснование",ДокОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат	= Выборка.Ссылка;							
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //ПолучитьХДС(ДокОснование)
 


Функция УстановитьСвойствоХДТО(ОбъектХДТО,Имя,Значение) //По чудо логике разработчиков 1С - неопределено присваивать НЕЛЬЗЯ !!! 
	Если НЕ (Значение=Неопределено ИЛИ Значение="") Тогда
		ОбъектХДТО[Имя]=Значение;	
	КонецЕсли;
КонецФункции //УстановитьСвойствоХДТО(ОбъектХДТО,Имя,Значение)

Функция ПолучитьВыборкуТЧДокумента(ДокСсылка,ИмяТЧ)
	ТипДокумента	= ТипЗнч(ДокСсылка);
	ТипЗнчСтрВнутр	= ЗначениеВСтрокуВнутр(ТипДокумента);
	
	Запрос			= Новый Запрос;
	Запрос.Текст	= "
	|ВЫБРАТЬ
	|	*
	|ИЗ
	|	"+ФР_ОбщегоНазначения_ПИ.ИмяТипа(ТипЗнчСтрВнутр)+"."+ИмяТЧ+"
	|ГДЕ
	|	Ссылка=&Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка",ДокСсылка);
	Возврат Запрос.Выполнить().Выбрать();
КонецФункции //ПолучитьВыборкуТЧДокумента(ДокСсылка,ИмяТЧ)

Функция ВыгрузитьДок_БлокировкаАкции(ДокВыборка)	
	ИмяТаблицы		= "Документ.БлокировкаАкции";	
	ИмяТипаХДТО		= ИмяТаблицы;
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТаблицы,ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ);	
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_БлокировкаАкции(ДокВыборка)

Функция ВыгрузитьДок_ВводОстатковТМЦ(ДокВыборка)
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,"Ссылка,Номер,Дата,Валюта,Курс,Склад,СуммаДокумента");	
		РеквизитыШапки.Вставить("Подразделение",ПолучитьРеквизитШапки(РеквизитыШапки.Склад,"Подразделение"));
	КонецЕсли;	
	
	
	ЮрЛицоФранча				= РегистрыСведений.ФР_ЮрЛицаПодразделений.ПолучитьЮрЛицо(РеквизитыШапки.Подразделение,РеквизитыШапки.Дата);
	
	ОбъектХДТО					= СоздатьОбъектХДТО("Документ.ОстаткиСобственныхТМЦ");	
	
	ОбъектХДТО.Дата			= РеквизитыШапки.Дата;	
	ОбъектХДТО.Организация	= ВыгрузитьСпр_Организации_КС(ЮрЛицоФранча);
	ОбъектХДТО.Склад		= ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад);
	
	ТоварыXDTO	= СоздатьОбъектХДТО("Документ.ОстаткиСобственныхТМЦ.ТМЦ");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл	
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		ПроцентНДС			= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаXDTO			= СоздатьОбъектХДТО("Документ.ОстаткиСобственныхТМЦ.ТМЦ.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		СтрокаXDTO.ВидЗапасов			= "СобственныеТовары";		
		ТекЕдиница						= ?(ЗначениеЗаполнено(ВыборкаПоТЧ.Единица),ВыборкаПоТЧ.Единица,Ед_Штука);
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ТекЕдиница);		
		
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		
		СтрокаXDTO.СуммаБезНДС			= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.КоличествоУпаковок	= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);		
		
		Если ПроцентНДС<>0 Тогда	
			СтрокаXDTO.СуммаНДС          = Окр(ВыборкаПоТЧ.Всего*ПроцентНДС/(1+ПроцентНДС),2,1);
			СтрокаXDTO.СуммаБезНДС		 = СтрокаXDTO.СуммаБезНДС-СтрокаXDTO.СуммаНДС;
		КонецЕсли;		
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;		
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ОбъектХДТО.ТМЦ				= ТоварыXDTO;
	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(РеквизитыШапки.Ссылка),"Ссылка","ДокументСсылка.ПоступлениеТоваровУслуг",ПространствоИмен_ЕД);
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(РеквизитыШапки.Номер),"Номер","string",ПространствоИмен_СТ);
	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕД,"Ответственный",ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШапки.Автор));	
	
	Возврат ОбъектХДТО;
КонецФункции

Функция ВыгрузитьДок_ЗПК_ЗПС(ДокВыборка)	
	ИмяТаблицы		= "Документ.Заказ";	
	ИмяТипаХДТО		= "Документ.ЗаказПоставщику";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекСклад				= ?(ЗначениеЗаполнено(ДокВыборка.СкладПолучатель_ДИ),ДокВыборка.СкладПолучатель_ДИ,ДокВыборка.СкладПолучатель);
	ТекОрганизация 			= ?(ЗначениеЗаполнено(ТекСклад),ПолучитьРеквизитШапки(ТекСклад,"Организация"),РеквизитыШ.Контрагент);	
	ТекПодразделение		= ДокВыборка.Подразделение;	
	
	Если НЕ ЗначениеЗаполнено(ТекПодразделение) Тогда
		ТекПодразделение	= ФранчПодразделениеСсылки(РеквизитыШ.ПунктДоставки);			
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ТекСклад) Тогда
		ТекСклад	= ПолучитьРеквизитШапки(ТекПодразделение,"ОсновнойСклад","Справочник");	
	КонецЕсли; 
	
	ОбъектХДТО					= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"Товары");
	
	//ОбъектХДТО.Ссылка			= РеквизитыШ.Ссылка;
	//
	//ОбъектХДТО.Дата				= РеквизитыШ.Дата;
	//ОбъектХДТО.Номер			= РеквизитыШ.Номер;				
	//
	//
	//ОбъектХДТО.Подразделение	= ТекПодразделение;		
	//ОбъектХДТО.Склад			= ТекСклад;
	//
	//ОбъектХДТО.Договор			= РеквизитыШ.Договор;	
	//
	//ОбъектХДТО.Валюта			= ДокВыборка.Валюта;
	//ОбъектХДТО.Курс				= ДокВыборка.Курс;
	//
	//ОбъектХДТО.КоличествоДокумента  = РеквизитыШ.КоличествоДокумента;
	//ОбъектХДТО.Комментарий			= РеквизитыШ.Комментарий;	
	//
	//ОбъектХДТО.МенеджерЦО			= РеквизитыШ.Менеджер;
	//ОбъектХДТО.Автор				= РеквизитыШ.Автор;
	
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Контрагент		= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.Организация.УникальныйИдентификатор());
	
	ТоварыXDTO					= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Номенклатура = Null Тогда Продолжить КонецЕсли; 
		Если ВыборкаПоТЧ.Заявка=0 И ВыборкаПоТЧ.ПодтвержденнаяЗаявка=0 И ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;	
		
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ,,"Единица");
		СтрокаТЧ_ХДТО.Единица	= Ед_Штука;		
		
		ПроцентНДС	= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаТЧ_ХДТО.Всего			= ВыборкаПоТЧ.Всего;
		СтрокаТЧ_ХДТО.Цена			= Окр(?(ВыборкаПоТЧ.Количество=0,0,СтрокаТЧ_ХДТО.Всего/ВыборкаПоТЧ.Количество),2,1);
		//+HELP-2538 20250115 Михайловский
		//меняю
		//СтрокаТЧ_ХДТО.СуммаБезНДС	= СтрокаТЧ_ХДТО.Всего*ПроцентНДС/(1+ПроцентНДС);
		//СтрокаТЧ_ХДТО.НДС			= СтрокаТЧ_ХДТО.Всего-СтрокаТЧ_ХДТО.СуммаБезНДС;
		//нга
		СтрокаТЧ_ХДТО.НДС	= СтрокаТЧ_ХДТО.Всего * ПроцентНДС /(1 + ПроцентНДС);
		СтрокаТЧ_ХДТО.СуммаБезНДС			= СтрокаТЧ_ХДТО.Всего - СтрокаТЧ_ХДТО.НДС;
		//-HELP-2538 20250115 Михайловский
		ТоварыXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары				= ТоварыXDTO;	
	
	СостСогласования	= ДокВыборка.СостояниеСогласования;
	Если ЗначениеЗаполнено(СостСогласования) Тогда	
		Если СостСогласования=Перечисления.СостоянияСогласования.Согласован Тогда		
			СостСоглПоставщик	= "Согласовано";
			СостСоглПокупатель	= "Согласовано";			
		ИначеЕсли СостСогласования	= Перечисления.СостоянияСогласования.НаСогласованииЦО Тогда		
			СостСоглПоставщик	= "НаСогласовании";
			СостСоглПокупатель	= "ВРаботе";
		ИначеЕсли ДокВыборка.СостояниеСогласования=Перечисления.СостоянияСогласования.НаСогласованииКонтрагент Тогда		
			СостСоглПоставщик	= "Согласовано";
			СостСоглПокупатель	= "НаСогласовании";			
		ИначеЕсли ДокВыборка.СостояниеСогласования=Перечисления.СостоянияСогласования.ОтмененЦО Тогда		
			СостСоглПоставщик	= "НеСогласовано";
			СостСоглПокупатель	= "ВРаботе";			
		ИначеЕсли ДокВыборка.СостояниеСогласования=Перечисления.СостоянияСогласования.ОтмененКонтрагент Тогда		
			СостСоглПоставщик	= "ВРаботе";
			СостСоглПокупатель	= "НеСогласовано";
		Иначе
			СостСоглПоставщик	= "ВРаботе";
			СостСоглПокупатель	= "ВРаботе";
		КонецЕсли;
		
		ОбъектХДТО.СостояниеСогласования_Поставщик		= СостСоглПоставщик;
		ОбъектХДТО.СостояниеСогласования_Покупатель_ЦО	= СостСоглПокупатель;		
	КонецЕсли;	
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ЗПК_ЗПС

Функция ВыгрузитьДок_ЗНВПок(ДокВыборка)	
	ИмяТаблицы		= "Документ.ЗаявкаНаВозвратОтПокупателя";	
	ИмяТипаХДТО		= "Документ.ЗаявкаНаВозвратОтПокупателя";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекПодразделение		= РеквизитыШ.Подразделение;	
	ТекОрганизация 			= ОрганизацияПодразделения(ТекПодразделение);
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"Товары,СостояниеСогласования_Поставщик,СостояниеСогласования_Покупатель");
	
	ОбъектХДТО.Подразделение	= ТекПодразделение;		
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Контрагент		= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.Организация.УникальныйИдентификатор());		
	
	ОбъектХДТО.Склад			= РеквизитыШ.СкладПриемки;
	
	ОбъектХДТО.СостояниеСогласования_Покупатель	= ВыгрузитьПер_СостояниеСогласования(РеквизитыШ.СостояниеСогласования_Покупатель);
	ОбъектХДТО.СостояниеСогласования_Поставщик	= ВыгрузитьПер_СостояниеСогласования(РеквизитыШ.СостояниеСогласования_Поставщик);	
	
	ИмяТЧ	= "Товары";
	ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТипаХДТО+"."+ИмяТЧ);
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ЗНВПок

Функция ВыгрузитьДок_ЗРК_АКТ(ДокВыборка)	
	ИмяТаблицы		= "Документ.ЗаявкаНаРекламацию";	
	ИмяТипаХДТО		= "Документ.АктОРасхождениях";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"Товары");
	
	ОбъектХДТО.Подразделение	= РеквизитыШ.ПодразделениеФР;
	ОбъектХДТО.Организация	    = ПолучитьОрганизациюКонтрагента(РеквизитыШ.КонтрагентФР);	
	
	Если РеквизитыШ.СостояниеЗаявки = Перечисления.СостоянияКоррекции.ВРаботе Тогда
		ОбъектХДТО.Статус = "ВРаботе";
	ИначеЕсли РеквизитыШ.СостояниеЗаявки = Перечисления.СостоянияКоррекции.Отклонена Тогда		
		ОбъектХДТО.Статус = "Отклонен";
	ИначеЕсли РеквизитыШ.СостояниеЗаявки = Перечисления.СостоянияКоррекции.Принята Тогда		
		ОбъектХДТО.Статус = "Согласован";
	ИначеЕсли РеквизитыШ.СостояниеЗаявки = Перечисления.СостоянияКоррекции.Утверждена Тогда		
		ОбъектХДТО.Статус = "Согласован";
	ИначеЕсли РеквизитыШ.СостояниеЗаявки = Перечисления.СостоянияКоррекции.ПринятаЧастично Тогда		
		ОбъектХДТО.Статус = "СогласованЧастично";	
	КонецЕсли; 
	
	ИмяТЧ	= "Товары";
	ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТипаХДТО+"."+ИмяТЧ);
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ЗРК_АКТ

Функция ВыгрузитьДок_ИНВ_КС(РеквизитыШапки)
	
	КС_XDTO				= СоздатьОбъектХДТО("КлючевыеСвойстваИнвентаризацияТоваров");	
	
	КС_XDTO.Ссылка		= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	КС_XDTO.Дата		= РеквизитыШапки.Дата;
	КС_XDTO.Номер		= РеквизитыШапки.Номер; 
	КС_XDTO.Организация	= ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Склад_Организация);
	
	Возврат КС_XDTO;
	
КонецФункции //ВыгрузитьДок_ИНВ_КС(ДокСсылка)

Функция ВыгрузитьДок_ИНВ(ДокВыборка)
	Если 1=2 Тогда
		ДокСсылка=Документы.Инвентаризация.ПустаяСсылка();	
	КонецЕсли;
	
	ВидДокумента	= "ИнвентаризацияТоваров";
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		ИменаРеквизитов	= РеквизитыШапок.Получить("Документ.Инвентаризация");			
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,ИменаРеквизитов);		
	КонецЕсли;
	
	МетаОбъект	= ДокСсылка.Метаданные();
	
	ОбъектХДТО						= СоздатьОбъектХДТО("Документ."+ВидДокумента);	
	
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьДок_ИНВ_КС(РеквизитыШапки);		
	// + HELP-2150 20241118 Михайловский
	//ОбъектХДТО.Ответственный	= ВыгрузитьСпр_Пользователи_Элемент_КС(ДокСсылка.Автор);
	Попытка
		ОбъектХДТО.Ответственный	= ВыгрузитьСпр_Пользователи_Элемент_КС(ДокСсылка.Автор);
	Исключение
	КонецПопытки;
	// - HELP-2150 20241118 Михайловский
	ОбъектХДТО.Подразделение	= ВыгрузитьСпр_Подразделения_Элемент_КС(ДокСсылка.Склад.Подразделение);	
	ОбъектХДТО.Склад			= ВыгрузитьСпр_Склады_Элемент_КС(ДокСсылка.Склад);
	Если ЗначениеЗаполнено(ДокСсылка.Комментарий) Тогда
		ОбъектХДТО.Комментарий		= ДокСсылка.Комментарий;	
	КонецЕсли;	
	
	ТоварыХДТО	= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл	
		СтрокаХДТО						= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");			
		
		СтрокаХДТО.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		СтрокаХДТО.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ВыборкаПоТЧ.Единица);
		
		СтрокаХДТО.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаХДТО.КоличествоУчет		= ВыборкаПоТЧ.КоличествоРасч;
		
		СтрокаХДТО.Сумма				= ВыборкаПоТЧ.Цена*ВыборкаПоТЧ.КоличествоФакт;
		СтрокаХДТО.СуммаУчет			= ВыборкаПоТЧ.Цена*ВыборкаПоТЧ.КоличествоРасч;
		
		СтрокаХДТО.Цена					= ВыборкаПоТЧ.Цена;			
		СтрокаХДТО.ЦенаВРознице			= ВыборкаПоТЧ.Цена;
		СтрокаХДТО.ЦенаЗаУпаковку		= ВыборкаПоТЧ.Цена;			
		
		СтрокаХДТО.ТипЗапасов			= "СобственныеТовары";		
		
		ДобавитьЭлементХДТО(СтрокаХДТО,	ВыборкаПоТЧ.КоличествоФакт,	    "КоличествоФакт", 		"decimal", ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаХДТО,	ВыборкаПоТЧ.ЦенаОприходования,	"ЦенаОприходования",	"decimal", ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаХДТО,	ВыборкаПоТЧ.КоличествоОпр,		"КоличествоОпр", 	 	"decimal", ПространствоИмен_СТ);
		
		ТоварыХДТО.Строка.Добавить(СтрокаХДТО);		
	КонецЦикла;
		
	Если ТоварыХДТО.Строка.Количество()>0 Тогда
		ОбъектХДТО.Товары	= ТоварыХДТО;		
	КонецЕсли; 
	
	ДобавитьСостояниеНакладной(ОбъектХДТО, ДокСсылка.СостояниеНакладной);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,ДокСсылка.ГруппыТоваров,		"ГруппыТоваров",	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,ДокСсылка.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,ДокСсылка.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;	
КонецФункции

Функция ВыгрузитьДок_ОПР(ДокВыборка)
	ИмяТаблицы	= Метаданные.Документы.ОприходованиеТМЦ.ПолноеИмя();
	ИмяТипаХДТО	= ИмяТаблицы;
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ДокСсылка	= ВхПараметр.Ссылка;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ИменаТЧ	= "Товары";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ);		
	
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл	
		ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТаблицы+"."+ИмяТЧ);
	КонецЦикла;
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.Сертификаты=ТЧ_ХДТО;		
	КонецЕсли;
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьДокумент_ОПР(ДокВыборка)

Функция ВыгрузитьДок_ОПР_КС(РеквизитыШапки)
	
	КС_XDTO				= СоздатьОбъектХДТО("КлючевыеСвойстваОприходованиеТоваров");	
	
	КС_XDTO.Ссылка		= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	КС_XDTO.Дата		= РеквизитыШапки.Дата;
	КС_XDTO.Номер		= РеквизитыШапки.Номер; 
	КС_XDTO.Организация	= ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Организация);
	
	Возврат КС_XDTO;
	
КонецФункции //ВыгрузитьДокумент_КС_ОПР(ДокСсылка)

Функция ВыгрузитьДок_ОПР_ЕД(ДокВыборка)
	ВидДокумента= "ОприходованиеТоваров";
	
	Если 1=2 Тогда
		ДокСсылка=Документы.ОприходованиеТоваров.ПустаяСсылка();	
	КонецЕсли;	
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		ИменаРеквизитов	= РеквизитыШапок.Получить("Документ.ОприходованиеТМЦ");			
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,ИменаРеквизитов);		
	КонецЕсли;	
	
	ОбъектХДТО					= СоздатьОбъектХДТО("Документ."+ВидДокумента);	
	
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьДок_ОПР_КС(РеквизитыШапки);		
	
	УстановитьСвойствоХДТО(ОбъектХДТО,"Ответственный",ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШапки.Автор));
	ОбъектХДТО.Комментарий			= РеквизитыШапки.Комментарий;
	УстановитьСвойствоХДТО(ОбъектХДТО,"Подразделение",	ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШапки.Подразделение));
	УстановитьСвойствоХДТО(ОбъектХДТО,"Склад",			ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад));
	
	ТоварыХДТО	= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл	
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		СтрокаXDTO			= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ВыборкаПоТЧ.Единица);
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.Цена					= ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество;		
		
		СтрокаXDTO.ТипЗапасов			= "СобственныеТовары";
		
		ТоварыХДТО.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;	
	
	ОбъектХДТО.Товары	= ТоварыХДТО;
	
	ДобавитьСостояниеНакладной(ОбъектХДТО,ДокСсылка.СостояниеНакладной);
	
	ВалютаХДТО			= ВыгрузитьСпр_Валюты_КС(ДокВыборка.Валюта);
	ПодразделениеХДТО	= ВыгрузитьСпр_Подразделения_Элемент_КС(ДокВыборка.Подразделение);
	СтатьяЗатратХДТО	= ВыгрузитьСпр_СтатьиЗатрат_Элемент_КС(РеквизитыШапки.СтатьяЗатрат);
	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"Валюта",			ВалютаХДТО);	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"Подразделение",	ПодразделениеХДТО);	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"СтатьяЗатрат",	СтатьяЗатратХДТО);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Курс,				"Курс",				"decimal",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.ГруппыТоваров,	"ГруппыТоваров",	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Комментарий,		"Комментарий",		"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДокумент_ОПР(ДокВыборка)

Функция ВыгрузитьДок_ПКО(ДокВыборка)	
	ИмяТаблицы		= "Документ.ПриходныйКассовыйОрдер";	
	ИмяТипаХДТО		= ИмяТаблицы;
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТаблицы,ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"ВидОперации");
	
	УстановитьСвойствоХДТО(ОбъектХДТО,"ВидОперации",XMLСтрока(РеквизитыШ.ВидОперации));
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РКО(ДокВыборка)

Функция ВыгрузитьДок_ПНК_КС(ДокСсылка,ВидДокумента)
	КС_XDTO				= СоздатьОбъектХДТО("КлючевыеСвойства"+ВидДокумента);	
	
	КС_XDTO.Ссылка		= СериализаторXDTO.XMLСтрока(ДокСсылка);
	КС_XDTO.Дата		= ДокСсылка.Дата;
	КС_XDTO.Номер		= ДокСсылка.Номер; 
	КС_XDTO.Организация	= ВыгрузитьСпр_Организации_КС(ДокСсылка.Организация);
	КС_XDTO.Контрагент	= ВыгрузитьСпр_Контрагенты_Элемент_КС(ПоставщикДляПеремещений);
	
	Возврат КС_XDTO;
КонецФункции //Выгрузить_КС_ПНК(ДокСсылка,ВидДокумента)

Функция ВыгрузитьДок_ПНК(ДокСсылка)
	Если 1=2 Тогда
		ДокСсылка=Документы.ПриходнаяНакладная.ПустаяСсылка();	
	КонецЕсли;
	
	ВидДокумента="ПоступлениеТоваровУслуг";
	
	МетаОбъект	= ДокСсылка.Метаданные();	
	
	ОбъектХДТО						= СоздатьОбъектХДТО("Документ."+ВидДокумента);
	
	ОбъектХДТО.КлючевыеСвойства		= ВыгрузитьДок_ПНК_КС(ДокСсылка,ВидДокумента);		
	
	ТоварыXDTO						= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");
	
	Товары	= ПолучитьВыборкуТЧ(ДокСсылка);
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		СтрокаXDTO			= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(СтрокаТЧ.ДанныеНоменклатуры);
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(СтрокаТЧ.ДанныеОКЕИ);
		СтрокаXDTO.Количество			= СтрокаТЧ.Количество;
		СтрокаXDTO.Сумма				= СтрокаТЧ.Всего;
		СтрокаXDTO.Цена					= Окр(СтрокаТЧ.Всего/СтрокаТЧ.Количество,2,1);
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(СтрокаТЧ.СтавкаНДС);
		СтрокаXDTO.СуммаНДС				= СтрокаТЧ.НДС;
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ОбъектХДТО.Товары				= ТоварыXDTO;
	
	ОбъектХДТО.Валюта				= ВыгрузитьСпр_Валюты_КС(ДокСсылка.Валюта);
	ОбъектХДТО.ВидОперации			= "ПокупкаУПоставщика";
	ОбъектХДТО.Сумма				= ДокСсылка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС		= СериализаторXDTO.XMLСтрока(Истина);
	ОбъектХДТО.Подразделение		= ВыгрузитьСпр_Подразделения_Элемент_КС(ДокСсылка.Подразделение);	
	
	ОбъектХДТО.Склад				= ВыгрузитьСпр_Склады_Элемент_КС(ДокСсылка.Склад);
	ОбъектХДТО.ДанныеВзаиморасчетов	= Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(ДокСсылка.Валюта);
	
	ДобавитьСостояниеНакладной(ОбъектХДТО,ДокСсылка.СостояниеНакладной);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,ДокСсылка.Проведен,			"Проведен",			"boolean",ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,ДокСсылка.ПометкаУдаления,	"ПометкаУдаления",	"boolean",ПространствоИмен_СТ);
		
	Возврат ОбъектХДТО;
КонецФункции

Функция ВыгрузитьДок_ПНК_ВЗВ(ДокВыборка)
	Если 1=2 Тогда
		ДокСсылка=Документы.ПриходнаяНакладная.ПустаяСсылка();	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		РеквизитыШапки	= РеквизитыШапок.Получить("Документ.ПриходнаяНакладная");	
	КонецЕсли;	
	
	ОбъектХДТО				= СоздатьОбъектХДТО("Документ.ВозвратТоваровОтПокупателя");
	КлючевыеСвойстваXDTO	= СоздатьОбъектХДТО("КлючевыеСвойстваВозвратТоваровОтПокупателя");	
	
	КлючевыеСвойстваXDTO.Ссылка			= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	КлючевыеСвойстваXDTO.Дата			= РеквизитыШапки.Дата;
	КлючевыеСвойстваXDTO.Номер			= РеквизитыШапки.Номер; 
	КлючевыеСвойстваXDTO.Организация	= ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Организация);	
	
	ОбъектХДТО.КлючевыеСвойства			= КлючевыеСвойстваXDTO;		
	ОбъектХДТО.ВидОперации				= "ВозвратОтРозничногоПокупателя";	
		
	ОбъектХДТО.Валюта					= ВыгрузитьСпр_Валюты_КС(РеквизитыШапки.Валюта);
	ОбъектХДТО.Сумма					= ДокСсылка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС		= СериализаторXDTO.XMLСтрока(Истина);
	ОбъектХДТО.Подразделение			= ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШапки.Подразделение);
	ОбъектХДТО.Склад					= ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад);
	ОбъектХДТО.Контрагент				= ВыгрузитьСпр_Контрагенты_Элемент_КС(РеквизитыШапки.Контрагент);
	ОбъектХДТО.ДанныеВзаиморасчетов	= Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(РеквизитыШапки.Валюта);
	
	Если ЗначениеЗаполнено(РеквизитыШапки.ДокОснование) И ТипЗнч(РеквизитыШапки.ДокОснование)=Тип("ДокументСсылка.Чек") Тогда
		ОКС=НайтиОКСпоЧеку(РеквизитыШапки.ДокОснование);			
		Если ЗначениеЗаполнено(ОКС) Тогда		
			ДокументРеализацииОТ 								= ОбъектХДТО.Свойства().Получить("ДокументРеализации");			
			
    		ДокументРеализацииXDTO 								= Фабрика.Создать(ДокументРеализацииОТ.Тип);
			ДокументРеализацииXDTO.ОтчетОРозничныхПродажахСсылка= ВыгрузитьДок_ОКС_КС(ОКС);			
    		
    		ОбъектХДТО.ДокументРеализации 						= ДокументРеализацииXDTO;			
		КонецЕсли; 
	КонецЕсли; 
	
	ТоварыXDTO	= СоздатьОбъектХДТО("Документ.ВозвратТоваровОтПокупателя.Товары");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		СтрокаXDTO						= СоздатьОбъектХДТО("Документ.ВозвратТоваровОтПокупателя.Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.Цена					= ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество;
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);
		СтрокаXDTO.СуммаНДС				= ВыборкаПоТЧ.НДС;
		СтрокаXDTO.ВозвратПодДеятельность = "ОблагаетсяНДС";		
		
		ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.Количество,"Заявка","decimal",ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.Количество,"ПодтвержденнаяЗаявка","decimal",ПространствоИмен_СТ);
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;	
	
	КодОперацииXDTO	= СоздатьЗначениеХДТО("КодыОперацийОстатки","ВозвратОтПокупателя",ПространствоИмен_ЕЕ);	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"КодОперации",КодОперацииXDTO);
	
	ДобавитьСостояниеНакладной(ОбъектХДТО,ДокСсылка.СостояниеНакладной);			
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Проведен,			"Проведен",			"boolean",ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.ПометкаУдаления,	"ПометкаУдаления",	"boolean",ПространствоИмен_СТ);
		
	Возврат ОбъектХДТО;
КонецФункции

Функция ВыгрузитьДок_ПРМ_ПНК_ЕЕ(ДокВыборка)	
	ИмяТаблицы		= "Документ.Перемещение";	
	ИмяТипаХДТО		= "Документ.ПриходнаяНакладная";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекСклад				= ?(ЗначениеЗаполнено(ДокВыборка.СкладПолучатель_ДИ),ДокВыборка.СкладПолучатель_ДИ,ДокВыборка.СкладПолучатель);
	ТекОрганизация 			= ?(ЗначениеЗаполнено(ТекСклад),ПолучитьРеквизитШапки(ТекСклад,"Организация"),РеквизитыШ.Контрагент);	
	ТекПодразделение		= ?(ЗначениеЗаполнено(ДокВыборка.ПодразделениеПолучатель_ДИ),ДокВыборка.ПодразделениеПолучатель_ДИ,ДокВыборка.Подразделение);	
	
	Если НЕ ЗначениеЗаполнено(ТекПодразделение) Тогда
		ТекПодразделение	= ФранчПодразделениеСсылки(РеквизитыШ.ПунктДоставки);			
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ТекСклад) Тогда
		ТекСклад	= ПолучитьРеквизитШапки(ТекПодразделение,"ОсновнойСклад","Справочник");	
	КонецЕсли; 
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ОбъектХДТО.Ссылка		= РеквизитыШ.Ссылка;
	
	ОбъектХДТО.Дата							= РеквизитыШ.Дата;
	ОбъектХДТО.Номер						= РеквизитыШ.Номер;	
	ОбъектХДТО.ДатаВходящегоДокумента		= РеквизитыШ.Дата;
	ОбъектХДТО.НомерВходящегоДокумента		= РеквизитыШ.Номер;	
	ОбъектХДТО.ВидВходящегоДокумента		= "ПРМ";
	ОбъектХДТО.СостояниеНакладнойУПоставщика = РеквизитыШ.СостояниеНакладной;	
	
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Подразделение	= ТекПодразделение;		
	ОбъектХДТО.Склад			= ТекСклад;		
	
	Если ЗначениеЗаполнено(РеквизитыШ.Контрагент) Тогда	
		ОбъектХДТО.Контрагент	= РеквизитыШ.Контрагент;	
	Иначе		
		ОбъектХДТО.Контрагент	= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.Организация.УникальныйИдентификатор());
	КонецЕсли; 
	
	//ОбъектХДТО.Договор		= РеквизитыШ.Договор;	
	
	ОбъектХДТО.Валюта		= ДокВыборка.Валюта;
	ОбъектХДТО.Курс			= ДокВыборка.Курс;
	
	ОбъектХДТО.Комментарий	= РеквизитыШ.Комментарий;	
	
	ОбъектХДТО.Менеджер		= РеквизитыШ.Менеджер;
	ОбъектХДТО.Автор		= РеквизитыШ.Автор;
	
	СуммаДокумента			= 0;
	ТоварыXDTO				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;	
		
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ,,"Единица");
		СтрокаТЧ_ХДТО.Единица	= Ед_Штука;
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		
		ПроцентНДС	= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаТЧ_ХДТО.Цена			= Окр(?(ВыборкаПоТЧ.Количество=0,0,ВыборкаПоТЧ.Себестоимость/ВыборкаПоТЧ.Количество),2,1);		
		СтрокаТЧ_ХДТО.Всего			= ВыборкаПоТЧ.Себестоимость;
		//+HELP-2538 20250115 Михайловский
		//меняю
		//СтрокаТЧ_ХДТО.СуммаБезНДС	= ВыборкаПоТЧ.Себестоимость*ПроцентНДС/(1+ПроцентНДС);
		//СтрокаТЧ_ХДТО.НДС			= СтрокаТЧ_ХДТО.Всего-СтрокаТЧ_ХДТО.СуммаБезНДС;
		
		СтрокаТЧ_ХДТО.НДС	= ВыборкаПоТЧ.Себестоимость * ПроцентНДС /(1 + ПроцентНДС);
		СтрокаТЧ_ХДТО.СуммаБезНДС			= СтрокаТЧ_ХДТО.Всего - СтрокаТЧ_ХДТО.НДС;
		//-HELP-2538 20250115 Михайловский
		СуммаДокумента	= СуммаДокумента+ВыборкаПоТЧ.Себестоимость;
		
		ТоварыXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;	
	
	ОбъектХДТО.КодОперации				= Перечисления.КодыОперацийОстатки.Закупка;
	ОбъектХДТО.Сумма					= ДокВыборка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);	
	
	ОбъектХДТО.СуммаДокумента			= СуммаДокумента;	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.Сертификаты=ТЧ_ХДТО;		
	КонецЕсли; 
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РНК_ПНК_ЕЕ

Функция ВыгрузитьДок_ПРМ_ПНК_ЕД(ДокВыборка)
	ИмяТаблицы		= "Документ.Перемещение";
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"ПРМ_ПНК");	
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	//ЮрЛицоФранча	= РегистрыСведений.ФР_ЮрЛицаПодразделений.ПолучитьЮрЛицо(РеквизитыШапки.Подразделение,РеквизитыШапки.Дата);
	
	ОбъектХДТО						= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг");
	КС_XDTO							= СоздатьОбъектХДТО("КлючевыеСвойстваПоступлениеТоваровУслуг");	
	
	КС_XDTO.Ссылка					= СериализаторXDTO.XMLСтрока(РеквизитыШ.Ссылка);
	КС_XDTO.Дата					= РеквизитыШ.Дата;
	КС_XDTO.Номер					= РеквизитыШ.Номер;	
	
	КС_XDTO.Организация	= ВыгрузитьСпр_Организации_КС(РеквизитыШ.СкладПолучатель_Организация);
	КС_XDTO.Контрагент	= ВыгрузитьСпр_Контрагенты_Элемент_КС(РеквизитыШ.Контрагент);
	
	ОбъектХДТО.КлючевыеСвойства		= КС_XDTO;	
	
	СуммаДокумента	=0; 
	
	ТоварыXDTO	= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Товары");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл	
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		ПроцентНДС			= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаХДТО			= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Товары.Строка");
		
		СтрокаХДТО.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		
		ТекЕдиница						= ?(ЗначениеЗаполнено(ВыборкаПоТЧ.Единица),ВыборкаПоТЧ.Единица,Ед_Штука);
		СтрокаХДТО.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ТекЕдиница);		
		
		СтрокаХДТО.Количество			= ВыборкаПоТЧ.Количество;
		
		СтрокаХДТО.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаХДТО.Цена					= ВыборкаПоТЧ.Цена;
		СтрокаХДТО.ЦенаЗаУпаковку		= Окр(ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество,2,1);
		СтрокаХДТО.КоличествоУпаковок	= ВыборкаПоТЧ.Количество;
		СтрокаХДТО.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);
		СтрокаХДТО.СуммаНДС				= ВыборкаПоТЧ.НДС;
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;		
		
		ДобавитьЭлементХДТО(СтрокаХДТО,ВыборкаПоТЧ.Заявка,				"Заявка",				"decimal",ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаХДТО,ВыборкаПоТЧ.ПодтвержденнаяЗаявка,"ПодтвержденнаяЗаявка",	"decimal",ПространствоИмен_СТ);
		
		ТоварыXDTO.Строка.Добавить(СтрокаХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;
	
	ОбъектХДТО.Валюта					= ВыгрузитьСпр_Валюты_КС(РеквизитыШ.Валюта);
	ОбъектХДТО.ВидОперации				= "ПокупкаУПоставщика";
	ОбъектХДТО.Сумма					= ДокВыборка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);
	ОбъектХДТО.Подразделение			= ВыгрузитьСпр_Подразделения_Элемент_КС(ДокВыборка.Подразделение);
	ОбъектХДТО.Склад					= ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШ.СкладПолучатель);
	ОбъектХДТО.ДанныеВзаиморасчетов		= Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(РеквизитыШ.Валюта);	
	
	КодОперацииXDTO	= Фабрика.Создать(Фабрика.Тип(ПространствоИмен_ЕЕ,"КодыОперацийОстатки"),"Закупка");	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"КодОперации",КодОперацииXDTO);	
		
	ДобавитьСостояниеНакладной(ОбъектХДТО,РеквизитыШ.СостояниеНакладной,"УПоставщика");
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ГруппыТоваров,	"ГруппыТоваров",	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Комментарий,		"Комментарий",		"string",	ПространствоИмен_СТ);
	ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШ.Автор),"Автор",	ПространствоИмен_ЕД);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
		
	Возврат ОбъектХДТО;
КонецФункции

Функция ВыгрузитьДок_ПРМ_ПРМ_ЕД(ДокСсылка)
	Если 1=2 Тогда
		ДокСсылка=Документы.Перемещение.ПустаяСсылка();	
	КонецЕсли;
	
	МетаОбъект	= ДокСсылка.Метаданные();
	
	ВидДокумента="ПеремещениеТоваров";		
	
	ЭлементXDTO				= СоздатьОбъектХДТО("Документ."+ВидДокумента);
	КлючевыеСвойстваXDTO	= СоздатьОбъектХДТО("КлючевыеСвойства"+ВидДокумента);	
	
	КлючевыеСвойстваXDTO.Ссылка			= СериализаторXDTO.XMLСтрока(ДокСсылка);
	КлючевыеСвойстваXDTO.Дата			= ДокСсылка.Дата;
	КлючевыеСвойстваXDTO.Номер			= ДокСсылка.Номер; 
	КлючевыеСвойстваXDTO.Организация	= ВыгрузитьСпр_Организации_КС(ДокСсылка.Организация);	
	
	ЭлементXDTO.КлючевыеСвойства		= КлючевыеСвойстваXDTO;	
	
	ЭлементXDTO.Комментарий				= ДокСсылка.Комментарий;
	
	ЭлементXDTO.СкладОтправитель		= ВыгрузитьСпр_Склады_Элемент_КС(ДокСсылка.Склад);
	ЭлементXDTO.СкладПолучатель			= ВыгрузитьСпр_Склады_Элемент_КС(ДокСсылка.СкладПолучатель);
	Товары		= ПолучитьВыборкуТЧ(ДокСсылка);
	ТоварыXDTO	= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");
	Для Каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		ПроцентНДС			= ПроцентНДСпоСтавке(СтрокаТЧ.СтавкаНДС);
		
		СтрокаXDTO			= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(СтрокаТЧ.ДанныеНоменклатуры);
		ЕдиницаИзмерения				= ВыгрузитьСпр_Единицы_Элемент_КС(СтрокаТЧ.ДанныеОКЕИ);
		Если ЕдиницаИзмерения<>Неопределено Тогда
			СтрокаXDTO.ЕдиницаИзмерения	= ЕдиницаИзмерения;		
		Иначе
			Сообщить_("Ай ай ! "+ДокСсылка+" "+СтрокаТЧ.Количество,СтатусСообщения.Важное);
			СтрокаXDTO.ЕдиницаИзмерения	= ВыгрузитьСпр_Единицы_Элемент_КС(ДанныеШтуки);
		КонецЕсли;
		
		СтрокаXDTO.Количество			= СтрокаТЧ.Количество;
		СтрокаXDTO.КоличествоУпаковок	= СтрокаТЧ.Количество;		
		
		СтрокаXDTO.ТипЗапасов			= "СобственныеТовары";
		
		СтрокаXDTO.ЦенаВРознице			= Окр(СтрокаТЧ.Цена,2,1);		
		СтрокаXDTO.СуммаВРознице		= СтрокаТЧ.Цена*СтрокаТЧ.Количество;
		СтрокаXDTO.СтавкаНДСВРознице	= ВыгрузитьПер_СтавкаНДС(СтрокаТЧ.СтавкаНДС);
		
		//СтрокаXDTO.Цена					= Окр(СтрокаXDTO.Сумма/СтрокаТЧ.Количество,2,1);		
		//СтрокаXDTO.СуммаНДС				= Окр(СтрокаXDTO.Сумма*ПроцентНДС/(100+ПроцентНДС),2,1);
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ЭлементXDTO.Товары					= ТоварыXDTO;	

	//+ HELP-1519 20241015 Михайловский
	//ДобавитьСостояниеНакладной(ЭлементXDTO,ДокСсылка.СостояниеНакладной);	
	//ДобавитьСостояниеНакладной(ЭлементXDTO,ДокСсылка.СостояниеНакладнойУПолучателя,"УПолучателя");
	ДобавитьСостояниеНакладной(ЭлементXDTO,XMLСтрока(ДокСсылка.СостояниеНакладной));	
	ДобавитьСостояниеНакладной(ЭлементXDTO,XMLСтрока(ДокСсылка.СостояниеНакладнойУПолучателя),"УПолучателя");
	//- HELP-1519 20241015 Михайловский
		
	Возврат ЭлементXDTO;
КонецФункции

Функция ВыгрузитьДок_ПРМ_ПРМ_ЕЕ(ДокВыборка)	
	ИмяТаблицы		= "Документ.Перемещение";	
	ИмяТипаХДТО		= "Документ.Перемещение";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка		= ВхПараметр.Ссылка;
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	ИменаТЧ			= "Товары";
	//+ HELP-1519 20241015 Михайловский
	//ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ+",СостояниеНакладной,СостояниеНакладнойУПолучателя");
	ОбъектХДТО.СостояниеНакладной				= XMLСтрока(ДокСсылка.СостояниеНакладной);
	ОбъектХДТО.СостояниеНакладнойУПолучателя	= XMLСтрока(ДокСсылка.СостояниеНакладнойУПолучателя);
	//- HELP-1519 20241015 Михайловский
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл	
		ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТаблицы+"."+ИмяТЧ);
	КонецЦикла;
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.Сертификаты=ТЧ_ХДТО;		
	КонецЕсли;
			
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ПРМ_ПРМ_ЕЕ

Функция ВыгрузитьДок_ПРМ_РНК_ЕД(ДокВыборка)
	Если 1=2 Тогда
		ДокСсылка=Документы.Перемещение.ПустаяСсылка();	
	КонецЕсли;
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		РеквизитыШапки	= РеквизитыШапок.Получить("Документ.Перемещение_ПРМ_РНК");	
	КонецЕсли;
	
	ВидДокумента	= "РеализацияТоваровУслуг";
	
	ЭлементXDTO				= СоздатьОбъектХДТО("Документ."+ВидДокумента);
	КлючевыеСвойстваXDTO	= СоздатьОбъектХДТО("КлючевыеСвойства"+ВидДокумента);	
	
	КлючевыеСвойстваXDTO.Ссылка			= СериализаторXDTO.XMLСтрока(РеквизитыШапки.Ссылка);
	КлючевыеСвойстваXDTO.Дата			= РеквизитыШапки.Дата;
	КлючевыеСвойстваXDTO.Номер			= РеквизитыШапки.Номер; 
	КлючевыеСвойстваXDTO.Организация	= ВыгрузитьСпр_Организации_КС(РеквизитыШапки.Контрагент);	
	
	ЭлементXDTO.КлючевыеСвойства		= КлючевыеСвойстваXDTO;	
	
	ЭлементXDTO.ВидОперации				= "РеализацияКлиенту";
	ЭлементXDTO.Валюта					= ВыгрузитьСпр_Валюты_КС(РеквизитыШапки.Валюта);
	ЭлементXDTO.Сумма					= РеквизитыШапки.СуммаДокумента;	
	ЭлементXDTO.Склад					= ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад);
	ЭлементXDTO.Контрагент				= ВыгрузитьСпр_Контрагенты_Элемент_КС(РеквизитыШапки.Организация);
	ЭлементXDTO.ДанныеВзаиморасчетов	= Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(РеквизитыШапки.Валюта);
		
	СтрокаТЧ		= ПолучитьВыборкуТЧ(ДокВыборка.Ссылка);
	ТоварыXDTO		= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");
	Пока СтрокаТЧ.Следующий() Цикл	
		Если СтрокаТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		ПроцентНДС			= ПроцентНДСпоСтавке(СтрокаТЧ.СтавкаНДС);
		
		СтрокаXDTO			= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(СтрокаТЧ.Номенклатура,СтрокаТЧ.Характеристика);		
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(Ед_Штука);
		
		СтрокаXDTO.Количество			= СтрокаТЧ.Количество;
		
		Сумма							= СтрокаТЧ.Себестоимость;
		
		СтрокаXDTO.Сумма				= Сумма;
		СтрокаXDTO.Цена					= Окр(Сумма/СтрокаТЧ.Количество,2,1);
		СтрокаXDTO.ЦенаЗаУпаковку		= Окр(Сумма/СтрокаТЧ.Количество,2,1);
		СтрокаXDTO.КоличествоУпаковок	= СтрокаТЧ.Количество;
		СтрокаXDTO.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(СтрокаТЧ.СтавкаНДС);
		СтрокаXDTO.СуммаНДС				= Окр(Сумма*ПроцентНДС/(100+ПроцентНДС),2,1);
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;
	
	ЭлементXDTO.Товары	= ТоварыXDTO;		
	
	ДобавитьСостояниеНакладной(ЭлементXDTO,РеквизитыШапки.СостояниеНакладной);
	ДобавитьЭлементХДТО(ЭлементXDTO,РеквизитыШапки.Проведен,		"Проведен",			"boolean",ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ЭлементXDTO,РеквизитыШапки.ПометкаУдаления, "ПометкаУдаления",	"boolean",ПространствоИмен_СТ);
	
	Возврат ЭлементXDTO;
КонецФункции

Функция ВыгрузитьДок_ПРМ_РНК_ЕЕ(ДокВыборка)	
	ИмяТаблицы		= "Документ.Перемещение";	
	ИмяТипаХДТО		= "Документ.РасходнаяНакладная";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекСклад				= РеквизитыШ.Склад;
	ТекОрганизация 			= ?(ЗначениеЗаполнено(ТекСклад),ПолучитьРеквизитШапки(ТекСклад,"Организация"),РеквизитыШ.Контрагент);
	ТекПодразделение		= ДокВыборка.Склад_Подразделение;	
	
	Если НЕ ЗначениеЗаполнено(ТекПодразделение) Тогда
		ТекПодразделение	= ПолучитьРеквизитШапки(ТекСклад,"Подразделение");;			
	КонецЕсли;	
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ОбъектХДТО.Ссылка		= РеквизитыШ.Ссылка;
	
	ОбъектХДТО.Дата							= РеквизитыШ.Дата;
	ОбъектХДТО.Номер						= РеквизитыШ.Номер;	
	ОбъектХДТО.ДатаВходящегоДокумента		= РеквизитыШ.Дата;
	ОбъектХДТО.НомерВходящегоДокумента		= РеквизитыШ.Номер;	
	ОбъектХДТО.ВидВходящегоДокумента		= "ПРМ";
	ОбъектХДТО.СостояниеНакладной			= РеквизитыШ.СостояниеНакладной;	
	
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Подразделение	= ТекПодразделение;		
	ОбъектХДТО.Склад			= ТекСклад;		
	
	ОбъектХДТО.Контрагент		= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.СкладПолучатель_Организация.УникальныйИдентификатор());	
	//ОбъектХДТО.Договор		= РеквизитыШ.Договор;	
	
	ОбъектХДТО.Валюта		= ДокВыборка.Валюта;
	ОбъектХДТО.Курс			= ДокВыборка.Курс;
	
	ОбъектХДТО.Комментарий	= РеквизитыШ.Комментарий;	
	
	ОбъектХДТО.Менеджер		= РеквизитыШ.Автор_ФизЛицо;
	ОбъектХДТО.Автор		= РеквизитыШ.Автор;
	
	СуммаДокумента			= 0;
	ТоварыXDTO				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;	
		
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ,,"Единица");
		СтрокаТЧ_ХДТО.Единица	= Ед_Штука;
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		
		ПроцентНДС	= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаТЧ_ХДТО.Цена			= Окр(?(ВыборкаПоТЧ.Количество=0,0,ВыборкаПоТЧ.Себестоимость/ВыборкаПоТЧ.Количество),2,1);		
		СтрокаТЧ_ХДТО.Всего			= ВыборкаПоТЧ.Себестоимость;
		//+HELP-2538 20250115 Михайловский
		//меняю
		//СтрокаТЧ_ХДТО.СуммаБезНДС	= ВыборкаПоТЧ.Себестоимость*ПроцентНДС/(1+ПроцентНДС);
		//СтрокаТЧ_ХДТО.НДС			= СтрокаТЧ_ХДТО.Всего-СтрокаТЧ_ХДТО.СуммаБезНДС;
		СтрокаТЧ_ХДТО.НДС = ВыборкаПоТЧ.Себестоимость * ПроцентНДС/(1 + ПроцентНДС);
		СтрокаТЧ_ХДТО.СуммаБезНДС			= СтрокаТЧ_ХДТО.Всего - СтрокаТЧ_ХДТО.НДС;
		//-HELP-2538 20250115 Михайловский
		СуммаДокумента	= СуммаДокумента+ВыборкаПоТЧ.Себестоимость;
		
		ТоварыXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;	
	
	ОбъектХДТО.КодОперации				= Перечисления.КодыОперацийОстатки.ВозвратПоставщику;
	ОбъектХДТО.Сумма					= ДокВыборка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);	
	
	ОбъектХДТО.СуммаДокумента			= СуммаДокумента;	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".ПодарочныеСертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".ПодарочныеСертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.ПодарочныеСертификаты=ТЧ_ХДТО;		
	КонецЕсли; 
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ПРМ_РНК_ЕЕ

Функция ВыгрузитьДок_ПС_КС(ДокВыборка)
	ИмяТаблицы	= "Документ.ПереводСредств";
	ИмяТипаХДТО	= "Документ.ПеремещениеДС.КС";
	
	Если 1=2 Тогда
		ДокСсылка=Документы.ПереводСредств.ПустаяСсылка();	
	КонецЕсли;
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"КС");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= ПолучитьИзКэша(РеквизитыШ.Ссылка,ИмяТаблицы);
	Если ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда
		ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
		
		ОбъектХДТО.Ссылка	= РеквизитыШ.Ссылка;
		ОбъектХДТО.Номер	= РеквизитыШ.Номер;
		ОбъектХДТО.Дата		= РеквизитыШ.Дата;
		
		ВставитьВКэш(ДокСсылка,ОбъектХДТО,ИмяТаблицы);		
	КонецЕсли; 
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_ПС_КС(ДокВыборка)

Функция ВыгрузитьДок_ПС(ДокВыборка)
	ИмяТаблицы	= "Документ.ПереводСредств";
	ИмяТипаХДТО	= "Документ.ПеремещениеДенежныхСредств";
	
	Если 1=2 Тогда
		ДокСсылка=Документы.ПереводСредств.ПустаяСсылка();	
	КонецЕсли;
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО							= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ОбъектХДТО.Ссылка					= РеквизитыШ.Ссылка;		
	ОбъектХДТО.Дата						= РеквизитыШ.Дата;		
	ОбъектХДТО.Номер					= РеквизитыШ.Номер;
	ОбъектХДТО.Автор					= РеквизитыШ.Автор;
	ОбъектХДТО.Организация				= РеквизитыШ.Организация;	
	ОбъектХДТО.СтатьяДДС				= РеквизитыШ.СтатьяДДС;
	
	ОбъектХДТО.СуммаДокумента			= РеквизитыШ.СуммаДокумента;
	ОбъектХДТО.Валюта					= РеквизитыШ.Валюта;
	ОбъектХДТО.Курс						= РеквизитыШ.Курс;
	
	ОбъектХДТО.Источник_Подразделение	= РеквизитыШ.Источник_Подразделение;
	ОбъектХДТО.Источник_Касса			= РеквизитыШ.Источник_Касса;
	
	ОбъектХДТО.Получатель_Подразделение	= РеквизитыШ.Получатель_Подразделение;
	ОбъектХДТО.Получатель_Касса			= РеквизитыШ.Получатель_Касса;
	
	ОбъектХДТО.Комментарий				= РеквизитыШ.Комментарий;	
	ОбъектХДТО.ВидОперации				= РеквизитыШ.ВидОперации;
	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
			
	Возврат ОбъектХДТО;	
КонецФункции

Функция ВыгрузитьДок_РНК_ПНК(ДокВыборка)	
	ИмяТаблицы		= "Документ.РасходнаяНакладная";	
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекСклад				= ?(ЗначениеЗаполнено(ДокВыборка.СкладПолучатель_ДИ),ДокВыборка.СкладПолучатель_ДИ,ДокВыборка.Склад);
	ТекОрганизация 			= ?(ЗначениеЗаполнено(ТекСклад),ПолучитьРеквизитШапки(ТекСклад,"Организация"),РеквизитыШ.Контрагент);	
	
	ОбъектХДТО				= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг");
	КлючевыеСвойстваXDTO	= СоздатьОбъектХДТО("КлючевыеСвойстваПоступлениеТоваровУслуг");	
	
	КлючевыеСвойстваXDTO.Ссылка			= СериализаторXDTO.XMLСтрока(РеквизитыШ.Ссылка);
	КлючевыеСвойстваXDTO.Дата			= РеквизитыШ.Дата;
	КлючевыеСвойстваXDTO.Номер			= РеквизитыШ.Номер; 
	КлючевыеСвойстваXDTO.Организация	= ВыгрузитьСпр_Организации_КС(ТекОрганизация);
	КлючевыеСвойстваXDTO.Контрагент		= ВыгрузитьСпр_Контрагенты_Элемент_КС(РеквизитыШ.Организация);
	
	ОбъектХДТО.КлючевыеСвойства			= КлючевыеСвойстваXDTO;	
	
	СуммаДокумента	= 0; 
	
	
	ТоварыXDTO	= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Товары");	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		ПроцентНДС			= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);
		
		СтрокаХДТО						= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Товары.Строка");
		
		СтрокаХДТО.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		
		ТекЕдиница						= ?(ЗначениеЗаполнено(ВыборкаПоТЧ.Единица),ВыборкаПоТЧ.Единица,Ед_Штука);		
		
		Если ВыборкаПоТЧ.Характеристика.Родитель.Код<>ВыборкаПоТЧ.Номенклатура.Код Тогда
			Сообщить_("ой ой");		
		КонецЕсли; 
		
		СтрокаХДТО.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ТекЕдиница);		
		
		СтрокаХДТО.Количество			= ВыборкаПоТЧ.Количество;
		
		СтрокаХДТО.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаХДТО.Цена					= Окр(ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество,2,1);
		СтрокаХДТО.ЦенаЗаУпаковку		= Окр(ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество,2,1);
		СтрокаХДТО.КоличествоУпаковок	= ВыборкаПоТЧ.Количество;
		СтрокаХДТО.СтавкаНДС			= ВыгрузитьПер_СтавкаНДС(ВыборкаПоТЧ.СтавкаНДС);
		СтрокаХДТО.СуммаНДС				= ВыборкаПоТЧ.НДС;
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		ДобавитьЭлементХДТО(СтрокаХДТО,ВыборкаПоТЧ.Заявка,				"Заявка",				"decimal",ПространствоИмен_СТ);
		ДобавитьЭлементХДТО(СтрокаХДТО,ВыборкаПоТЧ.ПодтвержденнаяЗаявка,"ПодтвержденнаяЗаявка",	"decimal",ПространствоИмен_СТ);		
		
		СуммаДокумента	= СуммаДокумента+ВыборкаПоТЧ.Всего;
		
		ТоварыXDTO.Строка.Добавить(СтрокаХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;
	
	ОбъектХДТО.Валюта					= ВыгрузитьСпр_Валюты_КС(ДокВыборка.Валюта);
	ОбъектХДТО.ВидОперации				= "ПокупкаУПоставщика";
	ОбъектХДТО.Сумма					= ДокВыборка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);	
	
	ТекПодразделение					= ?(ЗначениеЗаполнено(ДокВыборка.ПодразделениеПолучатель_ДИ),ДокВыборка.ПодразделениеПолучатель_ДИ,ДокВыборка.Подразделение);
	УстановитьСвойствоХДТО(ОбъектХДТО,"Подразделение",ВыгрузитьСпр_Подразделения_Элемент_КС(ТекПодразделение));	
	
	УстановитьСвойствоХДТО(ОбъектХДТО,"Склад",ВыгрузитьСпр_Склады_Элемент_КС(ТекСклад));	
	
	ОбъектХДТО.ДанныеВзаиморасчетов		= Выгрузить_ОбщиеСвойстваДанныеВзаиморасчетов(РеквизитыШ.Валюта,РеквизитыШ.Договор,Истина);
	ОбъектХДТО.Комментарий				= РеквизитыШ.Комментарий;
	
	КодОперацииXDTO	= Фабрика.Создать(Фабрика.Тип(ПространствоИмен_ЕЕ,"КодыОперацийОстатки"),"Закупка");	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕЕ,"КодОперации",КодОперацииXDTO);
	
	СуммаДокументаXDTO = Фабрика.Создать(Фабрика.Тип(ПространствоИмен_СТ,"float"),СуммаДокумента);
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"СуммаДокумента",СуммаДокументаXDTO);
		
	ДобавитьСостояниеНакладной(ОбъектХДТО,РеквизитыШ.СостояниеНакладной,"УПоставщика");	
	
	ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_ФизическиеЛица_Элемент_КС(РеквизитыШ.Менеджер),"Менеджер",	ПространствоИмен_ЕД);
	ДобавитьСвойствоХДТО(ОбъектХДТО,ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШ.Автор),		"Автор",	ПространствоИмен_ЕД);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ХПС_ОбъектХДТО	= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Сертификаты",ПространствоИмен_ЕЕ);
		
		ХПС_Объект		= ХПС_Ссылка.ПолучитьОбъект();
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл
			ОбработкаПрерыванияПользователя_();
			
			СертификатХДТО			= ВыгрузитьСпр_ПодарочныеСертификаты_КС(ВыборкаПоТЧ.Сертификат);
			Если СертификатХДТО<>Неопределено Тогда
				СтрокаХДТО				= СоздатьОбъектХДТО("Документ.ПоступлениеТоваровУслуг.Сертификаты.Строка",ПространствоИмен_ЕЕ);			
				СтрокаХДТО.Сертификат	= СертификатХДТО;
			
				ХПС_ОбъектХДТО.Строка.Добавить(СтрокаХДТО);			
			КонецЕсли;			
		КонецЦикла;
		
		ДобавитьСвойствоХДТО(ОбъектХДТО,ХПС_ОбъектХДТО,"Сертификаты",ПространствоИмен_ЕЕ);		
	КонецЕсли; 
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РНК_ПНК

Функция ВыгрузитьДок_РНК_ПНК_ЕЕ(ДокВыборка)	
	ИмяТаблицы		= "Документ.РасходнаяНакладная";	
	ИмяТипаХДТО		= "Документ.ПриходнаяНакладная";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекСклад				= ПрочитатьЗначениеСвойства(ДокСсылка,СВ_СкладПолРНК);	
	ТекПодразделение		= ПрочитатьЗначениеСвойства(ДокСсылка,СВ_ПодразделениеРНК);	
	Если НЕ ЗначениеЗаполнено(ТекПодразделение) Тогда
		ТекПодразделение	= ФранчПодразделениеСсылки(РеквизитыШ.ПунктДоставки);		
	КонецЕсли;	
	ТекОрганизация 			= ПрочитатьЗначениеСвойства(РеквизитыШ.Контрагент,СВ_ОрганизацияКонтр);
	Если НЕ ЗначениеЗаполнено(ТекОрганизация) Тогда	
		ТекОрганизация		= ОрганизацияПодразделения(ТекПодразделение);
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(ТекСклад) И ЗначениеЗаполнено(ТекПодразделение) Тогда //Из подчиненных документов брать нельзя - там каша иногда
		ТекСклад	= ПолучитьРеквизитШапки(ТекПодразделение,"ОсновнойСклад","Справочник");	
	КонецЕсли; 
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ОбъектХДТО.Ссылка		= РеквизитыШ.Ссылка;
	
	ОбъектХДТО.Дата							= РеквизитыШ.Дата;
	ОбъектХДТО.Номер						= РеквизитыШ.Номер;	
	ОбъектХДТО.ДатаВходящегоДокумента		= РеквизитыШ.Дата;
	ОбъектХДТО.НомерВходящегоДокумента		= РеквизитыШ.Номер;	
	ОбъектХДТО.ВидВходящегоДокумента		= "РНК";	
	ОбъектХДТО.СостояниеНакладнойУПоставщика = РеквизитыШ.СостояниеНакладной;	
	
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Подразделение	= ТекПодразделение;		
	ОбъектХДТО.Склад			= ТекСклад;		
	
	ОбъектХДТО.Контрагент	= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.Организация.УникальныйИдентификатор());	
	ОбъектХДТО.Договор		= РеквизитыШ.Договор;	
	
	ОбъектХДТО.Валюта		= ДокВыборка.Валюта;
	ОбъектХДТО.Курс			= ДокВыборка.Курс;
	
	ОбъектХДТО.Комментарий	= РеквизитыШ.Комментарий;	
	
	ОбъектХДТО.Менеджер		= РеквизитыШ.Менеджер;
	ОбъектХДТО.Автор		= РеквизитыШ.Автор;
	ОбъектХДТО.ГруппыТоваров= РеквизитыШ.ГруппыТоваров;
	
	СуммаДокумента			= 0;
	ТоварыXDTO				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);	
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;	
		
		СтрокаТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ,,"Единица");
		СтрокаТЧ_ХДТО.Единица	= Ед_Штука;
		
		//ГТД=ПолучитьГрупповойПериодическийРеквизит(СтрокаТЧ.Номенклатура.Родитель,"НомерГТД",ДокСсылка.Дата);
		//Если ЗначениеЗаполнено(ГТД) Тогда
		//	СтрокаXDTO.ДанныеГТД		= Выгрузить_ОбщиеСвойстваДанныеНомераГТД(ГТД);	
		//КонецЕсли;
		
		СуммаДокумента	= СуммаДокумента+ВыборкаПоТЧ.Всего;
		
		ТоварыXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);		
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;	
	
	ОбъектХДТО.КодОперации				= Перечисления.КодыОперацийОстатки.Закупка;
	ОбъектХДТО.Сумма					= ДокВыборка.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);	
	
	ОбъектХДТО.СуммаДокумента			= СуммаДокумента;	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.Сертификаты=ТЧ_ХДТО;		
	КонецЕсли; 
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РНК_ПНК_ЕЕ

Функция ВыгрузитьДок_РКМ_КП(ДокВыборка)	
	ИмяТаблицы		= "Документ.РекламационнаяНакладная";	
	ИмяТипаХДТО		= "Документ.КорректировкаПоступления";
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	ДокСсылка				= ВхПараметр.Ссылка;
	РеквизитыШ				= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	ТекПодразделение		= ФранчПодразделениеСсылки(РеквизитыШ.ПунктДоставки);
	ТекОрганизация 			= ОрганизацияПодразделения(ТекПодразделение);	
	
	ОбъектХДТО				= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ИменаТЧ	= "Товары";	
	
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ+",Номер");
	
	ОбъектХДТО.ДатаВходящегоДокумента	= РеквизитыШ.Дата;
	ОбъектХДТО.НомерВходящегоДокумента	= РеквизитыШ.Номер;	
	ОбъектХДТО.ВидВходящегоДокумента	= ""+ДокСсылка.Метаданные();	
	
	ОбъектХДТО.Организация		= Справочники.Организации.ПолучитьСсылку(ТекОрганизация.УникальныйИдентификатор());
	ОбъектХДТО.Подразделение	= ТекПодразделение;	
	
	ОбъектХДТО.Контрагент	= Справочники.Контрагенты.ПолучитьСсылку(РеквизитыШ.Организация.УникальныйИдентификатор());
	ОбъектХДТО.ВидОперации	= "СогласованноеИзменение";	
	
	ОбъектХДТО.АктОРасхождениях = РеквизитыШ.ЗаявкаНаРекламацию;
	
	ТоварыXDTO				= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары",ПространствоИмен_ЕЕ);	
	
	КоличествоДокумента		= 0;
	КоличествоРасхождений	= 0;
	
	СуммаДокумента			= 0;
	СуммаРасхождений		= 0;
	
	ВыборкаПоТЧ				= ПолучитьВыборкуТЧ(ДокВыборка);	
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		//Если ВыборкаПоТЧ.Количество=ВыборкаПоТЧ.КоличествоДоИзменения Тогда Продолжить КонецЕсли;	
		
		СтрокаТЧ_ХДТО		= СоздатьОбъектХДТО(ИмяТипаХДТО+".Товары.Строка",ПространствоИмен_ЕЕ);
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧ_ХДТО,ВыборкаПоТЧ);		
		
		Всего				= ВыборкаПоТЧ.Количество			*ВыборкаПоТЧ.Цена;
		ВсегоДоИзменения 	= ВыборкаПоТЧ.КоличествоДоИзменения	*ВыборкаПоТЧ.Цена;
		
		СтрокаТЧ_ХДТО.ВсегоДоИзменения 	= ВсегоДоИзменения;
		СтрокаТЧ_ХДТО.Всего 			= Всего;
		
		СтрокаТЧ_ХДТО.Единица			= Ед_Штука;	
		
		ПроцентНДС						= ПроцентНДСпоСтавке(ВыборкаПоТЧ.СтавкаНДС);		
		Если ПроцентНДС<>0 Тогда	
			СтрокаТЧ_ХДТО.НДС          	= Окр(Всего*ПроцентНДС/(1+ПроцентНДС),2,1);
			СтрокаТЧ_ХДТО.СуммаБезНДС	= Всего	- СтрокаТЧ_ХДТО.НДС;
			
			СтрокаТЧ_ХДТО.НДСДоИзменения			= Окр(ВсегоДоИзменения*ПроцентНДС/(1+ПроцентНДС),2,1);
			СтрокаТЧ_ХДТО.СуммаБезНДСДоИзменения	= ВсегоДоИзменения-СтрокаТЧ_ХДТО.НДСДоИзменения;;
		КонецЕсли;
		
		ТоварыXDTO.Строка.Добавить(СтрокаТЧ_ХДТО);		
		
		КоличествоДокумента		= КоличествоДокумента	+ ВыборкаПоТЧ.Количество;
		СуммаДокумента			= СуммаДокумента		+ Всего;	
		
		КоличествоРасхождений   = КоличествоРасхождений	+ (ВыборкаПоТЧ.Количество - ВыборкаПоТЧ.КоличествоДоИзменения);
		СуммаРасхождений		= СуммаРасхождений		+ (Всего-ВсегоДоИзменения);
	КонецЦикла;
	
	ОбъектХДТО.Товары					= ТоварыXDTO;	
	
	ОбъектХДТО.СуммаДокумента			= СуммаДокумента;
	ОбъектХДТО.КоличествоДокумента		= КоличествоДокумента;
	
	ОбъектХДТО.СуммаРасхождений			= СуммаРасхождений;
	ОбъектХДТО.КоличествоРасхождений	= КоличествоРасхождений;
	
	
	
	//ОбъектХДТО.КодОперации			= Перечисления.КодыОперацийОстатки.Закупка;	
	ОбъектХДТО.СуммаВключаетНДС			= СериализаторXDTO.XMLСтрока(Истина);	
			
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РКМ_КП

Функция ВыгрузитьДок_РКО(ДокВыборка)	
	ИмяТаблицы		= "Документ.РасходныйКассовыйОрдер";	
	ИмяТипаХДТО		= ИмяТаблицы;
	
	ВхПараметр		= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	РеквизитыШ		= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ИмяТаблицы);	
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО		= СоздатьОбъектХДТО(ИмяТаблицы,ПространствоИмен_ЕЕ);
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,"ВидОперации");
	
	УстановитьСвойствоХДТО(ОбъектХДТО,"ВидОперации",XMLСтрока(РеквизитыШ.ВидОперации));
		
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьДок_РКО(ДокВыборка)

Функция ВыгрузитьДок_СВД(ДокВыборка)
	ИмяТаблицы	= Метаданные.Документы.СверкаДанных.ПолноеИмя();
	ИмяТипаХДТО	= ИмяТаблицы;
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ИменаТЧ	= "Данные";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ);
	
	ОбъектХДТО.ИмяПланаОбмена = "ОбменСЕЕ";
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьДок_СВД(ДокВыборка) 

Функция ВыгрузитьДок_СПН(ДокВыборка)
	ИмяТаблицы	= Метаданные.Документы.СписаниеТМЦ.ПолноеИмя();
	ИмяТипаХДТО	= ИмяТаблицы;
	
	ВхПараметр	= РазобратьВходнойПараметр(ДокВыборка,ИмяТаблицы);
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли; 
	
	РеквизитыШ	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"");
	
	Если НЕ ЗначениеЗаполнено(РеквизитыШ.ВерсияДанных) Тогда Возврат Неопределено КонецЕсли;
	ДокСсылка	= ВхПараметр.Ссылка;
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО,ПространствоИмен_ЕЕ);	
	
	ИменаТЧ	= "Товары";
	ЗаполнитьЗначенияСвойств(ОбъектХДТО,РеквизитыШ,,ИменаТЧ);		
	
	Для Каждого ИмяТЧ Из СтрРазделить(ИменаТЧ,",") Цикл	
		ОбъектХДТО[ИмяТЧ]	= ВыгрузитьТЧвХДТО(ПолучитьВыборкуТЧ(ДокВыборка,ИмяТЧ),ИмяТаблицы+"."+ИмяТЧ);
	КонецЦикла;
	
	ХПС_Ссылка	= НайтиХПС(ДокСсылка);
	Если ЗначениеЗаполнено(ХПС_Ссылка) Тогда
		ТЧ_ХДТО	= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты",ПространствоИмен_ЕЕ);	
		
		ВыборкаПоТЧ	= ПолучитьВыборкуТЧДокумента(ХПС_Ссылка,"Сертификаты");
		Пока ВыборкаПоТЧ.Следующий() Цикл			
			СтрокаТЧ_ХДТО						= СоздатьОбъектХДТО(ИмяТипаХДТО+".Сертификаты.Строка",ПространствоИмен_ЕЕ);
			СтрокаТЧ_ХДТО.ПодарочныйСертификат	= ВыборкаПоТЧ.Сертификат;			
			ТЧ_ХДТО.Строка.Добавить(СтрокаТЧ_ХДТО);
		КонецЦикла;
		
		ОбъектХДТО.Сертификаты=ТЧ_ХДТО;		
	КонецЕсли;
	
	Возврат ОбъектХДТО;	
КонецФункции //ВыгрузитьДок_СПН(ДокВыборка)

Функция ВыгрузитьДок_СПН_ЕД(ДокВыборка)
	Если 1=2 Тогда
		ДокСсылка=Документы.СписаниеТМЦ.ПустаяСсылка();	
	КонецЕсли;
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);
	
	Если НаВходеВыборка Тогда
		РеквизитыШапки	= ДокВыборка;
	Иначе
		ИменаРеквизитов	= РеквизитыШапок.Получить("Документ.СписаниеТМЦ");			
		РеквизитыШапки	= ПолучитьРеквизитыШапки(ДокСсылка,ИменаРеквизитов);		
	КонецЕсли;	
	
	ВидДокумента= "СписаниеЗапасов";
	
	МетаОбъект	= ДокСсылка.Метаданные();
	
	ОбъектХДТО						= СоздатьОбъектХДТО("Документ."+ВидДокумента);	
	
	ОбъектХДТО.КлючевыеСвойства	= ВыгрузитьДок_СПН_КС(РеквизитыШапки);		
	УстановитьСвойствоХДТО(ОбъектХДТО,"Ответственный",	ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШапки.Автор));
	ОбъектХДТО.Комментарий		= РеквизитыШапки.Комментарий;
	УстановитьСвойствоХДТО(ОбъектХДТО,"Подразделение",	ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШапки.Подразделение));
	УстановитьСвойствоХДТО(ОбъектХДТО,"Склад",			ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШапки.Склад));
	
	ТоварыXDTO				= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары");
	
	ВыборкаПоТЧ	= ПолучитьВыборкуТЧ(ДокВыборка);
	ВыборкаПоТЧ.Сбросить();
	Пока ВыборкаПоТЧ.Следующий() Цикл
		Если ВыборкаПоТЧ.Количество=0 Тогда Продолжить КонецЕсли;
		
		СтрокаXDTO						= СоздатьОбъектХДТО("Документ."+ВидДокумента+".Товары.Строка");
		
		СтрокаXDTO.ДанныеНоменклатуры	= Выгрузить_ОбщиеСвойстваДанныеНоменклатуры(ВыборкаПоТЧ.Номенклатура,ВыборкаПоТЧ.Характеристика);
		СтрокаXDTO.ЕдиницаИзмерения		= ВыгрузитьСпр_Единицы_Элемент_КС(ВыборкаПоТЧ.Единица);
		СтрокаXDTO.Количество			= ВыборкаПоТЧ.Количество;
		СтрокаXDTO.Сумма				= ВыборкаПоТЧ.Всего;
		СтрокаXDTO.Цена					= Окр(ВыборкаПоТЧ.Всего/ВыборкаПоТЧ.Количество,2,1);		
		
		СтрокаXDTO.ТипЗапасов			= "СобственныеТовары";
		
		ТоварыXDTO.Строка.Добавить(СтрокаXDTO);		
	КонецЦикла;	
	
	ОбъектХДТО.Товары	= ТоварыXDTO;
	
	ДобавитьСостояниеНакладной(ОбъектХДТО,РеквизитыШапки.СостояниеНакладной);	
	
	ПодразделениеХДТО	= ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШапки.Подразделение);	
	СтатьяЗатратХДТО	= ВыгрузитьСпр_СтатьиЗатрат_Элемент_КС(РеквизитыШапки.СтатьяЗатрат);
	
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"Подразделение",	ПодразделениеХДТО);
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_СТ,"СтатьяЗатрат",	СтатьяЗатратХДТО);	
	
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.ГруппыТоваров,	"ГруппыТоваров",	"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Комментарий,		"Комментарий",		"string",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.Проведен,			"Проведен",			"boolean",	ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШапки.ПометкаУдаления,	"ПометкаУдаления",	"boolean",	ПространствоИмен_СТ);
			
	Возврат ОбъектХДТО;	
КонецФункции

Функция ВыгрузитьДок_СПН_КС(ДокВыборка)
	
	КС_XDTO				= СоздатьОбъектХДТО("КлючевыеСвойстваСписаниеЗапасов");	
	
	КС_XDTO.Ссылка		= СериализаторXDTO.XMLСтрока(ДокВыборка.Ссылка);
	КС_XDTO.Дата		= ДокВыборка.Дата;
	КС_XDTO.Номер		= ДокВыборка.Номер; 
	КС_XDTO.Организация	= ВыгрузитьСпр_Организации_КС(ДокВыборка.Организация);
	
	Возврат КС_XDTO;
	
КонецФункции //ВыгрузитьДокумент_КС_ОПР(ДокСсылка)

Функция ВыгрузитьДок_ОКС(ДокВыборка)
	Если 1=2 Тогда
		ДокСсылка=Документы.ОтчетКассовойСмены.ПустаяСсылка();	
	КонецЕсли;
	КэшГТД								= Новый Соответствие;
	
	НаВходеВыборка	= (ТипЗнч(ДокВыборка)=Тип("ВыборкаИзРезультатаЗапроса"));	
	ДокСсылка		= ?(НаВходеВыборка,ДокВыборка.Ссылка,ДокВыборка);	
	// + HELP-2150 20241118 Михайловский
	//ОбъектХДТО	= СоздатьОбъектХДТО("Документ.ОтчетОРозничныхПродажах");
	ОбъектХДТО	= СоздатьОбъектХДТО("Документ.ОтчетКассовойСмены");
	// - HELP-2150 20241118 Михайловский
	
	Если НаВходеВыборка Тогда
		РеквизитыШ	= ДокВыборка;
	Иначе
		РеквизитыШ	= ПолучитьРеквизитыШапки(ДокСсылка,РеквизитыШапок.Получить("Документ.ОтчетКассовойСмены"));	
	КонецЕсли;
	
	ОбъектХДТО.КлючевыеСвойства		= ВыгрузитьДок_ОКС_КС(РеквизитыШ);		
	
	УстановитьСвойствоХДТО(ОбъектХДТО,"Ответственный",	ВыгрузитьСпр_Пользователи_Элемент_КС(РеквизитыШ.Автор));	
	УстановитьСвойствоХДТО(ОбъектХДТО,"Валюта",			ВыгрузитьСпр_Валюты_КС(РеквизитыШ.Валюта));	
	ОбъектХДТО.Сумма				= РеквизитыШ.СуммаДокумента;	
	ОбъектХДТО.СуммаВключаетНДС		= СериализаторXDTO.XMLСтрока(Истина);
	ОбъектХДТО.Подразделение		= ВыгрузитьСпр_Подразделения_Элемент_КС(РеквизитыШ.Подразделение);
	ОбъектХДТО.Склад				= ВыгрузитьСпр_Склады_Элемент_КС(РеквизитыШ.Склад);
	ОбъектХДТО.КассаККМ				= ВыгрузитьСпр_Кассы_Элемент_КС(РеквизитыШ.Касса);
    ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.СуммаСдачиПодарочногоСертификата, "СуммаСдачиПодарочногоСертификата", "decimal", ПространствоИмен_СТ);
//            ОбъектХДТО.СуммаСдачиПодарочногоСертификата=РеквизитыШ.СуммаСдачиПодарочногоСертификата;

	
	Если РеквизитыШ.КодОперации	= Перечисления.КодыОперацийОстатки.ВозвратОтПокупателя Тогда
		ОбъектХДТО.ТоварыВозвратПродажи	= ВыгрузитьДок_ОКС_ТЧ_Возвраты(ДокВыборка);				
	Иначе
		ОбъектХДТО.ТоварыПродажа		= ВыгрузитьДок_ОКС_ТЧ_Товары(ДокВыборка);
	КонецЕсли;				
	
	Если РеквизитыШ.ВидОплаты=Перечисления.ВидыОплаты.БН Тогда		
		ОплатаПлатежнымиКартамиXDTO		= СоздатьОбъектХДТО("ОплатаПлатежнымиКартами");
		
		СтрокаXDTO						= СоздатьОбъектХДТО("ОплатаПлатежнымиКартами.Строка");
		
		Если РеквизитыШ.КодОперации	= Перечисления.КодыОперацийОстатки.Реализация Тогда
			СтрокаXDTO.СуммаОплаты		= РеквизитыШ.СуммаДокумента-РеквизитыШ.СуммаОплатыСертификатами;				
		Иначе
			СтрокаXDTO.СуммаОплаты		= -РеквизитыШ.СуммаДокумента; 				
		КонецЕсли;		
		
		СтрокаXDTO.НомерКарты           = "9999 9999 9999 9999 9999";
		СтрокаXDTO.Эквайрер             = ВыгрузитьСпр_Контрагенты_Элемент_КС(КонтрагентЭквайринг);
	
		ОплатаПлатежнымиКартамиXDTO.Строка.Добавить(СтрокаXDTO);	
	
		ОбъектХДТО.ОплатаПлатежнымиКартами=ОплатаПлатежнымиКартамиXDTO;		
	КонецЕсли;
	
	Если РеквизитыШ.СуммаОплатыСертификатами>0 Тогда
		ПодарочныеСертификатыXDTO=СоздатьОбъектХДТО("ПодарочныеСертификаты");
		
		ВыборкаПоТЧ	= ДокВыборка.ПодарочныеСертификаты.Выбрать();
		Пока ВыборкаПоТЧ.Следующий() Цикл		
			СтрокаXDTO						= СоздатьОбъектХДТО("ПодарочныеСертификаты.Строка");		
			
			СтрокаXDTO.ДанныеСертификата    = ВыгрузитьСпр_ПодарочныеСертификаты_КС(ВыборкаПоТЧ.Сертификат);
			СтрокаXDTO.Сумма				= ВыборкаПоТЧ.СуммаОплатыСертификатами;
			
			ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.НомерЧекаККМ,	"НомерЧекаККМ",	"string",ПространствоИмен_СТ);
			ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.НомерЧека,		"НомерЧека",	"string",ПространствоИмен_СТ);
			ДобавитьЭлементХДТО(СтрокаXDTO,ВыборкаПоТЧ.СуммаЧека,		"СуммаЧека",	"decimal",ПространствоИмен_СТ);						
			ДобавитьСвойствоХДТО(СтрокаXDTO,ВыгрузитьСпр_Пользователи_Элемент_КС(ВыборкаПоТЧ.АвторЧека),"АвторЧека",ПространствоИмен_ЕЕ);
			
			ПодарочныеСертификатыXDTO.Строка.Добавить(СтрокаXDTO);	
		КонецЦикла; 
		
		ОбъектХДТО.ОплатаСертификатами=ПодарочныеСертификатыXDTO;
	КонецЕсли;
	
	ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(РеквизитыШ.КодОперации),	"КодОперации",		"КодыОперацийОстатки",	ПространствоИмен_ЕЕ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.Проведен,					"Проведен",			"boolean",				ПространствоИмен_СТ);
	ДобавитьЭлементХДТО(ОбъектХДТО,РеквизитыШ.ПометкаУдаления,			"ПометкаУдаления",	"boolean",				ПространствоИмен_СТ);	
	
	Возврат ОбъектХДТО;	
КонецФункции

