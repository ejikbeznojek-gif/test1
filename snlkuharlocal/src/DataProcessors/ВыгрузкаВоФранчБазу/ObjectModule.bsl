Функция ПолучитьРеквизитыШапки_(ОбъектСсылка,Знач СписокРеквизитов,ИмяТаблицы=Неопределено) Экспорт
	Если ТипЗнч(СписокРеквизитов)=Тип("Строка") Тогда
		СписокЭлементов	=СтрРазделить(СписокРеквизитов,",");
		СписокРеквизитов=Новый Соответствие;
		Для Каждого Элемент Из СписокЭлементов Цикл
			СписокРеквизитов.Вставить(Элемент,СтрЗаменить(Элемент,".","_"));		
		КонецЦикла;
	КонецЕсли;
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ Ссылка";
	Для Каждого Элемент Из СписокРеквизитов Цикл
		Запрос.Текст=Запрос.Текст+",
		|	"+Элемент.Ключ+" "+?(ПустаяСтрока(Элемент.Значение),"","КАК "+Элемент.Значение);
	КонецЦикла;
	
	Если ИмяТаблицы=Неопределено Тогда
		ИмяТаблицы=ТипОбъекта(ОбъектСсылка)+"."+ОбъектСсылка.Метаданные().Имя;	
	КонецЕсли;
	
	Результат=Новый Структура;
	Для Каждого Элемент Из СписокРеквизитов Цикл
		Результат.Вставить(?(ПустаяСтрока(Элемент.Значение),Элемент.Ключ,Элемент.Значение),Неопределено);	
	КонецЦикла; 
	
	Если ПустаяСтрока(ИмяТаблицы) Тогда
		ИмяТаблицы	= ОбъектСсылка.Метадынные().ПолноеИмя();
		//Возврат Результат;	
	КонецЕсли;
	
	Запрос.Текст=Запрос.Текст+"
	|ИЗ
	|	"+ИмяТаблицы+"
	|ГДЕ
	|	Ссылка=&ОбъектСсылка";
	Запрос.УстановитьПараметр("ОбъектСсылка",ОбъектСсылка);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат,Выборка);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции //ПолучитьРеквизитыШапки(ОбъектСсылка,СписокРеквизитов) Экспорт

Функция НайтиОКСпоЧеку(ЧекСсылка)
	Результат= Документы.ОтчетКассовойСмены.ПустаяСсылка();
	
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ОКС.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары КАК ОКС
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	Документ.Чек КАК Чек
	|ПО 	
	|	НАЧАЛОПЕРИОДА(ОКС.Ссылка.Дата,День) = НАЧАЛОПЕРИОДА(Чек.Дата,День)
	|	И ОКС.Ссылка.Касса	= Чек.КассаККМ
	|	И ОКС.НомерЧекаККМ 	= Чек.НомерЧекаККМ
	|ГДЕ
	|	Чек.Ссылка = &ЧекСсылка	
	|";
	
	Запрос.УстановитьПараметр("ЧекСсылка",ЧекСсылка);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Результат = Выборка.Ссылка;	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //НайтиОКСпоЧеку

