Функция ВыгрузитьСпр_Подразделения_Элемент_ЕД(СпрВыборка)
	ИмяТаблицы	= "Справочник.Подразделения";
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,"Элемент");
	
	Если Реквизиты.ВерсияДанных="" Тогда Возврат Неопределено КонецЕсли; 
	
	ОбъектХДТО	= СоздатьОбъектХДТО(ИмяТаблицы);
	
	ОбъектХДТО.КлючевыеСвойства = ВыгрузитьСпр_Подразделения_Элемент_КС(Реквизиты.Ссылка);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.Код,"Код","string",ПространствоИмен_СТ);
	
	СкладХДТО	= ВыгрузитьСпр_КС(Реквизиты.ОсновнойСклад,"Склады","Наименование","КлючевыеСвойстваСклад");
	ОбъектХДТО.Добавить(ФормаXML.Элемент,ПространствоИмен_ЕД,"ОсновнойСклад",СкладХДТО);	
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Подразделения_Элемент(Ссылка)

Функция ВыгрузитьСпр_Подразделения_Элемент_КС(Ссылка,Знач ДатаВыгрузки=Неопределено)	
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда Возврат Неопределено КонецЕсли;	
	
	ИмяТаблицы	= "Справочник.Подразделения";
	
	ОбъектХДТО	= ПолучитьИзКэша(Ссылка,ИмяТаблицы);	
	
	Если ОбъектХДТО	= Неопределено Тогда	
		Если ОбъектСуществует(Ссылка,ИмяТаблицы) Тогда
			ОбъектХДТО	= ВыгрузитьСпр_КС(Ссылка,"Подразделения","Наименование","КлючевыеСвойстваПодразделение");
		
			Если ДатаВыгрузки=Неопределено Тогда
				ДатаВыгрузки=ТекущаяДата();	
			КонецЕсли; 
			
			Организация	= РегистрыСведений.ФР_ЮрЛицаПодразделений.ПолучитьЮрЛицо(Ссылка,ДатаВыгрузки);
			
			ДобавитьЭлементХДТО(ОбъектХДТО,XMLСтрока(Организация),"Организация","string",ПространствоИмен_СТ);		
		КонецЕсли;		
		
		ВставитьВКэш(Ссылка,ОбъектХДТО,ИмяТаблицы);
	КонецЕсли;
	
	Возврат ОбъектХДТО;
КонецФункции //ВыгрузитьСпр_Подразделения_Элемент_КС(Ссылка)

Функция ВыгрузитьСпр_Размеры_Элемент(СпрВыборка)		
	ИмяТаблицы		= "Справочник.Размеры";
	ВариантВыгрузки = "Элемент";
	ИмяОбъектаХДТО	= ИмяТаблицы+"."+ВариантВыгрузки;
	
	ВхПараметр	= РазобратьВходнойПараметр(СпрВыборка,ИмяТаблицы);	
	
	Если НЕ ВхПараметр.Результат Тогда Возврат Неопределено КонецЕсли;	
	
	ОбъектХДТО					= СоздатьОбъектХДТО(ИмяОбъектаХДТО,ПространствоИмен_ЕЕ);	
	ОбъектХДТО.КлючевыеСвойства = ВыгрузитьСпр_Размеры_КС(СпрВыборка);	
	
	Реквизиты	= ПолучитьРеквизитыДляВыгрузки(ВхПараметр,ВариантВыгрузки);
	
	ДобавитьЭлементХДТО(ОбъектХДТО,Реквизиты.ПометкаУдаления,"ПометкаУдаления","string",ПространствоИмен_СТ);
	
