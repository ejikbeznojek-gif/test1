	С.Вставить("Документ.ПеремещениеТоваров",			"Документ.Перемещение");
	С.Вставить("Документ.ПоступлениеТоваровУслуг",		"Документ.ПриходнаяНакладная");
	С.Вставить("Документ.ОприходованиеТоваров",			"Документ.ОприходованиеТМЦ");
