	Запрос.УстановитьПараметр("МН",МН);
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();	
	
	Сч			= 0;
	МР = Запрос.ВыполнитьПакет();
	ТЗНом = МР[1].Выгрузить();
	ТЗГрп = МР[2].Выгрузить();
	//+HELP-7358 20251022 Михайловский
	Попытка
		МОб0= ВыгрузитьСпр_Номенклатуры_Грп(ТЗГрп);
		Для Каждого ТЭл Из МОб0 Цикл
			Рез.Добавить(ТЭл);
