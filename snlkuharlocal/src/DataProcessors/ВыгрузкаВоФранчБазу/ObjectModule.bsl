Функция ДобавитьОбработчикЗагрузки(ТО,ИмяТипаХДТО,Знач ИмяТаблицы, Знач ПроцедураЗагрузки = "")
	
	Поля				= ФР_ОбщегоНазначения_КС.СтрокуВСтруктуру(ИмяТаблицы,"Тип,Вид,Суффикс",".");	
	ИмяТаблицыТек		= ПолучитьТипТек(Поля.Тип+"."+Поля.Вид);
	
	Если СтрНайти("Справочник,Документ,ПланВидовХарактеристик",Поля.Тип)<>0 Тогда
		Попытка
			ТипОбъекта	= СформироватьТипСсылки(ИмяТаблицыТек);	
		Исключение
			Сообщить_("Тип не определен: """+ИмяТаблицыТек+""" !",СтатусСообщения.Важное);
		КонецПопытки;		
	Иначе
		ТипОбъекта	= "";		
	КонецЕсли;	
	
	СтрокаТО			= ТО.Добавить();
	
	СтрокаТО.ИмяТипаХДТО= ИмяТипаХДТО;	
	
	СтрокаТО.ИмяТаблицы	= ИмяТаблицы;
	СтрокаТО.ТипОбъекта	= ТипОбъекта;	
	
	Если ПустаяСтрока(ПроцедураЗагрузки) Тогда		
		ПроцедураЗагрузки	= ФР_ОбщегоНазначения_КС.СлепитьЗаполненныеПараметры("_","Загрузить"+СокращениеТипа(Поля.Тип),Поля.Вид,Поля.Суффикс);
	КонецЕсли; 
	
	СтрокаТО.ПроцедураЗагрузки	= ПроцедураЗагрузки;
	
КонецФункции //ДобавитьОбработчикВыгрузки(ТО,	ИмяТаблицы, ВариантВыгрузки,ПроцедураВыгрузки)

Процедура ЗагрузитьДанныеИзОчереди(УзелПолучатель) Экспорт
	УзелПараметров	= ФР_ОбщегоНазначения_ПИ.ЭтотУзел();
	Если КомпонентаОбмена=Неопределено Тогда		
		ТекУзелПолучатель	= УзелПолучатель;
		Если НЕ ЗначениеЗаполнено(ТекУзелПолучатель) Тогда Возврат КонецЕсли;		
		Если НЕ ИнициализироватьКомпонентуОбмена(ТекУзелПолучатель) Тогда Возврат КонецЕсли;	
	КонецЕсли;	
	
	Сч			= 0;
	ВсегоБайт	= 0;
	
	ИмяОчереди	= "to_"+УзелПолучатель.Код;
	
	ФР_Регламент.ВыгрузитьЗаглушку(КомпонентаОбмена,ИмяОчереди,"Чудо текст"); // Пинок - почему то не считывает из очереди - если там одно сообщение
	
	КомпонентаОбмена.НачатьПриемСообщений(ИмяОчереди);		
	КомпонентаОбмена.Пауза(500);
	
	Сообщение		= "";
	НомерДоставки	= "";	
	
	ДопПараметры    = Новый Структура("ИД_Сеанса",Новый УникальныйИдентификатор());
	
	ДанныеСообщения		= КомпонентаОбмена.ПрочитатьСообщение(НомерДоставки);	
	
	Пока Число(НомерДоставки)<>0 Цикл				
		ОбработкаПрерыванияПользователя_(); 
		
		СообщениеСтрокой	= ПолучитьСтрокуИзДвоичныхДанных(ДанныеСообщения);
		
		Сообщить_(""+Сч+", размер ДД: "+ДанныеСообщения.Размер()+", размер строки: "+СтрДлина(СообщениеСтрокой));
		
		Сч=Сч+1;
		Если Сч%100=0 Тогда
			//Сообщить_(""+Сч+", размер ДД: "+ДанныеСообщения.Размер()+", размер строки: "+СтрДлина(СообщениеСтрокой));
		КонецЕсли;
		
		ВсегоБайт	= ВсегоБайт+ДанныеСообщения.Размер();
		
		ПрочитатьДанныеСообщения(СообщениеСтрокой,ДопПараметры);
		
		КомпонентаОбмена.ПодтвердитьЧтение(Число(НомерДоставки));
				
		Сообщение	= КомпонентаОбмена.ПрочитатьСообщение(НомерДоставки);
	КонецЦикла;
	
	
	ЗаписьЖурналаРегистрации("ОбменДанными",УровеньЖурналаРегистрации.Информация,Метаданные.ПланыОбмена.ФР_ОбменСФРК,ТекУзелПолучатель,"Отправлено: "+Сч+" объектов. Суммарный размер: "+ВсегоБайт);
	
КонецПроцедуры

Функция ПрочитатьДанныеСообщения(СообщениеСтрокой,ДопПараметры) Экспорт
	#ЕСЛИ КЛИЕНТ ТОГДА
	ОбработкаПрерыванияПользователя(); 
	#КОНЕЦЕСЛИ	
	
	Ошибки		= Новый Массив;
	
	//СтрокаХЗ	= ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	
	Пакет		= Неопределено;	
	Попытка
		Пакет	= ЗначениеИзСтрокиВнутр(СообщениеСтрокой);
	Исключение
		Ошибки.Добавить("Ошибка десериализации сообщения.");
	КонецПопытки;	
	
	ДанныеОбмена	= Неопределено;	
	
	ПротоколОбмена	= СоздатьПротоколОбмена();	
	Отправитель		= Неопределено;
	ИД_Пакета		= Неопределено;
	ИД_Сеанса		= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"ИД_Сеанса");
	НачалоОбработки	= ТекущаяДата();
	
	Если Пакет = Неопределено Тогда
		Ошибки.Добавить("Некорректные входящие данные. Невозможно разобрать пакет из строки.");
	ИначеЕсли ТипЗнч(Пакет)=Тип("Структура") Тогда
		ОбъектыОбмена.Очистить();		
		
		ИД_Пакета	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(Пакет,"ИД_Пакета");
		Если ИД_Пакета=Неопределено Тогда
			Пакет.Вставить("ИД_Пакета",Справочники.СтатистикаОбменов.ПустаяСсылка().УникальныйИдентификатор());		
		КонецЕсли; 
		
		Для Каждого Данные Из Пакет.Данные Цикл
			Попытка
				Значен	= XMLЗначение(Тип("ХранилищеЗначения"),Данные);		
				Строка	= Значен.Получить();						
				
				Попытка
					ДанныеОбмена	= ЗагрузитьФайлХДТО(Строка,ДопПараметры);
					Отправитель		= ДанныеОбмена.Отправитель; 
					
					Для Каждого ТекстОшибки Из ДанныеОбмена.Ошибки Цикл
						Ошибки.Добавить(ТекстОшибки);					
					КонецЦикла;					
				Исключение
					Ошибка			=  ОписаниеОшибки();
					Ошибки.Добавить(Ошибка);
					
					МЗ				= РегистрыСведений.ОшибкиОбмена.СоздатьМенеджерЗаписи();
					
					МЗ.КлючЗаписи	= Новый УникальныйИдентификатор();
					МЗ.Дата			= ТекущаяДата();
					МЗ.ДанныеПакета	= Строка;
					
					МЗ.ОписаниеОшибки = Ошибка;
					
					МЗ.Записать();
				КонецПопытки;				
			Исключение
				Ошибки.Добавить("Ошибка разбора XDTO. "+ОписаниеОшибки());				
			КонецПопытки;			
		КонецЦикла;
	Иначе
		Ошибки.Добавить("Некорректные входящие данные. Неверный тип данных пакета.");
	КонецЕсли;
	
	ЭлементСтатистики	= ЗаписатьЭлементСтатистики_Прием(СтрДлина(СообщениеСтрокой),Пакет,Ошибки,НачалоОбработки,ИД_Сеанса,СообщениеСтрокой);
	
	Возврат Новый Структура("ИД_Пакета,ЭлементСтатистики,Отправитель,Результат,Ошибки",ИД_Пакета,ЭлементСтатистики,Отправитель,(Ошибки.Количество()=0),Ошибки);
КонецФункции

Функция ЗагрузитьФайлХДТО(Строка=Неопределено,ДопПараметры=Неопределено) Экспорт
	ПротоколЗагрузки=СоздатьПротоколЗагрузки();
	
	Если ТипЗнч(ДопПараметры)=Тип("Структура") Тогда
		фПерезаписыватьРеквизитыСправочников	= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"фПерезаписыватьРеквизитыСправочников",	фПерезаписыватьРеквизитыСправочников);
		фПерезаписыватьДокументы				= ФР_ОбщегоНазначения_КС.ПолучитьЗначениеПараметра(ДопПараметры,"фПерезаписыватьДокументы",				фПерезаписыватьДокументы);
	КонецЕсли;	
	
	ЧтениеXML = Новый ЧтениеXML;
	Если Строка=Неопределено Тогда
		ЧтениеXML.ОткрытьФайл(ИмяФайлаОбмена);
	Иначе
		ЧтениеXML.УстановитьСтроку(Строка);	
	КонецЕсли;	
	
	ЧтениеXML.Прочитать();		
	ТипXML		= ПолучитьXMLТип(ЧтениеXML);
	
	ЧтениеXML.Прочитать();
	ТипХДТО		= Фабрика.Тип("http://www.1c.ru/SSL/Exchange/Message","Header");		
	ОбъектХДТО	= Фабрика.ПрочитатьXML(ЧтениеXML,Фабрика.Тип("http://www.1c.ru/SSL/Exchange/Message","Header"));		
	
	КонфирмХДТО	= ПолучитьСвойствоХДТО(ОбъектХДТО,"Confirmation");
	Если КонфирмХДТО<>Неопределено Тогда
		
		ИмяПланаОбмена	= "ФР_ОбменСФРК";		
		Отправитель		= ПланыОбмена[ИмяПланаОбмена].НайтиПоКоду(КонфирмХДТО.From);		
		Если Отправитель = ФР_ОбщегоНазначения_ПИ.ЭтотУзел(ИмяПланаОбмена) Тогда
			Отправитель = Неопределено;		
		КонецЕсли; 		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Отправитель) Тогда
		Отправитель="Нечто";	
	КонецЕсли; 
	
	ПротоколЗагрузки.Отправитель=Отправитель;
	
	
	ТипXML		= ПолучитьXMLТип(ЧтениеXML);	
	ИмяТипаХДТО	= "";
	
	Сч			= 0;
	Ошибки		= Новый Массив;
	
	ЧтениеXML.Прочитать();	
	Пока ЧтениеXML.ТипУзла<>ТипУзлаXML.КонецЭлемента Цикл		
		
		ИмяТипаХДТО	= ПолучитьXMLТип(ЧтениеXML).ИмяТипа;
		ТипОбъекта	= РазложитьПолныйТип(ИмяТипаХДТО);		
		
		Попытка
			ОбъектХДТО	= Фабрика.ПрочитатьXML(ЧтениеXML);						
		Исключение			
			// + HELP-1867 20241031 Михайловский
			ЗагрБФ = Ложь;
			Если ИмяТипаХДТО = "Справочник.Акции.Элемент" Тогда
				ЗагрБФ = ЗагрузитьБезФабрики(Строка, ИмяТипаХДТО, ТипОбъекта);
			КонецЕсли;	
			// + HELP-1867 20241031 Михайловский
			ОбъектХДТО	= Неопределено;	
			// + HELP-1867 20241031 Михайловский
			//ТекстОшибки	= "Ошибка разбора ХДТО. Тип: "+ИмяТипаХДТО+"."+Символы.ПС+ОписаниеОшибки();
			ТекстОшибки	= "Ошибка разбора ХДТО. Тип: "+ИмяТипаХДТО+". Прямая загрузка из XML " + ?(ЗагрБФ, "выполнена", "не выполнена ") + Символы.ПС+ОписаниеОшибки();
			// - HELP-1867 20241031 Михайловский		
			ДобавитьОбъектВПротоколОбмена(ИмяТипаХДТО,,"ЧтениеХДТО",ТекстОшибки);			
			Ошибки.Добавить(ТекстОшибки);
			
			МЗ				= РегистрыСведений.ОшибкиОбмена.СоздатьМенеджерЗаписи();
			
			МЗ.КлючЗаписи	= Новый УникальныйИдентификатор();
			МЗ.Дата			= ТекущаяДата();
			МЗ.ДанныеПакета	= Строка;
			
			МЗ.ОписаниеОшибки = ТекстОшибки;
			
			МЗ.Записать();			
			
			Прервать;			
		КонецПопытки;		
		
		Вид 		= ТипОбъекта.Вид;
		Тип			= ТипОбъекта.Тип;
		
		Если Тип="Справочник" Тогда			
			ЗагрузитьСправочник(ОбъектХДТО,ИмяТипаХДТО,Отправитель);
		ИначеЕсли Тип="Документ" Тогда 
			ЗагрузитьДокумент(ОбъектХДТО,ИмяТипаХДТО,Отправитель);		
		ИначеЕсли Тип="РегистрСведений" Тогда
			ЗагрузитьРегистрСведений(ОбъектХДТО,Вид,Отправитель);		
		ИначеЕсли Тип="InformationRegisterRecordSet" Тогда
			НЗ=СериализаторXDTO.ПрочитатьXDTO(ОбъектХДТО);			
			ЗаписатьОбъект(НЗ,Отправитель);
		ИначеЕсли Тип="" Тогда
			Если Вид="ОбщиеСвойстваДанныеПодарочногоСертификата" Тогда
				ЗагрузитьСправочник(ОбъектХДТО,"Справочник.ПодарочныеСертификаты",Отправитель);
			КонецЕсли;			
		КонецЕсли;		
		
		Сч=Сч+1;
		
		Если Сч%100=0 Тогда
			Состояние_("Загружено: "+Сч);		
		КонецЕсли;
		ОбработкаПрерыванияПользователя_();		
	КонецЦикла; 
	
	ЧтениеXML.Закрыть();
	
	КодОтправителя=?(ТипЗнч(Отправитель)=Тип("Строка"),Отправитель,Отправитель.Код);
	
	Возврат Новый Структура("Отправитель,Ошибки",КодОтправителя,Ошибки);
КонецФункции

// + HELP-1867 20241031 Михайловский
Функция ИмяБезПИ(Имя)
	ОтвС = Новый Структура;
	ПозДД = СтрНайти(Имя, ":");
	ОтвС.Вставить("ПИм", ?(ПозДД, Лев(Имя, ПозДД - 1), ""));
	ОтвС.Вставить("Имя", ?(ПозДД, Сред(Имя, ПозДД + 1), Имя));
	Возврат ОтвС;
КонецФункции

Функция ЗагрузитьБезФабрики(СтрокаПотока, ИмяТипаХДТО, ТипОбъекта)
	Рез = Ложь;
	Вид 		= ТипОбъекта.Вид;
	Тип			= ТипОбъекта.Тип;
	Если ИмяТипаХДТО = "Справочник.Акции.Элемент" Тогда
		МасРекв = Новый Массив;
		МасРекв.Добавить("Ссылка");
		МасРекв.Добавить("Родитель");
		МасРекв.Добавить("Наименование");
		МасРекв.Добавить("Код");
		МасРекв.Добавить("ДатаНачала");
		МасРекв.Добавить("ДатаОкончания");
		МасРекв.Добавить("Описание");
		МасРекв.Добавить("ШтрихКод");
		МасРекв.Добавить("ДатаНачалаДействияПС");
		МасРекв.Добавить("ДатаОкончанияДействияПС");
		МасРекв.Добавить("КомплектРасширенная");
		МасРекв.Добавить("ОдинКупонНаЧек");
		МасРекв.Добавить("ПометкаУдаления");
		Попытка
			Соот = Новый Соответствие;
			ЧтениеXML = Новый ЧтениеXML;
			Уст = Ложь;
			Если НЕ СтрокаПотока = Неопределено Тогда
				ЧтениеXML.УстановитьСтроку(СтрокаПотока);
				Пока ЧтениеXML.Прочитать() Цикл
					ИмяБезПИ = ИмяБезПИ(ЧтениеXML.Имя).Имя;
					Если ИмяБезПИ = ИмяТипаХДТО Тогда
						ЗаписатьВЛог("Регламент","Обмен ФР. тип акции: "+ИмяБезПИ ,"Информация",Ложь);
						Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
							Уст = Истина;
