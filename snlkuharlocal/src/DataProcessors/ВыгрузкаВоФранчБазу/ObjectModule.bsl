			КонецЕсли; 
			
			//Пока Выборка.Следующий() Цикл
			//	ОбработкаПрерыванияПользователя_();
			//	Если НужноНаименование И НЕ ЗначениеЗаполнено(Выборка.Наименование) Тогда Продолжить КонецЕсли;
			//	
			//	
