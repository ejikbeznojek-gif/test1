Функция ЗагрузитьСпр_Бренды_Элемент(ОбъектХДТО,Отправитель=Неопределено)	
	Менеджер	= Справочники.ФР_Бренды;	
	Результат	= НайтиСоздатьСправочник(ОбъектХДТО.Ссылка,"ФР_Бренды",Ложь);	
	
	Если Результат.Найден И НЕ фПерезаписыватьРеквизитыСправочников Тогда
		Возврат Результат.Ссылка;		
	Иначе
		СпрОбъект	= Результат.Объект;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(СпрОбъект,ОбъектХДТО,,"Ссылка");	
		
	Возврат ЗаписатьОбъект(СпрОбъект,Отправитель);	
КонецФункции //ЗагрузитьСпр_Бренды_Элемент(ОбъектХДТО,Отправитель=Неопределено)

