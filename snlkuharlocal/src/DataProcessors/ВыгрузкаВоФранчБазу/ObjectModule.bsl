Функция ПолучитьРеквизитыНоменклатуры(Ссылка)
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ	
	|	"+ТекстЗапроса_Номенклатура_Элемент_Ревизиты()+"	
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Ссылка=&Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка",Ссылка);	
	
	ДанныеНом	= Новый Структура();
	
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда		
		ДанныеНом.Вставить("Номенклатура",		ЗаполнитьПоляПоВыборке(Выборка,"Номенклатура",		"Ссылка,Код,Наименование,Артикул"));
		
		Характеристика	= ЗаполнитьПоляПоВыборке(Выборка,"Характеристика",	"Ссылка,Код,Наименование");		
		
		Характеристика.Вставить("Цвет",			ЗаполнитьПоляПоВыборке(Выборка,"Цвет",				"Родитель,Ссылка,Код,Наименование"));
		Характеристика.Вставить("Размер",		ЗаполнитьПоляПоВыборке(Выборка,"Размер",			"Родитель,Ссылка,Код,Наименование"));		 
		
		ДанныеНом.Вставить("Характеристика",	Характеристика);				
	КонецЕсли;
	
	Возврат ДанныеНом;
КонецФункции //ПолучитьРеквизитыНоменклатуры(Ссылка)


