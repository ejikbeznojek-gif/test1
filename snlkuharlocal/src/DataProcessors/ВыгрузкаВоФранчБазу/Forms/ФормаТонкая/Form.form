    <name>СписокПРЛ</name>
    <title>
      <key>ru</key>
      <value>Список УСК</value>
    </title>
    <id>17</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Документы.Ссылка 		КАК Ссылка,
	Документы.Номер 		КАК Номер,
	Документы.Дата 			КАК Дата,
	Документы.Дата2			КАК Дата2,	
	Документы.Проведен 		КАК Проведен,	
	Документы.Автор 		КАК Автор,
	Документы.ТипЦен 		КАК ТипЦен,
	Документы.Организация 	КАК Организация,
	
	Подразделения.Ссылка КАК Подразделение	
ИЗ
	Документ.ПрайсЛист КАК Документы
ЛЕВОЕ СОЕДИНЕНИЕ
	Справочник.Подразделения КАК Подразделения	
ПО 		
	Подразделения.РозничныйТипЦен 			= Документы.ТипЦен
	ИЛИ Подразделения.РозничныйТипЦенРаспродажа	= Документы.ТипЦен
ЛЕВОЕ СОЕДИНЕНИЕ	
	ПланОбмена.Основной КАК ПланОбмена
ПО
	ПланОбмена.Код = Подразделения.КодФизическогоУзла77		
ГДЕ
	Документы.Проведен
	И (ПланОбмена.ПометкаУдаления=Ложь	ИЛИ ПланОбмена.ВерсияДанных ЕСТЬ NULL)
	И Подразделения.Ссылка	= &amp;Подразделение</queryText>
      <mainTable>Document.ПрайсЛист</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
