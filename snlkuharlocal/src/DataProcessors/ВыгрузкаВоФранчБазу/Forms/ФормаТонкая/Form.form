  <attributes>
    <name>СписокПНК</name>
    <title>
      <key>ru</key>
      <value>Список ПНК</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ВЫРАЗИТЬ(Реквизиты.ЗначениеРеквизита КАК Справочник.Подразделения) КАК ЗначениеРеквизита,
	Накладные.*,
	
	Свойства1.Значение КАК СкладПолучатель,
	Свойства2.Значение КАК ОрганизацияКонтрагента
ИЗ
	Документ.РасходнаяНакладная КАК Накладные
ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	РегистрСведений.РеквизитыСправочников КАК Реквизиты
ПО 
	Накладные.ПунктДоставки = Реквизиты.Справочник
	И Накладные.Проведен
	И Реквизиты.ИмяРеквизита = &quot;ПодразделениеФранчайзинга&quot;
	И Реквизиты.ЗначениеРеквизита = &amp;Подразделение
ЛЕВОЕ СОЕДИНЕНИЕ
	РегистрСведений.ЗначенияСвойствОбъектов КАК Свойства1
ПО
	Свойства1.Объект	 = Накладные.Ссылка
	И Свойства1.Свойство = &amp;СВ_СкладПолРНК
ЛЕВОЕ СОЕДИНЕНИЕ
	РегистрСведений.ЗначенияСвойствОбъектов КАК Свойства2
ПО
	Свойства2.Объект	 = Накладные.Контрагент
	И Свойства2.Свойство = &amp;СВ_ОрганизацияКонтр</queryText>
      <mainTable>Document.РасходнаяНакладная</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>СписокПРМ</name>
    <title>
      <key>ru</key>
      <value>Список ПРМ</value>
    </title>
    <id>3</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
