&НаСервере
Функция ПроверитьДанныеНовогоМагазинаНаСервере()	
	Сообщения		= Новый Массив;
	Подразделение	= Объект.ПодразделениеПолучатель;
	Если Подразделение.Пустая() Тогда			
		Сообщения.Добавить(СоздатьСообщение("Не указано подразделение нового магазина !","red",Истина));		
	КонецЕсли; 	
	
	Возврат Сообщения;
КонецФункции

&НаСервере
Функция СоздатьСообщение(ТекстСообщения,Цвет,Ошибка)
	Возврат Новый Структура("ТекстСообщения,Цвет,Ошибка",ТекстСообщения,Цвет,Ошибка);	
КонецФункции // ()

&НаСервереБезКонтекста
Процедура ЗарегистрироватьДокументыНаСервере(МассивСсылок)	
	ТО	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОБъектов();
	
	Для Каждого Ссылка Из МассивСсылок Цикл
		ОТ	= ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ЗначениеВСтрокуВнутр(ТипЗнч(Ссылка)));
		
		СтрокаТО				= ТО.Добавить();	
		СтрокаТО.ОбъектТип		= ОТ.ПолноеИмя;
		СтрокаТО.ОбъектСсылка   = Ссылка;
		//СтрокаТО.Получатель = ;		
		
		Если ТипЗнч(Ссылка)=Тип("ДокументСсылка.ПрайсЛист") Тогда			
			РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьЦены(Ссылка);
		ИначеЕсли ТипЗнч(Ссылка)=Тип("ДокументСсылка.УстановкаСкидок") Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьСкидки(Ссылка);
		КонецЕсли; 
		
	КонецЦикла; 
	
	ДопПараметры	= Новый Структура("РегистрироватьДопОбъекты",Ложь);
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО,ДопПараметры);	
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьДокументы(Команда)
	МассивСсылок	= Новый Массив;
	Если ТипЗнч(ЭтаФорма.ТекущийЭлемент)=Тип("ТаблицаФормы") Тогда		
		Для Каждого Элемент Из ЭтаФорма.ТекущийЭлемент.ВыделенныеСтроки Цикл	
			МассивСсылок.Добавить(Элемент);
		КонецЦикла; 
		ЗарегистрироватьДокументыНаСервере(МассивСсылок);	
	КонецЕсли; 
	
	ВывестиВТерминал("Зарегистрировано: "+МассивСсылок.Количество(),"green");
КонецПроцедуры
 
&НаКлиенте
Процедура ЗарегистрироватьПодчиненныеСправочники(Команда)
	
	МассивСсылок	= ЗарегистрироватьПодчиненныеСправочникиНаСервере(Объект.ПодразделениеПолучатель);
	
	СсылкиПотипам	= РассортироватьСсылкиПоТипам(МассивСсылок);
	Для Каждого Элемент Из СсылкиПотипам Цикл
		МассивСсылок	= Элемент.Значение;		
		ВывестиВТерминал(СтрШаблон("Зарегистрировано к выгрузке. Получатель: %1, объект: %2, кол-во: %3.",Объект.ПодразделениеПолучатель,Элемент.Ключ,МассивСсылок.Количество()),"green");
	КонецЦикла; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗарегистрироватьПодчиненныеСправочникиНаСервере(Подразделение)
	Запрос	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	Запрос.Текст="	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка
	|ПОМЕСТИТЬ ВТ_РНК
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Накладные
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.РеквизитыСправочников КАК Реквизиты
	|ПО 
	|	Накладные.ПунктДоставки = Реквизиты.Справочник
	|	И Реквизиты.ИмяРеквизита = ""ПодразделениеФранчайзинга""
	|	И Реквизиты.ЗначениеРеквизита = &Подразделение
	|;	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Автор КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Ссылки
	|ИЗ
	|	Документ.ОтчетКассовойСмены
	|ГДЕ
	|	Подразделение=&Подразделение
	|	И Проведен
	|	И НЕ Автор.ВерсияДанных ЕСТЬ NULL
	|ОБЪЕДИНИТЬ	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица
	|ГДЕ
	|	Подразделение	= &Подразделение
	|	И НЕ ПометкаУдаления
	|	И НЕ ЭтоГруппа
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ
	|	&Подразделение
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка
	|ИЗ
	|	Справочник.Кассы
	|ГДЕ
	|	Владелец=&Подразделение	
	|	И НЕ ПометкаУдаления
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	СкладПолучатель КАК Ссылка
	|ИЗ
	|	Документ.Перемещение
	|ГДЕ
	|	СкладПолучатель.Подразделение	= &Подразделение	
	|	И Проведен
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Склад КАК Ссылка
	|ИЗ
	|	Документ.Перемещение
	|ГДЕ
	|	СкладПолучатель.Подразделение	= &Подразделение	
	|	И Проведен
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Организация КАК Ссылка
	|ИЗ
	|	Справочник.Склады
	|ГДЕ
	|	Подразделение=&Подразделение	
	|	И НЕ ПометкаУдаления
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка.Контрагент КАК Ссылка
	|ИЗ
	|	ВТ_РНК	
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка.Договор КАК Ссылка
	|ИЗ
	|	ВТ_РНК
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка.Менеджер КАК Ссылка
	|ИЗ
	|	ВТ_РНК	
	|ОБЪЕДИНИТЬ	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Продавец КАК Ссылка
	|ИЗ
	|	Документ.ОтчетКассовойСмены.Товары
	|ГДЕ
	|	Ссылка.Подразделение=&Подразделение
	|	И Ссылка.Проведен
	|	И НЕ Менеджер.ВерсияДанных ЕСТЬ NULL
	|ОБЪЕДИНИТЬ
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Склад КАК Ссылка
	|ИЗ
	|	Документ.ОтчетКассовойСмены
	|ГДЕ
	|	Подразделение=&Подразделение
	|	И Проведен
	|	И НЕ Склад.ВерсияДанных ЕСТЬ NULL
	|;
	|ВЫБРАТЬ 
	|	Ссылка 
	|ИЗ 
	|	ВТ_Ссылки
	|";
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);	
	
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьВыборку(Запрос,"");
	
	Запрос.Текст="ВЫБРАТЬ Ссылка ИЗ ВТ_Ссылки";	
	
	МС	= Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Для Каждого Ссылка Из МС Цикл
		ТипСсылки = ТипЗнч(Ссылка);
		Если ТипСсылки = Тип("СправочникСсылка.Договоры") Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.СделатьЗаписьРегистрации(Ссылка,"Элемент");
		ИначеЕсли ТипСсылки = Тип("СправочникСсылка.Контрагенты") Тогда
			РегистрыСведений.ФР_ОбъектыКВыгрузке.СделатьЗаписьРегистрации(Ссылка,"Элемент");
		КонецЕсли; 	
	КонецЦикла; 
	
	
	Возврат МС;	
КонецФункции 

&НаСервере
Функция РассортироватьСсылкиПоТипам(МассивСсылок)
	СсылкиПоТипам	= Новый Соответствие;
	
	Для Каждого Ссылка Из МассивСсылок Цикл
		Если ЗначениеЗаполнено(Ссылка) Тогда		
			ОТ		= ФР_ОбщегоНазначения_ПИ.ОписаниеТипа(ЗначениеВСтрокуВнутр(ТипЗнч(Ссылка)));		
			Если ЗначениеЗаполнено(ОТ.ПолноеИмя) Тогда
				Ссылки	= СсылкиПоТипам.Получить(ОТ.ПолноеИмя);
				Если Ссылки=Неопределено Тогда
					Ссылки=Новый Массив;				
				КонецЕсли; 
				Ссылки.Добавить(Ссылка);
				СсылкиПоТипам.Вставить(ОТ.ПолноеИмя,Ссылки);			
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат СсылкиПоТипам;	
КонецФункции // ()

&НаСервере
Процедура ЗарегистрироватьКоличествоПосетителейНаСервере()
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Дата,
	|	Подразделение
	|ИЗ
	|	РегистрСведений.КоличествоПосетителей
	|ГДЕ
	|	Подразделение = &ПодразделениеПолучатель
	|	И Дата МЕЖДУ &Дата1 И &Дата2 
	|";
	
	Запрос.УстановитьПараметр("Дата1",НачалоДня(Объект.Дата1));
	Запрос.УстановитьПараметр("Дата2",КонецДня(Объект.Дата2));
	
	Запрос.УстановитьПараметр("ПодразделениеПолучатель",Объект.ПодразделениеПолучатель);	
	
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НЗ	= РегистрыСведений.КоличествоПосетителей.СоздатьНаборЗаписей();
		НЗ.Отбор.Подразделение.Установить(Выборка.Подразделение,Истина);
		НЗ.Отбор.Дата.Установить(Выборка.Дата,Истина);
		
		РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъект(НЗ);	
	КонецЦикла; 
КонецПроцедуры

