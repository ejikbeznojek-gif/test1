&НаСервере
Процедура ОбработатьБитыеСсылки(Режим)
	ТО	= ПолучитьТаблицуБитыхСсылок(СписокБитыхСсылок);
		
	Если Режим="Выгрузить" Тогда
		ОбработкаОбъект	= РеквизитФормыВЗначение("Объект");
		
		ДопПараметры	= Новый Структура("СписокОбъектов",ТО);
		Результат		= ОбработкаОбъект.ВыгрузитьПакетом("Файл",ДопПараметры);
		
		Сообщить(Результат.ВыгруженоОбъектов);		
	ИначеЕсли Режим="Инфо" Тогда
		ТекстОперации="Получена инфа";		
		КривыеОбъекты.Очистить();
		Для Каждого СтрокаТО Из ТО Цикл
			СтрокаКО				= КривыеОбъекты.Добавить();		
			СтрокаКО.ОбъектСсылка	= СтрокаТО.ОбъектСсылка;		
			СтрокаКО.ОбъектТип  	= СтрокаТО.ОбъектТип
		КонецЦикла;
	ИначеЕсли  Режим="ПоказатьАртикулы" Тогда
		Для Каждого СтрокаТО Из ТО Цикл
			Сообщить(СтрШаблон("%1,%2,%3",СтрокаТО.ОбъектТип,СтрокаТО.ОбъектСсылка.УникальныйИдентификатор(),СтрокаТО.ОбъектСсылка.КодПроизводителя));
		КонецЦикла				
	Иначе
		РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);		
	КонецЕсли;		
	
	Если Режим<>"Инфо" Тогда
		ТО.Свернуть("ОбъектТип","Количество");
		ТО.Сортировать("ОбъектТип");
		Для Каждого СтрокаТО Из ТО Цикл
			Сообщить(?(Режим="Выгрузить","Выгружено","Зарегистрировано")+": "+СтрокаТО.ОбъектТип+" : "+СтрокаТО.Количество+" об.");	
		КонецЦикла;	
	КонецЕсли;	

КонецПроцедуры

