&НаСервере
Функция ЗарегистрироватьШКпоХарактеристикамНаСервере()
	ТО	= ПолучитьТаблицуБитыхСсылок(СписокБитыхСсылок);
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка
  	|ИЗ
	|	Справочник.ШтрихКоды	
	|ГДЕ	
	|	Владелец В (&МассивНоменклатуры)	
	|	И ТипШК	= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)
	|	И НЕ Наименование ПОДОБНО ""9999%""
	|УПОРЯДОЧИТЬ ПО 	
	|	Наименование
	|";	
	
	Результат = РеквизитФормыВЗначение("Объект").ЗарегистрироватьВыборку(Запрос.Текст,"Справочник.ШтрихКоды","Элемент",Новый Структура("МассивНоменклатуры",ТО.ВыгрузитьКолонку("ОбъектСсылка")));
	
	Возврат Результат.Зарегистрировано;
КонецФункции


&НаСервере
Функция ПолучитьТаблицуБитыхСсылок(СтрокаБС)	
	ОбработкаОбъект	= РеквизитФормыВЗначение("Объект");
	
	Текст=Новый ТекстовыйДокумент;
	Текст.УстановитьТекст(СтрокаБС);
	
	ТО	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();	
	ТО.Колонки.Добавить("Количество",ПолучитьОписаниеТиповЧисла(10));
	
	ВыгруженныеОбъекты	= Новый Соответствие;
	
	Всего	=   Текст.КоличествоСтрок();
	Для Сч=1 По Текст.КоличествоСтрок() Цикл		
		ДанныеСтроки	= ФР_ОбщегоНазначения_КС.СтрокуВСтруктуру(Текст.ПолучитьСтроку(Сч),"ПолноеИмяТипа,ТекстСсылки");
		
		ПолноеИмяТипа	= ДанныеСтроки.ПолноеИмяТипа;
		ТекстСсылки		= СокрЛП(ДанныеСтроки.ТекстСсылки);
		
		Менеджер	  	= ОбработкаОбъект.ПолучитьМенеджер(ПолноеИмяТипа);
		
		Если СтрДлина(ТекстСсылки)>12 Тогда
			Ссылка	= Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(ТекстСсылки));
		Иначе
			Ссылка	= Менеджер.НайтиПоКоду(ТекстСсылки);	
		КонецЕсли;		
		
		ПолноеИмяТипаТек	= ОбработкаОбъект.ПолучитьПолноеИмяТипаТек(ПолноеИмяТипа);
		Если НЕ Ссылка.Пустая() И ОбработкаОбъект.ОбъектСуществует(Ссылка,ПолноеИмяТипаТек) Тогда			
			СтрокаТО					= ТО.Добавить();
			
			СтрокаТО.ОбъектТип			= ПолноеИмяТипаТек;
			СтрокаТО.ОбъектСсылка		= Ссылка;			
			СтрокаТО.ВариантВыгрузки	= РегистрыСведений.ФР_ОбъектыКВыгрузке.ВариантВыгрузки(Ссылка);
			СтрокаТО.Количество			= 1;
		Иначе
			Сообщить("Не найден объект: '"+ПолноеИмяТипаТек+"' по ссылке: """+ТекстСсылки+""".",СтатусСообщения.Важное);
		КонецЕсли;
		Всего=Всего-1;
		Если Всего%100=0 Тогда
			 //Состояние("Разбор данных о ссылках. Осталось: "+Всего+" строк.");
		КонецЕсли; 
	КонецЦикла;

	//Состояние("");
	
	Возврат ТО;
КонецФункции //ПолучитьТаблицуБитыхСсылок(СтрокаБС)

&НаСервере
Функция ТЗвМассивСтруктур(ТЗ)
	Колонки	= Новый Массив;
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Колонки.Добавить(Колонка.Имя);	
	КонецЦикла; 
	
	СтрокаКолонок	= СтрСоединить(Колонки,",");
	
	Результат	= Новый Массив;
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		ДанныеСтроки	= Новый Структура(СтрокаКолонок);	
		ЗаполнитьЗначенияСвойств(ДанныеСтроки,СтрокаТЗ);
		
		Результат.Добавить(ДанныеСтроки);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции //ТЗвМассивСтруктур(ТЗ)
 

