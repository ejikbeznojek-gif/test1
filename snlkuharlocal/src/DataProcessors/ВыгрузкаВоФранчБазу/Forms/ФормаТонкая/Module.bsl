КонецПроцедуры

Функция ЗарегистрироватьЦеныПоставщикаНаСервере(Подразделение)
	ОбработкаОбъект	= РеквизитФормыВЗначение("Объект");
	
	Запрос	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц=Новый МенеджерВременныхТаблиц;
	Запрос.Текст="
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка
	|ПОМЕСТИТЬ ВТ_РНК
	|ИЗ
	|	Документ.РасходнаяНакладная КАК Накладные
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.РеквизитыСправочников КАК Реквизиты
	|ПО 
	|	Накладные.ПунктДоставки = Реквизиты.Справочник
	|	И Реквизиты.ИмяРеквизита = ""ПодразделениеФранчайзинга""
	|	И Реквизиты.ЗначениеРеквизита = &Подразделение
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	Ссылка.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВТ_Контрагенты
	|ИЗ
	|	ВТ_РНК	
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	ТипЦен 
	|ПОМЕСТИТЬ ВТ_ТипыЦен
	|ИЗ 
	|	Справочник.Контрагенты.Скидки 
	|ГДЕ 
	|	Ссылка В (ВЫБРАТЬ Контрагент ИЗ ВТ_Контрагенты)
	|;	
	|ВЫБРАТЬ Контрагент ИЗ ВТ_Контрагенты
	|";
	
	Запрос.УстановитьПараметр("Подразделение",	Подразделение);		
	Запрос.УстановитьПараметр("Дата1",			НачалоДня(Объект.Дата1));
	
	ТО	= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТО 					= ТО.Добавить();
		
		СтрокаТО.ОбъектТип 			= "Справочник.Контрагенты";
		СтрокаТО.ОбъектСсылка		= Выборка.Контрагент;
		СтрокаТО.ВариантВыгрузки	= "Документ.ЦеныПоставщика";
	КонецЦикла;
	
	Запрос.Текст="ВЫБРАТЬ ТипЦен ИЗ ВТ_ТипыЦен";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТО 					= ТО.Добавить();
		
		СтрокаТО.ОбъектТип 			= "Справочник.ТипыЦен";
		СтрокаТО.ОбъектСсылка		= Выборка.ТипЦен;
		СтрокаТО.ВариантВыгрузки	= "Элемент";
	КонецЦикла;	
	
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	Ссылка КАК Прайс,
	|	Ссылка.ТипЦен КАК ТипЦен
	|ИЗ
	|	Документ.ПрайсЛист
	|ГДЕ
	|	Дата2 >= &Дата1
	|	И Проведен
	|	И ТипЦен В (ВЫБРАТЬ ТипЦен ИЗ ВТ_ТипыЦен)
	|";	
	
	Если ЗначениеЗаполнено(Объект.Дата1) Тогда
		Выборка	= Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТО 					= ТО.Добавить();
		
			СтрокаТО.ОбъектТип 			= "Документ.ПрайсЛист";
			СтрокаТО.ОбъектСсылка		= Выборка.Прайс;			
			
			//Процедура ЗаполнитьСтрокуРегистрации_РС(СтрокаТО,Вид,Отбор) Экспорт
			
			СтрокаТО 					= ТО.Добавить();
		
			СтрокаТО.ОбъектТип 			= "Документ.ПрайсЛист";
			СтрокаТО.ОбъектСсылка		= Выборка.Прайс;		
			
			Отбор=Новый Структура("Прайс,ТипЦен");
			ЗаполнитьЗначенияСвойств(Отбор,Выборка);
			ОбработкаОбъект.ЗаполнитьСтрокуРегистрации_РС(СтрокаТО,"ЦеныНоменклатуры",Отбор);			
		КонецЦикла;	
	КонецЕсли;
	
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);		
	
КонецФункции

