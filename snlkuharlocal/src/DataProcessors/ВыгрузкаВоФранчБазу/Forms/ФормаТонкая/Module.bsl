&НаКлиенте
Функция ПолучитьСсылкиНаНакладные()
	МассивСсылок	= Новый Массив;
	
	Если ЭтаФорма.ТекущийЭлемент=Элементы.СписокПНК Тогда
		ТекСписок	= Элементы.СписокПНК;		
	ИначеЕсли ЭтаФорма.ТекущийЭлемент=Элементы.СписокПРМ Тогда			
		ТекСписок	= Элементы.СписокПРМ;
	Иначе
		Возврат МассивСсылок;
	КонецЕсли; 
	
	
	Для Каждого Строка Из ТекСписок.ВыделенныеСтроки Цикл
		МассивСсылок.Добавить(Строка);	
	КонецЦикла;

	Возврат МассивСсылок;
КонецФункции // ()

