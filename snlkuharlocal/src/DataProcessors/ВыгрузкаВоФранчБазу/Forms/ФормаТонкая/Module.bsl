&НаСервере
Процедура УстановитьОтборДокументов()
	
	СВ_ПодразделениеРНК 	= ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоКоду("00295");
	СВ_СкладПолРНК			= ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоКоду("00296");	
	СВ_ОрганизацияКонтр 	= ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоКоду("00297");
	
	СписокПНК.Параметры.УстановитьЗначениеПараметра("СВ_СкладПолРНК", 		СВ_СкладПолРНК);
	СписокПНК.Параметры.УстановитьЗначениеПараметра("СВ_ОрганизацияКонтр", 	СВ_ОрганизацияКонтр);
	
	//Документы	
	СписокИНВ.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокОКС.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокОПР.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокСПН.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокПНК.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокПНК_ВЗВ.Параметры.УстановитьЗначениеПараметра("Подразделение", 	Объект.ПодразделениеПолучатель);
    СписокПРМ.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);	
	СписокПРМ_ВЗВ.Параметры.УстановитьЗначениеПараметра("Подразделение", 	Объект.ПодразделениеПолучатель);	
	СписокРНК.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокПРЛ.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокУСК.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокЭПС.Параметры.УстановитьЗначениеПараметра("Подразделение", 		Объект.ПодразделениеПолучатель);
	СписокВВодОст.Параметры.УстановитьЗначениеПараметра("Подразделение", 	Объект.ПодразделениеПолучатель);
	
	//Справочники
	СписокКасс.Параметры.УстановитьЗначениеПараметра("Подразделение", Объект.ПодразделениеПолучатель);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПНК_ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("СостояниеНакладной");	
	
	СписокНакладных_ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки, МассивРеквизитов);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПРМ_ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("СостояниеНакладной");
	
	СписокНакладных_ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки, МассивРеквизитов);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокНакладных_ПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки, МассивРеквизитов) Экспорт
	
	ВыделяемыеЦветомСостояния = Новый Массив;
	ВыделяемыеЦветомСостояния.Добавить(Перечисления.СостоянияНакладной.Отгружена);
	ВыделяемыеЦветомСостояния.Добавить(Перечисления.СостоянияНакладной.Принята);
	
	Для Каждого СтрокаДинСписка Из Строки Цикл
		
		Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
			
			ДанныеСтроки		= СтрокаДинСписка.Значение.Данные;
			ОформлениеСтроки	= СтрокаДинСписка.Значение.Оформление;
			
			ТекСостояние	= ДанныеСтроки[ИмяРеквизита];			
			ОформлениеПоля	= ОформлениеСтроки[ИмяРеквизита];
			
			УстановитьПараметрОформленияПоля(ОформлениеПоля, "Текст", ФР_ОбщегоНазначения_ПИ.БукваСостоянияНакладной_(ТекСостояние));
			
			Если ВыделяемыеЦветомСостояния.Найти(ТекСостояние) <> Неопределено Тогда
				УстановитьПараметрОформленияПоля(ОформлениеПоля, "ЦветФона", WebЦвета.СветлоЗеленый);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьПараметрОформленияПоля(ОформлениеПоля, ПараметрОформления, Значение)
	ЭлементОформления = ОформлениеПоля.Элементы.Найти(ПараметрОформления);
	Если ЭлементОформления <> Неопределено Тогда
		ЭлементОформления.Значение = Значение;
	КонецЕсли;
КонецПроцедуры


