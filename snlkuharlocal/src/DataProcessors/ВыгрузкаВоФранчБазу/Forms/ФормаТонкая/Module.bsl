&НаКлиенте
Процедура ВыгрузитьСсылки_СтандартныйФормат(Команда)
	
	ИмяФайла = ВыбратьФайл();
	Если ПустаяСтрока(ИмяФайла) Тогда Возврат КонецЕсли; 
	
	МассивСсылок = ПолучитьТаблицуБитыхСсылок(СписокБитыхСсылок).ВыгрузитьКолонку("ОбъектСсылка");
	
	//СтрокаXML = ПолучитьСтрокуXML(ПараметрКоманды);
	Результат	= ВыгрузитьВXML(МассивСсылок);
	Ошибки		= Результат.Ошибки;
	Если Ошибки.Количество()=0 Тогда
		СтрокаXML	= ПолучитьИзВременногоХранилища(Результат.Адрес);
		
		ЗаписатьСтрокуВФайл(СтрокаXML, ИмяФайла);	
		
		ПоказатьОповещениеПользователя("Выгрузка в файл XML завершена.", , , БиблиотекаКартинок.ЗакончитьРедактирование, СтатусОповещенияПользователя.Важное);  
	Иначе
		ПоказатьПредупреждение(,СтрШаблон("Ошибка выгрузки в файл XML !%1%2",Символы.ПС,СтрСоединить(Ошибки,Символы.ПС)));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ВыбратьФайл()
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Выберите файл для сохранения";
	Диалог.ПолноеИмяФайла = "";
	Диалог.ПредварительныйПросмотр = Ложь;
	Диалог.Фильтр = "Файлы XML (*.xml)|*.xml";
	
	мИмяФайла = "";	
	Если Диалог.Выбрать() Тогда
		мИмяФайла = Диалог.ПолноеИмяФайла;	
	КонецЕсли;	
	
	Возврат мИмяФайла;
КонецФункции //ВыбратьФайл()

&НаКлиенте
Процедура ЗаписатьСтрокуВФайл(Строка, ИмяФайла)
	ЗаписьТекста = Новый ЗаписьТекста;
	ЗаписьТекста.Открыть(ИмяФайла);
	ЗаписьТекста.Записать(Строка);
	ЗаписьТекста.Закрыть();
КонецПроцедуры 
 

&НаСервере
Функция ВыгрузитьВXML(МассивСсылок)			
	Результат	= Новый Структура("Адрес,Ошибки",Неопределено,Новый Массив);
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();		
				
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("_1CV8DtUD", "http://www.1c.ru/V8/1CV8DtUD/");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("V8Exch", "http://www.1c.ru/V8/1CV8DtUD/");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("v8",  "http://v8.1c.ru/data");
	ЗаписьXML.ЗаписатьНачалоЭлемента("V8Exch:Data");
	
	Для Каждого Ссылка Из МассивСсылок Цикл	
		ЗаписатьXML(ЗаписьXML,Ссылка.ПолучитьОбъект());			
	КонецЦикла;
		
	ЗаписьXML.ЗаписатьКонецЭлемента(); //V8Exc:Data
	ЗаписьXML.ЗаписатьКонецЭлемента(); //V8Exc:_1CV8DtUD	
	
	СтрДанных		= ЗаписьXML.Закрыть();
	Результат.Адрес	= ПоместитьВоВременноеХранилище(СтрДанных);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ВыгрузитьСсылки(Элемент)
	ИмяФайла = ВыбратьФайл();
	Если ПустаяСтрока(ИмяФайла) Тогда Возврат КонецЕсли;
	
	ТО 			= ПолучитьТаблицуБитыхСсылок(СписокБитыхСсылок);
	Результат 	= ВыгрузитьСсылкиНаСервере(ТО.ВыгрузитьКолонку("ОбъектСсылка"));
	
	ЗаписатьСтрокуВФайл(Результат.Данные, ИмяФайла);	
	
	ПоказатьОповещениеПользователя("Сохранен файл",,ИмяФайла,,СтатусОповещенияПользователя.Информация);
КонецПроцедуры

&НаСервере
Функция ВыгрузитьСсылкиНаСервере(МассивСсылок)
	
	СписокОбъектов	= Новый Массив;
	Для Каждого Ссылка Из МассивСсылок Цикл		
		Если РегистрыСведений.ФР_ОбъектыКВыгрузке.НужноРегистрироватьОбъект(Ссылка).Нужно Тогда
			СписокОбъектов.Добавить(Ссылка);	
		КонецЕсли; 
	КонецЦикла;	
	
	ОбрОбъект 		= РеквизитФормыВЗначение("Объект");
	ОбрОбъект.ИмяФайлаОбмена	= "";
	ОбрОбъект.УзелПолучатель	= ПланыОбмена.ФР_ОбменСФРК.НайтиПоКоду("CO_FR");
	
	ДопПараметры	= Новый Структура("СписокОбъектов", СписокОбъектов);
	
	Результат		= РеквизитФормыВЗначение("Объект").ВыгрузитьПакетом("Файл", ДопПараметры);
	
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ЗарегитьДекларацииПоМодели(Элемент)
	
	Зарегистрировть_рсИстория_ДекларацииПоМодели_НаСервере();
	
КонецПроцедуры

&НаСервере
Процедура Зарегистрировть_рсИстория_ДекларацииПоМодели_НаСервере()
	ТабСсылки	= ПолучитьТаблицуБитыхСсылок(СписокБитыхСсылок);
	
	Запрос = Новый Запрос;
	Запрос.Текст	= "	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Ссылки ИЗ &ТабСсылки КАК ТабСсылки
	|;	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбъектСсылка КАК Модель	
	|ПОМЕСТИТЬ
	|	ВТ_Номенклатура
	|ИЗ
	|	ВТ_Ссылки
	|ГДЕ
	|	ОбъектСсылка ССЫЛКА Справочник.Номенклатура 
	|;
	|ВЫБРАТЬ 	
	|	История.Объект			КАК Объект,
	|	История.Реквизит		КАК Реквизит,
	|	История.Значение		КАК Значение,
	|	История.Документ		КАК Документ,
	|	ПоследниеПериоды.Период	КАК Период	
	|ИЗ
	|	РегистрСведений.История	КАК История
	|ПРАВОЕ СОЕДИНЕНИЕ	
	|(
	|ВЫБРАТЬ
	|	Объект 				КАК Номенклатура,
	|	Реквизит			КАК Реквизит,
	|	МАКСИМУМ(Период)	КАК Период
	|ИЗ
	|	РегистрСведений.История
	|ГДЕ 	
	|	Объект ССЫЛКА Справочник.Номенклатура
	|	И Реквизит = ""Декларация""
	|	И НЕ ВЫРАЗИТЬ(Объект КАК Справочник.Номенклатура).ВерсияДанных ЕСТЬ NULL
	|	И Объект В (ВЫБРАТЬ РАЗЛИЧНЫЕ Модель ИЗ ВТ_Номенклатура)
	|СГРУППИРОВАТЬ ПО
	|	Объект,
	|	Реквизит
	|) КАК ПоследниеПериоды
	|ПО
	|	История.Период = ПоследниеПериоды.Период
	|	И История.Объект ССЫЛКА Справочник.Номенклатура
	|	И История.Объект	= ПоследниеПериоды.Номенклатура
	|	И История.Реквизит	= ПоследниеПериоды.Реквизит	
	|УПОРЯДОЧИТЬ ПО Объект
	|";
	
	
	Запрос.УстановитьПараметр("ТабСсылки", ТабСсылки);
	
	ТО			= РегистрыСведений.ФР_ОбъектыКВыгрузке.СоздатьТаблицуОбъектов();
	
	Результат	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	Сч=Выборка.Количество();
	
	Пока Выборка.Следующий() Цикл
		//ОбработкаПрерыванияПользователя();
		
		НЗ	= РегистрыСведений.История.СоздатьНаборЗаписей();
		
		НЗ.Отбор.Период.Установить(Выборка.Период,Истина);	
		НЗ.Отбор.Объект.Установить(Выборка.Объект,Истина);
		НЗ.Отбор.Реквизит.Установить(Выборка.Реквизит,Истина);
		НЗ.Отбор.Документ.Установить(Выборка.Документ,Истина);
		
		СтрокаТО	= ТО.Добавить();
		
		СтрокаТО.ОбъектСсылка		= Выборка.Объект;		
		СтрокаТО.ВариантВыгрузки	= "РегистрСведений.История";
		СтрокаТО.ОтборРС			= Новый ХранилищеЗначения(ЗначениеВСтрокуВнутр(НЗ.Отбор));		
		СтрокаТО.ОтборРС_Хэш		= ФР_ОбщегоНазначения_С.ХэшСтрока(СтрокаТО.ОтборРС);	
		
		СтрокаТО	= ТО.Добавить();		
		СтрокаТО.ОбъектСсылка		= Выборка.Значение;
		
		Сч=Сч-1;
		Если Сч%100=0 Тогда
			//Состояние(Сч);		
		КонецЕсли; 
	КонецЦикла; 
			
	РегистрыСведений.ФР_ОбъектыКВыгрузке.ЗарегистрироватьОбъекты(ТО);	
	Сообщить("Зарегистрировано: "+ТО.Количество());
КонецПроцедуры