Функция НайтиАдресПД (Индекс, город, улица,Контрагент)
	
	
	Запрос = Новый Запрос;
	запрос.текст = 	"ВЫБРАТЬ
	|	Адрес.Индекс КАК Индекс,
	|	Адрес.Регион КАК Регион,
	|	Адрес.Район КАК Район,
	|	Адрес.Город КАК Город,
	|	Адрес.НаселенныйПункт КАК НаселенныйПункт,
	|	Адрес.Улица КАК Улица,
	|	Адрес.Дом КАК Дом,
	|	Адрес.Объект.Ссылка.Владелец КАК ОбъектСсылка,
	|	Адрес.Объект.Ссылка КАК ПД
	|ИЗ
	|	(ВЫБРАТЬ
	|		КонтактнаяИнформация.Объект КАК Объект,
	|		КонтактнаяИнформация.Поле1 КАК Индекс,
	|		КонтактнаяИнформация.Поле2 КАК Регион,
	|		КонтактнаяИнформация.Поле3 КАК Район,
	|		КонтактнаяИнформация.Поле4 КАК Город,
	|		КонтактнаяИнформация.Поле5 КАК НаселенныйПункт,
	|		КонтактнаяИнформация.Поле6 КАК Улица,
	|		КонтактнаяИнформация.Поле7 КАК Дом
	|	ИЗ
	|		РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|	ГДЕ
	|		КонтактнаяИнформация.Вид = &Вид
	|		И КонтактнаяИнформация.Тип = &Тип) КАК Адрес
	|ГДЕ
	|	Адрес.Объект.Владелец = &текконтр
	|	И Адрес.Индекс = &ТекИндекс
	|
	|УПОРЯДОЧИТЬ ПО
	|	Индекс"; 
	
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.АдресДоставкиКонтрагента);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес);
	Запрос.УстановитьПараметр("ТекИндекс", Индекс);
	Запрос.УстановитьПараметр("текконтр", Контрагент);
	
	РЕз = запрос.Выполнить().Выбрать();
	ПД = неопределено;
	Пока рез.Следующий() цикл
		
		ТекПД = рез.ПД;
		Наименование = ТекПД.Наименование;			               
		
		Если СтрНайти(Наименование, "на прямую") > 0 Тогда
			продолжить;;
		Иначе
			ПД = ТекПД;
			прервать;
		КонецЕсли; 
	КонецЦикла;
		
	возврат ПД;
	
	
КонецФункции	

 
