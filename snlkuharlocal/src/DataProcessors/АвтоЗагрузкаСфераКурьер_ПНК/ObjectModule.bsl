			Иначе
				Строка = "Для РНК "+Выборка.Ссылка+" пришла корректировка, но документ уже отправлен на склад. Дальнейшая загрузка РНК прекращается.";
				Ошибки.Добавить(Строка);
				Возврат Неопределено;
			КонецЕсли;
		Иначе
			Строка = "Для заказа № "+НомерЗаказа+" пришла корректировка, но РНК не обнаружена. Будет создан новый документ";
			Ошибки.Добавить(Строка);
			Возврат Документы.РасходнаяНакладная.СоздатьДокумент();
		КонецЕсли;
	Конецесли;
КонецФункции
