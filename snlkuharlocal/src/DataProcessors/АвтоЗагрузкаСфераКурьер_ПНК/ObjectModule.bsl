Процедура ПроверитьФайлыНаФТП()
	Запрос = Новый Запрос;
	ЗапросДок = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрФайловЕКОД.ПолноеИмяФайла,
	|	РегистрФайловЕКОД.НомерЗаказа,
	|	РегистрФайловЕКОД.ДатаЗаказа,
	|	РегистрФайловЕКОД.Узел
	|ИЗ
	|	РегистрСведений.РегистрФайловЕКОД КАК РегистрФайловЕКОД
	|ГДЕ
	|	РегистрФайловЕКОД.Документ_Создан = ЛОЖЬ";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		// Находим документ по номеру и дате заказа
		Если Найти(Выборка.ПолноеИмяФайла, "ORDER") > 0 Тогда
			ЗапросДок.Текст =
			"ВЫБРАТЬ
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.НомерЗаказа = &НомерЗаказа
			|	И РасходнаяНакладная.ДатаЗаказа = &ДатаЗаказа
			|	И РасходнаяНакладная.Склад.Подразделение = &Подразделение";
			поз = Найти(Выборка.ПолноеИмяФайла, "ORDER");
		Иначе
			ЗапросДок.Текст =
			"ВЫБРАТЬ
			|	АктПриемки.Ссылка
			|ИЗ
			|	Документ.АктПриемки КАК АктПриемки
			|ГДЕ
			|	АктПриемки.НомерЗаказа = &НомерЗаказа
			|	И АктПриемки.ДатаЗаказа = &ДатаЗаказа
			|	И АктПриемки.РНК.Склад.Подразделение = &Подразделение";
			поз = Найти(Выборка.ПолноеИмяФайла, "RECADV");
		КонецЕсли;
		ЗапросДок.УстановитьПараметр("НомерЗаказа", Выборка.НомерЗаказа);
		ЗапросДок.УстановитьПараметр("ДатаЗаказа", Выборка.ДатаЗаказа); 
		ЗапросДок.УстановитьПараметр("Подразделение", Выборка.Узел.Подразделение);
		ВыборкаДок = ЗапросДок.Выполнить().Выбрать();
		Если ВыборкаДок.Количество() > 0 Тогда
			ПутьКФайлу = Лев(Выборка.ПолноеИмяФайла, поз-1);
			ИмяФайла = СтрЗаменить(Выборка.ПолноеИмяФайла, ПутьКФайлу, "");
			//Катаев+ 26/06/13 Добавил проверку на наличие слеша. Если он есть то оставляем только то что после него находится.
			поз = Найти(ИмяФайла,"\");
			Если поз > 0 Тогда
				ИмяФайла = Прав(ИмяФайла,стрДлина(имяФайла)-поз);
			КонецЕсли;
			//Катаев- 26/06/13
			
			//нечаева 23,05,17+++
			ПутьКФТП = "\\srvftp\ftp_1c$\snl\ecod\"+Выборка.Узел.Код+"\";
			//нечаева 23,05,17---
			
			// Удаляем файл с фтп
			//Катаев+ 14/07/14 На фтп из имени файла убраны русские буквы
			//УдалитьФайлы(ПутьКФТП, ИмяФайла);
			ИмяФайлаНаФТП = УбратьРБ(ИмяФайла);
			УдалитьФайлы(ПутьКФТП, ИмяФайлаНаФТП);
			//Катаев- 14/07/14
			// Переносим файл из папки ЕКОД в архив
			фф = новый файл(ПутьКФайлу+"ARHIV\");
			Если НЕ фф.Существует() Тогда
				//создатькаталог(ПутьКФайлу+"ARHIV\");
				попытка
					создатькаталог(ПутьКФайлу+"ARHIV\");
				исключение
					#Если клиент тогда
						сообщить(" +++++++++++++++++"+ПутьКФайлу);
					#конецесли	
				конецпопытки;
				
			КонецЕсли;	
			ИмяДляЗаписи=ПутьКФайлу+"ARHIV\"+ИмяФайла;
			Попытка
				КопироватьФайл(Выборка.ПолноеИмяФайла,ИмяДляЗаписи);
			Исключение
			КонецПопытки;	
			// Отмечаем в регистре сведений что документ создан, что бы впоследсвии не проверять его
			рег = РегистрыСведений.РегистрФайловЕКОД;
			Отбор = Новый Структура("ПолноеИмяФайла");
			Отбор.ПолноеИмяФайла = Выборка.ПолноеИмяФайла;
			ВыборкаРег = рег.Выбрать(Отбор,"Возр");
			Если ВыборкаРег.Следующий() Тогда
				СтрокаРег = ВыборкаРег.ПолучитьМенеджерЗаписи();
				СтрокаРег.Прочитать();
				СтрокаРег.Документ_Создан = Истина;
				СтрокаРег.Записать(Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ПереносФайловНаФТП()
	Путь = Новый СписокЗначений;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИЛН_Организации.Наименование,
	|	ИЛН_Организации.Узел
	|ИЗ
	|	Справочник.ИЛН_Организации КАК ИЛН_Организации
	|ГДЕ
	|	ИЛН_Организации.ПометкаУдаления = ЛОЖЬ
	|	И ИЛН_Организации.Узел <> &Узел";
	Запрос.УстановитьПараметр("Узел",ПланыОбмена.Основной.ЭтотУзел());
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Путь1 = Константы.КаталогЕКОД.Получить()+Выборка.Наименование+"\.config\filebase.xml";
		Файл = Новый ЧтениеXML;
		Попытка                              
			Файл.ОткрытьФайл(Путь1);
		Исключение
			Продолжить;
		КонецПопытки;
		Пока Файл.Прочитать() Цикл
			Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "doc_type" Тогда
				файл.Прочитать();
				ТипДок = Файл.Значение;
			КонецЕсли;
			
			Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "file_path" Тогда
				файл.Прочитать(); 
				ТекПуть = Файл.Значение;
				//заменяем c:\ediConnector2\ediEcod\
				Нов=Прав(ТекПуть,СтрДлина(ТекПуть)-25);
				Нов=Константы.КаталогЕКОД.Получить()+Нов;
				ТекПуть=Нов;
			КонецЕсли;
			
			Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "partner" и (ТипДок="ORDER" ИЛИ ТипДок="RECADV") Тогда
				ФайлКоп = Новый Файл(ТекПуть);
				//Катаев+ 24/04/13 для удобства сделал отдельную процедуру
				СохранитьФайлНаФТП(ФайлКоп, Выборка.Узел.Код, ТекПуть)
				//Катаев- 24/04/13
			Конецесли;
		КонецЦикла;
		Файл.Закрыть();
	КонецЦикла;
КонецПроцедуры

Процедура ПереносФайловСФТП(ТекущийУзел)
	Узел = ПланыОбмена.Основной.НайтиПоКоду("SNL");
	Соединение=УстановитьFTPСоединение(Узел.АдресОбмена,Узел.Пользователь,Узел.Пароль,,Узел.ПассивныйРежим);
	Попытка
		//нечаева 23,05,17+++
		Файлы = Соединение.НайтиФайлы("/SNL/ECod/"+ТекущийУзел.Код+"/","*.*");
		//нечаева 23,05,17---
	Исключение
		//сообщить(ОписаниеОшибки());
		Возврат;
	КонецПопытки;
	Для Каждого Файл Из Файлы Цикл
		ИмяФайлаСообщения = Файл.ПолноеИмя;
		ИмяФайлаФилиала = Константы.КаталогЕКОД.Получить()+Файл.Имя;
		// Проверяем  копировали уже файл или нет
		Запрос1 = Новый Запрос;
		Запрос1.Текст =
		"ВЫБРАТЬ
		|	РегистрФайловЕКОД.ПолноеИмяФайла,
		|	РегистрФайловЕКОД.Документ_Создан
		|ИЗ
		|	РегистрСведений.РегистрФайловЕКОД КАК РегистрФайловЕКОД
		|ГДЕ
		|	РегистрФайловЕКОД.ПолноеИмяФайла ПОДОБНО &ПолноеИмяФайла";
		Запрос1.УстановитьПараметр("ПолноеИмяФайла", ИмяФайлаФилиала);
		Выборка1 = Запрос1.Выполнить().Выбрать();
		Если Выборка1.Количество() = 0 Тогда
			Соединение.Получить(ИмяФайлаСообщения, ИмяФайлаФилиала);
			РазмерОригинал = Файл.Размер();
			ФайлФилиала = Новый Файл(ИмяФайлаФилиала);
			РазмерФилиал = ФайлФилиала.Размер();
			Если РазмерФилиал = РазмерОригинал Тогда
				Запись=РегистрыСведений.РегистрФайловЕКОД.СоздатьМенеджерЗаписи();
				Запись.Дата = ТекущаяДата();
				Запись.ПолноеИмяФайла = ИмяФайлаФилиала;
				Запись.Узел = ПланыОбмена.Основной.ЭтотУзел();
				Запись.Документ_Создан = Ложь;
				Запись.Записать(Ложь);
			Иначе	
				УдалитьФайлы(ФайлФилиала.Путь, ФайлФилиала.Имя);
			КонецЕсли;
		Конецесли;
	КонецЦикла;
КонецПроцедуры

Функция СформироватьПутиФайловФилиала()
	ТекПуть = Константы.КаталогЕКОД.Получить();
	Результат33 = Новый Массив(10000,3);
	//Катаев+ 28/06/13
	//Файлы = НайтиФайлы(ТекПуть,"*.*");
	Файлы = НайтиФайлы(ТекПуть,"*.xml");
	//Катаев- 28/06/13
	номПП = 1;
	Для каждого Файл из Файлы Цикл
		Если Файл.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;
		Если Найти(Файл.Имя, "ORDER") <> 0 Тогда
			ТипДок = "ORDER";
		Иначе
			ТипДок = "RECADV";
		КонецЕсли;
		Результат33[НомПП][0]=Файл.ПолноеИмя;
		Результат33[НомПП][1]="";                  
		Результат33[НомПП][2]=ТипДок;                  
		НомПП=НомПП+1;
		фф = новый файл(ТекПуть+"ARHIV\");
		Если НЕ фф.Существует() Тогда
			//создатькаталог(ТекПуть+"ARHIV\");
			попытка
				создатькаталог(ТекПуть+"ARHIV\");
			исключение
				#Если клиент тогда
					сообщить("++++++++++++++++++++++"+ТекПуть);
				#конецесли	
			конецпопытки;
			
		КонецЕсли;	
		ИмяДляЗаписи=ТекПуть+"ARHIV\"+Файл.Имя;
		Попытка
			КопироватьФайл(Файл.ПолноеИмя,ИмяДляЗаписи);
		Исключение
		КонецПопытки;	
	КонецЦикла;
	Возврат Результат33;
КонецФункции
