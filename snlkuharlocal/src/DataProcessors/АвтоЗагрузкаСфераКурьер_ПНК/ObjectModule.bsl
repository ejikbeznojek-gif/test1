Функция ПолучитьНомераУпаковокНом(ТекТовар,ДокОбъект)
	
	ТЗ = Новый ТаблицаЗначений;
	
	ТекДок = ДокОбъект.Ссылка;
	
	Запрос = Новый запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЛистНабораТовары.Количество КАК Количество,
	|	ЛистНабораТовары.Номенклатура,
	|	ЛистНабораТовары.ТипШК,
	|	ВЫРАЗИТЬ(ВложенныйЗапрос.SSCCКод КАК СТРОКА(50)) КАК Номер,
	|	ВложенныйЗапрос.ЛистНабора
	|ИЗ
	|	Документ.ЛистНабора.Товары КАК ЛистНабораТовары
	|		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПаллетаЛистыНабора.Ссылка.SSCCКод КАК SSCCКод,
	|			ПаллетаЛистыНабора.Ссылка КАК Ссылка,
	|			ПаллетаЛистыНабора.ЛистНабора КАК ЛистНабора
	|		ИЗ
	|			Документ.Паллета.ЛистыНабора КАК ПаллетаЛистыНабора
	|		ГДЕ
	|			ПаллетаЛистыНабора.ЛистНабора.Проведен = ИСТИНА) КАК ВложенныйЗапрос
	|		ПО ЛистНабораТовары.Ссылка = ВложенныйЗапрос.ЛистНабора
	|ГДЕ
	|	ЛистНабораТовары.Ссылка.ДокОснование = &ТекРНК
	|	И ЛистНабораТовары.Номенклатура в иерархии(&ТекНом)
	//нечаева 03,03,17++
	|	И ЛистНабораТовары.Ссылка.ПометкаУдаления = ложь
	|	И ВложенныйЗапрос.Ссылка.Проведен = истина";
	//нечаева 03,03,17--
	
	запрос.УстановитьПараметр("ТекРНК",ТекДок.ссылка);
	запрос.УстановитьПараметр("ТекНом",ТекТовар);
	резПалетты = Запрос.Выполнить().Выгрузить();
	//11,04,17 ++
	резПалетты.Колонки.Добавить("Продукция");
	//11,04,17 --
	КолПаллет = резПалетты.Количество();
	
	//11,04,17 ++
	//нечаева , если переклейка, или комплектация белье, тогда палетный ярлык по продукции, а не по номенклатуре.  
	Если  ДокОбъект.Ссылка.ОтгрузкаКомплектов Тогда
		
		ТЗПродукция = ДокОбъект.Комплектующие.Выгрузить();
		//заполним продукцию.		
		//11,04,17 ++
		//нечаева , если переклейка, или комплектация белье, тогда палетный ярлык по продукции, а не по номенклатуре.  
		Если  ДокОбъект.Ссылка.ОтгрузкаКомплектов Тогда
			
			ТЗПродукция = ДокОбъект.Комплектующие.Выгрузить();
			//заполним продукцию.		
			Для каждого текстрока из резПалетты Цикл
				НайденнаяСтрока = ТЗПродукция.Найти(ТекСтрока.номенклатура,"номенклатура");
				Если НайденнаяСтрока <> Неопределено ТОгда
					ТекСтрока.Продукция = НайденнаяСтрока.Продукция;
				КонецЕсли;
			КонецЦикла;		
			
		КонецЕсли;	
		
	КонецЕсли;	
	//11,04,17 --
	
	ТЗ = резПалетты;
	
	
	возврат ТЗ;
	
