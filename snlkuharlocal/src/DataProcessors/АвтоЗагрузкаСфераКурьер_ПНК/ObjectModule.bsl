//Катаев+ 24/04/13
Процедура СохранитьФайлНаФТП(ФайлКоп, Филиал, ТекПуть)
	Если ФайлКоп.Существует() Тогда
		Запрос1 = Новый Запрос;
		Запрос1.Текст =
		"ВЫБРАТЬ
		|	РегистрФайловЕКОД.ПолноеИмяФайла,
		|	РегистрФайловЕКОД.Документ_Создан
		|ИЗ
		|	РегистрСведений.РегистрФайловЕКОД КАК РегистрФайловЕКОД
		|ГДЕ
		|	РегистрФайловЕКОД.ПолноеИмяФайла ПОДОБНО &ПолноеИмяФайла";
		Запрос1.УстановитьПараметр("ПолноеИмяФайла", ТекПуть);
		Выборка1 = Запрос1.Выполнить().Выбрать();
		Если Выборка1.Количество() = 0 Тогда
			// считываем номер и дату заказа
			ФайлЕКОД = Новый ЧтениеXML;
			ФайлЕКОД.ОткрытьФайл(ТекПуть);
			НомерЗаказа = "";
			ДатаЗаказа = Дата(1,1,1);
			Пока ФайлЕКОД.Прочитать() Цикл
				Если ФайлЕКОД.ТипУзла = ТипУзлаXML.НачалоЭлемента И (ФайлЕКОД.ЛокальноеИмя = "OrderNumber" или ФайлЕКОД.ЛокальноеИмя = "BuyerOrderNumber") Тогда
					ФайлЕКОД.Прочитать();
					НомерЗаказа = ФайлЕКОД.Значение;
				КонецЕсли;
				Если ФайлЕКОД.ТипУзла = ТипУзлаXML.НачалоЭлемента И (ФайлЕКОД.ЛокальноеИмя = "OrderDate" или ФайлЕКОД.ЛокальноеИмя ="BuyerOrderDate") Тогда
					ФайлЕКОД.Прочитать();
					ДатаЗаказа = Дата(СтрЗаменить(ФайлЕКОД.Значение,"-",""));
				КонецЕсли;
			КонецЦикла;
			ФайлЕКОД.Закрыть();        // \\srvftp\ftp_1c$\snl\ecod\
			//нечаева 23,05,17+++ новый путь
			//ПутьФТП = "\\srvftp\ftp_1c$\snl\ecod\"+Филиал+"\";
			//нечаева 20,09,23+++
			//ПутьФТП = "\\srvbase-ekf\1C_Base\E-COD\";
			ПутьФТП = "\\srv1c-ekf\E-COD\";
			//нечаева 20,09,23---
			Каталог = Новый Файл(ПутьФТП);
			Если Не Каталог.Существует() Тогда
				попытка
					создатькаталог(ПутьФТП);
				исключение
					#Если клиент тогда
						сообщить(ПутьФТП);
					#конецесли	
				конецпопытки;
				
				//	СоздатьКаталог(ПутьФТП);
			КонецЕсли;
			//Катаев+ 08/11/13 из имени файла убираем русские буквы
			//ИмяДляЗаписи = ПутьФТП+файлКоп.Имя;
			ИмяДляЗаписи = ПутьФТП+УбратьРБ(файлКоп.Имя);
			//Катаев- 08/11/13
			ФайлНов = Новый Файл(ИмяДляЗаписи);
			попытка
				КопироватьФайл(ФайлКоп.ПолноеИмя,ИмяДляЗаписи);  // на сервер екатеренбурга не кпируем, если нет доступа
				Если ФайлНов.Размер() = ФайлКоп.Размер() Тогда
					// Производим пометку что файл успешно загружен на фтп, что бы избежать повторной загрузки
					Запись=РегистрыСведений.РегистрФайловЕКОД.СоздатьМенеджерЗаписи();
					Запись.Дата = ТекущаяДата();
					Запись.ПолноеИмяФайла = ТекПуть;
					Запись.Узел = ПланыОбмена.Основной.НайтиПоКоду(Филиал);
					Запись.Документ_Создан = Ложь;
					Запись.ДатаЗаказа = ДатаЗаказа;
					Запись.НомерЗаказа = НомерЗаказа;
					Запись.Записать();
				Иначе
					УдалитьФайлы(ФайлНов.Путь, ФайлНов.Имя);
				КонецЕсли;
			исключение
			конецпопытки;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
