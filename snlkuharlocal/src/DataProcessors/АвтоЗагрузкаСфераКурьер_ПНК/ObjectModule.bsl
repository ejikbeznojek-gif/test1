Функция ПолучитьНомерЗаявки(ДокОбъект)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &Документ
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита = &ИмяРеквизита";
	Запрос.УстановитьПараметр("Документ", ДокОбъект.Ссылка);
	Запрос.УстановитьПараметр("ИмяРеквизита", "НомерЗаявкиМолния");
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЗначениеРеквизита;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции


