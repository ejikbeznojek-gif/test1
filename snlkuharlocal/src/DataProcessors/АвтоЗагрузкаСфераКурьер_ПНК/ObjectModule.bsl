		Заказкм = Документы.ЗаказНаЭмиссиюКодовМаркировкиСУЗ.СоздатьДокумент();
		Заказкм.ДокументОснование = пнк;
		Заказкм.ВидНоменклатурыЧЗВДокументе = ПЕРЕЧИСЛЕНИЯ.ВидыНоменклатурыЧЗ.Набор;
		заказкм.Комментарий = "Загрузка ПНК из СФЕРЫ";
		Заказкм.Организация = справочники.Организации.НайтиПоКоду("SS-001");  // ее
		Заказкм.Дата = ТекущаяДата();
		Заказкм.Статус = ПЕРЕЧИСЛЕНИЯ.СтатусыДокументовМаркировки.ВРаботе;  // ПОТОМ НА ОБРАБОТАН ЗАМЕНИТЬ
		Заказкм.СпособВводаВОборот = перечисления.СпособыВводаВОборотСУЗ.ПокупкаВРФ;
		Заказкм.ПодразделениеНанесения = СПРАВОЧНИКИ.Подразделения.НайтиПоКоду("SSP-0211"); // склад часцы.
		Заказкм.Записать();	
		Заказкм = заказкм.Ссылка;
	КонецЕсли;
	
	//если не ЗначениеЗаполнено(ЗаказКМ) тогда
	//	Сообщить("Заполните заказ");
	//	Возврат;
	//КонецЕсли;
	

	
	Для каждого текстрока из СписокМарок цикл

		СтруктураДанных=новый Структура("Владелец,Наименование,ЗаказКМ,ЗначениеШтрихкода,КодировкаШтрихкода,Количество,ТипКода,ТипУпаковки,ТипШК,СпособВводаВОборот");
		СтруктураДанных.СпособВводаВОборот = ЗаказКМ.СпособВводаВОборот;
		СтруктураДанных.ЗаказКМ=ЗаказКМ.Ссылка;
		СтруктураДанных.КодировкаШтрихкода = Перечисления.ТипыКодировокШК.GS1_DataMatrix;
		СтруктураДанных.Количество = 1;
		СтруктураДанных.ТипКода = Перечисления.ТипыКодовМаркировки.Товар;
		СтруктураДанных.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар;
		СтруктураДанных.ТипШК=Перечисления.ТипыШтрихКодов.Штука;
		
	
	    Кодкм= ТекстрОКА.киз;
		если КодКМ="" тогда Прервать; КонецЕсли;
		
		если СтрДлина(КодКМ)=31 тогда
			КодКМ=Лев(КодКМ+Хвост,83);
		ИначеЕсли СтрДлина(КодКМ)=83 тогда
		иначе
			//Сообщить("неправильная длинна кода ЧЗ - "+КодКМ);
			Продолжить;			
		КонецЕсли;
		
		Кусок1=Лев(КодКМ,31);
		кусок2=Сред(КодКм,32,6);
		Кусок3=Сред(КодКм,38);
		
		СтруктураДанных.ЗначениеШтрихКода=Кусок1+"<GS>"+кусок2+"<GS>"+Кусок3;
		СтруктураДанных.Наименование=Лев(КодКМ,31);
		если СтрДлина(СтруктураДанных.ЗначениеШтрихКода)<>91 тогда
			//Сообщить("неправильная длинна кода ЧЗ - "+КодКМ);
			Продолжить;
		КонецЕсли;
		ГТИН=Сред(КодКм,3,14);

		запрос=новый запрос;
		запрос.Текст="ВЫБРАТЬ ПЕРВЫЕ 1
		             |	Номенклатура.Ссылка КАК Ссылка
		             |ИЗ
		             |	Справочник.Номенклатура КАК Номенклатура
		             |ГДЕ
		             |	Номенклатура.ГТИН = &ГТИН
		             |	И не Номенклатура.ПометкаУдаления";
		запрос.УстановитьПараметр("ГТИН",ГТИН);
		Результат=запрос.Выполнить().Выгрузить();
		если результат.Количество()=0 тогда
			//Сообщить(");
			ЗаписатьВЛог("Маркировка","по коду "+КодКМ+" не нашлось владельца - "+ пнк+" ",,,,);
           
			Продолжить;
		иначе
			СтруктураДанных.Владелец = Результат.Получить(0).ссылка;
		КонецЕсли;
		
		КодЧЗ = НайтиЧЗ(СокрЛП(СтруктураДанных.Наименование));
		Если КодЧЗ = Неопределено Тогда
			КодЧЗ=Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
			ЗаполнитьЗначенияСвойств(КодЧЗ,СтруктураДанных);
			КодЧЗ.Записать();
		Иначе
			Если КодЧЗ.ЗаказКМ = ЗаказКМ Тогда
				Продолжить;     
			Иначе
				//Сообщить("Уже есть код ЧЗ "+СтруктураДанных.Наименование+" док Эмиссии: "+КодЧЗ.ЗаказКМ );
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	
	
КонецПроцедуры

Функция НайтиЧЗ(Строка)
	ЗАпрос = новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК МаркаЧЗ
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.Наименование = &Наименование
	|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование",Строка);
	Рез = запрос.Выполнить().Выбрать();
	Если рез.Следующий() Тогда
		Возврат Рез.МаркаЧЗ;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
		
КонецФункции


Процедура ФормированиеХКМ(ДокПолучатель,ТЗТовары_Марки)

	//------------------------------------------------------------------------------------------
	//      создаем ХКМ
	//------------------------------------------------------------------------------------------
	// Проверим, есть ли уже ХКМ, если есть, то просто его перезаполним. Если нет, то создаем новый.
	Запрос = новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	              |	ХранилищеКодовМаркировки.Ссылка КАК Ссылка,
	              |	ХранилищеКодовМаркировки.ПометкаУдаления КАК ПометкаУдаления
	              |ИЗ
	              |	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
	              |ГДЕ
	              |	ХранилищеКодовМаркировки.ДокОснование = &ТекДок
	              |	И ХранилищеКодовМаркировки.ПометкаУдаления = ЛОЖЬ
	              |	И ХранилищеКодовМаркировки.ПланФакт = &план";
	
	запрос.УстановитьПараметр("ТекДок",ДокПолучатель);  
	запрос.УстановитьПараметр("План",перечисления.ПланФакт.План);
	
	Рез = запрос.Выполнить().Выгрузить();  
	Если рез.Количество()>0 Тогда
		ДокХКМ  = рез[0].ссылка;
		документХКМ = докХКМ.получитьОбъект(); 
		//!!!!!!!!!!!!!!!!!
		// если уже есть ХКМ к ПНК, то не перезаполняем ее пока.
		 возврат;
		
	иначе
		
		ДокументХКМ = Документы.ХранилищеКодовМаркировки.ПустаяСсылка(); 
		
		ДокументХКМ = документы.ХранилищеКодовМаркировки.СоздатьДокумент();
		ДокументХКМ.Автор = ПараметрыСеанса.Пользователь;
		ДокументХКМ.ДокОснование = ДокПолучатель.ссылка;
		ДокументХКМ.Организация = ДокПолучатель.организация; // единая европа?  пусть пока бтк
		ДокументХКМ.ПланФакт = перечисления.ПланФакт.План;
		ДокументХКМ.Получатель = ДокПолучатель.контрагент; //???  бтк
		ДокументХКМ.Комментарий = "Возврат от Гиперглобуса, загрузка из Сферы";
		ДокументХКМ.дата =  КонецДня(текущаядата()-24*60*60);//КонецДня(ДокПолучатель.дата);
		ДокументХКМ.УстановитьНовыйНомер( "PPP"+"-");
    
	конецЕсли;

	
	
	// заполняем марками
	//-------------------------------------------
	ДокументХКМ.ШтрихкодыУпаковок.очистить();
	ТЗТовары_Марки.Сортировать("Киз");
	
	Для каждого ТекстрМ из ТЗТовары_Марки цикл   
		//ТекМаркаТ = ТекстрМ.Марка;
		//сообщить(ТекстрМ.Марка);
		МаркаН = ДокументХКМ.ШтрихкодыУпаковок.добавить();
		//------------------------------------------------------------	
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	Ссылка 			КАК КодМаркировки
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров	
		|ГДЕ
		|	Наименование = &ДанныеКМ
		|	И ( 
		|		ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
		|		ИЛИ ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
		|	)
		|";
		
		Запрос.УстановитьПараметр("ДанныеКМ", ТекстрМ.киз);
		
		ВыборкаМ = Запрос.Выполнить().Выгрузить();
		//-----------------------------------------------------------------------------------
		
		Если ВыборкаМ.Количество()>0 Тогда 
		МаркаН.ШтрихкодУпаковки = ВыборкаМ[0].КодМаркировки;
	иначе 
		//сообщить(" -  "+ТекстрМ.киз); 
		ЗаписатьВЛог("Маркировка","Не удалось найти и добавить марку, к "+ ДокПолучатель+ " - "+ТекстрМ.киз+" "+ТекущаяДата()+" "+ОписаниеОшибки(),,,,);

	КонецЕсли;
	
		
	КонецЦикла;
	
	попытка
		ДокументХКМ.Записать(РежимЗаписиДокумента.Запись);
	исключение
		ЗаписатьВЛог("Маркировка","Не удалось записать документ ХКМ, к ПНК Гиперглобус - "+ ДокПолучатель+"   "+ТекущаяДата()+" "+ОписаниеОшибки(),,,,);
		//сообщить(описаниеошибки());
	КонецПопытки;

	//	сообщить(ДокПолучатель);
	//	сообщить(ДокументХКМ);
	//-----------------------------------------------
	
	
	
КонецПроцедуры



// формируем структуру для загрузки до 01,04,25 ++
Процедура СформироватьСтруктуруУПД_ст(Путь,ИмяКр)
	
	// потом в регистр это записать.
	//------------------------------
	Файл = Новый ЧтениеXML;
	Попытка
		Файл.ОткрытьФайл(Путь);
		// очищаем все файлы.
		ТЗШапка.Очистить();
		СтрокаШапка=ТЗШапка.Добавить();
		//нечаева 12,09,18++
		//СтрокаШапка.Промо=0;
		//нечаева 12,09,18---
		Файлы.Очистить();
		Ошибки.Очистить();
		ТЗПечать.Очистить();
	Исключение
		//сообщить(ОписаниеОшибки());
	КонецПопытки;
	
	//---------------------------------			
	НомСим = СтрНайти(ИмяКр,"_"); // 9 символов ид.
	ИдЭдО = Сред(ИмяКр,НомСим-9,9);
	СтрокаШапка.ИдЭДО = ИдЭДО;
	//-----------------------------------
	                                     	
	
	ШК="";
	Артикул="";
	НомерСФКонтрагента="";
	ТипСФКонтрагента="";
	Контрагент=неопределено;
	НомерСтроки=0;
	ПризнакЗаписиДокумента=Истина;
	НазваниеПунктаДоставки = "Нет названия";
	НаименованиеК = "Контрагент не определен";
	//Катаев+ 03/10/13 Принудительный сброс единицы упаковки.
	Единица = "";
	//Катаев- 03/13/13
	
	Количество=0;
	//------------------------------------------
	
	МеханизмЧтения = Новый ЧтениеXML;
	МеханизмЧтения.ОткрытьФайл(Путь);
	Построитель = Новый ПостроительDOM;
	ДокументУПД = Построитель.Прочитать(МеханизмЧтения);
	
	//цикл для обхода узлов
	Для каждого элемента Из ДокументУПД.ЭлементДокумента.ДочерниеУзлы Цикл
		//сообщить(элемента.имяУзла);
		//
		Если элемента.ИмяУзла = "Документ" Тогда
			ДокШапка = элемента;
			//атрибуты главного узла
			ТипУПД = ДокШапка.Атрибуты.ПолучитьИменованныйЭлемент("Функция").Значение;
			//сообщить(типУПД);
			Если ТИпУПД <> "ДОП" Тогда
				продолжить;
				// могут быть другие типы, их мы пока не грузим.
			КонецЕсли;
			
			// ИД в корусе получить еще
			// ------------------дальше вложенные узлы
			Для каждого значения Из ДокШапка.ДочерниеУзлы Цикл 
				//сообщить("  "+значения.ИмяУзла);
				
				// сама шапка                                             
				Если значения.ИмяУзла = "СвСчФакт" тогда 
					НомерСФ = Значения.Атрибуты.ПолучитьИменованныйЭлемент("НомерСчФ").Значение;
					ДатаСФ = Значения.Атрибуты.ПолучитьИменованныйЭлемент("ДатаСчФ").Значение;
					СвКонтрагента=Значения;
					
					СтрокаШапка.НомерСФ = НомерСФ;
					СтрокаШапка.ДатаСФ = ДатаСФ;
					
					Для каждого СвК Из СвКонтрагента.ДочерниеУзлы Цикл 
						//сообщить("   "+свк.ИмяУзла);
						//-------------------------------------------------------------------------------------------- 
						// СвПрод сведения о продавце - гиперглобус у входящего
						Если  СВК.ИмяУзла = "СвПрод" Тогда
							// только для продавца будем читать ИНН
							Для каждого ИДП1 Из СвК.ДочерниеУзлы Цикл
								//сообщить("    "+идп1.ИмяУзла);
								//ИДСв
								Для каждого ИДП2 Из ИДП1.ДочерниеУзлы Цикл
									//сообщить("     "+идп2.ИмяУзла);
									//
										
									//СвЮЛУч
									Если идп2.ИмяУзла = "СвЮЛУч" тогда
										//СвЮЛУч
										ИННЮЛ = идп2.Атрибуты.ПолучитьИменованныйЭлемент("ИННЮЛ").Значение;
										КПП = идп2.Атрибуты.ПолучитьИменованныйЭлемент("КПП").Значение;
									//	сообщить(ИННЮЛ);
										
										
										Контрагент=справочники.Контрагенты.ПустаяСсылка();
										Запрос=Новый Запрос;
										//Катаев+ 29/10/14 В запрос добавлена проверка на то что это не группа.
										Запрос.Текст=
										"ВЫБРАТЬ
										|	Контрагенты.Ссылка
										|ИЗ
										|	Справочник.Контрагенты КАК Контрагенты
										|ГДЕ
										|	Контрагенты.ИНН = &ТекКод
										|	И Контрагенты.ЭтоГруппа = ЛОЖЬ";
										//Катаев- 29/10/14
										
										Запрос.УстановитьПараметр("ТекКод",СокрЛП(ИННЮЛ));
										Выборка = запрос.Выполнить().Выбрать();
										Пока выборка.Следующий() Цикл
											Контрагент=выборка.ссылка;
											СтрокаШапка.Контрагент=Контрагент;
											прервать;
										КонецЦикла; 
										
																		
									конецЕсли;	
								конецЦикла;
							КонецЦикла; 
						конецЕсли;
						//
						// адрес грузополучателя
						//--------------------------------------------------------------------------------------------------------------
						
						Если  СВК.ИмяУзла = "ГрузОт" Тогда
							Индекс= "";
							Город = "";
							Улица = "";
							
							// только для продавца будем читать ИНН
							Для каждого ИДП1 Из СвК.ДочерниеУзлы Цикл
								//сообщить("   "+идп1.ИмяУзла);
								Для каждого ИДП2 Из ИДП1.ДочерниеУзлы Цикл
									//сообщить("     "+идп2.ИмяУзла);
									
									//СвЮЛУч
									Если идп2.ИмяУзла = "Адрес" тогда
										
										Для каждого ИДП3 Из ИДП2.ДочерниеУзлы Цикл
											//АдрРФ
											// адрес грузополучателя получить по регистру
											Индекс = идп3.Атрибуты.ПолучитьИменованныйЭлемент("Индекс").Значение;
											
											попытка
												ГОрод = идп3.Атрибуты.ПолучитьИменованныйЭлемент("Город").Значение;
											исключение
												ГОрод = "";
											конецПопытки;
											
										    // может быть не заполнено
											попытка
												Улица = идп3.Атрибуты.ПолучитьИменованныйЭлемент("Улица").Значение;
											исключение
												улица = "";
											конецпопытки;
										
											//сообщить(улица);
										конецЦикла;
									конецЕсли;	
								конецЦикла;
							КонецЦикла;
							// ищем пункт доставки через регистр
							Если Индекс<>""  и Улица<>"" Тогда
								
								ПунктДоставки = НайтиАдресПД(Индекс,ГОрод,Улица,Контрагент);
							//	сообщить(ПунктДоставки);
							//	тзШапка.ПунктДоставки = ПунктДоставки;						
							КонецЕсли;
							
						конецЕсли;
						
						//-------------------------------------------------------------------------------------------- 
						// СвПрод сведения о покупателе - гиперглобус у входящего
						Если  СВК.ИмяУзла = "СвПокуп" Тогда
							// только для продавца будем читать ИНН
							Для каждого ИДП1 Из СвК.ДочерниеУзлы Цикл
								//сообщить("    "+идп1.ИмяУзла);
								//ИДСв
								Для каждого ИДП2 Из ИДП1.ДочерниеУзлы Цикл
									//сообщить("     "+идп2.ИмяУзла);
									//
									//СвЮЛУч
									Если идп2.ИмяУзла = "СвЮЛУч" тогда
										//СвЮЛУч
										ИННОР = идп2.Атрибуты.ПолучитьИменованныйЭлемент("ИННЮЛ").Значение;
