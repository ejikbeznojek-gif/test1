Функция ФормированиеПечати(Строки,Шапка) Экспорт
	
	СтрШапка=Шапка.Получить(0);
	Организация=СтрШапка.Организация;
	
	Макет = ЭтотОбъект.ПолучитьМакет("ЗаказУпрощеннаяФорма");
	
	//Макет = ЭтотОбъект.ПолучитьМакет("Заказ");
	ТабДок= Новый ТабличныйДокумент;
	ТабДок.Очистить();
	ТабДок.Вывод=ИспользованиеВывода.Разрешить;
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьЗаголовок.Параметры.Заполнить(Шапка.Получить(0));
	Организация=Справочники.Организации.НайтиПоКоду("SSP-12"); //КБ- Стиль
	
	Если не Контрагент.Пустая() Тогда 	
		Договор=Контрагент.ОсновнойДоговор;
		Если не (Договор=Неопределено) и не (Договор=справочники.Договоры.ПустаяСсылка()) Тогда
			Если ЗначениеЗаполнено(Договор.Организация) Тогда
				Организация=Договор.Организация;		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;		
	ГЛНПродавца="";
	ЕИ="4607182079990";
	КБ="4607182769990";
	Если Организация.код="SSP-12" Тогда
		ОбластьЗаголовок.Параметры.ГЛНПродавца=КБ;
	КонецЕсли;
	
	Если Организация.код="SS-001" Тогда
		ОбластьЗаголовок.Параметры.ГЛНПродавца=КБ;
	КонецЕсли;
	
	ОбластьЗаголовок.Параметры.НаименованиеПродавца=Организация.Наименование;
	
	ОбластьИтоги = Макет.ПолучитьОбласть("Итоги");
	ОбластьИтоги.Параметры.Заполнить(Шапка.Получить(0));
	ОбластьСтрока = Макет.ПолучитьОбласть("ТекущаяСтрока");
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("Шапка");
	
	ТабДок.Вывести(ОбластьЗаголовок);
	ТабДок.Вывести(ОбластьШапкаТаблицы);
	НомПП=1;
	ОбщСумма=0; ОбщКолУпак=0;
	Для каждого ТекСтрока Из Строки Цикл
		
		ОбластьСтрока.Параметры.Заполнить(ТекСтрока);
		Если ТекСтрока.Колво-ТекСтрока.КолвоОтредактированное Тогда
			ОбластьСтрока.Область("Колво").ЦветТекста = Новый Цвет(255, 0, 0);
		Иначе
			ОбластьСтрока.Область("Колво").ЦветТекста = Новый Цвет(0, 0, 0);
		КонецЕсли;	
		
		Если ТекСтрока.Найдена Тогда
			ОбластьСтрока.Параметры.Найдена="v";
			ОбластьСтрока.Область("ТекущаяСтрока").ЦветТекста = Новый Цвет(0, 0, 0);
		Иначе	
			ОбластьСтрока.Параметры.Найдена="";
			ОбластьСтрока.Область("ТекущаяСтрока").ЦветТекста = Новый Цвет(255, 0, 0);
		КонецЕсли;
		
		ОбластьСтрока.Параметры.НомПП=НомПП;
		ТабДок.Вывести(ОбластьСтрока);
		НомПП=НомПП+1;
		ОбщСумма=ОбщСумма+ТекСтрока.СуммаБезНДС;
		Если НЕ ТекСтрока.КолУпак=Неопределено тогда
			ОбщКолУпак=ОбщКолУпак+Число(ТекСтрока.КолУпак);
		КонецЕсли;	
		
	КонецЦикла;	
	
	ОбластьИтоги.Параметры.общСумма=ОбщСумма;	
	ОбластьИтоги.Параметры.ОбщКолУпак=ОбщКолУпак;	
	ТабДок.Вывести(ОбластьИтоги);
	ТабДок.ОтображатьСетку=Ложь;
	
	
	//	ТабДок.Показать();
	
	// нечаева 04,12,19++ поменяла формат
	НомЗ = СтрЗаменить(СтрШапка.НомЗаказа, "/", "_");		
	НомЗ = СтрЗаменить(НомЗ, "\", "_");		
	НомЗ = СтрЗаменить(НомЗ, " ", "_");		
	Имя=Константы.КаталогЕКОД.Получить()+НомЗ+".xls";     //++++
	
	Попытка
		ТабДок.Вывод=ИспользованиеВывода.Разрешить;
		ТабДок.Записать(Имя,"xls");
	Исключение
		КритичОшибки.Добавить("Не возможно создать файл печати для заказа "+СтрШапка.НомЗаказа+". Контрагент - "+СтрШапка.контрагент+".  "+ОписаниеОшибки() );
	КонецПопытки;
	// нечаева 04,12,19---
	
	
	Возврат Имя;
	
КонецФункции

// доработка по контрагентам
// 1 округляем количество товаров, если нужно!
// 2 разброс по скаладам, формирование документов.
// 3 условия поиска ШК (для отдельных групп из номенклатуры - Интри, европакеты... кб-стиль)
Процедура ОбработкаДанныхЗагрузки(Шапка,Строки)
	
	СтрШапка=Шапка.Получить(0);
	ТипЦен=Справочники.ТипыЦен.ПустаяСсылка();
	ТипСкидки=Справочники.ТипыСкидок.ПустаяСсылка();
	Организация=Неопределено;
	Менеджер=Неопределено;
	Регион=Неопределено;
	Договор=Неопределено;
	Подразделение=Неопределено;
	ОтсрочкаПлатежа=Неопределено;
	КодПоставщикаКонтрагента=Неопределено;
	ПунктДоставки=Неопределено;
	НомерЗаказа=Неопределено;
	ТипILNКонтрагента=Неопределено;
	ДатаЗаказа=Неопределено;
	ДатаОтгрузки=Неопределено;
	Склад=Неопределено;   //Справочники.Склады.НайтиПоКоду("STA-61");
	Контрагент=СтрШапка.Контрагент;
	Если Контрагент=Неопределено тогда
		Контрагент=Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	ПунктДоставки=СтрШапка.ПунктДоставки;
	НомЗаказа=СтрШапка.НомЗаказа;
	НомерЗаказа=СтрШапка.НомЗаказа;
	//нечаева 08,04,21+++
	КодПоставщикаШапка = СтрШапка.КодДоговора;
	//нечаева 08,04,21---
	
	
	ДатаЗаказа=СтрШапка.ДатаЗаказа;
	ДатаДоставки=СтрШапка.ДатаДоставки;
	//нечаева 27,11,17++
	ВремяДоставки = СтрШапка.ВремяДоставки;
	//нечаева 27,11,17-- 
	ТипILNКонтрагента=СтрШапка.ТипILNКонтрагента;
	
	
	//нечаева 31,08,21+++ для озона
	Если  контрагент.код = "SSP-4991" ТОгда
		
		Склад= Справочники.Склады.НайтиПоКоду("STC-60");
		
	КонецЕсли;
	//нечаева 31,08,21---
	
	//нечаева 21,04,23+++
	Если  НЕ Контрагент.ОсновнойСкладОтгрузки.пустая() ТОгда
		
		Склад= Контрагент.ОсновнойСкладОтгрузки;
		
	КонецЕсли;
	// нечаева 21,04,23---
	
	
	ПризКр=0;
	//сообщить("    запись документа");
	Если не Контрагент.Пустая() Тогда 	
		// 1. Обрабатываем количество, делаем округление  соответствуещее коли-ву в блочке
		Если Контрагент.ОткруглятьКоличество Тогда
			
			Для каждого ТекСтрока Из Строки Цикл
				ПризКратности=1;
				Ном=ТекСтрока.Номенклатура;
				КолЗаказано=ТекСтрока.Колво;
				
				Если НЕ ТипЗнч(Ном) = Тип("СправочникСсылка.Номенклатура") Тогда
					ТекСтрока.КолвоОтредактированное=КолЗаказано;
					продолжить;
				КонецЕсли;
				
				ШтукВКор=Ном.Родитель.ШтукВКоробочке;
				Если ШтукВКор-0>0 Тогда 
					// проверяем на кратность 5 или 6
					Если (ШтукВКор/5)=Цел((ШтукВКор/5)) Тогда
						ПризКратности=5
					ИначеЕсли (ШтукВКор/6)=Цел((ШтукВКор/6)) Тогда
						ПризКратности=6
					Иначе
						ПризКратности=1;
					КонецЕсли;
					
					Если (КолЗаказано/ПризКратности)<>Цел((КолЗаказано/ПризКратности)) Тогда
						КолУпак=Цел(Окр(КолЗаказано/ПризКратности,0,0));
						НовКолво=КолУпак*ПризКратности;
						ТекСтрока.КолвоОтредактированное=НовКолво;
					Иначе
						ТекСтрока.КолвоОтредактированное=КолЗаказано;
					Конецесли;
				КонецЕсли;
			КонецЦикла;
		Иначе
			Для каждого ТекСтрока Из Строки Цикл
				Если ТекСтрока.Единица<>"Блочок" Тогда
					КолЗаказано=ТекСтрока.Колво;
					ТекСтрока.КолвоОтредактированное=КолЗаказано;
				Иначе
					Попытка
						КолЗаказано=ТекСтрока.Колво*ТекСтрока.ВУпак;
						ТекСтрока.КолвоОтредактированное=КолЗаказано;
					исключение
						КолЗаказано=ТекСтрока.Колво;
						ТекСтрока.КолвоОтредактированное=КолЗаказано;
					КонецПопытки;	
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		// 2. проверяем дублированный заказ есть или нет. в пределах недели;
		Если Контрагент.ПроверятьНаличиеЗаказа Тогда
			
			Дата1=ТекущаяДата();
			Дата2=ТекущаяДата() - 60 * 60 * 24 * 7; // неделя назад;
			
			Запрос=новый Запрос;
			Запрос.Текст="ВЫБРАТЬ
			|	РасходнаяНакладная.Номер,
			|	РасходнаяНакладная.Дата,
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.Контрагент = &Контрагент
			|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
			|	И РасходнаяНакладная.Дата МЕЖДУ НачалоПериода(&Дата2) И КонецПериода(&Дата1)";
			
			Запрос.УстановитьПараметр("Контрагент",Контрагент);
			Запрос.УстановитьПараметр("ПунктДоставки",ПунктДоставки);
			Запрос.УстановитьПараметр("Дата1",Дата1);
			Запрос.УстановитьПараметр("Дата2",Дата2);
			
			Рез=Запрос.Выполнить().Выбрать();
			
			// добавляем в сообщения менеджерам
			Пока Рез.Следующий() Цикл
				Строка="Для заказа ЕКОДЕ № "+НомЗаказа+" существует копия заказа РНК №"+Рез.Номер+" от "+Рез.Дата;
				Ошибки.Добавить(Строка);
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	// 3. разбивка по складам, создаем несколько документов. 
	// выбираем различные склады, и в цикла по кадому выбираем номеклатуру и создаем документы;
	
	// загрузка ТЗ в запрос
	//--------------------------------------------
	ТЗСклады=Строки;
	
	// создается для временной таблицы
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТЗ.Колонки.Добавить("Найдена", Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	ДанныеСкладов=Неопределено;
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст  = "ВЫБРАТЬ различные
	|    ТЗ.Склад как Склад,
	|    ТЗ.Найдена
	|ПОМЕСТИТЬ ТЗ
	|ИЗ
	|    &ТЗ КАК ТЗ";
	
	Запрос.УстановитьПараметр("ТЗ", ТзСклады);
	Запрос.Выполнить();
	
	Запрос.Текст="ВЫБРАТЬ
	|	ТЗ.Склад КАК Склад,
	|	ТЗ.Найдена
	|ИЗ
	|	ТЗ КАК ТЗ
	|ГДЕ
	|	ТЗ.Найдена = 1";
	РезультатСклады=Запрос.Выполнить().Выбрать();
	
	Если РезультатСклады.Количество()=0 Тогда
		// пустой документ! не формируем ?
		//Катаев+ 08/04/13 Для филиалов склад берем по умолчанию
		//Склад=Справочники.Склады.НайтиПоКоду("STA-61");
		Если ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
			Склад=Справочники.Склады.НайтиПоКоду("STA-61");
		Иначе
			Склад = ПолучитьЗначениеПоУмолчанию("ОсновнойСклад",Справочники.Пользователи.НастройкиПоУмолчанию);
		КонецЕсли;
		//Катаев- 08/04/13
		//нечаева 31,08,21+++ для озона
		Если  контрагент.код = "SSP-4991" ТОгда
			
			Склад= Справочники.Склады.НайтиПоКоду("STC-60");
			
		КонецЕсли;
		
		//нечаева 21,04,23+++
		Если  НЕ контрагент.ОсновнойСкладОтгрузки.пустая() ТОгда
			
			Склад= контрагент.ОсновнойСкладОтгрузки;
			
		КонецЕсли;
		// нечаева 21,04,23---
		
		
		
		//нечаева 31,08,21---
		
		// Катаев+ 21/03/13 Создавать новый документ надо только для оригинала
		//ДокОбъект=Документы.РасходнаяНакладная.СоздатьДокумент();
		//ДокОбъект = ПолучитьНакладную(Склад, Шапка.НомЗаказа, Шапка.ДатаЗаказа, Шапка.ТипЗаказа);
		ДокОбъект = ПолучитьНакладную(Склад, Шапка[0].НомЗаказа, Шапка[0].ДатаЗаказа, Шапка[0].ТипЗаказа);
		Если ДокОбъект = Неопределено Тогда
			Возврат;
		КонецЕсли;
		// Катаев- 21/03/13
		//-----------------------------------------------------------------------------------------
		//    автозаполнение параметров шапки документа, разница в шапке - в складе отгрузки
		//-----------------------------------------------------------------------------------------
		Если не Контрагент.Пустая() Тогда 	
			//------------------------------------------
			//Организация=Справочники.Организации.НайтиПоКоду("SSP-12"); //КБ- Стиль
			//нечаева18,07,17++
			Организация=Справочники.Организации.НайтиПоКоду("SS-001"); 
			//нечаева18,07,17--
			
			ТипЦен=Контрагент.ТипЦен;
			Договор=Контрагент.ОсновнойДоговор;
			
			//нечаева 24,10,17++ для дикси мегамарт два договора прописали по коду
			Если контрагент.код = "SSP-3687" ТОгда
				Договор = справочники.Договоры.НайтиПоКоду("SNL-022280");
			КонецЕсли;
			//нечаева 24,10,17*--
			
			
			Если не (Договор=Неопределено) и не (Договор=справочники.Договоры.ПустаяСсылка()) Тогда
				//ТипЦен		=Договор.ТипЦен;
				ОтсрочкаПлатежа =Договор.ОтсрочкаПлатежа;
				Если ЗначениеЗаполнено(Договор.Организация) Тогда
					Организация=Договор.Организация;		
				КонецЕсли;
			КонецЕсли;
			//Катаев+ 30/05/13 Для Перекрестка отгрузка может быть и через ГалантТрейд
			Если Контрагент.Код = "SSP-3674" Тогда
				Если СтрШапка.Организация = "4607814849991" Тогда
					Организация = Справочники.Организации.НайтиПоКоду("SNL-48");
					Договор = Справочники.Договоры.НайтиПоКоду("SMN-1143");
				КонецЕсли;
			КонецЕсли;
			//Катаев- 30/05/13
			//----  доп. обработка;
			ДокОбъект.ДопОбработки.Очистить();
			Для Каждого СтрокаТЧ Из Контрагент.ВидыДопОбработок Цикл
				СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
			КонецЦикла; 
			//нечаева 23,03,17+++
			// добавляем из пункта доставки доп. обработки.
			Попытка
				Для Каждого СтрокаТЧ Из ПунктДоставки.ВидыДопОбработок Цикл
					СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
					СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
				КонецЦикла;  
			Исключение
			КонецПопытки;
			//нечаева 23,03,17---
			//Нечаева 12,09,18+++
			// для х5 промо доп обработка
