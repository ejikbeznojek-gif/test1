Функция ПолучитьНомераУпаковок(ДокОбъект)
	
	ТЗ = Новый ТаблицаЗначений;
	
	ТекДок = ДокОбъект.Ссылка;
	
	запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	РеквизитыРНКПНКПРМ.ЗначениеРеквизита как Номер,
	|	0 КАК Код
	|ИЗ
	|	РегистрСведений.РеквизитыРНКПНКПРМ КАК РеквизитыРНКПНКПРМ
	|ГДЕ
	|	РеквизитыРНКПНКПРМ.Документ = &текдок
	|	И РеквизитыРНКПНКПРМ.ИмяРеквизита ПОДОБНО &рек";
	запрос.УстановитьПараметр("ТекДок",ТекДок.ссылка);
	запрос.УстановитьПараметр("рек","СерийныйНомерУпаковки%");
	РезКоды = Запрос.Выполнить().Выгрузить();
	
	РР=2;
	Для каждого Стр Из 	РезКоды цикл
		
		Стр.код = РР;
		РР=РР+1;
		
	КонецЦикла;
	
	
	ТЗ = резКоды;
	
	
	возврат ТЗ;
	
КонецФункции

Процедура  ЗаписатьДанныеВРегистрОтправкаЭлектронныхДокументов(ДокСсылка,ОшибкаЗаписи=неопределено,ВидДокумента)
	
	//очистим, если есть данные
	НаборЗаписей = РегистрыСведений.ОтправкаЭлектронныхДокументов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ВидДокумента.Установить(ВидДокумента); 
	НаборЗаписей.Отбор.Документ.Установить(ДокСсылка); 
	НаборЗаписей.Записать(); 
	
	//запишем
	НаборЗаписей = РегистрыСведений.ОтправкаЭлектронныхДокументов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ВидДокумента.Установить(ВидДокумента); 
	НаборЗаписей.Отбор.Документ.Установить(ДокСсылка); 
	
	НоваяЗапись = НаборЗаписей.Добавить(); 
	НоваяЗапись.ВидДокумента = ВидДокумента;
	НоваяЗапись.НомерЗаказа = ДокСсылка.НомерЗаказа;
	НоваяЗапись.датаЗаказа  = ДокСсылка.ДатаЗаказа;
	Новаязапись.Документ = ДокСсылка;
	новаязапись.ДокументОтправлен = истина;
	новаязапись.дата = ТекущаяДата();
	
	НаборЗаписей.Записать(); 
	
	//тут же Регистрируем записи в обмен  из набора записей в SNL
	// для филиалов, со складов будет в Цо писаться, обмен по регистру идет только в офис.
	Если ПараметрыСеанса.ЭтотУзел.ТипУзла <> Перечисления.ТипУзлаИБ.УправляющееПодразделение и ПараметрыСеанса.ЭтотУзел.ТипУзла <> Перечисления.ТипУзлаИБ.Склад 	Тогда
		
		тзНаборЗаписей = НаборЗаписей.Выгрузить();
		НаборЗаписей.Отбор.ВидДокумента.Установить(ВидДокумента); 
		НаборЗаписей.Отбор.ВидДокумента.Использование=Истина;
		НаборЗаписей.Отбор.Документ.Установить(ДокСсылка);
		НаборЗаписей.Отбор.Документ.Использование=Истина;
		
		НаборЗаписей.Отбор.НомерЗаказа.Установить(ДокСсылка.номерЗаказа);
		НаборЗаписей.Отбор.номерЗаказа.Использование=Истина;
		НаборЗаписей.Отбор.датаЗаказа.Установить(ДокСсылка.ДатаЗаказа);
		НаборЗаписей.Отбор.ДатаЗаказа.Использование=Истина;
		
		НаборЗаписей.Прочитать();
		НаборЗаписей.ОбменДанными.Получатели.Добавить(ПланыОбмена.Основной.НайтиПоКоду("SNL"));			  
		ПланыОбмена.ЗарегистрироватьИзменения(ПланыОбмена.Основной.НайтиПоКоду("SNL"),НаборЗаписей);
		
	КонецЕсли;	
	//конец регистрации обмена	регистра
	
КонецПроцедуры

