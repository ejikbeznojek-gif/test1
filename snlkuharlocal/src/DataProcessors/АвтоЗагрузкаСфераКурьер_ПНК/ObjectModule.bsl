Функция НайтиРНКСт(стрШапка)
	Запрос = Новый Запрос;
	сз = Новый СписокЗначений;
	//Катаев+ 28/05/14 Уведомления приходят от других пунктов доставки. Отключаем проверку на пункт доставки
	////Катаев+ 19/06/13 В уведомлении может не быть указан Пункт доставки
	//Если ПустаяСтрока(стрШапка.ПунктДоставки) Тогда
	//	Запрос.УстановитьПараметр("ВыборПунктДоставки", Ложь);
	//Иначе
	//	Запрос.УстановитьПараметр("ВыборПунктДоставки", Истина);
	//КонецЕсли;
	//Катаев- 19/06/13
	Запрос.УстановитьПараметр("ВыборПунктДоставки", Ложь);
	//Катаев- 28/05/14
	Запрос.УстановитьПараметр("ПунктДоставки", стрШапка.ПунктДоставки);
	Запрос.УстановитьПараметр("Контрагент", стрШапка.Контрагент);
	
	//нечаева 12,12,16+++
	Запрос.УстановитьПараметр("Номер", стрШапка.НомерРНК);
	//нечаева 12,12,16---
	
	// Пробуем определить по Дате и Номеру РНК
	Если стрШапка.НомерРНК <> Неопределено Тогда
		Если стрШапка.ДатаРНК = Неопределено Тогда
			Запрос.Текст =
			"ВЫБРАТЬ
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.Номер = &Номер
			|	И РасходнаяНакладная.Дата >= &Дата
			//Катаев+ 19/06/13
			//|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
			|	И ВЫБОР
			|			КОГДА &ВыборПунктДоставки
			|				ТОГДА РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
			|			ИНАЧЕ ИСТИНА
			|		КОНЕЦ
			//Катаев- 19/06/13
			|	И РасходнаяНакладная.Контрагент = &Контрагент
			|	И РасходнаяНакладная.Проведен";
			Запрос.УстановитьПараметр("Дата", стрШапка.ДатаПриемаТовара-86400*30);
		Иначе
			Запрос.Текст =
			"ВЫБРАТЬ
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.Номер = &Номер
			//Катаев+ 01/04/13
			//|	И РасходнаяНакладная.Дата = &Дата
			|	И НАЧАЛОПЕРИОДА(РасходнаяНакладная.Дата, ДЕНЬ) = &Дата
			//Катаев- 01/04/13
			//Катаев+ 19/06/13
			//|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
			|	И ВЫБОР
			|			КОГДА &ВыборПунктДоставки
			|				ТОГДА РасходнаяНакладная.ПунктДоставки >= &ПунктДоставки
			|			ИНАЧЕ ИСТИНА
			|		КОНЕЦ
			//Катаев- 19/06/13
			|	И РасходнаяНакладная.Контрагент = &Контрагент
			|	И РасходнаяНакладная.Проведен";
			//Катаев+ 01/04/13
			ДатаРНК = Дата(СтрЗаменить(стрШапка.ДатаРНК,"-",""));
			//нечаева 19.07.17++
			Запрос.УстановитьПараметр("Дата", НачалоДня(ДатаРНК)-86400*30);
			//нечаева 19,07,17---
			//Катаев- 01/04/13
		КонецЕсли;
		Запрос.УстановитьПараметр("Номер", стрШапка.НомерРНК);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			сз.Добавить(Выборка.Ссылка)
		КонецЦикла;
		Если сз.Количество() <> 0 Тогда
			Возврат сз;
		КонецЕсли;
	КонецЕсли;
	// Пробуем определить по Дате, Номеру заказа и адресу доставки;
	//Катаев+ 28/05/14 А здесь включаем
	Если ПустаяСтрока(стрШапка.ПунктДоставки) Тогда
		Запрос.УстановитьПараметр("ВыборПунктДоставки", Ложь);
	Иначе
		Запрос.УстановитьПараметр("ВыборПунктДоставки", Истина);
	КонецЕсли;
	//Катаев- 28/05/14
	Если стрШапка.ДатаЗаказа = Неопределено Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РасходнаяНакладная.Ссылка
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	РасходнаяНакладная.НомерЗаказа = &Номер
		|	И РасходнаяНакладная.ДатаЗаказа >= &Дата
		//Катаев+ 19/06/13
		//|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
		|	И ВЫБОР
		|			КОГДА &ВыборПунктДоставки
		|				ТОГДА РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		//Катаев- 19/06/13
		|	И РасходнаяНакладная.Контрагент = &Контрагент
		|	И РасходнаяНакладная.Проведен";      //нечаева 25,04,17+++
		Запрос.УстановитьПараметр("Дата", НачалоГода(стрШапка.ДатаПриемаТовара));
