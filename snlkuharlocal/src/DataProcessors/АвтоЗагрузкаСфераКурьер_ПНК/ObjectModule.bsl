			ДокОбъект.ОтсрочкаПлатежа=ОтсрочкаПлатежа;		
			ДокОбъект.ТипЦен=ТипЦен; //Контрагент.ТипЦен;
			ДокОбъект.ВидОплаты=Перечисления.ВидыОплаты.БН;
			ДокОбъект.Подразделение = Подразделение;
			ДокОбъект.ЛевыйКонтрагент=Контрагент;
			ДокОбъект.СостояниеНакладной=Перечисления.СостоянияНакладной.ВРаботе;
			ДокОбъект.Отгружен=перечисления.Отгружен.Резерв;
			ДокОбъект.ПунктДоставки=ПунктДоставки;
			ДокОбъект.Склад=Склад;		
			УстановитьНомерДокументаКлиентСервер(ДокОбъект);
			ДокОбъект.Валюта=Справочники.Валюты.НайтиПоКоду("810");
			ДокОбъект.Автор	=Неопределено;
			
			Если СокрЛП(Контрагент.Код)=КодМетро И (Лев(ДокОбъект.Номер,3)<>"SSP" или Лев(ДокОбъект.Номер,3)<>"SST") Тогда
				УстановитьНомерДокументаКлиентСервер(ДокОбъект);	
			КонецЕсли;
			
			ДокОбъект.КодОперации=Перечисления.КодыОперацийОстатки.Реализация;
			ДокОбъект.ДатаОформления	=ДокОбъект.Дата;
			
			//Валетов + 30.06.2026 Изменение 0000000060
			//ДокОбъект.ДатаОплаты	    =ПолучитьДатуОплаты1(ДокОбъект.ДатаОтгрузки,ДокОбъект.ОтсрочкаПлатежа);	
			ПараметрыРасчетаДатыОплаты  = ОбщегоНазначенияКС.ПолучитьЗаполнитьПараметрыРасчетаДатыОплатыПоДокументу(ДокОбъект);
			ДокОбъект.ДатаОплаты 		= ОбщегоНазначенияКС.ПолучитьДатуОплатыПоДокументуКлиентСервер(ПараметрыРасчетаДатыОплаты); 
			//Валетов-
	
			СкидкаКонтрагента=ПолучитьРеквизитРодителя(Контрагент,"Скидка");
			ДокОбъект.Скидка=СкидкаКонтрагента;
			
			ПересчетТЧ(ДокОбъект,"Товары",ДокОбъект.Валюта,ДокОбъект.Валюта,ДокОбъект.Курс,ДокОбъект.Курс,Истина);	
			
			
			//проверим на пустые цены!!
			//нечаева 15,03,16+++
			
			ОтборНулевыеЦены=новый Структура("Цена",0);
			МассивНулевыхЦен=ДокОбъект.Товары.НайтиСтроки(ОтборНулевыеЦены);
			
			Для каждого текстрока из МассивНулевыхЦен цикл
				
				Отбор2=новый Структура("номенклатура",ТекСтрока.номенклатура);
				тстрока=ДокОбъект.Товары.НайтиСтроки(Отбор2);
				Ошибки.Добавить("Для товара -  "+ТекСтрока.номенклатура +" Цена =0, не записано в заказе, проверьте матрицу! " );
				ТекНом =тстрока[0].НомерСтроки; //.удалить()
				докобъект.товары.Удалить(ТекНом-1);
				
			КонецЦикла;
			//нечаева 15,03,16---
			
			
			
			Попытка
				ДокОбъект.Записать(режимЗаписиДокумента.Запись);
				Файлы.Добавить("Создан документ: "+ДокОбъект.Дата+" "+ДокОбъект.Номер+", склад: "+ДокОбъект.Склад+".");
				//Сообщить("Записан документ - "+ДокОбъект.Дата+" "+ДокОбъект.Номер);
				// записать номер в "ошибки" для вывода менеджерам
			Исключение
				// Катаев+ 22/08/13 Если возникла ошибка с уникальностью номера, то пробуем обновить нумерацию объектов и сгенерировать номер заново
				Инфо = ИнформацияОбОшибке();
				Если Найти(Инфо.Описание, "Не уникальный номер документа") > 0 Тогда
					ОбновитьНумерациюОбъектов();
					УстановитьНомерДокументаКлиентСервер(ЭтотОбъект);
					Попытка
						ДокОбъект.Записать(режимЗаписиДокумента.Запись);
						Файлы.Добавить("Создан документ: "+ДокОбъект.Дата+" "+ДокОбъект.Номер+", склад: "+ДокОбъект.Склад+".");
					Исключение
						Если ПризКр=0 тогда
							КритичОшибки.Добавить("После обновления нумерации для заказа Заказ из ECODE №"+НомерЗаказа+".  Контрагент -"+Контрагент +". ПунктДоставки - "+ПунктДоставки+" документ не записан! "+ОписаниеОшибки() );
							//Катаев+ 11/12/14
							Отказ = Истина;
							//Катаев- 11/12/14
						конецЕсли;
					КонецПопытки;
				Иначе	
					Если ПризКр=0 тогда
						КритичОшибки.Добавить("Для заказа Заказ из ECODE №"+НомерЗаказа+".  Контрагент -"+Контрагент +". ПунктДоставки - "+ПунктДоставки+" документ не записан! "+ОписаниеОшибки() );
						//Катаев+ 11/12/14
						Отказ = Истина;
						//Катаев- 11/12/14
					конецЕсли;
				КонецЕсли;
				// Катаев- 22/08/13
				//Сообщить(ОписаниеОшибки());
			КонецПопытки;
			//сообщить("    документ записан");
			ПризКр=ПризКр+1;
			
			
		КонецЦикла;
	КонецЦикла;
	// конец заполнения документа
	
КонецПроцедуры


// для Метро
//нечаева 09,09,19+++
Процедура ОбработкаДанныхЗагрузкиМетро(Шапка,Строки)
	
	//	
	//// Пробегаем по строкам и переприсваиваем значение из папки колготки на = папке кбстиль =4
	//Для каждого ТекСтр из Строки Цикл
	//	
	//	Если ТекСтр.Номенклатура.Родитель=Справочники.номенклатура.НайтиПоКоду("SNL-063466") или  // папка колготки
	//	   ТекСтр.Номенклатура.Родитель.Родитель=Справочники.номенклатура.НайтиПоКоду("SNL-063466") или
	//	   ТекСтр.Номенклатура.Родитель.Родитель.родитель=Справочники.номенклатура.НайтиПоКоду("SNL-063466") или
	//	   ТекСтр.Номенклатура.Родитель.Родитель.родитель.родитель=Справочники.номенклатура.НайтиПоКоду("SNL-063466")
	//	Тогда
	//	   ТекСтр.ПризнакГруппыНом=4;
	//	КонецЕсли;   
	//			   
	//КонецЦикла;
	
	СтрШапка=Шапка.Получить(0);
	ТипЦен=Справочники.ТипыЦен.ПустаяСсылка();
	ТипСкидки=Справочники.ТипыСкидок.ПустаяСсылка();
	Организация=Неопределено;
	Менеджер=Неопределено;
	Регион=Неопределено;
	Договор=Неопределено;
	Подразделение=Неопределено;
	ОтсрочкаПлатежа=Неопределено;
	КодПоставщикаКонтрагента=Неопределено;
	ПунктДоставки=Неопределено;
	НомерЗаказа=Неопределено;
	ТипILNКонтрагента=Неопределено;
	ДатаЗаказа=Неопределено;
	ДатаОтгрузки=Неопределено;
	Склад=Неопределено;   //Справочники.Склады.НайтиПоКоду("STA-61");
	Контрагент=СтрШапка.Контрагент;
	Если Контрагент=Неопределено тогда
		Контрагент=Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	ПунктДоставки=СтрШапка.ПунктДоставки;
	НомЗаказа=СтрШапка.НомЗаказа;
	НомерЗаказа=СтрШапка.НомЗаказа;
	ДатаЗаказа=СтрШапка.ДатаЗаказа;
	ДатаДоставки=СтрШапка.ДатаДоставки;
	ТипILNКонтрагента=СтрШапка.ТипILNКонтрагента;
	КодДоговора=СтрШапка.КодДоговора;
	
	ПризКр=0;
	//сообщить("    запись документа");
	Если не Контрагент.Пустая() Тогда 	
		// 1. Обрабатываем количество, делаем округление  соответствуещее коли-ву в блочке
		Если Контрагент.ОткруглятьКоличество Тогда
			
			Для каждого ТекСтрока Из Строки Цикл
				ПризКратности=1;
				Ном=ТекСтрока.Номенклатура;
				КолЗаказано=ТекСтрока.Колво;
				
				Если НЕ ТипЗнч(Ном) = Тип("СправочникСсылка.Номенклатура") Тогда
					ТекСтрока.КолвоОтредактированное=КолЗаказано;
					продолжить;
				КонецЕсли;
				
				ШтукВКор=Ном.Родитель.ШтукВКоробочке;
				Если ШтукВКор-0>0 Тогда 
					// проверяем на кратность 5 или 6
					Если (ШтукВКор/5)=Цел((ШтукВКор/5)) Тогда
						ПризКратности=5
					ИначеЕсли (ШтукВКор/6)=Цел((ШтукВКор/6)) Тогда
						ПризКратности=6
					Иначе
						ПризКратности=1;
					КонецЕсли;
					
					Если (КолЗаказано/ПризКратности)<>Цел((КолЗаказано/ПризКратности)) Тогда
						КолУпак=Цел(Окр(КолЗаказано/ПризКратности,0,0));
						НовКолво=КолУпак*ПризКратности;
						ТекСтрока.КолвоОтредактированное=НовКолво;
					Иначе
						ТекСтрока.КолвоОтредактированное=КолЗаказано;
					Конецесли;
				КонецЕсли;
			КонецЦикла;
		Иначе
			Для каждого ТекСтрока Из Строки Цикл
				КолЗаказано=ТекСтрока.Колво;
				ТекСтрока.КолвоОтредактированное=КолЗаказано;			
			КонецЦикла;
			
		КонецЕсли;
		
		// 2. проверяем дублированный заказ есть или нет. в пределах недели;
		Если Контрагент.ПроверятьНаличиеЗаказа Тогда
			
			Дата1=ТекущаяДата();
			Дата2=ТекущаяДата() - 60 * 60 * 24 * 7; // неделя назад;
			
			Запрос=новый Запрос;
			Запрос.Текст="ВЫБРАТЬ
			|	РасходнаяНакладная.Номер,
			|	РасходнаяНакладная.Дата,
			|	РасходнаяНакладная.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.Контрагент = &Контрагент
			|	И РасходнаяНакладная.ПунктДоставки = &ПунктДоставки
			|	И РасходнаяНакладная.Дата МЕЖДУ НачалоПериода(&Дата2) И КонецПериода(&Дата1)";
			
			Запрос.УстановитьПараметр("Контрагент",Контрагент);
			Запрос.УстановитьПараметр("ПунктДоставки",ПунктДоставки);
			Запрос.УстановитьПараметр("Дата1",Дата1);
			Запрос.УстановитьПараметр("Дата2",Дата2);
			
			Рез=Запрос.Выполнить().Выбрать();
			
			// добавляем в сообщения менеджерам
			Пока Рез.Следующий() Цикл
				Строка="Для заказа ЕКОДЕ № "+НомЗаказа+" существует копия заказа РНК №"+Рез.Номер+" от "+Рез.Дата;
				Ошибки.Добавить(Строка);
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	//-------------------------------------------------------------------------------------------------------------------------------------------
	//@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
	// когда складов несколько и есть данные, которые нашлись
	//-------------------------------------------------------------------------------------------------------------------------------------------
	
	// загрузка ТЗ в запрос
	//--------------------------------------------
	ТЗСклады=Строки;
	
	// создается для временной таблицы
	ТЗ  = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТЗ.Колонки.Добавить("Найдена", Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	ДанныеСкладов=Неопределено;
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст  = "ВЫБРАТЬ различные
	|    ТЗ.Склад как Склад,
	|    ТЗ.Найдена
	|ПОМЕСТИТЬ ТЗ
	|ИЗ
	|    &ТЗ КАК ТЗ";
	
	Запрос.УстановитьПараметр("ТЗ", ТзСклады);
	Запрос.Выполнить();
	
	Запрос.Текст="ВЫБРАТЬ
	|	ТЗ.Склад КАК Склад,
	|	ТЗ.Найдена
	|ИЗ
	|	ТЗ КАК ТЗ
	|ГДЕ
	|	ТЗ.Найдена = 1";
	РезультатСклады=Запрос.Выполнить().Выбрать();
	
	
	КоличествоСкладов=РезультатСклады.Количество();
	
	Если РезультатСклады.Количество()=0 Тогда
		// пустой документ! не формируем ?
		Склад=Справочники.Склады.НайтиПоКоду("STA-61");
		// Катаев+ 21/03/13 Создавать новый документ надо только для оригинала
		//ДокОбъект=Документы.РасходнаяНакладная.СоздатьДокумент();
		//ДокОбъект = ПолучитьНакладную(Склад, Шапка.НомЗаказа, Шапка.ДатаЗаказа, Шапка.ТипЗаказа);
		ДокОбъект = ПолучитьНакладную(Склад, Шапка[0].НомЗаказа, Шапка[0].ДатаЗаказа, Шапка[0].ТипЗаказа);
		Если ДокОбъект = Неопределено Тогда
			Возврат;
		КонецЕсли;
		// Катаев- 21/03/13
		//-----------------------------------------------------------------------------------------
		//    автозаполнение параметров шапки документа, разница в шапке - в складе отгрузки
		//-----------------------------------------------------------------------------------------
		Если не Контрагент.Пустая() Тогда 	
			//------------------------------------------
			Организация=Справочники.Организации.НайтиПоКоду("SS-001"); //КБ- Стиль
			ТипЦен=Контрагент.ТипЦен;
			//Мессерле
			Запрос=новый запрос;
			запрос.Текст="ВЫБРАТЬ
			|	Договоры.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Договоры КАК Договоры
			|ГДЕ
			|	Договоры.КодПоставщика.Наименование = &КодПоставщика
			|	И Договоры.КодЦБ = &КодЦБ
			|	И Договоры.НеИспользовать = ложь";
			
			Запрос.УстановитьПараметр("КодПоставщика",КодДоговора);
			Запрос.УстановитьПараметр("КодЦБ",Контрагент.КодЦБ);
			
			Выб=запрос.Выполнить().Выбрать();
			Если выб.следующий() тогда
				Договор=выб.ссылка;
			иначе
				Договор=Контрагент.ОсновнойДоговор;
			Конецесли;
			//Мессерле
			
			Если не (Договор=Неопределено) и не (Договор=справочники.Договоры.ПустаяСсылка()) Тогда
				//ТипЦен		=Договор.ТипЦен;
				ОтсрочкаПлатежа =Договор.ОтсрочкаПлатежа;
				Если ЗначениеЗаполнено(Договор.Организация) Тогда
					Организация=Договор.Организация;		
				КонецЕсли;
			КонецЕсли;
			//----  доп. обработка;
			
			ДокОбъект.ДопОбработки.Очистить();
			Для Каждого СтрокаТЧ Из Контрагент.ВидыДопОбработок Цикл
				СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
				СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
			КонецЦикла;  
			//нечаева 23,03,17+++
			// добавляем из пункта доставки доп. обработки.
			Попытка
				Для Каждого СтрокаТЧ Из ПунктДоставки.ВидыДопОбработок Цикл
					СтрокаДО=ДокОбъект.ДопОбработки.Добавить();	
					СтрокаДО.ВидДопОбработки=СтрокаТЧ.ДопОбработка;
				КонецЦикла;  
			Исключение
			КонецПопытки;
			//нечаева 23,03,17---
			
			//-----------------------------------------------
			Менеджер=Контрагент.Менеджер;
			Если Менеджер=Неопределено или Менеджер=Справочники.ФизическиеЛица.ПустаяСсылка() и ПризКр=0 Тогда
				КритичОшибки.Добавить("Для контрагента "+контрагент.наименование+"  код - "+контрагент.код+"  не определен менеджер! Заказ екоде №"+ Номерзаказа );
			Иначе
				Если Не СтрДлина(Менеджер.Емэйл)>2  и ПризКр=0   Тогда
					КритичОшибки.Добавить("Для менеджера "+Менеджер.наименование+"  код - "+Менеджер.код+"  не определен ЕМэйл!" );
				КонецЕсли;
			КонецЕсли;
			
			//Катаев+ 06/08/14 Из ЕКОД все контрагенты грузятся с использованием номенклатурной матрицы. Проверку убрал
			//Если Контрагент.ТипЦен=Справочники.ТипыЦен.ПустаяСсылка() и ПризКр=0 и Контрагент.код<>"SSP-3674" Тогда
			//	//Катаев+ 17/10/13 Проверяем есть ли тип цены по пункту доставки
			//	//КритичОшибки.Добавить("Для контрагента "+Контрагент.Наименование+" не установлен тип цен по умолчанию!");
			//	Если ПунктДоставки = Неопределено Тогда
			//		КритичОшибки.Добавить("Для контрагента "+Контрагент.Наименование+" не установлен тип цен по умолчанию!");
			//	Иначе
			//		Если Не ЗначениеЗаполнено(ПунктДоставки.ТипЦен) Тогда
			//			КритичОшибки.Добавить("Для контрагента "+Контрагент.Наименование+" не установлен тип цен по умолчанию!");
			//		КонецЕсли;
			//	КонецЕсли;
			//	//Катаев- 17/10/13
			//КонецЕсли;
			//Катаев- 06/08/14 
