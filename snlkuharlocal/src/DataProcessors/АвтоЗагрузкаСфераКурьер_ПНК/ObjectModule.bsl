// Катаев+ 21/03/13 Генерация накладной.
Функция ПолучитьНакладную(Склад, НомерЗаказа, ДатаЗаказа, ТипЗаказа)
	Если ТипЗаказа = "Оригинал" Тогда
		Возврат Документы.РасходнаяНакладная.СоздатьДокумент();
	Иначе
		// Делаем поиск РНК по Складу, Номеру и Дате заказа
		Запрос = Новый запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РасходнаяНакладная.Ссылка,
		|	РасходнаяНакладная.СостояниеНакладной
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	РасходнаяНакладная.ДатаЗаказа = &ДатаЗаказа
		|	И РасходнаяНакладная.НомерЗаказа = &НомерЗаказа
		|	И РасходнаяНакладная.Склад = &Склад";
		Запрос.УстановитьПараметр("НомерЗаказа", НомерЗаказа);
		Запрос.УстановитьПараметр("Склад", Склад);
		Запрос.УстановитьПараметр("ДатаЗаказа", ДатаЗаказа);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Количество() > 1 Тогда
			спРНК = "";
			Пока Выборка.Следующий() Цикл
				спРНК = спРНК + Выборка.Ссылка.Номер + ";"
			КонецЦикла;
			Строка = "Для заказа № "+НомерЗаказа+" пришла корректировка, но было обнаружено более одного РНК ("+спРНК+"). Корректировку необходимо провести вручную.";
			Ошибки.Добавить(Строка);
			Возврат Неопределено;
		КонецЕсли;
		Если Выборка.Следующий() Тогда
			Если Выборка.Ссылка.Проведен Тогда
				Строка = "Для РНК "+Выборка.Ссылка+" пришла корректировка, но документ уже проведен. Корректировку необходимо провести вручную";
				Ошибки.Добавить(Строка);
				Возврат Неопределено;
			КонецЕсли;
			Если Выборка.СостояниеНакладной = перечисления.СостоянияНакладной.ВРаботе Тогда
				Строка = "Для РНК "+Выборка.Ссылка+" пришла корректировка. Документ будет изменен";
				Ошибки.Добавить(Строка);
