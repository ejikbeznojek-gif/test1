Функция КонтрагентФилиала(ТекПуть, ТипДок)
	Файл = Новый ЧтениеXML;
	Попытка                              
		Файл.ОткрытьФайл(ТекПуть);
	Исключение
		Возврат "SNL";
	КонецПопытки;
	Пока Файл.Прочитать() Цикл
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "Buyer" тогда
			// ИЛН контрагента
			Пока НЕ (Файл.ТипУзла = ТипУзлаXML.КонецЭлемента И Файл.ЛокальноеИмя = "Buyer") цикл
				файл.Прочитать(); 
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ILN" тогда
					файл.Прочитать(); 
					ИЛНКонтрагента=Файл.Значение;
					прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "DeliveryPoint" тогда
			// ИЛН пункта доставки
			Пока НЕ (Файл.ТипУзла = ТипУзлаXML.КонецЭлемента И Файл.ЛокальноеИмя = "DeliveryPoint") цикл
				файл.Прочитать(); 
				Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "ILN" тогда
					файл.Прочитать(); 
					ИЛНПунктаДоставки=Файл.Значение;
					прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	Файл.Закрыть();
	Контрагент = НайтиКонтрагента(ИЛНКонтрагента, ИЛНПунктаДоставки);
	Если Контрагент = Неопределено Тогда
		Возврат Неопределено;
	Иначе
		
		//нечаева 28,01,16 +++ "ООО Молл" грузим с ЦО
		если Контрагент.код = "CHF-0006" Тогда
			Филиал = "SNL";
			Возврат Филиал;
		КонецЕсли;
		//нечаева 28,01,16 +++
		
		
		//нечаева 22,09,17 +++ "Бьюти Лайф ООО" грузим с ЦО
		если Контрагент.родитель.код = "EKF-0488" Тогда   // EKF-0488   "EKF-0735"
			Филиал = "SNL";
			Возврат Филиал;
		КонецЕсли;
		//нечаева 22,09,17 ---
		
		//нечаева 22,08,22 +++ "элемент трейд" грузим с ЦО
		если Контрагент.код = "EKF-0100" Тогда
			Филиал = "SNL";
			Возврат Филиал;
		КонецЕсли;
		//нечаева 22,08,22 ---
		
		
		
		// определяем к какому узлу он относится
		// Катаев+ 07/05/13 определяем узел по пункту доставки, если определить не получится, то определяем по контрагенту
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПунктыДоставки.УзелДоставки
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|ГДЕ
		|	ПунктыДоставки.КодИЛН = &КодИЛН";
		Запрос.УстановитьПараметр("КодИЛН", ИЛНПунктаДоставки);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если Не ПустаяСтрока(Выборка.УзелДоставки) тогда
				Возврат Выборка.УзелДоставки.Код;
			КонецЕсли;
		КонецЕсли;
		// Катаев- 07/05/13
		
		Группа = Контрагент.Родитель;
		Филиал = "SNL";
		попытка
			//сообщить();
			Пока Группа.Уровень() > 1 Цикл
				Если Группа.РегиональныеУзлы.Количество() = 0 Тогда
					Группа = Группа.Родитель;
				Иначе
					тз = Группа.РегиональныеУзлы.Выгрузить();
					Если тз.Количество() = 1 Тогда
						Филиал = тз[0].КодУзла;
					Иначе
						Филиал = "SNL";
					КонецЕсли;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		исключение
			//Сообщить("-- "+Группа); 
			//сообщить("---"+Контрагент);
			Филиал = "SNL";
			
		конецПопытки;
		Возврат Филиал;
	КонецЕсли;
