		ЕстьДляАшана =  ТЗГЛН.Найти(СокрЛП(ИЛНКонтрагента),"GLNPok");
		Если ЕстьДляАшана<>неопределено Тогда
			Контрагент=справочники.Контрагенты.НайтиПоКоду("SSP-2450");
