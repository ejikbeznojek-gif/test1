Функция ПеренестиВДанныеЗамеров(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат	= МаркировкаКС.СтруктураРезультата();
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, пОбработки);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	ИД_Записи,Данные,Автор,НомерСеанса,НомерСоединения
	|ИЗ
	|	РегистрСведений.ДанныеЛогов КАК ДанныеЛогов
	|ГДЕ
	|	ДатаЗаписи МЕЖДУ &Дата1 И &Дата2	
	|	И (Автор = &Автор ИЛИ &Автор = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка))
	|	И НЕ Прочитана 
	|УПОРЯДОЧИТЬ ПО
    |	ДатаЗаписи,ИД_Записи
	|";
	
	Запрос.УстановитьПараметр("Дата1", НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата2));
	
	Запрос.УстановитьПараметр("Автор", МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Автор", Справочники.Пользователи.ПустаяСсылка()));
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	
	инт_ДлительныеОперации.СообщитьПрогресс("", "Запись логов в РС. К обработке: " + ВсегоСтрок + " записей.");
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ  
		
		//ТД 		= Новый ТаблицаЗначений;
		//ТД.Колонки.Добавить("ДатаЗаписи", 		ПолучитьОписаниеТиповДаты(ЧастиДаты.ДатаВремя));
		//ТД.Колонки.Добавить("ИмяТаблицы", 		ПолучитьОписаниеТиповСтроки(200));
		//ТД.Колонки.Добавить("ВремяОбработки", 	ПолучитьОписаниеТиповЧисла(10, 3));             
		//ТД.Колонки.Добавить("Ссылка", 			Новый ОписаниеТипов(Типы));
		//ТД.Колонки.Добавить("Автор", 				Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
		//ТД.Колонки.Добавить("ВесЗамера",			ПолучитьОписаниеТиповЧисла(10));
		//ТД.Колонки.Добавить("РежимЗаписи",		ПолучитьОписаниеТиповСтроки(20));			
		
		рРазбора = РегистрыСведений.ДанныеЛогов.РазобратьПакет(Выборка.Данные);
		Если рРазбора.Успешно Тогда
			ЗаписатьПакетВДанныеЗамеров(рРазбора.Данные, Выборка);
			УстановитьФлаг_Прочитана(Выборка.ИД_Записи);
		Иначе
			МаркировкаКС.ДобавитьОшибки(Результат, рРазбора);		
		КонецЕсли;		
		
		Сч = Сч + 1;
		Если Сч % 10 = 0 Тогда                   
			ТекстСообщения = СтрШаблон("Запись логов в РС. Обработано: %1 из %2 записей.", Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);					
			//Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов	= Сч;
	Результат.ВремяВыполнения		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЗаписатьПакетВДанныеЗамеров(ДанныеРазбора, Выборка)
	НЗ = РегистрыСведений.ДанныеЗамеровПроизводительности.СоздатьНаборЗаписей();	
	НЗ.Отбор.ИД_Записи.Установить(Выборка.ИД_Записи, Истина);
	
	Сч = 0;
	Для каждого СтрокаД Из ДанныеРазбора Цикл
		Сч = Сч + 1;
		
		Запись = НЗ.Добавить();		
		Запись.НомерЗаписи = Сч;
		
		ЗаполнитьЗначенияСвойств(Запись, СтрокаД);
		ЗаполнитьЗначенияСвойств(Запись, Выборка, "ИД_Записи,Автор,НомерСеанса,НомерСоединения");
		
		Запись.Основание = СтрокаД.Ссылка;
		
		ИмяТ = СтрокуВСтруктуру(СтрокаД.ИмяТаблицы, "Класс,Вид,ДопИнфо", ".");
		
		Запись.ВремяВыполнения = СтрокаД.ВремяОбработки;		
		
		ЗаполнитьЗначенияСвойств(Запись, ИмяТ);		
	КонецЦикла;
	
	НЗ.Записать(Истина);
КонецФункции // ()

Функция УстановитьФлаг_Прочитана(ИД_Записи, Прочитана = Истина)
	Запись = РегистрыСведений.ДанныеЛогов.СоздатьМенеджерЗаписи();
	Запись.ИД_Записи = ИД_Записи;
	Запись.Прочитать();
	
	Если ЗначениеЗаполнено(Запись.ИД_Записи) Тогда
		Запись.Прочитана = Прочитана;
		Запись.Записать();	
	КонецЕсли;
КонецФункции // ()

Функция СтрокуВСтруктуру(Строка, СтрПоля, Разделитель=",")
	Части	= СтрРазделить(Строка,Разделитель);
	Поля	= СтрРазделить(СтрПоля,",");
	
	Результат	= Новый Структура;
	
	Для Сч=1 По Поля.Количество()  Цикл
		Инд=Сч-1;
		Если Сч<=Части.Количество() Тогда
			Результат.Вставить(Поля[Инд],Части[Инд]);
		Иначе
			Результат.Вставить(Поля[Инд],"");			
		КонецЕсли; 	
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции // ()

Функция ОчиститьДанныеЗамеров(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат	= МаркировкаКС.СтруктураРезультата();
	
	Начало		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, пОбработки);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	ИД_Записи
	|ИЗ
	|	РегистрСведений.ДанныеЗамеровПроизводительности
	|ГДЕ
	|	ДатаЗаписи МЕЖДУ &Дата1 И &Дата2
	|";
	
	Запрос.УстановитьПараметр("Дата1", НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата2));
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	
	инт_ДлительныеОперации.СообщитьПрогресс("", "Очистка записей в РС. К обработке: " + ВсегоСтрок + " записей.");
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ  
		
		НЗ = РегистрыСведений.ДанныеЗамеровПроизводительности.СоздатьНаборЗаписей();
		НЗ.Отбор.ИД_Записи.Установить(Выборка.ИД_Записи, Истина);
		НЗ.Записать();		
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда                   
			ТекстСообщения = СтрШаблон("Запись логов в РС. Обработано: %1 из %2 записей.", Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);								
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов	= Сч;
	Результат.ВремяВыполнения		= (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);	
	КонецЕсли;
	
КонецФункции

Функция Сформировать(тПараметры = Неопределено) Экспорт
	пОбработки = Новый Структура;
	пОбработки.Вставить("Дата1", НачалоДня(ТекущаяДата()) - 3*24*60*60);
	пОбработки.Вставить("Дата2", КонецДня(ТекущаяДата()));
	
	ЗаписатьВЛог("Регламент", "Перенос данных замеров производительности. Начало", "Информация");
	
	рОбработки = ПеренестиВДанныеЗамеров(пОбработки);	
	
	ЗаписатьВЛог("Регламент", "Перенос данных замеров производительности. Окончание. Обработано записей: " + рОбработки.ОбработаноОбъектов, "Информация", , , рОбработки.ВремяВыполнения);
КонецФункции //Сформировать(тПараметры = Неопределено) Экспорт
