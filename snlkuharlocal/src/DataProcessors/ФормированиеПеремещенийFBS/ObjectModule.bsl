Функция СоздатьДокументПРМ(Знач СкладПолучатель, Знач СкладОтправитель, ДопКомментарий = "")

	Подсортировка=документы.Перемещение.СоздатьДокумент();
	Подсортировка.Склад = СкладОтправитель; //Параметры.Получить("СкладОтправитель");
	Подсортировка.СкладПолучатель = СкладПолучатель; //Параметры.Получить("СкладFBS");
	Подсортировка.ИБ=Справочники.ИБ.НайтиПоКоду("SSP");
	Подсортировка.Менеджер=ПараметрыСеанса.Пользователь.ФизЛицо;
	Подсортировка.Автор=ПараметрыСеанса.Пользователь;
