 //++Данилова Е.В. 10.12.2025  SNL-51 
 
 Процедура СформироватьОбратныеПРМcFBS(ТЧТоваров,ПараметрыРегламента,ДопКомментарий = "")
	 
		//Возврат; 
 	   //вычислим общий остаток, вычислим разницу, чтобы перенести, получим табблицу остатков и перенесем
	   
	   СкладПолучательМаркировка = ПараметрыРегламента.Получить("СкладПолучательМаркировка");
	   СкладПолучатель = ПараметрыРегламента.Получить("СкладПолучатель"); 
	   СкладFBSОбычный = ПараметрыРегламента.Получить("СкладFBS");
	   СкладFBSМаркировка  = ПараметрыРегламента.Получить("СкладFBSМаркировка");
	   
	   Если Не ЗначениеЗаполнено(СкладПолучательМаркировка) 
		   ИЛИ НЕ ЗначениеЗаполнено(СкладПолучатель)  Тогда
		   
		   ЗаписатьВЛог("Регламент","Не заполнены склады получатели. Обработка формирования ПРМ с FBS прервана.","Информация"); 
	   
	   	Возврат; 	
	   
	   КонецЕсли;
	   
	   Запрос = Новый Запрос;
	   Запрос.Текст = "ВЫБРАТЬ
	   |	ТЗТовары.Количество КАК Количество,
	   |	ТЗТовары.Номенклатура КАК Номенклатура
	   |ПОМЕСТИТЬ ВТТовары
	   |ИЗ
	   |	&ТЗТовары КАК ТЗТовары
	   |;
	   |
	   |////////////////////////////////////////////////////////////////////////////////
	   |ВЫБРАТЬ
	   |	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	   |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество
	   |ПОМЕСТИТЬ ВТОстаткиFBS
	   |ИЗ
	   |	РегистрНакопления.ОстаткиТМЦ.Остатки(
	   |			&Дата1,
	   |			Склад В (&СкладыFBS)
	   |				И Номенклатура В
	   |					(ВЫБРАТЬ
	   |						ВТТовары.Номенклатура
	   |					ИЗ
	   |						ВТТовары КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	   |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	   |				&Дата1,
	   |				Склад В (&СкладыFBS)
	   |					И Номенклатура В
	   |						(ВЫБРАТЬ
	   |							ВТТовары.Номенклатура
	   |						ИЗ
	   |							ВТТовары КАК ВТТовары)) КАК РезервыТМЦОстатки
	   |		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	   |ГДЕ
	   |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) > 0
	   |;
	   |
	   |////////////////////////////////////////////////////////////////////////////////
	   |ВЫБРАТЬ
	   |	ВТТовары.Номенклатура КАК Номенклатура,
	   |	ВТОстаткиFBS.Количество - ВТТовары.Количество КАК Разница
	   |ПОМЕСТИТЬ ВТТоварыДляПРМ
	   |ИЗ
	   |	ВТТовары КАК ВТТовары
	   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОстаткиFBS КАК ВТОстаткиFBS
	   |		ПО ВТТовары.Номенклатура = ВТОстаткиFBS.Номенклатура
	   |ГДЕ
	   |	ВТОстаткиFBS.Количество - ВТТовары.Количество > 0
	   |;
	   |
	   |////////////////////////////////////////////////////////////////////////////////
	   |ВЫБРАТЬ
	   |	ОстаткиТМЦОстатки.Склад КАК Склад,
	   |	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	   |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Остаток
	   |ИЗ
	   |	РегистрНакопления.ОстаткиТМЦ.Остатки(
	   |			&Дата1,
	   |			Склад В (&СкладыFBS)
	   |				И Номенклатура В
	   |					(ВЫБРАТЬ
	   |						ВТТовары.Номенклатура
	   |					ИЗ
	   |						ВТТоварыДляПРМ КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	   |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	   |				&Дата1,
	   |				Склад В (&СкладыFBS)
	   |					И Номенклатура В
	   |						(ВЫБРАТЬ
	   |							ВТТовары.Номенклатура
	   |						ИЗ
	   |							ВТТоварыДляПРМ КАК ВТТовары)) КАК РезервыТМЦОстатки
	   |		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	   |			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	   |ГДЕ
	   |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) > 0
	   |;
	   |
	   |////////////////////////////////////////////////////////////////////////////////
	   |ВЫБРАТЬ
	   |	ВТТоварыДляПРМ.Номенклатура КАК Номенклатура,
	   |	ВТТоварыДляПРМ.Разница КАК Количество
	   |ИЗ
	   |	ВТТоварыДляПРМ КАК ВТТоварыДляПРМ";
	   Запрос.УстановитьПараметр("Дата1",ТекущаяДата());
	   Запрос.УстановитьПараметр("ТЗТовары",ТЧТоваров);
	   
	   СкладыFBS = Новый Массив; 
	   СкладыFBS.Добавить(СкладFBSОбычный);
	   СкладыFBS.Добавить(СкладFBSМаркировка);
	   
	   Запрос.УстановитьПараметр("СкладыFBS",СкладыFBS);
	   
	   ПакетРезультатов = Запрос.ВыполнитьПакет(); 
	   
	   Выборка = ПакетРезультатов[3].выбрать(); 
	   
	   ТЧТоварыДляПРМ = ПакетРезультатов[4].Выгрузить(); 
	   
	   ДокПРММаркировка = СоздатьДокументПРМ(СкладПолучательМаркировка,СкладFBSМаркировка, ДопКомментарий); 
	   ДокПРМОбычный = СоздатьДокументПРМ(СкладПолучатель,СкладFBSОбычный,ДопКомментарий); 
	   
	   Для каждого СтрокаТоваров Из ТЧТоварыДляПРМ Цикл
	   
	   	  КоличествоПереместить = СтрокаТоваров.Количество; 
		  Отбор = Новый Структура("Номенклатура",СтрокаТоваров.Номенклатура); 
		  
		  Пока Выборка.НайтиСледующий(Отбор) Цикл
			  
			  Если КоличествоПереместить = 0 Тогда
				  
				  Прервать; 	
				  
			  КонецЕсли;
			  
			  Остаток = Выборка.Остаток;
			  Кол = Мин(Остаток,КоличествоПереместить); 
			  
			  Если Выборка.Склад.ЭтоСкладМаркированногоТовара Тогда
				  
				  СтрТЧ = ДокПРММаркировка.Товары.Добавить(); 
				  СтрТЧ.Номенклатура	=	СтрокаТоваров.номенклатура;
				  СтрТЧ.Заявка		=	Кол;
				  стртч.ПодтвержденнаяЗаявка				=	Кол;			
				  стртч.ПодтвержденнаяЗаявкаПеремещения	=	стртч.ПодтвержденнаяЗаявка;
				  СтрТЧ.Количество						=	стртч.ПодтвержденнаяЗаявка;				
				  
				  ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокПРММаркировка);
				  РассчитатьСуммуТабЧасти(СтрТЧ, ДокПРММаркировка);
				  
			  Иначе 
				  СтрТЧ = ДокПРМОбычный.Товары.Добавить();
				  СтрТЧ.Номенклатура	=	СтрокаТоваров.номенклатура;
				  СтрТЧ.Заявка		=	Кол;
				  стртч.ПодтвержденнаяЗаявка				=	Кол;			
				  стртч.ПодтвержденнаяЗаявкаПеремещения	=	стртч.ПодтвержденнаяЗаявка;
				  СтрТЧ.Количество						=	стртч.ПодтвержденнаяЗаявка;				
				  
				  ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ДокПРМОбычный);
				  РассчитатьСуммуТабЧасти(СтрТЧ, ДокПРМОбычный);
			  КонецЕсли;
			  
			  КоличествоПереместить = КоличествоПереместить - Кол; 
			  
		  КонецЦикла;
		  
		  Выборка.Сбросить(); 
	   
	  КонецЦикла;
	  НачатьТранзакцию(); 
	  Если ДокПРМОбычный.Товары.Количество() > 0  Тогда
		  
		  
		  ДокПРМОбычный.Записать(РежимЗаписиДокумента.Проведение); 
		  
	  КонецЕсли;
	  
	  Если ДокПРММаркировка.Товары.Количество() > 0  Тогда
		  
		  
		  ДокПРММаркировка.Записать(РежимЗаписиДокумента.Проведение); 
		  
	  КонецЕсли;
	  Если ТранзакцияАктивна() Тогда
		  
		  ЗафиксироватьТранзакцию();	
		  
	  КонецЕсли;
	  
	   
	   
 КонецПроцедуры
 
