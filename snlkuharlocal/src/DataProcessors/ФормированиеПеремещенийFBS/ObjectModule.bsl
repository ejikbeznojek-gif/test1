	КонецЦикла; 
	
	Возврат СписокДействующихМатриц; 

КонецФункции

Функция СформироватьПРМнаFBS1(Знач параметры, СписокДействующихМатриц,ТЗСпайкиИсключить)
	
	МассивСкладовОбычные = Новый Массив; 
	Для НомерПараметра = 1 По 10 Цикл 
		Если Параметры.Получить("СкладОтправитель"+Строка(НомерПараметра)) <> Неопределено Тогда
			
			МассивСкладовОбычные.Добавить(Параметры.Получить("СкладОтправитель"+Строка(НомерПараметра))); 
			
		КонецЕсли;	
	КонецЦикла;
	
	
	ОписаниеТиповСклад = Новый ОписаниеТипов("СправочникСсылка.Склады");
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(14)); 
	
	ТаблицаСкладовПоПриоритетам = Новый ТаблицаЗначений;
	ТаблицаСкладовПоПриоритетам.Колонки.Добавить("Склад",ОписаниеТиповСклад);
	ТаблицаСкладовПоПриоритетам.Колонки.Добавить("Приоритет",ОписаниеТиповЧисло);
	Приоритет = 1; 
	Для каждого СкладИзНастроек Из МассивСкладовОбычные Цикл
		НСтрока = ТаблицаСкладовПоПриоритетам.Добавить(); 
		НСтрока.Склад = СкладИзНастроек; 
		НСтрока.Приоритет = Приоритет; 
		
		Приоритет = Приоритет +1; 		
	КонецЦикла;
	
	//для тестов 
	//Товар = Параметры.Получить("Товар"); 	
	
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|	МатрицаТовары.Номенклатура КАК Номенклатура,
	//|	ВЫБОР КОГДА МАКСИМУМ(МатрицаТовары.МинимальноеКоличество)>МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) ТОГДА
	//|	МАКСИМУМ(МатрицаТовары.МинимальноеКоличество) ИНАЧЕ МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) КОНЕЦ КАК МинимальноеКоличество
	////|	МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) КАК МинимальныйОстатокКоличество
	//|ИЗ
	//|	Документ.Матрица.Товары КАК МатрицаТовары  
	//////ТЕСТ 
	////|ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
	////|	ПО МатрицаТовары.Номенклатура = НоменклатураКоплектующие.Ссылка
	//|ГДЕ
	//|	МатрицаТовары.Ссылка В(&СписокДействующихМатриц) //И  (МатрицаТовары.Номенклатура = &Товар ИЛИ НоменклатураКоплектующие.Номенклатура =  &Товар) 
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	МатрицаТовары.Номенклатура
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	Номенклатура
	//|АВТОУПОРЯДОЧИВАНИЕ";
	Запрос = Новый Запрос;
	Если ТЗСпайкиИсключить = неопределено Тогда 
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МатрицаТовары.Номенклатура КАК Номенклатура,
		|	ВЫБОР КОГДА МАКСИМУМ(МатрицаТовары.МинимальноеКоличество)>МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) ТОГДА
		|	МАКСИМУМ(МатрицаТовары.МинимальноеКоличество) ИНАЧЕ МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) КОНЕЦ КАК МинимальноеКоличество
		//|	МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество) КАК МинимальныйОстатокКоличество
		|ИЗ
		|	Документ.Матрица.Товары КАК МатрицаТовары  
		////ТЕСТ 
		//|ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.Коплектующие КАК НоменклатураКоплектующие
		//|	ПО МатрицаТовары.Номенклатура = НоменклатураКоплектующие.Ссылка
		|ГДЕ
		|	МатрицаТовары.Ссылка В(&СписокДействующихМатриц) //И  (МатрицаТовары.Номенклатура = &Товар ИЛИ НоменклатураКоплектующие.Номенклатура =  &Товар) 
		|
		|СГРУППИРОВАТЬ ПО
		|	МатрицаТовары.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура
		|АВТОУПОРЯДОЧИВАНИЕ";
	Иначе
		Запрос.Текст = "ВЫБРАТЬ
		|	ТЗСпайки.Номенклатура КАК Номенклатура,
		|	ТЗСпайки.КОличество КАК КОличество
		|ПОМЕСТИТЬ ВТСпайки
		|ИЗ
		|	&ТЗСпайки КАК ТЗСпайки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	ВложенныйЗапрос.МинимальноеКоличество - ЕСТЬNULL(ВТСпайки.КОличество, 0) КАК МинимальноеКоличество
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		МатрицаТовары.Номенклатура КАК Номенклатура,
		|		ВЫБОР
		|			КОГДА МАКСИМУМ(МатрицаТовары.МинимальноеКоличество) > МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество)
		|				ТОГДА МАКСИМУМ(МатрицаТовары.МинимальноеКоличество)
		|			ИНАЧЕ МАКСИМУМ(МатрицаТовары.МинимальныйОстатокКоличество)
		|		КОНЕЦ КАК МинимальноеКоличество
		|	ИЗ
		|		Документ.Матрица.Товары КАК МатрицаТовары
		|	ГДЕ
		|		МатрицаТовары.Ссылка В(&СписокДействующихМатриц)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		МатрицаТовары.Номенклатура) КАК ВложенныйЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСпайки КАК ВТСпайки
		|		ПО (ВТСпайки.Номенклатура = ВложенныйЗапрос.Номенклатура)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВложенныйЗапрос.Номенклатура
		|АВТОУПОРЯДОЧИВАНИЕ";
		
	КонецЕсли;
	Запрос.УстановитьПараметр("СписокДействующихМатриц",СписокДействующихМатриц);
	Запрос.УстановитьПараметр("ТЗСпайки",ТЗСпайкиИсключить);
	/////////////ТЕСТ
	//Запрос.УстановитьПараметр("Товар",Товар); 
	////////////////////////////
	Выборка = Запрос.Выполнить().выбрать();
	
	
	ОписаниеТиповНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	
	ТЗНоменклатуры = Новый ТаблицаЗначений;
	ТЗНоменклатуры.Колонки.Добавить("Номенклатура",ОписаниеТиповНоменклатура);
	ТЗНоменклатуры.Колонки.Добавить("Количество",ОписаниеТиповЧисло);  
	
	
	//ТЗСпайки = Новый ТаблицаЗначений; 
	//ТЗСпайки.Колонки.Добавить("Номенклатура");
	//ТЗСпайки.Колонки.Добавить("Количество");
	//
	//ТЗНеСпайки = Новый ТаблицаЗначений; 
	//ТЗНеСпайки.Колонки.Добавить("Номенклатура");
	//ТЗНеСпайки.Колонки.Добавить("Количество");
	
	ОписаниеТиповНомен = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,0)); 
	ТЗНехватаетОстатков = Новый ТаблицаЗначений;
	ТЗНехватаетОстатков.Колонки.Добавить("Номенклатура",ОписаниеТиповНомен);
	ТЗНехватаетОстатков.Колонки.Добавить("Количество",ОписаниеТиповЧисло);	
	
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.МинимальноеКоличество > 0 Тогда
			СтрокаТЗ = Неопределено;
			Номенклатура = Выборка.Номенклатура;   	
			
			
			Если Номенклатура.Коплектующие.Количество() = 1  
				или (Номенклатура.родитель.ШтукВКомплекте>1 и Номенклатура.Коплектующие.Количество()>0) 
				Тогда	
				
				
				Для каждого СтрокаКомплектующих Из Номенклатура.Коплектующие Цикл
					//++Данилова Е.В. 15.01.2026
					Если СтрокаКомплектующих.Номенклатура.Родитель.ВидНоменклатуры <> Перечисления.ВидыНоменклаутры.Товар Тогда
						
						Продолжить; 	
						
					КонецЕсли;
					//--Данилова Е.В. 15.01.2026 
					СтрокаТЗ = ТЗНоменклатуры.Добавить();
					СтрокаТЗ.Номенклатура = СтрокаКомплектующих.Номенклатура;
					СтрокаТЗ.Количество = Выборка.МинимальноеКоличество*СтрокаКомплектующих.Количество;
				КонецЦикла;
				
				//СтрокаСпайки = ТЗСпайки.Добавить(); 
				//СтрокаСпайки.Номенклатура = Номенклатура; 
				//СтрокаСпайки.Количество   = Выборка.МинимальноеКоличество; 
				//
			ИначеЕсли  Номенклатура.Коплектующие.Количество() = 0 Тогда
				СтрокаТЗ = ТЗНоменклатуры.Добавить();
				СтрокаТЗ.Номенклатура = Выборка.Номенклатура;
				СтрокаТЗ.Количество = Выборка.МинимальноеКоличество;
				
				
				//СтрокаНеСпайки = ТЗНеСпайки.Добавить(); 
				//СтрокаНеСпайки.Номенклатура = Номенклатура; 
				//СтрокаНеСпайки.Количество   = Выборка.МинимальноеКоличество; 
				
			Иначе
				СообщитьИзМодуля("Некорректное количество комплектующих "+Номенклатура);
				СтрокаТЗ = ТЗНоменклатуры.Добавить();
				СтрокаТЗ.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
				СтрокаТЗ.Количество = 0;
			КонецЕсли;
			
			
			
		КонецЕсли;
	КонецЦикла; 
	
	ТЗНоменклатуры.Свернуть("Номенклатура","Количество");
	ТЗНоменклатуры.Сортировать("Номенклатура");
	
	ТЗНоменклатурыКопия = ТЗНоменклатуры.Скопировать();//для расчета обратного ПРМ  
	
	ТЗНоменклатуры.Колонки.Добавить("ОбщийОстаток",ОписаниеТиповЧисло); 
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаСкладовПоПриоритетам.Склад КАК Склад,
	               |	ТаблицаСкладовПоПриоритетам.Приоритет КАК Приоритет
	               |ПОМЕСТИТЬ ВТСкладыПоПриоритетам
	               |ИЗ
	               |	&ТаблицаСкладовПоПриоритетам КАК ТаблицаСкладовПоПриоритетам
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗТовары.Количество КАК Количество,
	               |	ТЗТовары.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТТовары
	               |ИЗ
	               |	&ТЗТовары КАК ТЗТовары
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	               |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество
	               |ПОМЕСТИТЬ ВТОстаткиFBS
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТМЦ.Остатки(
	               |			&Дата1,
	               |			Склад В (&СкладыFBS)
	               |				И Номенклатура В
	               |					(ВЫБРАТЬ
	               |						ВТТовары.Номенклатура
	               |					ИЗ
	               |						ВТТовары КАК ВТТовары)) КАК ОстаткиТМЦОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	               |				&Дата1,
	               |				Склад В (&СкладыFBS)
	               |					И Номенклатура В
	               |						(ВЫБРАТЬ
	               |							ВТТовары.Номенклатура
	               |						ИЗ
	               |							ВТТовары КАК ВТТовары)) КАК РезервыТМЦОстатки
	               |		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	               |ГДЕ
	               |	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) > 0
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТовары.Номенклатура КАК Номенклатура,
	               |	ВТТовары.Количество КАК Количество,
	               |	ВТСкладыПоПриоритетам.Склад КАК Склад,
	               |	ВТСкладыПоПриоритетам.Приоритет КАК Приоритет
	               |ПОМЕСТИТЬ ВТТоварыПоСкладам
	               |ИЗ
	               |	ВТТовары КАК ВТТовары,
	               |	ВТСкладыПоПриоритетам КАК ВТСкладыПоПриоритетам
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТовары.Склад КАК Склад,
	               |	ВТТовары.Приоритет КАК Приоритет,
	               |	ВТТовары.Номенклатура КАК Номенклатура,
	               |	ВТТовары.Количество КАК Количество,
	               |	ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Остаток,
	               |	ЕСТЬNULL(ВТОстаткиFBS.Количество, 0) КАК ОстатокFBS
	               |ПОМЕСТИТЬ ВТОстатки
	               |ИЗ
	               |	ВТТоварыПоСкладам КАК ВТТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТМЦ.Остатки(
	               |				&Дата1,
	               |				Склад В
	               |					(ВЫБРАТЬ
	               |						ВТСкладыПоПриоритетам.Склад
	               |					ИЗ
	               |						ВТСкладыПоПриоритетам КАК ВТСкладыПоПриоритетам)) КАК ОстаткиТМЦОстатки
	               |		ПО ВТТовары.Номенклатура = ОстаткиТМЦОстатки.Номенклатура
	               |			И ВТТовары.Склад = ОстаткиТМЦОстатки.Склад
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	               |				&Дата1,
	               |				Склад В
	               |					(ВЫБРАТЬ
	               |						ВТСкладыПоПриоритетам.Склад
	               |					ИЗ
	               |						ВТСкладыПоПриоритетам КАК ВТСкладыПоПриоритетам)) КАК РезервыТМЦОстатки
	               |		ПО (ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура)
	               |			И (ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиFBS КАК ВТОстаткиFBS
	               |		ПО (ВТОстаткиFBS.Номенклатура = ВТТовары.Номенклатура)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТОстатки.Номенклатура КАК Номенклатура,
				   //++Данилова Е.В. 15.01.2026  SNL-98
	               |	СУММА(ВЫБОР
	               |			КОГДА ВТОстатки.Остаток < 0
	               |				ТОГДА 0
	               |			ИНАЧЕ ВТОстатки.Остаток
	               |		КОНЕЦ) КАК Остаток, 
				   //--Данилова Е.В. 15.01.2026 
	               |	МАКСИМУМ(ВТОстатки.Количество) КАК Количество,
	               |	МАКСИМУМ(ВТОстатки.ОстатокFBS) КАК ОстатокFBS
	               |ИЗ
	               |	ВТОстатки КАК ВТОстатки
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТОстатки.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТовары.Номенклатура КАК Номенклатура,
	               |	ВЫБОР
	               |		КОГДА ВТТовары.Количество - ЕСТЬNULL(ВТОстаткиFBS.Количество, 0) > 0
	               |			ТОГДА ВТТовары.Количество - ЕСТЬNULL(ВТОстаткиFBS.Количество, 0)
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК Количество
	               |ИЗ
	               |	ВТТовары КАК ВТТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиFBS КАК ВТОстаткиFBS
	               |		ПО (ВТОстаткиFBS.Номенклатура = ВТТовары.Номенклатура)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТОстатки.Склад КАК Склад,
	               |	ВТОстатки.Номенклатура КАК Номенклатура,
	               |	ВТОстатки.Остаток КАК Остаток
	               |ИЗ
	               |	ВТОстатки КАК ВТОстатки
	               |ГДЕ
	               |	ВТОстатки.Остаток > 0
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВТОстатки.Приоритет
	               |ИТОГИ ПО
	               |	Склад";
	
	Запрос.УстановитьПараметр("Дата1",ТекущаяДата());
	Запрос.УстановитьПараметр("ТаблицаСкладовПоПриоритетам",ТаблицаСкладовПоПриоритетам);
	Запрос.УстановитьПараметр("ТЗТовары",ТЗНоменклатуры); 
	СкладыFBS = Новый Массив;
	СкладыFBS.Добавить(Параметры.Получить("СкладFBS")); 
	СкладыFBS.Добавить(Параметры.Получить("СкладFBSМаркировка"));
	
	Запрос.УстановитьПараметр("СкладыFBS", СкладыFBS);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	ВыборкаОбщиеОстатки 			= ПакетЗапросов[5].Выбрать();
	ТЧКоличествоДляРаспределения 	= ПакетЗапросов[6].Выгрузить();
	ВыборкаОстаткиПоСкладам = ПакетЗапросов[7].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СкладFBSПолучатель = Параметры.Получить("СкладFBS"); 
	
	Пока ВыборкаОбщиеОстатки.Следующий() Цикл
		
		Отбор = Новый Структура("Номенклатура",ВыборкаОбщиеОстатки.Номенклатура); 	
		СтрокиПоТовару = ТЗНоменклатуры.НайтиСтроки(Отбор);
		
		Если СтрокиПоТовару.Количество() > 0  Тогда
			
			СтрокиПоТовару[0].ОбщийОстаток = Макс(ВыборкаОбщиеОстатки.остаток,0) + Макс(ВыборкаОбщиеОстатки.ОстатокFBS,0); 	
			СтрокиПоТовару[0].Количество = ВыборкаОбщиеОстатки.Количество; 	
		КонецЕсли;
		
	КонецЦикла;
	МассивПРМСозданных1 = Новый Массив; 
	
	Пока ВыборкаОстаткиПоСкладам.Следующий() Цикл
		
		ПРМНовый = СоздатьДокументПРМ(СкладFBSПолучатель,ВыборкаОстаткиПоСкладам.Склад); 
		
		ВыборкаДетальныеЗаписи = ВыборкаОстаткиПоСкладам.Выбрать(); 
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ОтборНоменклатура = Новый Структура("Номенклатура",ВыборкаДетальныеЗаписи.Номенклатура); 	
			СтрокиНайденные = ТЧКоличествоДляРаспределения.НайтиСтроки(ОтборНоменклатура);
			Если СтрокиНайденные.Количество() > 0  Тогда
				
				СтрокаНайденная = СтрокиНайденные[0]; 
				НеобходимоеКоличество = СтрокаНайденная.Количество;
				
				Если НеобходимоеКоличество = 0 Тогда
					
					Продолжить;	
					
				КонецЕсли;
				
				КоличествоВПРМ = Мин(НеобходимоеКоличество,ВыборкаДетальныеЗаписи.Остаток);					
				
				СтрТЧ	=	ПРМНовый.Товары.Добавить();
				СтрТЧ.Номенклатура	=	ВыборкаДетальныеЗаписи.номенклатура;
				СтрТЧ.Заявка		=	НеобходимоеКоличество;
				стртч.ПодтвержденнаяЗаявка				=	КоличествоВПРМ;			
				стртч.ПодтвержденнаяЗаявкаПеремещения	=	стртч.ПодтвержденнаяЗаявка;
				СтрТЧ.Количество						=	стртч.ПодтвержденнаяЗаявка;				
				
				ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ПРМНовый);
				РассчитатьСуммуТабЧасти(СтрТЧ, ПРМНовый);
				
				СтрокаНайденная.Количество = СтрокаНайденная.Количество - КоличествоВПРМ; 
				
			Иначе 
				Продолжить; 
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПРМНовый.Товары.Количество() > 0   Тогда
			
			МассивПРМСозданных1.Добавить(ПРМНовый); 	
			
		КонецЕсли;
		
	КонецЦикла;
	
	//кол-во
	
	//Для каждого СтрокаСпаек Из ТЗСпайки Цикл
