	//	ОстатокОбщий = 	Строкинайденные[0].ОбщийОстаток; 
	//	
	//	НеобходимоеКоличество =  СтрокаНеСпаек.Количество - ОстатокОбщий; 
	//	Если НеобходимоеКоличество > 0  Тогда
	//		
	//		СтрокаНеХватает = ТЗНехватаетОстатков.Добавить(); 
	//		СтрокаНеХватает.Номенклатура = СтрокаНеСпаек.Номенклатура; 			
	//		СтрокаНеХватает.Количество = НеобходимоеКоличество;	
	//		
	//	КонецЕсли;
	//	
	//КонецЦикла; 
	
	Для каждого СтрокаТЧ Из ТЗНоменклатуры Цикл 
		
		НеобходимоеКоличество = СтрокаТЧ.Количество - СтрокаТЧ.ОбщийОстаток; 	
		Если НеобходимоеКоличество > 0  Тогда
			СтрокаНеХватает = ТЗНехватаетОстатков.Добавить(); 
			СтрокаНеХватает.Номенклатура = СтрокаТЧ.Номенклатура; 			
			СтрокаНеХватает.Количество = НеобходимоеКоличество;
		КонецЕсли;
	КонецЦикла;
	
	ТЗНехватаетОстатков.Свернуть("Номенклатура","Количество"); 
	
	
	//СкладFBSМаркировка = Параметры.Получить("СкладFBSМаркировка");
	СкладFBSПолучатель2 = Параметры.Получить("СкладFBS");
	
	МассивСкладовОтправители = Новый Массив; 
	Для НомерПараметра = 1 По 10 Цикл 
		Если Параметры.Получить("СкладОтправитель"+Строка(НомерПараметра)) <> Неопределено Тогда
			
			МассивСкладовОтправители.Добавить(Параметры.Получить("СкладОтправитель"+Строка(НомерПараметра))); 
			
		КонецЕсли;	
	КонецЦикла;
	
	ТаблицаСкладовПоПриоритетам = Новый ТаблицаЗначений;
	ТаблицаСкладовПоПриоритетам.Колонки.Добавить("Склад",ОписаниеТиповСклад);
	ТаблицаСкладовПоПриоритетам.Колонки.Добавить("Приоритет",ОписаниеТиповЧисло);
	Приоритет = 1; 
	Для каждого СкладИзНастроек Из МассивСкладовОтправители Цикл
		НСтрока = ТаблицаСкладовПоПриоритетам.Добавить(); 
		НСтрока.Склад = СкладИзНастроек; 
		НСтрока.Приоритет = Приоритет; 
		
		Приоритет = Приоритет +1; 		
	КонецЦикла;
	
	МассивПРМСозданных = Новый Массив;
	
	Если ЗначениеЗаполнено(СкладFBSПолучатель2) 
		И МассивСкладовОтправители.Количество() > 0 
		И ТЗНехватаетОстатков.Количество() > 0 Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧНехватает.Номенклатура КАК Номенклатура,
		|	ТЧНехватает.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&ТЧНеХватает КАК ТЧНехватает
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаСкладовПоПриоритетамМаркировка.склад КАК склад,
		|	ТаблицаСкладовПоПриоритетамМаркировка.Приоритет КАК Приоритет
		|ПОМЕСТИТЬ ВТСклады
		|ИЗ
		|	&ТаблицаСкладовПоПриоритетамМаркировка КАК ТаблицаСкладовПоПриоритетамМаркировка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
		|	ОстаткиТМЦОстатки.КоличествоОстаток - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество,
		|	ОстаткиТМЦОстатки.Склад КАК Склад
		|ПОМЕСТИТЬ ВТОстаткиМаркировки
		|ИЗ
		|	РегистрНакопления.ОстаткиТМЦ.Остатки(
		|			,
		|			Склад В (&СкладыМаркировки)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТТовары.Номенклатура
		|					ИЗ
		|						ВТТовары КАК ВТТовары)) КАК ОстаткиТМЦОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(, Склад В (&СкладыМаркировки)) КАК РезервыТМЦОстатки
		|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
		|			И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	ВТТовары.Количество КАК Количество
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|ГДЕ
		|	ВТТовары.Количество > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	ВТТовары.Количество КАК Количество,
		|	ЕСТЬNULL(ВТОстаткиМаркировки.Количество, 0) КАК Остаток,
		|	ВТОстаткиМаркировки.Склад КАК Склад
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстаткиМаркировки КАК ВТОстаткиМаркировки
		|		ПО (ВТОстаткиМаркировки.Номенклатура = ВТТовары.Номенклатура)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСклады КАК ВТСклады
		|		ПО (ВТСклады.склад = ВТОстаткиМаркировки.Склад)
		|ГДЕ
		|	ВТТовары.Количество > 0
		|	И ЕСТЬNULL(ВТОстаткиМаркировки.Количество, 0) > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТСклады.Приоритет,
		|	Номенклатура
		|ИТОГИ ПО
		|	Склад";	
		
		Запрос.УстановитьПараметр("ТаблицаСкладовПоПриоритетамМаркировка",ТаблицаСкладовПоПриоритетам);
		Запрос.УстановитьПараметр("СкладFBSМаркировка",СкладFBSПолучатель2); 
		Запрос.УстановитьПараметр("СкладыМаркировки",МассивСкладовОтправители);
		Запрос.УстановитьПараметр("ТЧНеХватает",ТЗНехватаетОстатков);
		
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		
		ТЧНеобхКоличество = ПакетЗапросов[3].Выгрузить();
		
		ВыборкаСклады = ПакетЗапросов[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		//создание ПРМ по складам  	
		
		Пока ВыборкаСклады.Следующий() Цикл
			
			ПРМНовый = СоздатьДокументПРМ(СкладFBSПолучатель2,ВыборкаСклады.Склад); 
			
			ВыборкаДетальныеЗаписи = ВыборкаСклады.Выбрать(); 
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				ОтборНоменклатура = Новый Структура("Номенклатура",ВыборкаДетальныеЗаписи.Номенклатура); 	
				СтрокиНайденные = ТЧНеобхКоличество.НайтиСтроки(ОтборНоменклатура);
				Если СтрокиНайденные.Количество() > 0  Тогда
					
					СтрокаНайденная = СтрокиНайденные[0]; 
					НеобходимоеКоличество = СтрокаНайденная.Количество;
					
					Если НеобходимоеКоличество = 0 Тогда
						
						Продолжить;	
						
					КонецЕсли;
					
					КоличествоВПРМ = Мин(НеобходимоеКоличество,ВыборкаДетальныеЗаписи.Остаток);					
					
					СтрТЧ	=	ПРМНовый.Товары.Добавить();
					СтрТЧ.Номенклатура	=	ВыборкаДетальныеЗаписи.номенклатура;
					СтрТЧ.Заявка		=	НеобходимоеКоличество;
					стртч.ПодтвержденнаяЗаявка				=	КоличествоВПРМ;			
					стртч.ПодтвержденнаяЗаявкаПеремещения	=	стртч.ПодтвержденнаяЗаявка;
					СтрТЧ.Количество						=	стртч.ПодтвержденнаяЗаявка;				
					
					ПриИзмененииНоменклатурыТабЧасти(СтрТЧ, ПРМНовый);
					РассчитатьСуммуТабЧасти(СтрТЧ, ПРМНовый);
					
					СтрокаНайденная.Количество = СтрокаНайденная.Количество - КоличествоВПРМ; 
					
				Иначе 
					Продолжить; 
				КонецЕсли;
				
			КонецЦикла;
			
			Если ПРМНовый.Товары.Количество() > 0   Тогда
				
				МассивПРМСозданных.Добавить(ПРМНовый); 	
				
			КонецЕсли;
			
		КонецЦикла;
		
		
	КонецЕсли;
	
	НачатьТранзакцию(); 
	
	Для каждого НовыйПРМ1 Из МассивПРМСозданных1 Цикл
		УстановитьНомерДокументаКлиентСервер(НовыйПРМ1);
		НовыйПРМ1.Записать(РежимЗаписиДокумента.Проведение);
		СообщитьИзМодуля(НовыйПРМ1);	
		
	КонецЦикла;  
	
	Для каждого НовыйПРМ Из МассивПРМСозданных Цикл
		УстановитьНомерДокументаКлиентСервер(НовыйПРМ);	
		НовыйПРМ.Записать(РежимЗаписиДокумента.Проведение);
		СообщитьИзМодуля(НовыйПРМ);	
		
	КонецЦикла;
	
	Если  ТранзакцияАктивна() Тогда
		
		ЗафиксироватьТранзакцию();	
		
	КонецЕсли;
	
	Попытка
		ЗаписатьВЛог("Регламент","Контроль по остатку: ","Информация"); 
		
		Для каждого   НовыйПРМ1 Из МассивПРМСозданных1  Цикл
			
			КорректировкаПРМПоОстаткам(НовыйПРМ1);	
			
		КонецЦикла;
		
		
		Для каждого НовыйПРМ Из МассивПРМСозданных Цикл
			
			КорректировкаПРМПоОстаткам(НовыйПРМ);	
			
		КонецЦикла;
		
	Исключение
		ЗаписатьВЛог("Регламент","Контроль по остатку ошибка: "+ОписаниеОшибки(),"Информация");
	КонецПопытки; 
	
	Возврат ТЗНоменклатурыКопия;

КонецФункции


