//вынесла в отдельную процедуру 
Процедура КорректировкаПРМПоОстаткам(ПРМОбъект)

	ТЗ1 = ПРМОбъект.Товары.Выгрузить();
		
	Запрос1 = Новый Запрос;
	Запрос1.Текст = 
	"ВЫБРАТЬ
	|ТЗНом.Номенклатура КАК Номенклатура,
	|ТЗНом.НомерСтроки КАК НомерСтроки,
	|ТЗНом.Количество КАК Количество
	
	|ПОМЕСТИТЬ ВТ_Ном
	|ИЗ
	|	&ТЗНом КАК ТЗНом
	|;
	|ВЫБРАТЬ
	|	ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|	ОстаткиТМЦОстатки.КоличествоОстаток - ЕстьNull(РезервыТМЦОстатки.КоличествоОстаток,0) КАК Количество,
	|	ВТ_Ном.Количество КАК КолПрм,
	|	ВТ_Ном.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(, Склад = &Склад) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(, Склад = &Склад) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		СОЕДИНЕНИЕ ВТ_Ном КАК ВТ_Ном
	|		ПО ОстаткиТМЦОстатки.Номенклатура = ВТ_Ном.Номенклатура
	|		ГДЕ (ОстаткиТМЦОстатки.КоличествоОстаток - ЕстьNull(РезервыТМЦОстатки.КоличествоОстаток,0))<0
	|	УПОРЯДОЧИТЬ ПО 4 УБЫВ
	|";
	
	
	Запрос1.УстановитьПараметр("Склад",ПРМОбъект.Склад);
	Запрос1.УстановитьПараметр("ТЗНом",ТЗ1);
	Выб1 = Запрос1.Выполнить().Выбрать();
	ЗаписатьВЛог("Регламент","Контроль по остатку:  кол поз1 "+Строка(Выб1.Количество()),"Информация");
	ЕстьМод=Ложь;
	Пока Выб1.Следующий() Цикл
		ЕстьМод=Истина;
		СтрТЧ1=ПРМОбъект.Товары.Получить(Выб1.НомерСтроки-1);
		ФКол=Выб1.КолПрм+Выб1.Количество;
		Если (ФКол>0) Тогда
			
			СтрТЧ1.Заявка=ФКол;
			СтрТЧ1.ПодтвержденнаяЗаявка=ФКол;
			СтрТЧ1.Количество=ФКол;
			
			ПриИзмененииНоменклатурыТабЧасти(СтрТЧ1, ПРМОбъект);
			РассчитатьСуммуТабЧасти(СтрТЧ1, ПРМОбъект);
		Иначе
			ПРМОбъект.Товары.Удалить(Выб1.НомерСтроки-1);
		КонецЕсли;
	КонецЦикла;	
	Если ЕстьМод Тогда
		ПРМОбъект.Записать(РежимЗаписиДокумента.Проведение);
		ЗаписатьВЛог("Регламент","Контроль по остатку:  перезаписан документ  "+Строка(ПРМОбъект.Номер),"Информация");
	КонецЕсли;	
	

КонецПроцедуры
