Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	
	Если ТаблицаПараметров<>Неопределено Тогда
		Параметры=Новый Соответствие;
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			ЗаписатьВЛог("Регламент","Параметр: "+СтрокаТП.Имя+" - "+СтрокаТП.Значение,"Информация");		
			Параметры.Вставить(СтрокаТП.Имя,СтрокаТП.Значение);
		КонецЦикла;	
	КонецЕсли;
	  	
		
	СписокДействующихМатриц = ПолучитьСписокДействМатриц(параметры); 
	
	ТЗСпайкиИсключить = неопределено; 
	ТЗНоменклатурыКопияСпайки = СформироватьПРМНаСпайки(СписокДействующихМатриц,Параметры,ТЗСпайкиИсключить);
	СформироватьОбратныеПРМcFBS(ТЗНоменклатурыКопияСпайки,Параметры,"Спайки");
	
	ТЗНоменклатурыКопия = СформироватьПРМнаFBS(параметры,СписокДействующихМатриц,ТЗСпайкиИсключить); 
	
	СформироватьОбратныеПРМcFBS(ТЗНоменклатурыКопия,Параметры); 
	 
	 
КонецПроцедуры

