	//	Для каждого СтрокаКомпл  Из СтрокаСпаек.номенклатура.Коплектующие Цикл 
	//		Если Нехватает > 0 Тогда
	//			СтрокаНеХватает = ТЗНехватаетОстатков.Добавить(); 
	//			СтрокаНеХватает.Номенклатура = СтрокаКомпл.Номенклатура; 			
	//			СтрокаНеХватает.Количество = Нехватает  * СтрокаКомпл.Количество;
	//		КонецЕсли;
	//		
	//		Отбор = Новый Структура("номенклатура",СтрокаКомпл.номенклатура); 
	//		Строкинайденные = ТЗНоменклатуры.НайтиСтроки(Отбор);
	//		Для каждого Строканайденная Из Строкинайденные Цикл
