	Иначе
		
		ЛСК = Документы.ЛистСборкиКомплектовЧЗ.ПолучитьЛСКДляFBS(ЗСБ, , , , Истина);
		
	КонецЕсли;
	// Кельманов А.В. - Оптимизация работы - 2026.05.20 }
	
	ЛСКОбъект = ЛСК.ПолучитьОбъект();
	ЛСКОбъект.Дата = ТекущаяДата();
	ЛСКОбъект.Записать(РежимЗаписиДокумента.Проведение);

	ДопПараметры = Новый Структура("Статус, МассивДоступныхКодов, ТипКода, Добавлять", Перечисления.СтатусыКодовМаркировкиФакт.Зарезервирован, МассивДоступныхКодовЗСБ, Перечисления.ТипыКодовМаркировки.Набор, Истина);
	
	РезультатПолученияКодов = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьЗабронироватьСвободныеКодыШтук(МассивПродукцииДляПолученияКодов, ЛСК, ДопПараметры);		
	
	Если Не РезультатПолученияКодов.Успешно Тогда
		
		ТекстОшибки = СтрСоединить(РезультатПолученияКодов.Ошибки, Символы.ПС);
		
		Возврат Неопределено;	
		
	КонецЕсли;

