&НаСервере
Процедура ЗаполнитьТаблицуДанныхМатрицы()
	
	Запрос = Новый Запрос;				
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	МатрицаТовары.Номенклатура КАК Номенклатура,
	               |	МатрицаТовары.КратностьКоробки КАК КратностьКоробки,
	               |	МатрицаТовары.ШККонтрагента КАК ШККонтрагента,
	               |	МатрицаТовары.ШККонтрагентаДополнительный КАК ШККонтрагентаДополнительный,
	               |	МатрицаТовары.Номенклатура.Родитель КАК Модель,
	               |	МатрицаТовары.Номенклатура.КодПроизводителя КАК КодПроизводителя,
	               |	МатрицаТовары.Номенклатура.Цвет.Наименование КАК Цвет,
	               |	""Размер:"" + МатрицаТовары.Номенклатура.Размер.Наименование КАК Размер,
	               |	ВЫРАЗИТЬ(МатрицаТовары.Номенклатура.Цвет.РусскоеНаименование КАК СТРОКА(30)) КАК РусскоеНаименованиеЦвета,
	               |	МатрицаТовары.Номенклатура.Наименование КАК НаименованиеНоменклатуры,
	               |	0 КАК РазмерКомплекта,
	               |	МатрицаТовары.Кратность КАК КратностьБлочка,
	               |	МатрицаТовары.Ссылка.Акция КАК Акция,
	               |	МатрицаТовары.Ссылка.Дата КАК Дата
	               |ИЗ
	               |	Документ.Матрица.Товары КАК МатрицаТовары
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матрица.ПунктыДоставки КАК МатрицаПунктыДоставки
	               |		ПО МатрицаТовары.Ссылка = МатрицаПунктыДоставки.Ссылка
	               |ГДЕ
	               |	МатрицаТовары.Ссылка.Проведен
	               |	И МатрицаТовары.Ссылка.Контрагент = &Контрагент
	               |	И МатрицаТовары.Ссылка.Договор = &Договор
	               |	И МатрицаТовары.Ссылка.Дата <= &Дата1
	               |	И МатрицаТовары.Ссылка.ДатаОкончания >= &Дата2
	               |	И МатрицаПунктыДоставки.ПунктДоставки = &ПунктДоставки
	               |	И МатрицаТовары.Номенклатура В(&Номенклатура)
	               |	И МатрицаТовары.Ссылка.ПостояннаяАкция = &ПостояннаяАкция
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	МатрицаТовары.Ссылка.Акция УБЫВ,
	               |	МатрицаТовары.Ссылка.Дата УБЫВ";
	
	Если ЗначениеЗаполнено(ТекущийЛП) Тогда
		
		Дата = ТекущийЛП.Дата;
		
	Иначе
		
		Дата = ТекущаяДата();
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Дата2", НачалоДня(Дата));
	Запрос.УстановитьПараметр("Дата1", КонецДня(Дата));
	Запрос.УстановитьПараметр("Контрагент", РНК.Контрагент);		
	Запрос.УстановитьПараметр("ПунктДоставки", РНК.ПунктДоставки);				
	Запрос.УстановитьПараметр("Договор", РНК.Договор);		
	запрос.УстановитьПараметр("Номенклатура", РНК.Товары.ВыгрузитьКолонку("Номенклатура"));
	запрос.УстановитьПараметр("ПостояннаяАкция", РНК.ПостояннаяАкция);
	
	ТаблицаДанныхМатрицы = Запрос.Выполнить().Выгрузить();

КонецПроцедуры

&НаКлиенте
Процедура ПовторитьПечать(Команда)
	
	РаспечататьЭтикетки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЭтикеткаОнлайн(Команда)
	
	Если Не ЗначениеЗаполнено(ТекущийЛП) И ЗначениеЗаполнено(ПоследнийЛП) Тогда
		
		Результат = РезультатПечатиЭтикеткиОнлайн(); 
		
		Если Результат.Успех Тогда   	 
			
			Если Результат.ТабДокумент <> Неопределено Тогда
				
				Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
					Результат.ТабДокумент.Показать("Наклейки " + РНК.Номер);
				Иначе
					Попытка 
						Результат.ТабДокумент.Напечатать(); 
					Исключение
						Результат.ТабДокумент.Показать("Наклейки " + РНК.Номер);
					КонецПопытки;
				КонецЕсли;
				
			КонецЕсли;
			
			Если Результат.ТабДокументДоп <> Неопределено Тогда
				
				Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
