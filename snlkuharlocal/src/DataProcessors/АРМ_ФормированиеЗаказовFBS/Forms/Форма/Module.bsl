				ТабДокЭтикеткаЧЗ.Напечатать()
			Исключение
				ТабДокЭтикеткаЧЗ.Показать();
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ШтрихКодFBS) Или ЗначениеЗаполнено(НомерЗаказаFBS) Тогда
		
		Если ДопПараметрыНакладной.Имя = "WB_FBS" Тогда
			
			ТабДокЭтикеткаWB = ТабДокЭтикеткаWB();
			
			Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
				
				ТабДокЭтикеткаWB.Показать();
				
			Иначе
				
				Попытка 
					ТабДокЭтикеткаWB.Напечатать()
				Исключение
					ТабДокЭтикеткаWB.Показать();
				КонецПопытки;
				
			КонецЕсли;
			
		ИначеЕсли ДопПараметрыНакладной.Имя = "OZON_FBS" Тогда
			
			РаспечататьЭтикеткуОзонДляСхемыВБ();
			
		ИначеЕсли ДопПараметрыНакладной.Имя = "YANDEX_FBS" Или ДопПараметрыНакладной.Имя = "MAGNIT_FBS" Тогда
			
			РаспечататьЭтикеткуЯндексМагнитДляСхемыВБ();

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТабДокЭтикеткаЧЗ()
	
	ОбработкаПечатиЧЗ = Обработки.ПечатьЭтикетокЧЗ.Создать();
		
	ИмяМакета = "Этикетка_25_25";
	Макет = ОбработкаПечатиЧЗ.ПолучитьМакет(ИмяМакета);
	
	ТабДок = Новый ТабличныйДокумент;
	
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ОтображатьЗаголовки = Ложь;	
	ТабДок.ИмяПараметровПечати = "ПараметрыПечати_КМ_" + ИмяМакета;	
	
	ДопПараметры = Новый Структура("НомерШтуки, НомерКоробки, ШтукВКоробке", 1, 1, 1);
	
	ДанныеДляПечати	= МаркировкаКС.ПолучитьПоляКМДляПечати(ОжидаемыйДляСканированияКодЧЗ);
		
	Область = ОбработкаПечатиЧЗ.СформироватьЭтикету(Макет, ДанныеДляПечати, ДопПараметры);
	
	ТабДок.Вывести(Область);
	
	Возврат ТабДок; 
	
КонецФункции

&НаСервере
Функция ТабДокЭтикеткаWB()
	
	ТабДок = Новый ТабличныйДокумент;
	
	ТабДок.ИмяПараметровПечати = "АналогЗПЛВайлдберрис";
	
	ПолноеИмяФайла = СокрЛП(Константы.КаталогВнешнихОтчетов.Получить() + "PrnForms\РаботаСЗаказомКлиента.epf");
	ОбработкаПечати = ВнешниеОбработки.Создать(ПолноеИмяФайла);
	
	Макет = ОбработкаПечати.ПолучитьМакет("КРВайлдберис"); 

	ОблСтрока = Макет.ПолучитьОбласть("Строка");
	
	ОблСтрока.Параметры.ПрефиксЗаказа = ПрефиксЗаказа;
	ОблСтрока.Параметры.СуффиксЗаказа = СуффиксЗаказа;
	
	Размер = 144;
	
	ДвДанные = ФормированиеПечатныхФорм.ДанныеQRКода(ШтрихКодFBS, 0, Размер);
	
	Если ДвДанные <> Неопределено Тогда
		Карт = Новый Картинка(ДвДанные);				
		ОблСтрока.Область(1, 2).Картинка = Карт;
	КонецЕсли;
	
	ТабДок.РазмерСтраницы = "Custom";
	ТабДок.ВысотаСтраницы = 41;
	ТабДок.ШиринаСтраницы = 58;
	ТабДок.ПолеСправа = 0;
	ТабДок.ПолеСлева = 0;
	ТабДок.ПолеСверху = 0;
	ТабДок.ПолеСнизу = 0;
	ТабДок.Автомасштаб = Истина;
	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ОтображатьЗаголовки = Ложь;
	
	ТабДок.Вывести(ОблСтрока);
	
	Возврат ТабДок; 
	
КонецФункции

&НаСервере
Функция ТабДокЭтикеткаСШКМатрицы(ТекстОшибки = "")
	
	Если ТаблицаДанныхМатрицы = Неопределено Тогда
		ЗаполнитьТаблицуДанныхМатрицы();
	КонецЕсли;
	
	СтрокаМатрицы = ТаблицаДанныхМатрицы.Найти(ТекШтукаСпайка, "Номенклатура");
	
	Если СтрокаМатрицы = Неопределено Тогда
		ТекстОшибки = "" + ТекШтукаСпайка + " нет в матрице. Этикетка не распечатана.";
		Возврат Неопределено;
	КонецЕсли;

	НаборПолей = Новый Структура("КодПроизводителя, Модель, ЦветБольшой, РазмерБольшой, РусскоеНаименованиеЦвета, РусскийПроизводитель, ДатаИзготовления, НаименованиеНоменклатуры, РазмерКомплекта");
	
	НаборПолей.ДатаИзготовления = НРег(Формат(ТекущаяДата() - 90 * 24 * 60 * 60, "ДФ=MMMM") + " " + Формат(НачалоМесяца(ТекущаяДата() - 90 * 24 * 60 * 60), "ДФ=yyyy") + " г.");
	
	ЗаполнитьЗначенияСвойств(НаборПолей, СтрокаМатрицы);
	
	НаборПолей.РазмерБольшой = ВРег(СтрокаМатрицы.Размер);
	НаборПолей.ЦветБольшой = ВРег(СтрокаМатрицы.Цвет);
	НаборПолей.РусскоеНаименованиеЦвета = ВРег(СтрокаМатрицы.РусскоеНаименованиеЦвета);
	
	// Кельманов А.В. - SNL-233 - 2026.05.15 {
	//Если ОтгрузкаКомплектов Тогда
	//	
	//	Макет = Обработки.АРМ_ФормированиеЗаказовFBS.ПолучитьМакет("ЭтикеткаКомплект");

	//	НаборПолей.РазмерКомплекта = ПолучитьРеквизитШапки(ТекШтукаСпайка, "Родитель.ШтукВКомплекте", "Справочник"); 

	//Иначе
	//	
	//	Макет = Обработки.АРМ_ФормированиеЗаказовFBS.ПолучитьМакет("Этикетка1_2х0_85_ЕАС");
	//	
	//КонецЕсли;
	Макет = Обработки.АРМ_ФормированиеЗаказовFBS.ПолучитьМакет("ЭтикеткаКомплект");

	НаборПолей.РазмерКомплекта = ПолучитьРеквизитШапки(ТекШтукаСпайка, "Родитель.ШтукВКомплекте", "Справочник"); 
	// Кельманов А.В. - SNL-233 - 2026.05.15 }
	
	ТабДок = Новый ТабличныйДокумент;
	
	ТабДок.ИмяПараметровПечати = "УвеличенныйШКFBS";
	
	ОблЭтикетка = Макет.ПолучитьОбласть("Строка");
	ОблЭтикетка.Параметры.Заполнить(НаборПолей);
	
	Компонента = ПодключитьКомпонентуИзМакета("Barcode", "ОбщийМакет.КомпонентаПечатиШтрихкодов");
	
	ПараметрыШК = Маркировка_ПИ.ПараметрыГенерацииШКпоУмолчанию();
	Рисунок = ОблЭтикетка.Рисунки.ШтрихКод;
	
	Эталон = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьМакет("Эталон");
	ММвВПикселе = Эталон.Рисунки.Квадрат100Пикселей.Высота / 100;	
	
	ПараметрыШК.ТипКода	= 1;
	
	ПараметрыШК.Высота = Окр(Рисунок.Высота / ММвВПикселе);
	ПараметрыШК.Ширина = Окр(Рисунок.Ширина / ММвВПикселе);
	
	ПараметрыШК.Масштабировать = Ложь;	
	ПараметрыШК.СохранятьПропорции = Истина;	
	ПараметрыШК.ОтображатьТекст = Истина;
	ПараметрыШК.РазмерШрифта = 12;
	ПараметрыШК.ВертикальноеВыравнивание = 1;	
	
	ПараметрыШК.УголПоворота = 0;	
	ПараметрыШК.Штрихкод = СтрокаМатрицы.ШККонтрагента;	
	ПараметрыШК.УбратьЛишнийФон = Истина;
	
	рШтрихКод = ПодготовитьИзображениеШтрихкодаEAN13(Компонента, ПараметрыШК);	
	
	Рисунок.Картинка = рШтрихКод.Картинка;

	ТабДок.Вывести(ОблЭтикетка);
	
	Возврат ТабДок;

КонецФункции

&НаКлиенте
Процедура РаспечататьЭтикеткуОзонДляСхемыВБ()

	ЭтикеткаСформировалась = Ложь;
	
	ПутьЭтик = "\\srvfile-sk\FBS";
	
	ИмяФайлаЭтикеткиОзон = ПутьЭтик + "\" + НомерЗаказаFBS + ".pdf";
	
	ФайлЭтикетки = Новый Файл(ИмяФайлаЭтикеткиОзон);
	
	Если ФайлЭтикетки.Существует() Тогда    		
		
		Попытка				
			ЗапуститьПриложение(ИмяФайлаЭтикеткиОзон);
			ЭтикеткаСформировалась = Истина;
		Исключение
		КонецПопытки;
		
	КонецЕсли;	  
	
	Если Не ЭтикеткаСформировалась Тогда
		
		ТабДокВременнаяЭтикеткаFBS = ТабДокВременнаяЭтикеткаFBS();
		
		Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
			
			ТабДокВременнаяЭтикеткаFBS.Показать();
			
		Иначе
			
			Попытка 
				ТабДокВременнаяЭтикеткаFBS.Напечатать()
			Исключение
				ТабДокВременнаяЭтикеткаFBS.Показать();
			КонецПопытки;
			
		КонецЕсли;
					
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура РаспечататьЭтикеткуЯндексМагнитДляСхемыВБ()
	
	ЭтикеткаСформировалась = Ложь;
	
	ИмяФайлаЭтикеткиЯндексМагнит = ИмяФайлаЭтикеткиЯндексМагнит();
	
	ФайлЭтикетки = Новый Файл(ИмяФайлаЭтикеткиЯндексМагнит);
	
	Если ФайлЭтикетки.Существует() Тогда
		
		Попытка
			ЗапуститьПриложение(ИмяФайлаЭтикеткиЯндексМагнит);
			ЭтикеткаСформировалась = Истина;
		Исключение
			Сообщить(СтрШаблон("Этикетка по заказу %1 не готова!", НомерЗаказаFBS))
		КонецПопытки
		
	КонецЕсли;
	
	Если Не ЭтикеткаСформировалась Тогда
		
		ТабДокВременнаяЭтикеткаFBS = ТабДокВременнаяЭтикеткаFBS();
		
		Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
			
			ТабДокВременнаяЭтикеткаFBS.Показать();
			
		Иначе
			
			Попытка 
				ТабДокВременнаяЭтикеткаFBS.Напечатать()
			Исключение
				ТабДокВременнаяЭтикеткаFBS.Показать();
			КонецПопытки;
			
		КонецЕсли;
					
	КонецЕсли;	

КонецПроцедуры

