
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Сканировщик = ПараметрыСеанса.Пользователь;
	
	РежимСканирования = Перечисления.РежимСканирования.Добавление;
	
	ПодтверждатьЭтикеткуОнлайнСканированием = Истина; // Кельманов А.В. - SNL-233 - 2026.05.15
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
Функция ПроверкаРНК(ТекстОшибки = "")
		
	ОтгрузкаКомплектов = Ложь;
	
	ИспользоватьЛНТолькоДляНабора = ИспользоватьЛНТолькоДляНабора(РНК);
	
	Если Не ИспользоватьЛНТолькоДляНабора Тогда
		
		ТекстОшибки = "Для накладной не установлен признак ""Использовать ЛН только для набора""!";
		
		Возврат Ложь;
		
	КонецЕсли;

	ДопПараметрыНакладной = ОбщегоНазначения_ПИ.ПолучитьДопПараметрыНакладной(РНК);
	
	Если Не ДопПараметрыНакладной.ОтгрузкаFBS Тогда
		
		ТекстОшибки = "Это не накладная FBS!";
		
		Возврат Ложь;
		
	КонецЕсли;

	Если РНК.СостояниеНакладной <> Перечисления.СостоянияНакладной.ОжиданиеПереукладки И РНК.СостояниеНакладной <> Перечисления.СостоянияНакладной.Переукладка Тогда
		
		ТекстОшибки = "Состояние накладной: " + РНК.СостояниеНакладной + ". Допустимые состояния: ""Ожидание переукладки"" и ""Переукладка""";
		
		Возврат Ложь;
		
	КонецЕсли;
	
	ОтгрузкаКомплектов = РНК.ОтгрузкаКомплектов;
	
	Возврат Истина;
		
КонецФункции

&НаСервере
Процедура ЗаполнитьЛистыПереукладки()
	
	ЛистыПереукладки.Очистить();
	
	Если Не ЗначениеЗаполнено(РНК) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистПереукладки.Ссылка КАК ЛП
	               |ИЗ
	               |	Документ.ЛистПереукладки КАК ЛистПереукладки
	               |ГДЕ
	               |	ЛистПереукладки.ДокОснование = &РНК
	               |	И НЕ ЛистПереукладки.Завершен
	               |	И НЕ ЛистПереукладки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("РНК", РНК);
	
	ЛистыПереукладки.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

