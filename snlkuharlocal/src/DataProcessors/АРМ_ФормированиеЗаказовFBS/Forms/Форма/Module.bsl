		Иначе 
			
			МаркировкаКС.ВывестиОшибки(Результат);
			
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	Если Товары.Количество() > 0 Или ШтрихкодыУпаковок.Количество() > 0 Тогда
		
		Сообщить("Есть несохранённые данные. Сначала завершите работу."); 
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущийЛП) Тогда
		
		Сообщить("Нет активного листа переукладки."); 
		
		Возврат;
		
	КонецЕсли;
	
	ЗавершитьТекущийЛП();
	
	Сообщить(Строка(ТекущийЛП) + " завершен и доступен только для просмотра");		
	
	ЗаполнитьЛистыПереукладки();
	ЗаполнитьТовары_ПланФакт(); // Кельманов А.В. - ИЗМ-0000000063 - 2026.06.19
	
	ПоследнийЛП = ТекущийЛП;
	
	ТекущийЛП = Неопределено;
	ТекущийЛСК = Неопределено;
	ТипКороба = Неопределено;
	
	Товары_ТекущийЛП.Очистить();
	ШтрихкодыУпаковок_ТекущийЛП.Очистить();
	
	Результат = РезультатПечатиЭтикеткиОнлайн(); 
	
	Если Результат.Успех Тогда   	 
		
		Если Результат.ТабДокумент <> Неопределено Тогда

			Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
				Результат.ТабДокумент.Показать("Наклейки " + РНК.Номер);
			Иначе
				Попытка 
					Результат.ТабДокумент.Напечатать(); 
				Исключение
					Результат.ТабДокумент.Показать("Наклейки " + РНК.Номер);
				КонецПопытки;
			КонецЕсли;

		КонецЕсли;
		
		Если Результат.ТабДокументДоп <> Неопределено Тогда

			Если ПараметрыСеанса.ВыводитьПечатныеФормыНаПредпросмотр Тогда
				Результат.ТабДокументДоп.Показать("ДополнительнаяЭтикеткаНаКоробИзЛП" + СтрЗаменить(РНК.Контрагент.Код, "-", ""));
			Иначе
				Попытка 
					Результат.ТабДокументДоп.Напечатать(); 
				Исключение
					Результат.ТабДокументДоп.Показать("ДополнительнаяЭтикеткаНаКоробИзЛП" + СтрЗаменить(РНК.Контрагент.Код, "-", ""));
				КонецПопытки;
			КонецЕсли;

		КонецЕсли;
		
		// Кельманов А.В. - SNL-233 - 2026.05.19 {
		//УстановитьВидимость();
		Если Не ЗначениеЗаполнено(ОжидаемыйДляСканированияКодЛП) Тогда
			
			УстановитьВидимость();
			
		КонецЕсли;
		// Кельманов А.В. - SNL-233 - 2026.05.19 }
	
	Иначе 
		
		МаркировкаКС.ВывестиОшибки(Результат);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция РезультатПечатиЭтикеткиОнлайн()
	
	ЛНДляПечати = ТекущийЛП;
	
	Если Не ЗначениеЗаполнено(ТекущийЛП) И ЗначениеЗаполнено(ПоследнийЛП) Тогда
		
		ЛНДляПечати = ПоследнийЛП;
		
	КонецЕсли;
		
	ПравилаРаботыСАгрегациейЧЗ = МаркировкаКС.ПолучитьСтруктуруПравилРаботыСАгрегациейПоНакладной(РНК); 
	
	ДопПараметры = Обработки.ПечатьЛистаНабора.СтруктураПечатиЭтикеткиОнлайн(); 
	ДопПараметры.КодАгрегации = ЛНДляПечати.КодАгрегации; 
	ДопПараметры.ЭтоУзел_Склад = Истина; 
	ДопПараметры.ДопПараметрыНакладной = ДопПараметрыНакладной; 
	ДопПараметры.КоличествоЕдиниц = 0; 
	ДопПараметры.ПравилаРаботыСАгрегациейЧЗ = ПравилаРаботыСАгрегациейЧЗ;

	Результат = Обработки.ПечатьЛистаНабора.ПечатьЭтикеткиОнлайн(ЛНДляПечати.ПолучитьОбъект(), Неопределено, ДопПараметры, Неопределено, Неопределено);
	
	// Кельманов А.В. - SNL-233 - 2026.05.15 {
	Если Результат.Успех И ПодтверждатьЭтикеткуОнлайнСканированием Тогда
		
		МассивКодовQR = Результат.МассивКодовQR;
		
		Если МассивКодовQR.Количество() > 0 Тогда
			
			ОжидаемыйДляСканированияКодЛП = МассивКодовQR[0];
			
			Если ЗначениеЗаполнено(ОжидаемыйДляСканированияКодЛП) Тогда
				
				Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте распечатанную этикетку онлайн";
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	// Кельманов А.В. - SNL-233 - 2026.05.15 }
			
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПроверитьВсёОтсканировано()
	
	ВсёОтсканировано = Ложь;

	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	               |	СУММА(РасходнаяНакладнаяТовары.Количество) КАК Количество
	               |ПОМЕСТИТЬ ВТ_РНК
	               |ИЗ
	               |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	               |ГДЕ
	               |	РасходнаяНакладнаяТовары.Ссылка = &РНК
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	РасходнаяНакладнаяТовары.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЛистПереукладкиТовары.Номенклатура КАК Номенклатура,
	               |	СУММА(ЛистПереукладкиТовары.Отсканировано) КАК Количество
	               |ПОМЕСТИТЬ ВТ_ЛП
	               |ИЗ
	               |	Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
	               |ГДЕ
	               |	ЛистПереукладкиТовары.Ссылка.ДокОснование = &РНК
	               |	И ЛистПереукладкиТовары.Ссылка.Проведен
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЛистПереукладкиТовары.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_РНК.Номенклатура КАК Номенклатура,
	               |	ВТ_РНК.Количество КАК КоличествоРНК,
	               |	ЕСТЬNULL(ВТ_ЛП.Количество, 0) КАК КоличествоЛП
	               |ИЗ
	               |	ВТ_РНК КАК ВТ_РНК
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЛП КАК ВТ_ЛП
	               |		ПО ВТ_РНК.Номенклатура = ВТ_ЛП.Номенклатура
	               |ГДЕ
	               |	ВТ_РНК.Количество > ЕСТЬNULL(ВТ_ЛП.Количество, 0)";
	
	Запрос.УстановитьПараметр("РНК", РНК);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		
		ВсёОтсканировано = Истина;
		
	КонецЕсли;
	
	Возврат ВсёОтсканировано;
	
КонецФункции

