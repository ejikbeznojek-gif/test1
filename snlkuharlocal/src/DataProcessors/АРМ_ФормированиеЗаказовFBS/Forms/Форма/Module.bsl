	               |ГДЕ
	               |	ЗаданиеНаСборкуКомплектовЧЗШтрихкодыУпаковок.Ссылка = &ЗСБ";
	
	Запрос.УстановитьПараметр("ЗСБ", ЗСБ);
	
	МассивДоступныхКодовЗСБ = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодУпаковки");
	
	Если МассивДоступныхКодовЗСБ.Количество() = 0 Тогда
		
		ТекстОшибки = "Не обнаружены зарезервированные коды ЧЗ спаек в ЗСБ!";
		
		Возврат Неопределено;	
		
	КонецЕсли;
	
	МассивПродукцииДляПолученияКодов = Новый Массив;
