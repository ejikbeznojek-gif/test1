&НаКлиенте
Процедура РНКПриИзменении(Элемент)

	ОбработатьИзменениеРНК();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеРНК(ТекстОшибки = "")
	
	Если ЗначениеЗаполнено(РНК) И Не ПроверкаРНК(ТекстОшибки) Тогда
		
		РНК = Неопределено;
		
	КонецЕсли;
	
	// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 {
	Если НужноОбновитьНакладнуюПоЗаказу(РНК) Тогда
		
		ОбновитьНакладнуюПоЗаказу(РНК);
		
	КонецЕсли;
	// Кельманов А.В. - ИЗМ-0000000122 - 2026.06.26 }

	ЗаполнитьЛистыПереукладки();	
	ЗаполнитьТовары_ПланФакт(); // Кельманов А.В. - ИЗМ-0000000063 - 2026.06.19
	
	Товары.Очистить();
	ШтрихкодыУпаковок.Очистить();
	
	ОжидаемыйДляСканированияКодЧЗ = Неопределено; 
	ОтсканированныйОжидаемыйКодЧЗ = Неопределено; 
	
	НомерЗаказаFBS = Неопределено; 
	ШтрихКодFBS = Неопределено; 
	ПрефиксЗаказа = Неопределено; 
	СуффиксЗаказа = Неопределено; 
	ТекШтукаСпайка = Неопределено; 
	
	ДатаНачалаСканирования = Неопределено;

	ТекущийЛП = Неопределено;
	ТекущийЛСК = Неопределено;
	ПоследнийЛП = Неопределено;
	ЗСБ = Неопределено;
	ТаблицаДанныхМатрицы = Неопределено;
	ТипКороба = Неопределено;
	
	Товары_ТекущийЛП.Очистить();
	ШтрихкодыУпаковок_ТекущийЛП.Очистить();
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
	
    ГруппаТестТолькоПросмотр = Не РольДоступна("Администратор");
	
	Элементы.РНК.ТолькоПросмотр = ГруппаТестТолькоПросмотр;
	Элементы.РежимСканирования.ТолькоПросмотр = ГруппаТестТолькоПросмотр;
	Элементы.ИмитацияСканирования.ТолькоПросмотр = ГруппаТестТолькоПросмотр;
	
	Если ЗначениеЗаполнено(РНК) Тогда
		
		Заголовок = "Формирование заказов FBS: " + РНК;
		
		Элементы.НадписьОтсканируйтеЗНБ.Видимость = Ложь;		
		Элементы.ГруппаСтраницы.Видимость = Истина;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСканирование;
		
		Элементы.ПланФактКомплектующие.Видимость = ОтгрузкаКомплектов; // Кельманов А.В. - Изменение 0000000063 - 2026.07.10
	
		Элементы.НадписьОтсканируйте.Видимость = Истина;
		
		Если (Не ЗначениеЗаполнено(ТекущийЛП) И Не ЗначениеЗаполнено(ТипКороба)) Или ИзменениеТипаКороба Тогда
			
			Элементы.НадписьОтсканируйте.Заголовок = "Укажите тип короба (отсканируйте ШК коробки)";
			
		ИначеЕсли ЗначениеЗаполнено(НадписьОтсканируйтеПоследнее) Тогда
			
			Элементы.НадписьОтсканируйте.Заголовок = НадписьОтсканируйтеПоследнее;
			
			НадписьОтсканируйтеПоследнее = "";
			
		ИначеЕсли ОтгрузкаКомплектов Тогда
			
			Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код ЧЗ комплектующей или штрихкод упаковки";
			
		Иначе
			
			Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код ЧЗ штуки товара";
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекущийЛП) Тогда
			
			Элементы.НадписьЛП.Заголовок = ТекущийЛП;
			
		Иначе
			
			Элементы.НадписьЛП.Заголовок = "Лист переукладки: [Будет создан новый]";
			
		КонецЕсли;
		
		Если ЛистыПереукладки.Количество() > 0 Тогда
			
			Элементы.ГруппаНезавершённыеЛП.Видимость = Истина;
			
		Иначе
			
			Элементы.ГруппаНезавершённыеЛП.Видимость = Ложь;
			
		КонецЕсли;
	
		Если Товары_ТекущийЛП.Количество() > 0 Или ШтрихкодыУпаковок_ТекущийЛП.Количество() > 0 Тогда
			
			Элементы.ГруппаТекущийЛП.Видимость = Истина;
			
		Иначе
			
			Элементы.ГруппаТекущийЛП.Видимость = Ложь;
			
		КонецЕсли;
		
		Элементы.ИзменитьТипКороба.Доступность = ЗначениеЗаполнено(ТипКороба) И Не ИзменениеТипаКороба;
	
	Иначе
		
		Заголовок = "Формирование заказов FBS";
		
		Элементы.НадписьОтсканируйтеЗНБ.Видимость = Истина;		
		Элементы.ГруппаСтраницы.Видимость = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмитацияСканированияПриИзменении(Элемент)
	
	ВнешнееСобытие(Неопределено, "BarCodeValue", ИмитацияСканирования); 
	
	ИмитацияСканирования = "";

КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	
	Если Не ВводДоступен() Тогда 
		Возврат; 
	КонецЕсли;
	
	Если Не ЭтоСобытиеСканера(Событие) Тогда 
		Возврат; 
	КонецЕсли;
	
	Данные = СтрЗаменить(Данные, Символы.ПС, "");
	
	// Кухарь А.Ю.  27.03.2026 начало
	// Пустая задача
	Данные = СтрЗаменить(Данные, Символ(29), "");
	// Кухарь А.Ю.  27.03.2026 конец	
	
	ТекстОшибки = "";
	
	// Кельманов А.В. - SNL-233 - 2026.05.15 {
	Если ЗначениеЗаполнено(ОжидаемыйДляСканированияКодЛП) Тогда 
		
		Если Данные = ОжидаемыйДляСканированияКодЛП Тогда
			
			ОжидаемыйДляСканированияКодЛП = Неопределено;
			
			Сообщить("Этикетка онлайн отсканирована");
			
			Если ЗавершитьРаботуПоНакладнойПослеСканированияЭтикеткиОнлайн Тогда
				
				ЗавершитьРаботуПоНакладнойПослеСканированияЭтикеткиОнлайн = Ложь;
				
				Сообщить("Формирование заказов FBS по " + РНК + " завершено");
				
				РНК = Неопределено;
				
				ОбработатьИзменениеРНК();
				
			Иначе
				
				УстановитьВидимость();
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = "Отсканируйте распечатанную этикетку онлайн (QR код: " + ОжидаемыйДляСканированияКодЛП + ")";
			
			Сообщить(ТекстОшибки);
			
		КонецЕсли;
		
		ДопИнфо = "ЛП FBS - Сканирование этикетки онлайн";
		
		ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
		
		Возврат;
			
	КонецЕсли;
	// Кельманов А.В. - SNL-233 - 2026.05.15 }

	Если Не ЗначениеЗаполнено(РНК) Тогда
		
		ЗаданиеПоШК = глНайтиДокПоШК(Данные, ТекстОшибки);
		
		Если ТипЗнч(ЗаданиеПоШК) = Тип("ДокументСсылка.ЗаданиеНабора") Тогда
			
			РС_ДанныеПоШК = ЗаданиеПоШК;
			РС_НазначениеШК = ПредопределенноеЗначение("Справочник.НазначенияШК.Документ");
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЗаданиеПоШК) Или ТипЗнч(ЗаданиеПоШК) <> Тип("ДокументСсылка.ЗаданиеНабора") Тогда
			
			ТекстСообщения = "Не найдено задание по ШК";
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				
				ТекстОшибки = ТекстОшибки + Символы.ПС + ТекстСообщения;
				
			Иначе
				
				ТекстОшибки = ТекстСообщения;
				
			КонецЕсли;

			Сообщить(ТекстСообщения);
			
		Иначе
			
			РНК = ЗаданиеПоШК.Накладная;
			
			ОбработатьИзменениеРНК(ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				
				Сообщить(ТекстОшибки);
				
			КонецЕсли;
			
		КонецЕсли;
		
		ДопИнфо = "ЛП FBS - Получение накладной по коду ЗНБ";
		
		ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
		
		Возврат;
		
	КонецЕсли;
	
	Если (Не ЗначениеЗаполнено(ТекущийЛП) И Не ЗначениеЗаполнено(ТипКороба)) Или ИзменениеТипаКороба Тогда
		
		ОпределитьТипКороба(Данные, ТекстОшибки);
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			
			Сообщить(ТекстОшибки);
			
		Иначе
			
			ИзменениеТипаКороба = Ложь;
			
			УстановитьВидимость();
			
		КонецЕсли; 
		
		ДопИнфо = "ЛП FBS - Сканирование ШК коробки";
		
		ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
		
		Возврат;
			
	КонецЕсли;
			
	Если Не ЗначениеЗаполнено(ДатаНачалаСканирования) Тогда
		
		ДатаНачалаСканирования = ТекущаяДата();
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОжидаемыйДляСканированияКодЧЗ) Тогда
		
		Если ОтсканированОжидаемыйДляСканированияКодЧЗ(Данные, ТекстОшибки) Тогда
			
			ОтсканированныйОжидаемыйКодЧЗ = ОжидаемыйДляСканированияКодЧЗ;
			
			ОжидаемыйДляСканированияКодЧЗ = Неопределено;
			
			Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код заказа FBS";
			
		Иначе
			
			ТекстСообщения = "Отсканируйте код ЧЗ спайки: " + ОжидаемыйДляСканированияКодЧЗ;
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				
				ТекстОшибки = ТекстОшибки + Символы.ПС + ТекстСообщения;
				
			Иначе
				
				ТекстОшибки = ТекстСообщения;
				
			КонецЕсли;

			Сообщить(ТекстСообщения);
			
		КонецЕсли;
		
		ДопИнфо = "ЛП FBS - Сканирование кода ЧЗ спайки";
		
		ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
		
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ШтрихКодFBS) Или ЗначениеЗаполнено(НомерЗаказаFBS) Тогда
		
		ДопИнфо = "ЛП FBS - Сканирование кода заказа FBS";
		
		Если Данные = ШтрихКодFBS Или Данные = НомерЗаказаFBS Тогда
			
			ЗаписатьОтсканированныеДанные(ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				
				Сообщить(ТекстОшибки);
				
			Иначе
				
				ОбновитьДанныеПоТоварамТекущегоЛП();			
				ОчиститьТекущиеДанныеСканирования(Неопределено);
				
				Если ПроверитьВсёОтсканировано() Тогда
					
					ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
					
					ПечатьЭтикеткаОнлайн(Неопределено);
					
					// Кельманов А.В. - SNL-233 - 2026.05.15 {
					//Сообщить("Формирование заказов FBS по " + РНК + " завершено");
					//
					//РНК = Неопределено;
					//
					//ОбработатьИзменениеРНК();
					Если ЗначениеЗаполнено(ОжидаемыйДляСканированияКодЛП) Тогда
						
						ЗавершитьРаботуПоНакладнойПослеСканированияЭтикеткиОнлайн = Истина;
						
					Иначе
						
						Сообщить("Формирование заказов FBS по " + РНК + " завершено");
						
						РНК = Неопределено;
						
						ОбработатьИзменениеРНК();
						
					КонецЕсли;
					// Кельманов А.В. - SNL-233 - 2026.05.15 }
					
					Возврат;
					
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = "Отсканируйте код заказа FBS";
			
			Сообщить(ТекстОшибки);
			
		КонецЕсли;
		
		ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);
		
		Возврат;
		
	КонецЕсли;
	
	ОбработатьСканированиеШтукиКомплектующей(Данные, ТекстОшибки);
	
	РаспечататьЭтикетки(ТекстОшибки);
	
	Если ОтгрузкаКомплектов Тогда
		
		Если Данные = "8888888890003" Тогда
			
			ДопИнфо = "ЛП FBS - Сканирование кода завершения спайки";
			
		Иначе
			
			ДопИнфо = "ЛП FBS - Сканирование кода комплектующей";
			
		КонецЕсли;
		
	Иначе
		
		ДопИнфо = "ЛП FBS - Сканирование кода ЧЗ товара";
		
	КонецЕсли;
		
	ЗаписатьФактСканирования(Данные, ТекстОшибки, ДопИнфо);	
		
КонецПроцедуры

&НаСервере
Процедура ОбработатьСканированиеШтукиКомплектующей(Данные, ТекстОшибки = "")
	
	Если Не ЗначениеЗаполнено(ТекущийЛП) Тогда
		
		ЛПОбъект = Документы.ЛистПереукладки.СоздатьДокумент();
		
		ЛПОбъект.Заполнить(РНК);
		ЛПОбъект.Дата = ТекущаяДата();
		ЛПОбъект.ДатаНачалаСканирования = ДатаНачалаСканирования;
		ЛПОбъект.Сканировщик = Сканировщик;
		ЛПОбъект.СканировщикФизЛицо = Сканировщик.ФизЛицо;
		ЛПОбъект.ТипКороба = ТипКороба;
		
		// Кельманов А.В. - SNL-234 - 2026.05.15 {
		РезультатПоиска = Документы.ЛистПереукладки.НайтиЕдиныйЗНАПоРНК(РНК);
		
		Если РезультатПоиска.Успех Тогда
			
			ЛПОбъект.ЗаданиеНаАгрегацию = РезультатПоиска.Данные;
			
		КонецЕсли; 
		// Кельманов А.В. - SNL-234 - 2026.05.15 }
	
		ЛПОбъект.Бригада.Загрузить(ТекущаяБригада()); // Кельманов А.В. - SNL-246 - 2026.05.26
		
		ЛПОбъект.ДополнительныеСвойства.Вставить("ЗаписьИзОбработкиFBS", Истина);		
		ЛПОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		ТекущийЛП = ЛПОбъект.Ссылка;
		
		УстановитьВидимость();
			
	КонецЕсли;
	
	ДанныеМаркиЧЗ = Неопределено;
	
	Если ОтгрузкаКомплектов И Данные = "8888888890003" Тогда
		
		ДанныеЗаказаFBS = НайтиШКЗаказаПоЗапчастям(); 
		
		Если ДанныеЗаказаFBS <> Неопределено Тогда
			
			Если ТипЗнч(ДанныеЗаказаFBS) = Тип("Строка") Тогда
				
				ТекстОшибки = ДанныеЗаказаFBS;
				
				Сообщить(ТекстОшибки);
				
				Возврат;
				
			КонецЕсли;
			
			ШтрихКодFBS = ДанныеЗаказаFBS.ШтрихКодFBS;
			НомерЗаказаFBS = ДанныеЗаказаFBS.НомерЗаказаFBS;
			ПрефиксЗаказа = ДанныеЗаказаFBS.ПрефиксЗаказа;
			СуффиксЗаказа = ДанныеЗаказаFBS.СуффиксЗаказа;
			ТекШтукаСпайка = ДанныеЗаказаFBS.Продукция;
			
			ОжидаемыйДляСканированияКодЧЗ = ПолучитьКодЧЗСпайкиИзЗСБ(ТекШтукаСпайка, ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				
				Сообщить(ТекстОшибки);
				
				Возврат;
				
			КонецЕсли;
			
			Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код ЧЗ спайки: " + ОжидаемыйДляСканированияКодЧЗ;
			
		Иначе
			
			ТекстОшибки = "Заказ FBS по отсканированным комплектующим не найден. Проверьте, что в накладной есть спайка с отсканированным составом.";
			
			Сообщить(ТекстОшибки);
			
			Возврат;
			
		КонецЕсли;
			
	Иначе
		
		Номенклатура = НайтиТоварПоШтрихКоду(Данные, Перечисления.ТипыШтрихКодов.Штука, , ДанныеМаркиЧЗ, , , ТекстОшибки);
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			
			Возврат;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			
			РС_ДанныеПоШК = Номенклатура;
			РС_НазначениеШК = ПредопределенноеЗначение("Справочник.НазначенияШК.Товар");
			РС_ТипШК = Перечисления.ТипыШтрихКодов.Штука;
			
		КонецЕсли;
		
		ЭтоТовар = (ЗначениеРеквизитаОбъекта(Номенклатура.Родитель, "ВидНоменклатуры") = Перечисления.ВидыНоменклаутры.Товар);
		
		Если ДанныеМаркиЧЗ.СканировалиКодЧЗ 
			Или (ОтгрузкаКомплектов И Не ЭтоТовар) Тогда
			
			Если ДанныеМаркиЧЗ.СканировалиКодЧЗ Тогда
				
				МассСтрокЧЗ = ШтрихкодыУпаковок.НайтиСтроки(Новый Структура("ШтрихкодУпаковки", ДанныеМаркиЧЗ.МаркаЧЗ));
				
				Если МассСтрокЧЗ.Количество() = 0 Тогда
					
					Запрос = Новый Запрос; 
					
					Запрос.Текст = "ВЫБРАТЬ
					               |	ЛистПереукладки.Ссылка КАК Ссылка
					               |ИЗ
					               |	Документ.ЛистПереукладки КАК ЛистПереукладки
					               |ГДЕ
					               |	ЛистПереукладки.ДокОснование = &РНК
					               |	И ЛистПереукладки.ШтрихкодыУпаковок.ШтрихкодУпаковки = &ШтрихкодУпаковки
					               |	И ЛистПереукладки.Проведен";
					
					Запрос.УстановитьПараметр("РНК", РНК);
					Запрос.УстановитьПараметр("ШтрихкодУпаковки", ДанныеМаркиЧЗ.МаркаЧЗ);
					
					Выборка = Запрос.Выполнить().Выбрать();
					
					Если Выборка.Следующий() Тогда
						
						ТекстОшибки = "Код " + ДанныеМаркиЧЗ.МаркаЧЗ + " уже был ранее отсканирован в ЛП по данной накладной";
						
					КонецЕсли;
					
				Иначе
					
					ТекстОшибки = "Код " + ДанныеМаркиЧЗ.МаркаЧЗ + " уже был отсканирован ранее";
					
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					
					Сообщить(ТекстОшибки);
					
					Возврат;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если ОтгрузкаКомплектов Тогда
				
				МассСтрокНоменклатура = РНК.Комплектующие.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура)); 
				
			Иначе
				
				МассСтрокНоменклатура = РНК.Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура)); 
				
			КонецЕсли;
			
			Если МассСтрокНоменклатура.Количество() = 0 Тогда
				
				ТекстОшибки = "Номенклатуры " + Номенклатура + " нет в накладной";
				
				Сообщить(ТекстОшибки);
				
				Возврат;
				
			КонецЕсли;
			
			Запрос = Новый Запрос; 
			
			Запрос.Текст = "ВЫБРАТЬ
			               |	Товары.Номенклатура КАК Номенклатура,
			               |	Товары.Количество КАК Количество
			               |ПОМЕСТИТЬ ВТ_ТоварыТекущие
			               |ИЗ
			               |	&Товары КАК Товары
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	РасходнаяНакладнаяКомплектующие.Продукция КАК Продукция,
			               |	РасходнаяНакладнаяКомплектующие.Количество КАК КоличествоКомплектующего
			               |ПОМЕСТИТЬ ВТ_Продукция
			               |ИЗ
			               |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
			               |ГДЕ
			               |	РасходнаяНакладнаяКомплектующие.Ссылка = &РНК
			               |	И РасходнаяНакладнаяКомплектующие.Номенклатура = &Номенклатура
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ВТ_Продукция.Продукция КАК Продукция,
			               |	ВТ_Продукция.КоличествоКомплектующего КАК КоличествоКомплектующего,
			               |	СУММА(РасходнаяНакладнаяКомплектующие.КоличествоПродукции) КАК КоличествоПродукции
			               |ПОМЕСТИТЬ ВТ_КоличествоПродукции
			               |ИЗ
			               |	ВТ_Продукция КАК ВТ_Продукция
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
			               |		ПО ВТ_Продукция.Продукция = РасходнаяНакладнаяКомплектующие.Продукция
			               |ГДЕ
			               |	РасходнаяНакладнаяКомплектующие.Ссылка = &РНК
			               |
			               |СГРУППИРОВАТЬ ПО
			               |	ВТ_Продукция.Продукция,
			               |	ВТ_Продукция.КоличествоКомплектующего
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ВТ_ТоварыТекущие.Количество КАК Количество
			               |ПОМЕСТИТЬ ВТ_КоличествоОтсканировано
			               |ИЗ
			               |	ВТ_ТоварыТекущие КАК ВТ_ТоварыТекущие
			               |ГДЕ
			               |	ВТ_ТоварыТекущие.Номенклатура = &Номенклатура
			               |
			               |ОБЪЕДИНИТЬ ВСЕ
			               |
			               |ВЫБРАТЬ
			               |	ЛистПереукладкиТовары.Количество
			               |ИЗ
			               |	Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
			               |ГДЕ
			               |	ЛистПереукладкиТовары.Ссылка.ДокОснование = &РНК
			               |	И ЛистПереукладкиТовары.Номенклатура = &Номенклатура
			               |	И ЛистПереукладкиТовары.Ссылка.Проведен
			               |
			               |ОБЪЕДИНИТЬ ВСЕ
			               |
			               |ВЫБРАТЬ
			               |	ВТ_КоличествоПродукции.КоличествоКомплектующего * ЛистПереукладкиТовары.Количество / ВТ_КоличествоПродукции.КоличествоПродукции
			               |ИЗ
			               |	Документ.ЛистПереукладки.Товары КАК ЛистПереукладкиТовары
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КоличествоПродукции КАК ВТ_КоличествоПродукции
			               |		ПО ЛистПереукладкиТовары.Номенклатура = ВТ_КоличествоПродукции.Продукция
			               |ГДЕ
			               |	ЛистПереукладкиТовары.Ссылка.ДокОснование = &РНК
			               |	И ЛистПереукладкиТовары.Ссылка.Проведен
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	СУММА(ВТ_КоличествоОтсканировано.Количество) КАК Количество
			               |ПОМЕСТИТЬ ВТ_КоличествоОтсканированоСумма
			               |ИЗ
			               |	ВТ_КоличествоОтсканировано КАК ВТ_КоличествоОтсканировано
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	РасходнаяНакладнаяТовары.Количество КАК Количество
			               |ПОМЕСТИТЬ ВТ_КоличествоНакладная
			               |ИЗ
			               |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
			               |ГДЕ
			               |	РасходнаяНакладнаяТовары.Ссылка = &РНК
			               |	И РасходнаяНакладнаяТовары.Номенклатура = &Номенклатура
			               |
			               |ОБЪЕДИНИТЬ ВСЕ
			               |
			               |ВЫБРАТЬ
			               |	РасходнаяНакладнаяКомплектующие.Количество
			               |ИЗ
			               |	Документ.РасходнаяНакладная.Комплектующие КАК РасходнаяНакладнаяКомплектующие
			               |ГДЕ
			               |	РасходнаяНакладнаяКомплектующие.Ссылка = &РНК
			               |	И РасходнаяНакладнаяКомплектующие.Номенклатура = &Номенклатура
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	СУММА(ВТ_КоличествоНакладная.Количество) КАК Количество
			               |ПОМЕСТИТЬ ВТ_КоличествоНакладнаяСумма
			               |ИЗ
			               |	ВТ_КоличествоНакладная КАК ВТ_КоличествоНакладная
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ВТ_КоличествоНакладнаяСумма.Количество КАК КоличествоНакладная,
			               |	ВТ_КоличествоОтсканированоСумма.Количество КАК КоличествоОтсканировано
			               |ИЗ
			               |	ВТ_КоличествоОтсканированоСумма КАК ВТ_КоличествоОтсканированоСумма
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КоличествоНакладнаяСумма КАК ВТ_КоличествоНакладнаяСумма
			               |		ПО (ВТ_КоличествоНакладнаяСумма.Количество = ВТ_КоличествоОтсканированоСумма.Количество)";
			
			Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());
			Запрос.УстановитьПараметр("РНК", РНК);
			Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				
				ТекстОшибки = "Номенклатуры " + Номенклатура + " уже отсканировано достаточное количество. Положите отсканированную единицу обратно.";
				
				Сообщить(ТекстОшибки);
				
				Возврат;
				
			КонецЕсли;
			
			МассСтрокОтсканировано = Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
			
			Если МассСтрокОтсканировано.Количество() = 0 Тогда
				
				НовСтрТовары = Товары.Добавить();
				
				НовСтрТовары.Номенклатура = Номенклатура;
				НовСтрТовары.Количество = 1;
				
			Иначе
				
				СтрТовары = МассСтрокОтсканировано[0];
				
				СтрТовары.Количество = СтрТовары.Количество + 1;
				
			КонецЕсли;
			
			Если ДанныеМаркиЧЗ.СканировалиКодЧЗ Тогда
				
				НовСтрЧЗ = ШтрихкодыУпаковок.Добавить();
				
				НовСтрЧЗ.ШтрихкодУпаковки = ДанныеМаркиЧЗ.МаркаЧЗ;
				
			КонецЕсли;
			
			// Кельманов А.В. - Изменение 0000000063 - 2026.07.09 {
			Если ОтгрузкаКомплектов И Не ЭтоТовар Тогда
				
				ДанныеЗаказаFBS = НайтиШКЗаказаПоЗапчастям(); 
				
				Если ДанныеЗаказаFBS <> Неопределено Тогда
					
					Если ТипЗнч(ДанныеЗаказаFBS) = Тип("Строка") Тогда
						
						ТекстОшибки = ДанныеЗаказаFBS;
						
						Сообщить(ТекстОшибки);
						
						Возврат;
						
					КонецЕсли;
					
					ШтрихКодFBS = ДанныеЗаказаFBS.ШтрихКодFBS;
					НомерЗаказаFBS = ДанныеЗаказаFBS.НомерЗаказаFBS;
					ПрефиксЗаказа = ДанныеЗаказаFBS.ПрефиксЗаказа;
					СуффиксЗаказа = ДанныеЗаказаFBS.СуффиксЗаказа;
					ТекШтукаСпайка = ДанныеЗаказаFBS.Продукция;
					
					ОжидаемыйДляСканированияКодЧЗ = ПолучитьКодЧЗСпайкиИзЗСБ(ТекШтукаСпайка, ТекстОшибки);
					
					Если ЗначениеЗаполнено(ТекстОшибки) Тогда
						
						Сообщить(ТекстОшибки);
						
						Возврат;
						
					КонецЕсли;
					
					Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код ЧЗ спайки: " + ОжидаемыйДляСканированияКодЧЗ;
					
				Иначе
					
					//ТекстОшибки = "Заказ FBS по отсканированным комплектующим не найден. Проверьте, что в накладной есть спайка с отсканированным составом.";
					//
					//Сообщить(ТекстОшибки);
					//
					//Возврат;
					
				КонецЕсли;
				
			КонецЕсли;
			// Кельманов А.В. - Изменение 0000000063 - 2026.07.09 }
			
		Иначе
			
			Если ОтгрузкаКомплектов Тогда
				
				ТекстОшибки = "Отсканируйте код ЧЗ комплектующей или штрихкод упаковки";
				
			Иначе
				
				ТекстОшибки = "Отсканируйте код ЧЗ штуки товара";
				
			КонецЕсли;
			
			Сообщить(ТекстОшибки);
			
			Возврат;
			
		КонецЕсли;
		
		Если Не ОтгрузкаКомплектов Тогда
			
			ДанныеЗаказаFBS = НайтиШКЗаказаПоЗапчастям(); 
			
			Если ДанныеЗаказаFBS <> Неопределено Тогда
				
				Если ТипЗнч(ДанныеЗаказаFBS) = Тип("Строка") Тогда
					
					ТекстОшибки = ДанныеЗаказаFBS;
					
					Сообщить(ТекстОшибки);
					
					Возврат;
					
				КонецЕсли;
				
				ШтрихКодFBS = ДанныеЗаказаFBS.ШтрихКодFBS;
				НомерЗаказаFBS = ДанныеЗаказаFBS.НомерЗаказаFBS;
				ПрефиксЗаказа = ДанныеЗаказаFBS.ПрефиксЗаказа;
				СуффиксЗаказа = ДанныеЗаказаFBS.СуффиксЗаказа;
				ТекШтукаСпайка = ДанныеЗаказаFBS.Продукция;
				
				Элементы.НадписьОтсканируйте.Заголовок = "Отсканируйте код заказа FBS";
				
			Иначе
				
				ТекстОшибки = "Заказ FBS для отсканированного товара не найден";
				
				Сообщить(ТекстОшибки);
				
				Возврат;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
					
КонецПроцедуры

&НаСервере
Функция ОтсканированОжидаемыйДляСканированияКодЧЗ(Данные, ТекстОшибки = "")
	
	ДанныеМаркиЧЗ = Неопределено;
	
	Номенклатура = НайтиТоварПоШтрихКоду(Данные, Перечисления.ТипыШтрихКодов.Штука, , ДанныеМаркиЧЗ, , , ТекстОшибки);

	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		
		РС_ДанныеПоШК = Номенклатура;
		РС_НазначениеШК = ПредопределенноеЗначение("Справочник.НазначенияШК.Товар");
		РС_ТипШК = Перечисления.ТипыШтрихКодов.Штука;
		
	КонецЕсли;
			
	Если ДанныеМаркиЧЗ.СканировалиКодЧЗ И ДанныеМаркиЧЗ.МаркаЧЗ = ОжидаемыйДляСканированияКодЧЗ Тогда
		
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ОпределитьТипКороба(Данные, ТекстОшибки = "")
	
	ТипКороба = Справочники.ТипыКоробов.НайтиПоРеквизиту("ШтрихКод", Данные);			 
	
	Если ТипКороба.Пустая() Тогда
		
		ТекстОшибки = "Не найден тип короба с штрих-кодом: """ + Данные + """ !";
		
	Иначе
		
		РС_ДанныеПоШК = ТипКороба;
		РС_НазначениеШК = ПредопределенноеЗначение("Справочник.НазначенияШК.ТипКороба");
		
		Если ИзменениеТипаКороба И ЗначениеЗаполнено(ТекущийЛП) Тогда
						
			ЛПОбъект = ТекущийЛП.ПолучитьОбъект();			
			ЛПОбъект.ТипКороба = ТипКороба;
			ЛПОбъект.ДополнительныеСвойства.Вставить("ЗаписьИзОбработкиFBS", Истина);			
			ЛПОбъект.Записать(РежимЗаписиДокумента.Запись);
	
		КонецЕсли;
					
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьЛП(Команда)
	
	Если Товары.Количество() > 0 Или ШтрихкодыУпаковок.Количество() > 0 Тогда
		
		Сообщить("Сначала закончите работу с текущим ЛП."); 
		
		Возврат;
		
	КонецЕсли;
	
	Ошибки = "";
	
	АктивироватьЛПНаСервере(Ошибки);
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		
		Сообщить(Ошибки);
		
		Возврат;
		
	КонецЕсли;
	
	УстановитьВидимость();

КонецПроцедуры

&НаСервере
Процедура АктивироватьЛПНаСервере(Ошибки)

	МассСтрок = ЛистыПереукладки.НайтиСтроки(Новый Структура("Выбрать", Истина));	
	
	Если МассСтрок.Количество() <> 1 Тогда
		
		Ошибки = "Нужно выделить 1 ЛП";
		
		Возврат;
		
	КонецЕсли;
	
	ТекущийЛП = МассСтрок[0].ЛП;
	
	ТипКороба = ТекущийЛП.ТипКороба;
	
	МассСтрок[0].Выбрать = Ложь;
	
	ОбновитьДанныеПоТоварамТекущегоЛП();
	
	ТаблицаДанныхМатрицы = Неопределено;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоТоварамТекущегоЛП()
	
	Товары_ТекущийЛП.Очистить();
	ШтрихкодыУпаковок_ТекущийЛП.Очистить();
	
	Товары_ТекущийЛП.Загрузить(ТекущийЛП.Товары.Выгрузить());
	ШтрихкодыУпаковок_ТекущийЛП.Загрузить(ТекущийЛП.ШтрихкодыУпаковок.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТекущиеДанныеСканирования(Команда)
	
	Товары.Очистить();
	ШтрихкодыУпаковок.Очистить();
	
	ОжидаемыйДляСканированияКодЧЗ = Неопределено; 
	ОтсканированныйОжидаемыйКодЧЗ = Неопределено; 
	
	ШтрихКодFBS = Неопределено;
	НомерЗаказаFBS = Неопределено;
	ПрефиксЗаказа = Неопределено;
	СуффиксЗаказа = Неопределено;
	ТекШтукаСпайка = Неопределено;
						
	Если Не ЗначениеЗаполнено(ТекущийЛП) И ЗначениеЗаполнено(ТипКороба) Тогда
		
		ТипКороба = Неопределено;
			
	КонецЕсли;
			
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
Функция НайтиШКЗаказаПоЗапчастям()
	
	СтруктураВозврата = Новый Структура("ШтрихКодFBS, НомерЗаказаFBS, ПрефиксЗаказа, СуффиксЗаказа, Продукция");
	
	ТЗ = Товары.Выгрузить();

	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЛистПереукладкиШтрихкодыУпаковок.НомерЗаказа КАК НомерЗаказаFBS
	               |ИЗ
	               |	Документ.ЛистПереукладки.ШтрихкодыУпаковок КАК ЛистПереукладкиШтрихкодыУпаковок
	               |ГДЕ
	               |	ЛистПереукладкиШтрихкодыУпаковок.Ссылка.ДокОснование = &РНК
	               |	И ЛистПереукладкиШтрихкодыУпаковок.Ссылка.Проведен";

	Запрос.УстановитьПараметр("РНК", РНК);
	
	МассивНомеровЗаказаFBS = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("НомерЗаказаFBS");	

	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS КАК НомерЗаказаFBS
	               |ПОМЕСТИТЬ ВТ_ШКFBSСОтсканированнойНоменклатурой
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Комплектующие КАК ПолныеДанныеЗаданияНабораКомплектующие
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Накладная = &РНК
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Проведен
	               |	И НЕ ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS В (&МассивНомеровЗаказа)
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Номенклатура В(&Номенклатура)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Номенклатура КАК Номенклатура,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Продукция КАК Продукция,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS КАК НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.ПрефиксЗаказа КАК ПрефиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.СуффиксЗаказа КАК СуффиксЗаказа,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Количество КАК Количество
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Комплектующие КАК ПолныеДанныеЗаданияНабораКомплектующие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ШКFBSСОтсканированнойНоменклатурой КАК ВТ_ШКFBSСОтсканированнойНоменклатурой
	               |		ПО ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS = ВТ_ШКFBSСОтсканированнойНоменклатурой.ШтрихКодFBS
	               |			И ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS = ВТ_ШКFBSСОтсканированнойНоменклатурой.НомерЗаказаFBS
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Накладная = &РНК
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Проведен
	               |ИТОГИ ПО
	               |	ШтрихКодFBS,
	               |	НомерЗаказаFBS";
	
	Запрос.УстановитьПараметр("МассивНомеровЗаказа", МассивНомеровЗаказаFBS); 
	Запрос.УстановитьПараметр("Номенклатура", ТЗ.ВыгрузитьКолонку("Номенклатура"));
	
	ВыборкаШтрихКодFBS = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихКодFBS");

	Пока ВыборкаШтрихКодFBS.Следующий() Цикл
		
		ВыборкаНомерЗаказаFBS = ВыборкаШтрихКодFBS.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерЗаказаFBS");
		
		Пока ВыборкаНомерЗаказаFBS.Следующий() Цикл
			
			Выборка = ВыборкаНомерЗаказаFBS.Выбрать();

			ОбщееКоличество = ТЗ.Итог("Количество");
			КоличествоВЗаказе = 0;
			Продукция = Неопределено;
			ТекПрефиксЗаказа = Неопределено;
			ТекСуффиксЗаказа = Неопределено;
			
			ЗаказНашёлся = Истина;
			
			Пока Выборка.Следующий() Цикл
				
				КоличествоВЗаказе = КоличествоВЗаказе + Выборка.Количество;
				Продукция = Выборка.Продукция;
				ТекПрефиксЗаказа = Выборка.ПрефиксЗаказа;
				ТекСуффиксЗаказа = Выборка.СуффиксЗаказа;
				
				СтрТЗ = ТЗ.Найти(Выборка.Номенклатура);
				
				Если СтрТЗ = Неопределено Тогда
					
					ЗаказНашёлся = Ложь;
					
					Прервать;
					
				КонецЕсли;
				
				Если СтрТЗ.Количество <> Выборка.Количество Тогда
					
					ЗаказНашёлся = Ложь;
					
					Прервать;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ОбщееКоличество = КоличествоВЗаказе И ЗаказНашёлся Тогда

				ЗаполнитьЗначенияСвойств(СтруктураВозврата, ВыборкаНомерЗаказаFBS);
				СтруктураВозврата.Продукция = Продукция;
				СтруктураВозврата.ПрефиксЗаказа = ТекПрефиксЗаказа;
				СтруктураВозврата.СуффиксЗаказа = ТекСуффиксЗаказа;
				
				Возврат СтруктураВозврата;

			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;	
	
	РанееОтсканированныйНомер = ПроверитьСуществующиеЗаказы(МассивНомеровЗаказаFBS, ТЗ); 

	Если РанееОтсканированныйНомер <> Неопределено Тогда
		
		ТекстСообщения = "Все заказы FBS по данной номенклатуре уже отсканированы!";
		
		Если ОтгрузкаКомплектов Тогда
			
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "номенклатуре", "спайке");
			
		КонецЕсли;
		
		Возврат ТекстСообщения;
		
	КонецЕсли;
	 
	Возврат РанееОтсканированныйНомер;
	
КонецФункции

&НаСервере
Функция ПроверитьСуществующиеЗаказы(МассивНомеровЗаказаFBS, ТЗ); 
	
	СтруктураВозврата = Новый Структура("ШтрихКодFBS, НомерЗаказаFBS");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS КАК НомерЗаказаFBS
	               |ПОМЕСТИТЬ ВТ_ШКFBSСОтсканированнойНоменклатурой
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Комплектующие КАК ПолныеДанныеЗаданияНабораКомплектующие
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Накладная = &РНК
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Проведен
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS В(&МассивНомеровЗаказа)
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Номенклатура В(&Номенклатура)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Номенклатура КАК Номенклатура,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS КАК ШтрихКодFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS КАК НомерЗаказаFBS,
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Количество КАК Количество
	               |ИЗ
	               |	Документ.ПолныеДанныеЗаданияНабора.Комплектующие КАК ПолныеДанныеЗаданияНабораКомплектующие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ШКFBSСОтсканированнойНоменклатурой КАК ВТ_ШКFBSСОтсканированнойНоменклатурой
	               |		ПО ПолныеДанныеЗаданияНабораКомплектующие.ШтрихКодFBS = ВТ_ШКFBSСОтсканированнойНоменклатурой.ШтрихКодFBS
	               |			И ПолныеДанныеЗаданияНабораКомплектующие.НомерЗаказаFBS = ВТ_ШКFBSСОтсканированнойНоменклатурой.НомерЗаказаFBS
	               |ГДЕ
	               |	ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Накладная = &РНК
	               |	И ПолныеДанныеЗаданияНабораКомплектующие.Ссылка.Проведен
	               |ИТОГИ ПО
	               |	ШтрихКодFBS,
	               |	НомерЗаказаFBS";
	
	Запрос.УстановитьПараметр("РНК", РНК);
	Запрос.УстановитьПараметр("МассивНомеровЗаказа", МассивНомеровЗаказаFBS); 
	Запрос.УстановитьПараметр("Номенклатура", ТЗ.ВыгрузитьКолонку("Номенклатура"));	
	
	ВыборкаШтрихКодFBS = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихКодFBS");

	Пока ВыборкаШтрихКодFBS.Следующий() Цикл
		
		ВыборкаНомерЗаказаFBS = ВыборкаШтрихКодFBS.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерЗаказаFBS");
		
		Пока ВыборкаНомерЗаказаFBS.Следующий() Цикл
			
			Выборка = ВыборкаНомерЗаказаFBS.Выбрать();
			
			ОбщееКоличество = ТЗ.Итог("Количество");
			
			КоличествоВЗаказе = 0;
			
			ЗаказНашёлся = Истина; 
			
			Пока Выборка.Следующий() Цикл
				
				КоличествоВЗаказе = КоличествоВЗаказе + Выборка.Количество;
				
				СтрТЗ = ТЗ.Найти(Выборка.Номенклатура);
				
				Если СтрТЗ = Неопределено Тогда
					
					ЗаказНашёлся = Ложь;
					
					Прервать;
					
				КонецЕсли;
				
				Если СтрТЗ.Количество <> Выборка.Количество Тогда
					
					ЗаказНашёлся = Ложь;
					
					Прервать;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ОбщееКоличество = КоличествоВЗаказе И ЗаказНашёлся Тогда

				ЗаполнитьЗначенияСвойств(СтруктураВозврата, ВыборкаНомерЗаказаFBS);
				
				Возврат СтруктураВозврата;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;	
	
	Возврат Неопределено;
	
