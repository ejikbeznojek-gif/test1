	Выб = Запр.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		НовСтр = ТЗДок.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Выб);
	КонецЦикла;	
КонецПроцедуры

