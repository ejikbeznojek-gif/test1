
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	//Вставить содержимое обработчика  
	Если НЕ ЗначениеЗаполнено(Объект.ДокОбъект) Тогда
		ВызватьИсключение("Обработка может быть открыта только из Списка документов!");
	КонецЕсли;
	Если ПоХКМЗНВ(Объект.ДокОбъект) Тогда
			
		Элементы.Группа6.ТекущаяСтраница = Элементы.Группа7; 
		Элементы.Группа8.Видимость = Ложь; 
		ОбновитьНаСервере1();
		//Элементы.Группа1.ТекущаяСтраница = Элементы.Группа2;
		//ОбновитьНаСервере();
	Иначе
		Элементы.Группа7.Видимость = Ложь;
		Элементы.Группа6.ТекущаяСтраница = Элементы.Группа8;
		Элементы.Группа1.ТекущаяСтраница = Элементы.Группа2;
		ОбновитьНаСервере();
	КонецЕсли;	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоХКМЗНВ(ЗНВ)
	Рез = Ложь;  
	Запр = Новый Запрос;
	Запр.Текст = 
	"ВЫБРАТЬ
	|	ХранилищеКодовМаркировки.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
	|ГДЕ
	|	ХранилищеКодовМаркировки.ДокОснование = &ЗНВ";
	Запр.УстановитьПараметр("ЗНВ", ЗНВ);
	Выб = Запр.Выполнить().Выбрать();
	Если Выб.Следующий() Тогда
		Рез = Истина;
	КонецЕсли;	
	Возврат Рез;
КонецФункции	

&НаСервере
