&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьНаСервере();
КонецПроцедуры

&НаСервере
Функция СкорректироватьРаспределениеНаСервере()
	// Вставить содержимое обработчика.
	ОтветС = Новый Структура ("Мод, Сооб", Ложь, "Распределение не выполнено");	
	//ОтветС = "Распределение выполнено";
	ТЗРКМ = ТЗДок.Выгрузить();
	ТЗРКМ.Свернуть("РКМ");
	Для Каждого ТСтр Из ТЗРКМ Цикл
		Если ЗначениеЗаполнено(ТСтр.РКМ) Тогда
			ОтветС.Сооб = "Уже есть привязанные РКМ, распределение невозможно";
			Возврат ОтветС;
		КонецЕсли;	
	КонецЦикла;
	ДокВ = Объект.ДокОбъект.ПолучитьОбъект();
	Для Каждого ТТов Из ДокВ.Товары Цикл
		НПП = ТТов.НомерСтроки;
		Найды = ТЗДок.НайтиСтроки(Новый Структура("НПП", НПП));
		
		Если Найды.Количество() Тогда
			Если НЕ ТТов.ДокументОтгрузки = Найды[0].РНК ИЛИ НЕ ЗначениеЗаполнено(Найды[0].РНКПодобран) Тогда
				ОтветС.Мод = Истина;
				ТТов.ДокументОтгрузки = Найды[0].РНК;
				ТТов.Цена = Найды[0].ЦенаРНК;
				ТТов.Всего = ТТов.Цена * ТТов.Количество;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	ОтветС.Сооб = "Распределение выполнено";
	ДокВ.Записать();
	Возврат ОтветС;
КонецФункции

&НаКлиенте
Процедура СкорректироватьРаспределение(Команда)
	Элементы.Группа1.ТекущаяСтраница = Элементы.Группа2;
	Отв = СкорректироватьРаспределениеНаСервере();
	Если Отв.Мод = Истина Тогда
		ОбновитьНаСервере();
	КонецЕсли;	
	ПоказатьПредупреждение(, Отв.Сооб, 20);
КонецПроцедуры

&НаСервере
Процедура СоздатьРекламацииНаСервере()
	// Вставить содержимое обработчика.  
	ДатаЗНВ = Объект.ДокОбъект.Дата;
	ТЗДок1.Очистить();
	РНКРКМ.Очистить();
	Запр = Новый Запрос;
	Запр.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура КАК Номенклатура,
	|	ЗаявкаНаВозвратОтПокупателяТовары.Количество КАК КолвоВозврат,
	|	ЕСТЬNULL(ХранилищеКодовМаркировкиТовары.Ссылка, ЗНАЧЕНИЕ(Документ.ХранилищеКодовМаркировки.ПустаяСсылка)) КАК ХКМ,
	|	ЕСТЬNULL(ХранилищеКодовМаркировкиТовары1.Ссылка, ЗНАЧЕНИЕ(Документ.ХранилищеКодовМаркировки.ПустаяСсылка)) КАК ХКМ1,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Количество, 0) КАК КолвоРНК,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Цена, 0) КАК ЦенаРНК,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Ссылка, ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)) КАК РНК,
	|	ЕСТЬNULL(ПриходнаяНакладнаяТовары.Ссылка, ЗНАЧЕНИЕ(Документ.ПриходнаяНакладная.ПустаяСсылка)) КАК ПНК,
	|	ЕСТЬNULL(ПриходнаяНакладнаяТовары.Количество, 0) КАК КолвоПНК,
	|	ЕСТЬNULL(РекламационнаяНакладнаяТовары.Ссылка, ЗНАЧЕНИЕ(Документ.РекламационнаяНакладная.ПустаяСсылка)) КАК РКМ,
	|	ЕСТЬNULL(РекламационнаяНакладнаяТовары.Ссылка.ДокументВозврата, ЗНАЧЕНИЕ(Документ.ПриходнаяНакладная.ПустаяСсылка)) КАК РКМ_ПНК,
	|	ЕСТЬNULL(РекламационнаяНакладнаяТовары.Количество, 0) КАК КолвоРКМ,
	|	ЗаявкаНаВозвратОтПокупателяТовары.НомерСтроки КАК НПП,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Единица, ЗНАЧЕНИЕ(Справочник.Единицы.ПустаяССылка)) КАК Единица,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Цена, 0) КАК Цена,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.ЦенаБезСкидки, 0) КАК ЦенаБезСкидки,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Коэффициент, 1) КАК Коэффициент,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.Объем, 0) КАК Объем,
	|	ЕСТЬNULL(РасходнаяНакладнаяТовары.СтавкаНДС, ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС20)) КАК СтавкаНДС
	|ИЗ
	|	Документ.ЗаявкаНаВозвратОтПокупателя.Товары КАК ЗаявкаНаВозвратОтПокупателяТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|		ПО (РасходнаяНакладнаяТовары.Ссылка = ЗаявкаНаВозвратОтПокупателяТовары.ДокументОтгрузки)
	|			И ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура = РасходнаяНакладнаяТовары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	|		ПО (ПриходнаяНакладнаяТовары.Ссылка.ДокОснование = &Ссылка)
	|			И ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура = ПриходнаяНакладнаяТовары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки.Товары КАК ХранилищеКодовМаркировкиТовары
	|		ПО ЗаявкаНаВозвратОтПокупателяТовары.ДокументОтгрузки = ХранилищеКодовМаркировкиТовары.Ссылка.ДокОснование
	|			И ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура = ХранилищеКодовМаркировкиТовары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки.Товары КАК ХранилищеКодовМаркировкиТовары1
	|		ПО (ПриходнаяНакладнаяТовары.Ссылка = ХранилищеКодовМаркировкиТовары1.Ссылка.ДокОснование)
	|			И (ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура = ХранилищеКодовМаркировкиТовары.Номенклатура)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РекламационнаяНакладная.Товары КАК РекламационнаяНакладнаяТовары
	|		ПО ЗаявкаНаВозвратОтПокупателяТовары.ДокументОтгрузки.Ссылка = РекламационнаяНакладнаяТовары.Ссылка.ДокОснование
	|			И ЗаявкаНаВозвратОтПокупателяТовары.Номенклатура = РекламационнаяНакладнаяТовары.Номенклатура
	|ГДЕ
	|	ЗаявкаНаВозвратОтПокупателяТовары.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаявкаНаВозвратОтПокупателяТовары.НомерСтроки";
	Запр.УстановитьПараметр("Ссылка", Объект.ДокОбъект);
	//Запр.УстановитьПараметр("ДатаНач", ДатаНач);
	//Запр.УстановитьПараметр("ДатаКон", ДатаКон);
	Выб = Запр.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		НовСтр = ТЗДок1.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Выб);
	КонецЦикла; 
	ТЗС = ТЗДок1.Выгрузить();
	ТЗС.Свернуть("РНК"); 
	ТЗС1 = ТЗДок1.Выгрузить();
	ТЗС1.Свернуть("ПНК, РНК"); 
	ТЗС2 = ТЗДок1.Выгрузить();
	ТЗС2.Свернуть("РНК, РКМ"); 
	СоотДок = Новый Соответствие;
	
	Для Каждого ТекСтр Из ТЗС Цикл
		
			
		НовСтр = РНКРКМ.Добавить();
		НовСтр.РНК = ТекСтр.РНК;
		Найды1 = ТЗС2.НайтиСтроки(Новый Структура("РНК", НовСтр.РНК));
		ТекРКМ = Неопределено;
		Для Каждого Найд1 Из Найды1 Цикл
			Если ЗначениеЗаполнено(Найд1.РКМ) Тогда
				ТекРКМ = Найд1.РКМ;
				НовСтр.РКМ = ТекРКМ;
			КонецЕсли;	
		КонецЦикла;	
		Если ТекРКМ = Неопределено Тогда
			ДокРКМ = Документы.РекламационнаяНакладная.СоздатьДокумент();
			ДокРКМ.ИБ = ПолучитьИБПоУмолчанию(); 
			Найды = ТЗС1.НайтиСтроки(Новый Структура("РНК", НовСтр.РНК));
			ТД = ТекущаяДатаСеанса();
			Если Найды.Количество() Тогда 
				Если Месяц(Найды[0].ПНК.Дата) = Месяц(ТД) Тогда
					ДокРКМ.Дата = Найды[0].ПНК.Дата;
				Иначе
    				ДокРКМ.Дата = ТекущаяДатаСеанса();
				КонецЕсли;
			Иначе
				ДокРКМ.Дата = ТекущаяДатаСеанса();
			КонецЕсли;
			ДокРКМ.ДокОснование = ТекСтр.РНК;
			ДокРКМ.Валюта = ТекСтр.РНК.Валюта;
			РКМОбработкаЗаполнения(ТекСтр.РНК, ДокРКМ);
			ДокРКМ.ВидРекламации = Перечисления.ВидыРекламаций.Возврат;
			ДокРКМ.ЗаявкаНаВозвратОтПокупателя = Объект.ДокОбъект.Ссылка;
			УстановитьНомерДокументаКлиентСервер(ДокРКМ);
			ДокРКМ.Записать();
			НовСтр.РКМ = ДокРКМ.Ссылка; 
			НовСтр.НовыйРКМ = Истина;
		КонецЕсли;
		СоотДок.Вставить(НовСтр.РНК, НовСтр.РКМ);
	КонецЦикла; 
	Для Каждого КлЗ Из СоотДок Цикл
		ТРНК = КлЗ.Ключ;
		ТРКМ = КлЗ.Значение;  
		ДокРКМ = ТРКМ.ПолучитьОбъект();
		Если 1=2 Тогда
			ДокРКМ = Документы.РекламационнаяНакладная.СоздатьДокумент();
		КонецЕсли;
		Найды = ТЗДок1.НайтиСтроки(Новый Структура("РНК", ТРНК));
		Если Найды.Количество() Тогда
