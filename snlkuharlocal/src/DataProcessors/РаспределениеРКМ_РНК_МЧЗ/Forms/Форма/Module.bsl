	МРНК = ТЗС1.ВыгрузитьКолонку("РНК");
	Запр = Новый Запрос;
	Запр.Текст =
	"ВЫБРАТЬ
	|	РасходнаяНакладнаяТовары.Ссылка КАК Ссылка,
	|	РасходнаяНакладнаяТовары.НомерСтроки КАК НомерСтроки,
	|	РасходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	|	РасходнаяНакладнаяТовары.Количество КАК Количество,
	|	РасходнаяНакладнаяТовары.Единица КАК Единица,
	|	РасходнаяНакладнаяТовары.Коэффициент КАК Коэффициент,
	|	РасходнаяНакладнаяТовары.ЦенаБезСкидки КАК ЦенаБезСкидки,
	|	РасходнаяНакладнаяТовары.Цена КАК Цена,
	|	РасходнаяНакладнаяТовары.Сумма КАК Сумма,
	|	РасходнаяНакладнаяТовары.Объем КАК Объем,
	|	РасходнаяНакладнаяТовары.СтавкаНДС КАК СтавкаНДС,
	|	РасходнаяНакладнаяТовары.НДС КАК НДС,
	|	РасходнаяНакладнаяТовары.Всего КАК Всего,
	|	РасходнаяНакладнаяТовары.ВсегоБезСкидки КАК ВсегоБезСкидки,
	|	РасходнаяНакладнаяТовары.Скидка КАК Скидка,
	|	РасходнаяНакладнаяТовары.ПодтвержденнаяЗаявка КАК ПодтвержденнаяЗаявка,
	|	РасходнаяНакладнаяТовары.Заявка КАК Заявка,
	|	РасходнаяНакладнаяТовары.ТипЦен КАК ТипЦен,
	|	РасходнаяНакладнаяТовары.ЦенаПосредника КАК ЦенаПосредника,
	|	РасходнаяНакладнаяТовары.ЦенаБезБонуса КАК ЦенаБезБонуса,
	|	РасходнаяНакладнаяТовары.ВсегоБезБонуса КАК ВсегоБезБонуса,
	|	РасходнаяНакладнаяТовары.Акция КАК Акция,
	|	РасходнаяНакладнаяТовары.КоличествоКомплектующих КАК КоличествоКомплектующих,
	|	РасходнаяНакладнаяТовары.ТребуетсяМаркировка КАК ТребуетсяМаркировка
	|ИЗ
	|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	|ГДЕ
