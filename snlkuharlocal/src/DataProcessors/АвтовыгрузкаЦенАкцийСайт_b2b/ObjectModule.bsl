Процедура ЗагрузитьСогласиеПромоАкции() Экспорт
	
	возврат; //10,07,23
	СтруктураПараметровСайта = ПроцедурыОбменаССайтом.ПолучитьСтруктуруПараметровДляСоединения(ЭтотОбъект);
	ИмяПутиОтвета = КомандаЗагрузкиСогласиеПромо(СтруктураПараметровСайта);
	
	
	///------------------------------------------------------------
	// обработка и загрузка документа акции
	ТЗЗагрузки = Новый ТаблицаЗначений;
	
	 // максимальная длина строки - 20 символов
    КвалификаторыСтроки = Новый КвалификаторыСтроки(20);
    ОписаниеСтроки = Новый ОписаниеТипов("Строка", ,КвалификаторыСтроки);
	
	ТЗЗагрузки.Колонки.Добавить("Акция", ОписаниеСтроки);
	ТЗЗагрузки.Колонки.Добавить("Контрагент", ОписаниеСтроки);
	
	Файл = Новый ЧтениеXML;
	//Путь = "C:\Users\nechaeva\Desktop\Работа с заказми битрикс\confirmSales.xml";
	Путь =  ИмяПутиОтвета;
	Попытка
		Файл.ОткрытьФайл(Путь);
	Исключение
		//сообщить("Ошибка чтения файла");
		возврат;
	КонецПопытки;
	
	
	Пока Файл.Прочитать() Цикл
		
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "Акция" тогда
			СтрокаТаблицы = ТЗЗагрузки.Добавить();
		КонецЕсли;
		
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "КодПользователя" тогда
			файл.Прочитать(); 
			НомерК = Файл.Значение;
			СтрокаТаблицы.Контрагент = НомерК;
		КонецЕсли;
		
		Если Файл.ТипУзла = ТипУзлаXML.НачалоЭлемента И Файл.ЛокальноеИмя = "КодАкции" тогда
			файл.Прочитать(); 
			Номер = Файл.Значение;
			СтрокаТаблицы.Акция = Номер;
		КонецЕсли;
		
	КонецЦикла;		
	// выберем различные документы акции, и потом по ним будем проставлять галки	
	ТЗАкций = новый таблицаЗначений;
	//ТЗАкций.Колонки.Добавить("Акция");
	ТЗАкций = ТЗЗагрузки.Скопировать();
	ТЗАкций.свернуть("Акция");
	
	Для каждого ТекСтрокаАкция из ТЗАкций цикл
		
		ТекКодАкции = ТекСтрокаАкция.Акция;
		ТекКод = Сред(ТекКодАкции,4,СтрДлина(ТекКодАкции)-3);
		// выберем всех контаргентов оттуда;
		
		
		ТЗ2  = Новый ТаблицаЗначений;
		ТЗ2.Колонки.Добавить("Акция", ОписаниеСтроки);
		ТЗ2.Колонки.Добавить("Контрагент", ОписаниеСтроки);
		ТЗ2.Колонки.Добавить("Родитель", ОписаниеСтроки);
		
		Запрос = Новый Запрос;
		ДанныеСкладов=Неопределено;
		МВТ = Новый МенеджерВременныхТаблиц;
		Запрос.МенеджерВременныхТаблиц = МВТ;
		Запрос.Текст  = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТЗ2.Акция КАК Акция,
		|	ТЗ2.Контрагент
		|ПОМЕСТИТЬ ТЗ2
		|ИЗ
		|	&ТЗ2 КАК ТЗ2
		|ГДЕ
		|	ТЗ2.Акция = &ТекАкция";
		Запрос.УстановитьПараметр("ТекАкция",ТекКодАкции);
		Запрос.УстановитьПараметр("ТЗ2", ТЗЗагрузки);
		Запрос.Выполнить();
		
		Запрос.Текст="ВЫБРАТЬ
		|	ТЗ2.акция КАК акция,
		|	ТЗ2.контрагент
		|ИЗ
		|	ТЗ2 КАК ТЗ2
		|
		|УПОРЯДОЧИТЬ ПО
		|	Контрагент";
		РезНом=Запрос.Выполнить().Выгрузить();

		ТекДок = документы.УстановкаСкидокПоКонтрагентам.НайтиПоНомеру(ТекКод, НачалоГОда(ТекущаяДата()));
		
		Если Текдок = документы.УстановкаСкидокПоКонтрагентам.ПустаяСсылка() Тогда
			продолжить;
		КонецЕсли;
		//--------------------------------------
		НачатьТранзакцию();
		ТО = ТекДок.ПолучитьОбъект();
		естьИзменения= ложь;
		// тут контрагент ведущий, проставим по всем его подконтрагентам.
		
		Для каждого ТекСтрока из Резном цикл
			
			ТКонтрагент = Справочники.Контрагенты.НайтиПоКоду(Текстрока.контрагент);
			
		//	сообщить(ТКонтрагент);
			// это ведущий по акции, по нему найдем подчиненных и по ним по всем проставим 
			СписокПодчиненныхКонтрагентов = ВсеПодчиненныеКонтрагенты(ТКонтрагент.Код);
			Если СписокПодчиненныхКонтрагентов<> неопределено тогда
							
				Для каждого текКонтр из СписокПодчиненныхКонтрагентов цикл
					
				//	сообщить(текКонтр.ссылка);
					
					НайденнаяСтрока = ТО.Контрагенты.Найти(текКонтр.ссылка,"контрагент");
					Если НайденнаяСтрока <> Неопределено и НайденнаяСтрока.согласован = ложь  Тогда
						НайденнаяСтрока.согласован = истина;
						естьИзменения=истина; //сообщить("1");

					КонецЕсли;
				КонецЦикла;
				
			конецЕсли;
		КонецЦикла;
		
		Если ЕстьИзменения тогда
			ТО.Записать();
			ЗафиксироватьТранзакцию();
		иначе
			ОтменитьТранзакцию();
		конецЕсли;
				
	КонецЦикла;	
	
	//Сообщить("Акции прогружены");
	пп=1;
		
КонецПроцедуры
	
