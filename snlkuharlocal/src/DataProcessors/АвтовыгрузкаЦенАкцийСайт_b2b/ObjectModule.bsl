	Валюта = Справочники.Валюты.НайтиПоНаименованию(КодВалютыСтрока);
	Возврат Валюта;
	
КонецФункции	

Функция СоздатьОбновитьДокументы(ДеревоДокументов, СтруктураСтатистики, МассивДокументовДляПроведения, МассивЗагруженныхДокументов)
	
	Успешно = Истина;
	//сообщить("------------- создать оюновить документы");
	Для Каждого Док Из ДеревоДокументов.Строки Цикл
		
		НовыйДокумент = Истина;
		ПризнакПроведения=Док.РанееЗагруженныйДокументСсылка.Проведен;
		
		
		// если не 3 статуса, тогда только обновляем статусы на сайте, номенклатуру, документы не перезаписываем!!!
		ТаблицаПараметров=Док.строки;
		Обновлять=Ложь;                                                 // имя колонки
		НайденнаяСтрока = ТаблицаПараметров.Найти("Статус заказа", "СвойствоНаименование");
		Значение=Неопределено;
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			Значение = НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		
		НеПерезаписывать=Док.РанееЗагруженныйДокументСсылка.БольшеНеПерезаписыватьДокумент;
		Если Значение<>Неопределено Тогда
			Если СтрЧислоВхождений(Значение, "[T]")>0 Или СтрЧислоВхождений(Значение, "[C]")>0 или СтрЧислоВхождений(Значение, "[K]")>0 Тогда
				Обновлять=Истина;
			КонецЕСли;
		КонецЕсли;
		
		//	сообщить(""+Док.ДокументОбъект.НомерВходящегоДокументаЭлектронногоОбмена+"  "+Значение+"   "+Док.РанееЗагруженныйДокументСсылка+"  "+Обновлять);
		
		//-----------------------------------------------------------------------------
		Если Не Обновлять или НеПерезаписывать Тогда
			продолжить;
		КонецЕсли;	
		//-----------------------------------------------------------------------------
		
		
		// если на документ есть ссылки, то он вообще пропускается и не загружается  !!!
		Если Док.ЕстьСсылкиНаРанееЗагруженныйДокумент Тогда
			СтруктураСтатистики.Пропущено = СтруктураСтатистики.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Док.РанееЗагруженныйДокументСсылка) Тогда
			СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
			НовыйДокумент = Ложь;
		Иначе
			СтруктураСтатистики.Создано   = СтруктураСтатистики.Создано + 1;
		КонецЕсли;	
		
		Попытка
			
			// отдельная работа с комментарием
			Если Не ПустаяСтрока(Док.ДокументОбъект.Комментарий) Тогда
				Попытка
					СтрокаИмениСайта = Док.Строки.Найти("Сайт", "СвойствоНаименование");
					Если СтрокаИмениСайта = Неопределено Тогда
						ИмяСайта = HTTPОбменСервер;
					Иначе					
						ИмяСайта = СтрокаИмениСайта.СвойствоЗначение;
					КонецЕсли;
					Док.ДокументОбъект.Комментарий   = Док.ДокументОбъект.Комментарий + " " + ИмяСайта;
				Исключение
				КонецПопытки;
			КонецЕсли;
			
			
			Если НЕ НовыйДокумент Тогда
				// вдруг поменялся статус!!! он меняется после сохранения.
				Док.ДокументОбъект.СостояниеНакладной = Док.РанееЗагруженныйДокументСсылка.СостояниеНакладной;
				Док.ДокументОбъект.ВидОплаты = Док.РанееЗагруженныйДокументСсылка.ВидОплаты;
				Док.ДокументОбъект.ДатаОтгрузки = Док.РанееЗагруженныйДокументСсылка.ДатаОтгрузки;
				
				ПересчетТЧ(Док.ДокументОбъект,"Товары",Рубли,Рубли,1,1,Истина); 
				ПроверкаНаСертификаты(Док.ДокументОбъект);  // установка цен на сертификаты.
				
				Док.ДокументОбъект.ПодарочныеСертификаты.Очистить();
				
				Для каждого ТекСтрока из Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты цикл
					
					НовСтр=Док.ДокументОбъект.ПодарочныеСертификаты.добавить();
					НовСтр.номерСертификата=Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты[0].номерСертификата;
					НовСтр.Номинал=Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты[0].Номинал;
					НовСтр.СрокДействия=Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты[0].СрокДействия;
					НовСтр.Сертификат=Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты[0].сертификат;
					НовСтр.СуммаОплатыСертификатами=Док.РанееЗагруженныйДокументСсылка.ПодарочныеСертификаты[0].СуммаОплатыСертификатами;
					
				КонецЦикла;
				
				//------------------------------------
				// создаем сертификат
				Если Док.ДокументОбъект.СуммаБонуса<>0 Тогда
					
					// проверяем есть ли сертификаты и его сумму или создаем новый, если сертификата нет.
					Если Док.ДокументОбъект.ПодарочныеСертификаты.Количество()=0 Тогда
						
						НовыйСертиф=Справочники.ПодарочныеСертификаты.СоздатьЭлемент();
						НовыйСертиф.Владелец=Справочники.Номенклатура.НайтиПоКоду("SNL-254357");
						НовыйСертиф.ВидСертификата=справочники.ВидыПодарочныхСертификатов.ЕЕИзЧека;
						НовыйСертиф.Подарок=Истина;
						НовыйСертиф.Использован=истина;
						НовыйСертиф.Номинал=Док.ДокументОбъект.СуммаБонуса;
						//Если ТекущаяДата()>='20110401' Тогда
						//	НовыйСертиф.ПодразделениеВыдачи=Справочники.Подразделения.НайтиПоКоду("SSP-0004");  // тц
						//	НовыйСертиф.ПодразделениеПредъявления=Справочники.Подразделения.НайтиПоКоду("SSP-0004");
						//	НовыйСертиф.ПодразделениеПолучатель=Справочники.Подразделения.НайтиПоКоду("SSP-0004");
						//Иначе	
						НовыйСертиф.ПодразделениеВыдачи=Справочники.Подразделения.НайтиПоКоду("SSP-0004");
						НовыйСертиф.ПодразделениеПредъявления=Справочники.Подразделения.НайтиПоКоду("SSP-0004");
						НовыйСертиф.ПодразделениеПолучатель=Справочники.Подразделения.НайтиПоКоду("SSP-0004");
						//КонецЕсли;
						//НовыйСертиф.ПодразделениеЗатрат=Справочники.Подразделения.НайтиПоКоду("SSP-0083");
						
						НовыйСертиф.СрокДействия=360;
						НовыйСертиф.ДатаВыдачи=ТекущаяДата();
						НовыйСертиф.ДатаПогашения=ТекущаяДата();
						НовыйСертиф.НомерЧекаВыдачи=Док.РанееЗагруженныйДокументСсылка.номер;
						НовыйСертиф.НомерЧекаПогашения=Док.РанееЗагруженныйДокументСсылка.номер;
						НовыйСертиф.Записать();
						
						//-----------------------------------------------
						// добавляем в строку сетрификаты.
						
						НовСер=Док.ДокументОбъект.ПодарочныеСертификаты.добавить();
						НовСер.Сертификат=НовыйСертиф.Ссылка;
						НовСер.НомерСертификата=НовыйСертиф.Код;
						НовСер.Номинал=НовыйСертиф.номинал;
						НовСер.СуммаОплатыСертификатами=НовыйСертиф.номинал;
						
						
					КонецЕсли;
				Иначе
					
					// проверяем сумму, перезаписываем
					Если Док.ДокументОбъект.ПодарочныеСертификаты.Итог("Номинал")<>Док.ДокументОбъект.суммаБонуса Тогда
						
						Сертиф=Док.ДокументОбъект.ПодарочныеСертификаты[0].Сертификат.ПолучитьОбъект();
						Сертиф.Номинал=Док.ДокументОбъект.суммаБонуса;
						Сертиф.записать();
						
