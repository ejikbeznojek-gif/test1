Процедура ПроверкаНаСертификаты(Док)
	
	Для каждого ТекСтрока Из Док.Товары Цикл
		
		Если ТекСтрока.Номенклатура.Код="SNL-096562" Тогда
			ТекСтрока.Цена=500;
			ТекСтрока.ЦенаБезСкидки=500;
			ТекСтрока.Скидка=-1;
			РассчитатьСуммуТабЧасти(ТекСтрока, Док);	
		КонецЕсли;
		
		Если ТекСтрока.Номенклатура.Код="SNL-095774" Тогда
			ТекСтрока.Цена=1000;
			ТекСтрока.ЦенаБезСкидки=1000;
			ТекСтрока.Скидка=-1;
			РассчитатьСуммуТабЧасти(ТекСтрока, Док);
		КонецЕсли;
		
		Если ТекСтрока.Номенклатура.Код="SNL-096577" Тогда
			ТекСтрока.Цена=2000;
			ТекСтрока.ЦенаБезСкидки=2000;
			ТекСтрока.Скидка=-1;
			РассчитатьСуммуТабЧасти(ТекСтрока, Док);
		КонецЕсли;
		
		Если ТекСтрока.Номенклатура.Код="SNL-096561" Тогда
			ТекСтрока.Цена=3000;
			ТекСтрока.ЦенаБезСкидки=3000;
			ТекСтрока.Скидка=-1;
			РассчитатьСуммуТабЧасти(ТекСтрока, Док);
		КонецЕсли;
		
		Если ТекСтрока.Номенклатура.Код="SNL-231090" Тогда
