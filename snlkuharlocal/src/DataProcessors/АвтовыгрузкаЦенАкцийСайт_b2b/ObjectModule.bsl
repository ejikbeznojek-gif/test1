	ЗаписьXML.ЗаписатьАтрибут("ДатаФормирования", Формат(ДатаФормирования, "ДФ=yyyy-MM-dd'T'ЧЧ:мм:сс"));	
	
	ЗаписьXML.ЗаписатьАтрибут("ВерсияСхемы","2.04.1CBitrix");
	ЗаписьXML.ЗаписатьАтрибут("ФорматДаты","ДФ=dd.MM.yyyy; ДЛФ=D");
	ЗаписьXML.ЗаписатьАтрибут("ФорматВремени","ДФ=ЧЧ:мм:сс; ДЛФ=T");
