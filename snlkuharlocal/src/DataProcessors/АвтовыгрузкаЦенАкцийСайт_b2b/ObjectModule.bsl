		МассивПодкаталогов.Добавить(мПодкаталогФайлов);
	КонецЕсли;	
	
	Успешно = HTTPВыгрузитьНаСервер(СтруктураПараметровСайта, МассивПодкаталогов, Истина, "catalog");
	
	
	
	//ОчиститьКаталогНаДиске();	
	
	Возврат Успешно;
	
КонецФункции	

