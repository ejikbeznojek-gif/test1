	ЗаписьXML.ЗаписатьАтрибут("ФорматСуммы","ЧЦ=18; ЧДЦ=2; ЧРД=,; ЧГ=""");
	ЗаписьXML.ЗаписатьАтрибут("ФорматКоличества","ЧЦ=18; ЧДЦ=2; ЧРД=,; ЧГ=""");
	//	ЗаписьXML.ЗаписатьАтрибут("ДатаФормирования",ПараметрЗаголовка);
	
	
	Возврат ЗаписьXML;
	
