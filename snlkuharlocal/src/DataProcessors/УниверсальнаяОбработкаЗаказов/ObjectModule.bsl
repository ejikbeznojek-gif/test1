			Сообщить( Строка("В указанных заказах состояние заказа отлично от (В работе): " + ЗаказНевработе ));
		КонецЕсли;
		
		Для каждого СтрМасс из МассивРабочихЗаказов цикл
			
			ОбъектЗаказ =  СтрМасс.получитьОБъект();
			
			МассивДополнительныхСкладов = новый массив;	 
			//++Данилова Е.В. 17.11.2025 HELP-7070
			МассивЗаказовКОбработке = Новый Массив;
			МассивЗаказовКОбработке.Добавить(ОбъектЗаказ.ссылка);
			КэшОстатков 	= Новый Соответствие; 
