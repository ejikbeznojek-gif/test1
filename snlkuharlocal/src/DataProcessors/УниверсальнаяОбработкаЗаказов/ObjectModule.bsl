	//|		И РезервыТМЦ.Склад В(&МассивСкладов)
	//|	
	//|	СГРУППИРОВАТЬ ПО
	//|		РезервыТМЦ.Номенклатура) КАК Сводный 
	////--Данилова Е.В. 17.04.2025
	//|
	//|		ПО Товары.Номенклатура = Сводный.Номенклатура
	//|ГДЕ
	//|	Товары.Ссылка В(&МассивСсылок)
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	Товары.Номенклатура
	//|
	////++Данилова Е.В. 17.04.2025
	//|ИМЕЮЩИЕ 
	//|СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - ВЫБОР
	//|			КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	//|				ТОГДА 0
	//|			ИНАЧЕ (СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)))
	//|		КОНЕЦ > 0  "; 
	////|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) + СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) > 0"; 
	////--Данилова Е.В. 17.04.2025
	
	 //--Данилова Е.В. 16.10.2025
	УстановитьПривилегированныйРежим(Истина);
	//++Данилова Е.В. 16.10.2025 HELP-7296
	//ТаблицаКЗагрузке = Запрос.Выполнить().Выгрузить();
	ПакетЗапросов = Запрос.ВыполнитьПакет(); 
	
	ТаблицаКзагрузкеСОбСкладов = ПакетЗапросов[0].Выгрузить(); 
	ТаблицаКзагрузкеМаркСкладов = ПакетЗапросов[1].Выгрузить();
	//--Данилова Е.В. 16.10.2025
	УстановитьПривилегированныйРежим(Ложь);
	
	ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, СостояниеНакладнойУПолучателя, Отгружен, ДатаПриемки",
		Перечисления.СостоянияНакладной.ВРаботе, Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, Дата(1,1,1));
	
	МассивНомеров = Новый Массив; 
	Для каждого ССылкаИзМассива Из МассивСсылок Цикл
	
		МассивНомеров.Добавить(ССылкаИзМассива.Номер); 	
	
	КонецЦикла;
	НомераВСтроку = СтрСоединить(МассивНомеров,","); 
	КомментарийКПРМ = "ПРМ на недостающие по заказам:" + НомераВСтроку; 

