// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
Функция СоздатьПРМНаНедостающие_Старая(МассивСсылок) Экспорт 
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат неопределено;
	КонецЕсли;
	
	Если МассивСсылок.Количество() = 0 Тогда
		Сообщить("Не выбраны Заказы!!!");
		Возврат неопределено;
	КонецЕсли;
	
	СтруктураПроверки = Документы.Заказ.ОбщиеПроверкиПолучитьСтруктуру(МассивСсылок);
	
	Если СтруктураПроверки.МассивСкладов.Количество() > 1 Тогда
		Сообщить("Выделены Заказы с разными <Складами>");
		Возврат неопределено;
	КонецЕсли;
	//++Данилова Е.В. 16.10.2025 HELP-7296
	
	Если СтруктураПроверки.МассивСкладовМаркировки.Количество() > 1 Тогда
		Сообщить("Выделены Заказы с разными <Складами маркировки>");
		Возврат неопределено;
	КонецЕсли;
	
	//--Данилова Е.В. 16.10.2025
	
	Если СтруктураПроверки.МассивПроведения.Количество() > 1 Тогда
		Сообщить("В выделенных строках есть непроведенные документы.");
		Возврат Неопределено;
	Иначе
		Если СтруктураПроверки.МассивПроведения[0] = Ложь Тогда
			Сообщить("Заказы не проведены.");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	СкладПолучатель = СтруктураПроверки.МассивСкладов[0];
	Склад = ?(ЗначениеЗаполнено(СкладПолучатель.ФизическийСклад), СкладПолучатель.ФизическийСклад, Справочники.Склады.НайтиПоКоду("STA-48"));
	
	МассивСкладов = ?(СтруктураПроверки.МассивСкладов.Количество() = 0, Новый Массив, СтруктураПроверки.МассивСкладов);
	//++Данилова Е.В. 16.10.2025 HELP-7296 
	МассивСкладовМаркировки = ?(СтруктураПроверки.МассивСкладовМаркировки.Количество() = 0, Новый Массив, СтруктураПроверки.МассивСкладовМаркировки);
	СкладПолучательМаркировка = СтруктураПроверки.МассивСкладовМаркировки[0];
	СкладМаркировка = ?(ЗначениеЗаполнено(СкладПолучательМаркировка.ФизическийСклад), СкладПолучательМаркировка.ФизическийСклад, Справочники.Склады.НайтиПоКоду("STD-95"));
	//--Данилова Е.В. 16.10.2025
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДополнительныеСклады.Склад КАК Склад
	|ИЗ
	|	Документ.Заказ.ДополнительныеСклады КАК ДополнительныеСклады
	|ГДЕ
	|	ДополнительныеСклады.Ссылка В(&МассивСсылок)
	|	И ДополнительныеСклады.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл 
		//++Данилова Е.В. 16.10.2025 HELP-7296 
		Если Выборка.Склад.ЭтоСкладМаркированногоТовара Тогда
		
			МассивСкладовМаркировки.Добавить(Выборка.Склад); 	
		Иначе 
			МассивСкладов.Добавить(Выборка.Склад);
		КонецЕсли;
		//МассивСкладов.Добавить(Выборка.Склад); 
		//--Данилова Е.В. 16.10.2025 
	КонецЦикла;
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("Дата", КонецДня(ТекущаяДатаСеанса()));
	//++Данилова Е.В. 16.10.2025 HELP-7296
	Запрос.УстановитьПараметр("МассивСкладовМаркировки", МассивСкладовМаркировки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) КАК КоличествоИсх,
	|	СУММА(Сводный.Остаток) КАК Остаток,
	|	СУММА(Сводный.Резерв) КАК Резерв,
	|	СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) - ВЫБОР
	|				КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|					ТОГДА 0
	|				ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|			КОНЕЦ > 0
	|			ТОГДА СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) - ВЫБОР
	|					КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|						ТОГДА 0
	|					ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Количество
	|ИЗ
	|	Документ.Заказ.Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗаказДополнительныеДвижения.Ссылка КАК Ссылка,
	|			ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура,
	|			СУММА(ЗаказДополнительныеДвижения.Количество) КАК Количество
	|		ИЗ
	|			Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|		ГДЕ
	|			ЗаказДополнительныеДвижения.Ссылка В(&МассивСсылок)
	|			И НЕ ЗаказДополнительныеДвижения.Склад.ЭтоСкладМаркированногоТовара
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗаказДополнительныеДвижения.Ссылка,
	|			ЗаказДополнительныеДвижения.Номенклатура) КАК ЗаказДополнительныеДвижения
	|		ПО Товары.Ссылка = ЗаказДополнительныеДвижения.Ссылка
	|			И Товары.Номенклатура = ЗаказДополнительныеДвижения.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Остатки.Номенклатура КАК Номенклатура,
	|			СУММА(ЕСТЬNULL(Остатки.КоличествоОстаток, 0)) КАК Остаток,
	|			СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ.Остатки(
	|					&Дата,
	|					Склад В (&МассивСкладов)
	|						И НЕ Склад.ЭтоСкладМаркированногоТовара
	|						И Номенклатура В
	|							(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|								Товары.Номенклатура КАК Номенклатура
	|							ИЗ
	|								Документ.Заказ.Товары КАК Товары
	|							ГДЕ
	|								Товары.Ссылка В (&МассивСсылок))) КАК Остатки
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|						&Дата,
	|						Склад В (&МассивСкладов)
	|							И НЕ Склад.ЭтоСкладМаркированногоТовара
	|							И Номенклатура В
	|								(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|									Товары.Номенклатура КАК Номенклатура
	|								ИЗ
	|									Документ.Заказ.Товары КАК Товары
	|								ГДЕ
	|									Товары.Ссылка В (&МассивСсылок))) КАК Резервы
	|				ПО Остатки.Номенклатура = Резервы.Номенклатура
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Остатки.Номенклатура
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			РезервыТМЦ.Номенклатура,
	|			0,
	|			-СУММА(ЕСТЬNULL(РезервыТМЦ.Количество, 0))
	|		ИЗ
	|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|		ГДЕ
	|			РезервыТМЦ.Регистратор В(&МассивСсылок)
	|			И РезервыТМЦ.Склад В(&МассивСкладов)
	|			И НЕ РезервыТМЦ.Склад.ЭтоСкладМаркированногоТовара
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РезервыТМЦ.Номенклатура) КАК Сводный
	|		ПО Товары.Номенклатура = Сводный.Номенклатура
	|ГДЕ
	|	Товары.Ссылка В(&МассивСсылок)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - ВЫБОР
	|		КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|			ТОГДА 0
	|		ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|	КОНЕЦ > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) КАК КоличествоИсх,
	|	СУММА(Сводный.Остаток) КАК Остаток,
	|	СУММА(Сводный.Резерв) КАК Резерв,
	|	СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) - ВЫБОР
	|				КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|					ТОГДА 0
	|				ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|			КОНЕЦ > 0
	|			ТОГДА СУММА(ЕСТЬNULL(ЗаказДополнительныеДвижения.Количество, 0)) - ВЫБОР
	|					КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|						ТОГДА 0
	|					ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Количество
	|ИЗ
	|	Документ.Заказ.Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗаказДополнительныеДвижения.Ссылка КАК Ссылка,
	|			ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура,
	|			СУММА(ЗаказДополнительныеДвижения.Количество) КАК Количество
	|		ИЗ
	|			Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|		ГДЕ
	|			ЗаказДополнительныеДвижения.Ссылка В(&МассивСсылок)
	|			И ЗаказДополнительныеДвижения.Склад.ЭтоСкладМаркированногоТовара
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗаказДополнительныеДвижения.Ссылка,
	|			ЗаказДополнительныеДвижения.Номенклатура) КАК ЗаказДополнительныеДвижения
	|		ПО Товары.Ссылка = ЗаказДополнительныеДвижения.Ссылка
	|			И Товары.Номенклатура = ЗаказДополнительныеДвижения.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Остатки.Номенклатура КАК Номенклатура,
	|			СУММА(ЕСТЬNULL(Остатки.КоличествоОстаток, 0)) КАК Остаток,
	|			СУММА(ЕСТЬNULL(Резервы.КоличествоОстаток, 0)) КАК Резерв
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ.Остатки(
	|					&Дата,
	|					Склад В (&МассивСкладовМаркировки)
	|						И Склад.ЭтоСкладМаркированногоТовара
	|						И Номенклатура В
	|							(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|								Товары.Номенклатура КАК Номенклатура
	|							ИЗ
	|								Документ.Заказ.Товары КАК Товары
	|							ГДЕ
	|								Товары.Ссылка В (&МассивСсылок))) КАК Остатки
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|						&Дата,
	|						Склад В (&МассивСкладовМаркировки)
	|							И Склад.ЭтоСкладМаркированногоТовара
	|							И Номенклатура В
	|								(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|									Товары.Номенклатура КАК Номенклатура
	|								ИЗ
	|									Документ.Заказ.Товары КАК Товары
	|								ГДЕ
	|									Товары.Ссылка В (&МассивСсылок))) КАК Резервы
	|				ПО Остатки.Номенклатура = Резервы.Номенклатура
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Остатки.Номенклатура
	|		
	|		ОБЪЕДИНИТЬ
	|		
	|		ВЫБРАТЬ
	|			РезервыТМЦ.Номенклатура,
	|			0,
	|			-СУММА(ЕСТЬNULL(РезервыТМЦ.Количество, 0))
	|		ИЗ
	|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|		ГДЕ
	|			РезервыТМЦ.Регистратор В(&МассивСсылок)
	|			И РезервыТМЦ.Склад В(&МассивСкладовМаркировки)
	|			И РезервыТМЦ.Склад.ЭтоСкладМаркированногоТовара
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РезервыТМЦ.Номенклатура) КАК Сводный
	|		ПО Товары.Номенклатура = Сводный.Номенклатура
	|ГДЕ
	|	Товары.Ссылка В(&МассивСсылок)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - ВЫБОР
	|		КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	|			ТОГДА 0
	|		ИНАЧЕ СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	|	КОНЕЦ > 0"; 
	//|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) + СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) > 0"; 
	

	//"ВЫБРАТЬ
	//|	Товары.Номенклатура КАК Номенклатура,
	//|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) КАК КоличествоИсх,
	//|	СУММА(Сводный.Остаток) КАК Остаток,
	//|	СУММА(Сводный.Резерв) КАК Резерв,
	//|	СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) КАК СвободныйОстаток, 
	////++Данилова Е.В. 17.04.2025 HELP-4410
	////|	ВЫБОР
	////|		КОГДА СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) + СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) > 0
	////|			ТОГДА СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) + СУММА(ЕСТЬNULL(Сводный.Резерв, 0))
	////|		ИНАЧЕ 0
	////|	КОНЕЦ КАК Количество 
	//|ВЫБОР
	//|	КОГДА СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - ВЫБОР
	//|			КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	//|				ТОГДА 0
	//|			ИНАЧЕ (СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)))
	//|		КОНЕЦ > 0
	//|		ТОГДА СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) - ВЫБОР
	//|				КОГДА СУММА(ЕСТЬNULL(Сводный.Остаток, 0)) - СУММА(ЕСТЬNULL(Сводный.Резерв, 0)) < 0
	//|					ТОГДА 0
