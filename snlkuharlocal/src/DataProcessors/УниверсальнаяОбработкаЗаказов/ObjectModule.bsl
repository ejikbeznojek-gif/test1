//++Данилова Е.В. 17.11.2025 HELP-7070 
Функция СоздатьПРМНаНедостающие(МассивСсылок) Экспорт 
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат неопределено;
	КонецЕсли;
	
	Если МассивСсылок.Количество() = 0 Тогда
		Сообщить("Не выбраны Заказы!!!");
		Возврат неопределено;
	КонецЕсли;
	
	СтруктураПроверки = Документы.Заказ.ОбщиеПроверкиПолучитьСтруктуру(МассивСсылок);
	
	Если СтруктураПроверки.МассивСкладов.Количество() > 1 Тогда
		Сообщить("Выделены Заказы с разными <Складами>");
		Возврат неопределено;
	КонецЕсли;
		
	Если СтруктураПроверки.МассивСкладовМаркировки.Количество() > 1 Тогда
		Сообщить("Выделены Заказы с разными <Складами маркировки>");
		Возврат неопределено;
	КонецЕсли;
	
	Если СтруктураПроверки.МассивПроведения.Количество() > 1 Тогда
		Сообщить("В выделенных строках есть непроведенные документы.");
		Возврат Неопределено;
	Иначе
		Если СтруктураПроверки.МассивПроведения[0] = Ложь Тогда
			Сообщить("Заказы не проведены.");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	СкладПолучатель = СтруктураПроверки.МассивСкладов[0];
	СкладПолучательМаркировка = СтруктураПроверки.МассивСкладовМаркировки[0];
	
	Склад = ?(ЗначениеЗаполнено(СкладПолучатель.ФизическийСклад), СкладПолучатель.ФизическийСклад, Справочники.Склады.НайтиПоКоду("STA-48"));
	
	МассивСкладов = ?(СтруктураПроверки.МассивСкладов.Количество() = 0, Новый Массив, СтруктураПроверки.МассивСкладов);
	
	Если ЗначениеЗаполнено(СкладПолучательМаркировка) Тогда 
		МассивСкладов.Добавить(СкладПолучательМаркировка);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДополнительныеСклады.Склад КАК Склад
	|ИЗ
	|	Документ.Заказ.ДополнительныеСклады КАК ДополнительныеСклады
	|ГДЕ
	|	ДополнительныеСклады.Ссылка В(&МассивСсылок)
	|	И ДополнительныеСклады.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл 
		МассивСкладов.Добавить(Выборка.Склад);	 
	КонецЦикла;
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("Дата", КонецДня(ТекущаяДатаСеанса()));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0)) КАК ПодтвержденнаяЗаявка
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	Документ.Заказ.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка В(&МассивСсылок)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.ПодтвержденнаяЗаявка КАК КоличествоИсх,
	|	Вложенныйзапрос.Остаток КАК Остаток,
	|	Вложенныйзапрос.Резерв КАК Резерв,
	|	Вложенныйзапрос.Остаток - Вложенныйзапрос.Резерв КАК СвободныйОстаток,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0) - ВЫБОР
	|				КОГДА ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0) < 0
	|					ТОГДА 0
	|				ИНАЧЕ ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0)
	|			КОНЕЦ > 0
	|			ТОГДА ЕСТЬNULL(Товары.ПодтвержденнаяЗаявка, 0) - ВЫБОР
	|					КОГДА ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0) < 0
	|						ТОГДА 0
	|					ИНАЧЕ ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0)
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Количество
	|ИЗ
	|	ВТТовары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Сводный.Номенклатура КАК Номенклатура,
	|			СУММА(Сводный.Остаток) КАК Остаток,
	|			СУММА(Сводный.Резерв) КАК Резерв,
	|			СУММА(Сводный.Остаток) - СУММА(Сводный.Резерв) КАК СвободныйОстаток
	|		ИЗ
	|			(ВЫБРАТЬ
	|				ЕСТЬNULL(Остатки.Номенклатура, Резервы.Номенклатура) КАК Номенклатура,
	|				ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток,
	|				ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв
	|			ИЗ
	|				РегистрНакопления.ОстаткиТМЦ.Остатки(
	|						&Дата,
	|						Склад В (&МассивСкладов)
	|							И Номенклатура В
	|								(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|									Товары.Номенклатура КАК Номенклатура
	|								ИЗ
	|									Документ.Заказ.Товары КАК Товары
	|								ГДЕ
	|									Товары.Ссылка В (&МассивСсылок))) КАК Остатки
	|					ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|							&Дата,
	|							Склад В (&МассивСкладов)
	|								И Номенклатура В
	|									(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|										Товары.Номенклатура КАК Номенклатура
	|									ИЗ
	|										Документ.Заказ.Товары КАК Товары
	|									ГДЕ
	|										Товары.Ссылка В (&МассивСсылок))) КАК Резервы
	|					ПО Остатки.Номенклатура = Резервы.Номенклатура
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				РезервыТМЦ.Номенклатура,
	|				0,
	|				-СУММА(ЕСТЬNULL(РезервыТМЦ.Количество, 0))
	|			ИЗ
	|				РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|			ГДЕ
	|				РезервыТМЦ.Регистратор В(&МассивСсылок)
	|				И РезервыТМЦ.Склад В(&МассивСкладов)
	|			
	|			СГРУППИРОВАТЬ ПО
	|				РезервыТМЦ.Номенклатура) КАК Сводный
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Сводный.Номенклатура) КАК Вложенныйзапрос
	|		ПО Товары.Номенклатура = Вложенныйзапрос.Номенклатура
	|ГДЕ
	|	Товары.ПодтвержденнаяЗаявка - ВЫБОР
	|			КОГДА ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0) < 0
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(Вложенныйзапрос.Остаток, 0) - ЕСТЬNULL(Вложенныйзапрос.Резерв, 0)
	|		КОНЕЦ > 0";   
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТаблицаКЗагрузке = Запрос.Выполнить().Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, СостояниеНакладнойУПолучателя, Отгружен, ДатаПриемки",
		Перечисления.СостоянияНакладной.ВРаботе, Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, Дата(1,1,1));
	
	МассивНомеров = Новый Массив; 
	Для каждого ССылкаИзМассива Из МассивСсылок Цикл
	
		МассивНомеров.Добавить(ССылкаИзМассива.Номер); 	
	
	КонецЦикла;
	НомераВСтроку = СтрСоединить(МассивНомеров,","); 
	КомментарийКПРМ = "ПРМ на недостающие по заказам:" + НомераВСтроку; 
	ДополнительныеРеквизиты.Вставить("НеЗаписыватьДокумент",истина); 	
	Перемещение = ЗаполнениеДокументов.СоздатьПеремещение(,ТаблицаКЗагрузке,
		Справочники.Склады.ПустаяСсылка(), Справочники.Склады.ПустаяСсылка(), КомментарийКПРМ, ДополнительныеРеквизиты, Ложь, Истина);
		
	Возврат Перемещение;

КонецФункции // СоздатьПРМНаНедостающие()


//--Данилова Е.В. 17.11.2025
Функция СоздатьРНКПРМПоРезервам(МассивСсылок, ИзФормыЗаказа = Ложь,
	РасходныеНакладные = неопределено,
	МассивПРМ = неопределено,
	МассивРНК = Неопределено,
	ФлагСоздаватьПРМ = неопределено) Экспорт 
	
	Если ТипЗнч(МассивСсылок) <> Тип("Массив") Тогда
		Возврат неопределено;
	КонецЕсли;
	
	МассивСостояниеНакладной = Новый Массив;
	
	СтруктураПроверки = Документы.Заказ.ОбщиеПроверкиПолучитьСтруктуру(МассивСсылок);
	
	Если СтруктураПроверки.МассивСкладов.Количество() > 1 Тогда
		Сообщить("Выделены Заказы с разными <Складами>");
		Возврат неопределено;
	КонецЕсли;
