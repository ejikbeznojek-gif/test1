				СтрокаТаблицыМарк.СкладМаркировки =   Строчка.СкладМаркировки;
			Конецесли; 
			//--Данилова Е.В. 17.04.2025
			Массив = новый массив;		
			Массив = строчка.ДополнительныеСклады.выгрузитьколонку("Склад");
			Если ЗначениеЗаполнено(ИсключающееИЛИ(МассивДопСклада,Массив)) тогда			
				флагОшибки = истина;
			КонецЕсли;
			
			
			Если Строчка.СостояниеНакладной <>  перечисления.СостоянияЗаказаКонтрагента.ВРаботе тогда			
				СтрокаТаблицыЗаказовВработе = 	ТаблицаДляПроверкиЗаказовВработе.Добавить();	
				СтрокаТаблицыЗаказовВработе.ссылка =   Строчка.ссылка;			
			Иначе
				МассивРабочихЗаказов.Добавить(Строчка);			
			КонецЕсли;	
		Конеццикла;
		
		Таблица.Свернуть("склад"); 
		//++Данилова Е.В. 17.04.2025 HELP-4400
		ТаблицаМаркировки.Свернуть("СкладМаркировки");
		Если ТаблицаМаркировки.Количество() > 1 тогда
			сообщить("В указанных заказах отличаются склады маркировки");
			Возврат ЛОЖЬ;
		КонецЕСли;
		//--Данилова Е.В. 17.04.2025
		
		Если таблица.Количество() > 1 тогда
			сообщить("В указанных заказах отличаются склады");
			Возврат ЛОЖЬ;
		КонецЕСли;
		
		
		Если флагОшибки= Истина тогда
			сообщить("В указанных заказах отличаются ДопСклады");
			Возврат ЛОЖЬ;
		КонецЕСли;
		
		// Проверка Заказов
		СписокЗаказовНеВРаботе="";
		
		Если  ТаблицаДляПроверкиЗаказовВработе.Количество() > 0 тогда
			ЗаказНевработе = Строка(Символы.ПС+ "");
			Для каждого СтрокаТч из ТаблицаДляПроверкиЗаказовВработе цикл
				ЗаказНевработе = Строка(ЗаказНевработе + Строка(Строка(СтрокаТч.ссылка) + символы.ПС)); 			
