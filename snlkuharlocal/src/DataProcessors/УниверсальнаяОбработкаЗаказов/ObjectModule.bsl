	//|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	//|						&Дата,
	//|						Склад В (&МассивСкладов)
	//|							И Номенклатура В
	//|								(ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|									Товары.Номенклатура КАК Номенклатура
	//|								ИЗ
	//|									Документ.Заказ.Товары КАК Товары
	//|								ГДЕ
	//|									Товары.Ссылка В (&МассивСсылок))) КАК Резервы
	//|				ПО Остатки.Номенклатура = Резервы.Номенклатура
	//|		
	//|		ОБЪЕДИНИТЬ ВСЕ
	//|		
	////|		ВЫБРАТЬ
	////|			РезервыТМЦ.Номенклатура,
	////|			0,
	////|			-ЕСТЬNULL(РезервыТМЦ.Количество, 0)
	////|		ИЗ
	////|			РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	////|		ГДЕ
	////|			РезервыТМЦ.Регистратор В(&МассивСсылок)
	////|			И РезервыТМЦ.Склад В(&МассивСкладов)) КАК Сводный 
	////++Данилова Е.В. 17.04.2025  HELP-4410
	//|ВЫБРАТЬ
	//|		РезервыТМЦ.Номенклатура,
