			//--Данилова Е.В. 17.11.2025
				
				МассивДополнительныхСкладов.Добавить(СтрДопСклада.склад);        				 
				
			КонецЦикла;
			//++Данилова Е.В. 17.04.2025 HELP-4400
			Если ЗначениеЗаполнено(ОбъектЗаказ.СкладМаркировки) Тогда
				
				МассивДополнительныхСкладов.Добавить(ОбъектЗаказ.СкладМаркировки);	
				
			КонецЕсли;	
			//--Данилова Е.В. 17.04.2025
			//++Данилова Е.В. 17.11.2025 HELP-7070 
			//ПолучитьОстатки(СтрМасс.товары.выгрузитьКолонку("номенклатура"),СтрМасс.Склад,МассивРабочихЗаказов,КэшОстатков, ФлагФизСклад = Ложь,МассивДополнительныхСкладов);
			ПолучитьОстатки(СтрМасс.товары.выгрузитьКолонку("номенклатура"),СтрМасс.Склад,МассивЗаказовКОбработке,КэшОстатков, ФлагФизСклад = Ложь,МассивДополнительныхСкладов);
			//--Данилова Е.В. 17.11.2025
			Для Каждого СтрМассТовары из ОбъектЗаказ.товары Цикл
				
				Если КэшОстатков.Получить(СтрМассТовары.Номенклатура) = Неопределено Тогда
					СтрМассТовары.Количество = 	0;
				Иначе	
					Если КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток >= СтрМассТовары.ПодтвержденнаяЗаявка тогда
						СтрМассТовары.количество = 	СтрМассТовары.подтвержденнаяЗаявка;						
						КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток= КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток  - СтрМассТовары.ПодтвержденнаяЗаявка; 					 
					ИНАЧЕ
						СтрМассТовары.количество = КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток;						
						КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток = КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток - СтрМассТовары.ПодтвержденнаяЗаявка; 					 
					КонецЕсЛИ
				КонецЕсли;
				
				РассчитатьСуммуТабЧасти(СтрМассТовары, ОбъектЗаказ);
				
			КонецЦикла;
			
			Попытка
				ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
