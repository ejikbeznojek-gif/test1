				Перечисления.СостоянияНакладной.ВРаботе, Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, ТекущаяДата(), Дата(1,1,1), Заказ.Менеджер);
				
				ДокСсылка = ЗаполнениеДокументов.СоздатьПеремещение(Заказ, ТоварыМаркировки, СкладМаркировки, СкладПолучательИзРеквизита, СокрЛП(Заказ.Комментарий), ДополнительныеРеквизиты, Ложь, Истина);
				
				Если ДокСсылка <> Неопределено Тогда
					МассивРНК.Добавить(ДокСсылка);
					//++Данилова Е.В. 30.09.2025 HELP-7111
					МассивРНКДляДобавленияВЗаказ.Добавить(ДокСсылка); 
					//--Данилова Е.В. 30.09.2025
					ФлагПеречитатьЗаказ = Истина;
				КонецЕсли;
			КонецЕсли; 
			
			Если ФлагСоздаватьПРМ 
				И СоздаватьДокументНеМаркировки Тогда
				
				ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, СостояниеНакладнойУПолучателя, Отгружен, Дата, ДатаПриемки, Менеджер",
				Перечисления.СостоянияНакладной.ВРаботе, Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, ТекущаяДата(), Дата(1,1,1), Заказ.Менеджер);
				
				ДокСсылка = ЗаполнениеДокументов.СоздатьПеремещение(Заказ, ТоварыНеМаркировки, СкладИсточник, СкладПолучательИзРеквизита, СокрЛП(Заказ.Комментарий), ДополнительныеРеквизиты, Ложь, Истина);
				
				Если ДокСсылка <> Неопределено Тогда
					МассивРНК.Добавить(ДокСсылка);
					//++Данилова Е.В. 30.09.2025 HELP-7111
					МассивРНКДляДобавленияВЗаказ.Добавить(ДокСсылка); 
					//--Данилова Е.В. 30.09.2025
					ФлагПеречитатьЗаказ = Истина;
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ ФлагСоздаватьПРМ
				И СоздаватьДокументМаркировки Тогда
				
				ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, Отгружен, Склад, Дата", Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, СкладМаркировки, ТекущаяДата());
				//++Данилова Е.В. 01.09.2025 HELP-6853	
				//ДокСсылкаМаркированныхТоваров = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Заказ, ТоварыМаркировки, ДополнительныеРеквизиты, Ложь, СокрЛП(Заказ.Комментарий) + " маркированный товар",,Истина,истина);
				ДокСсылкаМаркированныхТоваров = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Заказ, ТоварыМаркировки, ДополнительныеРеквизиты, Ложь, СокрЛП(Заказ.Комментарий),,Истина,истина);
				//--Данилова Е.В. 01.09.2025
				Если ДокСсылкаМаркированныхТоваров <> Неопределено Тогда
					МассивРНК.Добавить(ДокСсылкаМаркированныхТоваров);
					//++Данилова Е.В. 30.09.2025 HELP-7111
					МассивРНКДляДобавленияВЗаказ.Добавить(ДокСсылкаМаркированныхТоваров); 
					//--Данилова Е.В. 30.09.2025
					ФлагПеречитатьЗаказ = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ ФлагСоздаватьПРМ
				И СоздаватьДокументНеМаркировки Тогда
				
				ДополнительныеРеквизиты = Новый Структура("СостояниеНакладной, Отгружен, Склад, Дата", Перечисления.СостоянияНакладной.ВРаботе, Перечисления.Отгружен.Резерв, СкладИсточник, ТекущаяДата());
				//++Данилова Е.В. 01.09.2025 HELP-6853
				//ДокСсылкаНеМаркированныхТоваров = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Заказ, ТоварыНеМаркировки, ДополнительныеРеквизиты, Ложь, СокрЛП(Заказ.Комментарий) + " Немаркированный товар",,Истина,истина);
				ДокСсылкаНеМаркированныхТоваров = ЗаполнениеДокументов.СоздатьРасходнуюНакладную(Заказ, ТоварыНеМаркировки, ДополнительныеРеквизиты, Ложь, СокрЛП(Заказ.Комментарий),,Истина,истина);
				
				//--Данилова Е.В. 01.09.2025 
				Если ДокСсылкаНеМаркированныхТоваров <> Неопределено Тогда
					МассивРНК.Добавить(ДокСсылкаНеМаркированныхТоваров);
					//++Данилова Е.В. 30.09.2025 HELP-7111
					МассивРНКДляДобавленияВЗаказ.Добавить(ДокСсылкаНеМаркированныхТоваров); 
					//--Данилова Е.В. 30.09.2025
					ФлагПеречитатьЗаказ = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ФлагПеречитатьЗаказ <> Неопределено  Тогда 
				
				Если НЕ ИзФормыЗаказа Тогда
					
					ПеречитаемЗаказ = Заказ.ПолучитьОбъект();
					
					Если ПеречитаемЗаказ <> Неопределено Тогда
						
						Попытка
							ПеречитаемЗаказ.Заблокировать();
						Исключение
							СообщитьИзМодуля("Не могу заблокировать " + Строка(ПеречитаемЗаказ));
							СообщитьИзМодуля("Возможно, открыта форма Заказа. Закройте форму и нажмите кнопку ещё раз!");
							Если ТранзакцияАктивна() Тогда
								ОтменитьТранзакцию();
							КонецЕсли;
							Возврат неопределено;
						КонецПопытки;
						
						ПеречитаемЗаказ.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ПодтвержденныйЗаказ;
						//++Данилова Е.В. 30.09.2025 HELP-7111
						//Для каждого СозданныйРНКПРМ Из МассивРНК  Цикл
						Для каждого СозданныйРНКПРМ Из МассивРНКДляДобавленияВЗаказ  Цикл
							Если НЕ ЗначениеЗаполнено(СозданныйРНКПРМ) Тогда
							
								Продолжить; 	
							
							КонецЕсли;
							//--Данилова Е.В. 30.09.2025
							
							СтрТЧ = ПеречитаемЗаказ.РасходныеНакладные.Найти(СозданныйРНКПРМ,"Документ");	
							Если СтрТЧ = Неопределено Тогда
								СтрТЧ = ПеречитаемЗаказ.РасходныеНакладные.Добавить();
								СтрТЧ.Документ = СозданныйРНКПРМ;
							КонецЕсли;
							
						КонецЦикла;
						Попытка
							ПеречитаемЗаказ.Записать(РежимЗаписиДокумента.Проведение);
							ПеречитаемЗаказ.Разблокировать();
						Исключение
							ПеречитаемЗаказ.Разблокировать();
							СообщитьИзМодуля("Не могу перезаписать " + Строка(ПеречитаемЗаказ));
							Если ТранзакцияАктивна() Тогда
								ОтменитьТранзакцию();
							КонецЕсли;
							Возврат неопределено;
						КонецПопытки;
						
						
						
					КонецЕсли;
					
				Иначе
					
					Для каждого СозданныйРНКПРМ Из МассивРНК  Цикл
						
						РасходныеНакладные.Добавить(СозданныйРНКПРМ); 
						
					КонецЦикла; 				
					
				КонецЕсли;
				
			КонецЕсли;  
			
		КонецЕсли; 
		//--Данилова Е.В. 01.04.2025
	КонецЦикла;
	
	///////// ПРОВЕДЕНИЕ РНК И ПЕРЕМЕЩЕНИЙ ////////////////////////////////////////////////////////
	
	Если НЕ ИзФормыЗаказа Тогда
		
		Для Каждого ДокРНК ИЗ МассивРНК Цикл
			
			ПроводимоеРНК = ДокРНК.ПолучитьОбъект();
			
			Если ПроводимоеРНК <> Неопределено Тогда
				
				Попытка
					ПроводимоеРНК.Заблокировать();
				Исключение
					СообщитьИзМодуля("Не могу заблокировать " + Строка(ПроводимоеРНК));
					Если ТранзакцияАктивна() тогда
						ОтменитьТранзакцию();
					КонецЕсли;
					Возврат неопределено;
				КонецПопытки;
				
				Если НЕ ФлагСоздаватьПРМ Тогда
					//++Данилова Е.В. 10.01.2025 закомментировала
					//Если ПроводимоеРНК.ПунктДоставки.ВидыДопОбработок.Количество() = 0 Тогда
					//	Для Каждого СтрокаТЧ Из ПроводимоеРНК.Контрагент.ВидыДопОбработок Цикл
					//		СтрокаДО = ПроводимоеРНК.ДопОбработки.Добавить();	
					//		СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
					//	КонецЦикла;
					//Иначе
					//	Для Каждого СтрокаТЧ Из ПроводимоеРНК.ПунктДоставки.ВидыДопОбработок Цикл
					//		СтрокаДО = ПроводимоеРНК.ДопОбработки.Добавить();	
					//		СтрокаДО.ВидДопОбработки = СтрокаТЧ.ДопОбработка;
					//	КонецЦикла;
					//КонецЕсли;
					
					Если ПроводимоеРНК.ПунктДоставки.ТипДоставки = Перечисления.ТипыДоставки.Перегруз или ПроводимоеРНК.ПунктДоставки.ТипДоставки = Перечисления.ТипыДоставки.Самовывоз тогда
						ПроводимоеРНК.АдресПерегруза = ПроводимоеРНК.ПунктДоставки.АдресАнтор;
					КонецЕсли;
					
				КонецЕсли;
				
				Попытка
					ПроводимоеРНК.Записать(РежимЗаписиДокумента.Проведение);
					ПроводимоеРНК.Разблокировать();
				Исключение
					СообщитьИзМодуля("Не могу провести " + Строка(ПроводимоеРНК));
					Если ТранзакцияАктивна() тогда 
						//Валетов + ПУСТАЯ ЗАДАЧА. Разблокируем объект, даже если отменяем транзакцию
						Попытка
							Если ПроводимоеРНК.Заблокирован() Тогда
								ПроводимоеРНК.Разблокировать();
							КонецЕсли;    
						Исключение 
							//Ничего не заблокировано, разблокировать нечего
						КонецПопытки;
						//Валетов -
						
						ОтменитьТранзакцию();
					КонецЕсли; 
					
					Возврат неопределено;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
		
	КонецЕсли;
	
	
	ПараметрыСеанса.ЗапущенаОбработка = Ложь;
	
	Возврат Истина; 
	
КонецФункции

Функция ПроверкаОстатковЛокальная(МассивСсылок)  Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДополнительныеСклады.Склад КАК Склад
	|ПОМЕСТИТЬ Склады
	|ИЗ
	|	Документ.Заказ.ДополнительныеСклады КАК ДополнительныеСклады
	|ГДЕ
	|	ДополнительныеСклады.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заказ.Склад
	|ИЗ
	|	Документ.Заказ КАК Заказ
	|ГДЕ
	|	Заказ.Ссылка В(&МассивСсылок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Склады.Склад КАК Склад
	|ИЗ
	|	Склады КАК Склады";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивСкладов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	УстановитьПривилегированныйРежим(Ложь);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказДополнительныеДвижения.Количество) КАК Количество,
	|	ЗаказДополнительныеДвижения.Склад КАК Склад
	|ПОМЕСТИТЬ ТЗЗаказа
	|ИЗ
	|	Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|ГДЕ
	|	ЗаказДополнительныеДвижения.Ссылка В (&МассивСсылок)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказДополнительныеДвижения.Номенклатура,
	|	ЗаказДополнительныеДвижения.Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РезервыТМЦ.Склад КАК Склад,
	|	РезервыТМЦ.Номенклатура КАК Номенклатура,
	|	СУММА(РезервыТМЦ.Количество) КАК Количество
	|ПОМЕСТИТЬ ТЗРезервовЗаказа
	|ИЗ
	|	РегистрНакопления.РезервыТМЦ КАК РезервыТМЦ
	|ГДЕ
	|	РезервыТМЦ.Регистратор В (&МассивСсылок)
	|
	|СГРУППИРОВАТЬ ПО
	|	РезервыТМЦ.Склад,
	|	РезервыТМЦ.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, РезервыТМЦОстатки.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Склад, РезервыТМЦОстатки.Склад) КАК Склад,
	|	СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(ТЗРезервовЗаказа.Количество, 0)) КАК Остаток
	|ПОМЕСТИТЬ ТЗОстатков
	|ИЗ
	|	РегистрНакопления.ОстаткиТМЦ.Остатки(
	|			&Дата,
	|			Склад В (&МассивСкладов)
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура
	|					ИЗ
	|						Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|					ГДЕ
	|						ЗаказДополнительныеДвижения.Ссылка В (&МассивСсылок))) КАК ОстаткиТМЦОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|				,
	|				Склад В (&МассивСкладов)
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							ЗаказДополнительныеДвижения.Номенклатура КАК Номенклатура
	|						ИЗ
	|							Документ.Заказ.ДополнительныеДвижения КАК ЗаказДополнительныеДвижения
	|						ГДЕ
	|							ЗаказДополнительныеДвижения.Ссылка В (&МассивСсылок))) КАК РезервыТМЦОстатки
	|		ПО ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|			И ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗРезервовЗаказа КАК ТЗРезервовЗаказа
	|		ПО ОстаткиТМЦОстатки.Склад = ТЗРезервовЗаказа.Склад
	|			И ОстаткиТМЦОстатки.Номенклатура = ТЗРезервовЗаказа.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Номенклатура, РезервыТМЦОстатки.Номенклатура),
	|	ЕСТЬNULL(ОстаткиТМЦОстатки.Склад, РезервыТМЦОстатки.Склад)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗЗаказа.Номенклатура КАК Номенклатура,
	|	ТЗЗаказа.Количество КАК Количество,
	|	ТЗЗаказа.Склад КАК Склад,
	|	ЕСТЬNULL(ТЗОстатков.Остаток, 0) КАК Остаток
	|ИЗ
	|	ТЗЗаказа КАК ТЗЗаказа
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗОстатков КАК ТЗОстатков
	|		ПО ТЗЗаказа.Номенклатура = ТЗОстатков.Номенклатура
	|			И ТЗЗаказа.Склад = ТЗОстатков.Склад
	|ГДЕ
	|	ЕСТЬNULL(ТЗОстатков.Остаток, 0) < 0
	|";			  
	
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());	 
	
	Ошибки = "";
	МассивОшибок = Новый Массив;
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Результат.Следующий() Цикл
		МассивОшибок.Добавить("По номенклатуре " + Результат.Номенклатура + ", на складе " + Результат.Склад + " недостаточно товара. На остатках - " + Результат.Остаток + " , требуется " + Результат.Количество);
	КонецЦикла;
	
	Если МассивОшибок.Количество() > 0 тогда
		Ошибки = СтрСоединить(МассивОшибок,Символы.ПС);
	КонецЕсли;
	
	Возврат Ошибки;
	
КонецФункции

Функция КорректироватьПоОстаткам(ДокОбъект) Экспорт
	
	КэшОстатков="";
	
	ФлагФизСклад = Ложь;
	КэшОстатков = Новый Соответствие; 	 
	флагОшибки=ложь; 	
		
	
	Если ДокОбъект.СостояниеНакладной <>  перечисления.СостоянияЗаказаКонтрагента.ВРаботе тогда			
				
		Сообщить("В заказе состояние заказа отлично от (В работе)");
		Возврат неопределено; 
				
	КонецЕсли;	
			
	МассивРабочихЗаказов = Новый Массив; 	
	МассивРабочихЗаказов.Добавить(ДокОбъект.ссылка); 
	
	МассивДополнительныхСкладов = новый массив;	 			 
	Для каждого СтрДопСклада из ДокОбъект.дополнительныеСклады цикл
		
		МассивДополнительныхСкладов.Добавить(СтрДопСклада.склад);        				 
		
	КонецЦикла;	
	//++Данилова Е.В. 17.04.2025 HELP-4400
	Если ЗначениеЗаполнено(ДокОбъект.СкладМаркировки) Тогда
		
		МассивДополнительныхСкладов.Добавить(ДокОбъект.СкладМаркировки);	
		
	КонецЕсли;	
	//--Данилова Е.В. 17.04.2025
	
	ПолучитьОстатки(ДокОбъект.товары.выгрузитьКолонку("номенклатура"),ДокОбъект.Склад,МассивРабочихЗаказов,КэшОстатков, ФлагФизСклад = Ложь,МассивДополнительныхСкладов); 
	
	Для Каждого СтрМассТовары из ДокОбъект.товары Цикл
		
		Если КэшОстатков.Получить(СтрМассТовары.Номенклатура) = Неопределено Тогда
			СтрМассТовары.Количество = 	0;
		Иначе	
			Если КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток >= СтрМассТовары.ПодтвержденнаяЗаявка тогда
				СтрМассТовары.количество = 	СтрМассТовары.подтвержденнаяЗаявка;						
				КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток= КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток  - СтрМассТовары.ПодтвержденнаяЗаявка; 					 
			ИНАЧЕ
				СтрМассТовары.количество = КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток;						
				КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток = КэшОстатков.Получить(СтрМассТовары.номенклатура).СвободныйОСтаток - СтрМассТовары.ПодтвержденнаяЗаявка; 					 
			КонецЕсЛИ
		КонецЕсли;
		
		РассчитатьСуммуТабЧасти(СтрМассТовары, ДокОбъект);
		
	КонецЦикла;
	
	Возврат Истина; 
		
	
	
КонецФункции

Функция ИсключающееИЛИ(Массив1, Массив2)  Экспорт   
	Результат = Новый Массив;    
	Повтор = Новый Соответствие;    
	Для каждого Элемент Из Массив1 Цикл
		Повтор[Элемент] = ?(Повтор[Элемент] = Неопределено, Ложь, Истина)
	КонецЦикла;    
	Для каждого Элемент Из Массив2 Цикл
		Повтор[Элемент] = ?(Повтор[Элемент] = Неопределено, Ложь, Истина)
	КонецЦикла;    
	Для каждого Элемент Из Повтор Цикл
		Если НЕ Элемент.Значение Тогда
			Результат.Добавить(Элемент.Ключ)
		КонецЕсли 
	КонецЦикла;    
	Возврат Результат
КонецФункции

Функция КорректироватьПоОстаткамПоМассивуСсылок(МассивСсылок) Экспорт
	КэшОстатков="";
	
	ФлагФизСклад 	= Ложь;
	КэшОстатков 	= Новый Соответствие; 	 
	флагОшибки		=	ложь;
	
	Результат = Истина; 
	
	Если МассивСсылок.Количество() = 0 тогда 
		Сообщить("Список заказов пуст!");
	ИНаче
		Таблица = новый ТаблицаЗначений;
		Таблица.Колонки.Добавить("Склад",Новый ОписаниеТипов("СправочникСсылка.Склады"));
