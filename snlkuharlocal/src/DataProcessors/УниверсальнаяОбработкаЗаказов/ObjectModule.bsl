	//	
	//Возврат Перемещение;
	НачатьТранзакцию(); 
	МассивПеремещений = Новый Массив; 
	Если ТаблицаКзагрузкеСОбСкладов.Количество() > 0  Тогда
		
		Перемещение = ЗаполнениеДокументов.СоздатьПеремещение(,ТаблицаКзагрузкеСОбСкладов,
		Склад, СкладПолучатель, КомментарийКПРМ, ДополнительныеРеквизиты, Ложь, Истина);
		
		МассивПеремещений.Добавить(Перемещение); 
		
	КонецЕсли;
	
	Если ТаблицаКзагрузкеМаркСкладов.Количество() > 0  Тогда
		
		Перемещение = ЗаполнениеДокументов.СоздатьПеремещение(,ТаблицаКзагрузкеМаркСкладов,
		СкладМаркировка, СкладПолучательМаркировка, КомментарийКПРМ, ДополнительныеРеквизиты, Ложь, Истина);
		
		МассивПеремещений.Добавить(Перемещение);
	КонецЕсли;
	
	Если  ТранзакцияАктивна() Тогда
	
		ЗафиксироватьТранзакцию();	
	
	КонецЕсли;
	
	Возврат МассивПеремещений; 

