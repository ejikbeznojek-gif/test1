		МассивДопСклада = МассивСсылок.Получить(0).ДополнительныеСклады.выгрузитьколонку("Склад");
		
		
		Для каждого Строчка из МассивСсылок цикл			
			СтрокаТаблицы = 	Таблица.Добавить();	
			
