Функция СоздатьОбновитьДокументы(ДеревоДокументов, СтруктураСтатистики, МассивДокументовДляПроведения, МассивЗагруженныхДокументов)
	
	
	// создание документов Заказ.
	//!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!+++++++!!!!!!!!
	
	
	Успешно = Истина;
	//сообщить("------------- создать оюновить документы");
	Для Каждого Док Из ДеревоДокументов.Строки Цикл
		
		НовыйДокумент = Истина;
		ПризнакПроведения=Док.РанееЗагруженныйДокументСсылка.Проведен;
		
		Попытка
			ДокЗагруженныйОб = Док.РанееЗагруженныйДокументСсылка.получитьОбЪект();
		Исключение
			ДокЗагруженныйОб =неопределено;
		КонецПопытки;
		
		Если ДокЗагруженныйОб <> неопределено Тогда
			
			НовыйДокумент=ложь;
			
		КонецЕсли;	
		
		
		// если не 3 статуса, тогда только обновляем статусы на сайте, номенклатуру, документы не перезаписываем!!!
		ТаблицаСтрок=Док.строки;  
		// тут все параметры считаны, доп. реквизиты.
		Обновлять=Ложь;   
		
		//--------------------------------------------------------------------------
		СтатусЗаказа=""; // имя колонки
		
		НайденнаяСтрока = ТаблицаСтрок.Найти("Статуса заказа ИД", "СвойствоНаименование");
		
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			СтатусЗаказа = СокрЛП(НайденнаяСтрока.СвойствоЗначение);
		КонецЕсли;
		
		//--------------------------------------------------------------------------
		НайденнаяСтрока = ТаблицаСтрок.Найти("Статус заказа", "СвойствоНаименование");
		ЗначениеСтатуса=Неопределено;
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			ЗначениеСтатуса = НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		//--------------------------------------------------------------------------
		// "Комментарии покупателя"
		КомментарииПокупателя = "";
		НайденнаяСтрока = ТаблицаСтрок.Найти("Комментарии покупателя", "СвойствоНаименование");
		
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			КомментарииПокупателя = СокрЛП(НайденнаяСтрока.СвойствоЗначение);
		КонецЕсли;
		Если новыйДокумент Тогда
			Док.ДокументОбъект.комментарий = КомментарииПокупателя;
		КонецЕсли;
		
		//----------------------------------------------------------------------
		// пока для подстраховки
		//"Отменен"
		ЗаказОтменен = ложь; // имя колонки
		
		НайденнаяСтрока = ТаблицаСтрок.Найти("Отменен", "СвойствоНаименование");
		
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			ЗаказОтменен = СокрЛП(НайденнаяСтрока.СвойствоЗначение);
			Если ЗаказОтменен Тогда
				СтатусЗаказа = "D"
			конецЕсли;	
		КонецЕсли;
		ЕстьИзмененияСтатуса = истина;
		// проверим , что есть изменения статуса, тогда меняем данные
		Если не НовыйДокумент ТОгда
			Если СтатусЗаказа = "D" и 
				(Док.РанееЗагруженныйДокументСсылка.состояниеСогласования = перечисления.СостоянияСогласования.ОтмененКонтрагент или 
				Док.РанееЗагруженныйДокументСсылка.состояниеСогласования = перечисления.СостоянияСогласования.ОтмененЦО) ТОгда
				
				СтруктураСтатистики.Пропущено = СтруктураСтатистики.Пропущено + 1;
				ЕстьИзмененияСтатуса = ложь;  // для уже отмененных и отмеченных дальше ничего не делаем
				
				продолжить;
				
			КонецЕсли;
			
		КонецЕсли;
		
		
		// все равно нужно загрузить, иначе битрикс его до бесконечности будет отправлять
		Если НовыйДокумент и  СтатусЗаказа = "D" ТОгда
			
			
			Док.ДокументОбъект.состояниеСогласования = перечисления.СостоянияСогласования.ОтмененКонтрагент;
			
		КонецЕсли;	
		
		
		//-----------------------------------------------
		
		НеПерезаписывать= ложь; ///   Док.РанееЗагруженныйДокументСсылка.БольшеНеПерезаписыватьДокумент;
		Если ЗначениеСтатуса<>Неопределено Тогда
			Если СтрЧислоВхождений(ЗначениеСтатуса, "[A]")>0  или СтрЧислоВхождений(ЗначениеСтатуса, "[N]")>0 
				или СтрЧислоВхождений(ЗначениеСтатуса, "[D]")>0  или СтрЧислоВхождений(ЗначениеСтатуса, "[P]")>0
				Тогда
				Обновлять=Истина;
			КонецЕСли;
		КонецЕсли;
		
		// d B P только статусы меняем и все.
		//--------------------------------------------------------------------------------------------
		Если СтатусЗаказа = "D" и не НовыйДокумент Тогда
			попытка
				ДокРанееЗагр = ДокЗагруженныйОб;
				ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.ОтмененКонтрагент;
				ДокРанееЗагр.записать();
				
				СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
				НовыйДокумент = Ложь;
				
				Если ПризнакПроведения Тогда
					
					МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект.ссылка);
					
				КонецЕсли;	
				
				продолжить;
			исключение
				//	сообщить(ОписаниеОшибки());
			конецпопытки;
		КонецЕсли;	
		
		//*************************************************
		//попытка
		Если СтатусЗаказа = "P" и Док.РанееЗагруженныйДокументСсылка.состояниеСогласования <> перечисления.СостоянияСогласования.Согласован и не НовыйДокумент Тогда
			попытка
				ДокРанееЗагр = ДокЗагруженныйОб;
				ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.Согласован;
			исключение
				
				
			конецПопытки;
			
		КонецЕсли;	
		//***********************************************
		
		Если (СтатусЗаказа = "A") и НЕ НовыйДокумент Тогда      //    			
			ДокРанееЗагр = ДокЗагруженныйОб;
			//ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.ОтправленКонтаргенту; 
			ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.НаСогласованииКонтрагент;
			ДокРанееЗагр.записать();
			СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
			
			Если ПризнакПроведения Тогда
				
				МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект.ссылка);
				
			КонецЕсли;	
			
			продолжить;
			
		КонецЕсли;	
		
		///   тут запись документов
		Если (СтатусЗаказа = "N") и НЕ НовыйДокумент Тогда    			
			
			ДокРанееЗагр = ДокЗагруженныйОб; 
			ДокРанееЗагр.состояниеСогласования = перечисления.СостоянияСогласования.НаСогласованииЦО;
			
			
		КонецЕсли;	
		
		
		
		// --------------------------------------------------------------------------------------------
		// отладка	
		//	сообщить(""+Док.ДокументОбъект.НомерВходящегоДокументаЭлектронногоОбмена+"  "+Значение+"   "+Док.РанееЗагруженныйДокументСсылка+"  "+Обновлять);
		
		//-----------------------------------------------------------------------------
		Если Не Обновлять или НеПерезаписывать Тогда
			продолжить;
		КонецЕсли;	
		//-----------------------------------------------------------------------------
		
		
		// если на документ есть ссылки, то он вообще пропускается и не загружается  !!!
		Если Док.ЕстьСсылкиНаРанееЗагруженныйДокумент Тогда
			СтруктураСтатистики.Пропущено = СтруктураСтатистики.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Док.РанееЗагруженныйДокументСсылка) Тогда
			СтруктураСтатистики.Обновлено = СтруктураСтатистики.Обновлено + 1;
			НовыйДокумент = Ложь;
		Иначе
			СтруктураСтатистики.Создано   = СтруктураСтатистики.Создано + 1;
		КонецЕсли;	
		
		Попытка
			
			// отдельная работа с комментарием
			Если Не ПустаяСтрока(Док.ДокументОбъект.Комментарий) Тогда
				Попытка
					СтрокаИмениСайта = Док.Строки.Найти("Сайт", "СвойствоНаименование");
					Если СтрокаИмениСайта = Неопределено Тогда
						ИмяСайта = HTTPОбменСервер;
					Иначе					
						ИмяСайта = СтрокаИмениСайта.СвойствоЗначение;
					КонецЕсли;
					Док.ДокументОбъект.Комментарий   = Док.ДокументОбъект.Комментарий ; //+ " " + ИмяСайта;
				Исключение
				КонецПопытки;
			КонецЕсли;
			
			
			
			Если НЕ НовыйДокумент Тогда
				
				// ранее загруж. пересчитаем
				
				ПересчетТЧ(ДокЗагруженныйОб,"Товары",Рубли,Рубли,1,1,Истина); 
				
			Иначе
				// это новый документ    ++++++++++
				УстановитьНомерДокумента2(Док.ДокументОбъект);
				пп=1;
				
				Док.ДокументОбъект.СостояниеНакладной = Перечисления.СостоянияЗаказаКонтрагента.ВРаботе;
				
				// статус тут прописывать?!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
				
				
				//-------------------------------------
				ПересчетТЧ(Док.ДокументОбъект,"Товары",Рубли,Рубли,1,1,Истина); 
				
			КонецЕсли;	
			
			Если новыйДокумент тогда
				Попытка
					
					Док.ДокументОбъект.дата = текущаядата();
					Док.ДокументОбъект.Записать(); // ???? Зачем новый записывать, 
					
					
				Исключение
					СообщитьОбИсключительнойОшибке(Ложь,""+ Док.ДокументОбъект+ ОписаниеОшибки());
					ЗаписатьВЛог("ОбменССайтом",""+ Док.ДокументОбъект+ОписаниеОшибки(),"");
					Возврат Ложь;
				конецПопытки;
				
				
				Если ПризнакПроведения Тогда
					
					МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект.ссылка);
					
				КонецЕсли;	
			Иначе	
				попытка
					ДокЗагруженныйОб.записать();
				исключение
					СообщитьОбИсключительнойОшибке(Ложь,""+ДокЗагруженныйОб+ ОписаниеОшибки());
					ЗаписатьВЛог("ОбменССайтом",""+ ДокЗагруженныйОб +ОписаниеОшибки(),"");
					Возврат Ложь;
				конецПопытки;
				
			конецЕсли;
			
			
			
			//*********************************************			
			
			//	Если ПризнакПроведения и НЕ Док.ДокументОбъект.ПометкаУдаления  ТОгда
			//		
			//		//МассивДокументовДляПроведения.Добавить(Док.ДокументОбъект);
			//		Попытка
			//			Док.ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
