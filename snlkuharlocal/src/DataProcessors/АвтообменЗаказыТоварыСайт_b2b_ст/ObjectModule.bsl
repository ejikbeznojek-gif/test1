Процедура ВыгрузитьБазовыеРеквизитыТабличнойЧастиТоваров(ОбъектXML, Выборка, ИдКаталога)
	
	
	ЗаписатьТекстовойУзел(ОбъектXML, "ЦенаЗаЕдиницу",    Выборка.ЦенаИсточник); // цена
	
	Если Выборка.Заявка>0 Тогда
		ЗаписатьТекстовойУзел(ОбъектXML, "Количество",       Выборка.Заявка);  
	иначе
		ЗаписатьТекстовойУзел(ОбъектXML, "Количество",       Выборка.Количество);  
		
	конецЕсли;
	
	ЗаписатьТекстовойУзел(ОбъектXML, "Сумма",            Выборка.Сумма);
	ЗаписатьТекстовойУзел(ОбъектXML, "Единица",          СтрЗаменить(Выборка.Единица,".",""));
	ЗаписатьТекстовойУзел(ОбъектXML, "Коэффициент",      "1");	
	
	
