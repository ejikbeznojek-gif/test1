Процедура Договор_ПриИзменении2(ДокОбъект)
	
	Договор = ДокОбъект.договор;
	Док = ДокОбъект;
	//контроль менеджера
	Если НЕ Договор.Менеджер.Пустая() И НЕ Договор.Менеджер.Штатный Тогда
		//Предупреждение("Некорректный менеджер в договоре!");			
		Если НЕ РольДоступна("Администратор") Тогда
			Договор=Неопределено;		
		КонецЕсли;		
	КонецЕсли;
	
	Если НЕ Договор.Пустая() Тогда
		если Док.ЭтоНовый()	тогда
			если ЗначениеЗаполнено(Договор.ВидОплаты) тогда	
				Док.ВидОплаты=Договор.ВидОплаты;
				УстановитьНомерДокумента2(ДокОбъект);
			КонецЕсли;
		иначе
			если Договор.ВидОплаты<>Док.ВидОплаты и ЗначениеЗаполнено(Договор.ВидОплаты) тогда
				//сообщить("Не сопадают виды оплаты накладной и договора, договор не был изменён!");
				Договор=Док.Ссылка.ПолучитьОбъект().договор;
			КонецЕсли;
		КонецЕсли;
		
		
		Если Док.ТипЦен.Пустая() Тогда
			Док.ТипЦен		=Договор.ТипЦен;		
		КонецЕсли;
		Если Док.ОтсрочкаПлатежа<>Договор.ОтсрочкаПлатежа Тогда
			Если НЕ Док.ОтсрочкаПлатежа.Пустая() Тогда
				//	Предупреждение("Изменена отсрочка платежа",2);			
			КонецЕсли; 
			Док.ОтсрочкаПлатежа =Договор.ОтсрочкаПлатежа;
			//			Док.ОтсрочкаПлатежаПриИзменении();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Договор.Менеджер) Тогда
			Док.Менеджер=Договор.Менеджер;		
		Иначе
			Док.Менеджер=Док.Контрагент.Менеджер;
		КонецЕсли; 
		//Кухарь 15.03.16 начало
		//Чтобы подразделение поменять
		//	Менеджер_ПриИзменении();
		//Кухарь 15.03.16 конец
		
		//	ДатаПриИзменении(Элемент);
		
		Если ЗначениеЗаполнено(Договор.Организация) Тогда
			Док.Организация=Договор.Организация;
			//крохин начало
			Док.БанковскийСчет = Док.Организация.ОсновнойБанковскийСчет;
			//крохин конец
		КонецЕсли;
		
		
		// Нечаева +++ 27,02,13   берем из договора номер счета
		Если ЗначениеЗаполнено(Договор.РасчетныйСчетДляОплаты)  Тогда
			Док.БанковскийСчет = Договор.РасчетныйСчетДляОплаты;
		КонецЕсли;
		
		если Договор.ВалютаКредита<>Док.Валюта  тогда
			Док.Валюта=Договор.ВалютаКредита;
			//ОбнулитьЦеныВТабЧасти(Товары,ЭтотОбъект);
		КонецЕсли;
		
		
		//	ЗапросНаПересчетЦен();	
		
		Если Док.Контрагент.Ведущий.ТолькоПредоплата Тогда
			Док.ОтсрочкаПлатежа = Справочники.ОтсрочкиПлатежа.НайтиПоКоду("1");
			Док.ОтсрочкаПлатежаПриИзменении();
		КонецЕсли;
		
		
	КонецЕсли;	
	
	
	
КонецПроцедуры

Функция ОбработатьНачалоЭлемента(ОбъектCML, Знач ИмяЭлемента, ДеревоДокументов);
	
