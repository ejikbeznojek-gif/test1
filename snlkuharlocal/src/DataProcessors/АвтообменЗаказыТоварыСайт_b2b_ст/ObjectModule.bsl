Процедура СформироватьФайлыПоКонтрагентам2_ст(ПутьДляВыгрузки,безканаласбыта = истина,списокКонтрагентов,СтруктураИзменений)  
	
	ИмяФайлаВыгрузки = ПутьДляВыгрузки;
	
	ЗапросПД = новый Запрос;
	ЗапросПД.текст = "ВЫБРАТЬ
	|	ПунктыДоставки.Ссылка КАК Ссылка,
	|	ПунктыДоставки.Владелец КАК Владелец,
	|	ПунктыДоставки.Код КАК Код,
	|	ПунктыДоставки.Наименование КАК Наименование,
	|	ПунктыДоставки.ТраспортнаяКомпания КАК ТраспортнаяКомпания,
	|	ПунктыДоставки.ПочтовыйАдресДляДокументов КАК ПочтовыйАдресДляДокументов,
	|	ПунктыДоставки.ПочтовыйАдрес КАК ПочтовыйАдрес,
	|	ПунктыДоставки.ПунктПерегруза КАК ПунктПерегруза,
	|	ПунктыДоставки.Регион КАК Регион
	|ИЗ
	|	Справочник.ПунктыДоставки КАК ПунктыДоставки
	|ГДЕ
	|	ПунктыДоставки.ПометкаУдаления = ЛОЖЬ
	|	И ПунктыДоставки.Владелец.Ссылка В ИЕРАРХИИ(&текконтр)
	|	И ПунктыДоставки.Владелец.НеИспользовать = ложь
	|	И ПунктыДоставки.Владелец.Ведущий.ВыгружатьВИнтернетМагазин = &выгружать 
	|	И ПунктыДоставки.Владелец.ПометкаУдаления = ложь";
	ЗапросПД.УстановитьПараметр("текконтр", СписокКонтрагентов); // не интегральные
	ЗапросПД.УстановитьПараметр("выгружать", перечисления.ВыгружатьНаСайт.Да);
	
	РезультатПД = ЗапросПД.Выполнить().Выбрать();
	
	//------------------------------------------------------------------------------------------------
	// первый файл
	
	Запрос=Новый запрос;
	Запрос.Текст="ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты.Владелец КАК Владелец,
	|	Контрагенты.Код КАК Код,
	|	Контрагенты.Наименование КАК Наименование,
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.КПП КАК КПП,
	|	Контрагенты.ОсновнойБанковскийСчет КАК ОсновнойБанковскийСчет,
	|	ВЫРАЗИТЬ(Контрагенты.ЮридическийАдрес КАК СТРОКА(150)) КАК ЮридическийАдрес,
	|	Контрагенты.Менеджер КАК Менеджер,
	|	Контрагенты.Ведущий КАК Ведущий,
	|	Контрагенты.Ведущий.Код КАК ВедущийКод,
	|	Контрагенты.Ведущий.Наименование КАК ВедущийНаименование,
	|	Контрагенты.Ведущий.Менеджер КАК ВедущийМенеджер,
	|	Контрагенты.Ведущий.КодЦБ КАК ВедущийКодЦБ,
	|	ВЫРАЗИТЬ(Контрагенты.Менеджер.ЕМэйл КАК СТРОКА(100)) КАК МенеджерЕМэйл,
	|	ВЫРАЗИТЬ(Контрагенты.Ведущий.ЕМэйл1 КАК СТРОКА(100)) КАК ВедущийЕМэйл1,
	|	ВЫРАЗИТЬ(Контрагенты.Ведущий.ЕМэйл2 КАК СТРОКА(100)) КАК ВедущийЕМэйл2,
	|	ВЫРАЗИТЬ(Контрагенты.Ведущий.Телефоны КАК СТРОКА(100)) КАК ВедущийТелефоны,
	|	ВЫРАЗИТЬ(Контрагенты.ПолноеНаименование КАК СТРОКА(100)) КАК ПолноеНаименование,
	|	Контрагенты.ОГРН КАК ОГРН,
	|	ВЫРАЗИТЬ(Контрагенты.Телефоны КАК СТРОКА(100)) КАК Телефоны,
	|	Контрагенты.ОсновнойБанковскийСчет.Банк КАК ОсновнойБанковскийСчетБанк,
	|	Контрагенты.ОсновнойБанковскийСчет.НомерСчета КАК ОсновнойБанковскийСчетНомерСчета,
	|	Контрагенты.ОсновнойБанковскийСчет.Банк.Код КАК ОсновнойБанковскийСчетБанкБИК,
	|	Контрагенты.ОсновнойБанковскийСчет.Банк.КоррСчет КАК ОсновнойБанковскийСчетБанкКоррСчет,
	|	Контрагенты.КаналСбыта1.Код КАК КаналСбыта1Код,
	|	Контрагенты.КаналСбыта.Ссылка КАК КаналСбытаСсылка,
	|	Контрагенты.КаналСбыта1 КАК КаналСбыта1,
	|	Контрагенты.НеИспользовать КАК НеИспользовать
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка В ИЕРАРХИИ(&текконтрагент)
	|	И Контрагенты.ПометкаУдаления = ЛОЖЬ
	|	И Контрагенты.НеИспользовать = ЛОЖЬ
	|	И Контрагенты.Ведущий.ВыгружатьВИнтернетМагазин = &выгружать";
	
	
	Запрос.УстановитьПараметр("текконтрагент", СписокКонтрагентов);
	Запрос.УстановитьПараметр("выгружать", перечисления.ВыгружатьНаСайт.Да);
	
	РезультатЗапрос = Запрос.Выполнить();
	Выборка         = РезультатЗапрос.Выбрать();
	
	/////////////////////////////////////////////////////////////////////////////
