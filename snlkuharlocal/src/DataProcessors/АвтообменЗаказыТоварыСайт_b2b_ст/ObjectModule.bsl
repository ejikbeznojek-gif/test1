Функция ПолучитьПоСтруктуреСтрокиСФИО(СтруктураДанныхКонтрагента)
	
	ТекущаяСтрока = "";
	Фамилия = "";
	Имя = "";
	Отчество = "";
	
	СтруктураДанныхКонтрагента.Свойство("Фамилия", Фамилия);
	СтруктураДанныхКонтрагента.Свойство("Имя", Имя);
	СтруктураДанныхКонтрагента.Свойство("Отчество", Отчество);
	
	Если ЗначениеЗаполнено(Фамилия) Тогда
		ТекущаяСтрока = Фамилия;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Имя) Тогда
		ТекущаяСтрока = СокрЛП(ТекущаяСтрока + " " + Имя);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отчество) Тогда
		ТекущаяСтрока = СокрЛП(ТекущаяСтрока + " " + Отчество);
	КонецЕсли;
	
	Возврат ТекущаяСтрока;
	
КонецФункции


Функция ОпределитьВидНоменклатурыПоТипу(ТипНоменклатуры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|ВидыНоменклатуры.Ссылка КАК ВидНоменклатуры
	|ИЗ
	|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|ГДЕ
	|	ВидыНоменклатуры.ТипНоменклатуры = &ТипНоменклатуры
	|";
	Запрос.УстановитьПараметр("ТипНоменклатуры", ТипНоменклатуры);	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат РезультатЗапроса.Выгрузить()[0].ВидНоменклатуры;
	
КонецФункции

Функция ИнициализироватьВидыНоменкалтуры()
	
	Если ЗначениеЗаполнено(мВидНоменклатурыТовар)
		И ЗначениеЗаполнено(мВидНоменклатурыУслуга) Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	мВидНоменклатурыТовар = Перечисления.ВидыНоменклаутры.Товар;
	мВидНоменклатурыУслуга = Перечисления.ВидыНоменклаутры.Услуга;	
	
	Если ЗначениеЗаполнено(мВидНоменклатурыТовар)
		И ЗначениеЗаполнено(мВидНоменклатурыУслуга) Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(мВидНоменклатурыТовар) Тогда
		
		СообщитьПользователю("Не удалось найти вид номенклатуры: Товар", Ложь);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(мВидНоменклатурыУслуга) Тогда
		
		СообщитьПользователю("Не удалось найти вид номенклатуры: Услуга", Ложь);
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

//// Распределяет заданную сумму по выбранной колонке 
////
//// Параметры: 
////  ИмяКолонки         - cтрока, имя колонки, по которой распределяется сумма ("Количество" или "Сумма");
////  СуммаРаспределения - число, распределяемая сумма
////
////
Процедура РаспределитьСуммуПоКолонке(ДокументОбъект, Товары, ИмяТабЧасти, СуммаРаспределения)	
	
	МассивДанныхКолонки = Товары.ВыгрузитьКолонку("Сумма");
	
	МассивРаспределения = ПроцедурыОбменаССайтом.РаспределитьПропорционально(СуммаРаспределения, МассивДанныхКолонки);
	
	Если МассивРаспределения = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	мТекущийПользователь = ПараметрыСеанса.Пользователь; //глЗначениеПеременной("глТекущийПользователь");
	
	Индекс = 0;
	Для каждого СтрокаТабличнойЧасти Из Товары Цикл
		
		СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Сумма + МассивРаспределения[Индекс];
		//ОбработкаТабличныхЧастей.ПриИзмененииСуммыТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект, мТекущийПользователь ,,истина, ,истина, ИмяТабЧасти);
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
КонецПроцедуры


//// тут заполняются по строкам товары и меняются значения в загруженных документах.

Функция ИдентифицироватьНоменклатуру(ДеревоДокументов)
	//возврат ложь;
	
	//++++++++++++++++++++++++++++++++++++++++
	//	сообщить("------------ идентифицировать номенклатуры");
	Успешно = Истина;
	ЕстьИзмененияДок = ложь;
	Успешно = ИнициализироватьВидыНоменкалтуры();
	
	Если НЕ Успешно Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	
	ТЗТОваровССайта = Новый ТаблицаЗначений;
	ТЗТОваровССайта.колонки.Добавить("Номенклатура");
	
	
	Для Каждого СтрокаДД Из ДеревоДокументов.Строки Цикл
		
		//Если СтрокаДД.ЕстьСсылкиНаРанееЗагруженныйДокумент Тогда
		//	Продолжить;
		//КонецЕсли;	
		
		
		//*************************************************************************************
		// не грузим определененные параметры, не обновляем номенклатуру в этом случае.
		ТаблицаСтрок=СтрокаДД.строки;
		Обновлять=Ложь;                                                 // имя колонки
		НайденнаяСтрока = ТаблицаСтрок.Найти("Статус заказа", "СвойствоНаименование");
		Значение=Неопределено;
		Если НайденнаяСтрока = Неопределено Тогда
		Иначе
			Значение = НайденнаяСтрока.СвойствоЗначение;
		КонецЕсли;
		
		НеПерезаписывать= ложь;  //СтрокаДД.РанееЗагруженныйДокументСсылка.БольшеНеПерезаписыватьДокумент;
		
		Если Значение<>Неопределено Тогда
			Если СтрЧислоВхождений(Значение, "[A]")>0 или СтрЧислоВхождений(Значение, "[N]")>0 или СтрЧислоВхождений(Значение, "[P]")>0 Тогда
				Обновлять=Истина;
			КонецЕСли;
		КонецЕсли;
		//сообщить(""+СтрокаДД.ДокументОбъект.НомерВходящегоДокументаЭлектронногоОбмена+"  "+Значение+"   "+СтрокаДД.РанееЗагруженныйДокументСсылка+" --"+Обновлять);
		//-------------------------------------------------------------------------------------
		Если Не Обновлять или НеПерезаписывать Тогда
			продолжить;
		КонецЕсли;	
		//-------------------------------------------------------------------------------------
		//*************************************************************************************
		
		ОтобразитьСостояние("Идентификация товаров в документе: " + СтрокаДД.ДокументОбъект);
		СущДок = неопределено;
		колСтрокТоваровСущДок =0;
		Если не СтрокаДД.РанееЗагруженныйДокументСсылка.пустая() ТОгда
			СущДок = СтрокаДД.РанееЗагруженныйДокументСсылка.получитьОбъект();
			СтрокаИзСущДок=СущДок.Товары;
			КолСтрокТоваровСущДок = СущДок.товары.количество();
		КонецЕсли;
		
		
		Для Каждого ТоварУслугаСвойство Из СтрокаДД.Строки Цикл
			Номенклатура=Неопределено;
			Если ЗначениеЗаполнено(ТоварУслугаСвойство.СвойствоНаименование) Тогда
				Продолжить;
			КонецЕсли;
			
			ТипНоменклатурыCML = "";
			
			Для Каждого ПодчиненнаяСтрокаТовараУслуги Из ТоварУслугаСвойство.Строки Цикл
				
				Если ЗначениеЗаполнено(ПодчиненнаяСтрокаТовараУслуги.ЗначениеРеквизитаНаименование)
					И ПодчиненнаяСтрокаТовараУслуги.ЗначениеРеквизитаНаименование = ЗначениеCML_ТипНоменклатуры Тогда
					
					ТипНоменклатурыCML = ПодчиненнаяСтрокаТовараУслуги.ЗначениеРеквизитаЗначение;
					Прервать;
					
				КонецЕсли;	
				
			КонецЦикла;			
			
			ХарактеристикаНоменклатуры =Неопределено;  //Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
			СтавкаНДСНоменклатуры = ?(ЗначениеЗаполнено(ТоварУслугаСвойство.СтавкаНДС), ТоварУслугаСвойство.СтавкаНДС, СтрокаДД.СтавкаНДС);
			
			Если ТипНоменклатурыCML = ТипНоменклатурыCML_Услуга Тогда	
				Номенклатура = НайтиСоздатьНоменклатуру(ТоварУслугаСвойство, мВидНоменклатурыУслуга, СтавкаНДСНоменклатуры);
			Иначе
				Номенклатура = НайтиСоздатьНоменклатуру(ТоварУслугаСвойство, мВидНоменклатурыТовар, СтавкаНДСНоменклатуры, ХарактеристикаНоменклатуры);
				//++-++
			КонецЕсли;
			//*******************
			НовстрССайта = ТЗТОваровССайта.Добавить();
			НовстрССайта.Номенклатура = Номенклатура;
			//******************/
			//!!!! добавляем документ первый раз
			Если СтрокаДД.РанееЗагруженныйДокументСсылка.пустая() Тогда
				
				
				Если Номенклатура.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Услуга Тогда
					
					// добавляем в новый документ (обновляем старый)
					НовСтрока = СтрокаДД.ДокументОбъект.Услуги.Добавить();
					НовСтрока.Номенклатура = Номенклатура;
					НовСтрока.Единица 		     = Номенклатура.основнаяЕдиница; //.ЕдиницаХраненияОстатков;
					НовСтрока.Содержание   = Номенклатура.Наименование;
					НовСтрока.Количество   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.Заявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.ПодтвержденнаяЗаявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.Коэффициент      			 = Номенклатура.ОсновнаяЕдиница.Коэффициент;
					НовСтрока.СтавкаНДС    = ПолучитьСтавкуНДС(Номенклатура);
					НовСтрока.Сумма	= РассчитатьСуммуСУчетомСкидок(ТоварУслугаСвойство);
					НовСтрока.Скидка= ТоварУслугаСвойство.СуммаСкидки;
					
					
					СтавкаНДС=ПроцентНДСпоСтавке(НовСтрока.СтавкаНДС);
					НовСтрока.НДС	=НовСтрока.Сумма*СтавкаНДС/(1+СтавкаНДС);			
					НовСтрока.Всего	=НовСтрока.Сумма;
					НовСтрока.Сумма  =НовСтрока.Всего-НовСтрока.НДС;
					
					
				Иначе	
					// вид товар новый документ
					
					НовСтрока = СтрокаДД.ДокументОбъект.Товары.Добавить();
					НовСтрока.Номенклатура     			 = Номенклатура;
					НовСтрока.Единица 		     = Номенклатура.основнаяЕдиница; //.ЕдиницаХраненияОстатков;
					НовСтрока.Количество   	   	 = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.Заявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.ПодтвержденнаяЗаявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.Коэффициент      			 = Номенклатура.ОсновнаяЕдиница.Коэффициент;
					НовСтрока.СтавкаНДС    = ПолучитьСтавкуНДС(Номенклатура);
					НовСтрока.Сумма	= РассчитатьСуммуСУчетомСкидок(ТоварУслугаСвойство);
					НовСтрока.Скидка= ТоварУслугаСвойство.СуммаСкидки;
					НовСтрока.ЦенаИсточник = ТоварУслугаСвойство.ТоварУслугаЦенаЗаЕдиницу;
					
					//РассчитатьСуммуТабЧасти(НовСтрока, СтрокаДД.ДокументОбъект);
					//ОбработкаТабличныхЧастей.ПриИзмененииСуммыТабЧасти(НовСтрока, СтрокаДД.ДокументОбъект, глЗначениеПеременной("глТекущийПользователь"),,истина, ,истина, "Товары");
					//ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(НовСтрока, СтрокаДД.ДокументОбъект);
					//
				КонецЕсли;
				
			Иначе
				//!!!!! уже есть документ, нужно проверить откорректировать данные по документу
				// если на сайте обнулили, то строки этой в заказе нет.
				
				
				Если Номенклатура.ВидНоменклатуры = Перечисления.ВидыНоменклаутры.Услуга Тогда
					
					// услуги просто обновляем		
					
					НовСтрока = СтрокаДД.ДокументОбъект.Услуги.Добавить();
					НовСтрока.Номенклатура = Номенклатура;
					НовСтрока.Единица 		     = Номенклатура.основнаяЕдиница; //.ЕдиницаХраненияОстатков;
					НовСтрока.Содержание   = Номенклатура.Наименование;
					НовСтрока.Заявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.ПодтвержденнаяЗаявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
					НовСтрока.Коэффициент      			 = Номенклатура.ОсновнаяЕдиница.Коэффициент;
					НовСтрока.СтавкаНДС    = ПолучитьСтавкуНДС(Номенклатура);
					НовСтрока.Сумма	= РассчитатьСуммуСУчетомСкидок(ТоварУслугаСвойство);
					НовСтрока.Скидка= ТоварУслугаСвойство.СуммаСкидки;
					
					
					СтавкаНДС=ПроцентНДСпоСтавке(НовСтрока.СтавкаНДС);
					НовСтрока.НДС	=НовСтрока.Сумма*СтавкаНДС/(1+СтавкаНДС);			
					НовСтрока.Всего	=НовСтрока.Сумма;
					НовСтрока.Сумма  =НовСтрока.Всего-НовСтрока.НДС;
					
					
				Иначе
					
					// если вид товары и документ уже был загружен
					
					НайденнаяСтрока = СтрокаИзСущДок.Найти(Номенклатура, "Номенклатура");
					Если НайденнаяСтрока = Неопределено Тогда
						//тогда добавляем просто
						попытка
							НовСтрока = СтрокаДД.РанееЗагруженныйДокументСсылка.Товары.Добавить();
							НовСтрока.Номенклатура     	 = Номенклатура;
							НовСтрока.Единица 		     = Номенклатура.основнаяЕдиница; //.ЕдиницаХраненияОстатков;
							НовСтрока.ПодтвержденнаяЗаявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
							НовСтрока.Коэффициент      		 = Номенклатура.ОсновнаяЕдиница.Коэффициент;
							НовСтрока.СтавкаНДС    = ПолучитьСтавкуНДС(Номенклатура);
							НовСтрока.Сумма	= РассчитатьСуммуСУчетомСкидок(ТоварУслугаСвойство);
							НовСтрока.Скидка= ТоварУслугаСвойство.СуммаСкидки;
						исключение
							//	сообщить(ОписаниеОшибки());
						конецПопытки;
						
					Иначе
						//изменяем подтв. количество, общее количество -  не меняем
						Если  НайденнаяСтрока.ПодтвержденнаяЗаявка<> ТоварУслугаСвойство.ТоварУслугаКоличество ТОгда
							
							НайденнаяСтрока.ПодтвержденнаяЗаявка   = ТоварУслугаСвойство.ТоварУслугаКоличество;
							РассчитатьСуммуТабЧасти(НайденнаяСтрока, СущДок);
							
							ЕстьИзмененияДок = истина;
							
						КонецЕсли;						
						
						
					КонецЕсли;
					
					
				КонецЕсли;
				
				
				
			КонецЕсли;
			
			
			
		КонецЦикла;
		
		
		// смотрим не пропустили ли удаленные строки из заказа, их добавляем и обнуляем подтв. заявку и количество.???
		// Сравним общее количество строк.
		Если СущДок<>Неопределено Тогда
			Если  ТЗТОваровССайта.Количество()<> колСтрокТоваровСущДок  Тогда
				
				Таблица1= сущдок.товары.выгрузить();
				ТЗУдаленныеСтроки = РазницаТаблицЗначений(ТЗТОваровССайта, Таблица1, "Номенклатура");
				// обнулим строки
				Для каждого Текстрока из ТЗУдаленныеСтроки цикл
					
					НоменУд = Текстрока.Номенклатура;
					
					НайденнаяСтрока = СтрокаИзСущДок.Найти(НоменУд, "Номенклатура");
					Если НЕ НайденнаяСтрока = Неопределено   Тогда
						//изменяем подтв. количество, общее количество -  не меняем
						Если  НайденнаяСтрока.ПодтвержденнаяЗаявка<>0  Тогда						
							НайденнаяСтрока.ПодтвержденнаяЗаявка   = 0;
							РассчитатьСуммуТабЧасти(НайденнаяСтрока, СущДок);
							
							ЕстьИзмененияДок = истина;
							
						КонецЕсли;		
						
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;	
		
		Если  не СущДок = Неопределено  Тогда
			
			Если СтрЧислоВхождений(Значение, "[A]")>0 или СтрЧислоВхождений(Значение, "[N]")>0    Тогда
				СущДок.состояниеСогласования = перечисления.СостоянияСогласования.НаСогласованииЦО;
			КонецЕсли;	
			
			Если  СтрЧислоВхождений(Значение, "[P]")>0   Тогда
				СущДок.состояниеСогласования = перечисления.СостоянияСогласования.Согласован;
			КонецЕсли;	
		КонецЕсли;
		
		Если ЕстьИзмененияДок и не СущДок = Неопределено Тогда
			
			//СущДок.состояниеСогласования = перечисления.СостоянияСогласования.НаСогласованииЦО;
			попытка
				ПересчетТЧ(СущДок,"Товары",Рубли,Рубли,1,1,Истина); 
				СущДок.записать();
			исключение
				#если клиент тогда
					сообщить(""+ОписаниеОшибки());
				# конецЕсли
			конецПопытки;
			
		КонецЕсли;	
		
		
	КонецЦикла;	
	
	//Если ЕстьИзмененияДок и не СущДок = Неопределено Тогда
	//	
	//	//СущДок.состояниеСогласования = перечисления.СостоянияСогласования.НаСогласованииЦО;
	//	попытка
	//		ПересчетТЧ(СущДок,"Товары",Рубли,Рубли,1,1,Истина); 
	//		СущДок.записать(РежимЗаписиДокумента.Проведение);
	//	исключение
	//		#если клиент тогда
	//			сообщить(""+ОписаниеОшибки());
	//		# конецЕсли
	//	конецПопытки;
	//	
	//КонецЕсли;	
	//
	
	
	Возврат Успешно;
	
	
КонецФункции	

Функция РазницаТаблицЗначений(Таблица0, Таблица1, Измерения) 
	// возвращает удаленные товары в заказе на стороне сайта. (разница между двумя таблицами значений)
	
	ВсеКолонки = "";
	Для Каждого Колонка Из Таблица0.Колонки Цикл 
		ВсеКолонки = ВсеКолонки + ", " + Колонка.Имя
	КонецЦикла;
	ВсеКолонки = Сред(ВсеКолонки, 2);
	
	Таблица = Таблица1.Скопировать();    
	
	Таблица.Колонки.Добавить("Знак", Новый ОписаниеТипов("Число"));
	
	Таблица.ЗаполнитьЗначения(1, "Знак");
	
	Для Каждого Строка Из Таблица0 Цикл ЗаполнитьЗначенияСвойств(Таблица.Добавить(), Строка) КонецЦикла;
	
	Таблица.Колонки.Добавить("Счёт");
	Таблица.ЗаполнитьЗначения(1, "Счёт");
	
	Таблица.Свернуть(ВсеКолонки, "Знак, Счёт");
	
	Ответ = Таблица.Скопировать(Новый Структура("Счёт", 1), ВсеКолонки + ", Знак");
	
	Ответ.Сортировать(Измерения);
	
	Возврат Ответ
	
КонецФункции



Функция РассчитатьСуммуСУчетомСкидок(СтрокаТовара);
	
	Сумма 		= СтрокаТовара.ТоварУслугаСумма;
	ЦенаЗаЕдиницу 	= СтрокаТовара.ТоварУслугаЦенаЗаЕдиницу;
	СуммаСкидки = 0;
	
	Для Каждого СтрокаСкидки Из СтрокаТовара.Строки Цикл
		
		Если ЗначениеЗаполнено(СтрокаСкидки.СуммаСкидки)Тогда
			//И НЕ СтрокаСкидки.СкидкаВСумме Тогда
			
			СуммаСкидки = СуммаСкидки + СтрокаСкидки.СуммаСкидки;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Если СуммаСкидки>0 Тогда
		СтрокаТовара.СуммаСкидки=Окр((СуммаСкидки*100/(ЦенаЗаЕдиницу+СуммаСкидки)),0);
	Иначе
		СтрокаТовара.СуммаСкидки=0;
	КонецЕсли;	
	
	// Сумма = Сумма - СуммаСкидки;		
	Возврат Сумма;
	
КонецФункции

