Функция ПолучитьТК(Контр) Экспорт
	рез = неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПунктыДоставки.ТраспортнаяКомпания.Наименование КАК ТраспортнаяКомпанияНаименование
	|ИЗ
	|	Справочник.ПунктыДоставки КАК ПунктыДоставки
	|ГДЕ
	|	ПунктыДоставки.Владелец = &ТекКонтр
	|	И ПунктыДоставки.ПометкаУдаления = ложь";
	Запрос.УстановитьПараметр("ТекКонтр",контр);
	рез = запрос.Выполнить().Выгрузить();
	
	возврат рез;
	
конецФункции	

Функция ПолучитьПД(Контр) Экспорт
	рез = неопределено;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПунктыДоставки.Наименование КАК Наименование,
	|	ПунктыДоставки.Код КАК Код
	|ИЗ
	|	Справочник.ПунктыДоставки КАК ПунктыДоставки
	|ГДЕ
	|	ПунктыДоставки.Владелец = &ТекКонтр
	|	И ПунктыДоставки.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("ТекКонтр",контр);
	рез = запрос.Выполнить().Выгрузить();
	
	возврат рез;
	
конецФункции	

