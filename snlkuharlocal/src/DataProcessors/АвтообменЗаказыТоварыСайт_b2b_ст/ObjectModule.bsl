Функция ЗаполнитьНовинки()
	
	// получим все текущие новинки
	ТзТек = неопределено;
	
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспродажаТовары.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.Новинки.Новинки КАК РаспродажаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Новинки.ИнетМагазины КАК РаспродажаИМИнетМагазины
	|		ПО РаспродажаТовары.Ссылка = РаспродажаИМИнетМагазины.Ссылка
	|ГДЕ
	|	РаспродажаТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И РаспродажаТовары.Ссылка.КонецПериода >= &ТекДата
	|	И РаспродажаТовары.Ссылка.НачалоПериода <= &ТекДата
	|	И РаспродажаИМИнетМагазины.ИнетМагазин.Ссылка = &стильпарк";
	
	запрос.УстановитьПараметр("стильпарк",справочники.ИнетМагазины.НайтиПоКоду("00007")); // б2б
	запрос.УстановитьПараметр("текдата",ТекущаяДата());
	ТЗТек  = запрос.Выполнить().выгрузить();
	// нечаева 07,10,22+++
	// теепрь получим список моделей, т.к. выше заполняют еще и коллекциями
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.родитель.Ссылка КАК номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ложь
	|	И Номенклатура.ПометкаУдаления = ложь
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&тексписок)";
	
	запрос.УстановитьПараметр("тексписок", ТЗТек); // стильпарк
	запрос.УстановитьПараметр("текдата",ТекущаяДата());
	ТЗТек  = запрос.Выполнить().выгрузить();
	
	
	// нечаева 07,10,22---
	
	Возврат ТЗТек;
	
	
