//СтруктураИзменений
Функция  ВыполнитьОбменКонтрагентами(СтруктураИзменений)
	
	Успешно = истина;
	Если НЕ ОпределитьМожноВыгрузитьТовары() Тогда
		
		СообщитьПользователю("Выгрузка контрагентов не произведена.", Истина);
		Возврат Истина;
		
	КонецЕсли;
	
	
	Если ВыгружатьТолькоИзменения И НЕ мПринудительнаяПолнаяВыгрузка Тогда
		//  тут список контрагентов
		МассивИзменений = СтруктураИзменений.Контрагенты;
	
		Если МассивИзменений.Количество() = 0 Тогда
			
			СообщитьПользователю("Изменения контрагентов не зарегистрированы. Выгрузка контрагентов не произведена.", Истина); 
			Возврат Истина;
			
		КонецЕсли;	
		
	КонецЕсли;
	
	
	
	HTTPОбменАдресСкрипта = НачалоАдресаСкрипта;
	
	НомерНастройки = "034"; 
	//ЗаписатьВЛог("b2b"," Интернет-магазин. Начало выгрузки!","");
	
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	//Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом Тогда        
	//	ЗаписатьВЛог("b2b","Отмена выполнения. Задача: Обмен остатками. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
	//	Возврат;
	//КонецЕсли;
	
	мПринудительнаяПолнаяВыгрузка = ПроцедурыОбменаССайтом.ПолучитьФлагПринудительнойПолнойВыгрузки(НастройкаСсылка);
	мДатаФормирования = ТекущаяДата();
	мСтруктураИнформацииИсторииОбмена = ПолучитьСтруктуруИнформацииДляИстории();
	мСтруктураИнформацииИсторииОбмена.ДатаНачалаПоследнейВыгрузки = ТекущаяДата();
	мНомерВыгрузки = НомерНастройки;
	НастройкаСсылка= справочники.НастройкиОбменаССайтом.НайтиПоКоду(НомерНастройки);
	
	
	Если Настройкассылка.Пустая() Тогда
		ЗаписатьВЛог("b2b"," настройка не найдена - "+НомерНастройки,"Информация");
		возврат ложь;
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НастройкаСсылка); // заполяем параметры обработки данными.
	
	НачалоАдресаСкрипта = НастройкаСсылка.HTTPОбменАдресСайта;
	СтруктураАдреса = ПроцедурыОбменаССайтом.РазобратьАдресСайта(НачалоАдресаСкрипта);
	
	HTTPОбменПорт = СтруктураАдреса.HTTPПорт;
	HTTPОбменСервер = СтруктураАдреса.HTTPСервер;
	HTTPОбменЗащищенноеСоединение = СтруктураАдреса.HTTPЗащищенноеСоединение;
	НачалоАдресаСкрипта = СтруктураАдреса.HTTPАдресСкрипта;
	
	//	ЗаписатьВЛог("ОбменССайтом",""+HTTPОбменИмяПользователя+" + "+HTTPОбменПароль,"Инф");
	
	//Если ВыгружатьТолькоИзменения Тогда
	//	СтруктураИзменений = ПолучитьВсеИзмененияИзПланаОбмена();
	//КонецЕсли;
	
	
	Если ПустаяСтрока(КаталогВыгрузки) Тогда
		КаталогВыгрузки = КаталогВременныхФайлов(); //КаталогВременныхФайлов();
	Иначе
		ПоследнийСимвол = Сред(КаталогВыгрузки, СтрДлина(КаталогВыгрузки), 1);
		Если ПоследнийСимвол <> "\" Тогда
			КаталогВыгрузки = КаталогВыгрузки + "\";			
		КонецЕсли;
	КонецЕсли;
	
	мКаталогНаДиске = КаталогВыгрузки + мПодкаталогБезопасностиКаталогаВыгрузки+ "\";
	
	СоздатьКаталог(мКаталогНаДиске);
	
	ОчиститьКаталогНаДиске();
	
	СтруктураПараметровСайта = ПроцедурыОбменаССайтом.ПолучитьСтруктуруПараметровДляСоединения(ЭтотОбъект);
	КонтрагентыУспешноВыгружены = Истина;
	
	//------------------------------------------------------------------------------------------------------
	// сформируем для групп пользователей
	//-----------------------------   
	
	ОчиститьКаталогНаДиске();
	// времеенно для тестов
	СписокКонтрагентов = справочники.Контрагенты.НайтиПоКоду("SSP-5884");
	Если МассивИзменений.количество()>0 Тогда
		СписокКонтрагентов = МассивИзменений;
	КонецЕсли;	
	
	СформироватьФайлыПоКонтрагентам(мКаталогНаДиске,,СписокКонтрагентов,СтруктураИзменений,ВыгружатьТолькоИзменения);
	СформироватьФайлыПоКонтрагентам2(мКаталогНаДиске,,СписокКонтрагентов,СтруктураИзменений,ВыгружатьТолькоИзменения);
	ОсновныеДействияФормыГруппыПользователей(мКаталогНаДиске,СтруктураИзменений);
	
	
	СкопироватьВ_архив("Kontragent\"); 
	
	для пп=5 по 7 цикл
		ИмяК = ""+мКаталогНаДиске+МассивЗнИм[пп];
		//ПроцедурыОбменаССайтом.СкопироватьНаFTPКонтр(ИмяК,МассивЗнИм[пп],"users"); 
		ПроцедурыОбменаССайтом.СкопироватьНаFTP(ИмяК,МассивЗнИм[пп],"users"); 
	конецЦикла;
	
	
	//// выполним команду на загрузку файлов 
	//Отобразитьсостояние("Выполняем команду");
	//
	команда = "local/crons/import/index.php"; ////
	//КомандаЗагрузкиКонтр(СтруктураПараметровСайта,команда);
	
	ЗаписатьВЛог("b2b"," Выгрузка на фтп контрагентов закончена!","Инф");
	
	                        
	Возврат Успешно;
	
КонецФункции

