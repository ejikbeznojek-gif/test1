Функция ПолучитьСвойстваМодели(Модель)
	Запрос=Новый Запрос;
	Запрос.Текст="	
	|ВЫБРАТЬ	
	|	ВЫБОР
	|		КОГДА Объект=&Брэнд ТОГДА 1
	|		КОГДА Объект=&Модель ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК Уровень,
	|	Свойство,
	|	Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	Объект = &Модель ИЛИ Объект = &Брэнд
	|УПОРЯДОЧИТЬ ПО Уровень,Объект";	
	
	Свойства=Новый Структура;
	
	Запрос.УстановитьПараметр("Модель",Модель);
	Запрос.УстановитьПараметр("Брэнд",Модель.Родитель);
	
	Выборка=Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Попытка
			КодСвойства=СтрЗаменить(Выборка.Свойство,"""","");	
			КодСвойства=СтрЗаменить(Выборка.Свойство," ","");
			
			Свойства.Вставить(КодСвойства,Выборка.Значение);		
		Исключение
			СообщитьПользователю("Ошибочное свойство: "+Выборка.Свойство,,);
		КонецПопытки;		
	КонецЦикла;	
	
	Возврат Свойства;
КонецФункции //ПолучитьСвойстваНоменклатуры(Номенклатура) 

