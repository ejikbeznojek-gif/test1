Процедура Сформировать(ТаблицаПараметров=НЕОПРЕДЕЛЕНО) Экспорт
	
	
	ЗаписатьВЛог("b2b","Начало выполнения. Задача: 1 обмен номенкл, контрагентами. !","Информация");
	
	СтрокаСоединенияСразрешеннымОбменом            =ВРег(СокрЛП(Константы.СтрокаСоединенияИБ_АвтоматическийОбмен.Получить()));
	ТекСтрокаСоединения                            =ВРег(СокрЛП(СтрокаСоединенияИнформационнойБазы()));
	
	
	Если ТаблицаПараметров<>Неопределено Тогда
		Параметры=Новый Соответствие;
		Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
			ЗаписатьВЛог("b2b","Параметр: "+СтрокаТП.Имя+" - "+СтрокаТП.Значение,"Информация");		
			Параметры.Вставить(СтрокаТП.Имя,СтрокаТП.Значение);
		КонецЦикла;	
	КонецЕсли;
	
	//Кухарь А.Ю. 31.03.2026 начало
	// Если ТекСтрокаСоединения<>СтрокаСоединенияСразрешеннымОбменом тогда
	Если не ОбщегоНазначения_ПИ.ЭтоНеКопияАЖиваяБаза() тогда
		//Кухарь А.Ю. 31.03.2026 конец      
		ЗаписатьВЛог("b2b","Отмена выполнения. Задача: обмен ном, контраг b2b. Автообмен разрешен для базы: """+СтрокаСоединенияСразрешеннымОбменом+""", тек. база: """+ТекСтрокаСоединения+""" !","Информация");                     
		Возврат;
	КонецЕсли;
	
	//ЗаписатьВЛог("b2b","Начало выполнения. Задача: 2 обмен заказами. !","Информация");                     
	
	Если ПланыОбмена.Основной.ЭтотУзел() = ПланыОбмена.Основной.НайтиПоКоду("SNL") Тогда
		
		НомерНастройки = параметры.Получить("НомерНастройки");
		ЗаписатьВЛог("b2b","ном "+НомерНастройки,"Информация");
		
		ВыгрузитьДанные(); // 
		
	КонецЕсли;
	
	
	// теперь пропишем у уже загруженных заказов кода
	ЗаписатьВЛог("b2b","Конец выполнения. Задача: 3 Обмен номенкл, контрагентами. !","Информация");                     
	
	
КонецПроцедуры


