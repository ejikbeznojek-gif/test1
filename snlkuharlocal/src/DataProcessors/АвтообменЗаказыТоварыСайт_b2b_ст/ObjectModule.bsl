Функция ПроверитьВыгрузку(ТекНоменклатура)
	
	Выгружать=Ложь;
	
	
	Если (ТекНоменклатура.ВыгружатьВИнтернетМагазин = Перечисления.ВыгружатьНаСайт.Да) тогда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;	
	
	Выгружать1 = (ПолучитьРеквизитРодителя(ТекНоменклатура,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать1=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;	
	
	Выгружать2 = (ПолучитьРеквизитРодителя(ТекНоменклатура.Родитель,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать2=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;
	
	Выгружать3 = (ПолучитьРеквизитРодителя(ТекНоменклатура.Родитель.Родитель,"ВыгружатьВИнтернетМагазин") = Перечисления.ВыгружатьНаСайт.Да);
	Если Выгружать3=Истина ТОгда
		Возврат Истина;
	Иначе
		Если ТекНоменклатура.Родитель.Родитель.Родитель.ВыгружатьВИнтернетМагазин=Перечисления.ВыгружатьНаСайт.Нет Тогда
			Возврат Ложь;
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Выгружать;
	
