Функция ПолучитьЦену(Ном,ТипЦЕн)
	
	Цена=0;
	
	Запрос=новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Модель,
	|	ЦеныНоменклатурыСрезПоследних.ТипЦен КАК ТипЦен,
	|	ЦеныНоменклатурыСрезПоследних.Прайс.Дата КАК ДатаПрайса,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ПОМЕСТИТЬ Цены
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			{(&Дата2)},
	|			Прайс.Проведен
	|				И Прайс.Дата2 >= &Дата2 {(ТипЦен).*}) КАК ЦеныНоменклатурыСрезПоследних
	|ГДЕ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура В Иерархии (&ТекНом)
	|	И ЦеныНоменклатурыСрезПоследних.ТипЦен = &Тектипцен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Модель,
	|	ТипЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Цены.ДатаПрайса) КАК ДатаПрайса,
	|	Цены.Модель,
	|	Цены.ТипЦен
	|ПОМЕСТИТЬ Прайсы
	|ИЗ
	|	Цены КАК Цены
	|
	|СГРУППИРОВАТЬ ПО
	|	Цены.ТипЦен,
	|	Цены.Модель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Прайсы.Модель,
	|	Прайсы.ТипЦен,
	|	Цены.Цена
	|ИЗ
	|	Прайсы КАК Прайсы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены
	|		ПО (Цены.Модель = Прайсы.Модель)
	|			И (Цены.ТипЦен = Прайсы.ТипЦен)
	|			И (Цены.ДатаПрайса = Прайсы.ДатаПрайса)  ";
	
	Запрос.УстановитьПараметр("ТекНом",Ном);
	Запрос.УстановитьПараметр("Тектипцен",ТипЦен);
	Запрос.УстановитьПараметр("Дата2",ТекущаяДата());
	
	Рез=Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда
		Цена=Рез.Цена;
	КонецЕсли;	
	
	Возврат Цена;
	
КонецФункции		
