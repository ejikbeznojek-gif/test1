					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=0; ЧРГ=' '; ЧГ=3,0</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Накладная</dataPath>
			<field>Накладная</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Накладная</v8:content>
				</v8:item>
			</title>
			<valueType>
				<v8:Type xmlns:d5p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d5p1:DocumentRef.РасходнаяНакладная</v8:Type>
			</valueType>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СостояниеНакладной</dataPath>
			<field>СостояниеНакладной</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КОтгрузкеШт</dataPath>
			<field>КОтгрузкеШт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>К отгрузке шт.</v8:content>
				</v8:item>
			</title>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>0</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=0; ЧРГ=' '; ЧГ=3,0</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаОтгрузки</dataPath>
			<field>ДатаОтгрузки</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>//ПЛАНИРУЕМАЯ ОТГРУЗКА
ВЫБРАТЬ	
	Номенклатура		КАК Номенклатура,
	СУММА(Количество) 	КАК КОтгрузкеШт
ПОМЕСТИТЬ ВТ_Отгрузка	
ИЗ
	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
ГДЕ
	Ссылка.Проведен
	И Ссылка.ДатаОтгрузки МЕЖДУ &amp;Дата1 И &amp;Дата2
	И Ссылка.Отгружен = ЗНАЧЕНИЕ(Перечисление.Отгружен.Резерв)
	И Ссылка.СостояниеНакладной &lt;&gt; ЗНАЧЕНИЕ(Перечисление.СостоянияНакладной.ВРаботе)
	И Ссылка.ТребуетсяМаркировка
	И НЕ (
		Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)  
		ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)  
	)
{
	ГДЕ
		Ссылка 							КАК Накладная,
		Ссылка.Склад.* 					КАК Склад,		
		Ссылка.Склад.Подразделение		КАК Подразделение,
		Ссылка.ДатаОтгрузки				КАК ДатаОтгрузки,
		Ссылка.СостояниеНакладной 		КАК СостояниеНакладной,
		Номенклатура.Родитель.* 		КАК Модель,			
		Номенклатура.* 					КАК Номенклатура
}
СГРУППИРОВАТЬ ПО
	Номенклатура	
;
//ДОСТУПНЫЕ КМ
ВЫБРАТЬ
	ШтрихКодУпаковки.Владелец КАК Номенклатура,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихКодУпаковки) КАК КолШК	
ПОМЕСТИТЬ ВТ_КоличествоШК
ИЗ
	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(&amp;Дата2, 		
		ШтрихКодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)	
		{
			ШтрихКодУпаковки.Владелец.Родитель.* 	КАК Модель,			
			ШтрихКодУпаковки.Владелец.* 			КАК Номенклатура		 	
		}
	) КАК Статусы
ГДЕ
	Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ГотовКПечати)
	ИЛИ Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.Нанесен)
	ИЛИ Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКодовМаркировкиФакт.ВОбороте)
{
ГДЕ
	ВЫРАЗИТЬ(Местонахождение КАК Справочник.Подразделения).* КАК Подразделение	
}
СГРУППИРОВАТЬ ПО
	ШтрихКодУпаковки.Владелец 			
ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;		
//Остатки
ВЫБРАТЬ
	Номенклатура.Родитель   КАК Модель,
	Номенклатура,	
	КоличествоОстаток 		КАК ОстатокШт
ПОМЕСТИТЬ ВТ_Остатки	
ИЗ
	РегистрНакопления.ОстаткиТМЦ.Остатки(,		
		{		
			Номенклатура.* 			КАК Номенклатура,
			Склад.* 				КАК Склад,
			Склад.Подразделение		КАК Подразделение,
			Номенклатура.Родитель.* КАК Модель			
		}	
		НЕ (
			Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.ПустаяСсылка)  
			ИЛИ Номенклатура.СтатусКарточкиВЧЗ = ЗНАЧЕНИЕ(Перечисление.СтатусыКарточкиНоменклатурыВЧЗ.НеПодлежитМаркировке)  
		)				
	)
		
;
ВЫБРАТЬ
	Номенклатура 		КАК Номенклатура,
	СУММА(ОстатокШт)	КАК ОстатокШт,
	СУММА(ПроданоШт)	КАК ПроданоШт,
	СУММА(КМДоступно)	КАК КМДоступно,
	СУММА(КОтгрузкеШт)	КАК КОтгрузкеШт
ПОМЕСТИТЬ ВТ_ДанныеДляРасчета	
ИЗ
(
	ВЫБРАТЬ
		ВТ_Остатки.Номенклатура		КАК Номенклатура,
		ОстатокШт		 			КАК ОстатокШт,
		0 							КАК ПроданоШт, 
		0							КАК КМДоступно,
		0							КАК КОтгрузкеШт
	ИЗ
		ВТ_Остатки
	{ГДЕ
		ВТ_Остатки.Модель.* КАК Модель
	}	
	ОБЪЕДИНИТЬ ВСЕ
	ВЫБРАТЬ
		Номенклатура					КАК Номенклатура,
		0								КАК ОстатокШт,				
		КолРасхОборот - КолПрихОборот	КАК ПроданоШт,
		0								КАК КМДоступно,
		0								КАК КОтгрузкеШт		
	ИЗ
		РегистрНакопления.Продажи.Обороты({&amp;Дата1}, {&amp;Дата2}, , 			
			Номенклатура В (ВЫБРАТЬ РАЗЛИЧНЫЕ Номенклатура ИЗ ВТ_Остатки)
			И НЕ &amp;фРасчетПодОтгрузки
			{				
				Номенклатура.Родитель.* 			КАК Модель,			
				Номенклатура.* 						КАК Номенклатура
			}
		)
	{
		ГДЕ
			Регистратор.Склад.Подразделение.*	КАК Подразделение			
	}	
			
	ОБЪЕДИНИТЬ ВСЕ
	ВЫБРАТЬ	
		ВТ_КоличествоШК.Номенклатура,
		0,
		0,
		КолШК		КАК КМДоступно,
		0			КАК КОтгрузкеШт		
	ИЗ
		ВТ_КоличествоШК	
	ОБЪЕДИНИТЬ ВСЕ
	ВЫБРАТЬ     
		Номенклатура,
		0,
		0,
		0 КАК КМДоступно,
		КОтгрузкеШт				
	ИЗ
		ВТ_Отгрузка	
) КАК Сводный
СГРУППИРОВАТЬ ПО
	Номенклатура			
;
ВЫБРАТЬ
	Номенклатура.Родитель	КАК Модель,
	Номенклатура,
	ПроданоШт,
	ОстатокШт,
	КМДоступно,	
	ВЫБОР 
		КОГДА ПроданоШт &gt; 0 И ПроданоШт/2 &gt; КМДоступно ТОГДА ВЫРАЗИТЬ(ПроданоШт/2 - КМДоступно КАК Число(10,0))
		ИНАЧЕ 0
	КОНЕЦ КАК КМНужноЗаказатьПоПродажам,
	КОтгрузкеШт	
ИЗ
	ВТ_ДанныеДляРасчета
ГДЕ
	КОтгрузкеШт &gt; 0 ИЛИ НЕ &amp;фРасчетПодОтгрузки	
{
ВЫБРАТЬ
	Модель.*,
	Номенклатура.*,
	ПроданоШт,
	ОстатокШт,
	КМДоступно,	
	КМНужноЗаказатьПоПродажам,
	КОтгрузкеШт	
}
{   
ГДЕ
	КОтгрузкеШт
}</query>
		<autoFillFields>false</autoFillFields>
	</dataSet>
	<calculatedField>
		<dataPath>КМ.НужноЗаказать</dataPath>
		<expression>ВЫБОР
  КОГДА &amp;фРасчетПодОтгрузки ТОГДА
    ВЫБОР
	  КОГДА КМ.Доступно&lt;КОтгрузкеШт ТОГДА КОтгрузкеШт - КМ.Доступно 
	  ИНАЧЕ 0
	КОНЕЦ  
  ИНАЧЕ	
    ВЫБОР
	  КОГДА 
	    ВЫБОР
	      КОГДА &amp;МинЗапасПроцент&gt;0 И КМ.НужноЗаказатьПоПродажам&lt;(ОстатокШт*&amp;МинЗапасПроцент/100) ТОГДА ОстатокШт*&amp;МинЗапасПроцент/100
	      КОГДА ОстатокШт&gt;КМ.НужноЗаказатьПоПродажам ТОГДА КМ.НужноЗаказатьПоПродажам
	      ИНАЧЕ ОстатокШт 
	    КОНЕЦ&gt;КМ.Доступно 
	  ТОГДА
	    ВЫБОР
	      КОГДА &amp;МинЗапасПроцент&gt;0 И КМ.НужноЗаказатьПоПродажам&lt;(ОстатокШт*&amp;МинЗапасПроцент/100) ТОГДА ОстатокШт*&amp;МинЗапасПроцент/100
	        КОГДА ОстатокШт&gt;КМ.НужноЗаказатьПоПродажам ТОГДА КМ.НужноЗаказатьПоПродажам
	        ИНАЧЕ ОстатокШт 
	    КОНЕЦ - КМ.Доступно 
	  ИНАЧЕ 0
	КОНЕЦ    
КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>КМ.Нужно заказать</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=0; ЧРГ=' '; ЧГ=3,0</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Поле1</dataPath>
		<expression>КМ.НужноЗаказать</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Поле1</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>КМ.НужноЗаказать</dataPath>
		<expression>Сумма(КМ.НужноЗаказать)</expression>
	</totalField>
	<totalField>
		<dataPath>КМ.Доступно</dataPath>
		<expression>Сумма(КМ.Доступно)</expression>
