				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КМ.НужноЗаказатьПоПродажам</dataPath>
			<field>КМНужноЗаказатьПоПродажам</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>КМ.Нужно заказать по продажам</v8:content>
