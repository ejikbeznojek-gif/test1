		Книга	= Ексель.WorkBooks.Open(ИмяФайла1);
	Исключение
		//ЗаписатьВЛог("Регламент","Не удалось открыть файл списка номенклатуры! Загрузка отменена.","Информация");  
		ПризКр=1;
		//Возврат СписокДляПрайса;
