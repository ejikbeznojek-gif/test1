Функция ПолучитьАртикулыЦеныМатрицы(Контрагент,Договор)
	
	
	// для договоров не по матрице
	Попытка
		Если Договор.НеИспользоватьМатрицу Тогда
			НеИспользоватьМартицуПоДоговору=Истина;
		иначе
			НеИспользоватьМартицуПоДоговору=ложь;
		КонецЕсли;	
	Исключение
		НеИспользоватьМартицуПоДоговору=ложь;
	конецПопытки;
	ТЗ = новый ТаблицаЗначений;
	Тз.Очистить();
	
	Попытка
		//Если контрагент.ИспользоватьНоменклатурнуюМатрицу и не НеИспользоватьМартицуПоДоговору Тогда
			// проверяем по какому типу расчитывать цену - с учетом договора или нет(если по договору не найдено). 
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Матрица.Ссылка КАК Ссылка1
			|ИЗ
			|	Документ.Матрица КАК Матрица
			|ГДЕ
			|	Матрица.Контрагент = &Контрагент
			|	И Матрица.Дата <= &Дата1
			|	И Матрица.ДатаОкончания >= &Дата2
			|	И Матрица.Договор = &Договор
			|	И Матрица.Проведен = истина
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			
			Запрос.УстановитьПараметр("Дата2",НачалоДня(ТекущаяДата()));
			Запрос.УстановитьПараметр("Дата1",КонецДня(ТекущаяДата()));
			Запрос.УстановитьПараметр("Контрагент",Контрагент);
			Запрос.УстановитьПараметр("Договор",Договор);
			ТЗЕстьМатрицаПоДоговору = Запрос.Выполнить().Выгрузить();
					
			
			//запрос на получение
			Запрос=Новый Запрос;
			Запрос.Текст=
			"ВЫБРАТЬ
			|	МатрицаТовары.Номенклатура,
			|	МатрицаТовары.ШККонтрагента,
			|	МатрицаТовары.АртикулКонтрагента,
			|	МатрицаТовары.Ссылка,
			|	МатрицаТовары.НаименованиеКонтрагента,
			|	МатрицаТовары.Кратность,
			|	МатрицаТовары.ШККонтрагентаБлочок,
			|	МатрицаТовары.ШКСпайки,
			|	МатрицаТовары.Цена,
			|	МатрицаТовары.Номенклатура.Код
			|ИЗ
