	Запрос.УстановитьПараметр("ДатаКонецДня", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ДатаНачалоДня", КонецДня(ТекущаяДата()));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[1].Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВыборкаАкции = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаКонтрагенты = РезультатЗапроса[2].Выбрать();
	
	Пока ВыборкаАкции.Следующий() Цикл
		
		СтруктураСкидок = Новый Структура;
		
		СтруктураСкидок.Вставить("code", ВыборкаАкции.Номер);
		СтруктураСкидок.Вставить("name", ВыборкаАкции.Наименование);
		СтруктураСкидок.Вставить("startDate", Формат(ВыборкаАкции.ДатаНачала, "ДФ='dd.MM.yyyy HH:mm:ss'"));
		СтруктураСкидок.Вставить("endDate", Формат(ВыборкаАкции.ДатаОкончания, "ДФ='dd.MM.yyyy HH:mm:ss'"));
		
		ВыборкаСкидки = ВыборкаАкции.Выбрать();
		
		МассивНоменклатуры = Новый Массив;
		
		Пока ВыборкаСкидки.Следующий() Цикл
			
			Если ЗначениеЗаполнено(ВыборкаСкидки.КодМодели) Тогда
				СтруктураТоваров = Новый Структура;
				СтруктураТоваров.Вставить("code", ВыборкаСкидки.КодМодели);
				СтруктураТоваров.Вставить("discountDistr", ВыборкаСкидки.Скидка);
				СтруктураТоваров.Вставить("discountClient", ВыборкаСкидки.СкидкаКонечныйПокупатель);
				МассивНоменклатуры.Добавить(СтруктураТоваров);
			КонецЕсли;
		
		КонецЦикла;
		
		Если МассивНоменклатуры.Количество() > 0 Тогда
			СтруктураСкидок.Вставить("products", МассивНоменклатуры);
		КонецЕсли;
		
		ВыборкаКонтрагенты.Сбросить();
		МассивКонтрагентов = Новый Массив;
		
		Пока ВыборкаКонтрагенты.Следующий() Цикл
		                                     
			Если ВыборкаКонтрагенты.Номер = ВыборкаАкции.Номер Тогда
				
				Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодКонтрагента) Тогда
					СтруктураКонтрагента = Новый Структура;
					СтруктураКонтрагента.Вставить("distr", ВыборкаКонтрагенты.КодКонтрагента); 
					СтруктураКонтрагента.Вставить("active", ВыборкаКонтрагенты.УчавствуетВАкции);
					МассивКонтрагентов.Добавить(СтруктураКонтрагента);	
				КонецЕсли;
				
			КонецЕсли;
		
		КонецЦикла;
		
		Если МассивКонтрагентов.Количество() > 0 Тогда
			СтруктураСкидок.Вставить("distributors", МассивКонтрагентов);
		КонецЕсли;
		
		МассивСкидок.Добавить(СтруктураСкидок);
		
	КонецЦикла; 
	
	ВнутренняяСтруктураДанных.Вставить("deepDiscounts", МассивСкидок);
	ОбщаяСтруктураВыгружаемыхСкидок.Вставить("data", ВнутренняяСтруктураДанных);
	
	Возврат ОбщаяСтруктураВыгружаемыхСкидок;
	
КонецФункции

