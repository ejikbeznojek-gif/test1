#Область ОсновныеПроцедурыИФункции
                   
Процедура ВыполнитьВыгрузкуАкций(
		ЗапроситьСтатусВыгрузкиАкцийНаПортал = Ложь,
		ВыгрузитьАкцииНаПортал = Ложь,
		ПолнаяВыгрузка = Ложь
	) Экспорт
	
	ТипЗапроса = "ВыгрузкаАкций";
	СтруктураПодключения = b2b_ОбменДаннымиПоAPI.ПолучитьСтруктуруПодключения();
	СтруктураПодключения.Вставить("ТипЗапроса", ТипЗапроса);
	
	Если ЗапроситьСтатусВыгрузкиАкцийНаПортал Тогда
		ВыполнитьЗапросСтатусовВыгрузкиДанныхНаПортал(СтруктураПодключения);
	КонецЕсли;
	//++Данилова Е.В. 24.07.2025  HELP-6121 
	//оставляем только полную выгрузку, изменения выгружаются сразу на портал при записи акции 
	//Если ВыгрузитьАкцииНаПортал Тогда
	Если ВыгрузитьАкцииНаПортал 
		И ПолнаяВыгрузка Тогда
		//--Данилова Е.В. 24.07.2025
		СтруктураПодключения.Вставить("ПолнаяВыгрузка", ПолнаяВыгрузка); 
		ВыполнитьВыгрузкуАкцииНаПортал(СтруктураПодключения);
	КонецЕсли;
	
	
КонецПроцедуры

Процедура ВыполнитьВыгрузкуКонтрагентов(
		ЗапроситьСтатусВыгрузкиКонтрагентовНаПортал = Ложь, 
		ВыгрузитьКонтрагентовНаПортал = Ложь,
		ПолнаяВыгрузка = Ложь
	) Экспорт
	
	ТипЗапроса = "ВыгрузкаКонтрагентов";
	СтруктураПодключения = b2b_ОбменДаннымиПоAPI.ПолучитьСтруктуруПодключения();
	СтруктураПодключения.Вставить("ТипЗапроса", ТипЗапроса);
	
	Если ЗапроситьСтатусВыгрузкиКонтрагентовНаПортал Тогда
		ВыполнитьЗапросСтатусовВыгрузкиДанныхНаПортал(СтруктураПодключения);
	КонецЕсли;
	
	Если ВыгрузитьКонтрагентовНаПортал Тогда
		СтруктураПодключения.Вставить("ПолнаяВыгрузка", ПолнаяВыгрузка); 
		ВыполнитьВыгрузкуКонтрагентовНаПортал(СтруктураПодключения);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьЗапросСтатусовВыгрузкиДанныхНаПортал(СтруктураПодключения)
	
	b2b_ОбменДаннымиПоAPI.ПолучитьРезультатОбработкиОчередиНаПортале(СтруктураПодключения);

КонецПроцедуры

Процедура ВыполнитьВыгрузкуКонтрагентовНаПортал(СтруктураПодключения)
	
	// получение списка контрагентов из узла плана обмена
	Если Не СтруктураПодключения.ПолнаяВыгрузка Тогда
		
		СтруктураИзменений = b2b_ОбменДаннымиПоAPI.ПолучитьВсеИзмененияИзПланаОбмена(
			СтруктураПодключения.Узел, 
			"Контрагенты"
		);
		
		Если СтруктураИзменений = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		СписокКонтрагентов = СтруктураИзменений.Данные;
		
		Если СписокКонтрагентов.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ втВсеКонтрагентыДляОбработки
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка В(&Контрагенты)
		|	И Контрагенты.ВыгружатьВИнтернетМагазин = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|	И Контрагенты.Владелец = &Интегральная
		|	И НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.НеИспользовать
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	Контрагенты.Ведущий
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Ведущие
		|		ПО (Контрагенты.Ведущий = Ведущие.Ссылка)
		|ГДЕ
		|	Контрагенты.Ссылка В(&Контрагенты)
		|	И Контрагенты.Владелец <> &Интегральная
		|	И НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.НеИспользовать
		|	И Ведущие.ВыгружатьВИнтернетМагазин = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|;";
		
	Иначе
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ втВсеКонтрагентыДляОбработки
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Владелец = &Интегральная
		|	И ВыгружатьВИнтернетМагазин = ЗНАЧЕНИЕ(Перечисление.ВыгружатьНаСайт.Да)
		|	И НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.НеИспользовать
		|;";
		
	КонецЕсли;
	
	// получение выборки данных для отправки на портал
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса + 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(Контрагенты.Код, """") КАК Код,
		|	ЕСТЬNULL(ВЫБОР
		|			КОГДА НЕ Контрагенты.НеИспользовать
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ, ЛОЖЬ) КАК Активность,
		|	ЕСТЬNULL(Контрагенты.Наименование, """") КАК Наименование,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(Контрагенты.ЕМэйл1 КАК СТРОКА(100))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(Контрагенты.ЕМэйл1 КАК СТРОКА(100))
		|		ИНАЧЕ ВЫБОР
		|				КОГДА (ВЫРАЗИТЬ(Контрагенты.ЕМэйл2 КАК СТРОКА(100))) <> """"
		|					ТОГДА ВЫРАЗИТЬ(Контрагенты.ЕМэйл2 КАК СТРОКА(100))
		|				ИНАЧЕ """"
		|			КОНЕЦ
		|	КОНЕЦ КАК ЕМэйл,
		|	ЕСТЬNULL(Контрагенты.ИНН, """") КАК ИНН,
		|	ЕСТЬNULL(Контрагенты.РаботаСМаркированнымТоваромПодтверждена, """") КАК РаботаСМаркированнымТоваром,
		|	"""" КАК ВторичнаяВалюта,
		|	ЕСТЬNULL(ФизЛицоМенеджер.Код, """") КАК КодМенеджер,
		|	ЕСТЬNULL(ФизЛицоМенеджер.Наименование, """") КАК НаименованиеМенеджер,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(ФизЛицоМенеджер.ЕМэйл КАК СТРОКА(100)), """") КАК ЕМэйлМенеджер,
		|	ЕСТЬNULL(ФизЛицоАссистент.Код, """") КАК КодАссистент,
		|	ЕСТЬNULL(ФизЛицоАссистент.Наименование, """") КАК НаименованиеАссистент,
		|	ВЫБОР
		|		КОГДА ФизЛицоАссистент.ЕМэйл ЕСТЬ NULL
		|			ТОГДА """"
		|		ИНАЧЕ ВЫРАЗИТЬ(ФизЛицоАссистент.ЕМэйл КАК СТРОКА(100))
		|	КОНЕЦ КАК ЕМэйлАссистент,
		|	ЕСТЬNULL(ФизЛицоУправляющийТерритории.Код, """") КАК КодУправляющийТерритории,
		|	ЕСТЬNULL(ФизЛицоУправляющийТерритории.Наименование, """") КАК НаименованиеУправляющийТерритории,
		|	ВЫБОР
		|		КОГДА ФизЛицоУправляющийТерритории.ЕМэйл ЕСТЬ NULL
		|			ТОГДА """"
		|		ИНАЧЕ ВЫРАЗИТЬ(ФизЛицоУправляющийТерритории.ЕМэйл КАК СТРОКА(100))
		|	КОНЕЦ КАК ЕМэйлУправляющийТерритории,
		|	"""" КАК Дистрибьюторы,
		|	втВсеКонтрагентыДляОбработки.Ссылка КАК Ссылка,
		|	ГруппаПользователя.Код КАК КодКаналСбыта,
		|	ГруппаПользователя.Наименование КАК НаименованиеКаналСбыта,
		|	ЕСТЬNULL(Контрагенты.ИННИностранногоКонтрагента, """") КАК ИННИностранногоКонтрагента
		|ПОМЕСТИТЬ втОсновныеДанные
		|ИЗ
		|	втВсеКонтрагентыДляОбработки КАК втВсеКонтрагентыДляОбработки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизЛицоМенеджер
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизЛицоАссистент
		|				ПО ФизЛицоМенеджер.АссистентМенеджера = ФизЛицоАссистент.Ссылка
		|			ПО Контрагенты.Менеджер = ФизЛицоМенеджер.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизЛицоУправляющийТерритории
		|			ПО Контрагенты.УправляющийТерритории = ФизЛицоУправляющийТерритории.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КаналСбыта КАК ГруппаПользователя
		|			ПО Контрагенты.КаналСбыта1 = ГруппаПользователя.Ссылка
		|		ПО втВсеКонтрагентыДляОбработки.Ссылка = Контрагенты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(Контрагенты.Код, """") КАК КодЮрЛицо,
		|	ВЫБОР
		|		КОГДА НЕ Контрагенты.НеИспользовать
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК АктивностьЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.Наименование, """") КАК НаименованиеЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.Ссылка, """") КАК СсылкаЮрЛицо,
		|	"""" КАК ДиректорЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.ИНН, """") КАК ИННЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.ОГРН, """") КАК ОГРНЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.ЮридическийАдрес, """") КАК ЮридическийАдресЮрЛицо,
		|	ЕСТЬNULL(Контрагенты.Телефоны, """") КАК ТелефоныЮрЛицо,
		|	ЕСТЬNULL(БанковскиеСчета.НомерСчета, """") КАК РасчетныйСчетЮрЛицо,
		|	ЕСТЬNULL(Банки.Наименование, """") КАК БанкЮрЛицо,
		|	ЕСТЬNULL(Банки.КоррСчет, """") КАК КоррСчетЮрЛицо,
		|	ЕСТЬNULL(Банки.Код, """") КАК БИКЮрЛицо,
		|	Контрагенты.РаботаСМаркированнымТоваромПодтверждена КАК РаботаСМаркировкойЮрЛицо,
		|	втОсновныеДанные.Код КАК Код,
		|	втОсновныеДанные.Активность КАК Активность,
		|	втОсновныеДанные.Наименование КАК Наименование,
		|	втОсновныеДанные.ЕМэйл КАК ЕМэйл,
		|	втОсновныеДанные.ИНН КАК ИНН,
		|	втОсновныеДанные.РаботаСМаркированнымТоваром КАК РаботаСМаркированнымТоваром,
		|	втОсновныеДанные.ВторичнаяВалюта КАК ВторичнаяВалюта,
		|	втОсновныеДанные.КодМенеджер КАК КодМенеджер,
		|	втОсновныеДанные.НаименованиеМенеджер КАК НаименованиеМенеджер,
		|	втОсновныеДанные.ЕМэйлМенеджер КАК ЕМэйлМенеджер,
		|	втОсновныеДанные.КодАссистент КАК КодАссистент,
		|	втОсновныеДанные.НаименованиеАссистент КАК НаименованиеАссистент,
		|	ЕСТЬNULL(втОсновныеДанные.ЕМэйлАссистент, """") КАК ЕМэйлАссистент,
		|	втОсновныеДанные.КодУправляющийТерритории КАК КодУправляющийТерритории,
		|	втОсновныеДанные.НаименованиеУправляющийТерритории КАК НаименованиеУправляющийТерритории,
		|	втОсновныеДанные.ЕМэйлУправляющийТерритории КАК ЕМэйлУправляющийТерритории,
		|	втОсновныеДанные.Дистрибьюторы КАК Дистрибьюторы,
		|	втОсновныеДанные.Ссылка КАК Ссылка,
		|	втОсновныеДанные.КодКаналСбыта КАК КодКаналСбыта,
		|	втОсновныеДанные.НаименованиеКаналСбыта КАК НаименованиеКаналСбыта,
		|	ЕСТЬNULL(Контрагенты.ИННИностранногоКонтрагента, """") КАК ИННЮрЛицаИностранногоКонтрагента,
		|	втОсновныеДанные.ИННИностранногоКонтрагента КАК ИННИностранногоКонтрагента
		|ИЗ
		|	втОсновныеДанные КАК втОсновныеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
		|				ПО БанковскиеСчета.Банк = Банки.Ссылка
		|			ПО Контрагенты.ОсновнойБанковскийСчет = БанковскиеСчета.Ссылка
		|		ПО втОсновныеДанные.Ссылка = Контрагенты.Ведущий
		|ИТОГИ
		|	МАКСИМУМ(Код),
		|	МАКСИМУМ(Активность),
		|	МАКСИМУМ(Наименование),
		|	МАКСИМУМ(ЕМэйл),
		|	МАКСИМУМ(ИНН),
		|	МАКСИМУМ(РаботаСМаркированнымТоваром),
		|	МАКСИМУМ(ВторичнаяВалюта),
		|	МАКСИМУМ(КодМенеджер),
		|	МАКСИМУМ(НаименованиеМенеджер),
		|	МАКСИМУМ(ЕМэйлМенеджер),
		|	МАКСИМУМ(КодАссистент),
		|	МАКСИМУМ(НаименованиеАссистент),
		|	МАКСИМУМ(ЕМэйлАссистент),
		|	МАКСИМУМ(КодУправляющийТерритории),
		|	МАКСИМУМ(НаименованиеУправляющийТерритории),
		|	МАКСИМУМ(ЕМэйлУправляющийТерритории),
		|	МАКСИМУМ(Дистрибьюторы),
		|	МАКСИМУМ(КодКаналСбыта),
		|	МАКСИМУМ(НаименованиеКаналСбыта)
		|ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ФизическиеЛица.Код, """") КАК КодТерриториальныйМенеджер,
		|	ЕСТЬNULL(ФизическиеЛица.Наименование, """") КАК НаименованиеТерриториальныйМенеджер,
		|	ЕСТЬNULL(ФизическиеЛица.ЕМэйл, """") КАК ЕМэйлТерриториальныйМенеджер,
		|	втОсновныеДанные.Ссылка КАК Ссылка
		|ИЗ
		|	втОсновныеДанные КАК втОсновныеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ТерриториальныеМенеджеры КАК КонтрагентыТерриториальныеМенеджеры
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|			ПО КонтрагентыТерриториальныеМенеджеры.ТерриториальныйМенеджер = ФизическиеЛица.Ссылка
		|		ПО втОсновныеДанные.Ссылка = КонтрагентыТерриториальныеМенеджеры.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(НоменклатураСкидки.Наименование, """") КАК НаименованиеСкидки,
		|	ЕСТЬNULL(СкидкиКонтрагентов.Скидка, """") КАК ПроцентСкидки,
		|	ВЫБОР
		|		КОГДА ВЫРАЗИТЬ(НоменклатураСкидки.Код КАК СТРОКА(30)) ЕСТЬ NULL
		|			ТОГДА """"
		|		ИНАЧЕ ""ttd"" + (ВЫРАЗИТЬ(НоменклатураСкидки.Код КАК СТРОКА(30)))
		|	КОНЕЦ КАК ТипТовараДляСкидки,
		|	втОсновныеДанные.Ссылка КАК Ссылка
		|ИЗ
		|	втОсновныеДанные КАК втОсновныеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СкидкиКонтрагентов КАК СкидкиКонтрагентов
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСкидки
		|			ПО СкидкиКонтрагентов.Номенклатура = НоменклатураСкидки.Ссылка
		|		ПО втОсновныеДанные.Ссылка = СкидкиКонтрагентов.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	втОсновныеДанные.Ссылка КАК Ведущий
		|ПОМЕСТИТЬ втСписокЮрЛиц
		|ИЗ
		|	втОсновныеДанные КАК втОсновныеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|		ПО втОсновныеДанные.Ссылка = Контрагенты.Ведущий
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПунктыДоставки.Код КАК КодПунктыДоставки,
		|	ВЫБОР
		|		КОГДА НЕ ПунктыДоставки.НеИспользовать
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК АктивностьПунктыДоставки,
		|	ВЫБОР
		|		КОГДА ПунктыДоставки.Код = ОсновнойПунктДоставкиКонтрагента.Код
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ОсновнойПунктДоставки,
		|	ПунктыДоставки.Наименование КАК НаименованиеПунктДоставки,
		|	ЕСТЬNULL(Регионы.Наименование, """") КАК РегионПунктДоставки,
		|	ВЫБОР
		|		КОГДА ПунктыДоставки.ТипДоставки = ЗНАЧЕНИЕ(Перечисление.ТипыДоставки.Перегруз)
		|			ТОГДА ЕСТЬNULL(ПунктыДоставки.АдресАнтор.Наименование, """")
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ПунктыДоставки.ТипДоставки = ЗНАЧЕНИЕ(Перечисление.ТипыДоставки.ТранспортнаяКомпания)
		|					ТОГДА ЕСТЬNULL(ПунктыДоставки.ПунктПерегруза.Наименование, """")
		|				ИНАЧЕ ВЫРАЗИТЬ(ПунктыДоставки.АдресПолучателя КАК СТРОКА(150))
		|			КОНЕЦ
		|	КОНЕЦ КАК АдресПунктДоставки,
		|	ПунктыДоставки.ТипДоставки КАК ТипДоставкиПунктДоставки,
		|	втСписокЮрЛиц.Ведущий КАК Ведущий,
		|	втСписокЮрЛиц.Ссылка КАК СсылкаЮрЛицо,
		|	ЕСТЬNULL(ТранспКомпания.Код, """") КАК КодТранспортнойКомпании,
		|	ЕСТЬNULL(ТранспКомпания.Наименование, """") КАК НаименованиеТранспортнойКомпании
		|ИЗ
		|	Справочник.ПунктыДоставки КАК ПунктыДоставки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПунктыДоставки КАК ОсновнойПунктДоставкиКонтрагента
		|			ПО Контрагенты.ОсновнойПунктДоставки = ОсновнойПунктДоставкиКонтрагента.Ссылка
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСписокЮрЛиц КАК втСписокЮрЛиц
		|			ПО (втСписокЮрЛиц.Ссылка = Контрагенты.Ссылка)
		|		ПО ПунктыДоставки.Владелец = Контрагенты.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Регионы КАК Регионы
		|		ПО ПунктыДоставки.Регион = Регионы.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК ТранспКомпания
		|		ПО ПунктыДоставки.ТраспортнаяКомпания = ТранспКомпания.Ссылка
		|ГДЕ
		|	НЕ ПунктыДоставки.ПометкаУдаления
		|	И НЕ Контрагенты.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Интегральная", Справочники.ИБ.НайтиПоКоду("SMN"));
	Запрос.УстановитьПараметр("Контрагенты", СписокКонтрагентов);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	// если нет ни одного контрагента - выходим
	Если РезультатЗапроса[1].Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	// обработка выборки данных, сериализация в строку JSON 
	
	// общая структура, в которой будет находится весь запрос
	ОбщаяСтруктураДанных = Новый Структура;
	СтруктураМассивовКонтрагентов = Новый Структура;	
	
	//// группы пользователей
	//ВыборкаГруппыПользователя = РезультатЗапроса[2].Выбрать();
	
	// контрагенты, управляющие территорией, ассистент менеджера, юр.лица
	ВыборкаКонтрагенты = РезультатЗапроса[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	// территориальные менеджеры	
	ВыборкаТерриториальныеМенеджеры = РезультатЗапроса[3].Выбрать(); 
	
	// персональные скидки	
	ВыборкаПерсональныеСкидки = РезультатЗапроса[4].Выбрать(); 
	
	// пункты доставки юр.лиц	
	ВыборкаПунктыДоставки = РезультатЗапроса[6].Выбрать();

	МассивКонтрагентов = Новый Массив;
	
	Пока ВыборкаКонтрагенты.Следующий() Цикл 
		
		Если ВыборкаКонтрагенты.ЕМэйл = "" Тогда
			
			// электронная почта обязательное поле для отправки данных на портал
			// если эл.почта не заполнена - фиксируем ошибку и пропускаем обработку
			b2b_ОбменДаннымиПоAPI.ЗаписатьОшибкуОбменДаннымиПоAPI(
				СтруктураПодключения.ИдентификаторЗапроса, 
				, 
				СтрШаблон("У контрагента с кодом %1 не заполнено обязательное поле электронная почта", ВыборкаКонтрагенты.Код)
			);
			Продолжить;
			
		КонецЕсли;
		
		// основные поля контрагента
		СтруктураКонтрагент = Новый Структура;
		СтруктураКонтрагент.Вставить("login", ВыборкаКонтрагенты.Код);
		СтруктураКонтрагент.Вставить("active", ВыборкаКонтрагенты.Активность);
		СтруктураКонтрагент.Вставить("name", ВыборкаКонтрагенты.Наименование);
		СтруктураКонтрагент.Вставить("email", ВыборкаКонтрагенты.ЕМэйл);
		//++Данилова Е.В. 25.08.2025 без задачи 
		Если ЗначениеЗаполнено(ВыборкаКонтрагенты.ИННИностранногоКонтрагента) Тогда
			СтруктураКонтрагент.Вставить("inn", ВыборкаКонтрагенты.ИННИностранногоКонтрагента);
		Иначе 	
			СтруктураКонтрагент.Вставить("inn", ВыборкаКонтрагенты.ИНН);
		КонецЕсли;
		//СтруктураКонтрагент.Вставить("inn", ВыборкаКонтрагенты.ИНН); 
		//--Данилова Е.В. 25.08.2025
		
		// ответственный менеджер
		Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодМенеджер) Тогда
			СтруктураОтветственныйМенеджер = Новый Структура;
			СтруктураОтветственныйМенеджер.Вставить("code", ВыборкаКонтрагенты.КодМенеджер); 
			СтруктураОтветственныйМенеджер.Вставить("name", ВыборкаКонтрагенты.НаименованиеМенеджер); 
			СтруктураОтветственныйМенеджер.Вставить("email", ВыборкаКонтрагенты.ЕМэйлМенеджер);
			СтруктураКонтрагент.Вставить("responsibleManager", СтруктураОтветственныйМенеджер);
		КонецЕсли;
		
		// ассистен менеджера
		Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодАссистент) Тогда
			СтруктураАссистентМенеджера = Новый Структура;
			СтруктураАссистентМенеджера.Вставить("code", ВыборкаКонтрагенты.КодАссистент);
			СтруктураАссистентМенеджера.Вставить("name", ВыборкаКонтрагенты.НаименованиеАссистент);
			СтруктураАссистентМенеджера.Вставить("email", ВыборкаКонтрагенты.ЕМэйлАссистент);
			СтруктураКонтрагент.Вставить("managerAssistant", СтруктураАссистентМенеджера);
		КонецЕсли;
		
		// группы пользователей
		МассивГруппПользователя = Новый Массив;
		Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодКаналСбыта) Тогда 
			ГруппаПользователя = Новый Структура;
			ГруппаПользователя.Вставить("code", ВыборкаКонтрагенты.КодКаналСбыта); 
			ГруппаПользователя.Вставить("name", ВыборкаКонтрагенты.НаименованиеКаналСбыта);
			МассивГруппПользователя.Добавить(ГруппаПользователя);
		КонецЕсли;
		Если МассивГруппПользователя.Количество() > 0 Тогда
			СтруктураКонтрагент.Вставить("userGroups", МассивГруппПользователя);
		КонецЕсли;
		
		// управляющий территорией
		Если ЗначениеЗаполнено(ВыборкаКонтрагенты.КодУправляющийТерритории) Тогда
			СтруктураУправляющийТерриторией = Новый Структура;
			СтруктураУправляющийТерриторией.Вставить("code", ВыборкаКонтрагенты.КодУправляющийТерритории); 
			СтруктураУправляющийТерриторией.Вставить("name", ВыборкаКонтрагенты.НаименованиеУправляющийТерритории);
			СтруктураУправляющийТерриторией.Вставить("email", ВыборкаКонтрагенты.ЕМэйлУправляющийТерритории);
			СтруктураКонтрагент.Вставить("chiefTerritoryManager", СтруктураУправляющийТерриторией);
		КонецЕсли;
		
		// территориальные менеджеры
		ВыборкаТерриториальныеМенеджеры.Сбросить();
		МассивТерриториальныхМенеджеров = Новый Массив;
		Пока ВыборкаТерриториальныеМенеджеры.Следующий() Цикл
			Если ВыборкаТерриториальныеМенеджеры.Ссылка = ВыборкаКонтрагенты.Ссылка Тогда
				Если ЗначениеЗаполнено(ВыборкаТерриториальныеМенеджеры.КодТерриториальныйМенеджер) Тогда
					СтруктураТерриториальныйМенеджер = Новый Структура;
					СтруктураТерриториальныйМенеджер.Вставить("code", ВыборкаТерриториальныеМенеджеры.КодТерриториальныйМенеджер);
					СтруктураТерриториальныйМенеджер.Вставить("name", ВыборкаТерриториальныеМенеджеры.НаименованиеТерриториальныйМенеджер);
					СтруктураТерриториальныйМенеджер.Вставить("email", ВыборкаТерриториальныеМенеджеры.ЕМэйлТерриториальныйМенеджер); 
					МассивТерриториальныхМенеджеров.Добавить(СтруктураТерриториальныйМенеджер);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если МассивТерриториальныхМенеджеров.Количество() > 0 Тогда
			СтруктураКонтрагент.Вставить("territoryManagers", МассивТерриториальныхМенеджеров);
		КонецЕсли;
		
		// дистрибьюторов не передаем (даже пустой массив) 
		
		// территориальные скидки
		ВыборкаПерсональныеСкидки.Сбросить();
		МассивТерриториальныеСкидки = Новый Массив;
		Пока ВыборкаПерсональныеСкидки.Следующий() Цикл
			Если ВыборкаПерсональныеСкидки.Ссылка = ВыборкаКонтрагенты.Ссылка Тогда
				Если ЗначениеЗаполнено(ВыборкаПерсональныеСкидки.НаименованиеСкидки) Тогда
					СтруктураПерсональныеСкидки = Новый Структура;
					СтруктураПерсональныеСкидки.Вставить("name", ВыборкаПерсональныеСкидки.НаименованиеСкидки);
					СтруктураПерсональныеСкидки.Вставить("discount", ВыборкаПерсональныеСкидки.ПроцентСкидки);
					СтруктураПерсональныеСкидки.Вставить("tipTovDiscount", ВыборкаПерсональныеСкидки.ТипТовараДляСкидки); 
					МассивТерриториальныеСкидки.Добавить(СтруктураПерсональныеСкидки);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если МассивТерриториальныеСкидки.Количество() > 0 Тогда
			СтруктураКонтрагент.Вставить("personalDiscounts", МассивТерриториальныеСкидки);
		КонецЕсли;
		
		// юридические лица
		ВыборкаЮрЛица = ВыборкаКонтрагенты.Выбрать();
		МассивЮрЛиц = Новый Массив;
		РаботаСМаркировкой = Ложь;
		
		Пока ВыборкаЮрЛица.Следующий() Цикл
			
			Если ЗначениеЗаполнено(ВыборкаЮрЛица.КодЮрЛицо) Тогда
				
				СтруктураПрофильЮридическогоЛица = Новый Структура;
				СтруктураПрофильЮридическогоЛица.Вставить("code", ВыборкаЮрЛица.КодЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("active", ВыборкаЮрЛица.АктивностьЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("name", ВыборкаЮрЛица.НаименованиеЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("director", ВыборкаЮрЛица.ДиректорЮрЛицо);
				//++Данилова Е.В. 25.08.2025 без задачи 
				Если ЗначениеЗаполнено(ВыборкаЮрЛица.ИННЮрЛицаИностранногоКонтрагента) Тогда
				   СтруктураПрофильЮридическогоЛица.Вставить("inn", ВыборкаЮрЛица.ИННЮрЛицаИностранногоКонтрагента);
				Иначе	
				   СтруктураПрофильЮридическогоЛица.Вставить("inn", ВыборкаЮрЛица.ИННЮрЛицо);
				КонецЕсли;
				//СтруктураПрофильЮридическогоЛица.Вставить("inn", ВыборкаЮрЛица.ИННЮрЛицо); 
				//--Данилова Е.В. 25.08.2025 
				СтруктураПрофильЮридическогоЛица.Вставить("ogrn", ВыборкаЮрЛица.ОГРНЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("legalAddress", ВыборкаЮрЛица.ЮридическийАдресЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("phone", ВыборкаЮрЛица.ТелефоныЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("accountNumber", ВыборкаЮрЛица.РасчетныйСчетЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("bank", ВыборкаЮрЛица.БанкЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("correspondentBankAccount", ВыборкаЮрЛица.КоррСчетЮрЛицо);
				СтруктураПрофильЮридическогоЛица.Вставить("bik", ВыборкаЮрЛица.БИКЮрЛицо); 
				СтруктураПрофильЮридическогоЛица.Вставить("worksWithLabeling", ВыборкаЮрЛица.РаботаСМаркировкойЮрЛицо);
				
				Если ВыборкаЮрЛица.РаботаСМаркировкойЮрЛицо Тогда
					РаботаСМаркировкой = ВыборкаЮрЛица.РаботаСМаркировкойЮрЛицо;
				КонецЕсли;
				
				// пункты доставки юр.лиц
				МассивПунктыДоставки = Новый Массив;
				
				ВыборкаПунктыДоставки.Сбросить();
				
				Пока ВыборкаПунктыДоставки.Следующий() Цикл
					
					Если ВыборкаПунктыДоставки.Ведущий = ВыборкаКонтрагенты.Ссылка Тогда
						
						Если ВыборкаПунктыДоставки.СсылкаЮрЛицо <> ВыборкаЮрЛица.СсылкаЮрЛицо Тогда
							Продолжить;
						КонецЕсли;
						
						Если ЗначениеЗаполнено(ВыборкаПунктыДоставки.КодПунктыДоставки) Тогда
							
							СтруктураПунктыДоставки = Новый Структура;
							СтруктураПунктыДоставки.Вставить("code", ВыборкаПунктыДоставки.КодПунктыДоставки); 
							СтруктураПунктыДоставки.Вставить("active", ВыборкаПунктыДоставки.АктивностьПунктыДоставки); 
							СтруктураПунктыДоставки.Вставить("isMain", ВыборкаПунктыДоставки.ОсновнойПунктДоставки);
							СтруктураПунктыДоставки.Вставить("name", ВыборкаПунктыДоставки.НаименованиеПунктДоставки);
							СтруктураПунктыДоставки.Вставить("region", ВыборкаПунктыДоставки.РегионПунктДоставки);
							СтруктураПунктыДоставки.Вставить("address", XMLСтрока(ВыборкаПунктыДоставки.АдресПунктДоставки));
							
							// тип доставки
							МТипыДоставок=Новый соответствие;
							МтипыДоставок.Вставить("Доставка","DOSTAVKA");
							МтипыДоставок.Вставить("ТранспортнаяКомпания","TRANSCORP");
							МтипыДоставок.Вставить("Самовывоз","SAMOVYVOZ");
							МтипыДоставок.Вставить("Перегруз","PEREGRUZ");
							
							ТипДоставки = ВыборкаПунктыДоставки.ТипДоставкиПунктДоставки;
							Если Не ЗначениеЗаполнено(ТипДоставки) Тогда
								ТипДоставки = "";
							КонецЕсли;
							ТипДоставкиСиноним = XMLСтрока(ТипДоставки);
							ТИпДоставкиДляСтруктуры = МтипыДоставок.Получить(ТипДоставкиСиноним); 
							СтруктураТипДоставки = Новый Структура;
							СтруктураТипДоставки.Вставить("code", ?(ТИпДоставкиДляСтруктуры = Неопределено, "", ТИпДоставкиДляСтруктуры)); 
							СтруктураТипДоставки.Вставить("name", Строка(ТипДоставкиСиноним));
							
							СтруктураПунктыДоставки.Вставить("deliveryType", СтруктураТипДоставки); 
							
							// транспортная компания
							Если ТипДоставки = Перечисления.ТипыДоставки.ТранспортнаяКомпания Тогда
							 
								Если ЗначениеЗаполнено(ВыборкаПунктыДоставки.КодТранспортнойКомпании) Тогда
									
									СтруктураТранспортнаяКомпания = Новый Структура;
									СтруктураТранспортнаяКомпания.Вставить("code", ВыборкаПунктыДоставки.КодТранспортнойКомпании); 
									СтруктураТранспортнаяКомпания.Вставить("name", ВыборкаПунктыДоставки.НаименованиеТранспортнойКомпании);
									
									СтруктураПунктыДоставки.Вставить("tk", СтруктураТранспортнаяКомпания);
									
								КонецЕсли; 
								
							КонецЕсли;
							
							МассивПунктыДоставки.Добавить(СтруктураПунктыДоставки);
						
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;
				
				Если МассивПунктыДоставки.Количество() > 0 Тогда
					СтруктураПрофильЮридическогоЛица.Вставить("deliveries", МассивПунктыДоставки);
				КонецЕсли;
				
				МассивЮрЛиц.Добавить(СтруктураПрофильЮридическогоЛица);
			
			КонецЕсли;
			
		КонецЦикла;
		// работа с маркированным товаром 
		СтруктураКонтрагент.Вставить("worksWithLabeling", РаботаСМаркировкой);
		
		Если МассивЮрЛиц.Количество() > 0 Тогда
			СтруктураКонтрагент.Вставить("profiles", МассивЮрЛиц);
		КонецЕсли;
		
		МассивКонтрагентов.Добавить(СтруктураКонтрагент);
		
	КонецЦикла;
	
	Если МассивКонтрагентов.Количество() > 0 Тогда
		// для отладки, комментарий не удалять
		// params структура queueable false
		//СтруктураОтладки = Новый Структура;
		//СтруктураОтладки.Вставить("queueable", false);
		//СтруктураМассивовКонтрагентов.Вставить("params", СтруктураОтладки); 
		//
		СтруктураМассивовКонтрагентов.Вставить("users", МассивКонтрагентов);
		ОбщаяСтруктураДанных.Вставить("data", СтруктураМассивовКонтрагентов);
	Иначе
		Возврат;
	КонецЕсли;
	
	СтруктураПодключения.Вставить("Данные", СписокКонтрагентов);
	
	ОтправитьВыгружаемыеДанныеНаПорталПоAPI(СтруктураПодключения, ОбщаяСтруктураДанных);
	
КонецПроцедуры

