Процедура ВыполнитьВыгрузкуАкцииНаПортал(СтруктураПодключения)
	
	// определяем, что будет выгружено на портал
	СписокДокументовУстановкаСкидокПоКонтрагентам = Неопределено;
	
	Если Не СтруктураПодключения.ПолнаяВыгрузка Тогда
		СтруктураИзменений = b2b_ОбменДаннымиПоAPI.ПолучитьВсеИзмененияИзПланаОбмена(
			СтруктураПодключения.Узел, 
			"УстановкаСкидокПоКонтрагентам"
		);
		
		Если СтруктураИзменений = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		СписокДокументовУстановкаСкидокПоКонтрагентам = СтруктураИзменений.Данные;
		
		Если СписокДокументовУстановкаСкидокПоКонтрагентам.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	СтруктураПодключения.Вставить("Данные", СписокДокументовУстановкаСкидокПоКонтрагентам);
	
	// получаем струкуру для отправки на портал
	СтруктураДляВыгрузкиАкций = ПолучитьСтруктуруДляВыгрузкиАкций(СтруктураПодключения);
	
	Если СтруктураДляВыгрузкиАкций = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// создаем соединение и отправляем данные
	ОтправитьВыгружаемыеДанныеНаПорталПоAPI(СтруктураПодключения, СтруктураДляВыгрузкиАкций);
	
КонецПроцедуры 
//Данилова Е.В. 23.07.2025 HELP-6121
Процедура ОтправитьВыгружаемыеДанныеНаПорталПоAPI(СтруктураПодключения, СтруктураДляВыгрузкиНаПортал, РезультатОтправки = Ложь)  Экспорт 
	
	// создаем соединение
	СоединениеHTTP = b2b_ОбменДаннымиПоAPI.HTTPСоединениеДляОбменаДаннымиAPI(СтруктураПодключения);
	
	HTTPзапрос = Новый HTTPзапрос();
	
	ЗаголовокHTTP = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Content-Type", "application/json");
	ЗаголовокHTTP.Вставить("Authorization", СтруктураПодключения.КлючАвторизации);
	
	HTTPЗапрос.Заголовки = ЗаголовокHTTP;
	
	// записываем в РС b2b_ЗапросыНаОбновлениеВОчереди, ТипЗапроса = "ВыгрузкаАкций" 
	ВходныеПараметры = Новый Структура;
	//ВходныеПараметры.Вставить("ИдентификаторОчереди", Структура_JSON_Ответ.requestId); 
	ВходныеПараметры.Вставить("ТипЗапроса", СтруктураПодключения.ТипЗапроса);
	
	Если СтруктураПодключения.ТипЗапроса = "ВыгрузкаКонтрагентов" Тогда
		HTTPзапрос.АдресРесурса = СтруктураПодключения.МетодAPIВыгрузитьКонтрагентов;
	ИначеЕсли СтруктураПодключения.ТипЗапроса = "ВыгрузкаАкций" Тогда
		HTTPзапрос.АдресРесурса = СтруктураПодключения.МетодAPIВыгрузитьАкции;	
	КонецЕсли;
	
	ВходныеПараметры.Вставить("Данные", СтруктураПодключения.Данные);
	
	ТекстЗапроса = b2b_ОбменДаннымиПоAPI.СериализоватьВСтрокуJSON(СтруктураДляВыгрузкиНаПортал);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	// отправка данных на портал и записываем в журнал: b2b_ЗапросыНаОбновлениеИстория
	Попытка
		Ответ = СоединениеHTTP.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		// записываем ошибку в лог РС b2b_ЖурналОшибок
        b2b_ОбменДаннымиПоAPI.ЗаписатьОшибкуОбменДаннымиПоAPI(
			СтруктураПодключения.ИдентификаторЗапроса, 
			, 
			ОписаниеОшибки()
		);
		Возврат;
	КонецПопытки;
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
	
	РезультатЧтенияJSON = b2b_ОбменЗаявками.СтруктураJSONЗапроса(Ответ); 
	Структура_JSON_Ответ =  РезультатЧтенияJSON.Структура_JSON;
	
	b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчереди(
		Строка(СтруктураПодключения.ИдентификаторЗапроса), 
		//++Данилова Е.В. 24.07.2025 HELP-6121
		?(Структура_JSON_Ответ <> неопределено И Структура_JSON_Ответ.Свойство("requestId"),Структура_JSON_Ответ.requestId,""),
		//--Данилова Е.В. 24.07.2025
		ТекстЗапроса, 
		ВходныеПараметры, 
		СтруктураПодключения.ХранитьПодробностиЛогирования
	); 

	// Смирнов М.Ю. 04.08.2025 HELP-6165 начало
	ИдентификаторКлиентаДляЗаписиВРС = "";
	Если Структура_JSON_Ответ <> Неопределено И Структура_JSON_Ответ.Свойство("requestId") Тогда
		ИдентификаторКлиентаДляЗаписиВРС = Структура_JSON_Ответ.requestId;
	КонецЕсли;
	b2b_ОбменЗаявками.ЗаписатьВЖурналЗапросыНаОбновлениеВОчередиРезультат(
		Строка(СтруктураПодключения.ИдентификаторЗапроса),
		ИдентификаторКлиентаДляЗаписиВРС,
		Новый Структура("РезультатJson, ИдентификаторОчереди", Структура_JSON_Ответ, ""),
		,
		,
		Ложь,
		СтруктураПодключения.ХранитьПодробностиЛогирования
	);
	// Смирнов М.Ю. 04.08.2025 HELP-6165 конец
	
	//++Данилова Е.В. 23.07.2025 HELP-6121
	РезультатОтправки = Ответ.КодСостояния = 200; 
	//--Данилова Е.В. 23.07.2025
	
КонецПроцедуры

Функция ПолучитьСтруктуруДляВыгрузкиАкций(СтруктураПодключения) Экспорт
	
	Запрос = Новый Запрос;
	
	Если Не СтруктураПодключения.ПолнаяВыгрузка Тогда
		УсловиеЗапроса = 
		" ГДЕ
		|	УстановкаСкидокПоКонтрагентам.Проведен = ИСТИНА
		|	И УстановкаСкидокПоКонтрагентам.Ссылка В(&СписокДокументов)";
		Запрос.УстановитьПараметр("СписокДокументов", СтруктураПодключения.Данные);
	Иначе
		УсловиеЗапроса = 
		" ГДЕ
		|	УстановкаСкидокПоКонтрагентам.Проведен = ИСТИНА
		|	И УстановкаСкидокПоКонтрагентам.Дата <= &ДатаНачалоДня
		|	И УстановкаСкидокПоКонтрагентам.Дата2 >= &ДатаКонецДня";
	КонецЕсли;
	
	ОбщаяСтруктураВыгружаемыхСкидок = Новый Структура;
	ВнутренняяСтруктураДанных = Новый Структура;
