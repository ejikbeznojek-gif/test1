
Функция ПечатьПакетная(ДопПараметры=Неопределено) Экспорт 
	//крохин начало
	//Катаев+ 31/10/13 Добавил документ
	ЗаписатьВЛог("Печать Документов","Печать накладных. Документ: "+ДокОбъект+" Пользователь: "+ИмяПользователя()+", компьютер: "+ИмяКомпьютера(),"Информация");
	//крохин конец
	
	ТабДок	= Новый ТабличныйДокумент;
	
	МетаДок		= ДокОбъект.Метаданные();
	ВидДокумента= МетаДок.Имя;
	
	Если ВидДокумента="РасходнаяНакладная" Тогда
		ВидНакладной="Расходная накладная";
		Получатель	=ДокОбъект.Контрагент;
	ИначеЕсли ВидДокумента="ПриходнаяНакладная" Тогда
		ВидНакладной="Приходная накладная";				
		Получатель	=ДокОбъект.Склад;
	ИначеЕсли ВидДокумента="Перемещение" Тогда
		ВидНакладной="Перемещение";		
		Получатель	=ДокОбъект.СкладПолучатель;
	ИначеЕсли ВидДокумента="ОтчетКассовойСмены" Тогда
		ВидНакладной="ОКС";		
		Получатель	=ДокОбъект.Касса;				
	ИначеЕсли ВидДокумента="ПродажаИМ" Тогда
		ВидНакладной="Продажа интернет-магазина";		
		Получатель	=ДокОбъект.Контрагент;
	Иначе
		ВидНакладной="";		
	КонецЕсли; 
	
	Макет=ПолучитьМакет("Накладная");
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	//крохин начало 23.08.2011
	//в ЛН нет организации	
	//ОблЗаголовок.Параметры.Фирма		= Объект.Организация.НаименованиеПолное;
	МетаданныеДокумента = ДокОбъект.Метаданные();
	Если ЕстьРеквизитДокумента("Организация",МетаданныеДокумента) Тогда
		ОблЗаголовок.Параметры.Фирма		= ДокОбъект.Организация.НаименованиеПолное;
	Иначе
		ОблЗаголовок.Параметры.Фирма        = Справочники.Организации.НайтиПоКоду("SS-001").НаименованиеПолное; 
	КонецЕсли;
	//крохин конец 23.08.2011
	ОблЗаголовок.Параметры.Склад		= "Склад: "+ДокОбъект.Склад;
	ОблЗаголовок.Параметры.ВидНакладной = ВидНакладной;
	ОблЗаголовок.Параметры.Номер		= ДокОбъект.Номер;		
	ОблЗаголовок.Параметры.Дата			= Формат(ДокОбъект.Дата,"ДФ=dd.MM.yyyy");		
	ОблЗаголовок.Параметры.Получатель	= Получатель;
	Попытка
		ОблЗаголовок.Параметры.ДатаОтгрузки	= "Дата отгрузки: "+Формат(ДокОбъект.ДатаОтгрузки,"ДФ=dd.MM.yyyy");			
	Исключение
		
	КонецПопытки;
	
	Если ЕстьРеквизитДокумента("Комментарий",МетаДок) Тогда
		ОблЗаголовок.Параметры.Комментарий	= СокрЛП(ДокОбъект.Комментарий);	
	КонецЕсли; 
	
	ТабДок.Вывести(ОблЗаголовок);
	
	Если ВидДокумента="РасходнаяНакладная" И ДокОбъект.ДопОбработка>0 Тогда
		ТабДок.Вывести(Макет.ПолучитьОбласть("ЗаголовокДопОбработка"));
		Для Каждого СтрокаТЧ Из ДокОбъект.ДопОбработки Цикл
			Если СтрокаТЧ.ВидДопОбработки=Справочники.ВидыДопОбработки.БезОбработки Тогда Продолжить КонецЕсли; 
			
			ОблСтрока=Макет.ПолучитьОбласть("СтрокаДопОбработки");		
			ОблСтрока.Параметры.Заполнить(СтрокаТЧ);
			
			ОблСтрока.Параметры.ВидДопОбработки = ?(Пустаястрока(строкаТЧ.ВидДопОбработки.Описание) ,строкаТЧ.ВидДопОбработки,СтрокаТЧ.ВидДопОбработки.Описание);
			
			
			ТабДок.Вывести(ОблСтрока);			
		КонецЦикла;	
	КонецЕсли;
	
	ОблШапка	= Макет.ПолучитьОбласть("Шапка");
	
	ТабДок.Вывести(ОблШапка);
	
	ТШК=ПолучитьШтрихКоды(ДокОбъект.Товары);
	
	Сч=0;
	
	//нечаева 03,07,14 добавила кцн++
	//16,07,14 +++ нечаева
	//ТекДокумент=Объект;
    ТК = ПолучитьТаблицуНакладной(ДокОбъект);               
	//16,07,14 --- нечаева
	//нечаева 03,07,14 добавила кцн--
	
	
	Для Каждого СтрокаТоваров Из ТК Цикл
		Если СтрокаТоваров.Количество=0 Тогда Продолжить КонецЕсли; 
		
		СтрокаТШК=ТШК.Найти(СтрокаТоваров.Номенклатура,"Номенклатура");
		Если СтрокаТШК=Неопределено Тогда
			СтрокаТШК=ТШК.Добавить();			
			СтрокаТШК.Номенклатура=СтрокаТоваров.Номенклатура;
		КонецЕсли; 
		
		Сч=Сч+1;
		
		ОблСтрока	= Макет.ПолучитьОбласть("Строка");
		
		ОблСтрока.Параметры.Сч=Сч;
		
		ОблСтрока.Параметры.Заполнить(СтрокаТоваров);					
		ОблСтрока.Параметры.Заполнить(СтрокаТоваров.Номенклатура);		
		ОблСтрока.Параметры.ШтрихКод=СтрокаТШК.ШтрихКод;
		
		ТабДок.Вывести(ОблСтрока);		
	КонецЦикла; 
	
	// нечаева ++
	Если ВидДокумента="ПродажаИМ" Тогда
		
		Для Каждого СтрокаТоваров Из ДокОбъект.Услуги Цикл
			//Если СтрокаТоваров.Количество=0 Тогда Продолжить КонецЕсли; 
			
			СтрокаТШК=ТШК.Найти(СтрокаТоваров.Номенклатура,"Номенклатура");
			Если СтрокаТШК=Неопределено Тогда
				СтрокаТШК=ТШК.Добавить();			
				СтрокаТШК.Номенклатура=СтрокаТоваров.Номенклатура;
			КонецЕсли; 
			
			Сч=Сч+1;
			
			ОблСтрока	= Макет.ПолучитьОбласть("Строка");
			
			ОблСтрока.Параметры.Сч=Сч;
			
			ОблСтрока.Параметры.Заполнить(СтрокаТоваров);					
			ОблСтрока.Параметры.Заполнить(СтрокаТоваров.Номенклатура);		
			ОблСтрока.Параметры.ШтрихКод=СтрокаТШК.ШтрихКод;
			ОблСтрока.Параметры.Количество=0;
			
			ТабДок.Вывести(ОблСтрока);		
		КонецЦикла; 
		
		ОблПодвал	= Макет.ПолучитьОбласть("ПодвалИМ");
		ОблПодвал.Параметры.Сч=Сч;
		ОблПодвал.Параметры.Количество	=ДокОбъект.Товары.Итог("Количество");
		
		ОблПодвал.Параметры.Всего		=ДокОбъект.Товары.Итог("Всего")+ДокОбъект.Услуги.Итог("Всего");
		
		//крохин начало 06.03.2012
		//есть ещё оплата сертификатом
		//ОблПодвал.Параметры.ВсегоКОплате=Объект.Товары.Итог("Всего")+Объект.Услуги.Итог("Всего")-Объект.СуммаБонуса;
		ОблПодвал.Параметры.СуммаОплатыСертификатом = ДокОбъект.СуммаОплатыСертификатом;
		ОблПодвал.Параметры.ВсегоКОплате=ДокОбъект.Товары.Итог("Всего")+ДокОбъект.Услуги.Итог("Всего")-ДокОбъект.СуммаБонуса-ДокОбъект.СуммаОплатыСертификатом;
		//крохин конец 06.03.2012
		ОблПодвал.Параметры.СуммаБонуса	=ДокОбъект.СуммаБонуса;
		
		
	Иначе
		
		
		ОблПодвал	= Макет.ПолучитьОбласть("Подвал");
		ОблПодвал.Параметры.Сч=Сч;
		ОблПодвал.Параметры.Количество	=ДокОбъект.Товары.Итог("Количество");
		
		//крохин начало 06.09.2011	
		//какая-то ахинея, все закомментировал
		//		//крохин начало 23.08.2011
		//	//в ЛН нет организации	
		//	//ОблПодвал.Параметры.Всего		=Объект.Товары.Итог("Всего");
		//	МетаданныеДокумента = Объект.Метаданные();
		//	Если ЕстьРеквизитДокумента("Организация",МетаданныеДокумента) Тогда
		//	ОблЗаголовок.Параметры.Фирма		= Объект.Организация.НаименованиеПолное;
		//Иначе
		//	ОблПодвал.Параметры.Всего		=0; 
		//	КонецЕсли;
		//	//крохин конец 23.08.2011
		ОблПодвал.Параметры.Всего		=ТК.Итог("Всего");
		//крохин конец 06.09.2011
		
	КонецЕсли;
	
	ТабДок.Вывести(ОблПодвал);		
	
	ЗаполнениеДокументов.ВывестиКонтрольнуюИнформациюВВыходнуюТаблицуСервер(ДокОбъект,ТабДок,ПолучитьМакет("Накладная"));
	
	ТабДок.ИмяПараметровПечати	= "ПараметрыПечати_"+ЭтотОбъект.Метаданные().Имя+"_"+ВидДокумента;
	ТабДок.ОтображатьСетку 		= Ложь;	
	ТабДок.ОтображатьЗаголовки 	= Ложь;
	
	Возврат ТабДок;
	
КонецФункции // ПечатьПакетная()


Функция ПолучитьШтрихКоды(ТЧ)
	Номенклатура=ТЧ.ВыгрузитьКолонку("Номенклатура");
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|ВЫБРАТЬ
	|	ШтрихКоды.Владелец КАК Номенклатура,
	|	ШтрихКоды.Наименование КАК ШтрихКод
	|ИЗ
	|	Справочник.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.Владелец В(&Номенклатура)
	//крохин начало 22.09.2015
	//все 9 - служебный ШК, не для печати
    |	И ШтрихКоды.Наименование <> ""9999999999999""	
	//крохин конец 22.09.2015
	|	И ШтрихКоды.ТипШК = &ТипШК
	|	И ШтрихКоды.ВидШК = &ВидШК";
	
	
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("ТипШК",Перечисления.ТипыШтрихКодов.Штука);
	Запрос.УстановитьПараметр("ВидШК",Перечисления.ВидыШК.Основной);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции // ПолучитьШтрихКоды()

//нечаева 03,07,14 добавила кцн++
Функция ПолучитьТаблицуНакладной(ТекДокумент, Режим="Накладная",СФ=Неопределено)
	ТН=Новый ТаблицаЗначений;
	
	ТН.Колонки.Добавить("Номенклатура");	
	ТН.Колонки.Добавить("Количество");
	ТН.Колонки.Добавить("НДС");
	ТН.Колонки.Добавить("Сумма");
	ТН.Колонки.Добавить("Всего");	
	
	Если Режим="СФ"  Тогда		
		Если СФ=Неопределено ИЛИ СФ.Пустая() Тогда
			СообщитьИзМодуля("Невоможно определить сводную СФ для печати !");		
		Иначе
			Запрос=Новый Запрос;
			Запрос.Текст="ВЫБРАТЬ Накладная ИЗ Документ.СчетФактура.Накладные ГДЕ Ссылка=&СФ";
			Запрос.УстановитьПараметр("СФ",СФ);			
			СписокНакладных=Запрос.Выполнить().Выгрузить();
			
			Запрос=Новый Запрос;
			Запрос.Текст="
			|ВЫБРАТЬ
			|	Номенклатура,
			|	СУММА(Количество) КАК Количество,
			|	СУММА(НДС) КАК НДС,
			|	СУММА(Всего) КАК Всего,
			|	Номенклатура.Родитель КАК Модель
			|ИЗ
			|	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
			|ГДЕ
			|	РасходнаяНакладнаяТовары.Ссылка.Ссылка В(&СписокНакладных)
			|СГРУППИРОВАТЬ ПО Номенклатура";		
			
			Запрос.УстановитьПараметр("СписокНакладных",СписокНакладных);
			ИсходнаяТЧ=Запрос.Выполнить().Выгрузить();		
		КонецЕсли; 
	Иначе
		ИсходнаяТЧ=ТекДокумент.Товары.выгрузить();		
	КонецЕсли;
	
	
	//*кцн добавм
	НеУчитыватьРекламации=ложь;
	//крохин начало 15.09.2014
	//а ЛН нет колонок с ценами и рекламаций
	//Если НЕ НеУчитыватьРекламации Тогда
	Если ТипЗнч(СписокНакладных) = ТипЗнч(Документы.ЛистНабора.ПустаяСсылка()) Тогда
	ИначеЕсли НЕ НеУчитыватьРекламации Тогда
	//крохин конец 15.09.2014
	
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	РекламационнаяНакладнаяТовары.Номенклатура,
		|	СУММА(РекламационнаяНакладнаяТовары.Количество) КАК Количество,
		|	СУММА(РекламационнаяНакладнаяТовары.НДС) КАК НДС,
		|	СУММА(РекламационнаяНакладнаяТовары.Всего) КАК Всего
		|ИЗ
		|	Документ.РекламационнаяНакладная.Товары КАК РекламационнаяНакладнаяТовары
		|ГДЕ
		|	РекламационнаяНакладнаяТовары.Ссылка.ДокОснование.Ссылка В(&СписокНакладных)
		|	И РекламационнаяНакладнаяТовары.Ссылка.Проведен
		|
		|СГРУППИРОВАТЬ ПО
		|	РекламационнаяНакладнаяТовары.Номенклатура";		
		Если  СписокНакладных = Неопределено Тогда
			СписокНакладных = ТекДокумент.Ссылка;
		КонецЕсли;
		Запрос.УстановитьПараметр("СписокНакладных",СписокНакладных);
		РекламационнаяТЧ=Запрос.Выполнить().Выгрузить();
		Для Каждого СтрокаТЧ Из РекламационнаяТЧ Цикл
			СтрокаТН=ИсходнаяТЧ.Добавить();
			СтрокаТН.Номенклатура = СтрокаТЧ.Номенклатура;
			СтрокаТН.НДС = -СтрокаТЧ.НДС;
			СтрокаТН.Всего = -СтрокаТЧ.Всего;
			СтрокаТН.Количество = -СтрокаТЧ.Количество;
		КонецЦикла;
		ИсходнаяТЧ.Свернуть("Номенклатура","НДС,Количество,Всего");
		// нечаева 20,11,13  +++
		
		// рекламации по ценам
		// нечаева 05,02,14 +++++++++++
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	КорректировкаЦенВНакладнойТовары.Номенклатура,
		|	СУММА(КорректировкаЦенВНакладнойТовары.Количество) КАК Количество,
		|	СУММА(КорректировкаЦенВНакладнойТовары.НДС) КАК НДС,
		|	СУММА(КорректировкаЦенВНакладнойТовары.Всего) КАК Всего
		|ИЗ
		|	Документ.КорректировкаЦенВНакладной.Товары КАК КорректировкаЦенВНакладнойТовары
		|ГДЕ
		|	КорректировкаЦенВНакладнойТовары.Ссылка.ДокОснование.Ссылка В(&СписокНакладных)
		|	И КорректировкаЦенВНакладнойТовары.Ссылка.Проведен
		|
		|СГРУППИРОВАТЬ ПО
		|	КорректировкаЦенВНакладнойТовары.Номенклатура";		
		Если  СписокНакладных = Неопределено Тогда
			СписокНакладных = ТекДокумент.Ссылка;
		КонецЕсли;
		Запрос.УстановитьПараметр("СписокНакладных",СписокНакладных);
		РекламационнаяТЧ=Запрос.Выполнить().Выгрузить();
		Для Каждого СтрокаТЧ Из РекламационнаяТЧ Цикл
			СтрокаТН=ИсходнаяТЧ.Добавить();
			СтрокаТН.Номенклатура = СтрокаТЧ.Номенклатура;
			СтрокаТН.НДС = -СтрокаТЧ.НДС;
			СтрокаТН.Всего = -СтрокаТЧ.Всего;
			СтрокаТН.Количество =0;
		КонецЦикла;
		ИсходнаяТЧ.Свернуть("Номенклатура","НДС,Количество,Всего");
		
		// нечаева 05,02,14 -----------
		
	Иначе
		
		Запрос=Новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	КорректировкаЦенВНакладнойТовары.Номенклатура,
		|	СУММА(КорректировкаЦенВНакладнойТовары.Количество) как количество,
		|	СУММА(КорректировкаЦенВНакладнойТовары.НДС) как ндс,
		|	СУММА(КорректировкаЦенВНакладнойТовары.Всего)  как всего
		|ИЗ
		|	Документ.КорректировкаЦенВНакладной.Товары КАК КорректировкаЦенВНакладнойТовары
		|ГДЕ
		|	КорректировкаЦенВНакладнойТовары.Ссылка.ДокОснование.Ссылка В(&СписокНакладных)
		|	И (НЕ КорректировкаЦенВНакладнойТовары.Ссылка.Проведен)
		|	И КорректировкаЦенВНакладнойТовары.Ссылка.Отработано = Истина
		|
		|СГРУППИРОВАТЬ ПО
		|	КорректировкаЦенВНакладнойТовары.Номенклатура";		
		Если  СписокНакладных = Неопределено Тогда
			СписокНакладных = ТекДокумент.Ссылка;
