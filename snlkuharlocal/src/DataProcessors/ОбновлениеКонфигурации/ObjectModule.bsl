КонецПроцедуры 

// Добавляет перед управляющими символами знак ^
//
// Параметр:
//  ИсходнаяСтрока - строка, которую требуется подготовить для использования
//                 в командной строке.
//
// Возвращаемое значение:
//  Строка - строка, подготовленная для использования в командной строке.
// 
Функция ПодготовитьСтрокуДляКоманднойСтроки(Знач ИсходнаяСтрока) Экспорт
	
	СтрокаРезультат = ИсходнаяСтрока;
	Спецсимволы     = РазложитьСтрокуВМассивПодстрок("( ) < > | & % """, " ");
	
	Для Каждого СпецСимвол Из Спецсимволы Цикл
		
		СтрокаРезультат = СтрЗаменить(СтрокаРезультат, СпецСимвол, "^" + СпецСимвол);
		
	КонецЦикла;
	
	Возврат СтрокаРезультат;
	
КонецФункции // ПодготовитьСтрокуДляКоманднойСтроки()

