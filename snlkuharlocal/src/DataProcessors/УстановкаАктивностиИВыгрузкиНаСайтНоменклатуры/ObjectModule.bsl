
Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	
	МассивСкладов=новый Массив; 
	МассивКоллекцийОсновной=новый Массив;
	МассивКоллекцийРаспродажный=новый Массив;
	МассивКоллекцийОбщий=новый Массив;  //МассивКоллекцийРаспродажный+МассивКоллекцийОсновной
	МассивНоменклатуры=новый Массив;
	//крохин начало 06.12.2022
	МассивКоллекцийСтильпарк = новый Массив;
	МассивЕмайлов = новый Массив;
		
	//крохин конец 06.12.2022
	СтрокаПараметров="";
	//ТипЦен1 = неопределено;
	//ТипЦен2 = Неопределено;
		
	// Кухарь А.Ю.  27.12.2023 начало
	МассивУстаревшейНоменклатуры = новый Массив; 
	// Кухарь А.Ю.  27.12.2023 конец
	
	
	Если ТаблицаПараметров = Неопределено Тогда
	КонецЕсли;
	
	СтароеИмяПараметра="";
	Для Каждого СтрокаТП ИЗ ТаблицаПараметров Цикл
		
		НовоеИмяПараметра="Параметр: "+СтрокаТП.Имя+" - ";
		если СтароеИмяПараметра<>НовоеИмяПараметра тогда
			ИмяПараметра=НовоеИмяПараметра;
		иначе
			ИмяПараметра="";
		КонецЕсли;
		
		СтрокаПараметров=СтрокаПараметров+", "+ИмяПараметра+СтрокаТП.Значение; 
		
		Если СтрокаТП.Имя = "Склад" Тогда			
			МассивСкладов.Добавить(СтрокаТП.Значение);
		ИначеЕсли  СтрокаТП.Имя = "Номенклатура" Тогда			
			//МассивНоменклатуры.Добавить(СтрокаТП.Значение);   // Шворобей ВЮ 20.09.2023 ++
		ИначеЕсли  СтрокаТП.Имя = "КоллекцияОсновная" Тогда			
			МассивКоллекцийОсновной.Добавить(СтрокаТП.Значение);	
			МассивКоллекцийОбщий.Добавить(СтрокаТП.Значение);	
		ИначеЕсли  СтрокаТП.Имя = "КоллекцияРаспродажная" Тогда			
			МассивКоллекцийРаспродажный.Добавить(СтрокаТП.Значение);
			МассивКоллекцийОбщий.Добавить(СтрокаТП.Значение);
			//крохин начало 06.12.2022
		ИначеЕсли  СтрокаТП.Имя = "КоллекцияСтильпарк" Тогда			
			МассивКоллекцийСтильпарк.Добавить(СтрокаТП.Значение);
			МассивКоллекцийОсновной.Добавить(СтрокаТП.Значение);
			МассивКоллекцийОбщий.Добавить(СтрокаТП.Значение);
			//крохин конец 06.12.202
			// Кухарь А.Ю.  27.12.2023 начало
		ИначеЕсли  СтрокаТП.Имя = "УстаревшаяНоменклатура" Тогда
			МассивУстаревшейНоменклатуры.Добавить(СтрокаТП.значение);
			// Кухарь А.Ю.  27.12.2023 конец
			// Нечаева 10,01,23++
		ИначеЕсли  СтрокаТП.Имя = "Емайл" Тогда
			МассивЕмайлов.Добавить(СтрокаТП.значение);
		ИначеЕсли  СтрокаТП.Имя = "ТипЦен1" Тогда
			ТипЦен1 = СтрокаТП.значение;
		ИначеЕсли  СтрокаТП.Имя = "ТипЦен2" Тогда
			ТипЦен2 = СтрокаТП.значение;
			// Нечаева 10,01,23--	
		КонецЕсли;
		СтароеИмяПараметра=НовоеИмяПараметра;
	КонецЦикла;
	
	
	// Шворобей ВЮ 20.09.2023 ++
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ТоварнаяГруппаВерхнегоУровня
	|	И Номенклатура.ЭтоГруппа
	|	И НЕ Номенклатура.ПометкаУдаления";
	
	УстановитьПривилегированныйРежим(Истина);
	МассивНоменклатуры = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
	УстановитьПривилегированныйРежим(Ложь);
	// Шворобей ВЮ 20.09.2023 ++
	
	МассивВидовКомплекта=новый Массив;
	МассивВидовКомплекта.Добавить(Перечисления.ВидыКомплектов.Комплект);
	МассивВидовКомплекта.Добавить(Перечисления.ВидыКомплектов.Ассортито);
	МассивВидовКомплекта.Добавить(Перечисления.ВидыКомплектов.АссортитоКомплектов);
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////
	//Сначала ставим  активность на элементы из МассивКоллекцийРаспродажный + МассивКоллекцийОсновной, который есть на остатках (1я вложенная табличка)
	//+  ставим активность на элементы из МассивКоллекцийОсновной, который  не снят с производства   (2я вложенная табличка)
	// МассивКоллекцийОбщий это МассивКоллекцийРаспродажный+МассивКоллекцийОсновной 
	
	Запрос = Новый Запрос;
	// Шворобей ВЮ 29.08.2023 ++
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т1.Номенклатура КАК Номенклатура
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|		СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) КАК КоличествоОстаток
	|	ИЗ
	|		РегистрНакопления.ОстаткиТМЦ.Остатки(
	|				&Дата2,
	|				Склад В (&МассивСкладов)
//крохин начало 07.05.2024
//опечатка
//	|					И Номенклатура В ИЕРАРХИИ (&МассивКоллекцийРаспродажный)
    |					И Номенклатура.Ссылка В ИЕРАРХИИ (&МассивНоменклатуры)
//крохин конец 07.05.2024
	|					И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|					И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийОбщий)
	|					И НЕ Номенклатура.ВидКомплекта В (&МассивВидовКомплекта)
	|					И НЕ Номенклатура.ЭтоГруппа
	|					И Номенклатура.ЖизненныйЦиклНоменклатуры <> ЗНАЧЕНИЕ(перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК ОстаткиТМЦОстатки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|					&Дата2,
	|					Склад В (&МассивСкладов)
//крохин начало 07.05.2024
//опечатка	
//	|						И Номенклатура В ИЕРАРХИИ (&МассивКоллекцийРаспродажный)
    |				     	И Номенклатура.Ссылка В ИЕРАРХИИ (&МассивНоменклатуры)
//крохин конец 07.05.2024
	|						И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|						И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийОбщий)
	|						И НЕ Номенклатура.ВидКомплекта В (&МассивВидовКомплекта)
	|						И НЕ Номенклатура.ЭтоГруппа
	|						И Номенклатура.ЖизненныйЦиклНоменклатуры <> ЗНАЧЕНИЕ(перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК РезервыТМЦОстатки
	|			ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|				И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ОстаткиТМЦОстатки.Номенклатура
	|	
	|	ИМЕЮЩИЕ
	|		СУММА(ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0)) > 0
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Номенклатура.Ссылка,
	|		0
	|	ИЗ
	|		Справочник.Номенклатура КАК Номенклатура
	|	ГДЕ
	|		НЕ Номенклатура.ПометкаУдаления
	|		И НЕ Номенклатура.СнятСПроизводства
	|		И Номенклатура.Ссылка В ИЕРАРХИИ(&МассивНоменклатуры)
	|		И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|		И Номенклатура.Родитель.Коллекция В(&МассивКоллекцийОсновной)
	|		И НЕ Номенклатура.ВидКомплекта В (&МассивВидовКомплекта)
	|		И Номенклатура.ЖизненныйЦиклНоменклатуры <> ЗНАЧЕНИЕ(перечисление.ЖизненныйЦиклНоменклатуры.Активна)
	|		И НЕ Номенклатура.ЭтоГруппа) КАК т1";
	// Шворобей ВЮ 29.08.2023 ++
	
	запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);
	запрос.УстановитьПараметр("МассивСкладов",МассивСкладов);
	запрос.УстановитьПараметр("МассивКоллекцийОбщий",МассивКоллекцийОбщий);	
	запрос.УстановитьПараметр("МассивКоллекцийОсновной",МассивКоллекцийОсновной);	
	запрос.УстановитьПараметр("МассивКоллекцийРаспродажный",МассивКоллекцийРаспродажный);	
	запрос.УстановитьПараметр("МассивВидовКомплекта",МассивВидовКомплекта);		
	запрос.УстановитьПараметр("Дата2",ТекущаяДата());
	
	Результат=запрос.Выполнить().Выбрать();
	ЗаписатьВЛог("Регламент","Начало выполнения установка активности элементов номенклатуры. Количество элементов ="+Строка(Результат.Количество())+". "+ СтрокаПараметров,"Информация");
	
	ВыводитьСообщения=ложь;
	#Если Клиент тогда
		ВыводитьСообщения=Истина;
	#КонецЕсли
	
	КоличествоЭлементов=0;
	
	Пока Результат.Следующий() цикл
		НоменклатураОбъект=Результат.Номенклатура.получитьОбъект();
		НоменклатураОбъект.ЖизненныйЦиклНоменклатуры=Перечисления.ЖизненныйЦиклНоменклатуры.Активна;
		попытка
			НоменклатураОбъект.записать();
			если ВыводитьСообщения тогда
				Сообщить("Установлена активность на "+НоменклатураОбъект);
			КонецЕсли;			
			КоличествоЭлементов=КоличествоЭлементов+1;
		Исключение
			ЗаписатьВЛог("Регламент","Не удалось записать "+НоменклатураОбъект.наименование+", "+ОписаниеОшибки(),"Информация");
			Продолжить;
		КонецПопытки;	
	КонецЦикла;
	
	ЗаписатьВЛог("Регламент","Завершение выполнения  установка активности номенклатуры. Обработано "+КоличествоЭлементов+" элементов","Информация");
	
	
	КоличествоЭлементов=0;
	
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////
	//Теперь снимаем  активность на элементы из МассивКоллекцийОсновной , которых нет на остатках + сняты с производства (1я табличка)
	//+  снимаем активность на элементы из МассивКоллекцийРаспродажный, которых нет на остатках   (2я табличка)
	//+ снимаем активность на элементы из которые не входят ни в 1 массив коллекций (3я табличка) 
	
	// Шворобей ВЮ 30.08.2023 ++
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ном.Ссылка, ВложенныйЗапрос.Номенклатура) КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.Количество, 0)) КАК Количество
	|ИЗ
	|	Справочник.Номенклатура КАК ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|			ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ.Остатки(
	|					&Дата2,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В ИЕРАРХИИ (&МассивНоменклатуры)
	|						И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|						И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийОсновной)
	|						И НЕ Номенклатура.ЭтоГруппа
	|						И Номенклатура.СнятСПроизводства
	|						И Номенклатура.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК ОстаткиТМЦОстатки
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|						&Дата2,
	|						Склад В (&МассивСкладов)
	|							И Номенклатура В ИЕРАРХИИ (&МассивНоменклатуры)
	|							И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|							И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийОсновной)
	|							И НЕ Номенклатура.ЭтоГруппа
	|							И Номенклатура.СнятСПроизводства
	|							И Номенклатура.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК РезервыТМЦОстатки
	|				ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|					И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад) КАК ВложенныйЗапрос
	|		ПО ном.Ссылка = ВложенныйЗапрос.Номенклатура
	|ГДЕ
	|	НЕ ном.ПометкаУдаления
	|	И ном.Ссылка В ИЕРАРХИИ(&МассивНоменклатуры)
	|	И ном.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|	И ном.Родитель.Коллекция В(&МассивКоллекцийОсновной)
	|	И ном.СнятСПроизводства
	|	И НЕ ном.ЭтоГруппа
	|	И ном.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ЖизненныйЦиклНоменклатуры.Активна)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ном.Ссылка, ВложенныйЗапрос.Номенклатура)
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.Количество, 0)) <= 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ном.Ссылка, ВложенныйЗапрос.Номенклатура),
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.Количество, 0))
	|ИЗ
	|	Справочник.Номенклатура КАК ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ОстаткиТМЦОстатки.Номенклатура КАК Номенклатура,
	|			ЕСТЬNULL(ОстаткиТМЦОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыТМЦОстатки.КоличествоОстаток, 0) КАК Количество
	|		ИЗ
	|			РегистрНакопления.ОстаткиТМЦ.Остатки(
	|					&Дата2,
	|					Склад В (&МассивСкладов)
	|						И Номенклатура В ИЕРАРХИИ (&МассивНоменклатуры)
	|						И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|						И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийРаспродажный)
	|						И НЕ Номенклатура.ЭтоГруппа
	|						И Номенклатура.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК ОстаткиТМЦОстатки
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТМЦ.Остатки(
	|						&Дата2,
	|						Склад В (&МассивСкладов)
	|							И Номенклатура В ИЕРАРХИИ (&МассивНоменклатуры)
	|							И Номенклатура.Родитель.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ВидыНоменклаутры.Товар)
	|							И Номенклатура.Родитель.Коллекция В (&МассивКоллекцийРаспродажный)
	|							И НЕ Номенклатура.ЭтоГруппа
	|							И Номенклатура.ЖизненныйЦиклНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ЖизненныйЦиклНоменклатуры.Активна)) КАК РезервыТМЦОстатки
	|				ПО ОстаткиТМЦОстатки.Номенклатура = РезервыТМЦОстатки.Номенклатура
	|					И ОстаткиТМЦОстатки.Склад = РезервыТМЦОстатки.Склад) КАК ВложенныйЗапрос
	|		ПО ном.Ссылка = ВложенныйЗапрос.Номенклатура
	|ГДЕ
	|	НЕ ном.ПометкаУдаления  
	//++Данилова Е.В. 29.10.2025 HELP-7654 
