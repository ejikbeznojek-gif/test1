		ТипЦен3=Справочники.ТипыЦен.НайтиПоКоду("SNL-0584");  // SALE ТР (точечная розница))
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТекТипЦен1",ТипЦен1);
	Запрос.УстановитьПараметр("Тектипцен2",ТипЦен2);
	
	СписокНомПОСайту=Запрос.Выполнить().Выгрузить();
	если ВыводитьСообщения тогда
