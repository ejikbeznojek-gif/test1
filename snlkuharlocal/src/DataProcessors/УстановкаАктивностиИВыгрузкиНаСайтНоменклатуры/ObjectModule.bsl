	               |										ТОГДА ""Нет""
	               |									ИНАЧЕ ""Нет""
	               |								КОНЕЦ
	               |						КОНЕЦ
	               |				КОНЕЦ
	               |		КОНЕЦ = ""Да""
	               |	И ИтогоЦены1.Цена1 ЕСТЬ NULL
	               |	И ИтогоЦены2.Цена2 ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Дата2",конецдня(текущаядата()));
	Запрос.УстановитьПараметр("ТекНом",справочники.Номенклатура.НайтиПоКоду("SNL-414140"));
	
	Если типцен1=неопределено ТОгда
		ТипЦен1=Справочники.ТипыЦен.НайтиПоКоду("SNL-0229"); //обцл
