

Процедура Сформировать(ТаблицаПараметров = Неопределено) Экспорт
	ТЗ = Новый ТаблицаЗначений;
	Тз.Колонки.Добавить("Склад");
	ТЗ.Колонки.Добавить("ВидНакладной");
	ТЗ.Колонки.Добавить("НомерНакладной");
	ТЗ.Колонки.Добавить("НомерСтроки");
	ТЗ.Колонки.Добавить("Номенклатура");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗаявкаНаОтгрузкуНакладные.Накладная
	|ИЗ
	|	Документ.ЗаявкаНаОтгрузку.Накладные КАК ЗаявкаНаОтгрузкуНакладные
	|ГДЕ
	|	ЗаявкаНаОтгрузкуНакладные.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ЗаявкаНаОтгрузкуНакладные.Ссылка.Проведен";
	Запрос.УстановитьПараметр("Дата1",НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Дата2",КонецДня(ТекущаяДата()));
	Выборка = Запрос.Выполнить().Выбрать();
	//Кухарь 31.10.18 начало
	//Ещё 1 отбивка по подозрительному объёму паллет
	ОтбивкаПлохойОбъемПаллеты="" ;
	//Кухарь 31.10.18 Конец
	Пока Выборка.Следующий() Цикл 
		Накладная = Выборка.Накладная;
		Если Ложь Тогда
			Накладная = Документы.РасходнаяНакладная.НайтиПоНомеру("");
		КонецЕсли;
		Если Накладная.Метаданные().имя = "РасходнаяНакладная" ИЛИ Накладная.Метаданные().имя = "Перемещение" Тогда
			//Кухарь 31.10.18 начало
			//Ещё 1 отбивка по подозрительному объёму паллет
			если Накладная.КоличествоПаллет>0 Тогда
				РасчОбъемПаллет=Накладная.ОбъемКоробов + 0.15 * Накладная.КоличествоПаллет;		
				если РасчОбъемПаллет>Накладная.ОбъемПаллет тогда
					ОтбивкаПлохойОбъемПаллеты=ОтбивкаПлохойОбъемПаллеты+?(Накладная.Метаданные().имя = "РасходнаяНакладная","РНК ","ПРМ ")+ Накладная.Номер+ " расчётный объём паллет больше фактического."+Символы.ВК
					+" Расчётный объем паллет - "+Строка(РасчОбъемПаллет)+". Фактический объем паллет - "+Строка(Накладная.ОбъемПаллет)+" м3."+Символы.ВК+Символы.ПС;
				КонецЕсли;
			КонецЕсли;		
			//Кухарь 31.10.18 Конец
			Для Каждого СтрокаТЧ Из Накладная.Товары Цикл
				Если СтрокаТЧ.Количество > 0 И СтрокаТЧ.Объем = 0 Тогда
					СтрокаТЗ = ТЗ.Добавить();
					СтрокаТЗ.Склад = Накладная.Склад;
					СтрокаТЗ.ВидНакладной = ?(Накладная.Метаданные().имя = "РасходнаяНакладная","РНК","ПРМ");
					СтрокаТЗ.НомерНакладной = Накладная.Номер;
					СтрокаТЗ.НомерСтроки = СтрокаТЧ.НомерСтроки;
					СтрокаТЗ.Номенклатура = СтрокаТЧ.Номенклатура;				
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	ТЗ.Сортировать("Склад,ВидНакладной,НомерНакладной,НомерСтроки");
	Если ТЗ.Количество() > 0 Тогда
		Текст = "";
		ТекСклад = Справочники.Склады.ПустаяСсылка();
		Для Каждого СтрокаТЗ ИЗ ТЗ Цикл
			Если ТекСклад = СтрокаТЗ.Склад Тогда		
					
				// Кухарь А.Ю.  24.08.2022 начало
				//На складе попросили добавить код номенклатуры в сообщение
				//Текст = Текст + "Не указан объем в  " +СтрокаТЗ.ВидНакладной +" "+СтрокаТЗ.НомерНакладной+". Номер строки: "+СтрокаТЗ.НомерСтроки + ". Номенклатура: "+СтрокаТЗ.Номенклатура +". Объем коробки: "+строка(СтрокаТЗ.Номенклатура.Родитель.ОбъемКоробки)+". Шт. в коробке: "+строка(СтрокаТЗ.Номенклатура.Родитель.ШтукВКоробке)+символы.ВК+"*************************************************"+Символы.ПС;	
				Текст = Текст + "Не указан объем в  " +СтрокаТЗ.ВидНакладной +" "+СтрокаТЗ.НомерНакладной+". Номер строки: "+СтрокаТЗ.НомерСтроки + ". Номенклатура: "+СтрокаТЗ.Номенклатура +" ("+СтрокаТЗ.Номенклатура.код+") "+". Объем коробки: "+строка(СтрокаТЗ.Номенклатура.Родитель.ОбъемКоробки)+". Шт. в коробке: "+строка(СтрокаТЗ.Номенклатура.Родитель.ШтукВКоробке)+символы.ВК+"*************************************************"+Символы.ПС;					
				// Кухарь А.Ю.  24.08.2022 конец
				
			Иначе
				Если НЕ ТекСклад.Пустая() Тогда		
					ПослатьПисьмо(Текст,ТекСклад);
					Текст = "";
				КонецЕсли;
				ТекСклад = СтрокаТЗ.Склад;
				//Текст = "Склад: "+ТекСклад+ символы.ПС;    +" ("+СтрокаТЗ.Номенклатура.код+") "
				// Кухарь А.Ю.  24.08.2022 начало
				//На складе попросили добавить код номенклатуры в сообщение
				// Текст = "Не указан объем в  " +СтрокаТЗ.ВидНакладной +" "+СтрокаТЗ.НомерНакладной+". Номер строки: "+СтрокаТЗ.НомерСтроки + ". Номенклатура: "+СтрокаТЗ.Номенклатура + ". Объем коробки: "+строка(СтрокаТЗ.Номенклатура.Родитель.ОбъемКоробки)+". Шт. в коробке: "+строка(СтрокаТЗ.Номенклатура.Родитель.ШтукВКоробке)+Символы.ВК+"*************************************************"+Символы.ПС;	
				Текст = "Не указан объем в  " +СтрокаТЗ.ВидНакладной +" "+СтрокаТЗ.НомерНакладной+". Номер строки: "+СтрокаТЗ.НомерСтроки + ". Номенклатура: "+СтрокаТЗ.Номенклатура +" ("+СтрокаТЗ.Номенклатура.код+") " + ". Объем коробки: "+строка(СтрокаТЗ.Номенклатура.Родитель.ОбъемКоробки)+". Шт. в коробке: "+строка(СтрокаТЗ.Номенклатура.Родитель.ШтукВКоробке)+Символы.ВК+"*************************************************"+Символы.ПС;	 
				// Кухарь А.Ю.  24.08.2022 конец					
			КонецЕсли;

		КонецЦикла;
		//Потом вернуть
		//ПослатьПисьмо(Текст,ТекСклад);
		
	КонецЕсли;
	
	//Кухарь 31.10.18 начало
	//Ещё 1 отбивка по подозрительному объёму паллет
	если ОтбивкаПлохойОбъемПаллеты<>"" тогда
		//Михайловский С. 20220712 -оповещения настраиваемыми делаем+++
		//вместо

		//СписокПолучателей=новый СписокЗначений;
		//СписокПолучателей.Добавить("semeikina@collant.ru");
		//СписокПолучателей.Добавить("gamova@collant.ru");
		//СписокПолучателей.Добавить("gimelshpak@collant.ru");
		//СписокПолучателей.Добавить("mamchenkov@collant.ru");
		//СписокПолучателей.Добавить("poryadochnov@collant.ru");
		//СписокПолучателей.Добавить("barinov@collant.ru");
		//СписокПолучателей.Добавить("chervyakov@collant.ru");
		//СписокПолучателей.Добавить("turchinskii@collant.ru");
		//СписокПолучателей.Добавить("krohin@collant.ru");
		//СписокПолучателей.Добавить("nikolaev@collant.ru");
		//СписокПолучателей.Добавить("ryabova@collant.ru");
		//// Кухарь А.Ю. 27.12.2021 начало
		//СписокПолучателей.Добавить("operatorschastsy@collant.ru");
		//// Кухарь А.Ю. 27.12.2021 конец
		//настраиваемый список
		СписокПолучателей=СформСписокПолучат(Справочники.ТипыРассылок.НеУказанОбъемВДокументе);
		//Михайловский С. 20220712 -оповещения настраиваемыми делаем---
		ПослатьТестовоеПисьмо(ОтбивкаПлохойОбъемПаллеты,СписокПолучателей,"Некорректный объём паллет.");
	КонецЕсли;
	//Кухарь 31.10.18 Конец
	
	
	
	
