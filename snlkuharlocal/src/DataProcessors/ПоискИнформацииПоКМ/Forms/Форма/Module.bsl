&НаКлиенте
Процедура ПослеВыбораДокумента(ВыбранноеЗначение,ДополнительныеПараметры) Экспорт 

	Если ВыбранноеЗначение = Неопределено Тогда
	
		Возврат;
	Конецесли; 
	
	ДанныеКМ.Очистить();  
	ИнформацияТЧ.Очистить();
		
	Если ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.ЗаказНаЭмиссиюКодовМаркировкиСУЗ") Тогда 
		
		ЗаполнитьДанныеПоЗаказуКМ(ВыбранноеЗначение); 
		
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.МаркировкаТоваровИСМП") Тогда 
		
		ЗаполнитьДанныеПоОперацииМаркировка(ВыбранноеЗначение); 
		
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		
		ЗаполнитьДанныеПоХКМДокОснованию(ВыбранноеЗначение);
		//++Данилова Е.В. 20.10.2025 MARK-3138
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда
		
		ЗаполнитьДанныеПоХКМ(ВыбранноеЗначение); 
		
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("ДокументСсылка.РекламационнаяНакладная") Тогда
		
		ЗаполнитьДанныеПоХКМДокОснованию(ВыбранноеЗначение);
		//--Данилова Е.В. 20.10.2025
		
	КонецЕсли;
	
	ПерезаполнитьНомерСтроки(); 
	
КонецПроцедуры // ВыбранныйДокумент()

&НаСервере
Функция ЗаполнитьДанныеПоЗаказуКМ(Знач ЗаказКМ)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК ШКУпаковки,
		|	ШтрихкодыУпаковокТоваров.Наименование КАК ЗначениеШК
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.ЗаказКМ = &ЗаказКМ";
	
	Запрос.УстановитьПараметр("ЗаказКМ", ЗаказКМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = ДанныеКМ.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи); 
	КонецЦикла; 


КонецФункции // ()

&НаСервере
Функция ЗаполнитьДанныеПоОперацииМаркировка(Знач ОперацияМаркировка)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШКУпаковки,
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки.Наименование КАК ЗначениеШК
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
		|ГДЕ
		|	МаркировкаТоваровИСМП.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодНабора,
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодНабора.Наименование
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
		|			И (МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодНабора <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
		|ГДЕ
		|	МаркировкаТоваровИСМП.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки,
		|	МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки.Наименование
		|ИЗ
		|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
		|		ПО МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка = МаркировкаТоваровИСМП.Ссылка
		|			И (МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
		|ГДЕ
		|	МаркировкаТоваровИСМП.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ОперацияМаркировка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = ДанныеКМ.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи); 
	КонецЦикла;
	
	


КонецФункции // ()

