&НаСервере
Функция ЗаполнитьДанныеПоХКМ(Знач ХКМ)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки КАК ШКУпаковки,
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодУпаковки.Наименование КАК ЗначениеШК
		|ИЗ
		|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
		|		ПО ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка = ХранилищеКодовМаркировки.Ссылка
		|ГДЕ
		|	ХранилищеКодовМаркировки.ссылка = &ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодНабора,
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодНабора.Наименование
		|ИЗ
		|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
		|		ПО ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка = ХранилищеКодовМаркировки.Ссылка
		|			И (ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодНабора <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
		|ГДЕ
		|	ХранилищеКодовМаркировки.ссылка = &ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодКоробки,
		|	ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодКоробки.Наименование
		|ИЗ
		|	Документ.ХранилищеКодовМаркировки.ШтрихкодыУпаковок КАК ХранилищеКодовМаркировкиШтрихкодыУпаковок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ХранилищеКодовМаркировки КАК ХранилищеКодовМаркировки
		|		ПО ХранилищеКодовМаркировкиШтрихкодыУпаковок.Ссылка = ХранилищеКодовМаркировки.Ссылка
		|			И (ХранилищеКодовМаркировкиШтрихкодыУпаковок.ШтрихкодКоробки <> ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка))
		|ГДЕ
		|	ХранилищеКодовМаркировки.ссылка = &ссылка";
	
	Запрос.УстановитьПараметр("ссылка", ХКМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = ДанныеКМ.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
	КонецЦикла;

КонецФункции // ЗаполнитьДанныеПоХКМПНК()

