&НаСервере
Процедура ЗаполнитьМассивКМПоШК(МассивШК)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК ШКУпаковки,
		|	ШтрихкодыУпаковокТоваров.Наименование КАК ЗначениеШК
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.Ссылка В(&МассивШК)";
	
	Запрос.УстановитьПараметр("МассивШК", МассивШК);
	
	ДанныеКМ.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры // ЗаполнитьМассивКМПоШК()

