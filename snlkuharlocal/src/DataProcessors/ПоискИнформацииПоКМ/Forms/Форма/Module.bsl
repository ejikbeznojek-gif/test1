&НаКлиенте
 Процедура ВнешнееСобытие(Источник, Событие, Данные)
	 Если ТолькоПросмотр Тогда Возврат КонецЕсли;
	 Если НЕ ВводДоступен() Тогда Возврат КонецЕсли;
	 
	 Если НЕ ЭтоСобытиеСканера(Событие) Тогда Возврат КонецЕсли;
	 
	 глТорговоеОборудование.СканерПосылкаДанных(1);
	 глСобытиеСканераОтработано = Истина;
	 
	ОбработатьВводШК(Данные);	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВводШК(Данные)
	Если СтрДлина(Данные) < 31 Тогда
		
		Сообщить("В данном документе разрешено сканировать товар только по кодам ЧЗ !", СтатусСообщения.Важное);				
		
	Иначе
		//Валетов + 25,11,2025 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-7967
		//Попались 10 кодов у которых GS стоит впереди.
		Если СтрНайти(Данные, Символ(29)) > 0 Тогда 
			Данные 	= СтрЗаменить(Данные, Символ(29), "");			
		КонецЕсли;
		//Валетов +	
		
		Данные 	= Лев(СтрЗаменить(Данные, Символы.ПС, ""), 31);
		
		ДобавитьЗначениеШКОтсканированное(Данные);
		
		ПерезаполнитьНомерСтроки();
		
	КонецЕсли;		
КонецПроцедуры //ОбработатьВводШК(Данные)


&НаСервере
Функция ДобавитьЗначениеШКОтсканированное(Знач ДанныеОтсканир)
	ДанныеОтсканир	= Лев(СтрЗаменить(ДанныеОтсканир, Символы.ПС, ""), 31);
	
	Результат	= МаркировкаКС.СтруктураРезультата(Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Владелец		КАК Номенклатура,
	|	Владелец.Код	КАК Номенклатура_Код,
	|	Ссылка 			КАК КодМаркировки,
	|	СпособВводаВОборот
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров	
	|ГДЕ
	|	Наименование = &ДанныеКМ
	|	И ( 
	|		ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Товар)
	|		ИЛИ ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|	)
	|";
	
	Запрос.УстановитьПараметр("ДанныеКМ", ДанныеОтсканир);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КодМаркировки) Тогда
		СтрокаТЧ = ДанныеКМ.Добавить(); 		
		СтрокаТЧ.ШКУпаковки = Выборка.КодМаркировки;	
		СтрокаТЧ.ЗначениеШК = ДанныеОтсканир;
		
	Иначе
		СтрокаТЧ = ДанныеКМ.Добавить(); 		
		СтрокаТЧ.ЗначениеШК = ДанныеОтсканир;		
	КонецЕсли; 

	Возврат Результат;
КонецФункции //НайтиТоварПоКМ(ДанныеКМ)
 
&НаКлиенте
 Процедура Проверка1С(Команда)
	 
	ИнформацияТЧ.Очистить();
	
	МассивКМ = ПолучитьМассивКМНаСервере();
	
	
	ПараметрыФона = Новый Массив; 
	ПараметрыФона.Добавить(МассивКМ); 
	
	
	пВыполнения = инт_ДлительныеОперации.ПараметрыВыполненияФункции(Новый УникальныйИдентификатор);
	
	рЗапуска = инт_ДлительныеОперации.ВыполнитьВФоне("Обработка.ПоискИнформацииПоКМ.ПолучитьДанныеПоКодамКМ", ПараметрыФона, пВыполнения);	
	
	Если рЗапуска.Статус = "Ошибка" Тогда
		Сообщить(рЗапуска.ПодробноеПредставлениеОшибки, СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;
	
	пОжидания = инт_ДлительныеОперацииК.ПараметрыОжидания(ЭтотОбъект);
	пОжидания.ВыводитьПрогрессВыполнения = Истина;
	пОжидания.Заголовок = "Получение данных по КМ из базы 1С";
	
	ооЗавершение = Новый ОписаниеОповещения("ОжиданиеЗавершенияФЗ", ЭтотОбъект,Новый Структура("ЗапросВЧЗ",Ложь));
	
	инт_ДлительныеОперацииК.ОжидатьЗавершение(рЗапуска, ооЗавершение, пОжидания);
КонецПроцедуры

&НаСервере
Процедура ПроверитьКодыБезФонаНаСервере()
	
	ИнформацияТЧ.Очистить();
	
	МассивКМ = ПолучитьМассивКМНаСервере();
	
	ОбработкаАПи = Обработки.АпиЧЗ.Создать(); 
	РезультатОтработки  = ОбработкаАПи.ПолучитьДанныеИзЧЗПоКодамКМ(МассивКМ); 
	
	Если ТипЗнч(РезультатОтработки) = Тип("Структура") Тогда		
				
		ОтработатьУспешныйРезультат(РезультатОтработки);
		
		ОтработатьНеНайденныеКодыКМ(РезультатОтработки);
	Иначе 
		Сообщить("Некорректный тип результата запросы: " + ТипЗнч(РезультатОтработки)+" ! Ожидаемый тип: 'Структура' !", СтатусСообщения.Важное);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьКодыБезФона(Команда)
	ПроверитьКодыБезФонаНаСервере();
КонецПроцедуры

