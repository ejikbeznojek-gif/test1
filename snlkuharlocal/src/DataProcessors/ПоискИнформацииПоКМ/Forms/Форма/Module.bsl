&НаКлиенте
Процедура ДанныеКМПриАктивизацииСтроки(Элемент)
	
	ДанныеКМПриАктивизацииСтрокиОтбор();

	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеКМПриАктивизацииСтрокиОтбор()
	
	Перем Текущиеданные, ФиксированныйОтбор;
	
	Текущиеданные = Элементы.ДанныеКМ.ТекущиеДанные;
	
	Если Текущиеданные <> Неопределено
		И ОтборПоСтрокам Тогда
		
		Если ЗначениеЗаполнено(Текущиеданные.ШКУпаковки) Тогда
		
			ФиксированныйОтбор = Новый ФиксированнаяСтруктура(Новый Структура("ШК",Текущиеданные.ШКУпаковки));	
		Иначе 
			ФиксированныйОтбор = Новый ФиксированнаяСтруктура(Новый Структура("requestedCis",Текущиеданные.ЗначениеШК));
		КонецЕсли;
		
		
		Элементы.ИнформацияТЧ.ОтборСтрок = ФиксированныйОтбор ; 
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтрокиТаблицы(ДанныеЗаполнения,Перевод, КолонкиТЧ)   	
	
	НоваяСтрока = ИнформацияТЧ.Добавить();
	
	Для каждого ЭлементСтруктуры Из ДанныеЗаполнения Цикл
		
		Если КолонкиТЧ.Найти(ЭлементСтруктуры.Ключ) = Неопределено Тогда
			
			Продолжить; 	
			
		КонецЕсли; 
		
		
		Если ЭлементСтруктуры.Ключ = "cis"
			ИЛИ ЭлементСтруктуры.Ключ = "requestedCis" Тогда
			
			Если НЕ ЗначениеЗаполнено(НоваяСтрока.ШК)  Тогда
				
				НоваяСтрока.ШК  = НайтиШКПоКМ(ЭлементСтруктуры.Значение);
				ДанныеФакт = СтатусЧЗФакт(НоваяСтрока.ШК); 
				НоваяСтрока.СтатусЧЗФакт = ДанныеФакт.Статус;
				НоваяСтрока.Местонахождение = ДанныеФакт.Местонахождение;
				
			КонецЕсли;
			 
			
		КонецЕсли;
		
		Если ЭлементСтруктуры.Ключ = "child"
			ИЛИ ЭлементСтруктуры.Ключ = "ogvs" 
			 ИЛИ ЭлементСтруктуры.Ключ = "certDoc" Тогда
			
			ЗначениеКлюча = СтрСоединить(ЭлементСтруктуры.Значение,";");
			
		ИначеЕсли  ЭлементСтруктуры.Ключ = "emissionDate" 
			ИЛИ ЭлементСтруктуры.Ключ = "introducedDate"
			ИЛИ ЭлементСтруктуры.Ключ = "applicationDate"
			ИЛИ ЭлементСтруктуры.Ключ = "date" Тогда
			
			ЗначениеКлюча = ПрочитатьДатуJSON(ЭлементСтруктуры.Значение, ФорматДатыJSON.ISO); 
		Иначе
			ЗначениеКлюча  = ПереводЗначенияАПИ(ЭлементСтруктуры.Значение,Перевод); 
		КонецЕсли;
		
		
		НоваяСтрока[ЭлементСтруктуры.Ключ] = ЗначениеКлюча;
		
	КонецЦикла;
	
КонецПроцедуры // ЗаполнитьСтрокиТаблицы()

