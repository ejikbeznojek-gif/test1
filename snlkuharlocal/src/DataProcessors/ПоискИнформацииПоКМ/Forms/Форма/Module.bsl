&НаКлиенте
Процедура ОжиданиеЗавершенияФЗ(Результат = Неопределено, ДопПараметры = Неопределено) Экспорт
	Если ТипЗнч(Результат) = Тип("Структура") Тогда		
		Если Результат.Статус = "Выполнено" Тогда  			
						
			Если ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда
				ДанныеЗапроса = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
				//Данилова Е.В. 24.03.2025
				Если ДанныеЗапроса = неопределено Тогда
				
					ЗаписатьВЛог("Получение информации КМ","Результат фонового задания неопределено","Ошибка"); 	
				    ВозВрат; 
					
				КонецЕсли;
				Если ДопПараметры.ЗапросВЧЗ  Тогда
					
					ОтработатьУспешныйРезультат(ДанныеЗапроса);
					//++Данилова Е.В. 05.03.2025 MARK-1462 
					ОтработатьНеНайденныеКодыКМ(ДанныеЗапроса); 
					//--Данилова Е.В. 05.03.2025	
				Иначе
					Для каждого СоответствиеИзМассива Из ДанныеЗапроса.Данные Цикл
						
						Для каждого ЭлементСоответствия Из СоответствиеИзМассива Цикл
							
							НоваяСтрока = ИнформацияТЧ.Добавить(); 
							ЗаполнитьЗначенияСвойств(НоваяСтрока,ЭлементСоответствия.Значение); 
							
						КонецЦикла;
						
					КонецЦикла;
				КонецЕсли;
				
				ПерезаполнитьНомерСтроки("ИнформацияТЧ");
				
				Если НЕ ДанныеЗапроса.Успешно Тогда
					
					МаркировкаКС.ВывестиОшибки(ДанныеЗапроса);
					
				КонецЕсли; 					
				
				
			Иначе
				ДанныеЗапроса = Неопределено;
			КонецЕсли; 
			
		ИначеЕсли Результат.Статус = "Ошибка" Тогда
			Сообщить(Результат.ПодробноеПредставлениеОшибки, СтатусСообщения.Важное);		
		КонецЕсли;	
	Иначе
		Сообщить("Некорректный тип результата фонового задания: " + ТипЗнч(Результат)+" ! Ожидаемый тип: 'Структура' !", СтатусСообщения.Важное);
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОтработатьНеНайденныеКодыКМ(Знач ДанныеЗапроса) 	
		
	Если ДанныеЗапроса.Сообщения.Количество() > 0  Тогда
		
		Для каждого МассивНеОтрабКодовСтрока Из ДанныеЗапроса.Сообщения Цикл
			
			МассивНеОтрабКодов = СтрРазделить(МассивНеОтрабКодовСтрока,";"); 
			
			Для каждого КодНеОтработанный  Из МассивНеОтрабКодов Цикл
				
				НоваяСтрока = ИнформацияТЧ.Добавить();
				НоваяСтрока.requestedCis = КодНеОтработанный; 
				НоваяСтрока.errorMessage = "КИ не найден";
				НоваяСтрока.ШК  = НайтиШКПоКМ(КодНеОтработанный);
				//НоваяСтрока.СтатусЧЗФакт = СтатусЧЗФакт(НоваяСтрока.ШК);
				ДанныеФакт = СтатусЧЗФакт(НоваяСтрока.ШК); 
				НоваяСтрока.СтатусЧЗФакт = ДанныеФакт.Статус;
				НоваяСтрока.Местонахождение = ДанныеФакт.Местонахождение;
				
			КонецЦикла;
			
		КонецЦикла;
		
		
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОтработатьУспешныйРезультат(Знач ДанныеЗапроса)
	
	КолонкиТЧ 	= КолонкиТЧИнформация();
	Перевод 	= ПереводЗначенияАПИСоответствие();  
	
	Для каждого  ОтработДанныеЗапроса Из ДанныеЗапроса.Данные Цикл
		
		Если ОтработДанныеЗапроса.Успешно  Тогда  		
			
			
			Для каждого ЭлементМассива Из ОтработДанныеЗапроса.Данные Цикл  //ответ 
				
				ДанныеМассив = МаркировкаКС.ПрочитатьЖСОН(ЭлементМассива); //приходит массив
				
				Если ТипЗнч(ДанныеМассив) = Тип("Массив")  Тогда					
					
					Для каждого ДанныеСтруктура Из  ДанныеМассив Цикл
						
						Если ДанныеСтруктура.Свойство("cisInfo")  Тогда
							
							ЗаполнитьСтрокиТаблицы(ДанныеСтруктура.cisInfo,Перевод,КолонкиТЧ); 
							
						КонецЕсли;  									
						
					КонецЦикла; 
					
					
				ИначеЕсли ТипЗнч(ДанныеМассив) = Тип("Структура")
					И ДанныеСтруктура.Свойство("gis") Тогда
					
					ЗаполнитьСтрокиТаблицы(ДанныеСтруктура.gis,Перевод,КолонкиТЧ);
					
				КонецЕсли;
				
			КонецЦикла;
			
			Модифицированность = Ложь; 
			
		Иначе 
			
			МаркировкаКС.ВывестиОшибки(ОтработДанныеЗапроса); 
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

