	Для Каждого ШтрихкодУпаковки Из ВвестиКоды() Цикл
		Если ТипЗнч(ШтрихкодУпаковки) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") Тогда 			
			Строки = ДанныеКМ.НайтиСтроки(Новый Структура("ШКУпаковки", ШтрихкодУпаковки));
		Иначе
			Строки = ДанныеКМ.НайтиСтроки(Новый Структура("ЗначениеШК", ШтрихкодУпаковки));
		КонецЕсли; 
		Для Каждого Строка Из Строки Цикл
			ДанныеКМ.Удалить(Строка);		
		КонецЦикла;
	КонецЦикла;
	ПерезаполнитьНомерСтроки();
КонецПроцедуры

