&НаКлиенте
Процедура ДобавитьКоды(Команда)
	Для Каждого ШтрихкодУпаковки Из ВвестиКоды() Цикл
		
		СтрокаТЧ = ДанныеКМ.Добавить();
		Если ТипЗнч(ШтрихкодУпаковки) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") Тогда
			
			СтрокаТЧ.ШКУпаковки = ШтрихкодУпаковки;	
			СтрокаТЧ.ЗначениеШК = ЗначениеРеквизитаШКУпаковки(ШтрихкодУпаковки);
		Иначе 
			СтрокаТЧ.ЗначениеШК = ШтрихкодУпаковки; 
		КонецЕсли;		
		
	КонецЦикла;
	ПерезаполнитьНомерСтроки();
КонецПроцедуры

