	Перем СтрокаТЧ, ЭлементМассива;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
		Для каждого ЭлементМассива Из ВыбранноеЗначение Цикл
			
			СтрокаТЧ = ДанныеКМ.Добавить();							
			СтрокаТЧ.ШКУпаковки = ЭлементМассива;
			СтрокаТЧ.ЗначениеШК = ЗначениеРеквизитаШКУпаковки(ЭлементМассива);
			
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.ШтрихкодыУпаковокТоваров") Тогда
		
		СтрокаТЧ = ДанныеКМ.Добавить();							
		СтрокаТЧ.ШКУпаковки = ВыбранноеЗначение;
		СтрокаТЧ.ЗначениеШК = ЗначениеРеквизитаШКУпаковки(ВыбранноеЗначение);
		
		
	КонецЕсли;
	
