&НаСервере
Процедура КоллекцииОбъектовМетаданных_НоваяСтрока(Имя, Синоним, Картинка, КартинкаОбъекта, ЭтоКоллекцияОбщие, Таб)
	НоваяСтрока = Таб.Добавить();
	НоваяСтрока.Имя               = Имя;
	НоваяСтрока.Синоним           = Синоним;
	НоваяСтрока.Картинка          = Картинка;
	НоваяСтрока.КартинкаОбъекта   = КартинкаОбъекта;
	НоваяСтрока.ЭтоКоллекцияОбщие = ЭтоКоллекцияОбщие;
КонецПроцедуры

&НаСервере
Функция НоваяСтрокаДерева(Имя, ПолноеИмя, Синоним, Картинка, Родитель, ЭтоОбъектМетаданных = Ложь)
	Коллекция = Родитель.ПолучитьЭлементы();
	НоваяСтрока = Коллекция.Добавить();
	НоваяСтрока.Имя                 = Имя;
	НоваяСтрока.Представление       = ?(ЗначениеЗаполнено(Синоним), Имя+?(ЭтоОбъектМетаданных," ("+Синоним+")",""), Имя);
	НоваяСтрока.Пометка             = 0;
	НоваяСтрока.Картинка            = Картинка;
	НоваяСтрока.ПолноеИмя           = ПолноеИмя;
	НоваяСтрока.ЭтоОбъектМетаданных = ЭтоОбъектМетаданных;      
	НоваяСтрока.ОсновнаяТаблица 	= ?(ЭтоОбъектМетаданных,ПолучитьДанныеПоОбъектуНаСервере(ПолноеИмя),"");;
	Возврат НоваяСтрока;
КонецФункции

&НаСервере
Функция ВыводКоллекцииОбъектовМетаданных(Имя, ПолноеИмя, Синоним, Картинка, КартинкаОбъекта, Родитель = Неопределено, Подсистемы = Неопределено, Проверять = Истина)
	НоваяСтрока = НоваяСтрокаДерева(Имя, ПолноеИмя, Синоним, Картинка, Родитель, Подсистемы <> Неопределено И Подсистемы <> Метаданные.Подсистемы);
	
	Таб = Новый ТаблицаЗначений();
	Таб.Колонки.Добавить("Имя");
	Таб.Колонки.Добавить("ПолноеИмя");
	Таб.Колонки.Добавить("Синоним");
	Таб.Колонки.Добавить("КартинкаОбъекта");
	
	Если Подсистемы = Неопределено Тогда
		Для каждого ЭлементКоллекцииМетаданных ИЗ Метаданные[Имя] Цикл
			Стр = Таб.Добавить();
			Стр.Имя 			= ЭлементКоллекцииМетаданных.Имя; 
			Стр.ПолноеИмя 		= ЭлементКоллекцииМетаданных.ПолноеИмя(); 
			Стр.Синоним 		= ЭлементКоллекцииМетаданных.Синоним; 
			Стр.КартинкаОбъекта = КартинкаОбъекта; 
		КонецЦикла;
	КонецЕсли;
	
	Таб.Сортировать("Имя");
	
	Для каждого СтрокаДобавления ИЗ Таб Цикл
		НоваяСтрокаДерева(СтрокаДобавления.Имя,
		СтрокаДобавления.ПолноеИмя,
		СтрокаДобавления.Синоним,
		СтрокаДобавления.КартинкаОбъекта,
		НоваяСтрока,
		Истина);
	КонецЦикла;
	Возврат НоваяСтрока;
КонецФункции

&НаКлиенте
Процедура ОбработатьТаблицу(Команда)
	Если (Объект.ВыводитьТаблицыСДанными) ИЛИ (Объект.ОчищатьТаблицыСДанными) ИЛИ (Объект.ОчищатьТаблицыСДаннымиРегистров) Тогда
		Попытка
			SQLcon = Новый COMОбъект("ADODB.Connection");
			SQLcon.CursorLocation=3;
			SQLcon.ConnectionTimeout = 30;
			SQLcon.CommandTimeout = 1200;
			SQLcon.Open("File Name="+Объект.ПутьКФайлуПодключенияSQL);
			SQLrst = Новый COMОбъект("ADODB.RecordSet");
			SQLrst.ActiveConnection=SQLcon;
			SQLrst.CursorType=3;
			SQLrst.LockType=3;
		Исключение
			Сообщить("SQL Ошибка! Обратитесь к программисту" + ОписаниеОшибки());
		КонецПопытки;
		cmd = "
		| SELECT TOP 100 * 
		| FROM ["+Объект.НазваниеБД+"].[dbo].["+СтрТЗ.ИмяТаблицыХранения+"]
		|";
		SQLrst=SQLcon.Execute(cmd);
		Если SQLrst.RecordCount>0 Тогда
			Если Объект.ОчищатьТаблицыСДанными Тогда
				SQLrst1 = Новый COMОбъект("ADODB.RecordSet");
				SQLrst1.ActiveConnection=SQLcon;
				SQLrst1.CursorType=3;
				SQLrst1.LockType=3;
				cmd = "
				| DELETE FROM ["+Объект.НазваниеБД+"].[dbo].["+СтрТЗ.ИмяТаблицыХранения+"]
				|  WHERE
				| _Date_Time <=(Convert(datetime,'40121231',104))
				|";
				SQLrst1=SQLcon.Execute(cmd);
				Сообщить(СтрТЗ.ИмяТаблицы+" - удалены данные до 01.01.2013");
			ИначеЕсли Объект.ОчищатьТаблицыСДаннымиРегистров Тогда
				SQLrst1 = Новый COMОбъект("ADODB.RecordSet");
				SQLrst1.ActiveConnection=SQLcon;
				SQLrst1.CursorType=3;
				SQLrst1.LockType=3;
				cmd = "
				| DELETE FROM ["+Объект.НазваниеБД+"].[dbo].["+СтрТЗ.ИмяТаблицыХранения+"]
				|";
				SQLrst1=SQLcon.Execute(cmd);
				Сообщить(СтрТЗ.ИмяТаблицы+" - удалены данные");
			Иначе
				Сообщить(СтрТЗ.ИмяТаблицыХранения);
			КонецЕсли;
		КонецЕсли;
		SQLrst.Close();
		SQLcon.Close();
	КонецЕсли;
КонецПроцедуры

