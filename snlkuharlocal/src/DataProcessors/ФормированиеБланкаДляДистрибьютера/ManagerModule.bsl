
Функция ОтправитьВОблакоМейл(Файл, СтруктураНастроек = Неопределено) Экспорт
	
	Если СтруктураНастроек = Неопределено Тогда
		СтруктураНастроек = СоздатьСтруктуруНастроек(Неопределено, "ListBuckets");
	КонецЕсли;
	
	СтруктураВозвратаGET = ОтправитьGETЗапрос(СтруктураНастроек);
	
	Если СтруктураВозвратаGET.КодСостояния = 200 Тогда
		СтруктураНастроек = СоздатьСтруктуруНастроек(СтруктураНастроек, "ListObjects");
		СтруктураВозвратаGET = ОтправитьGETЗапрос(СтруктураНастроек);
	КонецЕсли;
	
	Если СтруктураВозвратаGET.КодСостояния = 200 Тогда
		СтруктураНастроек.Вставить("ИмяФайла", Файл);
		СтруктураНастроек = СоздатьСтруктуруНастроек(СтруктураНастроек, "UploadFile");
		СтруктураВозвратаPUT = ОтправитьPUTЗапрос(СтруктураНастроек);
		Возврат СтруктураВозвратаPUT;
	КонецЕсли;
	
	Возврат СтруктураВозвратаGET;
	
КонецФункции

Функция СоздатьСтруктуруНастроек(СтруктураНастроек = Неопределено, ИмяКоманды = "ListBuckets") Экспорт
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	// Cloud Storage предоставляет RESTful XML API для программного управления хранимыми данными с помощью стандартных HTTP-запросов.
	// API-интерфейс совместим с API-интерфейсом Amazon AWS S3, что позволяет взаимодействовать с сервисом, используя уже известные инструменты.

	// Основной протокол доступа к Cloud Storage — это протокол, созданный Amazon Web Services для сервиса AWS S3 (Simple Storage Service).

	// Вы можете передавать команды Cloud Storage через клиент AWS CLI.

	//Перед началом работы с API создайте аккаунт и бакет, если этого не сделано ранее.
	
	// Создать необходимый ключ доступа и секретный ключ можно в меню "Аккаунты" сервиса "Объектное хранилище" графического интерфейса панели VK Cloud.
	// При создании аккаунта будет сгенерирован Access Key ID и Secret Key значения, которые необходимы для использования.
	//////////////////////////////////////////////////////////////////////////////////////////////
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	// Endpoint URL:        https://hb.vkcs.cloud или https://hb.ru-msk.vkcs.cloud (наш hb.bizmrg.com)
	// Access Key ID:       k9bZfEbRMg8CmftNDCwjNp
	// Secret Key:          hyb57DvWoWhR39cdtXgYEnbtVw19ugyJWa9sd18Mzr2J
	// Default region name: ru-msk
	// Service:		        s3
	// Hash algorithm:		AWS4-HMAC-SHA256
	// Current Prefix:		report1c
	//////////////////////////////////////////////////////////////////////////////////////////////
	
	Если СтруктураНастроек = Неопределено Тогда
		СтруктураНастроек = Новый Структура;
	КонецЕсли;
	
	/////////// НЕИЗМЕНЯЕМЫЕ ПАРАМЕТРЫ ///////////////////////////////////////////////////////////
	
	СтруктураНастроек.Вставить("AccessKey",     "id3bqTbD9fu9ADM7UAi1VM");
	СтруктураНастроек.Вставить("SecretKey",     "8kiVMbqecF5mwYmQCwsZBuuyiDH1Wq6Ze9YtZx7k2k7e");
	СтруктураНастроек.Вставить("EndPoint",      "hb.ru-msk.vkcs.cloud");
	
	СтруктураНастроек.Вставить("AWS4_request",  "aws4_request");
	СтруктураНастроек.Вставить("HashAlgorithm", "AWS4-HMAC-SHA256");
	СтруктураНастроек.Вставить("Region",        "ru-msk");
	СтруктураНастроек.Вставить("Service",       "s3");
	
	СтруктураНастроек.Вставить("BucketName",    "collantpics");
	СтруктураНастроек.Вставить("CurrentPrefix", "report");
	
	/////////// ВЫЧИСЛЯЕМЫЕ ПАРАМЕТРЫ ////////////////////////////////////////////////////////////
	
	Дата = ТекущаяУниверсальнаяДата();
	СтруктураНастроек.Вставить("dateStamp", 				Формат(Дата, "ДФ=""ггггММдд"""));
	СтруктураНастроек.Вставить("date", 						ДатаAmz(Дата));
	СтруктураНастроек.Вставить("ФлагЗащищенноеСоединение",  Истина);
	
	/////////////// ПРЕФИКС ///////////////////////////////////////////////////////////////////////
	
	Prefix = СтрЗаменить(ПреобразованиеСтрокиВURL(СтруктураНастроек.CurrentPrefix), "%2F", "/");  
	PrefixEncoded = ПреобразованиеСтрокиВURL(СтруктураНастроек.CurrentPrefix);
	СтруктураНастроек.Вставить("PrefixEncoded", PrefixEncoded);
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	// ОБЩИЕ ЗАГОЛОВКИ
	// Общие заголовки, которые можно использовать в большинстве запросов:
	//
	// Authorization  - Детали авторизации для запроса в формате AWS Signature Version 4 или AWS Signature Version 2
	// Content-Length - Длина тела запроса в байтах. Требуется для запросов PUT, содержащих тело XML.
	// Content-Type   - Тип MIME тела запроса (например text/plain)
	// Date           - Текущая дата и время в формате всемирного координированного времени (UTC) в формате RFC 2822. Пример: Mon, 10 Jul 2017 19:05:09 +0000
	// Host           - Целевой хост для запроса (например, my-test-bucket1.hb.vkcs.cloud).
	// x-amz-content-sha256 - Хэш SHA256 полезной нагрузки запроса. Требуется при использовании AWS Signature Version 4 для аутентификации.
	// x-amz-date     - Текущая дата и время в формате всемирного координированного времени (UTC) с использованием формата ISO 8601: %Y%m%dT%H%M%SZ (например 20200831T172753Z).
	//                  Если предоставляется, он имеет приоритет над заголовком «Дата».
	///////////////////////////////////////////////////////////////////////////////////////////////
	
	///////////////////////////////////////////////////////////////////////////////////////////////
	// CanonicalRequest =
	// ${HTTPMethod}\n                   "GET", "PUT", "POST"
	// ${canonicalURI}\n                 UriEncode(resource)                                      (АдресМетода)
	// ${canonicalQueryString}\n         UriEncode(QueryParameter1)+"="+UriEncode(Value1)+"&"+
	//									 UriEncode(QueryParameterN)+"="+UriEncode(ValueN)         (ПараметрыЗапроса)
	// ${canonicalHeaders}\n             НРЕГ(HeaderName1)+":"+СокрЛП(Value1)+"\n"+
	//									 НРЕГ(HeaderNameN)+":"+СокрЛП(ValueN)+"\n"
	// ${signedHeaders}\n                НРЕГ(HeaderName1)+";"+НРЕГ(HeaderName2)+";"+НРЕГ(HeaderNameN)
	// ${HashedPayload}                  Hex(SHA256Hash(payload))
	//
	// stringToSign = "AWS4-HMAC-SHA256" + "\n" +
	//		date(format=ISO08601) + "\n" +
	//		date(format=YYYYMMDD) + "/" + "ru-msk" + "/" + "s3/aws4_request" + "\n" +
	//		Hex(SHA256Hash(CanonicalRequest))
	//
	// dateKey = HMAC-SHA256("AWS4" + ${SECRET_KEY}, date(format=YYYYMMDD))
	// dateRegionKey = HMAC-SHA256(dateKey, "ru-msk")
	// dateRegionServiceKey = HMAC-SHA256(dateRegionKey, "s3")
	// signingKey = HMAC-SHA256(dateRegionServiceKey, "aws4_request")
	// signature = Hex(HMAC-SHA256(signingKey, stringToSign))
	/////////////////////////////////////////////////////////////////////////////////////////////////
	
	// HTTPMethod— это один из методов HTTP, например GET, PUT, HEAD и DELETE.
	
	// CanonicalURI— это закодированная в URI версия компонента абсолютного пути URI — все, что начинается с «/», следующего за именем домена,
	// и до конца строки или до символа вопросительного знака ('?'), если у вас есть запрос строковые параметры.
	// URI в следующем примере — /examplebucket/myphoto.jpg это абсолютный путь, и вы не кодируете «/» в абсолютном пути
	
	// CanonicalQueryString указывает параметры строки запроса в кодировке URI. Вы URI-кодируете имя и значения индивидуально.
	// Вы также должны отсортировать параметры в канонической строке запроса в алфавитном порядке по имени ключа. Сортировка происходит после кодирования.
	// Строка запроса в следующем примере URI prefix=somePrefix&marker=someMarker&max-keys=20:
	
	// http://s3.amazonaws.com/examplebucket?prefix=somePrefix&marker=someMarker&max-keys=20
	// Каноническая строка запроса выглядит следующим образом (для удобства чтения в этот пример добавлены разрывы строк):
	
	// UriEncode("marker")+"="+UriEncode("someMarker")+"&"+
	// UriEncode("max-keys")+"="+UriEncode("20") + "&" +
	// UriEncode("prefix")+"="+UriEncode("somePrefix")
	
	// CanonicalHeaders представляет собой список заголовков запросов с их значениями. Отдельные пары имени и значения заголовка разделяются символом
	// новой строки («\n»). Имена заголовков должны быть в нижнем регистре. Чтобы построить строку, необходимо отсортировать имена заголовков в алфавитном порядке,
	// как показано в следующем примере:
	
	// Lowercase(<HeaderName1>)+":"+Trim(<value>)+"\n"
	// Lowercase(<HeaderName2>)+":"+Trim(<value>)+"\n"
	// ...
	// Lowercase(<HeaderNameN>)+":"+Trim(<value>)+"\n"
	
	// Список CanonicalHeaders должен включать следующее:
	// HTTP - host заголовок.
	// Если Content-Type заголовок присутствует в запросе, его необходимо добавить в CanonicalHeaders список.
	// Также необходимо добавить любые x-amz-* заголовки, которые вы планируете включить в свой запрос.
	// Например, если вы используете временные учетные данные безопасности, вам необходимо включить их x-amz-security-token в свой запрос.
	// Вы должны добавить этот заголовок в список файлов CanonicalHeaders.
	
	// Заголовок x-amz-content-sha256 необходим для всех запросов AWS Signature версии 4. Он предоставляет хэш полезной нагрузки запроса.
	// Если полезных данных нет, необходимо предоставить хеш пустой строки.
	
	// SignedHeaders представляет собой отсортированный в алфавитном порядке список имен заголовков запроса, разделенных точкой с запятой.
	// Заголовки запросов в списке — это те же заголовки, которые вы включили в CanonicalHeadersстроку. Например, для предыдущего примера
	// значение SignedHeadersбудет следующим:  host;x-amz-content-sha256;x-amz-date
	
	// HashedPayload — шестнадцатеричное значение хэша SHA256 полезных данных запроса Hex(SHA256Hash(<payload>) (ТелоЗапроса)
	
	// Если в запросе нет ТелоЗапроса, вы вычисляете хэш пустой строки следующим образом:
	// Hex(SHA256Hash("")) - хэш возвращает следующее значение: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
	
	// Например, когда вы загружаете объект с помощью запроса PUT, вы предоставляете данные объекта в теле.
	// Когда вы извлекаете объект с помощью запроса GET, вы вычисляете хеш пустой строки.
	
	/////////// НАСТРАИВАЕМЫЕ ПАРАМЕТРЫ //////////////////////////////////////////////////////////
	
	Если ИмяКоманды = "UploadFile" Тогда
		СтруктураНастроек.Вставить("HTTPMethod", "PUT");
	Иначе	
		СтруктураНастроек.Вставить("HTTPMethod", "GET");       // "PUT", "POST"
	КонецЕсли;
	
	////////// НАДО ЭКРАНИРОВАТЬ ИМЯ ФАЙЛА ///////////////////////////////////////////////////////
	
	Если СтруктураНастроек.Свойство("ИмяФайла") Тогда
		Файл = Новый Файл(СтруктураНастроек.ИмяФайла);
		Если Файл.Существует() Тогда
			ИмяФайлаEncoded = СтрЗаменить(ПреобразованиеСтрокиВURL(Файл.Имя), "%2F", "/");
			СтруктураНастроек.Вставить("ИмяФайлаEncoded", ИмяФайлаEncoded);
		КонецЕсли;
	КонецЕсли;
	
	СтруктураНастроек.Вставить("Метод", "/" + ?(ИмяКоманды = "UploadFile", СтруктураНастроек.CurrentPrefix + "/" + ИмяФайлаEncoded, ""));  // "/" + СтруктураНастроек.BucketName + "/"
	
	//////////////////// ЗАПРОС НА ПОДКЛЮЧЕНИЕ ////////////////////////////////////////////////////
	// Адрес: http://<AccessKey>@<EndPoint>      http://k9bZfEbRMg8CmftNDCwjNp@hb.bizmrg.com
	///////////////////////////////////////////////////////////////////////////////////////////////
	
	QueryParameters = Новый Структура;
	СтруктураНастроек.Вставить("ПараметрыЗапроса", QueryParameters);
	
	ТелоЗапроса = ""; // Это полезные данные, передаваемые в запрос, для GET не нужно
	Если ИмяКоманды = "CreateBucket" Тогда
		ТелоЗапроса = "<CreateBucketConfiguration><LocationConstraint>ru-msk</LocationConstraint></CreateBucketConfiguration>";
	КонецЕсли;
	СтруктураНастроек.Вставить("ТелоЗапроса", ТелоЗапроса);   // Payload
	
	/////////////////// ЗАГОЛОВКИ ////////////////////////////////////////////////////////////////
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Host", ?(ИмяКоманды = "UploadFile" ИЛИ ИмяКоманды = "ListObjects", СтруктураНастроек.BucketName + ".", "") + СтруктураНастроек.EndPoint);
	
	//Кухарь А.Ю.  09.01.2024 начало
	// 	Заголовки.Вставить("Content-Type","application/xml;charset=windows-1251");   // application/xml
	Заголовки.Вставить("Content-Type","application/vnd.ms-excel;charset=windows-1251");   // application/vnd.ms-excel
	//Кухарь А.Ю.  09.01.2024 конец
	
	
	Если ИмяКоманды = "UploadFile" Тогда
		contentHash = Lower(GetHexStringFromBinaryData(ХешФайла(СтруктураНастроек.ИмяФайла, HashFunction.SHA256)));
	Иначе
		contentHash = HexSHA256Hash(СтруктураНастроек.ТелоЗапроса);	
	КонецЕсли;
	
	Заголовки.Вставить("x-amz-content-sha256", contentHash);
	Заголовки.Вставить("x-amz-date", ДатаAmz(Дата));
	
	ТЗЗаголовков = ПолучитьТаблицуПараметров(Заголовки);
	ТЗЗаголовков.Сортировать("Параметр Возр");
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	// queryParams = "delimiter=%2F&list-type=2&max-keys=" + Object.MaxKeysPerRequest + "&prefix=" + PrefixEncoded;
	
	CanonicalQueryString = "";
	Для Каждого Элемент ИЗ QueryParameters Цикл
		CanonicalQueryString = CanonicalQueryString + ПреобразованиеСтрокиВURL(Элемент.Ключ) + "=" + ПреобразованиеСтрокиВURL(Элемент.Значение) + "&";	
	КонецЦикла;
	CanonicalQueryString = Лев(CanonicalQueryString, СтрДлина(CanonicalQueryString) - 1);
	
	CanonicalHeaders = ""; SignedHeaders = "";
	Для Каждого Стр ИЗ ТЗЗаголовков Цикл
		CanonicalHeaders = CanonicalHeaders + НРЕГ(Стр.Параметр) + ":" + СокрЛП(Стр.Значение) + Символы.ПС;
		SignedHeaders = SignedHeaders + НРЕГ(Стр.Параметр) + ";";
	КонецЦикла;
	SignedHeaders = Лев(SignedHeaders, СтрДлина(SignedHeaders) - 1);
	
	Credential = СтруктураНастроек.AccessKey + "/" + СтруктураНастроек.dateStamp + "/" + СтруктураНастроек.Region + 
		"/" + СтруктураНастроек.Service + "/" + СтруктураНастроек.AWS4_request;
	
	//////////////////////////////////////////////////////////////////////////////////////////////
	//	CanonicalRequest = verb + NewLine +
	//		AbsolutePath + NewLine +
	//		queryParams + NewLine + 
	//		"content-type:" + contentType + NewLine +   
	//		"host:" + HostS3 + NewLine  +
	//		"x-amz-content-sha256:" + contentHash + NewLine  +
	//		"x-amz-date:" + date + NewLine + 
	//		NewLine +
	//		"content-type;host;x-amz-content-sha256;x-amz-date" + NewLine +
	//		"" + contentHash;
	
	CanonicalRequest = СтруктураНастроек.HTTPMethod + Символы.ПС +
		СтруктураНастроек.Метод + Символы.ПС +
		CanonicalQueryString + Символы.ПС +
		CanonicalHeaders + Символы.ПС +
		SignedHeaders + Символы.ПС +
		contentHash;
		
	/////////////////////////////////////////////////////////////////////////////////////////////////
	//	date 	  = Format(CurrentUniversalDate(), "DF=yyyyMMddTHHmmssZ");
	//	dateStamp = Format(CurrentUniversalDate(), "DF=yyyyMMdd");
	//	scope = dateStamp + "/" + Object.Region + "/" + Object.Service + "/aws4_request";
	//	stringToSign = "AWS4-HMAC-SHA256" + NewLine + date + NewLine + scope + NewLine + canonicalRequestHash;
	
	//	canonicalRequestByte = Hash(CanonicalRequest, HashFunction.SHA256);    
	//	canonicalRequestHash = Lower(GetHexStringFromBinaryData(canonicalRequestByte));
	
	StringToSign = СтруктураНастроек.HashAlgorithm + Символы.ПС +
		СтруктураНастроек.date + Символы.ПС + СтруктураНастроек.dateStamp + "/" +
		СтруктураНастроек.Region + "/" + СтруктураНастроек.Service + "/" + СтруктураНастроек.AWS4_request + Символы.ПС +
		HexSHA256Hash(CanonicalRequest);
		
	/////////////////////////////////////////////////////////////////////////////////////////////////
	//	SigningKey = GetSignatureKey(Object.SecretKey, dateStamp, Object.Region, Object.Service);
	//	signatureByte = HMACSHA256(SigningKey, GetBinaryDataFromString(stringToSign));   
	//	signatureHash = Lower(GetHexStringFromBinaryData(signatureByte));
	//	
	//	Authorization = "AWS4-HMAC-SHA256 Credential=" + Object.AccessKey + "/" + scope 
	//		+ ",SignedHeaders=content-type;host;x-amz-content-sha256;x-amz-date,Signature=" + signatureHash;
	
	SigningKey = GetSignatureKey(СтруктураНастроек);
	signatureHash = SignatureCalculate(SigningKey, StringToSign);
	
	Authorization = СтруктураНастроек.HashAlgorithm + " " +
		"Credential=" + Credential + "," +
		"SignedHeaders=" + SignedHeaders + "," +
		"Signature=" + signatureHash;
	
	Заголовки.Вставить("Authorization", Authorization);
	СтруктураНастроек.Вставить("Заголовки", Заголовки);
	
	Возврат СтруктураНастроек;
	
КонецФункции

////////////// POST Запрос с Телом выгрузки /////////////////////////////////////////////////////////////
// АдресМетода, Ресурс, ТелоЗапроса, ПараметрыЗапроса, ФлагЗащищенноеСоединение = Истина
/////////////////////////////////////////////////////////////////////////////////////////////////////////
Функция ОтправитьPUTЗапрос(СтруктураНастроек) Экспорт
	
	SSL = ?(СтруктураНастроек.ФлагЗащищенноеСоединение = Истина, Новый ЗащищенноеСоединениеOpenSSL(), Неопределено);
	
 	Попытка 
		СоединениеHTTP = Новый HTTPСоединение(СтруктураНастроек.EndPoint,443,,,,, SSL);
	Исключение
		СообщитьОбОшибке(ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
	Ресурс = СтруктураНастроек.Метод + ?(СтруктураНастроек.ПараметрыЗапроса.Количество() > 0, "?", "");
	
	Если СтруктураНастроек.ПараметрыЗапроса.Количество() > 0 Тогда
		Сч = 0;
		Для Каждого Элемент Из СтруктураНастроек.ПараметрыЗапроса Цикл
			Если Сч = 0 Тогда
				Ресурс = Ресурс + Элемент.Ключ + "=" + Элемент.Значение;
			Иначе
				Ресурс = Ресурс + "&" + Элемент.Ключ + "=" + Элемент.Значение;
			КонецЕсли;
			Сч = Сч + 1;
		КонецЦикла;
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(Ресурс, СтруктураНастроек.Заголовки);
	
	Если СтруктураНастроек.ТелоЗапроса <> "" Тогда
		HTTPЗапрос.УстановитьТелоИзСтроки(СтруктураНастроек.ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("ИмяФайла") Тогда
		HTTPЗапрос.УстановитьИмяФайлаТела(СтруктураНастроек.ИмяФайла);
	КонецЕсли;
	
	HTTPОтвет = СоединениеHTTP.ВызватьHTTPМетод(СтруктураНастроек.HTTPMethod, HTTPЗапрос);
	
	ОтветСервера = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
	Если ОтветСервера <> "" Тогда
		Результат = ЧитатьXML(ОтветСервера, Истина);
	Иначе
		Результат = "";
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура("Результат", Результат);
	
	Возврат Результат;
	
КонецФункции

///////////////// GET Запрос с Параметрами ///////////////////////////////////////////////////////////
//    Сервер, Метод, ПараметрыЗапроса, Заголовки, Пользователь = Неопределено, Пароль = Неопределено, ФлагЗащищенноеСоединение = Истина
//////////////////////////////////////////////////////////////////////////////////////////////////////
Функция ОтправитьGETЗапрос(СтруктураНастроек) Экспорт
	
	SSL = ?(СтруктураНастроек.ФлагЗащищенноеСоединение = Истина, Новый ЗащищенноеСоединениеOpenSSL(), Неопределено);

	Попытка
		Соединение = Новый HTTPСоединение(СтруктураНастроек.EndPoint,443,,,,, SSL);
	Исключение
		СообщитьОбОшибке(ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
	Ресурс = СтруктураНастроек.Метод + ?(СтруктураНастроек.ПараметрыЗапроса.Количество() > 0, "?", "");
	
	Если СтруктураНастроек.ПараметрыЗапроса.Количество() > 0 Тогда
		Сч = 0;
		Для Каждого Элемент Из СтруктураНастроек.ПараметрыЗапроса Цикл
			Если Сч = 0 Тогда
				Ресурс = Ресурс + Элемент.Ключ + "=" + Элемент.Значение;
			Иначе
				Ресурс = Ресурс + "&" + Элемент.Ключ + "=" + Элемент.Значение;
			КонецЕсли;
			Сч = Сч + 1;
		КонецЦикла;
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(Ресурс, СтруктураНастроек.Заголовки);
	
	ОтветСервера = Соединение.Получить(HTTPЗапрос);
	
	ТекстОтвета = ОтветСервера.ПолучитьТелоКакСтроку();
	
	Результат = ЧитатьXML(ТекстОтвета, Истина);
	
	СтруктураВозврата = Новый Структура("КодСостояния, Результат", ОтветСервера.КодСостояния, Результат);
	
	Возврат СтруктураВозврата;
	
КонецФункции

////////////////// ФУНКЦИИ ШИФРОВАНИЯ КЛЮЧА /////////////////////////////////////////////////////////////

#Область HMAC_SHA256

Function GetSignatureKey(СтруктураНастроек) 
	
	DateKey				 = HMACSHA256("AWS4" + СтруктураНастроек.SecretKey, СтруктураНастроек.dateStamp);  // HMACSHA256("AWS4" + СтруктураНастроек.SecretKey, GetBinaryDataFromString(СтруктураНастроек.dateStamp));
	DateRegionKey 		 = HMACSHA256(DateKey, СтруктураНастроек.Region);   //  GetBinaryDataFromString(СтруктураНастроек.Region)
	DateRegionServiceKey = HMACSHA256(DateRegionKey, СтруктураНастроек.Service);  //  GetBinaryDataFromString(СтруктураНастроек.Service)
	SigningKey 	 	 	 = HMACSHA256(DateRegionServiceKey,	СтруктураНастроек.AWS4_request);  //  GetBinaryDataFromString(СтруктураНастроек.AWS4_request)

    Return SigningKey; 
	
EndFunction

// Формирует подпись переданных данных с помощью переданного ключа алгоритмом HMAC-SHA256.
//
// Параметры:
//   Ключ - ДвоичныеДанные - двоичные данные ключа подписи.
//   Данные - Строка - подписываемые данные.
//
// Возвращаемое значение:
//   Строка - подпись в формате Base64.
//
Функция SignatureCalculate(Ключ, Данные) Экспорт
	
	Возврат Lower(GetHexStringFromBinaryData(HMACSHA256(Ключ, Данные)));
	
КонецФункции

// Параметры:
//   Ключ - ДвоичныеДанные - двоичные данные ключа подписи.
//   Данные - Строка - подписываемые двоичные данные.
Функция HMACSHA256(Знач ВходнойКлюч, Знач ВходныеДанные) Экспорт
	
	Если ТипЗнч(ВходнойКлюч) = Тип("Строка") Тогда
		Ключ = ПолучитьДвоичныеДанныеИзСтроки(ВходнойКлюч);
	Иначе
		Ключ = ВходнойКлюч;
	КонецЕсли;
	
	Если ТипЗнч(ВходныеДанные) = Тип("Строка") Тогда
		Данные = ПолучитьДвоичныеДанныеИзСтроки(ВходныеДанные);
	Иначе
		Данные = ВходныеДанные;
	КонецЕсли;
	
	Возврат HMAC(Ключ, Данные, ХешФункция.SHA256, 64);
	
КонецФункции

