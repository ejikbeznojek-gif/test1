Функция СоздатьТаблицуПараметровЗапроса() Экспорт
	ПараметрыЗапроса = Новый ТаблицаЗначений;
	ПараметрыЗапроса.Колонки.Добавить("Параметр");
	ПараметрыЗапроса.Колонки.Добавить("Значение");
