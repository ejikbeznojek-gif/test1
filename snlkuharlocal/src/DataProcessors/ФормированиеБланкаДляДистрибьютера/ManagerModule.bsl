// Вычисление представления для ТелаЗапроса
// Hex(SHA256Hash(payload))
Функция HexSHA256Hash(Знач ВходныеДанные = "") Экспорт
	
	Возврат Lower(GetHexStringFromBinaryData(Хеш(ВходныеДанные, ХешФункция.SHA256)));
	
КонецФункции

