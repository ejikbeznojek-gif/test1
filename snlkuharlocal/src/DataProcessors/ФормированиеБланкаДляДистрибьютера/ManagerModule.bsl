/////////////////// ФУНКЦИИ КОДИРОВКИ ДАННЫХ //////////////////////////////////////////////////////////////
// 	Lowercase()	Преобразуйте строку в нижний регистр.  НРЕГ()
//	Hex()	Кодировка в нижнем регистре по основанию 16.
//	SHA256Hash()	Криптографическая хеш-функция Secure Hash Algorithm (SHA).
//	HMAC-SHA256()	Вычисляет HMAC с использованием алгоритма SHA256 с предоставленным ключом подписи. Это последняя подпись.
//	Trim()	Удалите все начальные и конечные пробелы.  СокрЛП()
//	UrlEncode()	
//	URI кодирует каждый байт. UriEncode() должен обеспечивать соблюдение следующих правил:
//	URI кодирует каждый байт, кроме незарезервированных символов: «A» — «Z», «a» — «z», «0» — «9», «-», «.», «_» и «~».
//	Символ пробела является зарезервированным символом и должен кодироваться как «%20» (а не как «+»).
//	Каждый байт, закодированный URI, состоит из «%» и двухзначного шестнадцатеричного значения байта.
//	Буквы в шестнадцатеричном значении должны быть прописными, например «%1A».
//	Кодируйте косую черту '/' везде, кроме имени ключа объекта. Например, если имя ключа объекта — photos/Jan/sample.jpg, косая черта в имени ключа не кодируется.
#Область КодировкаДанных

// Функция переводит десятичное число в шестнадцатеричное
// Параметры:  _Число - Число - Десятичное число
// Возвращаемое значение:  Строка - Шестнадцатеричное число
//
Функция DecToHex(Знач _Число)
	База = 16;
	Результат = "";
	Пока _Число <> 0 Цикл
		Поз =_Число % База;
		Результат = Сред("0123456789ABCDEF", Поз + 1, 1) + Результат;
		_Число = Цел(_Число / База);
	КонецЦикла;
	Возврат Результат;
КонецФункции // DecToHex()

// Функция переводит обычную cтроку в шестнадцатеричное представление
// Параметры:
//     ТекстСообщения - Строка - Текст сообщения
//     ТипКодировки   - Число  - Тип кодировки (1 - каждый символ представляется 2 байтами, 0 - 1 байтом)
// Возвращаемое значение: Строка - Строка после перекодировки
//
Функция Str2Hex(ТекстСообщения, ТипКодировки = 0) Экспорт
	СтрокаЗнаков = "";
	Если ТипКодировки = 1 Тогда
		ДлинаКодаСимвола = 4;
	Иначе
		ДлинаКодаСимвола = 2;
	КонецЕсли;
	Для К = 1 По СтрДлина(ТекстСообщения) Цикл
		СтрокаЗнаков = СтрокаЗнаков + Padl(DecToHex(КодСимвола(Сред(ТекстСообщения, К, 1))), ДлинаКодаСимвола, "0");
	КонецЦикла;
	Возврат НРЕГ(СтрокаЗнаков);
КонецФункции // Str2Hex()

// Параметры:
//      Стр    - Строка  - Строка
//      Длина  - Число   - Длина строки
//      Чем    - Строка  - Символ для добавления
//
// Возвращаемое значение:
//      Строка - Строка, дополненная до указанной длины
//
Функция Padl(Знач Стр, Длина, Чем = " ") 
	СимволовДополнить = Длина - СтрДлина(Стр);
	Добавок = "";
	Для Н = 1 По СимволовДополнить Цикл
		Добавок = Добавок + Чем;
	КонецЦикла;
	Возврат  Добавок + Стр;
КонецФункции

