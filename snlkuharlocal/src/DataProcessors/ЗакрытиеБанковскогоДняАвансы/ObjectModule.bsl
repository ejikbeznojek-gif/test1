#Область СозданиеПРС

Функция СформироватьППпоДДСзаПериод(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, пОбработки);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка,Дата,Номер
	|ИЗ
	|	Документ.ДвиженияДенежныхСредств
	|ГДЕ
	|	Дата МЕЖДУ &Дата1 И &Дата2
	|	И Проведен
	|	И БанковскийСчет ССЫЛКА Справочник.БанковскиеСчета	
	|";                             
	
	Запрос.УстановитьПараметр("Дата1", НачалоДня(Дата1));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата2));
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок  = Выборка.Количество();
	Сч = 0;
	
	Сообщить("К обработке: " + ВсегоСтрок + " выписок.");	
	
	мСсылок = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Сч = Сч + 1;                                                        
		
		Документы.ПоступлениеНаРасчетныйСчет.СоздатьППвходящие(Выборка.Ссылка);
						
		Если Сч % 10 = 0 ИЛИ Сч >= ВсегоСтрок Тогда			
			ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=0"), СтрШаблон("Обработано: %1 из %2", Сч, ВсегоСтрок));
		КонецЕсли;	
	КонецЦикла;	
	
	Результат.ОбработаноОбъектов = Сч;
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции //СформироватьППпоДДСзаПериод

Функция ПроверитьНаличиеПРС(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Платежи.Ссылка 	КАК ДДС_Ссылка,    
	|	ПРС.Ссылка 		КАК ПРС_Ссылка,
	|	ПРС.Договор		КАК ДоговорПРС,
	|	Платежи.Договор	КАК ДоговорДДС,
	|	Платежи.КонтрагентПоБанку 	КАК Контрагент,
	|	Платежи.Приход  			КАК СуммаДДС,
	|	ПРС.СуммаДокумента 			КАК СуммаПРС,
	|	ВЫБОР
	|		КОГДА ПРС.Договор <> Платежи.Договор ТОГДА ""Не совпадает договор""
	|		КОГДА ПРС.Ссылка ЕСТЬ NULL ТОГДА ""Отсутствует ПРС""  
	|	ИНАЧЕ
	|		NULL
	|	КОНЕЦ КАК Ошибка,	
	|	Платежи.УИД_СтрокиПлатежа
	|ИЗ
	|	Документ.ДвиженияДенежныхСредств.Платежи КАК Платежи
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	Документ.ПоступлениеНаРасчетныйСчет КАК ПРС
	|ПО 
	|	Платежи.УИД_СтрокиПлатежа = ПРС.УИД_СтрокиПлатежа
	|ГДЕ
	|	Платежи.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
	|	И Платежи.Ссылка.Проведен
	|	И Платежи.Приход > 0
	|	И (
	|		ПРС.Ссылка ЕСТЬ NULL ИЛИ ПРС.СуммаДокумента<>Платежи.Приход
	|		ИЛИ ПРС.Договор <> Платежи.Договор
	|	)	
	|УПОРЯДОЧИТЬ ПО
	|	Платежи.Ссылка.Дата,	
	|	Платежи.Ссылка.Номер
	|";
	
	мДата1 = НачалоМесяца(ТекущаяДата());
	мДата1 = НачалоМесяца(мДата1 - 1);
	
	Дата2 = МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Дата2", ТекущаяДата());
	
	Запрос.УстановитьПараметр("Дата1", МаркировкаКС.ПолучитьЗначениеПараметра(пОбработки, "Дата1", мДата1));
	Запрос.УстановитьПараметр("Дата2", КонецДня(Дата2));
	
	рЗапроса = Запрос.Выполнить();
	Выборка = рЗапроса.Выбрать();
	Если Выборка.Количество() > 0 Тогда
		ТекстОшибки = СтрШаблон("Найдено %1 строк ДДС без привязанных поступлений !", Выборка.Количество());
		Результат.Ошибки.Добавить(ТекстОшибки);
		Результат.Успешно = Ложь;
		
		ДопПараметры = Новый Структура("ВнешниеДанные", Новый Структура("рЗапроса", рЗапроса));		
		Результат.Данные = РаботаНадСКД_КС.ВывестиСхемуВТД(ПолучитьМакет("Проверка_ПРС"), , , ДопПараметры);		
	КонецЕсли;
	
	Результат.ОбработаноОбъектов = Выборка.Количество();
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);	
	КонецЕсли;
	
	Возврат Результат;	

КонецФункции //ПроверитьНаличиеПРС(пОбработки, АдресВозврата = Неопределено) Экспорт


#КонецОбласти

Функция ВыполнитьПроверкиПакетом(пОбработки, АдресВозврата = Неопределено) Экспорт
	Результат = МаркировкаКС.СтруктураРезультата();
	
	Результат.Вставить("ПакетныйРезультат", Истина);
	Результат.Данные = Новый Структура;
	
	Результат.Данные.Вставить("ПроверкаПРС", ПроверитьНаличиеПРС(пОбработки));
	
	Если ЭтоАдресВременногоХранилища(АдресВозврата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресВозврата);	
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции //ВыполнитьПроверкиПакетом(пОбработки, АдресВозврата = Неопределено) Экспорт

