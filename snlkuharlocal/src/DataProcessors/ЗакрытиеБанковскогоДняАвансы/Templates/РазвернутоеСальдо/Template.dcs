			</valueType>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.КонРазвДт</dataPath>
			<field>СуммаВалКонРазвДт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма вал.Кон разв дт</v8:content>
