				<v8:NumberQualifiers>
					<v8:Digits>19</v8:Digits>
					<v8:FractionDigits>2</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.КонРазвКт</dataPath>
			<field>СуммаВалКонРазвКт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма вал.Кон разв кт</v8:content>
				</v8:item>
			</title>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>19</v8:Digits>
					<v8:FractionDigits>2</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.НачРазвКт</dataPath>
			<field>СуммаВалНачРазвКт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма вал.Нач разв кт</v8:content>
				</v8:item>
			</title>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>19</v8:Digits>
					<v8:FractionDigits>2</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.Приход</dataPath>
			<field>СуммаВалПриход</field>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>19</v8:Digits>
					<v8:FractionDigits>2</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.Расход</dataPath>
			<field>СуммаВалРасход</field>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>19</v8:Digits>
					<v8:FractionDigits>2</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаВал.НачРазвДт</dataPath>
			<field>СуммаВалНачРазвДт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма вал.Нач разв дт</v8:content>
				</v8:item>
			</title>
			<valueType>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>0</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</valueType>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2; ЧРГ=' '; ЧГ=3,0</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период.Секунда</dataPath>
			<field>ПериодСекунда</field>
			<useRestriction>
				<field>true</field>
			</useRestriction>
			<role>
				<dcscom:periodNumber>2</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Регистратор</dataPath>
			<field>Регистратор</field>
			<role>
				<dcscom:periodNumber>1</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидДоговора</dataPath>
			<field>ВидДоговора</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Вид договора</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ 
	Договор,
	СУММА(СуммаВалКонРазвДт) КАК СуммаВалКонРазвДт,
	СУММА(СуммаВалКонРазвКт) КАК СуммаВалКонРазвКт		
ПОМЕСТИТЬ ВТ_Договора	
ИЗ
(
	ВЫБРАТЬ
		Договор,
		ДокументРасчетов КАК ВнемДокРасчетов,
		
		ВЫБОР КОГДА СуммаВалКонечныйОстаток &gt; 0 ТОГДА СуммаВалКонечныйОстаток ИНАЧЕ 0 КОНЕЦ КАК СуммаВалКонРазвДт,
		ВЫБОР КОГДА СуммаВалКонечныйОстаток &lt; 0 ТОГДА -СуммаВалКонечныйОстаток ИНАЧЕ 0 КОНЕЦ КАК СуммаВалКонРазвКт
	ИЗ
		РегистрНакопления.ВзаиморасчетыПоДокументамРасчетов.ОстаткиИОбороты({&amp;Дата2}, {&amp;Дата2}, , , 
			Договор.Организация = &amp;Организация
			И Договор.ВидДоговора_Новый = ЗНАЧЕНИЕ(Справочник.ВидыДоговоров.Товары_Продажа)
			И НЕ Договор.ДопСоглашение
			//И Договор.Владелец.СтранаРегистрации = ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.Россия)
		)
) КАК ОстаткиПоДокументам	
СГРУППИРОВАТЬ ПО
	Договор	
ИМЕЮЩИЕ                                                 
	СУММА(СуммаВалКонРазвДт) &gt; 0
	И СУММА(СуммаВалКонРазвКт) &gt; 0
;
ВЫБРАТЬ              
	Договор.Владелец КАК Контрагент,
	Договор,
	Договор.ВидДоговора_Новый КАК ВидДоговора,
	ДокументРасчетов,               
	
	ПериодСекунда,
	Регистратор,
	
	ВЫБОР КОГДА СУММА(СуммаВалНачальныйОстаток) &gt; 0 ТОГДА СУММА(СуммаВалНачальныйОстаток) ИНАЧЕ 0 КОНЕЦ КАК СуммаВалНачРазвДт,
	ВЫБОР КОГДА СУММА(СуммаВалНачальныйОстаток) &lt; 0 ТОГДА -СУММА(СуммаВалНачальныйОстаток) ИНАЧЕ 0 КОНЕЦ КАК СуммаВалНачРазвКт,	
	
	СУММА(СуммаВалПриход) КАК СуммаВалПриход,
	СУММА(СуммаВалРасход) КАК СуммаВалРасход,
	                                   
	ВЫБОР КОГДА СУММА(СуммаВалКонечныйОстаток) &gt; 0 ТОГДА СУММА(СуммаВалКонечныйОстаток) ИНАЧЕ 0 КОНЕЦ КАК СуммаВалКонРазвДт,
	ВЫБОР КОГДА СУММА(СуммаВалКонечныйОстаток) &lt; 0 ТОГДА -СУММА(СуммаВалКонечныйОстаток) ИНАЧЕ 0 КОНЕЦ КАК СуммаВалКонРазвКт	
ИЗ
	РегистрНакопления.ВзаиморасчетыПоДокументамРасчетов.ОстаткиИОбороты({&amp;Дата1}, {&amp;Дата2}, Авто, , Договор В (ВЫБРАТЬ РАЗЛИЧНЫЕ Договор ИЗ ВТ_Договора))
СГРУППИРОВАТЬ ПО	
	Договор,
	ДокументРасчетов,
	
	ПериодСекунда,
	Регистратор</query>
	</dataSet>
	<totalField>
		<dataPath>СуммаВал.КонРазвДт</dataPath>
		<expression>Сумма(СуммаВал.КонРазвДт)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаВал.КонРазвКт</dataPath>
		<expression>Сумма(СуммаВал.КонРазвКт)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаВал.НачРазвДт</dataPath>
		<expression>Сумма(СуммаВал.НачРазвДт)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаВал.НачРазвКт</dataPath>
		<expression>Сумма(СуммаВал.НачРазвКт)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаВал.Приход</dataPath>
		<expression>Сумма(СуммаВал.Приход)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаВал.Расход</dataPath>
		<expression>Сумма(СуммаВал.Расход)</expression>
	</totalField>
	<parameter>
		<name>Дата1</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата1</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>Дата2</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата2</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>Организация</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Организация</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:CatalogRef.Организации</v8:Type>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>true</useRestriction>
	</parameter>
	<settingsVariant>
		<dcsset:name>Отчет</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Отчет</v8:content>
			</v8:item>
		</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
				<dcsset:item xsi:type="dcsset:SelectedItemFolder">
					<dcsset:lwsTitle>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Остаток нач.</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.НачРазвДт</dcsset:field>
					</dcsset:item>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.НачРазвКт</dcsset:field>
					</dcsset:item>
					<dcsset:placement>Auto</dcsset:placement>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemFolder">
					<dcsset:lwsTitle>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Обороты</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.Приход</dcsset:field>
					</dcsset:item>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.Расход</dcsset:field>
					</dcsset:item>
					<dcsset:placement>Auto</dcsset:placement>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemFolder">
					<dcsset:lwsTitle>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Остаток кон.</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.КонРазвДт</dcsset:field>
						<dcsset:lwsTitle>
							<v8:item>
								<v8:lang>ru</v8:lang>
								<v8:content>Разв. Дт </v8:content>
							</v8:item>
						</dcsset:lwsTitle>
					</dcsset:item>
					<dcsset:item xsi:type="dcsset:SelectedItemField">
						<dcsset:field>СуммаВал.КонРазвКт</dcsset:field>
						<dcsset:lwsTitle>
							<v8:item>
								<v8:lang>ru</v8:lang>
								<v8:content>Разв Кт.</v8:content>
							</v8:item>
						</dcsset:lwsTitle>
					</dcsset:item>
