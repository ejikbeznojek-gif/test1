Функция ВыполнитьШагПроверки_ДублиКодовШтук(МВТ)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "ДублиКодовШтук", "ДублиКодовШтук", Неопределено);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = "	 
				   |ВЫБРАТЬ КодУпаковки, СУММА(1) КАК КоличествоДублей ИЗ ВТ_РезультатыПоиска
				   |СГРУППИРОВАТЬ ПО КодУпаковки
				   |ИМЕЮЩИЕ СУММА(1)>1
				   |";

	ДублированоКодов = 0;
	рЗапроса = Запрос.Выполнить();
	Выборка = рЗапроса.Выбрать();
	ДублированоКодов = Выборка.Количество();

	Если ДублированоКодов > 1 Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Найдено %1 дублированых кодов штук.", ДублированоКодов));

		Результат.Данные.рЗапроса = рЗапроса;
	КонецЕсли;

	Возврат Результат;	
КонецФункции

&НаСервере
Функция ВыполнитьШагПроверки_КоличествоНоменклатуры(МВТ, ЗаказПоставщику)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "Общее кол-во номенклатуры", "ДублиКодовШтук",
		Неопределено);

	Если Не ЗначениеЗаполнено(ЗаказПоставщику) Тогда
		Результат.Успешно = Неопределено;
		Результат.Сообщения.Добавить("Не выбран заказ поставщику.");
		Возврат Результат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = "	 
				   |ВЫБРАТЬ
				   |	Номенклатура,
				   |	СУММА(КолОтчет) КАК КолОтчет,
				   |	СУММА(КолЗПС) КАК КолЗПС
				   |ИЗ
				   |(
				   |ВЫБРАТЬ 
				   |	ШтрихКодУпаковки.Владелец	КАК Номенклатура,
				   |	СУММА(1)					КАК КолОтчет,
				   |	0							КАК КолЗПС
				   |ИЗ 
				   |	ВТ_РезультатыПоиска
				   |СГРУППИРОВАТЬ ПО 
				   |	ШтрихКодУпаковки.Владелец
				   |ОБЪЕДИНИТЬ ВСЕ
				   |ВЫБРАТЬ
				   |	Номенклатура,
				   |	0		        КАК КолОтчет,
				   |	Количество 		КАК Количество
				   |ИЗ
				   |	" + ЗаказПоставщику.Метаданные().ПолноеИмя() + ".Товары
																	   |ГДЕ
																	   |	Ссылка = &ЗаказПоставщику
																	   |) КАК Сводный	
																	   |СГРУППИРОВАТЬ ПО
																	   |	Номенклатура
																	   |";

	Запрос.УстановитьПараметр("ЗаказПоставщику", ЗаказПоставщику);

	КолКодовШтукЗПС			= 0;
	КолКодовШтукОтчет	    = 0;

	РЗапроса = Запрос.Выполнить();
	Выборка = рЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.КолОтчет <> Выборка.КолЗПС Тогда
			Результат.Успешно = Ложь;
		КонецЕсли;

		КолКодовШтукЗПС			= КолКодовШтукЗПС + Выборка.КолЗПС;
		КолКодовШтукОтчет	    = КолКодовШтукОтчет + Выборка.КолОтчет;
	КонецЦикла;

	Если Не Результат.Успешно Тогда
		Результат.Ошибки.Добавить(СтрШаблон("Не совпадает количество по отчету и ЗПС !"));
		Результат.Данные.рЗапроса = рЗапроса;
	КонецЕсли;

	Результат.Данные.Вставить("ДопИнфо", Новый Структура("КолКодовШтукЗПС,КолКодовШтукОтчет", КолКодовШтукЗПС,
		КолКодовШтукОтчет));

	Возврат Результат;	
КонецФункции


