			мИмяФайла = Файл.ПолноеИмя;
			
			ДДанные = Новый ДвоичныеДанные(мИмяФайла);
			СтрокаДанных	= ПолучитьСтрокуИзДвоичныхДанных(ДДанные);
			
			//Если НаполнениеЗПС Тогда
			//	рЧтения 		= ПрочитатьТаблицуКодовИзСтроки_НаполнениеЗПСНаСервере(СтрокаДанных);
			//Иначе
			//	рЧтения 		= ПрочитатьТаблицуКодовИзСтрокиНаСервере(СтрокаДанных);
			//КонецЕсли;
			//МассивДанных.Добавить(рЧтения);  
			 //++Данилова Е.В. 28.05.2026 MARK-3727
			  МассивДанныхДляЧтения.Добавить(СтрокаДанных);
			 //--Данилова Е.В. 28.05.2026 
		КонецЦикла;
		//Возврат ПрочитатьКодыИзКаталогаНаКлиенте(КаталогЗагрузки,НаполнениеЗПС);
