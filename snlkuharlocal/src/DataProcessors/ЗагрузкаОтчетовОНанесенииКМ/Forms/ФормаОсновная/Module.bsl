		рЗапроса));

	Обр 			= Обработки.ПроверкаКарточекДляНК.Создать();
	Обр.ВывестиСхемуВТД(ОбработкаОбъект.ПолучитьМакет("СодержимоеОтчетаОНанесении"), "Основной",
		ПараметрыДанных, ДопПараметры);		
	
	
