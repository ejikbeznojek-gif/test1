Функция ВыполнитьШагПроверки_ОтсутствиеКодовКоробок(МВТ)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "Отсутствие кодов коробок",
		"НеНайденныеКодыКоробок", Неопределено);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = "	 
				   |ВЫБРАТЬ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КодКоробки) КАК Количество ИЗ ВТ_РезультатыПоиска
				   |ГДЕ НЕ ШтрихКодКоробки.ВерсияДанных ЕСТЬ NULL	 
				   |";

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Не найдено %1 кодов коробок.", Выборка.Количество));

		Запрос.Текст = "
					   |ВЫБРАТЬ КодКоробки, СУММА(1) КАК Количество ИЗ ВТ_РезультатыПоиска
					   |ГДЕ 
					   |	НЕ ШтрихКодКоробки.ВерсияДанных ЕСТЬ NULL	 
					   |СГРУППИРОВАТЬ ПО
					   |	КодКоробки
					   |";

		Результат.Данные.рЗапроса = Запрос.Выполнить();
	КонецЕсли;

	Возврат Результат;	
КонецФункции
