&НаСервере
Процедура кнЗаполнитьЗПСНаСервере(РДанныеДляЧтения)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	РЧтения = ПрочитатьКодыНаСервере(РДанныеДляЧтения,ВидОперации = 1);
	//РЧтения = ОбработкаОбъект.ПрочитатьКоды(Объект.ИмяФайла, фЗагружатьИзФайла,истина);
	Если Не рЧтения.Успешно Тогда
		МаркировкаКС.ВывестиОшибки(рЧтения);
		Возврат;
	КонецЕсли;

	Сообщить(СтрШаблон("Прочитано: %1 кодов, %2 коробок.", рЧтения.Данные.КолКодовШтук, рЧтения.Данные.КолКодовКоробок));
	
	МожноЗагружать = Истина; 
	РПроверок = ПроверитьДанныеФайлаСПроверкой(рЧтения.Данные.МВТ);
	Для Каждого ЭлМассиваПроверок Из РПроверок Цикл
		Если НЕ ЭлМассиваПроверок.Успешно Тогда
			МожноЗагружать = Ложь; 	
		КонецЕсли;
	КонецЦикла;
	Если НЕ МожноЗагружать Тогда
		ВывестиРезультатыПроверок(РПроверок); 
		Возврат; 
	КонецЕсли;
	ВыполнитьЗагрузкуДанныхвЗПС(рЧтения.Данные.МВТ);    
	
КонецПроцедуры
&НаСервере
Процедура ВыполнитьЗагрузкуДанныхвЗПС(МВТ)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	 Запрос.текст =  "ВЫБРАТЬ
	                 |	ВТ_РезультатыПоиска.ЗПС_Ссылка КАК ЗПС,
	                 |	ВТ_РезультатыПоиска.КП_Ссылка КАК КП,
	                 |	ВТ_РезультатыПоиска.ШтрихкодУпаковки.Владелец КАК Номенклатура,
	                 |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_РезультатыПоиска.ШтрихкодУпаковки) КАК Количество
	                 |ИЗ
	                 |	ВТ_РезультатыПоиска КАК ВТ_РезультатыПоиска
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	ВТ_РезультатыПоиска.ЗПС_Ссылка,
	                 |	ВТ_РезультатыПоиска.КП_Ссылка,
	                 |	ВТ_РезультатыПоиска.ШтрихкодУпаковки.Владелец
	                 |ИТОГИ ПО
	                 |	ЗПС,
	                 |	КП
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ РАЗЛИЧНЫЕ
	                 |	ВТ_РезультатыПоиска.ЗПС_Ссылка КАК ЗПС,
	                 |	ВТ_РезультатыПоиска.КП_Ссылка КАК КП,
	                 |	ВТ_РезультатыПоиска.ШтрихкодКоробки КАК ШтрихкодКоробки,
	                 |	МаркировкаТоваровИСМП.Ссылка КАК ОМ
	                 |ПОМЕСТИТЬ ВТКоробкиДляИзменения
	                 |ИЗ
	                 |	ВТ_РезультатыПоиска КАК ВТ_РезультатыПоиска
	                 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК МаркировкаТоваровИСМП
	                 |		ПО ВТ_РезультатыПоиска.КП_Ссылка = МаркировкаТоваровИСМП.ДокументОснование
	                 |			И (МаркировкаТоваровИСМП.Проведен)
	                 |			И (МаркировкаТоваровИСМП.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация))
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	                 |		ПО (МаркировкаТоваровИСМП.Ссылка = МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка)
	                 |			И ВТ_РезультатыПоиска.ШтрихкодКоробки = МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодКоробки
	                 |			И ВТ_РезультатыПоиска.ШтрихкодУпаковки = МаркировкаТоваровИСМПШтрихкодыУпаковок.ШтрихкодУпаковки
	                 |ГДЕ
	                 |	МаркировкаТоваровИСМПШтрихкодыУпаковок.Ссылка ЕСТЬ NULL
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	ВТКоробкиДляИзменения.ОМ КАК ОМ,
	                 |	ВТ_РезультатыПоиска.ШтрихкодКоробки КАК ШтрихкодКоробки,
	                 |	ВТ_РезультатыПоиска.ШтрихкодУпаковки КАК ШтрихкодУпаковки
	                 |ИЗ
	                 |	ВТКоробкиДляИзменения КАК ВТКоробкиДляИзменения
	                 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РезультатыПоиска КАК ВТ_РезультатыПоиска
	                 |		ПО (ВТ_РезультатыПоиска.ЗПС_Ссылка = ВТКоробкиДляИзменения.ЗПС)
	                 |			И (ВТ_РезультатыПоиска.КП_Ссылка = ВТКоробкиДляИзменения.КП)
	                 |			И (ВТ_РезультатыПоиска.ШтрихкодКоробки = ВТКоробкиДляИзменения.ШтрихкодКоробки)
	                 |ИТОГИ ПО
	                 |	ОМ,
	                 |	ШтрихкодКоробки";
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	ВыборкаЗПС = ПакетРезультатов[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаАгрегации = ПакетРезультатов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	НачатьТранзакцию();
	МассивОбъектов = Новый Массив;  
	Пока ВыборкаЗПС.Следующий() Цикл
		ЗПСОбъект = ВыборкаЗПС.ЗПС.ПолучитьОбъект(); 
		ЗПСОбъект.Товары.Очистить(); 
		ВыборкаКП = ВыборкаЗПС.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		Пока ВыборкаКП.Следующий() Цикл
			ВыборкаТовары = ВыборкаКП.Выбрать(); 
			Пока ВыборкаТовары.Следующий() Цикл
				НоваяСтрока = ЗПСОбъект.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаТовары);
				НоваяСтрока.ЗаявкаПоставщику =  ВыборкаКП.КП; 
				ПриИзмененииНоменклатурыТабЧасти(НоваяСтрока, ЗПСОбъект);
				РассчитатьСуммуТабЧасти(НоваяСтрока,ЗПСОбъект,"ОтВсего");
			КонецЦикла;
		КонецЦикла;
		ЗПСОбъект.Записать();
		МассивОбъектов.Добавить(ЗПСОбъект.ссылка);  		
	КонецЦикла;
	
	Пока ВыборкаАгрегации.Следующий() Цикл
		ОперацияМаркировкаОб = ВыборкаАгрегации.ОМ.ПолучитьОбъект();
		ВыборкаКороб = ВыборкаАгрегации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаКороб.Следующий() Цикл
			Отбор = Новый Структура("ШтрихкодКоробки", ВыборкаКороб.ШтрихкодКоробки);
			СтрокиКороба = ОперацияМаркировкаОб.ШтрихкодыУпаковок.НайтиСтроки(Отбор);
			Если СтрокиКороба.Количество() > 0 Тогда
				Для Каждого СтрокаКороба Из СтрокиКороба Цикл
					ОперацияМаркировкаОб.ШтрихкодыУпаковок.Удалить(СтрокаКороба);
				КонецЦикла;
			КонецЕсли;
			ВыборкаКМ = ВыборкаКороб.Выбрать();
			Пока ВыборкаКМ.Следующий() Цикл
				СтрокаКороба  = ОперацияМаркировкаОб.ШтрихкодыУпаковок.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаКороба, ВыборкаКМ);
			КонецЦикла;
		КонецЦикла;
		ОперацияМаркировкаОб.Записать();
		
		МассивОбъектов.Добавить(ОперацияМаркировкаОб.ссылка);
	КонецЦикла;
	
	Если ТранзакцияАктивна() Тогда
		ЗафиксироватьТранзакцию();

		Сообщить("Были внесены измненения в объекты:" + Символы.ПС + СтрСоединить(МассивОбъектов, Символы.пс));

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
