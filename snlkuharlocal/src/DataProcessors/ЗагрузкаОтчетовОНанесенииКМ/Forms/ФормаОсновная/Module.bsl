				   |	ШтрихкодУпаковки.Владелец 			КАК Номенклатура,
				   |	ШтрихкодКоробки,		
				   |	СУММА(1) КАК КоличествоФайл,
				   |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШтрихкодУпаковки.Владелец) КАК КолПозицийВКоробке
				   |ИЗ 
				   |	ВТ_РезультатыПоиска 
				   |СГРУППИРОВАТЬ ПО 
				   |	ШтрихкодУпаковки.Владелец,
				   |	ШтрихкодКоробки
				   |";

	ТабДокумент = Новый ТабличныйДокумент;

	РЗапроса		= Запрос.Выполнить();

	ПараметрыДанных	= Новый Структура("ЗПС_Ссылка", Объект.ВыбЗПС);
