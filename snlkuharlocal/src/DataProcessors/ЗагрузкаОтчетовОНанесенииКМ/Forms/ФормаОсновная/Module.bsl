		СтрокаДанных = ПолучитьСтрокуИзДвоичныхДанных(ДДанные);
		МассивДанныхДляЧтения.Добавить(СтрокаДанных); 
		//Возврат	ПрочитатьКодыИзФайлаНаКлиенте(Объект.ИмяФайла,НаполнениеЗПС);
		
	Иначе
		Файл = Новый Файл(Объект.ИмяФайла);					
