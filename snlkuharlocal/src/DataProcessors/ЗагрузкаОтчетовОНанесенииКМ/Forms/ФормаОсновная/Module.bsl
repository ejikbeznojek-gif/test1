#Область СлужебныеПроцедурыИФункции
&НаКлиенте
Процедура ПослеОтветаОчиститьЗПС(ОтветНаВопрос,ДопПараметры) Экспорт
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		РЧтения = ПрочитатьКодыНаКлиенте(); 
		кнЗаполнитьЗПСНаСервере(РЧтения);	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверитьДанныеФайлаНаСервере(РДанныеДляЧтения,ТабДокДополнительно = неопределено,ИмяТД = "")
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	РЧтения = ПрочитатьКодыНаСервере(РДанныеДляЧтения,ВидОперации = 1); 
//	РЧтения = ОбработкаОбъект.ПрочитатьКоды(Объект.ИмяФайла, фЗагружатьИзФайла);

	Если рЧтения.Успешно Тогда
		Сообщить(СтрШаблон("Прочитано: %1 кодов, %2 коробок.", рЧтения.Данные.КолКодовШтук,
			рЧтения.Данные.КолКодовКоробок));

		РПроверок = ПроверитьДанныеФайлаСПроверкой(рЧтения.Данные.МВТ);
		ВывестиРезультатыПроверок(рПроверок);
	Иначе
		МаркировкаКС.ВывестиОшибки(рЧтения);

		НеНайденныеКоды = МаркировкаКС.ПолучитьЗначениеПараметра(рЧтения.Данные, "НеНайденныеКоды");
		Если НеНайденныеКоды <> Неопределено Тогда
			ТабДокДополнительно = Новый ТабличныйДокумент;

			Обр 			= Обработки.ПроверкаКарточекДляНК.Создать();
			ДопПараметры	= Новый Структура("ТД_Результат,ВнешниеДанные", ТабДокДополнительно,
				Новый Структура("Данные", НеНайденныеКоды));

			Обр.ВывестиСхемуВТД(ОбработкаОбъект.ПолучитьМакет("НеНайденныеКоды"), "Основной", , ДопПараметры);				
			
			//ТД.Показать("Не найденные коды штук");
			ИмяТД = "Не найденные коды штук";
			
			ТДокумент = Элементы.ТД_ОшибочныеКодыШтук;
			ТДокумент.Очистить();
			ТДокумент = ТабДокДополнительно; 
			
		КонецЕсли;

		НеНайденныеКодыКоробок = МаркировкаКС.ПолучитьЗначениеПараметра(рЧтения.Данные, "НеНайденныеКодыКоробок");
		Если НеНайденныеКодыКоробок <> Неопределено Тогда
			ТабДокДополнительно = Новый ТабличныйДокумент;

			Обр 			= Обработки.ПроверкаКарточекДляНК.Создать();
			ДопПараметры	= Новый Структура("ТД_Результат,ВнешниеДанные", ТабДокДополнительно,
				Новый Структура("Данные", НеНайденныеКодыКоробок));

			Обр.ВывестиСхемуВТД(ОбработкаОбъект.ПолучитьМакет("НеНайденныеКоды"), "Основной", , ДопПараметры);

			//ТД.Показать("Не найденные коды коробок.");
			ИмяТД = "Не найденные коды коробок.";
			
			ТДокумент = Элементы.ТД_ОшибочныеКодыКоробок; 
			ТДокумент.Очистить();
			ТДокумент = ТабДокДополнительно; 
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПроверитьДанныеФайлаСПроверкой(МВТ)	
	
	РПроверок = Новый Массив;
	
	рПроверок.Добавить(ВыполнитьШагПроверки_НаличиеКодовШтук(МВТ));
	Если ргНумерацияКоробок = 0 Тогда //Наша нумерация
		рПроверок.Добавить(ВыполнитьШагПроверки_НаличиеКодовКоробок(МВТ));
	Иначе
		рПроверок.Добавить(ВыполнитьШагПроверки_ОтсутствиеКодовКоробок(МВТ));
	КонецЕсли;	
	рПроверок.Добавить(ВыполнитьШагПроверки_ДублиКодовШтук(МВТ));
	//++Данилова Е.В. 13.05.2026 ASU-2790
	Если ВидОперации = 0 Тогда 
		рПроверок.Добавить(ВыполнитьШагПроверки_КоличествоНоменклатуры(МВТ, Объект.ВыбЗПС));
	Иначе 
		рПроверок.Добавить(ВыполнитьШагПроверки_НайденыДокументыПоГУИД(МВТ));	
	КонецЕсли;
	//--Данилова Е.В. 13.05.2026 
	Возврат рПроверок;
	
КонецФункции

&НаСервере
Функция ВывестиРезультатыПроверок(РПроверок)
	
	ТД_Результат.Очистить();
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект"); 
	Макет = ОбработкаОбъект.ПолучитьМакет("ОтчетОПроверке");
	
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОблЗаголовок.Параметры.Заполнить(Новый Структура("ИмяФайла,ЗаказПоставщику", Объект.ИмяФайла, Объект.ВыбЗПС));
	
	ТД_Результат.Вывести(ОблЗаголовок);
	
	ТД_Результат.Вывести(Макет.ПолучитьОбласть("Шапка"));
	
	Для Каждого рШага Из рПроверок Цикл		
		ОблСтрока = Макет.ПолучитьОбласть("Строка");
		ОблРезультат = ОблСтрока.Область(1,4);
		
		пОбласти = Новый Структура("ИмяШага,Ошибки,Результат", рШага.Данные.Имя, СтрСоединить(рШага.Ошибки, Символы.ПС));
		ДопИнфо = МаркировкаКС.ПолучитьЗначениеПараметра(рШага.Данные, "ДопИнфо", Новый Структура);
		
		Если рШага.Успешно = Неопределено Тогда
			пОбласти.Результат = "Не выполнялась";					
			ОблРезультат.ЦветФона = WebЦвета.Желтый;
		ИначеЕсли рШага.Успешно = Истина Тогда
			пОбласти.Результат = "Успешно";					
			ОблРезультат.ЦветФона = WebЦвета.ЗеленыйЛес;
		ИначеЕсли рШага.Успешно = Ложь Тогда
			пОбласти.Результат = "Ошибка";					
			ОблРезультат.ЦветФона = WebЦвета.Розовый;			
		КонецЕсли; 
		
		Сообщить("" + рШага.Данные.Имя	+ " " + рШага.Успешно);
		
		ОблСтрока.Параметры.Заполнить(пОбласти);
		ОблСтрока.Параметры.Заполнить(ДопИнфо);
		
		ТД_Результат.Вывести(ОблСтрока);
	КонецЦикла; 
КонецФункции //ВывестиРезультатыПроверок(рПроверок) 

&НаСервере
Функция ВыполнитьШагПроверки_НаличиеКодовШтук(МВТ)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "Наличие кодов штук", "НеНайденныеКоды", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = "	 
	|ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Количество ИЗ ВТ_РезультатыПоиска
	|ГДЕ ШтрихКодУпаковки.ВерсияДанных ЕСТЬ NULL	 
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Не найдено %1 кодов маркировки.", Выборка.Количество));
		
		Запрос.Текст = "
		|ВЫБРАТЬ КодКоробки,КодУпаковки,1 КАК Количество ИЗ ВТ_РезультатыПоиска
		|ГДЕ ШтрихКодУпаковки.ВерсияДанных ЕСТЬ NULL	 
		|";
		
		Результат.Данные.рЗапроса = Запрос.Выполнить();
	КонецЕсли;	
	
	Возврат Результат;	
КонецФункции //ВыполнитьШагПроверки_НеНайденныеКодыШтук(МВТ) 
&НаСервере
Функция ВыполнитьШагПроверки_НаличиеКодовКоробок(МВТ)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "Наличие кодов коробок", "НеНайденныеКодыКоробок",
		Неопределено);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = "	 
				   |ВЫБРАТЬ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КодКоробки) КАК Количество ИЗ ВТ_РезультатыПоиска
				   |ГДЕ ШтрихКодКоробки.ВерсияДанных ЕСТЬ NULL	 
				   |";

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Не найдено %1 кодов коробок.", Выборка.Количество));

		Запрос.Текст = "
					   |ВЫБРАТЬ КодКоробки,КодУпаковки,1 КАК Количество ИЗ ВТ_РезультатыПоиска
					   |ГДЕ ШтрихКодКоробки.ВерсияДанных ЕСТЬ NULL	 
					   |";

		Результат.Данные.рЗапроса = Запрос.Выполнить();
	КонецЕсли;

	Возврат Результат;	
