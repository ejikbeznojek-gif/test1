&НаСервере
Процедура кнСравнитьОтчетСПланомНаСервере(РДанныеДляЧтения)
	Если Не ЕстьПлановыеАгрегации() Тогда
		Сообщить("Не найдено плановых агрегаций к ЗПС: " + Объект.ВыбЗПС, СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;

	ОбработкаОбъект = РеквизитФормыВЗначение("Объект"); 
	РЧтения = ПрочитатьКодыНаСервере(РДанныеДляЧтения,ВидОперации = 1);
	//РЧтения = ОбработкаОбъект.ПрочитатьКоды(Объект.ИмяФайла, фЗагружатьИзФайла);

	Если Не рЧтения.Успешно Тогда
		МаркировкаКС.ВывестиОшибки(рЧтения);
		Возврат;
	КонецЕсли;

	Сообщить(СтрШаблон("Прочитано: %1 кодов, %2 коробок.", рЧтения.Данные.КолКодовШтук, рЧтения.Данные.КолКодовКоробок));

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = рЧтения.Данные.МВТ;

	Запрос.Текст = "		
				   |ВЫБРАТЬ
				   |	ШтрихкодКоробки,
				   |	ШтрихкодУпаковки
				   |ПОМЕСТИТЬ ВТ_ДанныеАгрегаций
				   |ИЗ
				   |	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
				   |ГДЕ
				   |	Ссылка.ВидОперации = &ВидОперации
				   |	И Ссылка.ДокументОснование = &ДокументОснование
				   |ИНДЕКСИРОВАТЬ ПО ШтрихкодКоробки,ШтрихкодУпаковки
				   |;		
				   |ВЫБРАТЬ 
				   |	ВЫБОР 
				   |		КОГДА 
				   |			НЕ ВТ_ДанныеАгрегаций.ШтрихкодКоробки ЕСТЬ NULL
				   |			И НЕ ВТ_ДанныеАгрегаций.ШтрихкодУпаковки ЕСТЬ NULL 
				   |		ТОГДА Истина
				   |		ИНАЧЕ Ложь
				   |	КОНЕЦ КАК ЕстьВАгрегациях,
				   |	IsNULL(ВТ_ДанныеАгрегаций.ШтрихкодКоробки, ВТ_РезультатыПоиска.ШтрихкодКоробки) 		КАК ШтрихкодКоробки,
				   |	ВТ_РезультатыПоиска.ШтрихкодУпаковки	КАК ШтрихкодУпаковки_Файл,		
				   |	ВТ_ДанныеАгрегаций.ШтрихкодУпаковки		КАК ШтрихкодУпаковки_Агрегации,
				   |	IsNULL(ВТ_РезультатыПоиска.Количество,0) 	КАК Количество_Файл
				   |ИЗ
				   |	ВТ_ДанныеАгрегаций
				   |ПОЛНОЕ СОЕДИНЕНИЕ		
				   |	ВТ_РезультатыПоиска
				   |ПО
				   |	ВТ_РезультатыПоиска.ШтрихкодКоробки = ВТ_ДанныеАгрегаций.ШтрихкодКоробки			
				   |	И ВТ_РезультатыПоиска.ШтрихкодУпаковки = ВТ_ДанныеАгрегаций.ШтрихкодУпаковки			
				   |ГДЕ
				   |	ВТ_ДанныеАгрегаций.ШтрихкодКоробки 				ЕСТЬ NULL
				   |	ИЛИ ВТ_ДанныеАгрегаций.ШтрихкодУпаковки			ЕСТЬ NULL
				   |	ИЛИ ВТ_РезультатыПоиска.ШтрихкодКоробки 		ЕСТЬ NULL
				   |	ИЛИ ВТ_РезультатыПоиска.ШтрихкодУпаковки 		ЕСТЬ NULL
				   |	ИЛИ ВТ_РезультатыПоиска.ШтрихкодКоробки.Владелец <> ВТ_РезультатыПоиска.ШтрихкодУпаковки.Владелец
				   |УПОРЯДОЧИТЬ ПО
				   |	IsNULL(ВТ_ДанныеАгрегаций.ШтрихкодКоробки.Наименование, ВТ_РезультатыПоиска.ШтрихкодКоробки.Наименование),
				   |	IsNULL(ВТ_ДанныеАгрегаций.ШтрихкодУпаковки.Наименование, ВТ_РезультатыПоиска.ШтрихкодУпаковки.Наименование)
				   |";

	Запрос.УстановитьПараметр("ВидОперации", Перечисления.ВидыОперацийМаркировки.Агрегация);
	Запрос.УстановитьПараметр("ДокументОснование", Объект.ВыбЗПС);

	РЗапроса = Запрос.Выполнить();
	Выборка = рЗапроса.Выбрать();	

	Обр 			= Обработки.ПроверкаКарточекДляНК.Создать();
	ДопПараметры	= Новый Структура("ТД_Результат,ВнешниеДанные", ТД_Результат,
		Новый Структура("Данные", рЗапроса));

	Обр.ВывестиСхемуВТД(ОбработкаОбъект.ПолучитьМакет("СравнениеОтчетаОНанесении"), "Основной", ,
		ДопПараметры);  
		
    Запрос.МенеджерВременныхТаблиц = рЧтения.Данные.МВТ;
	Запрос.Текст = "
				   |ВЫБРАТЬ
				   |	ВТ_ДанныеФайла.ШтрихкодУпаковки 	КАК ШтрихкодУпаковки_файл,
				   |	ВТ_ДанныеАгрегаций.ШтрихкодУпаковки	КАК ШтрихкодУпаковки_Заказ
				   |ИЗ
				   |	ВТ_ДанныеФайла
				   |ПОЛНОЕ СОЕДИНЕНИЕ
				   |	ВТ_ДанныеАгрегаций
				   |ПО
				   |	ВТ_ДанныеФайла.ШтрихкодУпаковки = ВТ_ДанныеАгрегаций.ШтрихкодУпаковки
				   |ГДЕ
				   |	ВТ_ДанныеФайла.ШтрихкодУпаковки ЕСТЬ NULL
				   |	ИЛИ ВТ_ДанныеАгрегаций.ШтрихкодУпаковки ЕСТЬ NULL
				   |";

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 0 Тогда
		Сообщить("КМ штук отчета совпадают с кодами из агрегаций заказа.", СтатусСообщения.Информация);
	КонецЕсли;

КонецПроцедуры
&НаСервере
Функция ЕстьПлановыеАгрегации()
	Запрос = Новый Запрос;
	Запрос.Текст = "
				   |ВЫБРАТЬ
				   |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ссылка) КАК КолАгрегаций
				   |ИЗ
				   |	Документ.МаркировкаТоваровИСМП 
				   |ГДЕ
				   |	ДокументОснование = &ДокументОснование
				   |	И ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)	
				   |	И Статус В (&Статусы)
				   |	И Проведен
				   |";

	Статусы = Новый Массив;
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.ОжиданиеОтложеннойОбработки);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.Обрабатывается);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.Обработан);
	Статусы.Добавить(Перечисления.СтатусыДокументовМаркировки.ОшибкаОбработки);

	Запрос.УстановитьПараметр("Статусы", Статусы);
	Запрос.УстановитьПараметр("ДокументОснование", Объект.ВыбЗПС);

	Выборка = Запрос.Выполнить().Выбрать();

	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.КолАгрегаций))

КонецФункции

