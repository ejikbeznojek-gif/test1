Функция ВыполнитьШагПроверки_НайденыДокументыПоГУИД(МВТ)
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Структура("Имя,МакетОтчета,рЗапроса", "Ненайденные ЗПС/КП по идентификатору", "НеНайденыДокументы", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
	"	 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|ЗПС_Строка	КАК ГУИД
	|ИЗ ВТ_РезультатыПоиска
	|ГДЕ 
	|ВТ_РезультатыПоиска.ЗПС_ссылка = Значение(Документ.ЗаказПоставщику.ПустаяСсылка) 	  
	|ОБЪЕДИНИТЬ ВСЕ 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|КП_Строка
	|ИЗ ВТ_РезультатыПоиска
	|ГДЕ 
	|ВТ_РезультатыПоиска.КП_ссылка = Значение(Документ.КонтрактСПроизводителем.ПустаяСсылка)  
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить(СтрШаблон("Не найден ЗПС/КП по идентификатору %1.", Выборка.ГУИД));	
		
	КонецЦикла;	
	Результат.Данные.рЗапроса = Запрос.Выполнить();
	Возврат Результат;	
КонецФункции

