	Если рЧтения.Успешно Тогда
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = рЧтения.Данные.МВТ;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ КодКоробки КАК КодАгрегации ИЗ ВТ_ДанныеФайла ГДЕ КодКоробки<>"""" УПОРЯДОЧИТЬ ПО КодКоробки ";

		ВыборкаКодыКоробок = Запрос.Выполнить().Выбрать();

		Если ВыборкаКодыКоробок.Количество() > 0 Тогда
			ДокАгрегации = Документы.МаркировкаТоваровИСМП.ПолучитьСоздатьДокАгрегации(Объект.ВыбЗПС,
				Перечисления.ТипыШтрихКодов.Коробка, Перечисления.ТипыУпаковок.МонотоварнаяУпаковка,
				Новый Структура("ВидОперации", Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов));
			Если ЗначениеЗаполнено(ДокАгрегации) Тогда
				Если 1 = 1 Тогда
					ДокОбъект = ДокАгрегации.ПолучитьОбъект();
				Иначе
					ДокОбъект = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
				КонецЕсли;

				ДокОбъект.ВидОперацииИСМП = Неопределено;

				ДокОбъект.ПодразделениеНанесения = ПолучитьРеквизитШапки(Объект.ВыбЗПС, "Контрагент");

				ДокОбъект.ШтрихкодыУпаковок.Очистить();
				Пока ВыборкаКодыКоробок.Следующий() Цикл
					СтрокаТЧ = ДокОбъект.ШтрихкодыУпаковок.Добавить();
					СтрокаТЧ.КодАгрегации = Прав(СокрЛП(ВыборкаКодыКоробок.КодАгрегации), 18);
				КонецЦикла;

				ДокОбъект.фКодыАгрегацийДляПоставщиков	= Истина;
				ДокОбъект.КоличествоКодовSSCC			= ДокОбъект.ШтрихкодыУпаковок.Количество();

				ДокОбъект.Статус = Перечисления.СтатусыДоков_Маркировка.ВРаботе;
				ДокОбъект.Записать(РежимЗаписиДокумента.Запись);

				Сообщить("Заполнен доумент: " + ДокАгрегации, СтатусСообщения.Информация);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура кнВынутьКоробкиНаСервере(РДанныеДляЧтения)
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Коды = ПрочитатьКодыНаСервере(РДанныеДляЧтения,ВидОперации = 1);
	//Коды = ОбработкаОбъект.ПрочитатьКоды(Объект.ИмяФайла, фЗагружатьИзФайла);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Коды.Данные.МВТ;

	Запрос.Текст = "
				   |ВЫБРАТЬ РАЗЛИЧНЫЕ ШтрихКодКоробки ПОМЕСТИТЬ ВТ_Коробки ИЗ ВТ_РезультатыПоиска ИНДЕКСИРОВАТЬ ПО ШтрихКодКоробки
				   |;
				   |ВЫБРАТЬ ШтрихКодКоробки ИЗ ВТ_Коробки
				   |;
				   |ВЫБРАТЬ
				   |	ТЧ_Агрегации.ШтрихкодКоробки 			КАК ШтрихкодКоробки,
				   |	ТЧ_Агрегации.Ссылка.Статус 				КАК Статус,
				   |	ТЧ_Агрегации.Ссылка						КАК ДокАгрегации,
				   |	ТЧ_Агрегации.Ссылка.ДокументОснование	КАК ЗПС_Дубль
				   |ИЗ
				   |	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК ТЧ_Агрегации
				   |ВНУТРЕННЕЕ СОЕДИНЕНИЕ
				   |	ВТ_Коробки	
				   |ПО
				   |	ВТ_Коробки.ШтрихкодКоробки = ТЧ_Агрегации.ШтрихкодКоробки
				   |ГДЕ
				   |	ТЧ_Агрегации.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
				   |	И ТЧ_Агрегации.Ссылка.ДокументОснование <> &ВыбЗПС
				   |ИТОГИ ПО
				   |	ЗПС_Дубль,
				   |	ДокАгрегации
				   |";

	Запрос.УстановитьПараметр("ВыбЗПС", Объект.ВыбЗПС);

	РЗапроса = Запрос.ВыполнитьПакет();

	КоробкиКПереносу	= Новый Соответствие;
	Выборка_Коробки		= рЗапроса[рЗапроса.ВГраница() - 1].Выбрать();
	Пока Выборка_Коробки.Следующий() Цикл
		КоробкиКПереносу[Выборка_Коробки.ШтрихКодКоробки] = Истина;
	КонецЦикла;

	Выборка_ЗПС_Дубль	= рЗапроса[рЗапроса.ВГраница()].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ЗПС_Дубль");

	Пока Выборка_ЗПС_Дубль.Следующий() Цикл
		Выборка_ДокАгрегации = Выборка_ЗПС_Дубль.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ДокАгрегации");
		Пока Выборка_ДокАгрегации.Следующий() Цикл
			Сообщить("Удаление коробок из: " + Выборка_ЗПС_Дубль.ЗПС_Дубль + " " + Выборка_ДокАгрегации.ДокАгрегации
				+ " " + Выборка_ДокАгрегации.Статус);

			ДокАгрегации = Выборка_ДокАгрегации.ДокАгрегации.ПолучитьОбъект();
			Если 1 = 2 Тогда
				ДокАгрегации = Документы.МаркировкаТоваровИСМП.СоздатьДокумент();
			КонецЕсли;

			КоробкиТекДокумента = Новый Соответствие;
			СтрокиКУдалению = Новый Массив;
			Для Каждого СтрокаТЧ Из ДокАгрегации.ШтрихкодыУпаковок Цикл
				Если ЗначениеЗаполнено(СтрокаТЧ.ШтрихкодКоробки) И КоробкиКПереносу[СтрокаТЧ.ШтрихкодКоробки]
					<> Неопределено Тогда
					СтрокиКУдалению.Добавить(СтрокаТЧ);
					КоробкиТекДокумента[СтрокаТЧ.ШтрихкодКоробки] = Истина;
				КонецЕсли;
			КонецЦикла;

			Сообщить("	к удалению " + СтрокиКУдалению.Количество() + " строк.");

			Для Каждого Строка Из СтрокиКУдалению Цикл
				ДокАгрегации.ШтрихкодыУпаковок.Удалить(Строка);
			КонецЦикла;

			ДокАгрегации.Записать(?(ДокАгрегации.Проведен, РежимЗаписиДокумента.Проведение,
				РежимЗаписиДокумента.Запись));

			Сообщить("	записан документ: " + ДокАгрегации);

			Если Выборка_ДокАгрегации.Статус = Перечисления.СтатусыДокументовМаркировки.Обработан Тогда
//				Для Каждого КиЗ Из КоробкиТекДокумента Цикл
//					//Сообщить("		"  + КиЗ.Ключ);			
//				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура кнЗаменитьКодыВФайлеНаСервере(РДанныеДляЧтения,Коробки,ТДокумент = Неопределено)
		
	ТКодыКривые = ПолучитьТаблицуКодыИзСтроки(КодыКривые);
	ТКодыРовные = ПолучитьТаблицуКодыИзСтроки(КодыРовные);
	
	Если тКодыКривые.Количество() = 0 Тогда
		Ошибки = "Не указаны заменяемые коды !";
	Иначе
		Если тКодыРовные.Количество()<>тКодыКривые.Количество() Тогда
			Ошибки = "Не совпадет количество заменяемых и новых кодов !";			
		КонецЕсли;		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(Ошибки) Тогда
		Сообщить(Ошибки, СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;
	
	ТЗамены = Новый ТаблицаЗначений;
	ТЗамены.Колонки.Добавить("КодСтарый", 	ПолучитьОписаниеТиповСтроки(200));
	ТЗамены.Колонки.Добавить("КодНовый",	ПолучитьОписаниеТиповСтроки(200));
	
	Для Сч = 0 По тКодыКривые.Количество()-1  Цикл
		СтрокаЗамены = ТЗамены.Добавить();	
		СтрокаЗамены.КодСтарый  = тКодыКривые[Сч].КодУпаковки;
		СтрокаЗамены.КодНовый	= тКодыРовные[Сч].КодУпаковки;	
	КонецЦикла;
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	РЧтения = ПрочитатьКодыНаСервере(РДанныеДляЧтения,ВидОперации = 1);
	//РЧтения = ОбработкаОбъект.ПрочитатьКоды(Объект.ИмяФайла, 0);
	
	Если рЧтения.Успешно Тогда
	Иначе
		МаркировкаКС.ВывестиОшибки(рЧтения);
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = рЧтения.Данные.МВТ;
	Запрос.Текст = "	
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Замена ИЗ &тЗамены КАК тЗамены ИНДЕКСИРОВАТЬ ПО КодСтарый
	|;
	|ВЫБРАТЬ
	|   ВТ_ДанныеФайла.КодКоробки 	КАК КодКоробки,
	|	ВТ_ДанныеФайла.КодУпаковки 	КАК КодСтарый,
	|	ВТ_Замена.КодНовый	 		КАК КодНовый	
	|ИЗ 
	|	ВТ_ДанныеФайла	
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_Замена
	|ПО
	|	ВТ_ДанныеФайла.КодУпаковки = ВТ_Замена.КодСтарый	
	|ИТОГИ ПО
	|	КодКоробки	
	|";
	
	Запрос.УстановитьПараметр("тЗамены", тЗамены);
	
	Коробки = Новый Массив; 
	
	Макет = ОбработкаОбъект.ПолучитьМакет("ЗаменаКодов");
	
	ТДокумент = Новый ТабличныйДокумент;	
	ТДокумент.Вывести(Макет.ПолучитьОбласть("Шапка"));
	
	Выборка_КодКоробки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "КодКоробки");
	ВсегоСтрок = Выборка_КодКоробки.Количество();
	Сч	= 0;	
	Пока Выборка_КодКоробки.Следующий() Цикл		
		Выборка = Выборка_КодКоробки.Выбрать();
		
		КодыШтук = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.КодНовый) Тогда
				КодыШтук.Добавить(Выборка.КодНовый);
				
				ОблСтрока = Макет.ПолучитьОбласть("Строка");
				ОблСтрока.Параметры.Заполнить(Выборка);
				
				ТДокумент.Вывести(ОблСтрока);
							
			 Иначе
				 КодыШтук.Добавить(Выборка.КодСтарый);
			 КонецЕсли;
		 КонецЦикла;
		 
		 Коробки.Добавить(Новый Структура("unitSerialNumber,sntins", Выборка_КодКоробки.КодКоробки, КодыШтук));
		
		Сч = Сч+1;
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПолучитьТаблицуКодыИзСтроки(ВходСтрока)
	ТКодов = Новый ТаблицаЗначений;	
	тКодов.Колонки.Добавить("КодУпаковки", ПолучитьОписаниеТиповСтроки(150));
	
	Для Каждого Код Из СтрРазделить(ВходСтрока, Символы.ПС) Цикл
		Если ЗначениеЗаполнено(Код) Тогда
			СтрокаТ = тКодов.Добавить();	
			СтрокаТ.КодУпаковки = Код;		
		КонецЕсли;		
	КонецЦикла;
	
	Возврат тКодов;
КонецФункции //ПолучитьТаблицуКодыИзСтроки(ВходСтрока)


&НаСервере
Процедура кнСоздатьХКМНаСервере()
		
	КодыМаркировки	= ПолучитьКодыИзАгрегаций(Объект.ВыбЗПС);

	Если ЗначениеЗаполнено(Объект.ВыбЗПС) Тогда
		РСозданияХКМ = Документы.ХранилищеКодовМаркировки.Создать_ХКМ_к_ЗПС_Импорт_ПоОтчетам(Объект.ВыбЗПС, КодыМаркировки);
		Если рСозданияХКМ.Успешно Тогда
			ТекстСообщения = СтрШаблон("Создано: %1 ХКМ к ЗПС: %2.", рСозданияХКМ.ОбработаноОбъектов, Объект.ВыбЗПС);
			Сообщить(ТекстСообщения, СтатусСообщения.Информация);
		Иначе
			МаркировкаКС.ВывестиОшибки(рСозданияХКМ);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьКодыИзАгрегаций(ЗПС_Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ШтрихкодУпаковки 				КАК ШтрихкодУпаковки,
	|	ШтрихкодКоробки 				КАК ШтрихкодКоробки,
	|	КодАгрегации 					КАК КодКоробки,
	|	ШтрихкодУпаковки.Наименование 	КАК КодУпаковки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|ГДЕ	
	|	Ссылка.ДокументОснование = &ЗПС_Ссылка
	|	И Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийМаркировки.Агрегация)
	|УПОРЯДОЧИТЬ ПО
	|	ШтрихкодКоробки.Наименование,
	|	ШтрихкодУпаковки.Наименование
	|";	
	
	Запрос.УстановитьПараметр("ЗПС_Ссылка", ЗПС_Ссылка);
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервере
Функция кнВыгрузитьАгрегациюНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка.ДокументОснование.Организация.ИНН КАК customerINN,
	|	ШтрихкодУпаковки,
	|	ШтрихкодКоробки,
	|	Ссылка.ДокументОснование.Дата 	КАК orderDate,
	|	Ссылка.ДокументОснование.Номер 	КАК orderNumber
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок КАК МаркировкаТоваровИСМПШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &ВыбАгрегация
	|ИТОГИ ПО
	|   Ссылка.ДокументОснование,
	|	ШтрихкодКоробки
	|";
	
	Запрос.УстановитьПараметр("ВыбАгрегация", ВыбАгрегация);
	
	Выборка_ДокументОснование = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ДокументОснование");
	Пока Выборка_ДокументОснование.Следующий() Цикл
		Коробки = Новый Массив;	
		
		Выборка_КА = Выборка_ДокументОснование.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ШтрихкодКоробки");
		Пока Выборка_КА.Следующий() Цикл
			ДанныеКоробки = Новый Структура("unitSerialNumber", ""+Выборка_КА.ШтрихкодКоробки); 
			
			Коды 	= Новый Массив;
			Выборка = Выборка_КА.Выбрать();
			Пока Выборка.Следующий() Цикл
				Коды.Добавить(""+Выборка.ШтрихкодУпаковки);				
			КонецЦикла;	
			ДанныеКоробки.Вставить("sntins", Коды);
			
			Коробки.Добавить(ДанныеКоробки);
		КонецЦикла;
		
		Данные	= Новый Структура("customerINN,orderNumber,orderDate,aggregationUnits",
		Выборка_ДокументОснование.customerINN, Выборка_ДокументОснование.orderNumber, Выборка_ДокументОснование.orderDate,
		Коробки
		);				
		
		
	КонецЦикла;
	
	Возврат Данные; 
КонецФункции

&НаСервере
Процедура кнЗаполнитьСоставАгрегационныхКодовНаСервере()
	Документы.МаркировкаТоваровИСМП.ПроверитьЗаполнитьСоставАгрегационныхКодов(ВыбАгрегация);
КонецПроцедуры

&НаСервере
Процедура кнПрописатьНоменклатуруВАКНаСервере()	
    
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодУпаковки.Владелец 	КАК Номенклатура,
	|	ШтрихкодКоробки 			КАК ШтрихкодКоробки
	|ИЗ
	|	Документ.МаркировкаТоваровИСМП.ШтрихкодыУпаковок
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И ШтрихкодКоробки.Владелец.ВерсияДанных ЕСТЬ NULL
	|";
	
	Запрос.УстановитьПараметр("Ссылка", ВыбАгрегация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ВсегоСтрок = Выборка.Количество();
	
	Пока Выборка.Следующий() Цикл
					
		СпрОбъект = Выборка.ШтрихкодКоробки.ПолучитьОбъект();	
		СпрОбъект.Владелец = Выборка.Номенклатура;
		СпрОбъект.Записать();
		
		ВсегоСтрок = ВсегоСтрок-1;
		
	КонецЦикла; 
	
	//ЗавершитьОповещение = Истина; 

КонецПроцедуры

&НаСервере
Процедура кнЗарегитьКодыПоЗаказуНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст =" 
	|ВЫБРАТЬ
