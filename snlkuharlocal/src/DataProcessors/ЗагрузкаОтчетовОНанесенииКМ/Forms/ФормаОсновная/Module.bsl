КонецПроцедуры

&НаКлиенте
Процедура кнЗаменитьКодыВФайле(Команда)
	ТДокумент = Новый ТабличныйДокумент();
	РЧтения = ПрочитатьКодыНаКлиенте();
	Ошибки = "";
	НовоеИмяФайла = "";
	Если ПустаяСтрока(Объект.ИмяФайла) Тогда
		Ошибки = "Не указано имя файла отчета !";
	Иначе
		Файл = Новый Файл(Объект.ИмяФайла);	
		Если Файл.Существует() Тогда
			Если Файл.ЭтоКаталог() Тогда
				Ошибки = "Должно быть указано имя файла а не каталога !";
			Иначе
				НовоеИмяФайла = Файл.Путь+Файл.ИмяБезРасширения+"_Нов"+Файл.Расширение;
			КонецЕсли;
		Иначе
			Ошибки = "Указанный файл отчета не существует !";
		КонецЕсли;
	КонецЕсли;
	Коробки = Неопределено; 
	кнЗаменитьКодыВФайлеНаСервере(РЧтения,Коробки, ТДокумент); 
	Если Коробки = неопределено Тогда
	
		Возврат; 
	
	КонецЕсли;
	Данные 	= Новый Структура("aggregationUnits", Коробки); 
	Запись = Новый ЗаписьJSON;
	Запись.ОткрытьФайл(НовоеИмяФайла); 
	ЗаписатьJSON(Запись, Данные);	
	Запись.Закрыть(); 
	Сообщить("Сформирован файл: " + НовоеИмяФайла, СтатусСообщения.Информация);
	
	ТДокумент.ОтображатьСетку		= Ложь;
	ТДокумент.ОтображатьЗаголовки	= Ложь;
	ТДокумент.Показать("Замена кодов в файле.");
	
КонецПроцедуры

