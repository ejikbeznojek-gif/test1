Функция ПрочитатьКоды(ИмяФайла, фЗагружатьИзФайла,НаполнениеЗПС = Ложь) Экспорт
	Если фЗагружатьИзФайла = 0 Тогда
		//++Данилова Е.В. 13.05.2026 ASU-2790
		//Возврат	ПрочитатьКодыИзФайла(ИмяФайла);
		Возврат	ПрочитатьКодыИзФайла(ИмяФайла,НаполнениеЗПС);
		//--Данилова Е.В. 13.05.2026 
	Иначе
		Файл = Новый Файл(ИмяФайла);					
		Если Файл.ЭтоКаталог() Тогда            
			КаталогЗагрузки = Файл.ПолноеИмя; 
		Иначе
			КаталогЗагрузки = Файл.Путь;			
		КонецЕсли;
		Если НЕ СтрЗаканчиваетсяНа(КаталогЗагрузки, ПолучитьРазделительПути()) Тогда
			КаталогЗагрузки = КаталогЗагрузки + ПолучитьРазделительПути();		
		КонецЕсли;
		//++Данилова Е.В. 13.05.2026 ASU-2790
		//Возврат ПрочитатьКодыИзКаталога(КаталогЗагрузки);
		Возврат ПрочитатьКодыИзКаталога(КаталогЗагрузки,НаполнениеЗПС);
		//--Данилова Е.В. 13.05.2026
	КонецЕсли;
КонецФункции //ПрочитатьКоды()
//
//Данилова Е.В. 13.05.2026 ASU-2790
Функция ПрочитатьКодыИзФайла(ИмяФайла,НаполнениеЗПС = Ложь)
	Результат = МаркировкаКС.СтруктураРезультата(Истина);
	
	ДД = Новый ДвоичныеДанные(ИмяФайла);
	СтрокаДанных = ПолучитьСтрокуИзДвоичныхДанных(ДД);
	//++Данилова Е.В. 13.05.2026 ASU-2790
	//рЧтения = ПрочитатьТаблицуКодовИзСтроки(СтрокаДанных);
	Если НаполнениеЗПС Тогда
		рЧтения = ПрочитатьТаблицуКодовИзСтроки_НаполнениеЗПС(СтрокаДанных);
	Иначе 
		рЧтения = ПрочитатьТаблицуКодовИзСтроки(СтрокаДанных);	
	КонецЕсли;
	 
	//Возврат СопоставитьКоды(рЧтения.Коды);
	Возврат СопоставитьКоды(рЧтения.Коды,НаполнениеЗПС);
	//--Данилова Е.В. 13.05.2026	
КонецФункции // ПрочитатьКодыИзФайла(ИмяФайла)
