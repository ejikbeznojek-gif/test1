Функция ИсключаемыеТипыСнизуВверх()
	МТ=Новый Массив;
	
	МТ.Добавить(Документы.ПрайсЛист);
	МТ.Добавить(Документы.УстановкаСкидок);
	
	Возврат МТ_ВСоответствие(МТ);
КонецФункции //ИсключаемыеТипыСнизуВверх()

Функция ИсключаемыеТипыСверхуВниз()
