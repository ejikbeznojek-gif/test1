	для каждого стр из данные цикл
		планыобмена.УдалитьРегистрациюИзменений(Узел,стр);
	конеццикла;
	#ЕСЛИ КЛИЕНТ ТОГДА
		Состояние("");
	#КОНЕЦЕСЛИ
	
Конецпроцедуры	

// Функция записи нового сообщения обмена в файл
// 
// Параметры:
//  ИмяФайла	- имя файла, в который будет записано сообщение обмена
//  ПланОбмена	- ссылка на план обмена, для которого формируется сообщение обмена
//
// Возвращаемое значение:
//  НомерСообщения - номер сообщения записанного в файл обмена
//
Функция ЗаписатьНовоеСообщение(ИмяФайла,ТО=Неопределено)
	
	ОбработанныеОбъекты=Новый Соответствие;
	
	МетаУзел=Метаданные();
	
	НомерСообщения = 0;
	
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	// Создаем объект записи XML
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ИмяФайла);
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	// Создаем новое сообщение
	ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();
	ЗаписьСообщения.НачатьЗапись(ЗаписьXML, Ссылка);
	
	// Для сокращения размера файла сообщения записываем соответствие пространств имен
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsd", "http://www.w3.org/2001/XMLSchema");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("v8", "http://v8.1c.ru/data");
	
	НомерСообщения = ЗаписьСообщения.НомерСообщения;
	
	ЗаписатьВЛог("ОбменДаннымиОсновной","Начало формирования сообщения: "+НомерСообщения,Перечисления.ТипыСообщенийЛога.Информация);	
	
	//ЗаписатьОшибкиЗагрузки(ЗаписьXML,Ссылка);
	//Мессерле -Для Риги не нужна вся номенклатура
	
	Если ЗаписьСообщения.Получатель.НоменклатураДляВключения.количество()>0 тогда
		СписокЗарегистрированнойНоменклатуры=Новый списокЗначений;	
		Счетчик = 0;
		ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(ЗаписьСообщения.Получатель, НомерСообщения,Метаданные.Справочники.Номенклатура);
		Пока ВыборкаИзменений.Следующий() Цикл		
			
			Данные = ВыборкаИзменений.Получить();		
			Если ТипЗнч(Данные)=Тип("СправочникОбъект.номенклатура") тогда
				СписокЗарегистрированнойНоменклатуры.Добавить(Данные.ссылка);
				Счетчик = Счетчик + 1;
				
				//Если счетчик=1000 тогда прервать;Конецесли;
				
			Конецесли;	
			
		Конеццикла;
		
		СписНом=ЗаписьСообщения.Получатель.НоменклатураДляВключения.выгрузитьколонку("Номенклатура");
		СписНом2=новый списокзначений;
		для ном=0 по списном.Количество()-1 цикл
			Списном2.Добавить(Списном[ном].родитель);
		Конеццикла;
		
		Запрос=новый Запрос;
		Запрос.Текст="ВЫБРАТЬ
		|	номенклатура.Ссылка КАК товар
		|ИЗ
		|	Справочник.Номенклатура КАК номенклатура
		|ГДЕ
		|	(НЕ(номенклатура.Ссылка В ИЕРАРХИИ (&СписокРазрешеннойНоменклатуры)
		|				ИЛИ номенклатура.Ссылка В (&СписокРодителей)))
		|	И номенклатура.Ссылка В(&СписокЗарегистрированной)";
		
		
		Запрос.УстановитьПараметр("СписокЗарегистрированной",СписокЗарегистрированнойНоменклатуры);
		Запрос.УстановитьПараметр("СписокРазрешеннойНоменклатуры", СписНом);
		Запрос.УстановитьПараметр("СписокРодителей", СписНом2);
		
		Выб=Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Товар");
		ГрупповоеУдалениеРегистрации(ЗаписьСообщения.Получатель,выб);
		Запрос.Текст="ВЫБРАТЬ
		|	номенклатура.Ссылка КАК товар
		|ИЗ
		|	Справочник.ШтрихКоды КАК номенклатура
		|ГДЕ
		|	номенклатура.Владелец В (&Спис)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Единицы.Ссылка
		|ИЗ
		|	Справочник.Единицы КАК Единицы
		|ГДЕ
		|	Единицы.Владелец В (&Спис)";
		Запрос.УстановитьПараметр("Спис",Выб);
		Выб1=Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Товар");
		ГрупповоеУдалениеРегистрации(ЗаписьСообщения.Получатель,выб1);
		#ЕСЛИ КЛИЕНТ ТОГДА
			Сообщить("Для узла "+ЗаписьСообщения.Получатель+" снята регистрация для "+выб.Количество()+" товаров и "+выб1.Количество()+" Штрих и единиц.Осталось зарег "+(Счетчик-выб.Количество())+" товаров");
		#КОНЕЦЕСЛИ
	Конецесли;
	//Мессерле -Для Риги не нужна вся номенклатура
	
	// Получаем выборку изменённых данных
	Счетчик = 0;
	ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(ЗаписьСообщения.Получатель, НомерСообщения);
	Пока ВыборкаИзменений.Следующий() Цикл		
		#Если Клиент Тогда
			ОбработкаПрерыванияПользователя();
			Счетчик = Счетчик + 1;
			Если Счетчик % 10 = 0 Тогда			
				Состояние("Выгрузка данных: " + Строка(Счетчик));
			КонецЕсли;			
		#КонецЕсли
		
		Данные = ВыборкаИзменений.Получить();		
		
		//+++Чирков 2021.07.09 доп. свойства номенклатуры
		Если НужноПропуститьЭтиДанные(Данные) Тогда
			Продолжить;		
		КонецЕсли;
		//---Чирков 2021.07.09
		
		// Если перенос данных не нужен, то, возможно, необходимо записать удаление данных
		Если Не НуженПереносДанных(Данные) Тогда
			
			// Получаем значение с возможным удалением данных
			//крохин начало
			//УдалениеДанных(Данные);
			Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
				УдалениеДанных(Данные);	
			Конецесли;
			//крохин конец			
		КонецЕсли;		
		
		// Записываем данные в сообщение
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда //Выгрузка только из ЦО
			
			ТипДанных = ТипЗнч(Данные);			
			ПодразделениеПолучатель	=ЗаписьСообщения.Получатель.Подразделение;
			СтрокиКУдалению			=Новый Массив;
			
			Если ТипДанных=Тип("ДокументОбъект.ДвиженияДенежныхСредств") ИЛИ ТипДанных=Тип("ДокументОбъект.КорректировкаЗадолженности") Тогда
				Если ТипЗнч(Данные)=Тип("ДокументОбъект.ДвиженияДенежныхСредств") Тогда
					ТекТЧ=Данные.Платежи;
				ИначеЕсли ТипЗнч(Данные)=Тип("ДокументОбъект.КорректировкаЗадолженности") Тогда
					ТекТЧ=Данные.Расчеты;			
				КонецЕсли;
				
				Для Каждого СтрокаТЧ Из ТекТЧ Цикл
					//Катаев+ 25/06/13 Проверяем не по договору, а по принадлежности контрагента к узлу
					//Если СтрокаТЧ.Договор.Подразделение<>ПодразделениеПолучатель Тогда
					//	СтрокиКУдалению.Добавить(СтрокаТЧ);				
					//КонецЕсли; 			
					ЗаписьУдалить = КонтрагентНеФилиала(СтрокаТЧ.Контрагент, ПодразделениеПолучатель);
					Если ЗаписьУдалить Тогда
						СтрокиКУдалению.Добавить(СтрокаТЧ);				
					КонецЕсли;
					//Катаев- 25/06/13
				КонецЦикла; 
				
				Для Каждого СтрокаТЧ Из СтрокиКУдалению Цикл
					ТекТЧ.Удалить(СтрокаТЧ);			
				КонецЦикла;			
			ИначеЕсли ТипДанных=Тип("ДокументОбъект.Взаимозачет") Тогда
				ТекТЧ=Данные.Взаимозачеты;
				
				Для Каждого СтрокаТЧ Из ТекТЧ Цикл
					//Катаев+ 25/06/13 Проверяем не по договору, а по принадлежности контрагента к узлу
					//Если НЕ (СтрокаТЧ.Договор_Дебитор.Подразделение=ПодразделениеПолучатель ИЛИ СтрокаТЧ.Договор_Кредитор.Подразделение=ПодразделениеПолучатель) Тогда
					//	СтрокиКУдалению.Добавить(СтрокаТЧ);				
					//КонецЕсли; 			
					ЗаписьУдалить = КонтрагентНеФилиала(СтрокаТЧ.Контрагент_Дебитор, ПодразделениеПолучатель);
					Если ЗаписьУдалить Тогда
						ЗаписьУдалить = КонтрагентНеФилиала(СтрокаТЧ.Контрагент_Кредитор, ПодразделениеПолучатель);
						Если ЗаписьУдалить Тогда
							СтрокиКУдалению.Добавить(СтрокаТЧ);
						КонецЕсли;
					КонецЕсли;
					//Катаев- 25/06/13
				КонецЦикла;				
				
				Для Каждого СтрокаТЧ Из СтрокиКУдалению Цикл
					ТекТЧ.Удалить(СтрокаТЧ);			
				КонецЦикла;				
				//Катаев+ 06/12/13
			ИначеЕсли ТипДанных=Тип("ДокументОбъект.ЗаявкаНаТСД") ТОгда
				ТекТЧ=Данные.Заявка;
				
				Для Каждого СтрокаТЧ Из ТекТЧ Цикл
					Если СтрокаТЧ.Накладная.Склад.Подразделение <> ПодразделениеПолучатель Тогда
						СтрокиКУдалению.Добавить(СтрокаТЧ);
					КонецЕсли;
				КонецЦикла;				
				
				Для Каждого СтрокаТЧ Из СтрокиКУдалению Цикл
					ТекТЧ.Удалить(СтрокаТЧ);			
				КонецЦикла;
				//Катаев- 06/12/13
				//Катаев+ 23/09/14 Для КЦН/Вычерк и РКМ/Вычерк если поле договор не заполенно, то проставляем принудительно
			ИначеЕсли ТипДанных=Тип("ДокументОбъект.КорректировкаЦенВНакладной") ИЛИ ТипДанных=Тип("ДокументОбъект.РекламационнаяНакладная") Тогда
				//Катаев+ 26/09/14
				//Если Данные.Договор = Справочники.Договоры.ПустаяСсылка() Тогда
				Если Данные.Договор = Справочники.Договоры.ПустаяСсылка() И ЕстьРеквизитДокумента("Договор", Данные.ДокОснование.Метаданные()) Тогда
					//Катаев- 26/09/14
					Данные.Договор = Данные.ДокОснование.Договор;
				КонецЕсли;
				//Катаев- 23/09/14
			КонецЕсли;
		КонецЕсли; 
		
		ЗаписатьДанные(ЗаписьXML, Данные);		
		
		#Если Клиент Тогда
			// Выводим диагностическое сообщение о записанных данных
			ВывестиДанные(Данные);
		#КонецЕсли
		
		ТипДанных=ТипЗнч(Данные);
		КоличествоОбъектов=ОбработанныеОбъекты.Получить(ТипДанных);		
		Если КоличествоОбъектов=Неопределено Тогда
			КоличествоОбъектов=0;
		КонецЕсли; 
		КоличествоОбъектов=КоличествоОбъектов+1;
		ОбработанныеОбъекты.Вставить(ТипДанных,КоличествоОбъектов);
	КонецЦикла;
	
	// Завершаем запись сообщения
	ЗаписьСообщения.ЗакончитьЗапись();
	ЗаписьXML.Закрыть();
	
	ВремяВыполнения = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
	ТипЧисло = Новый ОписаниеТипов("Число");
	КоличествоОбъектов = 0;
	Для Каждого КиЗ Из ОбработанныеОбъекты Цикл
		КоличествоОбъектов = КоличествоОбъектов + ТипЧисло.ПривестиЗначение(КиЗ.Значение);	
	КонецЦикла;
	ТекстСообщения = СтрШаблон("Окончание формирования сообщения: %1. Кол-во объектов: %2.", НомерСообщения, Формат(КоличествоОбъектов, "ЧРГ=' '; ЧГ=3,0"));
	ЗаписатьВЛог("ОбменДаннымиОсновной", ТекстСообщения, Перечисления.ТипыСообщенийЛога.Информация, , , ВремяВыполнения);	
	
	Возврат НомерСообщения;
	
КонецФункции // ЗаписатьНовоеСообщение(ИмяФайла)

