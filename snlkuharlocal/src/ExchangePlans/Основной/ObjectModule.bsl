Функция СериализоватьРегистрСведенийНаборЗаписей(ЗаписьXML, Данные) Экспорт
	
	МетаОбъект = Метаданные.НайтиПоТипу(ТипЗнч(Данные));
	ПолноеИмя = МетаОбъект.ПолноеИмя();
	
	Поз = Найти(ПолноеИмя,".");
	Если Поз <> 0 Тогда
		Имя = СокрЛП(Прав(ПолноеИмя, Поз + 2));
	КонецЕсли;
	
	ЗаписьXML = Новый ЗаписьXML;
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("InformationRegisterRecordSet." + Имя);
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("Filter");
			Для Каждого Элемент ИЗ Данные.Отбор Цикл
				ЗаписьXML.ЗаписатьНачалоЭлемента("FilterItem");
					ЗаписьXML.ЗаписатьНачалоЭлемента("Name");
						ЗаписьXML.ЗаписатьТекст(Элемент.Имя);
					ЗаписьXML.ЗаписатьКонецЭлемента();
					ЗаписьXML.ЗаписатьНачалоЭлемента("Value");
						ЗаписьXML.ЗаписатьТекст(XMLСтрока(Элемент.Значение));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				ЗаписьXML.ЗаписатьКонецЭлемента();
			КонецЦикла;
	       ЗаписьXML.ЗаписатьКонецЭлемента();
	
		ЗаписьXML.ЗаписатьНачалоЭлемента("Records");
		
		Для Каждого Запись ИЗ Данные Цикл
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("Record");
		
				Для Каждого СтандартныйРеквизит ИЗ МетаОбъект.СтандартныеРеквизиты Цикл
					ЗаписьXML.ЗаписатьНачалоЭлемента(СтандартныйРеквизит.Имя);
					       ЗаписьXML.ЗаписатьТекст(XMLСтрока(Запись[СтандартныйРеквизит.Имя]));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				КонецЦикла;
		
				Для Каждого Измерение ИЗ МетаОбъект.Измерения Цикл
					ЗаписьXML.ЗаписатьНачалоЭлемента(Измерение.Имя);
					       ЗаписьXML.ЗаписатьТекст(XMLСтрока(Запись[Измерение.Имя]));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				КонецЦикла;
				
				Для Каждого Ресурс ИЗ МетаОбъект.Ресурсы Цикл
					ЗаписьXML.ЗаписатьНачалоЭлемента(Ресурс.Имя);
					       ЗаписьXML.ЗаписатьТекст(XMLСтрока(Запись[Ресурс.Имя]));
					ЗаписьXML.ЗаписатьКонецЭлемента();
				КонецЦикла;
				
				Для Каждого Реквизит ИЗ МетаОбъект.Реквизиты Цикл
					ЗаписьXML.ЗаписатьНачалоЭлемента(Реквизит.Имя);
					Если ТипЗнч(Запись[Реквизит.Имя]) = Тип("ХранилищеЗначения") Тогда
						ЗаписьXML.ЗаписатьТекст(XMLСтрока(Новый ХранилищеЗначения(Запись[Реквизит.Имя])));
					Иначе
						Попытка
							ЗаписьXML.ЗаписатьТекст(XMLСтрока(Запись[Реквизит.Имя]));
						Исключение
							ЗаписьXML.ЗаписатьТекст(XMLСтрока(Новый ХранилищеЗначения(Запись[Реквизит.Имя])));
						КонецПопытки;
					КонецЕсли;
					ЗаписьXML.ЗаписатьКонецЭлемента();
				КонецЦикла;
		
			ЗаписьXML.ЗаписатьКонецЭлемента(); // Record
		
		КонецЦикла;
	
		ЗаписьXML.ЗаписатьКонецЭлемента(); // Records
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // InformationRegisterRecordSet
	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции
