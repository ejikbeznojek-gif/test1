// Процедура записи сообщения с измененными данными
//
Функция ЗаписатьСообщениеСИзменениями(ПротВыгрузки=Неопределено,Автомат=Ложь) Экспорт
	
	// Формируем имя временного файла	
	КаталогВременныхФайлов=СокрЛП(КаталогВременныхФайлов());
	Если Прав(КаталогВременныхФайлов,1)<>"\" Тогда
		КаталогВременныхФайлов=КаталогВременныхФайлов+"\";	
	КонецЕсли; 
	ИмяФайла = КаталогВременныхФайлов + ПолучитьИмяФайлаОбмена(мЭтотУзел, Ссылка, "_W");
	
	ЗаписатьВЛог("ОбменДаннымиОсновной","Начало выгрузки в узел: "+Ссылка.Код,Перечисления.ТипыСообщенийЛога.Информация);
	
	НачалоОбработки=ТекущаяДата();
	
	// Записываем новое сообщение обмена в файл
	НомерСообщения 		= ЗаписатьНовоеСообщение(ИмяФайла);
	
	КонецФормированияСообщения=ТекущаяДата();
	
	Результат			= ОтправитьФайлОбмена(ИмяФайла,НомерСообщения,Ссылка);
	
	КонецОбработки=ТекущаяДата();
	
	СпрОбъект=Справочники.СтатистикаОбменов.СоздатьЭлемент();
	СпрОбъект.УстановитьНовыйКод(ПланыОбмена.Основной.ЭтотУзел().Код);
	СпрОбъект.Операция="Выгрузка";
	СпрОбъект.Отправитель		=ПараметрыСеанса.ЭтотУзел.Код;
	СпрОбъект.Получатель		=Код;	
	СпрОбъект.НомерСообщения	=НомерСообщения;
	СпрОбъект.НачалоОбработки	=НачалоОбработки;
	СпрОбъект.КонецОбработки	=КонецОбработки;
	СпрОбъект.Пользователь		=ПараметрыСеанса.Пользователь;
	
	Если ТипЗнч(ОбработанныеОбъекты)=Тип("Соответствие") Тогда
		Для Каждого Элемент Из ОбработанныеОбъекты Цикл
			СтрокаТЧ=СпрОбъект.ОбработанныеОбъекты.Добавить();		
			СтрокаТЧ.Тип		=Элемент.Ключ;
			СтрокаТЧ.Количество	=Элемент.Значение;
		КонецЦикла; 	
	КонецЕсли;
	
	Если НЕ Результат.Результат Тогда
		СпрОбъект.ОшибкаВыполнения=Результат.Описание;			
	КонецЕсли; 
	
	СпрОбъект.Записать();
	
	//Объект=Ссылка.ПолучитьОбъект();
	//Объект.ДатаПоследнейВыгрузки=ТекущаяДата();
	//Если Результат.Результат Тогда
	//	Объект.РезультатПоследнейВыгрузки="ОК. Отправлено сообщение: "+НомерСообщения+".";
	//Иначе
	//	Объект.РезультатПоследнейВыгрузки="Ошибка отправки сообщения: "+НомерСообщения+" ! "+Результат.Описание;
	//КонецЕсли;
	//Объект.Записать();
	
	ЗаписатьВЛог("ОбменДаннымиОсновной","Конец выгрузки в узел: "+Ссылка.Код,Перечисления.ТипыСообщенийЛога.Информация);	
	
	ПротВыгрузки=ВыгруженныеДокументы;
	
	Возврат Результат;
КонецФункции// ЗаписатьСообщениеСИзменениями()

// Процедура получения сообщения обмена данными
// Получает сообщение с новыми данными для этого узла и загружает данные
//
Функция ПрочитатьСообщениеСИзменениями(Контроль=Истина,ПротЗагр=Неопределено) Экспорт
	
	Перем НомерСообщения;	// Номер принимаемого сообщения
	
	НеЗагружатьДвижения=Новый Соответствие;
	
	ОбработанныеОбъекты	=Новый Соответствие;
	
	//Чирков 11.06.13+++
	СоздатьТаблицуОшибок();
	//Чирков 11.06.13---
	
	// Формируем имя временного файла
	КаталогВременныхФайлов=СокрЛП(КаталогВременныхФайлов());
	Если Прав(КаталогВременныхФайлов,1)<>"\" Тогда
		КаталогВременныхФайлов=КаталогВременныхФайлов+"\";	
	КонецЕсли;	
	ИмяФайла = КаталогВременныхФайлов + ПолучитьИмяФайлаОбмена(мЭтотУзел, Ссылка, "_R");	
	
	ЗаписатьВЛог("ОбменДаннымиОсновной","Загрузка из: " + Код,Перечисления.ТипыСообщенийЛога.Информация);	
	
	НачалоОбработки=ТекущаяДата();
	
	ФайлПолучен=ПолучитьФайлОбмена(ИмяФайла,Ссылка);
	
	Результат=Новый Структура("Результат,Описание");
	
	Если ФайлПолучен Тогда		
		Попытка			
			// Читаем полученное сообщение из файла	
			НомерСообщения = ПрочитатьНовоеСообщение(ИмяФайла,Контроль);
			
			ПротЗагр=ЗагруженныеДокументы;	
			
			Результат.Вставить("Результат",Истина);
			Результат.Вставить("Описание","Выполнена загрузка");			
		Исключение			
			ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка получения сообщения ! Отправитель: "+Код+". "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка,Истина);
			
			Результат.Вставить("Результат",Ложь);
			Результат.Вставить("Описание","Ошибка загрузки ! "+ОписаниеОшибки());
		КонецПопытки;
		
		Если НомерСообщения <> Неопределено Тогда			
			// Удаляем файлы со старыми сообщениями обмена
			УдалитьФайлыОбмена(НомерСообщения,Ссылка); 			
		КонецЕсли;		
	Иначе
		ЗаписатьВЛог("ОбменДаннымиОсновной","Нет сообщений из: " + Код,Перечисления.ТипыСообщенийЛога.Информация);
		
		Результат.Вставить("Результат",Ложь);
		Результат.Вставить("Описание","Нет сообщений !");
	КонецЕсли;
	
	Попытка		
		// Удаляем файл с сообщением обмена		
		УдалитьФайлы(ИмяФайла);		
	Исключение
		ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка удаления полученных файлов ! Отправитель: " + Код,Перечисления.ТипыСообщенийЛога.Ошибка);	
	КонецПопытки;
	
	КонецОбработки=ТекущаяДата();
	
	
	СпрОбъект=Справочники.СтатистикаОбменов.СоздатьЭлемент();
	СпрОбъект.УстановитьНовыйКод(ПланыОбмена.Основной.ЭтотУзел().Код);
	СпрОбъект.Операция="Загрузка";
	СпрОбъект.Отправитель		=Код;
	СпрОбъект.Получатель		=ПараметрыСеанса.ЭтотУзел.Код;	
	СпрОбъект.НомерСообщения	=НомерСообщения;
	СпрОбъект.НачалоОбработки	=НачалоОбработки;
	СпрОбъект.КонецОбработки	=КонецОбработки;
	СпрОбъект.Пользователь		=ПараметрыСеанса.Пользователь;
	
	Если ТипЗнч(ОбработанныеОбъекты)=Тип("Соответствие") Тогда
		Для Каждого Элемент Из ОбработанныеОбъекты Цикл
			СтрокаТЧ=СпрОбъект.ОбработанныеОбъекты.Добавить();		
			СтрокаТЧ.Тип		=Элемент.Ключ;
			СтрокаТЧ.Количество	=Элемент.Значение;
		КонецЦикла; 	
	КонецЕсли;
	
	Для Каждого СтрокаОшибки Из ОшибкиЗагрузки Цикл
		СтрокаТЧ=СпрОбъект.Ошибки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ,СтрокаОшибки);	
	КонецЦикла; 
	
	Если НЕ Результат.Результат Тогда
		СпрОбъект.ОшибкаВыполнения=Результат.Описание;			
	КонецЕсли; 
	
	СпрОбъект.Записать();
	
	//Чирков Глюки системных блокировок - ошибки завершения обмена из-за этого, возможно
	//Объект						=Ссылка.ПолучитьОбъект();
	//Объект.ДатаПоследнейЗагрузки=ТекущаяДата();
	//Объект.РезультатПоследнейЗагрузки="";
	//Если Результат.Результат Тогда
	//	Объект.РезультатПоследнейЗагрузки="ОК. Прочитано сообщение: "+НомерСообщения+".";
	//ИначеЕсли Результат.Описание="Нет сообщений !" Тогда
	//	Объект.РезультатПоследнейЗагрузки="Нет сообщений !";						
	//Иначе
	//	Объект.РезультатПоследнейЗагрузки="Ошибка чтения сообщения: "+НомерСообщения+" ! "+Результат.Описание;
	//КонецЕсли; 
	//
	//Объект.Записать();
	
	ЗаписатьВЛог("ОбменДаннымиОсновной","Конец загрузки из: " + Код,Перечисления.ТипыСообщенийЛога.Информация);	
	
