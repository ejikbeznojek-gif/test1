						КодНастроек=КодНастроек+"__СоСкладаПолучателя";	
						//Феданченков М.С. 04.06.2026 начало
						//наряд 0000000556
						РозничныйСклад = Перечисления.ТипСклада.РозничныйТЦ;
						//Феданченков М.С. 04.06.2026 конец
