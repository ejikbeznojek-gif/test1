Процедура ОчиститьДвижения(Данные) Экспорт
	Если Данные.Ссылка.Пустая() Тогда Возврат КонецЕсли;
	Для Каждого Движение Из Данные.Метаданные().Движения Цикл
		Данные.Движения[Движение.Имя].Очистить();
		Данные.Движения[Движение.Имя].Записать();
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьСсылкуДанных(Данные)
	Тип=ТипОбъекта(Данные);	
	
	УИДСсылки=Неопределено;
	
	Если Тип="Документ" ИЛИ Тип="Справочник" Тогда
		Если Данные.Ссылка.Пустая() Тогда			
			НачатьТранзакцию();
			
			Попытка
				Данные.Записать();
			Исключение
				ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка записи: "+Данные+". Модуль узла обмена: "+Код+". Проц. ПолучитьСсылкуДанных() "+ОписаниеОшибки(),Перечисления.ТипыСообщенийЛога.Ошибка);
			КонецПопытки;
			
			УИДСсылки=Данные.Ссылка.УникальныйИдентификатор();			
			
			ОтменитьТранзакцию();			
		Иначе
			УИДСсылки=Данные.Ссылка.УникальныйИдентификатор();
		КонецЕсли; 		
	КонецЕсли; 
	
	Возврат УИДСсылки;
КонецФункции // ПолучитьСсылкуДанных()

Функция ПолучитьПредставлениеXML(Данные)
	Запись=Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	
	ЗаписатьXML(Запись,Данные);
	
	Возврат Запись.Закрыть();
КонецФункции // ПолучитьПредставлениеXML(Данные) 


Процедура УдалитьИзЖурналаРассогласований(Данные,Отправитель) Экспорт
	Тип=ТипОбъекта(Данные);
	
	Если Тип<>"Документ" И Тип<>"Справочник" Тогда Возврат КонецЕсли;
	
	Вид=Данные.Метаданные().Имя;
	
	Если мЭтотУзел.Код>Отправитель.Код Тогда
		КодУзла1=Отправитель.Код;		
		КодУзла2=мЭтотУзел.Код;	
	Иначе
		КодУзла1=мЭтотУзел.Код;		
		КодУзла2=Отправитель.Код;			
	КонецЕсли;	
	
	СсылкаНаОбъект=Данные.Ссылка;	
	ИДСсылки	=?(СсылкаНаОбъект.Пустая(),ПолучитьСсылкуДанных(Данные),СсылкаНаОбъект.УникальныйИдентификатор());
	
	Если СсылкаНаОбъект.Пустая() Тогда
		Если Тип="Документ" Тогда
			СсылкаНаОбъект=Документы[Вид].ПолучитьСсылку(Новый УникальныйИдентификатор(ИДСсылки));		
		ИначеЕсли Тип="Справочник" Тогда
			СсылкаНаОбъект=Справочники[Вид].ПолучитьСсылку(Новый УникальныйИдентификатор(ИДСсылки));
		КонецЕсли; 		
	КонецЕсли;
	
	Выборка=РегистрыСведений.РассогласованияОбъектов.Выбрать(Новый Структура("СсылкаНаОбъект",СсылкаНаОбъект));
	Пока Выборка.Следующий() Цикл
		Если Выборка.КодУзла1=КодУзла1 И Выборка.КодУзла2=КодУзла2 Тогда			
			Запись=Выборка.ПолучитьМенеджерЗаписи();
			Запись.Удалить();
		КонецЕсли;		
	КонецЦикла;
КонецПроцедуры

Процедура ЗаписатьВЖурналРассогласований(Данные,Отправитель,Ошибка="")
	Если Найти(Ошибка,"Ошибка записи")=0 Тогда
		Возврат; //пишем только ошибки записи
	КонецЕсли;
	
	Тип=ТипОбъекта(Данные);	
	
	Если Тип<>"Документ" И Тип<>"Справочник" Тогда Возврат КонецЕсли; 
	
	МетаОбъект	=Данные.Метаданные();
	
	Вид			=МетаОбъект.Имя;	
	
	Если мЭтотУзел.Код>Отправитель.Код Тогда
		КодУзла1=Отправитель.Код;		
		КодУзла2=мЭтотУзел.Код;	
	Иначе
		КодУзла1=мЭтотУзел.Код;		
		КодУзла2=Отправитель.Код;			
	КонецЕсли; 	
	
	Запись=Неопределено;
	
	СсылкаНаОбъект=Данные.Ссылка;	
	ИДСсылки	=?(СсылкаНаОбъект.Пустая(),ПолучитьСсылкуДанных(Данные),СсылкаНаОбъект.УникальныйИдентификатор());
	
	Если СсылкаНаОбъект.Пустая() Тогда
		Если Тип="Документ" Тогда
			СсылкаНаОбъект=Документы[Вид].ПолучитьСсылку(Новый УникальныйИдентификатор(ИДСсылки));		
		ИначеЕсли Тип="Справочник" Тогда
			СсылкаНаОбъект=Справочники[Вид].ПолучитьСсылку(Новый УникальныйИдентификатор(ИДСсылки));
		КонецЕсли; 		
	КонецЕсли; 
	
	Выборка=РегистрыСведений.РассогласованияОбъектов.Выбрать(Новый Структура("СсылкаНаОбъект",СсылкаНаОбъект));
	Пока Выборка.Следующий() Цикл
		Если Выборка.КодУзла1=КодУзла1 И Выборка.КодУзла2=КодУзла2 Тогда
			Запись=Выборка.ПолучитьМенеджерЗаписи();
			Прервать;
		КонецЕсли;		
	КонецЦикла;	
	
	Если Запись=Неопределено Тогда
		Запись=РегистрыСведений.РассогласованияОбъектов.СоздатьМенеджерЗаписи();	
		
		Запись.СсылкаНаОбъект	=СсылкаНаОбъект;
		
		Запись.КодУзла1    		=КодУзла1;
		Запись.КодУзла2    		=КодУзла2;
		
		Запись.Представление	=Данные;
		
		Запись.Ошибка			=Ошибка;
	КонецЕсли;
	
	Сжатие=Новый СжатиеДанных(9);	
	
	Запись.ДатаЗаписи			=ТекущаяДата();
	
	Если КодУзла1=Отправитель.Код Тогда
		Запись.СостояниеВУзле1	=Новый ХранилищеЗначения(ПолучитьПредставлениеXML(Данные),Сжатие);
	Иначе
		Запись.СостояниеВУзле2	=Новый ХранилищеЗначения(ПолучитьПредставлениеXML(Данные),Сжатие);
	КонецЕсли;
	
	Запись.Тип=Тип;
	Запись.Вид=Вид;
	
	Запись.НомерСообщения=ПараметрыСеанса.НомерСообщения;
	
	Запись.Записать();	
КонецПроцедуры

Процедура ЗаписатьВТаблицуОбмена(ТО,Данные,Результат,Описание="")
	СтрокаТЗ=ТО.Добавить();
	
	МетаОбъект=Данные.Метаданные();
	
	СтрокаТЗ.Вид			=МетаОбъект.Имя;
	ЗаполнитьЗначенияСвойств(СтрокаТЗ,Данные);
	
	СтрокаТЗ.ПредставлениеВида=""+МетаОбъект;
	Если СтрокаТЗ.Вид="РасходнаяНакладная" Тогда
		СтрокаТЗ.ПредставлениеВида=СтрокаТЗ.ПредставлениеВида+" "+СтрокаТЗ.ВидОплаты;		
	ИначеЕсли СтрокаТЗ.Вид="СчетФактура" Тогда
		Для Каждого СтрокаРНК Из Данные.Накладные Цикл
			Если СтрокаРНК.Накладная<>Неопределено И НЕ СтрокаРНК.Накладная.Пустая() Тогда
				СтрокаТЗ.Склад=СтрокаРНК.Накладная.Склад;				
				Прервать;			
			КонецЕсли;			
		КонецЦикла; 		
	КонецЕсли;	
	
	Если ЕстьРеквизитДокумента("Контрагент",МетаОбъект) Тогда
		СтрокаТЗ.Получатель	=Данные.Контрагент;
	ИначеЕсли ЕстьРеквизитДокумента("СкладПолучатель",МетаОбъект) Тогда
		СтрокаТЗ.Получатель	=Данные.СкладПолучатель;		                                                     	
	КонецЕсли;	
	
	СтрокаТЗ.Результат		=Результат;
	СтрокаТЗ.Описание		=Описание;
	СтрокаТЗ.Ссылка			=Данные.Ссылка;
КонецПроцедуры

