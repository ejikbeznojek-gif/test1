Функция СоздатьТаблицуОшибок()
	ОшибкиЗагрузки		=Новый ТаблицаЗначений;
	ОшибкиЗагрузки.Колонки.Добавить("ТипОбъекта");
	ОшибкиЗагрузки.Колонки.Добавить("Описание");
КонецФункции // СоздатьТаблицуОшибок()
