Функция ЗаписатьДанныеВБазу(Данные,ИсходныеДанные=Неопределено,ТипДанных,Отправитель,Описание,НовыйОбъект,ВидЗаписи="Полная")	
	Если ТипДанных="Документ" Тогда
		Данные.ОбменДанными.Отправитель = Отправитель;		
	Иначе		
		Если НЕ ПланыОбмена.ИзменениеЗарегистрировано(Отправитель,Данные) Тогда
			// Устанавливаем отправителя, чтобы для него при записи не было бы зарегистрировано изменение
			Данные.ОбменДанными.Отправитель = Отправитель;
		КонецЕсли;	
	КонецЕсли;
	
	// Включает режим Загрузка, так как данные могут загружаться в произвольном порядке и 
	// нужно отключить такой контроль данных, как проверка уникальности номеров		
	Данные.ОбменДанными.Загрузка = Истина;
	
	Если ИсходныеДанные=Неопределено Тогда
		ИсходныеДанные=Данные;	
	КонецЕсли; 
	
	НовыйОбъект=Ложь;
	Попытка		
		Если ТипДанных="Документ" ИЛИ  ТипДанных="Справочник" Тогда
			НовыйОбъект=Данные.Ссылка.Пустая();
		ИначеЕсли ТипДанных="РегистрНакопления" Тогда
			//Мессерле
			Если ТипЗнч(данные)=Тип("РегистрНакопленияНаборЗаписей.Партии") и  ТипЗнч(Данные.Отбор.Регистратор.Значение)=Тип("Документссылка.КоррекцияРегистраПартии") тогда
				данные.записать(ИСТИНА);
				возврат(Истина);
			Конецесли;
			//Мессерле
			
			Возврат Ложь;
			
			Документ=Данные.Отбор.Регистратор.Значение;
			Если НеЗагружатьДвижения.Получить(Документ)<>Неопределено Тогда Возврат Ложь КонецЕсли;			
		КонецЕсли;		
		
		Если ТипДанных="Документ" Тогда	 
			//Ратманов
			Если ТипЗнч(Данные)=Тип("ДокументСсылка.ХранилищеКодовМаркировки") Тогда       
				Данные.Записать();			
			Иначе	
				ОчиститьДвижения(Данные);			
				Если Данные.Проведен Тогда
					Данные.Записать();				
					Отказ=Ложь;
					Данные.ОбработкаПроведения(Отказ,РежимПроведенияДокумента.Неоперативный);
				Иначе
					Данные.Записать();			
				КонецЕсли;		
			КонецЕсли;		
		Иначе
			Данные.Записать();		
		КонецЕсли; 
		
		УдалитьИзЖурналаРассогласований(ИсходныеДанные,Отправитель);
		Возврат Истина;
	Исключение
		ТекстОшибки=ОписаниеОшибки();
		
		ЗаписатьВЖурналРассогласований(ИсходныеДанные,Отправитель,"Ошибка записи ! "+ТекстОшибки);
		
		Описание="Ошибка записи объекта: "+Данные+". Причина: "+ТекстОшибки;
		ЗаписатьВЛог("Ошибки записи при обмене",Описание,"Ошибка");
		
		//Чирков 11.06.13+++
		Если ТипЗнч(ОшибкиЗагрузки)<>Тип("ТаблицаЗначений") Тогда
			СоздатьТаблицуОшибок();				
		КонецЕсли;
		//Чирков 11.06.13---
		
		СтрокаОшибки=ОшибкиЗагрузки.Добавить();
		СтрокаОшибки.ТипОбъекта		=ТипЗнч(Данные);
		СтрокаОшибки.Описание		=Описание;
		
		Возврат Ложь;
	КонецПопытки;
КонецФункции // ЗаписатьОбъектвБазу() 

Функция ЗаписатьПолныеДанныеВБазу(Данные,ТипДанных,Отправитель,Описание,НовыйОбъект) Экспорт
	Возврат ЗаписатьДанныеВБазу(Данные,,ТипДанных,Отправитель,Описание,НовыйОбъект);
