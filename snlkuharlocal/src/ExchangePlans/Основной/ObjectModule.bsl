				Если КодНастроек="ЭмиссияПодарочныхСертификатов" Тогда
					ОтправитьОбратно=Истина;				
				КонецЕсли; 
			КонецЕсли;
		КонецЕсли;	
	ИначеЕсли ТипДанных="Справочник" И НЕ НовыйОбъект И НовыеДанные.Метаданные().Имя="Подразделения" Тогда
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ТекущиеДанные=НовыеДанные.Ссылка.ПолучитьОбъект();								
			ТекущиеДанные.НомерВерсииКонфигурации	=НовыеДанные.НомерВерсииКонфигурации;
			//крохин начало 19.04.2019
			//дата запрета редактирования грузится только из ЦО в ТЦ
			//ТекущиеДанные.ДатаЗапретаРедактирования =НовыеДанные.ДатаЗапретаРедактирования;
			//крохин конец 19.04.2019
			
			
			
			ЗаписатьДанныеВБазу(ТекущиеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);
		Иначе
			ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);
		КонецЕсли; 
		//крохин начало 29.01.2013
		
	ИначеЕсли ТипДанных="Справочник" И НЕ НовыйОбъект И НовыеДанные.Метаданные().Имя="Контрагенты" И НЕ НовыеДанные.Ссылка.ЭтоГруппа Тогда
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ТекущиеДанные=НовыеДанные.Ссылка.ПолучитьОбъект();
			НовыеДанные.Ведущий = ТекущиеДанные.Ведущий;
			НовыеДанные.КодЦБ = ТекущиеДанные.КодЦБ;
		КонецЕсли;
		ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);	 	
		//крохин конец 29.01.2013
		//крохин начало 23.05.2013
		//суммы накоплений ДК можно менять только в ЦО
	ИначеЕсли ТипДанных="Справочник" И НЕ НовыйОбъект И НовыеДанные.Метаданные().Имя="ДисконтныеКарты" Тогда
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ТекущиеДанные=НовыеДанные.Ссылка.ПолучитьОбъект();
			НовыеДанные.ОбщаяСумма = ТекущиеДанные.ОбщаяСумма;
			НовыеДанные.ОбщаяСуммаДо2013 = ТекущиеДанные.ОбщаяСуммаДо2013;
		КонецЕсли;
		ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);
		//крохин конец 23.05.2013
		
		//Катаев+ 01/12/14 Для Договоров в ЦО КодЦБ не меняем при повторной загрузке справочника
	ИначеЕсли ТипДанных="Справочник" И НЕ НовыйОбъект И НовыеДанные.Метаданные().Имя="Договоры" Тогда
		Если ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			ТекущиеДанные=НовыеДанные.Ссылка.ПолучитьОбъект();
			НовыеДанные.КодЦБ = ТекущиеДанные.КодЦБ;
			// не записывались нечаева 26,05,15+++
			ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);								
			// не записывались нечаева 26,05,15---
		КонецЕсли;
		//Катаев- 01/12/14
		// Кухарь А.Ю.  15.09.2022 начало
		// В номенклатуру в ЦО пишем не все реквизиты
	ИначеЕсли ТипДанных="Справочник" И НЕ НовыйОбъект И НовыеДанные.Метаданные().Имя="Номенклатура" и ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда		
		ТекущиеДанные=НовыеДанные.Ссылка.ПолучитьОбъект();
		СписокНеизменяемыхРеквизитовСтрокойДляЭлемента="ЖизненныйЦиклНоменклатуры,ВыгружатьВИнтернетМагазин";
		// Кухарь А.Ю.  31.10.2022 начало
		// СписокНеизменяемыхРеквизитовСтрокойДляГруппы="ВыгружатьВИнтернетМагазин";
		 СписокНеизменяемыхРеквизитовСтрокойДляГруппы="ВыгружатьВИнтернетМагазин,ВыгружатьНаСайтСтильПарк,ФР_Коллекция,ФР_ГруппаТоваров,ФР_ВидНоменклатуры,ФР_Бренд";	
		// Кухарь А.Ю.  31.10.2022 конец

		
		если не ТекущиеДанные.ЭтоГруппа тогда
			ЗаполнитьЗначенияСвойств(НовыеДанные,ТекущиеДанные,СписокНеизменяемыхРеквизитовСтрокойДляЭлемента);
		иначе
			ЗаполнитьЗначенияСвойств(НовыеДанные,ТекущиеДанные,СписокНеизменяемыхРеквизитовСтрокойДляГруппы);
		КонецЕсли;
		
		Возврат ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);	
		// Кухарь А.Ю.  15.09.2022 конец
		
	Иначе	
		Возврат ЗаписатьДанныеВБазу(НовыеДанные,,ТипДанных,Отправитель,Описание,НовыйОбъект);								
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции


//Получить вариант загрузки
Функция ПолучитьВариантЗагрузки(Данные,ТипДанных,Отправитель,Описание) Экспорт
	Вариант="Полная";
	
	Если ТипДанных="Документ" Тогда		
		Отказ=Ложь;
		Если НЕ КонтрольДатыЗапрета(Данные,Отказ,Ложь) Тогда		
			Вариант="Отказ";
			Описание="Документ за границей редактирования !!!";
			
			//ЗаписатьВЛог(ИмяЛога,Сообщение,ТипСообщения,ВыводитьСообщения=Ложь) Экспорт
			
			ЗаписатьВЛог("ОбменДанными","Ошибка записи документа ! "+Данные+", дата запрета: "+Константы.ДатаЗапретаРедактирования.Получить(),"Ошибка");
		Иначе
			Если НЕ Данные.Ссылка.Пустая() Тогда
				ВидДокумента=Данные.Метаданные().Имя;
				
				Если Данные.Метаданные().ТабличныеЧасти.Найти("Товары")<>Неопределено Тогда
					Если Данные.Метаданные().Имя="Матрица" Тогда
						//Вариант="Отказ";
						Вариант="Полная";
						//крохин начало 30.01.2013
						//ОКС тоже грузим полностью
					ИначеЕсли Данные.Метаданные().Имя="ОтчетКассовойСмены" Тогда
						Вариант="Полная";
						//крохин конец 30.01.2013
						//нечаева 07,10,16++
					ИначеЕсли Данные.Метаданные().Имя="ЛистНабора" Тогда
						Вариант="Полная";
						//нечаева 07,10,16--
						
					Иначе
						
						Вариант="Частичная";
						
						//Мессерле 25,07,12
						Если Данные.Метаданные().Имя="ЗаказПоставщику" и Данные.склад.Код="SSP-04" тогда //(9999) Китайские ЗПС для Риги
							Вариант="Полная";									
						КонецЕсли;
						//Мессерле 25,07,12
						
						Если Отправитель.ТипУзла=Перечисления.ТипУзлаИБ.ТорговоеПодразделение И Данные.Метаданные().Имя="ОтчетКассовойСмены" Тогда
							Вариант="Полная";									
						КонецЕсли;
					КонецЕсли;
				ИначеЕсли ВидДокумента="ЗаявкаНаОтгрузку" Тогда
					Вариант="Частичная";
				ИначеЕсли ВидДокумента="ЭмиссияПодарочныхСертификатов"  Тогда					
					Вариант="Частичная";					
					//Катаев+ 28/11/13
				ИначеЕсли ВидДокумента = "ЗаявкаНаТСД" Тогда
					Вариант="Частичная";					
					//Катаев- 28/11/13
				КонецЕсли;			
			КонецЕсли; 
		КонецЕсли;	
	КонецЕсли; 
	
	//крохин начало 29.01.2013
	//не грузим ведущих из филиалов
	Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение И ТипДанных="Справочник" И Данные.Метаданные().Имя = "Контрагенты" Тогда
		Вариант="Частичная";	
	КонецЕсли;
	//крохин конец 29.01.2013
	
	//Катаев+ 01/12/14 для договоров в ЦО тоже частичная загрузка
	Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение И ТипДанных="Справочник" И Данные.Метаданные().Имя = "Договоры" Тогда
		Вариант="Частичная";
	КонецЕсли;
	//Катаев- 01/12/14
	
	// Кухарь А.Ю.  15.09.2022 начало
	// Номенклатура в ЦО
	Если ПараметрыСеанса.ЭтотУзел.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение И ТипДанных="Справочник" И Данные.Метаданные().Имя = "Номенклатура" Тогда
		Вариант="Частичная";
	КонецЕсли;	 
	// Кухарь А.Ю.  15.09.2022 конец
	
	
	Возврат Вариант;
КонецФункции // ПолучитьВариантЗагрузки(Данные,ТипДанных,Отправитель,Описание)


// Функция чтения нового сообщения обмена из файла
//
// Параметры:
//  ИмяФайла - имя файла с сообщением обмена
// 
// Возвращаемое значение:
//  НомерСообщения - номер принятого сообщения
//
Функция ПрочитатьНовоеСообщение(ИмяФайла,Контроль=Истина)
	//ЗаписатьВПротоколОбмена(ВидЗаписи,Источник,НомерСообщения,Данные=Неопределено,Ошибка=Неопределено) Экспорт
	
	СбойЗагрузки=Ложь;
	
	// Создаем объект чтения XML
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ИмяФайла);
	
	// Загрузка из найденного файла
	ЧтениеСообщения = ПланыОбмена.СоздатьЧтениеСообщения();
	ЧтениеСообщения.НачатьЧтение(ЧтениеXML);
	
	НомерСообщения	 				= ЧтениеСообщения.НомерСообщения;
	ПараметрыСеанса.НомерСообщения	= НомерСообщения;
	
	Если ЧтениеСообщения.Отправитель <> Ссылка Тогда		
		// Сообщение предназначено не для этого узла
		ВызватьИсключение "Неверный узел";		
	КонецЕсли;
	
	ПараметрыСеанса.Отправитель		= ЧтениеСообщения.Отправитель;
	
	ТипПолучателя	=мЭтотУзел.ТипУзла;
	ТипОтправителя	=ТипУзла;
	Отправитель		=ЧтениеСообщения.Отправитель;
	
	// Удаляем регистрацию изменений для узла отправителя сообщения
	// по номеру принятого сообщения, полученного из сообщения
	ПланыОбмена.УдалитьРегистрациюИзменений(Отправитель, ЧтениеСообщения.НомерПринятого);
	
	// Читаем данные из сообщения пока это возможно
	Счетчик = 0;
	Пока ВозможностьЧтенияДанных(ЧтениеXML) Цикл
		
		// Читаем очередное значение
		Данные = ПрочитатьДанные(ЧтениеXML);
		
		#Если Клиент Тогда
			Счетчик = Счетчик + 1;
			Состояние("Загрузка данных: " + Строка(Счетчик));
			
			// Вывод диагностического сообщения о загружаемых данных
			ВывестиДанные(Данные);
		#КонецЕсли	
		
		Описание		="";
		ОбъектЗагружен			= Ложь;
		ОбъектЗагруженЧастично	= Ложь;
		НовыйОбъект				= Ложь;
		ЕстьРассогласования		= Ложь;
		ОтправитьОбратно		= Ложь;
		
		ТипДанных				= ТипОбъекта(Данные);
		//крохин начало 27.01.2012
		//запретим удаление
		Если ТипДанных  = "Удаление" Тогда
			Если ТипЗнч(Данные) = Тип("УдалениеОбъекта") Тогда		
				Представление = "Удаление объекта: "+Строка(Данные.Ссылка.Метаданные())+": "+Строка(Данные.Ссылка);
			Иначе
				Представление = Строка(Данные.Метаданные()) + ": " + Строка(Данные);				
			КонецЕсли;
			//логизируем удаление
			ЗаписатьВЛог("Попытка Удаления Объектка","Файл: "+ИмяФайла+". Объект: "+Представление ,"Информация");	
			
			Продолжить;
		КонецЕсли;
		//крохин конец 27.01.2012
		
		//+++Чирков 29.04.13 - забыли снять регистрацию с регистра - не нужно это загружать
		Если ТипДанных="РегистрСведений" И ТипЗнч(Данные)=Тип("РегистрСведенийНаборЗаписей.РассогласованияОбъектов") Тогда
			Продолжить;								
		КонецЕсли;
		//---Чирков 29.04.13
		
		Если ТипДанных="Справочник" И ОтключитьЗагрузкуСправочников И ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			СообщениеОтладки("Пропускаем загрузку: "+Данные);			
			Продолжить;
			
			
			
		ИначеЕсли ТипДанных="Документ" И ОтключитьОбменДокументами И ПараметрыСеанса.ТипУзла=Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
			СообщениеОтладки("Пропускаем загрузку: "+Данные);
			Продолжить;
			
		//Кухарь 14.02.19 начало
		//Номенклатуру в ЦО грузим только со складов
		ИначеЕсли  ТипДанных="Справочник" и ТипПолучателя=Перечисления.ТипУзлаИБ.УправляющееПодразделение тогда
			если Данные.Метаданные().имя="Номенклатура" тогда
				если ТипОтправителя<>Перечисления.ТипУзлаИБ.Склад тогда
					СообщениеОтладки("Пропускаем загрузку: "+Данные);
					Продолжить;
				КонецЕсли;
			КонецЕсли;

		//Кухарь 14.02.19 конец		
			
		КонецЕсли; 
		
		
		
		Если Контроль Тогда			
			ВариантЗагрузки=ПолучитьВариантЗагрузки(Данные,ТипДанных,Отправитель,Описание);
		Иначе
			ВариантЗагрузки="Полная";			
		КонецЕсли;
		
		Если ВариантЗагрузки="Полная" Тогда
			ОбъектЗагружен			=ЗаписатьПолныеДанныеВБазу(Данные,ТипДанных,Отправитель,Описание,НовыйОбъект);						
		ИначеЕсли ВариантЗагрузки="Частичная" Тогда
			ОбъектЗагруженЧастично	=ЗаписатьВозможныеДанныеВБазу(Данные,ТипДанных,Отправитель,Описание,НовыйОбъект,ЕстьРассогласования,ОтправитьОбратно);			
		Иначе
			ЕстьРассогласования=Истина;				
		КонецЕсли;
		
		Если ТипДанных="Документ" Тогда
			Если НЕ НовыйОбъект И ТипТекущегоУзла<>Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
				НеЗагружатьДвижения.Вставить(Данные.Ссылка,Истина);							
			КонецЕсли;
			
			Если ОбъектЗагружен ИЛИ ОбъектЗагруженЧастично Тогда
				Если ЕстьРассогласования Тогда
					ЗаписатьВТаблицуОбмена(ЗагруженныеДокументы,Данные,?(НовыйОбъект,"Загружен новый (ЧАСТИЧНО)","Частично изменен существующий"));
				Иначе
					ЗаписатьВТаблицуОбмена(ЗагруженныеДокументы,Данные,?(НовыйОбъект,"Загружен новый","Изменен существующий"));
				КонецЕсли;
				Если ОтправитьОбратно Тогда
					ПланыОбмена.ЗарегистрироватьИзменения(ЧтениеСообщения.Отправитель,Данные);
				КонецЕсли; 
			Иначе
				Если ОтправитьОбратно И Данные.Метаданные().Имя="ЭмиссияПодарочныхСертификатов" Тогда					
					ПланыОбмена.ЗарегистрироватьИзменения(ЧтениеСообщения.Отправитель,Данные);
				КонецЕсли;
				НеЗагружатьДвижения.Вставить(Данные.Ссылка,Истина);
				ЗаписатьВТаблицуОбмена(ЗагруженныеДокументы,Данные,"Не загружен",Описание);
			КонецЕсли;						
		КонецЕсли;		
		
		ТипДанных=ТипЗнч(Данные);
		КоличествоОбъектов=ОбработанныеОбъекты.Получить(ТипДанных);		
		Если КоличествоОбъектов=Неопределено Тогда
			КоличествоОбъектов=0;
		КонецЕсли; 
		КоличествоОбъектов=КоличествоОбъектов+1;
		ОбработанныеОбъекты.Вставить(ТипДанных,КоличествоОбъектов);
	КонецЦикла;
	
	Если СбойЗагрузки Тогда
		ЧтениеСообщения.ПрерватьЧтение();
	Иначе
		ЧтениеСообщения.ЗакончитьЧтение();
	КонецЕсли; 	
	
	ЧтениеXML.Закрыть();
	
	Возврат НомерСообщения;	
КонецФункции // ПрочитатьНовоеСообщение(ИмяФайла)

// Процедура записывает данных в формат XML
// Процедура анализирует переданный объект данных и на основе этого анализа
// записывает его определенным образом в формат XML
//
// Параметры:
//  ЗаписьXML	- объект, записывающий XML данные
//  Данные 		- данные, подлежащие записи в формат XML
//
Процедура ЗаписатьДанные(ЗаписьXML, Данные)
	
	ТипДанных	=ТипЗнч(Данные);
	ТипОбъекта	=ТипОбъекта(Данные);
	
	Если ОтключитьВыгрузкуСправочников Тогда
		Если ТипОбъекта="Справочник" И НеВыгружаемыеСправочники.СодержитТип(ТипДанных) Тогда	
			СообщениеОтладки("Пропускаем выгрузку: "+Данные);		
			Возврат;			
		ИначеЕсли ТипДанных=Тип("РегистрСведенийНаборЗаписей.ЗначенияСвойствОбъектов") Тогда
			Если НеВыгружаемыеСправочники.СодержитТип(ТипЗнч(Данные.Отбор.Объект.Значение)) Тогда			
				СообщениеОтладки("Пропускаем выгрузку: "+Данные);			
				Возврат;
			КонецЕсли; 		
		КонецЕсли;	
	КонецЕсли;	
	
	Если ОтключитьОбменДокументами И ТипОбъекта="Документ" Тогда
		СообщениеОтладки("Пропускаем выгрузку: "+Данные);		
		Возврат;
	КонецЕсли;
	
	Попытка
		ЗаписатьXML(ЗаписьXML, Данные, НазначениеТипаXML.Явное);	
	Исключение
		ЗаписатьВЛог("ОбменДаннымиОсновной","Ошибка выгрузки объекта: "+Данные,"Ошибка",Истина);
	КонецПопытки;	
	
	Если ТипОбъекта="Документ" Тогда
		ЗаписатьВТаблицуОбмена(ВыгруженныеДокументы,Данные,"Выгружен");	
	КонецЕсли;
	
КонецПроцедуры // ЗаписатьДанные(ЗаписьXML, Данные)

// Функция определяет возвможность чтения очередных данных из объекта ЧтениеXML
//
// Параметры:
//  ЧтениеXML - объект чтения XML
//
// Вовзращаемое значение:
//  Булево - Истина, если возможно чтение очередных данных или Ложь - в противном случае
//
Функция ВозможностьЧтенияДанных(ЧтениеXML)
	
	// Получаем тип данных XML, который может быть считан в данный момент
	ТипXML = ПолучитьXMLТип(ЧтениеXML);
	Если ТипXML = Неопределено Тогда Возврат Ложь КонецЕсли;
	
	Возврат ВозможностьЧтенияXML(ЧтениеXML);
	
КонецФункции // ВозможностьЧтенияДанных(ЧтениеXML)

// Функция читает данные из формат XML
// Процедура анализирует переданный объект ЧтениеXML и на основе этого анализа
// читает из него данные определенным образом
//
// Параметры:
//  ЧтениеXML	- объект, читающий XML данные
//
// Возвращаемое значение:
//  Данные - значение, прочитанное из объекта ЧтениеXML
//
Функция ПрочитатьДанные(ЧтениеXML)
	
	ТипXML = ПолучитьXMLТип(ЧтениеXML);
	
	Если ТипXML = Неопределено Тогда Возврат Неопределено КонецЕсли;
	
	Попытка
		ОбъектXML = ПрочитатьXML(ЧтениеXML);
	Исключение
		ОбъектXML = Неопределено;
		Сообщить(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат ОбъектXML;
	
КонецФункции // ПрочитатьДанные(ЧтениеXML)

