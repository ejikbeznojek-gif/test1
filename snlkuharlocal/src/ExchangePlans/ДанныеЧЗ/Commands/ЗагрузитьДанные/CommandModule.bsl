
&НаКлиенте
Процедура ОбработкаКоманды(УзелКорреспондент, ПараметрыВыполненияКоманды)	
	рПроверки = ПроверитьУзелКорреспондент(УзелКорреспондент);
	Если рПроверки.Успешно Тогда
		рЗагрузки = ЗагрузитьДанные(УзелКорреспондент);
	
		Если рЗагрузки.Успешно Тогда
			Сообщить("Успешно выполнен обмен данными с узлом: " + УзелКорреспондент);
		Иначе		
			МаркировкаК.ВывестиОшибки(рЗагрузки);
		КонецЕсли; 
	Иначе	
		МаркировкаК.ВывестиОшибки(рПроверки);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Функция ПроверитьУзелКорреспондент(УзелКорр)
	Результат = МаркировкаКС.СтруктураРезультата(Ложь);
	
	Если ЗначениеЗаполнено(УзелКорр) Тогда
		Если УзелКорр = Маркировка_ПИ.ЭтотУзел("ДанныеЧЗ") Тогда
			Результат.Ошибки.Добавить("Невозможен обмен с текущим узлом ! ("+УзелКорр+")");			
		Иначе
			Результат.Успешно = Истина;			
		КонецЕсли;	
	Иначе
		Результат.Ошибки.Добавить("Не указан узел корреспондент !");	
	КонецЕсли; 
	
	Возврат Результат;
КонецФункции //ПроверитьУзелКорреспондент(УзелКорр)

&НаСервере
Функция ЗагрузитьДанные(УзелСсылка)
	Возврат УзелСсылка.ПолучитьОбъект().ПрочитатьСообщениеСИзменениями();
КонецФункции // ()
 
