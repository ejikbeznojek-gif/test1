Функция КлассОбъекта(Данные)
	МетаОбъект = Метаданные.НайтиПоТипу(Данные);
	
	Если МетаОбъект = Неопределено Тогда Возврат "" КонецЕсли;
	
	Если Метаданные.Документы.Содержит(МетаОбъект) Тогда
		Возврат "Документ";	
	ИначеЕсли Метаданные.Справочники.Содержит(МетаОбъект) Тогда
		Возврат "Справочник";	
	ИначеЕсли Метаданные.РегистрыНакопления.Содержит(МетаОбъект) Тогда
		Возврат "РегистрНакопления";
	ИначеЕсли Метаданные.РегистрыСведений.Содержит(МетаОбъект) Тогда
		Возврат "РегистрСведений";
	Иначе
		Возврат "";			
	КонецЕсли; 

