//некрасиво смотрится пустое наименование + контроль за заведением дублей
Процедура ПередЗаписью(Отказ)
	Если ПустаяСтрока(Наименование) Тогда
		Наименование = "упаковка: "+Владелец;
	КонецЕсли;
	Выборка = Справочники.Упаковка.Выбрать(,Владелец,,);
	Пока Выборка.Следующий() Цикл
		Если Выборка.Ссылка <> Ссылка Тогда
			#Если Клиент Тогда
				Сообщить("у номенклатуры "+Владелец + " уже заведена упаковка. Отредактируйте существующую");
			#КонецЕсли
		Отказ = Истина;	
		КонецЕсли;
	КонецЦикла;
	
	//Кухарь 30.08.16 начало
	НадоВыгружать = Ложь;
	Если ОбменДанными.Загрузка Тогда
		НадоВыгружать = Ложь;
	Иначе 
		НадоВыгружать = Истина;
	КонецЕсли;
	Если НадоВыгружать Тогда
		УстановитьПолучателейИзмененийОбъекта(ЭтотОбъект);
	КонецЕсли;	
	//Кухарь 30.08.16 конец	
	
КонецПроцедуры
