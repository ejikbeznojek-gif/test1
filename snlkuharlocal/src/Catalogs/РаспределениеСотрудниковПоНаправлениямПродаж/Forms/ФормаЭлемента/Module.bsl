	ПараметрОткрытияФормы.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.Элементы);

	ОткрытьФорму("Справочник.ФизическиеЛица.Форма.ФормаВыбораУпр", ПараметрОткрытияФормы, ЭтотОбъект, , , ,
		ОписаниеОповещенияВыбор); 
		
КонецПроцедуры

