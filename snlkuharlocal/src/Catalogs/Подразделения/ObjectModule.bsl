	НомерВерсииКонфигурации="";
	//крохин начало 24.05.2012
	Ведущее = Неопределено;
	//крохин конец 24.05.2012
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ПараметрыСеанса.ЭтотУзел.Подразделение=Ссылка И ДатаЗапретаРедактирования<>Константы.ДатаЗапретаРедактирования.Получить() Тогда
		Константы.ДатаЗапретаРедактирования.Установить(ДатаЗапретаРедактирования);			
	КонецЕсли; 
	
	Если НЕ ЭтоГруппа И Ведущее.Пустая() Тогда
		Ведущее=Ссылка;	
		Записать();
	КонецЕсли;
КонецПроцедуры

