
#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)      
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипНастройки = 0 Тогда
		ЗначениеСтрокаНеограниченная = "";
		СтрокиСоответствия.Очистить();
	ИначеЕсли ТипНастройки = 1 Тогда
		ЗначениеНастройки = Неопределено;          
		ЗначениеСтрокаНеограниченная = "";
	ИначеЕсли ТипНастройки = 2 Тогда
		ЗначениеНастройки = Неопределено;	
		СтрокиСоответствия.Очистить();
	КонецЕсли; 
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	ОбновитьПовторноИспользуемыеЗначения();
КонецПроцедуры

