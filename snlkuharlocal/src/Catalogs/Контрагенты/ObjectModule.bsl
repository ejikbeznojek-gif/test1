Функция ЗаписатьПроИзмененияСкидок(ТаблицаИзмененныхСтрок) Экспорт
	
	Если ТипЗнч(ТаблицаИзмененныхСтрок) = Тип("ТаблицаЗначений") Тогда
		
		Для Каждого СтрокаСкидок Из ТаблицаИзмененныхСтрок Цикл
			
			Если ЗначениеЗаполнено(СтрокаСкидок.Номенклатура) Тогда
				
				Запись = РегистрыСведений.ЖурналИзмененийСкидок.СоздатьМенеджерЗаписи();
				
				Запись.Дата			= ТекущаяДатаСеанса();
				Запись.Номенклатура		= СтрокаСкидок.Номенклатура;			
				Запись.Контрагент		= Ссылка;
				
				Запись.СтараяСкидка		= СтрокаСкидок.ИсхСкидка;
				Запись.НоваяСкидка		= СтрокаСкидок.Скидка;
				
				Запись.СтараяНаценка		= СтрокаСкидок.ИсхНаценка;
				Запись.НоваяНаценка		= СтрокаСкидок.Наценка;
				
				Запись.ТипЦен			= СтрокаСкидок.ТипЦен;
				
				Запись.НомерСообщения	= ПараметрыСеанса.НомерСообщения;
				Запись.Отправитель		= ОбменДанными.Отправитель;			
				Запись.Пользователь		= ПараметрыСеанса.Пользователь;
				
				Запись.Записать();
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат Истина;
		
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции
