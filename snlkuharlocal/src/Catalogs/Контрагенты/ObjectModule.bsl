Процедура ВыгрузитьВТЦ()
	
	//крохин начало 19.04.2019
	//запретим выгружать Мегамарт АО Дикси ЮГ, по этому контрагенту в ЦО и филиале должны быть разные реквизиты
	Если Код = "SSP-3687" Тогда
Возврат;
    КонецЕсли;
	//крохин конец 19.04.2019

	
	//крохин начало
	//выгрузим контрагента в филиалы, если необходимо
	ТЗ=Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("КодУзла");
	//крохин начало 14.11.2012
	//по контрагенту тоже можно ставить отдельные узлы
	//ВерхнийУровень = ЭтотОбъект.Родитель;
	ВерхнийУровень = ЭтотОбъект.Ссылка;
	//крохин конец 14.11.2012
	Пока ВерхнийУровень <> Справочники.Контрагенты.ПустаяСсылка() Цикл
		Для Каждого КодУзла Из ВерхнийУровень.РегиональныеУзлы Цикл
			//Катаев+ 25/07/13
			//СтрокаТЗ = ТЗ.Добавить();
			//СтрокаТЗ.КодУзла = КодУзла.КодУзла;
			Если Не ПустаяСтрока(КодУзла.КодУзла) Тогда
				СтрокаТЗ = ТЗ.Добавить();
				СтрокаТЗ.КодУзла = КодУзла.КодУзла;
			КонецЕсли;
			//Катаев- 25/07/13
		КонецЦикла;
		ВерхнийУровень = ВерхнийУровень.Родитель;
	КонецЦикла;
	ТЗ.Свернуть("КодУзла");
	//крохин начало
	//из складских баз выгружаем только в ЦО
	Если ПараметрыСеанса.ТипУзла <> Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		ТЗ.Очистить();
		СтрокаТЗ = ТЗ.Добавить();
		СтрокаТЗ.КодУзла = "SNL";
	КонецЕсли;
	//крохин конец
	Если Тз.Количество() <> 0 Тогда
		СписокУзловПолучателей=Новый Массив;	
		Для Каждого строкаТЗ Из ТЗ Цикл
			//+HELP-5068 20250515 Михайловский
			//вместо
			//СписокУзловПолучателей.Добавить(ПланыОбмена.Основной.НайтиПоКоду(СтрокаТЗ.КодУзла));
			СсылУз = ПланыОбмена.Основной.НайтиПоКоду(СтрокаТЗ.КодУзла);
			Если НЕ СсылУз.Пустая() Тогда
