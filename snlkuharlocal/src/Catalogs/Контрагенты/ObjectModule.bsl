Процедура ПриЗаписи(Отказ)
	// +++ {Кузнецов Сергей Владимирович [07.11.2023]
	Если ПараметрыСеанса.ТипУзла = Перечисления.ТипУзлаИБ.УправляющееПодразделение Тогда
		Если НЕ ПроверяемыеРеквизиты.Количество()=0 Тогда
			Если  ПроверяемыеРеквизиты.Свойство("ЭтоНовый") И ПроверяемыеРеквизиты.ЭтоНовый Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(ПланыОбмена.ОбменМерч.НайтиПоНаименованию("Мерч",Истина), Ссылка);
			Иначе
				Если Владелец = Справочники.ИБ.НайтиПоНаименованию("Колготки Москва",Истина) И НЕ ЭтоГруппа И ((НЕ ПроверяемыеРеквизиты.Свойство("Наименование") И НЕ Наименование = ПроверяемыеРеквизиты["Наименование"]) ИЛИ (ПроверяемыеРеквизиты.Свойство("КодВторичногоКонтрагентаДляB2B") И НЕ КодВторичногоКонтрагентаДляB2B = ПроверяемыеРеквизиты["КодВторичногоКонтрагентаДляB2B"] И НЕ КодВторичногоКонтрагентаДляB2B = "")) ИЛИ (ПроверяемыеРеквизиты.Свойство("ЕМэйл1") И  НЕ ЕМэйл1 = ПроверяемыеРеквизиты["ЕМэйл1"]) ИЛИ (ПроверяемыеРеквизиты.Свойство("КаналСбыта1") И  НЕ КаналСбыта1 = ПроверяемыеРеквизиты["КаналСбыта1"]) ИЛИ  (ПроверяемыеРеквизиты.Свойство("Скидки") И ( НЕ ДанныеСовпадают(Скидки.Выгрузить(), ПроверяемыеРеквизиты["Скидки"])))  Тогда
					ПланыОбмена.ЗарегистрироватьИзменения(ПланыОбмена.ОбменМерч.НайтиПоНаименованию("Мерч",Истина), Ссылка);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	// }Кузнецов Сергей Владимирович +++ [07.11.2023]
