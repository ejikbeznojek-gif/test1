		//крохин начало
		//Префикс=Владелец.Код+"-";
		Если Владелец.Код = "SSP" Тогда
			// Кухарь А.Ю.  07.09.2022 начало
			//Кончились номера
			// Префикс="SSR-";
			Префикс="SST-";		
			// Кухарь А.Ю.  07.09.2022 конец

			//крохин начало 15.06.2012
			//в SMN тоже закончились коды
		ИначеЕсли Владелец.Код = "SMN" Тогда
			// Кухарь А.Ю.  21.06.2023 начало
			//SMR закончились
			//Префикс="SMR-";
			Префикс="SMS-";			
			// Кухарь А.Ю.  21.06.2023 конец
			//крохин конец 15.06.2012
		Иначе
			Префикс=Владелец.Код+"-"
		КонецЕсли;
		//крохин конец
		
	Иначе
		Префикс=ПолучитьПрефиксНомеров(ЭтотОбъект);	
	КонецЕсли;	
КонецПроцедуры

