Процедура ПриУстановкеНовогоКода(СтандартнаяОбработка, Префикс)
	Префикс=ПараметрыСеанса.ЭтотУзел.Код+"-";
КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	Если Владелец.ДлиннаКода<>0 И ПустаяСтрока(Идентификатор) Тогда
		Если Владелец.ТипКода="Строка" Тогда
			Идентификатор=Лев(Код,4)+Прав(Код,Владелец.ДлиннаКода-4);
		Иначе
			Идентификатор=Формат(Число(Сред(Код,5)),"ЧГ=0");		
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры
