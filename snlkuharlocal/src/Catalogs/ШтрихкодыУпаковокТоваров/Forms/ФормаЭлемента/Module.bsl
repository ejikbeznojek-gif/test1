
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	//Валетов + 28,01,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#HELP-8673 Перенес запрет на форму списка 
	//Отказ = Истина;  
	//Сообщить("Открытие данной формы запрещено");  
	//Валетов -
	
	МаркировкаС.УстановитьОтборДинСписка(СтатусыКМ_ЧЗ, 		Новый Структура("ШтрихКодУпаковки", Объект.Ссылка));
	МаркировкаС.УстановитьОтборДинСписка(СтатусыКМ_Факт, 	Новый Структура("ШтрихКодУпаковки", Объект.Ссылка));	
	
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(Короба, "ШтрихКодУпаковки", Объект.Ссылка, Истина);
	МаркировкаКС.УстановитьПараметрДинамическогоСписка(Наборы, "ШтрихКодУпаковки", Объект.Ссылка, Истина);
	
	Если Объект.ТипКода = Перечисления.ТипыКодовМаркировки.АТК Тогда
			
		МаркировкаКС.УстановитьПараметрДинамическогоСписка(СоставАТК, "КодАТК", Объект.Наименование, Истина);	
		
		Элементы.сКодыАТК.Видимость = Истина;
		
	ИначеЕсли Объект.ТипКода = Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка Тогда
		
		Элементы.сВложенныеШтрихкоды.Видимость = Истина;	
		
	ИначеЕсли Объект.ТипКода = Перечисления.ТипыКодовМаркировки.Набор Тогда
		
		Элементы.сВложенныеШтрихкоды.Видимость = Истина;	
		
	ИначеЕсли Объект.ТипКода = Перечисления.ТипыКодовМаркировки.Товар Тогда
		
		Элементы.сКороба.Видимость = Истина;
	
	КонецЕсли;
	
КонецПроцедуры
