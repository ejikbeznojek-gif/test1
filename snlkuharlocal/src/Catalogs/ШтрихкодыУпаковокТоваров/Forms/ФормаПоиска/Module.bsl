
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("МассивПолей") Тогда
	
		ЗаполнитьПоляДляВыбора(Параметры.МассивПолей); 	
	
	КонецЕсли;
	
	Если Параметры.Свойство("ВыбранныеЗначения") Тогда
	
		ВыбранныеЗначения.ЗагрузитьЗначения(Параметры.ВыбранныеЗначения);  	
	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновитьТипВыбранныхЗначений(); 
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаСервере
Процедура ЗаполнитьПоляДляВыбора(ПараметрПоля)

	Для каждого ЭлементМассива Из ПараметрПоля Цикл
		
		СтрокаПоиска = ПоляПоиска.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаПоиска,ЭлементМассива); 
		
	КонецЦикла;

КонецПроцедуры // ЗаполнитьПоляДляВыбора()


&НаКлиенте
Процедура ПоляПоискаВыборПриИзменении(Элемент)
	ТекущиеДанные 	= Элементы.ПоляПоиска.ТекущиеДанные; 
	Флаг 			= ТекущиеДанные.Выбор;
	
	СнятьРанееВыделенные();
	
	ВыбранныеЗначения.Очистить();
	
	ТекущиеДанные.Выбор = Флаг; 
	
	ОбновитьТипВыбранныхЗначений(); 
КонецПроцедуры

// <Описание процедуры>
//
// Параметры:
//  <Параметр1>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//  <Параметр2>  - <Тип.Вид> - <описание параметра>
//                 <продолжение описания параметра>
//
&НаКлиенте
Процедура ОбновитьТипВыбранныхЗначений()

	СтрокиВыбранные = ПоляПоиска.НайтиСтроки(Новый Структура("Выбор",истина));
	
	Если СтрокиВыбранные.Количество() = 0  Тогда
	
		Возврат; 	
	
	КонецЕсли;
	
	МассивТипов = Новый Массив; 
	Для каждого СтрокаВыбранная  Из  СтрокиВыбранные Цикл
		
		ТипыОписания = СтрокаВыбранная.Тип.Типы();  
		Для каждого ТипИзОписания Из ТипыОписания  Цикл  			
			МассивТипов.Добавить(ТипИзОписания);
		КонецЦикла;
		
	КонецЦикла; 
	
	//СписокТипов.ЗагрузитьЗначения(МассивТипов); 
	
	ВыбранныеЗначения.ТипЗначения = Новый ОписаниеТипов(МассивТипов); 
КонецПроцедуры // ()

