КонецФункции // ()

Функция ШтрихКодУникален()
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ	
	|	ЗначениеШтрихкода = &ЗначениеШтрихкода
	|	И Ссылка <> &Ссылка
	|";
	
	Запрос.УстановитьПараметр("ЗначениеШтрихкода", ЗначениеШтрихкода);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат НЕ (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка));
КонецФункции //ШтрихКодУникален()

Функция СоставКоробкиЗаполнен(ШтрихкодКоробки)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1 
	|	Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды
	|ГДЕ
	|	Ссылка = &ШтрихкодКоробки
	|";
	Запрос.УстановитьПараметр("ШтрихкодКоробки", ШтрихкодКоробки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат (Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка));
КонецФункции //СоставКоробкиЗаполнен(Коробка)