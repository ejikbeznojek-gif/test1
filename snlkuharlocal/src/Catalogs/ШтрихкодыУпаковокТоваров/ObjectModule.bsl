#Область СобытияОбъекта


Процедура ПередЗаписью(Отказ)
	ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи", Истина);
	
	Если ОбменДанными.Загрузка Тогда
		Если Маркировка_ПИ.ТипТекущегоУзла() = Перечисления.ТипУзлаИБ.Склад И ЗначениеЗаполнено(ОбменДанными.Отправитель) Тогда
			Если ТипКода = Перечисления.ТипыКодовМаркировки.ЛогистическаяУпаковка
				И СоставКоробкиЗаполнен(Ссылка) Тогда
				Отказ = Истина; //Коробку могли собрать уже - не надо от греха ее трогать 			
			КонецЕсли; 		
		КонецЕсли;
		
		ВидОперации = МаркировкаКС.ПолучитьЗначениеПараметра(ДополнительныеСвойства, "ВидОперации");
		Если ВидОперации <> Перечисления.ВидыОперацийМаркировки.БронированиеАгрегационныхКодов Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыСеанса.СверткаБазы Тогда Возврат КонецЕсли; 
	
	Если ТипКода = Перечисления.ТипыКодовМаркировки.Товар Тогда
		Наименование 		= Справочники.ШтрихкодыУпаковокТоваров.СформироватьНаименованиеШкGS1(ЗначениеШтрихкода);
		
		Если КодировкаШтрихкода.Пустая() Тогда
			КодировкаШтрихкода = Перечисления.ТипыКодировокШК.GS1_DataMatrix;		
		КонецЕсли;
	Иначе
		Если КодировкаШтрихкода.Пустая() Тогда
			КодировкаШтрихкода = Перечисления.ТипыКодировокШК.GS1_128;
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка И ЗначениеЗаполнено(ОбменДанными.Отправитель) Тогда Возврат КонецЕсли;
	
	Отказ = НЕ ШтрихКодУникален();
	
	Если НЕ Отказ Тогда
		Если СпособВводаВОборот <> Перечисления.СпособыВводаВОборотСУЗ.Импорт Тогда	//Импортные лучше с агрегацией отправить - от греха подальше
			локУстановитьСписокПолучателей();
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры


#КонецОбласти

