Функция ПолучитьЗабронироватьСвободныеКодыШтук(мНоменклатура, ДокБронирования, Знач ДопПараметры = Неопределено) Экспорт
	сНоменклатуры = Новый Соответствие;
	
	Если ТипЗнч(мНоменклатура) = Тип("Массив") Тогда
		Для Каждого Номенклатура Из мНоменклатура Цикл
			ТекКол = сНоменклатуры[Номенклатура];
			Если ТекКол = Неопределено Тогда
				ТекКол = 0;					
			КонецЕсли; 	
			сНоменклатуры[Номенклатура] = ТекКол + 1; 
		КонецЦикла;		
	ИначеЕсли ТипЗнч(мНоменклатура) = Тип("ТаблицаЗначений") Тогда
		Для Каждого СтрокаТЧ Из мНоменклатура Цикл
			ТекКол = сНоменклатуры[СтрокаТЧ.Номенклатура];
			Если ТекКол = Неопределено Тогда
				ТекКол = 0;						
			КонецЕсли;
			
			сНоменклатуры[СтрокаТЧ.Номенклатура] = ТекКол + СтрокаТЧ.Количество;
		КонецЦикла; 
	Иначе
		ТекКол = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Количество", 1);
		сНоменклатуры[мНоменклатура] = ТекКол;
	КонецЕсли;	
	
	Результат = МаркировкаКС.СтруктураРезультата();
	Результат.Данные = Новый Соответствие;
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = Новый Структура;	
	КонецЕсли;	
	
	Если НЕ ДопПараметры.Свойство("Местонахождение") Тогда
		ДопПараметры.Вставить("Местонахождение", ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла());	
	КонецЕсли;
	
	НовыйСтатус = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "НовыйСтатус", Перечисления.СтатусыКодовМаркировкиФакт.Распечатан);
	
	ЕстьОшибки = Ложь;
	Для Каждого КиЗ Из сНоменклатуры Цикл
		Номенклатура = Киз.Ключ;
		
		НачатьТранзакцию();
		
		Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		Попытка
			//+++Чирков 13.02.2026 - блокировка подставной таблицы - чтобы не мешать записи в основную
			//РегистрыСведений.СтатусыКМ_Факт.ЗаблокироватьТаблицу(Номенклатура);
			РегистрыСведений.СтатусыКМ_Факт_Штуки_Актуальные.ЗаблокироватьТаблицу(Номенклатура);
			//---Чирков 13.02.2026 - блокировка подставной таблицы - чтобы не мешать записи в основную
		Исключение
			ОтменитьТранзакцию();
			
			Результат.Успешно = Ложь;
			
			ТекстОшибки = СтрШаблон("Ном.: '%1'. %2.", Номенклатура, ОписаниеОшибки());
			
			Результат.Ошибки.Добавить("Блокировка транзакции. " + ТекстОшибки);
			
			ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", "Ошибка блокировки таблицы. " + ТекстОшибки, "Ошибка", , , (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000);
			
			Возврат Результат;			
		КонецПопытки;				
		
		Успешно = Ложь;
		
		рПолучения = ПолучитьСвободныеКодыШтук(Номенклатура, КиЗ.Значение, ДопПараметры);		
		Если рПолучения.Успешно Тогда
			Если РегистрыСведений.СтатусыКМ_Факт.УстановитьСтатусКМ(рПолучения.Данные, НовыйСтатус, ДокБронирования, ДопПараметры) Тогда
				Результат.Данные[Номенклатура] = рПолучения.Данные;
				Успешно = Истина;				
			Иначе
				Результат.Ошибки.Добавить("Ошибка обновления статуса кодов штук !");
			КонецЕсли;					
		Иначе			
			МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
		КонецЕсли;
		
		Если Успешно Тогда
			ЗафиксироватьТранзакцию();
		Иначе
			ОтменитьТранзакцию();
		КонецЕсли; 
	КонецЦикла;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьСвободныеКодыШтук(МассивНоменклатуры, ДокБронирования, Знач ДопПараметры = Неопределено) Экспорт

