#Область Штуки

Функция ПолучитьСвободныеКодыШтук(Номенклатура, Количество, ДопПараметры = Неопределено) Экспорт
	ДанныеЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерФункции("Функция.ШтрихКодыУпаковокТоваров.ПолучитьСвободныеКодыШтук");	
	
	Результат = МаркировкаКС.СтруктураРезультата();
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ " + МаркировкаКС.ЧислоБезДури(Количество) + "
	|	ШтрихКодУпаковки
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних(,
	|		Номенклатура	= &Номенклатура	
	|		И ТипШК			= ЗНАЧЕНИЕ(Перечисление.ТипыШтрихКодов.Штука)	
	|		//Фильтр_МассивДоступныхКодов
	|	)
	|ГДЕ
	|	Местонахождение = &Местонахождение	
	|	И НЕ ВПути	
	|	И Статус = &Статус
	|	И ШтрихКодУпаковки.ТипУпаковки	= ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МаркированныйТовар)
	|	И ШтрихКодУпаковки.ТипКода		= &ТипКода
	//Валетов + 01,08,2025 Пока отменили
	//|	И (
	//|		ШтрихКодУпаковки.СпособВводаВОборот = ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Импорт)
	//|		ИЛИ ШтрихКодУпаковки.ДатаУпаковки >= ДАТАВРЕМЯ(2025,6,1)
	//|	)	
	|	И НЕ ШтрихКодУпаковки.ПометкаУдаления
	|";	
	
	
	Местонахождение		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Местонахождение",		ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла());	
	Статус				= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус",				Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати);
	ТипКода				= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "ТипКода",				ТипКМпоУмолчанию(Номенклатура));
	
	МассивДоступныхКодов = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "МассивДоступныхКодов",	Новый Массив);
	Если МассивДоступныхКодов.Количество() > 0 Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "//Фильтр_МассивДоступныхКодов", "И ШтрихКодУпаковки В (&МассивДоступныхКодов)");	
		Запрос.УстановитьПараметр("МассивДоступныхКодов",МассивДоступныхКодов);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Номенклатура",		Номенклатура);
	Запрос.УстановитьПараметр("Местонахождение", 	Местонахождение);	
	Запрос.УстановитьПараметр("ТипКода",			ТипКода);
	Запрос.УстановитьПараметр("Статус",				Статус);	
	
	Попытка
