Функция ПолучитьПравилоВыгрузки(ДопПараметры = Неопределено) Экспорт	
	ОперИмпорта					= "Справочник.ШтрихкодыУпаковокТоваров";
	ОперИмпорта_Представление   = "КМ";
	
	ИмяТаблицы_Тек	= "Справочник.ШтрихкодыУпаковокТоваров";	
	ИмяТаблицы_Ист	= "Справочник.ШтрихкодыУпаковокТоваров";
	
	ЗапросыИст = ОбменДаннымиЧЗ.СоздатьТаблицуИменЗапросов();	
	
	#Область ВТ_Ссылки
	
	ТекстЗапросаИзменений = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ссылка
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".Изменения
	|ГДЕ
	|	Узел = &УзелПолучатель
	|	И ВЫБОР 
	|		КОГДА Ссылка.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка) 			ТОГДА Истина //По проcьбе Петрова - коробки - вне очереди
	|		КОГДА Ссылка.СпособВводаВОборот <> ЗНАЧЕНИЕ(Перечисление.СпособыВводаВОборотСУЗ.Импорт) 			ТОГДА Истина //Все кроме импорта
	|		КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ТекущаяДата,День),НАЧАЛОПЕРИОДА(&ТекущаяДата,Час),Час) МЕЖДУ 3 И 4 ТОГДА Истина //Можно вообще все в т.ч. и импорт
	|		КОГДА &ТипУзлаПолучателя <> ЗНАЧЕНИЕ(Перечисление.ТипУзлаИБ.Склад) 									ТОГДА Истина //Филиалы, магазины
	|		КОГДА Ссылка.Владелец.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.ГотовыйКомплект) ТОГДА Истина //11.09.2025 - ну очень нужно, ну очень срочно, никак не дотерпеть до вечера
	|		КОГДА Ссылка.Владелец.Родитель.ВидКомплекта = ЗНАЧЕНИЕ(Перечисление.ВидыКомплектов.Комплект) 		ТОГДА Истина
	|		ИНАЧЕ Ложь //Импорт - штуки - только с 3 до 4 часов утра
	|	КОНЕЦ
	|";			
	
	ТекстЗапроса = "
	|ВЫБРАТЬ 
	|	Ссылка	
	|ПОМЕСТИТЬ ВТ_Ссылки
	|ИЗ	
	|	" + ИмяТаблицы_Ист + "
	|ГДЕ
	|	Ссылка В (&МассивСсылок)
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|";	
	
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ВТ_Ссылки", ТекстЗапроса, Ложь);
	
	#КонецОбласти
	
	#Область Шапка
	
	Поля = Новый Массив;
	Поля.Добавить("Шапка.Ссылка,Шапка.Владелец,Шапка.ПометкаУдаления,Шапка.Наименование,Шапка.ЗаказКМ КАК Основание");
	Для Каждого МетаРекв Из Метаданные.Справочники.ШтрихкодыУпаковокТоваров.Реквизиты Цикл
		Поля.Добавить("Шапка." + МетаРекв.Имя);			
	КонецЦикла; 
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	" + СтрСоединить(Поля, ",") + "
    |ИЗ	
	|	" + ИмяТаблицы_Ист + " КАК Шапка
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = Шапка.Ссылка
	|УПОРЯДОЧИТЬ ПО 
	|	Наименование
	|";	                                      
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "Шапка", ТекстЗапроса, Истина, Ложь);	
	
	#КонецОбласти
	
	#Область ТЧ_ВложенныеТовары		
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ТЧ.*
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".ВложенныеТовары КАК ТЧ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = ТЧ.Ссылка
	|";
	
    ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ТЧ_ВложенныеТовары", ТекстЗапроса, Истина, Истина);
	
	#КонецОбласти
	
	#Область ТЧ_ВложенныеШтрихкоды
	
	ТекстЗапроса = "
	|ВЫБРАТЬ	
	|	ТЧ.*
	|ИЗ	
	|	" + ИмяТаблицы_Ист + ".ВложенныеШтрихкоды КАК ТЧ
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ 
	|	ВТ_Ссылки ПО ВТ_Ссылки.Ссылка = ТЧ.Ссылка
	|";	                                      
	ОбменДаннымиЧЗ.ДобавитьИмяТаблицы(ЗапросыИст, "ТЧ_ВложенныеШтрихкоды", ТекстЗапроса, Истина);	
	
	#КонецОбласти

	Возврат Новый Структура("РазмерПорции,ТекстЗапросаИзменений,ЗапросыИст,ОперИмпорта,ОперИмпорта_Представление", 5000, ТекстЗапросаИзменений, ЗапросыИст, ОперИмпорта, ОперИмпорта_Представление);
КонецФункции //Экспорт

Функция ЗагрузитьДанныеПакета(ДанныеПакета, Отправитель, ДопПараметры = Неопределено) Экспорт	
	Результат = МаркировкаКС.СтруктураРезультата();
	
	фПерезаписывать = МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "фПерезаписывать", Ложь);
	
	Таблицы	= МаркировкаКС.ПолучитьЗначениеПараметра(ДанныеПакета, "Таблицы");
	
	Шапка 		= Неопределено;
	ДанныеТЧ 	= Новый Соответствие;
	
	Для Каждого КиЗ Из Таблицы Цикл		
		Если СтрНачинаетсяС(КиЗ.Ключ,"ТЧ_") Тогда
			КиЗ.Значение.Индексы.Добавить("Ссылка");
			ДанныеТЧ[Сред(КиЗ.Ключ, 4)] = КиЗ.Значение;
		ИначеЕсли КиЗ.Ключ = "Шапка" Тогда
			Шапка = КиЗ.Значение;			
		КонецЕсли;		
	КонецЦикла;	  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Шапка ИЗ &Шапка КАК Шапка
	|;
	|ВЫБРАТЬ
	|	IsNULL(Ссылка.ВерсияДанных,"""") КАК ВерсияДанных,
	|	*
	|ИЗ
	|	ВТ_Шапка
	|ГДЕ
	|	Ссылка.ВерсияДанных ЕСТЬ NULL
	|	ИЛИ Ссылка.ТипУпаковки = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МонотоварнаяУпаковка)
	|	ИЛИ Ссылка.ТипУпаковки = ЗНАЧЕНИЕ(Перечисление.ТипыУпаковок.МультитоварнаяУпаковка)
	|	ИЛИ Ссылка.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.Набор)
	|	ИЛИ &фПерезаписывать
	|";  
	
	Запрос.УстановитьПараметр("Шапка", 				Шапка);
	Запрос.УстановитьПараметр("фПерезаписывать",	фПерезаписывать);	
	
	Менеджер = Справочники.ШтрихкодыУпаковокТоваров;
	
	Выборка 	= Запрос.Выполнить().Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= 0;
	ОшибокЗаписи = 0;
	
	Начало 		= ТекущаяУниверсальнаяДатаВМиллисекундах();
	СовсемНачало= Начало;
	
	ОшибкиЗаписи = ОбменДаннымиЧЗ.СоздатьТаблицуОшибокЗаписи();	
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА
		ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		Если ЗначениеЗаполнено(Выборка.ВерсияДанных) Тогда
			СпрОбъект = Выборка.Ссылка.ПолучитьОбъект();			
		Иначе			
			СпрОбъект = Менеджер.СоздатьЭлемент();		
			СпрОбъект.УстановитьСсылкуНового(Выборка.Ссылка);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СпрОбъект, Выборка, , "Ссылка");		
		
		Для Каждого КиЗ Из ДанныеТЧ Цикл
			СтрокиТЧ = КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка));		
			
			ТЧ_Объекта = СпрОбъект[КиЗ.Ключ];
			
			ТЧ_Объекта.Очистить();			
			Для Каждого СтрокаТЧ_Ист Из КиЗ.Значение.НайтиСтроки(Новый Структура("Ссылка", Выборка.Ссылка)) Цикл
				СтрокаТЧ_Тек = ТЧ_Объекта.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЧ_Тек, СтрокаТЧ_Ист);			
			КонецЦикла; 
		КонецЦикла;
		
		СпрОбъект.ДополнительныеСвойства.Вставить("ОтключитьЖурнализациюЗаписи", Истина);
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		СпрОбъект.ОбменДанными.Отправитель = Отправитель;
		
		Попытка
			СпрОбъект.Записать();		
			Результат.ОбработаноОбъектов = Результат.ОбработаноОбъектов + 1;
		Исключение
			СтрокаО = ОшибкиЗаписи.Добавить();
				
			СтрокаО.Основание	= СпрОбъект.ЗаказКМ;
			СтрокаО.ТекстОшибки	= ОписаниеОшибки();
			СтрокаО.Дата		= ТекущаяДата();
				
			ОшибокЗаписи = ОшибокЗаписи + 1;
		КонецПопытки;		
		
		Сч = Сч + 1;
		Если Сч % 100 = 0 Тогда
			ТекстСообщения = СтрШаблон("Загрузка КМ. Загружено: %1 из %2 элементов.", Сч, ВсегоСтрок);
			инт_ДлительныеОперации.СообщитьПрогресс(Формат(100*Сч/ВсегоСтрок, "ЧДЦ=2"), ТекстСообщения);		
		КонецЕсли;
		
		Если Сч % 1000 = 0 Тогда
			Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000;
			ТекстСообщения = СтрШаблон("Записано 1000 КМ. Время выполнения: %1, скорость записи: %2 кодов/с.", Время, Формат(1000 / Время, "ЧДЦ=0"));			
			ЗаписатьВЛог("Загрузка КМ", ТекстСообщения, "Информация", , , Время);
			
			Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли;		
	КонецЦикла;
	
	Результат.ОбработаноОбъектов = Шапка.Количество();Результат.Вставить("ПрочитаноОбъектов", Шапка.Количество()); 
	Результат.Вставить("ОшибокЗаписи", 	ОшибокЗаписи);
	Результат.Вставить("ОшибкиЗаписи", 	ОшибкиЗаписи);
	
	Время = (ТекущаяУниверсальнаяДатаВМиллисекундах() - СовсемНачало)/1000;
	ТекстСообщения = СтрШаблон("Окончание загрузки пакета. Прочитано: %1, записано: %2, ошибок записи: %3.",  Результат.ПрочитаноОбъектов, Результат.ОбработаноОбъектов, ОшибокЗаписи);
	ЗаписатьВЛог("Загрузка КМ", ТекстСообщения, "Информация", , , Время);
	
	Возврат Результат;	
КонецФункции // ()
	
#КонецОбласти 

#Область РаботаСКодамиGS1

Функция СформироватьНаименованиеШкGS1(ЗначениеШК) Экспорт
	
	Если ТипЗнч(ЗначениеШК) = Тип("Структура") Тогда
		ПоляШК = ЗначениеШК;
	Иначе		
		ПоляШК = ПолучитьПоляШК_GS1(ЗначениеШК);	
	КонецЕсли;	
	
	//Возврат "(01)"+Поля.ГТИН+"(21)"+СтрЗаменить(Поля.СН,Символ(29),"");
	Возврат "01"  +ПоляШК.ГТИН + "21"  +ПоляШК.СН;	
	
КонецФункции // ()
  
Функция ПолучитьПоляШК_GS1(Знач СтрШК) Экспорт
	СтрШК = СокрЛП(СтрШК);
	
	Если Лев(СтрШК,1) = Символ(232) Тогда  //FNC1 надо отрезать 
		СтрШК = Сред(СтрШК, 2);
	КонецЕсли;
	
	СтрШК = ВосстановитьКод_GS1(СтрШК);
	Части = СтрРазделить(СтрШК, Символ(29));
	
	Если Части.Количество() >= 2 Тогда
		СтрШК 	= Части[0];		
		ИДКП	= Части[1];			
	Иначе
		СтрШК 	= Части[0];		
		ИДКП	= "";
	КонецЕсли; 
	
	ГТИН 	= Сред(СтрШК,	3,	14);
	СН		= Сред(СтрШК,	19,	13);
	//ИДКП	= Сред(СтрШК,	35,	4);	
	
	Возврат Новый Структура("ГТИН,СН,ИДКП", ГТИН, СН, ИДКП);
КонецФункции //ПолучитьПоляШК(Знач СтрШК) Экспорт

Функция ПреобразоватьКод_GS1(Знач СтрШК) Экспорт
	Возврат Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(СтрШК));
	//Возврат Лев(СтрШК, 31) + СтрЗаменить(Сред(СтрШК, 32), Символ(29), "<GS>");
КонецФункции // ()
 
Функция ВосстановитьКод_GS1(Знач СтрШК) Экспорт
	Если СтрДлина(СтрШК) > 100 Тогда
		СтрВосстановленная = ПолучитьСтрокуИзДвоичныхДанных(Base64Значение(СтрШК));
	Иначе
		СтрВосстановленная = Лев(СтрШК, 31) + СтрЗаменить(Сред(СтрШК, 32), "<GS>", Символ(29)); //<GS> бывает в серийнике	
	КонецЕсли; 
	Возврат СтрВосстановленная;
КонецФункции //ВосстановитьКод_GS1(Знач СтрШК) 

#КонецОбласти 

