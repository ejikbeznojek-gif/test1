		рПолучения = МаркировкаКС.СтруктураРезультата(Ложь);
		рПолучения.Ошибки.Добавить("Блокировка транзакции. " + ТекстОшибки);
		
		ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт_А", "Ошибка блокировки таблицы. " + ТекстОшибки, "Ошибка", , , (ТекущаяУниверсальнаяДатаВМиллисекундах() - Начало)/1000);
		
		Возврат рПолучения;
	КонецПопытки;		
	
	рПолучения = ПолучитьСвободныеКодыАгрегации_Новая(ТипШК, ТипУпаковки, Количество, ДопПараметры);
	Если рПолучения.Успешно Тогда
		Если РегистрыСведений.СтатусыКМ_Факт_А.УстановитьСтатусКМ(рПолучения.Данные, НовыйСтатус, ДокБронирования, ДопПараметры) Тогда
			ЗафиксироватьТранзакцию();			
			
			Результат.Успешно	= Истина;
			Результат.Данные	= рПолучения.Данные;
		Иначе
			Результат.Ошибки.Добавить("Ошибка обновления статуса кодов агрегации ! ");
			
			ОтменитьТранзакцию();		
		КонецЕсли;		
	Иначе		
		ОтменитьТранзакцию();
		МаркировкаКС.ДобавитьОшибки(Результат, рПолучения);
	КонецЕсли; 	
	
	Возврат Результат;
КонецФункции //ПолучитьЗабронироватьСвободныеКодыАгрегации_Новая(ТипШК, Количество, ДопПараметры = Неопределено) Экспорт


Функция ПолучитьСвободныеКодыАгрегации(ТипШК, ТипУпаковки, Количество, ДопПараметры = Неопределено) Экспорт
	Если Маркировка_ПИ.ИспользоватьРегистрСтатусовКоробокДляБронирования() Тогда
		Возврат ПолучитьСвободныеКодыАгрегации_Новая(ТипШК, ТипУпаковки, Количество, ДопПараметры);
	Иначе                                                                                          
		Возврат ПолучитьСвободныеКодыАгрегации_Старая(ТипШК, ТипУпаковки, Количество, ДопПараметры);
	КонецЕсли;	
КонецФункции

Функция ПолучитьСвободныеКодыАгрегации_Старая(ТипШК, ТипУпаковки, Количество, ДопПараметры = Неопределено)
	Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат = МаркировкаКС.СтруктураРезультата();
		
	Запрос = Новый Запрос;   
	//Валетов + 09,10,2025 Пустая задача. Добавил проверку кодов по регистру Использованные КА
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ " + МаркировкаКС.ЧислоБезДури(Количество) + "
	|	Статусы.ШтрихКодУпаковки 				КАК ШтрихкодКоробки,
	|	Статусы.ШтрихКодУпаковки.Наименование	КАК КодАгрегации
	|ПОМЕСТИТЬ ВТ_КА
	|ИЗ
	|	РегистрСведений.СтатусыКМ_Факт.СрезПоследних( ,
	|		Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|		И ТипШК = &ТипШК
	|		И ШтрихКодУпаковки.СпособВводаВОборот В (&СпособВводаВОборот)
	|		И ШтрихКодУпаковки.ТипУпаковки = &ТипУпаковки
	|		И ШтрихКодУпаковки.ТипКода = ЗНАЧЕНИЕ(Перечисление.ТипыКодовМаркировки.ЛогистическаяУпаковка)
	|		И ШтрихКодУпаковки.Владелец = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|		И НЕ ШтрихКодУпаковки.ПометкаУдаления
	|	) КАК Статусы
	|ЛЕВОЕ СОЕДИНЕНИЕ 
	|	РегистрСведений.ИспользованныеКодыАгрегаций КАК ИспользованныеКА
	|ПО 
	|	Статусы.ШтрихКодУпаковки = ИспользованныеКА.ШтрихКодУпаковки
	|ГДЕ
	|	Статусы.Местонахождение = &Местонахождение
	|	И НЕ Статусы.ВПути
	|	И Статусы.Статус = &Статус
	|	И ИспользованныеКА.ШтрихКодУпаковки ЕСТЬ NULL
	|;
	|ВЫБРАТЬ
	|	ШтрихкодКоробки
	|ИЗ
	|	ВТ_КА
	|УПОРЯДОЧИТЬ ПО
	|	КодАгрегации
	|";
	
	Местонахождение		= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Местонахождение",		ОбщегоНазначения_ПИ.ПолучитьПодразделениеТекущегоУзла()); 
	//Валетов + 21,02,2026 https://yougile.collant.ru/team/ab6bad3a05c0/#MARK-3522
	//СпособВводаВОборот	= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "СпособВводаВОборот",	Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков);
	
	СпособВводаВОборот	= Новый Массив;	
	
	//+++Чирков Д.С. 27.03.2026- дичь была
	СпособВводаВОборот.Добавить(МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "СпособВводаВОборот", Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков));	
	Если СпособВводаВОборот[0] = Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков Тогда
		СпособВводаВОборот.Добавить(Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка);
	ИначеЕсли СпособВводаВОборот[0] = Перечисления.СпособыВводаВОборотСУЗ.Перемаркировка Тогда
		СпособВводаВОборот.Добавить(Перечисления.СпособыВводаВОборотСУЗ.МаркировкаОстатков);
	КонецЕсли;
	//---Чирков Д.С.
	
	//Валетов -
	Статус				= МаркировкаКС.ПолучитьЗначениеПараметра(ДопПараметры, "Статус",				Перечисления.СтатусыКодовМаркировкиФакт.ГотовКПечати);
	
	Запрос.УстановитьПараметр("Местонахождение", 	Местонахождение);
	Запрос.УстановитьПараметр("СпособВводаВОборот",	СпособВводаВОборот);
	Запрос.УстановитьПараметр("ТипУпаковки",		ТипУпаковки);
	Запрос.УстановитьПараметр("Статус",				Статус);	
	Запрос.УстановитьПараметр("ТипШК", 				ТипШК);	
	
	Попытка
		Результат.Данные = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШтрихкодКоробки");	
	Исключение
		Результат.Успешно = Ложь;
		Результат.Ошибки.Добавить("Блокировка транзакции. " + ОписаниеОшибки());
		Возврат Результат;
	КонецПопытки;
		
	ПолученоКМ = Результат.Данные.Количество();
	Если ПолученоКМ <> Количество Тогда	
		ТекстОшибки = СтрШаблон("Найдено %1 свободных, из %2 требуемых кодов маркировки (%3).", ПолученоКМ, Количество, ТипШК);		
		Результат.Ошибки.Добавить(ТекстОшибки);		
	КонецЕсли;
	
	Результат.Успешно = (Результат.Ошибки.Количество() = 0);
	
	ТекстСообщения = СтрШаблон("ШтрихкодыУпаковокТоваров.ПолучитьСвободныеКодыАгрегации. Получено: %1 кодов агрегации.", Количество);
	ЗаписатьВЛог("Мониторинг СтатусыКМ_Факт", ТекстСообщения, , , , (ТекущаяУниверсальнаяДатаВМиллисекундах()-Начало)/1000);
	
	Возврат Результат;
КонецФункции //ПолучитьСвободныеКодыАгрегации(ТипШК, Количество, ДопПараметры = Неопределено) Экспорт

