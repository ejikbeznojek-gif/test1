    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ	Ссылка, Код КАК КодУзла, &quot;ДанныеЧЗ&quot; КАК ПланОбмена ПОМЕСТИТЬ ВТ_СписокПО ИЗ ПланОбмена.ДанныеЧЗ ГДЕ ЭтотУзел
ОБЪЕДИНИТЬ                                          
ВЫБРАТЬ	Ссылка, Код КАК КодУзла, &quot;Основной&quot; КАК ПланОбмена ИЗ ПланОбмена.Основной ГДЕ ЭтотУзел
ОБЪЕДИНИТЬ                                          
ВЫБРАТЬ	Ссылка, Код КАК КодУзла, &quot;Свертка&quot; КАК ПланОбмена ИЗ ПланОбмена.Свертка ГДЕ ЭтотУзел
;	
ВЫБРАТЬ
	Спр.Ссылка,
	
	ТипПакета,	
	
	ПравилоВыгрузки,
	
	ВЫБОР КОГДА Направление=0 ТОГДА &quot;Отправка&quot; ИНАЧЕ &quot;Получение&quot; КОНЕЦ КАК Операция,
	
	Спр.ДатаСоздания,
	
	ПометкаУдаления,
	Код,
	
	Спр.ПланОбмена КАК ПланОбмена,
	НомерСообщения,
	Отправитель,
	Получатель,	
	
	ИД_Пакета,	
	              
	КоличествоОбъектовВПакете,
	КоличествоОшибокЗагрузки,
	РазмерСообщения,
	РазмерПакета,	
	ВремяФормирования,
	
	ДатаПорядка,
	       
	СостояниеПакетов.ИД_ЗаданияЗагрузкиДанных	КАК ИД_ЗаданияЗагрузкиДанных,	
	СостояниеПакетов.ДатаРедактированияЗаписи 	КАК ДатаОбновленияСостояния,	
	СостояниеПакетов.ДатаПолучения				КАК ДатаПолучения,
	СостояниеПакетов.ДатаЗагрузки				КАК ДатаЗагрузки,
	СостояниеПакетов.ВремяЗагрузки				КАК ВремяЗагрузки,
	СостояниеПакетов.ЕстьОшибкиЗагрузки			КАК ЕстьОшибкиЗагрузки	
ИЗ
	Справочник.ФР_ПакетыДанных КАК Спр
ЛЕВОЕ СОЕДИНЕНИЕ
	ВТ_СписокПО
ПО
	ВТ_СписокПО.ПланОбмена = Спр.ПланОбмена		
ЛЕВОЕ СОЕДИНЕНИЕ
	РегистрСведений.СостояниеПакетовОбмена КАК СостояниеПакетов
ПО
	Спр.Ссылка			= СостояниеПакетов.Пакет
	И Спр.ПланОбмена	= ВТ_СписокПО.ПланОбмена
	И СостояниеПакетов.КодУзла	= ВТ_СписокПО.КодУзла</queryText>
