 &НаКлиенте
Асинх Процедура ЗаполнитьРегионыПоРНКАсинхронно() 
	Обещание = ВвестиДатуАсинх(,"Укажите дату, начиная с которой будут анализироваться РНК");     	
	ДатаАнализа = Ждать Обещание;
	//
	если ЗначениеЗаполнено(ДатаАнализа) тогда
		ЗаполнитьРегионыПоРНКНаСервере(ДатаАнализа);   
		Сообщить("Готово");
	КонецЕсли;   
	
КонецПроцедуры



&НаСервере
Процедура ЗаполнитьРегионыПоРНКНаСервере(ДатаАнализа)  
	
	запрос = новый запрос;
	запрос.Текст =   "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасходнаяНакладная.ПунктДоставки.Регион КАК Регион
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Дата > &ДатаАнализа
	|	И РасходнаяНакладная.Контрагент = &Контрагент
	|	И НЕ РасходнаяНакладная.Склад.ЭтоСкладFBS
	|	И НЕ РасходнаяНакладная.Проведен
	|	И РасходнаяНакладная.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийОстатки.Комиссия)";     
	запрос.УстановитьПараметр("Контрагент",объект.Контрагент);
	запрос.УстановитьПараметр("ДатаАнализа",ДатаАнализа);
	Объект.Регионы.Загрузить(запрос.Выполнить().Выгрузить());	
КонецПроцедуры

