&НаСервере
Процедура КонтрольЗаполнения(Отказ, ПараметрыЗаписи) 
	СтруктураВозврата = новый Структура("Успех,Ошибки",Истина,новый Массив);
	Отбор = новый Структура("ПризнакГруппыРегиона",0);	
	МассивПустыхСтрок = Объект.Регионы.НайтиСтроки(Отбор);   
	
	
	
	
	если МассивПустыхСтрок.количество() > 0  тогда 
		Объект.ГруппироватьРегионы = Истина;       
		если МассивПустыхСтрок.количество()<> Объект.Регионы.Количество() тогда   
			СтруктураВозврата.Ошибки.Добавить("Не везде заполнен признак группы региона");
		КонецЕсли;  
	иначе
		Объект.ГруппироватьРегионы = Ложь;    
	КонецЕсли;


	
КонецПроцедуры

