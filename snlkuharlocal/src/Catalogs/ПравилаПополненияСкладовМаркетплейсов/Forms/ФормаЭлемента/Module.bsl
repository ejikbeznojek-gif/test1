&НаСервереБезКонтекста
Функция КратноеНаименованиеОрганизации (Организация)    
	КодОрганизации = ПолучитьРеквизитШапки(Организация,"Код","Справочник");
	если КодОрганизации = "SS-001" тогда 
		Возврат "ЕЕЭ";
	ИначеЕсли КодОрганизации = "SSP-99" тогда 
		Возврат "БТК";
	ИначеЕсли КодОрганизации = "SSR-03" тогда 
		Возврат "МПС";
	Иначе
		Возврат Организация.Наименование;
	КонецЕсли; 
КонецФункции

&НаСервере
Процедура ЗаписатьРегионыПоВсемКатегориямНаСервере()
	ТЗРегионов = Объект.Регионы.Выгрузить();
	запрос = новый запрос;
	запрос.Текст = "ВЫБРАТЬ
	|	ПравилаПополненияСкладовМаркетплейсов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПравилаПополненияСкладовМаркетплейсов КАК ПравилаПополненияСкладовМаркетплейсов
	|ГДЕ
	|	ПравилаПополненияСкладовМаркетплейсов.Ссылка <> &Ссылка
	|	И НЕ ПравилаПополненияСкладовМаркетплейсов.ПометкаУдаления
	|	И ПравилаПополненияСкладовМаркетплейсов.Контрагент = &Контрагент";
	запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);    
	запрос.УстановитьПараметр("Контрагент",Объект.Контрагент); 
	выборка = запрос.Выполнить().Выбрать();
	пока выборка.Следующий() цикл 
		ТекОбъект = выборка.ссылка.ПолучитьОбъект();
		ТекОбъект.Регионы.Загрузить(ТЗРегионов);  
		ТекОбъект.записать();
	КонецЦикла;


КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьРегионыПоВсемКатегориям(Команда)
	ЗаписатьРегионыПоВсемКатегориямНаСервере();
КонецПроцедуры



