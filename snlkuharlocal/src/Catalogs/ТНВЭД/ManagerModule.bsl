Функция ПолучитьПараметрыНоменклатурыНК(ТНВЭД) Экспорт
	Результат = ПланыВидовХарактеристик.СвойстваОбъектов.ПустаяСсылка();
	
	Запрос	= Новый ("Запрос");
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	Ссылка КАК ТНВЭД	
	|ИЗ
	|	Справочник.ТНВЭД
	|ГДЕ
	|	Ссылка = &ТНВЭД
	|ИТОГИ ПО
	|	Ссылка ИЕРАРХИЯ		
	|";	
	
	Запрос.УстановитьПараметр("ТНВЭД", 		ТНВЭД);	
	
	тГруппы = Запрос.Выполнить().Выгрузить();
	тГруппы.Колонки.Добавить("Уровень", ПолучитьОписаниеТиповЧисла(3));
	Для Каждого СтрокаТ Из тГруппы Цикл
		СтрокаТ.Уровень = тГруппы.Индекс(СтрокаТ)+1;	
	КонецЦикла; 
	
	Запрос.Текст = "
	|ВЫБРАТЬ * ПОМЕСТИТЬ ВТ_Группы ИЗ &тГруппы КАК тГруппы
	|;
	|ВЫБРАТЬ
	|	ВТ_Группы.Уровень 	КАК Уровень,	
	|	Ссылка				КАК ТНВЭД,	
	|	Параметр			КАК Параметр,
	|	НеИспользовать		КАК НеИспользовать,
	|	Обязательное		КАК Обязательное	
	|ПОМЕСТИТЬ ВТ_Параметры
	|ИЗ
	|	Справочник.ТНВЭД.КлассификаторыДляМаркировки КАК ТЧ_Параметры
	|ПРАВОЕ СОЕДИНЕНИЕ
	|	ВТ_Группы
	|ПО
	|	ТЧ_Параметры.Ссылка = ВТ_Группы.ТНВЭД	
	|;	
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_Параметры.Уровень) 	КАК Уровень,
	|	Параметр
	|ПОМЕСТИТЬ ВТ_МаксУровни
	|ИЗ
	|	ВТ_Параметры
	|СГРУППИРОВАТЬ ПО
	|	Параметр
	|;
	|ВЫБРАТЬ
	|	ВТ_МаксУровни.Уровень	 	КАК Уровень,
	|	ВТ_МаксУровни.Параметр		КАК Свойство,	
	|	ВТ_Параметры.Обязательное 	КАК Обязательное
	|ИЗ
	|	ВТ_МаксУровни
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	ВТ_Параметры
	|ПО
	|	ВТ_МаксУровни.Уровень 		= ВТ_Параметры.Уровень 
	|	И ВТ_МаксУровни.Параметр 	= ВТ_Параметры.Параметр 
	|ГДЕ
	|	ВТ_Параметры.НеИспользовать = Ложь
	|УПОРЯДОЧИТЬ ПО	
	|	ВТ_МаксУровни.Параметр.Наименование
	|";
	
	Запрос.УстановитьПараметр("тГруппы", тГруппы);	
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;	
КонецФункции // ()
