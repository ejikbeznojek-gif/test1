
&НаКлиенте
Функция УправлениеДоступностью()
	
	ТолькоПросмотр = НЕ ПолучитьПолномочиеПользователя("РедактированиеИТРесурсов");
	
	Если НЕ ТолькоПросмотр Тогда
	
		СтруктураДоступности = УстановитьДоступностьРеквизитов(ЭтаФорма, "СправочникОбъект.ИТ_Ресурсы");
	
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УправлениеДоступностью();
КонецПроцедуры

