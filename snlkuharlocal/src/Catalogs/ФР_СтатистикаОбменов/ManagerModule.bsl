Функция УдалитьМусор(ДопПараметры=Неопределено,АдресВозврата=Неопределено) Экспорт
	Запрос=Новый ("Запрос");
	Запрос.Текст="
	|ВЫБРАТЬ
	|	Ссылка,НачалоОбработки
	|ИЗ
	|	Справочник.СтатистикаОбменов
	|ГДЕ
	|	НетСообщений	
	|";	
	
	Результат	= Запрос.Выполнить();
	Выборка		= Результат.Выбрать();
	
	ВсегоСтрок	= Выборка.Количество();
	Сч			= ВсегоСтрок;
	
	Ошибки="";
	//КомпонентаОбмена = ОбщегоНазначения_КС.ПодключитьКомпонентуОбмена(Ошибки,"Прием");
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Пока Выборка.Следующий() Цикл
		#ЕСЛИ КЛИЕНТ ТОГДА 	
			ОбработкаПрерыванияПользователя();
		#КОНЕЦЕСЛИ
		
		ТекДата	= Выборка.НачалоОбработки;
		Выборка.Ссылка.ПолучитьОбъект().Удалить();
		//КомпонентаОбмена.Пауза(100);
		
		Сч=Сч-1;
		Если Сч%100=0 Тогда
			ЗафиксироватьТранзакцию();
			
			ФР_ОбщегоНазначения_КС.СообщитьПользователю("Очистка справочника ""Статистика обменов"" от мусора. Осталось: "+Сч+" эл-ов.");		
			
			ПроцентВыполнения = 100*(ВсегоСтрок-Сч)/ВсегоСтрок;
			ПроцентВыполнения = Окр(ПроцентВыполнения,2);
		
			// сообщаем "процент" и "текст сообщения"
			//ФР_ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения,СокрЛП(ТекДата));
			
			НачатьТранзакцию();
		КонецЕсли;		
	КонецЦикла; 
	
	ЗафиксироватьТранзакцию();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ВсегоСтрок;
КонецФункции // () 
