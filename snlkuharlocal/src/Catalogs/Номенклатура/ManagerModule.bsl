Функция ПолучитьТаблицуГТИНИзИстории(Знач Модель) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИсторияГТИННоменклатуры.ГТИН КАК ГТИН,
		|	МАКСИМУМ(ИсторияГТИННоменклатуры.Период) КАК Период
		|ПОМЕСТИТЬ ВТГТИНПоследние
		|ИЗ
		|	РегистрСведений.ИсторияГТИННоменклатуры КАК ИсторияГТИННоменклатуры
		|ГДЕ
		|	ИсторияГТИННоменклатуры.Номенклатура = &Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсторияГТИННоменклатуры.ГТИН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсторияГТИННоменклатуры.ГТИН КАК ГТИН,
		|	ИсторияГТИННоменклатуры.ВидГТИН КАК ВидГТИН,
		|	ИсторияГТИННоменклатуры.СнятСПроизводства КАК СнятСПроизводства,
		|	ИсторияГТИННоменклатуры.Период КАК Период
		|ИЗ
		|	РегистрСведений.ИсторияГТИННоменклатуры КАК ИсторияГТИННоменклатуры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТГТИНПоследние КАК ВТГТИНПоследние
		|		ПО (ВТГТИНПоследние.ГТИН = ИсторияГТИННоменклатуры.ГТИН)
		|			И (ВТГТИНПоследние.Период = ИсторияГТИННоменклатуры.Период)
		|ГДЕ
		|	ИсторияГТИННоменклатуры.Номенклатура = &Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИсторияГТИННоменклатуры.Период УБЫВ";
	
	Запрос.УстановитьПараметр("Номенклатура", Модель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить(); 


КонецФункции // ПолучитьТаблицуГТИНИзИстории()

